--source mysql_test/test_suite/ps/t/enable_ps.sql
#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
#
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#--disable_abort_on_error
--source mysql_test/include/index_quick_major.inc
--disable_warnings
drop table if exists test,test2,test3;
--enable_warnings
create table test(a varchar(4096) primary key);
# java模式不支持show create table的正则替换，就很容易导致跑的结果不一致
# --source mysql_test/include/show_create_table_old_version_replica2.inc
# show create table test;
# __all_virtual_table应该在系统租户下看得到，但是case里面没有使用data_length变量，所以这里注释掉
# let $table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 'test', table_id, 1);
# --disable_query_log
# eval select data_length from oceanbase.__all_virtual_column where column_name='a' and table_id=$table_id;
# --enable_query_log
--error 1074
create table test2(a varchar(262145) primary key);
create table test2(a int primary key,b varchar(16384) );
--error 1071
create index idx on test2(b);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
insert into  test2 values(1,'1') ;
insert into  test2 values(2,'2') ;
insert into  test2 values(3,'3') ;
insert into  test2 values(4,'4') ;
insert into  test2 values(5,'5') ;
insert into  test2 values(6,'6') ;
insert into  test2 values(7,'7') ;
insert into  test2 values(8,'8') ;
insert into  test2 values(9,'9') ;
insert into  test2 values(10,'0') ;
--let $a=''
--disable_query_log
 prepare stmt1 from update test2 set b=concat(b,?) where a=1;
 eval  set @x=$a;
--let $loop=40
while ( $loop)
{
  execute stmt1 using @x;
  eval update test2 set b=concat(b,$a) where a=2;
  eval update test2 set b=concat(b,$a) where a=3;
  eval update test2 set b=concat(b,$a) where a=4;
  eval update test2 set b=concat(b,$a) where a=5;
  eval update test2 set b=concat(b,$a) where a=6;
  eval update test2 set b=concat(b,$a) where a=7;
  eval update test2 set b=concat(b,$a) where a=8;
  eval update test2 set b=concat(b,$a) where a=9;
  eval update test2 set b=concat(b,$a) where a=10;
  select length(b) from test2 where a=1;
  dec $loop;
}
--enable_query_log
#--disable_parsing

  --error 1406
  eval update test2 set b=concat(b,$a) where a=1;
  eval update test2 set b=concat(b,substr($a,1,383)) where a=2;
  --error 1406
  eval update test2 set b=concat(b,substr($a,1,385)) where a=2;
  --error 1406
  eval update test2 set b=concat(b,substr($a,1,386)) where a=2;
  eval update test2 set b=concat(b,substr($a,1,383)) where a=3;
  eval update test2 set b=concat(b,substr($a,1,383)) where a=4;
  eval update test2 set b=concat(b,substr($a,1,383)) where a=5;
  eval update test2 set b=concat(b,substr($a,1,383)) where a=6;
  eval update test2 set b=concat(b,substr($a,1,383)) where a=7;
  eval update test2 set b=concat(b,substr($a,1,383)) where a=8;
  eval update test2 set b=concat(b,substr($a,1,383)) where a=1;
  eval update test2 set b=concat(b,substr($a,1,383)) where a=9;
--error 1406
eval update test2 set b=concat(b,'abcdefagfdgadfglkdfajglkjdfakgljdfklgjdfakjgdkajfgdkjfagakldjfgkfdjagdfakljgadkljgdfkagjakldjfgdklajgdfakjakjgdklfjdafdgdfjkgghijk123456789abcdefghijk12345678912345') where a=1;
#eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=2;
#eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=3;
#eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=4;
#eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=5;
#eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=6;
#eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=7;
#eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=8;
--error 1406
eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=3;
--error 1406
eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=3;
--error 1406
eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=3;
select count(*) from test2;
select a,length(b) from test2;
eval delete from test2 where a in(1) ;
#delete from test2 ;
#--disable_parsing
alter table test2 set EXPIRE_INFO (a >= 5);
sleep 5;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
prepare stmt1 from select a,length(b) from  test2  where a=3 and b like concat('3',concat(?,'%'));
eval set @x=$a;
execute stmt1 using @x;
#--disable_parsing
alter table test2 set EXPIRE_INFO (length(b) <26264);
sleep 2;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select a,length(b) from test2;
delete from test2 where a=1;
select *  from test2 where a=1;
delete from test2 where a in (2,3);
select * from test2 where a in (2,3);

#--enable_parsing
--source mysql_test/test_suite/ps/t/disable_ps.sql
