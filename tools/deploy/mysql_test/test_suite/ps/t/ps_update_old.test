--source mysql_test/test_suite/ps/t/enable_ps.sql
#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
# description: 对alter table对列进行增加或删除; 普通的update语句的测试以及比较复杂的update语句的测试
# ps_lose_update.test update_delete_limit_ps.test ps_complex_update.test

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#add a new column
prepare stmt1 from update t1 set b='ok' where a=?;
set @a=1;
execute stmt1 using @a;
alter table t1 add d int;
--real_sleep 1
execute stmt1 using @a;
select * from t1;
deallocate prepare stmt1;

#drop a exist column which not use
prepare stmt2 from update t1 set b='ok' where a=?;
set @a=1;
execute stmt2 using @a;
alter table t1 drop d ;
--real_sleep 1
execute stmt2 using @a ;
select * from t1;
deallocate prepare stmt2;

#drop a exist column which used by set
prepare stmt3 from update t1 set b='ok' where a=?;
set @a=1;
execute stmt3 using @a;
alter table t1 drop b ;
--real_sleep 1
--error ER_BAD_FIELD_ERROR
execute stmt3 using @a;
select * from t1;
deallocate prepare stmt3;

alter table t1 add b int;
--real_sleep 1
#drop column which used by where
prepare stmt4 from update t1 set b=2 where a=?;
set @a=1;
execute stmt4 using @a;
--error ER_NOT_SUPPORTED_YET
alter table t1 drop a ;
--real_sleep 1
execute stmt4 using @a;
select * from t1;
deallocate prepare stmt4;

drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#add a new column and drop it
prepare stmt5 from update t1 set b='ok' where a=?;
set @a=1;
execute stmt5 using @a;
alter table t1 add d int;
--real_sleep 1
alter table t1 drop d ;
--real_sleep 1
execute stmt5 using @a;
select * from t1;
deallocate prepare stmt5;

#drop a exist column,and add it which have not use
prepare stmt6 from update t1 set b='ok' where a=?;
set @a=1;
execute stmt6 using @a;
alter table t1 drop c ;
--real_sleep 1
alter table t1 add c int;
--real_sleep 1
execute stmt6 using @a;
select * from t1;
deallocate prepare stmt6;

#drop a exist column,and add it which set used and have same type
prepare stmt7 from update t1 set b='ok' where a=?;
set @a=1;
execute stmt7 using @a;
alter table t1 drop b ;
--real_sleep 1
alter table t1 add b varchar(255);
--real_sleep 1
execute stmt7 using @a;
select * from t1;
deallocate prepare stmt7;

#drop a exist column,and add it which set used and have different type
prepare stmt8 from update t1 set b='ok' where a=?;
set @a=1;
execute stmt8 using @a;
alter table t1 drop b ;
--real_sleep 1
alter table t1 add b int;
--real_sleep 1
--error ER_TRUNCATED_WRONG_VALUE_FOR_FIELD
execute stmt8 using @a;
select * from t1;
deallocate prepare stmt8;

#drop a exist column,and add it which where used and have same type
prepare stmt9 from update t1 set b='ok' where a=?;
set @a=1;
--error ER_TRUNCATED_WRONG_VALUE_FOR_FIELD
execute stmt9 using @a;
--error ER_NOT_SUPPORTED_YET
alter table t1 drop a ;
--real_sleep 1
--error ER_DUP_FIELDNAME
alter table t1 add a int;
--real_sleep 1
--error ER_TRUNCATED_WRONG_VALUE_FOR_FIELD
execute stmt9 using @a;
select * from t1;
deallocate prepare stmt9;

#drop a exist column,and add it which where used and have diff type
prepare stmt10 from update t1 set b='ok' where a=?;
set @a=1;
--error ER_TRUNCATED_WRONG_VALUE_FOR_FIELD
execute stmt10 using @a;
--error ER_NOT_SUPPORTED_YET
alter table t1 drop a ;
--real_sleep 1
--error ER_DUP_FIELDNAME
alter table t1 add a varchar(255);
--real_sleep 1
--error ER_TRUNCATED_WRONG_VALUE_FOR_FIELD
execute stmt10 using @a;
select * from t1;
deallocate prepare stmt10;



#drop table
prepare stmt11 from update t1 set b='ok' where a=?;
set @a=1;
--error ER_TRUNCATED_WRONG_VALUE_FOR_FIELD
execute stmt11 using @a;
drop table t1;
--real_sleep 1
--error 1146
execute stmt11 using @a;
deallocate prepare stmt11;

#drop table and create it again
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);
prepare stmt12 from update t1 set b='ok' where a=?;
set @a=1;
execute stmt12 using @a;
drop table t1;
create table t1( a int primary key,b varchar(255),c int);
execute stmt12 using @a;
select * from t1;
deallocate prepare stmt12;

#drop table and create it with diff schema
drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);
prepare stmt13 from update t1 set b='ok',c=2 where a=?;
set @a=1;
execute stmt13 using @a;
drop table t1;
create table t1( a int primary key,b varchar(255));
--error ER_BAD_FIELD_ERROR
execute stmt13 using @a;
select * from t1;
deallocate prepare stmt13;

#drop table and create it with diff name
drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);
prepare stmt14 from update t1 set b='ok' where a=?;
set @a=1;
execute stmt14 using @a;
drop table t1;
--real_sleep 1
create table t2( a int primary key,b varchar(255));
--error 1146
execute stmt14 using @a;
deallocate prepare stmt14;

# update_delete_limit_ps.test
--disable_warnings
drop table if exists tbl1;
--enable_warnings
create table tbl1 (pk int,i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3),i6 bool, primary key(pk));
insert into tbl1 values(1,1,'abc12','1agc',1.25,'2014-01-01 12:00:00',23.23,1),
                       (2,10,'23abc12','4agc1',-0.25,'2015-11-01 12:00:00',-23.230,0),
                       (3,201,'xx23abc12','cagc1',-2.25,'2015-11-21 11:20:10',3.231,1),
                       (4,80,'zx23abc12','zcagc1',2.25,'2013-01-21 11:20:10',-3.231,1),
                       (5,53,'cx23abc12','rcagc1',109.25,'2016-01-22 11:20:10',-13.131,0),
                       (6,78,'tx23abc12','icagc1',-109.25,'2014-09-16 16:24:00',-13.531,1),
                       (7,400,'yx23abc12','ocagc1',85.85,'2014-09-17 16:20:21',-93.131,0),
                       (8,50,'vx23abc12','wcagc1',-85.85,'2014-09-10 16:20:21',93.131,1),
                       (9,610,'ukx23abc12','pecagc1',-1.85,'2014-09-19 16:20:21',99.131,0),
                       (10,42,'kx23abc12','ecagc1',-85.86,'2014-09-18 16:20:21',-99.131,1),
                       (11,NULL,NULL,NULL,NULL,NULL,NULL,NULL);
create  index idx_1 on tbl1(i1);
--source mysql_test/include/check_all_idx_ok.inc
select date_sub(null, INTERVAL -6 DAY);
select * from tbl1;
update  tbl1 set i1=i1-20 where pk<=11 limit 20;
update  tbl1 set i1=i1+20 where pk<=11 limit 20;
select * from tbl1;
update  tbl1 set v2=concat(v2,'abc') where i1<=100 order by i1 limit 10;
update  tbl1 set v2=substr(v2,1,10) where i1<=100 order by i1 limit 10;
select * from tbl1;
#update  tbl1 set i3=concat(v2,'abc') where i1 in (1,201,10,80,420,600) order by i1 asc limit 5;
#update  tbl1 set i3=substr(v2,1,10)  where i1 in (1,201,10,80,420,600) order by i1 asc limit 5;
#update  tbl1 set i3=concat(v2,'abc') where i1 in (1,201,10,80,420,600)   limit 5;
#update  tbl1 set i3=substr(v2,1,10)  where i1 in (1,201,10,80,420,600)  limit 5;
update  tbl1 set i4=i4*2 limit 100;
select * from tbl1;
update  tbl1 set i4=i4/2 limit 100;
select * from tbl1;
update  tbl1 set d4=date_sub(d4, INTERVAL -6 DAY) limit 5,6;
update  tbl1 set d4=date_sub(d4, INTERVAL -6 DAY) where d4 is not null limit 5,6;
update  tbl1 set d4=date_add(d4, INTERVAL -6 DAY) limit 5,6;
update  tbl1 set d4=date_add(d4, INTERVAL -6 DAY) where d4 is not null limit 5,6;
update  tbl1 set i5=i5+0.05 limit 0,10;
update  tbl1 set i5=i5-0.05 order by i5 desc limit 0,10;
update  tbl1 set i6=i6 and 1 order by i6 asc limit 0,10;
select * from tbl1;
update  tbl1 set i1=i1+1-1 where i1>10 and i1<=1000 order by i1 limit 3,10;
delete from tbl1  where i1>10 and i1<=1000 order by i1 limit 10,10;
update  tbl1 set i1=i1+1-1 where  i1>10+1 and i1<1000 order by i1;
update  tbl1  set i1=i1+1-1 where i1 between 10+1 and 1000 order by i1 limit 3,10;
delete from tbl1  where i1 between 10+1 and 1000 order by i1 limit 10,10;

prepare stmt1 from update tbl1 set i1=i1-100 where i1>?+1 and i1<?-10 order by ? limit ?,?;
set @a=10;
set @b=1000;
set @c='i1';
set @d=0;
set @e=10;
execute stmt1 using @a, @b,@c,@d,@e;
set @c='v2';
set @a=10;
set @b=1000;
execute stmt1 using @a, @b,@c,@d,@e;
prepare stmt2 from delete from tbl1  where i1>?+1 and i1<?-10 order by ? limit ?,?;
set @a=10;
set @b=1000;
set @c='i1';
set @d=0;
set @e=10;
execute stmt2 using @a, @b,@c,@d,@e;
set @a=-110;
execute stmt2 using @a, @b,@c,@d,@e;
delete from tbl1 limit 100;

