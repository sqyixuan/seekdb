--source mysql_test/test_suite/ps/t/enable_ps.sql
#owner: xiaoyi.xy
#owner group: SQL1

--echo # *** test chars ending with space
set @v1 = 'a';
set @v2 = 'a ';
prepare stmt_1 from select 1 col_name from dual where ? = ?;
--echo // expected 1
execute stmt_1 using @v1, @v2;

--echo
--echo
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c char(10),var_c varchar(10));
insert into t1 values('a', 'a');
set @v1 = 'a ';
prepare stmt_2 from select case when c = ? then 1 else 0 end c1, case when var_c = ? then 1 else 0 end c2 from t1;
--echo //expected 1, 1
execute stmt_2 using @v1, @v1;
drop table t1;
--source mysql_test/test_suite/ps/t/disable_ps.sql
