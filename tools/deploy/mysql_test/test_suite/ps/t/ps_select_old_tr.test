--source mysql_test/test_suite/ps/t/enable_ps.sql

#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings



#----------------------nomal transaction-----------
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);


prepare stmt1 from select a,b from t1;
execute stmt1;
alter table t1 add d varchar(255);
sleep 2;
set autocommit=0;
execute stmt1;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt1;


prepare stmt2 from select a,b from t1;
execute stmt2;
alter table t1 drop d;
sleep 2;
set autocommit=0;
execute stmt2;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt2;



prepare stmt3 from select a,b from t1;
execute stmt3;
alter table t1 drop b;
--real_sleep 1
set autocommit=0;
--error ER_BAD_FIELD_ERROR
execute stmt3;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt3;


alter table t1 add b varchar(255);
--real_sleep 1


prepare stmt4 from select a,b from t1;
execute stmt4;
alter table t1 drop b;
--real_sleep 1
alter table t1 add b varchar(255);
--real_sleep 1
set autocommit=0;
execute stmt4;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt4;




prepare stmt5 from select a,b from t1;
execute stmt5;
alter table t1 drop b;
--real_sleep 1
alter table t1 add b int;
--real_sleep 1
set autocommit=0;
execute stmt5;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt5;




prepare stmt6 from select a,b from t1;
execute stmt6;
drop table t1;
sleep 1;
set autocommit=0;
--error 1146
execute stmt6;
commit;
set autocommit=1;
deallocate prepare stmt6;


create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);
prepare stmt7 from select a,b from t1 where a=?;
set @a=1;
execute stmt7 using @a;
drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);
set autocommit=0;
execute stmt7 using @a;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt7;



prepare stmt8 from select a,b from t1 where a=?;
set @a=2;
execute stmt8 using @a;
drop table t1;
create table t1( a int primary key,b varchar(255));
insert into t1 values(1,'a'),(2,'b'),(3,'c');
set autocommit=0;
execute stmt8 using @a;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt8;


drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);
prepare stmt9 from select a,b from t1 where a=?;
set @a=1;
execute stmt9 using @a;
drop table t1;
--real_sleep 1
create table t1( a int primary key,c int);
insert into t1 values(1,2),(2,3),(3,4);
set autocommit=0;
--error ER_BAD_FIELD_ERROR
execute stmt9 using @a;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt9;
--source mysql_test/test_suite/ps/t/disable_ps.sql
