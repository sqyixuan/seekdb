--source mysql_test/test_suite/ps/t/enable_ps.sql
#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
connection conn_admin;
alter system flush plan cache global;
alter system flush ps cache global;
alter system flush pl cache global;
alter system set plan_cache_evict_interval = '60s';

connection default;
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1(c1 int, c2 int);
create table t2(c1 int);
set autocommit  = 0;
insert into t1 values(1,1);
select * from t1 where c1 = 1;
select * from t2;
select expired, ps_sql, stmt_info_ref_count from oceanbase.V$OB_PS_ITEM_INFO order by stmt_id;

--echo
--echo *** test drop table ***
drop table t1;
create table t1(c1 varchar(10), c2 varchar(10), c3 varchar(10));
insert into t1 values('a','b','c');
select * from t1 where c1 = 1;
select expired, ps_sql, stmt_info_ref_count from oceanbase.V$OB_PS_ITEM_INFO order by stmt_id;

--echo
--echo *** test alter table ***
alter table t1 add c4 int;
select * from t1 where c1 = 1;
select * from t2;
select expired, ps_sql, stmt_info_ref_count from oceanbase.V$OB_PS_ITEM_INFO order by stmt_id;
drop table t1;

--echo
--echo *** test flush ps cache
connection conn_admin;
alter system flush ps cache global;
connection default;
select expired, ps_sql, stmt_info_ref_count from oceanbase.V$OB_PS_ITEM_INFO order by stmt_id;
commit;

connection conn_admin;
alter system set plan_cache_evict_interval = '1s';
