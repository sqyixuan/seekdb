--source mysql_test/test_suite/ps/t/enable_ps.sql
#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
####TITLE:ps语句，多个事务更新同一行，查询索引表、数据表、回表
####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk int primary key, a int, b int, c int, d int, e int);
create index i1 on t1(b,c) storing(d,e);

--source mysql_test/include/check_all_idx_ok.inc

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
insert into t1 values(1,1,1,1,1,1),(2,1,1,1,1,1),(3,1,1,1,1,1),(4,1,1,1,1,1);

connection conn1;
prepare trx1stmt1 from select pk, b, c, d, e from t1 where b between ? and ?;
prepare trx1stmt2 from select pk, a, b, c, d, e from t1 where pk>? and pk<?;
prepare trx1stmt3 from select * from t1 where b>? and b<?;
set @a1=0;
set @a2=10;
set @a3=1000;
prepare trx1utmt1 from update t1 set a=pk+100, b=pk+100, c=pk+100, d=pk+100, e=pk+100 where pk=?;

connection conn2;
prepare trx2stmt1 from select pk, b, c, d, e from t1 where b between ? and ?;
prepare trx2stmt2 from select pk, a, b, c, d, e from t1 where pk>? and pk<?;
prepare trx2stmt3 from select * from t1 where b>? and b<?;
set @a1=0;
set @a2=10;
set @a3=1000;
prepare trx2utmt1 from update t1 set a=pk+10, b=pk+10, c=pk+10, d=pk+10, e=pk+10 where pk=?;
prepare trx2dtmt1 from delete from t1 where pk=?;
prepare trx2itmt1 from insert into t1 values(?,1,1,1,1,1);
prepare trx2rtmt1 from replace into t1 values(?,1,1,1,1,1);

####CASE:多种DML操作同一行
connection conn1;
set autocommit=0;
--sorted_result
execute trx1stmt1 using @a1, @a3;
--sorted_result
execute trx1stmt2 using @a1, @a2;
--sorted_result
execute trx1stmt3 using @a1, @a3;

#pk=1,2个事务均不更新
#pk=2,仅事务2更新
#pk=3~6,2个事务均更新
#pk=7，仅事务2新增

## 事务2 更新第2、3行，删除第4行，写入第5、6、7行,提交
connection conn2;
set autocommit=0;
set @u1=2;
set @u2=3;
--sorted_result
execute trx2utmt1 using @u1;
--sorted_result
execute trx2utmt1 using @u2;

set @d1=4;
--sorted_result
execute trx2dtmt1 using @d1;

set @i1=5;
--sorted_result
execute trx2itmt1 using @i1;

set @r1=6;
set @r2=7;
--sorted_result
execute trx2rtmt1 using @r1;
--sorted_result
execute trx2rtmt1 using @r2;
 
commit;
--sorted_result
execute trx2stmt1 using @a1, @a3;
--sorted_result
execute trx2stmt2 using @a1, @a2;
--sorted_result
execute trx2stmt3 using @a1, @a3;

## 事务1 更新第3~6行
connection conn1;
set @u1=3;
set @u2=4;
set @u3=5;
set @u4=6;
--sorted_result
execute trx1utmt1 using @u1;
--sorted_result
execute trx1utmt1 using @u2;
--sorted_result
execute trx1utmt1 using @u3;
--sorted_result
execute trx1utmt1 using @u4;

--sorted_result
execute trx1stmt1 using @a1, @a3;
--sorted_result
execute trx1stmt2 using @a1, @a2;
--sorted_result
execute trx1stmt3 using @a1, @a3;
commit;
--sorted_result
execute trx1stmt1 using @a1, @a3;
--sorted_result
execute trx1stmt2 using @a1, @a2;
--sorted_result
execute trx1stmt3 using @a1, @a3;
commit;

connection conn2;
--sorted_result
execute trx2stmt1 using @a1, @a3;
--sorted_result
execute trx2stmt2 using @a1, @a2;
--sorted_result
execute trx2stmt3 using @a1, @a3;
commit;
--sorted_result
execute trx2stmt1 using @a1, @a3;
--sorted_result
execute trx2stmt2 using @a1, @a2;
--sorted_result
execute trx2stmt3 using @a1, @a3;
commit;

drop table t1;
--source mysql_test/test_suite/ps/t/disable_ps.sql
