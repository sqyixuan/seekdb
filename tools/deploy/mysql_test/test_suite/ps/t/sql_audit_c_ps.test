--source mysql_test/test_suite/ps/t/enable_ps.sql
#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
#####
## 该case与1.0不兼容
####
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set enable_sql_audit='false';
alter system flush sql audit global;
connection default;

--real_sleep 5
# 1396?
--error 0, 600,1396
drop user user4;
--error 0, 600,1396
drop user user5;
--error 0, 600,1396
drop user user6;

create user user4 identified by 'user4';
grant all on test.* to user4;
create user user5 identified by 'user5';
grant all on test.* to user5;
create user user6 identified by 'user6';
grant all on test.* to user6;
--real_sleep 3

connect(conn4,$OBMYSQL_MS0,user4,user4,test,$OBMYSQL_PORT);
connect(conn5,$OBMYSQL_MS0,user5,user5,test,$OBMYSQL_PORT);
connect(conn6,$OBMYSQL_MS0,user6,user6,test,$OBMYSQL_PORT);

--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6;
--enable_warnings

create table t1 (c1 int primary key);
create table t3 (c1 int primary key);

connection obsys;
alter system set enable_sql_audit='True';
--real_sleep 5
--disable_warnings
drop table if exists t2, t3, t4;
--enable_warnings
create table t3 (c1 int);

#admin
#alter&&DDL
create /*ps_sql_audit_test*/ table t2 (c1 int primary key);
select user_name, query_sql, db_name, ret_code from oceanbase.__all_virtual_sql_audit where query_sql like '%ps_sql_audit_test%';

--disable_result_log
help 'alter table';
--enable_result_log
select user_name, query_sql, db_name, ret_code from oceanbase.__all_virtual_sql_audit where query_sql like 'help \'alter table\'';

alter table t2 rename to t4;
select user_name, query_sql, db_name, ret_code from oceanbase.__all_virtual_sql_audit where query_sql like 'alter table t2 rename to t4';

alter table t3 set COMPRESSION = 'none';
select user_name, query_sql, db_name, ret_code from oceanbase.__all_virtual_sql_audit where query_sql like 'alter table t3 set COMPRESSION = \'none\'';

# syntax error
# alter system switch rootserver master;
# select user_name, query_sql, db_name, ret_code from oceanbase.__all_virtual_sql_audit where query_sql like 'alter system switch rootserver master';
#  syntax error
# alter system reload cluster;
# select user_name, query_sql, db_name, ret_code from oceanbase.__all_virtual_sql_audit where query_sql like 'alter system reload cluster';

#error sql
--disable_abort_on_error
--disable_result_log
insert into t1 values(1),(1);
--enable_result_log
select user_name, query_sql, db_name, ret_code from oceanbase.__all_virtual_sql_audit where query_sql like 'insert into t1 values(1),(1)'

--disable_result_log
select * from t1,t3;
--enable_result_log
select user_name, query_sql, db_name, ret_code from oceanbase.__all_virtual_sql_audit where query_sql like 'select * from t1,t3';

#update pk
insert into t3 values (1);
select user_name, query_sql, db_name, ret_code from oceanbase.__all_virtual_sql_audit where query_sql like 'insert into t3 values (1)';

update t3 set c1=2 where c1=1;
select user_name, query_sql, db_name, ret_code from oceanbase.__all_virtual_sql_audit where query_sql like 'update t3 set c1=2 where c1=1';

grant all privileges on t3 to 'user4';
select user_name, query_sql, db_name, ret_code from oceanbase.__all_virtual_sql_audit where query_sql like 'grant all privileges on t3 to \'user4\'';

grant all privileges on t3 to 'user5';
select user_name, query_sql, db_name, ret_code from oceanbase.__all_virtual_sql_audit where query_sql like 'grant all privileges on t3 to \'user5\'';

--real_sleep 3

connection conn4;
connection conn5;

#TSC
connection conn4;
begin;
select * from t3 where c1=2 for update wait 5;

connection conn5;
begin;
send update t3 set c1=3 where c1=2;
--real_sleep 2

connection conn4;
rollback;

connection conn5;
reap;
commit;

connection obsys;
select * from t3;
select user_name, query_sql, db_name, ret_code from oceanbase.__all_virtual_sql_audit where query_sql like 'select * from t3';

#PS
#在sql audit中看不到select语句
--disable_warnings
drop table if exists tbl_for_ps_sql_audit_mysqltest;
--enable_warnings
create table tbl_for_ps_sql_audit_mysqltest (c1 int);
prepare stmt from select ? from tbl_for_ps_sql_audit_mysqltest;
set @a=1;
execute stmt using @a;
select user_name, query_sql, db_name, ret_code from oceanbase.__all_virtual_sql_audit where query_sql like '%select%tbl_for_ps_sql_audit_mysqltest%';
--source mysql_test/test_suite/ps/t/disable_ps.sql
