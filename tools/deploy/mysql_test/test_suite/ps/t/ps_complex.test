--source mysql_test/test_suite/ps/t/enable_ps.sql
#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings


create table t1(i1 int, f1 float, s1 varchar(1024), d1  timestamp(6) default "2012-01-01 12:00:00", i2 int, f2 float,s2 varchar(1024), d2  timestamp(6) default "2012-01-01 12:00:00",primary key(i1,s1,d1));
prepare stmt_replace from replace into t1 values(?,?,?,?,?,?,?,?);

prepare stmt_insert from insert into t1 values(?,?,?,?,?,?,?,?);

prepare stmt_update from update t1 set i2=?,f2=?,s2=?,d2=? where i1=? and f1=? and s1=? and d1=?;
prepare stmt_update_with_other_column from update t1 set i2=?,f2=?,s2=?,d2=? where i1=? and f1=? and s1=? and d1=? and i2=? and f2=? and s2=? and d2=?;

prepare stmt_delete from delete from t1 where i1=? and f1=? and s1=? and d1=?;
prepare stmt_delete_with_other_column from delete from t1 where i1=? and f1=? and s1=? and d1=? and i2=? and f2=? and s2=? and d2=?;


prepare stmt_select from select * from t1 where i1=? and f1=? and s1=? and d1=?;

prepare stmt_select_with_all_columns from select * from t1 where i1=? and f1=? and s1=? and d1=? and i2=? and f2=? and s2=? and d2=?;

--let $l=99

--let $i1=1
--let $f1=1.5
--let $s1='s1'
--let $d1='2012-02-20 12:00:01'
--let $i1=100
--let $f1=100.5
--let $s1='s100'
--let $d1='2012-02-20 12:01:00'


set @i1=1;
set @f1=1.5;
set @s1='abcdefghigklmnopqrstuvwxyz';
set @d1=timestamp'2012-02-20 12:00:01';

set @i2=100;
set @f2=100.5;
set @s2='s100';
set @d2=timestamp'2012-02-20 12:01:00';

set @i3=1000;
set @f3=1000.5;
set @s3='s1000';
set @d3=timestamp'2012-02-20 13:00:00';


execute stmt_insert using @i1,@f1,@s1,@d1,@i2,@f2,@s2,@d2;
#
select * from t1;
#

#--error 1062
execute stmt_replace using @i1,@f1,@s1,@d1,@i2,@f2,@s2,@d2;
select * from t1;
#--error 1062
execute stmt_replace using @i1,@f1,@s1,@d1,@i2,@f2,@s2,@d2;
select * from t1;

execute stmt_update_with_other_column using @i3,@f3,@s3,@d3,@i1,@f1,@s1,@d1,@i2,@f2,@s2,@d2;
select * from t1;
execute stmt_update using @i3,@f3,@s3,@d3,@i1,@f1,@s1,@d1;
select * from t1;

execute stmt_select using @i1,@f1,@s1,@d1;
select * from t1;

execute stmt_select_with_all_columns using @i1,@f1,@s1,@d1,@i3,@f3,@s3,@d3;
select * from t1;

execute stmt_delete_with_other_column using @i1,@f1,@s1,@d1,@i2,@f2,@s2,@d2;
select * from t1;
execute stmt_delete using @i1,@f1,@s1,@d1;
select * from t1;

drop table t1;

# jdbc_ps_complex.test
--echo case 1: do update in trx
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c0 int primary key, c1 int);

prepare stmt_i from insert into t1 values(?,?),(?,?);
prepare stmt_u from update t1 set c1=? where c0=?;
prepare stmt_d from delete from t1 where c0=?;
prepare stmt_s from select c0,c1 from t1 where c0=? for update;
prepare stmt_select from select c0,c1 from t1;

set autocommit=0;
set @a1=1;
set @b1=1;
set @a2=2;
set @b2=2;
execute stmt_i using @a1,@b1,@a2,@b2;
execute stmt_u using @b2,@a1;
execute stmt_d using @a2;
execute stmt_s using @a1;
execute stmt_s using @a2;
commit;
set autocommit=1;
execute stmt_select;
disconnect conn1;

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t2(c0 varchar(1024) primary key, c1 varchar(1024));

prepare stmt_i from insert into t2 values(?,?),(?,?);
prepare stmt_u from update t2 set c1=? where c0=?;
prepare stmt_d from delete from t2 where c0=?;
prepare stmt_s from select c0,c1 from t2 where c0=? for update;
prepare stmt_select from select c0,c1 from t2;

set autocommit=0;
set @a1='s1';
set @b1='s1';
set @a2='s2';
set @b2='s2';
execute stmt_i using @a1,@b1,@a2,@b2;
execute stmt_u using @b2,@a1;
execute stmt_d using @a2;
execute stmt_s using @a1;
execute stmt_s using @a2;
commit;
set autocommit=1;
execute stmt_select;
disconnect conn1;


connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
--disable_warnings
drop table if exists t2,t3;
--enable_warnings

create table t3(c0 datetime primary key, c1 datetime(6));

prepare stmt_i from insert into t3 values(?,?),(?,?);
prepare stmt_u from update t3 set c1=? where c0=?;
prepare stmt_d from delete from t3 where c0=?;
prepare stmt_s from select c0,c1 from t3 where c0=? for update;
prepare stmt_select from select c0,c1 from t3;

set autocommit=0;
set @a1=timestamp'2013-03-28 12:18:01';
set @b1=timestamp'2013-03-28 12:18:01';
set @a2=timestamp'2013-03-28 12:19:01';
set @b2=timestamp'2013-03-28 12:19:01';
execute stmt_i using @a1,@b1,@a2,@b2;
execute stmt_u using @b2,@a1;
execute stmt_d using @a2;
execute stmt_s using @a1;
execute stmt_s using @a2;
commit;
set autocommit=1;
execute stmt_select;
disconnect conn1;


connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
--disable_warnings
drop table if exists t3,t4;
--enable_warnings

create table t4(c0 double primary key, c1 double);

prepare stmt_i from insert into t4 values(?,?),(?,?);
prepare stmt_u from update t4 set c1=? where c0=?;
prepare stmt_d from delete from t4 where c0=?;
prepare stmt_s from select c0,c1 from t4 where c0=? for update;
prepare stmt_select from select c0,c1 from t4;

set autocommit=0;
set @a1=1.5;
set @b1=1.6;
set @a2=2.5;
set @b2=2.6;
execute stmt_i using @a1,@b1,@a2,@b2;
execute stmt_u using @b2,@a1;
execute stmt_d using @a2;
execute stmt_s using @a1;
execute stmt_s using @a2;
commit;
set autocommit=1;
execute stmt_select;
disconnect conn1;

# jdbc_ps_all_statment.test
connection default;
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int, c2 varchar(30), primary key(c1), c3 int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4),(4,'a',2);

prepare stmt1 from delete from  t1 where c1=?;
set @a=1;
execute stmt1 using @a;
execute stmt1 using @a;
deallocate prepare stmt1;

prepare stmt2 from replace into t1 values (4, ?, 5);
set @a='xxxx';
execute stmt2 using @a;
execute stmt2 using @a;
execute stmt2 using @a;
deallocate prepare stmt2;

#select S.statement,S.id,S.prepare_count,S.slow_count from (select * from oceanbase.__all_statement) as S;

# tear down
drop table t1;
--source mysql_test/test_suite/ps/t/disable_ps.sql
