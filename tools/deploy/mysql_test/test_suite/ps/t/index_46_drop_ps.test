--source mysql_test/test_suite/ps/t/enable_ps.sql
#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps

--echo // here
--disable_abort_on_error
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--source mysql_test/include/index_quick_major.inc
--real_sleep 1

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--disable_warnings
drop database if exists ps_test;
--enable_warnings
create database ps_test;
use ps_test;

--disable_warnings
drop table if exists t1,t2,t3,t4,t5;
--enable_warnings
#case 1 
create table t1(pk int primary key, key1 int, key2 int, v3 varchar(20));
create index i1 on t1(key1);
insert into t1 values(1,5,2,'a'),(2,5,2,'b'),(4,5,2,'c');

sleep 1;
sleep 1;

--source mysql_test/include/check_all_idx_ok.inc

prepare stmt11 from select * from t1 where key1>=? and key1<?;
prepare stmt12 from select /*+ index(t1 i1)*/ * from t1 where key1>=? and key1<?;
set @a1=1;
set @a2=6;

execute stmt11 using @a1, @a2;
execute stmt12 using @a1, @a2;
drop index i1 on t1;
execute stmt11 using @a1, @a2;
execute stmt12 using @a1, @a2;
replace into t1 values(1,5,2,'aa');
execute stmt11 using @a1, @a2;
execute stmt12 using @a1, @a2;
drop table t1;

#case 2
create table t2(pk int primary key, key1 int, key2 int, v3 varchar(20));
create index i1 on t2(key1);
sleep 1;
sleep 1;

--source mysql_test/include/check_all_idx_ok.inc

prepare stmt21 from select * from t2 where key1>=? and key1<?;
prepare stmt22 from select /*+ index(t2 i1)*/ * from t2 where key1>=? and key1<?;
set @b1=1;
set @b2=6;

insert into t2 values(1,5,2,'a'),(2,5,2,'b'),(4,5,2,'c');
drop index i1 on t2;
execute stmt21 using @b1, @b2;
execute stmt22 using @b1, @b2;
# replace into t2 values(1,5,2,'aa');
--real_sleep 12
create index i2 on t2(key1);
drop index i2 on t2;
execute stmt21 using @b1, @b2;
execute stmt22 using @b1, @b2;
create index i1 on t2(key1);
sleep 3;

--source mysql_test/include/check_all_idx_ok.inc

replace into t2 values(1,5,2,'aaa');
execute stmt21 using @b1, @b2;
execute stmt22 using @b1, @b2;
drop index i1 on t2;
execute stmt21 using @b1, @b2;
execute stmt22 using @b1, @b2;
--real_sleep 12
execute stmt21 using @b1, @b2;
execute stmt22 using @b1, @b2;
drop table t2;

#case 3
--disable_warnings
drop table if exists t3;
--enable_warnings
create table t3(pk int primary key, key1 int, key2 int, v3 varchar(20));
create index i1 on t3(key1);
create index i2 on t3(key1,key2);
sleep 1;
sleep 1;

--source mysql_test/include/check_all_idx_ok.inc

prepare stmt31 from select * from t3 where key1>=? and key1<?;
prepare stmt32 from select /*+ index(t3 i1)*/ * from t3 where key1>=? and key1<?;
prepare stmt33 from select /*+ index(t3 i2)*/ * from t3 where key1>=? and key1<?;
set @c1=1;
set @c2=6;

insert into t3 values(1,5,2,'a'),(2,3,2,'b'),(4,1,2,'c');
execute stmt31 using @c1, @c2;
execute stmt32 using @c1, @c2;
execute stmt33 using @c1, @c2;
drop index i1 on t3;
execute stmt31 using @c1, @c2;
execute stmt32 using @c1, @c2;
execute stmt33 using @c1, @c2;
execute stmt31 using @c1, @c2;
execute stmt32 using @c1, @c2;
execute stmt33 using @c1, @c2;
--replace_column 1 table_id
select t.table_id, t.table_name from oceanbase.__all_virtual_database d inner join oceanbase.__all_virtual_table t on (d.database_id = t.database_id) and d.database_name='ps_test' and t.table_name like 't_';
drop table t3;
--replace_column 1 table_id
select t.table_id, t.table_name from oceanbase.__all_virtual_database d inner join oceanbase.__all_virtual_table t on (d.database_id = t.database_id) and d.database_name='ps_test' and t.table_name like 't_';

#case4
##unavailable
create table t4(pk int primary key, key1 int, key2 int, v3 varchar(20));
create index i1 on t4(key1);

prepare stmt41 from select * from t4 where key1>=? and key1<?;
prepare stmt42 from select /*+ index(t4 i1)*/ * from t4 where key1>=? and key1<?;
set @d1=1;
set @d2=6;

--replace_column 1 table_id
select t.table_id, t.table_name from oceanbase.__all_virtual_database d inner join oceanbase.__all_virtual_table t 
  on (d.database_id = t.database_id) and d.database_name='ps_test' and t.table_name like 't_';
insert into t4 values(1,5,2,'a'),(2,3,2,'b'),(4,1,2,'c');
drop index i1 on t4;
execute stmt41 using @d1, @d2;
execute stmt42 using @d1, @d2;
--replace_column 1 table_id
select t.table_id, t.table_name from oceanbase.__all_virtual_database d inner join oceanbase.__all_virtual_table t 
  on (d.database_id = t.database_id) and d.database_name='ps_test' and t.table_name like 't_';
--real_sleep 12
execute stmt41 using @d1, @d2;
execute stmt42 using @d1, @d2;

drop table t4;

##available 
create table t5(pk int primary key, key1 int, key2 int, v3 varchar(20));
create index i1 on t5(key1);
--replace_column 1 table_id
select t.table_id, t.table_name from oceanbase.__all_virtual_database d inner join oceanbase.__all_virtual_table t 
  on (d.database_id = t.database_id) and d.database_name='ps_test' and t.table_name like 't_';
--source mysql_test/include/check_all_idx_ok.inc

prepare stmt51 from select * from t5 where key1>=? and key1<?;
prepare stmt52 from select /*+ index(t5 i1)*/ * from t5 where key1>=? and key1<?;
set @e1=1;
set @e2=6;

insert into t5 values(1,5,2,'a'),(2,5,2,'b'),(4,5,2,'c');
drop index i1 on t5;
execute stmt51 using @e1, @e2;
execute stmt52 using @e1, @e2;
--replace_column 1 table_id
select t.table_id, t.table_name from oceanbase.__all_virtual_database d inner join oceanbase.__all_virtual_table t 
  on (d.database_id = t.database_id) and d.database_name='ps_test' and t.table_name like 't_';
--real_sleep 12
execute stmt51 using @e1, @e2;
execute stmt52 using @e1, @e2;
--replace_column 1 table_id
select t.table_id, t.table_name from oceanbase.__all_virtual_database d inner join oceanbase.__all_virtual_table t 
  on (d.database_id = t.database_id) and d.database_name='ps_test' and t.table_name like 't_';
drop table t5;
--source mysql_test/test_suite/ps/t/disable_ps.sql
