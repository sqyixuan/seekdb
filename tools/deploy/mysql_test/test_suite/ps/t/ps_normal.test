--source mysql_test/test_suite/ps/t/enable_ps.sql

#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int);
insert into t1 values(1, 1);
insert into t1 values(2, 2);
prepare stmt from select c1, c2 from t1 where c1 =?;
set @alike= 1;
execute stmt using @alike;
--source mysql_test/test_suite/ps/t/disable_ps.sql
