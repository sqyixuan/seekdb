--source mysql_test/test_suite/ps/t/enable_ps.sql
# owner: xiaoyi.xy
# owner group: SQL2
# description: 测试show processlist中要有ps执行的信息

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system flush plan cache global;

set @x = 10;
# set ob_log_level = 'debug';
prepare stmt1 from select user, tenant, db, command, state, info from oceanbase.__all_virtual_processlist where info like 'select%shaoge%from oceanbase.__all_virtual_processlist%';
execute stmt1;
--source mysql_test/test_suite/ps/t/disable_ps.sql
