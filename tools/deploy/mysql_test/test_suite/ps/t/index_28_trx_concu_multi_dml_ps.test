--source mysql_test/test_suite/ps/t/enable_ps.sql
#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
####TITLE:ps语句，事务1多种DML操作，多次提交，事务2读，查询索引表、数据表、回表
####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk int primary key, a int, b int, c int, d int);
create index i1 on t1(b, c) storing(d);

--source mysql_test/include/check_all_idx_ok.inc

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
prepare trx1stmt1 from select pk, b, c, d from t1 where b between ? and ?;
prepare trx1stmt2 from select pk, a, b from t1 where pk>? and pk<?;
prepare trx1stmt3 from select * from t1 where b>? and b<?;
set @a1=0;
set @a2=10;
prepare trx1itmt1 from insert into t1(pk, a, b, c, d) values(?,1,1,1,1);
prepare trx1rtmt1 from replace into t1(pk, a, b, c, d) values(?,?,?,?,?);
prepare trx1utmt1 from update t1 set a=a+?, b=b+?, c=c+?, d=d+? where pk=?;
prepare trx1dtmt1 from delete from t1 where pk=?;

connection conn2;
prepare trx2stmt1 from select pk, b, c, d from t1 where b between ? and ?;
prepare trx2stmt2 from select * from t1 where pk>? and pk<?;
prepare trx2stmt3 from select * from t1 where b>? and b<?;
set @a1=0;
set @a2=10;

####CASE:事务1多种dml操作，多次提交
connection conn1;
set autocommit=0;
set @i1=1;
set @i2=2;
set @i3=3;
--sorted_result
execute trx1itmt1 using @i1;
--sorted_result
execute trx1itmt1 using @i2;
--sorted_result
execute trx1itmt1 using @i3;
commit;

connection conn2;
set autocommit=0;
--sorted_result
execute trx2stmt1 using @a1, @a2;
--sorted_result
execute trx2stmt2 using @a1, @a2;
--sorted_result
execute trx2stmt3 using @a1, @a2;

####insert
connection conn1;
set @i4=4;
--sorted_result
execute trx1itmt1 using @i4;
commit;

connection conn2;
--sorted_result
execute trx2stmt1 using @a1, @a2;
--sorted_result
execute trx2stmt2 using @a1, @a2;
--sorted_result
execute trx2stmt3 using @a1, @a2;

####replace
connection conn1;
set @r1=1;
set @r2=2;
--sorted_result
execute trx1rtmt1 using @r1, @r2, @r2, @r2, @r2;
commit;

connection conn2;
--sorted_result
execute trx2stmt1 using @a1, @a2;
--sorted_result
execute trx2stmt2 using @a1, @a2;
--sorted_result
execute trx2stmt3 using @a1, @a2;

####update
connection conn1;
set @u1=1;
set @u2=2;
--sorted_result
execute trx1utmt1 using @u1, @u1, @u1, @u1 ,@u2;
commit;

connection conn2;
--sorted_result
execute trx2stmt1 using @a1, @a2;
--sorted_result
execute trx2stmt2 using @a1, @a2;
--sorted_result
execute trx2stmt3 using @a1, @a2;

####delete
connection conn1;
set @d1=3;
--sorted_result
execute trx1dtmt1 using @d1;
commit;

connection conn2;
--sorted_result
execute trx2stmt1 using @a1, @a2;
--sorted_result
execute trx2stmt2 using @a1, @a2;
--sorted_result
execute trx2stmt3 using @a1, @a2;
commit;

#### trans 2 commit, then select
--sorted_result
execute trx2stmt1 using @a1, @a2;
--sorted_result
execute trx2stmt2 using @a1, @a2;
--sorted_result
execute trx2stmt3 using @a1, @a2;

drop table t1;
--source mysql_test/test_suite/ps/t/disable_ps.sql
