--source mysql_test/test_suite/ps/t/enable_ps.sql
#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
# description: ps_lose_delete.test ps_complex_delete.test

# ps_lose_delete.test
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4),(4,'a',2);

#add new column
prepare stmt1 from delete from  t1 where a=?;
set @a=1;
execute stmt1 using @a;
alter table t1 add d int;
--real_sleep 1
execute stmt1 using @a;
select * from t1;
deallocate prepare stmt1;

#drop column
prepare stmt2 from delete from  t1 where a=?;
set @a=2;
execute stmt2 using @a;
alter table t1 drop d;
--real_sleep 1
execute stmt2 using @a ;
select * from t1;
deallocate prepare stmt2;

#drop column used
prepare stmt3 from delete from  t1 where a=?;
set @a=3;
execute stmt3 using @a;
--error ER_NOT_SUPPORTED_YET
alter table t1 drop a;
--real_sleep 1
execute stmt3 using @a;
select * from t1;
deallocate prepare stmt3;

#drop table
prepare stmt4 from delete from  t1 where a=?;
set @a=4;
execute stmt4 using @a;
drop table t1;
--error 1146
execute stmt4 using @a;
deallocate prepare stmt4;

create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4),(4,'a',2);

#drop table and create again
prepare stmt5 from delete from  t1 where a=?;
set @a=4;
execute stmt5 using @a;
drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4),(4,'a',2);
execute stmt5 using @a;
select * from t1;
deallocate prepare stmt5;

#drop table and create with diff name
prepare stmt6 from delete from  t1 where a=?;
set @a=4;
execute stmt6 using @a;
drop table t1;
create table t2( a int primary key,b varchar(255));
--error 1146
execute stmt6 using @a;
deallocate prepare stmt6;

# ps_complex_delete.test
--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6;
--enable_warnings

create table t1(i1 int, f1 float, s1 varchar(1024), d1 datetime(6), i2 int, f2 float,s2 varchar(1024), d2 datetime(6),primary key(i1,f1,s1,d1));
prepare stmt_delete from delete from t1 where i1=? and f1=? and s1=? and d1=?;
prepare stmt_replace from replace into t1 values(?,?,?,?,?,?,?,?);
--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @s1='$l@abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @i2=$l;
    eval set @f2=$l.5;
    eval set @s2='$l+abcdefg';
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_replace using @i1,@f1,@s1,@d1,@i2,@f2,@s2,@d2;
}

--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @s1='$l@abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00'; 
    dec $l;
    execute stmt_delete using @i1,@f1,@s1,@d1;
}
select * from t1;
drop table t1;

create table t2(i1 int, f1 float, s1 varchar(1024), d1 datetime(6), i2 int, f2 float,s2 varchar(1024), d2 datetime(6),primary key(i1,f1,s1,d1));
prepare stmt_delete  from  delete from t2 where i1=? and f1=? and s1=? and d1=? and i2=?;
prepare stmt_replace from replace into t2 values(?,?,?,?,?,?,?,?);
--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @s1='$l,abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @i2=$l;
    eval set @f2=$l.5;
    eval set @s2='$l.abcdefg';
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_replace using @i1,@f1,@s1,@d1,@i2,@f2,@s2,@d2;
}

--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @s1='$l,abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @i2=$l;
    execute stmt_delete using @i1,@f1,@s1,@d1,@i2;
}
select * from t2;
drop table t2;

create table t3(i1 int, f1 float, s1 varchar(1024), d1 datetime(6), i2 int, f2 float,s2 varchar(1024), d2 datetime(6),primary key(i1,f1,s1,d1));
prepare stmt_delete_f2  from delete from t3 where i1=? and f1=? and s1=? and d1=? and f2=?;
prepare stmt_replace from replace into t3 values(?,?,?,?,?,?,?,?);
--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @s1='$l#abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @i2=$l;
    eval set @f2=$l.5;
    eval set @s2='$l!abcdefg';
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_replace using @i1,@f1,@s1,@d1,@i2,@f2,@s2,@d2;
}

--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @s1='$l#abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @f2=$l.5;
    execute stmt_delete_f2 using @i1,@f1,@s1,@d1,@f2;
}

select * from t3;
drop table t3;

create table t4(i1 int, f1 float, s1 varchar(1024), d1 datetime(6), i2 int, f2 float,s2 varchar(1024), d2 datetime(6),primary key(i1,f1,s1,d1));
prepare stmt_delete_s2  from delete from t4 where i1=? and f1=? and s1=? and d1=? and s2=?;
prepare stmt_replace from replace into t4 values(?,?,?,?,?,?,?,?);
--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @s1='$l''abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @i2=$l;
    eval set @f2=$l.5;
    eval set @s2='$l abcdefg';
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_replace using @i1,@f1,@s1,@d1,@i2,@f2,@s2,@d2;
}

--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @s1='$l''abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @s2='$l abcdefg';
    execute stmt_delete_s2 using @i1,@f1,@s1,@d1,@s2;
}
select * from t4;
drop table t4;

create table t5(i1 int, f1 float, s1 varchar(1024), d1 datetime(6), i2 int, f2 float,s2 varchar(1024), d2 datetime(6),primary key(i1,f1,s1,d1));
prepare stmt_delete_d2  from delete from t5 where i1=? and f1=? and s1=? and d1=? and d2=?;
prepare stmt_replace from replace into t5 values(?,?,?,?,?,?,?,?);
--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @s1='$l abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @i2=$l;
    eval set @f2=$l.5;
    eval set @s2='$l abcdefg';
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_replace using @i1,@f1,@s1,@d1,@i2,@f2,@s2,@d2;
}


--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @s1='$l abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_delete_d2 using @i1,@f1,@s1,@d1,@d2;
}
select * from t5;
drop table t5;

create table t6(i1 int, f1 float, s1 varchar(1024), d1 datetime(6), i2 int, f2 float,s2 varchar(1024), d2 datetime(6),primary key(i1,f1,s1,d1));
prepare stmt_delete_all from delete from t6 where i1=? and f1=? and s1=? and d1=? and i2=? and f2=? and s2=? and d2=?;
prepare stmt_replace from replace into t6 values(?,?,?,?,?,?,?,?);
--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @s1='$l^abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @i2=$l;
    eval set @f2=$l.5;
    eval set @s2='$l^abcdefg';
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_replace using @i1,@f1,@s1,@d1,@i2,@f2,@s2,@d2;
}

--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @s1='$l^abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @i2=$l;
    eval set @f2=$l.5;
    eval set @s2='$l^abcdefg';
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_delete_all using @i1,@f1,@s1,@d1,@i2,@f2,@s2,@d2;
}
select * from t6;
drop table t6;
