--source mysql_test/test_suite/ps/t/enable_ps.sql
#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
# jdbc_replace_ps_trx.test
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#-------------------transaction prepare-----------------

#add a new column

prepare stmt1 from replace into t1 values (1,'d',?),(2,'f',6);
set @x=1;
execute stmt1 using @x;
alter table t1 add d int;
--real_sleep 1
set autocommit=0;
--error ER_WRONG_VALUE_COUNT_ON_ROW
execute stmt1 using @x;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt1;



alter table t1 drop d;
--real_sleep 1

#drop a no exist column

prepare stmt2 from replace into t1 values (3,'d',3),(4,'f',?);
set @x=1;
execute stmt2 using @x;
--error ER_CANT_DROP_FIELD_OR_KEY
alter table t1 drop q;
--real_sleep 1
set autocommit=0;
execute stmt2 using @x;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt2;



#drop a exist column

prepare stmt3 from replace into t1 values (3,'d',3),(4,'f',?);
set @x=1;
execute stmt3 using @x;
alter table t1 drop c;
--real_sleep 1
set autocommit=0;
--error ER_WRONG_VALUE_COUNT_ON_ROW
execute stmt3 using @x;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt3;

drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);


#add a new column and drop it

prepare stmt4 from replace into t1 values (3,'d',2),(4,?,2);
set @x='x';
execute stmt4 using @x;
alter table t1 add d int;
--real_sleep 1
--real_sleep 1
alter table t1 drop d;
--real_sleep 1
--real_sleep 1
set autocommit=0;
execute stmt4 using @x ;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt4;

drop table t1;

create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#add a new column and drop it

prepare stmt4 from replace into t1 values (3,'d',2),(4,?,2);
set @x='x';
execute stmt4 using @x;
alter table t1 add d int;
--real_sleep 1
--real_sleep 1
alter table t1 drop d;
--real_sleep 1
--real_sleep 1
set autocommit=0;
set @x='y';
execute stmt4 using @x;
rollback;
set autocommit=1;
select * from t1;
deallocate prepare stmt4;


drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);


#drop a exist column,and add it which have same type with before

prepare stmt5 from replace into t1 values (5,'d',?),(4,'f',2);
set @x=2;
execute stmt5 using @x;
alter table t1 drop b;
--real_sleep 1
alter table t1 add b varchar(255);
--real_sleep 1
set autocommit=0;
--error ER_TRUNCATED_WRONG_VALUE_FOR_FIELD
execute stmt5 using @x;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt5;


#drop a exist column,and add it which have same type with before

prepare stmt5 from replace into t1 values (5,'d',?),(4,'f',2);
set @x=2;
--error ER_TRUNCATED_WRONG_VALUE_FOR_FIELD
execute stmt5 using @x;
alter table t1 drop b;
--real_sleep 1
alter table t1 add b varchar(255);
--real_sleep 1
set autocommit=0;
set @x=3;
--error ER_TRUNCATED_WRONG_VALUE_FOR_FIELD
execute stmt5 using @x;
rollback;
set autocommit=1;
select * from t1;
deallocate prepare stmt5;


#drop a exist column,add it which have different type with before
prepare stmt6 from replace into t1 values (5,?,'d'),(4,2,'f');
set @x=2;
execute stmt6 using @x;
alter table t1 drop b;
--real_sleep 1
alter table t1 add b int;
--real_sleep 1
set autocommit=0;
set @x=3;
--error ER_TRUNCATED_WRONG_VALUE_FOR_FIELD
execute stmt6 using @x;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt6;

#drop table t1;

prepare stmt7 from replace into t1 values (1,2,?),(2,5,1);
set @x=2;
execute stmt7 using @x;
drop table t1;
--real_sleep 1
set autocommit=0;
--error 1146
execute stmt7 using @x;
commit;
set autocommit=1;
deallocate prepare stmt7;

create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#drop table and create it again

prepare stmt8 from replace into t1 values (1,2,?),(2,5,1);
set @x=2;
execute stmt8 using @x;
drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);
set autocommit=0;
execute stmt8 using @x ;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt8;

#drop table and create it with diff shecma

prepare stmt9 from replace into t1 values (1,2,?),(2,5,1);
set @x=2;
execute stmt9 using @x;
drop table t1;
create table t1( a int primary key,b varchar(255));
set autocommit=0;
--error ER_WRONG_VALUE_COUNT_ON_ROW
execute stmt9 using @x;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt9;


#add column

drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2);

prepare stmt10 from replace into t1(a,b,c) values (1,'d',?),(2,'f',6);
set @x=1;
execute stmt10 using @x ;
alter table t1 add d int;
--real_sleep 1
set autocommit=0;
execute stmt10 using @x;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt10;



drop table t1;
create table t1( a int primary key,b varchar(255),c int,d int);
insert into t1 values(1,'a',2,2);

#drop no use column

prepare stmt11 from replace into t1(a,b,c) values (1,'d',?),(2,'f',6);
set @x=1;
execute stmt11 using @x;
alter table t1 drop d;
--real_sleep 1
set autocommit=0;
execute stmt11 using @x;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt11;

drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);
alter table t1 add d int;
--real_sleep 1

#drop no use column

prepare stmt12 from replace into t1(a,b,c) values (1,'d',?),(2,'f',6);
set @x=1;
execute stmt12 using @x;
alter table t1 drop c;
--real_sleep 1
set autocommit=0;
--error ER_BAD_FIELD_ERROR
execute stmt12 using @x;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt12;

drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);


prepare stmt13 from replace into t1(a,b) values (1,'d'),(2,?);
set @x=1;
execute stmt13 using @x;
alter table t1 drop c;
--real_sleep 1
set autocommit=0;
execute stmt13 using @x;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt13;


drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#drop column add it again with same type

prepare stmt14 from replace into t1(a,b,c) values (1,'d',1),(2,?,1);
set @x=1;
execute stmt14 using @x;
alter table t1 drop c;
--real_sleep 1
alter table t1 add c int;
--real_sleep 1
set autocommit=0;
execute stmt14 using @x;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt14;

drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);


#drop column add it again with diff type

prepare stmt15 from replace into t1(a,b,c) values (1,'d',1),(2,?,1);
set @x=1;
execute stmt15 using @x;
alter table t1 drop b;
--real_sleep 1
alter table t1 add b int;
--real_sleep 1
set autocommit=0;
--error ER_TRUNCATED_WRONG_VALUE_FOR_FIELD
execute stmt15 using @x;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt15;


drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#add column drop it again

prepare stmt16 from replace into t1(a,b,c) values (1,'d',1),(2,?,1);
set @x=1;
execute stmt16 using @x;
alter table t1 add d int;
--real_sleep 1
alter table t1 drop d;
--real_sleep 1

set autocommit=0;
execute stmt16 using @x;
commit;
set autocommit=1;
select * from t1;
deallocate prepare stmt16;

# jdbc_replace_ps_trx.test
##
##case1
##
--echo case1:
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (i1 int, v2 varchar(20), f3 float, d4 datetime(6), primary key(i1));
insert into t1(i1,v2,f3,d4) values(1,'a',1.3,'2013-05-30 01:00:00'),(2,'b',2.3,'2013-05-30 02:00:00'),(3,'c',3.3,'2013-05-30 03:00:00'),(4,'d',4.3,'2013-05-30 04:00:00');
prepare stmt from replace into t1 values(?,?,?,?);
set autocommit=0;
set @a=1;
set @b='a1';
set @c=1.4;
set @d='2013-05-30 01:10:00';
execute stmt using @a,@b,@c,@d;
set @a=5;
set @b='e';
set @c=5.3;
set @d='2013-05-30 05:00:00';
execute stmt using @a,@b,@c,@d;
commit;
set autocommit=1;
select * from t1;
disconnect conn1;

##
##case2
##
--echo case2:
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn2;
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2 (i1 int, v2 varchar(20), f3 float, d4 datetime(6), primary key(i1));
insert into t2(i1,v2,f3,d4) values(1,'a',1.3,'2013-05-30 01:00:00'),(2,'b',2.3,'2013-05-30 02:00:00'),(3,'c',3.3,'2013-05-30 03:00:00'),(4,'d',4.3,'2013-05-30 04:00:00');
prepare stmt from replace into t2 values(1,?,?,?);
set autocommit=0;
set @a='a1';
set @b=1.4;
set @c='2013-05-30 01:10:00';
execute stmt using @a,@b,@c;
set @a='a2';
set @b=1.5;
set @c='2013-05-30 01:20:00';
execute stmt using @a,@b,@c;
commit;
set autocommit=1;
select * from t2;
disconnect conn2;

##
##case3
##
--echo case3:
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn3;
--disable_warnings
drop table if exists t3;
--enable_warnings
create table t3 (i1 int, v2 varchar(20), f3 float, d4 datetime(6), primary key(i1));
insert into t3(i1,v2,f3,d4) values(1,'a',1.3,'2013-05-30 01:00:00'),(2,'b',2.3,'2013-05-30 02:00:00'),(3,'c',3.3,'2013-05-30 03:00:00'),(4,'d',4.3,'2013-05-30 04:00:00');
prepare stmt from replace into t3 values(?,?,?,?),(?,?,?,?);
set autocommit=0;
set @a=2;
set @b='b1';
set @c=2.4;
set @d='2013-05-30 02:10:00';
set @e=5;
set @f='e';
set @g=5.3;
set @h='2013-05-30 05:00:00';
execute stmt using @a,@b,@c,@d,@e,@f,@g,@h;
set @a=3;
set @b='c1';
set @c=3.4;
set @d='2013-05-30 03:10:00';
set @e=3;
set @f='c2';
set @g=3.5;
set @h='2013-05-30 03:20:00';
execute stmt using @a,@b,@c,@d,@e,@f,@g,@h;
commit;
set autocommit=1;
select * from t3;
disconnect conn3;

##
##case4
##
--echo case4:
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn4;
--disable_warnings
drop table if exists t4;
--enable_warnings
create table t4 (i1 int, v2 varchar(20), f3 float, d4 datetime(6), primary key(i1));
insert into t4(i1,v2,f3,d4) values(1,'a',1.3,'2013-05-30 01:00:00'),(2,'b',2.3,'2013-05-30 02:00:00'),(3,'c',3.3,'2013-05-30 03:00:00'),(4,'d',4.3,'2013-05-30 04:00:00');
prepare stmt from replace into t4 values(2,?,?,?),(5,?,?,?),(5,?,?,?);
set autocommit=0;
set @a='b1';
set @b=2.4;
set @c='2013-05-30 02:10:00';
set @d='e';
set @e=5.3;
set @f='2013-05-30 05:00:00';
set @g='e1';
set @h=5.4;
set @i='2013-05-30 05:10:00';
execute stmt using @a,@b,@c,@d,@e,@f,@g,@h,@i;
commit;
set autocommit=1;
select * from t4;
disconnect conn4;

##
##case5
##
--echo case5:rollback
connect (conn5,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn5;
--disable_warnings
drop table if exists t5;
--enable_warnings
create table t5 (i1 int, v2 varchar(20), f3 float, d4 datetime(6), primary key(i1));
insert into t5(i1,v2,f3,d4) values(1,'a',1.3,'2013-05-30 01:00:00'),(2,'b',2.3,'2013-05-30 02:00:00'),(3,'c',3.3,'2013-05-30 03:00:00'),(4,'d',4.3,'2013-05-30 04:00:00');
prepare stmt from replace into t5 values(?,?,?,?),(?,?,?,?);
set autocommit=0;
set @a=2;
set @b='b1';
set @c=2.4;
set @d='2013-05-30 02:10:00';
set @e=5;
set @f='e';
set @g=5.3;
set @h='2013-05-30 05:00:00';
execute stmt using @a,@b,@c,@d,@e,@f,@g,@h;
set @a=3;
set @b='c1';
set @c=3.4;
set @d='2013-05-30 03:10:00';
set @e=3;
set @f='c2';
set @g=3.5;
set @h='2013-05-30 03:20:00';
execute stmt using @a,@b,@c,@d,@e,@f,@g,@h;
rollback;
set autocommit=1;
select * from t5;
disconnect conn5;


##
##case6
##
--echo case6:rollback
connect (conn6,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn6;
--disable_warnings
drop table if exists t6;
--enable_warnings
create table t6 (i1 int, v2 varchar(20), f3 float, d4 datetime(6), primary key(i1));
insert into t6(i1,v2,f3,d4) values(1,'a',1.3,'2013-05-30 01:00:00'),(2,'b',2.3,'2013-05-30 02:00:00'),(3,'c',3.3,'2013-05-30 03:00:00'),(4,'d',4.3,'2013-05-30 04:00:00');
prepare stmt from replace into t6 values(?,?,?,?),(?,?,?,?);
set autocommit=0;
set @a=2;
set @b='b1';
set @c=2.4;
set @d='2013-05-30 02:10:00';
set @e=5;
set @f='e';
set @g=5.3;
set @h='2013-05-30 05:00:00';
execute stmt using @a,@b,@c,@d,@e,@f,@g,@h;
set @a=3;
set @b='c1';
set @c=3.4;
set @d='2013-05-30 03:10:00';
set @e=3;
set @f='c2';
set @g=3.5;
set @h='2013-05-30 03:20:00';
execute stmt using @a,@b,@c,@d,@e,@f,@g,@h;
rollback;
set autocommit=1;
select * from t6;
disconnect conn6;

