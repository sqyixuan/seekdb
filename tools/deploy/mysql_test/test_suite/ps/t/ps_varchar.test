--source mysql_test/test_suite/ps/t/enable_ps.sql
#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#add by bug 
#when select use varchar in ps can't use primary and index;

--disable_warnings
drop table if exists test_2;
--enable_warnings
create table test_2 (id varchar(10000), name varchar(100), c3 int, c4 varchar(100), c5 int, c6 float);
let $i = 0;
while($i < 500)
{
     eval replace into test_2 values('abc$i',$i,$i,'2010-09-01',101,$i.$i);
     inc $i; 
}
set @@session.ob_query_timeout = 100000;
prepare stmt1 from select * from test_2 where id like ?;
set @a='abc1';
execute stmt1 using @a;
set @b='abc40000';
execute stmt1 using @b;
prepare stmt1 from select * from test_2 where name like ?;
set @a='1';
execute stmt1 using @a;
set @b='40000';
execute stmt1 using @b;


--source mysql_test/test_suite/ps/t/disable_ps.sql
