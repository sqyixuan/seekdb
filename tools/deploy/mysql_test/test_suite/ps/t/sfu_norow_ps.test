--source mysql_test/test_suite/ps/t/enable_ps.sql
#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#######:聆彸ps耀宒
--disable_query_log
--source mysql_test/include/index_quick_major.inc
sleep 2;
--enable_query_log
--disable_warnings
drop table if exists tbl1,tbl2;
--enable_warnings
create table tbl1 (pk int,i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3),i6 bool, primary key(pk));
####珨圉噙怓杅擂ㄛ珨圉雄怓杅擂
insert into tbl1 values(1,1,'abc12','1agc',1.25,'2014-01-01 12:00:00',23.23,1),
                       (2,10,'23abc12','4agc1',-0.25,'2015-11-01 12:00:00',-23.230,0),
                       (3,201,'xx23abc12','cagc1',-2.25,'2015-11-21 11:20:10',3.231,1),
                       (4,80,'zx23abc12','zcagc1',2.25,'2013-01-21 11:20:10',-3.231,1),
                       (5,53,'cx23abc12','rcagc1',109.25,'2016-01-22 11:20:10',-13.131,0);

create index idx1 on tbl1(i3);                       
--source mysql_test/include/check_all_idx_ok.inc


insert into tbl1 values (6,78,'tx23abc12','icagc1',-109.25,'2014-09-16 16:24:00',-13.531,1),(8,50,'vx23abc12','wcagc1',-85.85,'2014-09-10 16:20:21',93.131,1),
(9,610,'ukx23abc12','pecagc1',-1.85,'2014-09-19 16:20:21',99.131,0),(10,42,'kx23abc12','ecagc1',-85.86,'2014-09-18 16:20:21',-99.131,1),
(11,null,null,null,null,null,null,null);


connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
set autocommit=0;

connection conn2;
set autocommit=0;
#### ps 掀誕
connection conn1;
set @a=1002;
prepare stmt1 from select * from tbl1 where pk > ?;
execute stmt1 using @a;


connection conn2;
set @a=1003;
prepare stmt1 from insert into  tbl1 values(?,102,'abdggc12','1agc1d',1.215,'2014-01-01 12:00:10',33.23,1);
execute stmt1 using @a;
connection conn1;
commit;
connection conn2;
commit;

####  ps in  (in) 
connection conn1;

set @a=1009;
set @b=1008;
set @c='1005';
prepare stmt1 from select * from tbl1 where pk in (?,?,?,1,2,3) and i1>710 ;
execute stmt1 using @a,@b,@c;
connection conn2;
set @a=1009;
prepare stmt1 from insert into  tbl1 values(?,106,'abdg5c12','a1agc1d',1.315,'2014-01-01 13:00:10',93.23,1);
execute stmt1 using @a;
update tbl1 set pk=1009 where pk=1008;
update tbl1 set pk=21 where pk=2;
connection conn1;
commit;
connection conn2;
commit;


#### is not null(準翋瑩ㄘ and 媼棒徹薦
connection conn1;
set @a=5;
prepare stmt1 from select * from tbl1 where i5 is not null and pk>=? and i1>500 for update ;
execute stmt1 using @a;

connection conn2;
insert into  tbl1 values(401,108,'adaadbdgsdgc12','abass1agc1d',1.6215,'2018-01-01 12:10:10',-63.123,1);
--error 1205,4012
update tbl1 set pk=29 where pk in (9,-9,-90,-100);
select * from tbl1 where pk=29 for update;
connection conn1;
commit;
connection conn2;
commit;
