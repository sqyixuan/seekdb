# owner: chaser.ch
# owner group: transaction
# description: 本case是为了测试在含未提交事务的BufMerge按sql_sequence被回滚的情况

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

connection conn0;
alter system set enable_auto_leader_switch = false;

connection conn1;
--disable_warnings
drop table if exists t1;
--enable_warnings

#建表
create table t1(c1 int primary key, c2 varchar(50), c3 int, c4 datetime(6), c5 datetime(6)) table_mode = 'queuing';

connection conn0;
let $__table_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ table_id from oceanbase.__all_virtual_table where table_name= 't1', table_id, 1);
let $__svr_cnt__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ count(*) as c from oceanbase.__all_server, c, 1);

connection conn1;
#insert 30 rows
--disable_query_log

let $i=0;
while($i < 30) 
{
    eval insert into t1 values($i + 1000, 'Hello OceanBase & Happy New Year', $i, '2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log

# version 2
connection conn0;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
--source mysql_test/include/wait_daily_merge.inc

connection conn1;
begin;

connection conn1;
#create Savepoint
SAVEPOINT p1;

connection conn1;
delete from t1 where c1 % 2 = 0;
# remain 30 rows

connection conn1;
#insert 30 rows, 60 rows in total
--disable_query_log

let $i=0;
while($i < 30) 
{
    eval insert into t1 values($i + 2000, 'Hello OceanBase & Happy New Year', $i, '2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

connection conn0;
--echo 1st minor finish

connection conn1;
#create Savepoint
SAVEPOINT p2;

connection conn1;
update t1 set c3 = 1000;

connection conn1;
#create Savepoint
SAVEPOINT p3;

connection conn1;
#insert 30 rows, 60 rows in total
--disable_query_log

let $i=0;
while($i < 30) 
{
    eval insert into t1 values($i + 3000, 'Hello OceanBase & Happy New Year', $i, '2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

connection conn0;
let $i=300;
while ($i > 0)
{
  sleep 2;
  dec $i;
  let $minor_count = query_get_value(select count(1) as c from oceanbase.__all_virtual_table_mgr where table_type = 13 and table_id = $__table_id__, c, 1);
  if ($minor_count == $__svr_cnt__) 
  {
    let $i = -5;
  }
}
if ($i != -5)
{
  --echo buf minor failed 111
  --echo $__table_id__
  --echo $minor_count
}

sleep 60;

# version 3
connection conn0;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
--source mysql_test/include/wait_daily_merge.inc

connection conn1;
# should be 75 rows
select count(*) from t1;

connection conn1;
ROLLBACK TO SAVEPOINT p3;
# should be 45
select count(*) from t1 where c3 = 1000;
# should be 0
select * from t1 where c1 > 3000;

connection conn1;
ROLLBACK TO SAVEPOINT p2;
# should be 45
select count(*) from t1;
# should be 0
select count(*) from t1 where c3 = 1000;

connection conn1;
ROLLBACK TO SAVEPOINT p1;
# should be 30
select count(*) from t1;
# should be 15
select count(*) from t1 where c1 % 2 = 0;

connection conn1;
commit;

connection conn1;
drop table t1;
