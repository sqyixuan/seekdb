# owner: lixia.yq
# owner group: transaction
# description: 本case是为了测试在含未提交事务的Buf Merge，并执行若干DML操作的正确性

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

connection conn0;
alter system set enable_auto_leader_switch = false;

connection conn1;
--disable_warnings
drop table if exists table_two_trans;
--enable_warnings

#建表
create table table_two_trans(i1 int primary key, s2 varchar(50), s3 varchar(100), i4 int) table_mode='queuing';

connection conn0;
let $__table_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ table_id from oceanbase.__all_virtual_table where table_name= 'table_two_trans', table_id, 1);
let $__svr_cnt__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ count(*) as c from oceanbase.__all_server, c, 1);

connection conn1;
alter system set minor_compact_trigger = 2;
sleep 2;

connection conn1;
#事务开始 插入数据 200 rows
#insert
--disable_query_log

let $i=0;
while($i < 200) 
{
    eval insert into table_two_trans values($i, 'Hello OceanBase & Happy New Year', 'Every Thing is all right $i', 4 * $i);
    inc $i;
}
--enable_query_log

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

#insert 100 rows
connection conn2;
begin;
--disable_query_log
let $i=200;
while($i < 300) 
{
    eval insert into table_two_trans values($i, 'Hello OceanBase & Happy New Year', 'Every Thing is all right $i', 4 * $i);
    inc $i;
}
--enable_query_log

# test buf minor merge
connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

connection conn0;

let $i=300;
while ($i > 0)
{
  sleep 1;
  dec $i;
  let $minor_count = query_get_value(select count(1) as c from oceanbase.__all_virtual_table_mgr where table_type = 13 and table_id = $__table_id__, c, 1);
  if ($minor_count == $__svr_cnt__) 
  {
    let $i = -5;
  }
}

if ($i != -5)
{
  --echo buf minor failed111
  --echo $__table_id__
  --echo $minor_count
}


connection conn1;
delete from table_two_trans where i1 % 2 = 1;

connection conn1;
select count(*) from table_two_trans;
# should be 100

connection conn2;
select count(*) from table_two_trans;
select * from table_two_trans where i1 >= 200 && i1 < 205;
update table_two_trans set i4 = 1000;

connection conn2;
commit;

connection conn1;
select count(*) from table_two_trans;
#should be 200
commit;

connection conn1;
begin;
update table_two_trans set i4 = i1 * 10 + 10;
select * from table_two_trans where i1 >= 200 && i1 < 205;

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc
connection conn0;
let $i=300;
while ($i > 0)
{
  sleep 1;
  dec $i;
  let $minor_count = query_get_value(select count(1) as c from oceanbase.__all_virtual_table_mgr where table_type = 13 and table_id = $__table_id__, c, 1);
  if ($minor_count == $__svr_cnt__) 
  {
    let $i = -5;
  }
}

if ($i != -5)
{
  --echo buf minor failed222
  --echo $__table_id__
  --echo $minor_count
}

connection conn1;
delete from table_two_trans where i1 > 200 || i1 < 50;

connection conn0;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
--source mysql_test/include/wait_daily_merge.inc

connection conn0;
let $i=300;
while ($i > 0)
{
  sleep 1;
  dec $i;
  let $minor_count = query_get_value(select count(1) as c from oceanbase.__all_virtual_table_mgr where table_type = 13 and table_id = $__table_id__, c, 1);
  if ($minor_count == 0) 
  {
    let $i = -5;
  }
}

if ($i != -5)
{
  --echo buf minor failed333
  --echo $__table_id__
  --echo $minor_count
}

connection conn1;
select count(*) from table_two_trans;
rollback;
select count(*) from table_two_trans;

connection conn2;
select count(*) from table_two_trans;
select * from table_two_trans where i1 >= 200 && i1 < 205;

drop table table_two_trans;
