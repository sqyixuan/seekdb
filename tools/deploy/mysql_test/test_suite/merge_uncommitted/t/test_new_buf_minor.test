# owner: chaser.ch
# owner group: transaction
# description: 本case是为了测试在含未提交事务的BufMerge(指定primary key)

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

connection conn0;
alter system set enable_auto_leader_switch = false;

connection conn1;
--disable_warnings
drop table if exists test_buf_minor_table;
--enable_warnings

#建表
create table test_buf_minor_table(num int primary key, str varchar(50), tag int) table_mode='queuing';

connection conn0;
let $__table_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ table_id from oceanbase.__all_virtual_table where table_name= 'test_buf_minor_table', table_id, 1);
let $__svr_cnt__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ count(*) as c from oceanbase.__all_server, c, 1);

connection conn1;
#事务开始 插入数据21 rows
insert into test_buf_minor_table value(100, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(99, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(98, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(97, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(96, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(95, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(94, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(93, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(92, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(91, 'Hello OceanBase & Happy New Year', 1);

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

sleep 5;

connection conn1;
begin;
insert into test_buf_minor_table value(90, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(89, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(88, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(87, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(86, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(85, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(84, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(83, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(82, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(81, 'Hello OceanBase & Happy New Year', 1);
insert into test_buf_minor_table value(80, 'Hello OceanBase & Happy New Year', 1);

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc    

connection conn0;
let $i=200;
while ($i > 0)
{
  sleep 2;
  dec $i;
  let $minor_count = query_get_value(select count(1) as c from oceanbase.__all_virtual_table_mgr where table_type = 13 and table_id = $__table_id__, c, 1);
  if ($minor_count == $__svr_cnt__) 
  {
    let $i = -5;
  }
}
if ($i != -5)
{
  --echo buf minor failed 111
  --echo $__table_id__
  --echo $minor_count
}

# DELETE 7 rows
connection conn1;
delete from test_buf_minor_table where num > 98 || num < 85;

connection conn1;
#insert 200 rows
--disable_query_log

let $i=0;
while($i < 200) 
{
    eval insert into test_buf_minor_table values($i + 1000, 'Hello OceanBase & Happy New Year', 4);
    inc $i;
}
--enable_query_log

#不同事务查询sstable未提交事务
connection conn2;
select count(*) from test_buf_minor_table;

connection conn1;
select count(*) from test_buf_minor_table;
commit;

connection conn1;
select count(*) from test_buf_minor_table;

connection conn1;
delete from test_buf_minor_table where num % 2 = 0;
update test_buf_minor_table set tag = num * 10 + 10;

select count(*) from test_buf_minor_table;
#commit;

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc
connection conn0;
let $i=200;
while ($i > 0)
{
  sleep 1;
  dec $i;
  let $minor_count = query_get_value(select count(1) as c from oceanbase.__all_virtual_table_mgr where table_type = 13 and table_id = $__table_id__, c, 1);
  if ($minor_count == $__svr_cnt__) 
  {
    let $i = -5;
  }
}

if ($i != -5)
{
  --echo buf minor failed 222
  --echo $__table_id__
  --echo $minor_count
}

connection conn1;
delete from test_buf_minor_table where num > 1000;

connection conn0;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
--source mysql_test/include/wait_daily_merge.inc

connection conn0;
let $i=200;
while ($i > 0)
{
  sleep 1;
  dec $i;
  let $minor_count = query_get_value(select count(1) as c from oceanbase.__all_virtual_table_mgr where table_type = 13 and table_id = $__table_id__, c, 1);
  if ($minor_count == $__svr_cnt__) 
  {
    let $i = -5;
  }
}

if ($i != -5)
{
  --echo buf minor failed 333
  --echo $__table_id__
  --echo $minor_count
}

connection conn1;
select * from test_buf_minor_table;

connection conn2;
select * from test_buf_minor_table;

drop table test_buf_minor_table;
