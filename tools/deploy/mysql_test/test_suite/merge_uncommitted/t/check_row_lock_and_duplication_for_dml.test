# owner: chaser.ch
# owner group: storage
# description: row lock and duplication check in sstables during DML. 

set @@session.explicit_defaults_for_timestamp=off;

connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
alter system set minor_compact_trigger = 10;

--let $value=1
--let $bytes=1500
--let $byte=1
while($bytes)
{
    --let $value=$value$byte
    dec $bytes;
}

connection conn1;
--disable_warnings
drop table if exists test_dml_conflict_check;
--enable_warnings
create table test_dml_conflict_check(c1 varchar(2048) primary key, c2 int) BLOCK_SIZE = 4096 COMPRESSION = 'none';

connection conn4;
eval insert into test_dml_conflict_check values ('a$value',0);
begin;
eval update test_dml_conflict_check set c1=1 where c1='a$value';

connection conn1;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn3;
begin;
eval insert into test_dml_conflict_check values ('z$value',0);

connection conn2;
eval insert into test_dml_conflict_check values ('b$value',0);
eval insert into test_dml_conflict_check values ('c$value',0);
eval insert into test_dml_conflict_check values ('d$value',0);
eval insert into test_dml_conflict_check values ('e$value',0);
eval insert into test_dml_conflict_check values ('f$value',0);
eval insert into test_dml_conflict_check values ('g$value',0);
eval insert into test_dml_conflict_check values ('h$value',0);
eval insert into test_dml_conflict_check values ('i$value',0);
eval insert into test_dml_conflict_check values ('j$value',0);
eval insert into test_dml_conflict_check values ('k$value',0);
eval insert into test_dml_conflict_check values ('l$value',0);
eval insert into test_dml_conflict_check values ('m$value',0);
eval insert into test_dml_conflict_check values ('n$value',0);

--error 1205
eval delete from test_dml_conflict_check where c1='a$value';

connection conn1;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn2;
--error 1205
eval delete from test_dml_conflict_check where c1='a$value';

connection conn4;
commit;
connection conn3;
commit;

connection conn1;
--disable_warnings
drop table if exists test_dml_conflict_check;
--enable_warnings
create table test_dml_conflict_check(c1 varchar(2048) primary key, c2 int) BLOCK_SIZE = 4096 COMPRESSION = 'none';
connection conn2;
insert into test_dml_conflict_check values('2', 0);

connection conn1;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn3;
begin;
insert into test_dml_conflict_check values('1', 0); 

connection conn2;
set session transaction isolation level repeatable read;
begin;
select * from test_dml_conflict_check;
--error 1205
insert into test_dml_conflict_check values('1', 0); 

connection conn3;
commit;

connection conn2;
--error 6235 
insert into test_dml_conflict_check values('1', 0);

connection conn1;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn2;
--error 6235 
insert into test_dml_conflict_check values('1', 0);
commit;

drop table test_dml_conflict_check;
