# owner: gengli.wzy
# owner group: transaction
# description: test if dirty macro block will be rewrited

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

let $__timeout_def__ = 1000 * 1000 * 1000;

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
eval set SESSION ob_query_timeout = $__timeout_def__;
eval set SESSION ob_trx_timeout = $__timeout_def__;
eval set SESSION ob_trx_idle_timeout = $__timeout_def__;

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
eval set SESSION ob_query_timeout = $__timeout_def__;
eval set SESSION ob_trx_timeout = $__timeout_def__;
eval set SESSION ob_trx_idle_timeout = $__timeout_def__;
sleep 2;

connection conn1;
alter system set minor_compact_trigger = 10;
--disable_warnings
drop table if exists test_rewrite_dirty_macro_t;
drop sequence if exists test_rewrite_dirty_macro_seq;
--enable_warnings

create table test_rewrite_dirty_macro_t(c1 int primary key, c2 bigint, c3 varchar(2048)) compression "none";
let $__freeze_table_name__ = 'test_rewrite_dirty_macro_t';

connection conn0;
let $__tenant_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ tenant_id from oceanbase.__all_virtual_table where table_name= 'test_rewrite_dirty_macro_t', tenant_id, 1);
let $__table_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ table_id from oceanbase.__all_virtual_table where table_name= 'test_rewrite_dirty_macro_t', table_id, 1);
let $__svr_cnt__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ count(*) as c from oceanbase.__all_virtual_server_stat, c, 1);

# prepare data, insert rows more than one macro
--disable_query_log
--disable_result_log

connection conn1;

create sequence test_rewrite_dirty_macro_seq cache 10240 noorder;

insert into test_rewrite_dirty_macro_t 
select test_rewrite_dirty_macro_seq.nextval, random(), randstr(10, random()) 
from table(generator(3000));

--enable_query_log
--enable_result_log

connection conn1;
insert into test_rewrite_dirty_macro_t values (3001, 3001, "aaaa");

--source mysql_test/include/minor_freeze_tablet_and_wait_done.inc

connection conn1;
let $__now_time__ = query_get_value(select now() as c, c, 1);
alter system set minor_compact_trigger = 1;
--source mysql_test/include/wait_mini_minor_merge_for_table.inc

connection conn1;
insert into test_rewrite_dirty_macro_t values (3002, 3002, "aaaa");
commit;

insert into test_rewrite_dirty_macro_t values (4000,4000,"a");

let $__now_time__ = query_get_value(select now() as c, c, 1);


--source mysql_test/include/minor_freeze_tablet_and_wait_done.inc


--source mysql_test/include/wait_mini_minor_merge_for_table.inc


connection conn0;
let $use_old=query_get_value(select multiplexed_macro_block_count from oceanbase.__all_virtual_tablet_compaction_history where tablet_id in (select tablet_id from __all_virtual_tablet_to_ls where table_id = $__table_id__) order by finish_time desc limit 1, multiplexed_macro_block_count, 1);
echo $use_old;

connection conn1;
select count(1) from test_rewrite_dirty_macro_t;

drop table test_rewrite_dirty_macro_t;
alter system set minor_compact_trigger = 2;
