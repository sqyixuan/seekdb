set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;
alter system set enable_auto_leader_switch = false;
drop table if exists test_alter_several_times_table;
create table test_alter_several_times_table(c1 int primary key, c2 varchar(50), c3 int, c4 datetime(6), c5 datetime(6));
insert 30 rows
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
alter table test_alter_several_times_table table_mode='queuing';
insert 30 rows, 60 rows in total
begin;
delete from test_alter_several_times_table where c1 % 2 = 0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
1st minor finish
insert 30 rows
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
select count(*) from test_alter_several_times_table;
count(*)
60
rollback;
alter table test_alter_several_times_table table_mode='normal';
begin;
insert 30 rows
update test_alter_several_times_table set c3 = c1 + 1;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
select count(*) from test_alter_several_times_table;
count(*)
90
commit;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
alter table test_alter_several_times_table table_mode='queuing';
begin;
insert 10 rows, 100 rows in total
update test_alter_several_times_table set c3 = c3 + 1;
select count(*) from test_alter_several_times_table;
count(*)
100
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
delete from test_alter_several_times_table where c1 % 2 != 0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
select count(*) from test_alter_several_times_table;
count(*)
50
