set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;
alter system set enable_auto_leader_switch = false;
drop table if exists table_two_trans;
create table table_two_trans(i1 int primary key, s2 varchar(50), s3 varchar(100), i4 int) table_mode='queuing';
alter system set minor_compact_trigger = 2;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
begin;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
delete from table_two_trans where i1 % 2 = 1;
select count(*) from table_two_trans;
count(*)
100
select count(*) from table_two_trans;
count(*)
200
select * from table_two_trans where i1 >= 200 && i1 < 205;
i1	s2	s3	i4
200	Hello OceanBase & Happy New Year	Every Thing is all right 200	800
201	Hello OceanBase & Happy New Year	Every Thing is all right 201	804
202	Hello OceanBase & Happy New Year	Every Thing is all right 202	808
203	Hello OceanBase & Happy New Year	Every Thing is all right 203	812
204	Hello OceanBase & Happy New Year	Every Thing is all right 204	816
update table_two_trans set i4 = 1000;
commit;
select count(*) from table_two_trans;
count(*)
200
commit;
begin;
update table_two_trans set i4 = i1 * 10 + 10;
select * from table_two_trans where i1 >= 200 && i1 < 205;
i1	s2	s3	i4
200	Hello OceanBase & Happy New Year	Every Thing is all right 200	2010
201	Hello OceanBase & Happy New Year	Every Thing is all right 201	2020
202	Hello OceanBase & Happy New Year	Every Thing is all right 202	2030
203	Hello OceanBase & Happy New Year	Every Thing is all right 203	2040
204	Hello OceanBase & Happy New Year	Every Thing is all right 204	2050
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
delete from table_two_trans where i1 > 200 || i1 < 50;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select count(*) from table_two_trans;
count(*)
76
rollback;
select count(*) from table_two_trans;
count(*)
200
select count(*) from table_two_trans;
count(*)
200
select * from table_two_trans where i1 >= 200 && i1 < 205;
i1	s2	s3	i4
200	Hello OceanBase & Happy New Year	Every Thing is all right 200	1000
201	Hello OceanBase & Happy New Year	Every Thing is all right 201	1000
202	Hello OceanBase & Happy New Year	Every Thing is all right 202	1000
203	Hello OceanBase & Happy New Year	Every Thing is all right 203	1000
204	Hello OceanBase & Happy New Year	Every Thing is all right 204	1000
drop table table_two_trans;
