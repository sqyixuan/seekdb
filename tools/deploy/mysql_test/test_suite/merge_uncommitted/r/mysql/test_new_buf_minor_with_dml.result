set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;
alter system set enable_auto_leader_switch = false;
drop table if exists table_with_dml;
create table table_with_dml(i1 int primary key, s2 varchar(50), s3 varchar(100), i4 int) table_mode='queuing';
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
delete from table_with_dml where i1 % 2 = 1;
select count(*) from table_with_dml;
count(*)
500
select count(*) from table_with_dml;
count(*)
2500
select count(*) from table_with_dml;
count(*)
500
delete from table_with_dml where i4 = 0;
select count(*) from table_with_dml;
count(*)
499
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
commit;
begin;
update table_with_dml set i4 = i1 * 10 + 10;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
commit;
begin;
delete from table_with_dml where i1 > 2500;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
commit;
select count(*) from table_with_dml;
count(*)
250
select count(*) from table_with_dml;
count(*)
250
select * from table_with_dml where i1 > 2014 && i1 < 2022;
i1	s2	s3	i4
2016	Hello OceanBase & Happy New Year	Every Thing is all right 16	20170
2018	Hello OceanBase & Happy New Year	Every Thing is all right 18	20190
2020	Hello OceanBase & Happy New Year	Every Thing is all right 20	20210
select count(*) from table_with_dml where i4 = 0 || i1 % 2 = 1;
count(*)
0
drop table table_with_dml;
