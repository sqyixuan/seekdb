alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
delete from test_buf_minor_table where num > 98 || num < 85;
select count(*) from test_buf_minor_table;
count(*)
10
select count(*) from test_buf_minor_table;
count(*)
214
commit;
select count(*) from test_buf_minor_table;
count(*)
214
delete from test_buf_minor_table where num % 2 = 0;
update test_buf_minor_table set tag = num * 10 + 10;
select count(*) from test_buf_minor_table;
count(*)
107
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
delete from test_buf_minor_table where num > 1000;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
