set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;
alter system set enable_auto_leader_switch = false;
drop table if exists test_buf_minor_table;
create table test_buf_minor_table(num int primary key, str varchar(50), tag int) table_mode='queuing';
insert into test_buf_minor_table value(100, 'Hello OceanBase & Happy New Year', 1);
