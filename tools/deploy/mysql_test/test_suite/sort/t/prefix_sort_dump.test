# owner: luofan.zp
# owner group: SQL2
# tags: sort
## test prefix sort dump
--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_warnings
drop table if exists t_dump_prefix_topn;
--enable_warnings

alter system set _rowsets_max_rows = 5 tenant = sys;
alter system set _rowsets_max_rows = 5 tenant = all_user;
alter system set _rowsets_max_rows = 5 tenant = all_meta;
alter system set_tp tp_no = 246, error_code = 5, frequency = 1;

--sleep 1

create table t_dump_prefix_topn (a int, b int, index idx(a, b));
insert into t_dump_prefix_topn values(0,2),(0,4),(1,3),(1,1),(1,5);
insert into t_dump_prefix_topn values(3,2),(3,4),(3,3),(3,1),(3,5);
insert into t_dump_prefix_topn values(2,2),(2,4),(2,3),(2,1),(2,5);

select a, b from t_dump_prefix_topn order by a, b desc limit 50000;

alter system set _rowsets_max_rows = 256 tenant = sys;
alter system set _rowsets_max_rows = 256 tenant = all_user;
alter system set _rowsets_max_rows = 256 tenant = all_meta;
alter system set_tp tp_no = 246, error_code = 0, frequency = 1;
