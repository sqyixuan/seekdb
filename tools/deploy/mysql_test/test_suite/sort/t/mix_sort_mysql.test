# owner: luofan.zp
# owner group: sql2
# description: test for limit topn sort

--disable_warnings
drop table if exists t_simple_topn, t_simple_prefix_topn;
--enable_warnings
--result_format 4



############################# test for without vectorize ################################

alter system flush plan cache global;
alter system set _rowsets_enabled = false;


########## simple sort + topn sort : less/equal/more ##########

create table t_simple_topn(c int);

insert into t_simple_topn values(33),(35),(39),(30),(34);
select * from t_simple_topn order by c limit 3;
select * from t_simple_topn order by c limit 5;
select * from t_simple_topn order by c limit 8;

insert into t_simple_topn values(31),(38),(36);
select * from t_simple_topn order by c limit 5;
select * from t_simple_topn order by c limit 8;
select * from t_simple_topn order by c limit 11;

insert into t_simple_topn values(32),(37);
select * from t_simple_topn order by c limit 5;
select * from t_simple_topn order by c limit 8;
select * from t_simple_topn order by c limit 11;


########## simple sort + prefix sort + topn sort ##############

create table t_simple_prefix_topn (a int, b int, index idx(a, b));
insert into t_simple_prefix_topn values(1,2),(1,4),(1,3),(1,1),(1,5);
insert into t_simple_prefix_topn values(3,2),(3,4),(3,3),(3,1),(3,5);
insert into t_simple_prefix_topn values(2,2),(2,4),(2,3),(2,1),(2,5);

select a, b from t_simple_prefix_topn order by a, b desc;
select a, b from t_simple_prefix_topn order by a, b desc limit 5;
select a, b from t_simple_prefix_topn order by a, b desc limit 8;
select a, b from t_simple_prefix_topn order by a, b desc limit 20;

insert into t_simple_prefix_topn values(1,2),(1,4),(1,3);
insert into t_simple_prefix_topn values(3,2),(3,4),(3,3);
insert into t_simple_prefix_topn values(2,2),(2,4),(2,3);

select a, b from t_simple_prefix_topn order by a, b desc;
select a, b from t_simple_prefix_topn order by a, b desc limit 5;
select a, b from t_simple_prefix_topn order by a, b desc limit 8;
select a, b from t_simple_prefix_topn order by a, b desc limit 20;

insert into t_simple_prefix_topn values(1,2),(1,4),(1,3);
insert into t_simple_prefix_topn values(3,2),(3,4),(3,3);
insert into t_simple_prefix_topn values(2,2),(2,4),(2,3);

select a, b from t_simple_prefix_topn order by a, b desc;
select a, b from t_simple_prefix_topn order by a, b desc limit 5;
select a, b from t_simple_prefix_topn order by a, b desc limit 8;
select a, b from t_simple_prefix_topn order by a, b desc limit 20;


--disable_warnings
drop table if exists t_simple_topn, t_simple_prefix_topn;
--enable_warnings






############################# test for with vectorize ###################################

alter system flush plan cache global;
alter system set _rowsets_enabled = true;


########## simple sort + topn sort : less/equal/more ##########

create table t_simple_topn(c int);

insert into t_simple_topn values(33),(35),(39),(30),(34),(31),(38),(36),(32),(37);
insert into t_simple_topn values(53),(55),(59),(50),(54),(51),(58),(56),(52),(57);
insert into t_simple_topn values(93),(95),(99),(90),(94),(91),(98),(96),(92),(97);
insert into t_simple_topn values(3),(5),(9),(0),(4),(1),(8),(6),(2),(7);
insert into t_simple_topn values(43),(45),(49),(40),(44),(41),(48),(46),(42),(47);
insert into t_simple_topn values(13),(15),(19),(10),(14),(11),(18),(16),(12),(17);
insert into t_simple_topn values(83),(85),(89),(80),(84),(81),(88),(86),(82),(87);
insert into t_simple_topn values(63),(65),(69),(60),(64),(61),(68),(66),(62),(67);
insert into t_simple_topn values(23),(25),(29),(20),(24),(21),(28),(26),(22),(27);
insert into t_simple_topn values(73),(75),(79),(70),(74),(71),(78),(76),(72),(77);
insert into t_simple_topn select c + 100 from t_simple_topn;
insert into t_simple_topn select c + 200 from t_simple_topn;

select * from t_simple_topn order by c;
select * from t_simple_topn order by c limit 20;
select * from t_simple_topn order by c limit 256;
select * from t_simple_topn order by c limit 500;


########## simple sort + prefix sort + topn sort ##############

create table t_simple_prefix_topn (a int, b int, index idx(a, b));
insert into t_simple_prefix_topn values(1,2),(1,4),(1,3),(1,1),(1,5);
insert into t_simple_prefix_topn values(3,2),(3,4),(3,3),(3,1),(3,5);
insert into t_simple_prefix_topn values(2,2),(2,4),(2,3),(2,1),(2,5);
insert into t_simple_prefix_topn values(4,2),(4,4),(4,3),(4,1),(4,5);
insert into t_simple_prefix_topn values(5,2),(5,4),(5,3),(5,1),(5,5);

insert into t_simple_prefix_topn select a + 5, b from t_simple_prefix_topn;
insert into t_simple_prefix_topn select a + 10, b from t_simple_prefix_topn;
insert into t_simple_prefix_topn select a + 20, b from t_simple_prefix_topn;
insert into t_simple_prefix_topn select a + 40, b from t_simple_prefix_topn;


select a, b from t_simple_prefix_topn order by a, b desc;
select a, b from t_simple_prefix_topn order by a, b desc limit 20;
select a, b from t_simple_prefix_topn order by a, b desc limit 256;
select a, b from t_simple_prefix_topn order by a, b desc limit 500;


--disable_warnings
drop table if exists t_simple_topn, t_simple_prefix_topn;
--enable_warnings
