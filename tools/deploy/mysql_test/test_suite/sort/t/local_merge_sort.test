##local merge sort
explain
select c3 from t1_wlz where c1=100 and c2=200 and  partition_key >=date_format(date_sub('20190627', interval 8 MONTH), '%Y%m%d') and partition_key <=date_format('20190627', '%Y%m%d') order by c3;

select c3 from t1_wlz where c1=100 and c2=200 and  partition_key >=date_format(date_sub('20190627', interval 8 MONTH), '%Y%m%d') and partition_key <=date_format('20190627', '%Y%m%d') order by c3;

explain
select c3 from t1_wlz where c1=100 and c2=200  order by c3;
select c3 from t1_wlz where c1=100 and c2=200  order by c3;

explain
select id,c3 from t1_wlz where c1=100 and c2=200  order by c3;
select id,c3 from t1_wlz where c1=100 and c2=200  order by c3;

##desc
explain select id,c3 from t1_wlz where c1=100 and c2=200  order by c3 desc;
select id,c3 from t1_wlz where c1=100 and c2=200  order by c3 desc;

explain
select c3 from t1_wlz where c1=100 and c2=200 and id>1 order by c3;
select c3 from t1_wlz where c1=100 and c2=200 and id>1 order by c3;

##multi sort key
explain
select c3 from t1_wlz where c1=100 and id>1 order by c2,c3;
select c3 from t1_wlz where c1=100 and id>1 order by c2,c3;

explain
select c3 from t1_wlz where c1=100 and id>1 order by 1,c2,c3;
select c3 from t1_wlz where c1=100 and id>1 order by 1,c2,c3;

##desc not be local merge sort
explain
select c3 from t1_wlz where  id>1 order by c1 desc,c2,c3;
select c3 from t1_wlz where  id>1 order by c1 desc,c2,c3;

##can't be local merge sort
explain
select c3 from t1_wlz where c1=100 and c2>200 and id>1 order by c3;
select c3 from t1_wlz where c1=100 and c2>200 and id>1 order by c3;

explain
select c3 from t1_wlz where c1=100 and c2 in(200,300) and id>1 order by c3;
select c3 from t1_wlz where c1=100 and c2 in(200,300) and id>1 order by c3;

explain
select c3 from t1_wlz where c1=100 and c2=200 and id>1 order by c3,c4;
select c3 from t1_wlz where c1=100 and c2=200 and id>1 order by c3,c4;

explain
select id,c2,c3 from t1_wlz where c1=100 and c2>200  order by c2, c3 desc;
select id,c2,c3 from t1_wlz where c1=100 and c2>200  order by c2, c3 desc;

explain
select id,c2,c3 from t1_wlz where c1=100 and c2>200  order by c2 desc,c3;
select id,c2,c3 from t1_wlz where c1=100 and c2>200  order by c2 desc,c3;

##can't be prefix sort
explain
select /*+ index(t1_wlz IDX_OIT_N)*/c3 from t1_wlz where c1=100 and c2=200 and  partition_key >=date_format(date_sub('20190627', interval 8 MONTH), '%Y%m%d') and partition_key <=date_format('20190627', '%Y%m%d') order by c3,c4;
select /*+ index(t1_wlz IDX_OIT_N)*/c3 from t1_wlz where c1=100 and c2=200 and  partition_key >=date_format(date_sub('20190627', interval 8 MONTH), '%Y%m%d') and partition_key <=date_format('20190627', '%Y%m%d') order by c3,c4;



--disable_warnings
drop table t1_wlz;
--enable_warnings


--disable_warnings
