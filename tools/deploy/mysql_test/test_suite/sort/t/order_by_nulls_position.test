#owner: xiaoyi.xy
#owner group: sql1
#tags: optimizer

--result_format 4
--explain_protocol 2
--disable_info
--disable_metadata

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

--disable_result_log
--disable_query_log
create table t1 (a int, b int, c varchar(255));
create index idx_t1_a on t1(a);
--source mysql_test/include/check_all_idx_ok.inc

insert into t1 values (1, 1, NULL);
insert into t1 values (1, NULL, 'hello1');
insert into t1 values (1, NULL, 'hello1');
insert into t1 values (NULL, 1, 'hello2');
insert into t1 values (NULL, 1, 'hello2');
insert into t1 values (NULL, 2, NULL);
insert into t1 values (2, NULL, NULL);
insert into t1 values (2, 2, NULL);
insert into t1 values (2, 1, 'hello2');

--enable_query_log
--enable_result_log

--echo // CASE#1 Simple Order by
select * from t1 order by a;
select * from t1 order by b;
select * from t1 order by c;

select * from t1 order by a asc, b desc, c;
select * from t1 order by a desc, b asc, c desc;
select * from t1 order by a asc, b desc, c asc;

--echo // CASE#2 Group By
select /*+ no_use_hash_aggregation*/a from t1 group by a;

--echo // CASE#3 Use index
select /*+ index(t1 idx_t1_a)*/* from t1;

--echo // CASE#4 Eliminate Sort
select a from t1 where a is not null order by a desc;

select a from t1 order by a desc;

select a from t1 order by a asc;

--echo // Multi Partitions
--disable_query_log
--disable_result_log

--disable_warnings
drop table if exists t2;
--enable_warnings

--disable_query_log
--disable_result_log
create table t2 (a int primary key, b int, c int) partition by hash (a) partitions 2;

insert into t2 values (1, 1, 1);
insert into t2 values (2, 1, NULL);
insert into t2 values (3, 1, NULL);
insert into t2 values (4, 2, 1);
insert into t2 values (5, NULL, 1);
insert into t2 values (6, NULL, 1);

--enable_result_log
--enable_query_log
select * from t2;
select * from t2 order by b;
select * from t2 order by b desc;
select * from t2 order by b desc, c asc;
select * from t2 order by b desc, c desc;
select * from t2 order by b asc, c desc;
select * from t2 order by b asc, c asc;
