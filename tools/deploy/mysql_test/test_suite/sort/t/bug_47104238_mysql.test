alter system flush plan cache global;
alter system set _rowsets_enabled = true;

SELECT * FROM T_TOPN_M WHERE PK IN (SELECT PK FROM (SELECT col_varchar_10_key FROM T_TOPN_E ORDER BY col_varchar_10_key LIMIT 0));

alter system flush plan cache global;

