# owner group: SQL2
# tags: sort
## test topn sort

--disable_warnings
drop table if exists T_TOPN_E, T_TOPN_M;
--enable_warnings
--result_format 4


CREATE TABLE T_TOPN_E (
  col_int int,
  col_date_key date,
  col_date date,
  col_datetime_key datetime,
  pk int,
  col_varchar_20_key varchar(20),
  col_varchar_10_key varchar(10),
  col_int_key int,
  col_varchar_10 varchar(10),
  col_varchar_20 varchar(20),
  col_datetime datetime,
  /*Indices*/
  key idx7(pk, col_date_key ),
  key idx9(pk, col_datetime_key ),
  primary key (pk) ,
  key idx5(pk, col_varchar_20_key ),
  key idx3(pk, col_varchar_10_key ),
  key idx1(pk, col_int_key )
);

