68),(582, 848),(960, 337),(364, 892),(374, 998),(87, 682),(909, 964),(953, 586),(260, 239),(846, 946),(76, 285),(577, 997),(683, 217),(731, 875),(909, 167),(506, 830),(856, 0),(556, 597),(250, 883),(533, 931),(922, 70),(105, 76),(550, 201),(807, 100),(837, 927),(842, 645),(657, 774),(295, 69),(808, 331),(319, 371),(380, 510),(686, 783),(851, 6),(100, 414),(293, 943),(322, 78),(143, 503),(585, 248),(497, 995),(654, 434),(266, 505),(197, 994),(354, 667),(884, 562),(960, 354),(672, 997),(761, 251),(285, 781),(208, 992),(289, 712),(665, 412),(246, 349),(0, 608),(829, 807),(211, 279),(60, 735),(993, 817),(938, 838),(508, 142),(453, 729),(778, 467),(701, 419),(241, 30),(399, 478),(503, 80),(198, 230),(76, 97),(685, 177),(451, 128),(647, 737),(781, 326),(897, 136),(871, 643),(356, 785),(221, 3),(69, 246),(1, 21),(521, 737),(528, 324),(597, 558),(643, 71),(140, 592),(77, 68),(559, 818),(101, 598),(21, 570),(650, 271),(285, 247),(137, 665),(174, 86),(911, 43),(452, 687),(48, 413),(538, 304),(23, 389),(300, 147),(310, 246),(79, 163),(18, 480),(310, 758),(563, 633),(207, 71),(443, 995),(357, 699),(480, 992),(69, 88),(184, 805),(709, 385),(839, 912),(119, 459),(923, 844),(310, 775),(650, 249),(123, 577),(366, 130),(330, 572),(406, 978),(292, 611),(160, 229),(824, 298),(838, 755),(480, 239),(968, 505),(164, 173),(162, 175),(466, 381),(495, 1),(372, 976),(512, 121),(235, 983),(535, 730);
insert /*+query_timeout(1000000000)*/ into t5 select null, null from table(generator(10000));

#singe table single sort key, without parallel
explain basic select c1 from t1 order by c1 limit 5;
explain basic select c2 from t1 order by c2 desc limit 5;
explain basic select c1 from t2 order by c1 limit 5;
explain basic select c2 from t2 order by c2 desc limit 5;
select c1 from t1 order by c1 limit 5;
select c2 from t1 order by c2 desc limit 5;
select c1 from t2 order by c1 limit 5;
select c2 from t2 order by c2 desc limit 5;

#singe table single sort key, with parallel
explain basic select /*+parallel(2)*/ c1 from t1 order by c1 limit 5;
explain basic select /*+parallel(2)*/ c2 from t1 order by c2 desc limit 5;
explain basic select /*+parallel(2)*/ c1 from t2 order by c1 limit 5;
explain basic select /*+parallel(2)*/ c2 from t2 order by c2 desc limit 5;
select /*+parallel(2)*/ c1 from t1 order by c1 limit 5;
select /*+parallel(2)*/ c2 from t1 order by c2 desc limit 5;
select /*+parallel(2)*/ c1 from t2 order by c1 limit 5;
select /*+parallel(2)*/ c2 from t2 order by c2 desc limit 5;

#singe table multiple sort keys
explain basic select c1, c2 from t1 order by c1 desc, c2 asc limit 5;
explain basic select c1, c2 from t2 order by c1 asc, c2 desc limit 5;
explain basic select /*+parallel(2)*/ c1, c2 from t1 order by c1 desc, c2 asc limit 5;
explain basic select /*+parallel(2)*/ c1, c2 from t2 order by c1 asc, c2 desc limit 5;
select c1, c2 from t1 order by c1 desc, c2 asc limit 5;
select c1, c2 from t2 order by c1 asc, c2 desc limit 5;
select /*+parallel(2)*/ c1, c2 from t1 order by c1 desc, c2 asc limit 5;
select /*+parallel(2)*/ c1, c2 from t2 order by c1 asc, c2 desc limit 5;

#left outjoin, pushdown topn filter to left table
explain basic select /*+leading(t1 t2)*/ t1.c1 from t1 left join t2 on t1.c1=t2.c1 order by t1.c1 limit 5;
explain basic select /*+leading(t1 t2)*/ t1.c2 from t1 left join t2 on t1.c1=t2.c1 order by t1.c2 limit 5;
explain basic select /*+leading(t1 t2) parallel(2)*/ t1.c1 from t1 left join t2 on t1.c1=t2.c1 order by t1.c1 desc limit 5;
explain basic select /*+leading(t1 t2) parallel(2)*/ t1.c2 from t1 left join t2 on t1.c1=t2.c1 order by t1.c2 desc limit 5;
select /*+leading(t1 t2)*/ t1.c1 from t1 left join t2 on t1.c1=t2.c1 order by t1.c1 limit 5;
select /*+leading(t1 t2)*/ t1.c2 from t1 left join t2 on t1.c1=t2.c1 order by t1.c2 limit 5;
select /*+leading(t1 t2) parallel(2)*/ t1.c1 from t1 left join t2 on t1.c1=t2.c1 order by t1.c1 desc limit 5;
select /*+leading(t1 t2) parallel(2)*/ t1.c2 from t1 left join t2 on t1.c1=t2.c1 order by t1.c2 desc limit 5;

#right outjoin, pushdown topn filter to right table
explain basic select /*+leading(t1 t2) no_rewrite*/ t2.c1 from t1 right join t2 on t1.c1=t2.c1 order by t2.c1 limit 5;
explain basic select /*+leading(t1 t2) no_rewrite*/ t2.c2 from t1 right join t2 on t1.c1=t2.c1 order by t2.c2 desc limit 5;
explain basic select /*+leading(t1 t2) no_rewrite parallel(2)*/ t2.c1 from t1 right join t2 on t1.c1=t2.c1 order by t2.c1 limit 5;
explain basic select /*+leading(t1 t2) no_rewrite parallel(2)*/ t2.c2 from t1 right join t2 on t1.c1=t2.c1 order by t2.c2 desc limit 5;
select /*+leading(t1 t2) no_rewrite*/ t2.c1 from t1 right join t2 on t1.c1=t2.c1 order by t2.c1 limit 5;
select /*+leading(t1 t2) no_rewrite*/ t2.c2 from t1 right join t2 on t1.c1=t2.c1 order by t2.c2 desc limit 5;
select /*+leading(t1 t2) no_rewrite parallel(2)*/ t2.c1 from t1 right join t2 on t1.c1=t2.c1 order by t2.c1 limit 5;
select /*+leading(t1 t2) no_rewrite parallel(2)*/ t2.c2 from t1 right join t2 on t1.c1=t2.c1 order by t2.c2 desc limit 5;

#inner join, sort key in left table
#hash join, can not pushdown topn filter to left table
#merge join, without topn sort operator
#nested loop join, if without exchange, can pushdown to the left table
explain basic select /*+leading(t1 t2) use_hash(t2) */ t1.c1 from t1 join t2 on t1.c1=t2.c1 order by t1.c1 limit 5;
explain basic select /*+leading(t1 t2) use_merge(t2) */ t1.c1 from t1 join t2 on t1.c1=t2.c1 order by t1.c1 desc limit 5;
explain basic select /*+leading(t1 t2) use_nl(t2) */ t1.c1 from t1 join t2 on t1.c1=t2.c1 order by t1.c1 desc limit 5;
explain basic select /*+leading(t1 t2) use_nl(t2) */ t1.c1 from t1 join t1 t2 on t1.c1=t2.c1 order by t1.c1 desc limit 5;
select /*+leading(t1 t2) use_hash(t2) */ t1.c1 from t1 join t2 on t1.c1=t2.c1 order by t1.c1 limit 5;
select /*+leading(t1 t2) use_merge(t2) */ t1.c1 from t1 join t2 on t1.c1=t2.c1 order by t1.c1 desc limit 5;
select /*+leading(t1 t2) use_nl(t2) */ t1.c1 from t1 join t2 on t1.c1=t2.c1 order by t1.c1 desc limit 5;
select /*+leading(t1 t2) use_nl(t2) */ t1.c1 from t1 join t1 t2 on t1.c1=t2.c1 order by t1.c1 desc limit 5;

#inner join, sort key in right table
#merge join, without topn sort operator
#hash join, pushdown topn filter to right table
#nested loop join, if without material in right table, can pushdown topn filter
explain basic select /*+leading(t1 t2) use_hash(t2) */ t2.c1 from t1 join t2 on t1.c1=t2.c1 order by t2.c1 limit 5;
explain basic select /*+leading(t1 t2) use_hash(t2) parallel(2) px_join_filter(t2) px_part_join_filter(t2) tracing(13)*/ t2.c1 from t1 join t2 on t1.c1=t2.c1 order by t2.c1 limit 5;
explain basic select /*+leading(t1 t2) use_merge(t2) */ t2.c1 from t1 join t2 on t1.c1=t2.c1 order by t2.c1 desc limit 5;
explain basic select /*+leading(t1 t2) use_nl(t2) */ t2.c1 from t1 join t2 on t1.c1=t2.c1 order by t2.c1 desc limit 5;
explain basic select /*+leading(t1 t3) use_nl(t3) */ t3.c1 from t1 join t3 on t1.c1=t3.c1 order by t3.c1 desc limit 5;
select /*+leading(t1 t2) use_hash(t2) */ t2.c1 from t1 join t2 on t1.c1=t2.c1 order by t2.c1 limit 5;
select /*+leading(t1 t2) use_merge(t2) */ t2.c1 from t1 join t2 on t1.c1=t2.c1 order by t2.c1 desc limit 5;
select /*+leading(t1 t2) use_nl(t2) */ t2.c1 from t1 join t2 on t1.c1=t2.c1 order by t2.c1 desc limit 5;
select /*+leading(t1 t3) use_nl(t3) */ t3.c1 from t1 join t3 on t1.c1=t3.c1 order by t3.c1 desc limit 5;

#group by is a block op, can not pushdown topn filter
explain basic select /*+USE_HASH_AGGREGATION*/ c1, count(c2) from t1 group by c1 order by c1 limit 5;

#merge distinct always has a sort below, so can not pushdown topn filter
explain basic select /*+ NO_USE_HASH_DISTINCT*/ distinct * from t1 order by c1 limit 5;
explain basic select /*+ NO_USE_HASH_DISTINCT*/ distinct * from t2 order by c1 limit 5;

#hash distinct, can pushdown topn filter
explain basic select /*+ USE_HASH_DISTINCT*/ distinct * from t1 order by c1 limit 5;
explain basic select /*+ USE_HASH_DISTINCT*/ distinct * from t2 order by c1 limit 5;
select /*+ USE_HASH_DISTINCT*/ distinct * from t1 order by c1 limit 5;
select /*+ USE_HASH_DISTINCT*/ distinct * from t2 order by c1 limit 5;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--disable_query_log
connection obsys;
--enable_query_log
--disable_warnings
alter system major freeze tenant sys;
--enable_warnings
--source mysql_test/include/wait_daily_merge.inc

connect (obmysql, $OBMYSQL_MS0, root, , test, $OBMYSQL_PORT);
--disable_query_log
connection obmysql;
--enable_query_log

#test column table, topn filter pushdown as white filter
explain basic select c1 from t4 order by c1 limit 5;
explain basic select c2 from t4 order by c2 desc limit 5;
select c1 from t4 order by c1 limit 5;
select c2 from t4 order by c2 desc limit 5;

# test t5 with all null
select c1 from t5 order by c1 limit 5;
select c1 from t5 order by c1 desc limit 5;

insert /*+query_timeout(1000000000)*/ into t5 select random(135), random(4512) from table(generator(500000));
--disable_query_log
connection obsys;
--enable_query_log
--disable_warnings
alter system major freeze tenant sys;
--enable_warnings
--source mysql_test/include/wait_daily_merge.inc

--disable_query_log
connection obmysql;
--enable_query_log

# test t5 with null and normal data
select c1 from t5 order by c1, c2 limit 5;
select c1 from t5 order by c1 desc, c2 limit 5;

--disable_warnings
drop table if exists t1,t2,t3,t4,t5;
--enable_warnings

create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create table t3(c1 int, c2 int);

insert into t1 select random(456)%10000, random(123)%10000 from table(generator(300));
insert into t2 select random(456)%10000, random(123)%10000 from table(generator(300));
insert into t3 select random(456)%10000, random(123)%10000 from table(generator(300));

explain basic SELECT count(*) FROM t3 WHERE t3.c1 IN (
  (SELECT t1.c1 FROM t1 WHERE c1 IN (
  	(SELECT t2.c1 FROM t2 ORDER BY t2.c1 limit 1),
    (SELECT t2.c2 FROM t2 ORDER BY t2.c1 limit 1),
    (SELECT t1.c1 FROM t1 WHERE t1.c2=t3.c2 limit 1))
  )
);

SELECT count(*) FROM t3 WHERE t3.c1 IN (
  (SELECT t1.c1 FROM t1 WHERE c1 IN (
  	(SELECT t2.c1 FROM t2 ORDER BY t2.c1 limit 1),
    (SELECT t2.c2 FROM t2 ORDER BY t2.c1 limit 1),
    (SELECT t1.c1 FROM t1 WHERE t1.c2=t3.c2 limit 1))
  )
);

explain basic select /*+OPT_PARAM('enable_topn_runtime_filter', 'FALSE')*/ * from t1 order by t1.c1 limit 10;
explain basic select /*+OPT_PARAM('enable_topn_runtime_filter', 'true')*/ * from t1 order by t1.c1 limit 10;

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

CREATE TABLE `t1` (
  `c1` bigint NOT NULL,
  `c2` bigint DEFAULT NULL,
  `c5` bigint GENERATED ALWAYS AS ((`c1` + `c2`)) VIRTUAL,
  KEY `das_keep_order_index_11` (`c5`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION HEAP 
 partition by hash(c1)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`);

insert into t1(c1, c2) select random(123) % 10000000000, random(456) % 10000000000 from table(generator(3000));
explain basic select /*+parallel(2)*/ c1, c5 from t1 where c5 > 10 order by c5 limit 10;
select /*+parallel(2)*/ c1, c5 from t1 where c5 > 10 order by c5 limit 10;
explain basic select /*+parallel(2)*/ c1, c2 from t1 where c2 > 10 order by if(c2 > 0, c2, -c2), pow(c1, 2) limit 10;

--disable_warnings
drop table if exists t1;
drop table if exists obright_part2;
--enable_warnings

CREATE TABLE `obright_part2` (
  `grp_id` bigint(20) NOT NULL,
  `v1` varchar(65536) DEFAULT NULL,
  `gen_v1` varchar(10) GENERATED ALWAYS AS (substr(`v1`,1,10)) VIRTUAL,
  KEY `obright_part10` (`gen_v1`) LOCAL
) partition by key(grp_id) partitions 2 WITH COLUMN GROUP(each column);

insert into obright_part2(grp_id, v1) select random(123), randstr(20, random(123)) from table(generator(10000));

drop table obright_part2;
