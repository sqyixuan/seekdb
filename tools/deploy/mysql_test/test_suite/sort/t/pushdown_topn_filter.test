#owner: zhouhaiyu.zhy
#owner group: SQL Executor Group
# tags: Executor
# desc: test pushdown topn runtime filter

--result_format 4

--disable_warnings
drop table if exists t1,t2,t3,t4,t5;
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int) partition by hash(c1) partitions 32;
create table t3(c1 int, c2 int, INDEX idx1 (c1));
create table t4(c1 int, c2 int) WITH COLUMN GROUP(all columns, each column);
create table t5(c1 bigint, c2 bigint) WITH COLUMN GROUP(all columns, each column);
--enable_warnings

