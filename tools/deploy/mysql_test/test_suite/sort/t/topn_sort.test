#排序键为数值类型
select * from ts;
select * from ts order by c_uint limit 10;
select * from ts order by c_double limit 10;
select * from ts order by c_double limit 4,5;
select * from ts order by c_dec limit 10;
select * from ts order by c_dec limit 10,1;
select * from ts order by c_double, c_dec limit 10;
select * from ts order by c_int, c_uint, c_double, c_dec limit 30000;
select * from ts order by c_int, c_uint, c_double, c_dec limit 30001;

#explain basic 
explain basic select * from ts order by c_uint limit 10;
explain basic select * from ts order by c_double limit 10;
explain basic select * from ts order by c_double limit 4,5;
explain basic select * from ts order by c_dec limit 10;
explain basic select * from ts order by c_dec limit 10,1;
explain basic select * from ts order by c_double, c_dec limit 10;
explain basic select * from ts order by c_int, c_uint, c_double, c_dec limit 30000;
explain basic select * from ts order by c_int, c_uint, c_double, c_dec limit 30001;

