--disable_warnings
drop table if exists ts;
--enable_warnings

--disable_warnings
drop table if exists bt;
--enable_warnings

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

create table bt(c1 int, c2 int, c3 int, primary key(c3));
insert into bt values
(-1, -1, 1), 
(-1, -1, 0),
(-2, -3, -4),
(-1, -1, 4),
(-3, -5, -6),
(-6, -2, -1),
(-2, -3, -2),
(-1, -3, 10);
--let $count=0
--let $total=1000
--let $v2 = 1000
--let $v3 = 1000
--disable_query_log
while($count < $total)
{     
    eval insert into bt values($count, $v2, $v3);
    inc $count;
    dec $v2;
    inc $v3;
}
--enable_query_log
sleep 10;
select count(1) from bt;
select * from bt order by c1 limit 10;
select * from bt order by c1,c2 limit 10;
select * from bt order by c2,c3 limit 10;
select * from bt order by c1,c2 limit 10,5;
explain basic select * from bt order by c1 limit 100;
explain basic select * from bt order by c1 limit 200;
explain basic select * from bt order by c1 limit 300;
explain basic select * from bt order by c1 limit 100, 10;
explain basic select * from bt order by c1 limit 200, 10;
explain basic select * from bt order by c1 limit 1000;

connection my_obsys;
alter system set enable_sql_operator_dump=True;
connection default;
sleep 2; # wait config synced

