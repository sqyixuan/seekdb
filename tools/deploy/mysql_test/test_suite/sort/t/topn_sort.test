--disable_warnings
DROP TABLE IF EXISTS `a`;
DROP TABLE IF EXISTS `cc`;
--enable_warnings
CREATE TABLE `a` (
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;

CREATE TABLE `cc` (
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;
INSERT INTO `cc` VALUES ('v','p','v','g',4,5,1,'o','v'),('f','h','w','y',7,0,2,'s','a'),('i','v',NULL,'b',4,6,3,'o','w'),(NULL,'t','d','r',5,8,4,'x','l'),('l',NULL,'t','p',7,8,5,'c','t'),('m','h','r','x',5,7,6,'f','a'),(NULL,'e','f',NULL,0,1,7,'j','m'),('b','j','b','p',8,2,8,NULL,'z'),(NULL,'c','s',NULL,NULL,NULL,9,'a','e'),('l',NULL,NULL,NULL,0,9,10,'s',NULL),(NULL,'h','q','b',NULL,8,11,'c','l'),('i','d','z','v',1,0,12,'l',NULL),(NULL,'r','t','o',4,1,13,'z','u'),('p',NULL,NULL,'s',4,7,14,'k','c'),('r',NULL,'f','h',0,NULL,15,'j','q'),(NULL,'m','n','c',1,7,16,'i','n'),('k','y','h',NULL,NULL,8,17,'y','i'),('d','h','w','b',1,5,18,'a','f'),(NULL,'q',NULL,NULL,NULL,9,19,'r','j'),('q','z','j','o',0,7,20,'j','s'),(NULL,'o','p','c',3,9,21,'k','o'),(NULL,'h','g','e',6,2,22,'f',NULL),('j','q','v',NULL,4,5,23,'t',NULL),('d',NULL,NULL,NULL,4,0,24,NULL,'v'),('i',NULL,'b','d',9,9,25,'e','x'),('i','u','v','c',NULL,0,26,NULL,'g'),('j','v','k',NULL,2,3,27,'h','f'),('j','b',NULL,NULL,8,3,28,'s','e'),('h',NULL,NULL,NULL,NULL,8,29,'l','z');

explain
SELECT table2 . col_varchar_key AS field1,
       table1 . col_varchar_20_key AS field2,
       table2 . col_varchar_20_key AS field3
FROM (A AS table1
      INNER JOIN A AS table2 ON (table2 . `col_varchar_key` = table1 . `col_varchar_key`))
WHERE ((table2 . `col_varchar_key`,
        table2 . `col_varchar_10_key`) IN
         (SELECT 'i',
                 'y'
          UNION SELECT 'm',
                       'w'))
  OR (table1 . `col_int_key` IN (54,
                                 1)
      OR table1 . `pk` BETWEEN 89 AND (89 + 95))
  AND (table1 . `col_varchar_key` !=
         (SELECT COUNT(SUBQUERY2_t2 . `col_varchar_10_key`) AS SUBQUERY2_field1
          FROM (CC AS SUBQUERY2_t1
                INNER JOIN (CC AS SUBQUERY2_t2
                            INNER JOIN CC AS SUBQUERY2_t3 ON (SUBQUERY2_t3 . `col_int_key` = SUBQUERY2_t2 . `col_int_key`)) ON (SUBQUERY2_t3 . `col_varchar_key` = SUBQUERY2_t2 . `col_varchar_key`)))
       AND table1 . `col_varchar_10_key` >= table2 . `col_varchar_20_key`)
HAVING field1 <> 3
ORDER BY 1,
         field1,
         field2,
         field3
LIMIT 1000
OFFSET 4;

SELECT table2 . col_varchar_key AS field1,
       table1 . col_varchar_20_key AS field2,
       table2 . col_varchar_20_key AS field3
FROM (A AS table1
      INNER JOIN A AS table2 ON (table2 . `col_varchar_key` = table1 . `col_varchar_key`))
WHERE ((table2 . `col_varchar_key`,
        table2 . `col_varchar_10_key`) IN
         (SELECT 'i',
                 'y'
          UNION SELECT 'm',
                       'w'))
  OR (table1 . `col_int_key` IN (54,
                                 1)
      OR table1 . `pk` BETWEEN 89 AND (89 + 95))
  AND (table1 . `col_varchar_key` !=
         (SELECT COUNT(SUBQUERY2_t2 . `col_varchar_10_key`) AS SUBQUERY2_field1
          FROM (CC AS SUBQUERY2_t1
                INNER JOIN (CC AS SUBQUERY2_t2
                            INNER JOIN CC AS SUBQUERY2_t3 ON (SUBQUERY2_t3 . `col_int_key` = SUBQUERY2_t2 . `col_int_key`)) ON (SUBQUERY2_t3 . `col_varchar_key` = SUBQUERY2_t2 . `col_varchar_key`)))
       AND table1 . `col_varchar_10_key` >= table2 . `col_varchar_20_key`)
HAVING field1 <> 3
ORDER BY 1,
         field1,
         field2,
         field3
LIMIT 1000
OFFSET 4;

