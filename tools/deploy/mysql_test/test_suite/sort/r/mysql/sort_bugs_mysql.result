drop table if exists t_ps_limit;
result_format: 4
create table t_ps_limit(a int, b int);
insert into t_ps_limit values(1, 1);

prepare stmt from 'select a, b from t_ps_limit order by a limit ?';
execute stmt using @ivar;
+------+------+
| a    | b    |
+------+------+
+------+------+

set @ivar = 1;
execute stmt using @ivar;
+------+------+
| a    | b    |
+------+------+
|    1 |    1 |
+------+------+

drop table if exists t_ps_limit;
