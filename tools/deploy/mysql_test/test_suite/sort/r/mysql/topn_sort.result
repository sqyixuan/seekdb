drop table if exists ts;
create table ts(
c_int int signed, 
c_uint int unsigned, 
c_double double, 
c_dec decimal(20, 10), 
c_dte datetime(6), 
c_tsp timestamp(6), 
c_dt date, 
c_time time,
c_year year,
c_var varchar(30),
c_char char(30),
PRIMARY KEY (c_int, c_double)
);
