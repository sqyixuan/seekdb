######################### 标签：digest-7-3 pl/sql - 触发器  ######################### 
DROP TRIGGER tri_digest;//
CREATE TRIGGER tri_digest BEFORE INSERT
ON digest_table1 FOR EACH ROW
BEGIN
	DECLARE a int default 21;
	-- 循环insert插入5条数据(21,22,23,24,25)，id=24数据delete删除，id=25数据update修改
	loop1: LOOP
	  if a < 26 then
	    INSERT INTO digest_table2 VALUES(a,'DROP TRIGGER tri_digest',statement_digest('DROP TRIGGER tri_digest'),statement_digest_text('DROP TRIGGER tri_digest'),concat('触发器中插入数据',a));
	  elseif a = 27 then
	    UPDATE digest_table2 set sqls = 'DELETE FROM t1 WHERE c1 = "jcole"',digest = statement_digest('DELETE FROM t1 WHERE c1 = "jcole"'),digest_text = statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole"'),comments = concat('触发器中修改数据',a-2) WHERE id = 25;
	    LEAVE loop1;
	  else
	    DELETE FROM digest_table2 WHERE id = 24;	
	  end if;
	  set a = a + 1;
	end LOOP loop1;
END;
//
SELECT COUNT(*)  FROM digest_table1 ORDER BY id;//
