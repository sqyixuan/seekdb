##包含inout参数的存储过程
DROP PROCEDURE p_digest;//
CREATE  PROCEDURE p_digest(INOUT inouta varchar(255),OUT outb varchar(200),OUT outc varchar(200))
begin
    declare invalue varchar(255);
	set invalue := inouta;
	SELECT id,statement_digest(sqls),statement_digest_text(sqls) into inouta,outb,outc FROM digest_table1 WHERE statement_digest_text(sqls) = invalue;
    INSERT INTO digest_table2 VALUES(40,'SELECT * FROM tl WHERE id < 20',statement_digest('SELECT * FROM tl WHERE id < 20'),statement_digest_text('SELECT * FROM tl WHERE id < 20'),'SELECT 语句');
END;
//
SELECT COUNT(*) FROM digest_table1;//
+----------+
| COUNT(*) |
+----------+
|        4 |
+----------+
SET @inouta := statement_digest_text('SELECT * FROM tl WHERE id < 1');//
CALL p_digest(@inouta,@outb,@outc);//
SELECT * FROM digest_table2 ORDER BY id;//
