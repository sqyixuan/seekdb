#自定义变量，全局变量，in 参数作为 statement_digest/statement_digest_text 函数的参数
DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest(IN inc varchar(200))
begin
  declare a varchar(200);
  SET a := 'DELETE FROM t1 WHERE c1 <= 10';
  INSERT INTO digest_table2 VALUES(81,statement_digest(a),statement_digest_text(a),statement_digest_text(a),'自定义变量作为语句摘要函数的参数');
  INSERT INTO digest_table2 VALUES(82,statement_digest(@b),statement_digest_text(@b),statement_digest_text(@b),'全局变量作为语句摘要函数的参数');
  INSERT INTO digest_table2 VALUES(83,statement_digest(inc),statement_digest_text(inc),statement_digest_text(inc),'形参变量作为语句摘要函数的参数');
END;
//
