######################### 标签：digest-7-2 pl/sql - 函数  #########################   
#定义一个无参的函数
drop function f_digest;//
CREATE FUNCTION f_digest() returns varchar(255) READS SQL DATA 
begin
	declare b varchar(255);
	SELECT sqls,statement_digest_text(sqls) into @a,b FROM digest_table1 WHERE statement_digest(sqls) = statement_digest('UPDATE t1 SET id = id + 1');
	return b;
END;
//
SELECT f_digest() FROM dual;//
+----------------------------+
| f_digest()                 |
+----------------------------+
| UPDATE T1 SET ID = ID + ?  |
+----------------------------+
SELECT statement_digest_text(@a) FROM dual;//
+----------------------------+
| statement_digest_text(@a)  |
+----------------------------+
| UPDATE T1 SET ID = ID + ?  |
+----------------------------+
#定义一个有参的函数
DROP FUNCTION f_digest;//
CREATE FUNCTION f_digest(invalue varchar(255)) returns varchar(255) READS SQL DATA 
begin
	declare a varchar(255);
	SELECT digest_text into a FROM digest_table2 WHERE digest = invalue;
	return a;
END ;
//
SELECT f_digest(statement_digest('SELECT * FROM tl WHERE id = 20'));//
+--------------------------------------------------------------+
| f_digest(statement_digest('SELECT * FROM tl WHERE id = 20')) |
+--------------------------------------------------------------+
| SELECT * FROM TL WHERE ID = ?                                |
+--------------------------------------------------------------+
##dml语句
#条件语句
DROP FUNCTION f_digest;//
CREATE FUNCTION f_digest(invalue varchar(255),ina varchar(255),inb varchar(255),inc varchar(255))returns varchar(200) DETERMINISTIC
begin
    IF statement_digest_text(invalue) = 'SELECT ?' THEN 
	   INSERT INTO digest_table1 VALUES(9,ina,'调用函数语句');
    ELSE
	   INSERT INTO digest_table2 VALUES(90,ina,inb,inc,'调用函数语句');
    END IF;
    return '函数执行成功';
END;
