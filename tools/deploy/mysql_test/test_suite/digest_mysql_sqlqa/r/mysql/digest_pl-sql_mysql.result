##游标
DROP PROCEDURE test_pro;//
CREATE PROCEDURE test_pro()
BEGIN
	DECLARE a,b,c varchar(255);
    DECLARE i int default 60;
	DECLARE done INT DEFAULT 0;
	DECLARE digest_cursor CURSOR FOR SELECT sqls,statement_digest(sqls),statement_digest_text(sqls) FROM digest_table1 WHERE id < 5 and statement_digest(sqls) <> 0 GROUP BY statement_digest_text(sqls) HAVING statement_digest_text(sqls) like '%?%';
	DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
	
	OPEN digest_cursor;
	FETCH digest_cursor INTO a,b,c;
	WHILE done<>1 DO
      INSERT INTO digest_table2 VALUES(i,a,b,c,'游标中数据');
      FETCH digest_cursor INTO a,b,c;
	  SET i := i+1;
	END WHILE;
	CLOSE digest_cursor;
END;
//
SELECT COUNT(*) FROM digest_table2;//
+----------+
| COUNT(*) |
+----------+
|       14 |
+----------+
CALL test_pro();//
