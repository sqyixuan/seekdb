DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest()
BEGIN
  SET @s = 'update digest_table2 set sqls = ?,digest=?, digest_text= ?,comments = ? WHERE digest = statement_digest(?)';
  PREPARE stmdigest_table1 FROM @s;
  SET @a = 'DELETE FROM t1 PARTITION (p0) WHERE c1 < 5*10';
  SET @b = statement_digest(@a);
  SET @c = statement_digest_text(@a);
  SET @d = 'PREPARE 动态sql - update 语句';
  SET @e = 'DELETE FROM t1 PARTITION (p0) WHERE c1 < 5';
  EXECUTE stmdigest_table1 USING @a,@b,@c,@d,@e;

  SET @s = 'SELECT * FROM digest_table2 WHERE digest_text = ?';
  PREPARE stmt2 FROM @s;
  SET @a = 'DELETE FROM t1 PARTITION (p0) WHERE c1 < ?*?';
  EXECUTE stmt2 USING @a; 
  
  SET @s = 'delete FROM digest_table1 WHERE statement_digest(sqls) = ?';
  PREPARE stmdigest_table1 FROM @s;
  SET @a = statement_digest('DELETE FROM t1 PARTITION (p0) WHERE c1 < 5');
  EXECUTE stmdigest_table1 USING @a;

  SET @s = 'SELECT id,sqls,statement_digest(sqls),statement_digest_text(sqls) FROM digest_table1 WHERE id = ?';
  PREPARE stmt2 FROM @s;
  SET @a = 7;
  EXECUTE stmt2 USING @a;  
END;
//
CALL p_digest();//
