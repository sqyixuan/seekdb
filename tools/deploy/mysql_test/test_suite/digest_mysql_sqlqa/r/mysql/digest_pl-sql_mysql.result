##动态sql
DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest()
BEGIN
  SET @s = 'INSERT INTO digest_table1 VALUES(7,?,?);';
  PREPARE stmdigest_table1 FROM @s;
  SET @a = 'DELETE FROM t1 PARTITION (p0) WHERE c1 < 5';
  SET @b = 'PREPARE 动态sql - add1';
  EXECUTE stmdigest_table1 USING @a,@b;

  SET @s = 'INSERT INTO digest_table2 VALUES(70,?,?,?,?);';
  PREPARE stmt2 FROM @s;
  SET @a = 'DELETE FROM t1 PARTITION (p0) WHERE c1 < 5';
  SET @b = statement_digest(@a);
  SET @c = statement_digest_text(@a);
  SET @d = 'PREPARE 动态sql - add1';
  EXECUTE stmt2 USING @a,@b,@c,@d;
END;
//
SELECT COUNT(*) FROM digest_table1 ORDER BY id;//
+----------+
| COUNT(*) |
+----------+
|        5 |
+----------+
SELECT COUNT(*) FROM digest_table2 ORDER BY id;//
+----------+
| COUNT(*) |
+----------+
|       16 |
+----------+
CALL p_digest();//
SELECT * FROM digest_table1 ORDER BY id;//
