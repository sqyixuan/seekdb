purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


-----------------------------------------------------------------------------------------------------------------
------------------------- 语句摘要函数-statement_digest(statement)/statement_digest_text(statement)-----------------
### 用例：compress-3 statement_digest(statement)/statement_digest_text(statement) - pl/sql
-----------------------------------------------------------------------------------------------------------------
DROP TABLE digest_table1;//
CREATE TABLE `digest_table1` (
  `id` varchar(255) PRIMARY KEY,
  `sqls` varchar(255)  NOT NULL  COMMENT 'SQL语句',
  `comments` varchar(255)
);//
INSERT INTO digest_table1 VALUES(1,'INSERT INTO t1 VALUES(15,25)','INSERT 语句');//
INSERT INTO digest_table1 VALUES(2,'DELETE FROM t1 WHERE c1 = "whh"','DELETE 语句');//
INSERT INTO digest_table1 VALUES(3,'UPDATE t1 SET id = id + 1','UPDATE 语句');//
INSERT INTO digest_table1 VALUES(4,'SELECT * FROM tl WHERE id < 20','SELECT 语句');//
DROP TABLE digest_table2;//
CREATE TABLE `digest_table2` (
  `id` varchar(255) PRIMARY KEY,
  `sqls` varchar(255)  NOT NULL COMMENT 'SQL语句',
  `digest` varchar(255) NOT NULL COMMENT 'SQL 语句的摘要哈希值',
  `digest_text` varchar(255) NOT NULL COMMENT 'SQL 语句对应的摘要文本',
  `comments` varchar(255)
);//
INSERT INTO digest_table2 VALUES(0,'SELECT * FROM tl WHERE id = 20',statement_digest('SELECT * FROM tl WHERE id = 20'),statement_digest_text('SELECT * FROM tl WHERE id = 20'),'默认初始数据：SELECT 语句');//
######################### 标签：digest-7-1 pl/sql - 存储过程  #########################   
##无参数的存储过程
DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest()
begin
	declare a varchar(255);
	declare b varchar(255);
	declare c varchar(255);
	declare d varchar(255);
	SELECT id,sqls,statement_digest(sqls),statement_digest_text(sqls) into a,b,c,d FROM digest_table1 WHERE statement_digest(sqls) = statement_digest('INSERT INTO t1 VALUES(15,25)');
    INSERT INTO digest_table2 VALUES(a,b,c,d,'INSERT 语句');
	INSERT INTO digest_table2 VALUES(10,'INSERT INTO t1 VALUES(15,25*4)',statement_digest('INSERT INTO t1 VALUES(15,25*4)'),statement_digest_text('INSERT INTO t1 VALUES(15,25*4)'),'INSERT 语句');
END;
//
SELECT COUNT(*) FROM digest_table2;//
+----------+
| COUNT(*) |
+----------+
|        1 |
+----------+
CALL p_digest();//
SELECT * FROM digest_table2 ORDER BY id;//
+----+--------------------------------+----------------------------------+--------------------------------------+------------------------------------+
| id | sqls                           | digest                           | digest_text                          | comments                           |
+----+--------------------------------+----------------------------------+--------------------------------------+------------------------------------+
| 0  | SELECT * FROM tl WHERE id = 20 | 42748D49D488DA1184E2174A5E001131 | SELECT * FROM TL WHERE ID = ?        | 默认初始数据：SELECT 语句          |
| 1  | INSERT INTO t1 VALUES(15,25)   | 0896093076902A887B06E3329D9AF69E | INSERT INTO T1 VALUES ( ? , ? )      | INSERT 语句                        |
| 10 | INSERT INTO t1 VALUES(15,25*4) | AE06BCEB7FDFE5E7BF260DB315B7F7E0 | INSERT INTO T1 VALUES ( ? , ? * ? )  | INSERT 语句                        |
+----+--------------------------------+----------------------------------+--------------------------------------+------------------------------------+
##只有一个in参数的存储过程
DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest(in invalue varchar(255))
begin
	declare a varchar(255);
	declare b varchar(255);
	declare c varchar(255);
	declare d varchar(255);
	SELECT id,sqls,statement_digest(sqls),statement_digest_text(sqls) into a,b,c,d FROM digest_table1 WHERE statement_digest(sqls) = invalue;
	INSERT INTO digest_table2 VALUES(a,b,c,d,'DELETE 语句');
	INSERT INTO digest_table2 VALUES(20,'DELETE FROM t1 WHERE c1 = "whh2"',statement_digest('DELETE FROM t1 WHERE c1 = "whh2"'),statement_digest_text('DELETE FROM t1 WHERE c1 = "whh2"'),'DELETE 语句');
END;
//
SELECT COUNT(*) FROM digest_table2;//
+----------+
| COUNT(*) |
+----------+
|        3 |
+----------+
CALL p_digest(statement_digest('DELETE FROM t1 WHERE c1 = "whh"'));//
SELECT * FROM digest_table2 ORDER BY id;//
+----+----------------------------------+----------------------------------+--------------------------------------+------------------------------------+
| id | sqls                             | digest                           | digest_text                          | comments                           |
+----+----------------------------------+----------------------------------+--------------------------------------+------------------------------------+
| 0  | SELECT * FROM tl WHERE id = 20   | 42748D49D488DA1184E2174A5E001131 | SELECT * FROM TL WHERE ID = ?        | 默认初始数据：SELECT 语句          |
| 1  | INSERT INTO t1 VALUES(15,25)     | 0896093076902A887B06E3329D9AF69E | INSERT INTO T1 VALUES ( ? , ? )      | INSERT 语句                        |
| 10 | INSERT INTO t1 VALUES(15,25*4)   | AE06BCEB7FDFE5E7BF260DB315B7F7E0 | INSERT INTO T1 VALUES ( ? , ? * ? )  | INSERT 语句                        |
| 2  | DELETE FROM t1 WHERE c1 = "whh"  | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ?          | DELETE 语句                        |
| 20 | DELETE FROM t1 WHERE c1 = "whh2" | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ?          | DELETE 语句                        |
+----+----------------------------------+----------------------------------+--------------------------------------+------------------------------------+
##包含out参数的存储过程
DROP PROCEDURE p_digest;//
CREATE  PROCEDURE p_digest(out outa varchar(255),OUT outb varchar(200),OUT outc varchar(200))
begin
    declare i int default 9;
	SELECT id,statement_digest(sqls),statement_digest_text(sqls) into outa,outb,outc FROM digest_table1 WHERE statement_digest_text(sqls) like '%UPDATE%';
	INSERT INTO digest_table2 VALUES(30,'UPDATE t1 SET id = id + 6',statement_digest('UPDATE t1 SET id = id + 6'),statement_digest_text('UPDATE t1 SET id = id + 6'),'UPDATE 语句');
END;
//
SELECT COUNT(*) FROM digest_table2;//
+----------+
| COUNT(*) |
+----------+
|        5 |
+----------+
CALL p_digest(@outa,@outb,@outc);//
SELECT * FROM digest_table2 ORDER BY id;//
+----+----------------------------------+----------------------------------+--------------------------------------+------------------------------------+
| id | sqls                             | digest                           | digest_text                          | comments                           |
+----+----------------------------------+----------------------------------+--------------------------------------+------------------------------------+
| 0  | SELECT * FROM tl WHERE id = 20   | 42748D49D488DA1184E2174A5E001131 | SELECT * FROM TL WHERE ID = ?        | 默认初始数据：SELECT 语句          |
| 1  | INSERT INTO t1 VALUES(15,25)     | 0896093076902A887B06E3329D9AF69E | INSERT INTO T1 VALUES ( ? , ? )      | INSERT 语句                        |
| 10 | INSERT INTO t1 VALUES(15,25*4)   | AE06BCEB7FDFE5E7BF260DB315B7F7E0 | INSERT INTO T1 VALUES ( ? , ? * ? )  | INSERT 语句                        |
| 2  | DELETE FROM t1 WHERE c1 = "whh"  | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ?          | DELETE 语句                        |
| 20 | DELETE FROM t1 WHERE c1 = "whh2" | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ?          | DELETE 语句                        |
| 30 | UPDATE t1 SET id = id + 6        | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ?            | UPDATE 语句                        |
+----+----------------------------------+----------------------------------+--------------------------------------+------------------------------------+
SELECT @outa,@outb,@outc FROM dual;//
+-------+----------------------------------+----------------------------+
| @outa | @outb                            | @outc                      |
+-------+----------------------------------+----------------------------+
| 3     | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ?  |
