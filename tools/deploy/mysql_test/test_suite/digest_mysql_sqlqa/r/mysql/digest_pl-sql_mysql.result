##函数返回值作为存储过程的参数传递
DROP FUNCTION f_digest;//
CREATE FUNCTION f_digest(insqls varchar(255)) RETURNS varchar(255) READS SQL DATA 
BEGIN
	declare b varchar(255);
	SELECT sqls,statement_digest(sqls) into @sqls,b FROM digest_table1 WHERE statement_digest(sqls) = insqls;
	RETURN b;
END;
//
DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest(in infun varchar(255))
begin
  	INSERT INTO digest_table2 VALUES(80,@sqls,infun,statement_digest_text(@sqls),'函数返回值作为存储过程的参数传递');
END;
