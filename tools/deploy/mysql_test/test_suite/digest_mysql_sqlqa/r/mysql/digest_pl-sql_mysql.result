#循环语句
DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest()
begin
    declare i int default 51;
    WHILE i <= 52 do
      INSERT INTO digest_table2 VALUES(i,'ALTER TABLE t1 COMMENT = "WHILE 循环语句插入的"',statement_digest('ALTER TABLE t1 COMMENT ="WHILE 循环语句插入的"'),statement_digest_text('ALTER TABLE t1 COMMENT ="WHILE 循环语句插入的"'),'ALTER 语句');
      set i := i+1;
    END WHILE;

    loop_sqls:LOOP
      INSERT INTO digest_table2 VALUES(i,'ALTER TABLE t1 COMMENT ="LOOP 循环语句插入的"',statement_digest('ALTER TABLE t1 COMMENT ="LOOP 循环语句插入的"'),statement_digest_text('ALTER TABLE t1 COMMENT ="LOOP 循环语句插入的"'),'ALTER 语句');
      SET i := i+1;
      IF i > 54 THEN 
	    LEAVE loop_sqls;
      END IF;
    END LOOP loop_sqls;

    REPEAT
      INSERT INTO digest_table2 VALUES(i,'ALTER TABLE t1 COMMENT ="REPEAT 循环语句插入的"',statement_digest('ALTER TABLE t1 COMMENT ="REPEAT 循环语句插入的"'),statement_digest_text('ALTER TABLE t1 COMMENT ="REPEAT 循环语句插入的"'),'ALTER 语句');
      SET i := i+1;
      until i > 56	
    END REPEAT;
END;
//
SELECT COUNT(*) FROM digest_table2;//
+----------+
| COUNT(*) |
+----------+
|        8 |
+----------+
CALL p_digest();//
