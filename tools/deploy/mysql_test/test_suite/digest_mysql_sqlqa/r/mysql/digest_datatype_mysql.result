######################### 标签：digest-2-2 参数类型 - 字符串类型 #########################
DROP TABLE digest_table1;
CREATE TABLE digest_table1( 
  c1 CHAR(200), 
  c2 VARCHAR(200), 
  c3 BLOB(200), 
  c4 TEXT, 
  c5 BINARY(200),
  c6 VARBINARY(200), 
  c7 ENUM('','INSERT INTO t1(col1,col2) VALUES(15,col1*2)', 'DELETE FROM t1 WHERE c1 = "jcole" ORDER BY c2 LIMIT 1', 'UPDATE t1 SET id = id + 1 ORDER BY id DESC LIMIT 10', 'SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2 LIMIT 1,5'), 
  c8 SET('','INSERT INTO t2 VALUES(col1*3)','DELETE FROM t2 WHERE c1 = "jcole" ORDER BY c2 LIMIT 2','UPDATE t2 SET id = id + 3 ORDER BY id DESC LIMIT 20','SELECT * FROM t2 WHERE id >= 20 ORDER BY c1 LIMIT 5')
)default character set = 'utf8mb4';
## 没有插入数据场合
select statement_digest(c1) digest,statement_digest_text(c1) digest_text from digest_table1;
