######################### 标签：digest-6-3 约束 #########################
DROP TABLE digest_table1;
CREATE TABLE `digest_table1` (
  `id` int PRIMARY KEY,
  `sqls` varchar(255)  NOT NULL,
  `digest` varchar(255) UNIQUE,
  `digest_text` varchar(255) NOT NULL
);
#insert 
INSERT INTO digest_table1 VALUES(1,'INSERT INTO t1 VALUES(15,25)',statement_digest('INSERT INTO t1 VALUES(15,25)'),statement_digest_text('INSERT INTO t1 VALUES(15,25)'));
INSERT INTO digest_table1 VALUES(2,'DELETE FROM t1 WHERE c1 = "whh"',statement_digest('DELETE FROM t1 WHERE c1 = "whh"'),statement_digest_text('DELETE FROM t1 WHERE c1 = "whh"'));
INSERT INTO digest_table1 VALUES(3,'UPDATE t1 SET id = id + 1',statement_digest('UPDATE t1 SET id = id + 1'),statement_digest_text('UPDATE t1 SET id = id + 1'));
INSERT INTO digest_table1 VALUES(4,'SELECT * FROM tl WHERE id < 20',statement_digest('SELECT * FROM tl WHERE id < 20'),statement_digest_text('SELECT * FROM tl WHERE id < 20'));
SELECT * FROM digest_table1 ORDER BY id;
