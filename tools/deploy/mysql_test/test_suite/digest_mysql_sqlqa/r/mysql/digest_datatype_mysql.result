| statement_digest_text(c2)                               | id   | c2                                                     |
+---------------------------------------------------------+------+--------------------------------------------------------+
| INSERT INTO T1 ( COL1 , COL2 ) VALUES ( ? , COL1 * ? )  |    1 | INSERT INTO t1(col1,col2) VALUES(16,col1*3)            |
| DELETE FROM T1 WHERE C1 = ? ORDER BY C2 , C3 LIMIT ?    |    2 | DELETE FROM t1 WHERE c1 = "whh" ORDER BY c2,c3 LIMIT 2 |
| UPDATE T1 SET ID = ID + ? ORDER BY ID DESC LIMIT ?      |    3 | UPDATE t1 SET id = id + 1 ORDER BY id DESC LIMIT 4     |
+---------------------------------------------------------+------+--------------------------------------------------------+
#CASE WHEN
SELECT id,statement_digest(CASE WHEN c1 IS NULL THEN c2 ELSE c1 END) digest,statement_digest_text(CASE WHEN c1 IS NULL THEN c2 ELSE c1 END) digest_text FROM t1_view  ORDER BY id;
+------+----------------------------------+--------------------------------------------------+
| id   | digest                           | digest_text                                      |
+------+----------------------------------+--------------------------------------------------+
|    1 | 77B68119B2484298E19F6CFB653B54A2 | INSERT INTO T1 ( COL1 , COL2 ) VALUES ( ? , ? )  |
|    2 | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ?                      |
|    3 | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ?                        |
+------+----------------------------------+--------------------------------------------------+
SELECT id,CASE WHEN statement_digest(c1)= statement_digest('DELETE FROM t1 WHERE c1 = "whh"') THEN 'id=2的statement_digest（c1列）'  ELSE '其他列' END digest FROM t1_view ORDER BY id;
+------+------------------------------------+
| id   | digest                             |
+------+------------------------------------+
|    1 | 其他列                             |
|    2 | id=2的statement_digest（c1列）     |
|    3 | 其他列                             |
+------+------------------------------------+
SELECT id,CASE WHEN statement_digest_text(c2) LIKE '%INSERT%' THEN 'id=1的 statement_digest_text（c2列）' ELSE '其他列' END digest FROM t1_view ORDER BY id;
+------+------------------------------------------+
| id   | digest                                   |
+------+------------------------------------------+
|    1 | id=1的 statement_digest_text（c2列）     |
|    2 | 其他列                                   |
|    3 | 其他列                                   |
+------+------------------------------------------+
##连接查询
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e, t2_view p WHERE e.id = p.id ORDER BY e.id;
+------+----------------------------------+-------------------------------------------------------+
| id   | digest                           | digest_text                                           |
+------+----------------------------------+-------------------------------------------------------+
|    2 | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ? ORDER BY C2 , C3 LIMIT ?  |
|    3 | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ? ORDER BY ID DESC LIMIT ?    |
+------+----------------------------------+-------------------------------------------------------+
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e LEFT JOIN t2_view p ON e.id = p.id ORDER BY e.id;
+------+----------------------------------+---------------------------------------------------------+
| id   | digest                           | digest_text                                             |
+------+----------------------------------+---------------------------------------------------------+
|    1 | 77B68119B2484298E19F6CFB653B54A2 | INSERT INTO T1 ( COL1 , COL2 ) VALUES ( ? , COL1 * ? )  |
|    2 | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ? ORDER BY C2 , C3 LIMIT ?    |
|    3 | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ? ORDER BY ID DESC LIMIT ?      |
+------+----------------------------------+---------------------------------------------------------+
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e RIGHT JOIN t2_view p ON e.id = p.id ORDER BY e.id;
+------+----------------------------------+-------------------------------------------------------+
| id   | digest                           | digest_text                                           |
+------+----------------------------------+-------------------------------------------------------+
| NULL | NULL                             | NULL                                                  |
|    2 | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ? ORDER BY C2 , C3 LIMIT ?  |
|    3 | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ? ORDER BY ID DESC LIMIT ?    |
+------+----------------------------------+-------------------------------------------------------+
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e INNER JOIN t2_view p ON e.id = p.id WHERE statement_digest_text(e.c2) LIKE '%+%'  ORDER BY e.id;
+------+----------------------------------+-----------------------------------------------------+
| id   | digest                           | digest_text                                         |
+------+----------------------------------+-----------------------------------------------------+
|    3 | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ? ORDER BY ID DESC LIMIT ?  |
+------+----------------------------------+-----------------------------------------------------+
##SELECT嵌套
#SELECT
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM (SELECT id,c1,c2 FROM t1_view WHERE statement_digest_text(c2) LIKE '%+%') e ORDER BY e.id;
+------+----------------------------------+-----------------------------------------------------+
| id   | digest                           | digest_text                                         |
+------+----------------------------------+-----------------------------------------------------+
|    3 | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ? ORDER BY ID DESC LIMIT ?  |
+------+----------------------------------+-----------------------------------------------------+
#EXISTS / NOT EXISTS
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e WHERE EXISTS (SELECT statement_digest(p.c1) FROM t2_view p WHERE statement_digest(p.c1) like '%5F%' ) ORDER BY e.id;
+------+----------------------------------+---------------------------------------------------------+
| id   | digest                           | digest_text                                             |
+------+----------------------------------+---------------------------------------------------------+
|    1 | 77B68119B2484298E19F6CFB653B54A2 | INSERT INTO T1 ( COL1 , COL2 ) VALUES ( ? , COL1 * ? )  |
|    2 | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ? ORDER BY C2 , C3 LIMIT ?    |
|    3 | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ? ORDER BY ID DESC LIMIT ?      |
+------+----------------------------------+---------------------------------------------------------+
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t2_view e WHERE NOT EXISTS (SELECT statement_digest(p.id) FROM t2_view p WHERE statement_digest_text(p.c2)  like '%drop%' ) ORDER BY e.id;
+------+----------------------------------+-------------------------------------------------------------+
| id   | digest                           | digest_text                                                 |
+------+----------------------------------+-------------------------------------------------------------+
|    2 | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ? ORDER BY C2 , C3 LIMIT ?        |
|    3 | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ? ORDER BY ID DESC LIMIT ?          |
|    4 | F7A3D808C12C7E7E2392FCE142467F9D | SELECT * FROM TL WHERE ID < ? ORDER BY C1 , C2 LIMIT ? , ?  |
+------+----------------------------------+-------------------------------------------------------------+
#ANY
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e WHERE statement_digest(e.c1) = ANY (SELECT statement_digest(p.c1) FROM t2_view p) ORDER BY e.id;
+------+----------------------------------+-------------------------------------------------------+
| id   | digest                           | digest_text                                           |
+------+----------------------------------+-------------------------------------------------------+
|    2 | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ? ORDER BY C2 , C3 LIMIT ?  |
|    3 | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ? ORDER BY ID DESC LIMIT ?    |
+------+----------------------------------+-------------------------------------------------------+
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e WHERE statement_digest_text(e.c2) < ANY (SELECT statement_digest_text(p.c2) FROM t2_view p) ORDER BY e.id;
+------+----------------------------------+---------------------------------------------------------+
| id   | digest                           | digest_text                                             |
+------+----------------------------------+---------------------------------------------------------+
|    1 | 77B68119B2484298E19F6CFB653B54A2 | INSERT INTO T1 ( COL1 , COL2 ) VALUES ( ? , COL1 * ? )  |
|    2 | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ? ORDER BY C2 , C3 LIMIT ?    |
+------+----------------------------------+---------------------------------------------------------+
#ALL 
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e WHERE statement_digest(e.c1) = ALL (SELECT statement_digest(p.c1) FROM t2_view p WHERE p.id = 1) ORDER BY e.id;
+------+----------------------------------+---------------------------------------------------------+
| id   | digest                           | digest_text                                             |
+------+----------------------------------+---------------------------------------------------------+
|    1 | 77B68119B2484298E19F6CFB653B54A2 | INSERT INTO T1 ( COL1 , COL2 ) VALUES ( ? , COL1 * ? )  |
|    2 | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ? ORDER BY C2 , C3 LIMIT ?    |
|    3 | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ? ORDER BY ID DESC LIMIT ?      |
+------+----------------------------------+---------------------------------------------------------+
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e WHERE statement_digest_text(e.c2) <= ALL (SELECT statement_digest_text(p.c2) FROM t2_view p WHERE p.id <= 3) ORDER BY e.id;
+------+----------------------------------+-------------------------------------------------------+
| id   | digest                           | digest_text                                           |
+------+----------------------------------+-------------------------------------------------------+
|    2 | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ? ORDER BY C2 , C3 LIMIT ?  |
+------+----------------------------------+-------------------------------------------------------+
#CREATE AS 
CREATE VIEW t3_view AS SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e;
SELECT * FROM t3_view ORDER BY id;
+------+----------------------------------+---------------------------------------------------------+
| id   | digest                           | digest_text                                             |
+------+----------------------------------+---------------------------------------------------------+
|    1 | 77B68119B2484298E19F6CFB653B54A2 | INSERT INTO T1 ( COL1 , COL2 ) VALUES ( ? , COL1 * ? )  |
|    2 | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ? ORDER BY C2 , C3 LIMIT ?    |
|    3 | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ? ORDER BY ID DESC LIMIT ?      |
+------+----------------------------------+---------------------------------------------------------+
#WITH AS的SELECT
WITH a AS (SELECT id,c1,statement_digest(c1) digest FROM t1_view WHERE id<3) SELECT a.id,a.c1,a.digest FROM a ORDER BY a.id;
+------+-----------------------------------------+----------------------------------+
| id   | c1                                      | digest                           |
+------+-----------------------------------------+----------------------------------+
|    1 | INSERT INTO t1(col1,col2) VALUES(15,25) | 77B68119B2484298E19F6CFB653B54A2 |
|    2 | DELETE FROM t1 WHERE c1 = "whh"         | A66D5C4325D82467E443039AAED826F1 |
+------+-----------------------------------------+----------------------------------+
WITH a AS (SELECT id,c1,statement_digest_text(c2) digest_text FROM t1_view WHERE id<4) SELECT a.id,a.c1,a.digest_text FROM a ORDER BY a.id;
+------+-----------------------------------------+---------------------------------------------------------+
| id   | c1                                      | digest_text                                             |
+------+-----------------------------------------+---------------------------------------------------------+
|    1 | INSERT INTO t1(col1,col2) VALUES(15,25) | INSERT INTO T1 ( COL1 , COL2 ) VALUES ( ? , COL1 * ? )  |
|    2 | DELETE FROM t1 WHERE c1 = "whh"         | DELETE FROM T1 WHERE C1 = ? ORDER BY C2 , C3 LIMIT ?    |
|    3 | UPDATE t1 SET id = id + 1               | UPDATE T1 SET ID = ID + ? ORDER BY ID DESC LIMIT ?      |
+------+-----------------------------------------+---------------------------------------------------------+
#模糊查询like 
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e WHERE statement_digest(e.c1) LIKE '%B%' ORDER BY e.id;
+------+----------------------------------+---------------------------------------------------------+
| id   | digest                           | digest_text                                             |
+------+----------------------------------+---------------------------------------------------------+
|    1 | 77B68119B2484298E19F6CFB653B54A2 | INSERT INTO T1 ( COL1 , COL2 ) VALUES ( ? , COL1 * ? )  |
|    3 | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ? ORDER BY ID DESC LIMIT ?      |
+------+----------------------------------+---------------------------------------------------------+
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e WHERE statement_digest_text(e.c2) NOT LIKE '%alter%' ORDER BY e.id;
+------+----------------------------------+---------------------------------------------------------+
| id   | digest                           | digest_text                                             |
+------+----------------------------------+---------------------------------------------------------+
|    1 | 77B68119B2484298E19F6CFB653B54A2 | INSERT INTO T1 ( COL1 , COL2 ) VALUES ( ? , COL1 * ? )  |
|    2 | A66D5C4325D82467E443039AAED826F1 | DELETE FROM T1 WHERE C1 = ? ORDER BY C2 , C3 LIMIT ?    |
|    3 | 83091A9F378BA243C82A390F5F7BBB77 | UPDATE T1 SET ID = ID + ? ORDER BY ID DESC LIMIT ?      |
+------+----------------------------------+---------------------------------------------------------+
### update
UPDATE t1_view SET c1 = 'INSERT INTO t1 VALUES(15,25,35)' WHERE statement_digest(c1) = statement_digest('INSERT INTO t1(col1,col2) VALUES(15,25)');
UPDATE t1_view SET c2 = 'INSERT INTO t1(col1,col2) VALUES(16,col1*3/4)' WHERE statement_digest_text(c2) like '%*%' ORDER BY statement_digest_text(c2) DESC;
UPDATE t1_view SET c1 = 'UPDATE t1 SET id = id * 2' WHERE id = (SELECT id FROM t2_view WHERE statement_digest_text(c1) like '%+%');
SELECT id,c1,c2 FROM t1_view ORDER BY id;
+------+---------------------------------+--------------------------------------------------------+
| id   | c1                              | c2                                                     |
+------+---------------------------------+--------------------------------------------------------+
|    1 | INSERT INTO t1 VALUES(15,25,35) | INSERT INTO t1(col1,col2) VALUES(16,col1*3/4)          |
|    2 | DELETE FROM t1 WHERE c1 = "whh" | DELETE FROM t1 WHERE c1 = "whh" ORDER BY c2,c3 LIMIT 2 |
|    3 | UPDATE t1 SET id = id * 2       | UPDATE t1 SET id = id + 1 ORDER BY id DESC LIMIT 4     |
+------+---------------------------------+--------------------------------------------------------+
###delete
SELECT * FROM  t2_view ORDER BY id;
+------+---------------------------------+----------------------------------------------------------+
| id   | c1                              | c2                                                       |
+------+---------------------------------+----------------------------------------------------------+
|    2 | DELETE FROM t1 WHERE c1 = "whh" | DELETE FROM t1 WHERE c1 = "whh" ORDER BY c2,c3 LIMIT 2   |
|    3 | UPDATE t1 SET id = id * 2       | UPDATE t1 SET id = id + 1 ORDER BY id DESC LIMIT 4       |
|    4 | SELECT * FROM tl WHERE id < 20  | SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2 LIMIT 6,10 |
+------+---------------------------------+----------------------------------------------------------+
DELETE FROM t2_view WHERE statement_digest(c1) = statement_digest('DELETE FROM t1 WHERE c1 = "whh"') ORDER BY statement_digest(c1);
DELETE FROM t2_view WHERE statement_digest_text(c2) LIKE '%<%' ORDER BY statement_digest(c1);
SELECT * FROM  t2_view ORDER BY id;
+------+---------------------------+----------------------------------------------------+
| id   | c1                        | c2                                                 |
+------+---------------------------+----------------------------------------------------+
|    3 | UPDATE t1 SET id = id * 2 | UPDATE t1 SET id = id + 1 ORDER BY id DESC LIMIT 4 |
+------+---------------------------+----------------------------------------------------+
