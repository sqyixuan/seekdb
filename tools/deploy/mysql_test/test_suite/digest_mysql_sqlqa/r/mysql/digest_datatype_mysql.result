## 插入一条数据 场合
delete from digest_table1;
insert into digest_table1 values(
'INSERT INTO t1(col1,col2) VALUES(15,col1*2)',
'DELETE FROM t1 WHERE c1 = "jcole" ORDER BY c2 LIMIT 1',
'UPDATE t1 SET id = id + 1 ORDER BY id DESC LIMIT 10',
'SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2 LIMIT 5,10',
'SELECT SLEEP(5)',
'DROP DATABASE test_db1',
'INSERT INTO t1(col1,col2) VALUES(15,col1*2)',
'INSERT INTO t2 VALUES(col1*3)');
select statement_digest(c1) digest,statement_digest_text(c1) digest_text from digest_table1;
+----------------------------------+---------------------------------------------------------+
| digest                           | digest_text                                             |
+----------------------------------+---------------------------------------------------------+
| 07E12363E5475E5AEC1DA3EFEE6F2B8B | INSERT INTO T1 ( COL1 , COL2 ) VALUES ( ? , COL1 * ? )  |
+----------------------------------+---------------------------------------------------------+
select statement_digest(c2) digest,statement_digest_text(c2) digest_text from digest_table1;
+----------------------------------+--------------------------------------------------+
| digest                           | digest_text                                      |
+----------------------------------+--------------------------------------------------+
| 6B45C7E521D4182703BE53509A6731BC | DELETE FROM T1 WHERE C1 = ? ORDER BY C2 LIMIT ?  |
+----------------------------------+--------------------------------------------------+
select statement_digest(c3) digest,statement_digest_text(c3) digest_text from digest_table1;
+----------------------------------+-----------------------------------------------------+
| digest                           | digest_text                                         |
+----------------------------------+-----------------------------------------------------+
| 5FBBFF977811F90EEAFF001C2CE56851 | UPDATE t1 SET id = id + ? ORDER BY id DESC LIMIT ?  |
+----------------------------------+-----------------------------------------------------+
select statement_digest(c4) digest,statement_digest_text(c4) digest_text from digest_table1;
+----------------------------------+-------------------------------------------------------------+
| digest                           | digest_text                                                 |
+----------------------------------+-------------------------------------------------------------+
| 976130B3FF574FA174F8FB8A533D9D68 | SELECT * FROM TL WHERE ID < ? ORDER BY C1 , C2 LIMIT ? , ?  |
+----------------------------------+-------------------------------------------------------------+
select statement_digest(REPLACE(c5,'\0','')) digest,statement_digest_text(REPLACE(c5,'\0','')) digest_text from digest_table1;
+----------------------------------+---------------------+
| digest                           | digest_text         |
+----------------------------------+---------------------+
| BC6BB61A683C1D9B9AB98AAC8BF13C09 | SELECT SLEEP ( ? )  |
+----------------------------------+---------------------+
select statement_digest(c6) digest,statement_digest_text(c6) digest_text from digest_table1;
+----------------------------------+------------------------+
| digest                           | digest_text            |
+----------------------------------+------------------------+
| 3F33C9E4025D4FAAAD44C1396FD9C4F0 | DROP DATABASE test_db1 |
+----------------------------------+------------------------+
select statement_digest(c7) digest,statement_digest_text(c7) digest_text from digest_table1;
+----------------------------------+---------------------------------------------------------+
| digest                           | digest_text                                             |
+----------------------------------+---------------------------------------------------------+
| 07E12363E5475E5AEC1DA3EFEE6F2B8B | INSERT INTO T1 ( COL1 , COL2 ) VALUES ( ? , COL1 * ? )  |
+----------------------------------+---------------------------------------------------------+
select statement_digest(c8) digest,statement_digest_text(c8) digest_text from digest_table1;
+----------------------------------+-------------------------------------+
| digest                           | digest_text                         |
+----------------------------------+-------------------------------------+
| 0695F8B3C30CBB4EF26B9793C330F44A | INSERT INTO T2 VALUES ( COL1 * ? )  |
+----------------------------------+-------------------------------------+
