------------------------- 语句摘要函数-statement_digest(statement)/statement_digest_text(statement)--------------
###### 标签：digest-2 statement_digest(statement)/statement_digest_text(statement) - 参数类型 
-----------------------------------------------------------------------------------------------------------------
######################### 标签：digest-2-1 参数类型 - 数值类型 #########################
DROP TABLE digest_table1;
CREATE TABLE digest_table1( 
  c1 tinyint, 
  c2 smallint,
  c3 mediumint, 
  c4 int, 
  c5 bigint, 
  c6 float, 
  c7 double, 
  c8 DECIMAL(5,2), 
  c9 bit(10)
);
## 没有插入数据场合
select statement_digest(c1) digest,statement_digest_text(c1) digest_text from digest_table1;
