## CREATE TABLE 语句
set @sqlstr1='CREATE TABLE t1 (id INT(21) NOT NULL AUTO_INCREMENT PRIMARY KEY, c1 VARCHAR(25), c2 DATE, c3 BLOB, INDEX(c3(10)))';
set @sqlstr2='CREATE TEMPORARY TABLE t2 SELECT * FROM t1 LIMIT 0';
set @sqlstr3='CREATE TABLE t3 LIKE t1';
set @sqlstr4='CREATE TABLE t4 AS SELECT * FROM t1 LIMIT 0';
select statement_digest(@sqlstr1) digest from dual;
