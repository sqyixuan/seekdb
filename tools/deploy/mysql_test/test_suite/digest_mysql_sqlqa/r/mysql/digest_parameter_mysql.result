| digest_text                                        |
+----------------------------------------------------+
| CREATE TEMPORARY TABLE t2 SELECT * FROM t1 LIMIT 0 |
+----------------------------------------------------+
select statement_digest_text(@sqlstr3) digest_text from dual;
