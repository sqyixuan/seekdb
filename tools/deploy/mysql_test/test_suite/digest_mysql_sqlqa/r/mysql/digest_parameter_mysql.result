| digest_text                                                                                                                                                                                                    |
+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| UPDATE ITEMS , ( SELECT ID FROM ITEMS WHERE ID IN ( SELECT ID FROM ITEMS WHERE RETAIL / WHOLESALE > = ? AND QUANTITY < ? ) ) AS DISCOUNTED SET ITEMS.RETAIL = ITEMS.RETAIL * ? WHERE ITEMS.ID = DISCOUNTED.ID  |
+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
## WITH (公用表表达式)
select statement_digest('WITH cte1 AS (SELECT a, b FROM table1), cte2 AS (SELECT c, d FROM table2) SELECT b, d FROM cte1 JOIN cte2 WHERE cte1.a = cte2.c') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| 37BCEEC6B209F46AB8AD55362DDC0343 |
+----------------------------------+
select statement_digest('WITH cte (col1, col2) AS(SELECT 1, 2 UNION ALL SELECT 3, 4)SELECT col1, col2 FROM cte') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| 62B0FD223BD1E986C6ED856FCD948583 |
+----------------------------------+
select statement_digest('WITH cte1 AS (SELECT 1) SELECT * FROM (WITH cte2 AS (SELECT 2) SELECT * FROM cte2 JOIN cte1) AS dt') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| A8CA1AED11C130F1A8D13025BFD5B9F2 |
+----------------------------------+
select statement_digest('WITH cte1 AS (SELECT 1) SELECT * FROM (WITH cte2 AS (SELECT 2) SELECT * FROM cte2 JOIN cte1) AS dt') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| A8CA1AED11C130F1A8D13025BFD5B9F2 |
+----------------------------------+
select statement_digest('WITH RECURSIVE cte (n) AS(SELECT 1 UNION ALL SELECT n + 1 FROM cte WHERE n < 5)SELECT * FROM cte') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| 224287CB12BA6B0CE0A45FB2985CBBFB |
+----------------------------------+
select statement_digest_text('WITH cte1 AS (SELECT a, b FROM table1), cte2 AS (SELECT c, d FROM table2) SELECT b, d FROM cte1 JOIN cte2 WHERE cte1.a = cte2.c') digest_text from dual;
+------------------------------------------------------------------------------------------------------------------------------------------+
| digest_text                                                                                                                              |
+------------------------------------------------------------------------------------------------------------------------------------------+
| WITH CTE1 AS ( SELECT A , B FROM TABLE1 ) , CTE2 AS ( SELECT C , D FROM TABLE2 ) SELECT B , D FROM CTE1 JOIN CTE2 WHERE CTE1.A = CTE2.C  |
+------------------------------------------------------------------------------------------------------------------------------------------+
select statement_digest_text('WITH cte (col1, col2) AS(SELECT 1, 2 UNION ALL SELECT 3, 4)SELECT col1, col2 FROM cte') digest_text from dual;
+--------------------------------------------------------------------------------------------------+
| digest_text                                                                                      |
+--------------------------------------------------------------------------------------------------+
| WITH CTE ( COL1 , COL2 ) AS ( SELECT ? , ? UNION ALL SELECT ? , ? ) SELECT COL1 , COL2 FROM CTE  |
+--------------------------------------------------------------------------------------------------+
select statement_digest_text('WITH cte1 AS (SELECT 1) SELECT * FROM (WITH cte2 AS (SELECT 2) SELECT * FROM cte2 JOIN cte1) AS dt') digest_text from dual;
+-----------------------------------------------------------------------------------------------------------+
| digest_text                                                                                               |
+-----------------------------------------------------------------------------------------------------------+
| WITH CTE1 AS ( SELECT ? ) SELECT * FROM ( WITH CTE2 AS ( SELECT ? ) SELECT * FROM CTE2 JOIN CTE1 ) AS DT  |
+-----------------------------------------------------------------------------------------------------------+
select statement_digest_text('WITH cte1 AS (SELECT 1) SELECT * FROM (WITH cte2 AS (SELECT 2) SELECT * FROM cte2 JOIN cte1) AS dt') digest_text from dual;
+-----------------------------------------------------------------------------------------------------------+
| digest_text                                                                                               |
+-----------------------------------------------------------------------------------------------------------+
| WITH CTE1 AS ( SELECT ? ) SELECT * FROM ( WITH CTE2 AS ( SELECT ? ) SELECT * FROM CTE2 JOIN CTE1 ) AS DT  |
+-----------------------------------------------------------------------------------------------------------+
select statement_digest_text('WITH RECURSIVE cte (n) AS(SELECT 1 UNION ALL SELECT n + 1 FROM cte WHERE n < 5)SELECT * FROM cte') digest_text from dual;
+---------------------------------------------------------------------------------------------------------+
| digest_text                                                                                             |
+---------------------------------------------------------------------------------------------------------+
| WITH RECURSIVE CTE ( N ) AS ( SELECT ? UNION ALL SELECT N + ? FROM CTE WHERE N < ? ) SELECT * FROM CTE  |
+---------------------------------------------------------------------------------------------------------+
