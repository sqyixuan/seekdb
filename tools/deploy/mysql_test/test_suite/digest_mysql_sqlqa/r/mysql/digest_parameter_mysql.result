| digest                           |
+----------------------------------+
| F6B2AEE349ACD597E705230A0CDF8A65 |
+----------------------------------+
select statement_digest(@sqlstr2) digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| D0B79B3F7DA184C3FF5DD38574BBC387 |
+----------------------------------+
select statement_digest(@sqlstr3) digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| 621573751023FE4395613966C8098465 |
+----------------------------------+
select statement_digest(@sqlstr4) digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| 93D819205E60B9DA687534BBB404942F |
+----------------------------------+
select statement_digest_text(@sqlstr1) digest_text from dual;
