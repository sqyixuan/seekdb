| digest                           |
+----------------------------------+
| B834A65F1951D917BA59E8ECE514979C |
+----------------------------------+
select statement_digest_text('
SELECT CONCAT(last_name,", ",first_name) AS full_name
FROM mytable 
WHERE id > 10
ORDER BY full_name
limit 5;') digest_text from dual;
+-------------------------------------------------------------------------------------------------------------------+
| digest_text                                                                                                       |
+-------------------------------------------------------------------------------------------------------------------+
| SELECT CONCAT ( LAST_NAME , ? , FIRST_NAME ) AS FULL_NAME FROM MYTABLE WHERE ID > ? ORDER BY FULL_NAME LIMIT ? ;  |
+-------------------------------------------------------------------------------------------------------------------+
