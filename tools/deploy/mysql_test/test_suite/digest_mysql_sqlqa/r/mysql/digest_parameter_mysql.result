purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


-----------------------------------------------------------------------------------------------------------------
------------------------- 语句摘要函数-statement_digest(statement)/statement_digest_text(statement)--------------
###### 标签：digest-1 statement_digest(statement)/statement_digest_text(statement) - 参数个数 
-----------------------------------------------------------------------------------------------------------------
######################### 标签：digest-1-1 参数个数 - 0个参数 #########################
select statement_digest() digest from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'statement_digest'
select statement_digest_text() from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'statement_digest_text'
######################### 标签：digest-1-2 参数个数 - 1个参数  #########################
###### 标签：digest-1-2-1 null ######
select statement_digest(null), statement_digest_text(null) from dual;
+------------------------+-----------------------------+
| statement_digest(null) | statement_digest_text(null) |
+------------------------+-----------------------------+
| NULL                   | NULL                        |
+------------------------+-----------------------------+
select statement_digest(NULL), statement_digest_text(Null) from dual;
+------------------------+-----------------------------+
| statement_digest(NULL) | statement_digest_text(Null) |
+------------------------+-----------------------------+
| NULL                   | NULL                        |
+------------------------+-----------------------------+
select statement_digest('null') from dual;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'null' at line 1
select statement_digest_text('null') from dual;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'null' at line 1
###### 标签：digest-1-2-2 布尔值(false/true) ######
select statement_digest(true) from dual;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '1' at line 1
select statement_digest_text(false) from dual;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '0' at line 1
select statement_digest('true') from dual;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'true' at line 1
select statement_digest_text('false') from dual;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'false' at line 1
#######################################################
###### 标签：digest-1-2-3 字符串 ######
### 标签：digest-1-2-3-1-1 SQL 语句 - DDL(数据定义语句)
## ALTER DATABASE 语句
select statement_digest('ALTER DATABASE db1 DEFAULT CHARACTER SET gb2312') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| FA8E4C628B643B0B4E5AFC35D675FB33 |
+----------------------------------+
select statement_digest('ALTER DATABASE db2 DEFAULT COLLATE gb2312_chinese_ci') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| 5F6EBB5BE77B898F2E032605D207F49E |
+----------------------------------+
select statement_digest_text('ALTER DATABASE db1 DEFAULT CHARACTER SET gb2312') from dual;
+--------------------------------------------------------------------------+
| statement_digest_text('ALTER DATABASE db1 DEFAULT CHARACTER SET gb2312') |
+--------------------------------------------------------------------------+
| ALTER DATABASE db1 DEFAULT CHARACTER SET gb2312                          |
+--------------------------------------------------------------------------+
select statement_digest_text('ALTER DATABASE db2 DEFAULT COLLATE gb2312_chinese_ci') from dual;
+-------------------------------------------------------------------------------+
| statement_digest_text('ALTER DATABASE db2 DEFAULT COLLATE gb2312_chinese_ci') |
+-------------------------------------------------------------------------------+
| ALTER DATABASE db2 DEFAULT COLLATE gb2312_chinese_ci                          |
+-------------------------------------------------------------------------------+
## ALTER FUNCTION 语句
select statement_digest('ALTER FUNCTION fun1 NO SQL') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| 7A3DCAE6B61D02177904166C7F544F0B |
+----------------------------------+
select statement_digest('ALTER FUNCTION fun2 CONTAINS SQL ') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| BD629A655CAED272A71911AF75578DD3 |
+----------------------------------+
select statement_digest_text('ALTER FUNCTION fun1 NO SQL') from dual;
+-----------------------------------------------------+
| statement_digest_text('ALTER FUNCTION fun1 NO SQL') |
+-----------------------------------------------------+
| ALTER FUNCTION fun1 NO SQL                          |
+-----------------------------------------------------+
select statement_digest_text('ALTER FUNCTION fun2 CONTAINS SQL ') from dual;
+------------------------------------------------------------+
| statement_digest_text('ALTER FUNCTION fun2 CONTAINS SQL ') |
+------------------------------------------------------------+
| ALTER FUNCTION fun2 CONTAINS SQL                           |
+------------------------------------------------------------+
## ALTER INSTANCE 语句
## ALTER PROCEDURE 语句
select statement_digest('ALTER PROCEDURE pro1 COMMENT "string"') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| FDA591D387A10C0D830D63CE351A2567 |
+----------------------------------+
select statement_digest('ALTER PROCEDURE pro2 MODIFIES SQL DATA SQL SECURITY INVOKER') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| 91B4718924350B82D43D75D816EECBB3 |
+----------------------------------+
select statement_digest_text('ALTER PROCEDURE pro1 COMMENT "string"') from dual;
+----------------------------------------------------------------+
| statement_digest_text('ALTER PROCEDURE pro1 COMMENT "string"') |
+----------------------------------------------------------------+
| ALTER PROCEDURE pro1 COMMENT "string"                          |
+----------------------------------------------------------------+
select statement_digest_text('ALTER PROCEDURE pro2 MODIFIES SQL DATA SQL SECURITY INVOKER') from dual;
+--------------------------------------------------------------------------------------+
| statement_digest_text('ALTER PROCEDURE pro2 MODIFIES SQL DATA SQL SECURITY INVOKER') |
+--------------------------------------------------------------------------------------+
| ALTER PROCEDURE pro2 MODIFIES SQL DATA SQL SECURITY INVOKER                          |
+--------------------------------------------------------------------------------------+
## ALTER TABLE 语句
## issue:40938687 bug1: 语句摘要函数 statement_digest()/statement_digest_text(),参数是下列sql语句时，mysql成功，ob失败。
select statement_digest('ALTER TABLE t1 ROW_FORMAT = COMPRESSED') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| D329C5767A4B07156FBB8239C21176B4 |
+----------------------------------+
select statement_digest('ALTER TABLE t1 ADD COLUMN c2 INT GENERATED ALWAYS AS (c1 + 1) STORED') from dual;
+------------------------------------------------------------------------------------------+
| statement_digest('ALTER TABLE t1 ADD COLUMN c2 INT GENERATED ALWAYS AS (c1 + 1) STORED') |
+------------------------------------------------------------------------------------------+
| 6A3892F90B78638D2DB69B8D57A3B0CA                                                         |
+------------------------------------------------------------------------------------------+
select statement_digest('ALTER TABLE t1 COMMENT ="New table comment"') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| DEABE857585DA90CE9EA335F769BD39C |
+----------------------------------+
select statement_digest('ALTER TABLE t2 AUTO_INCREMENT = 13') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| DCB47A8C285583B590E56F51F566FE24 |
+----------------------------------+
select statement_digest_text('ALTER TABLE t1 ROW_FORMAT = COMPRESSED') from dual;
+-----------------------------------------------------------------+
| statement_digest_text('ALTER TABLE t1 ROW_FORMAT = COMPRESSED') |
+-----------------------------------------------------------------+
| ALTER TABLE t1 ROW_FORMAT = COMPRESSED                          |
+-----------------------------------------------------------------+
SELECT statement_digest_text('ALTER TABLE t1 ADD COLUMN c2 INT GENERATED ALWAYS AS (c1 + 1) STORED') FROM dual;
+-----------------------------------------------------------------------------------------------+
| statement_digest_text('ALTER TABLE t1 ADD COLUMN c2 INT GENERATED ALWAYS AS (c1 + 1) STORED') |
+-----------------------------------------------------------------------------------------------+
| ALTER TABLE t1 ADD COLUMN c2 INT GENERATED ALWAYS AS (c1 + 1) STORED                          |
+-----------------------------------------------------------------------------------------------+
select statement_digest_text('ALTER TABLE t1 COMMENT ="New table comment"') from dual;
+----------------------------------------------------------------------+
| statement_digest_text('ALTER TABLE t1 COMMENT ="New table comment"') |
+----------------------------------------------------------------------+
| ALTER TABLE t1 COMMENT ="New table comment"                          |
+----------------------------------------------------------------------+
select statement_digest_text('ALTER TABLE t2 AUTO_INCREMENT = 13') from dual;
+-------------------------------------------------------------+
| statement_digest_text('ALTER TABLE t2 AUTO_INCREMENT = 13') |
+-------------------------------------------------------------+
| ALTER TABLE t2 AUTO_INCREMENT = 13                          |
+-------------------------------------------------------------+
## ALTER TABLESPACE 语句
## ALTER VIEW 语句
## issue:40938687 bug1: 语句摘要函数 statement_digest()/statement_digest_text(),参数是下列sql语句时，mysql成功，ob失败。
select statement_digest('ALTER VIEW v1 AS SELECT c1,c2 FROM t1 WHERE c1 = "view"') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| B439836795C2946DA3C90E73167D99EF |
+----------------------------------+
select statement_digest('ALTER VIEW v2 AS SELECT a FROM t1 WHERE id > 1') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| 682A02F04DB9E1C4F67D2EF2FD77F449 |
+----------------------------------+
select statement_digest_text('ALTER VIEW v1 AS SELECT c1,c2 FROM t1 WHERE c1 = "view"') from dual;
+----------------------------------------------------------------------------------+
| statement_digest_text('ALTER VIEW v1 AS SELECT c1,c2 FROM t1 WHERE c1 = "view"') |
+----------------------------------------------------------------------------------+
| ALTER VIEW v1 AS SELECT c1,c2 FROM t1 WHERE c1 = "view"                          |
+----------------------------------------------------------------------------------+
select statement_digest_text('ALTER VIEW v2 AS SELECT a FROM t1 WHERE id > 1') from dual;
+-------------------------------------------------------------------------+
| statement_digest_text('ALTER VIEW v2 AS SELECT a FROM t1 WHERE id > 1') |
+-------------------------------------------------------------------------+
| ALTER VIEW v2 AS SELECT a FROM t1 WHERE id > 1                          |
+-------------------------------------------------------------------------+
## CREATE DATABASE 语句
