+----------------------------------+
| digest                           |
+----------------------------------+
| 9037200B33D778D6B96F1B83AE0BCF69 |
+----------------------------------+
select statement_digest_text(@sqlstr1) digest_text from dual;
+-------------------------------------------------------------------------------+
| digest_text                                                                   |
+-------------------------------------------------------------------------------+
| CREATE TRIGGER tri1 BEFORE INSERT ON t1 FOR EACH ROW SET @sum=@sum+NEW.salary |
+-------------------------------------------------------------------------------+
select statement_digest_text(@sqlstr2) digest_text from dual;
+--------------------------------------------------------------------------------+
| digest_text                                                                    |
+--------------------------------------------------------------------------------+
| CREATE TRIGGER tri2 AFTER UPDATE ON t2 FOR EACH ROW SELECT c1 INTO @va from t1 |
