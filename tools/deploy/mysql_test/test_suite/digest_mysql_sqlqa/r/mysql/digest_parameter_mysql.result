| digest                           |
+----------------------------------+
| F8FFF338AE28B2F7CEDC1CC952EA7F97 |
+----------------------------------+
select statement_digest('CREATE DATABASE db_name CHARACTER SET latin1 COLLATE latin1_swedish_ci') digest from dual;
+----------------------------------+
| digest                           |
+----------------------------------+
| 7D6B77E1254B470EA490E48FE70B4F27 |
+----------------------------------+
select statement_digest_text('CREATE DATABASE test_db1 DEFAULT CHARACTER SET gb2312') from dual;
+--------------------------------------------------------------------------------+
| statement_digest_text('CREATE DATABASE test_db1 DEFAULT CHARACTER SET gb2312') |
+--------------------------------------------------------------------------------+
| CREATE DATABASE test_db1 DEFAULT CHARACTER SET gb2312                          |
+--------------------------------------------------------------------------------+
select statement_digest_text('CREATE DATABASE db_name CHARACTER SET latin1 COLLATE latin1_swedish_ci') from dual;
+-------------------------------------------------------------------------------------------------+
| statement_digest_text('CREATE DATABASE db_name CHARACTER SET latin1 COLLATE latin1_swedish_ci') |
+-------------------------------------------------------------------------------------------------+
| CREATE DATABASE db_name CHARACTER SET latin1 COLLATE latin1_swedish_ci                          |
+-------------------------------------------------------------------------------------------------+
## CREATE FUNCTION 语句
## issue:40938983 bug2: 语句摘要函数 statement_digest()/statement_digest_text(),函数参数是CREATE FUNCTION 语句/CREATE PROCEDURE 语句，函数/存储过程参数的数据类型不同时，mysql成功，ob失败。
set @sqlstr1='CREATE FUNCTION fun1 (var CHAR(20)) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr2='CREATE FUNCTION fun1 (var VARCHAR(20)) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr3='CREATE FUNCTION fun1 (var BINARY) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr4='CREATE FUNCTION fun1 (var VARBINARY(20)) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr5='CREATE FUNCTION fun1 (var bigint) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr6='CREATE FUNCTION fun1 (var float) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr7='CREATE FUNCTION fun1 (var double) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr8='CREATE FUNCTION fun1 (var int) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr9='CREATE FUNCTION fun1 (var tinyint) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr10='CREATE FUNCTION fun1 (var smallint) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr11='CREATE FUNCTION fun1 (var mediumint) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr12='CREATE FUNCTION fun1 (var BLOB) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr13='CREATE FUNCTION fun1 (var TEXT) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr14='CREATE FUNCTION fun1 (var bit) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr15='CREATE FUNCTION fun1 (var decimal) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
select statement_digest(@sqlstr1) digest,statement_digest_text(@sqlstr1) digest_text from dual;
