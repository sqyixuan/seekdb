+--------------------------------------+
select statement_digest_text('SET GLOBAL max_connections = 1000') digest_text from dual;
+-----------------------------------+
| digest_text                       |
+-----------------------------------+
| SET GLOBAL max_connections = 1000 |
+-----------------------------------+
select statement_digest_text('SET @x = 1, SESSION sql_mode = ""') digest_text from dual;
+-----------------------------------+
| digest_text                       |
+-----------------------------------+
| SET @x = 1, SESSION sql_mode = "" |
+-----------------------------------+
select statement_digest_text('SET @total_tax = (SELECT SUM(tax) FROM t1 WHERE id <= 10)') digest_text from dual;
+-----------------------------------------------------------+
| digest_text                                               |
+-----------------------------------------------------------+
| SET @total_tax = (SELECT SUM(tax) FROM t1 WHERE id <= 10) |
+-----------------------------------------------------------+
