select statement_digest_text('CALL p(1)') digest_text from dual;
select statement_digest_text('CALL p(1,@var1)') digest_text from dual;
select statement_digest_text('CALL p(@var1,@var2,@var3)') digest_text from dual;

--echo ## DELETE 语句
select statement_digest('DELETE FROM t1 PARTITION (p0) WHERE c1 < 5') digest from dual;
select statement_digest('DELETE FROM t1 WHERE c1 = "jcole" ORDER BY c2 LIMIT 1') digest from dual;
select statement_digest('DELETE t1, t2 FROM t1 INNER JOIN t2 INNER JOIN t3 WHERE t1.id=t2.id AND t2.id=t3.id AND t1.c1 <= 10') digest from dual;
select statement_digest('DELETE FROM t1, t2 USING t1 INNER JOIN t2 INNER JOIN t3 WHERE t1.id=t2.id AND t2.id=t3.id') digest from dual;

select statement_digest_text('DELETE FROM t1 PARTITION (p0) WHERE c1 < 5') digest_text from dual;
select statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole" ORDER BY c2 LIMIT 1') digest_text from dual;
select statement_digest_text('DELETE t1, t2 FROM t1 INNER JOIN t2 INNER JOIN t3 WHERE t1.id=t2.id AND t2.id=t3.id AND t1.c1 <= 10') digest_text from dual;
select statement_digest_text('DELETE FROM t1, t2 USING t1 INNER JOIN t2 INNER JOIN t3 WHERE t1.id=t2.id AND t2.id=t3.id') digest_text from dual;

--echo ## INSERT 语句
select statement_digest('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)') digest from dual;
select statement_digest('INSERT INTO t1 PARTITION (p0) (col1,col2) VALUES(15,col1*2)') digest from dual;
select statement_digest('INSERT INTO t2 (a,b,c) VALUES(1,2,3), (4,5,6), (7,8,9)') digest from dual;
select statement_digest('INSERT INTO t1 (fld_id) SELECT t2.fld_order_id FROM t2 WHERE t2.fld_order_id > 100') digest from dual;
select statement_digest('INSERT INTO t1 (a,b,c) VALUES (1,2,3) ON DUPLICATE KEY UPDATE c=c+1') digest from dual;

select statement_digest_text('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)') digest_text from dual;
select statement_digest_text('INSERT INTO t1 PARTITION (p0) (col1,col2) VALUES(15,col1*2)') digest_text from dual;
select statement_digest_text('INSERT INTO t2 (a,b,c) VALUES(1,2,3), (4,5,6), (7,8,9)') digest_text from dual;
select statement_digest_text('INSERT INTO t1 (fld_id) SELECT t2.fld_order_id FROM t2 WHERE t2.fld_order_id > 100') digest_text from dual;
select statement_digest_text('INSERT INTO t1 (a,b,c) VALUES (1,2,3) ON DUPLICATE KEY UPDATE c=c+1') digest_text from dual;

--echo ## LOAD DATA 语句
select statement_digest('LOAD DATA INFILE "data.txt" INTO TABLE db2.my_table') digest from dual;
select statement_digest('LOAD DATA INFILE "/tmp/test.txt" INTO TABLE test IGNORE 1 LINES') digest from dual;
select statement_digest('LOAD DATA INFILE "data.txt" INTO TABLE tbl_name FIELDS TERMINATED BY "," LINES TERMINATED BY "\r\n" IGNORE 1 LINES') digest from dual;
select statement_digest('LOAD DATA INFILE "file.txt" INTO TABLE t1(column1, @var1)SET column2 = @var1/100') digest from dual;
select statement_digest('LOAD DATA INFILE "/tmp/bit_test.txt" INTO TABLE bit_test (@var1) SET b = CAST(CONV(MID(@var1, 3, LENGTH(@var1)-3), 2, 10) AS UNSIGNED)') digest from dual;

select statement_digest_text('LOAD DATA INFILE "data.txt" INTO TABLE db2.my_table') digest_text from dual;
select statement_digest_text('LOAD DATA INFILE "/tmp/test.txt" INTO TABLE test IGNORE 1 LINES') digest_text from dual;
select statement_digest_text('LOAD DATA INFILE "data.txt" INTO TABLE tbl_name FIELDS TERMINATED BY "," LINES TERMINATED BY "\r\n" IGNORE 1 LINES') digest_text from dual;
select statement_digest_text('LOAD DATA INFILE "file.txt" INTO TABLE t1(column1, @var1)SET column2 = @var1/100') digest_text from dual;
select statement_digest_text('LOAD DATA INFILE "/tmp/bit_test.txt" INTO TABLE bit_test (@var1) SET b = CAST(CONV(MID(@var1, 3, LENGTH(@var1)-3), 2, 10) AS UNSIGNED)') digest_text from dual;

--echo ## REPLACE  语句
select statement_digest('REPLACE INTO t1 VALUES (1, "Old", "2014-08-20 18:47:00")') digest from dual;
select statement_digest('REPLACE INTO t2 PARTITION  (p0) VALUES (1, 1+2, 2*3)') digest from dual;

select statement_digest_text('REPLACE INTO t1 VALUES (1, "Old", "2014-08-20 18:47:00")') digest_text from dual;
select statement_digest_text('REPLACE INTO t2 PARTITION  (p0) VALUES (1, 1+2, 2*3)') digest_text from dual;

--echo ## UPDATE  语句
select statement_digest('UPDATE t1 SET col1 = col1 + 1, col2 = col1') digest from dual;
select statement_digest('UPDATE t SET id = id + 1 ORDER BY id DESC LIMIT 10') digest from dual;
select statement_digest('UPDATE items,(SELECT id FROM items WHERE id IN (SELECT id FROM items WHERE retail / wholesale >= 1.3 AND quantity < 100)) AS discounted SET items.retail = items.retail * 0.9 WHERE items.id = discounted.id') digest from dual;

select statement_digest_text('UPDATE t1 SET col1 = col1 + 1, col2 = col1') digest_text from dual;
select statement_digest_text('UPDATE t SET id = id + 1 ORDER BY id DESC LIMIT 10') digest_text from dual;
select statement_digest_text('UPDATE items,(SELECT id FROM items WHERE id IN (SELECT id FROM items WHERE retail / wholesale >= 1.3 AND quantity < 100)) AS discounted SET items.retail = items.retail * 0.9 WHERE items.id = discounted.id') digest_text from dual;

--echo ## WITH (公用表表达式)
select statement_digest('WITH cte1 AS (SELECT a, b FROM table1), cte2 AS (SELECT c, d FROM table2) SELECT b, d FROM cte1 JOIN cte2 WHERE cte1.a = cte2.c') digest from dual;
select statement_digest('WITH cte (col1, col2) AS(SELECT 1, 2 UNION ALL SELECT 3, 4)SELECT col1, col2 FROM cte') digest from dual;
select statement_digest('WITH cte1 AS (SELECT 1) SELECT * FROM (WITH cte2 AS (SELECT 2) SELECT * FROM cte2 JOIN cte1) AS dt') digest from dual;
select statement_digest('WITH cte1 AS (SELECT 1) SELECT * FROM (WITH cte2 AS (SELECT 2) SELECT * FROM cte2 JOIN cte1) AS dt') digest from dual;
select statement_digest('WITH RECURSIVE cte (n) AS(SELECT 1 UNION ALL SELECT n + 1 FROM cte WHERE n < 5)SELECT * FROM cte') digest from dual;

select statement_digest_text('WITH cte1 AS (SELECT a, b FROM table1), cte2 AS (SELECT c, d FROM table2) SELECT b, d FROM cte1 JOIN cte2 WHERE cte1.a = cte2.c') digest_text from dual;
select statement_digest_text('WITH cte (col1, col2) AS(SELECT 1, 2 UNION ALL SELECT 3, 4)SELECT col1, col2 FROM cte') digest_text from dual;
select statement_digest_text('WITH cte1 AS (SELECT 1) SELECT * FROM (WITH cte2 AS (SELECT 2) SELECT * FROM cte2 JOIN cte1) AS dt') digest_text from dual;
select statement_digest_text('WITH cte1 AS (SELECT 1) SELECT * FROM (WITH cte2 AS (SELECT 2) SELECT * FROM cte2 JOIN cte1) AS dt') digest_text from dual;
select statement_digest_text('WITH RECURSIVE cte (n) AS(SELECT 1 UNION ALL SELECT n + 1 FROM cte WHERE n < 5)SELECT * FROM cte') digest_text from dual;


