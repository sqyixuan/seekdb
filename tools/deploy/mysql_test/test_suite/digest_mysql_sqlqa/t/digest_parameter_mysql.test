select statement_digest('SELECT s1 FROM t1 WHERE s1 <> ANY  (SELECT s1 FROM t2 WHERE b <= 20)') digest from dual;
select statement_digest('SELECT * FROM t1 WHERE 1 > ALL (SELECT MAX(s1) FROM t2 WHERE b >= 10)') digest from dual;
select statement_digest('SELECT * FROM t1 WHERE (col1,col2) = (SELECT col3, col4 FROM t2 WHERE id = 10)') digest from dual;
select statement_digest('SELECT column1 FROM t1 WHERE EXISTS (SELECT * FROM t2 WHERE b = 10)') digest from dual;
select statement_digest('SELECT * FROM t1 WHERE (SELECT a FROM t2 WHERE t2.a=t1.a) > 0') digest from dual;
select statement_digest('SELECT sb1,sb2,sb3 FROM (SELECT s1 AS sb1, s2 AS sb2, s3*2 AS sb3 FROM t1) AS sb WHERE sb1 > 1') digest from dual;
select statement_digest('SELECT (SELECT column1 + 5 FROM t1) FROM t2') digest from dual;

select statement_digest_text('SELECT * FROM t1 WHERE c1 = (SELECT c1 FROM t2 WHERE left(c2,6) = "beijing")') digest_text from dual;
