--echo ## CALL 语句
select statement_digest('CALL p()') digest from dual;
select statement_digest('CALL p(1)') digest from dual;
select statement_digest('CALL p(1,@var1)') digest from dual;
select statement_digest('CALL p(@var1,@var2,@var3)') digest from dual;

