--echo ## CREATE TRIGGER 语句
set @sqlstr1='CREATE TRIGGER tri1 BEFORE INSERT ON t1 FOR EACH ROW SET @sum=@sum+NEW.salary';
set @sqlstr2='CREATE TRIGGER tri2 AFTER UPDATE ON t2 FOR EACH ROW SELECT c1 INTO @va from t1';
set @sqlstr3='CREATE TRIGGER tri3 AFTER DELETE ON t2 FOR EACH ROW INSERT INTO t3 VALUES (1,2,3,4)';
set @sqlstr4='CREATE TRIGGER tri4 AFTER INSERT ON t2 FOR EACH ROW UPDATE t3 SET c1 = 2;';
set @sqlstr5='CREATE TRIGGER tri5 AFTER INSERT ON t2 FOR EACH ROW DELETE FROM t3 WHERE c1 = 1';


select statement_digest(@sqlstr1) digest from dual;
select statement_digest(@sqlstr2) digest from dual;
select statement_digest(@sqlstr3) digest from dual;
select statement_digest(@sqlstr4) digest from dual;
