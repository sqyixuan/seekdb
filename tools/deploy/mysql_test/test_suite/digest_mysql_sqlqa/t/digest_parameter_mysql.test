--echo ## SELECT 语句
--echo # SELECT 语句
select statement_digest('SELECT * FROM tbl WHERE age > 20 AND age < 30') digest from dual;
select statement_digest('SELECT * FROM tbl WHERE age BETWEEN  20 AND  25') digest from dual;
select statement_digest('SELECT * FROM tbl WHERE id IN (1,2,3,4,5,6,7)') digest from dual;
select statement_digest('SELECT * FROM tbl PARTITION (p0) WHERE id < 20 LIMIT 5') digest from dual;
select statement_digest('SELECT * FROM tbl WHERE id < 20 ORDER BY c1,c2 LIMIT 5,10') digest from dual;
select statement_digest('SELECT COUNT(col1) AS col2 FROM t GROUP BY col2 HAVING col2 = 2') digest from dual;
select statement_digest('SELECT * FROM t1 LIMIT 5 OFFSET 3') digest from dual;
select statement_digest('SELECT * FROM t1 WHERE name IS NULL') digest from dual;
select statement_digest('SELECT * FROM t1 WHERE name LIKE "%whh%"') digest from dual;
select statement_digest('SELECT * FROM t1 WHERE name LIKE "%WHH%"') digest from dual;

select statement_digest_text('SELECT * FROM tbl WHERE age > 20 AND age < 30') digest_text from dual;
select statement_digest_text('SELECT * FROM tbl WHERE age BETWEEN  20 AND  25') digest_text from dual;
select statement_digest_text('SELECT * FROM tbl WHERE id IN (1,2,3,4,5,6,7)') digest_text from dual;
select statement_digest_text('SELECT * FROM tbl PARTITION (p0) WHERE id < 20 LIMIT 5') digest_text from dual;
select statement_digest_text('SELECT * FROM tbl WHERE id < 20 ORDER BY c1,c2 LIMIT 5,10') digest_text from dual;
select statement_digest_text('SELECT COUNT(col1) AS col2 FROM t GROUP BY col2 HAVING col2 = 2') digest_text from dual;
select statement_digest_text('SELECT * FROM t1 LIMIT 5 OFFSET 3') digest_text from dual;
select statement_digest_text('SELECT * FROM t1 WHERE name IS NULL') digest_text from dual;
select statement_digest_text('SELECT * FROM t1 WHERE name LIKE "%whh%"') digest_text from dual;
select statement_digest_text('SELECT * FROM t1 WHERE name LIKE "%WHH%"') digest_text from dual;


--echo # SELECT ... INTO 语句
