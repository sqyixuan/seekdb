# owner: sean.yyj
# owner group: sql-sql1
# description: mysql语句摘要函数-参数个数
# tags: statement_digest,statement_digest_text
# author: whh01047778


purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 语句摘要函数-statement_digest(statement)/statement_digest_text(statement)--------------
--echo ###### 标签：digest-1 statement_digest(statement)/statement_digest_text(statement) - 参数个数 
--echo -----------------------------------------------------------------------------------------------------------------

--echo ######################### 标签：digest-1-1 参数个数 - 0个参数 #########################
--error 1582
select statement_digest() digest from dual;

--error 1582
select statement_digest_text() from dual;


--echo ######################### 标签：digest-1-2 参数个数 - 1个参数  #########################
--echo ###### 标签：digest-1-2-1 null ######
select statement_digest(null), statement_digest_text(null) from dual;

select statement_digest(NULL), statement_digest_text(Null) from dual;

--error 1064
select statement_digest('null') from dual;

--error 1064
select statement_digest_text('null') from dual;


--echo ###### 标签：digest-1-2-2 布尔值(false/true) ######
--error 1064
select statement_digest(true) from dual;

--error 1064
select statement_digest_text(false) from dual;

--error 1064
select statement_digest('true') from dual;

--error 1064
select statement_digest_text('false') from dual;


--echo #######################################################
--echo ###### 标签：digest-1-2-3 字符串 ######
--echo ### 标签：digest-1-2-3-1-1 SQL 语句 - DDL(数据定义语句)
--echo ## ALTER DATABASE 语句
select statement_digest('ALTER DATABASE db1 DEFAULT CHARACTER SET gb2312') digest from dual;
select statement_digest('ALTER DATABASE db2 DEFAULT COLLATE gb2312_chinese_ci') digest from dual;

select statement_digest_text('ALTER DATABASE db1 DEFAULT CHARACTER SET gb2312') from dual;
select statement_digest_text('ALTER DATABASE db2 DEFAULT COLLATE gb2312_chinese_ci') from dual;

--echo ## ALTER FUNCTION 语句
select statement_digest('ALTER FUNCTION fun1 NO SQL') digest from dual;
select statement_digest('ALTER FUNCTION fun2 CONTAINS SQL ') digest from dual;

select statement_digest_text('ALTER FUNCTION fun1 NO SQL') from dual;
select statement_digest_text('ALTER FUNCTION fun2 CONTAINS SQL ') from dual;

--echo ## ALTER INSTANCE 语句
#select statement_digest('ALTER INSTANCE ROTATE INNODB MASTER KEY') digest from dual;

#select statement_digest_text('ALTER INSTANCE ROTATE INNODB MASTER KEY') from dual;

--echo ## ALTER PROCEDURE 语句
select statement_digest('ALTER PROCEDURE pro1 COMMENT "string"') digest from dual;
select statement_digest('ALTER PROCEDURE pro2 MODIFIES SQL DATA SQL SECURITY INVOKER') digest from dual;

select statement_digest_text('ALTER PROCEDURE pro1 COMMENT "string"') from dual;
select statement_digest_text('ALTER PROCEDURE pro2 MODIFIES SQL DATA SQL SECURITY INVOKER') from dual;

--echo ## ALTER TABLE 语句
--echo ## issue:40938687 bug1: 语句摘要函数 statement_digest()/statement_digest_text(),参数是下列sql语句时，mysql成功，ob失败。
select statement_digest('ALTER TABLE t1 ROW_FORMAT = COMPRESSED') digest from dual;
select statement_digest('ALTER TABLE t1 ADD COLUMN c2 INT GENERATED ALWAYS AS (c1 + 1) STORED') from dual;
select statement_digest('ALTER TABLE t1 COMMENT ="New table comment"') digest from dual;
select statement_digest('ALTER TABLE t2 AUTO_INCREMENT = 13') digest from dual;

select statement_digest_text('ALTER TABLE t1 ROW_FORMAT = COMPRESSED') from dual;
SELECT statement_digest_text('ALTER TABLE t1 ADD COLUMN c2 INT GENERATED ALWAYS AS (c1 + 1) STORED') FROM dual;
select statement_digest_text('ALTER TABLE t1 COMMENT ="New table comment"') from dual;
select statement_digest_text('ALTER TABLE t2 AUTO_INCREMENT = 13') from dual;

--echo ## ALTER TABLESPACE 语句
#select statement_digest('ALTER TABLESPACE ts1 ENCRYPTION  = "Y"') digest from dual;
#select statement_digest('ALTER TABLESPACE ts1 ENCRYPTION  = "N"') digest from dual;

#select statement_digest_text('ALTER TABLESPACE ts1 ENCRYPTION  = "Y"') from dual;
#select statement_digest_text('ALTER TABLESPACE ts1 ENCRYPTION  = "N"') from dual;

--echo ## ALTER VIEW 语句
--echo ## issue:40938687 bug1: 语句摘要函数 statement_digest()/statement_digest_text(),参数是下列sql语句时，mysql成功，ob失败。
select statement_digest('ALTER VIEW v1 AS SELECT c1,c2 FROM t1 WHERE c1 = "view"') digest from dual;
select statement_digest('ALTER VIEW v2 AS SELECT a FROM t1 WHERE id > 1') digest from dual;

select statement_digest_text('ALTER VIEW v1 AS SELECT c1,c2 FROM t1 WHERE c1 = "view"') from dual;
select statement_digest_text('ALTER VIEW v2 AS SELECT a FROM t1 WHERE id > 1') from dual;

--echo ## CREATE DATABASE 语句
select statement_digest('CREATE DATABASE test_db1 DEFAULT CHARACTER SET gb2312') digest from dual;
select statement_digest('CREATE DATABASE db_name CHARACTER SET latin1 COLLATE latin1_swedish_ci') digest from dual;

select statement_digest_text('CREATE DATABASE test_db1 DEFAULT CHARACTER SET gb2312') from dual;
select statement_digest_text('CREATE DATABASE db_name CHARACTER SET latin1 COLLATE latin1_swedish_ci') from dual;

--echo ## CREATE FUNCTION 语句
--echo ## issue:40938983 bug2: 语句摘要函数 statement_digest()/statement_digest_text(),函数参数是CREATE FUNCTION 语句/CREATE PROCEDURE 语句，函数/存储过程参数的数据类型不同时，mysql成功，ob失败。
set @sqlstr1='CREATE FUNCTION fun1 (var CHAR(20)) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr2='CREATE FUNCTION fun1 (var VARCHAR(20)) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr3='CREATE FUNCTION fun1 (var BINARY) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr4='CREATE FUNCTION fun1 (var VARBINARY(20)) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr5='CREATE FUNCTION fun1 (var bigint) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr6='CREATE FUNCTION fun1 (var float) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr7='CREATE FUNCTION fun1 (var double) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr8='CREATE FUNCTION fun1 (var int) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr9='CREATE FUNCTION fun1 (var tinyint) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr10='CREATE FUNCTION fun1 (var smallint) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr11='CREATE FUNCTION fun1 (var mediumint) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr12='CREATE FUNCTION fun1 (var BLOB) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr13='CREATE FUNCTION fun1 (var TEXT) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr14='CREATE FUNCTION fun1 (var bit) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';
set @sqlstr15='CREATE FUNCTION fun1 (var decimal) RETURNS VARCHAR(20) BEGIN RETURN(SELECT name FROM name WHERE id = var); END';

select statement_digest(@sqlstr1) digest,statement_digest_text(@sqlstr1) digest_text from dual;
select statement_digest(@sqlstr2) digest,statement_digest_text(@sqlstr2) digest_text from dual;
select statement_digest(@sqlstr3) digest,statement_digest_text(@sqlstr3) digest_text from dual;
select statement_digest(@sqlstr4) digest,statement_digest_text(@sqlstr4) digest_text from dual;
select statement_digest(@sqlstr5) digest,statement_digest_text(@sqlstr5) digest_text from dual;
select statement_digest(@sqlstr6) digest,statement_digest_text(@sqlstr6) digest_text from dual;
select statement_digest(@sqlstr7) digest,statement_digest_text(@sqlstr7) digest_text from dual;
select statement_digest(@sqlstr8) digest,statement_digest_text(@sqlstr8) digest_text from dual;
select statement_digest(@sqlstr9) digest,statement_digest_text(@sqlstr9) digest_text from dual;
select statement_digest(@sqlstr10) digest,statement_digest_text(@sqlstr10) digest_text from dual;
select statement_digest(@sqlstr11) digest,statement_digest_text(@sqlstr11) digest_text from dual;
select statement_digest(@sqlstr12) digest,statement_digest_text(@sqlstr12) digest_text from dual;
select statement_digest(@sqlstr13) digest,statement_digest_text(@sqlstr13) digest_text from dual;
select statement_digest(@sqlstr14) digest,statement_digest_text(@sqlstr14) digest_text from dual;
select statement_digest(@sqlstr15) digest,statement_digest_text(@sqlstr15) digest_text from dual;


