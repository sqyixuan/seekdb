SELECT CONCAT(last_name,", ",first_name) AS full_name
FROM mytable 
WHERE id > 10
ORDER BY full_name
limit 5;') digest from dual;

select statement_digest_text('
SELECT CONCAT(last_name,", ",first_name) AS full_name
FROM mytable 
WHERE id > 10
ORDER BY full_name
limit 5;') digest_text from dual;

