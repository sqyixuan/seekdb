--echo ## CREATE TABLE 语句
set @sqlstr1='CREATE TABLE t1 (id INT(21) NOT NULL AUTO_INCREMENT PRIMARY KEY, c1 VARCHAR(25), c2 DATE, c3 BLOB, INDEX(c3(10)))';
set @sqlstr2='CREATE TEMPORARY TABLE t2 SELECT * FROM t1 LIMIT 0';
set @sqlstr3='CREATE TABLE t3 LIKE t1';
set @sqlstr4='CREATE TABLE t4 AS SELECT * FROM t1 LIMIT 0';

select statement_digest(@sqlstr1) digest from dual;
select statement_digest(@sqlstr2) digest from dual;
select statement_digest(@sqlstr3) digest from dual;
select statement_digest(@sqlstr4) digest from dual;

select statement_digest_text(@sqlstr1) digest_text from dual;
select statement_digest_text(@sqlstr2) digest_text from dual;
select statement_digest_text(@sqlstr3) digest_text from dual;
select statement_digest_text(@sqlstr4) digest_text from dual;

