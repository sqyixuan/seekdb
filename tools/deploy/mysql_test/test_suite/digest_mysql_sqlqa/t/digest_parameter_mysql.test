select statement_digest('DROP DATABASE test_db1') digest from dual;
select statement_digest('DROP DATABASE IF EXISTS test_db2') digest from dual;

select statement_digest_text('DROP DATABASE test_db1') digest_text from dual;
select statement_digest_text('DROP DATABASE IF EXISTS test_db2') digest_text from dual;

--echo ## DROP FUNCTION 语句 / DROP PROCEDURE 语句
--echo ## issue:40978782 bug3: 语句摘要函数 statement_digest()/statement_digest_text(),参数是下列SQL语句，并且含有IF EXISTS 关键字时，mysql成功，ob失败。
select statement_digest('DROP PROCEDURE pro1') digest from dual;
select statement_digest('DROP PROCEDURE pro2') digest from dual;

select statement_digest_text('DROP PROCEDURE pro1') digest_text from dual;
select statement_digest_text('DROP PROCEDURE pro2') digest_text from dual;

select statement_digest('DROP FUNCTION IF EXISTS fun1') digest from dual;
select statement_digest('DROP FUNCTION IF EXISTS fun2') digest from dual;

select statement_digest_text('DROP FUNCTION IF EXISTS fun1') digest_text from dual;
select statement_digest_text('DROP FUNCTION IF EXISTS fun2') digest_text from dual;

