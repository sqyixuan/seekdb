--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 语句摘要函数-statement_digest(statement)/statement_digest_text(statement)--------------
--echo ###### 标签：digest-3 statement_digest(statement)/statement_digest_text(statement) - 字符集        
--echo -----------------------------------------------------------------------------------------------------------------
--error 0,1051
drop table digest_table1;
create table digest_table1(
  c1 VARCHAR(200)
)default character set = 'utf8mb4';

insert into digest_table1 values(null),('INSERT INTO t1(col1,col2) VALUES(15,col1*2)'),('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)    '),('INSERT INTO t1 (col1,col2) VALUES(15,col1*2);');
select statement_digest(c1) digest,statement_digest_text(c1) digest_text from digest_table1;


--error 0,1051
drop table digest_table1;
create table digest_table1(
  c1 VARCHAR(200)
)default character set = 'gbk';

insert into digest_table1 values(null),('DELETE FROM t1 WHERE c1 = "jcole" ORDER BY c2 LIMIT 1'),('DELETE FROM t1 WHERE c1 = "jcole" ORDER BY c2 LIMIT 1    '),('DELETE FROM t1 WHERE c1 = "jcole" ORDER BY c2 LIMIT 1;');
select statement_digest(c1) digest,statement_digest_text(c1) digest_text from digest_table1;


--error 0,1051
drop table digest_table1;
create table digest_table1(
  c1 VARCHAR(200)
)default character set = 'binary';

insert into digest_table1 values(null),('SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2 LIMIT 5'),('SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2 LIMIT 5    '),('SELECT * FROM tl WHERE id < 30 ORDER BY c1,c2 LIMIT 15;');
select statement_digest(c1) digest,statement_digest_text(c1) digest_text from digest_table1;


--error 0,1051
drop table digest_table1;
create table digest_table1(
  c1 VARCHAR(200)
)default character set = 'gb18030';

insert into digest_table1 values(null),('SELECT * FROM tl WHERE id < 20'),('SELECT * FROM tl WHERE id < 30'),('SELECT * FROM tl WHERE id < 40');
select statement_digest(c1) digest,statement_digest_text(c1) digest_text from digest_table1;


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 语句摘要函数-statement_digest(statement)/statement_digest_text(statement)--------------
--echo ###### 标签：digest-4 statement_digest(statement)/statement_digest_text(statement) - 函数间嵌套        
--echo -----------------------------------------------------------------------------------------------------------------

--echo ######################### 标签：digest-4-1,digest-4-2 函数间嵌套 - 函数嵌套/被函数嵌套 #########################
--echo ##数字函数
--disable_warnings
SELECT ABS(statement_digest('SELECT ABS(-10)')) digest,ABS(statement_digest_text('SELECT ABS(-10)')) digest_text FROM dual;
--error 1064
SELECT statement_digest(ABS(-10)) digest,statement_digest_text(ABS(-10)) digest_text FROM dual;

SELECT AVG(statement_digest('SELECT 2+3*3')) digest,AVG(statement_digest_text('SELECT 2+3*3')) digest_text FROM dual;
--error 1064
SELECT statement_digest(AVG(10)) digest,statement_digest_text(AVG(10)) digest_text FROM dual;

SELECT CEIL(statement_digest('SELECT 2+3*3')) digest,CEIL(statement_digest_text('SELECT 2+3*3')) digest_text FROM dual;
--error 1064
SELECT statement_digest(CEIL(10.7)) digest,statement_digest_text(CEIL(10.7)) digest_text FROM dual;

SELECT FLOOR(statement_digest('SELECT 2+3')) digest,FLOOR(statement_digest_text('SELECT 2+3')) digest_text FROM dual;
--error 1064
SELECT statement_digest(FLOOR(10.7)) digest,statement_digest_text(FLOOR(10.7)) digest_text FROM dual;

SELECT MAX(statement_digest('SELECT 2+3')) digest,MAX(statement_digest_text('SELECT 2+3')) digest_text FROM dual;
--error 1064
SELECT statement_digest(MAX(20)) digest,statement_digest_text(MAX(20)) digest_text FROM dual;

SELECT MIN(statement_digest('SELECT concat("whh",18)')) digest,MIN(statement_digest_text('SELECT concat("whh",18)')) digest_text FROM dual;
--error 1064
SELECT statement_digest(MIN(10)) digest,statement_digest_text(MIN(10)) digest_text FROM dual;

SELECT ROUND(statement_digest('SELECT concat("whh",18)')) digest,ROUND(statement_digest_text('SELECT concat("whh",18)')) digest_text FROM dual;
--error 1064
SELECT statement_digest(ROUND(10)) digest,statement_digest_text(ROUND(10)) digest_text FROM dual;

SELECT TRUNCATE(statement_digest('SELECT concat("whh",18)'),1) digest,TRUNCATE(statement_digest_text('SELECT concat("whh",18)'),1) digest_text FROM dual;
--error 1064
SELECT statement_digest(TRUNCATE(10.12345,2)) digest,statement_digest_text(TRUNCATE(10.12345,2)) digest_text FROM dual;
--enable_warnings

--echo ##字符函数
SELECT UPPER(statement_digest('SELECT truncate(20.123456,2) FROM dual')) digest,UPPER(statement_digest_text('SELECT truncate(20.123456,2) FROM dual')) digest_text FROM dual;
SELECT statement_digest(UPPER('SELECT truncate(20.123456,2) FROM dual')) digest,statement_digest_text(UPPER('SELECT truncate(20.123456,2) FROM dual')) digest_text FROM dual;

SELECT LOWER(statement_digest('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)')) digest,LOWER(statement_digest_text('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)')) digest_text FROM dual;
SELECT statement_digest(LOWER('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)')) digest,statement_digest_text(LOWER('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)')) digest_text FROM dual;

SELECT INSTR(statement_digest('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)'),'ab') digest,INSTR(statement_digest_text('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)'),'t1') digest_text FROM dual;
--error 1064
SELECT statement_digest(INSTR('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)','t1')) digest,statement_digest_text(INSTR('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)','col1')) digest_text FROM dual;

SELECT LENGTH(statement_digest('UPDATE t1 SET id = id + 1 ORDER BY id DESC LIMIT 10')) digest,LENGTH(statement_digest_text('UPDATE t1 SET id = id + 1 ORDER BY id DESC LIMIT 10')) digest_text FROM dual;
--error 1064
SELECT statement_digest(LENGTH('UPDATE t1 SET id = id + 1 ORDER BY id DESC LIMIT 10')) digest,statement_digest_text(LENGTH('UPDATE t1 SET id = id + 1 ORDER BY id DESC LIMIT 10')) digest_text FROM dual;

SELECT REPLACE(statement_digest('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)'),0,'$') digest,REPLACE(statement_digest_text('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)'),'?','@') digest_text FROM dual;
SELECT statement_digest(REPLACE('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)','t1','t2')) digest,statement_digest_text(REPLACE('INSERT INTO t1 (col1,col2) VALUES(15,col1*2)','t1','t2')) digest_text FROM dual;

SELECT SUBSTR(statement_digest('SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2'),1,15) digest,SUBSTR(statement_digest_text('SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2'),1,29) digest_text FROM dual;
SELECT statement_digest(SUBSTR('SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2',1,42)) digest,statement_digest_text(SUBSTR('SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2',1,42)) digest_text FROM dual;

SELECT CONCAT('{',statement_digest('SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2'),'}') digest,CONCAT('{',statement_digest_text('SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2'),'}') digest_text FROM dual;
SELECT statement_digest(CONCAT('  ','SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2',';')) digest,statement_digest_text(CONCAT('   ','SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2',';')) digest_text FROM dual;

SELECT LPAD(statement_digest('SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2'),40,'$') digest,LPAD(statement_digest_text('SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2'),50,'$') digest_text FROM dual;
SELECT statement_digest(LPAD('SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2',60,' ')) digest,statement_digest_text(LPAD('SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2',50,' ')) digest_text FROM dual;

SELECT TRIM(statement_digest('   SELECT * FROM tl WHERE id < 20 LIMIT 3   ')) digest,TRIM(statement_digest_text('  SELECT * FROM tl WHERE id < 20 LIMIT 3  ')) digest_text FROM dual;
SELECT statement_digest(TRIM('   SELECT * FROM tl WHERE id < 20 LIMIT 3   ')) digest,statement_digest_text(TRIM('  SELECT * FROM tl WHERE id < 20 LIMIT 3  ')) digest_text FROM dual;

SELECT REVERSE(statement_digest('SELECT * FROM tl WHERE id < 20 LIMIT 3')) digest,REVERSE(statement_digest_text('SELECT * FROM tl WHERE id < 20 LIMIT 3')) digest_text FROM dual;
SELECT statement_digest(REVERSE(REVERSE('SELECT * FROM tl WHERE id < 20 LIMIT 3'))) digest,statement_digest_text(REVERSE(REVERSE('SELECT * FROM tl WHERE id < 20 LIMIT 3'))) digest_text FROM dual;

--echo ##日期函数
SELECT FROM_DAYS(statement_digest('UPDATE t1 SET id = id + 1')) digest,FROM_DAYS(statement_digest_text('UPDATE t1 SET id = id + 1')) FROM dual;
--error 1064
SELECT statement_digest(FROM_DAYS(729575)) digest,statement_digest_text(FROM_DAYS(729575)) FROM dual;

--echo ## 系统时间会变，所以预期执行结果也会不一样，知道sql语句支持就好，暂时注释掉
--echo ## --error 1064
