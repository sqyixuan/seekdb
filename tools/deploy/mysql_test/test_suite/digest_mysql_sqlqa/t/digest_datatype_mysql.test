--error 1210
select statement_digest_text(statement_digest_text(statement_digest_text(statement_digest_text('SELECT * FROM tl WHERE id < 20')))) digest_text from dual;

--echo ## statement_digest/statement_digest_text 相互嵌套
--error 1210
select statement_digest(statement_digest_text('UPDATE t1 SET id = id * 5')) digest from dual;
select statement_digest_text(concat('select sql_id, statement from oceanbase.v$plan_cache_plan_stat where sql_id = ',statement_digest('UPDATE t1 SET id = id * 5'))) digest_text from dual;
select statement_digest(statement_digest_text(concat('select sql_id, statement from oceanbase.v$plan_cache_plan_stat where sql_id = ',statement_digest('UPDATE t1 SET id = id * 5')))) digest from dual;

--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 语句摘要函数-statement_digest(statement)/statement_digest_text(statement)--------------
--echo ###### 标签：digest-5 statement_digest(statement)/statement_digest_text(statement) - 运算符        
--echo -----------------------------------------------------------------------------------------------------------------

--echo ######################### 标签：digest-5-1 运算符 - 算术运算符 #########################
select statement_digest('UPDATE t1 SET id = id + (1+2*4/3%3)') digest from dual;
select statement_digest_text('UPDATE t1 SET id = id + (1+2*4/3%3)') digest_text from dual;

--disable_warnings
select statement_digest('SELECT 3*5') + 3 -1 *9 / 4 % 3 digest from dual;
select statement_digest_text('SELECT 3*5')+ 3 -1 *9 / 4 % 3  digest_text from dual;

select statement_digest('SELECT 3*5') DIV 2 digest from dual;
select statement_digest_text('SELECT 3*5') MOD 3  digest_text from dual;
--enable_warnings

--echo ######################### 标签：digest-5-2 运算符 - 比较运算符 #########################
select statement_digest('UPDATE t1 SET id = id + 1') = statement_digest('UPDATE t1 SET id = id + 1')  '=' from dual;
select statement_digest('UPDATE t1 SET id = id + 1') > statement_digest('UPDATE t1 SET id = id + 2') '>' from dual;
select statement_digest('UPDATE t1 SET id = id + 1') < statement_digest('UPDATE t2 SET id = id + 1') '<' from dual;
select statement_digest('UPDATE t1 SET id = 1') >= statement_digest('UPDATE t1 SET id = 2') '>=' from dual;
select statement_digest('UPDATE t1 SET id = id + 1') <= statement_digest('DELETE FROM t1 WHERE c1 = "jcole"') '<=' from dual;
select statement_digest('UPDATE t1 SET id = id + 1') != statement_digest('INSERT INTO t1 (col1,col2) VALUES(15,2*2)') '!=' from dual;
select statement_digest('UPDATE t1 SET id = id + 1') <> statement_digest('UPDATE t1 SET id = id + 2') '<>' from dual;
select statement_digest_text('UPDATE t1 SET id = id + 1') = statement_digest_text('UPDATE t1 SET id = id + 1')  '=' from dual;
select statement_digest_text('UPDATE t1 SET id = id + 1') > statement_digest_text('UPDATE t1 SET id = id + 2') '>' from dual;
select statement_digest_text('UPDATE t1 SET id = id + 1') < statement_digest_text('UPDATE t2 SET id = id + 1') '<' from dual;
select statement_digest_text('UPDATE t1 SET id = 1') >= statement_digest_text('UPDATE t1 SET id = 2') '>=' from dual;
select statement_digest_text('UPDATE t1 SET id = id + 1') <= statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole"') '<=' from dual;
select statement_digest_text('UPDATE t1 SET id = id + 1') != statement_digest_text('INSERT INTO t1 (col1,col2) VALUES(15,2*2)') '!=' from dual;
select statement_digest_text('UPDATE t1 SET id = id + 1') <> statement_digest_text('UPDATE t1 SET id = id + 2') '<>' from dual;

select statement_digest('UPDATE t1 SET id = id + 1') in (statement_digest('UPDATE t1 SET id = id + 1'),'',1)  'in' from dual;
select statement_digest('UPDATE t1 SET id = id + 1') not in (statement_digest('UPDATE t1 SET id = id + 1'),'',1) 'not in' from dual;
select statement_digest(null) is null  'is null' from dual;
select statement_digest('UPDATE t1 SET id = 1')  is not null 'is not null' from dual;
select statement_digest('UPDATE t1 SET id = id + 1') between 0 and 100 'between' from dual;
select statement_digest('UPDATE t1 SET id = id + 1') not between 0 and 100 'not between' from dual;
select statement_digest('UPDATE t1 SET id = id + 1') <=> null '<=>' from dual;
select statement_digest('UPDATE t1 SET id = id + 1') LIKE '%bdb%' as 'like'  from dual;
select statement_digest('UPDATE t1 SET id = id + 1') REGEXP '^d89' as 'regexp' from dual;
select statement_digest('UPDATE t1 SET id = id + 1') RLIKE '^d89' as 'rlike' from dual;

select statement_digest_text('UPDATE t1 SET id = id + 1') in (statement_digest_text('UPDATE t1 SET id = id + 1'),'',1)  'in' from dual;
select statement_digest_text('UPDATE t1 SET id = id + 1') not in (statement_digest_text('UPDATE t1 SET id = id + 1'),'',1) 'not in' from dual;
select statement_digest_text(null) is null  'is null' from dual;
select statement_digest_text('UPDATE t1 SET id = 1')  is not null 'is not null' from dual;
select statement_digest_text('UPDATE t1 SET id = id + 1') between 0 and 100 'between' from dual;
select statement_digest_text('UPDATE t1 SET id = id + 1') not between 0 and 100 'not between' from dual;
select statement_digest_text(null) <=> null '<=>' from dual;
select statement_digest_text('UPDATE t1 SET id = id + 1') LIKE '%?%' as 'like'from dual;
select statement_digest_text('UPDATE t1 SET id = id + 1') REGEXP '^UPDATE' as 'regexp' from dual;
select statement_digest_text('UPDATE t1 SET id = id + 1') RLIKE '^UPDATE' as 'rlike' from dual;


--echo ######################### 标签：digest-5-3 运算符 - 逻辑运算符 #########################
--disable_warnings
select not statement_digest('DELETE FROM t1 WHERE c1 = "q"') 'not' from dual;
select statement_digest('DELETE FROM t1 WHERE c1 = "w"') and 1 'and' from dual;
select statement_digest('DELETE FROM t1 WHERE c1 = "e"') or 0 'or' from dual;
select statement_digest('DELETE FROM t1 WHERE c1 = "r"') xor statement_digest('DELETE FROM t1 WHERE c1 = "t"') 'xor' from dual;

select not statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole"') 'not' from dual;
select statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole"') and 1 'and' from dual;
select statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole"') or 0 'or' from dual;
select statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole"') xor statement_digest_text('DELETE FROM t1 WHERE c1 = "t"') 'xor' from dual;
--enable_warnings


--echo ######################### 标签：digest-5-4 运算符 - 位运算符 #########################
--disable_warnings
select statement_digest('DELETE FROM t1 WHERE c1 = "q"') & 1'&' from dual;
select statement_digest('DELETE FROM t1 WHERE c1 = "w"') | 1 '|' from dual;
select statement_digest('DELETE FROM t1 WHERE c1 = "e"') ^ 0 '^' from dual;
select !statement_digest('DELETE FROM t1 WHERE c1 = "r"') '!' from dual;
select statement_digest('DELETE FROM t1 WHERE c1 = "r"') >> 3 '>>' from dual;
select statement_digest('DELETE FROM t1 WHERE c1 = "r"') << 3 '<<' from dual;

select statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole"') & 1 '&' from dual;
select statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole"') | 1 '|' from dual;
select statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole"') ^ 3 '^' from dual;
select !statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole"') '!' from dual;
select statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole"') >> 3 '>>' from dual;
select statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole"') << 3 '<<' from dual;
--enable_warnings


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 语句摘要函数-statement_digest(statement)/statement_digest_text(statement)--------------
--echo ###### 标签：digest-6 statement_digest(statement)/statement_digest_text(statement) - 视图，索引，约束
--echo -----------------------------------------------------------------------------------------------------------------

--echo #################################################################################
--echo ### 表，视图创建
--error 0,1051
DROP TABLE digest_table1;
CREATE TABLE digest_table1( 
  id INT,
  c1 VARCHAR(200), 
  c2 VARCHAR(200)
);

insert into digest_table1 values(1,'INSERT INTO t1(col1,col2) VALUES(15,25)','INSERT INTO t1(col1,col2) VALUES(16,col1*3)');
insert into digest_table1 values(2,'DELETE FROM t1 WHERE c1 = "whh"','DELETE FROM t1 WHERE c1 = "whh" ORDER BY c2,c3 LIMIT 2');
insert into digest_table1 values(3,'UPDATE t1 SET id = id + 1','UPDATE t1 SET id = id + 1 ORDER BY id DESC LIMIT 4');
insert into digest_table1 values(4,'SELECT * FROM tl WHERE id < 20','SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2 LIMIT 6,10');

--error 0,1051
DROP TABLE digest_table2;
CREATE TABLE `digest_table2` (
  `id` int unsigned NOT NULL AUTO_INCREMENT,
  `sqls` varchar(255) NOT NULL COMMENT 'sql语句',
  `digest` varchar(255) NOT NULL DEFAULT '' COMMENT 'statement_digest',
  `digest_text` varchar(255) NOT NULL DEFAULT '' COMMENT 'statement_digest_text',
  PRIMARY KEY (`id`)
);

INSERT INTO digest_table2 VALUES(1,'INSERT INTO t1 VALUES(15,25)',statement_digest('INSERT INTO t1 VALUES(15,25)'),statement_digest_text('INSERT INTO t1 VALUES(15,25)'));
INSERT INTO digest_table2 VALUES(2,'DELETE FROM t1 WHERE c1 = "whh"',statement_digest('DELETE FROM t1 WHERE c1 = "whh"'),statement_digest_text('DELETE FROM t1 WHERE c1 = "whh"'));
INSERT INTO digest_table2 VALUES(3,'UPDATE t1 SET id = id + 1',statement_digest('UPDATE t1 SET id = id + 1'),statement_digest_text('UPDATE t1 SET id = id + 1'));
INSERT INTO digest_table2 VALUES(5,'SELECT * FROM tl WHERE id < 20',statement_digest('SELECT * FROM tl WHERE id < 20'),statement_digest_text('SELECT * FROM tl WHERE id < 20'));

--error 0,1051
DROP VIEW t1_view;
CREATE VIEW t1_view AS SELECT * FROM digest_table1 WHERE id <= 3;

--error 0,1051
DROP VIEW t2_view;
CREATE VIEW t2_view AS SELECT * FROM digest_table1 WHERE id >= 2;

--error 0,1051
DROP VIEW t3_view;


--echo ######################### 标签：digest-6-1 视图 #########################
--echo ### SELECT
--echo ##多列/单列
select id,statement_digest(c1) digest,statement_digest_text(c2) digest_text from t1_view ORDER BY id;
--echo ##issue:41063613 bug5: 
--error 1210
select id,statement_digest(CONCAT(c1,';',c2)) digest,statement_digest_text(CONCAT(c1,';',c2)) digest_text from t1_view ORDER BY id;

--echo ##WHERE 子句
SELECT id,c1,statement_digest(c1) digest FROM t1_view WHERE statement_digest(c1) = '2A79EA558908297E4C12584F07C76222';
SELECT id,c2,statement_digest_text(c2) digest_text FROM t1_view WHERE statement_digest_text(c2) like '%col1*?%';
SELECT id,c1,statement_digest(c1) digest,c2,statement_digest_text(c2) digest_text FROM t1_view WHERE statement_digest(c1) = statement_digest('DELETE FROM t1 WHERE c1 = "qwer"');

--echo ##order by 子句
SELECT id,statement_digest(c1) digest,statement_digest_text(c2) digest_text FROM t1_view ORDER BY statement_digest(c1);
SELECT id,statement_digest(c1) digest,statement_digest_text(c2) digest_text FROM t1_view ORDER BY statement_digest(c1) DESC;
SELECT id,statement_digest(c1) digest,statement_digest_text(c2) digest_text FROM t1_view ORDER BY statement_digest_text(c2);
SELECT id,statement_digest(c1) digest,statement_digest_text(c2) digest_text FROM t1_view ORDER BY statement_digest_text(c2) ASC;

--echo ##group by having 子句
SELECT id,statement_digest(c1) digest,statement_digest_text(c2) digest_text FROM t1_view GROUP BY statement_digest(c1) ORDER BY id;
SELECT id,statement_digest(c1) digest,statement_digest_text(c2) digest_text FROM t1_view GROUP BY statement_digest_text(c2),id ORDER BY id ;
SELECT id,statement_digest(c1) digest,statement_digest_text(c2) digest_text FROM t1_view GROUP BY statement_digest(c1) HAVING digest > statement_digest('DELETE FROM t1 WHERE c1 = "qwer"') ORDER BY id;

--echo #DISTINCT
SELECT distinct statement_digest(c1) digest,id,c1 FROM t1_view e ORDER BY id;
SELECT distinct statement_digest_text(c2),id,c2 FROM t1_view e ORDER BY id;

--echo #CASE WHEN
SELECT id,statement_digest(CASE WHEN c1 IS NULL THEN c2 ELSE c1 END) digest,statement_digest_text(CASE WHEN c1 IS NULL THEN c2 ELSE c1 END) digest_text FROM t1_view  ORDER BY id;
SELECT id,CASE WHEN statement_digest(c1)= statement_digest('DELETE FROM t1 WHERE c1 = "whh"') THEN 'id=2的statement_digest（c1列）'  ELSE '其他列' END digest FROM t1_view ORDER BY id; 
SELECT id,CASE WHEN statement_digest_text(c2) LIKE '%INSERT%' THEN 'id=1的 statement_digest_text（c2列）' ELSE '其他列' END digest FROM t1_view ORDER BY id; 

--echo ##连接查询
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e, t2_view p WHERE e.id = p.id ORDER BY e.id;
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e LEFT JOIN t2_view p ON e.id = p.id ORDER BY e.id;
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e RIGHT JOIN t2_view p ON e.id = p.id ORDER BY e.id;
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e INNER JOIN t2_view p ON e.id = p.id WHERE statement_digest_text(e.c2) LIKE '%+%'  ORDER BY e.id;

--echo ##SELECT嵌套
--echo #SELECT
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM (SELECT id,c1,c2 FROM t1_view WHERE statement_digest_text(c2) LIKE '%+%') e ORDER BY e.id;

--echo #EXISTS / NOT EXISTS
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e WHERE EXISTS (SELECT statement_digest(p.c1) FROM t2_view p WHERE statement_digest(p.c1) like '%5F%' ) ORDER BY e.id;
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t2_view e WHERE NOT EXISTS (SELECT statement_digest(p.id) FROM t2_view p WHERE statement_digest_text(p.c2)  like '%drop%' ) ORDER BY e.id;

--echo #ANY
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e WHERE statement_digest(e.c1) = ANY (SELECT statement_digest(p.c1) FROM t2_view p) ORDER BY e.id;
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e WHERE statement_digest_text(e.c2) < ANY (SELECT statement_digest_text(p.c2) FROM t2_view p) ORDER BY e.id;

--echo #ALL 
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e WHERE statement_digest(e.c1) = ALL (SELECT statement_digest(p.c1) FROM t2_view p WHERE p.id = 1) ORDER BY e.id;
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e WHERE statement_digest_text(e.c2) <= ALL (SELECT statement_digest_text(p.c2) FROM t2_view p WHERE p.id <= 3) ORDER BY e.id;

--echo #CREATE AS 
CREATE VIEW t3_view AS SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e; 
SELECT * FROM t3_view ORDER BY id;

--echo #WITH AS的SELECT
WITH a AS (SELECT id,c1,statement_digest(c1) digest FROM t1_view WHERE id<3) SELECT a.id,a.c1,a.digest FROM a ORDER BY a.id;
WITH a AS (SELECT id,c1,statement_digest_text(c2) digest_text FROM t1_view WHERE id<4) SELECT a.id,a.c1,a.digest_text FROM a ORDER BY a.id;

--echo #模糊查询like 
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e WHERE statement_digest(e.c1) LIKE '%B%' ORDER BY e.id;
SELECT e.id,statement_digest(e.c1) digest,statement_digest_text(e.c2) digest_text FROM t1_view e WHERE statement_digest_text(e.c2) NOT LIKE '%alter%' ORDER BY e.id;

--echo ### update
UPDATE t1_view SET c1 = 'INSERT INTO t1 VALUES(15,25,35)' WHERE statement_digest(c1) = statement_digest('INSERT INTO t1(col1,col2) VALUES(15,25)');
UPDATE t1_view SET c2 = 'INSERT INTO t1(col1,col2) VALUES(16,col1*3/4)' WHERE statement_digest_text(c2) like '%*%' ORDER BY statement_digest_text(c2) DESC;
UPDATE t1_view SET c1 = 'UPDATE t1 SET id = id * 2' WHERE id = (SELECT id FROM t2_view WHERE statement_digest_text(c1) like '%+%');
SELECT id,c1,c2 FROM t1_view ORDER BY id;

--echo ###delete
SELECT * FROM  t2_view ORDER BY id;
DELETE FROM t2_view WHERE statement_digest(c1) = statement_digest('DELETE FROM t1 WHERE c1 = "whh"') ORDER BY statement_digest(c1);
DELETE FROM t2_view WHERE statement_digest_text(c2) LIKE '%<%' ORDER BY statement_digest(c1);
SELECT * FROM  t2_view ORDER BY id;


--echo ######################### 标签：digest-6-2 索引 #########################
--error 0,1091
DROP INDEX `digest_index1` ON digest_table1;
--error 0,1091
DROP INDEX `digest_index2` ON digest_table1;

CREATE INDEX digest_index1 ON digest_table1(id);
ALTER TABLE digest_table1 ADD INDEX digest_index2(id);

--echo #insert 
insert into digest_table2 SELECT id+5,c1,statement_digest(c1),statement_digest_text(c1) FROM digest_table1 e WHERE id < 2;
SELECT * FROM digest_table2 ORDER BY id;

--echo #update 
UPDATE digest_table2 set sqls = 'INSERT INTO t1 VALUES(15,25*3)' WHERE digest = statement_digest('INSERT INTO t1 VALUES(15,25)');
SELECT * FROM digest_table2 ORDER BY id;

UPDATE digest_table2 set digest_text = statement_digest_text('UPDATE t1 SET id = id * 1') WHERE id = 3;
SELECT *  FROM digest_table2 ORDER BY id;

--echo #SELECT 
SELECT id,statement_digest(c1) digest,statement_digest_text(c2) digest_text FROM digest_table1 e WHERE statement_digest_text(c2) LIKE '%INSERT%' ORDER BY e.id;
SELECT id,statement_digest(c1) digest,statement_digest_text(c2) digest_text FROM digest_table1 e WHERE statement_digest_text(c2) LIKE '%UPDATE%' order by statement_digest(e.c2) desc;

--echo #delete 
SELECT count(*) FROM digest_table2;
DELETE FROM digest_table2 WHERE digest = statement_digest('SELECT * FROM tl WHERE id < 20');
SELECT * FROM digest_table2 ORDER BY id;


--echo ######################### 标签：digest-6-3 约束 #########################
--error 0,1051
DROP TABLE digest_table1;
CREATE TABLE `digest_table1` (
  `id` int PRIMARY KEY,
  `sqls` varchar(255)  NOT NULL,
  `digest` varchar(255) UNIQUE,
  `digest_text` varchar(255) NOT NULL
);

--echo #insert 
INSERT INTO digest_table1 VALUES(1,'INSERT INTO t1 VALUES(15,25)',statement_digest('INSERT INTO t1 VALUES(15,25)'),statement_digest_text('INSERT INTO t1 VALUES(15,25)'));
INSERT INTO digest_table1 VALUES(2,'DELETE FROM t1 WHERE c1 = "whh"',statement_digest('DELETE FROM t1 WHERE c1 = "whh"'),statement_digest_text('DELETE FROM t1 WHERE c1 = "whh"'));
INSERT INTO digest_table1 VALUES(3,'UPDATE t1 SET id = id + 1',statement_digest('UPDATE t1 SET id = id + 1'),statement_digest_text('UPDATE t1 SET id = id + 1'));
INSERT INTO digest_table1 VALUES(4,'SELECT * FROM tl WHERE id < 20',statement_digest('SELECT * FROM tl WHERE id < 20'),statement_digest_text('SELECT * FROM tl WHERE id < 20'));
SELECT * FROM digest_table1 ORDER BY id;

--echo #update 
UPDATE digest_table1 set sqls = 'INSERT INTO t1 VALUES(15,25*3)',digest_text=statement_digest_text('INSERT INTO t1 VALUES(15,25*3)') WHERE digest = statement_digest('INSERT INTO t1 VALUES(15,25)');
SELECT * FROM digest_table1 ORDER BY id;

--echo #SELECT 
SELECT * FROM digest_table1 WHERE digest = statement_digest('UPDATE t1 SET id = id + 1') ORDER BY id;
SELECT * FROM digest_table1 WHERE digest_text LIKE '%?%' ORDER BY id;

--echo #delete 
SELECT count(*) FROM digest_table1;
DELETE FROM digest_table1 WHERE digest = statement_digest('DELETE FROM t1 WHERE c1 = "whh"');
SELECT * FROM digest_table1 ORDER BY id;


