purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 语句摘要函数-statement_digest(statement)/statement_digest_text(statement)--------------
--echo ###### 标签：digest-2 statement_digest(statement)/statement_digest_text(statement) - 参数类型 
--echo -----------------------------------------------------------------------------------------------------------------

--echo ######################### 标签：digest-2-1 参数类型 - 数值类型 #########################
--error 0,1051
DROP TABLE digest_table1;
CREATE TABLE digest_table1( 
  c1 tinyint, 
  c2 smallint,
  c3 mediumint, 
  c4 int, 
  c5 bigint, 
  c6 float, 
  c7 double, 
  c8 DECIMAL(5,2), 
  c9 bit(10)
);

--echo ## 没有插入数据场合
select statement_digest(c1) digest,statement_digest_text(c1) digest_text from digest_table1;
select statement_digest(c2) digest,statement_digest_text(c2) digest_text from digest_table1;
select statement_digest(c3) digest,statement_digest_text(c3) digest_text from digest_table1;
select statement_digest(c4) digest,statement_digest_text(c4) digest_text from digest_table1;
select statement_digest(c5) digest,statement_digest_text(c5) digest_text from digest_table1;
select statement_digest(c6) digest,statement_digest_text(c6) digest_text from digest_table1;
select statement_digest(c7) digest,statement_digest_text(c7) digest_text from digest_table1;
select statement_digest(c8) digest,statement_digest_text(c8) digest_text from digest_table1;
select statement_digest(c9) digest,statement_digest_text(c9) digest_text from digest_table1;


