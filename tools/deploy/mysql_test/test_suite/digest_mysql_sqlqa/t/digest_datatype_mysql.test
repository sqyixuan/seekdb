insert into digest_table1 values('INSERT INTO t1(col1,col2) VALUES(17,col1*4)','DELETE FROM t1 WHERE c1 = "zhx" ORDER BY c1 LIMIT 20','UPDATE t1 SET id = id + 5 ORDER BY id DESC LIMIT 30','SELECT * FROM tl WHERE id = 20 ORDER BY c1,c2 LIMIT 5,10','SELECT SLEEP(20)','DROP DATABASE test_db3','SELECT * FROM tl WHERE id < 20 ORDER BY c1,c2 LIMIT 1,5','SELECT * FROM t2 WHERE id >= 20 ORDER BY c1 LIMIT 5');

