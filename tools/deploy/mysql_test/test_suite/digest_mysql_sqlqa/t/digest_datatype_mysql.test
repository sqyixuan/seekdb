--echo ##通用函数
SELECT IFNULL(NULL,statement_digest('UPDATE t1 SET id = id + 1')) digest,IFNULL(statement_digest_text('UPDATE t1 SET id = id + 1'),NULL) digest_text FROM dual;
SELECT statement_digest(IFNULL(NULL,'UPDATE t1 SET id = id + 3')) digest,statement_digest_text(IFNULL(NULL,'UPDATE t1 SET id = id + 3')) digest_text FROM dual;

SELECT COALESCE(NULL,statement_digest('DELETE FROM t1 WHERE c1 = "jcole" ')) digest,COALESCE(statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole" '),NULL) digest_text FROM dual;
SELECT statement_digest(COALESCE(NULL,'DELETE FROM t1 WHERE c1 = "whh" ')) digest,statement_digest_text(COALESCE(NULL,'DELETE FROM t1 WHERE c1 = "whh" ')) digest_text FROM dual;


--echo ######################### 标签：digest-4-2 函数间嵌套 - 多级函数嵌套 #########################
--echo ## statement_digest 自己嵌套自己
select statement_digest('SELECT * FROM tl WHERE id < 20') digest from dual;
--error 1064
select statement_digest(statement_digest('SELECT * FROM tl WHERE id < 20')) digest from dual;
--error 1064
select statement_digest(statement_digest(statement_digest('SELECT * FROM tl WHERE id < 20'))) digest from dual;
--error 1064
select statement_digest(statement_digest(statement_digest(statement_digest('SELECT * FROM tl WHERE id < 20')))) digest from dual;

--echo ## statement_digest_text 自己嵌套自己
select statement_digest_text('SELECT * FROM tl WHERE id < 20') digest_text from dual;
--echo ##issue:41146768 bug7: 语句摘要函数 statement_digest()/statement_digest_text(),参数的SQL语句含有?，mysql失败，ob成功。
--error 1210
select statement_digest_text(statement_digest_text('SELECT * FROM tl WHERE id < 20')) digest_text from dual;
--error 1210
