--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 语句摘要函数-statement_digest(statement)/statement_digest_text(statement)-----------------
--echo ### 用例：compress-3 statement_digest(statement)/statement_digest_text(statement) - pl/sql
--echo -----------------------------------------------------------------------------------------------------------------

--error 0,1051
DROP TABLE digest_table1;//
CREATE TABLE `digest_table1` (
  `id` varchar(255) PRIMARY KEY,
  `sqls` varchar(255)  NOT NULL  COMMENT 'SQL语句',
  `comments` varchar(255)
);//

INSERT INTO digest_table1 VALUES(1,'INSERT INTO t1 VALUES(15,25)','INSERT 语句');//
INSERT INTO digest_table1 VALUES(2,'DELETE FROM t1 WHERE c1 = "whh"','DELETE 语句');//
INSERT INTO digest_table1 VALUES(3,'UPDATE t1 SET id = id + 1','UPDATE 语句');//
INSERT INTO digest_table1 VALUES(4,'SELECT * FROM tl WHERE id < 20','SELECT 语句');//


--error 0,1051
DROP TABLE digest_table2;//
CREATE TABLE `digest_table2` (
  `id` varchar(255) PRIMARY KEY,
  `sqls` varchar(255)  NOT NULL COMMENT 'SQL语句',
  `digest` varchar(255) NOT NULL COMMENT 'SQL 语句的摘要哈希值',
  `digest_text` varchar(255) NOT NULL COMMENT 'SQL 语句对应的摘要文本',
  `comments` varchar(255)
);//

INSERT INTO digest_table2 VALUES(0,'SELECT * FROM tl WHERE id = 20',statement_digest('SELECT * FROM tl WHERE id = 20'),statement_digest_text('SELECT * FROM tl WHERE id = 20'),'默认初始数据：SELECT 语句');//

--echo ######################### 标签：digest-7-1 pl/sql - 存储过程  #########################   
--echo ##无参数的存储过程
--error 0,1305
DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest()
begin
	declare a varchar(255);
	declare b varchar(255);
	declare c varchar(255);
	declare d varchar(255);
	SELECT id,sqls,statement_digest(sqls),statement_digest_text(sqls) into a,b,c,d FROM digest_table1 WHERE statement_digest(sqls) = statement_digest('INSERT INTO t1 VALUES(15,25)');
    INSERT INTO digest_table2 VALUES(a,b,c,d,'INSERT 语句');
	INSERT INTO digest_table2 VALUES(10,'INSERT INTO t1 VALUES(15,25*4)',statement_digest('INSERT INTO t1 VALUES(15,25*4)'),statement_digest_text('INSERT INTO t1 VALUES(15,25*4)'),'INSERT 语句');
END;
//

SELECT COUNT(*) FROM digest_table2;//
CALL p_digest();//
SELECT * FROM digest_table2 ORDER BY id;//


--echo ##只有一个in参数的存储过程
--error 0,1305
DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest(in invalue varchar(255))
begin
	declare a varchar(255);
	declare b varchar(255);
	declare c varchar(255);
	declare d varchar(255);
	SELECT id,sqls,statement_digest(sqls),statement_digest_text(sqls) into a,b,c,d FROM digest_table1 WHERE statement_digest(sqls) = invalue;
	INSERT INTO digest_table2 VALUES(a,b,c,d,'DELETE 语句');
	INSERT INTO digest_table2 VALUES(20,'DELETE FROM t1 WHERE c1 = "whh2"',statement_digest('DELETE FROM t1 WHERE c1 = "whh2"'),statement_digest_text('DELETE FROM t1 WHERE c1 = "whh2"'),'DELETE 语句');
END;
//

SELECT COUNT(*) FROM digest_table2;//
CALL p_digest(statement_digest('DELETE FROM t1 WHERE c1 = "whh"'));//
SELECT * FROM digest_table2 ORDER BY id;//


--echo ##包含out参数的存储过程
--error 0,1305
DROP PROCEDURE p_digest;//
CREATE  PROCEDURE p_digest(out outa varchar(255),OUT outb varchar(200),OUT outc varchar(200))
begin
    declare i int default 9;
	SELECT id,statement_digest(sqls),statement_digest_text(sqls) into outa,outb,outc FROM digest_table1 WHERE statement_digest_text(sqls) like '%UPDATE%';
	INSERT INTO digest_table2 VALUES(30,'UPDATE t1 SET id = id + 6',statement_digest('UPDATE t1 SET id = id + 6'),statement_digest_text('UPDATE t1 SET id = id + 6'),'UPDATE 语句');
END;
//

SELECT COUNT(*) FROM digest_table2;//
CALL p_digest(@outa,@outb,@outc);//
SELECT * FROM digest_table2 ORDER BY id;//
SELECT @outa,@outb,@outc FROM dual;//


--echo ##包含inout参数的存储过程
--error 0,1305
DROP PROCEDURE p_digest;//
CREATE  PROCEDURE p_digest(INOUT inouta varchar(255),OUT outb varchar(200),OUT outc varchar(200))
begin
    declare invalue varchar(255);
	set invalue := inouta;
	SELECT id,statement_digest(sqls),statement_digest_text(sqls) into inouta,outb,outc FROM digest_table1 WHERE statement_digest_text(sqls) = invalue;
    INSERT INTO digest_table2 VALUES(40,'SELECT * FROM tl WHERE id < 20',statement_digest('SELECT * FROM tl WHERE id < 20'),statement_digest_text('SELECT * FROM tl WHERE id < 20'),'SELECT 语句');
END;
//

SELECT COUNT(*) FROM digest_table1;//
SET @inouta := statement_digest_text('SELECT * FROM tl WHERE id < 1');//
CALL p_digest(@inouta,@outb,@outc);//
SELECT * FROM digest_table2 ORDER BY id;//
SELECT @outa,@outb,@outc FROM dual;//


--echo ##dml语句
--echo #条件语句
--error 0,1305
DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest(IN invalue varchar(255),IN ina varchar(255),IN inb varchar(200),IN inc varchar(200))
begin
    IF statement_digest_text(invalue) = 'SELECT ?' THEN 
	   INSERT INTO digest_table1 VALUES(5,invalue,'desc 语句');
    ELSE 
	   INSERT INTO digest_table2 VALUES(50,ina,inb,inc,'call 语句');
    END IF;
END;
//

SELECT COUNT(*) FROM digest_table1;//
SELECT COUNT(*) FROM digest_table2;//
SET @invalue := 'SELECT "digest_table1"';//
SET @ina := 'call p_digest(@invalue,@ina,@inb,@inc)';//
SET @inb := statement_digest('call p_digest(@invalue,@ina,@inb,@inc)');//
SET @inc := statement_digest_text('call p_digest(@invalue,@ina,@inb,@inc)');//
CALL p_digest(@invalue,@ina,@inb,@inc);//
SELECT id,sqls FROM digest_table1 ORDER BY id;//
SELECT id,sqls,digest,digest_text FROM digest_table2 ORDER BY id;//

SELECT COUNT(*) FROM digest_table1;//
SELECT COUNT(*) FROM digest_table2;//
SET @invalue := 'SELECT 1+2';//
SET @ina := 'call p_digest(@invalue,@ina,@inb,@inc)';//
SET @inb := statement_digest('call p_digest(@invalue,@ina,@inb,@inc)');//
SET @inc := statement_digest_text('call p_digest(@invalue,@ina,@inb,@inc)');//
CALL p_digest(@invalue,@ina,@inb,@inc);//
SELECT id,sqls FROM digest_table1 ORDER BY id;//
SELECT id,sqls,digest,digest_text FROM digest_table2 ORDER BY id;//


--echo #循环语句
--error 0,1305
DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest()
begin
    declare i int default 51;
    WHILE i <= 52 do
      INSERT INTO digest_table2 VALUES(i,'ALTER TABLE t1 COMMENT = "WHILE 循环语句插入的"',statement_digest('ALTER TABLE t1 COMMENT ="WHILE 循环语句插入的"'),statement_digest_text('ALTER TABLE t1 COMMENT ="WHILE 循环语句插入的"'),'ALTER 语句');
      set i := i+1;
    END WHILE;

    loop_sqls:LOOP
      INSERT INTO digest_table2 VALUES(i,'ALTER TABLE t1 COMMENT ="LOOP 循环语句插入的"',statement_digest('ALTER TABLE t1 COMMENT ="LOOP 循环语句插入的"'),statement_digest_text('ALTER TABLE t1 COMMENT ="LOOP 循环语句插入的"'),'ALTER 语句');
      SET i := i+1;
      IF i > 54 THEN 
	    LEAVE loop_sqls;
      END IF;
    END LOOP loop_sqls;

    REPEAT
      INSERT INTO digest_table2 VALUES(i,'ALTER TABLE t1 COMMENT ="REPEAT 循环语句插入的"',statement_digest('ALTER TABLE t1 COMMENT ="REPEAT 循环语句插入的"'),statement_digest_text('ALTER TABLE t1 COMMENT ="REPEAT 循环语句插入的"'),'ALTER 语句');
      SET i := i+1;
      until i > 56	
    END REPEAT;
END;
//

SELECT COUNT(*) FROM digest_table2;//
CALL p_digest();//
SELECT * FROM digest_table2 ORDER BY id;//


--echo ##游标
--error 0,1305
DROP PROCEDURE test_pro;//
CREATE PROCEDURE test_pro()
BEGIN
	DECLARE a,b,c varchar(255);
    DECLARE i int default 60;
	DECLARE done INT DEFAULT 0;
	DECLARE digest_cursor CURSOR FOR SELECT sqls,statement_digest(sqls),statement_digest_text(sqls) FROM digest_table1 WHERE id < 5 and statement_digest(sqls) <> 0 GROUP BY statement_digest_text(sqls) HAVING statement_digest_text(sqls) like '%?%';
	DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
	
	OPEN digest_cursor;
	FETCH digest_cursor INTO a,b,c;
	WHILE done<>1 DO
      INSERT INTO digest_table2 VALUES(i,a,b,c,'游标中数据');
      FETCH digest_cursor INTO a,b,c;
	  SET i := i+1;
	END WHILE;
	CLOSE digest_cursor;
END;
//

SELECT COUNT(*) FROM digest_table2;//
CALL test_pro();//
SELECT id,sqls,digest,digest_text FROM digest_table2 ORDER BY id;//


--echo ##动态sql
--error 0,1305
DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest()
BEGIN
  SET @s = 'INSERT INTO digest_table1 VALUES(7,?,?);';
  PREPARE stmdigest_table1 FROM @s;
  SET @a = 'DELETE FROM t1 PARTITION (p0) WHERE c1 < 5';
  SET @b = 'PREPARE 动态sql - add1';
  EXECUTE stmdigest_table1 USING @a,@b;

  SET @s = 'INSERT INTO digest_table2 VALUES(70,?,?,?,?);';
  PREPARE stmt2 FROM @s;
  SET @a = 'DELETE FROM t1 PARTITION (p0) WHERE c1 < 5';
  SET @b = statement_digest(@a);
  SET @c = statement_digest_text(@a);
  SET @d = 'PREPARE 动态sql - add1';
  EXECUTE stmt2 USING @a,@b,@c,@d;
END;
//

SELECT COUNT(*) FROM digest_table1 ORDER BY id;//
SELECT COUNT(*) FROM digest_table2 ORDER BY id;//
CALL p_digest();//
SELECT * FROM digest_table1 ORDER BY id;//
SELECT * FROM digest_table2 ORDER BY id;//


--error 0,1305
DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest()
BEGIN
  SET @s = 'update digest_table2 set sqls = ?,digest=?, digest_text= ?,comments = ? WHERE digest = statement_digest(?)';
  PREPARE stmdigest_table1 FROM @s;
  SET @a = 'DELETE FROM t1 PARTITION (p0) WHERE c1 < 5*10';
  SET @b = statement_digest(@a);
  SET @c = statement_digest_text(@a);
  SET @d = 'PREPARE 动态sql - update 语句';
  SET @e = 'DELETE FROM t1 PARTITION (p0) WHERE c1 < 5';
  EXECUTE stmdigest_table1 USING @a,@b,@c,@d,@e;

  SET @s = 'SELECT * FROM digest_table2 WHERE digest_text = ?';
  PREPARE stmt2 FROM @s;
  SET @a = 'DELETE FROM t1 PARTITION (p0) WHERE c1 < ?*?';
  EXECUTE stmt2 USING @a; 
  
  SET @s = 'delete FROM digest_table1 WHERE statement_digest(sqls) = ?';
  PREPARE stmdigest_table1 FROM @s;
  SET @a = statement_digest('DELETE FROM t1 PARTITION (p0) WHERE c1 < 5');
  EXECUTE stmdigest_table1 USING @a;

  SET @s = 'SELECT id,sqls,statement_digest(sqls),statement_digest_text(sqls) FROM digest_table1 WHERE id = ?';
  PREPARE stmt2 FROM @s;
  SET @a = 7;
  EXECUTE stmt2 USING @a;  
END;
//

CALL p_digest();//
SELECT * FROM digest_table1 ORDER BY id;//
SELECT * FROM digest_table2 ORDER BY id;//


--echo ##函数返回值作为存储过程的参数传递
--error 0,1305
DROP FUNCTION f_digest;//
CREATE FUNCTION f_digest(insqls varchar(255)) RETURNS varchar(255) READS SQL DATA 
BEGIN
	declare b varchar(255);
	SELECT sqls,statement_digest(sqls) into @sqls,b FROM digest_table1 WHERE statement_digest(sqls) = insqls;
	RETURN b;
END;
//

--error 0,1305
DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest(in infun varchar(255))
begin
  	INSERT INTO digest_table2 VALUES(80,@sqls,infun,statement_digest_text(@sqls),'函数返回值作为存储过程的参数传递');
END;
//

SELECT COUNT(*) FROM digest_table2;//
CALL p_digest(f_digest(statement_digest('UPDATE t1 SET id = id + 1')));//
SELECT * FROM digest_table2 ORDER BY id;//


-- echo #自定义变量，全局变量，in 参数作为 statement_digest/statement_digest_text 函数的参数
--error 0,1305
DROP PROCEDURE p_digest;//
CREATE PROCEDURE p_digest(IN inc varchar(200))
begin
  declare a varchar(200);
  SET a := 'DELETE FROM t1 WHERE c1 <= 10';
  INSERT INTO digest_table2 VALUES(81,statement_digest(a),statement_digest_text(a),statement_digest_text(a),'自定义变量作为语句摘要函数的参数');
  INSERT INTO digest_table2 VALUES(82,statement_digest(@b),statement_digest_text(@b),statement_digest_text(@b),'全局变量作为语句摘要函数的参数');
  INSERT INTO digest_table2 VALUES(83,statement_digest(inc),statement_digest_text(inc),statement_digest_text(inc),'形参变量作为语句摘要函数的参数');
END;
//

SELECT COUNT(*) FROM digest_table2;//
SET @b := 'DELETE FROM t1 WHERE c1 >= 10';//
CALL p_digest('DELETE FROM t1 WHERE c1 = 10');//
SELECT * FROM digest_table2 ORDER BY id;//


--echo ######################### 标签：digest-7-2 pl/sql - 函数  #########################   
--echo #定义一个无参的函数
--error 0,1305
drop function f_digest;//
CREATE FUNCTION f_digest() returns varchar(255) READS SQL DATA 
begin
	declare b varchar(255);
	SELECT sqls,statement_digest_text(sqls) into @a,b FROM digest_table1 WHERE statement_digest(sqls) = statement_digest('UPDATE t1 SET id = id + 1');
	return b;
END;
//

SELECT f_digest() FROM dual;//
SELECT statement_digest_text(@a) FROM dual;//


--echo #定义一个有参的函数
--error 0,1305
DROP FUNCTION f_digest;//
CREATE FUNCTION f_digest(invalue varchar(255)) returns varchar(255) READS SQL DATA 
begin
	declare a varchar(255);
	SELECT digest_text into a FROM digest_table2 WHERE digest = invalue;
	return a;
END ;
//

SELECT f_digest(statement_digest('SELECT * FROM tl WHERE id = 20'));//


--echo ##dml语句
--echo #条件语句
--error 0,1305
DROP FUNCTION f_digest;//
CREATE FUNCTION f_digest(invalue varchar(255),ina varchar(255),inb varchar(255),inc varchar(255))returns varchar(200) DETERMINISTIC
begin
    IF statement_digest_text(invalue) = 'SELECT ?' THEN 
	   INSERT INTO digest_table1 VALUES(9,ina,'调用函数语句');
    ELSE
	   INSERT INTO digest_table2 VALUES(90,ina,inb,inc,'调用函数语句');
    END IF;
    return '函数执行成功';
END;
//

SELECT COUNT(*) FROM digest_table1;//
SELECT COUNT(*) FROM digest_table2;//
SET @invalue := 'SELECT 1';//
SET @ina := 'SELECT f_digest(@invalue,@ina,@inb,@inc)';//
SET @inb := statement_digest('SELECT f_digest(@invalue,@ina,@inb,@inc)');//
SET @inc := statement_digest_text('SELECT f_digest(@invalue,@ina,@inb,@inc)');//
SELECT f_digest(@invalue,@ina,@inb,@inc);//
SELECT id,sqls FROM digest_table1 ORDER BY id;//
SELECT id,sqls,digest,digest_text FROM digest_table2 ORDER BY id;//

SELECT COUNT(*) FROM digest_table1;//
SELECT COUNT(*) FROM digest_table2;//
SET @invalue := 'SELECT 1+2';//
SET @ina := 'SELECT f_digest(@invalue,@ina,@inb,@inc)';//
SET @inb := statement_digest('SELECT f_digest(@invalue,@ina,@inb,@inc)');//
SET @inc := statement_digest_text('SELECT f_digest(@invalue,@ina,@inb,@inc)');//
SELECT f_digest(@invalue,@ina,@inb,@inc);//
SELECT id,sqls FROM digest_table1 ORDER BY id;//
SELECT id,sqls,digest,digest_text FROM digest_table2 ORDER BY id;//


--echo #循环语句
--error 0,1305
DROP FUNCTION f_digest;//
CREATE FUNCTION f_digest() returns varchar(255) DETERMINISTIC
begin
    declare i int default 91;
    WHILE i <= 92 do
      INSERT INTO digest_table2 VALUES(i,'ALTER TABLE t1 COMMENT = "WHILE 循环语句插入的"',statement_digest('ALTER TABLE t1 COMMENT ="WHILE 循环语句插入的"'),statement_digest_text('ALTER TABLE t1 COMMENT ="WHILE 循环语句插入的"'),'ALTER 语句');
      set i := i+1;
    END WHILE;

    loop_sqls:LOOP
      INSERT INTO digest_table2 VALUES(i,'ALTER TABLE t1 COMMENT ="LOOP 循环语句插入的"',statement_digest('ALTER TABLE t1 COMMENT ="LOOP 循环语句插入的"'),statement_digest_text('ALTER TABLE t1 COMMENT ="LOOP 循环语句插入的"'),'ALTER 语句');
      SET i := i+1;
      IF i > 94 THEN 
	    LEAVE loop_sqls;
      END IF;
    END LOOP loop_sqls;

    REPEAT
      INSERT INTO digest_table2 VALUES(i,'ALTER TABLE t1 COMMENT ="REPEAT 循环语句插入的"',statement_digest('ALTER TABLE t1 COMMENT ="REPEAT 循环语句插入的"'),statement_digest_text('ALTER TABLE t1 COMMENT ="REPEAT 循环语句插入的"'),'ALTER 语句');
      SET i := i+1;
      until i > 96	
    END REPEAT;
	return '函数执行成功';
END;
//

SELECT COUNT(*) FROM digest_table2;//
SELECT f_digest();//
SELECT * FROM digest_table2 ORDER BY id;//


--echo ######################### 标签：digest-7-3 pl/sql - 触发器  ######################### 
--error 0,1360
DROP TRIGGER tri_digest;//
CREATE TRIGGER tri_digest BEFORE INSERT
ON digest_table1 FOR EACH ROW
BEGIN
	DECLARE a int default 21;
	-- 循环insert插入5条数据(21,22,23,24,25)，id=24数据delete删除，id=25数据update修改
	loop1: LOOP
	  if a < 26 then
	    INSERT INTO digest_table2 VALUES(a,'DROP TRIGGER tri_digest',statement_digest('DROP TRIGGER tri_digest'),statement_digest_text('DROP TRIGGER tri_digest'),concat('触发器中插入数据',a));
	  elseif a = 27 then
	    UPDATE digest_table2 set sqls = 'DELETE FROM t1 WHERE c1 = "jcole"',digest = statement_digest('DELETE FROM t1 WHERE c1 = "jcole"'),digest_text = statement_digest_text('DELETE FROM t1 WHERE c1 = "jcole"'),comments = concat('触发器中修改数据',a-2) WHERE id = 25;
	    LEAVE loop1;
	  else
	    DELETE FROM digest_table2 WHERE id = 24;	
	  end if;
	  set a = a + 1;
	end LOOP loop1;
END;
//

SELECT COUNT(*)  FROM digest_table1 ORDER BY id;//
SELECT COUNT(*)  FROM digest_table2 ORDER BY id;//
INSERT INTO digest_table1 VALUES(00,'DROP TRIGGER tri_digest','插入数据，触发触发器tri_digest');//
SELECT * FROM digest_table1 ORDER BY id;//
SELECT * FROM digest_table2 ORDER BY id;//


DELIMITER ;//

