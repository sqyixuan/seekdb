--error 0,1051
DROP TABLE digest_table1;
CREATE TABLE digest_table1( 
  `id` varchar(255) PRIMARY KEY,
  `sqls` varchar(255)  NOT NULL  COMMENT 'SQL语句',
  `comments` varchar(255) COMMENT '备注信息'
);

insert into digest_table1 values(1,'INSERT INTO t1(col1,col2) VALUES(15,25)','INSERT 语句');
insert into digest_table1 values(2,'DELETE FROM t1 WHERE c1 = "whh"','DELETE 语句');
insert into digest_table1 values(3,'UPDATE t1 SET id = id + 1','UPDATE 语句');
insert into digest_table1 values(4,'SELECT * FROM tl WHERE id < 20','SELECT 语句');

--error 0,1051
DROP TABLE digest_table2;
CREATE TABLE `digest_table2` (
  `id` int PRIMARY KEY,
  `sqls` varchar(255) NOT NULL COMMENT 'SQL 语句',
  `digest` varchar(255) NOT NULL DEFAULT '' COMMENT 'SQL 语句的摘要哈希值',
  `digest_text` varchar(255) NOT NULL DEFAULT '' COMMENT 'SQL 语句对应的摘要文本',
  `comments` varchar(255) COMMENT '备注信息'
);

INSERT INTO digest_table2 VALUES(3,'INSERT INTO t1 VALUES(15,25)',statement_digest('INSERT INTO t1 VALUES(15,25)'),statement_digest_text('INSERT INTO t1 VALUES(15,25)'),'INSERT 语句');
INSERT INTO digest_table2 VALUES(4,'DELETE FROM t1 WHERE c1 = "whh"',statement_digest('DELETE FROM t1 WHERE c1 = "whh"'),statement_digest_text('DELETE FROM t1 WHERE c1 = "whh"'),'DELETE 语句');
INSERT INTO digest_table2 VALUES(5,'UPDATE t1 SET id = id + 1',statement_digest('UPDATE t1 SET id = id + 1'),statement_digest_text('UPDATE t1 SET id = id + 1'),'UPDATE 语句');
INSERT INTO digest_table2 VALUES(6,'SELECT * FROM tl WHERE id < 20',statement_digest('SELECT * FROM tl WHERE id < 20'),statement_digest_text('SELECT * FROM tl WHERE id < 20'),'SELECT 语句');


--error 0,1051
DROP TABLE digest_table3;

--error 0,1051
DROP TABLE digest_table4;
CREATE TABLE `digest_table4` (
  `id` int PRIMARY KEY,
  `sqls` varchar(255),
  `digest` varchar(255),
  `digest_text` varchar(255),
  `comments` varchar(255)
);


--echo ######################### 标签：digest-8-1 SELECT #########################
--echo ### SELECT
--echo ##多列/单列
select id,sqls,statement_digest(sqls) digest,statement_digest_text(sqls) digest_text from digest_table1 ORDER BY id;
--echo ##issue:41063613 bug5: 
--error 1064
select id,sqls,statement_digest(CONCAT(sqls,';',id)) digest,statement_digest_text(CONCAT(sqls,';',id)) digest_text from digest_table1 ORDER BY id;

--echo ##where 子句
SELECT id,sqls,statement_digest(sqls) digest,statement_digest_text(sqls) digest_text FROM digest_table1 WHERE statement_digest(sqls) = '0B04B6E5D86365612449D928C5F14D8B';
SELECT id,sqls,statement_digest_text(sqls) digest_text FROM digest_table1 WHERE statement_digest_text(sqls) like '%+%';
SELECT id,sqls,statement_digest(sqls) digest,statement_digest_text(sqls) digest_text FROM digest_table1 WHERE statement_digest(sqls) = statement_digest('SELECT * FROM tl WHERE id < 20');

--echo ##order by 子句
SELECT id,statement_digest(sqls) digest,statement_digest_text(sqls) digest_text FROM digest_table1 ORDER BY statement_digest(sqls);
SELECT id,statement_digest(sqls) digest,statement_digest_text(sqls) digest_text FROM digest_table1 ORDER BY statement_digest(sqls) DESC;
SELECT id,statement_digest(sqls) digest,statement_digest_text(sqls) digest_text FROM digest_table1 ORDER BY statement_digest_text(sqls);
SELECT id,statement_digest(sqls) digest,statement_digest_text(sqls) digest_text FROM digest_table1 ORDER BY statement_digest_text(sqls) ASC;

--echo ##group by having 子句
SELECT id,statement_digest(sqls) digest,statement_digest_text(sqls) digest_text FROM digest_table1 GROUP BY statement_digest(sqls) ORDER BY id;
SELECT id,statement_digest(sqls) digest,statement_digest_text(sqls) digest_text FROM digest_table1 GROUP BY statement_digest_text(sqls),id ORDER BY id ;
SELECT id,statement_digest(sqls) digest,statement_digest_text(sqls) digest_text FROM digest_table1 GROUP BY statement_digest(sqls) HAVING digest > statement_digest('DELETE FROM t1 WHERE c1 = "qwer"') ORDER BY id;

--echo #DISTINCT
SELECT distinct statement_digest(sqls) digest,id,sqls FROM digest_table1 e ORDER BY id;
SELECT distinct statement_digest_text(sqls),id,sqls FROM digest_table1 e ORDER BY id;

--echo #CASE WHEN
SELECT id,statement_digest(CASE WHEN sqls IS NULL THEN 'select "NULL"' ELSE sqls END) digest,statement_digest_text(CASE WHEN sqls IS NULL THEN 'select "NULL"' ELSE sqls END) digest_text FROM digest_table1  ORDER BY id;
SELECT id,CASE WHEN statement_digest(sqls)= statement_digest('DELETE FROM t1 WHERE c1 = "whh"') THEN 'statement_digest（DELETE 语句）'  ELSE '其他' END digest FROM digest_table1 ORDER BY id; 
SELECT id,CASE WHEN statement_digest_text(sqls) LIKE '%INSERT%' THEN 'statement_digest_text（INSERT 语句）' ELSE '其他' END digest_text FROM digest_table1 ORDER BY id; 

--echo ##连接查询
SELECT e.id,statement_digest(e.sqls) digest,statement_digest_text(e.sqls) digest_text FROM digest_table1 e, digest_table2 p WHERE statement_digest(e.sqls) = p.digest ORDER BY e.id;
SELECT e.id,statement_digest(e.sqls) digest,statement_digest_text(e.sqls) digest_text FROM digest_table1 e LEFT JOIN digest_table2 p ON statement_digest_text(e.sqls) = p.digest_text ORDER BY e.id;
SELECT e.id,statement_digest(e.sqls) digest,statement_digest_text(e.sqls) digest_text FROM digest_table1 e RIGHT JOIN digest_table2 p ON e.id = p.id ORDER BY e.id;
SELECT e.id,statement_digest(e.sqls) digest,statement_digest_text(e.sqls) digest_text FROM digest_table1 e INNER JOIN digest_table2 p ON e.id = p.id WHERE statement_digest_text(e.sqls) LIKE '%+%'  ORDER BY e.id;

--echo ##SELECT嵌套
--echo #SELECT
SELECT e.id,statement_digest(e.sqls) digest,statement_digest_text(e.sqls) digest_text FROM (SELECT id,sqls FROM digest_table1 WHERE statement_digest_text(sqls) LIKE '%UPDATE%') e ORDER BY e.id;


--echo #EXISTS / NOT EXISTS
SELECT e.id,statement_digest(e.sqls) digest,statement_digest_text(e.sqls) digest_text FROM digest_table1 e WHERE EXISTS (SELECT p.digest FROM digest_table2 p WHERE p.digest like '%5F%') ORDER BY e.id;
SELECT e.id,statement_digest(e.sqls) digest,statement_digest_text(e.sqls) digest_text FROM digest_table2 e WHERE NOT EXISTS (SELECT p.digest FROM digest_table2 p WHERE p.digest like '%5F%') ORDER BY e.id;

--echo #ANY
SELECT e.id,statement_digest(e.sqls) digest,statement_digest_text(e.sqls) digest_text FROM digest_table1 e WHERE statement_digest(e.sqls) = ANY (SELECT p.digest FROM digest_table2 p) ORDER BY e.id;
SELECT e.id,statement_digest(e.sqls) digest,statement_digest_text(e.sqls) digest_text FROM digest_table1 e WHERE statement_digest_text(e.sqls) < ANY (SELECT p.digest FROM digest_table2 p) ORDER BY e.id;

--echo #ALL 
SELECT e.id,statement_digest(e.sqls) digest,statement_digest_text(e.sqls) digest_text FROM digest_table1 e WHERE statement_digest(e.sqls) = ALL (SELECT p.digest FROM digest_table2 p WHERE p.id = 1) ORDER BY e.id;
SELECT e.id,statement_digest(e.sqls) digest,statement_digest_text(e.sqls) digest_text FROM digest_table1 e WHERE statement_digest_text(e.sqls) <= ALL (SELECT p.digest_text FROM digest_table2 p WHERE p.id <= 3) ORDER BY e.id;

--echo #CREATE AS 
CREATE TABLE digest_table3 AS SELECT e.id,statement_digest(e.sqls) digest,statement_digest_text(e.sqls) digest_text FROM digest_table1 e; 
SELECT * FROM digest_table3 ORDER BY id;

--echo #WITH AS的SELECT
WITH a AS (SELECT id,sqls,statement_digest(sqls) digest FROM digest_table1 WHERE id<3) SELECT a.id,a.sqls,a.digest FROM a ORDER BY a.id;
WITH a AS (SELECT id,sqls,statement_digest(sqls) digest_text FROM digest_table1 WHERE id<4) SELECT a.id,a.sqls,a.digest_text FROM a ORDER BY a.id;

--echo #模糊查询like 
SELECT e.id,statement_digest(e.sqls) digest,statement_digest_text(e.sqls) digest_text FROM digest_table1 e WHERE statement_digest(e.sqls) LIKE '%B%' ORDER BY e.id;
SELECT e.id,statement_digest(e.sqls) digest,statement_digest_text(e.sqls) digest_text FROM digest_table1 e WHERE statement_digest_text(e.sqls) NOT LIKE '%alter%' ORDER BY e.id;


--echo ######################### 标签：digest-8-2 INSERT #########################
INSERT INTO digest_table4 VALUES(1,'INSERT INTO t1 VALUES(15,25)',statement_digest('INSERT INTO t1 VALUES(15,25)'),statement_digest_text('INSERT INTO t1 VALUES(15,25)'),'INSERT 语句');
INSERT INTO digest_table4 VALUES(2,'DELETE FROM t1 WHERE c1 = "whh"',statement_digest('DELETE FROM t1 WHERE c1 = "whh"'),statement_digest_text('DELETE FROM t1 WHERE c1 = "whh"'),'DELETE 语句');
INSERT INTO digest_table4 VALUES(3,'UPDATE t1 SET id = id + 1',statement_digest('UPDATE t1 SET id = id + 1'),statement_digest_text('UPDATE t1 SET id = id + 1'),'UPDATE 语句');
SELECT * FROM digest_table4 ORDER BY id;


--echo ######################### 标签：digest-8-3 UPDATE #########################
UPDATE digest_table2 SET sqls = 'INSERT INTO t1 VALUES("函数 在 UPDATE 场景使用")' WHERE digest = statement_digest('INSERT INTO t1 VALUES(15,25)');
UPDATE digest_table2 SET sqls = 'UPDATE t1 SET id = id * 1' WHERE digest_text like '%UPDATE%' ORDER BY statement_digest(sqls) DESC;
UPDATE digest_table2 SET sqls = 'DELETE FROM t1 WHERE c1 LIKE "%W%"',digest_text=statement_digest_text('DELETE FROM t1 WHERE c1 LIKE "%W%"')  WHERE id = (SELECT id FROM digest_table1 WHERE statement_digest_text(sqls) like '%DELETE%')+2;
SELECT * FROM digest_table2 ORDER BY id;


--echo ######################### 标签：digest-8-4 DELETE #########################
SELECT * FROM  digest_table2 ORDER BY id;
DELETE FROM digest_table2 WHERE digest = '96D7F3527739D8C62304A04A33A62A86' ORDER BY digest_text;
DELETE FROM digest_table2 WHERE digest_text LIKE '%DELETE%' ORDER BY digest;
SELECT * FROM  digest_table2 ORDER BY id;


--echo ######################### 标签：digest-8-5 replace #########################
REPLACE INTO digest_table2 VALUES(7,'INSERT INTO t1 VALUES("第一次插入的值")',statement_digest('INSERT INTO t1 VALUES("第一次插入的值")'),statement_digest_text('INSERT INTO t1 VALUES("第一次插入的值")'),'INSERT 语句');
SELECT * FROM digest_table2 where id = 7;

REPLACE INTO digest_table2 VALUES(7,'INSERT INTO t1 VALUES("第二次插入的值",2*2)',statement_digest('INSERT INTO t1 VALUES("第二次插入的值",2*2)'),statement_digest_text('INSERT INTO t1 VALUES("第二次插入的值",2*2)'),'INSERT 语句');
SELECT * FROM digest_table2 where id = 7;


