drop table t1;
result_format: 4
set ob_enable_parameter_anonymous_block = on;
create table t1 (a int primary key);
insert into t1 values (1);

# 关闭大 IN 改写
alter system set "_inlist_rewrite_threshold" = 2147483647;
alter system flush pl cache global;
alter system flush plan cache;

declare b number; 
begin select /*+no_rewrite*/ a into b from t1 where a in (1);
end;
//

select operator, name from GV$OB_PLAN_CACHE_PLAN_EXPLAIN where plan_id in 
(
  select plan_id from gv$ob_sql_audit 
  where pl_trace_id in 
  (
    select pl_trace_id 
    from gv$OB_SQL_AUDIT 
    where query_sql like '%begin select /*+no_rewrite*/ a into b from t1 where a in (1)%' and pl_trace_id is not null
  )
  and query_sql not like '%declare%'
)
;
+----------------------+------+
| OPERATOR             | NAME |
+----------------------+------+
|   PHY_VEC_TABLE_SCAN | T1   |
|  PHY_DIRECT_TRANSMIT | NULL |
| PHY_DIRECT_RECEIVE   | NULL |
+----------------------+------+

# 开启大 IN 改写
alter system set "_inlist_rewrite_threshold" = 1;

alter system flush pl cache global;
alter system flush plan cache;
declare b number;
begin select /*+no_rewrite*/ a into b from t1 where a in (1);
end;
//

select operator, name from GV$OB_PLAN_CACHE_PLAN_EXPLAIN where plan_id in 
(
  select plan_id from gv$ob_sql_audit 
  where pl_trace_id in 
  (
    select pl_trace_id 
    from gv$OB_SQL_AUDIT 
    where query_sql like '%begin select /*+no_rewrite*/ a into b from t1 where a in (1)%' and pl_trace_id is not null
  )
  and query_sql not like '%declare%'
)
;
+----------------------+------+
| OPERATOR             | NAME |
+----------------------+------+
|   PHY_VEC_TABLE_SCAN | T1   |
|  PHY_DIRECT_TRANSMIT | NULL |
| PHY_DIRECT_RECEIVE   | NULL |
+----------------------+------+

alter system flush pl cache global;
alter system flush plan cache;

# 这个语句会走大 IN 改写
declare b number;
begin select /*+no_rewrite*/ a into b from t1 where a in (1,2,3,4,5);
end;
//

select operator, name from GV$OB_PLAN_CACHE_PLAN_EXPLAIN where plan_id in 
(
  select plan_id from gv$ob_sql_audit 
  where pl_trace_id in 
  (
    select pl_trace_id 
    from gv$OB_SQL_AUDIT 
    where query_sql like '%begin select /*+no_rewrite*/ a into b from t1 where a in (1,2,3,4,5)%' and pl_trace_id is not null
  )
  and query_sql not like '%declare%'
)
;
+-----------------------------+------+
| OPERATOR                    | NAME |
+-----------------------------+------+
|     PHY_VALUES_TABLE_ACCESS | NULL |
|    PHY_VEC_HASH_DISTINCT    | NULL |
|    PHY_VEC_TABLE_SCAN       | T1   |
|   PHY_VEC_SUBPLAN_FILTER    | NULL |
|  PHY_DIRECT_TRANSMIT        | NULL |
| PHY_DIRECT_RECEIVE          | NULL |
+-----------------------------+------+

alter system flush pl cache global;
alter system flush plan cache;
# inlist 类型不统一, 不能走大 IN 改写
declare b number;
begin select /*+no_rewrite*/ a into b from t1 where a in (1,2.0,'3');
end;
//

select operator, name from GV$OB_PLAN_CACHE_PLAN_EXPLAIN where plan_id in 
(
  select plan_id from gv$ob_sql_audit 
  where pl_trace_id in 
  (
    select pl_trace_id 
    from gv$OB_SQL_AUDIT 
    where query_sql like '%begin select /*+no_rewrite*/ a into b from t1 where a in (1,2.0%' and pl_trace_id is not null
  )
  and query_sql not like '%declare%'
)
;
+----------------------+------+
| OPERATOR             | NAME |
+----------------------+------+
|   PHY_VEC_TABLE_SCAN | T1   |
|  PHY_DIRECT_TRANSMIT | NULL |
| PHY_DIRECT_RECEIVE   | NULL |
+----------------------+------+

alter system flush pl cache global;
alter system flush plan cache;

alter system set "_inlist_rewrite_threshold" = 2147483647;
drop table t1;
