alter system set _enable_defensive_check = 2;
drop table if exists t1;
drop view if exists t2;
set session sql_mode='';
CREATE TABLE t1 (a INT, b INT) PARTITION BY HASH (a) PARTITIONS 3;
insert into t1 values (10, 1.1), (20, 2.2);
CREATE VIEW t2 AS SELECT * FROM t1;
result_format: 4
explain_protocol: 2
EXPLAIN UPDATE t2, (SELECT a FROM t1 ORDER BY a) AS t SET t2.b = t.a+5;
Query Plan
===================================================================
|ID|OPERATOR                       |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------
|0 |DISTRIBUTED UPDATE             |        |4       |71          |
|1 |└─NESTED-LOOP JOIN CARTESIAN   |        |4       |16          |
|2 |  ├─PX COORDINATOR             |        |2       |9           |
|3 |  │ └─EXCHANGE OUT DISTR       |:EX10000|2       |8           |
|4 |  │   └─PX PARTITION ITERATOR  |        |2       |7           |
|5 |  │     └─TABLE FULL SCAN      |t1      |2       |7           |
|6 |  └─MATERIAL                   |        |2       |8           |
|7 |    └─PX COORDINATOR           |        |2       |8           |
|8 |      └─EXCHANGE OUT DISTR     |:EX20000|2       |8           |
|9 |        └─PX PARTITION ITERATOR|        |2       |7           |
|10|          └─TABLE FULL SCAN    |t1      |2       |7           |
===================================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      table_columns([{t1: ({t1: (t1.__pk_increment, t1.a, t1.b)}), hash_distinct}]),
      update([t1.b=column_conv(INT,PS:(11,0),NULL,cast(t1.a + 5, INT(-1, 0)))])
  1 - output([t1.TRANS_DEBUG_INFO], [t1.__pk_increment], [t1.a], [t1.b], [t1.a]), filter(nil), rowset=16
      conds(nil), nl_params_(nil), use_batch=false
  2 - output([t1.TRANS_DEBUG_INFO], [t1.__pk_increment], [t1.a], [t1.b]), filter(nil), rowset=16
  3 - output([t1.TRANS_DEBUG_INFO], [t1.__pk_increment], [t1.a], [t1.b]), filter(nil), rowset=16
      dop=1
  4 - output([t1.__pk_increment], [t1.a], [t1.b], [t1.TRANS_DEBUG_INFO]), filter(nil), rowset=16
      force partition granule
  5 - output([t1.__pk_increment], [t1.a], [t1.b], [t1.TRANS_DEBUG_INFO]), filter(nil), rowset=16
