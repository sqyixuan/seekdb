drop table if exists table1, t1;
create table table1 (id int, c0 NVARCHAR(50));
alter table table1 add column c1 NVARCHAR(50) check (c1 <> N'0');
alter table table1 add column c2 NVARCHAR(50) check (c2 <> '0');
create table t1 (c1 int);
alter table t1 add column c2 char check (c2 > 1);
insert into t1 (c2) values ('3');
insert into t1 (c2) values ('0');
ERROR HY000: check constraint violated
drop table t1;
drop table table1;
