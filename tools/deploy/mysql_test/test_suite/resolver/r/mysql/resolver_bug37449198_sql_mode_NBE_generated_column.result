 partition by list columns(b)
(partition `p0` values in ('abc\def','中国\人民'),
partition `p1` values in ('hig\多多','klm \ \ '))
CREATE TABLE t2 ( a INT AUTO_INCREMENT PRIMARY KEY, b VARCHAR(50), c varchar(100) GENERATED ALWAYS AS (CONCAT(b,'\n')) );
INSERT INTO t2(a,b) VALUES(1, '\n');
select * from t2;
a	b	c
1	\n	\n\\n
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `a` int(11) NOT NULL AUTO_INCREMENT,
  `b` varchar(50) DEFAULT NULL,
  `c` varchar(100) GENERATED ALWAYS AS (CONCAT(`b`,'\\n')) VIRTUAL,
  PRIMARY KEY (`a`)
) ORGANIZATION INDEX AUTO_INCREMENT = 2 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
set sql_mode = default;
drop table t1;
drop table t2;
