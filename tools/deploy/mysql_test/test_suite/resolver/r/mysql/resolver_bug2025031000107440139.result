drop user if exists foo;
drop database if exists test_show;
drop database if exists test_show_1;
create database test_show;
create database test_show_1;
create user foo;
# 下面这些对象是 foo 可访问的
create table test_show_1.t1(c1 int);
CREATE FUNCTION test_show_1.f1 (func_args_1 INT) RETURNS INT DETERMINISTIC BEGIN RETURN 1; END 
$$
grant select on test_show_1.t1 to foo;
grant execute on function test_show_1.f1 to foo;
# 下面这些对象是 foo 不可访问的
create view test_show_1.view1 AS SELECT * FROM test_show_1.t1;
create table test_show_1.t2(c1 int);
create view test_show_1.view2 AS SELECT * FROM test_show_1.t2;
CREATE FUNCTION test_show_1.f2 (func_args_1 INT) RETURNS INT DETERMINISTIC BEGIN RETURN 1; END 
$$
create table test_show.t0(c1 int);
create view test_show.view0 AS SELECT * FROM test_show.t0;
CREATE FUNCTION test_show.f0 (func_args_1 INT) RETURNS INT DETERMINISTIC BEGIN RETURN 1; END 
$$
alter system flush plan cache;
# 当前用户查询, 可以看到所有的对象
show databases status like "test_show";
Database (test_show)	Status
test_show	read write
show databases status like "test_show_1";
Database (test_show_1)	Status
test_show_1	read write
show table status from test_show;
