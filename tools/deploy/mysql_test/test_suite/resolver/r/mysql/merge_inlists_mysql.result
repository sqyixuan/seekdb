drop table if exists t1;
drop view if exists v1;
CREATE TABLE t1 (a inT, b VARCHAR(50), c DECIMAL(10, 2));
INSERT INTO t1 (a, b, c) VALUES
(1, 'apple', 10.50),
(2, 'banana', 20.75),
(3, 'cherry', 30.00),
(4, 'date', 40.25),
(5, 'elderberry', 50.50),
(6, 'fig', 60.75),
(7, 'grape', 70.00),
(8, 'honeydew', 80.25),
(9, 'kiwi', 90.50),
(10, 'lime', 100.75);
result_format: 4
explain_protocol: 2
# 测试 in OR in
EXPLAIN select /*+no_rewrite*/ * from t1 where a in (1) or a in (2, 3) or a in (4) or a in (5,6,7);
