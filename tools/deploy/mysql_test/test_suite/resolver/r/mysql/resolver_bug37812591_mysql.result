drop table if exists t1, t2;
create table t1 (
c01 int(255),
c02 decimal(10,0),
c03 decimal(10,5),
c04 bit(64),
c05 tinyint(255),
c06 smallint(6),
c07 mediumint(9),
c08 bigint(20),
c09 float,
c10 double,
c11 varchar(255),
c12 char(255),
c13 tinytext,
c14 mediumtext,
c15 tinyblob,
c16 longtext,
c17 mediumblob,
c18 longblob,
c19 binary(255),
c20 varbinary(255),
c21 timestamp,
c22 date,
c23 time,
c24 datetime,
c25 year(4),
c26 blob
);
create table t2 as select * from t1;
desc t1;
