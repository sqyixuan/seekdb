drop table if exists t1, t2;
drop function if exists n_1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(1,1,3),(2,2,0),(2,3,0),(2,2,0),(2,4,0);
create table t2(id int ,s1 int, s2 int);
set @num = 10;
create function n_1() returns int not deterministic
begin
DECLARE r INT unsigned DEFAULT 1; 
insert into t2 values(1,0,1);
set @num := @num - 1;
set r := @num;
return r;
end/
result_format: 4
select n_1() from t1 order by n_1() desc ;
+-------+
| n_1() |
+-------+
|     9 |
|     8 |
|     7 |
|     6 |
|     5 |
+-------+
select * from t2;
+------+------+------+
| id   | s1   | s2   |
+------+------+------+
|    1 |    0 |    1 |
|    1 |    0 |    1 |
|    1 |    0 |    1 |
|    1 |    0 |    1 |
|    1 |    0 |    1 |
+------+------+------+

drop table t1, t2;
drop function n_1;
