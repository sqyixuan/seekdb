drop table if exists W0CASE,W1CASE, t_range_partition_1_sub_1;
CREATE TABLE W0CASE (W0_TEST0 DATE, W0_TEST1 TIME, W0_TEST2 DATETIME, W0_TEST3 TIMESTAMP, W0_TEST4 YEAR)
PARTITION BY LIST (TIME_TO_SEC(W0_TEST1))
PARTITIONS 1
(PARTITION P0 VALUES IN (1234));
CREATE TABLE W1CASE (W1_TEST0 DATE, W1_TEST1 TIME, W1_TEST2 DATETIME, W1_TEST3 TIMESTAMP, W1_TEST4 YEAR)
PARTITION BY LIST (TIME_TO_SEC(W1_TEST2))
PARTITIONS 1
(PARTITION P0 VALUES IN (1234));
CREATE TABLE t_range_partition_1_sub_1 (
c1 DOUBLE,
c2 FLOAT,
c3 DECIMAL(10, 2),
c4 TIMESTAMP
)
PARTITION BY RANGE COLUMNS(c1) (
PARTITION p0 VALUES LESS THAN (1000) (
SUBPARTITION sp0 VALUES LESS THAN (0),
SUBPARTITION sp1 VALUES LESS THAN (1000)
),
PARTITION p1 VALUES LESS THAN (5000) (
SUBPARTITION sp10 VALUES LESS THAN (2000),
SUBPARTITION sp11 VALUES LESS THAN (5000)
)
);
ERROR 42000: Parse error
drop table W0CASE,W1CASE;
