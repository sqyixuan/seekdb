drop table if exists test;
create table test(id int default null, data int default null, tag varchar(5) default null);
insert into test values (1,1,'a'),(2,2,'a'),(3,3,'b');
select * from test;
id	data	tag
1	1	a
2	2	a
3	3	b
select id as t, sum(data) as data from test group by id order by sum(t);
t	data
1	1
2	2
3	3
select id, sum(data) as data from test group by id order by sum(data);
id	data
1	1
2	2
3	3
select id, sum(data) as data from test group by id order by min(data);
id	data
1	1
2	2
3	3
select id, data, std(data) as data from test group by id order by sum(data);
id	data	data
1	1	0
2	2	0
3	3	0
select id, avg(data) as data from test group by id order by avg(data);
id	data
1	1.0000
2	2.0000
3	3.0000
select id, max(data) as data from test group by id order by max(data);
id	data
1	1
2	2
3	3
select id, count(data) as data from test group by id order by count(data);
id	data
1	1
2	1
3	1
select id, std(data) as data from test group by id order by stddev(data);
id	data
1	0
2	0
3	0
select id, data, group_concat(data) as data from test group by id order by sum(data);
id	data	data
1	1	1
2	2	2
3	3	3
select id, count(1) as data from test group by id having data > 0 order by data desc;
id	data
1	1
2	1
3	1
select id as data, data from test order by data;
ERROR 23000: Column 'data' in order clause is ambiguous
select id + 1 as data, data from test group by id order by data;
ERROR 23000: Column 'data' in order clause is ambiguous
select count(id) as data, data from test group by id order by data;
ERROR 23000: Column 'data' in order clause is ambiguous
select id as data, data from test group by id order by data + 1;
data	data
1	1
2	2
3	3
select id as data, data from test group by id order by -data;
data	data
3	3
2	2
1	1
select id + 1 as data, data from test group by id order by data + 1;
data	data
2	1
3	2
4	3
select a.* from test as a join (select id, tag, data as d from test where id > 1 group by tag) as b on a.id > 1 where 1 order by id desc, tag desc;
id	data	tag
3	3	b
3	3	b
2	2	a
2	2	a
drop table if exists test;
