drop table if exists t1;
result_format: 4
CREATE TABLE T1 (pk INT,col_int NUMBER(10));

## compare subquery
select * from T1 WHERE (select min(abs(pk)) from T1)=0 or (select min(abs(col_int)) from T1)=0;
+------+---------+
| pk   | col_int |
+------+---------+
|    1 |       0 |
|    2 |       1 |
+------+---------+

## extract info after canonicalizer
select 1 from t1 having sum( pk ) > 1 or sum( pk ) > 1;
+---+
| 1 |
+---+
| 1 |
+---+

drop table if exists t1;
