## bug: 52416166
CREATE TABLE T_IFARE (
CARRIER CHAR(2) NOT NULL,
DELETE_ID int DEFAULT 0 NOT NULL)
PARTITION BY RANGE COLUMNS (CARRIER, DELETE_ID)(
PARTITION IFARE_1_PART_YY VALUES LESS THAN ('YY', MAXVALUE),
PARTITION IFARE_1_PART_ZH VALUES LESS THAN ('ZH', MAXVALUE),
PARTITION IFARE_0_PART_OTHER VALUES LESS THAN (MAXVALUE, MAXVALUE));

