--disable_warnings
drop table if exists t1,t2;
--enable_warnings

--explain_protocol 1
--result_format 4

create TABLE t1 (c1 int ,c2 int ,c3 int, primary key (c1,c2))
partition by range columns (c1,c2)
(partition p0 values less than (10,10),partition p1 values less than (100,100),partition p2 values less than (maxvalue,maxvalue));
--error 1149
alter TABLE t1 add partition (partition p1 values in (default));

--error 1564
create table t1(a int, b varchar(100), c int)
partition by range((a,c))
(partition p0 values less than ((100, 100)), partition p1 values less than ((200, 300)), partition p2 values less than (maxvalue));

drop table t1;
