# owner: dingjincheng.djc
# owner group: sql1
# tags: resolver
# descriptor: 

--disable_warnings
drop table if exists t1, t2, t3, full;
--enable_warnings

create table full(c1 int, c2 int);
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create table t3(c1 int, c2 int);

--result_format 4

select c1 from full;
select c1 full from t2;
select * from t1 full;
select full.c1 from (select * from t1) full;
select * from t1 full, t2;
select * from full join t2;
select * from full t1 join t2;
select * from t1 full cross join t2;
select * from t1 inner join t2 full;
select * from t1 inner join t2 full using(c1);
select * from t1 natural inner join t2 full;
select * from t1 full full join t2 on full.c1 = t2.c1;
select * from t1 full full outer join t2 on full.c1 = t2.c1;
select * from t1 full outer join t2 full on t1.c1 = full.c1;
select * from t1 full left join t2 on full.c1 = t2.c1;
select * from t1 right join t2 full on t1.c1 = full.c1;
select * from t1 left join t2 on t1.c1 = t2.c2 full join t3 full on t1.c1 = full.c1;
select * from t1 left join (select * from t2)full on t1.c1=full.c1;

drop table full;
drop table t1;
drop table t2;
drop table t3;