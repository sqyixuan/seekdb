# tags: optimizer,cross_validation

## bug: 

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set _enable_defensive_check = 2;
sleep 2;
connection default;

--disable_warnings
drop table if exists t1;
drop view if exists t2;
--enable_warnings

set session sql_mode='';
CREATE TABLE t1 (a INT, b INT) PARTITION BY HASH (a) PARTITIONS 3;
insert into t1 values (10, 1.1), (20, 2.2);
CREATE VIEW t2 AS SELECT * FROM t1;


--result_format 4
--explain_protocol 2
UPDATE t2, (SELECT a FROM t1 ORDER BY a) AS t SET t2.b = t.a+5;

select * from t1;

--explain_protocol 0
connection obsys;
alter system set _enable_defensive_check = 1;
connection default;

drop table t1;
drop view t2;
