# owner: lijinmao.ljm
# tags: optimizer, resolver
# owner group: sql1

--disable_warnings
drop table if EXISTS t1;
--enable_warnings

--result_format 4
create table t1 (c1 int, c2 VARCHAR(10), c3 longtext, c4 json);
insert into t1 values (\N, \N+1, '\N', NULL);
select * from t1;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_no = 1170, error_code = 4001, frequency = 1;
connection default;
alter system flush plan cache global;
select 1, NULL, \N, '\N', \N+1, null, length(null) from dual;
select HIT_COUNT, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like "select ?, ?, ?, ?, ?+?, ?, length(?) from dual";
select 1, \N, null, '\N', \N+2, \N, length(null) from dual;
select HIT_COUNT, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like "select ?, ?, ?, ?, ?+?, ?, length(?) from dual";
select 1, null, NULL, '\N', null+1, \N, length(\N) from dual;
select HIT_COUNT, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like "select ?, ?, ?, ?, ?+?, ?, length(?) from dual";

SET @query = 'SELECT ?, ? FROM dual';
PREPARE stmt FROM @query;
set @v1 = \N;
set @v2 = null;
EXECUTE stmt USING @v1, @v2;
DEALLOCATE PREPARE stmt;

select v.`null`, v.`\N+1` from (select \N, \N+1 from dual) v;

drop table t1;