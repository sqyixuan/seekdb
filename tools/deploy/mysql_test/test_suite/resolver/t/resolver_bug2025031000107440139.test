# owner: zhuangyifeng.zyf
# owner group: SQL1
# tags: resolver
# description: show database/table/function status should pass privilege check

--disable_warnings
drop user if exists foo;
drop database if exists test_show;
drop database if exists test_show_1;
--enable_warnings

create database test_show;
create database test_show_1;

create user foo;
--echo # 下面这些对象是 foo 可访问的
create table test_show_1.t1(c1 int);
DELIMITER $$;
CREATE FUNCTION test_show_1.f1 (func_args_1 INT) RETURNS INT DETERMINISTIC BEGIN RETURN 1; END 
$$
DELIMITER ;$$

grant select on test_show_1.t1 to foo;
grant execute on function test_show_1.f1 to foo;

--echo # 下面这些对象是 foo 不可访问的
create view test_show_1.view1 AS SELECT * FROM test_show_1.t1;
create table test_show_1.t2(c1 int);
create view test_show_1.view2 AS SELECT * FROM test_show_1.t2;
DELIMITER $$;
CREATE FUNCTION test_show_1.f2 (func_args_1 INT) RETURNS INT DETERMINISTIC BEGIN RETURN 1; END 
$$
DELIMITER ;$$

create table test_show.t0(c1 int);
create view test_show.view0 AS SELECT * FROM test_show.t0;
DELIMITER $$;
CREATE FUNCTION test_show.f0 (func_args_1 INT) RETURNS INT DETERMINISTIC BEGIN RETURN 1; END 
$$
DELIMITER ;$$

alter system flush plan cache;

--echo # 当前用户查询, 可以看到所有的对象
# -- disable_result_log
--replace_column 12 create_time 13 update_time 14 check_time 15 Collation 16 Checksum 17 create_options 18 Comment
show databases status like "test_show";
--replace_column 12 create_time 13 update_time 14 check_time 15 Collation 16 Checksum 17 create_options 18 Comment
show databases status like "test_show_1";
--replace_column 12 create_time 13 update_time 14 check_time 15 Collation 16 Checksum 17 create_options 18 Comment
show table status from test_show;
--replace_column 12 create_time 13 update_time 14 check_time 15 Collation 16 Checksum 17 create_options 18 Comment
show table status from test_show_1;
--replace_column 12 create_time 13 update_time 14 check_time 15 Collation 16 Checksum 17 create_options 18 Comment
show table status from test_show like "t0";
--replace_column 12 create_time 13 update_time 14 check_time 15 Collation 16 Checksum 17 create_options 18 Comment
show table status from test_show_1 like "t1";
--replace_column 12 create_time 13 update_time 14 check_time 15 Collation 16 Checksum 17 create_options 18 Comment
show table status from test_show_1 like "t2";
--replace_column 5 modified 6 create
show function status from test_show;
--replace_column 5 modified 6 create
show function status from test_show_1;
--replace_column 5 modified 6 create
show function status from test_show like "f0";
--replace_column 5 modified 6 create
show function status from test_show_1 like "f1";
--replace_column 5 modified 6 create
show function status from test_show_1 like "f2";
# --enable_result_log

connect (conn_foo,$OBMYSQL_MS0,foo,,test_show_1,$OBMYSQL_PORT);
--echo # foo 用户查询, 会受到访问权限的控制
--replace_column 12 create_time 13 update_time 14 check_time 15 Collation 16 Checksum 17 create_options 18 Comment
show databases status like "test_show";
--replace_column 12 create_time 13 update_time 14 check_time 15 Collation 16 Checksum 17 create_options 18 Comment
show databases status like "test_show_1";
--error 1044
show table status from test_show;
--echo # foo 只能看到 t1, 看不到 view1, t2, view2
--replace_column 12 create_time 13 update_time 14 check_time 15 Collation 16 Checksum 17 create_options 18 Comment
show table status from test_show_1;
--error 1044
show table status from test_show like "t0";
--replace_column 12 create_time 13 update_time 14 check_time 15 Collation 16 Checksum 17 create_options 18 Comment
show table status from test_show_1 like "t1";
--replace_column 12 create_time 13 update_time 14 check_time 15 Collation 16 Checksum 17 create_options 18 Comment
show table status from test_show_1 like "t2";
--error 1044
show function status from test_show;
--echo # foo 可以看到 f1, 不能看到 f2
--replace_column 5 modified 6 create
show function status from test_show_1;
--error 1044
show function status from test_show like "f0";
--replace_column 5 modified 6 create
show function status from test_show_1 like "f1";
--replace_column 5 modified 6 create
show function status from test_show_1 like "f2";

connection default;

drop database test_show;
drop database test_show_1;
drop user foo;
