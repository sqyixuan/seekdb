# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: resolver, optimizer
# description: 测试 inlist 合并功能

--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings

CREATE TABLE t1 (a inT, b VARCHAR(50), c DECIMAL(10, 2));

INSERT INTO t1 (a, b, c) VALUES
  (1, 'apple', 10.50),
  (2, 'banana', 20.75),
  (3, 'cherry', 30.00),
  (4, 'date', 40.25),
  (5, 'elderberry', 50.50),
  (6, 'fig', 60.75),
  (7, 'grape', 70.00),
  (8, 'honeydew', 80.25),
  (9, 'kiwi', 90.50),
  (10, 'lime', 100.75);
--result_format 4
--explain_protocol 2

--echo # 测试 in OR in
select /*+no_rewrite*/ * from t1 where a in (1) or a in (2, 3) or a in (4) or a in (5,6,7);
select /*+no_rewrite*/ * from t1 where b in ('a') or b in ('b') or b in ('apple', 'c') or b in ('e', 'f', 'g', 'banana');
select /*+no_rewrite*/ * from t1 where c in (0.0) or c in (1.0, 2.0) or c in (3.0, 4.0, 5.0, 10.5) or c in (30.0); 
--echo ## 常量类型相同的 inlist 可以合并, NULL 也可以
select /*+no_rewrite*/ * from t1 where a in (1) or a in (2, 3) or a in (4.0) or a in (5.0) or a in (6.0, 7.0);
select /*+no_rewrite*/ * from t1 where a in (NULL, NULL) or a in (NULL);
--echo ## inlist 中存在不同类型的常量时, 这个 inlist 不能合并
select /*+no_rewrite*/ * from t1 where a in (1,'2') or a in (3,4) or a in (5,6,7);
select /*+no_rewrite*/ * from t1 where a in (1,'2') or a in (3,4) or a in (5,6,7) or a in (NULL, NULL, 0.0);
--echo ## 只有满足条件的相邻的 inlist 才能合并
select /*+no_rewrite*/ * from t1 where a = 0 or a in (1) or a in (2,3) or a = 4 or a in (5,6,7) or a in (8);
select /*+no_rewrite*/ * from t1 where a in (1) or a in (5.0) or a in (2) or a in (6.0);
--echo ## in 左支是表达式时, 也可以合并. 但是左支包含常量时, 不能合并, 否则合并后右支的参数下标会不连续
select /*+no_rewrite*/ * from t1 where a+c in (1,2,3) or a+c in (4,5,6);
select /*+no_rewrite*/ * from t1 where ABS(a) in (1, 2, 3) OR ABS(a) in (4, 5);
select /*+no_rewrite*/ * from t1 where a+1 in (1,2,3) or a+1 in (4,5,6);
select /*+no_rewrite*/ * from t1 where 1 in (1,2,3) or 1 in (4,5,6);
--echo ## in 的右支不是常量列表时, 不能合并
select /*+no_rewrite*/ * from t1 where a in (select 1 from dual) or a in (select 2 from dual);
select /*+no_rewrite*/ * from t1 where a in (select a from t1 where a < 5) OR a in (select a from t1 where a > 5);
select /*+no_rewrite*/* from t1 where a in (1+0, 2*1) OR a in (3/1, 4-0);
--echo ## in 的左支不相同的两个 inlist 不能合并
select /*+no_rewrite*/ * from t1 where a in (1, 2) or b in ('hello', 'world');
--echo ## 一个查询中可以合并多个列上的条件
select /*+no_rewrite*/ * from t1 where a in (1, 2, 3) OR a in (4, 5) OR b in ('fig', 'grape') OR b in ('honeydew');
--echo ## in 左支包含多列也可以合并. 和单列的场景合并条件相同
select /*+no_rewrite*/ * from t1 where (a, b, c) in ((1, 'a', 1.0), (2, 'b', 2.0)) or (a, b, c) in ((3, 'c', 3.0)) or (a,b,c) in ((4.0,'d',5.0));
select /*+no_rewrite*/ * from t1 where (a+1, b, c) in ((1, 'a', 1.0), (2, 'b', 2.0)) or (a+1, b, c) in ((3, 'c', 3.0)) or (a,b,c) in ((4.0,'d',5.0));
--echo ## NOT IN OR 不能合并
select /*+no_rewrite*/ * from t1 where a not in (1,2) or a not in (3,4);
--echo ## 测试 create view
create view v1 as select * from t1 where a in (1,2,3,4) or a in (4,5,6);
select /*+no_rewrite*/ * from v1 where a in (1,2,3) or a in (4,5);
select /*+no_rewrite*/ * from v1 where a in (1,2,3) or a in (4,5) or a in ('6','7');
drop view v1;

--echo # NOT in AND NOT in
select /*+no_rewrite*/ * from t1
where
  a not in (1) and a not in (2) and a not in (3) and a not in (4) and a not in (5) and a not in (6) and a not in (7) and a not in (8)
  and a not in (9) and a not in (10) and a not in (11) and a not in (12) and a not in (13) and a not in (14) and a not in (15) and a not in (16)
  and a not in (17) and a not in (18) and a not in (19) and a not in (20) and a not in (21) and a not in (22) and a not in (23) and a not in (24)
  and a not in (25) and a not in (26) and a not in (27) and a not in (28) and a not in (29) and a not in (30) and a not in (31) and a not in (32)
  and a not in (33) and a not in (34) and a not in (35) and a not in (36) and a not in (37) and a not in (38) and a not in (39) and a not in (40)
  and a not in (41) and a not in (42) and a not in (43) and a not in (44) and a not in (45) and a not in (46) and a not in (47) and a not in (48)
  and a not in (49) and a not in (50) and a not in (51) and a not in (52) and a not in (53) and a not in (54) and a not in (55) and a not in (56)
  and a not in (57) and a not in (58) and a not in (59) and a not in (60) and a not in (61) and a not in (62) and a not in (63) and a not in (64)
;

select /*+no_rewrite*/ * from t1 where a not in (1) and a not in (2, 3) and a not in (4) and a not in (5,6,7);
select /*+no_rewrite*/ * from t1 where b not in ('a') and b not in ('b') and b not in ('apple', 'c') and b not in ('e', 'f', 'g', 'banana');
select /*+no_rewrite*/ * from t1 where c not in (0.0) and c not in (1.0, 2.0) and c not in (3.0, 4.0, 5.0, 10.5) and c not in (30.0); 
--echo ## 常量类型相同的 not inlist 可以合并, NULL 也可以
select /*+no_rewrite*/ * from t1 where a not in (1) and a not in (2, 3) and a not in (5.0) and a not in (6.0) and a not in (7.0, 8.0);
select /*+no_rewrite*/ * from t1 where a not in (NULL, NULL) and a not in (NULL);
--echo ## not inlist 中存在不同类型的常量时, 这个 not inlist 不能合并
select /*+no_rewrite*/ * from t1 where a not in (1,'2') and a not in (3,4) and a not in (5,6,7);
select /*+no_rewrite*/ * from t1 where a not in (1,'2') and a not in (3,4) and a not in (5,6,7) and a not in (NULL, NULL, 0.0);
--echo ## 只有满足条件的相邻的 not inlist 才能合并
select /*+no_rewrite*/ * from t1 where a = 0 and a not in (1) and a not in (2,3) and a = 4 and a not in (5,6,7) and a not in (8);
select /*+no_rewrite*/ * from t1 where a not in (1) and a not in (5.0) and a not in (2) and a not in (6.0);
--echo ## not in 左支是表达式时, 也可以合并. 但是左支包含常量时, 不能合并, 否则合并后右支的参数下标会不连续
select /*+no_rewrite*/ * from t1 where a+c not in (1,2,3) and a+c not in (4,5,6);
select /*+no_rewrite*/ * from t1 where ABS(a) not in (1, 2, 3) and ABS(a) not in (4, 5);
select /*+no_rewrite*/ * from t1 where a+1 not in (1,2,3) and a+1 not in (4,5,6);
select /*+no_rewrite*/ * from t1 where 1 not in (1,2,3) and 1 not in (4,5,6);
--echo ## not in 的右支不是常量列表时, 不能合并
select /*+no_rewrite*/ * from t1 where a not in (select 1 from dual) and a not in (select 2 from dual);
select /*+no_rewrite*/ * from t1 where a not in (select a from t1 where a < 5) and a not in (select a from t1 where a > 5);
select /*+no_rewrite*/* from t1 where a not in (1+0, 2*1) and a not in (3/1, 4-0);
--echo ## not in 的左支不相同的两个 not inlist 不能合并
select /*+no_rewrite*/ * from t1 where a not in (1, 2) and b not in ('hello', 'world');
--echo ## 一个查询中可以合并多个列上的条件
select /*+no_rewrite*/ * from t1 where a not in (1, 2, 3) and a not in (4, 5) and b not in ('fig', 'grape') and b not in ('honeydew');
--echo ## in 左支包含多列也可以合并. 和单列的场景合并条件相同
select /*+no_rewrite*/ * from t1 where (a, b, c) not in ((1, 'a', 1.0), (2, 'b', 2.0)) and (a, b, c) not in ((3, 'c', 3.0));
select /*+no_rewrite*/ * from t1 where (a, b, c) not in ((1, 'a', 1.0), (2, 'b', 2.0)) and (a, b, c) not in ((3, 'c', 3.0)) and (a,b,c) not in ((4.0,'d',5.0));
--echo ## IN AND IN 不能合并
select /*+no_rewrite*/ * from t1 where a in (1,2) and a in (3,4);
--echo ## 测试 create view
create view v1 as select * from t1 where a not in (1,2,3,4) and a not in (4,5,6);
select /*+no_rewrite*/ * from v1 where a not in (1,2,3) and a not in (4,5);
select /*+no_rewrite*/ * from v1 where a not in (1,2,3) and a not in (4,5) and a not in ('6','7');
drop view v1;

--echo # 测试 IN 转 values table
alter system set _inlist_rewrite_threshold = 2;
sleep 5;

--echo # 测试 in OR in
select /*+no_rewrite*/ * from t1 where a in (1) or a in (2, 3) or a in (4) or a in (5,6,7);
select /*+no_rewrite*/ * from t1 where b in ('a') or b in ('b') or b in ('apple', 'c') or b in ('e', 'f', 'g', 'banana');
select /*+no_rewrite*/ * from t1 where c in (0.0) or c in (1.0, 2.0) or c in (3.0, 4.0, 5.0, 10.5) or c in (30.0); 
--echo ## 常量类型相同的 inlist 可以合并, NULL 也可以
select /*+no_rewrite*/ * from t1 where a in (1) or a in (2, 3) or a in (4.0) or a in (5.0) or a in (6.0, 7.0);
select /*+no_rewrite*/ * from t1 where a in (NULL, NULL) or a in (NULL);
--echo ## inlist 中存在不同类型的常量时, 这个 inlist 不能合并
select /*+no_rewrite*/ * from t1 where a in (1,'2') or a in (3,4) or a in (5,6,7);
select /*+no_rewrite*/ * from t1 where a in (1,'2') or a in (3,4) or a in (5,6,7) or a in (NULL, NULL, 0.0);
--echo ## 只有满足条件的相邻的 inlist 才能合并
select /*+no_rewrite*/ * from t1 where a = 0 or a in (1) or a in (2,3) or a = 4 or a in (5,6,7) or a in (8);
select /*+no_rewrite*/ * from t1 where a in (1) or a in (5.0) or a in (2) or a in (6.0);
--echo ## in 左支是表达式时, 也可以合并. 但是左支包含常量时, 不能合并, 否则合并后右支的参数下标会不连续
select /*+no_rewrite*/ * from t1 where a+c in (1,2,3) or a+c in (4,5,6);
select /*+no_rewrite*/ * from t1 where ABS(a) in (1, 2, 3) OR ABS(a) in (4, 5);
select /*+no_rewrite*/ * from t1 where a+1 in (1,2,3) or a+1 in (4,5,6);
select /*+no_rewrite*/ * from t1 where 1 in (1,2,3) or 1 in (4,5,6);
--echo ## in 的左支不相同的两个 inlist 不能合并
select /*+no_rewrite*/ * from t1 where a in (1, 2) or b in ('hello', 'world');
--echo ## 一个查询中可以合并多个列上的条件
select /*+no_rewrite*/ * from t1 where a in (1, 2, 3) OR a in (4, 5) OR b in ('fig', 'grape') OR b in ('honeydew');
--echo ## in 左支包含多列也可以合并
select /*+no_rewrite*/ * from t1 where (a, b, c) in ((1, 'a', 1.0), (2, 'b', 2.0)) or (a, b, c) in ((3, 'c', 3.0));
--echo ## 测试 create view
create view v1 as select * from t1 where a in (1,2,3,4) or a in (4,5,6);
select /*+no_rewrite*/ * from v1 where a in (1,2,3) or a in (4,5);
select /*+no_rewrite*/ * from v1 where a in (1,2,3) or a in (4,5) or a in ('6','7');
drop view v1;

--echo # NOT in AND NOT in
select /*+no_rewrite*/ * from t1
where
  a not in (1) and a not in (2) and a not in (3) and a not in (4) and a not in (5) and a not in (6) and a not in (7) and a not in (8)
  and a not in (9) and a not in (10) and a not in (11) and a not in (12) and a not in (13) and a not in (14) and a not in (15) and a not in (16)
  and a not in (17) and a not in (18) and a not in (19) and a not in (20) and a not in (21) and a not in (22) and a not in (23) and a not in (24)
  and a not in (25) and a not in (26) and a not in (27) and a not in (28) and a not in (29) and a not in (30) and a not in (31) and a not in (32)
  and a not in (33) and a not in (34) and a not in (35) and a not in (36) and a not in (37) and a not in (38) and a not in (39) and a not in (40)
  and a not in (41) and a not in (42) and a not in (43) and a not in (44) and a not in (45) and a not in (46) and a not in (47) and a not in (48)
  and a not in (49) and a not in (50) and a not in (51) and a not in (52) and a not in (53) and a not in (54) and a not in (55) and a not in (56)
  and a not in (57) and a not in (58) and a not in (59) and a not in (60) and a not in (61) and a not in (62) and a not in (63) and a not in (64)
;

select /*+no_rewrite*/ * from t1 where a not in (1) and a not in (2, 3) and a not in (4) and a not in (5,6,7);
select /*+no_rewrite*/ * from t1 where b not in ('a') and b not in ('b') and b not in ('apple', 'c') and b not in ('e', 'f', 'g', 'banana');
select /*+no_rewrite*/ * from t1 where c not in (0.0) and c not in (1.0, 2.0) and c not in (3.0, 4.0, 5.0, 10.5) and c not in (30.0); 
--echo ## 常量类型相同的 not inlist 可以合并, NULL 也可以
select /*+no_rewrite*/ * from t1 where a not in (1) and a not in (2, 3) and a not in (5.0) and a not in (6.0) and a not in (7.0, 8.0);
select /*+no_rewrite*/ * from t1 where a not in (NULL, NULL) and a not in (NULL);
--echo ## not inlist 中存在不同类型的常量时, 这个 not inlist 不能合并
select /*+no_rewrite*/ * from t1 where a not in (1,'2') and a not in (3,4) and a not in (5,6,7);
select /*+no_rewrite*/ * from t1 where a not in (1,'2') and a not in (3,4) and a not in (5,6,7) and a not in (NULL, NULL, 0.0);
--echo ## 只有满足条件的相邻的 not inlist 才能合并
select /*+no_rewrite*/ * from t1 where a = 0 and a not in (1) and a not in (2,3) and a = 4 and a not in (5,6,7) and a not in (8);
select /*+no_rewrite*/ * from t1 where a not in (1) and a not in (5.0) and a not in (2) and a not in (6.0);
--echo ## not in 左支是表达式时, 也可以合并. 但是左支包含常量时, 不能合并, 否则合并后右支的参数下标会不连续
select /*+no_rewrite*/ * from t1 where a+c not in (1,2,3) and a+c not in (4,5,6);
select /*+no_rewrite*/ * from t1 where ABS(a) not in (1, 2, 3) and ABS(a) not in (4, 5);
select /*+no_rewrite*/ * from t1 where a+1 not in (1,2,3) and a+1 not in (4,5,6);
select /*+no_rewrite*/ * from t1 where 1 not in (1,2,3) and 1 not in (4,5,6);
--echo ## not in 的左支不相同的两个 not inlist 不能合并
select /*+no_rewrite*/ * from t1 where a not in (1, 2) and b not in ('hello', 'world');
--echo ## 一个查询中可以合并多个列上的条件
select /*+no_rewrite*/ * from t1 where a not in (1, 2, 3) and a not in (4, 5) and b not in ('fig', 'grape') and b not in ('honeydew');
--echo ## not in 左支包含多列也可以合并
select /*+no_rewrite*/ * from t1 where (a, b, c) not in ((1, 'a', 1.0), (2, 'b', 2.0)) and (a, b, c) not in ((3, 'c', 3.0));
--echo ## 测试 create view
create view v1 as select * from t1 where a not in (1,2,3,4) and a not in (4,5,6);
select /*+no_rewrite*/ * from v1 where a not in (1,2,3) and a not in (4,5);
select /*+no_rewrite*/ * from v1 where a not in (1,2,3) and a not in (4,5) and a not in ('6','7');
drop view v1;

alter system set _inlist_rewrite_threshold = 2147483647;
sleep 5;

--echo # 测试非参数化
set ob_enable_plan_cache=false;

--echo # 测试 in OR in
select /*+no_rewrite*/ * from t1 where a in (1) or a in (2, 3) or a in (4) or a in (5,6,7);
select /*+no_rewrite*/ * from t1 where b in ('a') or b in ('b') or b in ('apple', 'c') or b in ('e', 'f', 'g', 'banana');
select /*+no_rewrite*/ * from t1 where c in (0.0) or c in (1.0, 2.0) or c in (3.0, 4.0, 5.0, 10.5) or c in (30.0); 
--echo ## 常量类型相同的 inlist 可以合并, NULL 也可以
select /*+no_rewrite*/ * from t1 where a in (1) or a in (2, 3) or a in (4.0) or a in (5.0) or a in (6.0, 7.0);
select /*+no_rewrite*/ * from t1 where a in (NULL, NULL) or a in (NULL);
--echo ## inlist 中存在不同类型的常量时, 这个 inlist 不能合并
select /*+no_rewrite*/ * from t1 where a in (1,'2') or a in (3,4) or a in (5,6,7);
select /*+no_rewrite*/ * from t1 where a in (1,'2') or a in (3,4) or a in (5,6,7) or a in (NULL, NULL, 0.0);
--echo ## 只有满足条件的相邻的 inlist 才能合并
select /*+no_rewrite*/ * from t1 where a = 0 or a in (1) or a in (2,3) or a = 4 or a in (5,6,7) or a in (8);
select /*+no_rewrite*/ * from t1 where a in (1) or a in (5.0) or a in (2) or a in (6.0);
--echo ## in 左支是表达式时, 也可以合并. 非参数化场景, 左支包含常量时, 也可以合并
select /*+no_rewrite*/ * from t1 where a+c in (1,2,3) or a+c in (4,5,6);
select /*+no_rewrite*/ * from t1 where ABS(a) in (1, 2, 3) OR ABS(a) in (4, 5);
select /*+no_rewrite*/ * from t1 where a+1 in (1,2,3) or a+1 in (4,5,6);
select /*+no_rewrite*/ * from t1 where 1 in (1,2,3) or 1 in (4,5,6);
--echo ## in 的右支不是常量列表时, 不能合并
select /*+no_rewrite*/* from t1 where a in (1+0, 2*1) OR a in (3/1, 4-0);
--echo ## in 的左支不相同的两个 inlist 不能合并
select /*+no_rewrite*/ * from t1 where a in (1, 2) or b in ('hello', 'world');
--echo ## 一个查询中可以合并多个列上的条件
select /*+no_rewrite*/ * from t1 where a in (1, 2, 3) OR a in (4, 5) OR b in ('fig', 'grape') OR b in ('honeydew');
--echo ## in 左支包含多列也可以合并. 和单列的场景合并条件相同
select /*+no_rewrite*/ * from t1 where (a, b, c) in ((1, 'a', 1.0), (2, 'b', 2.0)) or (a, b, c) in ((3, 'c', 3.0)) or (a,b,c) in ((4.0,'d',5.0));
select /*+no_rewrite*/ * from t1 where (a+1, b, c) in ((1, 'a', 1.0), (2, 'b', 2.0)) or (a+1, b, c) in ((3, 'c', 3.0)) or (a,b,c) in ((4.0,'d',5.0));
--echo ## 测试 create view
create view v1 as select * from t1 where a in (1,2,3,4) or a in (4,5,6);
select /*+no_rewrite*/ * from v1 where a in (1,2,3) or a in (4,5);
select /*+no_rewrite*/ * from v1 where a in (1,2,3) or a in (4,5) or a in ('6','7');
drop view v1;

--echo # NOT in AND NOT in
select /*+no_rewrite*/ * from t1
where
  a not in (1) and a not in (2) and a not in (3) and a not in (4) and a not in (5) and a not in (6) and a not in (7) and a not in (8)
  and a not in (9) and a not in (10) and a not in (11) and a not in (12) and a not in (13) and a not in (14) and a not in (15) and a not in (16)
  and a not in (17) and a not in (18) and a not in (19) and a not in (20) and a not in (21) and a not in (22) and a not in (23) and a not in (24)
  and a not in (25) and a not in (26) and a not in (27) and a not in (28) and a not in (29) and a not in (30) and a not in (31) and a not in (32)
  and a not in (33) and a not in (34) and a not in (35) and a not in (36) and a not in (37) and a not in (38) and a not in (39) and a not in (40)
  and a not in (41) and a not in (42) and a not in (43) and a not in (44) and a not in (45) and a not in (46) and a not in (47) and a not in (48)
  and a not in (49) and a not in (50) and a not in (51) and a not in (52) and a not in (53) and a not in (54) and a not in (55) and a not in (56)
  and a not in (57) and a not in (58) and a not in (59) and a not in (60) and a not in (61) and a not in (62) and a not in (63) and a not in (64)
;

select /*+no_rewrite*/ * from t1 where a not in (1) and a not in (2, 3) and a not in (4) and a not in (5,6,7);
select /*+no_rewrite*/ * from t1 where b not in ('a') and b not in ('b') and b not in ('apple', 'c') and b not in ('e', 'f', 'g', 'banana');
select /*+no_rewrite*/ * from t1 where c not in (0.0) and c not in (1.0, 2.0) and c not in (3.0, 4.0, 5.0, 10.5) and c not in (30.0); 
--echo ## 常量类型相同的 not inlist 可以合并, NULL 也可以
select /*+no_rewrite*/ * from t1 where a not in (1) and a not in (2, 3) and a not in (5.0) and a not in (6.0) and a not in (7.0, 8.0);
select /*+no_rewrite*/ * from t1 where a not in (NULL, NULL) and a not in (NULL);
--echo ## not inlist 中存在不同类型的常量时, 这个 not inlist 不能合并
select /*+no_rewrite*/ * from t1 where a not in (1,'2') and a not in (3,4) and a not in (5,6,7);
select /*+no_rewrite*/ * from t1 where a not in (1,'2') and a not in (3,4) and a not in (5,6,7) and a not in (NULL, NULL, 0.0);
--echo ## 只有满足条件的相邻的 not inlist 才能合并
select /*+no_rewrite*/ * from t1 where a = 0 and a not in (1) and a not in (2,3) and a = 4 and a not in (5,6,7) and a not in (8);
select /*+no_rewrite*/ * from t1 where a not in (1) and a not in (5.0) and a not in (2) and a not in (6.0);
--echo ## not in 左支是表达式时, 也可以合并. 非参数化场景, 左支包含常量时, 也可以合并
select /*+no_rewrite*/ * from t1 where a+c not in (1,2,3) and a+c not in (4,5,6);
select /*+no_rewrite*/ * from t1 where ABS(a) not in (1, 2, 3) and ABS(a) not in (4, 5);
select /*+no_rewrite*/ * from t1 where a+1 not in (1,2,3) and a+1 not in (4,5,6);
select /*+no_rewrite*/ * from t1 where 1 not in (1,2,3) and 1 not in (4,5,6);
--echo ## not in 的右支不是常量列表时, 不能合并
select /*+no_rewrite*/* from t1 where a not in (1+0, 2*1) and a not in (3/1, 4-0);
--echo ## not in 的左支不相同的两个 not inlist 不能合并
select /*+no_rewrite*/ * from t1 where a not in (1, 2) and b not in ('hello', 'world');
--echo ## 一个查询中可以合并多个列上的条件
select /*+no_rewrite*/ * from t1 where a not in (1, 2, 3) and a not in (4, 5) and b not in ('fig', 'grape') and b not in ('honeydew');
--echo ## not in 左支包含多列也可以合并
select /*+no_rewrite*/ * from t1 where (a, b, c) not in ((1, 'a', 1.0), (2, 'b', 2.0)) and (a, b, c) not in ((3, 'c', 3.0));
--echo ## 测试 create view
create view v1 as select * from t1 where a not in (1,2,3,4) and a not in (4,5,6);
select /*+no_rewrite*/ * from v1 where a not in (1,2,3) and a not in (4,5);
select /*+no_rewrite*/ * from v1 where a not in (1,2,3) and a not in (4,5) and a not in ('6','7');
drop view v1;

--echo # 测试非参数化转 values table
alter system set _inlist_rewrite_threshold = 2;
sleep 5;

--echo # 测试 in OR in
select /*+no_rewrite*/ * from t1 where a in (1) or a in (2, 3) or a in (4) or a in (5,6,7);
select /*+no_rewrite*/ * from t1 where b in ('a') or b in ('b') or b in ('apple', 'c') or b in ('e', 'f', 'g', 'banana');
select /*+no_rewrite*/ * from t1 where c in (0.0) or c in (1.0, 2.0) or c in (3.0, 4.0, 5.0, 10.5) or c in (30.0); 
--echo ## 常量类型相同的 inlist 可以合并, NULL 也可以
select /*+no_rewrite*/ * from t1 where a in (1) or a in (2, 3) or a in (4.0) or a in (5.0) or a in (6.0, 7.0);
select /*+no_rewrite*/ * from t1 where a in (NULL, NULL) or a in (NULL);
--echo ## inlist 中存在不同类型的常量时, 这个 inlist 不能合并
select /*+no_rewrite*/ * from t1 where a in (1,'2') or a in (3,4) or a in (5,6,7);
select /*+no_rewrite*/ * from t1 where a in (1,'2') or a in (3,4) or a in (5,6,7) or a in (NULL, NULL, 0.0);
--echo ## 只有满足条件的相邻的 inlist 才能合并
select /*+no_rewrite*/ * from t1 where a = 0 or a in (1) or a in (2,3) or a = 4 or a in (5,6,7) or a in (8);
select /*+no_rewrite*/ * from t1 where a in (1) or a in (5.0) or a in (2) or a in (6.0);
--echo ## in 左支是表达式时, 也可以合并. 但是左支包含常量时, 不能合并, 否则合并后右支的参数下标会不连续
select /*+no_rewrite*/ * from t1 where a+c in (1,2,3) or a+c in (4,5,6);
select /*+no_rewrite*/ * from t1 where ABS(a) in (1, 2, 3) OR ABS(a) in (4, 5);
select /*+no_rewrite*/ * from t1 where a+1 in (1,2,3) or a+1 in (4,5,6);
select /*+no_rewrite*/ * from t1 where 1 in (1,2,3) or 1 in (4,5,6);
--echo ## in 的左支不相同的两个 inlist 不能合并
select /*+no_rewrite*/ * from t1 where a in (1, 2) or b in ('hello', 'world');
--echo ## 一个查询中可以合并多个列上的条件
select /*+no_rewrite*/ * from t1 where a in (1, 2, 3) OR a in (4, 5) OR b in ('fig', 'grape') OR b in ('honeydew');
--echo ## in 左支包含多列也可以合并
select /*+no_rewrite*/ * from t1 where (a, b, c) in ((1, 'a', 1.0), (2, 'b', 2.0)) or (a, b, c) in ((3, 'c', 3.0));
--echo ## 测试 create view
create view v1 as select * from t1 where a in (1,2,3,4) or a in (4,5,6);
select /*+no_rewrite*/ * from v1 where a in (1,2,3) or a in (4,5);
select /*+no_rewrite*/ * from v1 where a in (1,2,3) or a in (4,5) or a in ('6','7');
drop view v1;

--echo # NOT in AND NOT in
