--echo ## not in 左支是表达式时, 也可以合并. 但是左支包含常量时, 不能合并, 否则合并后右支的参数下标会不连续
select /*+no_rewrite*/ * from t1 where a+c not in (1,2,3) and a+c not in (4,5,6);
