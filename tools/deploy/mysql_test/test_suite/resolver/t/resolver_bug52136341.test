#owner group: sql1

--echo #bug:
--disable_warnings
drop DATABASE if exists db1;
drop DATABASE if exists db2;
--enable_warnings

CREATE DATABASE db1;
CREATE TABLE db1.t1 (
  a INT
);

CREATE DATABASE db2;
CREATE TABLE db2.t1 (
  a INT
);

DELETE FROM alias USING db1.t1, db2.t1 alias WHERE db1.t1.a = alias.a;
--error 1109
DELETE FROM db2.alias USING db1.t1, db2.t1 alias WHERE db1.t1.a = alias.a;

drop DATABASE if exists db1;
drop DATABASE if exists db2;