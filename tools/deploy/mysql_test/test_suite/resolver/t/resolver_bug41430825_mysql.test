# owner: dingjincheng.djc
# tags: resolver,optimizer
# owner group: sql1
# link: 

--disable_warnings
drop table if exists t1, t2, goods_cate;
create table t1 (c1 int);
create table t2 (c1 int);
CREATE TABLE `goods_cate` (
  `id` int(11) unsigned NOT NULL AUTO_INCREMENT,
  `name` varchar(100) NOT NULL COMMENT '类目名',
  `parent_id` int(11) NOT NULL DEFAULT '0' COMMENT '父级id',
  `is_parent` tinyint(2) NOT NULL DEFAULT '0' COMMENT '0不是父级 1父级',
  `sort` int(11) NOT NULL DEFAULT '0' COMMENT '排序',
  `path` varchar(200) NOT NULL COMMENT '父类组合',
  `create_time` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `update_time` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  `is_hidden` tinyint(3) unsigned NOT NULL DEFAULT '0' COMMENT '是否隐藏',
  PRIMARY KEY (`id`)
);
--enable_warnings

--disable_query_log
--disable_result_log
insert into t1 values (1), (2), (3), (4), (5);
insert into t2 values (1);
insert into goods_cate values (2391, 'a', 2390,  1, 0, '/a', now(), now(), 0);
insert into goods_cate values (2393, 'b', 2391,  1, 0, '/b', now(), now(), 0);
insert into goods_cate values (2394, 'c', 2393,  1, 0, '/c', now(), now(), 0);
insert into goods_cate values (2395, 'd', 2394,  1, 0, '/d', now(), now(), 0);
insert into goods_cate values (2396, 'e', 2395,  0, 0, '/e', now(), now(), 0);
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

select c1 as id, (select c1 from t1 where c1 = id) from t2;
select 1 as id, (select c1 from t1 where c1 = id) from dual;

--error 1054
select 1 as id, id + 1 from dual;

SELECT T2.id, T2.name FROM ( SELECT @r AS _id, (SELECT @r := parent_id FROM goods_cate WHERE id = _id) AS parent_id, @l := @l + 1 AS lvl FROM (SELECT @r := 2396, @l := 0) vars, goods_cate h WHERE @r <> 0) T1 JOIN goods_cate T2 ON T1._id = T2.id ORDER BY T2.id;

select (c1 + 1) f1, (select /*+no_unnest*/ c1 from t1 tb where tb.c1 = f1 limit 1) f2 from t1 ta group by f2;

select cast(c1 + 1 as char(20)) f1, (select /*+no_unnest*/ c1 from t1 tb where tb.c1 = f1 limit 1) f2 from t1 ta group by f2;

select (select /*+no_unnest*/ c1 from t1 tb where tb.c1 = ta.c1 limit 1) f1, (select /*+no_unnest*/ c1 from t1 tb where tb.c1 = f1 limit 1) f2 from t1 ta group by f2;

--error ER_ILLEGAL_REFERENCE
SELECT SUM(c1) OVER () AS c, (SELECT SUM(c))  FROM t1;

--error ER_ILLEGAL_REFERENCE
SELECT SUM(c1)  AS c, (SELECT SUM(c) from t2)  FROM t1;

--error 1056
SELECT SUM(c1)  AS c, (SELECT c from t2)  FROM t1;

select t1.c1 as x, (select group_concat(x) from t2) as res from t1;

select t1.c1 as x, (select group_concat(t1.c1) from t2 limit 1) as res from t1;

select t1.c1 as x, (select group_concat(x + t1.c1) from t2 limit 1) as res from t1;

select t1.c1 as x, (select group_concat(t2.c1 + x) from t2 limit 1) as res from t1;

drop table if exists t1, t2, goods_cate;