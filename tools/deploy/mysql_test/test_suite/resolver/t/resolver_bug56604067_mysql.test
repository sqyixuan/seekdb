#owner: yibo.tyf
#owner group: sql1
# tags: resolver

--disable_warnings
drop table if exists lineitem1,lineitem2;
--enable_warnings

create table lineitem1(
l_orderkey           bigint(20) NOT NULL ,
l_partkey            bigint(20) NOT NULL ,
l_suppkey            bigint(20) NOT NULL ,
l_linenumber         bigint(20) NOT NULL ,
primary key(L_ORDERKEY, L_LINENUMBER))
partition by hash(l_orderkey) partitions 4
SUBPARTITION BY RANGE(l_linenumber);

create table lineitem2(
l_orderkey           bigint(20) NOT NULL ,
l_partkey            bigint(20) NOT NULL ,
l_suppkey            bigint(20) NOT NULL ,
l_linenumber         bigint(20) NOT NULL ,
primary key(L_ORDERKEY, L_LINENUMBER))
partition by hash(l_orderkey) partitions 4
SUBPARTITION BY list(l_linenumber);

--result_format 4
--source mysql_test/include/show_create_table_old_version.inc
show create table lineitem1;
--source mysql_test/include/show_create_table_old_version.inc
show create table lineitem2;

drop table lineitem1,lineitem2;