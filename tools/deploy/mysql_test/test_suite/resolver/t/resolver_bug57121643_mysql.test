--result_format 4

## issue: 

let $test_table_cnt = 260;

--disable_warnings
let $cnt= 1;
while($cnt <= $test_table_cnt)
{
  let $ddl_str=drop table if exists t$cnt;
  eval $ddl_str;
  let $ddl_str=create table t$cnt (c1 int);
  eval $ddl_str;
  inc $cnt;
}
--enable_warnings

let $cnt= 2;
let $sql = select /*+NO_QUERY_TRANSFORMATION*/ c1 from t1;
while($cnt <= $test_table_cnt)
{
  let $sql=$sql union all select c1 from t$cnt;
  inc $cnt;
}
set ob_query_timeout=100000000;
eval $sql;

--disable_warnings
let $cnt= 1;
while($cnt <= $test_table_cnt)
{
  let $ddl_str=drop table if exists t$cnt;
  eval $ddl_str;
  inc $cnt;
}
--enable_warnings
