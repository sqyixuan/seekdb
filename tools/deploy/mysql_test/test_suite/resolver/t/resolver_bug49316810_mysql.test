#owner: yibo.tyf
#owner group: sql1
# tags: optimizer

--disable_warnings
drop tablegroup if exists tgmsy3;
drop tablegroup if exists tgmsy4;
--enable_warnings

#create tablegroup tgmsy3 binding true partition by range columns 2
#(partition p0 values less than (3,4),partition p1 values less than(12,345),partition p2 values less than (324543,3435));
#--error 1149
#alter tablegroup tgmsy3 add partition (partition p4 values in(default));

#create tablegroup tgmsy4 binding true partition by list columns 2
#(partition p0 values in ((3,4)), partition p1 values in ((5,6)), partition p2 values in ((7,8)));
#--error 1149
#alter tablegroup tgmsy4 add partition (partition p4 values less than (9,10));

#drop tablegroup tgmsy3;
#drop tablegroup tgmsy4;
