--disable_warnings
DROP TABLE if exists v0;
--enable_warnings

CREATE TABLE v0 ( v2 INTEGER , v1 INTEGER PRIMARY KEY UNIQUE PRIMARY KEY UNIQUE PRIMARY KEY UNIQUE PRIMARY KEY PRIMARY KEY UNIQUE UNIQUE PRIMARY KEY UNIQUE UNIQUE PRIMARY KEY ) COLLATE utf8_bin ;

--error 1241
select  * from v0 where ((1, 1), (1,2) ) not in (SELECT * FROM v0);

DROP TABLE v0;
