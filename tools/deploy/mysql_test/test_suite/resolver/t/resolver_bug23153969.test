--disable_warnings
drop table if exists security_account;
--enable_warnings

CREATE TABLE `security_account` (
  `SECURITY_ACCOUNT_ID` varchar(20) NOT NULL,
  `CUSTOMER_ID` bigint(20) NOT NULL,
  `ID_SN` bigint(20) NULL,
  `INFO_SN` bigint(20) NULL,
  `ACCOUNT_ID` varchar(20) NULL,
  `CUSTOMER_TYPE` varchar(2) NULL,
  `EXCHANGE_ID` char(1) NULL,
  `SECURITY_ACCOUNT_TYPE` char(2) NULL,
  `SECURITY_ACCOUNT_NAME` varchar(120) NULL,
  `SECU_ACCOUNT_STATUS` char(2) NULL,
  `OWNERSHIP_TYPE` char(1) NULL,
  `OPEN_MODE` char(1) NULL,
  `OPEN_AGENT_ID` char(6) NULL,
  `OPEN_BRANCH_ID` char(10) NULL,
  `CLOSE_AGENT_ID` char(6) NULL,
  `CLOSE_BRANCH_ID` char(10) NULL,
  `RELATION_CONFIRM_STATUS` char(1) NULL,
  `RELATION_CONFIRM_AGENT` char(6) NULL,
  `RELATION_CONFIRM_BRACH` char(10) NULL,
  `FOREIGN_STRATEGIC_INVESTOR` char(1) NULL,
  `SHENZHEN_PURCHASE_CAP_FLAG` char(1) NULL,
  `CLEARING_PARTICIPANT` char(6) NULL,
  `TAMFLAG` char(1) NULL,
  `TARGETED_BOND_ACCOUNT_FLAG` char(1) NULL,
  `COUNTERPART_ACCOUNT_ID` varchar(20) NULL,
  `SPECIAL_CLEARING_PARTICIPANT` varchar(8) NULL,
  `FIRST_TRD_DATE` int(11) NULL,
  `PBU` varchar(8) NULL,
  `OPEN_DATE` int(11) NULL,
  `UNQUALIFIED_FLAG` char(1) NULL,
  `PROPRIETARY_TRADING_FLAG` char(1) NULL,
  `PARENT_SECURITY_ACCOUNT_ID` varchar(20) NULL,
  `CLOSE_DATE` int(11) NULL DEFAULT '0',
  `RELATED_SEC_ACCT_ID` varchar(20) NULL,
  `IPO_CODE` varchar(6) NULL,
  `SPECIAL_FLAG` char(1) NULL DEFAULT '0',
  `TA_ASSIGN_FLAG` char(1) NULL DEFAULT '0',
  `F97_FLAG` char(1) NULL DEFAULT '0',
  `CRONK_FLAG` char(1) NULL DEFAULT '0',
  `FUND_OPEN_MODE` char(1) NULL,
  `ANNUAL_EXAMINATION_STATUS` char(1) NULL,
  `ANNUAL_EXAMINATION_DATE` int(11) NULL,
  `RESERVE_FLD` varchar(10) NULL,
  PRIMARY KEY (`CUSTOMER_ID`, `SECURITY_ACCOUNT_ID`),
  UNIQUE KEY `SECURITY_ACCOUNT_UI1` (`SECURITY_ACCOUNT_ID`) STORING (`SECURITY_ACCOUNT_TYPE`, `SECU_ACCOUNT_STATUS`, `FIRST_TRD_DATE`) GLOBAL BLOCK_SIZE 16384,
  KEY `SECURITY_ACCOUNT_IDX2` (`ACCOUNT_ID`) GLOBAL BLOCK_SIZE 16384,
  KEY `SECURITY_ACCOUNT_IDX3` (`CUSTOMER_ID`) GLOBAL BLOCK_SIZE 16384,
  KEY `SECURITY_ACCOUNT_IDX4` (`ID_SN`) GLOBAL BLOCK_SIZE 16384,
  KEY `SECURITY_ACCOUNT_IDX5` (`INFO_SN`) GLOBAL BLOCK_SIZE 16384,
  KEY `SECURITY_ACCOUNT_IDX7` (`OPEN_DATE`) GLOBAL BLOCK_SIZE 16384
)
partition by range(CUSTOMER_ID)
