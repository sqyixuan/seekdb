# owner: yibo.tyf
# owner group: sql1
# tags: resolver

--disable_warnings
drop table if exists t1, t2;
--enable_warnings
--result_format 4

create table t1 (c1 varchar(10)) partition by key (c1) partitions 3;
create table t2 (c1 varchar(10)) partition by key (c1) partitions 3;

## index on two same column with different prefix length not support
--error 1060
CREATE UNIQUE INDEX idx1 USING BTREE ON t1(c1(3), c1(6));

## index on one prefix column and explicit storing entire column
CREATE UNIQUE INDEX idx2 USING BTREE ON t1(c1(3)) storing (c1) global;
select column_name, rowkey_position, index_position, is_hidden
from oceanbase.__all_table t, oceanbase.__all_column c
where t.table_name like '%idx2' and t.table_id = c.table_id
order by column_name;

## index on one prefix column and implicit storing entire column
CREATE UNIQUE INDEX idx3 USING BTREE ON t2(c1(3)) global;
select column_name, rowkey_position, index_position, is_hidden
from oceanbase.__all_table t, oceanbase.__all_column c
where t.table_name like '%idx3' and t.table_id = c.table_id
order by column_name;

drop table if exists t1, t2;

--echo #bug:
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1(id int, s1 int);
create table t2(id int, c1 int);
INSERT INTO t1 VALUES(0,1),(1,0),(2,3),(0,4);
INSERT INTO t2 VALUES(0,1),(1,0),(2,3),(0,4);

select id, sum(s1), sum((select s1)), sum((select s1 from t2 limit 1)) from t1 group by id;

--error 1111
select id, sum((select max((select s1)) from t2)) from t1 group by id;