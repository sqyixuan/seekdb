# owner: dingjincheng.djc
# tags: optimizer
# owner group: sql1
# tags: optimizer, cross_validation

--result_format 4

# bugfix : 

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int default 0, c2 int, c3 int as (c1+1), index idx1(c3));

explain insert into t1(c1,c2) values(1, c1+1);
insert into t1(c1,c2) values(1, c1+1);
explain insert into t1(c2,c1) values(c1+1,1);
insert into t1(c2,c1) values(c1+1,1);
select * from t1;

explain insert into t1(c3,c1) values(default, 1);
insert into t1(c3,c1) values(default, 1);
explain insert into t1(c1,c3) values(1, default);
insert into t1(c1,c3) values(1, default);
select * from t1;

explain insert into t1(c1,c3,c2) values(1, default, c3+1);
insert into t1(c1,c3,c2) values(1, default, c3+1);
explain insert into t1(c3,c2,c1) values(default, c3+1, 1);
insert into t1(c3,c2,c1) values(default, c3+1, 1);
select * from t1;

explain insert into t1(c1,c3,c2) values(1, default, c3+1), (2,default,c3+2), (3, default, c1+2);
insert into t1(c1,c3,c2) values(1, default, c3+1), (2,default,c3+2), (3, default, c1+2);
explain insert into t1(c3,c2,c1) values(default, c3+1, 1), (default, c3+2, 2), (default,3,3);
insert into t1(c3,c2,c1) values(default, c3+1, 1), (default, c3+2, 2), (default,3,3);
select * from t1;
drop table t1;

#BugFix:
create table t1(c1 int as (c2+1), c2 int, c3 int);
explain insert into t1() values();
insert into t1() values();
select * from t1;