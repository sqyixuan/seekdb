# owner: dingjincheng.djc
# owner group: sql1
# tag: resolver

# this file tests the adaptive comment. e.g., "/*! xxxxx */" and "/*!VERSION xxxxx */".

# -- without version --
# normal case
select 1 /*! ,2 */;
select 1 /**! ,2 */;
#--error 1064
select 1 /*! ,2 **/;
select 1 /**! ,2 **/;

# test ' '(space)
select 1 /*!,2*/;
select 1 /*!,2 */;
select 1 /*! ,2*/;
select 1/*!,2*/,3;

# with version
select 1 /*!50600 ,2 */;
select 1 /*!80600 ,2 */;

# treated as normal comment 
select 1 /**!50600 ,2 */;
select 1 /**!80600 ,2 */;

#--error 1064
select 1 /*!50600 ,2 **/;
#--error 1064
select 1 /*!80600 ,2 **/;

# illegal version
#--error 1064
select 1 /*!506000 ,2 */;
#--error 1064
select 1 /*!5060 ,2 */;
select 1 /*!5061l ,2 */; 
--error 1064
select 1 /*!50*/l ,2 */;
#--error 1064
select 1 /*!5.6.11 ,2 */;

# in different clauses; only test sample cases, more complicated cases should be tested;
--error 0,1051
drop table t1;
create table t1 (c1 int);
insert into t1 values (1);
select 1 /*! ,* */ from t1; # should succeed
--error 1064
select 1 /*! ,* */ */ from t1; 
--error 1064
select 1 /*! ,* ***/ */ from t1; 
# -- with version --
insert into t1 values(1)/*!50000 ,(2),(3) */;
select * from t1;

update t1 set c1 = 1 /*!50000 where c1=2 */;
select * from t1;

delete from t1 /*!50000 where c1=2 */;
select * from t1;

# more create table cases to further test the real scenarios.
--error 0,1051
drop table t1;
create table t1 (c1 int /*! primary key*/, c2 int);
desc t1;

--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
create table t1 (c1 int);
create table t2 /*!50000 like t1 */;
desc t2;

#--error 0,1051
#drop table t1;
#create /*!50000 temporary */ table t1 (c1 int);
#desc t1;

--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
create table t1 (c1 int /*!50000 primary key*/);
create table t2 (c1 int,c2 int,/*! foreign key(c2) references t1(c1)*/);
desc t2;
--error 1452
insert into t2 values (1,1);
drop table t2;
drop table t1;

# test '*/'
select 1*/*!2*/;
select 1*/*!2**/3;

# test fast parser, the results of the following two sql should be 1;
select /*!111111 */;
select /*!111111 */;


create table t1 (c1 int);
select */*!,2*/ from t1;
--error 0,1051
drop table t1;
