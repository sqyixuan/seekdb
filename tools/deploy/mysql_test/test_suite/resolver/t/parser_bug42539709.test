# owner group: sql1
# tags: parser

CREATE TABLE IF NOT EXISTS `mdm_measurement_unit` (
  `measure_name` varchar(100) DEFAULT NULL COMMENT '计量名称',
  `measure_name_en` varchar(100) DEFAULT NULL,
  `unit_name` varchar(100) DEFAULT NULL COMMENT '单位',
  `unit_code` varchar(100) DEFAULT NULL COMMENT '英文单位',
  `is_base_unit` int(11) DEFAULT NULL COMMENT '是否基本单位',
  `is_base_unit_en` int(11) DEFAULT NULL COMMENT '是否基本单位',
  `conversion_factor` decimal(10,3) DEFAULT NULL COMMENT '换算系数',
  `pk_mdm` varchar(64) NOT NULL COMMENT '自定义主键',
  `mdm_code` varchar(50) DEFAULT NULL,
  `mdm_parentcode` varchar(50) DEFAULT NULL,
  `treeref_foreignkey` varchar(64) DEFAULT NULL,
  `treemasterid` varchar(64) DEFAULT NULL,
  `treeparentid` varchar(64) DEFAULT NULL,
  `link_fieldvalue` varchar(64) DEFAULT NULL,
  `mdm_duplicate` int(11) DEFAULT '0',
  `mdm_seal` int(11) DEFAULT '0',
  `mdm_version` int(11) DEFAULT NULL COMMENT '版本',
  `creator` varchar(64) DEFAULT NULL COMMENT '创建者',
  `createtime` varchar(19) DEFAULT NULL COMMENT '创建时间',
  `modifier` varchar(64) DEFAULT NULL COMMENT '更新者',
  `modifytime` varchar(19) DEFAULT NULL COMMENT '更新时间',
  `ts` timestamp NULL DEFAULT CURRENT_TIMESTAMP COMMENT '时间戳',
  `dr` int(11) DEFAULT '0' COMMENT '0 不删除 1 删除',
  `mul_language` json DEFAULT NULL COMMENT '多语json',
  `name2` varchar(100) DEFAULT NULL,
  `name3` varchar(100) DEFAULT NULL,
  `name4` varchar(100) DEFAULT NULL,
  `name5` varchar(100) DEFAULT NULL,
  `name6` varchar(100) DEFAULT NULL,
  `unit_name_resid` varchar(40) DEFAULT NULL COMMENT '多语平台编码',
  `mul_language_unit_name` json DEFAULT NULL COMMENT '多语json',
  `tenant_id` varchar(100) DEFAULT NULL,
  `sys_id` varchar(50) DEFAULT NULL ,
  `ytenant_id` varchar(36) DEFAULT '~',
  PRIMARY KEY (`pk_mdm`) USING BTREE,
  UNIQUE KEY `mdm_measurement_unit_m_c` (`mdm_code`) USING BTREE
) ENGINE=InnoDB ;
drop procedure if exists p_aa_updatecolumn;
DELIMITER //;
create procedure p_aa_updatecolumn(IN tablename varchar(50), IN columnname varchar(50),IN executeStr varchar(1000), IN executeType varchar(50))
BEGIN
  DECLARE CurrentDatabase VARCHAR(100);
  SELECT DATABASE() INTO CurrentDatabase;
  SET @tablename = tablename;
  SET @columnname = columnname;
  SET @executeType = executeType;
  SET @executeStr = executeStr;
  SET @count = (SELECT COUNT(*) FROM information_schema.COLUMNS WHERE table_schema=CurrentDatabase AND TABLE_NAME=@tablename AND
      COLUMN_NAME=@columnname);
  IF @executeType = 'add' AND @count = 0 THEN
  PREPARE stmt1 FROM @executeStr;
  EXECUTE stmt1;
  ELSEIF @executeType = 'alter' AND @count >0 THEN
  PREPARE stmt1 FROM @executeStr;
  EXECUTE stmt1;
  END IF;
END//
DELIMITER ;//

call p_aa_updatecolumn('mdm_measurement_unit','name3',"ALTER TABLE mdm_measurement_unit modify COLUMN name3 varchar(100) NULL AFTER name2;;",'alter');
drop procedure if exists p_aa_updatecolumn;
drop table `mdm_measurement_unit`;

