CREATE TABLE t2 ( a INT AUTO_INCREMENT PRIMARY KEY, b VARCHAR(50), c varchar(100) GENERATED ALWAYS AS (CONCAT(b,'\n')) );
INSERT INTO t2(a,b) VALUES(1, '\n');
select * from t2;
