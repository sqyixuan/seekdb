SET sql_mode = 'NO_BACKSLASH_ESCAPES';
CREATE TABLE t1(a INT , b VARCHAR(50)) PARTITION BY LIST columns(b)( PARTITION p0 VALUES IN ('abc\def','中国\人民'), PARTITION p1 VALUES IN ('hig\多多','klm \ \ '));
