select .e2 from dual;

create table TMIX91P(F06NUMERIC16X16     NUMERIC(16,16));
insert into TMIX91P values (.111111111111111);
insert into TMIX91P values (.99999999999);
insert into TMIX91P values (.1234567890);
select * from TMIX91P;

select .234wise from dual;
select 1 from dual where 0.1>0.1order by 1;

