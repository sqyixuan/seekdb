create table test.1(test int);
create table test_table(3e int);
INSERT INTO test_table (3e) VALUES (1.23E4);
--error 1064
select .e+10 from test_table;
--error 1054
select e+10 from test_table;
--error 1064
select .1e+ from test_table;
--error 1064
select .1e- from test_table;
select .1e+10 from test_table;
select -.1e-10 from test_table;
--error 1367
select .1e1000 from test_table;
