--disable_warnings
drop table if exists test,test_table,t1,TMIX91P, test.1,`123abc.123`;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_no = 1170, error_code = 4001, frequency = 1;
connection default;
--echo ========================================= test basic ===========================================

create table test(123abc double, 1a2b3c double, aa0011bb double, 00bb33cc double);
insert into test values (0.1,0.2,0.3,0.4);
insert into test values (1,2,3,4);
insert into test (123abc, 1a2b3c, aa0011bb, 00bb33cc) values (11,22,33,44);
select * from test;
select 123abc, 1a2b3c, aa0011bb, 00bb33cc from test;
select test.123abc, test.1a2b3c, test.aa0011bb, test.00bb33cc from test;
select `test`.`123abc`, `test`.`1a2b3c`, `test`.`aa0011bb`, `test`.`00bb33cc` from `test`;
select test.test.123abc, test.test.1a2b3c, test.test.aa0011bb, test.test.00bb33cc from test;
select `test`.`test`.`123abc`, `test`.`test`.`1a2b3c`, `test`.`test`.`aa0011bb`, `test`.`test`.`00bb33cc` from test;

--error 1054
select `test.test.123abc` from test;
select `test`.test.123abc from test;
--error 1064
select test.`test`.123abc from test;
select test.test.`123abc` from test;
select test.`test`.`123abc` from test;
--error 1054
select test.`test.123abc` from test;
--error 1064
select `test`.`test`.123abc from test;
--error 1064
select `test.test`.123abc from test;
select `test`.test.`123abc` from test;

--error 1054
select `test.test.*` from test;
select `test`.test.* from test;
select test.`test`.* from test;
select test.test.* from test;
--error 1054
select test.`test`.`*` from test;
--error 1054
select test.`test.*` from test;
select `test`.`test`.* from test;
--error 1051
select `test.test`.* from test;
--error 1054
select `test`.test.`*` from test;

select test.123abc, .123 from test;
select test.`123abc`, .123 from test;
select * from test where 123abc=1;
--error 1064
select * from test where `test`.123abc=0.1; 
select * from test where test.`123abc`=0.1; 


