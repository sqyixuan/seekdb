--echo ============================================ test create table ignore/replace ============================================
--error 0,942,1051
drop table t1;
--error 0,942,1051
drop table ignore_1;
--error 0,942,1051
drop table ignore_2;
--error 0,942,1051
drop table replace_1;
--error 0,942,1051
drop table replace_2;

--echo ============ test basic usage
create table t1(id int ,name varchar(10));
insert into t1 values(1,'zhangsan'),(1,'lisi'),(2,'wangwu');
create table ignore_1(id int primary key,name varchar(10));
insert ignore into ignore_1 select * from t1;
select * from ignore_1;
create table ignore_2(id int primary key,name varchar(10)) ignore select * from t1;
select * from ignore_2;
create table replace_1(id int primary key,name varchar(10));
replace into replace_1 select * from t1;
select * from replace_1;
create table replace_2(id int primary key,name varchar(10)) replace select * from t1;
select * from replace_2;

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ignore_1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ignore_2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table replace_1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table replace_2;

