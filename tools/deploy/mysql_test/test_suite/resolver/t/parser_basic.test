--echo ============================================ test KEY_BLOCK_SIZE ============================================
--error 0,942,1051
drop table t1;
--error 0,942,1051
drop table t2;
--error 0,942,1051
drop table t3;
--error 0,942,1051
drop table t4;
CREATE TABLE t1(
  c1 varchar(10) NOT NULL COMMENT 'c1 comment',
  c2 int(11) DEFAULT NULL,
  KEY i1 (c1) KEY_BLOCK_SIZE=16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' KEY_BLOCK_SIZE=16384; 
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
CREATE TABLE t2(
  c1 varchar(10) NOT NULL COMMENT 'c1 comment',
  c2 int(11) DEFAULT NULL,
  KEY i1 (c1) KEY_BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' KEY_BLOCK_SIZE 16384;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
alter table t1 ROW_FORMAT=COMPRESSED KEY_BLOCK_SIZE=123;
alter table t1 set key_block_size=9;
alter table t1 add index i2(c2) key_block_size=9;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

create table t3(c1 int);
create index test on t3(c1) key_block_size=1 key_block_size=1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t3;

create table t4(c1 int) key_block_size=1 key_block_size=1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t4;
--echo ============================================ test opt_column_reference ============================================
--error 0,942,1051
drop table t1;

create table t1( id int primary key, sid int references tb11(id) match full on delete set null);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
alter table t1 add column sid_test int references tb11(id) match full on delete set null;
alter table t1 add (sid_3 int references tb11(id) match full on delete set null,
                    sid_2 int references tb11(id) match full on delete set null);
alter table t1 add column e int references tb11(id) match full on delete set null first;
alter table t1 add column f int references tb11(id) match full on delete set null before id;
alter table t1 add column g int references tb11(id) match full on delete set null after id;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

