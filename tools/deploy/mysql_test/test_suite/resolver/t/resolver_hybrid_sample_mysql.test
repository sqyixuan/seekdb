--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

CREATE TABLE t1(c1 char(10));
INSERT INTO t1 VALUES('a'), ('b'), ('c');

explain select * from t1 SAMPLE HYBRID(1);
explain select * from t1 SAMPLE HYBRID(0.4) SEED(12345);
DROP TABLE t1;
