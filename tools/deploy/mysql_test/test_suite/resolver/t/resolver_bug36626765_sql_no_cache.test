select sql_no_cache 1;
select /*+ no_rewrite */ sql_no_cache 1;
select sql_no_cache /*+ no_rewrite */ 1;
select sql_no_cache distinct 1;
select /*+ no_rewrite */ sql_no_cache distinct 1;
select /*+ no_rewrite */ sql_no_cache /*+ no_merge */ distinct 1;

# more than 2 opt_query_expression_options
select distinct distinct distinct 1;

# sql_cache/sql_no_cache could alao be identifier
--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
create table t1 (sql_no_cache int);
create table t2 (sql_cache int);
insert into t1 values (1);
insert into t2 values (2);
select 1, sql_no_cache from t1;
select 1, sql_cache from t2;
drop table t1;
drop table t2;

