# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: resolver, optimizer
# description: insert 插入生成列时应该报错

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1(a int, b int generated always as (a + 1) virtual);

--error 3105
insert into t1 values(1,1);
--error 3105
insert into t1 values row(1,1);
--error 3105
insert into t1 values row(1,1), row(2,2);
--error 3105
insert into t1 select 1,1;
--error 3105
insert into t1 select 1,1 union select 2,2;
--error 1136
insert into t1 select 1,1,1 union select 2,2,2;

CREATE TABLE t2 (
  A int(11) DEFAULT NULL,
  B int(11) DEFAULT NULL,
  C int(11) GENERATED ALWAYS AS ((A + 0)) VIRTUAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 LOB_INROW_THRESHOLD=0
 partition by hash(c)
(partition p0,
partition p1,
partition p2,
partition p3,
partition p4);

--error 3105
INSERT INTO t2 SELECT 1,2,3 FROM dual UNION ALL SELECT 4,5,6 FROM dual;

drop table t1;
drop table t2;