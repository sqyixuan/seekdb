# owner: zhanyue.zzy
# owner group: sql1
# tags: resolver, optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings
--result_format 4

CREATE TABLE T1 (pk INT,col_int NUMBER(10));

--disable_query_log
--disable_result_log
INSERT INTO T1 VALUES(1,'0');
INSERT INTO T1 VALUES(2,'1');
select count(*) from t1;
--enable_result_log
--enable_query_log

## compare subquery
select * from T1 WHERE (select min(abs(pk)) from T1)=0 or (select min(abs(col_int)) from T1)=0;

## extract info after canonicalizer
select 1 from t1 having sum( pk ) > 1 or sum( pk ) > 1;

drop table if exists t1;
