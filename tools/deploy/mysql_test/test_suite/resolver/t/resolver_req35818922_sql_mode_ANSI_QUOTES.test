set @@session.sql_mode="ANSI_QUOTES";

--error 0,1051
drop table `t1`;
--error 0,1051
drop table `t2`;
--error 0,1051
drop table "t1 t2";

create table "t1" (c1 int);
create table "t1 t2" (c1 int);
create table t2 ("c1 c2" int);

select "c1 c2" from t2;
select c1 from "t1 t2";

# double  double-quotes
--error 0,1051
drop table "a""a";
create table "a""a" ("""c1" int);
insert into "a""a" values (1);
select * from "a""a";

--error 0,1051
drop table `t1`;
create table `t1` (c1 varchar(100));
--error 1050
create table "t1" (c1 varchar(100));
insert into "t1" values ('aaaa');
--error 1054
insert into "t1" values ("aaaa");
--error 1054
insert into "t1" values ("""");
insert into "t1" values ('"');
select * from "t1";
--error 1054
select "t1" from "t1";
drop table "t1";

--error 1064
create table "t1\"t2" (c1 int);
set @@session.sql_mode=default;
