# owner: guohanyun.ghy
# owner group: sql1
# tags: resolver


--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t12345;
drop view if exists view1;
drop view if exists view2;
drop view if exists view3;
--enable_warnings
--result_format 4

create table t1(c1 int);
create table t2(c1 int);
create table t3(c1 int);

insert into t1 values (1);
insert into t1 values (2);
insert into t1 values (3);
insert into t2 values (1);

select * from t1 where exists (select *);
select * from t1 where exists (select * from dual);
select * from t1 where exists (select * from t2);
select * from t1 where exists (select t1.* from t2);
select * from t1 where exists (select t12345.* from t2);
select * from t1 where exists (select * from t3);
select * from t1 where exists (select t1.* from t3);
select * from t1 where exists (select t12345.* from t3);
select * from t1 where exists (select t12345.* from dual);
select * from t1 where exists (select t12345.*);

update t1 set c1 = c1 + 1 where exists (select *);
update t1 set c1 = c1 + 1 where exists (select * from dual);
update t1 set c1 = c1 + 1 where exists (select * from t2);
update t1 set c1 = c1 + 1 where exists (select t12345.* from t2);
update t1 set c1 = c1 + 1 where exists (select t12345.* from t3);
update t1 set c1 = c1 + 1 where exists (select t12345.*);

create view view1 as select * from t1 where exists (select *);
create view view2 as select * from t1 where exists (select t12345.* from t2);
create view view3 as select * from t1 where exists (select t12345.*);

select * from view1;
select * from view2;
select * from view3;

--error 1051
select * from t1 where t1.c1 in (select t1.* from t2);
--error 1051
select * from t1 where t1.c1 in (select t1.* from dual);
--error 1096
select * from t1 where t1.c1 in (select * from dual);

drop table t1;
drop table t2;
drop table t3;
drop view view1;
drop view view2;
drop view view3;