--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings

--result_format 4

CREATE TABLE t1(rowid int );
INSERT INTO t1 VALUES (1);

CREATE VIEW v1 AS SELECT * FROM t1 ;
SELECT ROWID FROM t1;
SELECT * FROM t1;
SELECT ROWID FROM v1;
SELECT * FROM v1;

drop table t1;
drop view v1;
