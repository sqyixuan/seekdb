# owner: sean.yyj
# tags: optimizer
# owner group: sql1

--result_format 4

# bugfix : 

--disable_warnings
drop table if exists t1;
--enable_warnings

--explain_protocol 1
--result_format 4

create table t1(c1 int);

select /*+no_rewrite*/ 1 from t1 where (c1 = 1 and 3=3) and (4=4 and ((c1 = 1 and 1=1 and 2=2) or (c1 = 1 and 3=3)));

select /*+no_rewrite*/ 1 from t1 where ((c1 = 1 and 1=1 and 2=2) or (c1 = 1 and 3=3)) and (4=4 and ((c1 = 1 and 1=1 and 2=2) or (c1 = 1 and 3=3)));

select /*+no_rewrite*/ 1 from t1 where ((c1 = 1 and 1=1 and 2=2) or (c1 = 1 and 3=3 and 5=5)) and (4=4 and ((c1 = 1 and 1=1 and 2=2) or (c1 = 1 and 3=3 and 5=5)));

drop table t1;