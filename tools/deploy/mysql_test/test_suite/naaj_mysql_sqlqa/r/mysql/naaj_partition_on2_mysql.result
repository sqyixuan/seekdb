################Setting ''_ optimizer_ null_ aware_ Antijoin 'is ON################
alter system set weak_read_version_refresh_interval = '50ms';
select sleep(3) from dual;
sleep(3)
0
SET _optimizer_null_aware_antijoin=ON;
#PARTITION BY RANGE
DROP TABLE IF EXISTS t2;
Warnings:
Note	1051	Unknown table 'test.t2'
DROP TABLE IF EXISTS t1;
Warnings:
Note	1051	Unknown table 'test.t1'
CREATE TABLE t1(c0 INT,c1 INT)
PARTITION BY RANGE(c1)
(PARTITION l1 VALUES LESS THAN(50),
PARTITION l2 VALUES LESS THAN(100)
);
CREATE TABLE t2(c0 INT,c1 INT)
PARTITION BY RANGE(c1)
(PARTITION l1 VALUES LESS THAN(75),
PARTITION l2 VALUES LESS THAN(150)
);
CREATE PROCEDURE p1()
BEGIN
DECLARE j INT DEFAULT 1;
WHILE j <= 45 DO
IF MOD(j,11) = 0 THEN
INSERT INTO t1 VALUES(j,50);
ELSEIF MOD(j,9) = 0 THEN
INSERT INTO t1 VALUES(j,99);
ELSEIF MOD(j,7) = 0 THEN
INSERT INTO t1 VALUES(j,j+55);
ELSEIF MOD(j,5) = 0 THEN
INSERT INTO t1 VALUES(j,j-2);
ELSEIF MOD(j,3) = 0 THEN
INSERT INTO t1 VALUES(j,j*2);
ELSE
INSERT INTO t1 VALUES(j,j+1);
END IF;
SET j = j + 1;
END WHILE;
END;
//
CREATE  PROCEDURE p2()
BEGIN
DECLARE j INT DEFAULT 1;
WHILE j <= 45 DO
IF MOD(j,11) = 0 THEN
INSERT INTO t2 VALUES(j,j*2);
ELSEIF MOD(j,9) = 0 THEN
INSERT INTO t2 VALUES(j,121);
ELSEIF MOD(j,7) = 0 THEN
INSERT INTO t2 VALUES(j,j+100);
ELSEIF MOD(j,5) = 0 THEN
INSERT INTO t2 VALUES(j,j-5);
ELSEIF MOD(j,3) = 0 THEN
INSERT INTO t2 VALUES(j,j*-3);
ELSE
INSERT INTO t2 VALUES(j,j+2);
END IF;
SET j = j + 1;
END WHILE;
END;
//
CALL p1();
CALL p2();
