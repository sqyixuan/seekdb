tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1 WHERE tl1.c1 IS NOT NULL)) tp2 ON
tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY tp1.c0,tp1.c1)
