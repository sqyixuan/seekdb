#For the generated column with foreign key, the left table has null value and the right table has no null value.
DROP TABLE t2;
DROP TABLE t1;
CREATE TABLE t2(c0 INT,c1 CHAR(5) PRIMARY KEY);
CREATE TABLE t1(c0 INT,c1 CHAR(5) GENERATED ALWAYS AS (2 * c0) VIRTUAL, CONSTRAINT FK_c1_c0 FOREIGN KEY(c1) REFERENCES t2(c1));
