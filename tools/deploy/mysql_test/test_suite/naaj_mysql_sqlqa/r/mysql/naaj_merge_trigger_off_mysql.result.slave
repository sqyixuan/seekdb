DROP TRIGGER IF EXISTS tg1;
CREATE TRIGGER tg1 AFTER INSERT ON t2 FOR EACH ROW
BEGIN
DECLARE new_c0 INT;
DECLARE new_c1 VARCHAR(10);
DECLARE done INT DEFAULT false;
DECLARE cur_t1_c0 CURSOR FOR SELECT c0,c1 FROM t1 WHERE c1 NOT IN(SELECT c1 FROM t3 WHERE c1 IS NOT NULL);
DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = true;
OPEN cur_t1_c0;
do_loop:LOOP
FETCH cur_t1_c0 INTO new_c0,new_c1;
IF done THEN
LEAVE do_loop;
END IF;
INSERT INTO t1(c0,c1) VALUES(new_c0,new_c1);
END LOOP;
CLOSE cur_t1_c0;
END;
