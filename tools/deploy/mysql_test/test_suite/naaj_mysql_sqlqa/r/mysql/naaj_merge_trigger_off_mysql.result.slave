purge recyclebin;
# 环境清理
DROP USER zhang;
ERROR HY000: Operation DROP USER failed for 'zhang'@'%'
CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';
CREATE DATABASE IF NOT EXISTS naaj_test;
USE naaj_test;
################Setting ''_ optimizer_ null_ aware_ Antijoin 'is OFF################
SET _optimizer_null_aware_antijoin=OFF;
#MySQL不支持与Oracle一致的meger into语法，但是可以使用 on duplicate key update语法模拟meger into语法。
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,c1 CHAR(10));
CREATE TABLE t2(c0 INT,c1 VARCHAR(10));
INSERT INTO t1 VALUES(0,'AB'),(1,'中文'),(2,'# $ :'),(2,'12'),(4,22),(5,''),(6,NULL);
INSERT INTO t2 VALUES(0,'A'),(4,23),(5,NULL);
SELECT * FROM t1 ORDER BY 1,2;
c0	c1
0	AB
1	中文
2	# $ :
2	12
4	22
5	
6	NULL
SELECT * FROM t2 ORDER BY 1,2;
c0	c1
0	A
4	23
5	NULL
INSERT INTO t1 SELECT t2.c0,t2.c1 FROM t2 WHERE t2.c1 NOT IN(SELECT c1 FROM t1) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
SELECT * FROM t1 ORDER BY 1,2;
c0	c1
0	AB
1	中文
2	# $ :
2	12
4	22
5	
6	NULL
EXPLAIN BASIC INSERT INTO t1 SELECT /*+READ_CONSISTENCY (weak)*/ t2.c0,t2.c1 FROM t2 WHERE t2.c1 NOT IN(SELECT c1 FROM t1) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
Query Plan
=====================================
|ID|OPERATOR               |NAME    |
-------------------------------------
|0 |DISTRIBUTED INSERT_UP  |        |
|1 | SUBPLAN SCAN          |VIEW1   |
|2 |  NESTED-LOOP ANTI JOIN|        |
|3 |   TABLE SCAN          |t2      |
|4 |   MATERIAL            |        |
|5 |    PX COORDINATOR     |        |
|6 |     EXCHANGE OUT DISTR|:EX10000|
|7 |      TABLE SCAN       |t1      |
=====================================

