      columns([{t1: ({t1: (t1.__pk_increment, t1.c0, t1.c1)})}]), partitions(p0), 
      column_values([column_conv(BIGINT UNSIGNED,PS:(-1,-1),NOT NULL,t1.__pk_increment.nextval())], [column_conv(INT,PS:(11,0),NULL,VIEW1.c0)], [column_conv(CHAR,utf8mb4_general_ci,length:10,NULL,cast(VIEW1.c1, CHAR(1048576)))]),
      update([t1.c1=column_conv(CHAR,utf8mb4_general_ci,length:10,NULL,cast(inner_trim(2, ?, VIEW1.c1), CHAR(1048576)))])
  1 - output([VIEW1.c0], [VIEW1.c1]), filter(nil), 
      access([VIEW1.c0], [VIEW1.c1])
  2 - output([t2.c0], [t2.c1]), filter(nil), 
      conds([(T_OP_OR, t2.c1 = t1.c1, (T_OP_IS, t2.c1, NULL, 0), (T_OP_IS, t1.c1, NULL, 0))]), nl_params_(nil)
  3 - output([t2.c1], [t2.c0]), filter(nil), 
      access([t2.c1], [t2.c0]), partitions(p0)
