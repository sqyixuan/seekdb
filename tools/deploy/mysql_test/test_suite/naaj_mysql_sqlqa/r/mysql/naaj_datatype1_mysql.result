purge recyclebin;
# 环境清理
DROP USER if exists zhang;
CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';
CREATE DATABASE IF NOT EXISTS naaj_test;
USE naaj_test;
################Setting ''_ optimizer_ null_ aware_ Antijoin 'is ON################
SET _optimizer_null_aware_antijoin=ON;
DROP TABLE t1;
ERROR 42S02: Unknown table 'naaj_test.t1'
DROP TABLE t2;
ERROR 42S02: Unknown table 'naaj_test.t2'
#BLOB TYPE
CREATE TABLE t1(c0 INT,c1 BLOB);
CREATE TABLE t2(c0 INT,c1 BLOB);
INSERT INTO t1 VALUES(1,'A');
INSERT INTO t1 VALUES(2,'12');
INSERT INTO t1 VALUES(3,'A');
INSERT INTO t1 VALUES(4,'');
INSERT INTO t1 VALUES(5,NULL);
INSERT INTO t2 VALUES(1,'AB');
INSERT INTO t2 VALUES(2,'12');
INSERT INTO t2 VALUES(3,'');
INSERT INTO t2 VALUES(4,NULL);
INSERT INTO t2 VALUES(5,'a');
#There are null values on the right side of the left table
#IF "_optimizer_null_aware_antijoin"=ON,EXPLAIN:HASH JOIN ANTI NA
SELECT * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2;
c0	c1
SELECT * FROM t1 WHERE NOT EXISTS (SELECT c1 FROM t2) ORDER BY 1,2;
c0	c1
