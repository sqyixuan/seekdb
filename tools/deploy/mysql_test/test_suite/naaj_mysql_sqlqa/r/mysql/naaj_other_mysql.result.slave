purge recyclebin;
# 环境清理
DROP USER zhang;
ERROR HY000: Operation DROP USER failed for 'zhang'@'%'
CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';
CREATE DATABASE IF NOT EXISTS naaj_test;
USE naaj_test;
################Setting ''_ optimizer_ null_ aware_ Antijoin 'is ON################
SET _optimizer_null_aware_antijoin=ON;
#VIEW
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,c1 CHAR(50));
CREATE TABLE t2(c0 INT,c1 VARCHAR(50));
INSERT INTO t1 VALUES(1,'A');
INSERT INTO t1 VALUES(2,12);
INSERT INTO t1 VALUES(3,'A');
INSERT INTO t1 VALUES(4,NULL);
INSERT INTO t1 VALUES(5,'$ % &');
INSERT INTO t2 VALUES(1,12);
INSERT INTO t2 VALUES(2,'AB');
INSERT INTO t2 VALUES(3,'');
INSERT INTO t2 VALUES(4,NULL);
INSERT INTO t2 VALUES(5,'$%&');
CREATE OR REPLACE VIEW v1 AS SELECT * FROM t1;
CREATE OR REPLACE VIEW v2 AS SELECT * FROM t2;
SELECT * FROM v1 ORDER BY c0,c1;
c0	c1
1	A
2	12
3	A
4	NULL
5	$ % &
SELECT * FROM v2 ORDER BY c0,c1;
c0	c1
1	12
2	AB
3	
4	NULL
5	$%&
SELECT /*USE_HASH(v1,v2)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2) ORDER BY v1.c0,v1.c1;
c0	c1	c0	c1
EXPLAIN BASIC SELECT /*USE_HASH(v1,v2),READ_CONSISTENCY (weak)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2) ORDER BY v1.c0,v1.c1;
