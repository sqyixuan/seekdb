WHERE ta1.c1 NOT IN(SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ c1 FROM t2 tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(a4) WHERE c1 IS NOT NULL)) AND ta1.c0 < 2 ORDER BY 1,2,3;
