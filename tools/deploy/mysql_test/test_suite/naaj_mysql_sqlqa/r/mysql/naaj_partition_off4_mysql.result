(SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(a4) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(e2) tl2 WHERE tl2.c1 IS NOT NULL)) tp1 LEFT JOIN
(SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(e1) tl2 WHERE tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(a6) tl1)) tp2 ON
tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1)),
data2 AS (SELECT /*+parallel(5) USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
(SELECT /*NO_REWRITE*/ tl1.c0,tl1.c1 FROM t1 PARTITION(r2) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(b4) tl2)) tp1 LEFT JOIN
(SELECT te2.c0,te2.c1 FROM t2 PARTITION(b4) te2 WHERE te2.c1 NOT IN (SELECT ta1.c1 FROM t1 PARTITION(r1) ta1 WHERE ta1.c1 IS NOT NULL)) tp2 ON
tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1))
SELECT * FROM data1 d1,data2 d2 WHERE d1.c0=d2.c0 AND d2.c1 NOT IN(SELECT c1 FROM data1 WHERE c1 IS NOT NULL) ORDER BY 1,2;
EXPLAIN BASIC WITH
data1 AS (SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
(SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(a4) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(e2) tl2 WHERE tl2.c1 IS NOT NULL)) tp1 LEFT JOIN
(SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(e1) tl2 WHERE tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(a6) tl1)) tp2 ON
tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1)),
data2 AS (SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
(SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ tl1.c0,tl1.c1 FROM t1 PARTITION(r2) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(b4) tl2)) tp1 LEFT JOIN
(SELECT te2.c0,te2.c1 FROM t2 PARTITION(b4) te2 WHERE te2.c1 NOT IN (SELECT ta1.c1 FROM t1 PARTITION(r1) ta1 WHERE ta1.c1 IS NOT NULL)) tp2 ON
tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1))
SELECT /*+READ_CONSISTENCY (weak)*/ * FROM data1 d1,data2 d2 WHERE d1.c0=d2.c0 AND d2.c1 NOT IN(SELECT c1 FROM data1 WHERE c1 IS NOT NULL) ORDER BY 1,2;
