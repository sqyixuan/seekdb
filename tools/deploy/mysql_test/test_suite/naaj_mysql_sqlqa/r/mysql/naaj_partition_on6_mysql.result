SELECT /*+parallel(2) NO_REWRITE*/ * FROM
(SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t1 tl1 WHERE tl1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(e1) WHERE c1 IS NOT NULL)) ta1,
(SELECT /*+parallel(5) USE_NL(t1,t2)*/ * FROM t2 PARTITION(b3) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1) AND tl2.c1 IS NOT NULL) tb1
WHERE ta1.c1 NOT IN(SELECT /*+USE_HASH(t1,t2)*/ c1 FROM t2  WHERE c1 NOT IN(SELECT c1 FROM t1 PARTITION(a3))) AND ta1.c1 IS NOT NULL ORDER BY 1,2,3;
EXPLAIN BASIC SELECT /*+parallel(2) NO_REWRITE READ_CONSISTENCY (weak)*/ * FROM
(SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 tl1 WHERE tl1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(e1) WHERE c1 IS NOT NULL)) ta1,
(SELECT /*+parallel(5) USE_NL(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t2 PARTITION(b3) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1) AND tl2.c1 IS NOT NULL) tb1
WHERE ta1.c1 NOT IN(SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ c1 FROM t2  WHERE c1 NOT IN(SELECT c1 FROM t1 PARTITION(a3))) AND ta1.c1 IS NOT NULL ORDER BY 1,2,3;
