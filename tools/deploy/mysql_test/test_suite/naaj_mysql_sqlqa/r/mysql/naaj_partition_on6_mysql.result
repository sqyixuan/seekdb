data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tr1.c0,tb1.c1 FROM t1 PARTITION(r2) tr1 JOIN t2 PARTITION(e2) tb1 ON tr1.c0=tb1.c0 WHERE tb1.c1 <>ALL (SELECT c1 FROM t2 PARTITION(b1) WHERE c1 IS NOT NULL))
SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ COUNT(1) FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 WHERE d1.c1 <>ALL (SELECT c1 FROM data2 WHERE c1 IS NOT NULL);
