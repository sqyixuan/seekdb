data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2) */ t1.c0,t2.c1 FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY t1.c0,t1.c1)
SELECT /*NO_REWRITE*/ * FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 AND d1.c1 <>ALL (SELECT c1 FROM data2) ORDER BY 1,2;
