purge recyclebin;
# 环境清理
DROP USER zhang;
CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';
CREATE DATABASE IF NOT EXISTS naaj_test;
USE naaj_test;
################Setting ''_ optimizer_ null_ aware_ Antijoin 'is OFF################
