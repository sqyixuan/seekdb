#使用if...then创建存储过程
CREATE PROCEDURE test_case1(IN v_c0 INT)
BEGIN
DECLARE v_count INT;
IF v_c0 > 4000 AND v_c0 <= 5000 THEN
INSERT INTO t1 SELECT /*+USE_HASH(t1,t2)*/ t2.* FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 >= v_c0);
ELSEIF v_c0 >= 3000 THEN
INSERT INTO t1 SELECT /*+parallel(5) USE_HASH(t1,t2)*/ t2.* FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 >= v_c0 AND c1 IS NOT NULL);
ELSEIF v_c0 >= 2000 THEN
UPDATE t1 SET c0=c0+1 WHERE c1 <>ALL(SELECT /*+USE_HASH(tt,t2)*/ t2.c1 FROM (SELECT * FROM t2 WHERE c0 >= v_c0) tt JOIN t2 ON tt.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT * FROM t2 WHERE c0 >= v_c0) tt WHERE c0 >= v_c0) AND t2.c1 IS NOT NULL);
ELSEIF v_c0 >= 1000 THEN
DELETE FROM t1 WHERE c0 <>ALL(SELECT /*+parallel(2) USE_HASH(tt,t2)*/ t2.c0 FROM (SELECT * FROM t2 WHERE c0 >= v_c0) tt RIGHT JOIN t2 ON tt.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT * FROM t2 WHERE c0 >= v_c0) tt WHERE c0 >= v_c0 AND c1 IS NOT NULL));
ELSE
DELETE FROM t1 WHERE c0 <>ALL(SELECT /*+parallel(2) USE_HASH(tt,t2)*/ t2.c0 FROM (SELECT * FROM t2 WHERE c0 <= v_c0) tt RIGHT JOIN t2 ON tt.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT * FROM t2 WHERE c0 <= v_c0) tt WHERE c0 <= v_c0 AND c1 IS NOT NULL) AND t2.c1 IS NOT NULL);
END IF;
SELECT COUNT(1) FROM t1 INTO v_count;
SELECT v_count;
END;
//
CALL test_case1(4433);
v_count
10000
CALL test_case1(3580);
v_count
12923
CALL test_case1(2560);
v_count
12923
CALL test_case1(1560);
v_count
306
CALL test_case1(560);
v_count
196
