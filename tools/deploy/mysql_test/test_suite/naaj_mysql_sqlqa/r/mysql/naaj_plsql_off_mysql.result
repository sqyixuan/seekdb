CREATE PROCEDURE test_case2(IN v_c0 INT)
BEGIN
DECLARE v_count INT;
IF v_c0 <= 1000 THEN
INSERT INTO t1
WITH
s1 AS (SELECT /*+USE_HASH(t1,t2)*/ t2.* FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 <>ALL(SELECT c1 FROM t1 WHERE c0 > v_c0)),
s2 AS (SELECT /*+USE_HASH(t1,t2)*/ t2.* FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 < v_c0 AND c1 IS NOT NULL))
SELECT s2.* FROM s1 ,s2 WHERE s2.c1 NOT IN(SELECT c1 FROM s1 WHERE c1 IS NOT NULL);
ELSEIF v_c0 <= 2000 THEN
INSERT INTO t1
WITH
s1 AS (SELECT /*+USE_HASH(t1,t2)*/ t1.* FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 > v_c0 AND c1 IS NOT NULL)),
s2 AS (SELECT /*+USE_HASH(t1,t2)*/ t2.* FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 <>ALL(SELECT c1 FROM t1 WHERE c0 < v_c0))
SELECT s2.* FROM s1 JOIN s2 ON s1.c0=s2.c0 WHERE s2.c1 NOT IN(SELECT c1 FROM s1 WHERE c1 IS NOT NULL);
ELSEIF v_c0 <= 3000 THEN
UPDATE t1 SET c0=c0+1 WHERE c1 <>ALL(SELECT s1.c1 FROM
(SELECT t2.c0,t2.c1 FROM (SELECT * FROM t2) tt1 JOIN t2 ON tt1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT c1,c2 FROM t2 WHERE c0 >= v_c0) tt1 WHERE tt1.c2 < 200 AND tt1.c1 IS NOT NULL)) s1 LEFT JOIN
(SELECT t2.c0,t2.c1 FROM (SELECT * FROM t2) tt2 JOIN t2 ON tt2.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT c1,c2 FROM t2 WHERE c0 <= v_c0) tt2 WHERE tt2.c2 < 500 AND tt2.c1 IS NOT NULL)) s2
ON s1.c0=s2.c0 WHERE s2.c1 NOT IN(SELECT c1 FROM (SELECT t2.c0,t2.c1 FROM (SELECT * FROM t2) tt1 JOIN t2 ON tt1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT c1,c2 FROM t2 WHERE c0 >= v_c0) tt1 WHERE tt1.c2 < 200 AND tt1.c1 IS NOT NULL)) s1 WHERE c0>4500 AND c0 IS NOT NULL));
ELSEIF v_c0 <= 4000 THEN
DELETE FROM t1 WHERE c0 <>ALL(SELECT s2.c1 FROM
(SELECT /*+USE_HASH(tt1,t2)*/ t2.c0,t2.c1 FROM (SELECT * FROM t2 WHERE c0 <= 3170) tt1 JOIN t2 ON tt1.c0=t2.c0 WHERE t2.c1 <>ALL(SELECT c1 FROM (SELECT c1 FROM t2 WHERE c0 <= v_c0) tt1 WHERE t2.c0 > v_c0 AND c1 IS NOT NULL)) s1 JOIN
(SELECT /*+USE_HASH(tt2,t2)*/ t2.c0,t2.c1 FROM (SELECT * FROM t2 WHERE c0 >= 3170) tt2 JOIN t2 ON tt2.c0=t2.c0 WHERE t2.c1 <>ALL(SELECT c1 FROM (SELECT c1 FROM t2 WHERE c0 >= v_c0) tt2 WHERE t2.c0 < v_c0)) s2
ON s1.c0=s2.c0 WHERE s2.c1 NOT IN(SELECT c1 FROM (SELECT /*+USE_HASH(tt1,t2)*/ t2.c0,t2.c1 FROM (SELECT * FROM t2 WHERE c0 <= v_c0) tt1 JOIN t2 ON tt1.c0=t2.c0 WHERE t2.c1 <>ALL(SELECT c1 FROM (SELECT c1 FROM t2 WHERE c0 <= v_c0) tt1 WHERE t2.c0 > 3170 AND c1 IS NOT NULL)) s1));
ELSE
DELETE FROM t1 WHERE c0 <>ALL(SELECT s2.c1 FROM
(SELECT /*+USE_HASH(tt1,t2)*/ t2.c0,t2.c1 FROM (SELECT * FROM t2 WHERE c0 > v_c0) tt1 JOIN t2 ON tt1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT c1 FROM t2 WHERE c0 < v_c0) tt1 WHERE t2.c0 > v_c0)) s1,
(SELECT /*+USE_HASH(tt2,t2)*/ t2.c0,t2.c1 FROM (SELECT * FROM t2 WHERE c0 > v_c0) tt2 JOIN t2 ON tt2.c0=t2.c0 WHERE NOT EXISTS(SELECT c1 FROM (SELECT c1 FROM t2 WHERE c0 < v_c0) tt2 WHERE t2.c0 < v_c0)) s2
WHERE s2.c1 NOT IN(SELECT c1 FROM (SELECT t2.c0,t2.c1 FROM t2  WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT c1 FROM t2 WHERE c0 < v_c0) tt1 WHERE t2.c0 > v_c0)) s1));
END IF;
SELECT COUNT(1) FROM t1 INTO v_count;
SELECT v_count;
END;
//
