CREATE PROCEDURE test_case4(IN v_c0 INT)
BEGIN
DECLARE a INT DEFAULT 1;
DECLARE v_count INT;
loop1: LOOP
INSERT INTO t1 SELECT /*+USE_HASH(t1,t2)*/ t2.* FROM t1 LEFT JOIN t2 ON t1.c0 = t2.c0 WHERE
t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 > v_c0 AND c1 IS NOT NULL) AND t2.c0 BETWEEN a AND a*100;COMMIT;
DELETE FROM t1 WHERE c1 NOT IN(SELECT /*+USE_HASH(t2)*/ t2.c1 FROM t2 WHERE c1 IS NOT NULL AND
c1 <>ALL(SELECT c1 FROM (SELECT * FROM t2 WHERE c1 NOT IN(SELECT c1 FROM t2 WHERE c0 <=v_c0 AND c1 IS NOT NULL)) tt WHERE c0 < v_c0 AND
c1 NOT IN(SELECT c1 FROM t2 WHERE c1 IS NOT NULL AND c0 > 1000*a)) AND t2.c0 BETWEEN a*300 AND a*700);COMMIT;
IF a = 3 THEN
LEAVE loop1;
END IF;
SET a = a + 1;
END LOOP;
SELECT COUNT(1) FROM t1 INTO v_count;
SELECT v_count;
END;
//
CALL test_case4(5000);
v_count
5504
DROP PROCEDURE test_case4;
#PARTITION TABLE
DELETE FROM t1 WHERE 1=1;
CALL p1();
SELECT COUNT(1) FROM t1;
COUNT(1)
10000
SELECT COUNT(1) FROM t2;
COUNT(1)
5000
DROP TABLE IF EXISTS test1;
CREATE TABLE test1(c0 INT,c1 INT)
PARTITION BY HASH(c1) PARTITIONS 3;
INSERT INTO test1 SELECT t1.c0,t1.c1 FROM t1 WHERE c1 IS NOT NULL AND c0 < 2000;
SELECT COUNT(1) FROM test1;
COUNT(1)
1999
CREATE PROCEDURE test_case6(IN v_c0 INT)
BEGIN
DECLARE v_count INT;
IF v_c0 <= 1000 THEN
INSERT INTO test1 SELECT t1.c0,t1.c2 FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 NOT IN (SELECT c1 FROM t1 WHERE c1 IS NOT NULL);
ELSEIF v_c0 <= 2000 THEN
UPDATE test1 SET c1 = c1 + v_c0 WHERE c1 <>ALL(SELECT /*+USE_HASH*/ t1.c0 FROM t1 LEFT JOIN t2 ON t1.c0 = t2.c0  WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c1 IS NOT NULL));
ELSE
DELETE FROM test1 WHERE c1 NOT IN(SELECT /*+USE_HASH*/ t2.c0 FROM t1 RIGHT JOIN t2 ON t1.c0 = t2.c0 WHERE t1.c1 <>ALL(SELECT c1 FROM t2));
END IF;
SELECT COUNT(1) FROM test1 INTO v_count;
SELECT v_count;
END;
//
CALL test_case6(587);
v_count
4338
CALL test_case6(1587);
v_count
4338
CALL test_case6(2217);
v_count
0
DROP PROCEDURE test_case6;
DROP TABLE test1;
#调用 FUNCTION
CREATE FUNCTION f_test1(v_c0 INT,v_c1 VARCHAR(10))
RETURNS VARCHAR(100)
BEGIN
DECLARE v_count_t1 INT;
DECLARE v_count_t2 INT;
DECLARE v_count_t3 VARCHAR(100);
IF v_c0 <= 2000 AND v_c1 = '100AB' THEN
INSERT INTO t1 SELECT /*+USE_HASH(t1,t2)*/ t2.* FROM t2 WHERE
t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 > v_c0 AND c1 IS NOT NULL) AND t2.c0 BETWEEN v_c0-100 AND v_c0;
DELETE FROM t2 WHERE c1 <>ALL(SELECT /*+USE_HASH(t1)*/ t1.c1 FROM t1 WHERE
c1 IS NOT NULL AND c1 NOT IN(SELECT c1 FROM t1 WHERE c0 < v_c0 AND c1 NOT IN(SELECT c1 FROM t1 WHERE c1 IS NOT NULL AND c0 > v_c0-100)) AND t1.c0 >= v_c0);
ELSEIF v_c0 <= 4000 AND v_c1 = '@ % *' THEN
INSERT INTO t2 SELECT /*+USE_HASH(t1,t2)*/ t1.* FROM t1 WHERE
t1.c1 NOT IN(SELECT c1 FROM t2 WHERE c0 > v_c0) AND t1.c0 BETWEEN v_c0-100 AND v_c0;
DELETE FROM t1 WHERE c1 <>ALL(SELECT /*+USE_HASH(t2)*/ t2.c1 FROM t2 WHERE
c1 IS NOT NULL AND c1 NOT IN(SELECT c1 FROM t2 WHERE c0 < v_c0 AND c1 NOT IN(SELECT c1 FROM t2 WHERE c0 > v_c0-100)) AND t2.c0 >= v_c0);
ELSE
INSERT INTO t1 SELECT /*+USE_HASH(t1,t2)*/ t2.* FROM t2 WHERE
t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 > v_c0 AND c1 IS NOT NULL) AND t2.c0 BETWEEN v_c0-100 AND v_c0;
DELETE FROM t2 WHERE c1 <>ALL(SELECT /*+USE_NL(t1)*/ t1.c1 FROM t1 WHERE
c1 <>ALL(SELECT c1 FROM t1 WHERE c0 < v_c0 AND c1 <>ALL(SELECT c1 FROM t1 WHERE c0 > v_c0-100)) AND t1.c0 <= v_c0);
END IF;
SELECT COUNT(1) INTO v_count_t1 FROM t1;
SELECT COUNT(1) INTO v_count_t2 FROM t2;
SET v_count_t3 = CONCAT('t1表执行函数后条目合计：',v_count_t1,', t2表执行函数后条目合计：',v_count_t2);
RETURN v_count_t3;
END;
//
SELECT f_test1(3345,'100AB');
f_test1(3345,'100AB')
t1表执行函数后条目合计：10062, t2表执行函数后条目合计：3455
SELECT f_test1(1545,'100AB');
f_test1(1545,'100AB')
t1表执行函数后条目合计：10074, t2表执行函数后条目合计：3385
SELECT f_test1(4545,'100AB');
f_test1(4545,'100AB')
t1表执行函数后条目合计：10119, t2表执行函数后条目合计：3385
SELECT f_test1(2345,'@ % *');
f_test1(2345,'@ % *')
t1表执行函数后条目合计：3106, t2表执行函数后条目合计：3385
SELECT f_test1(5,'中');
f_test1(5,'中')
t1表执行函数后条目合计：3106, t2表执行函数后条目合计：1493
DROP FUNCTION f_test1;
