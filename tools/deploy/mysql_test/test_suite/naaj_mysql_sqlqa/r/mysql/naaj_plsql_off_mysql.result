purge recyclebin;
# 环境清理
DROP USER if exists zhang;
CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';
CREATE DATABASE IF NOT EXISTS naaj_test;
USE naaj_test;
################Setting ''_ optimizer_ null_ aware_ Antijoin 'is ON################
SET _optimizer_null_aware_antijoin=OFF;
#设置超时等待时间
SET wait_timeout=30000000;
SET ob_trx_timeout = 60000000;
SET ob_query_timeout = 60000000;
Create data
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,c1 VARCHAR(50),c2 INT,c3 DATE);
CREATE TABLE t2(c0 INT,c1 VARCHAR(50),c2 INT,c3 TIMESTAMP);
CREATE PROCEDURE p1()
BEGIN
DECLARE i INT DEFAULT 1;
wh1:WHILE i <= 10000 DO
IF i < 1000 THEN
INSERT INTO t1 VALUES(i,i||'AB',10.235,'2020-12-11');
ELSEIF i < 2000 THEN
INSERT INTO t1 VALUES(i,i+1,0.225,'2021-11-01');
ELSEIF i < 4000 THEN
INSERT INTO t1 VALUES(i,'@ % *',110.352,'2020-10-21');
ELSEIF i < 6000 THEN
INSERT INTO t1 VALUES(i,'',210.5,'2022-01-31');
ELSEIF i < 8000 THEN
INSERT INTO t1 VALUES(i,NULL,10,'2023-06-26');
ELSE
INSERT INTO t1 VALUES(i,'中文',1023.567,'2024-12-07');
END IF;
SET i = i + 1;
END WHILE wh1;
END;
//
CREATE PROCEDURE p2()
BEGIN
DECLARE j INT DEFAULT 1;
wh2:WHILE j <= 5000 DO
IF MOD(j,11) = 0 THEN
INSERT INTO t2 VALUES(j,j||'AB',123.567,'2024-12-07 17:45:57.357');
ELSEIF MOD(j,7) = 0 THEN
INSERT INTO t2 VALUES(j,j+1,13.67,'2023-12-07 12:15:47.3547');
ELSEIF MOD(j,5) = 0 THEN
INSERT INTO t2 VALUES(j,'@%*',113.5627,'2022-12-07 16:05:37.1543');
ELSEIF MOD(j,3) = 0 THEN
INSERT INTO t2 VALUES(j,'',23.543,'2021-12-07 14:35:27.054');
ELSEIF MOD(j,2) = 0 THEN
INSERT INTO t2 VALUES(j,NULL,0.537,'2022-12-07 02:15:19.004');
ELSE
INSERT INTO t2 VALUES(j,'中',3.267,'2024-12-07 15:55:17.0004');
END IF;
SET j = j + 1;
END WHILE wh2;
END;
//
CALL p1();
CALL p2();
#DQL
SELECT COUNT(1) FROM t1;
COUNT(1)
10000
SELECT COUNT(1) FROM t2;
COUNT(1)
5000
SELECT * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2);
c0	c1	c2	c3
EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2);
