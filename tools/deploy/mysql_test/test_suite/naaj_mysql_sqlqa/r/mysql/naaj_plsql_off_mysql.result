CREATE PROCEDURE test_case3(IN v_c0 INT)
BEGIN
DECLARE a INT DEFAULT 1;
DECLARE v_count INT;
wh1:WHILE a <=5 DO
INSERT INTO t1 SELECT /*+USE_HASH(tt,t2)*/ t2.* FROM (SELECT * FROM t2 WHERE c0 >= v_c0) tt RIGHT JOIN t2 ON tt.c0 = t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT * FROM t2 WHERE c0 >= v_c0) tt WHERE c0 > v_c0 AND c1 IS NOT NULL) AND t2.c0 BETWEEN a AND a*100;
DELETE FROM t1 WHERE c1 NOT IN(SELECT /*+USE_HASH(t2)*/ t2.c1 FROM t2 WHERE c1 IS NOT NULL AND c1 <>ALL(SELECT c1 FROM (SELECT * FROM t2 WHERE c0 <= v_c0) tt WHERE c0 < v_c0 AND c1 IS NOT NULL) AND t2.c0 BETWEEN a*400 AND a*700);
SET a = a + 1;
END WHILE wh1;
SELECT COUNT(1) FROM t1 INTO v_count;
SELECT v_count;
END;
//
CALL test_case3(5000);
v_count
0
DROP PROCEDURE test_case3;
#使用LOOP循环创建的存储过程
