WITH
data1 AS (SELECT /*+USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
(SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2 WHERE tl2.c1 IS NOT NULL)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1 WHERE tl1.c1 IS NOT NULL)) tp2 ON
tp1.c0=tp2.c0 WHERE tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY tp1.c0,tp1.c1),
data2 AS (SELECT /*+parallel(5) USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
(SELECT /*NO_REWRITE*/ tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2 WHERE tl2.c1 IS NOT NULL)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1 WHERE tl1.c1 IS NOT NULL)) tp2 ON
tp1.c0=tp2.c0 WHERE tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY tp1.c0,tp1.c1)
SELECT * FROM data1 d1,data2 d2 WHERE d1.c0=d2.c0 AND d2.c1 NOT IN(SELECT c1 FROM data1);
c0	c1	c0	c1
