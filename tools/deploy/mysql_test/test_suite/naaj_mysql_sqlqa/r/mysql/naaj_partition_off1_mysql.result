################Setting ''_ optimizer_ null_ aware_ Antijoin 'is OFF################
SET _optimizer_null_aware_antijoin=OFF;
#PARTITION BY LIST
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,c1 INT)
PARTITION BY LIST(c1)
(PARTITION l1 VALUES IN (0,NULL,1,2,3,4),
PARTITION l2 VALUES IN (10,11,12,13,14)
);
CREATE TABLE t2(c0 INT,c1 INT)
PARTITION BY LIST(c1)
(PARTITION l1 VALUES IN (0,1,2,3,4,5,6),
PARTITION l2 VALUES IN (10,NULL,12,13,14,15,16)
);
INSERT INTO t1 VALUES(1,0),(2,NULL),(3,1),(4,1),(5,2),(6,2),(7,3),(7,4),(8,10),(9,11),(10,12),(10,12);
INSERT INTO t2 VALUES(1,0),(2,2),(3,1),(4,NULL),(5,3),(6,5),(7,6),(8,10),(8,12),(9,13),(9,14),(10,14);
