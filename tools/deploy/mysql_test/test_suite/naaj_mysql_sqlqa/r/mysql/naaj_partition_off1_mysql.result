#使用with...as语法对数据进行分析
WITH
data1 AS (SELECT /*+parallel(5) USE_HASH(t1,t2)*/ t1.c0,t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY t1.c0,t1.c1),
data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2)*/ t1.c0,t2.c1 FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY t1.c0,t1.c1)
SELECT /*NO_REWRITE*/ * FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 WHERE d1.c1 <>ALL (SELECT c1 FROM data2);
c0	c1	c0	c1
EXPLAIN BASIC WITH
data1 AS (SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ t1.c0,t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY t1.c0,t1.c1),
data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ t1.c0,t2.c1 FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY t1.c0,t1.c1)
SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ * FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 WHERE d1.c1 <>ALL (SELECT c1 FROM data2);
