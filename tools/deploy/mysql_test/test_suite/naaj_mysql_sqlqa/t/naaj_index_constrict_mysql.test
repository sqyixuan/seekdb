--echo #The right table is a non null constraint.

DROP TABLE t2;
DROP TABLE t1;
CREATE TABLE t1(c0 INT,c1 CHAR(5) );
CREATE TABLE t2(c0 INT,c1 CHAR(5) NOT NULL);
INSERT INTO t1 VALUES(1,1),(2,2),(3,3),(4,4),(4,5),(5,6),(5,7),(6,null),(7,0);
