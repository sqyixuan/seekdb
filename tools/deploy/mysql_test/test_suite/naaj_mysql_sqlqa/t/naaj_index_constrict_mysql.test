#owner:peihan.dph
#owner group: 技术部-SQL-SQL2组
#description: 设定_optimizer_null_aware_antijoin=ON/OFF时，各种约束/索引的测试
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

#--source mysql_test/test_suite/naaj_mysql_sqlqa/include/create_tenant_by_charset_mysql.inc
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/conn_tenant_mysql.inc

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/check_schema_sync.inc
connection conn_charset_test_sys_mysql;
sleep 1;

--enable_result_log

--echo # 环境清理
--disable_warnings
#--error 01396
DROP USER if exists zhang;
--enable_warnings

CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';

--source mysql_test/include/check_schema_sync.inc
connect (zhang,$OBMYSQL_MS0,zhang,zhang,*NO-ONE*,$OBMYSQL_PORT);
connection zhang;
sleep 1;

#创建数据库naaj_test
CREATE DATABASE IF NOT EXISTS naaj_test;
USE naaj_test;

--echo ################Setting ''_ optimizer_ null_ aware_ Antijoin 'is ON################
SET _optimizer_null_aware_antijoin=ON;

--disable_warnings
--error 01051
DROP TABLE t1;
--error 01051
DROP TABLE t2;
--enable_warnings

--echo #PRIMARY KEY

CREATE TABLE t1(c0 INT,c1 INT PRIMARY KEY);
CREATE TABLE t2(c0 INT,c1 INT PRIMARY KEY);
INSERT INTO t1 VALUES(1,1),(2,2),(3,3),(4,4),(4,5),(5,6),(5,7),(6,8),(7,9),(8,10),(8,11),(8,12),(9,13),(10,14);
INSERT INTO t2 VALUES(1,1),(2,3),(2,5),(3,6),(4,7),(5,9),(6,10),(6,11),(8,12),(8,13),(9,14),(9,15),(10,16);
SELECT * FROM t1 ORDER BY 1,2;
SELECT * FROM t2 ORDER BY 1,2;

--echo #operator

SELECT * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;

SELECT * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE c1 NOT IN (NULL)) ORDER BY 1,2;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 >ALL (SELECT c1 FROM t2 WHERE c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2,3,4;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE EXISTS (SELECT c1 FROM t2 WHERE NOT EXISTS (SELECT c1 FROM t1)) ORDER BY 1,2;

SELECT /*+parallel(5) USE_NLJ(t1,t2)*/ * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE t2.c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;

--error 01064
SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE t2.c1 <>ALL (NULL)) ORDER BY 1,2;

--echo #Self connection

SELECT * FROM t1 WHERE t1.c1 NOT IN (SELECT c1 FROM t1 WHERE c1>5) ORDER BY 1,2;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE t1.c1 <>ALL (SELECT c1 FROM t1 WHERE t1.c1 NOT IN (SELECT c1 FROM t1 WHERE c1 > 5)) ORDER BY 1,2;

SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t1 a,t1 b WHERE a.c0=b.c0 AND a.c1 <>ALL (SELECT c1 FROM t1 WHERE t1.c1 NOT IN(1,2,3)) ORDER BY 1,2,3,4;

--echo #The primary key constraint limits other query cases.

SELECT * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2;

SELECT * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2,3,4;

SELECT * FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2,3,4;

SELECT * FROM t1 LEFT JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2,3,4;

SELECT * FROM t1 FULL JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2,3,4;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2) ORDER BY 1,2,3,4;

SELECT /*+USE_NLJ(t1,t2)*/ * FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2,3,4;

SELECT /*+USE_MERGE(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2) ORDER BY 1,2,3,4;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE t1.c1 >= t2.c1) ORDER BY 1,2;

SELECT * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2) ORDER BY 1,2;

SELECT * FROM t1 LEFT JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

SELECT * FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

SELECT * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

SELECT * FROM t1 FULL JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

SELECT /*+USE_NLJ(t1,t2)*/ * FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2 WHERE EXISTS (SELECT c1 FROM t1)) ORDER BY 1,2,3,4;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+USE_NLJ(t1,t2)*/ * FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2,3,4;

SELECT /*+USE_NLJ(t1,t2)*/ * FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

SELECT /*+USE_MERGE(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

SELECT /*+USE_NL(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+parallel(2) USE_NL(t1,t2)*/ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+parallel(5) USE_NLJ(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

SELECT /*+parallel(2) USE_MERGE(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

SELECT /*+parallel(2) USE_NL(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t1.c1 < t2.c1 AND t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

SELECT /*+parallel(2) USE_MERGE(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t1.c1 != t2.c1 AND t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

SELECT /*+parallel(2) USE_NL(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2 WHERE t1.c1 > t2.c1 AND t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

--echo #The left table has a primary key constraint and the right table has a null value.

DROP TABLE t1;
DROP TABLE t2;
CREATE TABLE t1(c0 INT,c1 INT PRIMARY KEY);
CREATE TABLE t2(c0 INT,c1 INT);
INSERT INTO t1 VALUES(1,1),(2,2),(3,3),(4,4),(4,5),(5,6),(5,7),(6,8),(7,9),(8,10),(8,11),(8,12),(9,13),(10,14);
INSERT INTO t2 VALUES(1,1),(2,3),(2,5),(3,6),(4,7),(5,9),(6,11),(8,12),(8,NULL),(9,14),(9,15),(10,14);
SELECT * FROM t1 ORDER BY 1,2;
SELECT * FROM t2 ORDER BY 1,2;

SELECT * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE c1 NOT IN (NULL)) ORDER BY 1,2;

SELECT * FROM t1 WHERE c1 >ALL (SELECT c1 FROM t2 WHERE c1 NOT IN (NULL)) ORDER BY 1,2;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE EXISTS (SELECT c1 FROM t2 WHERE NOT EXISTS (SELECT c1 FROM t1)) ORDER BY 1,2;

SELECT /*+parallel(2) USE_NL(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND EXISTS (SELECT c1 FROM t2 WHERE t1.c1 > t2.c1 AND t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

SELECT /*+parallel(2) USE_NL(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND NOT EXISTS (SELECT c1 FROM t2 WHERE EXISTS(SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ) ORDER BY 1,2,3,4;

SELECT * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE c1 NOT IN (NULL)) ORDER BY 1,2;

SELECT * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2 WHERE c1 IS NULL) ORDER BY 1,2;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE t1.c1 <>ALL (SELECT c1 FROM t1 WHERE t1.c1 NOT IN (SELECT c1 FROM t2)) ORDER BY 1,2;

SELECT /*+USE_NLJ(t1,t2)*/ * FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2 WHERE EXISTS (SELECT c1 FROM t1)) ORDER BY 1,2,3,4;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 >ALL (SELECT c1 FROM t2 WHERE c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2,3,4;

SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE t2.c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;

SELECT /*+parallel(5) USE_NLJ(t1,t2)*/ * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE t2.c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;

SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;

SELECT /*+parallel(2) USE_NL(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2 WHERE EXISTS(SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ) ORDER BY 1,2,3,4;

SELECT /*+parallel(2) USE_MERGE(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE NOT EXISTS(SELECT c1 FROM t2) ) ORDER BY 1,2,3,4;

--echo #The right table has a primary key constraint and the left table has a null value.

DROP TABLE t1;
DROP TABLE t2;
CREATE TABLE t1(c0 INT,c1 INT );
CREATE TABLE t2(c0 INT,c1 INT PRIMARY KEY);
INSERT INTO t1 VALUES(1,1),(2,2),(3,3),(4,NULL),(4,5),(5,6),(5,7),(6,8),(8,10),(8,11),(8,12),(9,13),(10,14);
INSERT INTO t2 VALUES(1,1),(2,3),(2,5),(3,6),(4,7),(5,9),(6,10),(6,11),(8,12),(8,13),(9,14),(9,15),(10,16);
SELECT * FROM t1 ORDER BY 1,2;
SELECT * FROM t2 ORDER BY 1,2;

SELECT * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE c1 NOT IN (NULL)) ORDER BY 1,2;

SELECT * FROM t1 WHERE c1 IS NOT NULL AND c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2;

SELECT * FROM t1 WHERE c1 >ALL (SELECT c1 FROM t2 WHERE c1 NOT IN (NULL)) ORDER BY 1,2;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE EXISTS (SELECT c1 FROM t2 WHERE NOT EXISTS (SELECT c1 FROM t1)) ORDER BY 1,2;

SELECT /*+parallel(2) USE_NL(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND EXISTS (SELECT c1 FROM t2 WHERE t1.c1 > t2.c1 AND t2.c1 IS NOT NULL) ORDER BY 1,2,3,4;

