--echo #使用if...then创建存储过程


DELIMITER //;
CREATE PROCEDURE test_case1(IN v_c0 INT)
BEGIN
    DECLARE v_count INT;
    IF v_c0 > 4000 AND v_c0 <= 5000 THEN
        INSERT INTO t1 SELECT /*+USE_HASH(t1,t2)*/ t2.* FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 >= v_c0);
    ELSEIF v_c0 >= 3000 THEN
        INSERT INTO t1 SELECT /*+parallel(5) USE_HASH(t1,t2)*/ t2.* FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 >= v_c0 AND c1 IS NOT NULL);
    ELSEIF v_c0 >= 2000 THEN
        UPDATE t1 SET c0=c0+1 WHERE c1 <>ALL(SELECT /*+USE_HASH(tt,t2)*/ t2.c1 FROM (SELECT * FROM t2 WHERE c0 >= v_c0) tt JOIN t2 ON tt.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT * FROM t2 WHERE c0 >= v_c0) tt WHERE c0 >= v_c0) AND t2.c1 IS NOT NULL);
    ELSEIF v_c0 >= 1000 THEN
        DELETE FROM t1 WHERE c0 <>ALL(SELECT /*+parallel(2) USE_HASH(tt,t2)*/ t2.c0 FROM (SELECT * FROM t2 WHERE c0 >= v_c0) tt RIGHT JOIN t2 ON tt.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT * FROM t2 WHERE c0 >= v_c0) tt WHERE c0 >= v_c0 AND c1 IS NOT NULL));
    ELSE
        DELETE FROM t1 WHERE c0 <>ALL(SELECT /*+parallel(2) USE_HASH(tt,t2)*/ t2.c0 FROM (SELECT * FROM t2 WHERE c0 <= v_c0) tt RIGHT JOIN t2 ON tt.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT * FROM t2 WHERE c0 <= v_c0) tt WHERE c0 <= v_c0 AND c1 IS NOT NULL) AND t2.c1 IS NOT NULL);
    END IF;

    SELECT COUNT(1) FROM t1 INTO v_count;
    SELECT v_count;
END;
//
DELIMITER ;//


CALL test_case1(4433);


CALL test_case1(3580);


CALL test_case1(2560);


CALL test_case1(1560);


CALL test_case1(560);


DROP PROCEDURE test_case1;

--echo #使用with...on语法创建的存储过程

DELETE FROM t1 WHERE 1=1;
COMMIT;

CALL p1();

SELECT COUNT(1) FROM t1;
SELECT COUNT(1) FROM t2;


DELIMITER //;
CREATE PROCEDURE test_case2(IN v_c0 INT)
BEGIN
    DECLARE v_count INT;
    IF v_c0 <= 1000 THEN
        INSERT INTO t1
        WITH
            s1 AS (SELECT /*+USE_HASH(t1,t2)*/ t2.* FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 <>ALL(SELECT c1 FROM t1 WHERE c0 > v_c0)),
            s2 AS (SELECT /*+USE_HASH(t1,t2)*/ t2.* FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 < v_c0 AND c1 IS NOT NULL))
        SELECT s2.* FROM s1 ,s2 WHERE s2.c1 NOT IN(SELECT c1 FROM s1 WHERE c1 IS NOT NULL);
     ELSEIF v_c0 <= 2000 THEN
        INSERT INTO t1
        WITH
            s1 AS (SELECT /*+USE_HASH(t1,t2)*/ t1.* FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 > v_c0 AND c1 IS NOT NULL)),
            s2 AS (SELECT /*+USE_HASH(t1,t2)*/ t2.* FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 <>ALL(SELECT c1 FROM t1 WHERE c0 < v_c0))
        SELECT s2.* FROM s1 JOIN s2 ON s1.c0=s2.c0 WHERE s2.c1 NOT IN(SELECT c1 FROM s1 WHERE c1 IS NOT NULL);
     ELSEIF v_c0 <= 3000 THEN
        UPDATE t1 SET c0=c0+1 WHERE c1 <>ALL(SELECT s1.c1 FROM
            (SELECT t2.c0,t2.c1 FROM (SELECT * FROM t2) tt1 JOIN t2 ON tt1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT c1,c2 FROM t2 WHERE c0 >= v_c0) tt1 WHERE tt1.c2 < 200 AND tt1.c1 IS NOT NULL)) s1 LEFT JOIN
            (SELECT t2.c0,t2.c1 FROM (SELECT * FROM t2) tt2 JOIN t2 ON tt2.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT c1,c2 FROM t2 WHERE c0 <= v_c0) tt2 WHERE tt2.c2 < 500 AND tt2.c1 IS NOT NULL)) s2
            ON s1.c0=s2.c0 WHERE s2.c1 NOT IN(SELECT c1 FROM (SELECT t2.c0,t2.c1 FROM (SELECT * FROM t2) tt1 JOIN t2 ON tt1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT c1,c2 FROM t2 WHERE c0 >= v_c0) tt1 WHERE tt1.c2 < 200 AND tt1.c1 IS NOT NULL)) s1 WHERE c0>4500 AND c0 IS NOT NULL));
     ELSEIF v_c0 <= 4000 THEN
        DELETE FROM t1 WHERE c0 <>ALL(SELECT s2.c1 FROM
            (SELECT /*+USE_HASH(tt1,t2)*/ t2.c0,t2.c1 FROM (SELECT * FROM t2 WHERE c0 <= 3170) tt1 JOIN t2 ON tt1.c0=t2.c0 WHERE t2.c1 <>ALL(SELECT c1 FROM (SELECT c1 FROM t2 WHERE c0 <= v_c0) tt1 WHERE t2.c0 > v_c0 AND c1 IS NOT NULL)) s1 JOIN
            (SELECT /*+USE_HASH(tt2,t2)*/ t2.c0,t2.c1 FROM (SELECT * FROM t2 WHERE c0 >= 3170) tt2 JOIN t2 ON tt2.c0=t2.c0 WHERE t2.c1 <>ALL(SELECT c1 FROM (SELECT c1 FROM t2 WHERE c0 >= v_c0) tt2 WHERE t2.c0 < v_c0)) s2
            ON s1.c0=s2.c0 WHERE s2.c1 NOT IN(SELECT c1 FROM (SELECT /*+USE_HASH(tt1,t2)*/ t2.c0,t2.c1 FROM (SELECT * FROM t2 WHERE c0 <= v_c0) tt1 JOIN t2 ON tt1.c0=t2.c0 WHERE t2.c1 <>ALL(SELECT c1 FROM (SELECT c1 FROM t2 WHERE c0 <= v_c0) tt1 WHERE t2.c0 > 3170 AND c1 IS NOT NULL)) s1));
     ELSE
        DELETE FROM t1 WHERE c0 <>ALL(SELECT s2.c1 FROM
            (SELECT /*+USE_HASH(tt1,t2)*/ t2.c0,t2.c1 FROM (SELECT * FROM t2 WHERE c0 > v_c0) tt1 JOIN t2 ON tt1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT c1 FROM t2 WHERE c0 < v_c0) tt1 WHERE t2.c0 > v_c0)) s1,
            (SELECT /*+USE_HASH(tt2,t2)*/ t2.c0,t2.c1 FROM (SELECT * FROM t2 WHERE c0 > v_c0) tt2 JOIN t2 ON tt2.c0=t2.c0 WHERE NOT EXISTS(SELECT c1 FROM (SELECT c1 FROM t2 WHERE c0 < v_c0) tt2 WHERE t2.c0 < v_c0)) s2
            WHERE s2.c1 NOT IN(SELECT c1 FROM (SELECT t2.c0,t2.c1 FROM t2  WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT c1 FROM t2 WHERE c0 < v_c0) tt1 WHERE t2.c0 > v_c0)) s1));
    END IF;

    SELECT COUNT(1) FROM t1 INTO v_count;
    SELECT v_count;
END;
//
DELIMITER ;//

CALL test_case2(1580);

CALL test_case2(2170);

CALL test_case2(3170);

#CALL p1;
--echo #此处本地执行报超时错误，Jenkins执行成功，且有结果输出，故先不执行
#CALL test_case2(5);
#CALL test_case2(4170);

DROP PROCEDURE test_case2;

--echo #使用WHILE循环创建的存储过程

DELETE FROM t1 WHERE 1=1;
COMMIT;

CALL p1();

SELECT COUNT(1) FROM t1;
SELECT COUNT(1) FROM t2;


DELIMITER //;
CREATE PROCEDURE test_case3(IN v_c0 INT)
BEGIN
    DECLARE a INT DEFAULT 1;
    DECLARE v_count INT;
    wh1:WHILE a <=5 DO
        INSERT INTO t1 SELECT /*+USE_HASH(tt,t2)*/ t2.* FROM (SELECT * FROM t2 WHERE c0 >= v_c0) tt RIGHT JOIN t2 ON tt.c0 = t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM (SELECT * FROM t2 WHERE c0 >= v_c0) tt WHERE c0 > v_c0 AND c1 IS NOT NULL) AND t2.c0 BETWEEN a AND a*100;
        DELETE FROM t1 WHERE c1 NOT IN(SELECT /*+USE_HASH(t2)*/ t2.c1 FROM t2 WHERE c1 IS NOT NULL AND c1 <>ALL(SELECT c1 FROM (SELECT * FROM t2 WHERE c0 <= v_c0) tt WHERE c0 < v_c0 AND c1 IS NOT NULL) AND t2.c0 BETWEEN a*400 AND a*700);
    SET a = a + 1;
    END WHILE wh1;
    SELECT COUNT(1) FROM t1 INTO v_count;
    SELECT v_count;
END;
//
DELIMITER ;//


CALL test_case3(5000);


DROP PROCEDURE test_case3;

--echo #使用LOOP循环创建的存储过程

DELETE FROM t1 WHERE 1=1;
COMMIT;

CALL p1();

SELECT COUNT(1) FROM t1;
SELECT COUNT(1) FROM t2;


DELIMITER //;
CREATE PROCEDURE test_case4(IN v_c0 INT)
BEGIN
    DECLARE a INT DEFAULT 1;
    DECLARE v_count INT;
    loop1: LOOP
        INSERT INTO t1 SELECT /*+USE_HASH(t1,t2)*/ t2.* FROM t1 LEFT JOIN t2 ON t1.c0 = t2.c0 WHERE
        t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 > v_c0 AND c1 IS NOT NULL) AND t2.c0 BETWEEN a AND a*100;COMMIT;

        DELETE FROM t1 WHERE c1 NOT IN(SELECT /*+USE_HASH(t2)*/ t2.c1 FROM t2 WHERE c1 IS NOT NULL AND
        c1 <>ALL(SELECT c1 FROM (SELECT * FROM t2 WHERE c1 NOT IN(SELECT c1 FROM t2 WHERE c0 <=v_c0 AND c1 IS NOT NULL)) tt WHERE c0 < v_c0 AND
        c1 NOT IN(SELECT c1 FROM t2 WHERE c1 IS NOT NULL AND c0 > 1000*a)) AND t2.c0 BETWEEN a*300 AND a*700);COMMIT;

        IF a = 3 THEN
            LEAVE loop1;
        END IF;
    SET a = a + 1;
    END LOOP;
    SELECT COUNT(1) FROM t1 INTO v_count;
    SELECT v_count;
END;
//
DELIMITER ;//


CALL test_case4(5000);

DROP PROCEDURE test_case4;


--echo #PARTITION TABLE

DELETE FROM t1 WHERE 1=1;

CALL p1();

SELECT COUNT(1) FROM t1;
SELECT COUNT(1) FROM t2;

DROP TABLE IF EXISTS test1;

CREATE TABLE test1(c0 INT,c1 INT)
PARTITION BY HASH(c1) PARTITIONS 3;
INSERT INTO test1 SELECT t1.c0,t1.c1 FROM t1 WHERE c1 IS NOT NULL AND c0 < 2000;
SELECT COUNT(1) FROM test1;


DELIMITER //;
CREATE PROCEDURE test_case6(IN v_c0 INT)
BEGIN
    DECLARE v_count INT;
    IF v_c0 <= 1000 THEN
        INSERT INTO test1 SELECT t1.c0,t1.c2 FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 NOT IN (SELECT c1 FROM t1 WHERE c1 IS NOT NULL);
    ELSEIF v_c0 <= 2000 THEN
        UPDATE test1 SET c1 = c1 + v_c0 WHERE c1 <>ALL(SELECT /*+USE_HASH*/ t1.c0 FROM t1 LEFT JOIN t2 ON t1.c0 = t2.c0  WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c1 IS NOT NULL));
    ELSE
        DELETE FROM test1 WHERE c1 NOT IN(SELECT /*+USE_HASH*/ t2.c0 FROM t1 RIGHT JOIN t2 ON t1.c0 = t2.c0 WHERE t1.c1 <>ALL(SELECT c1 FROM t2));
    END IF;
    SELECT COUNT(1) FROM test1 INTO v_count;
    SELECT v_count;
END;
//
DELIMITER ;//


CALL test_case6(587);

CALL test_case6(1587);

CALL test_case6(2217);


DROP PROCEDURE test_case6;
DROP TABLE test1;


--echo #调用 FUNCTION


DELIMITER //;
CREATE FUNCTION f_test1(v_c0 INT,v_c1 VARCHAR(10))
RETURNS VARCHAR(100)
BEGIN
    DECLARE v_count_t1 INT;
    DECLARE v_count_t2 INT;
    DECLARE v_count_t3 VARCHAR(100);
	IF v_c0 <= 2000 AND v_c1 = '100AB' THEN
    	INSERT INTO t1 SELECT /*+USE_HASH(t1,t2)*/ t2.* FROM t2 WHERE
    	t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 > v_c0 AND c1 IS NOT NULL) AND t2.c0 BETWEEN v_c0-100 AND v_c0;

    	DELETE FROM t2 WHERE c1 <>ALL(SELECT /*+USE_HASH(t1)*/ t1.c1 FROM t1 WHERE
    	c1 IS NOT NULL AND c1 NOT IN(SELECT c1 FROM t1 WHERE c0 < v_c0 AND c1 NOT IN(SELECT c1 FROM t1 WHERE c1 IS NOT NULL AND c0 > v_c0-100)) AND t1.c0 >= v_c0);

    ELSEIF v_c0 <= 4000 AND v_c1 = '@ % *' THEN
        INSERT INTO t2 SELECT /*+USE_HASH(t1,t2)*/ t1.* FROM t1 WHERE
        t1.c1 NOT IN(SELECT c1 FROM t2 WHERE c0 > v_c0) AND t1.c0 BETWEEN v_c0-100 AND v_c0;

    	DELETE FROM t1 WHERE c1 <>ALL(SELECT /*+USE_HASH(t2)*/ t2.c1 FROM t2 WHERE
    	c1 IS NOT NULL AND c1 NOT IN(SELECT c1 FROM t2 WHERE c0 < v_c0 AND c1 NOT IN(SELECT c1 FROM t2 WHERE c0 > v_c0-100)) AND t2.c0 >= v_c0);

    ELSE
        INSERT INTO t1 SELECT /*+USE_HASH(t1,t2)*/ t2.* FROM t2 WHERE
        t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 > v_c0 AND c1 IS NOT NULL) AND t2.c0 BETWEEN v_c0-100 AND v_c0;

    	DELETE FROM t2 WHERE c1 <>ALL(SELECT /*+USE_NL(t1)*/ t1.c1 FROM t1 WHERE
    	c1 <>ALL(SELECT c1 FROM t1 WHERE c0 < v_c0 AND c1 <>ALL(SELECT c1 FROM t1 WHERE c0 > v_c0-100)) AND t1.c0 <= v_c0);

    END IF;

    SELECT COUNT(1) INTO v_count_t1 FROM t1;
    SELECT COUNT(1) INTO v_count_t2 FROM t2;
    SET v_count_t3 = CONCAT('t1表执行函数后条目合计：',v_count_t1,', t2表执行函数后条目合计：',v_count_t2);

    RETURN v_count_t3;
END;
//
DELIMITER ;//


SELECT f_test1(3345,'100AB');

SELECT f_test1(1545,'100AB');

SELECT f_test1(4545,'100AB');

SELECT f_test1(2345,'@ % *');

SELECT f_test1(5,'中');

DROP FUNCTION f_test1;


