#owner:peihan.dph
#owner group: 技术部-SQL-SQL2组
#description: 在无索引约束等情况下，设定_optimizer_null_aware_antijoin=ON/OFF时，各种列类型测试
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/create_tenant_by_charset_mysql.inc
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/conn_tenant_mysql.inc

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/check_schema_sync.inc
connection conn_charset_test_sys_mysql;
sleep 1;

--enable_result_log

--echo # 环境清理
--disable_warnings
#--error 01396
DROP USER if exists zhang;
--enable_warnings

CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';

--source mysql_test/include/check_schema_sync.inc
connect (zhang,$OBMYSQL_MS0,zhang,zhang,*NO-ONE*,$OBMYSQL_PORT);
connection zhang;
sleep 1;

#创建数据库naaj_test
CREATE DATABASE IF NOT EXISTS naaj_test;
USE naaj_test;

--echo ################Setting ''_ optimizer_ null_ aware_ Antijoin 'is ON################
SET _optimizer_null_aware_antijoin=ON;

--disable_warnings
--error 01051
DROP TABLE t1;
--error 01051
DROP TABLE t2;
--enable_warnings

--echo #BLOB TYPE

CREATE TABLE t1(c0 INT,c1 BLOB);
CREATE TABLE t2(c0 INT,c1 BLOB);
INSERT INTO t1 VALUES(1,'A');
INSERT INTO t1 VALUES(2,'12');
INSERT INTO t1 VALUES(3,'A');
INSERT INTO t1 VALUES(4,'');
INSERT INTO t1 VALUES(5,NULL);
INSERT INTO t2 VALUES(1,'AB');
INSERT INTO t2 VALUES(2,'12');
INSERT INTO t2 VALUES(3,'');
INSERT INTO t2 VALUES(4,NULL);
INSERT INTO t2 VALUES(5,'a');

--echo #There are null values on the right side of the left table

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #There are null values on the right table

DELETE FROM t1 WHERE c0 IN(4,5);
SELECT * FROM t1 ORDER BY c0;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #There are null values on the left table

INSERT INTO t1 VALUES(4,'');
INSERT INTO t1 VALUES(5,NULL);
DELETE FROM t2 WHERE c0 IN(3,4);
SELECT * FROM t2 ORDER BY c0;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #There are no null values in the left and right tables

DELETE FROM t1 WHERE c0 IN(4,5);
SELECT * FROM t1 ORDER BY c0;
SELECT * FROM t2 ORDER BY c0;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc

--echo #Left table is empty

DELETE FROM t1;
INSERT INTO t2 VALUES(3,'');
INSERT INTO t2 VALUES(4,NULL);
SELECT * FROM t1 ORDER BY c0;
SELECT * FROM t2 ORDER BY c0;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #right table is empty

DELETE FROM t2;
INSERT INTO t1 VALUES(1,'A');
INSERT INTO t1 VALUES(2,'12');
INSERT INTO t1 VALUES(3,'A');
INSERT INTO t1 VALUES(4,'');
INSERT INTO t1 VALUES(5,NULL);


--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #The left and right tables are empty

DELETE FROM t2;
DELETE FROM t1;
SELECT * FROM t1 ORDER BY c0;
SELECT * FROM t2 ORDER BY c0;

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc

--echo #NUMBER TYPE

DROP TABLE t1;
DROP TABLE t2;
CREATE TABLE t1(c0 INT,c1 INT);
CREATE TABLE t2(c0 INT,c1 INT);
INSERT INTO t1 VALUES(1,12.3456);
INSERT INTO t1 VALUES(2,12);
INSERT INTO t1 VALUES(3,11);
INSERT INTO t1 VALUES(4,NULL);
INSERT INTO t2 VALUES(1,'123.452');
INSERT INTO t2 VALUES(2,12);
INSERT INTO t2 VALUES(3,'12.35');
INSERT INTO t2 VALUES(4,NULL);


--echo #There are null values on the right side of the left table

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #There are null values on the left table

DELETE FROM t2 WHERE c0 IN(4);
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #There are null values on the right table

INSERT INTO t2 VALUES(4,NULL);
DELETE FROM t1 WHERE c0 IN(4);
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #There are no null values in the left and right tables

DELETE FROM t2 WHERE c0 IN(4);
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc

--echo #Left table is empty

DELETE FROM t1;
INSERT INTO t2 VALUES(4,NULL);
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #right table is empty

DELETE FROM t2;
INSERT INTO t1 VALUES(1,12.3456);
INSERT INTO t1 VALUES(2,12);
INSERT INTO t1 VALUES(3,11);
INSERT INTO t1 VALUES(4,NULL);

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #The left and right tables are empty

DELETE FROM t2;
DELETE FROM t1;
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc

--echo #DATE TYPE

DROP TABLE t1;
DROP TABLE t2;
CREATE TABLE t1(c0 INT,c1 DATE);
CREATE TABLE t2(c0 INT,c1 DATE);
INSERT INTO t1 VALUES(1,'2031-10-11');
INSERT INTO t1 VALUES(2,'2111-01-21');
INSERT INTO t1 VALUES(3,NULL);
INSERT INTO t1 VALUES(4,'2011-11-21');
INSERT INTO t2 VALUES(1,'2111-01-21');
INSERT INTO t2 VALUES(2,'1991-11-21');
INSERT INTO t2 VALUES(3,'2001-01-21');
INSERT INTO t2 VALUES(4,NULL);

--echo #There are null values on the right side of the left table

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #There are null values on the left table

DELETE FROM t2 WHERE c0 IN(4);
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #There are null values on the right table
INSERT INTO t2 VALUES(4,NULL);
DELETE FROM t1 WHERE c0 IN(3);
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc

--echo #There are no null values in the left and right tables
DELETE FROM t2 WHERE c0 IN(4);
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #Left table is empty
DELETE FROM t1;
INSERT INTO t2 VALUES(4,NULL);
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #right table is empty
INSERT INTO t1 VALUES(1,'2031-10-11');
INSERT INTO t1 VALUES(2,'2111-01-21');
INSERT INTO t1 VALUES(3,NULL);
INSERT INTO t1 VALUES(4,'2011-11-21');
DELETE FROM t2;
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #The left and right tables are empty
DELETE FROM t1;

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


DROP TABLE t1;
DROP TABLE t2;

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/check_schema_sync.inc
connection conn_charset_test_sys_mysql;
sleep 1;

DROP USER 'zhang'@'%';
DROP DATABASE naaj_test;

disconnect zhang;
disconnect conn_charset_test_sys_mysql;

--echo  #########Empty recycle bin, delete test database, tables, etc##########
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/drop_tenant_mysql.inc
purge recyclebin;
