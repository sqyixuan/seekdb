#owner group: 技术部-SQL-SQL2组
#description: 创建分区表，设定_optimizer_null_aware_antijoin=OFF时，HASH分区下测试
#author: wb-zc01081081
# tags: optimizer



--echo ################Setting ''_ optimizer_ null_ aware_ Antijoin 'is OFF################
SET _optimizer_null_aware_antijoin=OFF;


--echo #PARTITION BY HASH
--echo #相同分区方式，相同分区键和连接键，分区数相同，走partition-wise和partition-none两个禁用场景

--disable_warnings
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
--enable_warnings
CREATE TABLE t1(c0 INT,c1 INT)
PARTITION BY HASH(c1)
PARTITIONS 3;
CREATE TABLE t2(c0 INT,c1 INT)
PARTITION BY HASH(c1)
PARTITIONS 3;


DELIMITER //;

CREATE PROCEDURE p1()
BEGIN
    DECLARE j INT DEFAULT 1;
    WHILE j <= 45 DO
        IF MOD(j,11) = 0 THEN
            INSERT INTO t1 VALUES(j,50);
        ELSEIF MOD(j,9) = 0 THEN
            INSERT INTO t1 VALUES(j,99);
        ELSEIF MOD(j,7) = 0 THEN
            INSERT INTO t1 VALUES(j,j+55);
        ELSEIF MOD(j,5) = 0 THEN
            INSERT INTO t1 VALUES(j,j-2);
        ELSEIF MOD(j,3) = 0 THEN
            INSERT INTO t1 VALUES(j,j*2);
        ELSE
            INSERT INTO t1 VALUES(j,j+1);
        END IF;
        SET j = j + 1;
    END WHILE;
END;
//


CREATE  PROCEDURE p2()
BEGIN
    DECLARE j INT DEFAULT 1;
    WHILE j <= 45 DO
        IF MOD(j,11) = 0 THEN
            INSERT INTO t2 VALUES(j,j*2);
        ELSEIF MOD(j,9) = 0 THEN
            INSERT INTO t2 VALUES(j,121);
        ELSEIF MOD(j,7) = 0 THEN
            INSERT INTO t2 VALUES(j,j+100);
        ELSEIF MOD(j,5) = 0 THEN
            INSERT INTO t2 VALUES(j,j-5);
        ELSEIF MOD(j,3) = 0 THEN
            INSERT INTO t2 VALUES(j,j*-3);
        ELSE
            INSERT INTO t2 VALUES(j,j+2);
        END IF;
        SET j = j + 1;
    END WHILE;
END;
//
DELIMITER ;//


CALL p1();
CALL p2();

SELECT * FROM t1 ORDER BY 1,2;
SELECT * FROM t2 ORDER BY 1,2;

SELECT * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2;

EXPLAIN BASIC SELECT * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2;


SELECT * FROM t1 WHERE NOT EXISTS (SELECT c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)) ORDER BY 1,2;

EXPLAIN BASIC SELECT * FROM t1 WHERE NOT EXISTS (SELECT c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)) ORDER BY 1,2;


SELECT * FROM t1 WHERE NOT EXISTS (SELECT c1 FROM t2);

EXPLAIN BASIC SELECT * FROM t1 WHERE NOT EXISTS (SELECT c1 FROM t2);


SELECT * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t1);

EXPLAIN BASIC SELECT * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t1);


SELECT * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2 WHERE NOT EXISTS (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2 WHERE NOT EXISTS (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 <>ALL (SELECT t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT * FROM t1 WHERE c1 <>ALL (SELECT t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 NOT IN (SELECT t2.c1 FROM t1 LEFT JOIN t2 ON t1.c0=t2.c0 AND t2.c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT * FROM t1 WHERE c1 NOT IN (SELECT t2.c1 FROM t1 LEFT JOIN t2 ON t1.c0=t2.c0 AND t2.c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;

--error 01064
