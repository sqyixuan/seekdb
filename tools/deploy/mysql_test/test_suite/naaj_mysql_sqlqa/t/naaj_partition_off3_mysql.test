EXPLAIN BASIC SELECT /*+USE_HASH(t1,t2) */ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN(SELECT c1 FROM t1 WHERE c1 IS NOT NULL);


