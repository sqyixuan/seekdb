SELECT * FROM t1 WHERE c1 <>ALL (SELECT t2.c1 FROM t1 RIGTH JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT * FROM t1 WHERE c1 <>ALL (SELECT t2.c1 FROM t1 RIGTH JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 NOT IN (SELECT t2.c1 FROM t1 FULL JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT * FROM t1 WHERE c1 NOT IN (SELECT t2.c1 FROM t1 FULL JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;


