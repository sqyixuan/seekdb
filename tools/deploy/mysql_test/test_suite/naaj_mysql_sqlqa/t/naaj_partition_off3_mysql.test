SELECT /*+USE_NL(t1,t2) */ * FROM t1 WHERE NOT EXISTS (SELECT /*+USE_HASH(t2) */ t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+USE_NL(t1,t2) */ * FROM t1 WHERE NOT EXISTS (SELECT /*+USE_HASH(t2) */ t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY 1,2,3,4;

EXPLAIN BASIC SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY 1,2,3,4;


SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE NOT EXISTS (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE NOT EXISTS (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(5) leading(t1 t2) USE_HASH(t1,t2)*/ * FROM t1 WHERE t1.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(5) leading(t1 t2) USE_HASH(t1,t2)*/ * FROM t1 WHERE t1.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(5) leading(t1 t2) PQ_DISTRIBUTE(t2 PARTITION NONE)  USE_HASH(t1, t2) */ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2)  ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(5) leading(t1 t2) PQ_DISTRIBUTE(t2 PARTITION NONE)  USE_HASH(t1, t2) */ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2)  ORDER BY t1.c0,t1.c1;


--echo #相同分区方式，相同分区键和连接键，不同分区数相同

DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
CREATE TABLE t1(c0 INT,c1 INT)
PARTITION BY HASH(c1)
PARTITIONS 3;
CREATE TABLE t2(c0 INT,c1 INT)
PARTITION BY HASH(c1)
PARTITIONS 2;

