--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

#--source mysql_test/test_suite/naaj_mysql_sqlqa/include/create_tenant_by_charset_mysql.inc
#--source mysql_test/test_suite/naaj_mysql_sqlqa/include/conn_tenant_mysql.inc

#--source mysql_test/test_suite/naaj_mysql_sqlqa/include/check_schema_sync.inc
connect (sys,$OBMYSQL_MS0,root,,*NO-ONE*,$OBMYSQL_PORT);
connection sys;
sleep 1;

--enable_result_log

--echo # 环境清理
--disable_warnings
--error 01396
DROP USER zhang;
--enable_warnings

CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';

--source mysql_test/include/check_schema_sync.inc
connect (zhang,$OBMYSQL_MS0,zhang,zhang,*NO-ONE*,$OBMYSQL_PORT);
connection zhang;
sleep 1;

#创建数据库naaj_test
CREATE DATABASE IF NOT EXISTS naaj_test;
USE naaj_test;


--echo ################Setting ''_ optimizer_ null_ aware_ Antijoin 'is OFF################
SET _optimizer_null_aware_antijoin=OFF;


DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,c1 CHAR(10));
CREATE TABLE t2(c0 INT,c1 VARCHAR(10));
INSERT INTO t2 VALUES(0,'A'),(1,'中文'),(2,'# $ :'),(2,'12'),(4,22),(5,''),(6,NULL);
INSERT INTO t1 VALUES(0,'A'),(1,'中'),(2,'# $ :'),(2,'11'),(4,23),(5,NULL);
SELECT * FROM t2 ORDER BY c0;
SELECT * FROM t1 ORDER BY c0;

INSERT INTO t2 SELECT c0,c1 FROM t2 WHERE c1 NOT IN (SELECT c1 FROM t1);
SELECT * FROM t2 ORDER BY c0,c1;
--disable_result_log
EXPLAIN BASIC INSERT INTO t2 SELECT c0,c1 FROM t2 WHERE c1 NOT IN (SELECT c1 FROM t1);
--enable_result_log


INSERT INTO t2 SELECT c0,c1 FROM t2 WHERE c1 NOT IN (SELECT c1 FROM t2);
SELECT * FROM t2 ORDER BY c0,c1;
--disable_result_log
EXPLAIN BASIC INSERT INTO t2 SELECT c0,c1 FROM t2 WHERE c1 NOT IN (SELECT c1 FROM t2);
--enable_result_log


INSERT INTO t2 SELECT c0,c1 FROM t2 WHERE c1 <>ALL (SELECT c1 FROM t1);
SELECT * FROM t2 ORDER BY c0,c1;
--disable_result_log
EXPLAIN BASIC INSERT INTO t2 SELECT c0,c1 FROM t2 WHERE c1 <>ALL (SELECT c1 FROM t1);
--enable_result_log


INSERT INTO t2 SELECT c0,c1 FROM t2 WHERE c1 <>ALL (SELECT c1 FROM t2);
SELECT * FROM t2 ORDER BY c0,c1;
--disable_result_log
EXPLAIN BASIC INSERT INTO t2 SELECT c0,c1 FROM t2 WHERE c1 <>ALL (SELECT c1 FROM t2);
--enable_result_log


INSERT INTO t2 SELECT c0,c1 FROM t2 WHERE NOT EXISTS (SELECT c1 FROM t1);
SELECT * FROM t2 ORDER BY c0,c1;
--disable_result_log
EXPLAIN BASIC INSERT INTO t2 SELECT c0,c1 FROM t2 WHERE NOT EXISTS (SELECT c1 FROM t1);
--enable_result_log

INSERT INTO t2 SELECT c0,c1 FROM t2 WHERE c1 NOT IN (NULL,'A','11');
SELECT * FROM t2 ORDER BY c0,c1;
--disable_result_log
EXPLAIN BASIC INSERT INTO t2 SELECT c0,c1 FROM t2 WHERE c1 NOT IN (NULL,'A','11');
--enable_result_log


--error 01064
INSERT INTO t2 SELECT c0,c1 FROM t2 WHERE c1 <>ALL (NULL,'A','11');


