#owner group: 技术部-SQL-SQL2组
#description: 创建分区表，设定_optimizer_null_aware_antijoin=OFF时，子分区下测试
#author: wb-zc01081081
# tags: optimizer


--echo ################Setting ''_ optimizer_ null_ aware_ Antijoin 'is OFF################
SET _optimizer_null_aware_antijoin=OFF;


--echo #range-->hash/key subpartition

--disable_warnings
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
--enable_warnings
CREATE TABLE t1(c0 INT,c1 DATE)
PARTITION BY RANGE COLUMNS(c1) SUBPARTITION BY HASH(TO_DAYS(c1)) SUBPARTITIONS 2
(PARTITION r1 VALUES LESS THAN('2000-03-31'),
 PARTITION r2 VALUES LESS THAN('2000-06-30'),
 PARTITION r3 VALUES LESS THAN('2000-09-30'),
 PARTITION r4 VALUES LESS THAN('2000-12-31')
 );
CREATE TABLE t2(c0 INT,c1 DATE)
PARTITION BY RANGE COLUMNS(c1) SUBPARTITION BY KEY(c1) SUBPARTITIONS 2
(PARTITION q1 VALUES LESS THAN('2000-06-30'),
 PARTITION q2 VALUES LESS THAN('2000-09-30'),
 PARTITION q3 VALUES LESS THAN('2000-12-31'),
 PARTITION q4 VALUES LESS THAN('2001-01-31')
 );


--disable_warnings
DELIMITER //;

CREATE PROCEDURE p3()
BEGIN
    DECLARE i INT DEFAULT 1;
    loop1:LOOP
        BEGIN
            DECLARE j INT DEFAULT 1;
            wh1:WHILE j <= 28 DO
                IF MOD(j,4) = 0  THEN
                    INSERT INTO t1 VALUES(j,STR_TO_DATE(CONCAT(2000,'-',i,'-',j),'%Y-%m-%d'));
                    INSERT INTO t2 VALUES(j,STR_TO_DATE(CONCAT(2000,'-',i,'-',(j+1)),'%Y-%m-%d'));
                ELSEIF MOD(j,3) = 0 THEN
                    INSERT INTO t1 VALUES(j,STR_TO_DATE(CONCAT(2000,'-',i,'-',j),'%Y-%m-%d'));
                    INSERT INTO t2 VALUES(j,STR_TO_DATE(CONCAT(2001,'-',1,'-',j),'%Y-%m-%d'));
                ELSEIF MOD(j,2) = 0 THEN
                    INSERT INTO t1 VALUES(j,STR_TO_DATE(CONCAT(2000,'-',i,'-',j),'%Y-%m-%d'));
                    INSERT INTO t2 VALUES(j,STR_TO_DATE(CONCAT(2000,'-',i,'-',(j-1)),'%Y-%m-%d'));
                ELSE
                    INSERT INTO t1 VALUES(j,STR_TO_DATE(CONCAT(2000,'-',i,'-',j),'%Y-%m-%d'));
                    INSERT INTO t2 VALUES(j,STR_TO_DATE(CONCAT(2000,'-',i,'-',j),'%Y-%m-%d'));
                END IF;
                SET j = j + 1;
            END WHILE wh1;
    	END;
    	SET i = i + 1;
    	
    	IF i >12 THEN
    	    LEAVE loop1;
    	END IF;
    END LOOP;
END;
//
DELIMITER ;//
--enable_warnings

CALL p3();
