--echo #使用with...as语法创建sql

--disable_result_log
WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2)*/ tr1.c0,t2.c1 FROM t1 PARTITION(r1) tr1,t2 WHERE tr1.c0=t2.c0 AND tr1.c1 NOT IN (SELECT c1 FROM t2)),
    data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2)*/ tr1.c0,tb1.c1 FROM t1 PARTITION(r2) tr1 JOIN t2 PARTITION(q1) tb1 ON tr1.c0=tb1.c0 WHERE tb1.c1 <>ALL (SELECT c1 FROM t2 PARTITION(q1sp1)))
    SELECT /*NO_REWRITE*/ COUNT(1) FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 WHERE d1.c1 <>ALL (SELECT c1 FROM data2);
--enable_result_log

EXPLAIN BASIC WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tr1.c0,t2.c1 FROM t1 PARTITION(r1) tr1,t2 WHERE tr1.c0=t2.c0 AND tr1.c1 NOT IN (SELECT c1 FROM t2)),
    data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tr1.c0,tb1.c1 FROM t1 PARTITION(r2) tr1 JOIN t2 PARTITION(q1) tb1 ON tr1.c0=tb1.c0 WHERE tb1.c1 <>ALL (SELECT c1 FROM t2 PARTITION(q1sp1)))
    SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ COUNT(1) FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 WHERE d1.c1 <>ALL (SELECT c1 FROM data2);


--disable_result_log
WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
        (SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(r2sp0) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(q2) tl2)) tp1 LEFT JOIN
        (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(q1) tl2 WHERE tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(r1sp1) tl1)) tp2 ON
        tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1)),
    data2 AS (SELECT /*+parallel(5) USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
        (SELECT /*NO_REWRITE*/ tl1.c0,tl1.c1 FROM t1 PARTITION(r2) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(q1sp0) tl2)) tp1 LEFT JOIN
        (SELECT te2.c0,te2.c1 FROM t2 PARTITION(q2sp0) te2 WHERE te2.c1 NOT IN (SELECT ta1.c1 FROM t1 PARTITION(r1) ta1)) tp2 ON
        tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1))
    SELECT COUNT(1) FROM data1 d1,data2 d2 WHERE d1.c0=d2.c0 AND d2.c1 NOT IN(SELECT c1 FROM data1 WHERE c1 IS NOT NULL);
--enable_result_log

EXPLAIN BASIC WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
        (SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(r2sp0) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(q2) tl2)) tp1 LEFT JOIN
        (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(q1) tl2 WHERE tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(r1sp1) tl1)) tp2 ON
        tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1)),
    data2 AS (SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
        (SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ tl1.c0,tl1.c1 FROM t1 PARTITION(r2) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(q1sp0) tl2)) tp1 LEFT JOIN
        (SELECT te2.c0,te2.c1 FROM t2 PARTITION(q2sp0) te2 WHERE te2.c1 NOT IN (SELECT ta1.c1 FROM t1 PARTITION(r1) ta1)) tp2 ON
        tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1))
    SELECT /*+READ_CONSISTENCY (weak)*/ COUNT(1) FROM data1 d1,data2 d2 WHERE d1.c0=d2.c0 AND d2.c1 NOT IN(SELECT c1 FROM data1 WHERE c1 IS NOT NULL);


