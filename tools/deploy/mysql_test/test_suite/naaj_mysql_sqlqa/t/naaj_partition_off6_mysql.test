SELECT /*+USE_HASH(t1,t2) */ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN(SELECT c1 FROM t1);

EXPLAIN BASIC SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak) */ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN(SELECT c1 FROM t1);


SELECT /*+USE_HASH */ * FROM t1 WHERE c1 <>ALL (SELECT t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+USE_HASH READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT /*+USE_HASH */ * FROM t1 WHERE c1 <>ALL (SELECT /*+USE_NL */ t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+USE_HASH READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT /*+USE_NL */ t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT /*+USE_NL(t1,t2) */ * FROM t1 WHERE NOT EXISTS (SELECT /*+USE_HASH(t2) */ t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+USE_NL(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 WHERE NOT EXISTS (SELECT /*+USE_HASH(t2) */ t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(2) USE_NL(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(2) USE_NL(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE NOT EXISTS (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE NOT EXISTS (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(5) USE_NL(t1,t2)*/ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(5) USE_NL(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(5) USE_MERGE(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(5) USE_MERGE(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 IN (1,NULL)) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 IN (1,NULL)) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(5) leading(t1 t2) USE_HASH(t1,t2)*/ * FROM t1 WHERE t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(5) leading(t1 t2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 WHERE t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(5) leading(t1 t2) PQ_DISTRIBUTE(t2 PARTITION NONE)  USE_HASH(t1, t2) */ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2)  ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(5) leading(t1 t2) PQ_DISTRIBUTE(t2 PARTITION NONE)  USE_HASH(t1, t2)  READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2)  ORDER BY t1.c0,t1.c1;


--echo #查询部分子分区的值


--disable_result_log
SELECT * FROM t1 PARTITION(a1) tr1,t2 tr2 WHERE tr1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(b1));
--enable_result_log

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 PARTITION(a1) tr1,t2 tr2 WHERE tr1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(b1));


--disable_result_log
SELECT * FROM t1 PARTITION(r1) ta1,t2 PARTITION(e1) tb1 WHERE ta1.c0=tb1.c0 AND ta1.c1 NOT IN(SELECT c1 FROM t2 PARTITION(b1)) ORDER BY 1,2,3;
--enable_result_log

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 PARTITION(r1) ta1,t2 PARTITION(e1) tb1 WHERE ta1.c0=tb1.c0 AND ta1.c1 NOT IN(SELECT c1 FROM t2 PARTITION(b1)) ORDER BY 1,2,3;


--disable_result_log
SELECT /*+parallel(2) NO_REWRITE*/ * FROM
(SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 PARTITION(a1) tl1 WHERE tl1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(b2))) ta1,
(SELECT /*+USE_NL(t1,t2)*/ * FROM t2 PARTITION(b1) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1 PARTITION(a2))) tb1
WHERE ta1.c1 NOT IN(SELECT /*+USE_MJ(t1,t2)*/ c1 FROM t2 PARTITION(e2) tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(a1))) AND ta1.c0 > 10;
--enable_result_log

EXPLAIN BASIC SELECT /*+parallel(2) NO_REWRITE READ_CONSISTENCY (weak)*/ * FROM
(SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 PARTITION(a1) tl1 WHERE tl1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(b2))) ta1,
(SELECT /*+USE_NL(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t2 PARTITION(b1) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1 PARTITION(a2))) tb1
WHERE ta1.c1 NOT IN(SELECT /*+USE_MJ(t1,t2) READ_CONSISTENCY (weak)*/ c1 FROM t2 PARTITION(e2) tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(a1))) AND ta1.c0 > 10;


--disable_result_log
SELECT /*+parallel(2) NO_REWRITE*/ * FROM
(SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 PARTITION(r2) tl1 WHERE tl1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(b3))) ta1,
(SELECT /*+USE_NL(t1,t2)*/ * FROM t2 PARTITION(e2) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1 PARTITION(a3))) tb1
WHERE ta1.c1 NOT IN(SELECT /*+USE_MJ(t1,t2)*/ c1 FROM t2 PARTITION(b4) tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(a4))) AND ta1.c0 < 2;
--enable_result_log

EXPLAIN BASIC SELECT /*+parallel(2) NO_REWRITE READ_CONSISTENCY (weak)*/ * FROM
(SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 PARTITION(r2) tl1 WHERE tl1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(b3))) ta1,
(SELECT /*+USE_NL(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t2 PARTITION(e2) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1 PARTITION(a3))) tb1
WHERE ta1.c1 NOT IN(SELECT /*+USE_MJ(t1,t2) READ_CONSISTENCY (weak)*/ c1 FROM t2 PARTITION(b4) tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(a4))) AND ta1.c0 < 2;


--disable_result_log
SELECT /*+parallel(2) NO_REWRITE*/ * FROM
(SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t1 PARTITION(a4) tl1 WHERE tl1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(e1))) ta1,
(SELECT /*+parallel(5) USE_NL(t1,t2)*/ * FROM t2 PARTITION(b3) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1 PARTITION(r1))) tb1
WHERE ta1.c1 NOT IN(SELECT /*+USE_HASH(t1,t2)*/ c1 FROM t2 PARTITION(e2) tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(r1))) AND ta1.c0 > 10 ORDER BY 1,2;
--enable_result_log

EXPLAIN BASIC SELECT /*+parallel(2) NO_REWRITE READ_CONSISTENCY (weak)*/ * FROM
(SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 PARTITION(a4) tl1 WHERE tl1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(e1))) ta1,
(SELECT /*+parallel(5) USE_NL(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t2 PARTITION(b3) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1 PARTITION(r1))) tb1
WHERE ta1.c1 NOT IN(SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ c1 FROM t2 PARTITION(e2) tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(r1))) AND ta1.c0 > 10 ORDER BY 1,2;


--disable_result_log
SELECT /*+parallel(2) NO_REWRITE*/ * FROM
(SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t1 tl1 WHERE tl1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(e1))) ta1,
(SELECT /*+parallel(5) USE_NL(t1,t2)*/ * FROM t2 PARTITION(b4) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1)) tb1
WHERE ta1.c1 NOT IN(SELECT /*+USE_HASH(t1,t2)*/ c1 FROM t2 tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(a3))) AND ta1.c0 < 2 ORDER BY 1,2,3;
--enable_result_log

EXPLAIN BASIC SELECT /*+parallel(2) NO_REWRITE READ_CONSISTENCY (weak)*/ * FROM
(SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 tl1 WHERE tl1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(e1))) ta1,
(SELECT /*+parallel(5) USE_NL(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t2 PARTITION(b4) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1)) tb1
WHERE ta1.c1 NOT IN(SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ c1 FROM t2 tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(a3))) AND ta1.c0 < 2 ORDER BY 1,2,3;


--echo #使用with...as语法创建sql

--disable_result_log
WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2)*/ tr1.c0,t2.c1 FROM t1 PARTITION(r1) tr1,t2 WHERE tr1.c0=t2.c0 AND tr1.c1 NOT IN (SELECT c1 FROM t2 PARTITION(b4))),
    data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2)*/ tr1.c0,tb1.c1 FROM t1 PARTITION(r2) tr1 JOIN t2 PARTITION(e2) tb1 ON tr1.c0=tb1.c0 WHERE tb1.c1 <>ALL (SELECT c1 FROM t2 PARTITION(b1) WHERE c1 IS NOT NULL))
    SELECT /*NO_REWRITE*/ * FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 WHERE d1.c1 <>ALL (SELECT c1 FROM data2 WHERE c1 IS NOT NULL);
--enable_result_log

EXPLAIN BASIC WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tr1.c0,t2.c1 FROM t1 PARTITION(r1) tr1,t2 WHERE tr1.c0=t2.c0 AND tr1.c1 NOT IN (SELECT c1 FROM t2 PARTITION(b4))),
    data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tr1.c0,tb1.c1 FROM t1 PARTITION(r2) tr1 JOIN t2 PARTITION(e2) tb1 ON tr1.c0=tb1.c0 WHERE tb1.c1 <>ALL (SELECT c1 FROM t2 PARTITION(b1) WHERE c1 IS NOT NULL))
    SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ * FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 WHERE d1.c1 <>ALL (SELECT c1 FROM data2 WHERE c1 IS NOT NULL);


--disable_result_log
WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
        (SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(a3) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(e1) tl2)) tp1 LEFT JOIN
        (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(e1) tl2 WHERE tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(a3) tl1)) tp2 ON
        tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1)),
    data2 AS (SELECT /*+parallel(5) USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
        (SELECT /*NO_REWRITE*/ tl1.c0,tl1.c1 FROM t1 PARTITION(r2) tl1 WHERE tl1.c1 <>ALL (SELECT c1 FROM t2 PARTITION(b3))) tp1 LEFT JOIN
        (SELECT te2.c0,te2.c1 FROM t2 PARTITION(b4) te2 WHERE te2.c1 NOT IN (SELECT c1 FROM t1 PARTITION(r2))) tp2 ON
        tp1.c0=tp2.c0 WHERE tp2.c1 <>ALL(SELECT c1 FROM t1))
    SELECT * FROM data1 d1,data2 d2 WHERE d1.c0=d2.c0 AND d2.c1 NOT IN(SELECT c1 FROM data1) ORDER BY 1,2,3;
--enable_result_log

EXPLAIN BASIC WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
        (SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(a3) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(e1) tl2)) tp1 LEFT JOIN
        (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(e1) tl2 WHERE tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(a3) tl1)) tp2 ON
        tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1)),
    data2 AS (SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
        (SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ tl1.c0,tl1.c1 FROM t1 PARTITION(r2) tl1 WHERE tl1.c1 <>ALL (SELECT c1 FROM t2 PARTITION(b3))) tp1 LEFT JOIN
        (SELECT te2.c0,te2.c1 FROM t2 PARTITION(b4) te2 WHERE te2.c1 NOT IN (SELECT c1 FROM t1 PARTITION(r2))) tp2 ON
        tp1.c0=tp2.c0 WHERE tp2.c1 <>ALL(SELECT c1 FROM t1))
    SELECT /*+READ_CONSISTENCY (weak)*/ * FROM data1 d1,data2 d2 WHERE d1.c0=d2.c0 AND d2.c1 NOT IN(SELECT c1 FROM data1) ORDER BY 1,2,3;


