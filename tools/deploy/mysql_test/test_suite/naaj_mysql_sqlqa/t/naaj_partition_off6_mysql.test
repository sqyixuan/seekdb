--echo #使用with...as语法创建sql

--disable_result_log
WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2)*/ tr1.c0,t2.c1 FROM t1 PARTITION(r1) tr1,t2 WHERE tr1.c0=t2.c0 AND tr1.c1 NOT IN (SELECT c1 FROM t2 PARTITION(b3))),
    data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2)*/ tr1.c0,tb1.c1 FROM t1 PARTITION(r2) tr1 JOIN t2 PARTITION(e2) tb1 ON tr1.c0=tb1.c0 WHERE tb1.c1 <>ALL (SELECT c1 FROM t2 PARTITION(b4) WHERE c1 IS NOT NULL))
    SELECT /*NO_REWRITE*/ * FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 WHERE d1.c1 <>ALL (SELECT c1 FROM data2 WHERE c1 IS NOT NULL) ORDER BY 1,2;
--enable_result_log

EXPLAIN BASIC WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2)*/ tr1.c0,t2.c1 FROM t1 PARTITION(r1) tr1,t2 WHERE tr1.c0=t2.c0 AND tr1.c1 NOT IN (SELECT c1 FROM t2 PARTITION(b3))),
    data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2)*/ tr1.c0,tb1.c1 FROM t1 PARTITION(r2) tr1 JOIN t2 PARTITION(e2) tb1 ON tr1.c0=tb1.c0 WHERE tb1.c1 <>ALL (SELECT c1 FROM t2 PARTITION(b4) WHERE c1 IS NOT NULL))
    SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ * FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 WHERE d1.c1 <>ALL (SELECT c1 FROM data2 WHERE c1 IS NOT NULL) ORDER BY 1,2;


--disable_result_log
WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
        (SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(a2) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(e1) tl2 WHERE c1 IS NOT NULL)) tp1 LEFT JOIN
        (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(e1) tl2 WHERE tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(a2) tl1 WHERE c1 IS NOT NULL)) tp2 ON
        tp1.c0=tp2.c0 WHERE tp2.c1 <>ALL(SELECT c1 FROM t1)),
    data2 AS (SELECT /*+parallel(5) USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
        (SELECT /*NO_REWRITE*/ tl1.c0,tl1.c1 FROM t1 PARTITION(r2) tl1 WHERE tl1.c1 <>ALL (SELECT c1 FROM t2 PARTITION(b3) WHERE c1 IS NOT NULL)) tp1 LEFT JOIN
        (SELECT te2.c0,te2.c1 FROM t2 PARTITION(b4) te2 WHERE te2.c1 NOT IN (SELECT c1 FROM t1 PARTITION(r2) WHERE c1 IS NOT NULL)) tp2 ON
        tp1.c0=tp2.c0 WHERE tp2.c1 <>ALL(SELECT c1 FROM t1))
    SELECT * FROM data1 d1,data2 d2 WHERE d1.c0=d2.c0 AND d2.c1 NOT IN(SELECT c1 FROM data1 WHERE c1 IS NOT NULL) ORDER BY 1,2,3;
--enable_result_log

