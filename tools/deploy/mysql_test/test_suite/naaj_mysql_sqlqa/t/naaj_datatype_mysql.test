#owner:peihan.dph
#owner group: 技术部-SQL-SQL2组
#description: 在无索引约束等情况下，设定_optimizer_null_aware_antijoin=ON时，各种列类型测试
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/create_tenant_by_charset_mysql.inc
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/conn_tenant_mysql.inc

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/check_schema_sync.inc
connection conn_charset_test_sys_mysql;
sleep 1;

--enable_result_log

--echo # 环境清理
--disable_warnings
--error 0,1396
DROP USER zhang;
--enable_warnings

CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';

--source mysql_test/include/check_schema_sync.inc
connect (zhang,$OBMYSQL_MS0,zhang,zhang,*NO-ONE*,$OBMYSQL_PORT);
connection zhang;
sleep 1;

#创建数据库naaj_test
CREATE DATABASE IF NOT EXISTS naaj_test;
USE naaj_test;

--echo ################Setting ''_ optimizer_ null_ aware_ Antijoin 'is ON################
SET _optimizer_null_aware_antijoin=ON;

--disable_warnings
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;

--echo #CHAR TYPE

CREATE TABLE t1(c0 INT,c1 CHAR(10));
CREATE TABLE t2(c0 INT,c1 CHAR(10));
INSERT INTO t1 VALUES(1,'A');
INSERT INTO t1 VALUES(2,12);
INSERT INTO t1 VALUES(3,'A');
INSERT INTO t1 VALUES(4,NULL);
INSERT INTO t1 VALUES(1,12);
INSERT INTO t2 VALUES(2,'AB');
INSERT INTO t2 VALUES(3,'');
INSERT INTO t2 VALUES(4,NULL);
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;

--echo #There are null values on the right side of the left table

SELECT * FROM t1 WHERE c1 NOT IN (NULL) ORDER BY t1.c0,t1.c1;

SELECT * FROM t1 WHERE c1 NOT IN ('12','AA') ORDER BY t1.c0,t1.c1;

--error 01064
SELECT * FROM t1 WHERE c0 <>ALL (2,3) ORDER BY t1.c0,t1.c1;
--error 01064
SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 <>ALL (NULL) ORDER BY t1.c0,t1.c1;

SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN ('A') ORDER BY 1,2,3;

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #There are null values on the right table

DELETE FROM t1 WHERE c0=4;
SELECT * FROM t1 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #There are null values on the left table

INSERT INTO t1 VALUES(4,NULL);
DELETE FROM t2 WHERE c0=4;
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #There are no null values in the left and right tables

DELETE FROM t1 WHERE c0=4;
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc

--echo #Left table is empty

DELETE FROM t1;
INSERT INTO t2 VALUES(4,NULL);
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #right table is empty

DELETE FROM t2;
INSERT INTO t1 VALUES(1,'A');
INSERT INTO t1 VALUES(2,12);
INSERT INTO t1 VALUES(3,'A');
INSERT INTO t1 VALUES(4,NULL);
INSERT INTO t1 VALUES(1,12);
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #The left and right tables are empty

DELETE FROM t2;
DELETE FROM t1;
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc

--echo #VARCHAR2 TYPE

DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,c1 VARCHAR(10));
CREATE TABLE t2(c0 INT,c1 VARCHAR(10));
INSERT INTO t1 VALUES(1,'A');
INSERT INTO t1 VALUES(2,'A');
INSERT INTO t1 VALUES(3,12);
INSERT INTO t1 VALUES(4,NULL);
INSERT INTO t1 VALUES(5,'%-$');
INSERT INTO t1 VALUES(6,'AB');
INSERT INTO t1 VALUES(7,'');
INSERT INTO t2 VALUES(1,'AB');
INSERT INTO t2 VALUES(2,12);
INSERT INTO t2 VALUES(3,'AB');
INSERT INTO t2 VALUES(4,12);
INSERT INTO t2 VALUES(5,'');
INSERT INTO t2 VALUES(6,NULL);
INSERT INTO t2 VALUES(7,'%--$');

--echo #There are null values on the right side of the left table

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #There are null values on the right table

DELETE FROM t1 WHERE c0 IN(4,7);
SELECT * FROM t1 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #There are null values on the left table

INSERT INTO t1 VALUES(4,NULL);
INSERT INTO t1 VALUES(7,'');
DELETE FROM t2 WHERE c0 IN(5,6);
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #There are no null values in the left and right tables

DELETE FROM t1 WHERE c0 IN(4,7);
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc

--echo #Left table is empty

DELETE FROM t1;
INSERT INTO t2 VALUES(5,'');
INSERT INTO t2 VALUES(6,NULL);
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #right table is empty

DELETE FROM t2;
INSERT INTO t1 VALUES(1,'A');
INSERT INTO t1 VALUES(2,'A');
INSERT INTO t1 VALUES(3,12);
INSERT INTO t1 VALUES(4,NULL);
INSERT INTO t1 VALUES(5,'%-$');
INSERT INTO t1 VALUES(6,'AB');
INSERT INTO t1 VALUES(7,'');
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


--echo #The left and right tables are empty

DELETE FROM t2;
DELETE FROM t1;
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/explain_na.inc


DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;

--enable_warnings

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/check_schema_sync.inc
connection conn_charset_test_sys_mysql;
sleep 1;

DROP USER 'zhang'@'%';
DROP DATABASE naaj_test;

disconnect zhang;
disconnect conn_charset_test_sys_mysql;

--echo  #########Empty recycle bin, delete test database, tables, etc##########
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/drop_tenant_mysql.inc
purge recyclebin;
