#description: 创建分区表，设定_optimizer_null_aware_antijoin=ON时，LIST分区情景测试
#author: wb-zc01081081
# tags: optimizer


--echo ################Setting ''_ optimizer_ null_ aware_ Antijoin 'is ON################
connect (conn_admin,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set weak_read_version_refresh_interval = '50ms';
select sleep(3) from dual;

connection default;
SET _optimizer_null_aware_antijoin=ON;


--echo #PARTITION BY LIST

--disable_warnings
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
--enable_warnings
CREATE TABLE t1(c0 INT,c1 CHAR(10))
PARTITION BY LIST COLUMNS(c1)
(PARTITION l1 VALUES IN('A',NULL,'中文','COL','NAL','AB',''),
 PARTITION l2 VALUES IN('10','12','$ % &','$%&','文')
);
CREATE TABLE t2(c0 INT,c1 CHAR(10))
PARTITION BY LIST COLUMNS(c1)
(PARTITION l1 VALUES IN('AB',NULL,'中','test 1','中guo','$&'),
 PARTITION l2 VALUES IN('10','12','$ % &','ABC','mars','13','')
 );
INSERT INTO t1 VALUES(1,'A'),(2,''),(3,12),(4,NULL),(5,'$ % &'),(6,'中文'),(7,'AB'),(7,''),(8,'NAL'),(9,NULL),(10,'$%&'),(10,'文');
INSERT INTO t2 VALUES(1,'AB'),(2,''),(3,'12'),(4,NULL),(5,'中'),(6,'$&'),(7,'ABC'),(8,'test 1'),(8,'13'),(9,'mars'),(9,'中guo'),(10,'$ % &');
SELECT * FROM t1 ORDER BY 1,2;
SELECT * FROM t2 ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2);

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2);


SELECT * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2);

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2);


SELECT * FROM t1 WHERE NOT EXISTS (SELECT c1 FROM t2);

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE NOT EXISTS (SELECT c1 FROM t2);


SELECT * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t1);

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t1);


--error 01064
SELECT * FROM t1 WHERE c1 <>ALL (NULL,'AB','中文');


SELECT * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT * FROM t1 WHERE NOT EXISTS (SELECT c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE NOT EXISTS (SELECT c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2 WHERE NOT EXISTS (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2 WHERE NOT EXISTS (SELECT c1 FROM t1)) ORDER BY 1,2;

SELECT * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT * FROM t1 WHERE NOT EXISTS (SELECT c1 FROM t2 WHERE c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE NOT EXISTS (SELECT c1 FROM t2 WHERE c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 NOT IN (SELECT t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 <>ALL (SELECT t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 NOT IN (SELECT t2.c1 FROM t1 LEFT JOIN t2 ON t1.c0=t2.c0 AND t2.c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT t2.c1 FROM t1 LEFT JOIN t2 ON t1.c0=t2.c0 AND t2.c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 <>ALL (SELECT t2.c1 FROM t1 RIGTH JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT t2.c1 FROM t1 RIGTH JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 NOT IN (SELECT t2.c1 FROM t1 FULL JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT t2.c1 FROM t1 FULL JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT /*+USE_HASH(t1,t2) */ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN(SELECT c1 FROM t1);

EXPLAIN BASIC SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN(SELECT c1 FROM t1);


SELECT /*+USE_HASH */ * FROM t1 WHERE c1 <>ALL (SELECT t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+USE_HASH READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT /*+USE_HASH */ * FROM t1 WHERE c1 <>ALL (SELECT /*+USE_NL */ t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+USE_HASH READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT /*+USE_NL */ t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT /*+USE_NL(t1,t2) */ * FROM
t1 WHERE NOT EXISTS (SELECT /*+USE_HASH(t2) */ t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+USE_NL(t1,t2) READ_CONSISTENCY (weak)*/ * FROM
t1 WHERE NOT EXISTS (SELECT /*+USE_HASH(t2) READ_CONSISTENCY (weak)*/ t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t2.c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;


SELECT /*+parallel(2) USE_HASH(t1,t2) */ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(2) USE_NL(t1,t2) */ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2) ORDER BY 1,2,3,4;

EXPLAIN BASIC SELECT /*+parallel(2) USE_NL(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2) ORDER BY 1,2,3,4;


SELECT /*+parallel(2) USE_HASH(t1,t2) */ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2,3,4;

EXPLAIN BASIC SELECT /*+parallel(2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2,3,4;


SELECT /*+parallel(2) USE_HASH(t1,t2) */ * FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE NOT EXISTS (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE NOT EXISTS (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(5) USE_NL(t1,t2) */ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(5) USE_NL(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(5) USE_HASH(t1,t2) */ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(5) USE_MERGE(t1,t2) */ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(5) USE_MERGE(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(5) USE_HASH(t1,t2) */ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2,3,4;

EXPLAIN BASIC SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2,3,4;


SELECT /*+parallel(5) USE_HASH(t1,t2) */ * FROM
t1 JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 IN ('AB','12','2','3','4','5','6',NULL)) ORDER BY 1,2,3,4;

EXPLAIN BASIC SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM
t1 JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 IN ('AB','12','2','3','4','5','6',NULL)) ORDER BY 1,2,3,4;


SELECT /*+parallel(5) leading(t1 t2) USE_HASH(t1,t2) */ * FROM t1 WHERE t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;

EXPLAIN BASIC SELECT /*+parallel(5) leading(t1 t2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 WHERE t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY t1.c0,t1.c1;


SELECT /*+parallel(5) leading(t1 t2) PQ_DISTRIBUTE(t2 PARTITION NONE)  USE_HASH(t1, t2) */ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2);

EXPLAIN BASIC SELECT /*+parallel(5) leading(t1 t2) PQ_DISTRIBUTE(t2 PARTITION NONE)  USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2);


--echo #查询某一分区的值

SELECT /*+USE_HASH(t1,t2) */ tp1.c0,tp1.c1 FROM t1 PARTITION(l1) tp1 LEFT JOIN t2 PARTITION(l1) tp2 ON tp1.c0=tp2.c0 AND tp2.c1 NOT IN(SELECT c1 FROM t1) ORDER BY tp1.c0,tp1.c1;

EXPLAIN BASIC SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM t1 PARTITION(l1) tp1 LEFT JOIN t2 PARTITION(l1) tp2 ON tp1.c0=tp2.c0 AND tp2.c1 NOT IN(SELECT c1 FROM t1) ORDER BY tp1.c0,tp1.c1;


SELECT /*+USE_HASH(t1,t2) */ tp1.c0,tp1.c1 FROM
t1 PARTITION(l1) tp1 RIGHT JOIN t2 PARTITION(l1) tp2 ON tp1.c0=tp2.c0
WHERE tp2.c1 <>ALL(SELECT tl1.c1 FROM t1 PARTITION(l2) tl1 WHERE tl1.c1<>ALL(SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) ORDER BY tp1.c0,tp1.c1;

EXPLAIN BASIC SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
t1 PARTITION(l1) tp1 RIGHT JOIN t2 PARTITION(l1) tp2 ON tp1.c0=tp2.c0
WHERE tp2.c1 <>ALL(SELECT tl1.c1 FROM t1 PARTITION(l2) tl1 WHERE tl1.c1<>ALL(SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) ORDER BY tp1.c0,tp1.c1;


SELECT /*+USE_HASH(t1,t2) */ tp1.c0,tp1.c1 FROM
(SELECT t1.c0,t1.c1 FROM t1,t2 WHERE t1.c1 <>ALL (SELECT c1 FROM t2 WHERE c0 > 3)) tp1 LEFT JOIN t2 PARTITION(l1) tp2 ON tp1.c0=tp2.c0
AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY tp1.c0,tp1.c1;

EXPLAIN BASIC SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
(SELECT t1.c0,t1.c1 FROM t1,t2 WHERE t1.c1 <>ALL (SELECT c1 FROM t2 WHERE c0 > 3)) tp1 LEFT JOIN t2 PARTITION(l1) tp2 ON tp1.c0=tp2.c0
AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY tp1.c0,tp1.c1;


SELECT /*+USE_HASH(t1,t2) */ tp1.c0,tp1.c1 FROM
(SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY tp1.c0,tp1.c1;

EXPLAIN BASIC SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
(SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY tp1.c0,tp1.c1;


SELECT /*+parallel(5) USE_HASH(t1,t2) */ tp1.c0,tp1.c1 FROM
(SELECT /*NO_REWRITE*/ tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY tp1.c0,tp1.c1;

EXPLAIN BASIC SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
(SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY tp1.c0,tp1.c1;



--echo #使用with...as语法对数据进行分析

WITH
    data1 AS (SELECT /*+parallel(5) USE_HASH(t1,t2) */ t1.c0,t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY t1.c0,t1.c1),
    data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2) */ t1.c0,t2.c1 FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY t1.c0,t1.c1)
    SELECT /*NO_REWRITE*/ * FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 AND d1.c1 <>ALL (SELECT c1 FROM data2) ORDER BY 1,2;


EXPLAIN BASIC WITH
    data1 AS (SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ t1.c0,t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY t1.c0,t1.c1),
    data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ t1.c0,t2.c1 FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY t1.c0,t1.c1)
    SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ * FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 AND d1.c1 <>ALL (SELECT c1 FROM data2) ORDER BY 1,2;


WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
        (SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
        tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
        tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY tp1.c0,tp1.c1),
    data2 AS (SELECT /*+parallel(5) USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
        (SELECT /*NO_REWRITE*/ tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
        tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
        tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY tp1.c0,tp1.c1)
    SELECT * FROM data1 d1,data2 d2 WHERE d1.c0=d2.c0 AND d2.c1 NOT IN(SELECT c1 FROM data1);


EXPLAIN BASIC WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
        (SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
        tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
        tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY tp1.c0,tp1.c1),
    data2 AS (SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
        (SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
        tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
        tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY tp1.c0,tp1.c1)
    SELECT /*+READ_CONSISTENCY (weak)*/ * FROM data1 d1,data2 d2 WHERE d1.c0=d2.c0 AND d2.c1 NOT IN(SELECT c1 FROM data1);



--echo #IS NOT NULL


SELECT * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2) AND c1 IS NOT NULL ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2) AND c1 IS NOT NULL ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) AND c1 IS NOT NULL ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2 WHERE c1 IS NOT NULL) AND c1 IS NOT NULL ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE c1 NOT IN(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE c1 NOT IN(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)) ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 NOT IN (SELECT t2.c1 FROM t1,t2 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 NOT IN (SELECT t2.c1 FROM t1,t2 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)) ORDER BY 1,2;


SELECT * FROM t1 WHERE c1 <>ALL (SELECT t2.c1 FROM t1,t2 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) AND t2.c1 IS NOT NULL) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 WHERE c1 <>ALL (SELECT t2.c1 FROM t1,t2 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) AND t2.c1 IS NOT NULL) ORDER BY 1,2;


