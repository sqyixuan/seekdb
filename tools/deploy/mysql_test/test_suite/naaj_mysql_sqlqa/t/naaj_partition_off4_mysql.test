WHERE ta1.c1 NOT IN(SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ c1 FROM t2 PARTITION(e1) tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(a4))) AND ta1.c0 > 10 ORDER BY 1,2,3,4;


--disable_result_log
SELECT /*+parallel(2) NO_REWRITE*/ * FROM
(SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t1 tl1 WHERE tl1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(e1))) ta1,
(SELECT /*+parallel(5) USE_NL(t1,t2)*/ * FROM t2 PARTITION(b1) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1 )) tb1
WHERE ta1.c1 NOT IN(SELECT /*+USE_HASH(t1,t2)*/ c1 FROM t2 tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(a4))) AND ta1.c0 < 2 ORDER BY 1,2,3,4;
