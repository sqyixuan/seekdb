(SELECT /*+USE_NL(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t2 PARTITION(e1) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1 PARTITION(a2))) tb1
