#owner:peihan.dph
#owner group: 技术部-SQL-SQL2组
#description: 创建分区表，设定_optimizer_null_aware_antijoin=OFF时，子分区下测试
#author: wb-zc01081081
# tags: optimizer


--echo ################Setting ''_ optimizer_ null_ aware_ Antijoin 'is OFF################
SET _optimizer_null_aware_antijoin=OFF;


--echo #SUBPARTITION
--echo #range-->HASH/KEY

--disable_warnings
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
--enable_warnings
CREATE TABLE t1(c0 INT,c1 INT)
PARTITION BY RANGE(c1) SUBPARTITION BY HASH(c1)
(PARTITION r1 VALUES LESS THAN (50)
 (SUBPARTITION a1 ,
  SUBPARTITION a2 ,
  SUBPARTITION a3 ),
 PARTITION r2 VALUES LESS THAN (100)
 (SUBPARTITION a4 ,
  SUBPARTITION a5 ,
  SUBPARTITION a6
));

CREATE TABLE t2(c0 INT,c1 INT)
PARTITION BY RANGE(c1) SUBPARTITION BY KEY(c1)
(PARTITION e1 VALUES LESS THAN(75)
 (SUBPARTITION b1 ,
  SUBPARTITION b2 ,
  SUBPARTITION b3 ),
 PARTITION e2 VALUES LESS THAN(150)
 (SUBPARTITION b4 ,
  SUBPARTITION b5 ,
  SUBPARTITION b6)
);

--disable_warnings
DELIMITER //;

CREATE PROCEDURE p1()
BEGIN
    DECLARE j INT DEFAULT 1;
    WHILE j <= 45 DO
        IF MOD(j,11) = 0 THEN
            INSERT INTO t1 VALUES(j,50);
        ELSEIF MOD(j,9) = 0 THEN
            INSERT INTO t1 VALUES(j,99);
        ELSEIF MOD(j,7) = 0 THEN
            INSERT INTO t1 VALUES(j,j+55);
        ELSEIF MOD(j,5) = 0 THEN
            INSERT INTO t1 VALUES(j,j-2);
        ELSEIF MOD(j,3) = 0 THEN
            INSERT INTO t1 VALUES(j,j*2);
        ELSE
            INSERT INTO t1 VALUES(j,j+1);
        END IF;
        SET j = j + 1;
    END WHILE;
END;
//


CREATE  PROCEDURE p2()
BEGIN
    DECLARE j INT DEFAULT 1;
    WHILE j <= 45 DO
        IF MOD(j,11) = 0 THEN
            INSERT INTO t2 VALUES(j,j*2);
        ELSEIF MOD(j,9) = 0 THEN
            INSERT INTO t2 VALUES(j,121);
        ELSEIF MOD(j,7) = 0 THEN
            INSERT INTO t2 VALUES(j,j+100);
        ELSEIF MOD(j,5) = 0 THEN
            INSERT INTO t2 VALUES(j,j-5);
        ELSEIF MOD(j,3) = 0 THEN
            INSERT INTO t2 VALUES(j,j*-3);
        ELSE
            INSERT INTO t2 VALUES(j,j+2);
        END IF;
        SET j = j + 1;
    END WHILE;
END;
//
DELIMITER ;//

--enable_warnings

CALL p1();
CALL p2();

SELECT * FROM t1 ORDER BY 1,2;
SELECT * FROM t2 ORDER BY 1,2;

SELECT * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2;

