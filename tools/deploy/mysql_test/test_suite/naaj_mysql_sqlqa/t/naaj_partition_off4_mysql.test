--echo #查询部分子分区的值

--disable_result_log
SELECT ta1.c0 FROM t1 PARTITION(a2) ta1,t2 tb1 WHERE ta1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(b2)) GROUP BY ta1.c0 ORDER BY 1;
--enable_result_log

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ ta1.c0 FROM t1 PARTITION(a2) ta1,t2 tb1 WHERE ta1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(b2)) GROUP BY ta1.c0 ORDER BY 1;


--disable_result_log
SELECT * FROM t1 PARTITION(a2) ta1,t2 PARTITION(b2) tb1 WHERE ta1.c0=tb1.c0 AND ta1.c1 NOT IN(SELECT c1 FROM t2 PARTITION(b2)) ORDER BY 1,2,3;
--enable_result_log

EXPLAIN BASIC SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t1 PARTITION(a2) ta1,t2 PARTITION(b2) tb1 WHERE ta1.c0=tb1.c0 AND ta1.c1 NOT IN(SELECT c1 FROM t2 PARTITION(b2)) ORDER BY 1,2,3;

--echo #查询子分区下，由于hash/key子分区分配规则不同，故每次打印结果是不一致的，因此在查询子分区时不打印结果

--disable_result_log
SELECT /*+parallel(2) NO_REWRITE*/ * FROM
(SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 PARTITION(a1) tl1 WHERE tl1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(b1))) ta1,
(SELECT /*+USE_NL(t1,t2)*/ * FROM t2 PARTITION(b3) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1 PARTITION(a3))) tb1
WHERE ta1.c1 NOT IN(SELECT /*+USE_MJ(t1,t2)*/ c1 FROM t2 PARTITION(b2) tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(a2))) AND ta1.c0 > 10 ORDER BY 1,2,3,4;
--enable_result_log

EXPLAIN BASIC SELECT /*+parallel(2) NO_REWRITE READ_CONSISTENCY (weak)*/ * FROM
(SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t1 PARTITION(a1) tl1 WHERE tl1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(b1))) ta1,
(SELECT /*+USE_NL(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t2 PARTITION(b3) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1 PARTITION(a3))) tb1
WHERE ta1.c1 NOT IN(SELECT /*+USE_MJ(t1,t2) READ_CONSISTENCY (weak)*/ c1 FROM t2 PARTITION(b2) tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(a2))) AND ta1.c0 > 10 ORDER BY 1,2,3,4;


--disable_result_log
SELECT /*+parallel(2) NO_REWRITE*/ * FROM
(SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 PARTITION(r1) tl1 WHERE tl1.c1 <>ALL(SELECT c1 FROM t2 PARTITION(b2))) ta1,
(SELECT /*+USE_NL(t1,t2)*/ * FROM t2 PARTITION(e1) tl2 WHERE tl2.c1 <>ALL(SELECT c1 FROM t1 PARTITION(a2))) tb1
WHERE ta1.c1 NOT IN(SELECT /*+USE_MJ(t1,t2)*/ c1 FROM t2 PARTITION(b4) tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(a4))) AND ta1.c0 < 2 ORDER BY 1,2,3,4;
--enable_result_log

