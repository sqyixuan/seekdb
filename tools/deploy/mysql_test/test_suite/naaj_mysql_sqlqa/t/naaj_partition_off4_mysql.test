WHERE ta1.c1 NOT IN(SELECT /*+USE_HASH(t1,t2)*/ c1 FROM t2 PARTITION(e1) tl3 WHERE tl3.c1 NOT IN(SELECT c1 FROM t1 PARTITION(a4))) AND ta1.c0 > 10 ORDER BY 1,2,3,4;
