#owner:peihan.dph
#owner group: 技术部-SQL-SQL2组
#description: 设定_optimizer_null_aware_antijoin=ON/OFF，列为生成列时，测试使用NAAJ算子
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

#--source mysql_test/test_suite/naaj_mysql_sqlqa/include/create_tenant_by_charset_mysql.inc
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/conn_tenant_mysql.inc

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/check_schema_sync.inc
connection conn_charset_test_sys_mysql;
sleep 1;

--enable_result_log

--echo # 环境清理
--disable_warnings
--error 0,1396
DROP USER zhang;
--enable_warnings

CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';

--source mysql_test/include/check_schema_sync.inc
connect (zhang,$OBMYSQL_MS0,zhang,zhang,*NO-ONE*,$OBMYSQL_PORT);
connection zhang;
sleep 1;

#创建数据库naaj_test
CREATE DATABASE IF NOT EXISTS naaj_test;
USE naaj_test;

--echo ################Setting ''_ optimizer_ null_ aware_ Antijoin 'is ON################
SET _optimizer_null_aware_antijoin=ON;

--disable_warnings
--error 01051
DROP TABLE t1;
--error 01051
DROP TABLE t2;
--enable_warnings

CREATE TABLE t1(c0 INT,c1 INT AS (2 * c0));
CREATE TABLE t2(c0 INT,c1 INT AS (4 * c0));
INSERT INTO t1(c0) VALUES(0),(1),(2),(2),(4),(6),(7),(NULL);
INSERT INTO t2(c0) VALUES(0),(1),(2),(3),(4),(5),(NULL);
SELECT * FROM t1 ORDER BY c0;
SELECT * FROM t2 ORDER BY c0;

--echo #operator

SELECT * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE c1 NOT IN (SELECT c1 FROM t1)) ORDER BY 1,2;

SELECT * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE c1 NOT IN (NULL)) ORDER BY 1,2;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 >ALL (SELECT c1 FROM t2 WHERE c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2,3;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE EXISTS (SELECT c1 FROM t2 WHERE NOT EXISTS (SELECT c1 FROM t1)) ORDER BY 1,2;

SELECT /*+parallel(5) USE_NLJ(t1,t2)*/ * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE t2.c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;

--error 01064
SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE t2.c1 <>ALL (NULL)) ORDER BY 1,2;

--echo #Self connection

SELECT * FROM t1 WHERE t1.c1 NOT IN (SELECT c1 FROM t1 WHERE c1>5) ORDER BY 1,2;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE t1.c1 <>ALL (SELECT c1 FROM t1 WHERE t1.c1 NOT IN (SELECT c1 FROM t1 WHERE c1 > 5)) ORDER BY 1,2;

SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t1 a,t1 b WHERE a.c0=b.c0 AND a.c1 <>ALL (SELECT c1 FROM t1 WHERE t1.c1 NOT IN(1,2,3)) ORDER BY a.c0,a.c1;

SELECT * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2;

SELECT * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2;

SELECT * FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2,3;

SELECT * FROM t1 LEFT JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2;

SELECT * FROM t1 FULL JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2) ORDER BY 1,2;

SELECT /*+USE_NLJ(t1,t2)*/ * FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2;

SELECT /*+USE_MERGE(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2);

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2) ORDER BY 1,2;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE t1.c1 >= t2.c1) ORDER BY 1,2;

SELECT * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2) ORDER BY 1,2;

SELECT * FROM t1 LEFT JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2,3;

SELECT * FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2,3;

SELECT * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2,3;

SELECT * FROM t1 FULL JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+USE_NLJ(t1,t2)*/ * FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2 WHERE EXISTS (SELECT c1 FROM t1)) ORDER BY 1,2;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+USE_NLJ(t1,t2)*/ * FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IN (SELECT c1 FROM t1)) ORDER BY 1,2;

SELECT /*+USE_NLJ(t1,t2)*/ * FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0 WHERE t1.c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+USE_MERGE(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+USE_NL(t1,t2)*/ * FROM t1 JOIN t2 ON t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+parallel(2) USE_NL(t1,t2)*/ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+parallel(5) USE_NLJ(t1,t2)*/ * FROM t1 WHERE c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+parallel(2) USE_MERGE(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+parallel(2) USE_NL(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2 WHERE t2.c1 IS NOT NULL) ORDER BY 1,2;

SELECT /*+parallel(2) USE_HASH(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t1.c1 < t2.c1 AND t2.c1 IS NOT NULL) ORDER BY 1,2,3;

SELECT /*+parallel(2) USE_MERGE(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 <>ALL (SELECT c1 FROM t2 WHERE t1.c1 != t2.c1 AND t2.c1 IS NOT NULL) ORDER BY 1,2,3;

SELECT /*+parallel(2) USE_NL(t1,t2)*/ * FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2 WHERE t1.c1 > t2.c1 AND t2.c1 IS NOT NULL) ORDER BY 1,2,3;

