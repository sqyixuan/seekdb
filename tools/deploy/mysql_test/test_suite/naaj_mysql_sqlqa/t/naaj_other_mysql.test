#tags: optimizer



--echo ################Setting ''_ optimizer_ null_ aware_ Antijoin 'is ON################
SET _optimizer_null_aware_antijoin=ON;


--echo #VIEW


DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,c1 CHAR(50));
CREATE TABLE t2(c0 INT,c1 VARCHAR(50));
INSERT INTO t1 VALUES(1,'A');
INSERT INTO t1 VALUES(2,12);
INSERT INTO t1 VALUES(3,'A');
INSERT INTO t1 VALUES(4,NULL);
INSERT INTO t1 VALUES(5,'$ % &');
INSERT INTO t2 VALUES(1,12);
INSERT INTO t2 VALUES(2,'AB');
INSERT INTO t2 VALUES(3,'');
INSERT INTO t2 VALUES(4,NULL);
INSERT INTO t2 VALUES(5,'$%&');

CREATE OR REPLACE VIEW v1 AS SELECT * FROM t1;
CREATE OR REPLACE VIEW v2 AS SELECT * FROM t2;
SELECT * FROM v1 ORDER BY c0,c1;
SELECT * FROM v2 ORDER BY c0,c1;

SELECT /*USE_HASH(v1,v2)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2) ORDER BY v1.c0,v1.c1;

EXPLAIN BASIC SELECT /*USE_HASH(v1,v2),READ_CONSISTENCY (weak)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2) ORDER BY v1.c0,v1.c1;


SELECT /*USE_MERGE(v1,v2)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2) ORDER BY v1.c0,v1.c1;


EXPLAIN BASIC SELECT /*USE_MERGE(v1,v2),READ_CONSISTENCY (weak)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2) ORDER BY v1.c0,v1.c1;


SELECT /*USE_HASH(v1,v2)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2 WHERE c1 <>ALL (SELECT c1 FROM v1)) ORDER BY v1.c0,v1.c1;


EXPLAIN BASIC SELECT /*USE_HASH(v1,v2),READ_CONSISTENCY (weak)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2 WHERE c1 <>ALL (SELECT c1 FROM v1)) ORDER BY v1.c0,v1.c1;


SELECT /*+parallel(5) USE_HASH(v1,v2)*/ * FROM v1 JOIN v2 ON v1.c0=v2.c0 WHERE v1.c1 NOT IN (SELECT c1 FROM v2) ORDER BY v1.c0,v1.c1;


EXPLAIN BASIC SELECT /*+parallel(5) USE_HASH(v1,v2),READ_CONSISTENCY (weak)*/ * FROM v1 JOIN v2 ON v1.c0=v2.c0 WHERE v1.c1 NOT IN (SELECT c1 FROM v2) ORDER BY v1.c0,v1.c1;


SELECT /*+parallel(2) USE_HASH(v1,v2)*/ * FROM v1  WHERE c1 <>ALL (SELECT c1 FROM v2) ORDER BY v1.c0,v1.c1;


EXPLAIN BASIC SELECT /*+parallel(2) USE_HASH(v1,v2),READ_CONSISTENCY (weak)*/ * FROM v1  WHERE c1 <>ALL (SELECT c1 FROM v2) ORDER BY v1.c0,v1.c1;


SELECT /*USE_HASH(v1,v2)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2 WHERE c1 IS NOT NULL) ORDER BY v1.c0,v1.c1;


EXPLAIN BASIC SELECT /*USE_HASH(v1,v2),READ_CONSISTENCY (weak)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2 WHERE c1 IS NOT NULL) ORDER BY v1.c0,v1.c1;


SELECT /*USE_MERGE(v1,v2)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2 WHERE c1 <>ALL(SELECT c1 FROM v1 WHERE c1 IS NOT NULL) AND c1 IS NOT NULL) ORDER BY v1.c0,v1.c1;


EXPLAIN BASIC SELECT /*USE_MERGE(v1,v2),READ_CONSISTENCY (weak)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2 WHERE c1 <>ALL(SELECT c1 FROM v1 WHERE c1 IS NOT NULL) AND c1 IS NOT NULL) ORDER BY v1.c0,v1.c1;


SELECT /*USE_HASH(v1,v2)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2 WHERE c1 <>ALL (SELECT c1 FROM v1) AND c1 IS NOT NULL) ORDER BY v1.c0,v1.c1;


EXPLAIN BASIC SELECT /*USE_HASH(v1,v2),READ_CONSISTENCY (weak)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2 WHERE c1 <>ALL (SELECT c1 FROM v1) AND c1 IS NOT NULL) ORDER BY v1.c0,v1.c1;


SELECT /*+parallel(5) USE_HASH(v1,v2)*/ * FROM v1 JOIN v2 ON v1.c0=v2.c0 WHERE v1.c1 NOT IN (SELECT c1 FROM v2 WHERE c1 IS NOT NULL) ORDER BY v1.c0,v1.c1;


EXPLAIN BASIC SELECT /*+parallel(5) USE_HASH(v1,v2),READ_CONSISTENCY (weak)*/ * FROM v1 JOIN v2 ON v1.c0=v2.c0 WHERE v1.c1 NOT IN (SELECT c1 FROM v2 WHERE c1 IS NOT NULL) ORDER BY v1.c0,v1.c1;


SELECT /*+parallel(2) USE_HASH(v1,v2)*/ * FROM v1  WHERE c1 <>ALL (SELECT c1 FROM v2 WHERE NOT EXISTS(SELECT c1 FROM v1 WHERE c1 IS NOT NULL)) ORDER BY v1.c0,v1.c1;

EXPLAIN BASIC SELECT /*+parallel(2) USE_HASH(v1,v2),READ_CONSISTENCY (weak)*/ * FROM v1  WHERE c1 <>ALL (SELECT c1 FROM v2 WHERE NOT EXISTS(SELECT c1 FROM v1 WHERE c1 IS NOT NULL)) ORDER BY v1.c0,v1.c1;


INSERT INTO v1 SELECT c0,c1 FROM v2 WHERE c1 NOT IN (SELECT c1 FROM v1);
SELECT * FROM v1 ORDER BY c0,c1;

--disable_result_log
EXPLAIN BASIC INSERT INTO v1 SELECT /*+READ_CONSISTENCY (weak)*/ c0,c1 FROM v2 WHERE c1 NOT IN (SELECT c1 FROM v1);
--enable_result_log

--error 01064
INSERT INTO (SELECT c0,c1 FROM v1 WHERE c1 <>ALL (SELECT c1 FROM v2)) VALUES(1,'不');

INSERT INTO v2 SELECT c0,c1 FROM v2 WHERE NOT EXISTS (SELECT c1 FROM v1);
SELECT * FROM v2 ORDER BY c0,c1;

--disable_result_log
EXPLAIN BASIC INSERT INTO v2 SELECT /*+READ_CONSISTENCY (weak)*/ c0,c1 FROM v2 WHERE NOT EXISTS (SELECT c1 FROM v1);
--enable_result_log

INSERT INTO v2 SELECT /*+parallel(2) USE_MERGE(v1) */ * FROM v1 WHERE c1 IN (SELECT /*+READ_CONSISTENCY (weak)*/ c1 FROM v2 WHERE c1 NOT IN (SELECT c1 FROM v1));
SELECT * FROM v2 ORDER BY c0,c1;

--disable_result_log
EXPLAIN BASIC INSERT INTO v2 SELECT /*+parallel(2) USE_MERGE(v1) ,READ_CONSISTENCY (weak)*/ * FROM v1 WHERE c1 IN (SELECT /*+READ_CONSISTENCY (weak)*/ c1 FROM v2 WHERE c1 NOT IN (SELECT c1 FROM v1));
--enable_result_log

INSERT INTO v2 SELECT /*+READ_CONSISTENCY (weak)*/ c0,c1 FROM v2 WHERE c1 IN (SELECT c1 FROM v1 WHERE c1 NOT IN (SELECT c1 FROM v2 WHERE c1 IS NOT NULL));
SELECT * FROM v2 ORDER BY c0,c1;

--disable_result_log
EXPLAIN BASIC INSERT INTO v2 SELECT /*+READ_CONSISTENCY (weak)*/ c0,c1 FROM v2 WHERE c1 IN (SELECT c1 FROM v1 WHERE c1 NOT IN (SELECT c1 FROM v2 WHERE c1 IS NOT NULL));
--enable_result_log


DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,c1 INT);
CREATE TABLE t2(c0 INT,c1 INT);
INSERT INTO t2 VALUES(0,0),(1,1),(2,1),(2,2),(4,3),(6,NULL);
INSERT INTO t1 VALUES(0,0),(1,2),(2,4),(2,6),(4,8),(5,NULL);
CREATE OR REPLACE VIEW v1 AS SELECT * FROM t1;
CREATE OR REPLACE VIEW v2 AS SELECT * FROM t2;
SELECT * FROM v2 ORDER BY c0;
SELECT * FROM v1 ORDER BY c0;

UPDATE v1 SET c1=c1+1 WHERE v1.c1 NOT IN (SELECT c1 FROM v2);
SELECT * FROM v1 ORDER BY c0,c1;

--disable_result_log
EXPLAIN BASIC UPDATE v1 SET c1=c1+1 WHERE c1 NOT IN (SELECT c1 FROM v2);
--enable_result_log

--error 01288
UPDATE (SELECT v1.c1 FROM v1 WHERE v1.c1 <>ALL (SELECT c1 FROM v2)) SET c1=c1+1;

UPDATE v1 SET c1=c1+1 WHERE NOT EXISTS (SELECT c1 FROM v2);
SELECT * FROM v1 ORDER BY c0,c1;

--disable_result_log
EXPLAIN BASIC UPDATE v1 SET c1=c1+1 WHERE NOT EXISTS (SELECT /*+READ_CONSISTENCY (weak)*/ c1 FROM v2);
--enable_result_log

UPDATE v1 SET c1=c1+1 WHERE v1.c1 NOT IN (SELECT /*+parallel(2) USE_NLJ(v2)*/ c1 FROM v2 WHERE c1 IN(SELECT c1 FROM v1));
SELECT * FROM v1 ORDER BY c0,c1;

--disable_result_log
EXPLAIN BASIC UPDATE t1 SET c1=c1+1 WHERE t1.c1 NOT IN (SELECT /*+parallel(2) USE_NLJ(t2),READ_CONSISTENCY (weak) */ c1 FROM t2 WHERE c1 IN(SELECT c1 FROM t1));
--enable_result_log

UPDATE v1 SET c1=c1+1 WHERE v1.c1 <>ALL (SELECT v2.c1 FROM v1 JOIN v2 ON v1.c0=v2.c0 AND v2.c1 NOT IN (SELECT c1 FROM v1));
SELECT * FROM t1 ORDER BY c0,c1;

--disable_result_log
EXPLAIN BASIC UPDATE v1 SET c1=c1+1 WHERE v1.c1 <>ALL (SELECT /*+READ_CONSISTENCY (weak)*/ v2.c1 FROM v1 JOIN v2 ON v1.c0=v2.c0 AND v2.c1 NOT IN (SELECT c1 FROM v1));
--enable_result_log

UPDATE v1 SET c1=c1+1 WHERE v1.c1 NOT IN (SELECT /*+parallel(5) USE_HASH(v2) */ c1 FROM v2 WHERE c1 <>ALL(SELECT c1 FROM v1 WHERE c1 IS NOT NULL));
SELECT * FROM v1 ORDER BY c0,c1;

--disable_result_log
EXPLAIN BASIC UPDATE v1 SET c1=c1+1 WHERE v1.c1 NOT IN (SELECT /*+parallel(5) USE_HASH(v2),READ_CONSISTENCY (weak) */ c1 FROM v2 WHERE c1 <>ALL(SELECT c1 FROM v1 WHERE c1 IS NOT NULL));
--enable_result_log


