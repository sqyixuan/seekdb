EXPLAIN BASIC SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
t1 PARTITION(l1) tp1 RIGHT JOIN t2 PARTITION(l1) tp2 ON tp1.c0=tp2.c0 WHERE tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY 1,2;


SELECT /*+parallel(2) NO_REWRITE*/ tp1.c0,tp1.c1 FROM
(SELECT /*NO_REWRITE*/ tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 NOT IN (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2 WHERE tl2.c1 IS NOT NULL)) tp1 LEFT JOIN
(SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE tl2.c1 <>ALL (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1 WHERE
tl1.c1 IS NOT NULL)) tp2 ON tp1.c0=tp2.c0 WHERE tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY 1,2;

