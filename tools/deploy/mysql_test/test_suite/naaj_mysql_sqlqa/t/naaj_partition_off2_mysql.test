t1 PARTITION(l1) tp1 RIGHT JOIN t2 PARTITION(l1) tp2 ON tp1.c0=tp2.c0
WHERE tp2.c1 <>ALL(SELECT tl1.c1 FROM t1 PARTITION(l2) tl1 WHERE tl1.c1<>ALL(SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) ORDER BY 1,2;

