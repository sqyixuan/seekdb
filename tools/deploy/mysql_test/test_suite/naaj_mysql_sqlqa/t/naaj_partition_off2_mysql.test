--echo #查询某一分区的值


SELECT /*+USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM t1 PARTITION(l1) tp1 LEFT JOIN t2 PARTITION(l1) tp2 ON tp1.c0=tp2.c0 AND tp2.c1 NOT IN(SELECT c1 FROM t1) ORDER BY 1,2;

