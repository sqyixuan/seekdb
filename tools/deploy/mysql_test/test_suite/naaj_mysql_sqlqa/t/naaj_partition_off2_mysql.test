(SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY 1,2;


SELECT /*+parallel(5) USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
(SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
(SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY 1,2;


--echo #使用with...as语法对数据进行分析

WITH
    data1 AS (SELECT /*+parallel(5) USE_HASH(t1,t2)*/ t1.c0,t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2)),
    data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2)*/ t1.c0,t1.c1 FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 <>ALL (SELECT c1 FROM t1))
    SELECT /*NO_REWRITE*/ * FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 AND d1.c1 <>ALL (SELECT c1 FROM data2) ORDER BY 1,2,3,4;


WITH
    data1 AS (SELECT /*+parallel(5) USE_HASH(t1,t2)*/ t1.c0,t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2)),
    data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2)*/ t1.c0,t1.c1 FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 <>ALL (SELECT c1 FROM t1))
    SELECT /*NO_REWRITE*/ * FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 WHERE d1.c1 <>ALL (SELECT c1 FROM data2) ORDER BY 1,2,3,4;

--disable_result_log
EXPLAIN BASIC WITH
    data1 AS (SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ t1.c0,t2.c1 FROM t1,t2 WHERE t1.c0=t2.c0 AND t1.c1 NOT IN (SELECT c1 FROM t2)),
    data2 AS (SELECT /*+parallel(2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ t1.c0,t1.c1 FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 <>ALL (SELECT c1 FROM t1))
    SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ * FROM data1 d1 LEFT JOIN data2 d2 ON d1.c0=d2.c0 WHERE d1.c1 <>ALL (SELECT c1 FROM data2) ORDER BY 1,2,3,4;
--enable_result_log

WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
        (SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
        tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
        tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)),
    data2 AS (SELECT /*+parallel(5) USE_HASH(t1,t2)*/ tp2.c0,tp2.c1 FROM
        (SELECT /*NO_REWRITE*/ tl2.c0,tl2.c1 FROM t1 PARTITION(l1) tl2 WHERE tl2.c1 <>ALL (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
        tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
        tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL))
    SELECT /*+READ_CONSISTENCY (weak)*/ * FROM data1 d1,data2 d2 WHERE d1.c0=d2.c0 AND d1.c1 NOT IN(SELECT c1 FROM data2);


WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
        (SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
        tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
        tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)),
    data2 AS (SELECT /*+parallel(5) USE_HASH(t1,t2)*/ tp2.c0,tp2.c1 FROM
        (SELECT /*NO_REWRITE*/ tl2.c0,tl2.c1 FROM t1 PARTITION(l1) tl2 WHERE tl2.c1 <>ALL (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
        tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
        tp1.c0=tp2.c0 WHERE tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL))
    SELECT * FROM data1 d1,data2 d2 WHERE d1.c0=d2.c0 AND d1.c1 NOT IN(SELECT c1 FROM data2) ORDER BY 1,2,3,4;

EXPLAIN BASIC WITH
    data1 AS (SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
        (SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
        tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
        tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)),
    data2 AS (SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp2.c0,tp2.c1 FROM
        (SELECT /*NO_REWRITE READ_CONSISTENCY (weak)*/ tl2.c0,tl2.c1 FROM t1 PARTITION(l1) tl2 WHERE tl2.c1 <>ALL (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
        tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
        tp1.c0=tp2.c0 WHERE tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL))
    SELECT * FROM data1 d1,data2 d2 WHERE d1.c0=d2.c0 AND d1.c1 NOT IN(SELECT c1 FROM data2) ORDER BY 1,2,3,4;


