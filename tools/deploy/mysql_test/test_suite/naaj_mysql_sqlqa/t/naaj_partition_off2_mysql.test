t1 PARTITION(l1) tp1 RIGHT JOIN t2 PARTITION(l1) tp2 ON tp1.c0=tp2.c0
WHERE tp2.c1 <>ALL(SELECT tl1.c1 FROM t1 PARTITION(l2) tl1 WHERE tl1.c1<>ALL(SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) ORDER BY 1,2;


SELECT /*+USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
(SELECT t1.c0,t1.c1 FROM t1,t2 WHERE t1.c1 <>ALL (SELECT c1 FROM t2 WHERE c0 > 30)) tp1 LEFT JOIN t2 PARTITION(l1) tp2 ON tp1.c0=tp2.c0
WHERE tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) AND tp1.c1 NOT IN(SELECT c1 FROM t2) AND tp1.c1 < 10 ORDER BY 1,2;

EXPLAIN BASIC SELECT /*+USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ tp1.c0,tp1.c1 FROM
(SELECT t1.c0,t1.c1 FROM t1,t2 WHERE t1.c1 <>ALL (SELECT c1 FROM t2 WHERE c0 > 30)) tp1 LEFT JOIN t2 PARTITION(l1) tp2 ON tp1.c0=tp2.c0
WHERE tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) AND tp1.c1 NOT IN(SELECT c1 FROM t2) AND tp1.c1 < 10 ORDER BY 1,2;


SELECT /*+USE_HASH(t1,t2)*/ tp1.c0,tp1.c1 FROM
(SELECT tl1.c0,tl1.c1 FROM t1 PARTITION(l1) tl1 WHERE tl1.c1 <>ALL (SELECT tl2.c1 FROM t2 PARTITION(l2) tl2)) tp1 LEFT JOIN (SELECT tl2.c0,tl2.c1 FROM t2 PARTITION(l1) tl2 WHERE
tl2.c1 NOT IN (SELECT tl1.c1 FROM t1 PARTITION(l2) tl1)) tp2 ON
tp1.c0=tp2.c0 AND tp2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ORDER BY 1,2;

