DROP TRIGGER IF EXISTS tg1;

DELIMITER //;

CREATE TRIGGER tg1 AFTER INSERT ON t2 FOR EACH ROW
BEGIN
DECLARE new_c0 INT;
DECLARE new_c1 VARCHAR(10);
DECLARE done INT DEFAULT false;
DECLARE cur_t1_c0 CURSOR FOR SELECT c0,c1 FROM t1 WHERE c1 NOT IN(SELECT c1 FROM t3 WHERE c1 IS NOT NULL);
DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = true;
OPEN cur_t1_c0;
    do_loop:LOOP
    FETCH cur_t1_c0 INTO new_c0,new_c1;
    IF done THEN
        LEAVE do_loop;
    END IF;
    INSERT INTO t1(c0,c1) VALUES(new_c0,new_c1);
    END LOOP;
CLOSE cur_t1_c0;
END;
//
DELIMITER ;//

INSERT INTO t2 VALUES(7,7);
SELECT * FROM t1 ORDER BY 1,2;
SELECT * FROM t2 ORDER BY 1,2;


--echo #CASE...WHEN...THEN


DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t3;
CREATE TABLE t1(c0 INT,c1 VARCHAR(10));
CREATE TABLE t2(c0 INT,c1 VARCHAR(10));
INSERT INTO t1 VALUES(0,'AB'),(1,'中文'),(2,'# $ :'),(2,'12'),(3,2),(5,''),(6,NULL);
INSERT INTO t2 VALUES(0,'AB'),(2,'GO @ 家'),(4,22),(5,''),(6,12);
SELECT * FROM t1 ORDER BY 1,2;
SELECT * FROM t2 ORDER BY 1,2;

SELECT CASE WHEN c1 NOT IN(SELECT c1 FROM t2) THEN '1'
            WHEN c1 <>ALL(SELECT c1 FROM t2 WHERE c0 IN(SELECT c0 FROM t1)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--disable_result_log
EXPLAIN BASIC SELECT CASE WHEN c1 NOT IN(SELECT c1 FROM t2) THEN '1'
            WHEN c1 <>ALL(SELECT c1 FROM t2 WHERE c0 IN(SELECT c0 FROM t1)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--enable_result_log

SELECT CASE WHEN c1 IN(SELECT c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1)) THEN '1'
            WHEN c1 <>ALL(SELECT c1 FROM t2 WHERE c0 NOT IN(SELECT c0 FROM t1)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--disable_result_log
EXPLAIN BASIC SELECT CASE WHEN c1 IN(SELECT c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1)) THEN '1'
            WHEN c1 <>ALL(SELECT c1 FROM t2 WHERE c0 NOT IN(SELECT c0 FROM t1)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--enable_result_log

SELECT CASE WHEN c1 IN(SELECT /*+USE_HASH(t2,t1) */ c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1)) THEN '1'
            WHEN c1 <>ALL(SELECT /*+USE_MERGE(t2,t1) */ c1 FROM t2 WHERE c0 NOT IN(SELECT c0 FROM t1)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--disable_result_log
EXPLAIN BASIC SELECT CASE WHEN c1 IN(SELECT /*+USE_HASH(t2,t1) READ_CONSISTENCY (weak) */ c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1)) THEN '1'
            WHEN c1 <>ALL(SELECT /*+USE_MERGE(t2,t1) READ_CONSISTENCY (weak) */ c1 FROM t2 WHERE c0 NOT IN(SELECT c0 FROM t1)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--enable_result_log

SELECT CASE WHEN c1 IN(SELECT /*+parallel(2) USE_HASH(t2,t1) */ t1.c1 FROM t1,t2 WHERE t2.c1 <>ALL(SELECT c1 FROM t1)) THEN '1'
            WHEN c1 <>ALL(SELECT /*+parallel(5) USE_HASH(t2,t1) */ t1.c1 FROM t1,t2 WHERE t2.c0 NOT IN(SELECT c0 FROM t1)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--disable_result_log
EXPLAIN BASIC SELECT CASE WHEN c1 IN(SELECT /*+USE_HASH(t2,t1) READ_CONSISTENCY (weak) */ c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1)) THEN '1'
            WHEN c1 <>ALL(SELECT /*+USE_MERGE(t2,t1) READ_CONSISTENCY (weak) */ c1 FROM t2 WHERE c0 NOT IN(SELECT c0 FROM t1)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--enable_result_log

SELECT CASE WHEN c1 NOT IN(SELECT c1 FROM t2 WHERE c1 IS NOT NULL) THEN '1'
            WHEN c1 <>ALL(SELECT c1 FROM t2 WHERE c0 IN(SELECT c0 FROM t1 WHERE c1 IS NOT NULL)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--disable_result_log
EXPLAIN BASIC SELECT CASE WHEN c1 NOT IN(SELECT c1 FROM t2 WHERE c1 IS NOT NULL) THEN '1'
            WHEN c1 <>ALL(SELECT c1 FROM t2 WHERE c0 IN(SELECT c0 FROM t1 WHERE c1 IS NOT NULL)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--enable_result_log

SELECT CASE WHEN c1 IN(SELECT c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)) THEN '1'
            WHEN c1 <>ALL(SELECT c1 FROM t2 WHERE c0 NOT IN(SELECT c0 FROM t1 WHERE c1 IS NOT NULL)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--disable_result_log
EXPLAIN BASIC SELECT CASE WHEN c1 IN(SELECT c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)) THEN '1'
            WHEN c1 <>ALL(SELECT c1 FROM t2 WHERE c0 NOT IN(SELECT c0 FROM t1 WHERE c1 IS NOT NULL)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--enable_result_log

SELECT CASE WHEN c1 IN(SELECT /*+USE_HASH(t2,t1)*/ c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)) THEN '1'
            WHEN c1 <>ALL(SELECT /*+USE_NL(t2,t1) */ c1 FROM t2 WHERE c0 NOT IN(SELECT c0 FROM t1 WHERE c1 IS NOT NULL)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--disable_result_log
EXPLAIN BASIC SELECT CASE WHEN c1 IN(SELECT /*+USE_HASH(t2,t1) READ_CONSISTENCY (weak) */ c1 FROM t2 WHERE c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)) THEN '1'
            WHEN c1 <>ALL(SELECT /*+USE_MERGE(t2,t1) READ_CONSISTENCY (weak) */ c1 FROM t2 WHERE c0 NOT IN(SELECT c0 FROM t1 WHERE c1 IS NOT NULL)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--enable_result_log

SELECT CASE WHEN c1 IN(SELECT /*+parallel(5) USE_HASH(t2,t1) */ t1.c1 FROM t1,t2 WHERE t2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)) THEN '1'
            WHEN c1 <>ALL(SELECT /*+parallel(5) USE_HASH(t2,t1) */ t1.c1 FROM t1,t2 WHERE t2.c0 NOT IN(SELECT c0 FROM t1 WHERE c1 IS NOT NULL)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--disable_result_log
EXPLAIN BASIC SELECT CASE WHEN c1 IN(SELECT /*+parallel(5) USE_HASH(t2,t1) READ_CONSISTENCY (weak) */ t1.c1 FROM t1,t2 WHERE t2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL)) THEN '1'
            WHEN c1 <>ALL(SELECT /*+parallel(5) USE_HASH(t2,t1) READ_CONSISTENCY (weak) */ t1.c1 FROM t1,t2 WHERE t2.c0 NOT IN(SELECT c0 FROM t1 WHERE c1 IS NOT NULL)) THEN '2'
            ELSE '3'
            END AS n
            FROM t1 ORDER BY 1;
--enable_result_log

