INSERT INTO t2 VALUES(0,'AB'),(2,'GUO @ 家'),(4,23),(7,12);
SELECT * FROM t1 ORDER BY 1,2;
SELECT * FROM t2 ORDER BY 1,2;


INSERT INTO t1 SELECT t2.c0,t2.c1 FROM t2 WHERE t2.c0 > 2
ON DUPLICATE KEY
UPDATE t1.c1 = (SELECT t2.c1 FROM t2 WHERE t2.c1  IN (SELECT c1 FROM t1 WHERE c1 NOT IN(SELECT c1 FROM t2 WHERE c0 < 4)));

SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*+READ_CONSISTENCY (weak)*/ t2.c0,t2.c1 FROM t2 WHERE t2.c0 > 2
ON DUPLICATE KEY
UPDATE t1.c1 = (SELECT /*+READ_CONSISTENCY (weak)*/ t2.c1 FROM t2 WHERE t2.c1  IN (SELECT c1 FROM t1 WHERE c1 NOT IN(SELECT c1 FROM t2 WHERE c0 < 4)));
--enable_result_log

