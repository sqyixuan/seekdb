CREATE TABLE t1(c0 INT,c1 CHAR(10));
CREATE TABLE t2(c0 INT,c1 VARCHAR(10) PRIMARY KEY);
INSERT INTO t1 VALUES(0,'AB'),(1,'中文'),(2,'# $ :'),(2,'12'),(4,2),(5,''),(6,NULL);
INSERT INTO t2 VALUES(0,'AB'),(2,'GUO @ 家'),(4,23),(7,12);
SELECT * FROM t1 ORDER BY 1,2;
SELECT * FROM t2 ORDER BY 1,2;


INSERT INTO t1 SELECT * FROM t2
WHERE t2.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 <> ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) AND c0<5)
ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;

SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t2
WHERE t2.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 <> ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) AND c0<5)
ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
--enable_result_log

INSERT INTO t1 SELECT * FROM t2
WHERE t2.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 <> ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) AND c0<5) AND c0<0
ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;

SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t2
WHERE t2.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 <> ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) AND c0<5) AND c0<0
ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
--enable_result_log

DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,c1 CHAR(10));
CREATE TABLE t2(c0 INT,c1 CHAR(10) PRIMARY KEY);
INSERT INTO t1 VALUES(0,'AB'),(1,'中文'),(2,'# $ :'),(2,'12'),(4,2),(5,''),(6,NULL);
INSERT INTO t2 VALUES(0,'AB'),(2,'GUO @ 家'),(4,23),(7,12);
SELECT * FROM t1 ORDER BY 1,2;
SELECT * FROM t2 ORDER BY 1,2;

INSERT INTO t1 SELECT * FROM (SELECT t2.c0,t2.c1 FROM t2 WHERE t2.c0 > 2) AS t3
WHERE t3.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 <> ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) AND c0<5)
ON DUPLICATE KEY
UPDATE t1.c1 = (SELECT t4.c1 FROM (SELECT t2.c0,t2.c1 FROM t2 WHERE t2.c0 > 2) AS t4
WHERE t4.c1 IN (SELECT c1 FROM t2 WHERE c1 NOT IN(SELECT c1 FROM t1 WHERE c0 < 4)));

SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*+READ_CONSISTENCY (weak)*/ * FROM (SELECT t2.c0,t2.c1 FROM t2 WHERE t2.c0 > 2) AS t3
WHERE t3.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 <> ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) AND c0<5)
ON DUPLICATE KEY
UPDATE t1.c1 = (SELECT /*+READ_CONSISTENCY (weak)*/ t4.c1 FROM (SELECT t2.c0,t2.c1 FROM t2 WHERE t2.c0 > 2) AS t4
WHERE t4.c1 IN (SELECT c1 FROM t2 WHERE c1 NOT IN(SELECT c1 FROM t1 WHERE c0 < 4)));
--enable_result_log

INSERT INTO t1 SELECT * FROM (SELECT t2.c0,t2.c1 FROM t2 WHERE t2.c0 > 2) AS t3
WHERE t3.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 <> ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) AND c0<5) AND c0<5
ON DUPLICATE KEY
UPDATE t1.c1 = (SELECT t4.c1 FROM (SELECT t2.c0,t2.c1 FROM t2 WHERE t2.c0 > 2) AS t4
WHERE t4.c1 IN (SELECT c1 FROM t2 WHERE c1 NOT IN(SELECT c1 FROM t1 WHERE c0 < 4)));

SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*+READ_CONSISTENCY (weak)*/ * FROM (SELECT t2.c0,t2.c1 FROM t2 WHERE t2.c0 > 2) AS t3
WHERE t3.c1 NOT IN (SELECT c1 FROM t2 WHERE c1 <> ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) AND c0<5) AND c0<5
ON DUPLICATE KEY
UPDATE t1.c1 = (SELECT /*+READ_CONSISTENCY (weak)*/ t4.c1 FROM (SELECT t2.c0,t2.c1 FROM t2 WHERE t2.c0 > 2) AS t4
WHERE t4.c1 IN (SELECT c1 FROM t2 WHERE c1 NOT IN(SELECT c1 FROM t1 WHERE c0 < 4)));
