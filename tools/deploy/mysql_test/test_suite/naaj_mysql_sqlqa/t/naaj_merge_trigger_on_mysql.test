DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t3;
CREATE TABLE t1(c0 INT,c1 VARCHAR(10));
CREATE TABLE t2(c0 INT,c1 VARCHAR(10));
CREATE TABLE t3(c0 INT,c1 VARCHAR(10));
INSERT INTO t1 VALUES(0,'AB'),(1,'中文'),(2,'# $ :'),(2,'12'),(3,2),(5,''),(6,NULL);
INSERT INTO t2 VALUES(0,'AB'),(2,'GUO @ 家'),(4,23),(5,''),(6,12);
INSERT INTO t3 VALUES(0,'AB'),(2,'GUO @ 家'),(4,23),(5,''),(6,12),(7,NULL);
SELECT * FROM t1 ORDER BY 1,2;
SELECT * FROM t2 ORDER BY 1,2;
SELECT * FROM t3 ORDER BY 1,2;

DROP TRIGGER IF EXISTS tg1;
DROP TRIGGER IF EXISTS tg2;
DROP TRIGGER IF EXISTS tg3;

DELIMITER //;
CREATE TRIGGER tg1 AFTER INSERT ON t2 FOR EACH ROW
BEGIN
    INSERT t1(c0,c1) VALUES((SELECT distinct(c0) FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t3 WHERE c1 IS NOT NULL) AND c0<2),(SELECT distinct(c1) FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t3 WHERE c1 IS NOT NULL) AND c0>2));
    INSERT t1(c0,c1) (SELECT c0,c1 FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t3 WHERE c1 IS NOT NULL));
    INSERT INTO t1 SELECT c0,c1 FROM t3 WHERE c1 NOT IN(SELECT c1 FROM t1 WHERE c1 <>ALL(SELECT c1 FROM t3));
END;
//

CREATE TRIGGER tg2 AFTER UPDATE ON t2 FOR EACH ROW
BEGIN
    DECLARE new_c2 INT;
    DECLARE new_c3 CHAR(10);
	SET new_c2=NEW.c0;
	SET new_c3=NEW.c1;
    UPDATE t1 SET c1= new_c3 WHERE c1 NOT IN (SELECT c1 FROM t3 WHERE c1 IS NOT NULL);
    UPDATE t1 SET c0=new_c2+1 WHERE c1 <>ALL (SELECT /*+parallel(2) USE_HASH(t3) */ c1 FROM t3 WHERE c1 NOT IN(SELECT c1 FROM t1));
END;
//

CREATE TRIGGER tg3 AFTER DELETE ON t2 FOR EACH ROW
BEGIN
    DECLARE old_c4 INT;
    DECLARE old_c5 CHAR(10);
	SET old_c4=OLD.c0;
	SET old_c5=OLD.c1;
    UPDATE t1 SET c0=old_c4+5 WHERE c1 <>ALL (SELECT /* USE_HASH(t3) */ c1 FROM t3 WHERE c1 NOT IN(SELECT c1 FROM t1));
    INSERT INTO t1 SELECT /*+parallel(5) USE_HASH(t3) */ c0,c1 FROM t3 WHERE c1 NOT IN(SELECT c1 FROM t1 WHERE c1 <>ALL(SELECT c1 FROM t3));
    INSERT t1(c0,c1) VALUES((SELECT distinct(c0) FROM t1 WHERE c1 <>ALL (SELECT c1 FROM t3 WHERE c1 IS NOT NULL) AND c0<2),old_c5);
END;
//

DELIMITER ;//

INSERT INTO t2 VALUES(7,7);
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;

UPDATE t2 SET c1='A' WHERE c0=7;
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;

DELETE FROM t2 WHERE c0=7;
SELECT * FROM t1 ORDER BY c0,c1;
SELECT * FROM t2 ORDER BY c0,c1;


