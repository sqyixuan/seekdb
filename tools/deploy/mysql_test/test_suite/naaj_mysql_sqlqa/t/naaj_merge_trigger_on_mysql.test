#owner:peihan.dph
#owner group: 技术部-SQL-SQL2组
#description: 设定_optimizer_null_aware_antijoin=ON时，在trigger/仿merger into语法中对算子使用的测试
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

#--source mysql_test/test_suite/naaj_mysql_sqlqa/include/create_tenant_by_charset_mysql.inc
--source mysql_test/test_suite/naaj_mysql_sqlqa/include/conn_tenant_mysql.inc

--source mysql_test/test_suite/naaj_mysql_sqlqa/include/check_schema_sync.inc
connection conn_charset_test_sys_mysql;
sleep 1;

--enable_result_log

--echo # 环境清理
--disable_warnings
#--error 01396

DROP USER if exists zhang;
--enable_warnings

CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';

--source mysql_test/include/check_schema_sync.inc
connect (zhang,$OBMYSQL_MS0,zhang,zhang,*NO-ONE*,$OBMYSQL_PORT);
connection zhang;
sleep 1;

#创建数据库naaj_test
--disable_warnings
drop database if exists naaj_test;
--enable_warnings
CREATE DATABASE IF NOT EXISTS naaj_test;
USE naaj_test;

--echo ################Setting ''_ optimizer_ null_ aware_ Antijoin 'is ON################
SET _optimizer_null_aware_antijoin=ON;

--disable_warnings

DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;


--echo #MySQL不支持与Oracle一致的meger into语法，但是可以使用 on duplicate key update语法模拟meger into语法。

CREATE TABLE t1(c0 INT,c1 CHAR(10));
CREATE TABLE t2(c0 INT,c1 VARCHAR(10));
INSERT INTO t1 VALUES(0,'AB'),(1,'中文'),(2,'# $ :'),(2,'12'),(4,22),(5,''),(6,NULL);
INSERT INTO t2 VALUES(0,'A'),(4,23),(5,NULL);
SELECT * FROM t1 ORDER BY 1,2;
SELECT * FROM t2 ORDER BY 1,2;
     
INSERT INTO t1 SELECT t2.c0,t2.c1 FROM t2 WHERE t2.c1 NOT IN(SELECT c1 FROM t1) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*+READ_CONSISTENCY (weak)*/ t2.c0,t2.c1 FROM t2 WHERE t2.c1 NOT IN(SELECT c1 FROM t1) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
--enable_result_log
     
INSERT INTO t1 SELECT t2.c0,t2.c1 FROM t2 WHERE NOT EXISTS(SELECT c1 FROM t1) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*+READ_CONSISTENCY (weak)*/ t2.c0,t2.c1 FROM t2 WHERE NOT EXISTS(SELECT c1 FROM t1) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
--enable_result_log
        
INSERT INTO t1 SELECT /*USE_NL(t1,t2)*/ * FROM t2 WHERE t2.c1 NOT IN (SELECT c1 FROM t1) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*USE_NL(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t2 WHERE t2.c1 NOT IN (SELECT c1 FROM t1) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
--enable_result_log

INSERT INTO t1 SELECT /*USE_HASH(t1,t2) */ t2.c0,t2.c1 FROM t1,t2
WHERE t1.c0=t2.c0 AND t2.c1 NOT IN (SELECT c1 FROM t1) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;

SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ t2.c0,t2.c1 FROM t1,t2
WHERE t1.c0=t2.c0 AND t2.c1 NOT IN (SELECT c1 FROM t1) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
--enable_result_log

INSERT INTO t1 SELECT /*USE_HASH(t1,t2) */ t2.c0,t2.c1 FROM t1 LEFT JOIN t2 ON t1.c0=t2.c0
WHERE t2.c1 <>ALL (SELECT c1 FROM t1) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;

SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ t2.c0,t2.c1 FROM t1 LEFT JOIN t2 ON t1.c0=t2.c0
WHERE t2.c1 <>ALL (SELECT c1 FROM t1) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
--enable_result_log

INSERT INTO t1 SELECT /*+parallel(2) USE_HASH(t1,t2) */ * FROM t2 WHERE t2.c1 <>ALL (SELECT c1 FROM t1) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*+parallel(2) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t2 WHERE t2.c1 <>ALL (SELECT c1 FROM t1) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
--enable_result_log

INSERT INTO t1 SELECT t2.c0,t2.c1 FROM t2 WHERE t2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*+READ_CONSISTENCY (weak)*/ t2.c0,t2.c1 FROM t2 WHERE t2.c1 <>ALL(SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
--enable_result_log

INSERT INTO t1 SELECT /*USE_HASH(t1,t2) */ * FROM t2
WHERE t2.c1 NOT IN (SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;

SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t2
WHERE t2.c1 NOT IN (SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
--enable_result_log

INSERT INTO t1 SELECT /*+parallel(5) USE_HASH(t1,t2)*/ * FROM t2
WHERE t2.c1 <>ALL (SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;

SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ * FROM t2
WHERE t2.c1 <>ALL (SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
--enable_result_log

INSERT INTO t1 SELECT /*+parallel(5) USE_HASH(t1,t2) */ t2.c0,t2.c1 FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0
WHERE t2.c1 <>ALL (SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;

SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*+parallel(5) USE_HASH(t1,t2) READ_CONSISTENCY (weak)*/ t2.c0,t2.c1 FROM t1 RIGHT JOIN t2 ON t1.c0=t2.c0
WHERE t2.c1 <>ALL (SELECT c1 FROM t1 WHERE c1 IS NOT NULL) ON DUPLICATE KEY UPDATE t1.c1 = t2.c1;
--enable_result_log

