INSERT INTO t1 VALUES(0,'AB'),(1,'中文'),(2,'# $ :'),(2,'12'),(4,2),(5,''),(6,NULL);
INSERT INTO t2 VALUES(0,'AB'),(2,'GUO @ 家'),(4,23),(7,12);
SELECT * FROM t1 ORDER BY 1,2;
SELECT * FROM t2 ORDER BY 1,2;

INSERT INTO t1 SELECT * FROM t2 WHERE t2.c1 <>ALL (SELECT c1 FROM t1 WHERE c1 IS NOT NULL)
ON DUPLICATE KEY
UPDATE t1.c1 = (SELECT t2.c1 FROM t2 WHERE t2.c1 <>ALL (SELECT c1 FROM t1));

SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t2 WHERE t2.c1 <>ALL (SELECT c1 FROM t1 WHERE c1 IS NOT NULL)
ON DUPLICATE KEY
UPDATE t1.c1 = (SELECT /*+READ_CONSISTENCY (weak)*/ t2.c1 FROM t2 WHERE t2.c1 <>ALL (SELECT c1 FROM t1));
--enable_result_log

INSERT INTO t1 SELECT * FROM t2 WHERE t2.c1 <>ALL (SELECT c1 FROM t1 WHERE c0 IS NOT NULL) AND t2.c0>10
ON DUPLICATE KEY
UPDATE t1.c1 = (SELECT t2.c1 FROM t2 WHERE t2.c1 <>ALL (SELECT c1 FROM t1));

SELECT * FROM t1 ORDER BY 1,2;
--disable_result_log
EXPLAIN BASIC INSERT INTO t1 SELECT /*+READ_CONSISTENCY (weak)*/ * FROM t2 WHERE t2.c1 <>ALL (SELECT c1 FROM t1 WHERE c0 IS NOT NULL) AND t2.c0>10
ON DUPLICATE KEY
UPDATE t1.c1 = (SELECT /*+READ_CONSISTENCY (weak)*/ t2.c1 FROM t2 WHERE t2.c1 <>ALL (SELECT c1 FROM t1));
--enable_result_log

