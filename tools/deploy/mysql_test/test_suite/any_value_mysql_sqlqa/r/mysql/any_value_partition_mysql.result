DROP TABLE tbl_1t;
CREATE TABLE test_1t(id INT NOT NULL,year INT,month INT,m_id INT) PARTITION BY RANGE(year) 
(PARTITION Dec2020 VALUES LESS THAN(2021),  
PARTITION Dec2021 VALUES LESS THAN(2022),
PARTITION Dec2024 VALUES LESS THAN(2025));
INSERT INTO test_1t VALUES(1,2019,2,1);
INSERT INTO test_1t VALUES(2,2020,5,3);
INSERT INTO test_1t VALUES(3,2020,1,2);
INSERT INTO test_1t VALUES(4,2021,2,4);
INSERT INTO test_1t VALUES(5,2021,5,5);
CREATE TABLE test_2t(id INT NOT NULL,m_id INT,p_sum INT) PARTITION BY RANGE(p_sum)
(PARTITION Dec100 VALUES LESS THAN(100),  
PARTITION Dec200 VALUES LESS THAN(200));
