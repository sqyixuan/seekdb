--error 1055 #此SQL在MySQL数据库中执行成功，OB的MySQL模式报错，此处有疑问，暂定为兼容性问题 
CREATE VIEW test_1v AS SELECT name,class FROM test_1t GROUP BY(class);
CREATE VIEW test_1v AS SELECT ANY_VALUE(name),class FROM test_1t GROUP BY(class);
SELECT * FROM test_1v;
DROP VIEW test_1v;


--error 1055 #此SQL在MySQL数据库中执行成功，OB的MySQL模式报错，此处有疑问，暂定为兼容性问题 
CREATE VIEW test_1v AS SELECT name,class FROM test_1t WHERE age >=(SELECT AVG(age) FROM test_1t) GROUP BY(class);
CREATE OR REPLACE VIEW test_1v AS SELECT ANY_VALUE(name),class FROM test_1t WHERE age >(SELECT AVG(age) FROM test_1t) GROUP BY(class);
SELECT * FROM test_1v; 
DROP VIEW test_1v;
--error 1055 #此SQL在MySQL数据库中执行成功，OB的MySQL模式报错，此处有疑问，暂定为兼容性问题 
CREATE OR REPLACE VIEW test_1v AS SELECT name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五');
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
CREATE OR REPLACE VIEW test_1v AS SELECT ANY_VALUE(name),class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五');
SELECT * FROM test_1v; 
DROP VIEW test_1v;
--error 1055 #此SQL在MySQL数据库中执行成功，OB的MySQL模式报错，此处有疑问，暂定为兼容性问题 
CREATE OR REPLACE VIEW test_1v AS SELECT name,class FROM (SELECT name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t1;
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
CREATE OR REPLACE VIEW test_1v AS SELECT name,class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t1;
SELECT * FROM test_1v; 
DROP VIEW test_1v; 
--error 1055 #此SQLMySQL数据执行成功，OB的MySQL模式报错，此处有疑问，暂定为兼容性问题
CREATE OR REPLACE VIEW test_1v AS SELECT name,class FROM test_1t WHERE EXISTS(SELECT name,class FROM test_1t GROUP BY(class));
CREATE OR REPLACE VIEW test_1v AS SELECT name,class FROM test_1t WHERE EXISTS(SELECT ANY_VALUE(name) AS name,class FROM test_1t GROUP BY(class) HAVING class IN('三一'));
SELECT * FROM test_1v; 
DROP VIEW test_1v; 


#any_value-7-2
