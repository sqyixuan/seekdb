set sql_mode = 'ONLY_FULL_GROUP_BY,STRICT_TRANS_TABLES';
SELECT @@SESSION.SQL_MODE;

--disable_query_log
CREATE DATABASE IF NOT EXISTS db_test DEFAULT CHARSET utf8 COLLATE utf8_general_ci;
USE db_test;
--enable_query_log

--echo # 环境清理
--disable_warnings
--error 0,1051
DROP TABLE test_1t CASCADE;
--enable_warnings

CREATE TABLE test_1t(id int primary key,name VARCHAR(20),class VARCHAR(20),age int);
INSERT INTO test_1t VALUES(1,'aa','三一',11),
		            (2,'aa','三一',12),
		            (3,'cc','三二',13),
		            (4,'dd','三二',14),
		            (5,'ee','三三',15),
		            (6,'ff','三三',16),
		            (7,'ee','三四',17);
SELECT * FROM test_1t;
#any_value-1-1
--error 1055
SELECT name,age,class FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(1t.name),1t.class,ANY_VALUE(1t.age) FROM test_1t 1t GROUP BY(1t.class);
SELECT ANY_VALUE(name),ANY_VALUE(class),ANY_VALUE(age) FROM test_1t GROUP BY(class);
#any_value-1-2/3/4
UPDATE test_1t SET age=11 WHERE id=3;
SELECT * FROM test_1t;
--error 1140
SELECT name,MIN(age) FROM test_1t;
SELECT ANY_VALUE(name),MIN(age) FROM test_1t;
--error 1140
SELECT ANY_VALUE(name),class,MIN(age) FROM test_1t;
SELECT ANY_VALUE(name), ANY_VALUE(class),MIN(age) FROM test_1t;

#any_value-1-5
--error 1054
SELECT ANY_VALUEname,class,age FROM test_1t GROUP BY(class);

#any_value-1-6
--error 1582
SELECT ANY_VALUE(name,class),MIN(age) FROM test_1t;
--error 1582
SELECT ANY_VALUE(1t.name,1t.class),MIN(1t.age) FROM test_1t 1t;
--error 1582
SELECT ANY_VALUE('name','age') FROM test_1t GROUP BY(class);
--error 1582
SELECT ANY_VALUE("name","age") FROM test_1t GROUP BY(class);

