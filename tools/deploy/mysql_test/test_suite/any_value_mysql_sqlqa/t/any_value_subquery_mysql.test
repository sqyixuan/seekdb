UPDATE test_2t SET name='a'; 
SELECT * FROM test_2t;
--error 1055
UPDATE test_2t t2,(SELECT name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一')) t1 SET t2.name=t1.name WHERE t1.class=t2.class;
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
UPDATE test_2t t2,(SELECT ANY_VALUE(name) AS name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一')) t1 SET t2.name=t1.name WHERE t1.class=t2.class;

--error 1055 #此SQL在MySQL数据库中执行成功，OB的MySQL模式报错，此处有疑问，暂定为兼容性问题
UPDATE test_2t SET name='B' WHERE class IN(SELECT class FROM test_1t GROUP BY(name));
UPDATE test_2t SET name='B' WHERE class IN(SELECT ANY_VALUE(class) FROM test_1t GROUP BY(name));
SELECT * FROM test_2t;
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
UPDATE test_2t SET name='a' WHERE class IN(SELECT class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t1);
SELECT * FROM test_2t;

