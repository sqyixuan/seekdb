DELETE FROM test_2t;

#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
INSERT INTO test_2t(name,class)SELECT ANY_VALUE(name),class FROM test_1t WHERE EXISTS(SELECT ANY_VALUE(name) AS name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三'));
INSERT INTO test_2t(name,class)SELECT name,class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t1;
SELECT * FROM test_2t;
DELETE FROM test_2t;
