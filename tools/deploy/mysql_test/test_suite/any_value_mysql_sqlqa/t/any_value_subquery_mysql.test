#any_value-6-1
--error 1055
SELECT name,class FROM test_1t WHERE age >=(SELECT AVG(age) FROM test_1t) GROUP BY(class);
SELECT ANY_VALUE(name),class FROM test_1t WHERE age >=(SELECT AVG(age) FROM test_1t) GROUP BY(class);
SELECT ANY_VALUE(name),class FROM test_1t WHERE age IN(SELECT DISTINCT(age) FROM test_1t) GROUP BY(class) ORDER BY ANY_VALUE(name) LIMIT 2;
--error 1055
SELECT name,class FROM test_1t WHERE age IN((SELECT age FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五');
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
SELECT ANY_VALUE(name),class FROM test_1t WHERE age IN((SELECT age FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五');
--error 1055
SELECT name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五');
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
SELECT ANY_VALUE(name),class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五');

--error 1055
SELECT name,class FROM (SELECT name,class FROM test_1t GROUP BY(class)) AS t1;
SELECT name,class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_1t GROUP BY(class)) AS t1;
--error 1055
SELECT name,class FROM (SELECT name,class FROM test_1t WHERE age IN(SELECT DISTINCT(age) FROM test_1t) GROUP BY(class) ORDER BY ANY_VALUE(name) LIMIT 2) AS t1;
SELECT name,class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_1t WHERE age IN(SELECT DISTINCT(age) FROM test_1t) GROUP BY(class) ORDER BY ANY_VALUE(name) LIMIT 2) AS t1;
--error 1055
SELECT name,class FROM (SELECT name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t1;
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
SELECT name,class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t1;

--error 1055 #此SQLMySQL数据执行成功，OB的MySQL模式报错，此处有疑问，暂定为兼容性问题
SELECT name,class FROM test_1t WHERE EXISTS(SELECT name,class FROM test_1t GROUP BY(class));
SELECT name,class FROM test_1t WHERE EXISTS(SELECT ANY_VALUE(name) AS name,class FROM test_1t GROUP BY(class) HAVING class IN('三一'));
--error 1055
SELECT name,class FROM test_1t WHERE EXISTS(SELECT name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三'));
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
SELECT name,class FROM test_1t WHERE EXISTS(SELECT ANY_VALUE(name) AS name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三'));

