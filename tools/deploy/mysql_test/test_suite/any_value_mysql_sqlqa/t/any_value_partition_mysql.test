set sql_mode = 'ONLY_FULL_GROUP_BY,STRICT_TRANS_TABLES';
SELECT @@SESSION.SQL_MODE;

CREATE DATABASE IF NOT EXISTS db_test DEFAULT CHARSET utf8 COLLATE utf8_general_ci;
USE db_test;

--echo # 环境清理
--disable_warnings
--error 1051
DROP TABLE tbl_1t CASCADE;
--error 1051
DROP TABLE test_2t CASCADE;
--error 1051
DROP TABLE test_1t CASCADE;
--enable_warnings

CREATE TABLE tbl_1t(id INT NOT NULL,year INT,month INT) PARTITION BY RANGE(year) 
 (PARTITION Dec2020 VALUES LESS THAN(2021),  
PARTITION Dec2021 VALUES LESS THAN(2022),
PARTITION Dec2024 VALUES LESS THAN(2025));
INSERT INTO tbl_1t VALUES(1,2019,2);
INSERT INTO tbl_1t VALUES(2,2020,5);
INSERT INTO tbl_1t VALUES(3,2020,1);
INSERT INTO tbl_1t VALUES(4,2021,2);
INSERT INTO tbl_1t VALUES(5,2021,5);
INSERT INTO tbl_1t VALUES(6,2022,1);
INSERT INTO tbl_1t VALUES(7,2022,5);
SELECT * FROM tbl_1t;

#any_value-5-3
--error 1055
SELECT DISTINCT(month),year FROM tbl_1t GROUP BY(year);
--error 1064
SELECT ANY_VALUE(DISTINCT(month)),year FROM tbl_1t GROUP BY(year);
SELECT DISTINCT(ANY_VALUE(month)),year FROM tbl_1t GROUP BY(year);
--error 1055
SELECT month,year FROM tbl_1t  GROUP BY(year) HAVING year>2020;
SELECT ANY_VALUE(month),year FROM tbl_1t  GROUP BY(year) HAVING year>2020;
SELECT DISTINCT(ANY_VALUE(month)),year FROM tbl_1t  GROUP BY(year) HAVING year>2020;
--error 1055
SELECT month,year FROM tbl_1t  GROUP BY(year) ORDER BY year ;
SELECT ANY_VALUE(month),year FROM tbl_1t  GROUP BY(year) ORDER BY year ASC;
SELECT ANY_VALUE(month),year FROM tbl_1t  GROUP BY(year) ORDER BY year DESC;
SELECT DISTINCT(ANY_VALUE(month)),year FROM tbl_1t  GROUP BY(year) HAVING year>13 ORDER BY year DESC;
--error 1055
SELECT month,year FROM tbl_1t  GROUP BY(year) LIMIT 2 ;
SELECT ANY_VALUE(month),year FROM tbl_1t  GROUP BY(year) LIMIT 1;
SELECT DISTINCT(ANY_VALUE(month)),year FROM tbl_1t  GROUP BY(year) HAVING year>2020 ORDER BY year DESC LIMIT 1;

--error 1055
SELECT DISTINCT(month),(SELECT ANY_VALUE(year) FROM tbl_1t),id FROM tbl_1t GROUP BY(id);
--error 1242
SELECT DISTINCT(ANY_VALUE(month)),(SELECT ANY_VALUE(year) FROM tbl_1t),id FROM tbl_1t GROUP BY(id);
--error 1064
SELECT DISTINCT(ANY_VALUE(month)),ANY_VALUE(SELECT year FROM tbl_1t),id FROM tbl_1t GROUP BY(id);
--error 1064
SELECT DISTINCT(ANY_VALUE(month)),ANY_VALUE(SELECT ANY_VALUE(year) FROM tbl_1t),id FROM tbl_1t GROUP BY(id);
SELECT DISTINCT(ANY_VALUE(month)),year FROM tbl_1t where year in (SELECT year FROM tbl_1t);
SELECT DISTINCT(month),year FROM tbl_1t where year in (SELECT ANY_VALUE(year) FROM tbl_1t);
SELECT DISTINCT(ANY_VALUE(month)),year FROM tbl_1t where year in (SELECT ANY_VALUE(year) FROM tbl_1t);

--error 1055
SELECT month,year FROM tbl_1t WHERE month in(SELECT month FROM tbl_1t) GROUP BY(year) HAVING year>2020;
--error 1055
SELECT month,year FROM tbl_1t WHERE month in(SELECT ANY_VALUE(month) FROM tbl_1t) GROUP BY(year) HAVING year>2020;
SELECT ANY_VALUE(month),year FROM tbl_1t WHERE month IN(SELECT month FROM tbl_1t) GROUP BY(year) HAVING year>2020;

#此sql查询结果与MySQL数据库不一致（底层的hash join返回的结果顺序不一样导致的）
SELECT ANY_VALUE(month),year FROM tbl_1t WHERE month IN(SELECT ANY_VALUE(month) FROM tbl_1t) GROUP BY(year) HAVING year>2020;
SELECT DISTINCT(ANY_VALUE(month)),year FROM tbl_1t WHERE month IN(SELECT ANY_VALUE(month) FROM tbl_1t) GROUP BY(year) HAVING year>2020;

--error 1064
SELECT ANY_VALUE(SELECT month FROM tbl_1t),year FROM tbl_1t  GROUP BY(year) ORDER BY year ASC;
--error 1242
SELECT (SELECT ANY_VALUE(month) FROM tbl_1t) month,year FROM tbl_1t  GROUP BY(year) ORDER BY year ASC;
--error 1055
SELECT month,year FROM tbl_1t WHERE month IN(SELECT month FROM tbl_1t) GROUP BY(year) ORDER BY year ASC;
SELECT ANY_VALUE(month),year FROM tbl_1t WHERE month IN(SELECT month FROM tbl_1t) GROUP BY(year) ORDER BY year ASC;
SELECT ANY_VALUE(month),year FROM tbl_1t WHERE month IN(SELECT month FROM tbl_1t) GROUP BY(year) ORDER BY year DESC;
--error 1055
SELECT month,year FROM tbl_1t WHERE month IN(SELECT ANY_VALUE(month) FROM tbl_1t) GROUP BY(year) ORDER BY year ASC;
SELECT ANY_VALUE(month),year FROM tbl_1t WHERE month IN(SELECT ANY_VALUE(month) FROM tbl_1t) GROUP BY(year) ORDER BY year ASC;
--error 1055
SELECT month,year FROM tbl_1t WHERE month IN(SELECT ANY_VALUE(month) FROM tbl_1t) GROUP BY(year) ORDER BY year DESC;
SELECT ANY_VALUE(month),year FROM tbl_1t WHERE month IN(SELECT ANY_VALUE(month) FROM tbl_1t) GROUP BY(year) ORDER BY year DESC;

#此sql查询结果与MySQL数据库不一致（底层的hash join返回的结果顺序不一样导致的）
SELECT DISTINCT(ANY_VALUE(month)),year FROM tbl_1t WHERE month IN(SELECT ANY_VALUE(month) FROM tbl_1t) GROUP BY(year) HAVING year>13 ORDER BY year ASC;

--error 1064
SELECT ANY_VALUE(SELECT month FROM tbl_1t),year FROM tbl_1t  GROUP BY(year) LIMIT 2;
--error 1242
SELECT (SELECT ANY_VALUE(month) FROM tbl_1t) month,year FROM tbl_1t  GROUP BY(year) LIMIT 2;
--error 1055
SELECT month,year FROM tbl_1t WHERE month IN(SELECT month FROM tbl_1t) GROUP BY(year) ORDER BY(year) DESC LIMIT 2;
SELECT ANY_VALUE(month),year FROM tbl_1t WHERE month IN(SELECT month FROM tbl_1t) GROUP BY(year) ORDER BY(year) DESC LIMIT 2;
--error 1055
SELECT month,year FROM tbl_1t WHERE month IN(SELECT ANY_VALUE(month) FROM tbl_1t) GROUP BY(year) ORDER BY(year) DESC LIMIT 2;
SELECT ANY_VALUE(month),year FROM tbl_1t WHERE month IN(SELECT ANY_VALUE(month) FROM tbl_1t) GROUP BY(year) ORDER BY(year) DESC LIMIT 2;

#此sql查询结果与MySQL数据库不一致（底层的hash join返回的结果顺序不一样导致的）
SELECT DISTINCT(ANY_VALUE(month)),year FROM tbl_1t WHERE month IN(SELECT ANY_VALUE(month) FROM tbl_1t) GROUP BY(year) HAVING year>13 ORDER BY year DESC LIMIT 2;
DROP TABLE tbl_1t;

CREATE TABLE test_1t(id INT NOT NULL,year INT,month INT,m_id INT) PARTITION BY RANGE(year) 
 (PARTITION Dec2020 VALUES LESS THAN(2021),  
PARTITION Dec2021 VALUES LESS THAN(2022),
PARTITION Dec2024 VALUES LESS THAN(2025));
INSERT INTO test_1t VALUES(1,2019,2,1);
INSERT INTO test_1t VALUES(2,2020,5,3);
INSERT INTO test_1t VALUES(3,2020,1,2);
INSERT INTO test_1t VALUES(4,2021,2,4);
INSERT INTO test_1t VALUES(5,2021,5,5);
CREATE TABLE test_2t(id INT NOT NULL,m_id INT,p_sum INT) PARTITION BY RANGE(p_sum)
(PARTITION Dec100 VALUES LESS THAN(100),  
PARTITION Dec200 VALUES LESS THAN(200));
INSERT INTO test_2t VALUES(1,1,98);
INSERT INTO test_2t VALUES(2,1,99);
INSERT INTO test_2t VALUES(3,2,102);
INSERT INTO test_2t VALUES(4,2,110);
INSERT INTO test_2t VALUES(5,4,170);
INSERT INTO test_2t VALUES(6,5,180);
SELECT * FROM test_1t;
SELECT * FROM test_2t;

