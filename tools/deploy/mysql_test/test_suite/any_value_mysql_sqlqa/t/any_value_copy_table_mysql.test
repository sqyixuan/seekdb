CREATE TABLE test_1t(id int NOT NULL AUTO_INCREMENT,class VARCHAR(20) NOT NULL,PRIMARY KEY(id));
INSERT INTO test_1t VALUES(1,'三一');
INSERT INTO test_1t VALUES(2,'三二');
INSERT INTO test_1t VALUES(3,'三三');
CREATE TABLE test_2t(sid int PRIMARY KEY,name VARCHAR(50),class_id int, index(class_id),CONSTRAINT fk_class_id FOREIGN KEY(class_id) REFERENCES test_1t(id));
INSERT INTO test_2t VALUES(1,'aa',1);
INSERT INTO test_2t VALUES(2,'bb',1);
INSERT INTO test_2t VALUES(3,'dd',2);
INSERT INTO test_2t VALUES(4,'cc',2);
