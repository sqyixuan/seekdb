SHOW CREATE TABLE test_2t;
CREATE TABLE `test_4t` (
  `id` int NOT NULL,
  `classid` int DEFAULT NULL,
  `name` varchar(20) DEFAULT NULL,
  `age` int DEFAULT NULL,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
