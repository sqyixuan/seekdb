#any_value-5-2
SHOW CREATE TABLE test_1t;
CREATE TABLE `test_2t` (
  `id` int NOT NULL,
  `name` varchar(20) DEFAULT NULL,
  `pdate` datetime DEFAULT NULL,
  `class` varchar(20) DEFAULT NULL,
  `age` int DEFAULT NULL,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 ;
INSERT INTO test_2t(id,name,pdate,class,age) SELECT id,name,pdate,class,age FROM test_1t;
SELECT * FROM test_1t;
SELECT * FROM test_2t;

#any_value-5-1-1
--error 1055
SELECT DISTINCT(name),class FROM test_2t GROUP BY(class);
--error 1055
SELECT DISTINCT(name),class,ANY_VALUE(age) FROM test_2t GROUP BY(class);
--error 1064
SELECT ANY_VALUE(DISTINCT(name)),class FROM test_2t GROUP BY(class);
SELECT DISTINCT(ANY_VALUE(name)),class,ANY_VALUE(age) FROM test_2t GROUP BY(class);
--error 1055
SELECT name,age FROM test_2t  GROUP BY(age) HAVING age>13;
SELECT ANY_VALUE(name),age FROM test_2t  GROUP BY(age) HAVING age>13;
SELECT DISTINCT(ANY_VALUE(name)),age FROM test_2t  GROUP BY(age) HAVING age>13;
--error 1055
SELECT name,age FROM test_2t  GROUP BY(age) ORDER BY age ;
SELECT ANY_VALUE(name),age FROM test_2t  GROUP BY(age) ORDER BY age ASC;
SELECT ANY_VALUE(name),age FROM test_2t  GROUP BY(age) ORDER BY age DESC;
SELECT DISTINCT(ANY_VALUE(name)),age FROM test_2t  GROUP BY(age) HAVING age>13 ORDER BY age DESC;
--error 1055
SELECT name,class FROM test_2t  GROUP BY(class) LIMIT 2 ;
SELECT ANY_VALUE(name),class FROM test_2t  GROUP BY(class) LIMIT 1;
SELECT DISTINCT(ANY_VALUE(name)),age FROM test_2t  GROUP BY(age) HAVING age>13 ORDER BY age DESC LIMIT 2;

--error 1055
SELECT DISTINCT(name),class,(SELECT ANY_VALUE(age) FROM test_2t) FROM test_2t GROUP BY(class);
