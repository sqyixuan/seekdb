SHOW CREATE TABLE test_1t;
 CREATE TABLE `test_3t` (
  `id` int NOT NULL AUTO_INCREMENT,
  `class` varchar(20) NOT NULL,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=4 DEFAULT CHARSET=utf8;
INSERT INTO test_3t(id,class) SELECT id,class FROM test_1t;

SHOW CREATE TABLE test_2t;
CREATE TABLE `test_4t` (
  `sid` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `class_id` int(11) DEFAULT NULL,
  PRIMARY KEY (`sid`),
  KEY `class_id` (`class_id`),
  CONSTRAINT `fk_class1_id` FOREIGN KEY (`class_id`) REFERENCES `test_1t` (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
INSERT INTO test_4t(sid,name,class_id) SELECT sid,name,class_id FROM test_2t;
