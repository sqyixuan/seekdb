CREATE TABLE `test_3t` (
  `id` int NOT NULL,
  `classid` int DEFAULT NULL,
  `class` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
