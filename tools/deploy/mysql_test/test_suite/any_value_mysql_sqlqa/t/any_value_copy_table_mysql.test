INSERT INTO test_1t VALUES(5,'ee','2021-07-27 14:59:31','三三',15);
INSERT INTO test_1t VALUES(6,'ee','2021-07-17 14:59:31','三三',16); 
INSERT INTO test_1t VALUES(7,'ee','2021-07-07 14:59:31','三三',14);
