# owner: zongmei.zzm
# owner group: SQL_Test_Exec.
# description: ANY_VALUE()
# author: wb-zc01081081

set sql_mode = 'ONLY_FULL_GROUP_BY,STRICT_TRANS_TABLES';
SELECT @@SESSION.SQL_MODE;

CREATE DATABASE IF NOT EXISTS db_test DEFAULT CHARSET utf8 COLLATE utf8_general_ci;
USE db_test;

--echo # 环境清理
--disable_warnings
--error 1051
DROP TABLE test_2t CASCADE;
--error 1051
DROP TABLE test_1t CASCADE;
--enable_warnings

CREATE TABLE test_1t(id int primary key,name VARCHAR(20),class VARCHAR(20),age int);
INSERT INTO test_1t VALUES(1,'aa','三一',13),
		            (2,'aa','三一',12),
		            (3,'cc','三二',14),
		            (4,'cc','三二',14),
		            (5,'ee','三三',15),
		            (6,'ff','三三',16),
		            (7,'ee','三四',13);
SELECT * FROM test_1t;

#any_value-2-1
#any_value-2-1-1
SELECT ANY_VALUE(name+'b'),class,ANY_VALUE(age+1) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name-'b'),class,ANY_VALUE(age-1) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name*'b'),class,ANY_VALUE(age*2) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age/2) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name/'b'),class,ANY_VALUE(age/2) FROM test_1t GROUP BY(class);

#any_value-2-1-2
UPDATE test_1t SET name='ee',age=15 WHERE id=6;
SELECT * FROM test_1t;
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE name='ee' AND age<18 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE name='ee' OR name='aa' GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE name NOT IN('ee')  GROUP BY(class);
SELECT ANY_VALUE(name AND age),class FROM test_1t WHERE name NOT IN('ee')  GROUP BY(class);
SELECT ANY_VALUE(name OR age),class FROM test_1t WHERE name NOT IN('ee')  GROUP BY(class);
--error 1064
SELECT ANY_VALUE(name NOT age),class FROM test_1t WHERE name NOT IN('ee')  GROUP BY(class);

#any_value-2-1-3
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE name='ee' GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age=15) FROM test_1t WHERE name='ee' GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE id>=2 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age>=13) FROM test_1t WHERE id>=2 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE id<=5 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age>=15) FROM test_1t WHERE id<=5 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE id<5 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age>15) FROM test_1t WHERE id<5 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE id<>2 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age<>14) FROM test_1t WHERE id<>2 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE name!='ee' GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age!=14) FROM test_1t WHERE name!='ee' GROUP BY(class);

#any_value-2-1-4
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE id<4||id>6 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age>15||age<14) FROM test_1t WHERE id<4||id>6 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE id = ANY(SELECT id FROM test_1t WHERE name='ee') GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age > ANY(SELECT age FROM test_1t WHERE id=1)) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE id = SOME(SELECT id FROM test_1t WHERE name='ee') GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age > SOME(SELECT age FROM test_1t WHERE id=1)) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE id > ALL(SELECT id FROM test_1t WHERE name='aa') GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age > ALL(SELECT age FROM test_1t WHERE id=1)) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE name LIKE '%e' GROUP BY(class);
SELECT ANY_VALUE(name LIKE '%e'),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE age REGEXP '3|5' GROUP BY(class);
SELECT ANY_VALUE(name REGEXP 'a|c'),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);

CREATE TABLE test_2t(id int primary key,name VARCHAR(20),class VARCHAR(20));
INSERT INTO test_2t VALUES(1,'a','三一'),
		            (2,'a','三一'),
		            (3,'cc',NULL),
		            (4,'ee',NULL),
		            (5,'ee',NULL),
		            (6,'ff','三三'),
		            (7,'ee',NULL);
SELECT * FROM test_2t;
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t WHERE EXISTS(SELECT name FROM test_2t WHERE name=test_1t.name) GROUP BY(class);
SELECT ANY_VALUE(EXISTS(SELECT name FROM test_2t WHERE name=test_1t.name) ),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
UPDATE test_2t SET class=NULL WHERE id IN(3,4,5,7);
SELECT * FROM test_2t;
SELECT ANY_VALUE(name),class FROM test_2t WHERE class IS NULL GROUP BY(class);
SELECT ANY_VALUE(name),ANY_VALUE(ISNULL(class)) FROM test_2t GROUP BY(class);
SELECT ANY_VALUE(name),class FROM test_2t WHERE class IS NOT NULL GROUP BY(class);
SELECT ANY_VALUE(name),ANY_VALUE(class IS NOT NULL) FROM test_2t GROUP BY(class);
#is nan/infinte 为PHP用法，在此不做测试
SELECT ANY_VALUE(name),class FROM test_2t WHERE id IN(1,2,4,5,7) GROUP BY(class);
SELECT ANY_VALUE(name IN('a')),class FROM test_2t GROUP BY(class);
SELECT ANY_VALUE(name),class FROM test_2t WHERE id NOT IN(3,6) GROUP BY(class);
SELECT ANY_VALUE(name NOT IN('a')),class FROM test_2t GROUP BY(class);
SELECT ANY_VALUE(name),class FROM test_1t WHERE id BETWEEN 1 AND 6 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age BETWEEN 12 AND 14) FROM test_1t GROUP BY(class);

#any_value-2-2
#any_value-2-2-1
SELECT ANY_VALUE(name)+'n',class,ANY_VALUE(age)+1 FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name)-'n',class,ANY_VALUE(age)-1 FROM test_1t GROUP BY(class);
--error 1054
SELECT ANY_VALUE(name)*n,class,ANY_VALUE(age)*2 FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age)*2 FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name)/'b',class,ANY_VALUE(age)/2 FROM test_1t GROUP BY(class);

#any_value-2-2-2
SELECT * FROM test_1t;
--error 1055
SELECT ANY_VALUE(name) AND age,class FROM test_1t WHERE name NOT IN('ee')  GROUP BY(class);
--error 1055
SELECT ANY_VALUE(name) OR age,class FROM test_1t WHERE name NOT IN('ee')  GROUP BY(class);
--error 1064
SELECT ANY_VALUE(name) NOT age,class FROM test_1t WHERE name NOT IN('ee')  GROUP BY(class);

#any_value-2-2-3
SELECT ANY_VALUE(name),class,ANY_VALUE(age)=15 FROM test_1t WHERE name='ee' GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age)>=13 FROM test_1t WHERE id>=2 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age)>=15 FROM test_1t WHERE id<=5 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age)>15 FROM test_1t WHERE id<5 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age)<>14 FROM test_1t WHERE id<>2 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age)!=14 FROM test_1t WHERE name!='ee' GROUP BY(class);

#any_value-2-2-4
SELECT ANY_VALUE(name),class,ANY_VALUE(age)>15||ANY_VALUE(age)<14 FROM test_1t WHERE id<4||id>6 GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) > ANY(SELECT age FROM test_1t WHERE id=1) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) > SOME(SELECT age FROM test_1t WHERE id=1) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) > ALL(SELECT age FROM test_1t WHERE id=1) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name) LIKE '%e',class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name) REGEXP 'a|c',class,ANY_VALUE(age) FROM test_1t GROUP BY(class);

UPDATE test_2t SET class='三二' WHERE id IN(3,4);
UPDATE test_2t SET class='三三' WHERE id=5;
UPDATE test_2t SET class='三四' WHERE id=7;
SELECT * FROM test_2t;
--error 1064
SELECT ANY_VALUE(name) EXISTS(SELECT name FROM test_2t WHERE name=test_1t.name) ,class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
UPDATE test_2t SET class=NULL WHERE id IN(3,4,5,7);
SELECT * FROM test_2t;
--error 1064
SELECT ANY_VALUE(name),ANY_VALUE(class) IS NULL(class) FROM test_2t GROUP BY(class);
--error 1064
SELECT ANY_VALUE(name),IS NULL(ANY_VALUE(class)) FROM test_2t GROUP BY(class);
SELECT ANY_VALUE(name),ANY_VALUE(class) IS NULL FROM test_2t GROUP BY(class);
SELECT ANY_VALUE(name),ANY_VALUE(class) IS NOT NULL FROM test_2t GROUP BY(class);
--error 1064
SELECT ANY_VALUE(name),IS NOT NULL(ANY_VALUE(class) ) FROM test_2t GROUP BY(class);
--error 1064
SELECT ANY_VALUE(name),ANY_VALUE(class) IS NOT NULL(class) FROM test_2t GROUP BY(class);
#is nan/infinte 为PHP用法，在此不做测试
SELECT ANY_VALUE(name) IN('a'),class FROM test_2t GROUP BY(class);
SELECT ANY_VALUE(name) NOT IN('a'),class FROM test_2t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) BETWEEN 12 AND 14 FROM test_1t GROUP BY(class);

DROP TABLE test_2t;
DROP TABLE test_1t;
DROP DATABASE db_test;
