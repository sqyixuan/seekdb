# owner: zongmei.zzm
# owner group: SQL_Test_Exec.
# description: ANY_VALUE()
# author: wb-zc01081081

set sql_mode = 'ONLY_FULL_GROUP_BY,STRICT_TRANS_TABLES';
SELECT @@SESSION.SQL_MODE;

CREATE DATABASE IF NOT EXISTS db_test DEFAULT CHARSET utf8 COLLATE utf8_general_ci;
USE db_test;
--echo # 环境清理
--disable_warnings
--error 1051
DROP TABLE test_1t CASCADE;
--enable_warnings

CREATE TABLE test_1t(c1 set('Alice','Bob','Charlie','David'), c2 int);
INSERT INTO test_1t VALUES('Alice', 1);
INSERT INTO test_1t VALUES('Bob', 1);
SELECT ANY_VALUE(c1) FROM test_1t GROUP BY(c2);
DROP TABLE test_1t;

#any_value-3-1
CREATE TABLE test_1t(id int primary key,name VARCHAR(20),class VARCHAR(20),age int);
INSERT INTO test_1t VALUES(1,'','三一',13), (2,'','三一',12),(3,'','三二',14), (4,'','三二',14);
SELECT * FROM test_1t;
--error 1055
SELECT name,class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
DROP TABLE test_1t;

#any_value-3-2
CREATE TABLE test_1t(id int primary key,name VARCHAR(20),pdate DATE,age int);
INSERT INTO test_1t VALUES(1,'aa','1999-2-1',13),(2,'aa','1999-8-1',12),(3,'cc','1995-9-1',14),(4,'cc','1995-4-1',15), (5,'ee','1997-10-1',15),(6,'ff','1998-2-1',16),(7,'ee','1997-3-1',13);
SELECT * FROM test_1t;
--error 1055
SELECT name,pdate,ANY_VALUE(age) FROM test_1t GROUP BY(name);
SELECT name,ANY_VALUE(pdate),ANY_VALUE(age) FROM test_1t GROUP BY(name);
DROP TABLE test_1t;

CREATE TABLE test_1t(id int primary key,name VARCHAR(20),pdate TIMESTAMP DEFAULT CURRENT_TIMESTAMP,age int);
INSERT INTO test_1t VALUES(1,'aa',now(),13);
SELECT SLEEP(1);
INSERT INTO test_1t VALUES(2,'aa',now(),12);
SELECT SLEEP(1);
INSERT INTO test_1t VALUES(3,'cc',now(),14);
SELECT SLEEP(1);
INSERT INTO test_1t VALUES(4,'cc',now(),15);
SELECT SLEEP(1);
INSERT INTO test_1t VALUES(5,'ee',now(),15);
SELECT SLEEP(1);
INSERT INTO test_1t VALUES(6,'ff',now(),16); 
SELECT SLEEP(1);
INSERT INTO test_1t VALUES(7,'ee',now(),13);

--disable_result_log
SELECT * FROM test_1t;
--error 1055
SELECT name,pdate,ANY_VALUE(age) FROM test_1t GROUP BY(name);
SELECT name,ANY_VALUE(pdate),ANY_VALUE(age) FROM test_1t GROUP BY(name);
--enable_result_log

DROP TABLE test_1t;
CREATE TABLE test_1t(id int primary key,name VARCHAR(20),pdate DATETIME,age int);
INSERT INTO test_1t VALUES(1,'aa',now(),13);
SELECT SLEEP(1);
INSERT INTO test_1t VALUES(2,'aa',now(),12);
SELECT SLEEP(1);
INSERT INTO test_1t VALUES(3,'cc',now(),14);
SELECT SLEEP(1);
INSERT INTO test_1t VALUES(4,'cc',now(),15);
SELECT SLEEP(1);
INSERT INTO test_1t VALUES(5,'ee',now(),15);
SELECT SLEEP(1);
INSERT INTO test_1t VALUES(6,'ff',now(),16); 
SELECT SLEEP(1);
INSERT INTO test_1t VALUES(7,'ee',now(),13);
--disable_result_log
SELECT * FROM test_1t;
--error 1055
SELECT name,pdate,ANY_VALUE(age) FROM test_1t GROUP BY(name);
SELECT name,ANY_VALUE(pdate),ANY_VALUE(age) FROM test_1t GROUP BY(name);
--enable_result_log
DROP TABLE test_1t;

#any_value-3-3
CREATE TABLE test_1t(id int primary key,name VARCHAR(20),class VARCHAR(20),age int);
INSERT INTO test_1t VALUES(1,'Aa','三一',13), (2,'aA','三一',12),(3,'BB','三二',14), (4,'bb','三二',12),
(5,'张三','三三',13), (6,'张三','三三',12),(7,'张sir','三四',15), (8,'张sir','三四',14);
SELECT * FROM test_1t;
--error 1055
SELECT name,class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
UPDATE test_1t SET name='!!' where id=1;
UPDATE test_1t SET name='@' where id=2;
UPDATE test_1t SET name='#' where id=3;
UPDATE test_1t SET name='$' where id=4;
UPDATE test_1t SET name='%' where id=5;
UPDATE test_1t SET name='……' where id=6;
UPDATE test_1t SET name='&' where id=7;
UPDATE test_1t SET name='*' where id=8;
SELECT * FROM test_1t;
--error 1055
SELECT name,class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
UPDATE test_1t SET name='(' where id=1;
UPDATE test_1t SET name=')' where id=2;
UPDATE test_1t SET name='_' where id=3;
UPDATE test_1t SET name='-' where id=4;
UPDATE test_1t SET name='=' where id=5;
UPDATE test_1t SET name='+' where id=6;
UPDATE test_1t SET name='\\' where id=7;
UPDATE test_1t SET name='||' where id=8;
SELECT * FROM test_1t;
--error 1055
SELECT name,class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
UPDATE test_1t SET name='[' where id=1;
UPDATE test_1t SET name=']' where id=2;
UPDATE test_1t SET name='{' where id=3;
UPDATE test_1t SET name='}' where id=4;
UPDATE test_1t SET name=';' where id=5;
UPDATE test_1t SET name=',' where id=6;
UPDATE test_1t SET name=':' where id=7;
UPDATE test_1t SET name='"' where id=8;
--error 1055
SELECT name,class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
DROP TABLE test_1t;

CREATE TABLE test_1t(id int primary key,name VARCHAR(20),age decimal(5,2));
INSERT INTO test_1t VALUES(1,'aa',13.71), (2,'aa',12.56),(3,'bb',13.78), (4,'bb',12.73);
SELECT * FROM test_1t;
--error 1055
SELECT name,age FROM test_1t GROUP BY(name);
SELECT name,ANY_VALUE(age) FROM test_1t GROUP BY(name);

DROP TABLE test_1t;
DROP DATABASE db_test;
