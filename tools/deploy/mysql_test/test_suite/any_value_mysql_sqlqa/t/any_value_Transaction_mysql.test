CREATE TABLE test_2t(id int,name VARCHAR(20),pdate DATETIME,class VARCHAR(20),age int);
INSERT INTO test_2t VALUES(1,'aa','2021-07-27 14:59:31','三一',14);
INSERT INTO test_2t VALUES(2,'aa','2021-07-28 14:59:31','三一',17);
INSERT INTO test_2t VALUES(3,'cc','2021-07-29 14:59:31','三二',13);
INSERT INTO test_2t VALUES(4,'cc','2021-07-27 14:59:31','三二',15);
INSERT INTO test_2t VALUES(5,'ee','2021-07-27 14:59:31','三三',12);
INSERT INTO test_2t VALUES(6,'ee','2021-07-17 14:59:31','三三',16); 
INSERT INTO test_2t VALUES(7,'ee','2021-07-07 14:59:31','三三',11);
SELECT * FROM test_2t;

SET AUTOCOMMIT=0;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

#事务中进行INSERT带子查询操作
BEGIN;
INSERT INTO test_1t(name,class)SELECT ANY_VALUE(name),class FROM test_2t GROUP BY(class);
INSERT INTO test_2t(name,class)SELECT ANY_VALUE(name),class FROM test_1t GROUP BY(class);
SELECT * FROM test_1t;
SELECT * FROM test_2t;
ROLLBACK;
BEGIN;
--error 1055
INSERT INTO test_1t(name,class)SELECT name,class FROM test_2t GROUP BY(class);
--error 1055
INSERT INTO test_2t(name,class)SELECT name,class FROM test_1t GROUP BY(class);
SELECT * FROM test_1t;
SELECT * FROM test_2t;
BEGIN;
--error 1055
INSERT INTO test_1t(name,class)SELECT name,class FROM test_2t GROUP BY(class);
--error 1055
INSERT INTO test_2t(name,class)SELECT name,class FROM test_1t GROUP BY(class);
COMMIT;
SELECT * FROM test_1t;
SELECT * FROM test_2t;
BEGIN;
INSERT INTO test_1t(name,class)SELECT ANY_VALUE(name),class FROM test_2t GROUP BY(class);
--error 1055
INSERT INTO test_2t(name,class)SELECT name,class FROM test_1t GROUP BY(class);
SELECT * FROM test_1t;
SELECT * FROM test_2t;
ROLLBACK;
BEGIN;
INSERT INTO test_1t(name,class)SELECT ANY_VALUE(name),class FROM test_2t GROUP BY(class);
--error 1055
INSERT INTO test_2t(name,class)SELECT name,class FROM test_1t GROUP BY(class);
COMMIT;
SELECT * FROM test_1t;
SELECT * FROM test_2t;
DELETE FROM test_1t WHERE id IS NULL;
SELECT * FROM test_1t;

BEGIN;
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
INSERT INTO test_1t(name,class)SELECT ANY_VALUE(name),class FROM test_2t WHERE EXISTS(SELECT ANY_VALUE(name) AS name,class FROM test_2t WHERE age IN((SELECT ANY_VALUE(age) FROM test_2t WHERE age<15) UNION (SELECT age FROM test_2t WHERE age>15)) GROUP BY(class) HAVING class IN('三一'));
INSERT INTO test_2t(name,class)SELECT ANY_VALUE(name),class FROM test_1t WHERE EXISTS(SELECT ANY_VALUE(name) AS name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一'));
SELECT * FROM test_1t;
SELECT * FROM test_2t;
ROLLBACK;
BEGIN;
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
INSERT INTO test_1t(name,class)SELECT name,class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_2t WHERE age IN((SELECT ANY_VALUE(age) FROM test_2t WHERE age<15) UNION (SELECT age FROM test_2t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t2;
INSERT INTO test_2t(name,class)SELECT name,class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t1;
SELECT * FROM test_1t;
SELECT * FROM test_2t;
ROLLBACK;
BEGIN;
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
INSERT INTO test_1t(name,class)SELECT name,class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_2t WHERE age IN((SELECT ANY_VALUE(age) FROM test_2t WHERE age<15) UNION (SELECT age FROM test_2t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t2;
--error 1055
INSERT INTO test_2t(name,class)SELECT name,class FROM (SELECT name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t1;
SELECT * FROM test_1t;
SELECT * FROM test_2t;
ROLLBACK;
BEGIN;
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
INSERT INTO test_1t(name,class)SELECT name,class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_2t WHERE age IN((SELECT ANY_VALUE(age) FROM test_2t WHERE age<15) UNION (SELECT age FROM test_2t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t2;
INSERT INTO test_2t(name,class)SELECT  ANY_VALUE(name),class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t1;
SELECT * FROM test_1t;
SELECT * FROM test_2t;
ROLLBACK;

#事务中进行UPDATE/INSERT带子查询操作
UPDATE test_2t SET name='a'; 
BEGIN;
INSERT INTO test_1t(name,class)SELECT ANY_VALUE(name),class FROM test_2t GROUP BY(class);
--error 1055
UPDATE test_2t t2,(SELECT name,class FROM test_1t GROUP BY(class)) t1 SET t2.name=t1.name WHERE t1.class=t2.class;
SELECT * FROM test_1t;
SELECT * FROM test_2t;
ROLLBACK;
BEGIN;
INSERT INTO test_1t(name,class)SELECT ANY_VALUE(name),class FROM test_2t GROUP BY(class);
UPDATE test_2t t2,(SELECT ANY_VALUE(name) AS name,class FROM test_1t GROUP BY(class)) t1 SET t2.name=t1.name WHERE t1.class=t2.class;
SELECT * FROM test_1t;
SELECT * FROM test_2t;
ROLLBACK;

BEGIN;
UPDATE test_1t t1,(SELECT ANY_VALUE(name) AS name,class FROM test_2t GROUP BY(class)) t2 SET t1.name=t2.name WHERE t1.class=t2.class;
--error 1055
UPDATE test_2t t2,(SELECT name,class FROM test_1t GROUP BY(class)) t1 SET t2.name=t1.name WHERE t1.class=t2.class;
SELECT * FROM test_1t;
SELECT * FROM test_2t;
ROLLBACK;
UPDATE test_2t SET name='A'; 
BEGIN;
UPDATE test_1t t1,(SELECT ANY_VALUE(name) AS name,class FROM test_2t GROUP BY(class)) t2 SET t1.name=t2.name WHERE t1.class=t2.class;
UPDATE test_2t SET name='B'; 
SELECT * FROM test_2t;
UPDATE test_2t t2,(SELECT ANY_VALUE(name) AS name,class FROM test_1t GROUP BY(class)) t1 SET t2.name=t1.name WHERE t1.class=t2.class;
SELECT * FROM test_1t;
SELECT * FROM test_2t;
ROLLBACK;

BEGIN;
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
UPDATE test_1t SET name='a' WHERE class IN(SELECT class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_2t WHERE age IN((SELECT ANY_VALUE(age) FROM test_2t WHERE age<15) UNION (SELECT age FROM test_2t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t2);
UPDATE test_2t SET name='b' WHERE class IN(SELECT class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t1);
SELECT * FROM test_1t;
SELECT * FROM test_2t;
ROLLBACK;

#事务中进行DELETE带子查询操作
UPDATE test_2t SET class='三六' WHERE id=7;
SELECT * FROM test_2t;
BEGIN;
DELETE FROM test_2t  WHERE class IN(SELECT ANY_VALUE(class) FROM test_1t GROUP BY(name));
--error 1055 #此SQL在MySQL数据库中执行成功，OB的MySQL模式报错，此处有疑问，暂定为兼容性问题 
DELETE FROM test_1t  WHERE class IN(SELECT class FROM test_2t GROUP BY(name));
SELECT * FROM test_1t;
SELECT * FROM test_2t;
ROLLBACK;


BEGIN;
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
DELETE FROM test_2t WHERE class IN(SELECT class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t1);
SELECT * FROM test_2t;
ROLLBACK;

BEGIN;
#MySQL 5.7版本报错，OB的MySQL模式和8.0版本成功
DELETE FROM test_2t WHERE class IN(SELECT class FROM (SELECT ANY_VALUE(name) AS name,class FROM test_1t WHERE age IN((SELECT ANY_VALUE(age) FROM test_1t WHERE age<15) UNION (SELECT age FROM test_1t WHERE age>15)) GROUP BY(class) HAVING class IN('三一','三三','三五')) AS t1);
SELECT * FROM test_2t;
COMMIT;
SELECT * FROM test_2t;
ROLLBACK;
SELECT * FROM test_2t;
DROP TABLE test_2t;
DROP TABLE test_1t;

#any_value-9 meger语法
CREATE TABLE test_1t(id int PRIMARY KEY,name VARCHAR(20),pdate DATETIME,class VARCHAR(20),age int);
INSERT INTO test_1t VALUES(1,'aa','2021-07-27 14:59:31','三一',11);
INSERT INTO test_1t VALUES(2,'aa','2021-07-28 14:59:31','三一',16);
INSERT INTO test_1t VALUES(3,'cc','2021-07-29 14:59:31','三二',13);
INSERT INTO test_1t VALUES(4,'cc','2021-07-27 14:59:31','三二',15);
INSERT INTO test_1t VALUES(5,'ee','2021-07-27 14:59:31','三三',12);
INSERT INTO test_1t VALUES(7,'gg','2021-07-07 14:59:31','三五',17);
SELECT * FROM test_1t;
CREATE TABLE test_2t(id int PRIMARY KEY,name VARCHAR(20),pdate DATETIME,class VARCHAR(20),age int);
INSERT INTO test_2t VALUES(1,'aa','2021-08-27 14:59:31','一',114);
INSERT INTO test_2t VALUES(2,'rr','2021-08-28 14:59:31','三',117);
INSERT INTO test_2t VALUES(3,'gg','2021-08-29 14:59:31','二',113);
INSERT INTO test_2t VALUES(4,'hh','2021-08-27 14:59:31','三',115);
INSERT INTO test_2t VALUES(6,'mm','2021-08-17 14:59:31','四',116); 
SELECT * FROM test_2t;
--error 1055
INSERT INTO test_1t(id,name,class) SELECT id,name,class FROM test_2t group by(class) ON DUPLICATE KEY UPDATE name=values(name);
INSERT INTO test_1t(id,name,class) SELECT ANY_VALUE(id),ANY_VALUE(name),class FROM test_2t group by(class) ON DUPLICATE KEY UPDATE name=values(name);
SELECT * FROM test_1t;
SELECT * FROM test_2t;

DELETE FROM test_1t;
DELETE FROM test_2t;
INSERT INTO test_1t VALUES(1,'aa','2021-07-27 14:59:31','三一',11);
INSERT INTO test_1t VALUES(2,'aa','2021-07-28 14:59:31','三一',16);
INSERT INTO test_1t VALUES(3,'cc','2021-07-29 14:59:31','三二',13);
INSERT INTO test_1t VALUES(4,'cc','2021-07-27 14:59:31','三二',15);
INSERT INTO test_1t VALUES(5,'ee','2021-07-27 14:59:31','三三',12);
INSERT INTO test_1t VALUES(7,'gg','2021-07-07 14:59:31','三五',17);
SELECT * FROM test_1t;
INSERT INTO test_2t VALUES(1,'aa','2021-08-27 14:59:31','一',114);
INSERT INTO test_2t VALUES(2,'rr','2021-08-28 14:59:31','三',117);
INSERT INTO test_2t VALUES(3,'gg','2021-08-29 14:59:31','二',113);
INSERT INTO test_2t VALUES(4,'hh','2021-08-27 14:59:31','三',115);
INSERT INTO test_2t VALUES(6,'mm','2021-08-17 14:59:31','四',116); 
SELECT * FROM test_2t;
--error 1055 #此SQL在MySQL数据库中执行成功，OB的MySQL模式报错，此处有疑问，暂定为兼容性问题 
INSERT INTO test_1t(id,name,class) SELECT ANY_VALUE(id),ANY_VALUE(name),class FROM test_2t WHERE age IN(SELECT age FROM test_2t GROUP BY (class)) group by(class) ON DUPLICATE KEY UPDATE name=values(name);
INSERT INTO test_1t(id,name,class) SELECT ANY_VALUE(id),ANY_VALUE(name),class FROM test_2t WHERE age IN(SELECT ANY_VALUE(age) FROM test_2t GROUP BY (class)) group by(class) ON DUPLICATE KEY UPDATE name=values(name);

DROP TABLE test_2t;
DROP TABLE test_1t;
DROP DATABASE db_test;

SET AUTOCOMMIT=1;
set ob_trx_timeout = 10;
set ob_query_timeout = 10;
