# owner group: SQL_Test_Exec.
# description: ANY_VALUE()
# author: wb-zc01081081

set sql_mode = 'ONLY_FULL_GROUP_BY,STRICT_TRANS_TABLES';
SELECT @@SESSION.SQL_MODE;

CREATE DATABASE IF NOT EXISTS db_test DEFAULT CHARSET utf8 COLLATE utf8_general_ci;
USE db_test;

--echo # 环境清理
--disable_warnings
--error 1051
DROP TABLE test_1t CASCADE;
--enable_warnings

CREATE TABLE test_1t(id int primary key,name VARCHAR(20),pdate DATETIME,class VARCHAR(20),age int);
INSERT INTO test_1t VALUES(1,'aa','2021-07-27 14:59:31','三一',13);
INSERT INTO test_1t VALUES(2,'aa','2021-07-28 14:59:31','三一',12);
INSERT INTO test_1t VALUES(3,'cc','2021-07-29 14:59:31','三二',14);
INSERT INTO test_1t VALUES(4,'cc','2021-07-27 14:59:31','三二',15);
INSERT INTO test_1t VALUES(5,'ee','2021-07-27 14:59:31','三三',15);
INSERT INTO test_1t VALUES(6,'ff','2021-07-17 14:59:31','三三',16); 
INSERT INTO test_1t VALUES(7,'ee','2021-07-07 14:59:31','三四',13);
SELECT * FROM test_1t;

#any_value-4-1
--error 1055
SELECT CAST(pdate AS DATE) as pdate ,class FROM test_1t GROUP BY(class);
SELECT CAST(ANY_VALUE(pdate) AS DATE) as pdate ,class FROM test_1t GROUP BY(class);
SELECT CAST(pdate AS DATE) as pdate,ANY_VALUE(age) FROM test_1t GROUP BY(pdate);
SELECT ANY_VALUE(name),CAST(ANY_VALUE(pdate) AS DATE) as pdate ,class FROM test_1t GROUP BY(class);

#any_value-4-2
UPDATE test_1t SET name=NULL WHERE id IN(3,4,5,6);
SELECT * FROM test_1t;
--error 1055
SELECT IFNULL(name,'ff') AS name,class FROM test_1t GROUP BY(class);
SELECT IFNULL(ANY_VALUE(name),'ff') AS name,class FROM test_1t GROUP BY(class);
SELECT IFNULL(ANY_VALUE(name),'ff') AS name,class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
SELECT IFNULL(name,'ff') AS name,ANY_VALUE(age) FROM test_1t GROUP BY(name);
--error 1055
SELECT NULLIF(name,'ff') AS name,class FROM test_1t GROUP BY(class);
SELECT NULLIF(ANY_VALUE(name),'aa') AS name,class FROM test_1t GROUP BY(class);
SELECT NULLIF(ANY_VALUE(name),'ff') AS name,class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
SELECT NULLIF(name,'ff') AS name,ANY_VALUE(age) FROM test_1t GROUP BY(name);

#any_value-4-3
UPDATE test_1t SET name='cc' WHERE id IN(3,4);
UPDATE test_1t SET name='ee' WHERE id IN(5);
UPDATE test_1t SET name='ff',age=15 WHERE id IN(6);
SELECT * FROM test_1t;
--error 1055
SELECT name,class,MAX(age) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,MAX(age) FROM test_1t GROUP BY(class);
SELECT class,MAX(ANY_VALUE(age)) FROM test_1t GROUP BY(class);
SELECT class,ANY_VALUE(MAX(age)) FROM test_1t GROUP BY(class);
--error 1055
SELECT name,class,AVG(age) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,AVG(age) FROM test_1t GROUP BY(class);
SELECT class,AVG(ANY_VALUE(age)) FROM test_1t GROUP BY(class);
SELECT class,ANY_VALUE(AVG(age)) FROM test_1t GROUP BY(class);
--error 1055
SELECT name,class,SUM(age) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,SUM(age) FROM test_1t GROUP BY(class);
SELECT class,SUM(ANY_VALUE(age)) FROM test_1t GROUP BY(class);
SELECT class,ANY_VALUE(SUM(age)) FROM test_1t GROUP BY(class);
--error 1055
SELECT name,class,COUNT(age) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,COUNT(age) FROM test_1t GROUP BY(class);
SELECT class,COUNT(ANY_VALUE(age)) FROM test_1t GROUP BY(class);
SELECT class,ANY_VALUE(COUNT(age)) FROM test_1t GROUP BY(class);
--error 1055
SELECT name,class,MIN(age) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,MIN(age) FROM test_1t GROUP BY(class);
SELECT class,MIN(ANY_VALUE(age)) FROM test_1t GROUP BY(class);
SELECT class,ANY_VALUE(MIN(age)) FROM test_1t GROUP BY(class);
--error 1055
SELECT name,class,GROUP_CONCAT(age) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,GROUP_CONCAT(age) FROM test_1t GROUP BY(class);
SELECT class,GROUP_CONCAT(ANY_VALUE(age)) FROM test_1t GROUP BY(class);
SELECT class,ANY_VALUE(GROUP_CONCAT(age)) FROM test_1t GROUP BY(class);
DROP TABLE test_1t;

#any_value-4-4
CREATE TABLE test_1t(id int primary key,name VARCHAR(20),pdate DATETIME,class VARCHAR(20),age decimal(5,2));
INSERT INTO test_1t VALUES(1,'aa','2021-07-27 14:59:31','三一',13.34);
INSERT INTO test_1t VALUES(2,'Aa','2021-07-28 14:59:31','三一',13.31);
INSERT INTO test_1t VALUES(3,'CC','2021-07-29 14:59:31','三二',14.5);
INSERT INTO test_1t VALUES(4,'CC','2021-07-27 14:59:31','三二',14.46);
INSERT INTO test_1t VALUES(5,'ee','2021-07-27 14:59:31','三三',15.27);
INSERT INTO test_1t VALUES(6,'EE','2021-07-17 14:59:31','三三',15.33); 
INSERT INTO test_1t VALUES(7,'fF','2021-07-07 14:59:31','三四',13.1);
SELECT * FROM test_1t;

--error 1055
SELECT name,class,FORMAT(age,0) FROM test_1t GROUP BY(class);
--error 1055
SELECT ANY_VALUE(name),class,FORMAT(age,0) FROM test_1t GROUP BY(class);
SELECT class,FORMAT(ANY_VALUE(age),0) FROM test_1t GROUP BY(class);
SELECT class,ANY_VALUE(FORMAT(age,0)) FROM test_1t GROUP BY(class);

--error 1055
SELECT UPPER(name),class FROM test_1t GROUP BY(class);
SELECT UPPER(name),ANY_VALUE(age) FROM test_1t GROUP BY(name);
SELECT ANY_VALUE(UPPER(name)),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
SELECT UPPER(ANY_VALUE(name)),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);

--error 1055
SELECT LOWER(name),class FROM test_1t GROUP BY(class);
SELECT LOWER(name),ANY_VALUE(age) FROM test_1t GROUP BY(name);
SELECT ANY_VALUE(LOWER(name)),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
SELECT LOWER(ANY_VALUE(name)),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);

--error 1055
SELECT INSTR(name,'a'),class FROM test_1t GROUP BY(class);
SELECT INSTR(name,'a'),ANY_VALUE(age) FROM test_1t GROUP BY(name);
SELECT ANY_VALUE(INSTR(name,'a')),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);
SELECT INSTR(ANY_VALUE(name),'a'),class,ANY_VALUE(age) FROM test_1t GROUP BY(class);

#any_value-4-5
UPDATE test_1t SET age=-13.34 WHERE id=1;
UPDATE test_1t SET age=-13.31 WHERE id=2;
UPDATE test_1t SET age=-14.46 WHERE id=3;
UPDATE test_1t SET age=-14.51 WHERE id=4;
SELECT * FROM test_1t;

--error 1055
SELECT ABS(age),class FROM test_1t GROUP BY(class);
--error 1055
SELECT ANY_VALUE(name),ABS(age) FROM test_1t GROUP BY(name);
SELECT ANY_VALUE(name),class,ANY_VALUE(ABS(age)) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ABS(ANY_VALUE(age)) FROM test_1t GROUP BY(class);

--error 1055
SELECT CEIL(age),class FROM test_1t GROUP BY(class);
--error 1055
SELECT ANY_VALUE(name),CEIL(age) FROM test_1t GROUP BY(name);
SELECT ANY_VALUE(name),class,ANY_VALUE(CEIL(age)) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,CEIL(ANY_VALUE(age)) FROM test_1t GROUP BY(class);

--error 1055
SELECT POWER(age,2),class FROM test_1t GROUP BY(class);
--error 1055
SELECT ANY_VALUE(name),POWER(age,2) FROM test_1t GROUP BY(name);
SELECT ANY_VALUE(name),class,ANY_VALUE(POWER(age,2)) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,POWER(ANY_VALUE(age),2) FROM test_1t GROUP BY(class);

--error 1055
SELECT MOD(age,2),class FROM test_1t GROUP BY(class);
--error 1055
SELECT ANY_VALUE(name),MOD(age,2) FROM test_1t GROUP BY(name);
SELECT ANY_VALUE(name),class,ANY_VALUE(MOD(age,2)) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,MOD(ANY_VALUE(age),2) FROM test_1t GROUP BY(class);

--error 1055
SELECT ROUND(age),class FROM test_1t GROUP BY(class);
--error 1055
SELECT ANY_VALUE(name),ROUND(age) FROM test_1t GROUP BY(name);
SELECT ANY_VALUE(name),class,ANY_VALUE(ROUND(age)) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,ROUND(ANY_VALUE(age)) FROM test_1t GROUP BY(class);

--error 1055
SELECT FLOOR(age),class FROM test_1t GROUP BY(class);
--error 1055
SELECT ANY_VALUE(name),FLOOR(age) FROM test_1t GROUP BY(name);
SELECT ANY_VALUE(name),class,ANY_VALUE(FLOOR(age)) FROM test_1t GROUP BY(class);
SELECT ANY_VALUE(name),class,FLOOR(ANY_VALUE(age)) FROM test_1t GROUP BY(class);

DROP TABLE test_1t;
DROP DATABASE db_test;
