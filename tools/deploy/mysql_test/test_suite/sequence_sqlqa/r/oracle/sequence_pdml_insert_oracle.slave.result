alter session set nls_date_format = 'yyyy-mm-dd hh24:mi:ss';
alter session set nls_timestamp_format = 'yyyy-mm-dd hh24:mi:ss.FF';
alter session set NLS_TIMESTAMP_TZ_FORMAT='YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
drop sequence seq;
drop table t1;
create sequence seq minvalue 10 maxvalue 200000 increment by 1;
create table t1(c1 int, c2 int, c3 int);
insert into t1 values(1,1,1);
insert into t1 values(2,2,2);
insert into t1 values(3,3,3);
insert into t1 values(4,4,4);
insert into t1 values(5,5,5);
set autocommit=0;
select seq.nextval from dual;
NEXTVAL
10
explain insert /*+enable_parallel_dml parallel(4)*/ into t1 select seq.nextval,seq.nextval,seq.nextval from t1;
