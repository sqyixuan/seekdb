#owner: jiahua.cjh
#group: storage

--disable_warnings
drop table if exists msdt_lob;
drop table if exists msdt_normal;
--enable_warnings

create table msdt_lob(c1 text, c2 int);

alter table msdt_lob drop c2;

create table msdt_normal(a int, b int);

# msdt_lob
let $tablet_id1 = query_get_value(select tablet_id from oceanbase.__all_virtual_table where table_name = 'msdt_lob', tablet_id, 1);

let $report_cnt1 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_tablet_meta_table where tablet_id = $tablet_id1, cnt, 1);
let $unit_cnt1 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_unit, cnt, 1);

--disable_query_log

let $__i__= 120;
while($__i__ > 0)
{
    sleep 1;
    dec $__i__;
    let $report_cnt1 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_tablet_meta_table where tablet_id = $tablet_id1, cnt, 1);
    if($report_cnt1 == $unit_cnt1)
    {
      let $__i__ = -1;
    }
}


eval select $report_cnt1 = $unit_cnt1 as result;
--enable_query_log

# msdt_normal
let $tablet_id2 = query_get_value(select tablet_id from oceanbase.__all_virtual_table where table_name = 'msdt_normal', tablet_id, 1);

let $report_cnt2 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_tablet_meta_table where tablet_id = $tablet_id2, cnt, 1);
let $unit_cnt2 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_unit, cnt, 1);

--disable_query_log
eval select $report_cnt2 = $unit_cnt2 as result;
--enable_query_log

drop table msdt_lob;
drop table msdt_normal;
