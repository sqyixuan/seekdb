set autocommit=0;//
drop table t1 ;//
create table t1 (a int ,b  int);//
insert into t1 select  
1a,1b from dual connect by level <1000 ;//
commit;//
drop package pkg2;//
create or replace package pkg2 as
cursor cc1 is select a from t1 ;
cursor cc2 is select a from t1  ;
a int :=1;
end;
//
drop package pkg2;//
create or replace package pkg2 as
cursor cc1 is select b from t1 ;
cursor cc2 is select a from t1  ;
a int :=1;
end;
//
insert into t1 select  
1a,1b from dual connect by level <2;//
declare
cursor cc1 is select b from t1  FOR UPDATE SKIP LOCKED;
begin 
for idx in cc1 loop
for idx in pkg1.cc1 loop
for idx in pkg2.cc1 loop
goto commit1;
end loop;
end loop;
<<commit1>>
commit;
end loop;
end;
