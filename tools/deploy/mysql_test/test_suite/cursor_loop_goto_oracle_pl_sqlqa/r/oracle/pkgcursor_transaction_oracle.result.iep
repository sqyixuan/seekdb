set autocommit=0;//
drop table t4 ;//
create table t4 as select 1 a from dual;//
drop table t1 ;//
create table t1 as select  
1a,1b,1c1cc,1aa,1hh,1g1h,1i,1j,1k,1l,1m,1n1o,1p,1q,1r,1s,1t,
1u,1v,1w,1x,1y,1z,1b1,1c1,1cc1,1aa1,1hh1,1g1,1h1,1i1,1j1,1k1,
1l1,1m1,1n1,1o1,1p1,1q1,1r1,1t1,1u1,1v1,1w1,1x1,1y1,1a2,1b2,1c2
,1cc2,1aa2,1hh2,1g2,1h2,1i2,1j2,1k2,1l2,1m2,1n2,1o2,1p2,1q2,1r2,
1s2,1t2,1u2,1v2,1w2,1x2,1y2,1z2,1a3,1b3,1c3,1cc3,1aa3,1hh3,1g3,1h3,
1i3,1j3,1k3,1l3,1m3,1n3,1o3,1p3,1q3,1r3,1s3,1t3,1u3,1v3,1w3,1x3,1y3,1z3,
