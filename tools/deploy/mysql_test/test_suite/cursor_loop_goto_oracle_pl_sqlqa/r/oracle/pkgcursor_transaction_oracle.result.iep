//
SAVEPOINT aa;//
insert into t1 values(9999);//
declare
a int;
begin
begin
for idx in pkg1.cc1 loop 
for idx in (select 1 from t1) loop 
goto lab;
end loop;
end loop;
end;
<<lab>>
