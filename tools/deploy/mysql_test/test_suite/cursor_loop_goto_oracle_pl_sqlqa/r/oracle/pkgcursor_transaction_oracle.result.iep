//
create or replace package body pkg1 is
procedure p1 is
cursor cc3 is select * from t1;
begin
for idx in cc1 loop
insert into t1 values(idx.a);
commit;
end loop;
for idx in cc2 loop
rollback;
end loop;
END;
end;
