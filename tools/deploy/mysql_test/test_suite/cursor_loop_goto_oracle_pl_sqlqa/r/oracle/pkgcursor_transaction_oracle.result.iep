begin
v_xid:=dbms_xa_xid(0,'0','20240119');

insert into t1 select level from dual connect by level <1;
for idx in pkg.cc2 loop
v_end:=dbms_xa.xa_end(v_xid,dbms_xa.TMSUCCESS);
v_xid:=dbms_xa_xid(0,'0','20240119');
v_commit:=dbms_xa.xa_commit(v_xid, onePhase => true);
dbms_output.put_line('XA_end  is:'||v_end );
dbms_output.put_line('XA_commit  is:'||v_commit);
end loop;
end;
