purge recyclebin;
drop user nxa8 cascade;
create user nxa8 identified by nxa8;
grant all on *.* to nxa8 with grant option;
grant dba to nxa8;
alter RESOURCE UNIT 2c2g MAX_CPU=2, MEMORY_SIZE='5G';
result_format: 4
alter session set nls_date_format='yyyy-mm-dd hh24:mi:ss';
alter session set nls_timestamp_format='yyyy-mm-dd hh24:mi:ss.ff';
alter session set nls_timestamp_tz_format='yyyy-mm-dd hh24:mi:ss.ff tzr tzd';
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
result_format: 4
#commit在事务内
set autocommit=0;
drop table t1 ;
create table t1 as select  
1a,1b,1c1cc,1aa,1hh,1g1h,1i,1j,1k,1l,1m,1n1o,1p,1q,1r,1s,1t,
1u,1v,1w,1x,1y,1z,1b1,1c1,1cc1,1aa1,1hh1,1g1,1h1,1i1,1j1,1k1,
1l1,1m1,1n1,1o1,1p1,1q1,1r1,1t1,1u1,1v1,1w1,1x1,1y1,1a2,1b2,1c2
,1cc2,1aa2,1hh2,1g2,1h2,1i2,1j2,1k2,1l2,1m2,1n2,1o2,1p2,1q2,1r2,
1s2,1t2,1u2,1v2,1w2,1x2,1y2,1z2,1a3,1b3,1c3,1cc3,1aa3,1hh3,1g3,1h3,
1i3,1j3,1k3,1l3,1m3,1n3,1o3,1p3,1q3,1r3,1s3,1t3,1u3,1v3,1w3,1x3,1y3,1z3,
1i31,1j31,1k31,1l31,1m31,1n31,1o31,1p31,1q31,1r31,1s31,1t31,1u31,1v31,1w31,1x31,1y31,1z31 from dual connect by level <50;
drop package pkg1;//
create or replace package pkg1 as
cursor cc1 is select * from t1;
cursor cc2 is select * from t1;
procedure p1;
end;
//
drop package pkg2;//
create or replace package pkg2 as
cursor cc1 is select * from t1;
cursor cc2 is select * from t1;
procedure p1;
end;
//
#commit
insert into t1 select  * from t1 FETCH FIRST 10 ROW ONLY;//
begin
SAVEPOINT transaction1;
for idx in pkg1.cc1 loop
insert into t1 select  * from t1 FETCH FIRST 10 ROW ONLY;
for idx in pkg1.cc2 loop
commit;
end loop;
end loop;
end;
//
select count(*) from t1;//
+----------+
| COUNT(*) |
+----------+
|      649 |
+----------+
#rollback
insert into t1 select  * from t1 FETCH FIRST 10 ROW ONLY;//
begin
for idx in pkg1.cc1 loop
rollback ;
end loop;
end;
//
select count(*) from t1;//
+----------+
| COUNT(*) |
+----------+
|      649 |
+----------+
#rollback to
begin
SAVEPOINT transaction1;
insert into t1 select  * from t1 FETCH FIRST 10 ROW ONLY;
begin
for idx in pkg1.cc1 loop
rollback to transaction1;
end loop;
end;
end;
//
select count(*) from t1;//
+----------+
| COUNT(*) |
+----------+
|      649 |
+----------+
