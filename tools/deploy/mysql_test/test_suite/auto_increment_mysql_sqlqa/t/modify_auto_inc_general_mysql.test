#owner:zhenjiang.xzj
#owner group: 技术部-存储
#description: 对不同类型的列修改为自增列并执行DML操作
#author: wb-zc01081081

--disable_warnings

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--enable_result_log


#创建数据库naaj_test
CREATE DATABASE IF NOT EXISTS naaj_test;
USE naaj_test;


#手工对比前，需要设置mysql数据库的sql_mode='STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_VALUE_ON_ZERO';

SET sql_mode='STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_VALUE_ON_ZERO';


--echo ####################不同数据类型列修改列为自增列/新增列为自增列并执行DML操作##############################
#注意，修改普通列为自增列时，可以知道自增步长。


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(5),
                c1 FLOAT(5,0) NOT NULL,
                c2 DOUBLE(5,0));
INSERT INTO t1 VALUES(0,1.5,1),
                     (1,2.5,2),
                     (1,3.5,3),
                     (NULL,4.5,4),
                     (3,5.5,5),
                     (0,6.5,6),
                     (7,7.5,7),
                     (NULL,8.5,8),
                     (9,9.5,9),
                     (11,10.5,10),
                     (0,11.5,11),
                     (12,12.5,12),
                     (13,13.5,13);

#修改数值列为自增列

#列中的行数据包含NULL值

ALTER TABLE t1 MODIFY c0 INT(5) AUTO_INCREMENT;
SHOW CREATE TABLE t1;

SELECT c0 FROM t1 ORDER BY 1;

INSERT INTO t1(c1,c2) VALUES(14.5,14);
SELECT c0 FROM t1 ORDER BY 1;

INSERT INTO t1(c1,c2) VALUES(14.5,14);
SELECT c0 FROM t1 ORDER BY 1;

INSERT INTO t1 VALUES(NULL,14.5,14);
SELECT c0 FROM t1 ORDER BY 1;

INSERT INTO t1 VALUES(3,15.5,15);
SELECT c0 FROM t1 ORDER BY 1;


#修改步长
SET auto_increment_increment=2;

INSERT INTO t1(c1,c2) VALUES(14.5,14);
SELECT c0 FROM t1 ORDER BY 1;

INSERT INTO t1(c1,c2) VALUES(14.5,14);
SELECT c0 FROM t1 ORDER BY 1;


#修改步长
SET auto_increment_increment=1;


#列中的行数据包含负值

DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(5),
                c1 FLOAT(5,0) NOT NULL,
                c2 DOUBLE(5,0));
INSERT INTO t1 VALUES(0,1.5,1),
                     (-1,2.5,2),
                     (1,3.5,3),
                     (-2,4.5,4),
                     (3,5.5,5),
                     (-6,6.5,6),
                     (7,7.5,7),
                     (-8,8.5,8),
                     (9,9.5,9),
                     (-10,10.5,10),
                     (11,11.5,11),
                     (12,12.5,12),
                     (-13,13.5,13);

ALTER TABLE t1 CHANGE c0 c0 INT(5) AUTO_INCREMENT;
SHOW CREATE TABLE t1;

SELECT c0 FROM t1 ORDER BY 1;

INSERT INTO t1(c1,c2) VALUES(14.5,14);
SELECT c0 FROM t1 ORDER BY 1;

INSERT INTO t1(c1,c2) VALUES(14.5,14);
SELECT c0 FROM t1 ORDER BY 1;

INSERT INTO t1 VALUES(-11,14.5,14);
SELECT c0 FROM t1 ORDER BY 1;

DELETE FROM t1 WHERE c0>-5;
COMMIT;
SELECT c0 FROM t1 ORDER BY 1;

INSERT INTO t1(c1,c2) VALUES(14.5,14);
SELECT c0 FROM t1 ORDER BY 1;


#全部为负值

DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(5),
                c1 FLOAT(5,0) NOT NULL,
                c2 DOUBLE(5,0));

INSERT INTO t1 VALUES(-4,1.5,1),(-5,2.5,2),(-11,3.5,3),(-2,4.5,4),(-3,5.5,5),(-6,6.5,6);

ALTER TABLE t1 CHANGE c0 c0 INT(5) AUTO_INCREMENT;
SHOW CREATE TABLE t1;

SELECT c0 FROM t1 ORDER BY 1;

INSERT INTO t1(c1,c2) VALUES(14.5,14);
SELECT c0 FROM t1 ORDER BY 1;


#修改非int类型数值列

#FLOAT

DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(5),c1 FLOAT NOT NULL);

INSERT INTO t1 VALUES(1,1.5),(2,2.5),(3,3.5),(4,4.5),(5,5.5),(6,6.5);

ALTER TABLE t1 MODIFY c1 FLOAT PRIMARY KEY AUTO_INCREMENT;
SHOW CREATE TABLE t1;

SELECT * FROM t1 ORDER BY 1;

INSERT INTO t1(c0) VALUES(7);
INSERT INTO t1(c0) VALUES(8);

#此处结果与mysql不一致，经和开发确认为bydesign。
SELECT * FROM t1 ORDER BY 1;


