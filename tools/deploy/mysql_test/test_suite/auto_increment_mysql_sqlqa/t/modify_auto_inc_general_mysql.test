ALTER TABLE t1 CHANGE c0 c0 CHAR(5) AUTO_INCREMENT;

--error 01063
ALTER TABLE t1 MODIFY c1 CHAR(5) PRIMARY KEY AUTO_INCREMENT;
--error 01063
ALTER TABLE t1 CHANGE c1 c1 CHAR(5) AUTO_INCREMENT;

--error 01063
ALTER TABLE t1 CHANGE c2 c2 CHAR(5) PRIMARY KEY AUTO_INCREMENT;
--error 01063
ALTER TABLE t1 MODIFY c2 CHAR(5) AUTO_INCREMENT;

--error 01063
ALTER TABLE t1 MODIFY c3 CHAR(5) PRIMARY KEY AUTO_INCREMENT;
--error 01063
ALTER TABLE t1 CHANGE c3 c3 CHAR(5) AUTO_INCREMENT;

SHOW CREATE TABLE t1;
SELECT * FROM t1 ORDER BY 1,2,3;


#修改列类型且修改为自增列

ALTER TABLE t1 MODIFY c0 INT AUTO_INCREMENT;
SHOW CREATE TABLE t1;
SELECT c0 FROM t1 ORDER BY 1;

INSERT INTO t1(c1,c2,c3) VALUES(10.5,10.90,15),(11.5,11.90,15),(12.5,11.90,16);
SELECT c0,c1 FROM t1 ORDER BY 1;

INSERT INTO t1 VALUES(NULL,13.5,10.90,17),(20,14.5,11.90,17),(NULL,15.5,11.90,17),(NULL,16.5,12.90,18);
SELECT c0,c1 FROM t1 ORDER BY 1;


#修改自增列步长
