CREATE TABLE t1(c0 INT(5));
INSERT INTO t1 VALUES(0),(0),(0),(0),(0);


ALTER TABLE t1 MODIFY c0 INT(5) PRIMARY KEY AUTO_INCREMENT;
SHOW CREATE TABLE t1;
SELECT * FROM t1 ORDER BY 1;

