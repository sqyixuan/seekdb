INSERT INTO t1 VALUES(30,17.5,11.90,19),(NULL,18.5,12.90,19),(40,19.5,13.90,20),(41,17.9,11.90,19),(NULL,20.5,14.90,21),(NULL,21.5,15.90,22);
SELECT c0,c1 FROM t1 ORDER BY 1;


