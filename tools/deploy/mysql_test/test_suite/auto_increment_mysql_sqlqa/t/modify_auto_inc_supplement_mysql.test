DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(4) DEFAULT 0,
                c1 FLOAT NOT NULL DEFAULT 0,
                c2 VARCHAR(10) UNIQUE,
                c3 YEAR,CHECK(c3>c0));
