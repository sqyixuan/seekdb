SELECT * FROM t2 ORDER BY c0;

--error 01062
INSERT INTO t2(c3,c1,c2) VALUES(2022,5.3,'u'),(2022,5.4,'v');
SELECT * FROM t2 ORDER BY 1;

INSERT INTO t2(c3,c1,c2) VALUES(2022,5.3,'u'),(2023,5.4,'v');
