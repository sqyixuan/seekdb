--echo #LIST分区，修改分区键为自增列，然后校验边界值


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 FLOAT(5,0),
                c1 INT PRIMARY KEY,
                c2 VARCHAR(10))
PARTITION BY LIST(c1)
(PARTITION p1 VALUES IN(1,2,3,15),
PARTITION p2 VALUES IN(4,5,6,25),
PARTITION p3 VALUES IN(7,8,9,35,-2147483648,-2147483649),
PARTITION p4 VALUES IN(10,11,12,2147483647,2147483648)
);

