--echo #RANGE_COLUMN分区，修改分区键为自增列，然后校验边界值


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 FLOAT(5,0),
                c1 INT(5),
                c2 VARCHAR(10),
                UNIQUE KEY(c1,c2))
PARTITION BY RANGE COLUMNS(c1,c2)
(PARTITION p1 VALUES LESS THAN(100,'F'),
PARTITION p2 VALUES LESS THAN(200,'L'),
PARTITION p3 VALUES LESS THAN(300,'T'),
PARTITION p4 VALUES LESS THAN(MAXVALUE,MAXVALUE)
);

