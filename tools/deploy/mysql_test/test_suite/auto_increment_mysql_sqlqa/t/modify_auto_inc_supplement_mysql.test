DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(4),
                c1 FLOAT ,
                c2 VARCHAR(10),
                c3 YEAR);
INSERT INTO t1 VALUES(-1,1.0,'a','2000'),
                     (-2,1.1,'b','2001'),
