--echo #KEY分区，修改分区键为自增列，然后校验边界值


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 FLOAT(5,0),
                c1 INT PRIMARY KEY,
                c2 VARCHAR(10))
PARTITION BY KEY(c1)
(PARTITION p1 ,
PARTITION p2 ,
PARTITION p3 ,
PARTITION p4
);

