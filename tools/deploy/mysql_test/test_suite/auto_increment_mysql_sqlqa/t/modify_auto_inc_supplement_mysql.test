--disable_warnings

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--enable_result_log


#创建数据库naaj_test
CREATE DATABASE IF NOT EXISTS naaj_test;
USE naaj_test;


SET sql_mode='STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_VALUE_ON_ZERO';


--echo #普通表中，修改列为自增列，插入、修改值为边界值校验

