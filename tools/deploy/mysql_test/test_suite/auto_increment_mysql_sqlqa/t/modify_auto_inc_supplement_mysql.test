#创建表时指定自增值，然后修改列为自增列


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(4) DEFAULT 0,
                c1 FLOAT NOT NULL DEFAULT 0,
                c2 VARCHAR(10) UNIQUE,
                c3 YEAR) AUTO_INCREMENT=20;
INSERT INTO t1 VALUES(-1,1.0,'a','2000'),
                     (-2,1.1,'b','2001'),
                     (0,1.2,'c','2002'),
                     (NULL,1.3,'d','2003'),
                     (NULL,1.4,'e','2004'),
                     (16,1.5,'f','2005'),
                     (7,1.6,'g','2006'),
                     (18,1.7,'h','2007'),
                     (-90,1.8,'i','2011'),
                     (NULL,1.9,'j','2012'),
                     (11,2.0,'k','2011'),
                     (NULL,2.1,'l','2012');
CREATE INDEX ind1 ON t1(c0,c1);

ALTER TABLE t1 MODIFY c0 TINYINT AUTO_INCREMENT;
SHOW CREATE TABLE t1;
SELECT * FROM t1 ORDER BY 1;

INSERT INTO t1 VALUES(NULL,3.2,'m','2013'),(NULL,3.4,'n','2014'),(90,3.5,'o','2015'),(NULL,3.7,'p','2015');
SELECT * FROM t1 ORDER BY 1;

INSERT INTO t1(c1,c2,c3) VALUES(3.8,'q','2016'),(3.9,'r','2017');
SELECT * FROM t1 ORDER BY 1;


#创建表时指定自增值，然后修改列为自增列,并修改自增值


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(4) DEFAULT 0,
                c1 FLOAT NOT NULL DEFAULT 0,
                c2 VARCHAR(10) UNIQUE,
                c3 YEAR) AUTO_INCREMENT=20;
INSERT INTO t1 VALUES(-1,1.0,'a','2000'),
                     (-2,1.1,'b','2001'),
                     (0,1.2,'c','2002'),
                     (NULL,1.3,'d','2003'),
                     (NULL,1.4,'e','2004'),
                     (16,1.5,'f','2005'),
                     (7,1.6,'g','2006'),
                     (18,1.7,'h','2007'),
                     (-90,1.8,'i','2011'),
                     (NULL,1.9,'j','2012'),
                     (11,2.0,'k','2011'),
                     (NULL,2.1,'l','2012');
CREATE INDEX ind1 ON t1(c0,c1);

