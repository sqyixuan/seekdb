                     (-90,1.8,'i','2011'),
                     (NULL,1.9,'j','2012'),
                     (11,2.0,'k','2011'),
                     (NULL,2.1,'l','2012');

ALTER TABLE t1 CHANGE c0 c0 INT AUTO_INCREMENT,CHANGE c1 c1 INT,ADD UNIQUE KEY uni_key(c0,c1);
SHOW CREATE TABLE t1;


DROP VIEW IF EXISTS v1;

CREATE VIEW v1 AS SELECT * FROM t1;
DESC v1;
SELECT * FROM v1 ORDER BY 1;

