#修改带有约束、索引等属性的列为自增列，插入、修改值为边界值校验


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(4) ZEROFILL,
                c1 FLOAT NOT NULL UNIQUE,
                c2 VARCHAR(5) DEFAULT 'TEST',
                c3 YEAR,
                PRIMARY KEY (c0,c3));
INSERT INTO t1 VALUES(1,1.0,'a','2000'),
                     (2,1.1,'b','2001'),
                     (3,1.2,'c','2002'),
                     (4,1.3,'d','2003'),
                     (5,1.4,'e','2004'),
                     (6,1.5,'f','2005'),
                     (7,1.6,'g','2006'),
                     (8,1.7,'h','2007'),
                     (9,1.8,'i','2008'),
                     (10,1.9,'j','2009'),
                     (11,2.0,'k','2010'),
                     (12,2.1,'l','2011');

CREATE INDEX ind_1 ON t1(c1);
CREATE INDEX ind_2 ON t1(c2,c3);


DROP TABLE IF EXISTS t2;
CREATE TABLE t2 LIKE t1;
INSERT INTO t2 SELECT * FROM t1;
SELECT * FROM t2 ORDER BY c0;
SHOW CREATE TABLE t2;

--error 01235
ALTER TABLE t2 MODIFY c0 INT AUTO_INCREMENT AFTER c1,MODIFY c3 INT AUTO_INCREMENT FIRST,MODIFY c1 FLOAT(5,0);

ALTER TABLE t2 MODIFY c0 INT AUTO_INCREMENT AFTER c1,MODIFY c3 INT FIRST,MODIFY c1 DOUBLE;


INSERT INTO t2(c0,c1,c2,c3) VALUES(NULL,2.1,'m',10),(NULL,3.0,'n',11),(25,4.0,'o',1500),(-116,5.1,'p',-3000),(NULL,6.2,'q',0),(NULL,7.0,'r',-100);
SELECT * FROM t2 ORDER BY 1;

--error 01062
