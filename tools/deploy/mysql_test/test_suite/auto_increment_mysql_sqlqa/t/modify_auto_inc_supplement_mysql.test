INSERT INTO t1 VALUES(8,NULL,'A');
SELECT * FROM t1 ORDER BY 1;

--error 01062
INSERT INTO t1(c0,c2) VALUES(9,'B');
SELECT * FROM t1 ORDER BY 1;


