ALTER TABLE t1 MODIFY c2 INT(5) AUTO_INCREMENT;
SHOW CREATE TABLE t1;
SELECT * FROM t1 ORDER BY 1;

INSERT INTO t1 VALUES(8,1,NULL),(9,2,NULL),(10,0,30),(11,6,-50),(12,-10,NULL),(13,7,NULL);
