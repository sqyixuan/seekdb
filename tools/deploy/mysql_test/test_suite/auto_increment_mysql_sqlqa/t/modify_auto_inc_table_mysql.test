INSERT INTO t1(c0,c2) VALUES(14,'G'),(15,'H');
SELECT * FROM t1 ORDER BY 1;



DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 FLOAT(5,0),
                c1 INT,
                c2 VARCHAR(10))
PARTITION BY KEY(c1) PARTITIONS 3;

INSERT INTO t1 VALUES(1,0,'A'),(2,2,'B'),(3,4,'C'),(4,14,'D'),(5,17,'E'),(6,20,'F'),(7,23,'G');

--echo #修改非分区键为自增列

--error 01366
ALTER TABLE t1 MODIFY c2 INT AUTO_INCREMENT;


ALTER TABLE t1 MODIFY c0 INT AUTO_INCREMENT;
SHOW CREATE TABLE t1;

--echo #此处执行sql查询结果与插入结果不一致，待开发修复后执行

--disable_parsing

INSERT INTO t1 VALUES(NULL,24,'A'),(NULL,25,'B'),(20,26,'A'),(-30,27,'B'),(NULL,28,'A'),(NULL,29,'B');
SELECT * FROM t1 ORDER BY 1;

INSERT INTO t1(c1,c2) VALUES(30,'G'),(31,'H');
SELECT * FROM t1 ORDER BY 1;

--enable_parsing



--echo ####HASH 分区####



DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 FLOAT(5,0),
                c1 INT,
                c2 VARCHAR(10))
PARTITION BY HASH(c1)
(PARTITION p1,PARTITION p2,PARTITION p3);

INSERT INTO t1 VALUES(1,0,'A'),(2,2,'B'),(3,4,'C'),(4,14,'D'),(5,17,'E'),(6,20,'F'),(7,23,'G');

--echo #修改分区键为自增列

ALTER TABLE t1 MODIFY c1 INT PRIMARY KEY AUTO_INCREMENT;
SHOW CREATE TABLE t1;

INSERT INTO t1 VALUES(8,NULL,'A'),(9,NULL,'B'),(10,50,'C'),(11,-60,'D'),(12,NULL,'E'),(13,NULL,'F');
SELECT * FROM t1 ORDER BY 1;

INSERT INTO t1(c0,c2) VALUES(14,'G'),(15,'H');
SELECT * FROM t1 ORDER BY 1;



DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 FLOAT(5,0),
                c1 INT(5),
                c2 VARCHAR(10))
PARTITION BY HASH(c1) PARTITIONS 3;

INSERT INTO t1 VALUES(1,1,'A'),(2,2,'B'),(3,0,'C'),(4,-20,'D'),(5,6,'E'),(6,-10,'F'),(7,7,'G');

--echo #修改分区键为自增列且修改列类型

--error 01659
ALTER TABLE t1 MODIFY c1 FLOAT PRIMARY KEY AUTO_INCREMENT;

SHOW CREATE TABLE t1;


--echo #修改非分区键为自增列

--error 01366
ALTER TABLE t1 MODIFY c2 INT AUTO_INCREMENT;


ALTER TABLE t1 MODIFY c0 INT AUTO_INCREMENT;
SHOW CREATE TABLE t1;

--echo #此处执行sql查询结果与插入结果不一致，待开发修复后执行

--disable_parsing

INSERT INTO t1 VALUES(NULL,24,'A'),(NULL,25,'B'),(20,26,'A'),(-30,27,'B'),(NULL,28,'A'),(NULL,29,'B');
SELECT * FROM t1 ORDER BY 1;

INSERT INTO t1(c1,c2) VALUES(30,'G'),(31,'H');
SELECT * FROM t1 ORDER BY 1;

--enable_parsing



--echo ####子分区####

#RANGE-->HASH

DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 FLOAT(5,0),
                c1 INT(5),
                c2 VARCHAR(10))
PARTITION BY RANGE COLUMNS(c2)
SUBPARTITION BY HASH(c1) SUBPARTITIONS 4
(PARTITION r1 VALUES LESS THAN('10'),
 PARTITION r2 VALUES LESS THAN('20'),
 PARTITION r3 VALUES LESS THAN('30'),
 PARTITION r4 VALUES LESS THAN('40'));

INSERT INTO t1 VALUES(1,1,'1'),(2,2,'2'),(3,0,'3'),(4,-20,'-5'),(5,6,'-10'),(6,-10,'11'),(7,7,'15');


--echo #修改子分区键为自增列

--error 01503
ALTER TABLE t1 MODIFY c1 INT(5) PRIMARY KEY AUTO_INCREMENT;

ALTER TABLE t1 MODIFY c1 INT(5) AUTO_INCREMENT;
SHOW CREATE TABLE t1;

INSERT INTO t1 VALUES(8,NULL,'17'),(9,NULL,'19'),(10,-50,'20'),(11,-100,'22'),(12,NULL,'24'),(13,NULL,'25');
SELECT * FROM t1 ORDER BY 1;

INSERT INTO t1(c0,c2) VALUES(14,'26'),(15,'28'),(16,'30');
SELECT * FROM t1 ORDER BY 1;

--error 01235
ALTER TABLE t1 MODIFY c2 INT(5) AUTO_INCREMENT;


--echo #修改主区分键为自增列且修改分区键类型


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 FLOAT(5,0),
                c1 INT(5),
                c2 VARCHAR(10))
PARTITION BY RANGE COLUMNS(c2)
SUBPARTITION BY HASH(c1) SUBPARTITIONS 4
(PARTITION r1 VALUES LESS THAN('10'),
 PARTITION r2 VALUES LESS THAN('20'),
 PARTITION r3 VALUES LESS THAN('30'),
 PARTITION r4 VALUES LESS THAN('40'));

