SELECT * FROM t1 ORDER BY 1;

--enable_parsing


#LIST-->KEY

DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 FLOAT(5,0),
                c1 INT(5),
                c2 YEAR,
                PRIMARY KEY(c1,c2))
PARTITION BY LIST (c2)
SUBPARTITION BY KEY(c1) SUBPARTITIONS 4
(PARTITION p1 VALUES IN(2000 ,2001 ,2002 ,2003 ,2004 ,2005 ,2006 ,2007 ,2008 ,2009 ,2010 ,2011 ,2012 ,2013 ,2014 ,2015),
 PARTITION p2 VALUES IN(2016 ,2017 ,2018 ,2019 ,2020 ,2021 ,2022 ,2023 ,2024 ,2025 ,2026 ,2027 ,2028 ,2029 ,2030),
 PARTITION p3 VALUES IN(2031 ,2032 ,2033 ,2034 ,2035 ,2036 ,2037 ,2038 ,2039 ,2040 ,2041 ,2042 ,2043 ,2044 ,2045));

