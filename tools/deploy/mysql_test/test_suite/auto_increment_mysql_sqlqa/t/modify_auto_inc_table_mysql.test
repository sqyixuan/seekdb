--echo ##########复制表##########



--echo #使用as关键字创建复制表

#修改复制表中的列为自增列，然后校验对复制表以及被复制表的影响

DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(4) ZEROFILL,
                c1 FLOAT ,
                c2 VARCHAR(10),
                c3 YEAR);
INSERT INTO t1 VALUES(1,1.0,'a','2000'),
                     (2,1.1,'b','2001'),
                     (3,1.2,'c','2002'),
                     (4,1.3,'d','2003'),
                     (5,1.4,'e','2004'),
                     (6,1.5,'f','2005'),
                     (7,1.6,'g','2006'),
                     (8,1.7,'h','2007'),
                     (9,1.8,'i','2011'),
                     (10,1.9,'j','2012'),
                     (11,2.0,'k','2011'),
                     (12,2.1,'l','2012');

CREATE INDEX ind_1 ON t1(c1);
CREATE INDEX ind_2 ON t1(c2,c3);


CREATE TABLE t2 AS SELECT * FROM t1;
SELECT * FROM t2 ORDER BY 1;
SHOW CREATE TABLE t2;

ALTER TABLE t2 MODIFY c1 INT(5) AUTO_INCREMENT;
SHOW CREATE TABLE t2;
SHOW CREATE TABLE t1;
SELECT * FROM t2 ORDER BY 1;
SELECT * FROM t1 ORDER BY 1;


INSERT INTO t2 VALUES(13,NULL,'m','2012'),(14,NULL,'m','2013'),(15,-20,'n','2014'),(16,-50,'n','2016'),(17,NULL,'o','2017'),(18,NULL,'p','2018');
SELECT * FROM t2 ORDER BY 1;
SELECT * FROM t1 ORDER BY 1;


INSERT INTO t2(c0,c2,c3) VALUES(19,'p','2019'),(20,'l','2020'),(21,'d','2021');
SELECT * FROM t2 ORDER BY 1;
SELECT * FROM t1 ORDER BY 1;


#修改被复制表的列为自增列，然后校验对复制表以及被复制表的影响


ALTER TABLE t1 MODIFY c0 INT(5) AUTO_INCREMENT;
SHOW CREATE TABLE t1;
SHOW CREATE TABLE t2;
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


INSERT INTO t1 VALUES(NULL,2.2,'m','2012'),(NULL,3.2,'m','2013'),(15,4.4,'n','2014'),(16,5.5,'n','2016'),(NULL,6.6,'o','2017'),(NULL,7.7,'p','2018');
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


INSERT INTO t1(c1,c2,c3) VALUES(8.8,'p','2019'),(9.9,'l','2020'),(10.2,'d','2021');
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


#修改被复制表的列为自增列后，使用as关键字创建复制表，校验自增列对复制表的影响


DROP TABLE IF EXISTS t2;

CREATE TABLE t2 AS SELECT * FROM t1;
SELECT * FROM t2 ORDER BY 1;
SHOW CREATE TABLE t2;

--error 01048
INSERT INTO t2 VALUES(NULL,2.2,'m','2012'),(NULL,3.2,'m','2013'),(15,4.4,'n','2014'),(16,5.5,'n','2016'),(NULL,6.6,'o','2017'),(NULL,7.7,'p','2018');

--error 01364
INSERT INTO t2(c1,c2,c3) VALUES(8.8,'p','2019'),(9.9,'l','2020'),(10.2,'d','2021');

INSERT INTO t2 VALUES(25,4.4,'n','2014'),(26,5.5,'n','2016');
SELECT * FROM t2 ORDER BY 1;



--echo #使用like关键字创建复制表



#修改复制表中的列为自增列，然后校验对复制表以及被复制表的影响

DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(4) ZEROFILL,
                c1 FLOAT ,
                c2 VARCHAR(10),
                c3 YEAR);
INSERT INTO t1 VALUES(1,1.0,'a','2000'),
                     (2,1.1,'b','2001'),
                     (3,1.2,'c','2002'),
                     (4,1.3,'d','2003'),
                     (5,1.4,'e','2004'),
                     (6,1.5,'f','2005'),
                     (7,1.6,'g','2006'),
                     (8,1.7,'h','2007'),
                     (9,1.8,'i','2011'),
                     (10,1.9,'j','2012'),
                     (11,2.0,'k','2011'),
                     (12,2.1,'l','2012');

CREATE INDEX ind_1 ON t1(c1);
CREATE INDEX ind_2 ON t1(c2,c3);


CREATE TABLE t2 LIKE t1;
INSERT INTO t2 SELECT * FROM t1;
SELECT * FROM t2 ORDER BY c0;
SHOW CREATE TABLE t2;

ALTER TABLE t2 MODIFY c1 INT(5) AUTO_INCREMENT;
SHOW CREATE TABLE t2;
SHOW CREATE TABLE t1;
SELECT * FROM t2 ORDER BY 1;
SELECT * FROM t1 ORDER BY 1;


