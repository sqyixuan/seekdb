#owner:zhenjiang.xzj
#owner group: 技术部-存储
#description: 对带有不同索引、约束的列修改为自增列并执行DML操作
#author: wb-zc01081081

--disable_warnings

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--enable_result_log


#创建数据库naaj_test
CREATE DATABASE IF NOT EXISTS naaj_test;
USE naaj_test;


SET sql_mode='STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_VALUE_ON_ZERO';


--echo #####################修改带有不同约束或者索引属性的列，并执行DML操作#########################
--echo #注意表中列为生成列，以及对表或行进行加锁后修改列属性

#修改列带有主键约束

DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(5) PRIMARY KEY,c1 INT(5));
INSERT INTO t1 VALUES(0,0),(2,1), (4,2),(6,3),(8,4),(10,5),(17,6),(18,7),(19,8),(11,9),(20,10),(22,11),(23,12);

--error 01063
ALTER TABLE t1 MODIFY c0 CHAR(6) AUTO_INCREMENT COMMENT'修改主键列为自增列';
--error 01063
ALTER TABLE t1 MODIFY c0 VARCHAR(6) AUTO_INCREMENT COMMENT'修改主键列为自增列';
--error 01063
ALTER TABLE t1 MODIFY c0 BINARY(6) AUTO_INCREMENT COMMENT'修改主键列为自增列';
--error 01063
ALTER TABLE t1 MODIFY c0 VARBINARY(6) AUTO_INCREMENT COMMENT'修改主键列为自增列';
--error 01063
ALTER TABLE t1 MODIFY c0 DATE AUTO_INCREMENT COMMENT'修改主键列为自增列';
--error 01063
ALTER TABLE t1 MODIFY c0 TIME AUTO_INCREMENT COMMENT'修改主键列为自增列';
--error 01063
ALTER TABLE t1 MODIFY c0 DATETIME AUTO_INCREMENT COMMENT'修改主键列为自增列';
--error 01063
ALTER TABLE t1 MODIFY c0 TIMESTAMP AUTO_INCREMENT COMMENT'修改主键列为自增列';
--error 01063
ALTER TABLE t1 MODIFY c0 SET('0','2','4','6','8','10','17','18','19','11','20','22','23') AUTO_INCREMENT COMMENT'修改主键列为自增列';
--error 01063
ALTER TABLE t1 MODIFY c0 TEXT AUTO_INCREMENT COMMENT'修改主键列为自增列';
--error 01063
ALTER TABLE t1 MODIFY c0 BLOB AUTO_INCREMENT COMMENT'修改主键列为自增列';


ALTER TABLE t1 MODIFY c0 FLOAT(6,0) AUTO_INCREMENT COMMENT'修改主键列为自增列' AFTER c1;
SHOW CREATE TABLE t1;
SELECT c0 FROM t1 ORDER BY 1;

--error 01062
INSERT INTO t1 VALUES(13,0);

INSERT INTO t1 VALUES(13,NULL),(14,NULL),(15,1),(16,3),(17,NULL),(18,NULL);
SELECT c0 FROM t1 ORDER BY 1;

INSERT INTO t1(c1) VALUES(19),(20),(21);
SELECT c0 FROM t1 ORDER BY 1;

ALTER TABLE t1 MODIFY c0 INT(5) AUTO_INCREMENT COMMENT'修改主键列为自增列' AFTER c1;
SHOW CREATE TABLE t1;


#联合主键

DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(5) ,c1 INT(5) ,c2 INT(5) ,PRIMARY KEY(c0,c1));
