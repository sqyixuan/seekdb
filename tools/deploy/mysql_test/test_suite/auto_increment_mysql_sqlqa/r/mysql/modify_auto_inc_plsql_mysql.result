CREATE FUNCTION f2( d INT)
RETURNS VARCHAR(100)
BEGIN
DECLARE d1 INT;
DECLARE d2 INT;
DECLARE d3 VARCHAR(100);
ALTER TABLE t2 MODIFY c0 INT PRIMARY KEY AUTO_INCREMENT;
ALTER TABLE t1 MODIFY c1 INT PRIMARY KEY AUTO_INCREMENT;
IF d > 10 THEN
INSERT INTO t1(c0,c2) VALUES(d+100,'test1'),(d+200,'test2'),(d+300,'test3');
INSERT INTO t2(c1) VALUES(d+50),(d+60),(d+70);
ELSEIF d > 5 THEN
INSERT INTO t1 VALUES(d*2,NULL,'AA'),(d*3,NULL,'BB'),(d*4,-100,'CC'),(d*5,50,'DD'),(d*6,NULL,'EE'),(d*7,NULL,'FF');
INSERT INTO t2 VALUES(NULL,100),(NULL,101),(-100,102),(50,103),(NULL,104),(NULL,105);
ELSE
INSERT INTO t1(c0) SELECT c1 FROM t2 WHERE c0 < 5;
INSERT INTO t2(c1) SELECT c1 FROM t1 WHERE c0 < 5;
END IF;
SELECT COUNT(c1) INTO d1 FROM t1;
SELECT COUNT(c0) INTO d2 FROM t2;
SET d3 = CONCAT('t1表执行函数后条目合计：',d1,',','t2表执行函数后条目合计：',d2);
RETURN d3;
END;
