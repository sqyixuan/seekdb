#####触发器#####
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT(5),
c1 INT,
c2 VARCHAR(10));
INSERT INTO t1 VALUES(1,0,'A'),(2,2,'B'),(3,4,'C'),(4,8,'D'),(5,16,'E'),(6,18,'F'),(7,20,'G');
DROP TABLE IF EXISTS t2;
CREATE TABLE t2(c0 INT(5),
c1 INT);
INSERT INTO t2 VALUES(1,0),(2,2),(3,4),(4,8),(5,16),(6,18),(7,20);
DROP TRIGGER IF EXISTS trg_insert;
CREATE TRIGGER trg_insert AFTER INSERT ON t2
FOR EACH ROW
BEGIN
DECLARE c INT;
SELECT MAX(c0) INTO c FROM t1;
IF NEW.c0 = c THEN
INSERT INTO t1(c0,c2) VALUES(NEW.c1,'TEST1'),(NEW.c1-NEW.c0,'TEST2');
ELSE
INSERT INTO t1 VALUES(NEW.c0,NULL,'AA'),(NEW.c0+1,NULL,'BB'),(NEW.c0+2,-50,'CC'),(NEW.c0+3,30,'DD'),(NEW.c0+4,NULL,'EE'),(NEW.c0+5,NULL,'FF');
END IF;
END;
