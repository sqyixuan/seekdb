--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# owner group: SQL3
# description: OUR GOAL: Make all this simple and effective!
--disable_warnings
drop table if exists split_table;
--enable_warnings


--real_sleep 2 


create table split_table(i1 bigint, v1 varchar(20), v2 varchar(20), v3 varchar(20), v4 varchar(20), v5 varchar(20), v6 varchar(20), v7 varchar(20), v8 varchar(20), v9 varchar(20),v10 varchar(20), i2 bigint, i3 bigint, n1 numeric, n2 numeric, f1 float, d1 double, t1  timestamp(6) default "2012-01-01 12:00:00",primary key(i1,v1));

--disable_result_log
--disable_query_log
let $cnt=40000;
while($cnt > 0)
{
    eval replace into split_table values($cnt,'a$cnt','a$cnt','a$cnt','a$cnt','a$cnt','a$cnt','bcdefghijklmn$cnt','bcdefghijklmn$cnt','bcdefghijklmn$cnt','bcdefghijklmn$cnt',$cnt,$cnt,$cnt$cnt,$cnt$cnt,$cnt.$cnt,$cnt.$cnt,'2014-03-11 00:00:00');
    dec $cnt;
}
--enable_result_log
--enable_query_log
update split_table set v2=1 ;

#let $memtable = query_get_value(select log_str from __updateserver_memtable_info where table_status='active',log_str, 1);
