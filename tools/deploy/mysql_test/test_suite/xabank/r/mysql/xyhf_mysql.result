DROP VIEW IF EXISTS `device_record_view`;
Warnings:
Note	1051	Unknown table 'xyhfdb.device_record_view'
CREATE
VIEW `device_record_view`
  AS
SELECT
`device_no`, `bind_flag_no`
FROM
`cool_device_record`
WHERE
((`is_before` = 1) AND (`bind_flag_no` > 0) AND (`type` NOT IN ('ADD', 'START', 'END')));
DROP VIEW IF EXISTS `menu_parent`;
Warnings:
Note	1051	Unknown table 'xyhfdb.menu_parent'
CREATE
VIEW `menu_parent`
  AS
SELECT
`name`, `id`
FROM
`cool_admin_menu`
WHERE
(`parent_id` = 0)
ORDER BY
`sort`;
select * from cool_business as cb
left join cool_agent as ca on ca.agent_id = cb.agent_id
left join cool_channel as ch on ch.channel_id = ca.channel_id
left join cool_openplatform_businessmainkey as cob on cob.business_id = cb.business_id
where ch.channel_code = '10014' and cob.bill_reback_url <> '';
