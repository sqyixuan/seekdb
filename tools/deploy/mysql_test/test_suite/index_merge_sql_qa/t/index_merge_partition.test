explain select /*+union_merge(t1 primary c4)*/ * from t1 where (c2 = 1000 or c3 > 300) and (c4 = '鄂A54321' or c5 = '鄂A0') and (c1 = 54321 or c4 = '鄂A201000');
--sorted_result
select /*+union_merge(t1 primary c4)*/ * from t1 where (c2 = 1000 or c3 > 300) and (c4 = '鄂A54321' or c5 = '鄂A0') and (c1 = 54321 or c4 = '鄂A201000');
explain select /*+union_merge(t1 c2 cg3)*/ * from t1 where (c2 = 1000 or c3 > 300) and (c4 = '鄂A54321' or c5 = '鄂A0') and (c1 = 54321 or c4 = '鄂A201000');
--sorted_result
select /*+union_merge(t1 c2 cg3)*/ * from t1 where (c2 = 1000 or c3 > 300) and (c4 = '鄂A54321' or c5 = '鄂A0') and (c1 = 54321 or c4 = '鄂A201000');
explain select /*+union_merge(t1 c2 c4 c4)*/ * from t1 where (c1 > 10 and c2 = -1) or (c4 = '鄂A54321' and c5 = '鄂A321') or (c4 = '鄂A345679' and c3 > 10);
--sorted_result
select /*+union_merge(t1 c2 c4 c4)*/ * from t1 where (c1 > 10 and c2 = -1) or (c4 = '鄂A54321' and c5 = '鄂A321') or (c4 = '鄂A345679' and c3 > 10);
explain select /*+union_merge(t1 c2 cg5 c4)*/ * from t1 where (c1 > 10 and c2 = -1) or (c4 = '鄂A54321' and c5 = '鄂A321') or (c4 = '鄂A345679' and c3 > 10);
--sorted_result
select /*+union_merge(t1 c2 cg5 c4)*/ * from t1 where (c1 > 10 and c2 = -1) or (c4 = '鄂A54321' and c5 = '鄂A321') or (c4 = '鄂A345679' and c3 > 10);
explain select /*+no_expand union_merge(t1 c2 c4 cg3)*/ * from t1 where (c1 > 10 and c2 = -1) or (c4 = '鄂A54321' and c5 = '鄂A321') or (c4 = '鄂A345679' and c3 > 10);
select /*+no_expand union_merge(t1 c2 c4 cg3)*/ * from t1 where (c1 > 10 and c2 = -1) or (c4 = '鄂A54321' and c5 = '鄂A321') or (c4 = '鄂A345679' and c3 > 10);

# 分区场景
explain select /*+union_merge(t1 c4 c2)*/ * from t1 partition(p0) where c4 = '鄂A54321' or c2 = 145679;
select /*+union_merge(t1 c4 c2)*/ * from t1 partition(p0) where c4 = '鄂A54321' or c2 = 145679;
explain select /*+union_merge(t1 c4 c2)*/ * from t1 partition(p1) where (c3 = 123 and c4 = '鄂A123') or c2 < -12312;
explain select /*+union_merge(t1 c4 c2)*/ * from t1 partition(p2) where (c3 = 123 and c4 = '鄂A32123') or (c2 = 123 and c5 < '鄂A321');
explain select /*+union_merge(t1 primary c3 c4)*/* from t1 partition(p3) where (c1 = 320123 or c3 = 321) and (c2 = 104321 or c4 = '鄂A320123') and (c1 > 10 or c2 < 1000) or c4 = '鄂A12345';
