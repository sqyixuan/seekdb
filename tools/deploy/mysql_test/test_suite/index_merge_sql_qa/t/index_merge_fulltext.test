#owner: guohanyun.ghy
#tags: optimizer,SQL,index merge
#owner group: sql1
#description: 测试非分区表，全文索引index merge场景

--disable_warnings
drop table if exists t1;
drop sequence if exists s1;
--enable_warnings
set ob_query_timeout=30000000;
alter system set _enable_index_merge=true;
create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100), c5 varchar(100));
create sequence s1 cache 1000000 order;
insert /*+enable_parallel_dml parallel(16) query_timeout(1000000000)*/ into t1 select s1.nextval, s1.currval-200000, s1.currval%1000, CONCAT('鄂A', s1.currval), CONCAT('鄂A', s1.currval%1000) from table(generator(400000));
create index c2 on t1(c2) local;
create index c3 on t1(c3) local;
create index cg3 on t1(c3) global;
create index c4 on t1(c4) local;
create FULLTEXT INDEX fidx4 ON t1(c4);
create index c5 on t1(c5) local;
create index c23 on t1(c2,c3) local;
call dbms_stats.gather_schema_stats(NULL);

--source mysql_test/include/minor_merge_tenant.inc

# 纯or场景
explain select * from t1 where c2 = 1 or MATCH(c4) AGAINST('鄂A12345');
select * from t1 where c2 = 1 or MATCH(c4) AGAINST('鄂A12345');
explain select * from t1 where c2 = 1 or MATCH(c4) AGAINST('鄂A12345') or c5 = '鄂A12345';
--sorted_result
select * from t1 where c2 = 1 or MATCH(c4) AGAINST('鄂A12345') or c5 = '鄂A12345';
explain select * from t1 where c1 = 10000 or c2 = 1 or c3 = 5 or MATCH(c4) AGAINST('鄂A12345');
explain select * from t1 where c1 = 10000 or c2 = 1 or c3 = 5 or MATCH(c4) AGAINST('鄂A12345') or c5 = '鄂A142145';

explain select * from t1 where c1 = 10 or c2 > 10 or MATCH(c4) AGAINST('鄂A12345');
explain select * from t1 where c1 > 391000 or c1 < 10 or MATCH(c4) AGAINST('鄂A12345');
explain basic select * from t1 where MATCH(c4) AGAINST('鄂A12345') or c2 in (10,30,50);
explain select * from t1 where MATCH(c4) AGAINST('鄂A12345') or c1 < 5 or c2 > 199900;
explain select * from t1 where c1 = 123 or c2 = 32131 or c5 = '鄂A142145' or c3 > 390000 or MATCH(c4) AGAINST('鄂A12345');

# and or 场景
explain select * from t1 where c2 = 1 and MATCH(c4) AGAINST('鄂A12345') or c3 > 390000;
explain select * from t1 where MATCH(c4) AGAINST('鄂A12345') or c3 > 10 and c2 = 10000;
select * from t1 where MATCH(c4) AGAINST('鄂A12345') or c3 > 10 and c2 = 10000;
explain select * from t1 where c1 = 1 and MATCH(c4) AGAINST('鄂A12345') or c3 > 390000;
explain select * from t1 where c3 = 10 or MATCH(c4) AGAINST('鄂A12345') and c2 = 10000;

explain select * from t1 where (c1 = 2 and c3 = 2) or (MATCH(c4) AGAINST('鄂A12345') and c3 > 6);
select * from t1 where (c1 = 2 and c3 = 2) or (MATCH(c4) AGAINST('鄂A12345') and c3 > 6);
explain select * from t1 where (c1 = 2 and c3 = 10) or (MATCH(c4) AGAINST('鄂A12345') and c3 > 6) or (c4 > '鄂A142145' and c2 = 5);
explain select * from t1 where (MATCH(c4) AGAINST('鄂A12345') and c5 = '鄂A345') or (MATCH(c4) AGAINST('鄂A12345') and c3 > 6) or (c4 > '鄂A142145' and c2 = 5);
explain select * from t1 where (c1 = 10 and c2 > -10000000) or (MATCH(c4) AGAINST('鄂A12345') and c1 = 12345) or (c3 > -199999 and c1 = 1);
select * from t1 where (c1 = 10 and c2 > -10000000) or (MATCH(c4) AGAINST('鄂A12345') and c1 = 12345) or (c3 > -199999 and c1 = 1);
explain select /*+no_expand union_merge(t1 c3 c4 c3)*/ * from t1 where (c3 = 10 and c2 > -10000) or (c4 > '鄂A12344' and c3 = 387655) or (c1 > 199999 and c3 = 1);
explain select * from t1 where (MATCH(c4) AGAINST('鄂A12345') and c5 > '鄂A3') or (c2 < 5 and c2 > 1) or (c4 > '鄂A12345' and c2 = 5);
explain select * from t1 where (MATCH(c4) AGAINST('鄂A12345') and c5 > '鄂A3') or (c2 < 5 and c2 > 1) or (c4 > '鄂A12345' and c4 < '鄂A12346');
--sorted_result
select * from t1 where (MATCH(c4) AGAINST('鄂A12345') and c5 > '鄂A3') or (c2 < 5 and c2 > 1) or (c4 > '鄂A12345' and c4 < '鄂A12346');
explain select * from t1 where (MATCH(c4) AGAINST('鄂A12345') and c5 > '鄂A3' and c3 = 345) or (c2 < 5 and c2 > 1 and c3 = 3) or (c4 > '鄂A12345' and c2 = 5);
explain select * from t1 where (MATCH(c4) AGAINST('鄂A12345') and c5 > '鄂A3' and c3 = 345) or (c2 < 5 and c2 > 1 and c3 = 3) or (c4 > '鄂A12345' and c2 = 5) or (c1 = 10000);
--sorted_result
select * from t1 where (MATCH(c4) AGAINST('鄂A12345') and c5 > '鄂A3' and c3 = 345) or (c2 < 5 and c2 > 1 and c3 = 3) or (c4 > '鄂A12345' and c2 = 5) or (c1 = 10000);

# or and 场景
explain select * from t1 where (c1 = 10 or MATCH(c4) AGAINST('鄂A12345')) and (c2 = 1 or c3 > 5);
explain select * from t1 where (c1 < 5 or c3 > 399900) and (MATCH(c4) AGAINST('鄂A12345') or c2 < 4);
explain select * from t1 where (c2 = -100 or c3 = 6) and (MATCH(c4) AGAINST('鄂A12345') or MATCH(c4) AGAINST('鄂A12346'));
explain select * from t1 where (c2 < -100000 or c3 > 300000) and (MATCH(c4) AGAINST('鄂A12345') or MATCH(c4) AGAINST('鄂A12346')) and (c2 = -187655 or c3 = 387654);
explain select /*+union_merge(t1 c4 fidx4)*/ * from t1 where (c1 = 10 or MATCH(c4) AGAINST('鄂A12345')) and (c4 < '鄂A12345' or MATCH(c4) AGAINST('鄂A12346')) and (c1 > 4 or c1 < 8);
explain select * from t1 where (c1 = 3 or MATCH(c4) AGAINST('鄂A12345')) and (c4 < '鄂A12345' or MATCH(c4) AGAINST('鄂A3')) and (c1 in (1,2,3,4,9));
explain select * from t1 where (c1 > 399900 or c1 < 9) and (c2 > 10000 or c2 < -100000) and (c3 <> 10) and (MATCH(c4) AGAINST('鄂A1 鄂A2 鄂A3 鄂A4 鄂A5') or MATCH(c4) AGAINST('鄂A6'));
--sorted_result
select * from t1 where (c1 > 399900 or c1 < 9) and (c2 > 10000 or c2 < -100000) and (c3 <> 10) and (MATCH(c4) AGAINST('鄂A1 鄂A2 鄂A3 鄂A4 鄂A5') or MATCH(c4) AGAINST('鄂A6'));
explain basic select * from t1 where (c2 < -199000 or c2 > 199000) and (c3 <> 10 or c1 < 5) and (MATCH(c4) AGAINST('鄂A1') or c1 in (2,3,4,9,10)) and (c5 = '鄂A142145' or c1 > 1);
######路径选择有bug
explain select * from t1 where (MATCH(c4) AGAINST('鄂A321312') or c3 > 5 or c2 < -100000 or c1 > 199000) and (MATCH(c4) AGAINST('鄂A321313') or c2 = 121314 or c1 = 199900) and (MATCH(c4) AGAINST('鄂A321314') or c1 > 199000) and (c1 > 188000);
explain select * from t1 where (MATCH(c4) AGAINST('鄂A189824') or c3 > 5 or c2 < -100000 or c1 > 199000) and (MATCH(c4) AGAINST('鄂A189824') or c3 > 200000 or c2 = 121314 or c1 = 199800) and (c1 < 199900) and (c1 > 188000);
explain select * from t1 where (MATCH(c4) AGAINST('鄂A12345') or MATCH(c4) AGAINST('鄂A12346') or MATCH(c4) AGAINST('鄂A12347') or MATCH(c4) AGAINST('鄂A12348')) and c3 != 1;
explain select * from t1 where (((MATCH(c4) AGAINST('鄂A12345') or MATCH(c4) AGAINST('鄂A12346') or MATCH(c4) AGAINST('鄂A12347') or MATCH(c4) AGAINST('鄂A12348')) AND NOT c1 IN (5)) or (c1 in (5) and MATCH(c4) AGAINST('鄂A5'))) and c3 != 346 and c5 != '鄂A347';
--sorted_result
select * from t1 where (((MATCH(c4) AGAINST('鄂A12345') or MATCH(c4) AGAINST('鄂A12346') or MATCH(c4) AGAINST('鄂A12347') or MATCH(c4) AGAINST('鄂A12348')) AND NOT c1 IN (5)) or (c1 in (5) and MATCH(c4) AGAINST('鄂A5'))) and c3 != 346 and c5 != '鄂A347';

# 不走hint，代价估算
######4002bug
explain select a.c1,a.c3,b.c1 from t1 a inner join t1 b on a.c2 = b.c2 where a.c1 = 5 or (a.c3 < 390000 and MATCH(b.c4) AGAINST('鄂A1'));
select a.c1,a.c3,b.c1 from t1 a inner join t1 b on a.c2 = b.c2 where a.c1 = 5 or (a.c3 < 390000 and MATCH(b.c4) AGAINST('鄂A1'));
explain basic select * from t1 where (c2 < -199000 or c2 > 199000) and (c3 <> 10 or c1 < 5) and (MATCH(c4) AGAINST('鄂A1') or c1 in (2,3,4,9,10)) and (c5 = '鄂A142145' or c1 > 1);
explain select * from t1 where (c3 = 10 and c2 > -10000) or (MATCH(c4) AGAINST('鄂A12345 鄂A345') and c3 = 387655) or (c1 > 199999 and c3 = 1);
explain select * from t1 where (c1 < 500000 and c2 = -10000) or (MATCH(c4) AGAINST('鄂A12345 鄂A345 鄂A123345') and c2 = -187655) or (c3 >= 1 and c2 = 1);
--sorted_result
select * from t1 where (c1 < 500000 and c2 = -10000) or (MATCH(c4) AGAINST('鄂A12345 鄂A345 鄂A123345') and c2 = -187655) or (c3 >= 1 and c2 = 1);
explain select * from t1 where (MATCH(c4) AGAINST('鄂A12345') and c5 > '鄂A15' and c3 = 345) or (c2 < 5 and c2 > 1 and c3 = 4) or (c4 > '鄂A12345' and c2 = 5) or (c1 = 10000);
--sorted_result
select * from t1 where (MATCH(c4) AGAINST('鄂A12345') and c5 > '鄂A15' and c3 = 345) or (c2 < 5 and c2 > 1 and c3 = 4) or (c4 > '鄂A12345' and c2 = 5) or (c1 = 10000);

# 反向hint不生效
explain select /*+union_merge(t1 fidx4 primary)*/* from t1 where c1 = 3 or MATCH(c4) AGAINST('鄂A321314');

--disable_warnings
drop table if exists t1;
drop sequence if exists s1;
--enable_warnings

alter system set _enable_index_merge = false;