-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4], [t1.c5]), filter([t1.c2 = 1 OR t1.c3 = 1]), rowset=256
      access([t1.c1], [t1.c2], [t1.c3], [t1.c4], [t1.c5]), partitions(p0)
      is_index_back=true, is_global_index=false, use_index_merge=true, filter_before_indexback[false], 
      index_name: c2, range_cond([t1.c2 = 1]), filter(nil)
      index_name: c3, range_cond([t1.c3 = 1]), filter(nil)
      lookup_filter([t1.c2 = 1 OR t1.c3 = 1])
