drop table if exists t1;
drop sequence if exists s1;
set ob_query_timeout=30000000;
alter system set _enable_index_merge=true;
create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100), c5 varchar(100))
PARTITION BY RANGE(c1)
(
PARTITION p0 VALUES LESS THAN (100000),
PARTITION p1 VALUES LESS THAN (200000),
PARTITION p2 VALUES LESS THAN (300000),
PARTITION p3 VALUES LESS THAN MAXVALUE
);
create sequence s1 cache 1000000 order;
insert /*+enable_parallel_dml parallel(16) query_timeout(1000000000)*/ into t1 select s1.nextval, s1.currval-200000, s1.currval%1000, CONCAT('鄂A', s1.currval), CONCAT('鄂A', s1.currval%1000) from table(generator(400000));
create index c2 on t1(c2) local;
create index c3 on t1(c3) local;
create index cg3 on t1(c3) global;
create index c4 on t1(c4) local;
create FULLTEXT INDEX fidx4 ON t1(c4);
create index c5 on t1(c5) local;
create index c23 on t1(c2,c3) local;
call dbms_stats.gather_schema_stats(NULL);
alter system minor freeze;
explain select * from t1 where c2 = 1 or MATCH(c4) AGAINST('鄂A12345');
Query Plan
====================================================================
|ID|OPERATOR                    |NAME        |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------------
|0 |DISTRIBUTED INDEX MERGE SCAN|t1(c2,fidx4)|2       |349         |
====================================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4], [t1.c5]), filter([t1.c2 = 1 OR MATCH(t1.c4) AGAINST('鄂A12345')]), rowset=16
      access([t1.c1], [t1.c2], [t1.c4], [t1.c3], [t1.c5]), partitions(p[0-3])
      is_index_back=true, is_global_index=false, use_index_merge=true, filter_before_indexback[false], 
      index_name: c2, range_cond([t1.c2 = 1]), filter(nil)
      index_name: fidx4, range_cond(nil), filter(nil)
      lookup_filter([t1.c2 = 1 OR MATCH(t1.c4) AGAINST('鄂A12345')])
select * from t1 where c2 = 1 or MATCH(c4) AGAINST('鄂A12345');
c1	c2	c3	c4	c5
12345	-187655	345	鄂A12345	鄂A345
200001	1	1	鄂A200001	鄂A1
