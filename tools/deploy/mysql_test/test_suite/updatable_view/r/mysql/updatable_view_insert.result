| c1   | c2   | c3   |
+------+------+------+
|    1 |    3 |    1 |
|    1 |    3 |    1 |
|    1 |    3 |    1 |
|    2 |    3 |    2 |
|    2 |    3 |    2 |
+------+------+------+
delete from v;
select * from v order by c1, c2, c3;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
+------+------+------+

