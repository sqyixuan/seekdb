##partition table, with index
create table t(c1 int, c2 int, c3 int) partition by hash(c1);
create view v1 as select a.c1,a.c2,a.c3 from t a;
create view v2(vc1,vc2,vc3) as select c1,c2,c3 from t;
create view v3 as select c1,c2,c3 from t;
create view vv1(vvc1,vvc2) as select a.c1,a.c2 from v1 a;
create view vv2 as select vc1,vc2,vc3 from v2;
create view vv3 as select c1 from v3;
create index t_idx on t(c1) global;
create index t_idx1 on t(c1) partition by hash(c1);
create index t_idx2 on t(c1) global;
create index t_idx3 on t(c1) global partition by hash(c1);
