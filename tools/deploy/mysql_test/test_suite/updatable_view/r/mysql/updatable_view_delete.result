drop view vv;

drop table if exists t;
drop view if exists v1;
drop view if exists v2;
drop view if exists v3;
drop view if exists vv1;
drop view if exists vv2;
drop view if exists vv3;
create table t(c1 int, c2 int, c3 int, c4 int generated always as (c1+c2));
create view v1 as select a.c1,a.c2,a.c3,a.c4 from t a;
create view v2(vc1,vc2,vc3,vc4) as select c1,c2,c3,c4 from t;
create view v3 as select c1,c2,c3 from t;
create view vv1(vvc1,vvc2) as select a.c1,a.c2 from v1 a;
create view vv2 as select vc1,vc2,vc3 from v2;
create view vv3 as select c1 from v3;
insert into t(c1,c2,c3) values(1,1,1);
insert into v1(c1,c2,c3) values(2,2,2);
delete from v1;
insert into v2(vc1,vc2,vc3) values(3,3,3);
delete from v2;
insert into v3(c1,c2) values(4,4);
delete from v3;
insert into vv1(vvc1) values(5);
delete from vv1;
insert into vv2 values(6,6,6);
delete from vv2;
insert into vv3 values(7);
delete from vv3;
drop table t;
drop view v1;
drop view v2;
drop view v3;
drop view vv1;
drop view vv2;
drop view vv3;

