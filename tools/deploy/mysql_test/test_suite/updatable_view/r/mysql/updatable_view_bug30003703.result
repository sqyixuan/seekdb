drop table if exists table10_bigint;
CREATE TABLE `table10_bigint` (
`col_char_20_index` char(20) DEFAULT NULL,
`col_timestamp_6_index` timestamp(6) NULL DEFAULT NULL,
`col_char_20` char(20) DEFAULT NULL,
`pk` bigint(20) NOT NULL,
`col_bigint_index` bigint(20) DEFAULT NULL,
`col_bigint` bigint(20) DEFAULT NULL,
`col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
PRIMARY KEY (`pk`),
KEY `idx3` (`pk`, `col_char_20_index`) ,
KEY `idx5` (`pk`, `col_timestamp_6_index`) ,
KEY `idx1` (`pk`, `col_bigint_index`) 
) DEFAULT CHARSET = utf8mb4 ;
result_format: 4
UPDATE table10_bigint
SET col_bigint = col_bigint_index
WHERE ( col_bigint in ( 5398 ) OR  ( COALESCE( 123 , 36 , 99 ) <> col_bigint ) ) 
  AND ( col_bigint in ( 5398 ) OR col_char_20_index IS NOT NULL ) 
  OR NOT ( 0 BETWEEN 0 AND 0 )
ORDER BY col_char_20_index  , pk ASC LIMIT 193;

drop table table10_bigint;
