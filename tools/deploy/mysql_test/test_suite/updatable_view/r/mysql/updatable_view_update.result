result_format: 4
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists a;
drop table if exists b;
drop table if exists c;
drop view if exists v1;
drop view if exists v2;
drop view if exists v3;
drop view if exists v;
drop view if exists vv;
drop view if exists vvv;
create table t1 (c1 int primary key, c2 int, c3 int);
create table t2 (c1 int primary key, c2 int, c3 int);
insert into t1 (c1, c2, c3) values (1, 1, 1);
insert into t2 (c1, c2, c3) values (1, 1, 1);
create view v1 as select * from t1;
create view v2 as select t1.c1 c1, t1.c2 c2, t1.c3 c3, t2.c1 c4, t2.c2 c5, t2.c3 c6 from t1, t2 where t1.c1 = t2.c1;

create table a (a1 int primary key, a2 int, a3 int);
create table b (b1 int primary key, b2 int, b3 int);
create table c (c1 int primary key, c2 int, c3 int);

explain update v1 set c3 = 4;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |UPDATE           |    |1       |34          |
|1 |└─TABLE FULL SCAN|t1  |1       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      table_columns([{t1: ({t1: (t1.c1, t1.c2, t1.c3)})}]),
      update([t1.c3=column_conv(INT,PS:(11,0),NULL,4)])
  1 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(MIN ; MAX)always true
update v1 set c3 = 4;
select * from t1;
+----+------+------+
| c1 | c2   | c3   |
+----+------+------+
|  1 |    1 |    4 |
+----+------+------+

explain update v2 set c2 = 3 where c4 = 1;
