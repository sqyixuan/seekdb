| c1   | c2   | c3   | c4   |
+------+------+------+------+
|    1 |    0 |    0 |    1 |
+------+------+------+------+
update vv1 a,v2 b set a.vvc2=20,b.vc2 = 1;
select * from t1;
+------+------+------+------+
| c1   | c2   | c3   | c4   |
+------+------+------+------+
|   10 |   20 |    3 |   30 |
+------+------+------+------+
select * from t2;
+------+------+------+------+
| c1   | c2   | c3   | c4   |
+------+------+------+------+
|    1 |    1 |    0 |    2 |
+------+------+------+------+
