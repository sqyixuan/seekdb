create table t1(c1 int, c2 int, c3 int, c4 int generated always as (c1+c2));
create table t2(c1 int, c2 int, c3 int, c4 int generated always as (c1+c2));
create view v1 as select a.c1,a.c2,a.c3,a.c4 from t1 a;
create view v2(vc1,vc2,vc3,vc4) as select c1,c2,c3,c4 from t2;
create view vv1(vvc1,vvc2) as select a.c1,a.c2 from v1 a;
create view vv2 as select vc1,vc2,vc3,vc4 from v2;
insert into t1(c1,c2,c3) values(1,2,3);
insert into t2(c1,c2,c3) values(0,0,0);
update t1,vv2 set t1.c1=10,vv2.vc1 = 1;
select * from t1;
+------+------+------+------+
| c1   | c2   | c3   | c4   |
+------+------+------+------+
|   10 |    2 |    3 |   12 |
+------+------+------+------+
select * from t2;
