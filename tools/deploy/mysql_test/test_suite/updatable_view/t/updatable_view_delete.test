# owner: bin.lb
#tags: optimizer
# owner group: sql3
# description: updatable view

--result_format 4

--disable_warnings
drop table if exists t1; 
drop table if exists t2; 
drop view if exists v1; 
drop view if exists v2; 

drop table if exists a;
drop table if exists b;
drop table if exists c;
drop view if exists v;
drop view if exists vv;
drop view if exists vvv;
--enable_warnings

create table a (a1 int primary key, a2 int, a3 int);
create table b (b1 int primary key, b2 int, b3 int);
create table c (c1 int primary key, c2 int, c3 int);
create table t1 (c1 int primary key, c2 int, c3 int);
create table t2 (c1 int primary key, c2 int, c3 int);
insert into t1 (c1, c2, c3) values (1, 1, 1); 
insert into t2 (c1, c2, c3) values (1, 1, 1); 
create view v1 as select * from t1; 

delete from v1 where c1 = 2;
select * from t1;
delete from v1 where c1 = 1;
select * from v1;

### error code
# subquery in select list
create view v as select a1, a2, a3,  1 < (select 3 from dual limit 1) x from a;
delete from v;
drop view v;
create view v as select a1, a2, a3,  1 < (select a1 from dual) x from a;
--error 1288
delete from v;
drop view v;
create view v as select a1, a2, a3,  1 < (select a1 from a limit 1) x from a;
--error 1288
delete from v;
drop view v;

create view vv as select a1 from a limit 1;
create view v as select a1, a2, a3,  1 < (select * from vv) x from a;
delete from v;
drop view vv;
drop view v;

# group by
create view v as select a1, a2, a3, count(*) from a;
--error 1288
delete from v;
drop view v;

# distinct
create view v as select distinct a1, a2, a3 from a;
--error 1288
delete from v;
drop view v;

# set
create view v as select * from a union all select * from b;
--error 1288
delete from v;
drop view v;

# limit 
create view v as select * from a limit 2;
--error 1288
delete from v;
drop view v;

# join
create view v as select a.* from a, b;
--error 1395
delete from v;
drop view v;

# subquery in where is OK
create view vv as select max(c3) c3 from a, c where a2 = c2;
create view v as select a.* from a where a2 > (select * from vv);
delete from v;
drop view v;
drop view vv;

# generated column
--disable_warnings
drop table if exists t;
drop view if exists v1;
drop view if exists v2;
drop view if exists v3;
drop view if exists vv1;
drop view if exists vv2;
drop view if exists vv3;
--enable_warnings
create table t(c1 int, c2 int, c3 int, c4 int generated always as (c1+c2));
create view v1 as select a.c1,a.c2,a.c3,a.c4 from t a;
create view v2(vc1,vc2,vc3,vc4) as select c1,c2,c3,c4 from t;
create view v3 as select c1,c2,c3 from t;
create view vv1(vvc1,vvc2) as select a.c1,a.c2 from v1 a;
create view vv2 as select vc1,vc2,vc3 from v2;
create view vv3 as select c1 from v3;
insert into t(c1,c2,c3) values(1,1,1);
insert into v1(c1,c2,c3) values(2,2,2);
delete from v1;
insert into v2(vc1,vc2,vc3) values(3,3,3);
delete from v2;
insert into v3(c1,c2) values(4,4);
delete from v3;
insert into vv1(vvc1) values(5);
delete from vv1;
insert into vv2 values(6,6,6);
delete from vv2;
insert into vv3 values(7);
delete from vv3;
drop table t;
drop view v1;
drop view v2;
drop view v3;
drop view vv1;
drop view vv2;
drop view vv3;


##partition table, with index
--explain_protocol 1
--disable_result_log
--disable_query_log
create table t(c1 int, c2 int, c3 int) partition by hash(c1);
create view v1 as select a.c1,a.c2,a.c3 from t a;
create view v2(vc1,vc2,vc3) as select c1,c2,c3 from t;
create view v3 as select c1,c2,c3 from t;
create view vv1(vvc1,vvc2) as select a.c1,a.c2 from v1 a;
create view vv2 as select vc1,vc2,vc3 from v2;
create view vv3 as select c1 from v3;
create index t_idx on t(c1) global;
create index t_idx1 on t(c1) partition by hash(c1);
create index t_idx2 on t(c1) global;
create index t_idx3 on t(c1) global partition by hash(c1);
insert into v1 values(2, 1, 1);
select * from t;
--enable_result_log
--enable_query_log

delete from v1;
insert /*+ no_rewrite */ into v1 values(2, 1, 2);
delete /*+ no_rewrite */ from v1;
insert into v2 values(3, 1, 1);
delete from v2;
insert /*+ no_rewrite */ into v2 values(3, 1, 2);
delete /*+ no_rewrite */ from v2;
insert into v3 values(4, 1, 1);
delete from v3;
insert /*+ no_rewrite */ into v3 values(4, 1, 2);
delete /*+ no_rewrite */ from v3;
insert into vv1 values(5, 1);
delete from vv1;
insert /*+ no_rewrite */ into vv1 values(5, 2);
delete /*+ no_rewrite */ from vv1;
insert into vv2 values(6, 1, 1);
delete from vv2;
insert /*+ no_rewrite */ into vv2 values(6, 1, 2);
delete /*+ no_rewrite */ from vv2;
insert into vv3 values(7);
delete from vv3;
insert /*+ no_rewrite */ into vv3 values(7);
delete /*+ no_rewrite */ from vv3;
select * from t;

--disable_query_log
--disable_result_log

drop table t;
drop view v1;
drop view v2;
drop view v3;
drop view vv1;
drop view vv2;
drop view vv3;


##no partition table, with index
create table t(c1 int, c2 int, c3 int);
create view v1 as select a.c1,a.c2,a.c3 from t a;
create view v2(vc1,vc2,vc3) as select c1,c2,c3 from t;
create view v3 as select c1,c2,c3 from t;
create view vv1(vvc1,vvc2) as select a.c1,a.c2 from v1 a;
create view vv2 as select vc1,vc2,vc3 from v2;
create view vv3 as select c1 from v3;
create index t_idx on t(c1);
create index t_idx1 on t(c1) partition by hash(c1);
create index t_idx2 on t(c1) global;
create index t_idx3 on t(c1) global partition by hash(c1);
insert into v1 values(2, 1, 1);
select * from t;
--enable_query_log
--enable_result_log

delete from v1;
insert /*+ no_rewrite */ into v1 values(2, 1, 2);
delete /*+ no_rewrite */ from v1;
insert into v2 values(3, 1, 1);
delete from v2;
insert /*+ no_rewrite */ into v2 values(3, 1, 2);
delete /*+ no_rewrite */ from v2;
insert into v3 values(4, 1, 1);
delete from v3;
insert /*+ no_rewrite */ into v3 values(4, 1, 2);
delete /*+ no_rewrite */ from v3;
insert into vv1 values(5, 1);
delete from vv1;
insert /*+ no_rewrite */ into vv1 values(5, 2);
delete /*+ no_rewrite */ from vv1;
insert into vv2 values(6, 1, 1);
delete from vv2;
insert /*+ no_rewrite */ into vv2 values(6, 1, 2);
delete /*+ no_rewrite */ from vv2;
insert into vv3 values(7);
delete from vv3;
insert /*+ no_rewrite */ into vv3 values(7);
delete /*+ no_rewrite */ from vv3;
select * from t;

--disable_query_log
--disable_result_log

drop table t;
drop view v1;
drop view v2;
drop view v3;
drop view vv1;
drop view vv2;
drop view vv3;
