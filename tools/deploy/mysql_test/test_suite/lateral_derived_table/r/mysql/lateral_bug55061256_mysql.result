      equal_conds([tmp.c2 = v1.c1]), other_conds(nil)
  2 - output([v1.c1]), filter(nil), rowset=16
      access([v1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([v1.__pk_increment]), range(MIN ; MAX)always true
  3 - output([tmp.c2]), filter(nil), rowset=16
