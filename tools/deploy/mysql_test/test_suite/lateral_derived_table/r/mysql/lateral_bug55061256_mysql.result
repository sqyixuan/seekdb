drop table if exists tmp;
create table tmp(c1 int, c2 int);
insert into tmp values (1,1),(2,1),(3,2),(4,3);
explain_protocol: 2
result_format: 4
EXPLAIN select distinct v2.c2 from tmp v1 join lateral(select * from tmp where c2=v1.c1) v2 on 1=1;
