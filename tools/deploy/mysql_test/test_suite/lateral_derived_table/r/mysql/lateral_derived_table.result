drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t11;
drop table if exists t12;
drop view if exists v1;
create table t1(a int, b int);
insert into t1 (a) values(1),(2);
create table t2 select * from t1;
create table t3 (a int, b int);
insert into t3 values(1, 10), (1, 11), (2, 10), (2, 11);
CREATE TABLE t11 (t11a int, t11b int);
INSERT INTO t11 VALUES (99, NULL),(99, 3),(99,0);
CREATE TABLE t12 (t12a int, t12b int, KEY idx (t12b));
INSERT INTO t12 VALUES (100,0),(150,200),(999, 0),(999, NULL);
create table t4 (c1 int primary key, c2 int, c3 int, key t4c2 (c2));
insert into t4 values (1,1,1),(2,2,2),(3,3,3),(4,4,4);
explain_protocol: 2
result_format: 4
LATERAL
# prevents join buffer if materialized (but not if merged)
EXPLAIN select dt.a from t1, lateral (select t1.a from t2) dt;
Query Plan
===========================================================
|ID|OPERATOR                   |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------
|0 |NESTED-LOOP JOIN CARTESIAN |    |4       |5           |
|1 |├─TABLE FULL SCAN          |t1  |2       |3           |
|2 |└─MATERIAL                 |    |2       |3           |
|3 |  └─TABLE FULL SCAN        |t2  |2       |3           |
===========================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a]), filter(nil), rowset=16
      conds(nil), nl_params_(nil), use_batch=false
  1 - output([t1.a]), filter(nil), rowset=16
      access([t1.a]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output(nil), filter(nil), rowset=16
  3 - output(nil), filter(nil), rowset=16
      access(nil), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select dt.a from t1, lateral (select t1.a from t2) dt;
+------+
| a    |
+------+
|    1 |
|    1 |
|    2 |
|    2 |
+------+

# no right join
select dt.a from t1 right join lateral (select t1.a from t2) dt on 1;
ERROR 42S22: Unknown column 't1.a' in 'field list'

# no bad left join either
select dt.a from lateral (select t1.a from t2) dt left join t1 on 1;
ERROR 42S22: Unknown column 't1.a' in 'field list'

# more complex case
SELECT * FROM t1
LEFT JOIN
lateral (select t1.a) as dt ON t1.a=dt.a
RIGHT JOIN
lateral (select dt.a) as dt1 ON dt.a=dt1.a;
ERROR 42S22: Unknown column 'dt.a' in 'field list'

# LATERAL DT depending on LATERAL DT
EXPLAIN SELECT * FROM t1
JOIN
lateral (select t1.a) as dt ON t1.a=dt.a
JOIN
lateral (select dt.a) as dt1 ON dt.a=dt1.a;
Query Plan
===============================================
|ID|OPERATOR       |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------
|0 |TABLE FULL SCAN|t1  |2       |3           |
===============================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a], [t1.b], [t1.a], [t1.a]), filter([t1.a = t1.a]), rowset=16
      access([t1.a], [t1.b]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
SELECT * FROM t1
JOIN
lateral (select t1.a) as dt ON t1.a=dt.a
JOIN
lateral (select dt.a) as dt1 ON dt.a=dt1.a;
+------+------+------+------+
| a    | b    | a    | a    |
+------+------+------+------+
|    1 | NULL |    1 |    1 |
|    2 | NULL |    2 |    2 |
+------+------+------+------+

