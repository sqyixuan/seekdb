# Inside view
create view v1 as
 select t1.a as f1, dt.a as f2
 from t1, lateral (select t1.a+t2.a as a from t2) dt;
show create view v1;
View	Create View	character_set_client	collation_connection
v1	CREATE VIEW `v1` AS select `test`.`t1`.`a` AS `f1`,`dt`.`a` AS `f2` from `test`.`t1`,lateral (select (`test`.`t1`.`a` + `test`.`t2`.`a`) AS `a` from `test`.`t2`) `dt`	utf8mb4	utf8mb4_general_ci
