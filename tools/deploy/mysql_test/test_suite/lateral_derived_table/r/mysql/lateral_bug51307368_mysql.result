partition p9);
CREATE TABLE `v1`(c0 TEXT  COMMENT 'asdf' , c1 DATETIME , c2 DATETIME  NULL, c3 DATETIME   COMMENT 'asdf' )  PARTITION BY KEY(c3)  partitions 19;
explain_protocol: 2
result_format: 4
EXPLAIN SELECT distinct        concat(t1.c0, '') AS t1c0,        t1.c1 AS t1c1,        t1.c2 AS t1c2,        concat(L0.C0, '') AS L0C0,        concat(L0.C1, '') AS L0C1,        concat(L0.C2, '') AS L0C2,        concat(L0.C3, '') AS L0C3,        L0.C4 AS L0C4,        L0.C5 AS L0C5      FROM        t1,        LATERAL (         SELECT            ALL t2.c0 AS C0,            t2.c1 AS C1,            t2.c2 AS C2,            t1.c0 AS C3,            t1.c1 AS C4,            t1.c2 AS C5          FROM            t2          WHERE            (             NOT (t1.c2)           )          ORDER BY            concat(t2.c2, '') ASC       ) L0;
