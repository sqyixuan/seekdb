result_format: 4
# 单层子查询
SELECT students.student_name, scoress.score
FROM students,
(SELECT score AS score
FROM scores
WHERE scores.student_id = students.student_id) AS scoress;
ERROR 42S22: Unknown column 'students.student_id' in 'where clause'
EXPLAIN BASIC SELECT students.student_name, scoress.score
FROM students, LATERAL
(SELECT score AS score 
FROM scores
WHERE scores.student_id = students.student_id) AS scoress;
Query Plan
=====================================
|ID|OPERATOR               |NAME    |
-------------------------------------
|0 |EXCHANGE IN REMOTE     |        |
|1 |└─EXCHANGE OUT REMOTE  |        |
|2 |  └─MERGE JOIN         |        |
|3 |    ├─TABLE FULL SCAN  |students|
|4 |    └─SORT             |        |
|5 |      └─TABLE FULL SCAN|scores  |
=====================================
