# 环境清理
drop table scores;
drop table students;
CREATE TABLE students (
student_id BIGINT NOT NULL PRIMARY KEY,
student_name VARCHAR(50) NOT NULL,
class_id BIGINT NOT NULL,
major_id BIGINT NOT NULL
);
