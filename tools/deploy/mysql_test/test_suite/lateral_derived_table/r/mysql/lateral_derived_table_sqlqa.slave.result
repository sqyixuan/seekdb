# 嵌套查询
EXPLAIN BASIC SELECT s.student_name, s.class_id, m.major_name, sc.course_name, sc.score
FROM students s
LEFT JOIN LATERAL 
(SELECT class_name
FROM classes
WHERE classes.class_id = s.class_id) AS c ON TRUE
LEFT JOIN LATERAL 
(SELECT major_name
FROM majors
WHERE majors.major_id = s.major_id) AS m ON TRUE
LEFT JOIN LATERAL 
(SELECT course_name, score
FROM scores
WHERE scores.student_id = s.student_id
ORDER BY score DESC LIMIT 1) AS sc ON TRUE;
