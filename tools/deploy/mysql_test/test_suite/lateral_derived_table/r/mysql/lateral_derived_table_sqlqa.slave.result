SELECT s.student_name, c.class_name, m.major_name, sc.course_name, sc.score
FROM students s
LEFT JOIN 
(SELECT class_id, class_name AS class_name
FROM classes GROUP BY class_id) AS c ON s.class_id = c.class_id
LEFT JOIN 
(SELECT major_id, major_name AS major_name
FROM majors GROUP BY major_id) AS m ON s.major_id = m.major_id
LEFT JOIN LATERAL 
(SELECT course_name, score 
FROM scores
WHERE scores.student_id = s.student_id
ORDER BY score DESC LIMIT 1) AS sc ON TRUE
INNER JOIN 
(SELECT student_id, COUNT(*) AS num_courses
FROM scores
GROUP BY student_id 
HAVING COUNT(*) >= 1) AS nc ON s.student_id = nc.student_id
CROSS JOIN 
(SELECT AVG(score) AS avg_score
FROM scores) AS avg WHERE sc.score >= avg.avg_score
GROUP BY s.student_id, c.class_name, m.major_name
HAVING MAX(sc.score) >= 60
ORDER BY s.student_name ASC LIMIT 10;
