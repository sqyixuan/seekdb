# 多层子查询
SELECT students.student_name, max_score.score, max_score_customer.course_name
FROM students,
(SELECT MAX(score) AS score
FROM scores
WHERE scores.student_id = students.student_id) AS max_score,
(SELECT course_name
FROM scores
WHERE scores.student_id = students.student_id
AND scores.score = max_score.score) AS max_score_customer;
