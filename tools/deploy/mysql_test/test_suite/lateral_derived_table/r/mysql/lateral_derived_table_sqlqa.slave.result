drop table classes;
CREATE TABLE classes (
class_id BIGINT NOT NULL PRIMARY KEY,
class_name VARCHAR(50) NOT NULL
);
insert into classes values(2023,'2023届');
insert into classes values(2022,'2022届');
insert into classes values(2021,'2021届');
insert into classes values(2020,'2020届');
drop table majors;
CREATE TABLE majors (
major_id BIGINT NOT NULL PRIMARY KEY,
major_name VARCHAR(50) NOT NULL
);
insert into majors values(1052,'计!算@机#科学与技术类');
insert into majors values(1053,'汉^&语言文学');
insert into majors values(1054,'临床*&^医学');
insert into majors values(1055,'手(机贴)膜');
insert into majors values(1056,'考?/古');
drop table scores;
CREATE TABLE scores (
score_id BIGINT NOT NULL PRIMARY KEY,
course_name VARCHAR(50) NOT NULL,
student_id BIGINT NOT NULL,
score BIGINT NOT NULL,
FOREIGN KEY (student_id) REFERENCES students(student_id)
);
