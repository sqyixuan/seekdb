#owner:dingjincheng.djc
#owner group: sql1
#tags: optimizer,lateral

--disable_warnings
drop table if exists t0;
drop table if exists t1;
--enable_warnings

CREATE TABLE t0(c0 MEDIUMINT ZEROFILL  COMMENT 'asdf' , c1 DECIMAL(52, 0)  , c2 DECIMAL ZEROFILL   COMMENT 'asdf' )   PARTITION BY KEY (c2, c0)  ;
CREATE TABLE IF NOT EXISTS t1(c0 DECIMAL , c1 DATETIME  COMMENT 'asdf' , c2 FLOAT  COMMENT 'asdf' )  ;

--explain_protocol 2
--result_format 4

SELECT ALL concat(t0.c0,'') FROM t0, LATERAL (SELECT t1.c0 AS C0  FROM t1 WHERE (t1.c0) IS NULL GROUP BY concat(t0.c0,'')) L0 ;

SELECT ALL concat(t0.c0,'') FROM t0, LATERAL (SELECT t1.c0 AS C0, t1.c1 AS C1, t1.c2 AS C2, t0.c0 AS C3, t0.c1 AS C4, t0.c2 AS C5 FROM t1 WHERE (t1.c0) IS NULL GROUP BY t1.c0, t1.c1, concat(t1.c2,''), concat(t0.c0,''), t0.c1, concat(t0.c2,'') LIMIT 2147483647) L0 ;

drop table if exists t0;
drop table if exists t1;


