drop table t1;
CREATE TABLE t1 (
  id INT NOT NULL PRIMARY KEY,
  data JSON
);
INSERT INTO t1 (id, data) VALUES (1, '{"name": "Alice", "age": 20}');
INSERT INTO t1 (id, data) VALUES (2, '{"name": "Bob", "age": 25}');
INSERT INTO t1 (id, data) VALUES (3, '{"name": "Charlie", "age": 30}');

--error 0,1051
drop table t2;
CREATE TABLE t2 (
  id INT NOT NULL PRIMARY KEY,
  info JSON
);
INSERT INTO t2 (id, info) VALUES (1, '{"city": "New York", "country": "USA"}');
INSERT INTO t2 (id, info) VALUES (2, '{"city": "London", "country": "UK"}');
INSERT INTO t2 (id, info) VALUES (3, '{"city": "Paris", "country": "France"}');

--sorted_result
SELECT t1.id, 
       JSON_EXTRACT(t1.data, '$.name') AS name, 
       JSON_EXTRACT(t1.data, '$.age') AS age, 
       JSON_EXTRACT(t2.info, '$.city') AS city, 
       JSON_EXTRACT(t2.info, '$.country') AS country
FROM t1, 
LATERAL (SELECT info FROM t2 where t1.id = t2.id) AS t2;

drop table t1;
drop table t2;
