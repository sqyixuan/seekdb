-- echo # 单层子查询
--error 1054
SELECT students.student_name, scoress.score
FROM students,
(SELECT score AS score
FROM scores
WHERE scores.student_id = students.student_id) AS scoress;

--sorted_result
SELECT students.student_name, scoress.score
FROM students, LATERAL
(SELECT score AS score 
FROM scores
WHERE scores.student_id = students.student_id) AS scoress;

-- echo # order by asc
SELECT students.student_name, scoress.score
FROM students, LATERAL
(SELECT score AS score
FROM scores
WHERE scores.student_id = students.student_id) AS scoress order by score asc;

-- echo # order by desc
SELECT students.student_name, scoress.score
FROM students, LATERAL
(SELECT score AS score
FROM scores
WHERE scores.student_id = students.student_id) AS scoress order by score desc;

-- echo # limit
SELECT students.student_name, scoress.score
FROM students, LATERAL
(SELECT score AS score
FROM scores
WHERE scores.student_id = students.student_id) AS scoress limit 1;

-- echo # max
SELECT students.student_name, max_score.score
FROM students, LATERAL
(SELECT MAX(score) AS score
FROM scores
WHERE scores.student_id = students.student_id) AS max_score;

-- echo # min
SELECT students.student_name, min_score.score
FROM students, LATERAL
(SELECT min(score) AS score
FROM scores
WHERE scores.student_id = students.student_id) AS min_score;

-- echo # sum
SELECT students.student_name, sum_score.score
FROM students, LATERAL
(SELECT sum(score) AS score
FROM scores
WHERE scores.student_id = students.student_id) AS sum_score;

-- echo # avg
SELECT students.student_name, avg_score.score
FROM students, LATERAL
(SELECT avg(score) AS score
FROM scores
WHERE scores.student_id = students.student_id) AS avg_score;

-- echo # conut
SELECT students.student_name, conut_score.score
FROM students, LATERAL
(SELECT count(score) AS score
FROM scores
WHERE scores.student_id = students.student_id) AS conut_score;

-- echo # group by
--sorted_result
SELECT students.student_name, scoress.score
FROM students, LATERAL
(SELECT max(score) AS score
FROM scores
WHERE scores.student_id = students.student_id group by students.student_id) AS scoress;

-- echo # having
--sorted_result
SELECT student_name, subquery.score
FROM students, LATERAL 
(SELECT score
FROM scores
WHERE scores.student_id = students.student_id
ORDER BY score DESC) AS subquery
HAVING subquery.score >= 60
ORDER BY subquery.score DESC;

-- echo # any
--sorted_result
SELECT student_name, score 
FROM students ,LATERAL 
(SELECT score
FROM scores
WHERE scores.student_id = students.student_id
AND score > ANY (SELECT score FROM scores
WHERE student_id = students.student_id)) AS subquery;

--sorted_result
SELECT student_name, score 
FROM students 
JOIN LATERAL 
(SELECT score
FROM scores
WHERE scores.student_id = students.student_id
AND score >= ANY (SELECT score
FROM scores
WHERE student_id = students.student_id)) AS subquery ON TRUE;

