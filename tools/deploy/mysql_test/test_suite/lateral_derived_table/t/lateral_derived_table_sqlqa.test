-- echo #count
SELECT student_id, students.student_name, score.course_name, majorss.major_name
FROM students,
LATERAL
(SELECT COUNT(course_name) AS course_name
FROM scores
WHERE scores.student_id = students.student_id) AS score, 
LATERAL
(SELECT major_name 
FROM majors
WHERE majors.major_id = students.major_id) AS majorss
ORDER BY student_name;

-- echo # 嵌套查询
--sorted_result
SELECT s.student_name, s.class_id, m.major_name, sc.course_name, sc.score
FROM students s
LEFT JOIN LATERAL 
(SELECT class_name
FROM classes
WHERE classes.class_id = s.class_id) AS c ON TRUE
LEFT JOIN LATERAL 
(SELECT major_name
FROM majors
WHERE majors.major_id = s.major_id) AS m ON TRUE
LEFT JOIN LATERAL 
(SELECT course_name, score
FROM scores
WHERE scores.student_id = s.student_id
ORDER BY score DESC LIMIT 1) AS sc ON TRUE;

--sorted_result
SELECT s.student_name, c.class_name, m.major_name, sc.course_name, sc.score
FROM students s
LEFT JOIN classes c ON s.class_id = c.class_id
LEFT JOIN majors m ON s.major_id = m.major_id
LEFT JOIN LATERAL 
(SELECT course_name, score
FROM scores
WHERE scores.student_id = s.student_id
ORDER BY score DESC LIMIT 1) AS sc ON TRUE;

--sorted_result
SELECT s.student_name, c.class_name, m.major_name, sc.course_name, sc.score
FROM students s
LEFT JOIN 
(SELECT class_id, class_name AS class_name
FROM classes GROUP BY class_id) AS c ON s.class_id = c.class_id
LEFT JOIN 
(SELECT major_id, major_name AS major_name
FROM majors GROUP BY major_id) AS m ON s.major_id = m.major_id
LEFT JOIN LATERAL 
(SELECT course_name, score 
FROM scores
WHERE scores.student_id = s.student_id
ORDER BY score DESC LIMIT 1) AS sc ON TRUE
INNER JOIN 
(SELECT student_id, COUNT(*) AS num_courses
FROM scores
GROUP BY student_id 
HAVING COUNT(*) >= 1) AS nc ON s.student_id = nc.student_id
CROSS JOIN 
(SELECT AVG(score) AS avg_score
FROM scores) AS avg WHERE sc.score >= avg.avg_score
GROUP BY s.student_id, c.class_name, m.major_name
HAVING MAX(sc.score) >= 60
ORDER BY s.student_name ASC LIMIT 10;


