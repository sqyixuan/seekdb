#owner:dingjincheng.djc
#owner group: sql1
#tags: optimizer,lateral

--disable_warnings
drop table if exists t0;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

CREATE TABLE IF NOT EXISTS t0(c0 DATETIME   COMMENT 'asdf' , c1 DOUBLE(27, 0)  , c2 DOUBLE(15, 0)  NULL COMMENT 'asdf' ) ; #USE_BLOOM_FILTER =  FALSE  PARTITION BY KEY(c0)  SUBPARTITION BY KEY(c1)  subpartitions 10 partitions 13;
CREATE TABLE IF NOT EXISTS t1(c0 DATETIME   COMMENT 'asdf' , c1 DOUBLE(27, 0)  , c2 DOUBLE(15, 0)  NULL COMMENT 'asdf' ) ; #USE_BLOOM_FILTER =  FALSE  PARTITION BY KEY(c0)  SUBPARTITION BY KEY(c1)  subpartitions 10 partitions 13;
CREATE TABLE t2(c0 DECIMAL(23, 0)  COMMENT 'asdf' , c1 FLOAT  COMMENT 'asdf' , c2 TINYTEXT )  PARTITION BY KEY(c1)  partitions 3;
CREATE TABLE t3(c0 FLOAT  , c1 TINYTEXT , c2 TINYTEXT  COMMENT 'asdf'  NULL, c3 DECIMAL(27, 0) ZEROFILL  , c4 MEDIUMINT ZEROFILL  COMMENT 'asdf'  NULL) PARTITION BY HASH(c4)  SUBPARTITION BY KEY (c4) subpartitions 19 partitions 16;
--explain_protocol 2
--result_format 4
SELECT t0.c0 FROM  t0 LEFT OUTER JOIN t3 ON true,  t2 LEFT JOIN LATERAL (SELECT t0.c0 AS C0 FROM DUAL) L0 ON true WHERE t3.c1;

drop table if exists t0;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;


