#owner:dingjincheng.djc
#owner group: sql1
#tags: optimizer,lateral

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

CREATE TABLE `t1` (
  `c0` mediumint(76) unsigned zerofill DEFAULT NULL,
  `c1` int(155) unsigned zerofill DEFAULT NULL,
  `c2` int(213) unsigned zerofill DEFAULT NULL COMMENT 'asdf',
  KEY `i270` (`c0`, `c1`)
 );

CREATE TABLE `t2` (
  `c0` float(38,0) DEFAULT NULL,
  `c1` tinyint(58) DEFAULT NULL,
  `c2` datetime DEFAULT NULL COMMENT 'asdf',
  KEY `i660` (`c0`, `c2`)
);

--explain_protocol 2
--result_format 4

SELECT /*+ ORDERED USE_CONCAT  */  t1.c0 FROM t1, LATERAL (SELECT t1.c1 AS C4 FROM t2  GROUP BY t2.c1) L0 WHERE ((!t1.c1)) OR L0.C4;

drop table if exists t1;
drop table if exists t2;


