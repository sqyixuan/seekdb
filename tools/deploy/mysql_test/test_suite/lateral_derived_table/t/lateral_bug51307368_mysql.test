#owner group: sql1
#tags: optimizer,lateral

--disable_warnings
drop table if exists `t1`;
drop table if exists `t2`;
drop table if exists `v0`;
drop table if exists `v1`;
--enable_warnings

CREATE TABLE `t1` (
  `c0` double(31,0) unsigned zerofill DEFAULT NULL,
  `c1` mediumtext DEFAULT NULL,
  `c2` varchar(500) DEFAULT NULL,
  KEY `i870` (`c2`(2), `c1`(3), `c0`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'lz4_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by key(c2)
(partition p0);

CREATE TABLE `t2` (
  `c0` smallint(5) unsigned zerofill DEFAULT NULL,
  `c1` smallint(5) unsigned zerofill DEFAULT NULL,
  `c2` float(50,0) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'lz4_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 
 partition by key(c2, c1, c0)
(partition p0,
partition p1,
partition p2,
partition p3,
partition p4,
partition p5,
partition p6,
partition p7,
partition p8,
partition p9);

CREATE TABLE `v1`(c0 TEXT  COMMENT 'asdf' , c1 DATETIME , c2 DATETIME  NULL, c3 DATETIME   COMMENT 'asdf' )  PARTITION BY KEY(c3)  partitions 19;

--explain_protocol 2
--result_format 4

SELECT distinct        concat(t1.c0, '') AS t1c0,        t1.c1 AS t1c1,        t1.c2 AS t1c2,        concat(L0.C0, '') AS L0C0,        concat(L0.C1, '') AS L0C1,        concat(L0.C2, '') AS L0C2,        concat(L0.C3, '') AS L0C3,        L0.C4 AS L0C4,        L0.C5 AS L0C5      FROM        t1,        LATERAL (         SELECT            ALL t2.c0 AS C0,            t2.c1 AS C1,            t2.c2 AS C2,            t1.c0 AS C3,            t1.c1 AS C4,            t1.c2 AS C5          FROM            t2          WHERE            (             NOT (t1.c2)           )          ORDER BY            concat(t2.c2, '') ASC       ) L0;

(SELECT /*+ NO_REWRITE  */ L0.C0 FROM LATERAL (SELECT ALL v1.c0 AS C0, v1.c1 AS C1, v1.c2 AS C2, v1.c3 AS C3 FROM v1 WHERE (((-207158333) IS NOT TRUE) NOT IN (((CAST(v1.c2 AS SIGNED)) ^ (CAST('2023-08-01 18:29:37' AS SIGNED))), ("^m5JgnvE0%vR*0+(<l0ogV3j") XOR (NULL))) IS UNKNOWN GROUP BY v1.c0, v1.c1, v1.c2, v1.c3) L0, v1 WHERE (((v1.c2) IS UNKNOWN) = ((L0.C1) IS FALSE)) && ("-797003240")) UNION ALL (SELECT /*+ NO_REWRITE  */ L0.C0 FROM LATERAL (SELECT ALL v1.c0 AS C0, v1.c1 AS C1, v1.c2 AS C2, v1.c3 AS C3 FROM v1 WHERE (((-207158333) IS NOT TRUE) NOT IN (((CAST(v1.c2 AS SIGNED)) ^ (CAST('2023-08-01 18:29:37' AS SIGNED))), ("^m5JgnvE0%vR*0+(<l0ogV3j") XOR (NULL))) IS UNKNOWN GROUP BY v1.c0, v1.c1, v1.c2, v1.c3) L0, v1 WHERE (((v1.c2) IS UNKNOWN) = ((L0.C1) IS FALSE)) && ((! ("-797003240"))));

drop table if exists `t1`;
drop table if exists `t2`;
drop table if exists `v1`;

