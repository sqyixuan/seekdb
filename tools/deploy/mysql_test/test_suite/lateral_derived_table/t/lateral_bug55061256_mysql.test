#owner:dingjincheng.djc
#owner group: sql1
#tags: optimizer,lateral

--disable_warnings
drop table if exists tmp;
--enable_warnings

create table tmp(c1 int, c2 int);
insert into tmp values (1,1),(2,1),(3,2),(4,3);
--explain_protocol 2
--result_format 4

select distinct v2.c2 from tmp v1 join lateral(select * from tmp where c2=v1.c1) v2 on 1=1;
select /*+no_rewrite*/ distinct v2.c2 from tmp v1 join lateral(select * from tmp where c2=v1.c1) v2 on 1=1;

drop table if exists tmp;


