drop database  IF EXISTS  ob100x;
create database ob100x  character set utf8;
use ob100x;
select database();



--echo     mod-1-1  0个参数
--error    1064                   
SELECT MOD() FROM dual;

--echo     mod-1-2  1个参数
--error    1064               
SELECT MOD(500) FROM dual;


--echo     mod-1-3-1  整数和整数
SELECT MOD(1200, 500) FROM dual;


--echo     mod-1-3-2  整数和小数
SELECT MOD(100, 1.2) FROM dual;


--echo     mod-1-3-3  正数和负数
SELECT MOD(-1200, 500) FROM dual;


--echo     mod-1-3-4    整数和""  
SELECT MOD(1200, "") FROM dual;


--echo     mod-1-3-5    整数和null   
SELECT MOD(-1200, null) FROM dual;

--echo     mod-1-3-6   小数和小数
SELECT MOD(2.22, 1.1) FROM dual;


--echo    mod-1-3-7-1     整数和0      
SELECT MOD(1,0) FROM dual;
SELECT MOD(-5,0) FROM dual;

--echo    mod-1-3-7-2    小数和0        
SELECT MOD(2.22,0) FROM dual;
SELECT MOD(-2.22,0) FROM dual;

--echo    mod-1-3-7-3    参数都为0      
SELECT MOD(0,0) FROM dual;
SELECT MOD(0,'0') FROM dual;

--echo    mod-1-3-7-4    0和null            
SELECT MOD(0,null) FROM dual;
SELECT MOD(null,0) FROM dual;

--echo    mod-1-3-7-5   字符和null     
SELECT MOD('0',null) FROM dual;
SELECT MOD(null,'0') FROM dual;


--echo    mod-1-3-7-6    0和空             
SELECT MOD(0,'') FROM dual;
SELECT MOD(0,' ') FROM dual;



--echo     mod-1-4    三个参数
--error    1064    
SELECT MOD(10, 20,5) FROM dual;



--echo    mod-2-1-1    char               
drop   table  if  exists   emp;
drop   table  if  exists   emp;
create table EMP(a char(2));
insert into EMP values('10');
SELECT MOD('3', e.a) FROM EMP e;


