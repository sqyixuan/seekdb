insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7370, 'SMITH002', 'CLERK002', 7902, '7980-12-07',  900, 15, 10,2);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7371, 'SMITH003', 'CLERK003', 7902, '7980-12-07',  250, 25, 50,3);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7372, 'SMITH004', 'CLERK004', 7902, '7980-12-07',  100, 35, 30,4);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7373, 'SMITH005', 'CLERK005', 7902, '7980-12-07',  200, 45, 80,5);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7374, 'SMITH006', 'CLERK002', 7902, '7980-12-07',  300, 55, 10,6);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7375, 'SMITH007', 'CLERK003', 7902, '7980-12-07',  400, 65, 20,7);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7376, 'SMITH008', 'CLERK006', 7902, '7980-12-07',  500, null, 20,8);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7377, 'SMITH009', 'CLERK008', 7902, '7980-12-07',  600, 75, 30,9);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7378, 'SMITH010', 'CLERK009', 7902, '7980-12-07',  800, 95, 20,10);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7379, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, 20,11);


drop   table  if  exists   EMP001;                     
CREATE OR  REPLACE  VIEW EMP001 AS   SELECT  *    FROM   emp;

--echo   mod-4-1-1-1-1  select   
SELECT MOD(e.empno, e.sal)   eee   FROM EMP001 e   ORDER BY  eee;


--echo   mod-4-1-1-1-2  select嵌套 
select       MOD(MOD(e.empno,e.sal), MOD(e.empno,e.tno))  eee   from    EMP001 e   ORDER BY  eee;


--echo   mod-4-1-1-1-3    some,any,all
select empno,sal from EMP001  e    where sal > any(select  MOD(e.empno,e.tno)  from  EMP001);
select empno,sal from EMP001  e    where sal > some(select  MOD(e.empno,e.tno)  from  EMP001);
select empno,sal from EMP001  e    where sal > all(select  MOD(e.empno,e.tno)  from  EMP001);


--echo   mod-4-1-1-1-4    create as        
drop   table  if  exists   EMP002;
create TABLE    EMP002   as   SELECT    MOD(e.empno,e.sal)   eee   from    EMP e;
select  *    FROM    EMP002;


--echo   mod-4-1-1-2   where  语句    
select       MOD(MOD(e.empno,e.sal), MOD(e.empno,e.tno))    eee  from    EMP001 e  WHERE  e.sal > 200  ORDER BY  eee;


--echo   mod-4-1-1-3     order by 子句
select       MOD(MOD(e.empno,e.sal), MOD(e.empno,e.tno))   eee   from    EMP001 e      ORDER BY  eee;  



--echo   mod-4-1-1-4     group by   子句
select       MOD(MOD(e.empno,e.sal), MOD(e.empno,e.tno))   eee    from    EMP001 e    GROUP  BY   MOD(MOD(e.empno,e.sal), MOD(e.empno,e.tno))    ORDER BY  eee;



--echo   mod-4-1-1-5     group by  having   子句
select       MOD(MOD(e.empno,e.sal), MOD(e.empno,e.tno))   eee    from    EMP001 e    GROUP  BY   MOD(MOD(e.empno,e.sal), MOD(e.empno,e.tno))    HAVING  MOD(eee,3)<100    ORDER BY  eee;




--echo     mod-4-1-2-1   根据字段插入
insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (9000, 'SMITH', 'CLERK', 7902,  '1980-12-17', 800, null, MOD(100,30),1);
select  *    FROM    EMP001    e   WHERE   e.EMPNO=9000;



--echo     mod-4-1-2-2    根据表插入
insert into EMP001 values (8000, 'SMITH', 'CLERK', 7902,  '1980-12-17', 800, null, MOD(100,30),1);
select  *    FROM    EMP001    e   WHERE   e.EMPNO=8000;


--echo     mod-4-1-2-3    插入语句中使用嵌套
insert into EMP001 values (7000, 'SMITH', 'CLERK', 7902,  '1980-12-17', 800, null, MOD(MOD(110,30), MOD(100,30)),1);
select  *    FROM    EMP001    e   WHERE   e.EMPNO=7000;




--echo     mod-4-1-2-4    插入语句中使用嵌套语句
insert into EMP001 values (7000, 'SMITH', 'CLERK', 7902,  '1980-12-17', 800, null, (SELECT   MOD(MOD(110,30), MOD(100,30))   FROM dual),1);
select  *    FROM    EMP001    e   WHERE   e.EMPNO=7000;


--echo     mod-4-1-3-1   单列              
UPDATE    EMP001  e  SET    e.DEPTNO = MOD(110,30)    WHERE   e.EMPNO = 7369;
select  *    FROM    EMP001    e   WHERE   e.EMPNO=7369;


--echo     mod-4-1-3-2  多列      
UPDATE    EMP001  e  SET    e.DEPTNO = MOD(110,30);
select  *    FROM    EMP001    e   ORDER  BY e.EMPNO,e.TNO;


--echo     mod-4-1-4-1   单列              
DELETE  FROM     EMP001      WHERE   EMPNO = 7369;
select  *    FROM    EMP001        WHERE   EMPNO=7369;


--echo     mod-4-1-4-2  多列      
DELETE          FROM     EMP001;
select      count(*)     FROM    EMP001;

--echo    mod-4-1-5    多列
with e as (SELECT   MOD(e.empno,e.sal),MOD(e.empno,e.tno)  from    EMP001 e)  select * from e;

--echo    mod-4-1-6     CASE WHEN语句
SELECT   sum(empno),  COUNT (CASE WHEN  MOD(e.empno,e.sal) = 1 THEN 1 
                         ELSE       NULL      END) 数据A,         
                         COUNT (CASE WHEN MOD(e.empno,e.sal) = 2 THEN 1                      
                         ELSE       NULL       END) 数据B   
                         FROM EMP001 e   ORDER  BY MOD(e.empno,e.sal);



                        
