drop   table  if  exists   emp;
create   TABLE   EMP (empno int,ename VARCHAR(10),job VARCHAR(9),mgr int,hiredate DATE,
sal FLOAT(7,0),comm FLOAT(7,0),deptno int,tno int);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7369, 'SMITH001', 'CLERK001', 7902, '7980-12-07',  800, null, 20,1);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7370, 'SMITH002', 'CLERK002', 7902, '7980-12-07',  900, 15, 10,2);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7371, 'SMITH003', 'CLERK003', 7902, '7980-12-07',  250, 25, 50,3);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7372, 'SMITH004', 'CLERK004', 7902, '7980-12-07',  100, 35, 30,4);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7373, 'SMITH005', 'CLERK005', 7902, '7980-12-07',  200, 45, 80,5);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7374, 'SMITH006', 'CLERK002', 7902, '7980-12-07',  300, 55, 10,6);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7375, 'SMITH007', 'CLERK003', 7902, '7980-12-07',  400, 65, 20,7);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7376, 'SMITH008', 'CLERK006', 7902, '7980-12-07',  500, null, 20,8);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7377, 'SMITH009', 'CLERK008', 7902, '7980-12-07',  600, 75, 30,9);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7378, 'SMITH010', 'CLERK009', 7902, '7980-12-07',  800, 95, 20,10);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7379, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, 20,11);


--echo   mod-3-1-1-1  select   
SELECT MOD(e.empno, e.sal)   eee FROM EMP e   ORDER  BY   eee;


--echo   mod-3-1-1-2  select嵌套 
select       MOD(MOD(e.empno,e.sal), MOD(e.empno,e.tno))  eee FROM EMP e   ORDER  BY   eee;


--echo   mod-3-1-1-3    some,any,all
select empno,sal from EMP  e    where sal > any(select   MOD(e.empno,e.tno)   from   emp e  where  tno>9) ORDER  BY   e.EMPNO;
select empno,sal from EMP  e    where sal < some(select   MOD(e.empno,e.tno)   from   emp e  where  tno>9) ORDER  BY   e.EMPNO;
select empno,sal from EMP  e    where sal < all(select   MOD(e.empno,e.tno)   from   emp e  where  tno>9) ORDER  BY   e.EMPNO;




--echo   mod-3-1-1-4    create as        
drop   table  if  exists   EMP001;
DROP VIEW  if  exists   EMP001;
create TABLE    EMP001   as   SELECT    MOD(e.empno,e.sal)   eee   from    EMP e;
select  *    FROM    EMP001   ORDER BY  eee;


--echo   mod-3-1-2   where  语句    
select       MOD(MOD(e.empno,e.sal), MOD(e.empno,e.tno))   eee   from    emp e  WHERE  e.sal > 2000    ORDER  BY   eee;


--echo   mod-3-1-3     order by 子句
select       MOD(MOD(e.empno,e.sal), MOD(e.empno,e.tno))    from    emp e     order by   e.sal;



--echo   mod-3-1-4     group by   子句
select       MOD(MOD(e.empno,e.sal), MOD(e.empno,e.tno))   eee    from    emp e    GROUP  BY   MOD(MOD(e.empno,e.sal), MOD(e.empno,e.tno))   ORDER BY eee;



--echo   mod-3-1-5     group by  having   子句
select       MOD(MOD(e.empno,e.sal), MOD(e.empno,e.tno))  eee    from    emp e    GROUP  BY   MOD(MOD(e.empno,e.sal), MOD(e.empno,e.tno))    HAVING   MOD(eee,1) <100    ORDER BY eee;




--echo     mod-3-2-1   根据字段插入
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (9000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, 20,11);
select  *    FROM    EMP    e   WHERE   e.EMPNO=9000;



--echo     mod-3-2-2    根据表插入
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (8000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, 20,11);
select  *    FROM    EMP    e   WHERE   e.EMPNO=8000;


--echo     mod-3-2-3    插入语句中使用嵌套
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, 20,11);
select  *    FROM    EMP    e   WHERE   e.EMPNO=7000;


--echo     mod-3-2-4    插入语句中使用嵌套语句
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (6000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, (SELECT   MOD(MOD(110,30), MOD(100,30))   FROM dual),11);
select  *    FROM    EMP    e   WHERE   e.EMPNO=6000;


--echo     mod-3-3-1   单列              
UPDATE    EMP  e  SET    e.DEPTNO = MOD(110,30)    WHERE   e.EMPNO = 7369;
select  *    FROM    EMP    e   WHERE   e.EMPNO=7369;


--echo     mod-3-3-2  多列      
UPDATE    EMP  e  SET    e.DEPTNO = MOD(110,30);
select  *    FROM    EMP    e   ORDER  BY e.EMPNO,e.TNO;


--echo     mod-3-4-1   单列              
DELETE  FROM     EMP      WHERE   EMPNO = 7369;
select  *    FROM    EMP       WHERE   EMPNO=7369;


--echo     mod-3-4-2  多列      
DELETE          FROM     EMP;
select      count(*)     FROM    EMP;

--echo    mod-3-5    多列
with e as (SELECT   MOD(e.empno,e.sal),MOD(e.empno,e.tno)  from    emp e)  select * from e;

#mysql不支持    ob支持
--echo    mod-3-6     CASE WHEN语句
SELECT   sum(empno),  COUNT (CASE WHEN  MOD(e.empno,e.sal) = 1 THEN 1 
                         ELSE       NULL      END) 数据A,         
                         COUNT (CASE WHEN MOD(e.empno,e.sal) = 2 THEN 1                      
                         ELSE       NULL       END) 数据B   
                         FROM EMP e   ORDER  BY MOD(e.empno,e.sal);
                        
                                          

