mod-7-1-3    :包含 in 参数和 out 参数的存储过程,只能将一行的查询到的用户名赋值给username 
drop procedure if exists myproc3;
create procedure myproc3(in userId int, out username varchar(20))
begin
set username= userId;	
SELECT *  FROM emp d where  d.DEPTNO> username;		
end
//
--  调用时，传入查询的userid 和 全局变量 @username
call myproc3(mod(110,20),@username);
empno	ename	job	mgr	hiredate	sal	comm	deptno	tno
7370	SMITH002	CLERK002	7902	7980-12-07	900	15	20	2
7372	SMITH004	CLERK004	7902	7980-12-07	100	35	20	4
mod-7-1-4     包含 inout 参数的存储过程
drop procedure if exists myproc4;
create procedure myproc4(inout a int)
begin
SELECT     mod(a,3)     FROM emp  e;	
end
//
--  用户变量 （全局的变量）作用域： 用户变量: 在当前连接（即当前会话）中都有效
set @num =1000;
call  myproc4(@num);
mod(a,3)
1
1
1
1
1
SELECT     mod(@num,3)     FROM emp  e;
mod(@num,3)
1
1
1
1
1
mod-7-2-1 无参数的自定义函数
drop function  IF EXISTS salemp001;
CREATE FUNCTION salemp001(saller001 int) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;#定义局部变量并初始化
SELECT  mod(10,AVG(SAL)) INTO ag #为局部变量赋值
FROM emp e INNER JOIN dept d ON e.DEPTNO=d.DEPTNO where  e.sal >saller001 GROUP BY d.DEPTNO having d.DEPTNO>10;
RETURN ag;
end//
SELECT salemp001(100);
salemp001(100)
10
mod-7-2-2  自定义函数  有参数
drop function  IF EXISTS salemp001;
CREATE FUNCTION salemp001(saller001 int) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;#定义局部变量并初始化
SELECT  mod(AVG(SAL),10) INTO ag #为局部变量赋值
FROM emp e INNER JOIN dept d ON e.DEPTNO=d.DEPTNO where  e.sal >saller001 GROUP BY d.DEPTNO having d.DEPTNO>10;
RETURN ag;
end//
SELECT salemp001(100);
salemp001(100)
0
mod-7-2-3   自定义函数使用循环 
drop function  IF EXISTS salemp001;
CREATE FUNCTION salemp001(saller001 int) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;
DECLARE i INT DEFAULT 1;
WHILE i<=1000 DO
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (saller001+i*10, 'SMITH001', 'CLERK001', 7902, '7980-12-07',  800, null, mod(100,30),1);
SET i = i+1;
END WHILE;
SELECT  count(*)  into  ag   from   EMP;
RETURN ag;
end
//
SELECT salemp001(100);
salemp001(100)
1005
drop database  IF EXISTS  ob100x;
