## 名字超过128个字节,报错
--error 1059
create database _123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_12345678;

## 名字为128个字节
--disable_warnings
drop database if exists _123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_1234567;
drop database if exists `_123_a_`;
drop database if exists 123__a;
drop database if exists `数据库`;
drop database if exists `database`;
drop database if exists `中国人中国人中国人中国人中国人中国人中国人`;
drop database if exists `table`;
drop database if exists `default`;
--enable_warnings
create database _123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_123456789_1234567;



create database _123_a_ default character set utf8;

create database 123__a default character set utf8 collate utf8_bin;

#show databases;

## 名字包含特殊字符,报错
--error 1064
create database db_/b_1;

--error 1064
create database db_db1@a;

--error 1064
create database db 1;

# --error 1064
# create database db_数据库;

--error 1064
create database db_'dababase'%(mydb)@#;

#show databases;

## database 识别符

## database名字是中文
create database `数据库`;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database `数据库`;
use `数据库`;
create table `表1` (c1 int primary key, index i_1(c1));
insert into  `表1` values(1),(2),(3);
select * from `表1`;

# TODO(nijia.nj):open it after fix bug
