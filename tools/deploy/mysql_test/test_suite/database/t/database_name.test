#create database `中国人中国人中国人中国人中国人中国人中国人中`;
create database `中国人中国人中国人中国人中国人中国人中国人`;
use `中国人中国人中国人中国人中国人中国人中国人`;

#show databases;

## database名字是关键字

create database `database`;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database `database`;
use `database`;
create table `table` (c1 int primary key, index i_1(c1));
insert into `table` values(1),(2),(3);
select * from `table`;

create database `table` default character set utf8mb4;
use `table`;

create database `default` default character set utf8;
use `default`;

