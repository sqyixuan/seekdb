## 3.语法错误
--error 1064
drop database if exist db_1;

--error 1064
drop database db_1, db_2;

--error 1064
drop database db_1 if exists;

## 4.在一个数据库内,访问另一个数据库的表，失败

use db_1;
select * from t_1;

--error 1146
select * from t_2;

drop database db_3;
--error 1049
show create database db_3;

## 5. database引用
select * from db_1.t_1;
select * from db_2.t_1;
select * from db_2.t_2 where db_2.t_2.c1=1;
delete from  db_2.t_1 where db_2.t_1.c1>2;

select count(*) from db_2.t_1;

drop table db_1.t_1;

let $count=10;
while($count>0)
{
  eval create database test_$count default character set=utf8 default collate= utf8_bin replica_num=1;
  eval drop database test_$count;
  dec $count;
}


