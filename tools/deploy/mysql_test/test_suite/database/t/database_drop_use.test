## 1.删除不存在的database
--disable_warnings
drop database if exists db_1;
drop database if exists db_2;
drop database if exists db_3;
--enable_warnings

--error 1008
drop database db_1;

## 2.删除存在的database
create database db_1
  default character set = utf8
  collate = utf8_bin;

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database db_1;

use db_1;
create table t_1(c1 int primary key, c2 char(20), c3 int, index i_1(c1, c2), unique index i_2(c3));
create index i_3 on t_1(c1, c2, c3);
create unique index i_4 on t_1(c3);
insert into t_1 values(1,1,1),(2,2,2);

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_1;

create database db_2
  default character set = utf8mb4
  collate = utf8mb4_bin
  replica_num = 1;

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database db_2;

use db_2;
create table t_1(c1 int primary key, c2 char(20), c3 int, index i_1(c1, c2), unique index i_2(c3));
create index i_3 on t_1(c1, c2, c3);
create unique index i_4 on t_1(c3);
insert into t_1 values(1,1,1),(2,2,2),(3,3,3);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_1;

create table t_2(c1 int primary key, c2 char(20), index i_1(c1, c2), unique index i_2(c1));
insert into t_2 values(1,1);

create database db_3;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database db_3;

