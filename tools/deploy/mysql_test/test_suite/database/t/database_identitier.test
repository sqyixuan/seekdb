## 表使用database识别符
--disable_warnings
create database if not exists bm_3;
--enable_warnings
use bm_3;

create table bm_3.t_3(c1 int primary key);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table bm_3.t_3;

insert into bm_3.t_3 values(1),(2);
select * from bm_3.t_3 ;

alter table bm_3.t_3 alter column c1 set default 1;
connection con1;
alter table bm_3.t_3 alter column c1 set default 2;
connection con1;

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_3;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table bm_3.t_3;

drop table bm_3.t_3;
show tables;

show databases;

## 清理环境
