connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

--disable_query_log
call oceanbase.drop_tenant_force('tenant1');
--enable_query_log

#--replace_column 1 gmt_create 2 gmt_modified 3 tenant_id 4 database_id 6 1 7 zone1;zone2 8 primary_zone
#select * from oceanbase.__all_virtual_database order by tenant_id;
disconnect obsys;
connection default;
