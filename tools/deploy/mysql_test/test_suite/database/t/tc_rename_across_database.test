--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : dachuan.sdc
#owner group : sql2
#--disable_abort_on_error
--disable_warnings
DROP DATABASE IF EXISTS hualong;
--enable_warnings
CREATE DATABASE hualong;
USE hualong;
--disable_warnings
DROP TABLE IF EXISTS t1,t2,t3;
--enable_warnings

CREATE TABLE t1(c1 INTEGER, primary key(c1));
CREATE TABLE t2(c1 INTEGER, primary key(c1));
#rename table t2 to n2;

alter table t2 rename to n2;

--source mysql_test/include/show_create_table_old_version.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table n2;
show tables;
--disable_warnings
DROP DATABASE IF EXISTS d1;
--enable_warnings
CREATE DATABASE d1;
CREATE TABLE d1.t2(c1 INTEGER, primary key(c1));

--source mysql_test/include/show_create_table_old_version.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1; 
--source mysql_test/include/show_create_table_old_version.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table d1.t2;

alter table t1 rename to d1.t3;
alter table d1.t2 rename to r1;

SHOW TABLES; 

USE d1;
SHOW TABLES; 

--source mysql_test/include/show_create_table_old_version.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t3; 

DROP TABLE hualong.n2;
drop table hualong.r1;

SHOW TABLES;
DROP DATABASE d1;
DROP DATABASE hualong;
