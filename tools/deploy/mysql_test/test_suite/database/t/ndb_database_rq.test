--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : dachuan.sdc
#owner group : sql2
#--disable_abort_on_error

use test;

--disable_warnings
drop database if exists mysqltest;
--enable_warnings

create database mysqltest;
create table mysqltest.t1 (a int primary key, b int);
use mysqltest;
show tables;

drop database mysqltest;
create database mysqltest;
use mysqltest;
show tables;

drop database mysqltest;

create database `mysqltest.db`;
create table `mysqltest.db`.t1 (a int primary key, b int);
drop table `mysqltest.db`.t1;
drop database `mysqltest.db`;

create database newdb;
create table newdb.t1 (a int primary key) ;

--disable_warnings
drop table if exists newdb.t1;
--enable_warnings

create table newdb.t1 (a int primary key,
                       b1  int,
                       b2  int,
                       b3  int,
                       b4  int,
                       b5  int,
                       b6  int,
                       b7  int,
                       b8  int,
                       b9  int,
                       b10 int,
                       b11 int,
                       b12 int,
                       b13 int,
                       b14 int,
                       b15 int,
                       b16 int,
                       b17 int,
                       b18 int,
                       b19 int,
                       b20 int,
                       b21 int,
                       b22 int,
                       b23 int,
                       b24 int,
                       b25 int,
                       b26 int,
                       b27 int,
                       b28 int,
                       b29 int);

drop database newdb;
create database newdb;
use newdb;
show tables;
create table newdb.t1(a int primary key);
show tables;
drop table t1;
drop database newdb;
