#结果不稳定，受其它case影响
# --replace_column 1 gmt_create 2 gmt_modified 3 tenant_id 4 database_id 7 zone1;zone2 8 primary_zone
# select * from oceanbase.__all_virtual_database where in_recyclebin = 0 order by tenant_id, database_id;
--enable_warnings
--disable_warnings
drop database if exists shanting;
--enable_warnings
--error ER_CONFLICTING_DECLARATIONS
create database shanting charset utf8 charset utf16;
--error ER_COLLATION_CHARSET_MISMATCH
create database shanting charset utf8 collate utf16_bin;
--error ER_CONFLICTING_DECLARATIONS
create database shanting collate utf8_bin charset utf16;
--error ER_COLLATION_CHARSET_MISMATCH
create database shanting collate utf8_bin collate utf16_bin;
create database shanting collate utf8_bin;
use shanting;
show variables like 'character_set_database';
show variables like 'collation_database';
--error ER_CONFLICTING_DECLARATIONS
alter database shanting charset utf8 charset utf16;
--error ER_COLLATION_CHARSET_MISMATCH
alter database shanting charset utf8 collate utf16_bin;
--error ER_CONFLICTING_DECLARATIONS
alter database shanting collate utf8_bin charset utf16;
--error ER_COLLATION_CHARSET_MISMATCH
alter database shanting collate utf8_bin collate utf16_bin;

alter database shanting charset utf16;
## 改完当前session立即生效
show variables like 'character_set_database';
show variables like 'collation_database';
alter database shanting collate gbk_chinese_ci;
show variables like 'character_set_database';
show variables like 'collation_database';

## 包含多个不冲突的charset/collation以最后一个为准
alter database shanting charset utf16 collate utf16_bin;
show variables like 'character_set_database';
show variables like 'collation_database';
drop database shanting;

disconnect obsys;
connection default;
