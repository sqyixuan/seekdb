--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : dachuan.sdc
#owner group : sql2
#description:this case is use for
#--disable_abort_on_error
let $unit1 = unit_1;
let $pool1 = pool_1;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $zone1 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 2, zone, 1); 
let $zone2 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 2, zone, 2); 

--disable_warnings
drop tenant if exists tenant1 force;

--disable_query_log
#eval CREATE RESOURCE UNIT if not exists $unit1 MAX_CPU=1, MEMORY_SIZE='2G';
#--disable_query_log
#--echo create resource pool $pool1
#eval create resource pool if not exists $pool1 unit='$unit1', unit_num = 1, zone_list = ('$zone1', '$zone2');
#--echo create tanant tenant1
#eval create tenant tenant1 resource_pool_list=('$pool1'), replica_num=2, zone_list=('$zone1','$zone2'),primary_zone='$zone1' set ob_tcp_invited_nodes='%';
--enable_query_log
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_warnings
disconnect obsys;
connection default;
connect (conn1,$OBMYSQL_MS0,root,,*NO-ONE*,$OBMYSQL_PORT);
select effective_tenant();

## 1.创建正常的数据库,属性全为默认值
--disable_warnings
drop database  if exists db_1;
--enable_warnings
create database db_1 ;

## 2.创建数据库，指定charset utf8, collate utf8_bin
--disable_warnings
drop database if exists db_2;
--enable_warnings
create database db_2
  default character set = utf8
  collate = utf8_bin
  replica_num = 2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database db_2;

## 3.创建数据库，指定charset utf8, collate utf8_general_ci
--disable_warnings
drop database if exists db_3;
--enable_warnings
create database db_3
  default character set = utf8
  collate = utf8_general_ci
  replica_num = 2;

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database db_3;

