## 8.创建正常的数据库，指定charset binary, collate binary
--disable_warnings
drop database if exists db_8;
--enable_warnings
create database db_8 default character set = binary collate = 'binary' replica_num = 2;

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database db_8;

--disable_warnings
drop database if exists db_9;
--enable_warnings
--error ER_COLLATION_CHARSET_MISMATCH
create database db_9 default character set = utf8 collate = 'binary';
#--error ER_COLLATION_CHARSET_MISMATCH
#create database db_9 default character set = utf8 collate = utf8mb4_bin;
#--error ER_COLLATION_CHARSET_MISMATCH
#create database db_9 default character set = utf8 collate = utf8mb4_general_ci;
--error ER_COLLATION_CHARSET_MISMATCH
create database db_9 default character set = binary collate = utf8mb4_bin;
--error ER_COLLATION_CHARSET_MISMATCH
create database db_9 default character set = binary collate = utf8mb4_general_ci;
--error ER_COLLATION_CHARSET_MISMATCH
create database db_9 default character set = binary collate = utf8_bin;
--error ER_COLLATION_CHARSET_MISMATCH
create database db_9 default character set = binary collate = utf8mb4_general_ci;
--error ER_COLLATION_CHARSET_MISMATCH
create database db_9 default character set = utf8mb4 collate = 'binary';
#--error ER_COLLATION_CHARSET_MISMATCH
#create database db_9 default character set = utf8mb4 collate = utf8_bin;
#--error ER_COLLATION_CHARSET_MISMATCH
#create database db_9 default character set = utf8mb4 collate = utf8_general_ci;

#show databases;

## ex. 测试修改数据库字符集语法
## 现在完全支持修改数据库字符集的语法，但暂时不支持该功能
--disable_warnings
drop database if exists db_xiaofeng;
--enable_warnings
create database db_xiaofeng;
use db_xiaofeng;
alter database character set utf8mb4;
alter database collate utf8mb4_bin;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database db_xiaofeng;
alter database db_xiaofeng character set utf8mb4;
alter database db_xiaofeng collate utf8mb4_bin;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database db_xiaofeng;
alter database db_xiaofeng character set = utf8mb4;
alter database db_xiaofeng collate = utf8mb4_bin;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database db_xiaofeng;

## 9.验证表与database的charset/collate一致

use db_1;
create table t_1(c1 varchar(20) primary key, c2 int, index i_1(c1, c2), unique key(c2));
create index i_2 on t_1(c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_1;
insert into t_1 values('t', 1);
--error 1062
insert into t_1 values('T', 1);


use db_2;
create table t_1(c1 varchar(20) primary key, c2 int, index i_1(c1, c2), unique key(c2));
create index i_2 on t_1(c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_1;
insert into t_1 values('t', 1);
--error 1062
insert into t_1 values('T', 1);

use db_3;
create table t_1(c1 varchar(20) primary key, c2 int, index i_1(c1, c2), unique key(c2));
create index i_2 on t_1(c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_1;
insert into t_1 values('t', 1);
--error 1062
insert into t_1 values('T', 1);

use db_5;
create table t_1(c1 varchar(20) primary key, c2 int, index i_1(c1, c2), unique key(c2));
create index i_2 on t_1(c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_1;
insert into t_1 values('t', 1);
--error 1062
insert into t_1 values('T', 1);

use db_6;
create table t_1(c1 varchar(20) primary key, c2 int, index i_1(c1, c2), unique key(c2));
create index i_2 on t_1(c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_1;
insert into t_1 values('t', 1);
--error 1062
insert into t_1 values('T', 1);

