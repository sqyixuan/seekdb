alter system set workarea_size_policy = 'manual';
show parameters like 'workarea_size_policy';
zone	svr_type	svr_ip	svr_port	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
#	observer	#	#	workarea_size_policy	STRING	manual	policy used to size SQL working areas (MANUAL/AUTO)	TENANT	TENANT	DEFAULT	DYNAMIC_EFFECTIVE	AUTO	0
alter system set workarea_size_policy = 'auto';
show parameters like 'workarea_size_policy';
zone	svr_type	svr_ip	svr_port	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
#	observer	#	#	workarea_size_policy	STRING	auto	policy used to size SQL working areas (MANUAL/AUTO)	TENANT	TENANT	DEFAULT	DYNAMIC_EFFECTIVE	AUTO	1
