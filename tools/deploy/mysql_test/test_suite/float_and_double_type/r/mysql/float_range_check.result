create table t1 (is_neg int, c1 float, c2 float, c3 float, c4 float);
insert into t1 values (0, 111, 11111111111, 11111111111, 111111111111111111111111111111111111);
insert into t1 values (1, -111, -11111111111, -11111111111, -111111111111111111111111111111111111);
select cast(c1 as decimal(4,2)), cast(c2 as decimal(15,5)), cast(c3 as decimal(20,10)), cast(c1 as decimal(65,30)) from t1;
+--------------------------+---------------------------+----------------------------+-------------------------------------+
| cast(c1 as decimal(4,2)) | cast(c2 as decimal(15,5)) | cast(c3 as decimal(20,10)) | cast(c1 as decimal(65,30))          |
+--------------------------+---------------------------+----------------------------+-------------------------------------+
|                    99.99 |          9999999999.99999 |      9999999999.9999999999 |  111.000000000000000000000000000000 |
|                   -99.99 |         -9999999999.99999 |     -9999999999.9999999999 | -111.000000000000000000000000000000 |
+--------------------------+---------------------------+----------------------------+-------------------------------------+

create table t2 (c1 decimal(4, 2), c2 decimal(15, 5), c3 decimal(20, 10), c4 decimal(65, 30));
insert into t2 select c1, c2, c3, c4 from t1 where is_neg = 0;
ERROR 22003: Out of range value for column 'c1' at row 1
insert into t2 select c1, c2, c3, c4 from t1 where is_neg = 1;
ERROR 22003: Out of range value for column 'c1' at row 1
set sql_mode = '';
insert into t2 select c1, c2, c3, c4 from t1 where is_neg = 0;
insert into t2 select c1, c2, c3, c4 from t1 where is_neg = 1;
select * from t2;
+--------+-------------------+------------------------+---------------------------------------------------------------------+
| c1     | c2                | c3                     | c4                                                                  |
+--------+-------------------+------------------------+---------------------------------------------------------------------+
|  99.99 |  9999999999.99999 |  9999999999.9999999999 |  99999999999999999999999999999999999.999999999999999999999999999999 |
| -99.99 | -9999999999.99999 | -9999999999.9999999999 | -99999999999999999999999999999999999.999999999999999999999999999999 |
+--------+-------------------+------------------------+---------------------------------------------------------------------+
drop table t1,t2;

drop database mysql_float;
