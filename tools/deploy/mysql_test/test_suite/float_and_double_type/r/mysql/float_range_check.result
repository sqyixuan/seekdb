drop table t_float_range;
SET sql_mode = 'STRICT_ALL_TABLES';
CREATE TABLE t_float_range (
    c1 FLOAT(10,2)
);
INSERT INTO t_float_range (c1) VALUES (99999999.99);
INSERT INTO t_float_range (c1) VALUES (99999999.999);
ERROR 22003: Out of range value for column 'c1' at row 1
