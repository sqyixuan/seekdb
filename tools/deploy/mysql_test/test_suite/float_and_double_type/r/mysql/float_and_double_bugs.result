explain select * from t1 join t2 on t1.c1 = t2.c2;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |HASH JOIN        |    |1       |5           |
|1 |├─TABLE FULL SCAN|t1  |1       |3           |
|2 |└─TABLE FULL SCAN|t2  |1       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t2.c2]), filter(nil), rowset=16
      equal_conds([cast(t1.c1, DOUBLE(-1, -1)) = cast(t2.c2, DOUBLE(-1, -1))]), other_conds(nil)
  1 - output([t1.c1]), filter(nil), rowset=16
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([t2.c2]), filter(nil), rowset=16
      access([t2.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select * from t1 join t2 on t1.c1 = t2.c2;
+------+------+
| c1   | c2   |
+------+------+
| 0.00 | 0.00 |
+------+------+

