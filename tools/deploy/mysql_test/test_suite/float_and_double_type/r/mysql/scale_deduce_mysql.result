    stddev(f_10_2), stddev(d_12_3),
    stddev(f_60_10), stddev(d_60_11),
    stddev(f_255_30), stddev(d_255_30),
    stddev(dec_15_3), stddev(dec_40_30)
from t1;
desc td;
