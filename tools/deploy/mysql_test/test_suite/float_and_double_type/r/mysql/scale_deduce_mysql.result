result_format: 4
drop database if exists mysql_double_md;
create database mysql_double_md;
use mysql_double_md;

create table t1(
    f           float,
    d           double,
    f_10_2      float(10, 2),
    d_12_3      double(12, 3),
    f_60_10     float(60, 10),
    d_60_11     double(60, 11),
    f_255_30    float(255, 30),
    d_255_30    double(255, 30),
    dec_15_3    decimal(15, 3),
    dec_40_30   decimal(40, 30)
);

##add
create table td as select
    f + f,
    f + d,
    f + f_10_2,
    f + d_12_3,
    f + f_60_10,
    f + d_60_11,
    f + f_255_30,
    f + d_255_30,
    f + dec_15_3,
    f + dec_40_30,
    d + d,
    d + f_10_2,
    d + d_12_3,
    d + f_60_10,
    d + d_60_11,
    d + f_255_30,
    d + d_255_30,
    d + dec_15_3,
    d + dec_40_30
from t1;
desc td;
+---------------+--------+------+-----+---------+-------+
| Field         | Type   | Null | Key | Default | Extra |
+---------------+--------+------+-----+---------+-------+
| f + f         | double | YES  |     | NULL    |       |
| f + d         | double | YES  |     | NULL    |       |
| f + f_10_2    | double | YES  |     | NULL    |       |
| f + d_12_3    | double | YES  |     | NULL    |       |
| f + f_60_10   | double | YES  |     | NULL    |       |
| f + d_60_11   | double | YES  |     | NULL    |       |
| f + f_255_30  | double | YES  |     | NULL    |       |
| f + d_255_30  | double | YES  |     | NULL    |       |
| f + dec_15_3  | double | YES  |     | NULL    |       |
| f + dec_40_30 | double | YES  |     | NULL    |       |
| d + d         | double | YES  |     | NULL    |       |
| d + f_10_2    | double | YES  |     | NULL    |       |
| d + d_12_3    | double | YES  |     | NULL    |       |
| d + f_60_10   | double | YES  |     | NULL    |       |
| d + d_60_11   | double | YES  |     | NULL    |       |
| d + f_255_30  | double | YES  |     | NULL    |       |
| d + d_255_30  | double | YES  |     | NULL    |       |
| d + dec_15_3  | double | YES  |     | NULL    |       |
| d + dec_40_30 | double | YES  |     | NULL    |       |
+---------------+--------+------+-----+---------+-------+
drop table td;

