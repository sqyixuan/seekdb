# owner: zuojiao.hzj
# owner group: sql2
# tags: float,double
# description: test mysql float/doubel scale deduce
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists mysql_double_md;
--enable_warnings

create database mysql_double_md;
use mysql_double_md;

--echo ##constant compare
create table t1(c1 float(10, 2));
insert into t1 values (1.23);
select * from t1 where c1 = 1.23;
select * from t1 where c1 = 1.2;
select * from t1 where c1 = 1.231;
select * from t1 where c1 = 1.230;
select * from t1 where c1 = 1.23000000;
select * from t1 where c1 = 1.2300000;
drop table t1;

create table t1(c1 double(10, 2));
insert into t1 values (1.23);
select * from t1 where c1 = 1.23;
select * from t1 where c1 = 1.2;
select * from t1 where c1 = 1.231;
select * from t1 where c1 = 1.230;
select * from t1 where c1 = 1.23000000;
select * from t1 where c1 = 1.2300000;
drop table t1;

--echo ##column compare
create table t1 (c1 float(10, 2));
create table t2 (c1 float(14, 4));
insert into t1 values (1.23), (1.24);
insert into t2 values (1.24), (1.25);
explain select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
drop table t1, t2;

create table t1 (c1 double(10, 2));
create table t2 (c1 double(14, 4));
insert into t1 values (1.23), (1.24);
insert into t2 values (1.24), (1.25);
explain select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
drop table t1, t2;

create table t1 (c1 float(10, 2));
create table t2 (c1 double(14, 4));
insert into t1 values (1.23), (1.24);
insert into t2 values (1.24), (1.25);
explain select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
drop table t1, t2;

--echo ##bound
create table t1 (c1 float(255, 30));
create table t2 (c1 float(255, 30));
insert into t1 values (1.23), (1.24);
insert into t2 values (1.24), (1.25);
select * from t1;
select * from t2;
explain select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
explain select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
drop table t1, t2;

create table t1 (c1 float(255, 30));
create table t2 (c1 float(255, 30));
insert into t1 values (1.23), (1.24);
insert into t2 values (1.24), (1.25);
select * from t1;
select * from t2;
explain select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
explain select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
drop table t1, t2;

create table t1 (c1 float(255, 30));
create table t2 (c1 double(255, 30));
insert into t1 values (1.23), (1.24);
insert into t2 values (1.24), (1.25);
select * from t1;
select * from t2;
explain select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
explain select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
drop table t1, t2;

create table t1 (c1 float(255, 0));
create table t2 (c1 float(255, 0));
insert into t1 values (1.23), (1.24);
insert into t2 values (1.24), (1.25);
select * from t1;
select * from t2;
explain select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
explain select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
drop table t1, t2;

create table t1 (c1 float(255, 0));
create table t2 (c1 float(255, 0));
insert into t1 values (1.23), (1.24);
insert into t2 values (1.24), (1.25);
select * from t1;
select * from t2;
explain select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
explain select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
drop table t1, t2;

create table t1 (c1 float(255, 0));
create table t2 (c1 double(255, 0));
insert into t1 values (1.23), (1.24);
insert into t2 values (1.24), (1.25);
select * from t1;
select * from t2;
explain select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_nl(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
explain select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
drop table t1, t2;


--echo ##hash join
create table t1 (c1 float(10, 2));
create table t2 (c1 float(14, 4));
insert into t1 values (1.23), (1.24);
insert into t2 values (1.24), (1.25);
explain select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
drop table t1, t2;

create table t1 (c1 double(10, 2));
create table t2 (c1 double(14, 4));
insert into t1 values (1.23), (1.24);
insert into t2 values (1.24), (1.25);
explain select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
drop table t1, t2;

create table t1 (c1 float(10, 2));
create table t2 (c1 double(14, 4));
insert into t1 values (1.23), (1.24);
insert into t2 values (1.24), (1.25);
explain select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
select /*+use_hash(t1, t2)*/ * from t1 join t2 on t1.c1 = t2.c1;
drop table t1, t2;

--echo ##hash group
create table t1 (c1 float(10, 2), c2 int);
insert into t1 values (1.23, 1), (1.20, 1), (1.230, 1), (-0, 1), (0, 1);
explain select c1, sum(c2) from t1 group by c1;
select c1, sum(c2) from t1 group by c1;
drop table t1;

--echo ##other cmp
create table t1 (c1 float(7,2),c2 float(8,2),c3 float(10,5),c4 float);
insert into t1 values(1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45);
select c1<=>1023.91,c2<=>0,c3<=>0,c4<=>0 from t1;
select c1<=1023.91,c2>=0,c3<0,c4>0 from t1;
drop table t1;

--echo ##hash join with different scale
create table t1 (c1 float(7,3),c2 float(8,2),c3 float(10,5),c4 float(255,30));
insert into t1 values(-1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
create table t2 (a1 int,a2 int,a3 int,a4 int);
insert into t2 values(-1023.909,11.59,2.222,-12.123),(123.5,11.60,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
explain select /*+use_hash(t1 t2)*/ * from t1 inner join t2 on t1.c4=t2.a4;
select /*+use_hash(t1 t2)*/ * from t1 inner join t2 on t1.c4=t2.a4;

explain select /*+use_hash(t1 t2)*/ a2,a3,a4 from t1 left join t2 on t1.c4=t2.a4 order by  c1;
select /*+use_hash(t1 t2)*/ a2,a3,a4 from t1 left join t2 on t1.c4=t2.a4 order by  c1;
drop table t1, t2;

create table t1 (c1 float(10, 2), c2 float(20, 10));
create table t2 (c1 double(10, 2), c2 double(20, 10));
create table t3 (c1 double(10, 2), c2 double(20, 10));
explain select /*+use_hash(t1 t2)*/ * from t1 inner join t2 on t1.c1=t2.c2;
explain select /*+use_hash(t1 t2)*/ * from t1 inner join t2 on t1.c2=t2.c1;
explain select /*+use_hash(t1 t2)*/ * from t1 inner join t2 on t1.c1=t2.c1;
explain select /*+use_hash(t1 t2)*/ * from t1 inner join t2 on t1.c2=t2.c2;
explain select /*+use_hash(t2 t3)*/ * from t2 inner join t3 on t2.c1=t3.c2;

drop table t1, t2, t3;


drop database mysql_double_md;
