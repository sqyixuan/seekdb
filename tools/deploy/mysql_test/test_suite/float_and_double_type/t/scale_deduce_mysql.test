    f_255_30 - dec_40_30,
    d_255_30 - d_255_30,
    d_255_30 - dec_15_3,
    d_255_30 - dec_40_30,
    dec_15_3 - dec_15_3,
    dec_15_3 - dec_40_30,
    dec_40_30 - dec_40_30
from t1;
desc td;
drop table td;

--echo ##mul
create table td as select
    f * f,
