--echo ##agg
create table td as select
    min(f), max(d),
    min(f_10_2), max(d_12_3),
    max(f_60_10), min(d_60_11),
    min(f_255_30), max(d_255_30),
    min(dec_15_3), max(dec_40_30)
from t1;
desc td;
drop table td;

create table td as select
    avg(f), avg(d),
    avg(f_10_2), avg(d_12_3),
    avg(f_60_10), avg(d_60_11),
    avg(f_255_30), avg(d_255_30),
    avg(dec_15_3), avg(dec_40_30)
from t1;
desc td;
