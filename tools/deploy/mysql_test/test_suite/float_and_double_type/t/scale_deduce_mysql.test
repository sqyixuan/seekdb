# owner: zuojiao.hzj
# owner group: sql2
# tags: float,double
# description: test mysql float/doubel scale deduce
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists mysql_double_md;
--enable_warnings

create database mysql_double_md;
use mysql_double_md;

create table t1(
    f           float,
    d           double,
    f_10_2      float(10, 2),
    d_12_3      double(12, 3),
    f_60_10     float(60, 10),
    d_60_11     double(60, 11),
    f_255_30    float(255, 30),
    d_255_30    double(255, 30),
    dec_15_3    decimal(15, 3),
    dec_40_30   decimal(40, 30)
);

--echo ##add
create table td as select
    f + f,
    f + d,
    f + f_10_2,
    f + d_12_3,
    f + f_60_10,
    f + d_60_11,
    f + f_255_30,
    f + d_255_30,
    f + dec_15_3,
    f + dec_40_30,
    d + d,
    d + f_10_2,
    d + d_12_3,
    d + f_60_10,
    d + d_60_11,
    d + f_255_30,
    d + d_255_30,
    d + dec_15_3,
    d + dec_40_30
from t1;
desc td;
drop table td;

create table td as select
    f_10_2 + f_10_2,
    f_10_2 + d_12_3,
    f_10_2 + f_60_10,
    f_10_2 + d_60_11,
    f_10_2 + f_255_30,
    f_10_2 + d_255_30,
    f_10_2 + dec_15_3,
    f_10_2 + dec_40_30,
    d_12_3 + d_12_3,
    d_12_3 + f_60_10,
    d_12_3 + d_60_11,
    d_12_3 + f_255_30,
    d_12_3 + d_255_30,
    d_12_3 + dec_15_3,
    d_12_3 + dec_40_30
from t1;
desc td;
drop table td;

create table td as select
    f_60_10 + f_60_10,
    f_60_10 + d_60_11,
    f_60_10 + f_255_30,
    f_60_10 + d_255_30,
    f_60_10 + dec_15_3,
    f_60_10 + dec_40_30,
    d_60_11 + d_60_11,
    d_60_11 + f_255_30,
    d_60_11 + d_255_30,
    d_60_11 + dec_15_3,
    d_60_11 + dec_40_30
from t1;
desc td;
drop table td;

create table td as select
    f_255_30 + f_255_30,
    f_255_30 + d_255_30,
    f_255_30 + dec_15_3,
    f_255_30 + dec_40_30,
    d_255_30 + d_255_30,
    d_255_30 + dec_15_3,
    d_255_30 + dec_40_30,
    dec_15_3 + dec_15_3,
    dec_15_3 + dec_40_30,
    dec_40_30 + dec_40_30
from t1;
desc td;
drop table td;

--echo ##sub
create table td as select
    f - f,
    f - d,
    f - f_10_2,
    f - d_12_3,
    f - f_60_10,
    f - d_60_11,
    f - f_255_30,
    f - d_255_30,
    f - dec_15_3,
    f - dec_40_30,
    d - d,
    d - f_10_2,
    d - d_12_3,
    d - f_60_10,
    d - d_60_11,
    d - f_255_30,
    d - d_255_30,
    d - dec_15_3,
    d - dec_40_30
from t1;
desc td;
drop table td;

