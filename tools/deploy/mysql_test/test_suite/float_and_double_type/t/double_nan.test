# owner: zuojiao.hzj
# owner group: sql2
# tags: float,double
# description: bug fixed suite
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists mysql_double_md;
--enable_warnings

create database mysql_double_md;
use mysql_double_md;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,mysql_double_md,$OBMYSQL_PORT);

--disable_query_log

create table t_co ( 
  c_w int ,
  c_yc3fhqcul tinyint ,
  c_o885lvwr3 tinyint ,
  c_ar text ,
  c_hm0fkncc int not null ,
  c_ypx08c2rg double ,
  c_u5gqigv9u double not null ,
  c_mc9wgv3lmi text not null ,
  c_vswysw text ,
  c_rv92 tinyint ,
  primary key(c_hm0fkncc),
  unique(c_hm0fkncc, c_rv92),
  index main_index (c_hm0fkncc)) partition by hash(c_hm0fkncc) partitions 8;

