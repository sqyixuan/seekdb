--enable_query_log
SELECT
  ceiling(
    cast(round(
      cast(case when (NOT NOT(cast((ref_0.c_u5gqigv9u >= ref_0.c_rv92) as unsigned))) then ref_0.c_ypx08c2rg else (select min(c_g3kz9bm) from t_i823jy)
           end
         as double), 
      cast(abs(
        cast(ref_0.c_hm0fkncc as signed)) as signed)) as double)) as c2
FROM
  t_co as ref_0
ORDER BY
  c2 ASC
LIMIT 138;

drop table t_co;

--disable_query_log

