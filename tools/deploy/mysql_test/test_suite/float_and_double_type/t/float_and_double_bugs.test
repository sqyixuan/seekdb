set runtime_filter_type='BLOOM_FILTER';
CREATE TABLE `t9` (`c1` double(16,14) unsigned);
CREATE TABLE `t1` (`c1` double(16,14) unsigned);
insert into t1 values(19.000),(20.123);
insert into t9 values(19.000),(20.123);
select /*+parallel(2) px_join_filter(t9) OPT_PARAM('enable_rich_vector_format', 'True') */  * from t1 join t9 on t1.c1=t9.c1;
select /*+parallel(2) no_px_join_filter(t9) OPT_PARAM('enable_rich_vector_format', 'True') */  * from t1 join t9 on t1.c1=t9.c1;
explain select /*+parallel(2) px_join_filter(t9) OPT_PARAM('enable_rich_vector_format', 'True') */  * from t1 join t9 on t1.c1=t9.c1;
drop table t1, t9;

