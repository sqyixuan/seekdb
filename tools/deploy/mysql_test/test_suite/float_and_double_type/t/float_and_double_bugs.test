CREATE INDEX i150 USING BTREE ON t0(c2(3), c0, c1, c3);
REPLACE INTO t0(c3) VALUES(4.7087617572518E13);
SELECT /*+no_rewrite*/ count(*) as rowCount FROM (SELECT /*+ USE_NL (t0) */ DISTINCT concat(t0.c0,'') AS t0c0, t0.c1 AS t0c1, t0.c2 AS t0c2, t0.c3 AS t0c3 FROM t0 WHERE (NOT (CAST(')id_2' AS SIGNED)))) as result WHERE concat(result.t0c0,'') = '0000000047087617572518' AND result.t0c1 IS NULL AND concat(result.t0c2,'') IS NULL AND result.t0c3 IS NULL;
SELECT count(*) as rowCount FROM (SELECT /*+ USE_NL (t0) */ DISTINCT concat(t0.c0,'') AS t0c0, t0.c1 AS t0c1, t0.c2 AS t0c2, t0.c3 AS t0c3 FROM t0 WHERE (NOT (CAST(')id_2' AS SIGNED)))) as result WHERE concat(result.t0c0,'') = '0000000047087617572518' AND result.t0c1 IS NULL AND concat(result.t0c2,'') IS NULL AND result.t0c3 IS NULL;
select/*+index(t0 i150)*/ * from t0 where c0 = 47087617572518 and c1 is null;
drop table t0;

