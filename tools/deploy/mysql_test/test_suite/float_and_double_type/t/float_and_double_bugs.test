CREATE TABLE IF NOT EXISTS t0(c0 DOUBLE(22, 0) ZEROFILL  COMMENT 'asdf' , c1 DECIMAL(49, 0) , c2 VARCHAR(500)  COMMENT 'asdf' , c3 DECIMAL(32, 0)  COMMENT 'asdf'  )  BLOCK_SIZE =  16384 , USE_BLOOM_FILTER =  true , AUTO_INCREMENT = 47087617572518 PARTITION BY KEY (c2, c3, c1, c0) SUBPARTITION BY KEY (c3, c2, c0, c1) subpartitions 18 partitions 1;
