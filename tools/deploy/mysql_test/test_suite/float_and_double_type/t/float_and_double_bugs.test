delimiter /;
CREATE  FUNCTION f1(a float(255,10))
returns float(255,30)
begin
    declare a float(255,30);
    SELECT  sum(c1)  FROM t1 into a ;
    return a;
END
/
delimiter ;/
select f1(1.2);
drop table t1;

--echo ## floor, ceil, abs expr scale fixed
create table t1 (c1 double(7,2),c2 double(8,2),c3 double(10,5),c4 double(255,30));
insert into t1 values(-1023.909,11.591,2.222,-12.123),(-123.5,11.5995,556.02,22.45),(null,0,1.234567894562,10.0000000000002);
create table t2 select CEIL(min(c1)) a from t1 ;
select * from t2 where a=-1023.0;
desc t2;
create table t3 select CEIL(min(c2)) b from t1 ;
select * from t3 where b =0;
desc t3;
create table t4 select CEIL(min(c3)) c from t1 ;
select * from t4 where c =2.0;
desc t4;
create table t5 select CEIL(min(c4)) d from t1 ;
select * from t5 where d =-12.0;
desc t5;
drop table t2, t3, t4, t5;

create table t2 select FLOOR(min(c1)) a from t1 ;
select * from t2 where a=-1024.0;
desc t2;
create table t3 select FLOOR(min(c2)) b from t1 ;
select * from t3 where b =0;
desc t3;
create table t4 select FLOOR(min(c3)) c from t1 ;
select * from t4 where c =1.0;
desc t4;
create table t5 select FLOOR(min(c4)) d from t1 ;
select * from t5 where d =-13.0;
desc t5;
drop table t2, t3, t4, t5;


create table t2 select ABS(min(c1)) a from t1 ;
desc t2;
create table t3 select ABS(min(c2)) b from t1 ;
desc t3;
create table t4 select ABS(min(c3)) c from t1 ;
desc t4;
create table t5 select ABS(min(c4)) d from t1 ;
desc t5;
drop table t2, t3, t4, t5;
drop table t1;

