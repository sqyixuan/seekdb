insert into t1 values(1023.909,11.591,2.222,-12.123),(-123.5,11.5995,556.02,22.45),(null,0,1.234567894562,10.0000000000002);
select (case when c1 < 400 or c1 is null then max(c1) when c2 =0 then false else max(c4) end ) a from t1;
SELECT IF(min(c1)<max(c2),min(c3),max(c4)) a  from t1;

--echo ## 
SELECT IFNULL(min(c2),max(c1)) a ,IFNULL(min(c3),max(c4)) b from t1;
create table t2 select IFNULL(min(c2),max(c1)) a ,IFNULL(min(c3),max(c4)) b  from t1;
desc t2;
drop table t2;

SELECT NULLIF(min(c2),max(c1)) a ,NULLIF(min(c3),max(c4)) b from t1;
create table t2 select NULLIF(min(c2),max(c1)) a ,NULLIF(min(c3),max(c4)) b  from t1;
desc t2;
drop table t2;

SELECT GREATEST(max(c1),max(c2),max(c2),max(c3)) a  from t1;
create table t2 select GREATEST(max(c1),max(c2),max(c2),max(c3)) a   from t1;
desc t2;
drop table t2;

SELECT LEAST(max(c1),max(c2),max(c2),max(c3)) a  from t1;
create table t2 select LEAST(max(c1),max(c2),max(c2),max(c3)) a   from t1;
desc t2;
drop table t2;

