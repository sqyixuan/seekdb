# owner: zuojiao.hzj
# owner group: sql2
# tags: float,double
# description: float range check
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists mysql_float;
--enable_warnings

create database mysql_float;
use mysql_float;

SET sql_mode = 'STRICT_ALL_TABLES';
CREATE TABLE t_float_range (
    c1 FLOAT(10,2)
);

--error 1264
INSERT INTO t_float_range (c1) VALUES (99999999.999);
--error 1264
INSERT INTO t_float_range (c1) VALUES (100000003.99);
SELECT * FROM t_float_range;

DROP TABLE IF EXISTS t_float_range;
CREATE TABLE t_float_range (
    c1 FLOAT(8,2)
);

--error 1264
INSERT INTO t_float_range (c1) VALUES (999999.999);
--error 1264
INSERT INTO t_float_range (c1) VALUES (1000003.99);
SELECT * FROM t_float_range;

SET sql_mode = '';
DROP TABLE IF EXISTS t_float_range;
CREATE TABLE t_float_range (
    c1 FLOAT(10,2)
);

INSERT INTO t_float_range (c1) VALUES (99999999.999);
INSERT INTO t_float_range (c1) VALUES (100000003.99);
SELECT * FROM t_float_range;

DROP TABLE IF EXISTS t_float_range;
CREATE TABLE t_float_range (
    c1 FLOAT(8,2)
);

INSERT INTO t_float_range (c1) VALUES (999999.999);
INSERT INTO t_float_range (c1) VALUES (1000003.99);
SELECT * FROM t_float_range;

drop table t_float_range;
SET sql_mode = 'STRICT_ALL_TABLES';
CREATE TABLE t_float_range (
    c1 FLOAT(10,2)
);
INSERT INTO t_float_range (c1) VALUES (99999999.99);
--error 1264
INSERT INTO t_float_range (c1) VALUES (99999999.999);
SELECT * FROM t_float_range;

create table t1 (is_neg int, c1 float, c2 float, c3 float, c4 float);
insert into t1 values (0, 111, 11111111111, 11111111111, 111111111111111111111111111111111111);
insert into t1 values (1, -111, -11111111111, -11111111111, -111111111111111111111111111111111111);
select cast(c1 as decimal(4,2)), cast(c2 as decimal(15,5)), cast(c3 as decimal(20,10)), cast(c1 as decimal(65,30)) from t1;

create table t2 (c1 decimal(4, 2), c2 decimal(15, 5), c3 decimal(20, 10), c4 decimal(65, 30));
--error 1264
insert into t2 select c1, c2, c3, c4 from t1 where is_neg = 0;
--error 1264
insert into t2 select c1, c2, c3, c4 from t1 where is_neg = 1;
set sql_mode = '';
insert into t2 select c1, c2, c3, c4 from t1 where is_neg = 0;
insert into t2 select c1, c2, c3, c4 from t1 where is_neg = 1;
select * from t2;
drop table t1,t2;

drop database mysql_float;
