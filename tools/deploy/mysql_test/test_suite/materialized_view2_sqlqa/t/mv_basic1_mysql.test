--disable_warnings
drop database  IF EXISTS  db1;
--enable_warnings
create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='';

--echo ##增加全量刷新的复杂查询场景

--echo ##列如果存在表达式的话不进行设置别名,oracle支持创建 ,ob报错不支持;
create table t1 (c1 number primary key, c2 number);
create materialized view mv1 refresh complete as select count(*) a from t1 ;
insert into t1 values(100,100);
CALL DBMS_MVIEW.REFRESH('mv1','c');
desc mv1;
desc t1;

--echo ##使用虚拟表
create table tt1 (c1 number , c2 varchar(10));
--error 4177
create materialized view tt_mv1 parallel 2 refresh complete as select 1 a from dual ;


--echo ##使用物化视图
drop table  if exists tt1;
drop materialized view if exists mv1;
drop materialized view if exists mv2;
create table tt1 (c1 number , c2 varchar(10));
create materialized view tt_mv1 parallel 2 refresh complete as select * from tt1 ;
create materialized view tt_mv2 parallel 2 refresh complete as select * from tt_mv1 ;
drop materialized view tt_mv2;


--echo ##使用普通视图
drop table  if exists tt1;
drop  view  if exists tt_v1;
drop materialized view tt_mv1;
create table tt1 (c1 number , c2 varchar(10));
create  view tt_v1  as select * from tt1 ;
--error 0,9808
create materialized view tt_mv1  as select * from tt_v1 ;

--echo ##包含多表连接
drop table if exists tt1;
drop table if exists tt2;
drop materialized view if exists tt_mv1;
drop materialized view if exists tt_mv2;
drop materialized view if exists tt_mv3;
drop materialized view if exists tt_mv4;
drop materialized view if exists tt_mv5;
drop materialized view if exists tt_mv6;
drop materialized view if exists tt_mv7;
create table tt1 (c1 number , c2 varchar(10));
create table tt2 (a1 number , a2 varchar(10));
INSERT INTO tt1 (c1, c2) VALUES (1, 'Text1');
INSERT INTO tt1 (c1, c2) VALUES (2, 'Text2');
INSERT INTO tt1 (c1, c2) VALUES (3, 'Text3');
INSERT INTO tt1 (c1, c2) VALUES (4, 'Text4');
INSERT INTO tt1 (c1, c2) VALUES (5, 'Text5');
INSERT INTO tt1 (c1, c2) VALUES (6, 'Text6');
INSERT INTO tt1 (c1, c2) VALUES (7, 'Text7');
INSERT INTO tt1 (c1, c2) VALUES (8, 'Text8');
INSERT INTO tt1 (c1, c2) VALUES (9, 'Text9');
INSERT INTO tt1 (c1, c2) VALUES (10, 'Text10');
insert into tt2 select * from tt1;

create materialized view tt_mv1 parallel 2 refresh complete as SELECT tt1.c1, tt1.c2 FROM tt1 INNER JOIN tt2 ON tt1.c1 = tt2.a1;
create materialized view tt_mv2 parallel 2 refresh complete as SELECT tt1.c1, tt1.c2, tt2.a1, tt2.a2 FROM tt1 LEFT JOIN tt2 ON tt1.c1 = tt2.a1;
create materialized view tt_mv3 parallel 2 refresh complete as SELECT tt1.c1, tt1.c2, tt2.a1, tt2.a2 FROM tt1 RIGHT JOIN tt2 ON tt1.c1 = tt2.a1;
create materialized view tt_mv4 parallel 2 refresh complete as SELECT tt1.c1, tt1.c2, tt2.a1, tt2.a2 FROM tt1 FULL OUTER JOIN tt2 ON tt1.c1 = tt2.a1;


--echo ##自连接（Self-join）
drop table  if exists tt1;
drop materialized view  if exists tt_mv1;
create table tt1 (c1 number , c2 varchar(10));
create materialized view tt_mv1 parallel 2 refresh complete as SELECT e1.c1 AS EmployeeID, e1.c2 AS EmployeeName, e2.c1 AS ManagerID, e2.c2 AS ManagerName FROM tt1 e1 JOIN tt1 e2 ON e1.c1 = e2.c1; 

--echo ##使用操作符INTERSECT, MINUS,此处创建mv夯住
drop table  if exists tt1;
drop table  if exists tt2;
drop materialized view  if exists tt_mv1;
drop materialized view  if exists tt_mv2;
drop materialized view  if exists tt_mv3;
drop materialized view  if exists tt_mv4;
drop materialized view  if exists tt_mv5;
create table tt1 (c1 number , c2 varchar(20));
create table tt2 (a1 number , a2 varchar(20));
INSERT INTO tt1 (c1, c2) VALUES (1, LPAD('中文', 10, 'ing'));
INSERT INTO tt1 (c1, c2) VALUES (2, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (3, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (4, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (5, 'null');
INSERT INTO tt1 (c1, c2) VALUES (6, null);
INSERT INTO tt1 (c1, c2) VALUES (7, '中ng123');
INSERT INTO tt1 (c1, c2) VALUES (8, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (9, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (10, LPAD('a', 30, 'x'));
insert into tt2 select * from tt1;

create materialized view tt_mv1 parallel 2 refresh complete as SELECT c1 FROM tt1 INTERSECT SELECT a1 FROM tt2 order by c1 limit 6;
create materialized view tt_mv2 parallel 2 refresh complete as SELECT c1 FROM tt1 MINUS SELECT a1 FROM tt2;
create materialized view tt_mv3 parallel 2 refresh complete as SELECT tt1.c1, tt1.c2 FROM tt1  UNION  SELECT  tt2.a1, tt2.a2 FROM tt2 ;
create materialized view tt_mv4 parallel 2 refresh complete as SELECT tt1.c1, tt1.c2 FROM tt1  UNION ALL SELECT  tt2.a1, tt2.a2 FROM tt2 ;
create materialized view tt_mv5 parallel 2 refresh complete as SELECT tt1.c1, tt1.c2, tt2.a1, tt2.a2 FROM tt1 LEFT JOIN tt2 ON tt1.c1 = tt2.a1 UNION ALL SELECT tt1.c1, tt1.c2, tt2.a1, tt2.a2 FROM tt1 RIGHT JOIN tt2 ON tt1.c1 = tt2.a1 WHERE tt1.c1 IS NULL;


--echo ##嵌套子查询
drop table  if exists tt1;
drop table  if exists tt2;
drop materialized view if exists tt_mv1;
drop materialized view if exists tt_mv2;
drop materialized view if exists tt_mv3;
drop materialized view if exists tt_mv4;
create table tt1 (c1 number primary key, c2 varchar(30));
create table tt2 (a1 number primary key, a2 varchar(30));
INSERT INTO tt1 (c1, c2) VALUES (1, LPAD('中文', 10, 'ing'));
INSERT INTO tt1 (c1, c2) VALUES (2, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (3, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (4, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (5, 'null');
INSERT INTO tt1 (c1, c2) VALUES (6, null);
INSERT INTO tt1 (c1, c2) VALUES (7, '中ng123');
INSERT INTO tt1 (c1, c2) VALUES (8, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (9, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (10, LPAD('a', 30, 'x'));
insert into tt2 select * from tt1 order by c1 limit 5;

create materialized view tt_mv1 parallel 2 refresh complete on demand as SELECT c1, (SELECT COUNT(*) FROM tt2 WHERE tt2.a1 = tt1.c1) AS tt2_count FROM tt1;
create materialized view tt_mv2 parallel 2 refresh complete on demand as SELECT * FROM tt1 WHERE c1 = (SELECT AVG(a1) FROM tt2);
create materialized view tt_mv3 parallel 2 refresh complete on demand as SELECT * FROM tt1 WHERE c1 < (SELECT MAX(a1) FROM tt2 WHERE a1 NOT IN (SELECT a1 FROM tt2 WHERE a1 < 5));
create materialized view tt_mv4 parallel 2 refresh complete on demand as SELECT * FROM tt1 WHERE c1 = (SELECT AVG(a1) FROM tt2) AND c2 IN (SELECT a2 FROM tt2 WHERE a1 IN (SELECT a1 FROM tt2 WHERE a1 > (SELECT MIN(a1) FROM tt2)));
CALL DBMS_MVIEW.REFRESH('tt_mv1','c');
CALL DBMS_MVIEW.REFRESH('tt_mv2','c');
CALL DBMS_MVIEW.REFRESH('tt_mv3','c');
CALL DBMS_MVIEW.REFRESH('tt_mv4','c');
select * from tt_mv1 order by c1;
select * from tt_mv2 order by c1;
select * from tt_mv3 order by c1;
select * from tt_mv4 order by c1;

--echo ##相关子查询
drop table if exists tt1;
drop table if exists tt2;
drop materialized view  if exists  tt_mv1;
drop materialized view  if exists  tt_mv2;
drop materialized view  if exists  tt_mv3;
create table tt1 (c1 number primary key, c2 varchar(30));
create table tt2 (a1 number primary key, a2 varchar(30));
INSERT INTO tt1 (c1, c2) VALUES (1, LPAD('中文', 10, 'ing'));
INSERT INTO tt1 (c1, c2) VALUES (2, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (3, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (4, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (5, 'null');
INSERT INTO tt1 (c1, c2) VALUES (6, null);
INSERT INTO tt1 (c1, c2) VALUES (7, '中ng123');
INSERT INTO tt1 (c1, c2) VALUES (8, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (9, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (10, LPAD('a', 30, 'x'));
insert into tt2 select * from tt1 order by c1 limit 5;

create materialized view tt_mv1 parallel 2 refresh complete as SELECT * FROM tt1 t1 WHERE t1.c2 LIKE '中文%' AND t1.c1 > (SELECT AVG(t2.a1) FROM tt2 t2  WHERE t2.a2 = t1.c2);
create materialized view tt_mv2 parallel 2 refresh complete as SELECT * FROM tt1 t1 WHERE t1.c1 > (SELECT AVG(t2.a1) FROM tt2 t2 WHERE t2.a2 = t1.c2)AND (SELECT COUNT(*) FROM tt2 t2 WHERE t2.a2 = t1.c2) >= 2;
create materialized view tt_mv3 parallel 2 refresh complete as SELECT * FROM tt1 t1_outer WHERE ( SELECT COUNT(*) FROM tt2 WHERE tt2.a2 = t1_outer.c2) > 2 AND t1_outer.c1 > (SELECT AVG(t2_inner.a1) FROM tt2 t2_inner WHERE t2_inner.a2 = t1_outer.c2)AND EXISTS (SELECT 1 FROM tt1 t1_inner WHERE t1_inner.c1 < t1_outer.c1 AND t1_inner.c2 = t1_outer.c2) order by c1;
CALL DBMS_MVIEW.REFRESH('tt_mv1','c');
CALL DBMS_MVIEW.REFRESH('tt_mv2','c');
CALL DBMS_MVIEW.REFRESH('tt_mv3','c');
select * from tt_mv1 order by c1;
select * from tt_mv2 order by c1;
select * from tt_mv3 order by c1;


--echo ##窗口函数
drop table if exists tt1;
drop table if exists tt2;
drop materialized view if exists tt_mv1;
drop materialized view if exists tt_mv2;
drop materialized view if exists tt_mv3;
drop materialized view if exists tt_mv4;
drop materialized view if exists tt_mv5;
drop materialized view if exists tt_mv6;
drop materialized view if exists tt_mv7;
create table tt1 (c1 number primary key, c2 varchar(30));
INSERT INTO tt1 (c1, c2) VALUES (1, LPAD('中文', 10, 'ing'));
INSERT INTO tt1 (c1, c2) VALUES (2, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (3, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (4, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (5, 'null');
INSERT INTO tt1 (c1, c2) VALUES (6, null);
INSERT INTO tt1 (c1, c2) VALUES (7, '中ng123');
INSERT INTO tt1 (c1, c2) VALUES (8, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (9, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (10, LPAD('a', 30, 'x'));

create materialized view tt_mv1 parallel 2 refresh complete on demand as SELECT c1, c2,ROW_NUMBER() OVER (ORDER BY c1) AS rn FROM tt1  order by c1,c2 limit 4;
create materialized view tt_mv2 parallel 2 refresh complete on demand as SELECT c1, c2,RANK() OVER (ORDER BY c1) AS rank FROM tt1  order by c1,c2 limit 4;
create materialized view tt_mv3 parallel 2 refresh complete on demand as SELECT c1, c2,DENSE_RANK() OVER (ORDER BY c1) AS dense_rank FROM tt1  order by c1,c2 limit 4;
create materialized view tt_mv4 parallel 2 refresh complete on demand as SELECT c1, c2,LEAD(c2, 1) OVER (ORDER BY c1) AS next_c2 FROM tt1  order by c1,c2 limit 4;
create materialized view tt_mv5 parallel 2 refresh complete on demand as SELECT c1, c2,LAG(c2, 1) OVER (ORDER BY c1) AS prev_c2 FROM tt1  order by c1,c2 limit 4;
create materialized view tt_mv6 parallel 2 refresh complete on demand as SELECT c1, c2,SUM(c1) OVER (ORDER BY c1) AS running_total FROM tt1  order by c1,c2 limit 4;
create materialized view tt_mv7 parallel 2 refresh complete on demand as SELECT c1, c2,AVG(c1) OVER (ORDER BY c1) AS running_avg FROM tt1  order by c1,c2 limit 4;

select * from tt_mv1 order by c1;
select * from tt_mv2 order by c1;
select * from tt_mv3 order by c1;
select * from tt_mv4 order by c1;
select * from tt_mv5 order by c1;
select * from tt_mv6 order by c1;
select * from tt_mv7 order by c1;



--echo ##group by
drop table if exists tt1;
drop table if exists tt2;
drop materialized view if exists tt_mv1;
drop materialized view if exists tt_mv2;
drop materialized view if exists tt_mv3;
drop materialized view if exists tt_mv4;
drop materialized view if exists tt_mv5;
drop materialized view if exists tt_mv6;
drop materialized view if exists tt_mv7;
drop materialized view if exists tt_mv8;
drop materialized view if exists tt_mv9;
drop materialized view if exists tt_mv10;
create table tt1 (c1 number primary key, c2 varchar(30));
create table tt2 (a1 number primary key, a2 varchar(30));
INSERT INTO tt1 (c1, c2) VALUES (1, LPAD('中文', 10, 'ing'));
INSERT INTO tt1 (c1, c2) VALUES (2, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (3, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (4, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (5, 'null');
INSERT INTO tt1 (c1, c2) VALUES (6, null);
INSERT INTO tt1 (c1, c2) VALUES (7, '中ng123');
INSERT INTO tt1 (c1, c2) VALUES (8, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (9, '中文ing123');
INSERT INTO tt1 (c1, c2) VALUES (10, LPAD('a', 30, 'x'));
insert into tt2 select * from tt1 order by c1 limit 5;

create materialized view tt_mv1 parallel 2 refresh complete on demand as SELECT upper(c2) a, COUNT(*) AS total_count FROM tt1 GROUP BY c2;
create materialized view tt_mv2 parallel 2 refresh complete on demand as SELECT upper(a2) a, MAX(a1) AS max_a1, MIN(a1) AS min_a1 FROM tt2 GROUP BY a2;
create materialized view tt_mv3 parallel 2 refresh complete on demand as SELECT SUM(c1) AS total_sum FROM tt1;
create materialized view tt_mv4 parallel 2 refresh complete on demand as SELECT t1.c2, upper(t2.a2) a, AVG(t1.c1) AS avg_c1, AVG(t2.a1) AS avg_a1 FROM tt1 t1 JOIN tt2 t2 ON t1.c2 = t2.a2 GROUP BY t1.c2, t2.a2;

--sorted_result
select * from tt_mv1;
select * from tt_mv2 order by a;
select * from tt_mv3 ;
select * from tt_mv4 order by c2;

--echo ##使用order by
drop table  if exists tt1;
drop materialized view  if exists tt_mv1;
create table tt1 (c1 number primary key, c2 varchar(30),c3 number,CONSTRAINT fk_c1 FOREIGN KEY (c3) REFERENCES tt1 (c1));
INSERT INTO tt1 (c1, c2, c3) VALUES (1, LPAD('中文', 10, 'ing'),1);
INSERT INTO tt1 (c1, c2, c3) VALUES (2, '中文ing123',2);
INSERT INTO tt1 (c1, c2, c3) VALUES (3, '中文ing123',3);
INSERT INTO tt1 (c1, c2, c3) VALUES (4, '中文ing123',4);
create materialized view tt_mv1 parallel 2 refresh complete on demand as SELECT c1, c2,c3 FROM tt1 order by c1 limit 2;
select * from tt_mv1 order by c1;
INSERT INTO tt1 (c1, c2, c3) VALUES (5, 'null',5);
INSERT INTO tt1 (c1, c2, c3) VALUES (6, null,6);
INSERT INTO tt1 (c1, c2, c3) VALUES (7, '中ing123',null);
CALL DBMS_MVIEW.REFRESH('tt_mv1','c');
select * from tt_mv1 order by c1;

--echo ##使用where子句多层嵌套，如多层嵌套的AND, OR, IN, EXISTS, NOT EXISTS, BETWEEN, LIKE等。
drop table if exists  tt1;
drop materialized view  if exists tt_mv1;
drop materialized view  if exists tt_mv2;
drop materialized view  if exists tt_mv3;
create table tt1 (c1 number primary key, c2 varchar(30),c3 number,CONSTRAINT fk_c1 FOREIGN KEY (c3) REFERENCES tt1 (c1));
INSERT INTO tt1 (c1, c2, c3) VALUES (1, LPAD('中文', 10, 'ing'),1);
INSERT INTO tt1 (c1, c2, c3) VALUES (119, '中ng123',119);
INSERT INTO tt1 (c1, c2, c3) VALUES (199, '中文ing123',199);
INSERT INTO tt1 (c1, c2, c3) VALUES (200, '中文in3',200);
create materialized view tt_mv1 parallel 2 refresh complete on demand as SELECT * FROM tt1 WHERE c2 LIKE '中文%' AND c1 BETWEEN 100 AND 200 AND EXISTS ( SELECT 1 FROM tt1  WHERE c1 = c3 AND c2 LIKE '中文ing123%');
create materialized view tt_mv2 parallel 2 refresh complete on demand as SELECT * FROM tt1 WHERE c2 LIKE '%中文%' AND c1 BETWEEN 100 AND 200 AND ( c1 = c3 OR NOT EXISTS (  SELECT 1  FROM tt1  WHERE c3 = c1  ) );
create materialized view tt_mv3 parallel 2 refresh complete on demand as SELECT * FROM tt1 WHERE (c2 LIKE '%中文%' OR c2 LIKE '%ing%') AND c1 IN (1, 119, 199, 200)  AND (  (c1 = c3 AND c1 < 120)   OR (NOT EXISTS ( SELECT 1 FROM tt1  WHERE c3 = c1 ) AND c1 >= 120) );

select * from tt_mv1 order by c1;
INSERT INTO tt1 (c1, c2, c3) VALUES (5, 'null',5);
INSERT INTO tt1 (c1, c2, c3) VALUES (6, null,6);
INSERT INTO tt1 (c1, c2, c3) VALUES (7, '中ing123',null);
CALL DBMS_MVIEW.REFRESH('tt_mv1','c');
CALL DBMS_MVIEW.REFRESH('tt_mv2','c');
CALL DBMS_MVIEW.REFRESH('tt_mv3','c');
select * from tt_mv1 order by c1;
select * from tt_mv2 order by c1;
select * from tt_mv3 order by c1;

--echo ##使用limit
drop table  if exists tt1;
drop materialized view  if exists tt_mv1;
create table tt1 (c1 number primary key, c2 varchar(30),c3 number);
INSERT INTO tt1 (c1, c2, c3) VALUES (119, '中ng123',119);
INSERT INTO tt1 (c1, c2, c3) VALUES (199, '中文ing123',199);
create materialized view tt_mv1  refresh complete on demand as SELECT c1,c2,c3 FROM tt1  order by c1 limit 1,1;
select * from tt_mv1 order by c1;
INSERT INTO tt1 (c1, c2, c3) VALUES (5, 'aa',5);
CALL DBMS_MVIEW.REFRESH('tt_mv1','c');
select * from tt_mv1 order by c1;
select * from tt1 order by c1;

--echo ##使用distinct结合聚合函数
drop table  if exists tt1;
drop materialized view  if exists tt_mv1;
drop materialized view  if exists tt_mv2;
drop materialized view  if exists tt_mv3;
drop materialized view  if exists tt_mv4;
create table tt1 (c1 number primary key, c2 varchar(30),c3 number);
INSERT INTO tt1 (c1, c2, c3) VALUES (119, '中ng123',119);
INSERT INTO tt1 (c1, c2, c3) VALUES (199, '中文ing123',199);
create materialized view tt_mv1  refresh complete on demand as SELECT COUNT(DISTINCT c2) AS unique_c2_count FROM tt1;
create materialized view tt_mv2  refresh complete on demand as SELECT SUM(DISTINCT c3) AS sum_of_distinct_c3 FROM tt1;
create materialized view tt_mv3  refresh complete on demand as SELECT MIN(DISTINCT c3) AS min_distinct_c3, MAX(DISTINCT c3) AS max_distinct_c3 FROM tt1;
create materialized view tt_mv4  refresh complete on demand as SELECT AVG(DISTINCT c3) AS avg_of_distinct_c3 FROM tt1;
select * from tt_mv1 ;
select * from tt_mv2 ;
select * from tt_mv3 ;
select * from tt_mv4 ;

--echo ##设置变量
drop table  if exists tt1;
drop materialized view  if exists tt_mv1;
drop materialized view  if exists tt_mv2;
drop materialized view  if exists tt_mv3;
drop materialized view  if exists tt_mv4;
create table tt1 (c1 number primary key, c2 varchar(30),c3 number);
INSERT INTO tt1 (c1, c2, c3) VALUES (119, '中ng123',119);
INSERT INTO tt1 (c1, c2, c3) VALUES (199, '中文ing123',199);
set @a = 4;
--error 1351
create materialized view tt_mv1 refresh complete on demand as SELECT c1,c2,c3 FROM tt1 where c1 > @a;



