--echo ##DBA_MVREF_STMT_STATS,__all_mview_refresh_stmt_stats
DROP MATERIALIZED VIEW LOG ON t1;
drop table if exists t1;
drop materialized view if exists mv1;
create table t1 (c1 number primary key, c2 varchar(10),c3 number);
create materialized view log on t1  with rowid, sequence(c2,c3) including new values;
create materialized view mv1 refresh fast  as select count(*) as cnt,c2 as c2  from t1 group by c2;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select MV_OWNER,MV_NAME,REFRESH_ID from oceanbase.DBA_MVREF_STMT_STATS where MV_NAME = 'MV1';
select * from oceanbase.__all_mview_refresh_stmt_stats ;

drop materialized view if exists mv1;
create materialized view mv1 refresh fast start with sysdate() + interval 1 second next sysdate() + interval 10 second as select count(*) as cnt,c2 as c2  from t1 group by c2;
select MV_OWNER,MV_NAME,REFRESH_ID from oceanbase.DBA_MVREF_STMT_STATS where MV_NAME = 'MV1';
select * from oceanbase.__all_mview_refresh_stmt_stats ;

DROP MATERIALIZED VIEW LOG ON t1;
drop table if exists t1;
drop materialized view if exists mv1;
create table t1 (c1 number primary key, c2 varchar(10),c3 number);
create materialized view mv1 refresh complete  as select count(*) as cnt,c2 as c2  from t1 group by c2;
CALL DBMS_MVIEW.REFRESH('mv1','c');
select MV_OWNER,MV_NAME,REFRESH_ID from oceanbase.DBA_MVREF_STMT_STATS where MV_NAME = 'MV1';
select * from oceanbase.__all_mview_refresh_stmt_stats ;

drop materialized view if exists mv1;
create materialized view mv1 refresh complete start with sysdate() + interval 1 second next sysdate() + interval 10 second as select count(*) as cnt,c2 as c2  from t1 group by c2;
select MV_OWNER,MV_NAME,REFRESH_ID from oceanbase.DBA_MVREF_STMT_STATS where MV_NAME = 'MV1';
select * from oceanbase.__all_mview_refresh_stmt_stats ;






