--echo ##设置相同sql_mode;
SET @@sql_mode='';


--echo ##DBA_MVIEWS,__all_mview
drop table if exists t1;
drop materialized view if exists mv1;
create table t1 (c1 number primary key, c2 varchar(10));
insert into t1 values(1,2);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2) including new values ;
create materialized view mv1 refresh fast as select count(*) as cnt,c2 as c2  from t1 group by c2;

CALL DBMS_MVIEW.REFRESH('mv1','f');
##select MVIEW_NAME,REFRESH_MODE,LAST_REFRESH_TYPE,LAST_REFRESH_DATE,LAST_REFRESH_END_TIME from oceanbase.DBA_MVIEWS where MVIEW_NAME ='MV1' ;

delete from t1 where c2 = 2;
CALL DBMS_MVIEW.REFRESH('mv1','c');
##select MVIEW_NAME,REFRESH_MODE,LAST_REFRESH_TYPE,LAST_REFRESH_DATE,LAST_REFRESH_END_TIME from oceanbase.DBA_MVIEWS where MVIEW_NAME ='MV1' ;

--echo ###DBA_MVIEW_LOGS
DROP MATERIALIZED VIEW LOG ON t1;
drop table if exists t1;
drop materialized view if exists mv1;
create table t1 (c1 number primary key, c2 varchar(10));
insert into t1 values(1,2);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2) including new values ;
create materialized view mv1 refresh fast as select count(*) as cnt,c2 as c2  from t1 group by c2;
##select * from oceanbase.DBA_MVIEW_LOGS where LOG_TABLE = 'MLOG$_T1';

call dbms_mview.purge_log('T1');
##select * from oceanbase.DBA_MVIEW_LOGS where LOG_TABLE = 'MLOG$_T1';

call dbms_mview.purge_log('T1');
##select * from oceanbase.DBA_MVIEW_LOGS where LOG_TABLE = 'MLOG$_T1';

CALL DBMS_MVIEW.REFRESH('mv1','f');
call dbms_mview.purge_log('T1');
select * from mlog$_t1;


