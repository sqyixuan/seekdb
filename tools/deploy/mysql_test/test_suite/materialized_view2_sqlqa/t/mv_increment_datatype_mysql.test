select * from mlog$_t1 order by SEQUENCE$$;

DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE if exists  t1;
DROP TABLE if exists  tt1;
drop materialized view if exists  mv1;
create table t1 (c1 time , c2 time);
INSERT INTO t1  VALUES (null, '10:12:01.119');
INSERT INTO t1  VALUES ('23:59:59.9', '23:59:59.333');
INSERT INTO t1  VALUES ('23:59:59.999999', null);
create table tt1 as select c1 as c1,count(*) as cnt from t1 group by c1;
select * from tt1 order by c1;

--echo ##year
DROP TABLE if exists  t1;
drop materialized view if exists  mv1;
create table t1 (c1 year , c2 year);
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c1,c2) including new values ;
create materialized view mv1  parallel 9 refresh fast on demand  as select c1 as c1,count(*) as cnt from t1 group by c1;
INSERT INTO t1  VALUES (null, 2023);
INSERT INTO t1  VALUES (0000, 2155);
INSERT INTO t1  VALUES (1970, null);
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1 order by c1;
select * from mlog$_t1 order by SEQUENCE$$;

DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE if exists  t1;
DROP TABLE if exists  tt1;
drop materialized view if exists  mv1;
create table t1 (c1 year , c2 year);
INSERT INTO t1  VALUES (null, 2023);
INSERT INTO t1  VALUES (0000, 2155);
INSERT INTO t1  VALUES (1970, null);
create table tt1 as select c1 as c1,count(*) as cnt from t1 group by c1;
select * from tt1 order by c1;



