--disable_warnings
drop database  IF EXISTS  ljh;
--enable_warnings
create database ljh;
use ljh;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';

##mysql
--echo ##int
DROP TABLE  if exists t1;
drop materialized view if exists  mv1;
create table t1 (c1 int primary key, c2 int);
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2) including new values ;
create materialized view mv1  parallel 9 refresh fast on demand  as select c1 as c1,count(*) as cnt from t1 group by c1;
insert into t1 values(1,2);
insert into t1 values(2,null);
insert into t1 values(4,2);
update t1 set c1= 5 where c2 is null;
delete  from t1  where c2 is not null ;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1 order by c1;
select * from mlog$_t1 order by SEQUENCE$$;

DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE  if exists t1;
DROP TABLE  if exists tt1;
drop materialized view if exists  mv1;
create table t1 (c1 int primary key, c2 int);
insert into t1 values(1,2);
insert into t1 values(2,null);
insert into t1 values(4,2);
update t1 set c1= 5 where c2 is null;
delete  from t1  where c2 is not null ;
create table tt1 as select c1 as c1,count(*) as cnt from t1 group by c1;
select * from tt1 order by c1;


