# owner: lana.lgx
# owner group: data
# description: materialized view
# tags: mv_basic
# author: wb-ljh01399065
 
--disable_warnings
drop database  IF EXISTS  ljh;
--enable_warnings
create database ljh;
use ljh;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='';

##mysql
--echo ##索引操作 支持
##增加索引
CREATE TABLE t1 (c1 int ,c2 int, c3 int, c4 int, CONSTRAINT constraint_name CHECK (c3>c2));
insert into t1 values(1,2,3,4);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c4,c3) including new values;
##唯一索引
CREATE UNIQUE INDEX index_name1 ON t1 (c1,c2,c3,c4);
##组合索引
CREATE  INDEX index_name2 ON t1 (c2,c4);
##主键索引 创建mlog后不支持对基表进行删除，增加，修改列为主键；不支持
--error 1235
ALTER TABLE t1 ADD PRIMARY KEY (c1,c2);
--error 1091
ALTER TABLE t1 DROP PRIMARY KEY;
show index from t1 where Column_name ='c1';

##增加check约束
ALTER TABLE t1 ADD CONSTRAINT constraint_name1 CHECK (c3>c2);
ALTER TABLE t1 DROP CHECK constraint_name;

##删除索引
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int ,c2 int, c3 int, c4 int);
CREATE  INDEX index_name1 ON t1 (c1,c2,c3,c4);
CREATE UNIQUE INDEX index_name2 ON t1 (c1,c4);
CREATE /*+ PARALLEL(10) */ INDEX index_name3 ON t1(c1 , c3 asc);
insert into t1 values(1,2,3,-44);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
drop INDEX index_name3 on t1;
drop INDEX index_name2 on t1;
drop INDEX index_name1 on t1;
show index from t1;


##重命名索引
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) ,c2 int(10), c3 int, c4 int);
CREATE  INDEX index_name1 ON t1 (c1,c2,c3,c4);
CREATE UNIQUE INDEX index_name2 ON t1 (c1,c4);
CREATE /*+ PARALLEL(10) */ INDEX index_name3 ON t1(c1 , c3 asc);
insert into t1 values(1,2,3,-44);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
ALTER TABLE t1 RENAME INDEX index_name1 TO new_idx_name1;
ALTER TABLE t1 RENAME INDEX index_name2 TO new_idx_name2;
ALTER TABLE t1 RENAME INDEX index_name3 TO new_idx_name3;
show index from t1;


##混合索引操作
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int ,c2 int(10), c3 int, c4 int);
CREATE  INDEX index_name1 ON t1 (c1,c2,c3,c4);
CREATE UNIQUE INDEX index_name2 ON t1 (c1,c4);
CREATE /*+ PARALLEL(10) */ INDEX index_name3 ON t1(c1 , c3 asc);
insert into t1 values(1,2,3,-44);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
--error 4179
ALTER TABLE t1 ADD INDEX index_name4(c1), DROP INDEX index_name1, RENAME INDEX index_name3 TO index_name1;
show index from t1;


--echo ##列操作
##末尾加列 不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) ,c2 int(10), c3 int, c4 int);
insert into t1 values(1,2,3,-44);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
--error 0,1235
ALTER TABLE t1 ADD c5 INT;
--error 1060,1235
ALTER TABLE t1 ADD c5 blob ;
--error 1060,1235
ALTER TABLE t1 ADD c5 json ;
--error 1060,1235
ALTER TABLE t1 ADD c5 varchar(1) ;
--error 1060,1235
ALTER TABLE t1 ADD c5 date ;

##中间加列
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) ,c2 int(10), c3 int);
insert into t1 values(1,2,3);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
--error 0,1235
ALTER TABLE t1 ADD COLUMN c4 INT BEFORE c3;

##重排列
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) ,c2 int(10), c3 int);
insert into t1 values(1,2,3);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
--error 1235
ALTER TABLE t1 MODIFY COLUMN c3 INT FIRST;
--error 1235
ALTER TABLE t1 MODIFY COLUMN c3 INT AFTER c2;


##修改列为主键
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key ,c2 int(10), c3 int, c4 int);
insert into t1 values(1,2,3,-44);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 DROP PRIMARY KEY,ADD PRIMARY KEY(c2);


##添加virtual列 不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) ,c2 int(10), c3 int, c4 int);
insert into t1 values(1,2,3,-44);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
--error 0,1235
ALTER TABLE t1 ADD c5 int GENERATED ALWAYS AS (c1*c2) VIRTUAL;


##删除virtual列 不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) ,c2 int(10), c3 int, c4 int,c5 int as (c1*c4) VIRTUAL );
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 drop column c5;

	
##修改列为not null	不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) ,c2 int(10), c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 MODIFY c4 int NOT NULL;
--error 1235
ALTER TABLE t1 MODIFY c1 date NOT NULL;


##修改列为null 不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) ,c2 int(10), c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
--error 1235
ALTER TABLE t1 MODIFY c4 int NULL;
--error 1235
ALTER TABLE t1 MODIFY c1 date NULL;



##设列默认值,删列默认值 不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) ,c2 int(10), c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
--error 1235
ALTER TABLE t1 ALTER COLUMN c1 SET DEFAULT 111;
--error 1235
ALTER TABLE t1 ALTER COLUMN c4 SET DEFAULT 111;

	
##删除列默认值	不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) DEFAULT 999999999,c2 int(10), c3 int, c4 int DEFAULT 999999999);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
--error 1235
ALTER TABLE t1 ALTER COLUMN c1 DROP DEFAULT;
--error 1235
ALTER TABLE t1 ALTER COLUMN c4 DROP DEFAULT;


	
##修改自增列值   不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) AUTO_INCREMENT PRIMARY KEY,c2 int(10), c3 int, c4 int DEFAULT 999999999);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 AUTO_INCREMENT=12;

##修改为自增列  不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10),c2 int(10), c3 int, c4 int DEFAULT 999999999);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 MODIFY c1 int AUTO_INCREMENT;

##添加/删除 STORED 生成列
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10),c2 int(10), c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 ADD COLUMN c5 number AS (c4*2) STORED;

DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10),c2 int(10), c3 int, c4 int,c5 number AS (c4*2) STORED);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 drop COLUMN c5 ;



##重命名列		不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) ,c2 int(10), c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
--error 1235
ALTER TABLE t1 RENAME COLUMN c1 TO c5;
--error 1235
ALTER TABLE t1 RENAME COLUMN c4 TO c6;


##增加或减少列类型长度或精度	不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int ,c2 varchar(10), c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
--error 1235
ALTER TABLE t1 MODIFY c1 int(20);
--error 1235
ALTER TABLE t1 MODIFY c1 int(5);
--error 1235
ALTER TABLE t1 MODIFY c1 int(10);
--error 1235
ALTER TABLE t1 MODIFY c2 varchar(10);
--error 1235
ALTER TABLE t1 MODIFY c2 varchar(11);
--error 1235
ALTER TABLE t1 MODIFY c2 varchar(1);
--error 1235
ALTER TABLE t1 MODIFY c2 varchar(0);
--error 1235
ALTER TABLE t1 MODIFY c2 varchar(1.1);



##混合列操作	Oracle不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) ,c2 varchar(10), c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
--error 1235
ALTER TABLE t1  ADD (c5 int, c6 int),  MODIFY c1 int;


--echo ##外键约束操作  支持
##增加外键
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
alter table t1 add constraint fk_c2 foreign key(c2) references t1(c1);

##删除外键
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int,constraint fk_c2 foreign key(c2) references t1(c1));
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
alter table  t1 drop constraint fk_c2;

##check约束 
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
ALTER TABLE t1 ADD CONSTRAINT fk_c2 FOREIGN KEY (c2) REFERENCES t1(c1);
ALTER TABLE t1 ADD CONSTRAINT chk_2 CHECK (c2 > 0);
ALTER TABLE t1 DROP  CONSTRAINT fk_c2 ;




##重命名表  不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 RENAME TO t2;



##修改行格式  不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 ROW_FORMAT = COMPRESSED;
--error 1235
ALTER TABLE t1 ROW_FORMAT = DEFAULT ;
--error 1235
ALTER TABLE t1 ROW_FORMAT = DYNAMIC ;
--error 1235
ALTER TABLE t1 ROW_FORMAT = REDUNDANT ;
--error 1235
ALTER TABLE t1 ROW_FORMAT = COMPACT;



##修改块大小  不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 BLOCK_SIZE = 1024;
--error 1235
ALTER TABLE t1 BLOCK_SIZE = 1048576;
--error 1235
ALTER TABLE t1 BLOCK_SIZE = 10476;
--error 5258
ALTER TABLE t1 BLOCK_SIZE = 1;


##修改压缩算法 不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;

--error 1235
ALTER TABLE t1 ROW_FORMAT = COMPRESSED;
--error 1235
ALTER TABLE t1 ROW_FORMAT = DEFAULT ;
--error 1235
ALTER TABLE t1 ROW_FORMAT = DYNAMIC ;
--error 1235
ALTER TABLE t1 ROW_FORMAT = REDUNDANT ;
--error 1235
ALTER TABLE t1 ROW_FORMAT = COMPACT;

##转换字符集  不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int) CHARACTER SET gbk;
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 CONVERT TO CHARACTER SET utf8mb4 COLLATE utf8mb4_bin;

DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 VARCHAR(50) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL ) ;
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 MODIFY c4 VARCHAR(50) CHARACTER SET gbk ;


##优化表空间 理解应该选择合适的表大小; 不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 BLOCK_SIZE = 1024;
--error 1235
ALTER TABLE t1 BLOCK_SIZE = 1048576;
--error 1235
ALTER TABLE t1 BLOCK_SIZE = 10476;
--error 1235
ALTER TABLE t1 BLOCK_SIZE = 1024;


##添加/删除分区  不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (
      c1      bigint NOT NULL
      , c2 varchar(50)
      , c3  timestamp NOT NULL  
  ) PARTITION BY RANGE(UNIX_TIMESTAMP(c3))
  (
      PARTITION M202001 VALUES LESS THAN(UNIX_TIMESTAMP('2020/02/01'))
      , PARTITION M202002 VALUES LESS THAN(UNIX_TIMESTAMP('2020/03/01'))
      , PARTITION M202003 VALUES LESS THAN(UNIX_TIMESTAMP('2020/04/01'))
      , PARTITION M202004 VALUES LESS THAN(UNIX_TIMESTAMP('2020/05/01'))
      , PARTITION M202005 VALUES LESS THAN(UNIX_TIMESTAMP('2020/06/01'))
  );
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2) including new values;
--error 1235
ALTER TABLE t1 ADD PARTITION(PARTITION M202006 VALUES LESS THAN(UNIX_TIMESTAMP('2020/07/01')));
--error 1235
ALTER TABLE t1 DROP PARTITION M202006;



##重分区  不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1(c1 INT, c2 DATETIME, PRIMARY KEY(c1, c2)) PARTITION BY HASH(c1) PARTITIONS 4;
create materialized view log on t1 parallel 9 with rowid, sequence including new values;
--error 1235
ALTER TABLE t1 PARTITION BY KEY(c1) PARTITIONS 10;


##修改为二级分区表  不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1(c1 INT, c2 DATETIME, PRIMARY KEY(c1, c2)) PARTITION BY HASH(c1) PARTITIONS 4;
create materialized view log on t1 parallel 9 with rowid, sequence including new values;
--error 1235
ALTER TABLE t1 PARTITION BY HASH(c1)SUBPARTITION BY RANGE COLUMNS(c2) SUBPARTITION TEMPLATE( SUBPARTITION p1 VALUES LESS THAN ('2016-10-10'), SUBPARTITION p2 VALUES LESS THAN ('2116-3-30')) PARTITIONS 2;


##TRUNCATE 表  不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
TRUNCATE table t1;


##删除表  不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
drop table t1;

##修改分区规则  不支持
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
create table t1 (c1 int primary key, c2 varchar(10))partition by hash(c1) partitions 5;
create materialized view log on t1 parallel 9 with rowid, sequence (c2) including new values;
--error 1235
ALTER TABLE t1 DROP PARTITION p3;
--error 1235
ALTER TABLE t1 TRUNCATE PARTITION p2;
--error 1064
ALTER TABLE t1 ADD PARTITION (p6);

##普通表转为分区表  语法不支持
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
CREATE TABLE t1(c1 int PRIMARY KEY, c2 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2) including new values;
--error 1064
ALTER TABLE t1 MODIFY PARTITION BY HASH(c1) PARTITIONS 4;


##TRUNCATE 分区  不支持
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
CREATE TABLE t1 (
      c1      bigint NOT NULL
      , c2 varchar(50)
      , c3  timestamp NOT NULL  
  ) PARTITION BY RANGE(UNIX_TIMESTAMP(c3))
  (
      PARTITION M202001 VALUES LESS THAN(UNIX_TIMESTAMP('2020/02/01'))
      , PARTITION M202002 VALUES LESS THAN(UNIX_TIMESTAMP('2020/03/01'))
      , PARTITION M202003 VALUES LESS THAN(UNIX_TIMESTAMP('2020/04/01'))
      , PARTITION M202004 VALUES LESS THAN(UNIX_TIMESTAMP('2020/05/01'))
      , PARTITION M202005 VALUES LESS THAN(UNIX_TIMESTAMP('2020/06/01'))
  );
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2) including new values;
--error 1235
ALTER TABLE t1 TRUNCATE PARTITION M202001, M202002;
drop materialized view log on t1;



