DROP MATERIALIZED VIEW LOG ON t2;
DROP TABLE t1;
DROP TABLE t2;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand  enable on query  computation    as select c1 as c1, count(*) cnt from t1 group by c1;
ALTER TABLE mv1 ADD CONSTRAINT check1 CHECK (c1>1);
--error 2443
ALTER TABLE mv1 drop CONSTRAINT check1 ;
