# tags: basic
# author: wb-ljh01399065
 
purge recyclebin;


--disable_warnings
--error 0,00600
drop user ljh cascade;
--enable_warnings
 
--echo # 创建用户并使用
create user ljh IDENTIFIED BY ljh;
grant all on *.* to ljh WITH GRANT OPTION;
grant dba to ljh;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,ljh@oracle,ljh,ljh,$OBMYSQL_PORT);
connection conn;
 
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

alter session set nls_date_format ='YYYY-MM-DD HH24:MI:SS';
alter session set nls_timestamp_format='YYYY-MM-DD HH24:MI:SS.FF';
alter session set nls_timestamp_tz_format='YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
alter session set time_zone='+08:00';

--disable_warnings
--source mysql_test/include/ignore_drop_mlog_err_oracle.inc
drop materialized view log on t1;
--source mysql_test/include/ignore_drop_mlog_err_oracle.inc
drop materialized view log on t2;
--source mysql_test/include/ignore_drop_mlog_err_oracle.inc
drop materialized view log on mv1;
--source mysql_test/include/ignore_drop_mlog_err_oracle.inc
drop materialized view log on mv2;
--source mysql_test/include/ignore_drop_mview_err_oracle.inc
drop materialized view mv1;
--source mysql_test/include/ignore_drop_mview_err_oracle.inc
drop materialized view mv2;
--source mysql_test/include/ignore_drop_table_err.inc
drop table t1;
--source mysql_test/include/ignore_drop_table_err.inc
drop table t2;
--enable_warnings


--echo ##增加多表join增量刷新的case
--echo ##两表内连接
create table t1 (c1 number(10) primary key,c2 number(10), c3 number, c4 number);
create table t2 (a1 number(10) primary key,a2 number(10), a3 number, a4 number);
create materialized view log on t1 parallel 2 with primary key, rowid, sequence (c2,c3,c4) including new values;
create materialized view log on t2 parallel 2 with primary key, rowid, sequence (a2,a3,a4) including new values;
create materialized view mv1  parallel 2 refresh fast on demand  as select c1 as c1,a1 as a1 from t1,t2 where t1.c1 = t2.a1 ;
insert into t1 values(1,2,3,4);
insert into t2 values(1,1,3,4);
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1;
drop materialized view mv1;

--echo ##使用union all/union
--source mysql_test/include/ignore_drop_mview_err_oracle.inc
DROP materialized view mv1;
--source mysql_test/include/ignore_drop_mview_err_oracle.inc
DROP materialized view mv2; 
DROP MATERIALIZED VIEW LOG ON t1;
DROP MATERIALIZED VIEW LOG ON t2;
DROP TABLE t1;
DROP TABLE t2;
create table t1 (c1 number(10) primary key,c2 number(10), c3 number, c4 number);
create table t2 (a1 number(10) primary key,a2 number(10), a3 number, a4 number);
create materialized view log on t1 parallel 2 with primary key, rowid, sequence (c2,c3,c4) including new values;
create materialized view log on t2 parallel 2 with primary key, rowid, sequence (a2,a3,a4) including new values;
--error 12052
create materialized view mv1  parallel 2 refresh fast on demand  as select c1 as c1 from t1 union all select a1 as a1  from t2;
--error 12052
create materialized view mv1  parallel 2 refresh fast on demand  as select c1 as c1 from t1 union  select a1 as a1  from t2;

--echo ##验证存在不兼容点 
--echo ##包含group by
DROP MATERIALIZED VIEW LOG ON t1;
DROP MATERIALIZED VIEW LOG ON t2;
DROP TABLE t1;
DROP TABLE t2;
create table t1 (c1 number(10) primary key,c2 number(10), c3 number, c4 number);
create table t2 (a1 number(10) primary key,a2 number(10), a3 number, a4 number);
create materialized view log on t1 parallel 2 with primary key, rowid, sequence (c2,c3,c4) including new values;
create materialized view log on t2 parallel 2 with primary key, rowid, sequence (a2,a3,a4) including new values;
--error 600
create materialized view mv1  parallel 2 refresh fast on demand  as select c1 as c1,a1 as a1, count(*) from t1,t2 group by c1,a1;

--echo ##连接表不具备主键
DROP MATERIALIZED VIEW LOG ON t1;
DROP MATERIALIZED VIEW LOG ON t2;
DROP TABLE t1;
DROP TABLE t2;
create table t1 (c1 number(10),c2 number(10), c3 number, c4 number);
create table t2 (a1 number(10),a2 number(10), a3 number, a4 number);
create materialized view log on t1 parallel 2 with primary key, rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view log on t2 parallel 2 with primary key, rowid, sequence (a1,a2,a3,a4) including new values;
--error 12052
create materialized view mv1  parallel 9 refresh fast on demand  as select c1 as c1,a1 as a1 from t1,t2 where t1.c1 = t2.a1 ;

--echo ##内联视图
DROP MATERIALIZED VIEW LOG ON t1;
DROP MATERIALIZED VIEW LOG ON t2;
DROP TABLE t1;
DROP TABLE t2;
create table t1 (c1 number(10) ,c2 number(10), c3 number, c4 number,primary key(c1));
create table t2 (a1 number(10) ,a2 number(10), a3 number, a4 number,primary key(a1));
create materialized view log on t1 parallel 2 with primary key, rowid, sequence (c2,c3,c4) including new values;
create materialized view log on t2 parallel 2 with primary key, rowid, sequence (a2,a3,a4) including new values;
--error 12052
create materialized view mv1 refresh fast on demand as select c1 as c1 ,a.a1 as a1 from (select a1 from t2)a,t1 where  t1.c1 = a.a1 ;
--error 12052
create materialized view mv2 refresh fast on demand as select count(c2) cnt_c1, sum(c2) sum_c1 from t1,(select a1 from t2)a;


--echo ##rt_mv上存在函数索引
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
create table t1 (c1 number(10) primary key,c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with primary key, rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation as select c1 as c1,count(*) cnt from t1 group by c1;
--error 600
create index idx1 on mv1(abs(c1));
select * from mv1 order by c1;


--echo ##存在列运算
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) primary key,c2 number(10), c3 number, c4 number);
insert into t1 values(1,2,1,-1);
insert into t1 values(-1,1,1,1);
insert into t1 values(2,1,3,1);
create materialized view log on t1 parallel 2 with primary key, rowid, sequence (c2,c4) including new values;
create materialized view mv1  parallel 2 refresh fast on demand enable on query  computation  as select a.c1 as ac1,b.c1 as bc1,a.c1+b.c2 cc from t1 a,t1 b where a.c1 = b.c1;
select * from mv1 order by ac1;

DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) primary key,c2 number(10), c3 number, c4 number);
insert into t1 values(1,2,1,-1);
insert into t1 values(-1,null,1,1);
insert into t1 values(2,null,3,1);
create materialized view log on t1 parallel 2 with primary key, rowid, sequence (c2,c4) including new values;
create materialized view mv1  parallel 2 refresh fast on demand enable on query  computation  as select a.c1 as ac1,b.c1 as bc1,a.c2 as c2,b.c4 as cc from t1 a,t1 b where a.c1 = b.c1;
update t1 set c1 =(select max(ac1) from mv1) where c3 =3;
delete from t1 where c2 in (select cc from mv1 where ac1<>1);
select * from mv1 order by ac1;


--echo ##单表简单查询
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values(1,1,1,1);
insert into t1 values(null,1,1,1);
CALL DBMS_MVIEW.REFRESH('mv1','f');
select c1 *12-1/1 from mv1 order by c1;
select max(c1) * max(c1)* max(c1)from mv1;
select min(c1) * min(c1)* min(c1)from mv1;
select avg(c1) * avg(c1)* avg(c1)from mv1;
select sum(c1) * sum(c1)* sum(c1)from mv1;
select count(c1) * count(c1) * count(c1)from mv1;

