--disable_warnings
drop database  IF EXISTS  ljh;
--enable_warnings
create database ljh;
use ljh;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='';



--echo ##修改table_dop
create table t1 (c1 int,c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand as select c1 as c1, count(*) cnt from t1 group by c1;
ALTER TABLE t1 PARALLEL  4;
--error 1235
ALTER TABLE mlog$_t1 PARALLEL  4;


DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;

create table t1 (c1 int,c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand as select c1 as c1, count(*) cnt from t1 group by c1;
ALTER TABLE t1 PARALLEL  4;
--error 1235
ALTER TABLE mlog$_t1 PARALLEL  4;


--echo ##charset_type --mysql不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int) CHARACTER SET gbk;
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 CONVERT TO CHARACTER SET utf8mb4 COLLATE utf8mb4_bin;

DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 VARCHAR(50) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL ) ;
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
--error 1235
ALTER TABLE t1 MODIFY c4 VARCHAR(50) CHARACTER SET gbk ;

DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int) CHARACTER SET gbk;
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand as select c1 as c1, count(*) cnt from t1 group by c1;

ALTER TABLE t1 CHARACTER SET utf8mb4;
--error 1235
ALTER TABLE mv1  CHARACTER SET utf8mb4 COLLATE utf8mb4_bin;

DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 VARCHAR(50) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL ) ;
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand as select c1 as c1, count(*) cnt from t1 group by c1;
--error 1235
ALTER TABLE t1 MODIFY c4 VARCHAR(50) CHARACTER SET gbk ;
--error 1235
ALTER TABLE mv1 MODIFY c1 VARCHAR(50) CHARACTER SET gbk ;

DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int) CHARACTER SET gbk;
create materialized view mv1  parallel 9 refresh complete on demand as select c1 as c1, count(*) cnt from t1 group by c1;
ALTER TABLE t1 CONVERT TO CHARACTER SET utf8mb4 COLLATE utf8mb4_bin;

DROP TABLE t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int) CHARACTER SET gbk;
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
ALTER TABLE t1 CHARACTER SET utf8mb4;
##这个语句是会修改列字符集的 而基表存在mlog，所以会不允许 
--error 1235
ALTER TABLE t1 CONVERT TO CHARACTER SET utf8mb4;

--echo ##设置表注释
##全量刷新
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int) comment ='table name is t1';
create materialized view mv1  parallel 9 refresh complete on demand as select c1 as c1, count(*) cnt from t1 group by c1;
ALTER TABLE t1 COMMENT = 'Your table comment here';
#SELECT table_comment FROM information_schema.tables WHERE table_schema = 'TEST' AND table_name = 'T1';

##增量刷新
DROP TABLE t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int) comment ='table name is t1';
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand as select c1 as c1, count(*) cnt from t1 group by c1;
ALTER TABLE t1 COMMENT = 'Your table comment here';
#SELECT table_comment FROM information_schema.tables WHERE table_schema = 'TEST' AND table_name = 'T1';


