--echo ##设置列注释
##全量刷新
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 INT primary key,c2 number(10), c3 number, c4 number);
create materialized view mv1(primary key(c1))  parallel 9 refresh complete on demand as select c1 as c1, count(*) cnt from t1 group by c1;
ALTER TABLE t1 MODIFY COLUMN c1 int COMMENT  '  ';
--error 1235
ALTER TABLE mv1 MODIFY COLUMN c1 int COMMENT  '  ';
ALTER TABLE t1 MODIFY COLUMN c1 INT  COMMENT '这是列注释';
--error 1235
ALTER TABLE mv1 MODIFY COLUMN c1 INT  COMMENT '这是列注释';
SHOW FULL COLUMNS FROM t1 ;
SHOW FULL COLUMNS FROM mv1 ;



##增量刷新
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand as select c1 as c1, count(*) cnt from t1 group by c1;
--error 1235
ALTER TABLE t1 MODIFY COLUMN c1 int COMMENT  '  ';
--error 1235
ALTER TABLE mv1 MODIFY COLUMN c1 int COMMENT  '  ';
--error 1235
ALTER TABLE t1 MODIFY COLUMN c1 INT  COMMENT '这是列注释';
