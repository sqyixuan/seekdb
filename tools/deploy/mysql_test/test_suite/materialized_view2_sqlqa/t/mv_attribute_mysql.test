create materialized view log on t1 with PRIMARY KEY,rowid, sequence (c2) including new values;
create materialized view mv1(c1,c2) partition by list(c1) (PARTITION p1 VALUES in(1,999,888),PARTITION p2 VALUES in(2,null)) refresh fast on demand as select count(*) as cnt,c1 as c1 from t1 group by c1;
insert into t1 values(1,1);
