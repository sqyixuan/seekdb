--echo ##增量刷新 删除mv的列
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 int , c2 varchar(100));
create materialized view log on t1 with rowid, sequence (c1,c2) including new values ;
create materialized view mv1 partition by hash(cnt) (PARTITION p1,PARTITION p2 ) refresh fast as select c2 as c2 ,count(*) as cnt from t1 group by c2;
