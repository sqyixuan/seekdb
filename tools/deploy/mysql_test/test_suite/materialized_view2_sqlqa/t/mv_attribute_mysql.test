--echo ##mv设置check约束
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
CREATE TABLE t1 (c1 varchar(200));
CREATE MATERIALIZED VIEW mv1 as select * from t1 ;
INSERT INTO t1 VALUES (2);
--error 1235
ALTER TABLE mv1 ADD CONSTRAINT check1 CHECK (c1 >1);
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from t1;
select * from mv1 order by 1;

--echo ##禁用表约束
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 number,CONSTRAINT check_C1 check (c1>1));
CREATE MATERIALIZED VIEW mv1 as select * from t1 ;
--error 1064
ALTER TABLE t1 DISABLE  CONSTRAINT check_C1;
--error 1235
ALTER TABLE mv1 ADD CONSTRAINT check1 CHECK (c1 >1);
--error 1064
ALTER TABLE mv1 DISABLE  CONSTRAINT check1;


drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 number,CONSTRAINT check_C1 check (c1>1));
create materialized view log on t1 with rowid, sequence (c1) including new values ;
CREATE MATERIALIZED VIEW mv1 refresh fast as select count(*) as cnt,c1 as c1 from t1 group by c1;
insert into t1 values(2);
--error 1235
ALTER TABLE mv1 ADD CONSTRAINT check1 CHECK (c1 >1);
--error 1064
ALTER TABLE mv1 DISABLE  CONSTRAINT check1;
--error 3819
insert into t1 values(1);
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from t1;
select * from mv1 order by 1;


--echo ## 重分区--不支持

--echo ##使用复制表
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 varchar(200));
create materialized view log on t1 with rowid, sequence (c1) including new values ;
create table tt1 as select c1 from mlog$_t1;
create materialized view log on tt1 with rowid, sequence (c1) including new values ;
CREATE MATERIALIZED VIEW mv1  refresh fast as select count(*) cnt,c1 as c1 from tt1 group by c1;
insert into tt1(c1) values('{"name": "John Doe", "age": 999}');
insert into tt1(c1) values(1);
insert into tt1(c1) values('中文');
CALL DBMS_MVIEW.REFRESH('mv1','f');
--error 1235
truncate table mv1 ;


create table ttt1 as select * from mv1;
select * from ttt1 order by c1;
truncate table ttt1 ;

DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key, c2 int  check(1<1)) ;
create materialized view log on t1 with rowid, sequence (c2) including new values ;
create materialized view mv1(c1,c2) partition by list(c1) (PARTITION partition_1 VALUES in(1,888,999),PARTITION partition_2 VALUES in(2,null))  refresh fast as select c2 as c2 ,count(*) as cnt from t1 group by c2;
--error 1235
alter table mv1 drop c2;
--error 1064
ALTER TABLE mv1 PARTITION partition_1 RENAME TO new_partition_1;


DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key, c2 int  check(1<1)) ;
create materialized view mv1(c1,c2) partition by list(c1) (PARTITION partition_1 VALUES in(1,888,999),PARTITION partition_2 VALUES in(2,null))  as select c2 as c2 ,count(*) as cnt from t1 group by c2;
alter table t1 drop c2;

drop table t1;
drop materialized view mv1;
create table t1 (c1 int , c2 int check(11>0),c3 int check(1>0)) ;
create materialized view log on t1 with rowid, sequence (c1,c3,c2) including new values ;
create materialized view mv1 refresh fast as select c2 as c2,count(*) as cnt from t1 group by c2 ;
--error 1235
ALTER TABLE t1 RENAME COLUMN c1 TO c1;
--error 1235
ALTER TABLE t1 RENAME COLUMN c1 TO c2;


DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key, c2 int check(11>null)) ;
create materialized view mv1 as select * from t1 ;
ALTER TABLE t1 ADD c3 json ;
insert into t1 values(1,2,'{"name": "John Doe", "age": 999}');
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from mv1;

drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key, c2 int UNIQUE,c3 VARCHAR(100) ) ;
create materialized view log on t1 with rowid, sequence (c2,c3) including new values ;
create materialized view mv1 refresh fast as select c3 as c3,count(*) as cnt from t1 group by c3 ;
insert into t1 values(1,2,'{"name": "John Doe", "age": 999}');
--error 1235
ALTER TABLE t1 MODIFY c3 VARCHAR(100) ;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1;
select * from t1;
show index from mv1;
show index from t1;


--echo ##全量刷新 添加列为多模类型覆盖测试
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 int , c2 varchar(100)) PARTITION BY HASH(c1) PARTITIONS 8;
create materialized view mv1 partition by hash(c1) (PARTITION p1,PARTITION p2 ) as select * from t1;
insert into t1(c2) values('{"name": "John Doe", "age": 999}');
--error 1235
ALTER TABLE mv1 ADD (c3 VARCHAR(255));
--error 1235
ALTER TABLE mv1 ADD (c4 json);
--error 1064
ALTER TABLE mv1 ADD (c5 xmltype);
--error 1064
ALTER TABLE mv1 ADD (c6 SDO_GEOMETRY);
CALL DBMS_MVIEW.REFRESH('mv1','c');
##show create table mv1;
select * from t1;
select * from mv1;


--echo ##全量刷新 删除mv的列
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 int , c2 json);
create materialized view mv1 partition by hash(c1) (PARTITION p1,PARTITION p2 ) as select * from t1;
insert into t1(c2) values('{"name": "John Doe", "age": 999}');
--error 1235
ALTER TABLE mv1 drop column c2;
CALL DBMS_MVIEW.REFRESH('mv1','c');
##show create table mv1;
select * from t1;
select * from mv1;



--echo ##增量刷新 添加列为多模类型覆盖测试
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 int , c2 varchar(100)) PARTITION BY HASH(c1) PARTITIONS 8;
create materialized view log on t1 with rowid, sequence (c1,c2) including new values ;
create materialized view mv1 partition by hash(c1) (PARTITION p1,PARTITION p2 ) refresh fast as select c1 as c1 ,count(*) as cnt from t1 group by c1;
