ALTER TABLE mv1 MODIFY COLUMN c1 INT  COMMENT '这是列注释';
SHOW FULL COLUMNS FROM t1 ;
SHOW FULL COLUMNS FROM mv1 ;


--echo ##如合并分区、拆分分区、修改分区，移动分区，删除分区
##合并分区 --ob不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
CREATE TABLE t1 (
  c1 NUMBER,
  c2 NUMBER,
  c3 NUMBER,
  c4 int,
  c5 NUMBER
)
PARTITION BY RANGE (c4) (
  PARTITION p0 VALUES LESS THAN (100),
  PARTITION p1 VALUES LESS THAN (200),
  PARTITION p2 VALUES LESS THAN (300),
  PARTITION p3 VALUES LESS THAN (400)
);
--error 1064
ALTER TABLE t1 MERGE PARTITIONS p1, p2 INTO PARTITION p1_p2;


##拆分分区 --ob不支持
DROP TABLE t1;
CREATE TABLE t1 (
  c1 NUMBER,
  c2 NUMBER,
  c3 NUMBER,
  c4 int,
  c5 NUMBER
)
PARTITION BY RANGE (c4) (
  PARTITION p0 VALUES LESS THAN (100),
  PARTITION p1 VALUES LESS THAN (200),
  PARTITION p2 VALUES LESS THAN (300),
  PARTITION p3 VALUES LESS THAN (400)
);
--error 1064
ALTER TABLE t1 SPLIT PARTITION p1 AT (TO_DATE('2021-06-01', 'YYYY-MM-DD')) INTO (PARTITION p1a, PARTITION p1b);


##修改分区
drop table t1;
CREATE TABLE t1 (c1 int,c2 int);
create materialized view log on t1 with rowid, sequence (c1,c2) including new values ;
create materialized view mv1  partition by list(c1) (PARTITION p1 VALUES in(1,5,9),PARTITION p2 VALUES in(2,6,10),PARTITION p3 VALUES in(3,7,0), PARTITION p4 VALUES in(4,8,null)) as select c1,count(*) cnt from t1 group by c1;
--echo ##重命名分区
--error 1064
ALTER TABLE mv1 RENAME PARTITION p1 TO p100;
--echo ##清空数据
--error 1235
ALTER TABLE mv1 TRUNCATE PARTITION p1;
--echo ##删除分区
--error 1235
ALTER TABLE mv1 DROP PARTITION p1;

--echo ##mv为list分区
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (
    c1 int NOT NULL,
    c2 VARCHAR(50),
    c3 VARCHAR(50) NOT NULL,
    c4 VARCHAR(100) NOT NULL,
    c5 VARCHAR(20),
    c6 DATE NOT NULL,
    c7 VARCHAR(10) NOT NULL,
    c8 NUMBER(8,2),
    c9 NUMBER(2,2),
    c10 int,
    c11 NUMBER(10),
    CONSTRAINT t1_primary_key PRIMARY KEY (c1),
    CONSTRAINT t1_unique_c4 UNIQUE (c4),
    CONSTRAINT t1_c8_check CHECK (c8 > 0),
    CONSTRAINT t1_c10_fk FOREIGN KEY (c10)
        REFERENCES t1 (c1)
);
CREATE MATERIALIZED VIEW mv1 PARTITION BY LIST (c1) (PARTITION p1 VALUES in(1,5,9),PARTITION p2 VALUES in(2,6,10),PARTITION p3 VALUES in(3,7,0), PARTITION p4 VALUES in(4,8,null)) as select * from t1 order by c1 limit 10;
