--echo ##创建list+list分区的mv
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key, c2 int) ;
create materialized view log on t1 with PRIMARY KEY,rowid, sequence (c2) including new values;
--error 1526
create materialized view mv1(c1,c2) PARTITION BY LIST(c1)
SUBPARTITION BY LIST(c1) (
  PARTITION p0 VALUES in(1,2,3,4) (
    SUBPARTITION p_1 VALUES in(3),
    SUBPARTITION p_2 VALUES in(4)
  ),
  PARTITION p1 VALUES in(5,6,7,8) (
    SUBPARTITION p_3 VALUES in(5),
    SUBPARTITION p_4 VALUES in(8)
  )
)
refresh fast on demand as select count(*) as cnt,c1 as c1 from t1 group by c1;


--echo ##创建hash+hash分区的mv
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 VARCHAR(999) not null) PARTITION BY HASH(c1) PARTITIONS 8;
create materialized view log on t1 with rowid, sequence (c2) including new values;
create materialized view mv1 partition by hash(c1)
SUBPARTITION BY hash(c1) 
(PARTITION p1,PARTITION p2,PARTITION p3,PARTITION p4,PARTITION p5,PARTITION p6,PARTITION p7,PARTITION p8,PARTITION p9,PARTITION p10,PARTITION p11,PARTITION p12,PARTITION p13,PARTITION p14,PARTITION p15,PARTITION p16 )refresh fast on demand as select count(*) as cnt,c1 as c1 from t1 group by c1;
