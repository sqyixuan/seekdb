drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (
    c1 int NOT NULL,
    c2 VARCHAR(50),
    c3 VARCHAR(50) NOT NULL,
    c4 VARCHAR(100) NOT NULL,
    c5 VARCHAR(20),
    c6 DATE NOT NULL,
    c7 VARCHAR(10) NOT NULL,
    c8 NUMBER(8,2),
    c9 NUMBER(2,2),
    c10 int,
    c11 int,
    CONSTRAINT t1_primary_key PRIMARY KEY (c1),
    CONSTRAINT t1_unique_c4 UNIQUE (c4),
    CONSTRAINT t1_c8_check CHECK (c8 > 0),
    CONSTRAINT t1_c10_fk FOREIGN KEY (c10)
        REFERENCES t1 (c1)
);
create materialized view log on t1 with rowid, sequence (c2,c3,c4,c5,c6,c7,c8,c9,c10,c11) including new values ;
CREATE MATERIALIZED VIEW mv1 PARTITION BY LIST (c11) (PARTITION p1 VALUES in(1,5,9),PARTITION p2 VALUES in(2,6,10),PARTITION p3 VALUES in(3,7,0), PARTITION p4 VALUES in(4,8,null)) refresh fast as select count(*) cnt,c11 as c11 from t1 group by c11;
