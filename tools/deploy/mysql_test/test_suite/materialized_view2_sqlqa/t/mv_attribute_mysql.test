--echo ##创建range+hash分区的mv
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key, c2 int) ;
create materialized view log on t1 with PRIMARY KEY,rowid, sequence (c2) including new values;
create materialized view mv1(c1,c2) partition by RANGE(c1)SUBPARTITION BY HASH(c1) SUBPARTITIONS 4 ( 
PARTITION p1 VALUES LESS THAN (3),
PARTITION p2 VALUES LESS THAN (5)
) refresh fast on demand as select count(*) as cnt,c1 as c1 from t1 group by c1;
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(5,3);
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1 order by c2;

--echo ##创建range+list分区的mv
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key, c2 int) ;
create materialized view log on t1 with PRIMARY KEY,rowid, sequence (c2) including new values;
--error 1064
create materialized view mv1 partition by RANGE(c1) (
  PARTITION p1 VALUES LESS THAN (3) (
    SUBPARTITION p_1 VALUES in(1,2,3),
    SUBPARTITION p_2 VALUES in(4,5),
    SUBPARTITION p_3 VALUES in(7),
    SUBPARTITION p_4 VALUES in(9)
  ),
  PARTITION p2 VALUES LESS THAN (8) (
    SUBPARTITION p_5 VALUES in(6,8),
    SUBPARTITION p_6 VALUES in(10)
  )
) refresh fast on demand as select count(*) as cnt,c1 as c1 from t1 group by c1;



--echo ##创建range+range分区的mv
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
create table t1 (c1 int primary key, c2 int) ;
create materialized view log on t1 with PRIMARY KEY,rowid, sequence (c2) including new values;
create materialized view mv1 partition by RANGE(c1)SUBPARTITION BY RANGE(c1) (
PARTITION p0 VALUES LESS THAN(0),
PARTITION p1 VALUES LESS THAN(100)
)
refresh fast on demand as select count(*) as cnt,c1 as c1 from t1 group by c1;

