--echo ##创建hash分区的mv
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 VARCHAR(999) not null) PARTITION BY HASH(c1) PARTITIONS 8;
create materialized view log on t1 with rowid, sequence (c2) including new values;
create materialized view mv1(c1, c2) partition by hash(c1) (PARTITION p1,PARTITION p2,PARTITION p3,PARTITION p4,PARTITION p5,PARTITION p6,PARTITION p7,PARTITION p8,PARTITION p9,PARTITION p10,PARTITION p11,PARTITION p12,PARTITION p13,PARTITION p14,PARTITION p15,PARTITION p16,PARTITION p17,PARTITION p18,PARTITION p19,PARTITION p20,PARTITION p21,PARTITION p22,PARTITION p23,PARTITION p24,PARTITION p25,PARTITION p26,PARTITION p27,PARTITION p28,PARTITION p29,PARTITION p30,PARTITION p31,PARTITION p32 )refresh fast on demand as select count(*) as cnt,c1 as c1 from t1 group by c1;
insert into t1 values(1,'中文ing23');
CALL DBMS_MVIEW.REFRESH('mv1','f');
##show create table mv1;
select * from t1 ;
select * from mv1 ;


--echo ##创建range分区的mv
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 number PRIMARY KEY, c2 number not null) ;
create materialized view log on t1 with PRIMARY KEY,rowid, sequence (c2) including new values;
create materialized view mv1(c1, c2) partition by range(c1) (PARTITION p1 VALUES LESS THAN (3),PARTITION p2 VALUES LESS THAN (8)) refresh fast on demand as select count(*) as cnt,c1 as c1 from t1 group by c1;
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(5,3);
CALL DBMS_MVIEW.REFRESH('mv1','f');
##show create table mv1;
select * from t1 order by c1 ;
select * from mv1 PARTITION(p1) order by c2;
select * from mv1 PARTITION(p2) order by c2;
##SHOW CREATE TABLE t1;
##SHOW CREATE TABLE mv1;

