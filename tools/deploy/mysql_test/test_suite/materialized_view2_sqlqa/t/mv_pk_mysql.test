--echo ##json列join --oracle不支持
DROP MATERIALIZED VIEW LOG ON t2;
drop table t1;
drop table t2;
drop  materialized view mv2;
create table t1 (c1 json, c2 json);
insert into t1(c1) values('{"key":[1,0,false,true]}');
create table t2(c1 int primary key, c2 int, c3 int, c4 json);
insert into t2 values(1,null,null,'{"key":[1,0,false,true]}');
create materialized view mv1 parallel 9 refresh complete on demand  as select * from t1 ;
select * from mv1,t2 where mv1.c2=t2.c4;


--echo ##full outer join
drop table t1;
drop table t2;
drop  materialized view mv1;
create table t1(pk int primary key, c1 int);
create table t2(c1 int);
create materialized view log on t1 with primary key, rowid, sequence ( c1) including new values;
create materialized view log on t2 with primary key, rowid, sequence ( c1) including new values;
create materialized view mv1(primary key(c1)) refresh fast on demand  enable on query computation  as select c1 as c1,count(*) cnt from t1 group by c1;
create materialized view mv2(primary key(cnt_c1)) refresh fast on demand  enable on query computation as select count(c1) cnt_c1, sum(c1) sum_c1 from t2;
insert into t1 values(1, null);
insert into t2 values(2);
select v.* from mv2 full outer join (select c1, 1 as c2 from mv1) v on mv2.cnt_c1 = v.c1 order by c1,c2;


--echo ##全量mv与rt_mv连接
DROP MATERIALIZED VIEW LOG ON t1;
DROP MATERIALIZED VIEW LOG ON t2;
drop table t1;
drop table t2;
drop  materialized view mv1;
drop  materialized view mv2;
create table t1 (c1 json, c2 json);
insert into t1(c1) values('{"bh": 12345, "xxmc": "北京大学"}');
create table t2(c1 int primary key, c2 int, c3 int, c4 int);
insert into t2 values(1,null,null,1);
create materialized view log on t2 with primary key, rowid, sequence ( c2, c3) including new values;
create materialized view mv1 parallel 9 refresh complete on demand  as select * from t1 ;
create materialized view mv2 refresh fast on demand  enable on query computation as select count(c3) cnt_c3, sum(c3) sum_c3 from t2;
select * from mv1,mv2;

--echo ##存在lob列和其他类型列join
DROP MATERIALIZED VIEW LOG ON t2;
drop table t1;
drop table t2;
drop  materialized view mv1;
drop  materialized view mv2;
create table t1 (c1 blob, c2 blob);
insert into t1(c1) values('1');
create table t2(c1 int primary key, c2 varchar(40), c3 int, c4 blob);
insert into t2 values(1,'1',null,'1');
create materialized view log on t2 with primary key, rowid, sequence ( c2, c3) including new values;
create materialized view mv1 parallel 9 refresh complete on demand  as select * from t1 ;
create materialized view mv2(primary key(c2)) refresh fast on demand   as select c2,count(*) cnt,count(c3) cnt_c3, sum(c3) sum_c3 from t2 group by c2;
select * from mv1,mv2 where mv1.c1=mv2.c2;



