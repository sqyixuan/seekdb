--disable_warnings
drop database  IF EXISTS  db1;
--enable_warnings
create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='';

--echo ##基表为普通表指定主键
CREATE TABLE t1 (c1 number , c2 varchar(100)) ;
create materialized view log on t1 with rowid, sequence (c1,c2) including new values ;
create materialized view mv1(primary key(c2)) refresh fast on demand as select c2 as c2 ,count(*) as cnt from t1 group by c2;
insert into t1(c2) values('{"name": "John Doe", "age": 999}');
insert into t1(c1,c2) values(1,'"age": 999}');
update t1 set c2 = 'ssa' where c1 is null;
delete from t1 where c2 ='ssa';
show index from mv1;
desc mv1;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1;
show create table mv1;


--echo ##基表为分区表指定主键
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 int , c2 varchar(100)) PARTITION BY HASH(c1) PARTITIONS 8;
create materialized view log on t1 with rowid, sequence (c1,c2) including new values ;
create materialized view mv1(primary key(c2)) refresh fast on demand as select c2 as c2 ,count(*) as cnt from t1 group by c2;
insert into t1(c2) values('{"name": "John Doe", "age": 999}');
insert into t1(c1,c2) values(1,'"age": 999}');
update t1 set c2 = 'ssa' where c1 is null;
delete from t1 where c2 ='ssa';
show index from mv1;
desc mv1;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1;
show create table mv1;

--echo ##基表为视图指定主键
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 int primary key, c2 varchar(100)) PARTITION BY HASH(c1) PARTITIONS 8;
create view v1 as select * from t1;
create materialized view log on t1 with rowid, sequence (c2) including new values ;
--error 9760
create materialized view mv1(primary key(c2))  refresh fast on demand as select c2 as c2 ,count(*) as cnt from v1 group by c2;
insert into t1(c1,c2) values(1,'"age": 999}');
update t1 set c2 = 'ssa' where c1 is null;
delete from t1 where c2 ='ssa';

--echo ##两表连接
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
CREATE TABLE t1 (c1 number , c2 varchar(100) primary key, check(c2 <> c1)) ;
create materialized view log on t1 with rowid, sequence (c1) including new values ;
create materialized view mv1(primary key(ac2,bc2)) refresh fast on demand  enable on query computation  as select a.c2 as ac2, b.c2 as bc2  from t1 a ,t1 b ;
insert into t1(c1,c2) values(1,'11');
update t1 set c2 = '2' where c1 =1;
delete from t1 where c2 ='ssa';
select * from mv1;


DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 number , c2 varchar(100) primary key, check(c2 <> c1)) ;
create materialized view log on t1 with rowid, sequence (c1) including new values ;
create materialized view mv1(primary key(c2,cnt)) refresh fast on demand   as select c2 as c2 ,count(*) as cnt from t1 group by c2;
insert into t1(c1,c2) values(1,'11');
update t1 set c2 = '2' where c1 =1;
delete from t1 where c2 ='ssa';
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1 order by c2;

DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) primary key,c2 number(10), c3 number, c4 number);
create table t2 (a1 number(10) primary key,a2 number(10), a3 number, a4 number);
create materialized view log on t1 parallel 2 with primary key, rowid, sequence (c2,c3,c4) including new values;
create materialized view log on t2 parallel 2 with primary key, rowid, sequence (a2,a3,a4) including new values;
create materialized view mv1(primary key(c1))  parallel 2 refresh fast on demand  as select c1 as c1,a1 as a1 from t1,t2 where t1.c1 = t2.a1 ;
insert into t1 values(1,2,3,4);
insert into t2 values(1,1,3,4);
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1;


--echo ##rtmv join 增量mv
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key, c2 int) ;
create materialized view log on t1 with PRIMARY KEY,rowid, sequence (c2) including new values;
create materialized view mv1(c1,c2) refresh fast on demand as select count(*) as cnt,c1 as c1 from t1 group by c1;
create materialized view mv2(c1,c2) refresh fast on demand enable on query computation as select count(*) as cnt,c1 as c1 from t1 group by c1;
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(5,3);
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1 order by c2;
select * from mv1 a ,mv2 b where a.c2=b.c2 order by a.c2,b.c2;

--echo ##都存在主键rtmv join 增量mv
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
drop materialized view mv2;
create table t1 (c1 int primary key, c2 int) ;
create materialized view log on t1 with PRIMARY KEY,rowid, sequence (c2) including new values;
create materialized view mv1(primary key(cnt,c1)) refresh fast on demand as select count(*) as cnt,c1 as c1 from t1 group by c1;
create materialized view mv2(primary key(cnt,c1)) refresh fast on demand enable on query computation as select count(*) as cnt,c1 as c1 from t1 group by c1;
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(5,3);
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1 order by c1;
select count(*) from mv1 a ,mv2 b ;


--echo ##指定rtmv主键后与基表join
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 number , c2 varchar(100) primary key) ;
create materialized view log on t1 with rowid, sequence (c1) including new values ;
create materialized view mv1 refresh fast on demand  enable on query computation as select c2 as c2 ,count(*) as cnt from t1 group by c2;
insert into t1(c1,c2) values(1,'11');
select * from t1,mv1;

--echo ##不同数据类型
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (
  c1 INT PRIMARY KEY,
  c2 INT,
  c3 FLOAT,
  c4 DECIMAL(10, 2),
  c5 CHAR(10),
  c6 VARCHAR(50),
  c7 DATE
);
INSERT INTO t1  VALUES (1, 100, 123.456, 789.01, 'Text1    ', 'Sample text', '2023-04-01');
INSERT INTO t1  VALUES (2, 200, 654.321, 210.98, 'Text2    ', 'Another sample', '2023-04-02');
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2,c3,c4,c6,c7) including new values ;
create materialized view mv1(primary key(sum_c))  parallel 9 refresh fast on demand enable on query  computation as select sum(c2 * c3) sum_c, count(c2 * c3) count, count(*) as c, c6 from t1 group by c6;
select * from mv1 order by c6;

--echo ##指定常量作为主键
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1(c1 number primary key, c2 int, c3 number, c4 number);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1(primary key(a)) refresh fast on demand enable on query  computation as select c2 as c2,count(*) cnt,10 as a  from t1 group by c2;

insert into t1 values(1,3,4,5);
insert into t1 values(2,3,4,5);
select * from mv1;


--echo ##使用运算符
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1(c1 number primary key, c2 number, c3 number, c4 number);
insert into t1 values(1,3,4,5);
insert into t1 values(2,0,4,5);
insert into t1 values(3,100,4,5);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1(primary key(c2,cnt,a)) refresh fast on demand enable on query  computation as select c2 as c2,count(*) cnt, c2*2+3/1-1+c2  as a  from t1 group by c2;
delete from t1 where c2 >0;
select * from mv1 where c2 in (null,0,1,2,3,4,5);
select * from mv1 a ,t1 b;

--echo ##多主键进行运算
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1(c1 number primary key, c2 number, c3 number, c4 number);
insert into t1 values(1,3,4,5);
insert into t1 values(2,0,2,5);
insert into t1 values(3,100,4,5);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1(primary key(c3,cnt,sum_cc,count_cc)) refresh fast on demand  as select c3 as c3,count(*) cnt, sum(c1*c2) sum_cc,count(c1*c2) count_cc  from t1 group by c3;
insert into t1 values(0,null,4,5);
update t1 set c1=9,c2=9 where c2 is null;
delete from t1 where c2 >=100;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from t1 order by c1;
select * from mv1 order by c3;
select * from mlog$_t1;

--echo ##指定sum列主键
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1(c1 number primary key, c2 varchar(10), c3 varchar(10), c4 number);
insert into t1 values(1,3,4,5);
insert into t1 values(2,0,2,5);
insert into t1 values(3,100,4,5);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1(primary key(sum_cc)) refresh fast on demand  as select c2 as c2,count(*) cnt, sum(c1*c4) sum_cc,count(c1*c4) count_cc  from t1 group by c2;
insert into t1 values(0,2,4,5);
update t1 set c1=9,c2=9 where c2 =2;
delete from t1 where c2 >=100;
--error 1048
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from t1 order by c1;
select * from mv1 order by sum_cc;
##select * from mlog$_t1 order by c1;

--echo ##修改主键列
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1(c1 varchar(10) primary key, c2 varchar(10), c3 varchar(10), c4 number);
insert into t1 values(1,3,4,5);
insert into t1 values(2,0,2,5);
insert into t1 values(3,100,4,5);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1(primary key(c2)) refresh fast on demand  as select c2 as c2,count(*) cnt, sum(c1*c4) sum_cc,count(c1*c4) count_cc  from t1 group by c2;
update t1 set c2='蘩騠字' where c1 not in (1,3,4) ;
select * from mlog$_t1 order by c2;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from t1 order by c1;
select * from mv1 order by sum_cc;
##select * from mlog$_t1 order by c1;


--echo ##枚举类型指定主键hang
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop  materialized view mv1;
create table t1 (c1 ENUM('中文ing123','蘩騠字','蘩騠字ss'), c2 ENUM('null','@!#%$','kasdhka'));
create materialized view mv1(primary key(c1))  parallel 9 refresh complete on demand  as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values('中文ing123','null');
insert into t1 values('蘩騠字','@!#%$');
insert into t1 values('蘩騠字ss',null);
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from t1 order by c1;
select * from mv1 order by c1;


--echo ##全量刷新指定主键
