create table t1 (c1 int, c2 int);
create materialized view mv1(primary key(c1)) parallel 9 refresh complete on demand  as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values(1,1);
insert into t1 values(1,null);
insert into t1 values(null,1);
select * from t1 order by c1,c2;
--error 1048
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from mv1 order by c1;

drop table t1;
drop  materialized view mv1;
create table t1 (c1 int, c2 int);
insert into t1 values(1,1);
insert into t1 values(1,null);
insert into t1 values(null,1);
--error 1048
create materialized view mv1(primary key(c1)) parallel 9 refresh complete on demand  as select c1 as c1, count(*) cnt from t1 group by c1;
select * from t1 order by c1,c2;


drop table t1;
create table t1 (c1 json, c2 json);
insert into t1(c1) values('{"key":[1,0,false,true]}');
--error 3152
