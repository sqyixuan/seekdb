##多数据类型验证
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (
c1 INT PRIMARY KEY,
c2 INT,
c3 FLOAT,
c4 DECIMAL(10, 2),
c5 CHAR(10),
c6 VARCHAR(50),
c7 DATE
);
INSERT INTO t1  VALUES (1, 100, 123.456, 789.01, 'Text1    ', 'Sample text', '2023-04-01');
INSERT INTO t1  VALUES (2, 200, 654.321, 210.98, 'Text2    ', 'Another sample', '2023-04-02');
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2,c3,c4,c6,c7) including new values ;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation as select sum(c2 * c3) sum_c, count(c2 * c3) count, count(*) as c, c6 from t1 group by c6;
INSERT INTO t1  VALUES (3, 200, 654.321, 210.98, 'Text2    ', 'Another sample', '2023-04-02');
delete from t1 where c1 =2;
select * from mv1 order by SUM_C;
SUM_C	COUNT	C	C6
12345.6	1	1	Sample text
130864.2	1	1	Another sample
select * from mv1 a,t1 b where a.c6=b.c6 order by 1,2,3,4,5,6;
SUM_C	COUNT	C	C6	C1	C2	C3	C4	C5	C6	C7
12345.6	1	1	Sample text	1	100	123.456	789.01	Text1     	Sample text	2023-04-01 00:00:00
130864.2	1	1	Another sample	3	200	654.321	210.98	Text2     	Another sample	2023-04-02 00:00:00
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (
c1 INT PRIMARY KEY,
c2 INT,
c3 FLOAT,
c4 DECIMAL(10, 2),
c5 CHAR(10),
c6 VARCHAR(50),
c7 DATE
);
INSERT INTO t1  VALUES (1, 100, 123.456, 789.01, 'Text1    ', 'Sample text', '2023-04-01');
INSERT INTO t1  VALUES (2, 200, 654.321, 210.98, 'Text2    ', 'Another sample', '2023-04-02');
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2,c3,c4,c6,c7) including new values ;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation as select sum(c2 * c3) sum_c, count(c2 * c3) count, count(*) as c, c6 from t1 group by c6;
update t1 set c2=300 where c6='Another sample';
select * from mv1 order by SUM_C;
SUM_C	COUNT	C	C6
12345.6	1	1	Sample text
196296.3	1	1	Another sample
select * from mv1 a,t1 b where a.c6=b.c6 order by 1,2,3,4,5,6;
SUM_C	COUNT	C	C6	C1	C2	C3	C4	C5	C6	C7
12345.6	1	1	Sample text	1	100	123.456	789.01	Text1     	Sample text	2023-04-01 00:00:00
196296.3	1	1	Another sample	2	300	654.321	210.98	Text2     	Another sample	2023-04-02 00:00:00
##正交函数
##cast
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 varchar(20) ,c2 varchar(20), c3 varchar(20), c4 varchar(20));
insert into t1 values('1','2541','155','21');
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation  as select c1 as c1, count(*) cnt,CAST(c1 AS json) cst from t1 group by c1;
create materialized view mv2  parallel 9 refresh fast on demand enable on query  computation  as select c1 as c1, count(*) cnt,CAST(c1 AS NCHAR(12)) cst from t1 group by c1;
insert into t1 values('123','152','15','中文');
insert into t1 values(null,'152','15','中文');
insert into t1 values('a','152','15','中文');
CALL DBMS_MVIEW.REFRESH('mv2','f');
SELECT * from mv1;
ERROR 22032: JSON syntax error
SELECT * from mv2 order by 1,2,3;
C1	CNT	CST
1	1	1           
123	1	123         
a	1	a           
NULL	1	NULL
