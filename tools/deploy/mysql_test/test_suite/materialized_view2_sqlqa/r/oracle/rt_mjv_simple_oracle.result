##增加外键
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) primary key,c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values(1,1,1,1);
insert into t1 values(2,1,1,1);
insert into t1 values(3,3,1,1);
insert into t1 values(4,2,1,1);
insert into t1 values(5,4,1,1);
insert into t1 values(6,null,1,1);
ALTER TABLE t1 ADD CONSTRAINT fk_c2 FOREIGN KEY (c2) REFERENCES t1(c1);
select * from mv1 a,t1 b  where a.c1=b.c2 and b.c2 is not null order by a.c1,b.c1;
C1	CNT	C1	C2	C3	C4
1	1	1	1	1	1
1	1	2	1	1	1
2	1	4	2	1	1
3	1	3	3	1	1
4	1	5	4	1	1
select count(*) from mv1 a,t1 b  where a.c1!=b.c2;
COUNT(*)
25
select count(*) from mv1 a,t1 b  where a.c1>b.c2;
COUNT(*)
19
select count(*) from mv1 a,t1 b  where a.c1<b.c2;
COUNT(*)
6
select count(*) from mv1 a,t1 b  where a.c1<>b.c2;
COUNT(*)
25
select count(*) from mv1 a,t1 b  where a.c1=b.c2;
COUNT(*)
5
ALTER TABLE t1 DROP  CONSTRAINT fk_c2 ;
##插入值验证
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
create materialized view mv2  parallel 9 refresh fast on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values(2,1,2,1);
insert into t1 values(null,1,4,1);
INSERT INTO t1 SELECT c1 + 4, c1,cnt,c1+1 FROM mv1;
SELECT * FROM mv1 a JOIN mv2 b ON a.c1=b.c1 ORDER BY a.c1;
C1	CNT	C1	CNT
2	1	2	1
6	1	6	1
SELECT * FROM mv1 a JOIN mv2 b ON a.c1=b.c1 where a.c1= ''or b.c1=1 ORDER BY a.c1;
C1	CNT	C1	CNT
SELECT * FROM mv1 a JOIN mv2 b ON a.c1>b.c1 ORDER BY a.c1;
C1	CNT	C1	CNT
6	1	2	1
SELECT * FROM mv1 a JOIN mv2 b ON a.c1<b.c1 ORDER BY a.c1;
C1	CNT	C1	CNT
2	1	6	1
SELECT * FROM mv1 a JOIN mv2 b ON a.c1<=>b.c1 ORDER BY a.c1,b.c1;
C1	CNT	C1	CNT
2	1	2	1
6	1	6	1
NULL	2	NULL	2
SELECT * FROM mv1, mv1 mv2, mv1 mv3  WHERE ((mv1.c1 = 5 AND mv3.c1 <> mv1.c1) OR mv1.c1 > 0) AND mv3.c1 < mv2.c1 order by 1,2,3;
C1	CNT	C1	CNT	C1	CNT
2	1	6	1	2	1
6	1	6	1	2	1
##两个不同数据类型
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
drop materialized view mv2;
create table t1 (c1 number(10) ,c2 varchar2(120), c3 date, c4 varchar2(120));
insert into t1 values(1,'as',to_Date('2024-03-25'),'{"name": "John", "age": 30, "city": "New York"}');
insert into t1 values(null,'qqw中',to_Date('2022-03-25'),'{"name": "John", "age": 30, "city": "New York"}');
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
create materialized view mv2  parallel 9 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt from t1 group by c2;
create materialized view mv3  parallel 9 refresh fast on demand enable on query  computation as select c3 as c3, count(*) cnt from t1 group by c3;
select count(*) from mv1,mv2 ;
COUNT(*)
4
select count(*) from mv2,mv3 ;
COUNT(*)
4
select count(*) from mv3,mv1 ;
COUNT(*)
4
select count(*) from mv3,t1 where t1.c4=mv3.c3;
ERROR HY000: a non-numeric character was found where a numeric was expected
select count(*) from mv2,t1 where t1.c4=mv2.c2;
COUNT(*)
0
select count(*) from mv1,t1 where t1.c4=mv1.c1;
ERROR 42000: invalid number
select count(*) from mv1,t1 ;
COUNT(*)
4
select count(*) from mv2,t1 ;
COUNT(*)
4
##复合主键
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 varchar2(120) check (c2 is json), c3 date, c4 number(10) not null,c5 varchar2(120),c6 number(10));
ALTER TABLE t1 ADD CONSTRAINT constraint_name PRIMARY KEY (c2,c3);
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid, sequence(c1,c4,c5,c6)  including new values;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation  as select c2 as c2, count(*) cnt from t1 group by c2;
insert into t1 values(1,'{"name": "John", "age": 30, "city": "New York"}',to_Date('2024-03-25'),2,4,6);
insert into t1 values(null,'{"name": "John", "age": 31, "city": "New York"}',to_Date('2022-03-25'),1,3,5);
select mv1.c2,count(*) from mv1,t1,mlog$_t1 where t1.c2=mv1.c2 and mv1.c2=mlog$_t1.c2 group by mv1.c2 order by c2;
C2	COUNT(*)
{"name": "John", "age": 30, "city": "New York"}	1
{"name": "John", "age": 31, "city": "New York"}	1
select mv1.c2,count(*) from mv1,mlog$_t1 where  mv1.cnt=mlog$_t1.c1 group by mv1.c2 order by c2;
C2	COUNT(*)
{"name": "John", "age": 30, "city": "New York"}	1
{"name": "John", "age": 31, "city": "New York"}	1
select mv1.c2,count(*) from mv1,mlog$_t1 where  mv1.c2<>mlog$_t1.c5 group by mv1.c2 order by c2;
C2	COUNT(*)
{"name": "John", "age": 30, "city": "New York"}	2
{"name": "John", "age": 31, "city": "New York"}	2
select mv1.c2,count(*) from mv1,t1 where  mv1.c2<>t1.c5 group by mv1.c2 order by c2;
C2	COUNT(*)
{"name": "John", "age": 30, "city": "New York"}	2
{"name": "John", "age": 31, "city": "New York"}	2
