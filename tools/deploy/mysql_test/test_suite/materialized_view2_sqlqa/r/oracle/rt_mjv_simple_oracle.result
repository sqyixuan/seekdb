##DATE
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 DATE primary key, c2 DATE);
INSERT INTO t1 (c1, c2) VALUES (TO_DATE('2022-01-01', 'YYYY-MM-DD'), TO_DATE('2022-01-01', 'YYYY-MM-DD'));
INSERT INTO t1 (c1, c2) VALUES (TO_DATE('2022-01-02', 'YYYY-MM-DD'), TO_DATE('2022-01-02', 'YYYY-MM-DD'));
UPDATE t1 SET c2 = TO_DATE('2022-01-03', 'YYYY-MM-DD') WHERE c1 = TO_DATE('2022-01-01', 'YYYY-MM-DD');
DELETE FROM t1 WHERE c1 = TO_DATE('2022-01-02', 'YYYY-MM-DD');
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2) including new values  ;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
select * from mv1 order by c1;
C1	CNT
2022-01-01 00:00:00	1
select * from mv1 a,t1 b where a.c1=b.c1;
C1	CNT	C1	C2
2022-01-01 00:00:00	1	2022-01-01 00:00:00	2022-01-03 00:00:00
select * from mv1 a,mv1 b where a.c1=b.cnt;
ERROR 22000: inconsistent datatypes
##timestamp
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 timestamp primary key, c2 timestamp);
INSERT INTO t1 (c1, c2) VALUES (TIMESTAMP '2022-01-01 00:00:00', TIMESTAMP '2022-01-01 00:00:00');
INSERT INTO t1 (c1, c2) VALUES (TIMESTAMP '2022-01-02 00:00:00', TIMESTAMP '2022-01-02 00:00:00');
UPDATE t1 SET c2 = TIMESTAMP '2022-01-03 00:00:00' WHERE c1 = TIMESTAMP '2022-01-01 00:00:00';
DELETE FROM t1 WHERE c1 = TIMESTAMP '2022-01-02 00:00:00';
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2) including new values ;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
select * from mv1 order by c1;
C1	CNT
2022-01-01 00:00:00.000000	1
select * from mv1 a,t1 b where a.c1=b.c1;
C1	CNT	C1	C2
2022-01-01 00:00:00.000000	1	2022-01-01 00:00:00.000000	2022-01-03 00:00:00.000000
##TIMESTAMP WITH TIMEZONE
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 TIMESTAMP WITH TIME ZONE , c2 TIMESTAMP WITH TIME ZONE);
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c1,c2) including new values  ;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
INSERT INTO t1 (c1, c2) VALUES (TIMESTAMP '2022-01-01 00:00:00 +00:00', TIMESTAMP '2022-01-01 00:00:00 +00:00');
INSERT INTO t1 (c1, c2) VALUES (TIMESTAMP '2022-01-02 00:00:00 +00:00', TIMESTAMP '2022-01-02 00:00:00 +00:00');
UPDATE t1 SET c2 = TIMESTAMP '2022-01-03 00:00:00 +00:00' WHERE c1 = TIMESTAMP '2022-01-01 00:00:00 +00:00';
DELETE FROM t1 WHERE c1 = TIMESTAMP '2022-01-02 00:00:00 +00:00';
select * from mv1 order by c1;
C1	CNT
2022-01-01 00:00:00.000000 +00:00 	1
select * from mv1 a,t1 b where a.c1=b.c1;
C1	CNT	C1	C2
2022-01-01 00:00:00.000000 +00:00 	1	2022-01-01 00:00:00.000000 +00:00 	2022-01-03 00:00:00.000000 +00:00 
##INTERVAL DAY TO SECOND
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 INTERVAL DAY TO SECOND , c2 INTERVAL DAY TO SECOND);
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c1,c2) including new values ;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
INSERT INTO t1 (c1, c2) VALUES (INTERVAL '2' DAY, INTERVAL '3' DAY);
INSERT INTO t1 (c1, c2) VALUES (INTERVAL '4' DAY, INTERVAL '5' DAY);
UPDATE t1 SET c2 = INTERVAL '6' DAY WHERE c1 = INTERVAL '2' DAY;
DELETE FROM t1 WHERE c1 = INTERVAL '4' DAY;
select * from mv1 order by c1;
C1	CNT
+02 00:00:00.000000	1
select * from mv1 a,t1 b where a.c1=b.c1;
C1	CNT	C1	C2
+02 00:00:00.000000	1	+02 00:00:00.000000	+06 00:00:00.000000
