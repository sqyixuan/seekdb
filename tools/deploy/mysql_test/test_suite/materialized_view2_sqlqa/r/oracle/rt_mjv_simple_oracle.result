DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 varchar2(120), c3 date, c4 number(10) not null);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation  as select c4 as c4, count(*) cnt from t1 group by c4;
