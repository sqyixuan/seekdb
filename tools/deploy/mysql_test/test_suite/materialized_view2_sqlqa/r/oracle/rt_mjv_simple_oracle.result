##五表连接
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
drop materialized view mv2;
drop materialized view mv3;
purge recyclebin;
create table t1 (c1 number(10) primary key,c2 number(10), c3 number, c4 number);
create table t2 (a1 number(10) primary key,a2 number(10), a3 number, a4 number);
create table t3 (b1 number(10) primary key,b2 number(10), b3 number, b4 number);
create table t4 (d1 number(10) primary key,d2 number(10), d3 number, d4 number);
create table t5 (h1 number(10) primary key,h2 number(10), h3 number, h4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view log on t2 parallel 9 with rowid, sequence (a2,a3,a4) including new values;
create materialized view log on t3 parallel 9 with rowid, sequence (b2,b3,b4) including new values;
create materialized view log on t4 parallel 9 with rowid, sequence (d2,d3,d4) including new values;
create materialized view log on t5 parallel 9 with rowid, sequence (h2,h3,h4) including new values;
create materialized view mv1 refresh fast on demand enable on query  computation as select c1 as c1 ,a1 as a1,b1 as b1,d1 as d1,h1 as h1 from t1,t2,t3,t4,t5 where c1=a1 and a1=b1 and b1=d1 and d1=h1;
create materialized view mv2 refresh fast on demand enable on query  computation as select c1 as c1, a1 as a1 from t1, t2 where c1=a1;
insert into t1 values(1,null,1,1);
insert into t2 values(1,null,2,2);
insert into t3 values(1,null,3,3);
insert into t4 values(1,null,4,4);
insert into t5 values(1,null,5,5);
select * from mv1;
C1	A1	B1	D1	H1
1	1	1	1	1
select * from mv2;
C1	A1
1	1
CREATE INDEX idx ON mv1 (c1,a1,b1,d1,h1) parallel 10;
alter index idx parallel 2;
drop index idx;
##rt_mv连接不同rt_mv
##使用普通视图
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop view v1;
drop materialized view mv1;
create table t1 (c1 number , c2 varchar(200));
create view v1 as select c2 as c2, count(*) cnt from t1 group by c2;
INSERT INTO t1 VALUES (1, '{"name": "John Doe", "age": 30}');
INSERT INTO t1 VALUES (null, '{"name": "John Doe", "age": 30}');
create materialized view log on t1  with rowid, sequence(c2) including new values;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation   as select c2 as c2, count(*) cnt from t1 group by c2;
select * from mv1,v1,t1 order by 1,2,3,4,5,6;
C2	CNT	C2	CNT	C1	C2
{"name": "John Doe", "age": 30}	2	{"name": "John Doe", "age": 30}	2	1	{"name": "John Doe", "age": 30}
{"name": "John Doe", "age": 30}	2	{"name": "John Doe", "age": 30}	2	NULL	{"name": "John Doe", "age": 30}
