create table t2 (a1 number(10) primary key,a2 number(10), a3 number, a4 number);
create materialized view log on t1 parallel 2 with primary key, rowid, sequence (c2,c3,c4) including new values;
create materialized view log on t2 parallel 2 with primary key, rowid, sequence (a2,a3,a4) including new values;
