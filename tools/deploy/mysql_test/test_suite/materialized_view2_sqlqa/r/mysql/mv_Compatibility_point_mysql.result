create table t1(c1 number primary key, c2 number, c3 number, c4 number);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1 refresh fast on demand  as select COUNT(*) cnt from t1 ;
create materialized view mv2 refresh fast on demand  as select count(c2) count_c2  from t1 ;
create materialized view mv3 refresh fast on demand  as select COUNT(*) cnt,count(c2) count_c2  from t1 ;
create materialized view mv4 refresh fast on demand  as select c2 as c2,COUNT(*) cnt,count(c2) count_c2  from t1 group by c2;
create materialized view mv6 refresh fast on demand  as select COUNT(c2) cnt,sum(c2) sum_c2  from t1 ;
create materialized view mv7 refresh fast on demand  as select c2 as c2,COUNT(*) cnt,count(c2) count_c2,sum(c2) sum_c2  from t1 group by c2;
create materialized view mv8 refresh fast on demand  as select COUNT(c2) cnt_c2,sum(c2) sum_c2,avg(c2) avg_c2  from t1 ;
create materialized view mv9 refresh fast on demand  as select c2 as c2,COUNT(*) cnt,COUNT(c2) cnt_c2,sum(c2) sum_c2,avg(c2) avg_c2  from t1 group by c2;
##聚合函数间的运算ob可以创建,oracle报错;暂不兼容oracle
create materialized view mv11 refresh fast on demand as select c2 as c2,c3 as c3, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3) * sum(c3)/c2 calc1, c2+sum(c3) calc2 from t1 group by c2,c3;
##聚合函数之间的运算扩展
DROP MATERIALIZED VIEW LOG ON t1;
drop table  if exists t1;
drop materialized view if exists mv1;
drop materialized view if exists mv2;
drop materialized view if exists mv3;
drop materialized view if exists mv4;
create table t1(c1 number primary key, c2 number, c3 number, c4 number);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3) * sum(c3)/c2 calc1, c2+sum(c3) calc2 from t1 group by c2;
create materialized view mv2 refresh fast on demand as select c2 as c2,c3 as c3, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)/c2 calc1, c2+sum(c3) calc2,c3+sum(c3) calc3 from t1 group by c2,c3;
create materialized view mv3 refresh fast on demand as select c2 as c2,c3 as c3, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3) * sum(c3)*c3*c2 calc1, c2+sum(c3) calc2,c3+sum(c3) calc3,sum(c3*c3) as sum_cc3 from t1 group by c2,c3;
##存在常量刷新报错4007;
create materialized view mv4 refresh fast on demand as select c2 as c2,count(*) cnt, count(c3) cnt_c3,10 as a  from t1 group by c2;
insert into t1 values(1,0,0,1);
insert into t1 values(2,0,0,1);
CALL DBMS_MVIEW.REFRESH('mv4','f');
select * from t1 order by c2;
c1	c2	c3	c4
1	0	0	1
2	0	0	1
select * from mv4 order by c2;
c2	cnt	cnt_c3	a
0	2	2	10
##结合case when使用
DROP MATERIALIZED VIEW LOG ON t1;
drop table  if exists t1;
drop materialized view  if exists mv1;
create table t1(c1 number primary key, c2 number, c3 number, c4 number);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1 refresh fast on demand as select c2 as c2, c3 as c3, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3) * sum(c3)/c2 calc1, c2+sum(c3) calc2,c3+sum(c3) calc3,CASE  WHEN c2 BETWEEN 1 AND 100 THEN c2    ELSE c3  END AS c2_group  FROM t1 GROUP BY  c2,c3;
insert into t1 values(2,1,1,1);
insert into t1 values(1,100,1,1);
insert into t1 values(3,200,1,1);
insert into t1 values(4,null,1,1);
insert into t1 values(495,9999,1,1);
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from t1 order by c1;
c1	c2	c3	c4
1	100	1	1
2	1	1	1
3	200	1	1
4	NULL	1	1
495	9999	1	1
select * from mv1 order by c2;
c2	c3	cnt	cnt_c3	sum_c3	avg_c3	calc1	calc2	calc3	c2_group
NULL	1	1	1	1	1.0000	NULL	NULL	2	1
1	1	1	1	1	1.0000	1.00000000	2	2	1
100	1	1	1	1	1.0000	0.01000000	101	2	100
200	1	1	1	1	1.0000	0.00500000	201	2	1
9999	1	1	1	1	1.0000	0.00010001	10000	2	1
