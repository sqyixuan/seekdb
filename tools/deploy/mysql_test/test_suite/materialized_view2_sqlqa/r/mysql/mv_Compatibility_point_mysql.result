drop database  IF EXISTS  ljh;
create database ljh;
use ljh;
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
##设置相同sql_mode;
SET @@sql_mode='';
##增量更新暂不支持汇总
##针对聚合函数min/max 的增量更新
create table t1(c1 number primary key, c2 number, c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1 refresh fast  as select c2 as c2, count(*) cnt,  min(c2) min_c2 from t1 group by c2;
ERROR HY000: cannot fast refresh materialized view mv1: the aggregate function type is not supported yet (only count/sum/avg/stddev/variance is supported)
create materialized view mv2 refresh fast  as select c2 as c2, count(*) cnt,  max(c2) max_c2 from t1 group by c2;
ERROR HY000: cannot fast refresh materialized view mv2: the aggregate function type is not supported yet (only count/sum/avg/stddev/variance is supported)
##使用内联视图
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
create table t1(c1 number primary key, c2 number, c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values purge  ;
create materialized view mv1 refresh fast  as select c2 as c2, count(*) cnt  from (select c2 as c2, count(*) cnt from t1 group by c2)t1 group by c2;
ERROR HY000: cannot fast refresh materialized view mv1: query has invalid table type(GENERATED_TABLE). only basic table and materialized view are supported
##使用join
DROP MATERIALIZED VIEW LOG ON t1;
drop table  if exists t1;
drop materialized view  if exists mv1;
Warnings:
Note	9757	materialized view `ljh`.`mv1` does not exist
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create table t2(c1 int, c2 int, c3 int, c4 int);
insert into t1 values(1,1,1,1);
insert into t2 values(1,1,1,1);
create materialized view log on t1 with primary key, rowid, sequence ( c2, c3) including new values;
create materialized view log on t2 with  rowid, sequence (c1, c2, c3) including new values;
create materialized view mv1 refresh fast  as select t1.c2 as c2, count(*) cnt  from t1 inner join t2 on t1.c2=t2.c2 group by t1.c2;
ERROR HY000: cannot fast refresh materialized view mv1: primary key definition is required for all base tables
create materialized view mv1 refresh fast  as select t1.c2 as c2, count(*) cnt  from t1  join (select 1 c2 from dual)t2 on t1.c2=t2.c2 group by t1.c2;
ERROR HY000: cannot fast refresh materialized view mv1: query has invalid table type(GENERATED_TABLE). only basic table and materialized view are supported
##使用子查询
DROP MATERIALIZED VIEW LOG ON t1;
drop table if exists  t1;
drop materialized view if exists  mv1;
Warnings:
Note	9757	materialized view `ljh`.`mv1` does not exist
drop materialized view  if exists mv2;
Warnings:
Note	9757	materialized view `ljh`.`mv2` does not exist
create table t1(c1 number primary key, c2 number, c3 number, c4 number);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2,c3,c4) including new values purge  ;
create materialized view mv1 refresh fast  as select c1 as c1  from t1 where c1 is not null group by c1;
ERROR HY000: cannot fast refresh materialized view mv1: a count(*) item is required to be added to the select item list
create materialized view mv2 refresh fast  as select c1 as c1  from t1 where c1 > 1 group by c1;
ERROR HY000: cannot fast refresh materialized view mv2: a count(*) item is required to be added to the select item list
##子查询结合group by预期创建失败;
create materialized view mv1 refresh fast  as select c2 as c2, count(*) cnt  from t1 where c1 in (select c1 from t1)  group by c2;
ERROR HY000: cannot fast refresh materialized view mv1: query with subquery is not supported
##包含 rownum/rand 等不能稳定输出值的表达式
DROP MATERIALIZED VIEW LOG ON t1;
drop table  if exists t1;
drop materialized view  if exists mv1;
Warnings:
Note	9757	materialized view `ljh`.`mv1` does not exist
create table t1(c1 number primary key, c2 number, c3 number, c4 number);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2,c3,c4) including new values purge  ;
create materialized view mv1 refresh fast  as select c2 as c2  from t1  limit 5  ;
ERROR HY000: cannot fast refresh materialized view mv1: query with order by or limit operators is not supported
create materialized view mv1 refresh fast  as select c2 as c2 , count(*) cnt from t1 group by c2  limit 5  ;
ERROR HY000: cannot fast refresh materialized view mv1: query with order by or limit operators is not supported
create materialized view mv1 refresh fast  as select c2 as c2 , count(*) cnt, rand(5) from t1  group by c2  ;
ERROR HY000: cannot fast refresh materialized view mv1: non-deterministic query is not supported
##仅支持SUM/COUNT 及使用这两种构造的聚合函数;
DROP MATERIALIZED VIEW LOG ON t1;
drop table  if exists t1;
drop materialized view if exists mv1;
Warnings:
Note	9757	materialized view `ljh`.`mv1` does not exist
drop materialized view if exists mv2;
Warnings:
Note	9757	materialized view `ljh`.`mv2` does not exist
drop materialized view if exists mv3;
Warnings:
Note	9757	materialized view `ljh`.`mv3` does not exist
create table t1(c1 number primary key, c2 number, c3 number, c4 number);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2,c3,c4) including new values purge  ;
create materialized view mv1 refresh fast  as select COUNT(*) cnt,sum(c2) as sum_c2,count(c2) count_c2 from t1 ;
create materialized view mv2 refresh fast  as select c2 as c2 ,COUNT(*) cnt,sum(c2) as sum_c2,count(c2) count_c2 from t1 group by c2;
create materialized view mv3 refresh fast  as select c2 as c2 , count(*) cnt,sum(c2) as sum_c2,count(c2) count_c2 from t1 where c1 is not null group by c2  ;
##聚合函数中仅支持简单column，必须输出 COUNT(*) 与 group by 列
##结合having使用报错不支持
create materialized view mv3 refresh fast  as select c2 as c2 , count(*) as count from t1  group by c2 having sum(c2)>1;
ERROR HY000: cannot fast refresh materialized view mv3: query with rollup/grouping sets/cube/having operators is not supported
create materialized view mv4 refresh fast  as select c2 as c2 , count(*) as count from (select c2 as c2 ,count(*)as count from t1 group by c2) t1  group by c2 having sum(c2)>1;
ERROR HY000: cannot fast refresh materialized view mv4: query with rollup/grouping sets/cube/having operators is not supported
##group by不使用COUNT(*)
create materialized view mv3 refresh fast  as select c2 as c2  from t1  group by c2 ;
ERROR HY000: cannot fast refresh materialized view mv3: a count(*) item is required to be added to the select item list
##单独使用having
create materialized view mv5 refresh fast  as select sum(c2) as sum_c2 from t1  having sum(c2)>(select 1 from dual group by 1);
ERROR HY000: cannot fast refresh materialized view mv5: query with subquery is not supported
create materialized view mv5 refresh fast  as select avg(c2) as avg_c2 from t1  having avg(c2)>(select 1 from dual group by 1);
ERROR HY000: cannot fast refresh materialized view mv5: query with subquery is not supported
create materialized view mv5 refresh fast  as select min(c2) as min_c2 from t1  having min(c2)>(select 1 from dual group by 1);
ERROR HY000: cannot fast refresh materialized view mv5: query with subquery is not supported
create materialized view mv5 refresh fast  as select max(c2) as max_c2 from t1  having max(c2)>(select 1 from dual group by 1);
ERROR HY000: cannot fast refresh materialized view mv5: query with subquery is not supported
create materialized view mv5 refresh fast  as select count(c2) as count_c2 from t1  having count(c2)>(select 1 from dual group by 1);
ERROR HY000: cannot fast refresh materialized view mv5: query with subquery is not supported
##单独使用rollup
create materialized view mv5 refresh fast  as select c1 as c1,c2 as c2 ,sum(c4) as sum_c4  from t1  group by c1,c2 with rollup ;
ERROR HY000: cannot fast refresh materialized view mv5: query with rollup/grouping sets/cube/having operators is not supported
create materialized view mv5 refresh fast  as select c1 as c1,c2 as c2 ,avg(c4) as avg_c4  from t1  group by c1,c2 with rollup ;
ERROR HY000: cannot fast refresh materialized view mv5: query with rollup/grouping sets/cube/having operators is not supported
create materialized view mv5 refresh fast  as select c1 as c1,c2 as c2 ,min(c4) as min_c4  from t1  group by c1,c2 with rollup ;
ERROR HY000: cannot fast refresh materialized view mv5: query with rollup/grouping sets/cube/having operators is not supported
create materialized view mv5 refresh fast  as select c1 as c1,c2 as c2 ,max(c4) as max_c4  from t1  group by c1,c2 with rollup ;
ERROR HY000: cannot fast refresh materialized view mv5: query with rollup/grouping sets/cube/having operators is not supported
create materialized view mv5 refresh fast  as select c1 as c1,c2 as c2 ,count(c4) as count_c4  from t1  group by c1,c2 with rollup ;
ERROR HY000: cannot fast refresh materialized view mv5: query with rollup/grouping sets/cube/having operators is not supported
##将having和rollup放置在子查询当中
create materialized view mv5 refresh fast  as select c2 as c2,sum(c2) as sum_c2 from (select sum(c2) from t1  having sum(c2)> 1)t,t1  group by c2;
ERROR HY000: cannot fast refresh materialized view mv5: query has invalid table type(GENERATED_TABLE). only basic table and materialized view are supported
create materialized view mv5 refresh fast  as select t1.c2 as a,sum(t1.c2) as sum_c2 from (select c1 as c1,c2 as c2 ,sum(c4) as sum_c4  from t1  group by c1,c2 with rollup)t,t1  group by t1.c2;
ERROR HY000: cannot fast refresh materialized view mv5: query has invalid table type(GENERATED_TABLE). only basic table and materialized view are supported
##order by使用
DROP MATERIALIZED VIEW LOG ON t1;
drop table  if exists t1;
drop materialized view if exists mv1;
drop materialized view if exists mv2;
drop materialized view if exists mv3;
create table t1(c1 number primary key, c2 number, c3 number, c4 number);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2,c3,c4) including new values purge  ;
create materialized view mv1 refresh fast  as select c1 as c1,c2 as c2 from t1  order by c2 desc ;
ERROR HY000: cannot fast refresh materialized view mv1: query with order by or limit operators is not supported
create materialized view mv2 refresh fast  as select c1 as c1,c2 as c2 from t1  order by c2 ;
ERROR HY000: cannot fast refresh materialized view mv2: query with order by or limit operators is not supported
##order by正交group by
create materialized view mv1 refresh fast  as select c2 as c2,COUNT(*) cnt,sum(c2) as sum_c2,count(c2) count_c2 from t1 group by c2 order by c2 desc ;
ERROR HY000: cannot fast refresh materialized view mv1: query with order by or limit operators is not supported
create materialized view mv2 refresh fast  as select c2 as c2,COUNT(*) cnt,sum(c2) as sum_c2,count(c2) count_c2 from t1 group by c2 order by c2  ;
ERROR HY000: cannot fast refresh materialized view mv2: query with order by or limit operators is not supported
##select子句中使用distinct
create materialized view mv5 refresh fast  as select distinct c2  from t1 ;
ERROR HY000: cannot fast refresh materialized view mv5: primary keys of all base tables are required in the select item list
##结合group by创建成功,和子查询问题类似 ;
create materialized view mv5 refresh fast  as select distinct c2 ,count(*) as cnt_c2 from t1 group by c2;
##聚合函数中使用distinct
create materialized view mv6 refresh fast  as select  count(distinct c2) as dt_c2 from t1  ;
ERROR HY000: cannot fast refresh materialized view mv6: query with nested aggregate functions or distinct keyword is not supported
##集合中使用distinct
create materialized view mv6 refresh fast  as select  distinct c2 from t1   UNION SELECT DISTINCT c2  FROM t1 ;
ERROR HY000: cannot fast refresh materialized view mv6: query with set operators UNION/INTERSECT/EXCEPT/MINUS is not supported
##集合中正交group by使用
create materialized view mv6 refresh fast  as select  distinct c2,count(*) as cnt_c2 from t1 group by c2  UNION SELECT DISTINCT c2 , count(*) as cnt_c2 FROM t1 group by c2 ;
ERROR HY000: cannot fast refresh materialized view mv6: query with set operators UNION/INTERSECT/EXCEPT/MINUS is not supported
##使用窗口函数
create materialized view mv6 refresh fast  as SELECT c1,c2,SUM(c2) OVER (ORDER BY c1) AS running_total_c2 FROM t1 ;
ERROR HY000: cannot fast refresh materialized view mv6: query with window functions is not supported
create materialized view mv6 refresh fast  as SELECT c1,c2,SUM(c2) OVER (ORDER BY c1) AS running_total_c2 FROM t1 group by c1,c2;
ERROR HY000: cannot fast refresh materialized view mv6: query with window functions is not supported
create materialized view mv6 refresh fast  as SELECT c1,c2,c3,AVG(c2) OVER (PARTITION BY c3) AS avg_c2_by_c3 FROM t1;
ERROR HY000: cannot fast refresh materialized view mv6: query with window functions is not supported
create materialized view mv6 refresh fast  as SELECT c1,c2,c3,AVG(c2) OVER (PARTITION BY c3) AS avg_c2_by_c3 FROM t1 group by c1,c2,c3;
ERROR HY000: cannot fast refresh materialized view mv6: query with window functions is not supported
create materialized view mv6 refresh fast  as SELECT c1,c2,RANK() OVER (ORDER BY c2 DESC) AS rank_by_c2,ROW_NUMBER() OVER (ORDER BY c2 DESC) AS rownum_by_c2 FROM t1;
ERROR HY000: cannot fast refresh materialized view mv6: query with window functions is not supported
create materialized view mv6 refresh fast  as SELECT c1,c2,RANK() OVER (ORDER BY c2 DESC) AS rank_by_c2,ROW_NUMBER() OVER (ORDER BY c2 DESC) AS rownum_by_c2 FROM t1 group by c1,c2;
ERROR HY000: cannot fast refresh materialized view mv6: query with window functions is not supported
create materialized view mv6 refresh fast  as SELECT c1,c2,LAG(c2) OVER (ORDER BY c1) AS prev_c2,LEAD(c2) OVER (ORDER BY c1) AS next_c2 FROM t1;
ERROR HY000: cannot fast refresh materialized view mv6: query with window functions is not supported
create materialized view mv6 refresh fast  as SELECT c1,c2,LAG(c2) OVER (ORDER BY c1) AS prev_c2,LEAD(c2) OVER (ORDER BY c1) AS next_c2 FROM t1 group by c1,c2;
ERROR HY000: cannot fast refresh materialized view mv6: query with window functions is not supported
