drop database  IF EXISTS  db1;
create database db1;
use db1;
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
##设置相同sql_mode;
SET @@sql_mode='';
##DBA_MVIEWS,__all_mview
drop table if exists t1;
Warnings:
Note	1051	Unknown table 'db1.t1'
drop materialized view if exists mv1;
Warnings:
Note	9757	materialized view `db1`.`mv1` does not exist
create table t1 (c1 number primary key, c2 varchar(10));
insert into t1 values(1,2);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2) including new values ;
create materialized view mv1 refresh fast as select count(*) as cnt,c2 as c2  from t1 group by c2;
CALL DBMS_MVIEW.REFRESH('mv1','f');
delete from t1 where c2 = 2;
CALL DBMS_MVIEW.REFRESH('mv1','c');
###DBA_MVIEW_LOGS
DROP MATERIALIZED VIEW LOG ON t1;
drop table if exists t1;
drop materialized view if exists mv1;
create table t1 (c1 number primary key, c2 varchar(10));
insert into t1 values(1,2);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2) including new values ;
create materialized view mv1 refresh fast as select count(*) as cnt,c2 as c2  from t1 group by c2;
call dbms_mview.purge_log('T1');
call dbms_mview.purge_log('T1');
CALL DBMS_MVIEW.REFRESH('mv1','f');
call dbms_mview.purge_log('T1');
select * from mlog$_t1;
c1	c2	SEQUENCE$$	DMLTYPE$$	OLD_NEW$$
##DBA_MVREF_CHANGE_STATS,__all_mview_refresh_change_stats
DROP MATERIALIZED VIEW LOG ON t1;
drop table if exists t1;
drop materialized view if exists mv1;
create table t1 (c1 number primary key, c2 varchar(10));
insert into t1 values(1,2);
create materialized view log on t1 parallel 9 with primary key,rowid, sequence (c2) including new values ;
create materialized view mv1 refresh fast as select count(*) as cnt,c2 as c2  from t1 group by c2;
CALL DBMS_MVIEW.REFRESH('mv1','f');
delete from t1 where c2 = 2;
CALL DBMS_MVIEW.REFRESH('mv1','c');
##DBA_MVREF_RUN_STATS,__all_mview_refresh_run_stats
DROP MATERIALIZED VIEW LOG ON t1;
drop table if exists t1;
drop materialized view if exists mv1;
create table t1 (c1 number primary key, c2 varchar(10),c3 number);
create materialized view log on t1  with rowid, sequence(c2,c3) including new values ;
create materialized view mv1 refresh fast as select count(*) as cnt,c2 as c2  from t1 group by c2;
CALL DBMS_MVIEW.REFRESH('mv1','aaaaaaa');
CALL DBMS_MVIEW.REFRESH('mv1','faa');
CALL DBMS_MVIEW.REFRESH('mv1','faaa');
CALL DBMS_MVIEW.REFRESH('mv1','fast');
ERROR HY000: Invalid argument
CALL DBMS_MVIEW.REFRESH('mv1','f');
##DBA_MVREF_STATS,__all_mview_refresh_stats
DROP MATERIALIZED VIEW LOG ON t1;
drop table if exists t1;
drop materialized view if exists mv1;
create table t1 (c1 number primary key, c2 varchar(10),c3 number);
create materialized view log on t1  with rowid, sequence(c2,c3) including new values;
create materialized view mv1 refresh fast  as select count(*) as cnt,c2 as c2  from t1 group by c2;
CALL DBMS_MVIEW.REFRESH('mv1','f');
drop materialized view if exists mv1;
create materialized view mv1 refresh fast start with sysdate() + interval 1 second next sysdate() + interval 10 second as select count(*) as cnt,c2 as c2  from t1 group by c2;
DROP MATERIALIZED VIEW LOG ON t1;
drop table if exists t1;
drop materialized view if exists mv1;
create table t1 (c1 number primary key, c2 varchar(10),c3 number);
create materialized view mv1 refresh complete  as select count(*) as cnt,c2 as c2  from t1 group by c2;
CALL DBMS_MVIEW.REFRESH('mv1','c');
drop materialized view if exists mv1;
create materialized view mv1 refresh complete start with sysdate() + interval 1 second next sysdate() + interval 10 second as select count(*) as cnt,c2 as c2  from t1 group by c2;
##DBA_MVREF_STATS_PARAMS,__all_mview_refresh_stats_params
drop table if exists t1;
drop materialized view if exists mv1;
create table t1 (c1 number primary key, c2 varchar(10),c3 number);
create materialized view log on t1  with rowid, sequence(c2,c3) including new values ;
create materialized view mv1 refresh fast as select count(*) as cnt,c2 as c2  from t1 group by c2;
CALL DBMS_MVIEW.REFRESH('mv1');
CALL DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('MV1', 'ADVANCED', 1.1);
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('MV1','TYPICAL', 365001);
ERROR HY000: Invalid argument
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('MV1','TYPICAL', 1);
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('MV1','NONE', 1);
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('MV1','ADVANCED', 1);
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('MV1','TYPICAL', 365000);
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('MV1','NONE', 365000);
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('MV1','ADVANCED', 365000);
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('MV1','TYPICAL', 99*999);
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('MV1','NONE', 99*999);
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('MV1','ADVANCED', 99*999);
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('MV1','TYPICAL', -1);
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('MV1','NONE', -1);
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('MV1','ADVANCED', -1);
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS(NULL, 'TYPICAL');
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS(NULL, 'ADVANCED');
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('', 'TYPICAL');
call DBMS_MVIEW_STATS.SET_MVREF_STATS_PARAMS('', 'ADVANCED');
##DBA_MVREF_STATS_SYS_DEFAULTS,__all_mview_refresh_stats_sys_defaults
DROP MATERIALIZED VIEW LOG ON t1;
drop table if exists t1;
drop materialized view if exists mv1;
create table t1 (c1 number primary key, c2 varchar(10),c3 number);
create materialized view log on t1  with rowid, sequence(c2,c3) including new values ;
create materialized view mv1 refresh fast as select count(*) as cnt,c2 as c2  from t1 group by c2;
call DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT(NULL, 9999);
ERROR HY000: Invalid value specified for parameter name
