c3	decimal(10,0)	NULL	YES		NULL		SELECT,INSERT,UPDATE,REFERENCES	
c4	decimal(10,0)	NULL	YES		NULL		SELECT,INSERT,UPDATE,REFERENCES	
SHOW FULL COLUMNS FROM mv1 ;
