##使用clob作为分区键
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 blob);
CREATE MATERIALIZED VIEW mv1 PARTITION BY LIST (c1) (PARTITION p1 VALUES in(1,5,9),PARTITION p2 VALUES in(2,6,10),PARTITION p3 VALUES in(3,7,0), PARTITION p4 VALUES in(4,8,null)) refresh complete as select count(*) cnt,c1 as c1 from t1 group by c1;
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
drop table t1;
CREATE TABLE t1 (c1 blob);
create materialized view log on t1 with rowid, sequence including new values ;
CREATE MATERIALIZED VIEW mv1 PARTITION BY LIST (c1) (PARTITION p1 VALUES in(1,5,9),PARTITION p2 VALUES in(2,6,10),PARTITION p3 VALUES in(3,7,0), PARTITION p4 VALUES in(4,8,null)) refresh fast as select count(*) cnt,c1 as c1 from t1 group by c1;
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
