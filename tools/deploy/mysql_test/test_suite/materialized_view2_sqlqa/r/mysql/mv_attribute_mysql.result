drop database  IF EXISTS  ljh;
create database ljh;
use ljh;
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
##设置相同sql_mode;
SET @@sql_mode='';
##修改table_dop
create table t1 (c1 int,c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand as select c1 as c1, count(*) cnt from t1 group by c1;
ALTER TABLE t1 PARALLEL  4;
ALTER TABLE mlog$_t1 PARALLEL  4;
ERROR 0A000: alter materialized view log is not supported
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 int,c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand as select c1 as c1, count(*) cnt from t1 group by c1;
ALTER TABLE t1 PARALLEL  4;
ALTER TABLE mlog$_t1 PARALLEL  4;
ERROR 0A000: alter materialized view log is not supported
##charset_type --mysql不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int) CHARACTER SET gbk;
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
ALTER TABLE t1 CONVERT TO CHARACTER SET utf8mb4 COLLATE utf8mb4_bin;
ERROR 0A000: this alter table to table with materialized view log is not supported
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 VARCHAR(50) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL ) ;
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
ALTER TABLE t1 MODIFY c4 VARCHAR(50) CHARACTER SET gbk ;
ERROR 0A000: modify column to table with materialized view log is not supported
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
