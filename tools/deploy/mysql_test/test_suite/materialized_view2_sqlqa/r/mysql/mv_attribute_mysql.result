##使用复制表
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 varchar(200));
create materialized view log on t1 with rowid, sequence (c1) including new values ;
create table tt1 as select c1 from mlog$_t1;
create materialized view log on tt1 with rowid, sequence (c1) including new values ;
CREATE MATERIALIZED VIEW mv1  refresh fast as select count(*) cnt,c1 as c1 from tt1 group by c1;
insert into tt1(c1) values('{"name": "John Doe", "age": 999}');
insert into tt1(c1) values(1);
insert into tt1(c1) values('中文');
CALL DBMS_MVIEW.REFRESH('mv1','f');
truncate table mv1 ;
ERROR 0A000: truncate materialized view is not supported
create table ttt1 as select * from mv1;
select * from ttt1 order by c1;
cnt	c1
1	1
