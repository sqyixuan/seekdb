##设置表注释
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int) comment ='table name is t1';
create materialized view mv1  parallel 9 refresh complete on demand as select c1 as c1, count(*) cnt from t1 group by c1;
ALTER TABLE t1 COMMENT = 'Your table comment here';
DROP TABLE t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int) comment ='table name is t1';
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand as select c1 as c1, count(*) cnt from t1 group by c1;
ALTER TABLE t1 COMMENT = 'Your table comment here';
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
CREATE TABLE t1 (c1 int(10) primary key,c2 int, c3 int, c4 int) comment ='table name is t1';
create materialized view mv1  parallel 9 refresh complete on demand as select c1 as c1, count(*) cnt from t1 group by c1;
ALTER TABLE mv1 COMMENT = 'Your table comment here';
