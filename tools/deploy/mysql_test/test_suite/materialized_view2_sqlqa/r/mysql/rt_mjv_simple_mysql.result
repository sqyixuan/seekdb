drop database  IF EXISTS  db1;
create database db1;
use db1;
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
##单表简单查询
create table t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh complete on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values(1,1,1,1);
insert into t1 values(null,1,1,1);
select c1 *12-1/1 from mv1 where c1 in (null,1,2,3,4 ) or c1 not in (null,1,2,3,4 ) order by c1;
c1 *12-1/1
11.0000
select max(c1) * max(c1)* max(c1)from mv1;
max(c1) * max(c1)* max(c1)
1
select min(c1) * min(c1)* min(c1)from mv1;
min(c1) * min(c1)* min(c1)
1
select avg(c1) * avg(c1)* avg(c1)from mv1;
avg(c1) * avg(c1)* avg(c1)
1.000000000000
select sum(c1) * sum(c1)* sum(c1)from mv1;
sum(c1) * sum(c1)* sum(c1)
1
select count(c1) * count(c1) * count(c1)from mv1;
count(c1) * count(c1) * count(c1)
1
##增加start with
##不加including new values
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) ;
create materialized view mv1  parallel 9 refresh complete on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values(1,1,1,1);
insert into t1 values(null,1,1,1);
select * from mv1 order by c1;
c1	cnt
NULL	1
1	1
select * from t1 order by c1;
c1	c2	c3	c4
NULL	1	1	1
1	1	1	1
truncate table t1;
ERROR 0A000: truncate table with materialized view log is not supported
##增加外键
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) primary key,c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh complete on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values(1,1,1,1);
insert into t1 values(2,1,1,1);
insert into t1 values(3,3,1,1);
insert into t1 values(4,2,1,1);
insert into t1 values(5,4,1,1);
insert into t1 values(6,null,1,1);
ALTER TABLE t1 ADD CONSTRAINT fk_c2 FOREIGN KEY (c2) REFERENCES t1(c1);
select * from mv1 a,t1 b  where a.c1=b.c2 and b.c2 is not null order by b.c1;
c1	cnt	c1	c2	c3	c4
1	1	1	1	1	1
1	1	2	1	1	1
3	1	3	3	1	1
2	1	4	2	1	1
4	1	5	4	1	1
select count(*) from mv1 a,t1 b  where a.c1!=b.c2;
count(*)
25
select count(*) from mv1 a,t1 b  where a.c1>b.c2;
count(*)
19
select count(*) from mv1 a,t1 b  where a.c1<b.c2;
count(*)
6
select count(*) from mv1 a,t1 b  where a.c1<>b.c2;
count(*)
25
select count(*) from mv1 a,t1 b  where a.c1=b.c2;
count(*)
5
ALTER TABLE t1 DROP  CONSTRAINT fk_c2 ;
