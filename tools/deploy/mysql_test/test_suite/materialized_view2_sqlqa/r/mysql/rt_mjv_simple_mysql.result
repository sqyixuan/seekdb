##子查询（select子句,where子句,having子句）
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh complete on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values(1,1,1,1);
insert into t1 values(3,1,11,1);
insert into t1 values(122,1,null,1);
insert into t1 values(100,1,1,1);
select a.c1,(select t1.c1 from t1 where t1.c1 =1)b from mv1 a order by a.c1;
c1	b
1	1
3	1
100	1
122	1
select a.c1,(select t1.c3 from t1 where t1.c3 is null)b from mv1 a order by a.c1;
c1	b
1	NULL
3	NULL
100	NULL
122	NULL
select a.c1,(select mlog$_t1.c3 from mlog$_t1 where mlog$_t1.c3 > 10)b from mv1 a order by a.c1;
c1	b
1	11
3	11
100	11
122	11
select a.c1 from mv1 a where cnt < (select avg(c1) from t1)order by a.c1;
c1
1
3
100
122
select a.c1 from mv1 a where cnt < (select avg(c3) from t1)order by a.c1;
c1
1
3
100
122
select a.c1 from mv1 a where cnt > (select avg(c1) from mlog$_t1)order by a.c1;
c1
select a.c1 from mv1 a where exists (select avg(c1) from mlog$_t1)order by a.c1;
c1
1
3
100
122
select a.c1 from mv1 a where cnt in (select avg(c1) from mlog$_t1)order by a.c1;
c1
select c1,avg(cnt) from mv1 group by c1 having avg(cnt) >1 order by c1;
c1	avg(cnt)
select c1,avg(cnt) from mv1 group by c1 having avg(cnt) is not null order by c1;
c1	avg(cnt)
1	1.0000
3	1.0000
100	1.0000
122	1.0000
##SELECT FOR UPDATE
SET AUTOCOMMIT=1;
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
insert into t1 values(1,1,1,1);
insert into t1 values(3,1,11,1);
insert into t1 values(122,1,null,1);
insert into t1 values(100,1,1,1);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh complete on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
SET AUTOCOMMIT=0;
select c1 from mv1 where c1 =1 for update;
c1
1
update t1 set c1=99 where c1 =1;
commit;
select * from mv1 order by c1;
c1	cnt
3	1
99	1
100	1
122	1
##rt_mv和基表join
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 int ,c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh complete on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values(1,1,1,1);
insert into t1 values(3,1,11,1);
insert into t1 values(122,1,null,1);
insert into t1 values(100,1,1,1);
create table t2 (c1 int ,c2 int, c3 int, c4 int);
insert into t1 values(1,1,1,1);
select count(*) from t1, mv1 ;
count(*)
20
select count(*) from t1 left join mv1 on t1.c1=mv1.c1 ;
count(*)
5
select count(*) from t2 left join mv1 on t2.c1=mv1.c1 ;
count(*)
0
select count(*) from t1 right join mv1 on t1.c1=mv1.c1 ;
count(*)
5
select count(*) from t1 inner join mv1 on t1.c1=mv1.c1 ;
count(*)
5
##连接视图
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP TABLE t2;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
create view v1 as select * from t1;
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh complete on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values(1,1,1,1);
insert into t1 values(3,1,11,1);
insert into t1 values(122,1,null,1);
select count(*) from mv1,v1;
count(*)
9
select count(*) from mv1,(select 1 from v1);
count(*)
9
