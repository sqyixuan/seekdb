##多数据类型验证
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
CREATE TABLE t1 (
c1 INT PRIMARY KEY,
c2 INT,
c3 FLOAT,
c4 DECIMAL(10, 2),
c5 CHAR(100),
c6 VARCHAR(500),
c7 DATE,
c8 ENUM('中文ing123','蘩騠字','蘩騠字ss'),
c9 year,
c10 json ,
c11 bit
);
INSERT INTO t1 VALUES (1, 100, 3.14, 1234.56, 'Sample Text', 'Variable Length Text', '2023-10-01', '中文ing123', 2024, '{"key": "value"}', b'1');
INSERT INTO t1 VALUES (3, 0, 1.618, 0.00, 'Empty Char', 'Longest String Possible Within Limit', '1999-12-31', '蘩騠字ss', 1998, 'null', b'1');
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2,c3,c4,c6,c7) including new values ;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation as select sum(c2 * c3) sum_c, count(c2 * c3) count, count(*) as c, c6 from t1 group by c6;
update t1 set c3 =9.99 where c1 = 1;
delete from t1 where c1=3;
INSERT INTO t1  VALUES (2, -200, 5.2, 9876.54, 'AnhSle', 'Shorter String', '2022-01-01', '蘩騠字', 2023, '{"another": {"nested": "object"}}', b'1');
select * from mv1 order by c6;
sum_c	count	c	c6
-1039.9999618530273	1	1	Shorter String
998.9999771118164	1	1	Variable Length Text
select * from mlog$_t1 order by c2;
c1	c2	c3	c4	c6	c7	SEQUENCE$$	DMLTYPE$$	OLD_NEW$$
2	-200	5.2	9876.54	Shorter String	2022-01-01	4	I	N
3	0	1.618	0.00	Longest String Possible Within Limit	1999-12-31	3	D	O
1	100	3.14	1234.56	Variable Length Text	2023-10-01	1	U	O
1	100	9.99	1234.56	Variable Length Text	2023-10-01	2	U	N
select * from mv1 a,t1 b where a.c6=b.c6 order by sum_c;
sum_c	count	c	c6	c1	c2	c3	c4	c5	c6	c7	c8	c9	c10	c11
-1039.9999618530273	1	1	Shorter String	2	-200	5.2	9876.54	AnhSle	Shorter String	2022-01-01	蘩騠字	2023	{"another": {"nested": "object"}}	
998.9999771118164	1	1	Variable Length Text	1	100	9.99	1234.56	Sample Text	Variable Length Text	2023-10-01	中文ing123	2024	{"key": "value"}	
