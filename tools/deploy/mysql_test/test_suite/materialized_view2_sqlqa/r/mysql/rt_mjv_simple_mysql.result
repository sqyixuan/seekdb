DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh complete on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values(1,1,1,1);
select * from mv1 a left join mv1 b on a.cnt=b.c1 ;
c1	cnt	c1	cnt
1	1	1	1
select * from mv1 right join (select c1 from mv1)a on a.c1=mv1.c1 ;
c1	cnt	c1
1	1	1
select * from mv1 inner join (select c1 from mv1)a on a.c1=mv1.c1 ;
c1	cnt	c1
1	1	1
##正交分区表
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
insert into t1 values(1,1,1,1);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh complete on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
CREATE TABLE t2 (c1 int PRIMARY KEY, c2 VARCHAR(999) not null) PARTITION BY HASH(c1) PARTITIONS 8;
select * from mv1 a left join  t2 b on a.cnt=b.c1 ;
c1	cnt	c1	c2
1	1	NULL	NULL
select * from mv1 a right join  t2 b on a.cnt=b.c1 ;
c1	cnt	c1	c2
select * from mv1 a inner join  t2 b on a.cnt=b.c1 ;
c1	cnt	c1	c2
##使用聚合函数
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh complete on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values(1,1,1,1);
CALL DBMS_MVIEW.REFRESH('mv1','f');
select count(distinct c1) a from mv1;
a
1
select sum(c1+cnt) from mv1;
sum(c1+cnt)
2
select avg(c1+cnt) from mv1;
avg(c1+cnt)
2.0000
select min(c1+cnt) from mv1;
min(c1+cnt)
2
select max(c1+cnt)+max(c1+cnt) from mv1;
max(c1+cnt)+max(c1+cnt)
4
select * from mv1;
c1	cnt
1	1
