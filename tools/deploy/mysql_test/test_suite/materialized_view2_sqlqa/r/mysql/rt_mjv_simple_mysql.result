insert into t1 values(null,1,null,1);
INSERT INTO t1 SELECT c1 + 4, c1,cnt,c1+1 FROM mv1;
select mv1.c1 from mv1,t1  WHERE mv1.c1 <> ANY (SELECT  1 FROM dual) ORDER BY mv1.c1;
c1
2
2
