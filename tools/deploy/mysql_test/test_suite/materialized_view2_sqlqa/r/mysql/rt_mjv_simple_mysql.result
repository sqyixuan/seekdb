##事务中使用
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh complete on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
START TRANSACTION;
insert into t1 values(1,4,8,12);
insert into t1 values(3,5,3,12);
SAVEPOINT my_savepoint1;
update t1 set c1=11 where c2=5;
insert into t1 values(2,3,3,3);
SAVEPOINT my_savepoint2;
delete from t1 where c1=1;
SAVEPOINT my_savepoint3;
select * from mv1 order by c1;
c1	cnt
2	1
11	1
select * from t1 order by c1;
c1	c2	c3	c4
2	3	3	3
11	5	3	12
ROLLBACK TO my_savepoint3;
select * from t1 order by c1;
c1	c2	c3	c4
2	3	3	3
11	5	3	12
select * from mv1 order by c1;
c1	cnt
2	1
11	1
ROLLBACK TO my_savepoint2;
select * from t1 order by c1;
c1	c2	c3	c4
1	4	8	12
2	3	3	3
11	5	3	12
select * from mv1 order by c1;
c1	cnt
1	1
2	1
11	1
ROLLBACK TO my_savepoint1;
select * from t1 order by c1;
c1	c2	c3	c4
1	4	8	12
3	5	3	12
select * from mv1 order by c1;
c1	cnt
1	1
3	1
##数据类型验证
##char
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
drop materialized view mv2;
create table t1 (c1 char(20) primary key, c2 char(20));
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2) including new values  ;
create materialized view mv1  parallel 9 never refresh   enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values('null','中文ing123');
insert into t1 values('nas','中文ing123');
insert into t1 values('false','999abc');
insert into t1 values('蘩騠字','21311111111111111111');
update t1 set c2='' where c1='null';
delete from t1 where c1 is null;
select * from mv1 a,t1 b where a.c1=b.c1 order by a.c1;
c1	cnt	c1	c2
false	1	false	999abc
nas	1	nas	中文ing123
null	1	null	
蘩騠字	1	蘩騠字	21311111111111111111
select * from mv1 a,mv1 b where a.c1=b.cnt;
c1	cnt	c1	cnt
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: 'nas'
Warning	1292	Truncated incorrect DECIMAL value: 'null'
Warning	1292	Truncated incorrect DECIMAL value: 'false'
Warning	1292	Truncated incorrect DECIMAL value: '蘩騠字'
