##两个不同数据类型
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
drop materialized view mv2;
create table t1 (c1 number(10) ,c2 varchar(120), c3 date, c4 varchar(120));
insert into t1 values(1,'as','2024-03-25','{"name": "John", "age": 30, "city": "New York"}');
insert into t1 values(null,'qqw中','2022-03-25','{"name": "John", "age": 30, "city": "New York"}');
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
create materialized view mv1  parallel 9 refresh complete on demand enable on query  computation as select c1 as c1, count(*) cnt from t1 group by c1;
create materialized view mv2  parallel 9 refresh complete on demand enable on query  computation as select c2 as c2, count(*) cnt from t1 group by c2;
create materialized view mv3  parallel 9 refresh complete on demand enable on query  computation as select c3 as c3, count(*) cnt from t1 group by c3;
select count(*) from mv1,mv2 ;
count(*)
4
select count(*) from mv2,mv3 ;
count(*)
4
select count(*) from mv3,mv1 ;
count(*)
4
select count(*) from mv3,t1 where t1.c4=mv3.c3;
count(*)
0
select count(*) from mv2,t1 where t1.c4=mv2.c2;
count(*)
0
select count(*) from mv1,t1 where t1.c4=mv1.c1;
count(*)
0
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: '{"name": "John", "age": 30, "city": "New York"}'
Warning	1292	Truncated incorrect DECIMAL value: '{"name": "John", "age": 30, "city": "New York"}'
select count(*) from mv1,t1 ;
count(*)
4
select count(*) from mv2,t1 ;
count(*)
4
##复合主键
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 varchar(120) , c3 date, c4 number(10) not null,c5 varchar(120),c6 number(10));
ALTER TABLE t1 ADD CONSTRAINT constraint_name PRIMARY KEY (c2,c3);
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid, sequence(c1,c4,c5,c6)  including new values;
create materialized view mv1  parallel 9 refresh complete on demand enable on query  computation  as select c2 as c2, count(*) cnt from t1 group by c2;
insert into t1 values(1,'{"name": "John", "age": 30, "city": "New York"}','2024-03-25',2,4,6);
insert into t1 values(null,'{"name": "John", "age": 31, "city": "New York"}','2022-03-25',1,3,5);
select mv1.c2,count(*) from mv1,t1,mlog$_t1 where t1.c2=mv1.c2 and mv1.c2=mlog$_t1.c2 group by mv1.c2 order by c2;
c2	count(*)
{"name": "John", "age": 30, "city": "New York"}	1
{"name": "John", "age": 31, "city": "New York"}	1
select mv1.c2,count(*) from mv1,mlog$_t1 where  mv1.cnt=mlog$_t1.c1 group by mv1.c2 order by c2;
c2	count(*)
{"name": "John", "age": 30, "city": "New York"}	1
{"name": "John", "age": 31, "city": "New York"}	1
select mv1.c2,count(*) from mv1,mlog$_t1 where  mv1.c2<>mlog$_t1.c5 group by mv1.c2 order by c2;
c2	count(*)
{"name": "John", "age": 30, "city": "New York"}	2
{"name": "John", "age": 31, "city": "New York"}	2
select mv1.c2,count(*) from mv1,t1 where  mv1.c2<>t1.c5 group by mv1.c2 order by c2;
c2	count(*)
{"name": "John", "age": 30, "city": "New York"}	2
{"name": "John", "age": 31, "city": "New York"}	2
##not null
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 varchar(120), c3 date, c4 number(10) not null);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
create materialized view mv1  parallel 9 refresh complete on demand enable on query  computation  as select c1 as c1, count(*) cnt from t1 group by c1;
insert into t1 values(1,'as','2024-03-25',2);
insert into t1 values(null,'qqw中','2022-03-25',1);
select * from mv1 order by c1;
c1	cnt
NULL	1
1	1
##存在check约束
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
drop materialized view mv1;
create table t1 (c1 number(10) ,c2 varchar(120), c3 date, c4 number(10) check(c4 >1));
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand enable on query  computation  as select c4 as c4, count(*) cnt from t1 group by c4;
insert into t1 values(1,'as','2024-03-25',2);
update t1 set c4=3 where c1 =1;
select * from mv1 order by c4;
c4	cnt
3	1
