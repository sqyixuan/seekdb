drop database  IF EXISTS  ljh;
create database ljh;
use ljh;
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
##设置相同sql_mode;
SET @@sql_mode='';
##索引操作 支持
CREATE TABLE t1 (c1 int ,c2 int, c3 int, c4 int, CONSTRAINT constraint_name CHECK (c3>c2));
insert into t1 values(1,2,3,4);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c4,c3) including new values;
CREATE UNIQUE INDEX index_name1 ON t1 (c1,c2,c3,c4);
CREATE  INDEX index_name2 ON t1 (c2,c4);
ALTER TABLE t1 ADD PRIMARY KEY (c1,c2);
