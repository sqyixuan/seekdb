create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
create materialized view mv1 refresh fast on demand enable on query  computation  as select c2_c3 as c2_c3, count(*) cnt, count(c2_c3) cnt_c23 from t1 group by c2_c3;
