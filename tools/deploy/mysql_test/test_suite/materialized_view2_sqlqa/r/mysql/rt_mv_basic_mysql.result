drop database  IF EXISTS  db1;
create database db1;
use db1;
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
##设置相同sql_mode;
SET @@sql_mode='';
##增量刷新验证
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create table t2(c1 int, c2 int, c3 int, c4 int);
insert into t1 values(1,1,1,1);
insert into t2 values(1,1,1,1);
create materialized view log on t1 with primary key, rowid, sequence (c2, c3) including new values;
create materialized view log on t2 with primary key, rowid, sequence (c2, c3) including new values;
create materialized view t1_mv1 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c3) cnt_c3, avg(c3) avg_c3, avg(c3) * sum(c3)/c2 calc1, c2+sum(c3) calc2 from t1 group by c2;
ERROR HY000: cannot ENABLE ON QUERY COMPUTATION for the materialized view t1_mv1: a standalone sum expression is required in the select item list when using expressions that derive from that sum operation
create materialized view t1_mv1 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, avg(c3) avg_c3, avg(c3) * sum(c3)/c2 calc1, c2+sum(c3) calc2 from t1 group by c2;
ERROR HY000: cannot ENABLE ON QUERY COMPUTATION for the materialized view t1_mv1: when using sum/avg/stddev/variance functions, a standalone count function of the corresponding column is required in the select item list
create materialized view t1_mv1 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c4) cnt_c4, sum(c3) sum_c3 from t1 group by c2;
ERROR HY000: cannot ENABLE ON QUERY COMPUTATION for the materialized view t1_mv1: column c4 of table t1 used in mv is required in the corresponding mlog table
create materialized view t1_mv1 refresh fast on demand enable on query  computation as select c4 as c4, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c4;
ERROR HY000: cannot ENABLE ON QUERY COMPUTATION for the materialized view t1_mv1: column c4 of table t1 used in mv is required in the corresponding mlog table
create materialized view t1_mv1 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
create materialized view t1_mv2 refresh fast on demand enable on query  computation as select count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1;
create materialized view t1_mv3 refresh fast on demand enable on query  computation as select count(c3) cnt_c3, sum(c3) sum_c3 from t1;
create materialized view t1_mv4 refresh fast on demand enable on query  computation as select c2 as c2, c3 as c3, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2, c3;
create materialized view t1_mv5 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3) * sum(c3)/c2 calc1, c2+sum(c3) calc2 from t1 group by c2;
insert into t1 values(2,2,3,4);
insert into t1 values(3,2,3,4);
insert into t1 values(4,2,3,4);
insert into t1 values(5,2,3,4);
CALL DBMS_MVIEW.REFRESH('t1_mv1','f');
CALL DBMS_MVIEW.REFRESH('t1_mv2','f');
CALL DBMS_MVIEW.REFRESH('t1_mv3','f');
CALL DBMS_MVIEW.REFRESH('t1_mv4','f');
CALL DBMS_MVIEW.REFRESH('t1_mv5','f');
select * from t1_mv1 order by c2;
c2	cnt	cnt_c3	sum_c3
1	1	1	1
2	4	4	12
select * from t1_mv2;
cnt	cnt_c3	sum_c3
5	5	13
select * from t1_mv3;
cnt_c3	sum_c3
5	13
select * from t1_mv4 order by c2;
c2	c3	cnt	cnt_c3	sum_c3
1	1	1	1	1
2	3	4	4	12
select * from t1_mv5 order by c2;
c2	cnt	cnt_c3	sum_c3	avg_c3	calc1	calc2
1	1	1	1	1.0000	1.00000000	2
2	4	4	12	3.0000	18.00000000	14
DROP MATERIALIZED VIEW LOG ON t1;
DROP MATERIALIZED VIEW LOG ON t2;
drop table t1;
drop table t2;
drop materialized view t1_mv1;
drop materialized view t1_mv2;
drop materialized view t1_mv3;
drop materialized view t1_mv4;
drop materialized view t1_mv5;
##针对空表进行验证
##物化视图中存在数据,进行刷新
##边界条件测试：测试在边界条件下的增量更新行为，例如测试在分区切换、分区维护、索引重建等情况下的表现。
##重复执行测试：多次执行增量更新操作，以确保在重复执行过程中不会出现数据重复、丢失或不一致的情况。
##dml操作验证
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1 refresh fast on demand enable on query  computation  as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
insert into t1 values(2,3,3,4);
update t1 set c2 = 1 where c1=2;
select * from mv1;
c2	cnt	cnt_c3	sum_c3
1	1	1	3
delete from t1 where c1 =2;
select * from mv1;
c2	cnt	cnt_c3	sum_c3
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1(c1 number primary key, c2 number, c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1 refresh complete on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
insert into t1 values(2,3,3,4);
update t1 set c2 = 1 where c1=2;
select * from mv1;
c2	cnt	cnt_c3	sum_c3
1	1	1	3
delete from t1 where c1 =2;
select * from mv1;
c2	cnt	cnt_c3	sum_c3
##表中存在空值进行验证
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1(c1 number primary key, c2 number, c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
##insert
insert into t1 values(2,null,3,4);
insert into t1 values(3,2,null,null);
insert into t1 values(4,2,null,4);
insert into t1 values(5,2,null,0);
##delete
delete from t1 where c3 is null;
select * from mv1;
c2	cnt	cnt_c3	sum_c3
NULL	1	1	3
select * from t1;
c1	c2	c3	c4
2	NULL	3	4
##重命名列
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
ALTER TABLE t1 RENAME COLUMN c1 TO new_c1;
ERROR 0A000: modify column to table with materialized view log is not supported
##重命名表
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
alter table t1 rename to t_t1;
ERROR 0A000: this alter table to table with materialized view log is not supported
##非空表验证
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
insert into t1 values(2,2,3,4);
insert into t1 values(3,2,3,4);
insert into t1 values(4,2,3,4);
insert into t1 values(5,2,3,4);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
select * from mv1 order by c2;
c2	cnt	cnt_c3	sum_c3
2	4	4	12
##增加外键索引
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
insert into t1 values(2,2,3,4);
insert into t1 values(3,2,3,4);
insert into t1 values(4,2,3,4);
insert into t1 values(5,2,3,4);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
alter table t1 add constraint fk_c2 foreign key(c2) references t1(c1);
CALL DBMS_MVIEW.REFRESH('mv1');
insert into t1 values(0,null,null,4);
CALL DBMS_MVIEW.REFRESH('mv1');
select * from mv1 order by c2;
c2	cnt	cnt_c3	sum_c3
NULL	1	0	NULL
2	4	4	12
select * from t1 order by c1;
c1	c2	c3	c4
0	NULL	NULL	4
2	2	3	4
3	2	3	4
4	2	3	4
5	2	3	4
##删除外键约束
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 number(10) primary key,c2 number(10), c3 number, c4 number,constraint fk_c2 foreign key(c2) references t1(c1));
insert into t1 values(2,2,3,4);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c4,c3) including new values;
create materialized view mv1 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
alter table  t1 drop constraint fk_c2;
insert into t1 values(0,null,null,4);
delete from t1 where c1 =2 ;
insert into t1 values(2,2,3,4);
select * from mv1 order by c2;
c2	cnt	cnt_c3	sum_c3
NULL	1	0	NULL
2	1	1	3
select * from t1 order by c1;
c1	c2	c3	c4
0	NULL	NULL	4
2	2	3	4
##创建唯一索引
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
insert into t1 values(1,2,3,4);
insert into t1 values(null,2,3,4);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c4,c3) including new values;
create materialized view mv1 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
CREATE UNIQUE INDEX index_name ON mv1 (cnt);
insert into t1 values(2,2,3,4);
insert into t1 values(null,null,null,null);
select * from mv1 order by cnt;
c2	cnt	cnt_c3	sum_c3
NULL	1	0	NULL
2	3	3	9
##创建普通索引
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int ,c2 int, c3 int, c4 int);
insert into t1 values(1,2,3,4);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c4,c3) including new values;
create materialized view mv1 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
CREATE  INDEX index_name ON mv1 (c2);
insert into t1 values(2,2,3,4);
select * from mv1 order by c2;
c2	cnt	cnt_c3	sum_c3
2	2	2	6
select * from t1 order by c1;
c1	c2	c3	c4
1	2	3	4
2	2	3	4
##创建函数索引  
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int ,c2 int, c3 int, c4 int);
insert into t1 values(1,2,3,4);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c4,c3) including new values;
create materialized view mv1 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
CREATE INDEX idx_name_abscase ON t1 ((abs(c2)));
CREATE INDEX idx_name_abscase1 ON mv1 ((abs(c2)));
ERROR 0A000: use functional index on materialized view not supported
insert into t1 values(2,2,3,4);
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1 order by c2;
c2	cnt	cnt_c3	sum_c3
2	2	2	6
select * from t1 order by c1;
c1	c2	c3	c4
1	2	3	4
2	2	3	4
##创建前缀索引
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 char(10) ,c2 int, c3 int, c4 int);
insert into t1 values(1,2,3,4);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c4,c3) including new values;
create materialized view mv1 refresh fast on demand enable on query  computation as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
CREATE INDEX idx_name ON t1 (c1(4));
insert into t1 values('aass',2,3,4);
CALL DBMS_MVIEW.REFRESH('mv1');
select * from mv1 order by c2;
c2	cnt	cnt_c3	sum_c3
2	2	2	6
select * from t1 order by c1;
c1	c2	c3	c4
1	2	3	4
aass	2	3	4
