##使用distinct结合聚合函数
drop table  if exists tt1;
drop materialized view  if exists tt_mv1;
drop materialized view  if exists tt_mv2;
drop materialized view  if exists tt_mv3;
drop materialized view  if exists tt_mv4;
create table tt1 (c1 number primary key, c2 varchar(30),c3 number);
INSERT INTO tt1 (c1, c2, c3) VALUES (119, '中ng123',119);
INSERT INTO tt1 (c1, c2, c3) VALUES (199, '中文ing123',199);
create materialized view tt_mv1  refresh complete on demand as SELECT COUNT(DISTINCT c2) AS unique_c2_count FROM tt1;
create materialized view tt_mv2  refresh complete on demand as SELECT SUM(DISTINCT c3) AS sum_of_distinct_c3 FROM tt1;
create materialized view tt_mv3  refresh complete on demand as SELECT MIN(DISTINCT c3) AS min_distinct_c3, MAX(DISTINCT c3) AS max_distinct_c3 FROM tt1;
create materialized view tt_mv4  refresh complete on demand as SELECT AVG(DISTINCT c3) AS avg_of_distinct_c3 FROM tt1;
select * from tt_mv1 ;
unique_c2_count
2
select * from tt_mv2 ;
sum_of_distinct_c3
