      access([a.c1], [a.c2], [a.c3]), partitions(p3)
      is_index_back=false, is_global_index=false, keep_ordering=true, 
      range_key([a.c1]), range[3 ; 3], 
      range_cond([a.c1 = demote_cast('3', INT(11, 0))])
  3 - output([b.c3]), filter(nil)
      sort_keys([b.c3, ASC])
  4 - output([b.c3]), filter(nil)
      access([b.c3]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([b.c1]), range(MIN ; MAX)always true
