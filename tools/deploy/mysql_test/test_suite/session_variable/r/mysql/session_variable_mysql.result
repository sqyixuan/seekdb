drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create table t2 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
insert into t1 values (1,1,1),(2,2,2),(3,3,3);
insert into t2 values (1,1,1),(2,2,3),(3,3,3);
select c3, (@rownum:= @rownum + 1) as ccbh from t1 a, (select @rownum:= 0) B;
c3	ccbh
1	1
2	2
3	3
explain update t1 a, t2 b set a.c2 = @val:=(a.c2 + 1) where a.c3 = b.c3 and a.c1 = '3';
