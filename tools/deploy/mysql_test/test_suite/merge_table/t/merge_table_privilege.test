##owner: fanxingkun.fxk
##owner group: 底层引擎部-轻量版
##description: MERGE TABLE 权限测试
##tags: merge_table privilege
##author: fanxingkun.fxk

--disable_warnings
drop database if exists db_merge_priv;
drop user if exists merge_nopriv;
drop user if exists merge_sel_inc;
drop user if exists merge_sel_both;
drop user if exists merge_sel_ins;
drop user if exists merge_full;
drop user if exists merge_no_inc_sel;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo ============================================
--echo Setup - 创建测试库、表和数据
--echo ============================================

create database db_merge_priv;
use db_merge_priv;

create table t_cur (id int primary key, v int);
create table t_inc (id int primary key, v int);
insert into t_cur values (1, 10), (2, 20);
insert into t_inc values (3, 30), (4, 40);

--echo ============================================
--echo 1. 无权限用户执行 MERGE TABLE - 预期失败
--echo ============================================

create user merge_nopriv identified by 'test123';
grant create on db_merge_priv.* to merge_nopriv;

connect (conn1,$OBMYSQL_MS0,merge_nopriv,test123,db_merge_priv,$OBMYSQL_PORT);
connection conn1;

--replace_regex /denied to user.*/denied/
--error 1142
merge table db_merge_priv.t_inc into db_merge_priv.t_cur;

--echo ============================================
--echo 2. incoming 仅 SELECT, current 无权限 - 预期失败
--echo ============================================

connection default;
create user merge_sel_inc identified by 'test123';
grant select on db_merge_priv.t_inc to merge_sel_inc;

connect (conn2,$OBMYSQL_MS0,merge_sel_inc,test123,db_merge_priv,$OBMYSQL_PORT);
connection conn2;

--replace_regex /denied to user.*/denied/
--error 1142
merge table db_merge_priv.t_inc into db_merge_priv.t_cur;

--echo ============================================
--echo 3. incoming SELECT + current 仅 SELECT（缺 INSERT/UPDATE）- 预期失败
--echo ============================================

connection default;
create user merge_sel_both identified by 'test123';
grant select on db_merge_priv.t_inc to merge_sel_both;
grant select on db_merge_priv.t_cur to merge_sel_both;

connect (conn3,$OBMYSQL_MS0,merge_sel_both,test123,db_merge_priv,$OBMYSQL_PORT);
connection conn3;

--replace_regex /denied to user.*/denied/
--error 1142
merge table db_merge_priv.t_inc into db_merge_priv.t_cur;

--echo ============================================
--echo 4. incoming SELECT + current SELECT+INSERT（缺 UPDATE）- 预期失败
--echo ============================================

connection default;
create user merge_sel_ins identified by 'test123';
grant select on db_merge_priv.t_inc to merge_sel_ins;
grant select, insert on db_merge_priv.t_cur to merge_sel_ins;

connect (conn4,$OBMYSQL_MS0,merge_sel_ins,test123,db_merge_priv,$OBMYSQL_PORT);
connection conn4;

--replace_regex /denied to user.*/denied/
--error 1142
merge table db_merge_priv.t_inc into db_merge_priv.t_cur;

--echo ============================================
--echo 5. incoming SELECT + current SELECT+INSERT+UPDATE - 预期成功
--echo ============================================

connection default;
create user merge_full identified by 'test123';
grant select on db_merge_priv.t_inc to merge_full;
grant select, insert, update on db_merge_priv.t_cur to merge_full;

connect (conn5,$OBMYSQL_MS0,merge_full,test123,db_merge_priv,$OBMYSQL_PORT);
connection conn5;

merge table db_merge_priv.t_inc into db_merge_priv.t_cur;
select * from db_merge_priv.t_cur order by id;

--echo ============================================
--echo 6. incoming 缺 SELECT + current 全权限 - 预期失败
--echo ============================================

connection default;
create user merge_no_inc_sel identified by 'test123';
grant select, insert, update on db_merge_priv.t_cur to merge_no_inc_sel;

connect (conn6,$OBMYSQL_MS0,merge_no_inc_sel,test123,db_merge_priv,$OBMYSQL_PORT);
connection conn6;

--replace_regex /denied to user.*/denied/
--error 1142
merge table db_merge_priv.t_inc into db_merge_priv.t_cur;

--echo ============================================
--echo 7. 清理
--echo ============================================

connection default;
drop user merge_nopriv;
drop user merge_sel_inc;
drop user merge_sel_both;
drop user merge_sel_ins;
drop user merge_full;
drop user merge_no_inc_sel;
drop database if exists db_merge_priv;
