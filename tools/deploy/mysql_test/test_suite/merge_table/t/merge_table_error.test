##owner: fanxingkun.fxk
##owner group: 底层引擎部-轻量版
##description: MERGE TABLE 错误场景测试
##tags: merge_table error
##author: fanxingkun.fxk

--disable_warnings
drop database if exists db_merge_err;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo ============================================
--echo 1. 错误场景 - current 表不存在
--echo ============================================

create database db_merge_err;
use db_merge_err;
create table t_inc (id int primary key, v int);
insert into t_inc values (1, 1);

--error 1146
merge table db_merge_err.t_inc into db_merge_err.non_existent_t;

--echo ============================================
--echo 2. 错误场景 - incoming 表不存在
--echo ============================================

create table t_cur (id int primary key, v int);
insert into t_cur values (1, 1);

--error 1146
merge table db_merge_err.non_existent_t into db_merge_err.t_cur;

--echo ============================================
--echo 3. 错误场景 - 数据库不存在
--echo ============================================

--error 1146
merge table db_merge_err.t_inc into no_such_db.t_cur;

--echo ============================================
--echo 4. 错误场景 - 无主键表
--echo ============================================

create table t_no_pk (id int, v int);
create table t_has_pk (id int primary key, v int);
insert into t_no_pk values (1, 1);
insert into t_has_pk values (1, 1);

--error 4029
merge table db_merge_err.t_has_pk into db_merge_err.t_no_pk;

--echo ============================================
--echo 5. 错误场景 - HEAP 表无主键
--echo ============================================

create table t_heap_no_pk1 (id int, v int) ORGANIZATION = HEAP;
create table t_heap_no_pk2 (id int, v int) ORGANIZATION = HEAP;
insert into t_heap_no_pk1 values (1, 1);
insert into t_heap_no_pk2 values (1, 1);

--error 1235
merge table db_merge_err.t_heap_no_pk1 into db_merge_err.t_heap_no_pk2;

--echo ============================================
--echo 6. 错误场景 - 列定义不一致（列数不同）
--echo ============================================

create table t_col3 (id int primary key, a int, b int);
create table t_col4 (id int primary key, a int, b int, c int);
insert into t_col3 values (1, 10, 20);
insert into t_col4 values (1, 10, 20, 30);

--error 4029
merge table db_merge_err.t_col4 into db_merge_err.t_col3;

--echo ============================================
--echo 7. 错误场景 - 列长度不一致
--echo ============================================

create table t_len1 (id int primary key, v varchar(20));
create table t_len2 (id int primary key, v varchar(30));

--error 4029
merge table db_merge_err.t_len2 into db_merge_err.t_len1;

--echo ============================================
--echo 8. 清理
--echo ============================================

drop database if exists db_merge_err;
