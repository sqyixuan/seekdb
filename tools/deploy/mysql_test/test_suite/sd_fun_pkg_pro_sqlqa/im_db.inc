   CREATE OR REPLACE  VIEW "IM"."ORGANIZATION" ("ORGID", "REGION", "ORGNAME", "ORGTYPE", "ORGLEVEL", "ISINNER", "MANAGERID", "PARENTID", "OPENPHONE", "ADDRESS", "POSTCODE", "CONTACTMAN", "CONTACTPHONE", "FAX", "EMAIL", "COUNTY", "AREAID", "OWNERTYPE", "NOTES", "CREATEDATE", "STATUS", "STATUSDATE", "AGENTTYPEID", "STARLEVEL", "DISTTYPEID", "ISCHANNELAUTHFILTER", "DEPARTCODE", "AGENTSTYLE", "ISPROVCHAIN", "CHAINNAME") AS
  SELECT
  ORG.ORGAID             ORGID,
  to_number(ORG.AreaCode)      REGION,
  ORG.ORGANAME           ORGNAME,
  ORG.ORGATYPEID         ORGTYPE,
  ORG.OrgaLevel          ORGLEVEL,
  ORG.isInner            ISINNER,
  ORG.MONITORID          MANAGERID,
  ORG.PARENTID           PARENTID,
  ORG.OPENPHONE          OPENPHONE,
  ORG.ADDRESS            ADDRESS,
  ORG.POSTALCODE         POSTCODE,
  ORG.CONTACTSTAFFNO     CONTACTMAN,
  ORG.CONTACTTELNO       CONTACTPHONE,
  ORG.FAXNO              FAX,
  ORG.EMAIL              EMAIL,
  ORG.Cityflag           COUNTY,
  ORG.BelongOrga         AREAID,
  ORG.OWNERTYPE          OWNERTYPE,
  ORG.OrgaDesc           NOTES,
  ORG.CreateDate         CREATEDATE,
  to_number(decode(ORG.ORGASTATE,1,0,0,1,2,2,0,ORG.ORGASTATE))       STATUS,
  ORG.StatusDate         STATUSDATE,
  ORG.AGENTTYPEID        AGENTTYPEID,
  ORG.STARLEVEL          STARLEVEL,
  ORG.DISTTYPEID         DISTTYPEID,
  ORG.ISCHANNELAUTHFILTER ISCHANNELAUTHFILTER,
  ORG.DEPARTCODE         DEPARTCODE,
  ORG.AGENTSTYLE         AGENTSTYLE,
  ORG.ISPROVCHAIN ISPROVCHAIN,
  ORG.CHAINNAME CHAINNAME
FROM "ICDPUB".T_UCP_ORGAINFO ORG;

