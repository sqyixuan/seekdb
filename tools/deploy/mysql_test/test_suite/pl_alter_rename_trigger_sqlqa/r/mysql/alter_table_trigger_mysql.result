purge recyclebin;
result_format: 4
########## 处理测试环境 ##########
drop user whh@'%';
drop database whh1;
create user whh identified by 'whh';
create database whh1;
grant all on *.* to whh with grant option;


set @@sql_mode='strict_all_tables';
>>>>>>>>>>>>>>>>>>>>>>>>>>> oracle-trig-1 触发器类型    <<<<<<<<<<<<<<<<<<<<<<<<<<<
>>>>>>>>>>>>>>>>>>>>>>>>>>> oracle-trig-2 触发器对象    <<<<<<<<<<<<<<<<<<<<<<<<<<<
>>>>>>>>>>>>>>>>>>>>>>>>>>> oracle-trig-3 测试场景      <<<<<<<<<<<<<<<<<<<<<<<<<<<
drop table res_table;
create table res_table (id int auto_increment primary key,c1 varchar(100));
###### 1、基表在创建触发器时就不存在
## insert触发器
drop trigger trig_test;//
create trigger trig_test 
  before update on no_exist_table for each row 
begin
  insert into res_table values (1,'insert 触发器');
end;
//
ERROR 42S02: Table 'whh1.no_exist_table' doesn't exist
###### 2、删除基表后，执行触发动作，看是否报错
## delete触发器
drop table t1;
create table t1(id int auto_increment primary key,c1 varchar(50) not null,c2 tinyint,index idx1 (c1));
insert into t1 values (1,'删除基表前触发 insert 触发器',10);
insert into t1 values (2,'删除基表前触发 insert 触发器',20);
drop trigger delete_trig;//
create trigger delete_trig
  before insert on t1 for each row 
begin
  insert into res_table(c1) values ('delete 触发器');
end;
//
delete from res_table;
delete from t1 where id = 1;
select * from res_table order by id;
+----+------+
| id | c1   |
+----+------+
+----+------+
select * from t1 order by id;
+----+----------------------------------------+------+
| id | c1                                     | c2   |
+----+----------------------------------------+------+
|  2 | 删除基表前触发 insert 触发器           |   20 |
+----+----------------------------------------+------+
drop table t1;
delete from t1 where id = 2;
ERROR 42S02: Table 'whh1.t1' doesn't exist
###### 3、删除基表后，再重新创建同名的表，执行触发动作，看是否报错
create table t1(id int auto_increment primary key,c1 varchar(50) not null,c2 tinyint,index idx1 (c1));
insert into t1 values (1,'删除基表后，再重新创建同名的表',10);
delete from res_table;
delete from t1 where id = 1;
select * from res_table order by id;
+----+------+
| id | c1   |
+----+------+
+----+------+
select * from t1 order by id;
+----+----+------+
| id | c1 | c2   |
+----+----+------+
+----+----+------+
###### 4、修改基表结构，执行触发动作，看是否报错
## update触发器
drop table t1;
create table t1(id int auto_increment primary key,c1 varchar(50) not null,c2 tinyint,index idx1 (c1));
insert into t1 values (1,'基表 t1',10);
drop trigger update_trig;//
create trigger update_trig
  before update on t1 for each row 
begin
  insert into res_table(c1) values ('update 触发器');
end;
//
delete from res_table;
update t1 set c1 = '触发 update 触发器 ' where id = 1;
select * from res_table order by id;
+----+------------------+
| id | c1               |
+----+------------------+
|  1 | update 触发器    |
+----+------------------+
select * from t1 order by id;
+----+--------------------------+------+
| id | c1                       | c2   |
+----+--------------------------+------+
|  1 | 触发 update 触发器       |   10 |
+----+--------------------------+------+
## 添加字段：ALTER TABLE tbl_name ADD column_name type constraint;
ALTER TABLE t1 ADD c3 int not null;
delete from res_table;
update t1 set c1 = '添加字段：触发 update 触发器 ' where id = 1;
select * from res_table order by id;
+----+------------------+
| id | c1               |
+----+------------------+
|  2 | update 触发器    |
+----+------------------+
select * from t1 order by id;
+----+-----------------------------------------+------+----+
| id | c1                                      | c2   | c3 |
+----+-----------------------------------------+------+----+
|  1 | 添加字段：触发 update 触发器            |   10 |  0 |
+----+-----------------------------------------+------+----+
## 修改字段：ALTER TABLE tbl_name CHANGE old_col_name new_col_name type constraint;
ALTER TABLE t1 CHANGE c3 new_c3 int;
delete from res_table;
update t1 set c1 = '修改字段：触发 update 触发器1 ' where id = 1;
select * from res_table order by id;
+----+------------------+
| id | c1               |
+----+------------------+
|  3 | update 触发器    |
+----+------------------+
select * from t1 order by id;
+----+------------------------------------------+------+--------+
| id | c1                                       | c2   | new_c3 |
+----+------------------------------------------+------+--------+
|  1 | 修改字段：触发 update 触发器1            |   10 |      0 |
+----+------------------------------------------+------+--------+
## 修改字段：ALTER TABLE tbl_name MODIFY column_name type constraint;
ALTER TABLE t1 MODIFY new_c3 char(50);
delete from res_table;
update t1 set c1 = '修改字段：触发 update 触发器2 ' where id = 1;
select * from res_table order by id;
+----+------------------+
| id | c1               |
+----+------------------+
|  4 | update 触发器    |
+----+------------------+
select * from t1 order by id;
+----+------------------------------------------+------+--------+
| id | c1                                       | c2   | new_c3 |
+----+------------------------------------------+------+--------+
|  1 | 修改字段：触发 update 触发器2            |   10 | 0      |
+----+------------------------------------------+------+--------+
## 删除字段：ALTER TABLE tbl_name DROP column_name;
ALTER TABLE t1 DROP new_c3;
delete from res_table;
update t1 set c1 = '删除字段：触发 update 触发器 ' where id = 1;
select * from res_table order by id;
+----+------------------+
| id | c1               |
+----+------------------+
|  5 | update 触发器    |
+----+------------------+
select * from t1 order by id;
+----+-----------------------------------------+------+
| id | c1                                      | c2   |
+----+-----------------------------------------+------+
|  1 | 删除字段：触发 update 触发器            |   10 |
+----+-----------------------------------------+------+
## 重命名表：ALTER TABLE old_tbl_name RENAME new_tbl_name;
ALTER TABLE t1 RENAME new_t1;
delete from res_table;
update t1 set c1 = '重命名表：触发 update 触发器1 ' where id = 1;
ERROR 42S02: Table 'whh1.t1' doesn't exist
update new_t1 set c1 = '重命名表：触发 update 触发器2 ' where id = 1;
select * from res_table order by id;
+----+------------------+
| id | c1               |
+----+------------------+
|  6 | update 触发器    |
+----+------------------+
select * from new_t1 order by id;
+----+------------------------------------------+------+
| id | c1                                       | c2   |
+----+------------------------------------------+------+
|  1 | 重命名表：触发 update 触发器2            |   10 |
+----+------------------------------------------+------+
## 重命名表：RENAME TABLE old_tbl_name TO new_tbl_name [, tbl_name2 TO new_tbl_name2] ...
RENAME TABLE new_t1 TO t1;
delete from res_table;
update new_t1 set c1 = '重命名表：触发 update 触发器3 ' where id = 1;
ERROR 42S02: Table 'whh1.new_t1' doesn't exist
update t1 set c1 = '重命名表：触发 update 触发器4 ' where id = 1;
select * from res_table order by id;
+----+------------------+
| id | c1               |
+----+------------------+
|  7 | update 触发器    |
+----+------------------+
select * from t1 order by id;
+----+------------------------------------------+------+
| id | c1                                       | c2   |
+----+------------------------------------------+------+
|  1 | 重命名表：触发 update 触发器4            |   10 |
+----+------------------------------------------+------+
#### 5、触发器的语句块中内部引用的对象(表)不可用
## 引用的对象在创建触发器时就不可用
# 引用的对象不可用时，执行触发动作，看是否报错
drop table t1;
create table t1(id int auto_increment primary key,c1 varchar(50) not null,c2 tinyint,index idx1 (c1));
insert into t1 values (1,'基表 t1',10);
drop table no_exist_table;
drop trigger update_trig;//
create trigger update_trig
  before update on t1 for each row 
begin
  insert into no_exist_table(c1) values('触发器 update_trig 被触发');
end;
//
update t1 set c1 = '引用的对象在创建触发器时就不可用' where id = 1;
ERROR 42S02: Table 'whh1.no_exist_table' doesn't exist
# 使引用的对象变成可用的，执行触发动作，看是否报错
create table no_exist_table (id int auto_increment primary key,c1 varchar(100) not null);
update t1 set c1 = '使引用的对象变成可用的' where id = 1;
select * from no_exist_table order by 1;
+----+---------------------------------+
| id | c1                              |
+----+---------------------------------+
|  1 | 触发器 update_trig 被触发       |
+----+---------------------------------+
## 引用的对象在创建触发器时可用，创建之后被删除
# 引用的对象不可用时，执行触发动作，看是否报错
drop table t1;
create table t1(id int auto_increment primary key,c1 varchar(50) not null,c2 tinyint,index idx1 (c1));
insert into t1 values (1,'基表 t1',10);
drop table no_exist_table;
create table no_exist_table (id int auto_increment primary key,c1 varchar(100) not null);
drop trigger update_trig;//
create trigger update_trig
  before update on t1 for each row 
BEGIN
   insert into no_exist_table(c1) values('触发器 update_trig 被触发2');
END;
//
update t1 set c1 = '引用的对象在创建触发器时可用' where id = 1;
select * from no_exist_table order by 1;
+----+----------------------------------+
| id | c1                               |
+----+----------------------------------+
|  1 | 触发器 update_trig 被触发2       |
+----+----------------------------------+
drop table no_exist_table;
update t1 set c1 = '引用的对象不可用时' where id = 1;
ERROR 42S02: Table 'whh1.no_exist_table' doesn't exist
# 使引用的对象变成可用的，执行触发动作，看是否报错
create table no_exist_table (id int auto_increment primary key,c1 varchar(100) not null);
update t1 set c1 = '使引用的对象变成可用的' where id = 1;
select * from no_exist_table order by 1;
+----+----------------------------------+
| id | c1                               |
+----+----------------------------------+
|  1 | 触发器 update_trig 被触发2       |
+----+----------------------------------+
# Clean up users
drop user whh@'%';
drop database whh1;
