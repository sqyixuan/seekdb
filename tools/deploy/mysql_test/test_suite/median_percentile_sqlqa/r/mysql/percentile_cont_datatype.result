#包含数据类型丰富的数据表
CREATE TABLE W0CASE (
id INT AUTO_INCREMENT PRIMARY KEY,
name VARCHAR(100),
age INT,
height DECIMAL(5,2),
birth_date DATE,
created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
is_active BOOLEAN,
description TEXT
);
INSERT INTO W0CASE(id,name,age,height,birth_date,is_active,description) VALUES
(1,'Alice', 30, 5.75, '1993-01-15', TRUE, 'Alice is a software engineer with over 5 years of experience.'),
(2,'Bob', 25, 6.00, '1998-05-22', FALSE, 'Bob is a recent graduate in computer science.'),
(3,'Charlie', 35, 5.90, '1988-07-30', TRUE, 'Charlie is a project manager at a tech company.');
SELECT PERCENTILE_CONT(age, 0.23) from  W0CASE;
PERCENTILE_CONT(age, 0.23)
27.3
SELECT PERCENTILE_CONT(height, 0.5), PERCENTILE_CONT(is_active, 0.5) from  W0CASE group by  description;
PERCENTILE_CONT(height, 0.5)	PERCENTILE_CONT(is_active, 0.5)
5.75	1
6	0
5.9	1
#时间类型
SELECT PERCENTILE_CONT(birth_date, 1) from  W0CASE;
ERROR HY000: argument is null, invalid, or out of range
SELECT PERCENTILE_CONT(created_at, 0) from  W0CASE;
ERROR HY000: argument is null, invalid, or out of range
drop table W0CASE;
#反拼case
create table tb_reconstrcut(a char(10),b int);
insert into tb_reconstrcut values('bshgg12',12),('jwioio',9091);
create view vq as select percentile_cont(b, 0.5) from tb_reconstrcut;
show create view vq;
View	Create View	character_set_client	collation_connection
vq	CREATE VIEW `vq` AS select percentile_cont(`test`.`tb_reconstrcut`.`b`,0.5) AS `percentile_cont(b, 0.5)` from `test`.`tb_reconstrcut`	utf8mb4	utf8mb4_general_ci
select * from vq;
percentile_cont(b, 0.5)
4551.5
drop view vq;
drop table tb_reconstrcut;
