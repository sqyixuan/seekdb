--disable_warnings
drop table if exists w0case;


--echo #参数类型 double
CREATE TABLE W0CASE(w0_test0 DOUBLE,w0_test1 varchar(20));
INSERT INTO W0CASE VALUES(10422.45254245,'a');
INSERT INTO W0CASE VALUES(2452542.543224520,'a');
INSERT INTO W0CASE VALUES(452542.5432453230,'b');
INSERT INTO W0CASE VALUES(44524250,'b');
INSERT INTO W0CASE VALUES(-54257375835353540,'b');
INSERT INTO W0CASE VALUES(0,'abh');
INSERT INTO W0CASE VALUES(-17976931348623157.7976931348623,'ah91');
INSERT INTO W0CASE VALUES(NULL, NULL);
INSERT INTO w0case VALUES(18734654684684.268486786178971878,'s');
SELECT PERCENTILE_CONT(W0_test0, 0.1232325665331) FROM W0CASE;
SELECT PERCENTILE_CONT(W0_test0, 0.5) FROM W0CASE;
SELECT PERCENTILE_CONT(W0_test0, 0) FROM W0CASE;
SELECT PERCENTILE_CONT(W0_test0, 1) FROM W0CASE;
SELECT PERCENTILE_CONT(W0_test0, 0.7899168167788) FROM W0CASE group by w0_test1 ASC ;
SELECT PERCENTILE_CONT(W0_test0, 0.9999999999999)  FROM W0CASE group by w0_test0;
SELECT ABS(PERCENTILE_CONT(W0_test0, 0.9999999999999))  FROM W0CASE group by w0_test0;
DROP TABLE W0CASE;

--echo #参数类型 double(M,D) UNSIGNED
CREATE TABLE W0CASE(w0_test0 DOUBLE(30,10) UNSIGNED,w0_test1 varchar(12));
