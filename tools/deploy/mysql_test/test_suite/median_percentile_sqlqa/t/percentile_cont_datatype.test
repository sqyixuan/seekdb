SELECT PERCENTILE_CONT(W0_test0, 0.5) FROM W0CASE GROUP BY w0_test1;
INSERT INTO W0CASE VALUES(0,' ');
SELECT PERCENTILE_CONT(W0_test0, 0) FROM W0CASE GROUP BY w0_test1 DESC;
SELECT PERCENTILE_CONT(W0_test0, 1) FROM W0CASE GROUP BY w0_test1;
SELECT PERCENTILE_CONT(W0_test0, 0.788113) FROM W0CASE GROUP BY w0_test0;
DROP TABLE W0CASE;

