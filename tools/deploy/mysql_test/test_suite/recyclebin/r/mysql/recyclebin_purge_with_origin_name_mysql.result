result_format: 4
set @@recyclebin = off;
drop database if exists xiaofeng_db1;
drop database if exists xiaofeng_db2;
set the session variable
set @@recyclebin = on;
show session variables like 'recyclebin';
Variable_name	Value
recyclebin	ON

create database xiaofeng_db1;
create database xiaofeng_db2;


## (1) 测试回收站新功能，支持使用 origin table name 对回收站中的对象进行 purge 操作 (依然支持使用 object name 进行 purge，功能和以前一样)
## 如果使用 origin table name 进行 purge，且回收站中有重复的原表名，则清理最早被删除到回收站的一张表
use xiaofeng_db1;
create table t1(c1 int);
create index idx on t1(c1);
drop table t1;
create table t1(c2 char);
create index idx on t1(c2);
drop table t1;

### 对比 purge t1 表前后回收站里 origin name 叫 t1 的最早被删除到回收站的表的 object name，如果不同，则说明 purge 时清理的是最早被删除到回收站的一张表
### purge 回收站里 origin name 叫 t1/idx 的最早被删除到回收站的表/索引之前

### purge 回收站里 origin name 叫 idx 的索引
use xiaofeng_db1;
purge index idx;

### purge 回收站里 origin name 叫 idx 的最早被删除到回收站的索引之后

### 对比 purge index idx 前后回收站里 origin name 叫 idx 的最早被删除到回收站的索引的 object name，如果不同，则说明 purge 时清理的是最早被删除到回收站的一张索引
+---+
| 1 |
+---+
+---+
### purge 回收站里 origin name 叫 t1 的表
use xiaofeng_db1;
purge table t1;

### purge 回收站里 origin name 叫 t1 的最早被删除到回收站的表之后
### 对比 purge t1 表前后回收站里 origin name 叫 t1 的最早被删除到回收站的表的 object name，如果不同，则说明 purge 时清理的是最早被删除到回收站的一张表
+---+
| 1 |
+---+
+---+

## (2) 进行 purge 时如果不指定库名，默认 purge 从当前 database 下删除的表；指定库名时暂时仅支持指定的库名为当前 database（权限问题）
use xiaofeng_db2;
create table t1(c1 int);
create index idx on t1(c1);
drop table t1;
create table t1(c2 char);
create index idx on t1(c2);
drop table t1;

### 指定库名时暂时仅支持指定的库名为当前 database（权限问题）
purge index xiaofeng_db1.idx;
ERROR 0A000: purge indexes in recyclebin dropped from other schema not supported
purge table xiaofeng_db1.t1;
ERROR 0A000: purge tables in recyclebin dropped from other schema not supported
purge index xiaofeng_db2.idx;
purge table xiaofeng_db2.t1;
purge table t1;

### 进行 purge 时如果不指定库名，默认 purge 从当前 database 下删除的表
### 对比 purge t1 表前后回收站里 origin name 叫 t1 的最早被删除到回收站的表的 object name，如果相同，则说明在 xiaofeng_db2 下 purge 时清理的都是从 xiaofeng_db2 里被删除到回收站的表
+---+
| 1 |
+---+
| 1 |
+---+
+---+
| 1 |
+---+
| 1 |
+---+
