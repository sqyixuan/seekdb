use hualong;
create table tr1 (c1 int primary key);
create table tr2 (c1 int, c2 int);
create table tr3 (c1 int, c2 varchar(100), key(c1), unique index(c2));
create table tr4 (c1 int primary key, c2 double) partition by key(c1) partitions 3;
create view v3 as select * from tr3;
