drop tenant if exists jx_tenant force;
drop resource pool if exists jx_pool;
drop resource unit if exists jx_unit;
CREATE RESOURCE UNIT jx_unit max_cpu 1, max_memory '2G', max_iops 100000,max_disk_size '10G', max_session_num 64, MIN_CPU=1, MIN_MEMORY= '1G', MIN_IOPS=128;
CREATE RESOURCE POOL jx_pool unit='jx_unit', unit_num=1, zone_list=('zone1');
CREATE TENANT jx_tenant charset='utf8mb4', replica_num=1, zone_list=('zone1'), primary_zone='zone1', resource_pool_list=('jx_pool');
alter tenant jx_tenant set variables ob_tcp_invited_nodes='%';
create user if not exists __oceanbase_inner_drc_user;
grant all privileges on *.* to __oceanbase_inner_drc_user;
drop database if exists jx_db;
create database jx_db;
use jx_db;
create table t1(c1 int, c2 varchar(50));
insert into t1 values(1, 'ant_fin');
drop table t1;
select * from t1;
ERROR 42S02: Table '__recyclebin.t1' doesn't exist
use jx_db;
select * from t1;
c1	c2
1	ant_fin
2	my_ob
3	ob_147
insert into t1 values(4, 'hello');
replace into t1 values(5, 'Have_a_nice_day');
select * from t1;
c1	c2
1	ant_fin
2	my_ob
3	ob_147
4	hello
5	Have_a_nice_day
drop database jx_db;
drop user __oceanbase_inner_drc_user;
drop tenant jx_tenant force;
drop resource pool jx_pool;
drop resource unit jx_unit;
