set @@recyclebin = off;
drop database if exists jx_db;
purge recyclebin;
show recyclebin;
OBJECT_NAME	ORIGINAL_NAME	TYPE	CREATETIME
set the session variable
set @@recyclebin = on;
show session variables like 'recyclebin';
Variable_name	Value
recyclebin	ON
create database jx_db;
use jx_db;
drop database jx_db;
purge recyclebin;
show recyclebin;
OBJECT_NAME	ORIGINAL_NAME	TYPE	CREATETIME
