set @@recyclebin = off;
drop database if exists db1;
drop database if exists db2;
set @@recyclebin = on;
create database db1;
create database db2;
use db1;
create table tr3 (c1 int, c2 varchar(100), c3 int default 10, key(c1), unique i2 (c2));
insert into tr3 (c1, c2) values (1, 'x'), (2, 'xx'), (3, 'xxx');
select * from tr3;
c1	c2	c3
1	x	10
2	xx	10
3	xxx	10
alter table tr3 add index i3 (c3);
alter table tr3 add column c4 varchar(100) default 'abc';
select * from tr3;
c1	c2	c3	c4
1	x	10	abc
2	xx	10	abc
3	xxx	10	abc
show index from tr3;
Table	Non_unique	Key_name	Seq_in_index	Column_name	Collation	Cardinality	Sub_part	Packed	Null	Index_type	Comment	Index_comment	Visible
tr3	1	c1	1	c1	A	NULL	NULL	NULL	YES	BTREE	available		YES
tr3	0	i2	1	c2	A	NULL	NULL	NULL	YES	BTREE	available		YES
tr3	1	i3	1	c3	A	NULL	NULL	NULL	YES	BTREE	unavailable		YES
drop table tr3;
flashback table tr3 to before drop rename to db2.new_tr3;
use db2;
select * from new_tr3;
c1	c2	c3	c4
1	x	10	abc
2	xx	10	abc
3	xxx	10	abc
create index i4 on new_tr3 (c4);
show index from new_tr3;
Table	Non_unique	Key_name	Seq_in_index	Column_name	Collation	Cardinality	Sub_part	Packed	Null	Index_type	Comment	Index_comment	Visible
new_tr3	1	c1	1	c1	A	NULL	NULL	NULL	YES	BTREE	available		YES
new_tr3	0	i2	1	c2	A	NULL	NULL	NULL	YES	BTREE	available		YES
new_tr3	1	i3	1	c3	A	NULL	NULL	NULL	YES	BTREE	unavailable		YES
new_tr3	1	i4	1	c4	A	NULL	NULL	NULL	YES	BTREE	unavailable		YES
drop index i3 on new_tr3;
alter table new_tr3 drop column c3;
select * from new_tr3;
c1	c2	c4
1	x	abc
2	xx	abc
3	xxx	abc
insert into new_tr3 (c1, c2) values(4, 'abc');
update new_tr3 set c2 = 'abcd' where c1 = 1;
delete from new_tr3 where c1 = 3;
select * from new_tr3;
c1	c2	c4
1	abcd	abc
2	xx	abc
4	abc	abc
alter table new_tr3 drop index i2;
rename table new_tr3 to db1.new_new_tr3;
select * from db1.new_new_tr3;
c1	c2	c4
1	abcd	abc
2	xx	abc
4	abc	abc
use db1;
create table table3 like new_new_tr3;
insert into table3 (c1, c2) values(1,'x'), (2, 'xx'), (3, 'xx');
select * from table3;
c1	c2	c4
1	x	abc
2	xx	abc
3	xx	abc
show index from table3;
Table	Non_unique	Key_name	Seq_in_index	Column_name	Collation	Cardinality	Sub_part	Packed	Null	Index_type	Comment	Index_comment	Visible
table3	1	c1	1	c1	A	NULL	NULL	NULL	YES	BTREE	available		YES
table3	1	i4	1	c4	A	NULL	NULL	NULL	YES	BTREE	available		YES
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
truncate table new_new_tr3;
select * from new_new_tr3;
c1	c2	c4
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
drop database db1;
drop database db2;
