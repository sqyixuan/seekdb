set @@recyclebin = off;
drop database if exists db1;
set the session variable
set @@recyclebin = on;
show session variables like 'recyclebin';
Variable_name	Value
recyclebin	ON
create database db1;
use db1;
create table tr3 (c1 int, c2 varchar(100), key(c1), unique index(c2));
create view v3 as select * from tr3;
drop table tr3;
drop view v3;
drop database db1;
flashback database db1 to before drop
flashback table tr3 to before drop
flashback table v3 to before drop
drop table db1.tr3;
drop view db1.v3;
drop database db1;
purge table tr3;
purge table v3;
purge database db1;
