set @@recyclebin = off;
drop database if exists jx_db;
purge recyclebin;
select count(*) from oceanbase.__all_recyclebin;
count(*)
0
set the session variable
set @@recyclebin = on;
show session variables like 'recyclebin';
Variable_name	Value
recyclebin	ON
create database jx_db;
use jx_db;
drop database jx_db;
select count(*) from oceanbase.__all_recyclebin;
count(*)
3001
purge recyclebin;
select count(*) from oceanbase.__all_recyclebin;
count(*)
0
