set @@recyclebin = off;
CREATE RESOURCE UNIT if not exists resource_unit MAX_CPU=1, MAX_MEMORY='1G', MAX_IOPS=100000, MAX_DISK_SIZE='512M', MAX_SESSION_NUM=64;
create resource pool resource_pool
CREATE TENANT if not exists tenant_test RESOURCE_POOL_LIST=('resource_pool') set ob_tcp_invited_nodes='%';
connect(con1, localhost, hualong@tenant_test,,test);
set @@recyclebin = off;
drop database if exists db1;
create user hualong;
grant CREATE, SELECT, INSERT, DELETE, DROP, ALTER, UPDATE, CREATE VIEW, INDEX on *.* to hualong;
create database db1;
create table db1.tr1(c1 int primary key, c2 int, key(c2));
create view db1.v1 as select * from db1.tr1;
set @@recyclebin = on;
drop table db1.tr1;
flashback table $tr1_index_objname to before drop;
ERROR 42501: Access denied; you need (at least one of) the SUPER privilege(s) for this operation
flashback table $tr1_objname to before drop;
ERROR 42501: Access denied; you need (at least one of) the SUPER privilege(s) for this operation
drop database db1;
flashback database hualong
ERROR 42501: Access denied; you need (at least one of) the SUPER privilege(s) for this operation
purge index
ERROR 42501: Access denied; you need (at least one of) the SUPER privilege(s) for this operation
purge table 
ERROR 42501: Access denied; you need (at least one of) the SUPER privilege(s) for this operation
purge database
ERROR 42501: Access denied; you need (at least one of) the SUPER privilege(s) for this operation
set @@recyclebin = off;
drop tenant tenant_test force;
drop resource pool resource_pool;
drop resource unit resource_unit;
