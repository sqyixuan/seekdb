# owner: dachuan.sdc
# owner group: sql2
# description:
#
# test of recyclebin of normal tenant

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

let $count = 5;
let $zone_count = 1;
let $unit_num = 1;

set @@recyclebin = off;

######################################################################
##create tenant
let $zone1 = query_get_value(select zone from oceanbase.dba_ob_zones, zone, 1);
--disable_warnings
eval CREATE RESOURCE UNIT if not exists resource_unit MAX_CPU=1, MEMORY_SIZE='2G';
--echo create resource pool resource_pool
--disable_query_log
eval CREATE RESOURCE POOL if not exists resource_pool UNIT='resource_unit', UNIT_NUM=$unit_num, ZONE_LIST=('$zone1');
--enable_query_log
eval CREATE TENANT if not exists tenant_test RESOURCE_POOL_LIST=('resource_pool') set ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc
--enable_warnings

--echo connect(con1, localhost, hualong@tenant_test,,test);
let $__tenant_name__ = 'tenant_test';
--source mysql_test/include/get_tenant_server.inc

let $tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'tenant_test', tenant_id, 1);

# 如果没有proxy，可能会出错
connect (tenant_test_root,$TE_SERVER_IP, root@tenant_test,,*NO-ONE*,$TE_SERVER_PORT);

set @@recyclebin = off;
--disable_warnings
drop database if exists db_drop;
drop database if exists db_left;
--enable_warnings

######################################################################

--echo set the session variable
set @@recyclebin = on;
select @@recyclebin;

create database db_drop;
create database db_left;
use db_left;

## query database id
connection default;
let $db_drop_id= query_get_value(select database_id from oceanbase.__all_virtual_database where tenant_id = $tenant_id and database_name = 'db_drop', database_id, 1);
let $db_left_id= query_get_value(select database_id from oceanbase.__all_virtual_database where tenant_id = $tenant_id and database_name = 'db_left', database_id, 1);

connection tenant_test_root;
create table tr1_drop (c1 int primary key);
create table tr2_drop (c1 int, c2 int);
create table tr3_drop (c1 int, c2 varchar(100), key(c1), unique index(c2));
create table tr4_drop (c1 int primary key, c2 double) partition by key(c1) partitions 3;
create view v3_drop as select * from tr3_drop;
create outline olt1_drop on select * from tr1_drop;

create table tr1_left (c1 int primary key);
create table tr2_left (c1 int, c2 int);
create table tr3_left (c1 int, c2 varchar(100), key(c1), unique index(c2));
create table tr4_left (c1 int primary key, c2 double) partition by key(c1) partitions 3;
create view v3_left as select * from tr3_left;

use db_drop;
create table tr5_drop (c1 int primary key);
create table tr6_drop (c1 int, c2 int);
create table tr7_drop (c1 int, c2 varchar(100), key(c1), unique index(c2));
create table tr8_drop (c1 int primary key, c2 double) partition by key(c1) partitions 3;
create view v7_drop as select * from tr7_drop;
create outline olt5_drop on select * from tr5_drop;

connection default;
let $tr1_left_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr1_left' and database_id = $db_left_id, table_id, 1);
let $tr2_left_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr2_left' and database_id = $db_left_id, table_id, 1);
let $tr3_left_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr3_left' and database_id = $db_left_id, table_id, 1);
let $tr4_left_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr4_left' and database_id = $db_left_id, table_id, 1);
let $v3_left_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'v3_left' and database_id = $db_left_id, table_id, 1);

let $tr1_drop_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr1_drop' and database_id = $db_left_id, table_id, 1);
let $tr2_drop_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr2_drop' and database_id = $db_left_id, table_id, 1);
let $tr3_drop_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr3_drop' and database_id = $db_left_id, table_id, 1);
let $tr4_drop_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr4_drop' and database_id = $db_left_id, table_id, 1);
let $v3_drop_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'v3_drop' and database_id = $db_left_id, table_id, 1);

connection tenant_test_root;
use db_left;
drop table tr1_drop, tr2_drop, tr3_drop, tr4_drop;
drop view v3_drop;
drop database db_drop;

select TABLE_SCHEMA, TABLE_NAME, COLUMN_NAME from information_schema.COLUMNS;
select TABLE_SCHEMA, TABLE_NAME from information_schema.VIEWS;
select TABLE_SCHEMA, TABLE_NAME from information_schema.TABLES order by table_name;
select CONSTRAINT_SCHEMA, CONSTRAINT_NAME, TABLE_SCHEMA, TABLE_NAME, COLUMN_NAME from information_schema.KEY_COLUMN_USAGE;
select SCHEMA_NAME from information_schema.SCHEMATA;
select TABLE_SCHEMA, TABLE_NAME, PARTITION_NAME from information_schema.PARTITIONS;
select GRANTEE, TABLE_SCHEMA from information_schema.SCHEMA_PRIVILEGES order by grantee, table_schema;
select TABLE_SCHEMA, TABLE_NAME, NON_UNIQUE, INDEX_SCHEMA, INDEX_NAME, COLUMN_NAME from information_schema.STATISTICS;
select CONSTRAINT_SCHEMA, CONSTRAINT_NAME, TABLE_SCHEMA,  TABLE_NAME, CONSTRAINT_TYPE from information_schema.TABLE_CONSTRAINTS;
select GRANTEE, TABLE_CATALOG, TABLE_SCHEMA, TABLE_NAME from information_schema.TABLE_PRIVILEGES;

###################################################################################
##clear
connection default;
drop tenant tenant_test force;
drop resource pool resource_pool;
drop resource unit resource_unit;

