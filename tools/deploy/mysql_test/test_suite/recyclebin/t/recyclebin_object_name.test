# description:
#
# test of recyclebin object


--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop database if exists jx_db;
--enable_warnings

--echo set the session variable
set @@recyclebin = on;
show session variables like 'recyclebin';

create database jx_db;
use jx_db;

#集群ID和租户ID，不修改情况下，都是1
connect (jx_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection jx_obsys;
let $clusterID = query_get_value(show parameters like 'cluster_id', value, 1);
let $tenantID = query_get_value(select exec_tenant_id from oceanbase.__all_virtual_ddl_operation where ddl_stmt_str != '' order by schema_version desc limit 1, exec_tenant_id, 1);
let $schemaVersion = query_get_value(select schema_version from oceanbase.__all_virtual_ddl_operation where ddl_stmt_str != '' order by schema_version desc limit 1, schema_version, 1);


connection default;
# 验证drop table 
create table t1(c1 int primary key, c2 int, c3 int, index idx1(c2), index idx2(c2, c3));
CREATE INDEX test_index on t1(c2, c3);
drop table t1;
connection jx_obsys;
--disable_query_log
eval select 1 from oceanbase.__all_virtual_recyclebin where object_name in (select concat("__recycle_\$_", $clusterID, "_", $tenantID, "_", schema_version) from oceanbase.__all_virtual_ddl_operation where ddl_stmt_str != '' order by schema_version desc limit 1) order by gmt_create desc limit 1; 
--enable_query_log

--disable_query_log
let $recycle_object_name = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin order by gmt_create desc limit 1, object_name, 1);
connection default;
eval flashback table $recycle_object_name to before drop;
connection jx_obsys;
--enable_query_log
select a.table_name from oceanbase.__all_virtual_table a left join oceanbase.__all_virtual_ddl_operation b on a.table_id = b.table_id where b.ddl_stmt_str != '' order by b.schema_version desc limit 1;
connection default;
--replace_regex /unavailable/available/
show index from t1;

# 验证drop index
#drop index idx1 on t1;
#eval select 1 from oceanbase.__all_virtual_recyclebin where object_name in (select concat("__recycle_\$_", $clusterID, "_", $tenantID, "_", schema_version) from oceanbase.__all_virtual_ddl_operation where ddl_stmt_str != '' order by schema_version desc limit 1) order by gmt_create desc limit 1; 
#--disable_query_log
#let $recycle_object_name = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin order by gmt_create desc limit 1, object_name, 1);
#eval flashback index $recycle_object_name to before drop;
#--enable_query_log
#select a.table_name from oceanbase.__all_virtual_table a left join oceanbase.__all_virtual_ddl_operation b on a.table_id = b.table_id where b.ddl_stmt_str != '' order by b.schema_version desc limit 1;
#show index from t1;

#alter table t1 drop index idx2;
#eval select 1 from oceanbase.__all_virtual_recyclebin where object_name in (select concat("__recycle_\$_", $clusterID, "_", $tenantID, "_", schema_version) from oceanbase.__all_virtual_ddl_operation where ddl_stmt_str != '' order by schema_version desc limit 1) order by gmt_create desc limit 1; 
#--disable_query_log
#let $recycle_object_name = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin order by gmt_create desc limit 1, object_name, 1);
#eval flashback index $recycle_object_name to before drop;
#--enable_query_log
#select a.table_name from oceanbase.__all_virtual_table a left join oceanbase.__all_virtual_ddl_operation b on a.table_id = b.table_id where b.ddl_stmt_str != '' order by b.schema_version desc limit 1;
#show index from t1;

# 验证drop view
create table t2(c1 int primary key, c2 int, c3 int, index(c2), index(c2, c3));
create view v2 as select * from t2;
drop view v2;
connection jx_obsys;
--disable_query_log
eval select 1 from oceanbase.__all_virtual_recyclebin where object_name in (select concat("__recycle_\$_", $clusterID, "_", $tenantID, "_", schema_version) from oceanbase.__all_virtual_ddl_operation where ddl_stmt_str != '' order by schema_version desc limit 1) order by gmt_create desc limit 1; 
--enable_query_log

--disable_query_log
let $recycle_object_name = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin order by gmt_create desc limit 1, object_name, 1);
connection default;
#echo $recycle_object_name;
eval flashback table $recycle_object_name to before drop;
connection jx_obsys;
--enable_query_log
select a.table_name from oceanbase.__all_virtual_table a left join oceanbase.__all_virtual_ddl_operation b on a.table_id = b.table_id where b.ddl_stmt_str != '' order by b.schema_version desc limit 1;
connection default;


# 验证drop view
drop database jx_db;
connection jx_obsys;
--disable_query_log
eval select 1 from oceanbase.__all_virtual_recyclebin where object_name in (select concat("__recycle_\$_", $clusterID, "_", $tenantID, "_", schema_version) from oceanbase.__all_virtual_ddl_operation where ddl_stmt_str != '' order by schema_version desc limit 1) order by gmt_create desc limit 1; 
--enable_query_log
--disable_query_log
let $recycle_object_name = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin order by gmt_create desc limit 1, object_name, 1);
connection default;
eval flashback database $recycle_object_name to before drop;
connection jx_obsys;
--enable_query_log
select a.database_name from oceanbase.__all_virtual_database a left join oceanbase.__all_virtual_ddl_operation b on a.database_id = b.database_id where b.ddl_stmt_str != '' order by b.schema_version desc limit 1;
connection default;
use jx_db;
--sleep 2
show tables;

set @@recyclebin = on;
drop database jx_db;


## 验证指定ddl_id来创建回收站对象名
connection default;
purge recyclebin;

connection jx_obsys;
delete from oceanbase.__all_ddl_id;
eval alter system change tenant $TENANT;
delete from oceanbase.__all_ddl_id;
alter system change tenant sys;

--source mysql_test/include/check_schema_sync.inc
connection default;

--disable_warnings
drop database if exists jx_drc;
