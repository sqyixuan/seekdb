connection default;

# 验证全局索引进回收站
set @__oceanbase_ddl_id = '1_1_123456830';
create table jx_t1(a int, b int, c int, d int, e int, primary key(a,b,c,d), index (b), index idx2(c)) partition by hash(b) partitions 2;
set @__oceanbase_ddl_id = '1_1_123456831';
create index gkey on jx_t1(b,c,d) global partition by hash(b) partitions 5;
--source mysql_test/include/check_all_idx_ok.inc
set @__oceanbase_ddl_id = '1_1_123456832';
drop table jx_t1;
connection jx_obsys;
#eval select object_name from oceanbase.__all_virtual_recyclebin where object_name = '__recycle_\$1_1_123456832';
--disable_query_log
let $recycle_object_name = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where ORIGINAL_NAME = 'jx_t1' order by gmt_create desc limit 1, object_name, 1);
#echo $recycle_object_name;
connection default;
set @__oceanbase_ddl_id = '1_1_123456833';
eval flashback table $recycle_object_name to before drop;
--enable_query_log
connection jx_obsys;
select a.table_name from oceanbase.__all_virtual_table a left join oceanbase.__all_virtual_ddl_operation b on a.table_id = b.table_id where b.ddl_stmt_str != '' order by b.schema_version desc limit 1;
connection default;
--replace_regex /unavailable/available/
show index from jx_t1;


# 验证drop database
