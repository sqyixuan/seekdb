# owner: dachuan.sdc
# owner group: sql2
# description:
#
# test of recyclebin

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop database if exists hualong;
drop database if exists hualong_2;
drop database if exists hualong_3;
drop database if exists hualong_4;
drop database if exists hualong_5;
drop database if exists hualong_6;
drop database if exists new_hualong_6;
drop database if exists recyclebin;
drop tablegroup if exists recyclebin_tg1;
drop tablegroup if exists recyclebin_tg2;
drop tablegroup if exists recyclebin_tg3;
set @@session.ob_query_timeout = 100000000;
purge recyclebin;
--enable_warnings

--echo set the session variable

set @@recyclebin = on;
show variables like 'recyclebin';
show session variables like 'recyclebin';
select @@recyclebin;


create database hualong;
create database hualong_2;
use hualong;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $database_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'hualong', database_id, 1);
let $database_id_2 = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'hualong_2', database_id, 1);
disconnect obsys;
connection default;
create table tr1 (c1 int primary key);
create table tr2 (c1 int, c2 int);
create table tr3 (c1 int, c2 varchar(100), key(c1), unique index(c2));
create table tr4 (c1 int primary key, c2 double) partition by key(c1) partitions 3;
create view v3 as select * from tr3;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr1' and database_id = $database_id, table_id, 1);
let $tr2_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr2' and database_id = $database_id, table_id, 1);
let $tr3_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr3' and database_id = $database_id, table_id, 1);
let $tr4_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr4' and database_id = $database_id, table_id, 1);
let $v3_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'v3' and database_id = $database_id, table_id, 1);
disconnect obsys;
connection default;

insert into tr1 values (1), (2), (3);
insert into tr2 values (1,1), (2,2), (3,3);
insert into tr3 values (1, 'x'), (2, 'xx'), (3, 'xxx');
insert into tr4 values (1, 1.1);
insert into tr4 values (2, 2.2);
insert into tr4 values (3, 3.3);


select * from tr1;
select * from tr2;
select * from tr3;
select * from tr4;

##query from __all_recyclebin;
let $start_time = query_get_value(select now(), now(), 1);
drop table tr1;
drop table tr2, tr3;
--error ER_BAD_TABLE_ERROR
drop table tr4, xxx;
drop table tr4;
drop view v3;
--error ER_BAD_TABLE_ERROR
drop table xxx;
--echo query from DBA_RECYCLEBIN
desc oceanbase.DBA_RECYCLEBIN;
--disable_query_log
--echo select original_name, type from oceanbase.__all_virtual_recyclebin where database in 'hualong'
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
eval select original_name, type from oceanbase.__all_virtual_recyclebin where database_id = $database_id and type != 2;
disconnect obsys;
connection default;
--enable_query_log

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr1_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr1_id, object_name, 1);
let $tr2_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr2_id, object_name, 1);
let $tr3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr3_id, object_name, 1);
let $tr4_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr4_id, object_name, 1);
let $v3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $v3_id, object_name, 1);
disconnect obsys;
connection default;

sleep 1;
show tables from hualong;
--echo flashback table tr1
--disable_query_log
eval flashback table $tr1_objname to before drop;
--enable_query_log
select * from tr1;

--echo flashback table tr3
--disable_query_log
eval flashback table $tr2_objname to before drop;
--enable_query_log
select * from tr2;

--echo flashback table tr3
--disable_query_log
eval flashback table $tr3_objname to before drop;
--enable_query_log
select * from tr3;
show index from tr3;

--echo flashback table tr4
--disable_query_log
eval flashback table $tr4_objname to before drop;
--enable_query_log
select * from tr4;

--echo flashback table v3
--disable_query_log
eval flashback table $v3_objname to before drop;
--enable_query_log
select * from v3;
sleep 1;
show tables from hualong;

##flashback and reanme
--echo flashback table and rename
drop table tr1, tr2, tr3, tr4;
drop view v3;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr1_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr1_id, object_name, 1);
let $tr2_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr2_id, object_name, 1);
let $tr3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr3_id, object_name, 1);
let $tr4_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr4_id, object_name, 1);
let $v3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $v3_id, object_name, 1);
disconnect obsys;
connection default;

--disable_query_log
--echo flashback table tr1 to before drop rename to hualong.__tr1
eval flashback table $tr1_objname to before drop rename to hualong.__tr1;

--echo flashback table tr2 to before drop rename to hualong.__tr2
eval flashback table $tr2_objname to before drop rename to __tr2;

--echo flashback table tr4 to before drop rename to hualong.__tr4
eval flashback table $tr4_objname to before drop rename to hualong.__tr4;

--echo flashback table v3 to before drop rename to hualong.__v3
eval flashback table $v3_objname to before drop rename to __v3;
--enable_query_log

sleep 1;
show tables from hualong;

drop database hualong;
show databases like 'hualong%';

--disable_query_log
--echo select original_name, type from oceanbase.DBA_RECYCLEBIN where type != 'NORMAL INDEX'
eval select original_name, type from oceanbase.DBA_RECYCLEBIN where type != 'NORMAL INDEX' and (original_name like 'tr3%' or original_name like 'hualong%');
--enable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $hualong_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where database_id = $database_id and type = 4, object_name, 1);
disconnect obsys;
connection default;

--echo flashback database hualong to before drop
--echo flashback table tr3 to before drop rename to hualong.__tr3
--disable_query_log
eval flashback database $hualong_objname to before drop;
eval flashback table hualong.$tr3_objname to before drop rename to hualong.__tr3;
--enable_query_log
sleep 1;
show index from hualong.__tr3;
show tables from hualong;

show databases like 'hualong%';
use hualong;
drop table __tr1;
drop table __tr2;
drop table __tr3;
drop table __tr4;
drop view __v3;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr1_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr1_id, object_name, 1);
let $tr2_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr2_id, object_name, 1);
let $tr3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr3_id, object_name, 1);
let $tr4_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr4_id, object_name, 1);
let $v3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $v3_id, object_name, 1);
disconnect obsys;
connection default;

--disable_query_log
--echo flashback table tr1 to before drop rename to hualong_2.tr1
eval flashback table $tr1_objname to before drop rename to hualong_2.tr1;
--echo flashback table tr2 to before drop rename to hualong_2.tr2
eval flashback table $tr2_objname to before drop rename to hualong_2.tr2;
--echo flashback table tr3 to before drop rename to hualong_2.tr3
eval flashback table $tr3_objname to before drop rename to hualong_2.tr3;
--echo flashback table tr4 to before drop rename to hualong_2.tr4
eval flashback table $tr4_objname to before drop rename to hualong_2.tr4;
--echo flashback table v3 to before drop rename to hualong_2.v3
eval flashback table $v3_objname to before drop rename to hualong_2.v3;
--enable_query_log

sleep 1;
show tables from hualong;
show tables from hualong_2;

--disable_query_log
--echo select original_name, type, tenant_id from oceanbase.__all_virtual_recyclebin in 'hualong2'
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
eval select original_name, type, tenant_id  from oceanbase.__all_virtual_recyclebin where database_id=$database_id_2;
disconnect obsys;
connection default;
--enable_query_log

select * from hualong_2.tr1;
select * from hualong_2.tr2;
select * from hualong_2.tr3;
sleep 1;
select /*+read_consistency(weak)*/ * from hualong_2.tr4;
--error 1356
select * from hualong_2.v3;

drop table hualong_2.tr1;
drop table hualong_2.tr2;
drop table hualong_2.tr3;
drop table hualong_2.tr4;
drop view hualong_2.v3;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr1_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr1_id, object_name, 1);
let $tr2_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr2_id, object_name, 1);
let $tr3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr3_id, object_name, 1);
let $tr4_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr4_id, object_name, 1);
let $v3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $v3_id, object_name, 1);
disconnect obsys;
connection default;

--disable_query_log
--echo purge table hualong_2.tr1
--error 5270
eval purge table $tr1_objname;
--echo purge table hualong_2.tr2
--error 5270
eval purge table $tr2_objname;
--echo purge table hualong_2.tr3
--error 5270
eval purge table $tr3_objname;
--echo purge table hualong_2.tr4
--error 5270
eval purge table $tr4_objname;
--echo purge table hualong_2.v3
--error 5270
eval purge table $v3_objname;
--enable_query_log

--disable_query_log
use hualong_2;
--echo purge table hualong_2.tr1
eval purge table $tr1_objname;
--echo purge table hualong_2.tr2
eval purge table $tr2_objname;
--echo purge table hualong_2.tr3
eval purge table $tr3_objname;
--echo purge table hualong_2.tr4
eval purge table $tr4_objname;
--echo purge table hualong_2.v3
eval purge table $v3_objname;
--enable_query_log

--echo recycle_bin should no longer exist any recycle object 
--disable_query_log
--echo select original_name, type, tenant_id from oceanbase.__all_virtual_recyclebin where database in 'hualong2'
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
eval select original_name, type, tenant_id from oceanbase.__all_virtual_recyclebin where database_id = $database_id_2;
disconnect obsys;
connection default;
--enable_query_log

##drop database with tablegroup

create database hualong_3;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $database_id_3 = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'hualong_3', database_id, 1);
disconnect obsys;
connection default;
create tablegroup recyclebin_tg1;
create tablegroup recyclebin_tg2;
create table hualong_3.tt (c1 int primary key, c2 int, key(c2));
create table hualong_3.tt2 (c1 int primary key, c2 int, key(c2));
# 原来primary_zone=''表示随机选择zone作为primary，现在改为RANDOM
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter tenant sys set primary_zone='RANDOM';
disconnect obsys;
connection default;
alter tablegroup recyclebin_tg1 add table hualong_3.tt;
alter tablegroup recyclebin_tg2 add table hualong_3.tt2;

drop database hualong_3;
### drop tablegroup should not affected by the table tt, which has been dropped
# drop tablegroup recyclebin_tg1;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $hualong_3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where database_id = $database_id_3 and type = 4, object_name, 1);
disconnect obsys;
connection default;
--disable_query_log
--echo flashback database hualong_3 to before drop
eval flashback database $hualong_3_objname to before drop;
--enable_query_log
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table hualong_3.tt;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table hualong_3.tt2;

## drop database with tablegroup
create database hualong_4;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $database_id_4 = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'hualong_4', database_id, 1);
disconnect obsys;
connection default;
create tablegroup recyclebin_tg3;
alter database hualong_4 default tablegroup = recyclebin_tg3;
drop database hualong_4;
drop tablegroup recyclebin_tg3;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $hualong_4_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where database_id = $database_id_4 and type = 4, object_name, 1);
disconnect obsys;
connection default;
--disable_query_log
--echo flashback database hualong_4 to before drop
eval flashback database $hualong_4_objname to before drop; 
--enable_query_log
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database hualong_4;

##flashback table exist
create database hualong_5;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $database_id_5 = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'hualong_5', database_id, 1);
disconnect obsys;
connection default;
create table hualong_5.tt (c1 int);
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tt_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tt' and database_id = $database_id_5, table_id, 1);
disconnect obsys;
connection default;
drop table hualong_5.tt;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tt_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tt_id, object_name, 1);
disconnect obsys;
connection default;

create table hualong_5.tt (c1 int);
--echo flashback table tt to before drop
--disable_query_log
--error  ER_TABLE_EXISTS_ERROR
eval flashback table hualong_5.$tt_objname to before drop;
--echo flashback table tt to before drop rename to ttt;
eval flashback table hualong_5.$tt_objname to before drop rename to ttt;
--enable_query_log


###create database with inner id
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set enable_sys_table_ddl = true;
disconnect obsys;
connection default;
set @@recyclebin = off;
--disable_warnings
drop database if exists inner_db;
--enable_warnings
set @@recyclebin = on;
select count(*) from oceanbase.DBA_RECYCLEBIN where ORIGINAL_NAME = 'inner_db';
create database inner_db database_id = 201500;
drop database inner_db;
select count(*) from oceanbase.DBA_RECYCLEBIN where ORIGINAL_NAME = 'inner_db';
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set enable_sys_table_ddl = false;
disconnect obsys;
connection default;

--disable_warnings
drop database if exists recyclebin;
drop table if exists recyclebin;
--enable_warnings
create database recyclebin;
create table recyclebin.recyclebin (recyclebin int);

##flashback database rename to new name
create database hualong_6;
use hualong_6;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $database_id_6 = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'hualong_6', database_id, 1);
disconnect obsys;
connection default;
create table aaa (c1 int primary key, c2 int, index i1(c1), unique i2(c2));
create table bbb (c1 int primary key, c2 int, index i1(c1), unique i2(c2));
create view va as select c1 from aaa;
create view vb as select c2 from bbb;
drop table aaa;
drop view vb;
drop database hualong_6;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $hualong_6_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where database_id = $database_id_6 and type = 4, object_name, 1);
disconnect obsys;
connection default;
--disable_query_log
--echo falshback database hualong_6 to before drop rename to new_hualong_6
eval flashback database $hualong_6_objname to before drop rename to new_hualong_6;
--enable_query_log
show tables from new_hualong_6;

###############################################################################
#clear
set @@recyclebin = off;
show session variables like 'recyclebin';
drop database hualong;
drop database hualong_2;
drop database hualong_3;
drop database hualong_4;
drop database hualong_5;
drop database new_hualong_6;
drop database recyclebin;
drop tablegroup recyclebin_tg2;
set @@session.ob_query_timeout = 100000000;
purge recyclebin;

