# owner group: sql2
# description:
#
# test of recyclebin

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists hualong_db;
--enable_warnings

create database hualong_db;
create table hualong_db.plan_table(a int);
#can hit plan cache if plan_cache's version not change
insert into hualong_db.plan_table values(1);

select * from hualong_db.plan_table;

drop database if exists hualong_db;
