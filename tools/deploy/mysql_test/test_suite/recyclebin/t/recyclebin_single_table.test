# owner: dachuan.sdc
# owner group: sql2
# description:
#
# test of recyclebin

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop database if exists db1;
drop database if exists db2;
--enable_warnings


set @@recyclebin = on;

create database db1;
create database db2;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $database_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db1', database_id, 1);
let $database_id_2 = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db2', database_id, 1);
disconnect obsys;
connection default;
use db1;

create table tr3 (c1 int, c2 varchar(100), c3 int default 10, key(c1), unique i2 (c2));
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr3_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr3' and database_id = $database_id, table_id, 1);
disconnect obsys;
connection default;

insert into tr3 (c1, c2) values (1, 'x'), (2, 'xx'), (3, 'xxx');

select * from tr3;

alter table tr3 add index i3 (c3);

alter table tr3 add column c4 varchar(100) default 'abc';

select * from tr3;

--source mysql_test/include/check_all_idx_ok.inc
show index from tr3;

drop table tr3;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr3_id, object_name, 1);
disconnect obsys;
connection default;

--disable_query_log
--echo flashback table tr3 to before drop rename to db2.new_tr3;
eval flashback table $tr3_objname to before drop rename to db2.new_tr3;
--enable_query_log

use db2;

select * from new_tr3;

create index i4 on new_tr3 (c4);

--source mysql_test/include/check_all_idx_ok.inc
show index from new_tr3;

drop index i3 on new_tr3;

alter table new_tr3 drop column c3;

select * from new_tr3;

insert into new_tr3 (c1, c2) values(4, 'abc');

update new_tr3 set c2 = 'abcd' where c1 = 1;

delete from new_tr3 where c1 = 3;

select * from new_tr3;

alter table new_tr3 drop index i2;

rename table new_tr3 to db1.new_new_tr3;

select * from db1.new_new_tr3;

use db1;

create table table3 like new_new_tr3;
insert into table3 (c1, c2) values(1,'x'), (2, 'xx'), (3, 'xx');
select * from table3;
show index from table3;

--source mysql_test/include/check_all_idx_ok.inc

truncate table new_new_tr3;
select * from new_new_tr3;

--source mysql_test/include/check_all_idx_ok.inc

drop database db1;
drop database db2;
