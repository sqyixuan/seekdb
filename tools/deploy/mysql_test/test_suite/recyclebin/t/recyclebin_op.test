# owner: dachuan.sdc
# owner group: sql2
# description:
#
# test of recyclebin

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop database if exists db1;
--enable_warnings

--echo set the session variable

set @@recyclebin = on;
show session variables like 'recyclebin';

create database db1;
use db1;

create table tr3 (c1 int, c2 varchar(100), key(c1), unique index(c2));
create view v3 as select * from tr3;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $db1_id= query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db1', database_id, 1);
let $tr3_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr3' and database_id = $db1_id, table_id, 1);
let $v3_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'v3' and database_id = $db1_id, table_id, 1);
disconnect obsys;
connection default;

drop table tr3;
drop view v3;
drop database db1;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr3_id, object_name, 1);
let $v3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $v3_id, object_name, 1);
let $db1_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where database_id = $db1_id and type = 4, object_name, 1);
disconnect obsys;
connection default;

--disable_query_log
--echo flashback database db1 to before drop
eval flashback database $db1_objname to before drop;
--echo flashback table tr3 to before drop
eval flashback table db1.$tr3_objname to before drop;
--echo flashback table v3 to before drop
eval flashback table db1.$v3_objname to before drop;
--enable_query_log

drop table db1.tr3;
drop view db1.v3;
drop database db1;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr3_id, object_name, 1);
let $v3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $v3_id, object_name, 1);
let $db1_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where database_id = $db1_id and type = 4, object_name, 1);
disconnect obsys;
connection default;


--disable_query_log
--echo purge table tr3;
--error 1046
eval purge table $tr3_objname;
--echo purge table v3;
--error 1046
eval purge table $v3_objname;
--echo purge database db1;
eval purge database $db1_objname;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--echo select operation_type from oceanbase.__all_virtual_ddl_operation where database = 'db1' order by schema_version;
eval select operation_type from oceanbase.__all_virtual_ddl_operation where tenant_id =1 and (database_id = $db1_id or table_id >= $tr3_id ) order by schema_version;
disconnect obsys;
connection default;

##test flashback database's op type
--disable_warnings
drop database if exists hualong_db;
--enable_warnings
create database hualong_db;
use hualong_db;
create table ft_1(c1 int, c2 int);
create table ft_2(c1 int primary key, c2 int);
create table ft_3(c1 int primary key, c2 int , c3 varchar(11), index idx(c1), unique(c1, c2));
# create table ft_4(c1 int primary key, c2 int, c3 varchar(11), index i1(c3) local) partition by key(c1) partitions 5;
# 目前不支持不同分区方式的table放到同一个tablegroup中
create table ft_4(c1 int primary key, c2 int, c3 varchar(11), index i1(c3) local);
create tablegroup recyclebin_op_tg1;
alter tablegroup recyclebin_op_tg1 add table ft_1, ft_2, ft_3, ft_4;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $hualong_db_id= query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'hualong_db', database_id, 1);
disconnect obsys;
connection default;
drop database hualong_db;
# 如果tablegoup下面有schema，目前不允许删除tablegroup
# drop tablegroup recyclebin_op_tg1;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $hualong_db_objname= query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where database_id = $hualong_db_id and type = 4, object_name, 1);
disconnect obsys;
connection default;
--echo flashback database hualong_db to before drop
--disable_query_log
eval flashback database $hualong_db_objname to before drop;
--enable_query_log
## 202 create database
## 204 drop database
## 206 drop database to recyclebin
## 207 flashback database
## 4 create table
## 20 create index
## 25 drop table to recyclebin
## 2 drop table
## 18 drop index
## 27 flashback table
## 22 alter tablegroup add table
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--echo select operation_type from oceanbase.__all_virtual_ddl_operation where database_name = 'hualong_db';
--disable_query_log
eval select operation_type from oceanbase.__all_virtual_ddl_operation where database_id = $hualong_db_id;
disconnect obsys;
connection default;
--enable_query_log

--enable_query_log
set @@recyclebin = off;
drop database hualong_db;
