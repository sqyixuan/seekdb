# owner: dachuan.sdc
# owner group: sql2
# description:
#
# test of recyclebin of normal tenant

--disable_abort_on_error
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

let $count = 5;
let $zone_count = 1;
let $unit_num = 1;

set @@recyclebin = off;

######################################################################
##create tenant
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $zone1 = query_get_value(select zone from oceanbase.dba_ob_zones, zone, 1);
--disable_warnings
--disable_query_log
#drop tenant if exists tenant_test force;
#drop resource pool if exists resource_pool;
#eval CREATE RESOURCE UNIT if not exists resource_unit MAX_CPU=1, MEMORY_SIZE='2G';
#--echo create resource pool resource_pool
--disable_query_log
#eval CREATE RESOURCE POOL if not exists resource_pool UNIT='resource_unit', UNIT_NUM=$unit_num, ZONE_LIST=('$zone1');
--enable_query_log
#eval CREATE TENANT if not exists tenant_test RESOURCE_POOL_LIST=('resource_pool') set ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc
--enable_warnings
disconnect obsys;
connection default;

--echo connect(con1, localhost, hualong,,test);
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);
disconnect obsys;
connection default;

connect (tenant_test_root,$TE_SERVER_IP, root,,*NO-ONE*,$TE_SERVER_PORT);

set @@recyclebin = off;
--disable_warnings
drop database if exists hualong;
drop database if exists hualong_2;
--enable_warnings

######################################################################

--echo set the session variable
set @@recyclebin = on;
show variables like 'recyclebin';
show session variables like 'recyclebin';
show global variables like 'recyclebin';
select @@global.`recyclebin`;
select @@recyclebin;

let $start_time = query_get_value(select now(), now(), 1);

create database hualong;
create database hualong_2;
use hualong;

## query database id
connection default;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $database_id = query_get_value(select database_id from oceanbase.__all_virtual_database where tenant_id = $tenant_id and database_name = 'hualong', database_id, 1);
let $database_id_2 = query_get_value(select database_id from oceanbase.__all_virtual_database where tenant_id = $tenant_id and database_name = 'hualong_2', database_id, 1);
disconnect obsys;
connection default;

connection tenant_test_root;
create table tr1 (c1 int primary key);
create table tr2 (c1 int, c2 int);
create table tr3 (c1 int, c2 varchar(100), key(c1), unique index(c2));
create table tr4 (c1 int primary key, c2 double) partition by key(c1) partitions 3;
create view v3 as select * from tr3;

connection default;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr1' and database_id = $database_id, table_id, 1);
let $tr2_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr2' and database_id = $database_id, table_id, 1);
let $tr3_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr3' and database_id = $database_id, table_id, 1);
let $tr4_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr4' and database_id = $database_id, table_id, 1);
let $v3_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'v3' and database_id = $database_id, table_id, 1);
disconnect obsys;
connection default;

connection tenant_test_root;
insert into tr1 values (1), (2), (3);
insert into tr2 values (1,1), (2,2), (3,3);
insert into tr3 values (1, 'x'), (2, 'xx'), (3, 'xxx');
insert into tr4 values (1, 1.1);
insert into tr4 values (2, 2.2);
insert into tr4 values (3, 3.3);


select * from tr1;
select * from tr2;
select * from tr3;
select * from tr4 where c1 =1;

##query from __all_recyclebin;
drop table tr1;
drop table tr2, tr3;
--error ER_BAD_TABLE_ERROR
drop table tr4, xxx;
drop table tr4;
drop view v3;
--error ER_BAD_TABLE_ERROR
drop table xxx;
--echo query from DBA_RECYCLEBIN
desc oceanbase.DBA_RECYCLEBIN;

connection default;
--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--echo select original_name, type from oceanbase.__all_virtual_recyclebin where database in 'hualong'
eval select original_name, type from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and database_id = $database_id and type != 2;
disconnect obsys;
connection default;
--enable_query_log

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr1_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr1_id, object_name, 1);
let $tr2_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr2_id, object_name, 1);
let $tr3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr3_id, object_name, 1);
let $tr4_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr4_id, object_name, 1);
let $v3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $v3_id, object_name, 1);
disconnect obsys;
connection default;

connection tenant_test_root;
show tables from hualong;
--echo flashback table tr1
--disable_query_log
eval flashback table $tr1_objname to before drop;
--enable_query_log
select * from tr1;

--echo flashback table tr3
--disable_query_log
eval flashback table $tr2_objname to before drop;
--enable_query_log
select * from tr2;

--echo flashback table tr3
--disable_query_log
eval flashback table $tr3_objname to before drop;
--enable_query_log
select * from tr3;
show index from tr3;

--echo flashback table tr4
--disable_query_log
eval flashback table $tr4_objname to before drop;
--enable_query_log
select * from tr4 where c1 = 1;

--echo flashback table v3
--disable_query_log
eval flashback table $v3_objname to before drop;
--enable_query_log
select * from v3;
show tables from hualong;

##flashback and reanme
--echo flashback table and rename
drop table tr1, tr2, tr3, tr4;
drop view v3;

connection default;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr1_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr1_id, object_name, 1);
let $tr2_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr2_id, object_name, 1);
let $tr4_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr4_id, object_name, 1);
let $v3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $v3_id, object_name, 1);
disconnect obsys;
connection default;
connection tenant_test_root;

--disable_query_log
--echo flashback table tr1 to before drop rename to hualong.__tr1
eval flashback table $tr1_objname to before drop rename to hualong.__tr1;

--echo flashback table tr2 to before drop rename to hualong.__tr2
eval flashback table $tr2_objname to before drop rename to __tr2;

--echo flashback table tr4 to before drop rename to hualong.__tr4
eval flashback table $tr4_objname to before drop rename to hualong.__tr4;

--echo flashback table v3 to before drop rename to hualong.__v3
eval flashback table $v3_objname to before drop rename to __v3;
--enable_query_log

sleep 1;
show tables from hualong;

drop database hualong;
show databases like '__recycle%';
show databases status like '__recycle%';
--disable_result_log
show recyclebin;
--enable_result_log

--disable_query_log
--echo select original_name, type from oceanbase.DBA_RECYCLEBIN where type != 'NORMAL INDEX'
eval select original_name, type from oceanbase.DBA_RECYCLEBIN where type != 'NORMAL INDEX';
--enable_query_log

connection default;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $hualong_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and database_id = $database_id and type = 4, object_name, 1);
disconnect obsys;
connection default;

connection default;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr3_id, object_name, 1);
disconnect obsys;
connection default;

connection tenant_test_root;
--echo flashback database hualong to before drop
--echo flashback table tr3 to before drop rename to hualong.__tr3
--disable_query_log
eval flashback database $hualong_objname to before drop;
eval flashback table hualong.$tr3_objname to before drop rename to hualong.__tr3;

--enable_query_log
sleep 1;
show tables from hualong;

#show databases;
show databases status like 'hualong%';
use hualong;
drop table __tr1;
drop table __tr2;
drop table __tr3;
drop table __tr4;
drop view __v3;

connection default;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr1_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr1_id, object_name, 1);
let $tr2_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr2_id, object_name, 1);
let $tr3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr3_id, object_name, 1);
let $tr4_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr4_id, object_name, 1);
let $v3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $v3_id, object_name, 1);
disconnect obsys;
connection default;

connection tenant_test_root;

--disable_query_log
--echo flashback table tr1 to before drop rename to hualong_2.tr1
eval flashback table $tr1_objname to before drop rename to hualong_2.tr1;
--echo flashback table tr2 to before drop rename to hualong_2.tr2
eval flashback table $tr2_objname to before drop rename to hualong_2.tr2;
--echo flashback table tr3 to before drop rename to hualong_2.tr3
eval flashback table $tr3_objname to before drop rename to hualong_2.tr3;
--echo flashback table tr4 to before drop rename to hualong_2.tr4
eval flashback table $tr4_objname to before drop rename to hualong_2.tr4;
--echo flashback table v3 to before drop rename to hualong_2.v3
eval flashback table $v3_objname to before drop rename to hualong_2.v3;
--enable_query_log

sleep 1;
show tables from hualong;
show tables from hualong_2;

connection default;
--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--echo select original_name, type, tenant_id from oceanbase.__all_virtual_recyclebin in 'hualong2'
eval select original_name, type, tenant_id  from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and database_id=$database_id_2;
disconnect obsys;
connection default;
--enable_query_log

connection tenant_test_root;
drop table hualong_2.tr1;
drop table hualong_2.tr2;
drop table hualong_2.tr3;
drop table hualong_2.tr4;
drop view hualong_2.v3;

connection default;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tr1_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr1_id, object_name, 1);
let $tr2_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr2_id, object_name, 1);
let $tr3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr3_id, object_name, 1);
let $tr4_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $tr4_id, object_name, 1);
let $v3_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $tenant_id and table_id = $v3_id, object_name, 1);
disconnect obsys;
connection default;

connection tenant_test_root;
--disable_result_log
show recyclebin;
select * from oceanbase.DBA_RECYCLEBIN;
--enable_result_log

use hualong_2;
--disable_query_log
--echo purge table hualong_2.tr1
eval purge table $tr1_objname;
--echo purge table hualong_2.tr2
eval purge table $tr2_objname;
--echo purge table hualong_2.tr3
eval purge table $tr3_objname;
--echo purge table hualong_2.tr4
eval purge table $tr4_objname;
--echo purge table hualong_2.v3
eval purge table $v3_objname;
--enable_query_log



connection default;
--echo recycle_bin should no longer exist any recycle object 
--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--echo select original_name, type, tenant_id from oceanbase.__all_virtual_recyclebin where database in 'hualong2'
eval select original_name, type, tenant_id from oceanbase.__all_virtual_recyclebin where database_id = $database_id_2;
disconnect obsys;
connection default;
--enable_query_log


connection tenant_test_root;
select ORIGINAL_NAME, TYPE from oceanbase.DBA_RECYCLEBIN;
drop database hualong;
drop database hualong_2;

###create database with inner id
connection default;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set enable_sys_table_ddl = true;
disconnect obsys;
connection default;

connection tenant_test_root;
set @@recyclebin = off;
--disable_warnings
drop database if exists inner_db;
--enable_warnings
set @@recyclebin = on;
select count(*) from oceanbase.DBA_RECYCLEBIN where ORIGINAL_NAME = 'inner_db';
create database inner_db database_id = 201500;
drop database inner_db;
select count(*) from oceanbase.DBA_RECYCLEBIN where ORIGINAL_NAME = 'inner_db';

connection default;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set enable_sys_table_ddl = false;
disconnect obsys;
connection default;

###################################################################################
##clear
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
#drop tenant tenant_test force;
#drop resource pool resource_pool;
#drop resource unit resource_unit;

--disable_query_log
--echo select count(*) from oceanbase.__all_virtual_recyclebin where tenant = 'sys'
#eval select count(*) from oceanbase.__all_virtual_recyclebin where tenant_id = 1;
