#
# test of recyclebin plan hit

use oceanbase;

set @@recyclebin = on;
--disable_warnings
drop database if exists hualong_db;
--enable_warnings
create database hualong_db;
create table hualong_db.plan_table(a int primary key, b int);
insert into hualong_db.plan_table values(1,1);
insert into hualong_db.plan_table values(3,3);
update hualong_db.plan_table set b = a + 1 where a = 1; 
delete from hualong_db.plan_table where a = 3;
select * from hualong_db.plan_table;
replace into hualong_db.plan_table values (1,11);
select * from hualong_db.plan_table;

--echo -------------------------------------------------------
drop database if exists hualong_db;
create database hualong_db;
create table hualong_db.plan_table(a int primary key, b int);
insert into hualong_db.plan_table values(1,1);
insert into hualong_db.plan_table values(3,3);
update hualong_db.plan_table set b = a + 1 where a = 1; 
delete from hualong_db.plan_table where a = 3;
select * from hualong_db.plan_table;
replace into hualong_db.plan_table values (1,11);
select * from hualong_db.plan_table;

--echo -------------------------------------------------------
drop database if exists hualong_db;
create database hualong_db;
create table hualong_db.plan_table(a int primary key, b int);
insert into hualong_db.plan_table values(1,1);
insert into hualong_db.plan_table values(3,3);
update hualong_db.plan_table set b = a + 1 where a = 1; 
delete from hualong_db.plan_table where a = 3;
select * from hualong_db.plan_table;
replace into hualong_db.plan_table values (1,11);
select * from hualong_db.plan_table;

drop database hualong_db;
