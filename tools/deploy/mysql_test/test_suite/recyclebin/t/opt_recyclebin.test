# owner: jim.wjh
# owner group: sql2
# description:
#
# test of purge recyclebin

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop database if exists jx_db;
--enable_warnings
purge recyclebin;
show recyclebin;

--echo set the session variable
set @@recyclebin = on;
show session variables like 'recyclebin';

create database jx_db;
use jx_db;

--disable_query_log
let $i = 0;
while($i < 10)
{
  eval create table t_$i(c1 int primary key, index idx(c1));
  eval create index idx_2 on t_$i(c1);
  eval insert into t_$i values(1000);
  eval create view v_$i as select * from t_$i;
  eval drop table t_$i;
  inc $i;
}
--enable_query_log

drop database jx_db;
purge recyclebin;
show recyclebin;
