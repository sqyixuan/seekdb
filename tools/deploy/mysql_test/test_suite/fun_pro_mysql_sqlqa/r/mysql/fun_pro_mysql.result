create procedure tb_flow_bytefile() 
BEGIN
DECLARE  vv_fileid	VARCHAR(30);
DECLARE break INT DEFAULT 0;
DECLARE cur_1 CURSOR FOR 
SELECT DISTINCT FILEID FROM tb_flow_bytefile where DATE_FORMAT(UPLOADTIME,'%Y%m') = '202003' ;
DECLARE CONTINUE HANDLER FOR NOT FOUND SET break = 1;
OPEN cur_1;
get_info:LOOP
FETCH cur_1 INTO vv_fileid; 
if break = 1 THEN
LEAVE get_info;
end if;
INSERT into tb_flow_bytefile_202003 
select * from tb_flow_bytefile 
where FILEID = vv_fileid
and DATE_FORMAT(UPLOADTIME,'%Y%m') = '202003';
COMMIT;
END LOOP get_info;
CLOSE cur_1; 
END
