drop database if exists yd;
create database yd;
use yd;
create table TB_SYS_WORKDAY(id int(11),WORKDAY date);
create table TB_SYS_WORKDAY_01(id int(11),WORKDAY date);
create table TB_CHNGROUP_DICT(id int(11),GROUP_ID VARCHAR(300),PARENT_GROUP_ID VARCHAR(300));
create table tb_chngroup_rel(id int(11),group_id VARCHAR(30),parent_group_id VARCHAR(30),current_level VARCHAR(30),parent_level VARCHAR(30),denorm_level varchar(30));
create table TB_CHNGROUP_DICT_bak(id int(11),  GROUP_ID varchar(30), PARENT_GROUP_ID varchar(30));
create table tb_chngroup_rel_bak(id int(11),group_id varchar(30), parent_group_id varchar(30), current_level varchar(30), parent_level varchar(30),denorm_level varchar(30));
create table tb_chngroup_rel_20180930(id int(11),group_id VARCHAR(30),parent_group_id VARCHAR(30),current_level VARCHAR(30),parent_level VARCHAR(30),denorm_level varchar(30));
create table tb_flow_bytefile(FILEID varchar(30),UPLOADTIME datetime);
create table tb_flow_bytefile_202003 (FILEID varchar(30),UPLOADTIME datetime);
create function GET_NODEORDER_FORMAT ( `_STR` varchar(60)) returns varchar(60) BEGIN
DECLARE a INT;
DECLARE b INT;
DECLARE c INT;
DECLARE d INT;
IF LENGTH(_STR) = 12 THEN
SET a = SUBSTRING(_STR, 2, 2);
SET b = SUBSTRING(_STR, 5, 2);
SET c = SUBSTRING(_STR, 8, 2);
SET d = SUBSTRING(_STR, 11, 2);
RETURN CONCAT(a,'.',b,'.',c,'.',d);
ELSE
RETURN '';
END IF;
END
//
create function ISCONTAIN (
`I_ROLE_IDS` varchar(128),
`ROLE_IDS` varchar(128)
) returns int(11)
BEGIN
DECLARE
a INT;
DECLARE
c VARCHAR(32);
SET
a = -1;
IF I_ROLE_IDS IS NULL
OR I_ROLE_IDS = '' THEN RETURN a;
END IF;
IF POSITION('|' in I_ROLE_IDS) > 0 THEN loop_label:
LOOP
set
c = SUBSTR(I_ROLE_IDS, 1, POSITION('|' in I_ROLE_IDS) -1);
IF POSITION(c in ROLE_IDS) > 0 THEN
set
a = 1;
LEAVE loop_label;
ELSE
set
I_ROLE_IDS = SUBSTR(I_ROLE_IDS, POSITION('|' in I_ROLE_IDS) + 1);
END IF;
IF POSITION('|' in I_ROLE_IDS) = 0 THEN IF I_ROLE_IDS = '' THEN
set
a = -1;
LEAVE loop_label;
ELSEIF POSITION(I_ROLE_IDS in ROLE_IDS) > 0 THEN
set
a = 1;
END IF;
LEAVE loop_label;
END IF;
END
LOOP
loop_label;
ELSEIF POSITION('|' in I_ROLE_IDS) = 0 THEN IF POSITION(I_ROLE_IDS in ROLE_IDS) > 0 THEN
set
a = 1;
ELSE
set
a = -1;
END IF;
ELSE
set
a = -1;
END IF;
RETURN a;
END
//
create function MYTRUNCATE (`S` varchar(60), `F` int(8), `RS` varchar(60)) returns varchar(60)
BEGIN
DECLARE
a VARCHAR(60);
DECLARE
c INT(8);
DECLARE
d INT(8);
DECLARE
e INT(8);
SET
c = 0,
d = 0,
e = 0;
SET
c = LENGTH(S);
SET
d = LENGTH(REPLACE(S, '.', ''));
IF S = 0 THEN
set
a = 0;
ELSEIF S = 100 THEN
SET
a = 100;
ELSEIF c = d + 1 THEN IF F = 0 THEN
set
e = INSTR(S, '.') - 1;
ELSE
set
e = INSTR(S, '.') + F;
END IF;
set
a = SUBSTR(S, 1, e);
ELSE
set
a = S;
END IF;
RETURN CONCAT(a, RS);
END
//
create function WORK_ERROR_DAY ( `START_TIME` datetime, `END_TIME` datetime) returns int(11) BEGIN
DECLARE TIME_DIFF INT;
DECLARE START_DATE DATE;
DECLARE END_DATE DATE; 
DECLARE START_IS_WORKDAY INT;
DECLARE END_IS_WORKDAY INT;
DECLARE WORK_DAY_BETWENN INT;  
IF (START_TIME>=END_TIME) THEN
RETURN 0;
END IF;
SET START_DATE = START_TIME;
SET END_DATE = END_TIME;    
SET TIME_DIFF = 0;
SELECT 1  INTO START_IS_WORKDAY FROM TB_SYS_WORKDAY WHERE WORKDAY = START_DATE;    
IF START_DATE=END_DATE THEN
IF START_IS_WORKDAY IS NOT NULL THEN
SET TIME_DIFF = UNIX_TIMESTAMP(END_TIME)-UNIX_TIMESTAMP(START_TIME);
END IF;
ELSE
SELECT 1  INTO END_IS_WORKDAY FROM TB_SYS_WORKDAY WHERE WORKDAY = END_DATE; 
SELECT COUNT(1) INTO WORK_DAY_BETWENN  FROM TB_SYS_WORKDAY WHERE WORKDAY >START_DATE AND WORKDAY < END_DATE;
IF START_IS_WORKDAY IS NOT NULL THEN
SET TIME_DIFF = TIME_DIFF - UNIX_TIMESTAMP(START_TIME)+UNIX_TIMESTAMP(START_DATE) +86400;
END IF;
IF END_IS_WORKDAY IS NOT NULL THEN
SET TIME_DIFF = TIME_DIFF + UNIX_TIMESTAMP(END_TIME)-UNIX_TIMESTAMP(END_DATE);
END IF; 
SET TIME_DIFF = TIME_DIFF + 86400*WORK_DAY_BETWENN;
END IF;
RETURN TIME_DIFF;
END
//
create function WORK_ERROR_DAY_01 (`START_TIME` datetime, `END_TIME` datetime) returns int(11)
BEGIN
DECLARE
TIME_DIFF INT;
DECLARE
START_DATE DATE;
DECLARE
END_DATE DATE;
DECLARE
START_IS_WORKDAY INT;
DECLARE
END_IS_WORKDAY INT;
DECLARE
WORK_DAY_BETWENN INT;
IF (START_TIME >= END_TIME) THEN RETURN 0;
END IF;
SET
START_DATE = START_TIME;
SET
END_DATE = END_TIME;
SET
TIME_DIFF = 0;
SELECT
1 INTO START_IS_WORKDAY
FROM
TB_SYS_WORKDAY_01
WHERE
WORKDAY = START_DATE;
IF START_DATE = END_DATE THEN IF START_IS_WORKDAY IS NOT NULL THEN
SET
TIME_DIFF = UNIX_TIMESTAMP(END_TIME) - UNIX_TIMESTAMP(START_TIME);
END IF;
ELSE
SELECT
1 INTO END_IS_WORKDAY
FROM
TB_SYS_WORKDAY_01
WHERE
WORKDAY = END_DATE;
SELECT
COUNT(1) INTO WORK_DAY_BETWENN
FROM
TB_SYS_WORKDAY_01
WHERE
WORKDAY > START_DATE
AND WORKDAY < END_DATE;
IF START_IS_WORKDAY IS NOT NULL THEN
SET
TIME_DIFF = TIME_DIFF - UNIX_TIMESTAMP(START_TIME) + UNIX_TIMESTAMP(START_DATE) + 86400;
END IF;
IF END_IS_WORKDAY IS NOT NULL THEN
SET
TIME_DIFF = TIME_DIFF + UNIX_TIMESTAMP(END_TIME) - UNIX_TIMESTAMP(END_DATE);
END IF;
SET
TIME_DIFF = TIME_DIFF + 86400 * WORK_DAY_BETWENN;
END IF;
RETURN TIME_DIFF;
END
//
create function WORK_DAY_PASS(
START_TIME datetime, 
PASSTIME int) 
returns datetime 
BEGIN
DECLARE PASS_DAY INT;
DECLARE LEAVE_TIME INT;
DECLARE START_DATE DATE;
DECLARE END_TIME DATETIME;
DECLARE START_IS_WORKDAY INT;
SET START_DATE = START_TIME;
SET PASS_DAY = FLOOR(PASSTIME/86400)+1;
SET LEAVE_TIME = PASSTIME%86400;
SELECT 1 INTO START_IS_WORKDAY FROM TB_SYS_WORKDAY WHERE WORKDAY = START_DATE;    
IF START_IS_WORKDAY IS NOT NULL THEN
SET LEAVE_TIME = LEAVE_TIME -86400+  (UNIX_TIMESTAMP(START_TIME)+28800)%86400;
IF LEAVE_TIME <0 THEN
SET LEAVE_TIME = LEAVE_TIME + 86400;
SET PASS_DAY  = PASS_DAY - 1; 
END IF;
ELSE
SET PASS_DAY = PASS_DAY -1;
END IF;
IF PASSTIME>=0 THEN
SELECT FROM_UNIXTIME(UNIX_TIMESTAMP(WORKDAY)+LEAVE_TIME,'%Y-%m-%d %H:%i:%S') INTO END_TIME FROM TB_SYS_WORKDAY 
WHERE WORKDAY >= START_DATE ORDER BY WORKDAY LIMIT 1,1;
ELSE
SET PASS_DAY = -PASS_DAY;
SELECT FROM_UNIXTIME(UNIX_TIMESTAMP(WORKDAY)+LEAVE_TIME,'%Y-%m-%d %H:%i:%S') INTO END_TIME FROM TB_SYS_WORKDAY 
WHERE WORKDAY <= START_DATE ORDER BY WORKDAY DESC LIMIT 1,1;
END IF;
RETURN END_TIME;
END
//
create function WORK_DAY_PASS_01(
START_TIME datetime, 
END_TIME datetime) 
returns int(11)
BEGIN
DECLARE TIME_DIFF INT;
DECLARE START_DATE DATE;
DECLARE END_DATE DATE; 
DECLARE START_IS_WORKDAY INT;
DECLARE END_IS_WORKDAY INT;
DECLARE WORK_DAY_BETWENN INT;  
IF (START_TIME>=END_TIME) THEN
RETURN 0;
END IF;
SET START_DATE = START_TIME;
SET END_DATE = END_TIME;    
SET TIME_DIFF = 0;
SELECT 1  INTO START_IS_WORKDAY FROM TB_SYS_WORKDAY_01 WHERE WORKDAY = START_DATE;    
IF START_DATE=END_DATE THEN
IF START_IS_WORKDAY IS NOT NULL THEN
SET TIME_DIFF = UNIX_TIMESTAMP(END_TIME)-UNIX_TIMESTAMP(START_TIME);	
END IF;
ELSE
SELECT 1  INTO END_IS_WORKDAY FROM TB_SYS_WORKDAY_01 WHERE WORKDAY = END_DATE; 
SELECT COUNT(1) INTO WORK_DAY_BETWENN  FROM TB_SYS_WORKDAY_01 WHERE WORKDAY >START_DATE AND WORKDAY < END_DATE;	
IF START_IS_WORKDAY IS NOT NULL THEN
SET TIME_DIFF = TIME_DIFF - UNIX_TIMESTAMP(START_TIME)+UNIX_TIMESTAMP(START_DATE) +86400;
END IF;
IF END_IS_WORKDAY IS NOT NULL THEN
SET TIME_DIFF = TIME_DIFF + UNIX_TIMESTAMP(END_TIME)-UNIX_TIMESTAMP(END_DATE);
END IF; 
SET TIME_DIFF = TIME_DIFF + 86400*WORK_DAY_BETWENN;
END IF;
RETURN TIME_DIFF;
END
//
create procedure SYN_DICT_REL ()
BEGIN
DECLARE
g_id,
g_parent_id VARCHAR(300);
DECLARE
break_1 INT DEFAULT 0;
DECLARE
break_2 INT DEFAULT 0;
DECLARE
cur_1 CURSOR FOR
SELECT
GROUP_ID,
PARENT_GROUP_ID
FROM
TB_CHNGROUP_DICT;
DECLARE
CONTINUE HANDLER FOR NOT FOUND
SET
break_1 = 1;
OPEN cur_1;
FETCH cur_1 INTO g_id,
g_parent_id;
WHILE break_1 <> 1 DO FETCH cur_1 INTO g_id,
g_parent_id;
SET
break_2 = 1;
WHILE break_2 <> -1 DO IF g_parent_id = ''
  OR g_parent_id IS NULL THEN
UPDATE
tb_chngroup_rel
SET
current_level = break_2 -1,
parent_level = parent_level + break_2 -1,
denorm_level = current_level - parent_level
WHERE
group_id = g_id;
SET
break_2 = -1;
ELSE
INSERT INTO
tb_chngroup_rel (
group_id,
parent_group_id,
current_level,
parent_level
)
VALUES
(g_id, g_parent_id, 0,(0 - break_2));
SET
break_2 = break_2 + 1;
SELECT
IFNULL(MAX(PARENT_GROUP_ID), '') INTO g_parent_id
FROM
TB_CHNGROUP_DICT
WHERE
group_id = g_parent_id;
END IF;
END WHILE;
END WHILE;
CLOSE cur_1;
END
//
create procedure SYN_DICT_REL_LN ()
BEGIN
DECLARE
g_id,
g_parent_id VARCHAR(300);
DECLARE
break_1 INT DEFAULT 0;
DECLARE
break_2 INT DEFAULT 0;
DECLARE
cur_1 CURSOR FOR
SELECT
GROUP_ID,
PARENT_GROUP_ID
FROM
TB_CHNGROUP_DICT_bak;
DECLARE
CONTINUE HANDLER FOR NOT FOUND
SET
break_1 = 1;
INSERT INTO
tb_chngroup_rel_bak (
group_id,
parent_group_id,
current_level,
parent_level
)
SELECT
GROUP_ID,
GROUP_ID,
0,
0
FROM
TB_CHNGROUP_DICT_bak;
COMMIT;
OPEN cur_1;
WHILE break_1 <> 1 DO FETCH cur_1 INTO g_id,
g_parent_id;
SET
break_2 = 1;
WHILE break_2 <> -1 DO IF g_parent_id = ''
  OR g_parent_id IS NULL THEN
UPDATE
tb_chngroup_rel_bak
SET
current_level = break_2 -1,
parent_level = parent_level + break_2 -1,
denorm_level = current_level - parent_level
WHERE
group_id = g_id;
SET
break_2 = -1;
ELSE
INSERT INTO
tb_chngroup_rel_bak (
group_id,
parent_group_id,
current_level,
parent_level
)
VALUES
(g_id, g_parent_id, 0,(0 - break_2));
SET
break_2 = break_2 + 1;
SELECT
IFNULL(MAX(PARENT_GROUP_ID), '') INTO g_parent_id
FROM
TB_CHNGROUP_DICT_bak
WHERE
group_id = g_parent_id;
END IF;
END WHILE;
END WHILE;
CLOSE cur_1;
DELETE FROM
tb_chngroup_rel_bak
WHERE
parent_group_id = '0';
UPDATE
tb_chngroup_rel_bak
SET
current_level = current_level -1,
parent_level = parent_level -1;
END
