--disable_warnings
drop database if exists yd;
--enable_warnings

create database yd;
use yd;

--source mysql_test/test_suite/fun_pro_mysql_sqlqa/fun_pro.sql

--echo #######################################GET_NODEORDER_FORMAT###########################
select GET_NODEORDER_FORMAT('abc');
select GET_NODEORDER_FORMAT('123456789012');

--echo #######################################ISCONTAIN######################################
select ISCONTAIN('','');

select ISCONTAIN('a|b|c|d|e|f','abc');

select ISCONTAIN('ab','abc');

--echo #######################################MYTRUNCATE#####################################

--disable_warnings
select MYTRUNCATE('',0,'');

select MYTRUNCATE('',0,'');

select MYTRUNCATE(0,0,'');

select MYTRUNCATE(100,0,'');

select MYTRUNCATE('abcd.',0,'');

select MYTRUNCATE('abcd.',1,'');

select MYTRUNCATE('abcd',1,'');

--enable_warnings

--echo #############################WORK_ERROR_DAY######################################
delete from TB_SYS_WORKDAY;

select WORK_ERROR_DAY('2021-08-04','2021-08-03');

insert into TB_SYS_WORKDAY values(1,'2021-08-04');

select WORK_ERROR_DAY('2021-08-04','2021-08-04');

insert into TB_SYS_WORKDAY values(2,'2021-08-05');

select WORK_ERROR_DAY('2021-08-04','2021-08-05');

select WORK_ERROR_DAY('2021-08-06','2021-08-06');

select WORK_ERROR_DAY('2021-08-06','2021-08-07');


--echo #############################WORK_ERROR_DAY_01###################################
delete from TB_SYS_WORKDAY_01;

insert into TB_SYS_WORKDAY_01 values(1,'2021-08-04');

select WORK_ERROR_DAY_01('2021-08-04','2021-08-04');

insert into TB_SYS_WORKDAY_01 values(2,'2021-08-05');

select WORK_ERROR_DAY_01('2021-08-04','2021-08-05');

select WORK_ERROR_DAY_01('2021-08-06','2021-08-06');

select WORK_ERROR_DAY_01('2021-08-06','2021-08-07');

--echo #############################WORK_DAY_PASS###################################
--echo #############################
delete from TB_SYS_WORKDAY;

insert into TB_SYS_WORKDAY values(1,'2021-08-04');

select WORK_DAY_PASS('2021-08-04',1);

select WORK_DAY_PASS('2021-08-04',-1);

--echo ############################WORK_DAY_PASS_01###############################
delete from TB_SYS_WORKDAY_01;
insert into TB_SYS_WORKDAY_01 values(1,'2021-08-04');
insert into TB_SYS_WORKDAY_01 values(2,'2021-08-05');

select WORK_DAY_PASS_01('2021-08-04','2021-08-04');

select WORK_DAY_PASS_01('2021-08-04','2021-08-06');

select WORK_DAY_PASS_01('2021-08-03','2021-08-05');

select WORK_DAY_PASS_01('2021-08-04','2021-08-05');


--echo ############################SYN_DICT_REL###############################
delete from tb_chngroup_dict;

delete from tb_chngroup_rel;

INSERT INTO tb_chngroup_dict (id,GROUP_ID,PARENT_GROUP_ID) VALUES (1,'1',0),(3,'3',NULL);

INSERT INTO tb_chngroup_rel (id,group_id,parent_group_id,current_level,parent_level) VALUES (3,'3','3',NULL,NULL);

INSERT INTO tb_chngroup_dict (id,GROUP_ID,PARENT_GROUP_ID) VALUES (2,2,1);

call SYN_DICT_REL();

select * from tb_chngroup_rel;

