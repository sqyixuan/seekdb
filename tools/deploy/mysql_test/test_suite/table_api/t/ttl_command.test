#owner: shenyunlong.syl
#owner group: shenzhen

connect (obsys, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

### 1. execute in sys tenant
connection obsys;
alter system set enable_kv_ttl = false tenant = all;
sleep 5;

--error 10501
alter system trigger ttl;
--error 10501
alter system trigger ttl tenant=all;
--error 10501
alter system trigger ttl tenant=mysql;

alter system set enable_kv_ttl = true tenant = all;
sleep 5;

--error 10505
alter system suspend ttl;
--error 10505
alter system resume ttl;
--error 10505
alter system cancel ttl;
--error 10505
alter system suspend ttl tenant=all;
--error 10505
alter system resume ttl tenant=all;
--error 10505
alter system cancel ttl tenant=mysql;

# sys tenant with tenant is empty
alter system trigger ttl;
sleep 20;

# sys tenant with tenant is all
connection obsys;
alter system trigger ttl tenant=all;
sleep 20;

# sys tenant with specified tenant
alter system trigger ttl tenant=mysql;
sleep 20;

# trigger with running task
alter system trigger ttl;
--error 10504
alter system trigger ttl;
--error 10504
alter system resume ttl;
sleep 20;

### 2. execute in user tenant
connection default;
alter system set enable_kv_ttl = false;
sleep 5;

--error 10501
alter system trigger ttl;

alter system set enable_kv_ttl = true;
sleep 5;

--error 10505
alter system suspend ttl;
--error 10505
alter system resume ttl;
--error 10505
alter system cancel ttl;

alter system trigger ttl;
sleep 20;

# trigger with running task
alter system trigger ttl;
--error 10504
alter system trigger ttl;
--error 10504
alter system resume ttl;
sleep 20;