#owner: shenyunlong.syl
#owner group: shenzhen

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;
alter system minor freeze;
alter system set enable_kv_ttl = true;
sleep 5;

#######################################################################################
#    TEST: delete data within both non-partitioned table partition table
#######################################################################################

######## TBALE 1: DATA WAS EXPIRED BY BOTH TTL & MAX VERSION
--disable_warnings
drop table if exists htable_ttl_trigger_1; create table if not exists htable_ttl_trigger_1 (K varbinary(1024), Q varbinary(256), T bigint, V varbinary(1024), primary key(K, Q, T)) kv_attributes ='{"Hbase": {"TimeToLive": 5, "MaxVersions": 2}}' partition by range columns(K)
(
  partition p1 values less than ('row2'),
  partition p2 values less than ('row3'),
  partition p3 values less than ('row4'),
  partition pm values less than (MAXVALUE)
);
--enable_warnings

# insert 4*7*500 rows, save one rows per cell
--let $count = 0
while($count < 500)
{
  --let $stmt=insert into htable_ttl_trigger_1(K, Q, T, V) values (concat('row', cast($count as char)), 'cq0', 0, 'del'), (concat('row', cast($count as char)), 'cq0', -1, 'del'), (concat('row', cast($count as char)), 'cq0', -2, 'del'), (concat('row', cast($count as char)), 'cq0', -3, 'del'), (concat('row', cast($count as char)), 'cq0', -4, 'del'), (concat('row', cast($count as char)), 'cq0', -5, 'del'), (concat('row', cast($count as char)), 'cq0', -9223372036854, 'no del'), (concat('row', cast($count as char)), 'cq1', 0, 'del'), (concat('row', cast($count as char)), 'cq1', -1, 'del'), (concat('row', cast($count as char)), 'cq1', -2, 'del'), (concat('row', cast($count as char)), 'cq1', -3, 'del'), (concat('row', cast($count as char)), 'cq1', -4, 'del'), (concat('row', cast($count as char)), 'cq1', -5, 'del'), (concat('row', cast($count as char)), 'cq1', -9223372036854, 'no del'), (concat('row', cast($count as char)), 'cq2', 0, 'del'), (concat('row', cast($count as char)), 'cq2', -1, 'del'), (concat('row', cast($count as char)), 'cq2', -2, 'del'), (concat('row', cast($count as char)), 'cq2', -3, 'del'), (concat('row', cast($count as char)), 'cq2', -4, 'del'), (concat('row', cast($count as char)), 'cq2', -5, 'del'), (concat('row', cast($count as char)), 'cq2', -9223372036854, 'no del'), (concat('row', cast($count as char)), 'cq3', 0, 'del'), (concat('row', cast($count as char)), 'cq3', -1, 'del'), (concat('row', cast($count as char)), 'cq3', -2, 'del'), (concat('row', cast($count as char)), 'cq3', -3, 'del'), (concat('row', cast($count as char)), 'cq3', -4, 'del'), (concat('row', cast($count as char)), 'cq3', -5, 'del'), (concat('row', cast($count as char)), 'cq3', -9223372036854, 'no del');
  
  eval $stmt;
  inc $count;
}

######## TBALE 2: DATA WAS EXPIRED BY ONLY MAX VERSIONS
--disable_warnings
drop table if exists htable_ttl_trigger_2; create table if not exists htable_ttl_trigger_2 (K varbinary(1024), Q varbinary(256), T bigint, V varbinary(1024), primary key(K, Q, T)) KV_ATTRIBUTES ='{"Hbase": {"MaxVersions": 2}}';
--enable_warnings

# insert 2*7*20 rows, save two rows per cell
--let $count = 0
while($count < 20)
{
  --let $stmt=insert into htable_ttl_trigger_2(K, Q, T, V) values (concat('row', cast($count as char)), 'cq0', -9223372036854775797, 'del'), (concat('row', cast($count as char)), 'cq0', -9223372036854775798, 'del'), (concat('row', cast($count as char)), 'cq0', -9223372036854775799, 'del'), (concat('row', cast($count as char)), 'cq0', -9223372036854775800, 'del'), (concat('row', cast($count as char)), 'cq0', -9223372036854775801, 'del'), (concat('row', cast($count as char)), 'cq0', -9223372036854775802, 'no del'), (concat('row', cast($count as char)), 'cq0', -9223372036854775803, 'no del'), (concat('row', cast($count as char)), 'cq1', -9223372036854775797, 'del'),                                                                (concat('row', cast($count as char)), 'cq1', -9223372036854775798, 'del'), (concat('row', cast($count as char)), 'cq1', -9223372036854775799, 'del'), (concat('row', cast($count as char)), 'cq1', -9223372036854775800, 'del'), (concat('row', cast($count as char)), 'cq1', -9223372036854775801, 'del'), (concat('row', cast($count as char)), 'cq1', -9223372036854775802, 'no del'), (concat('row', cast($count as char)), 'cq1', -9223372036854775803, 'no del');

  eval $stmt;
  inc $count;
}

alter system trigger ttl;
sleep 60;
select count(*) from htable_ttl_trigger_1;
select count(*) from htable_ttl_trigger_2;
select TABLE_NAME, TRIGGER_TYPE, STATUS, TTL_DEL_CNT, MAX_VERSION_DEL_CNT, SCAN_CNT, RET_CODE from (select * from oceanbase.dba_ob_kv_ttl_task_history where table_name = 'htable_ttl_trigger_1' or table_name = 'htable_ttl_trigger_2' order by START_TIME limit 5)order by TABLE_NAME asc, TABLET_ID asc;

drop table htable_ttl_trigger_1;
drop table htable_ttl_trigger_2;