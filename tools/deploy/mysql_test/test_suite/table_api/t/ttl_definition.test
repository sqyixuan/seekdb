#owner: shenyunlong.syl
#owner group: shenzhen

# test ttl definition parsing
# 

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;
alter system minor freeze;
alter system set enable_kv_ttl = true;
sleep 5;

--disable_warnings
drop table if exists test_ttl_definition;
--enable_warnings
create table test_ttl_definition(a varchar(1024) primary key, b varchar(1024), c datetime) TTL (  c    +   INTERVAL    0    SECOND )  partition by key(a) partitions 3;

drop procedure if exists insert_data;
delimiter |;
create PROCEDURE insert_data(del int, no_del int)
BEGIN
  DECLARE i INT DEFAULT 0;
	WHILE i < del do
    insert into test_ttl_definition(a, b, c) values (concat('row', cast(i as char)), 'hello world', now());
		set i = i + 1;
	end while;
  while i < del + no_del do
    insert into test_ttl_definition(a, b, c) values (concat('row', cast(i as char)), 'hello world', date_add(now(), interval + 1 HOUR));
		set i = i + 1;
  end while;
END |
delimiter ;|

call insert_data(1024, 0);

alter system trigger ttl;
sleep 70;
select count(*) from test_ttl_definition;
select TABLE_NAME, TRIGGER_TYPE, STATUS, TTL_DEL_CNT, MAX_VERSION_DEL_CNT, SCAN_CNT, RET_CODE from oceanbase.DBA_OB_KV_TTL_TASK_HISTORY where table_name = 'test_ttl_definition' or table_name is null and task_id = (select max(task_id) from oceanbase.DBA_OB_KV_TTL_TASK_HISTORY) order by table_name, tablet_id;

drop table test_ttl_definition;