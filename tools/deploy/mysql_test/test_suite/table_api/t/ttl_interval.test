#owner: shenyunlong.syl
#owner group: shenzhen

# 测试 TTL Interval 是否生效

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
connection default;
alter system set enable_kv_ttl = true;
sleep 5;

--disable_warnings
drop table if exists ttl_second_ts;
drop table if exists ttl_second_dt;
drop table if exists ttl_minute_ts;
drop table if exists ttl_minute_dt;
drop table if exists ttl_hour_ts;
drop table if exists ttl_hour_dt;
drop table if exists ttl_day_ts;
drop table if exists ttl_day_dt;
drop table if exists ttl_month_ts;
drop table if exists ttl_month_dt;
drop table if exists ttl_year_ts;
drop table if exists ttl_year_dt;
--enable_warnings

create table ttl_second_ts(a int primary key, c timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP)
  TTL(c + INTERVAL 50000 SECOND) partition by hash(a) partitions 3;
create table ttl_second_dt(a int primary key, c datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP)
  TTL(c + INTERVAL 50000 SECOND) partition by hash(a) partitions 3;
  
create table ttl_minute_ts(a int primary key, c timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP)
  TTL(c + INTERVAL 5000 MINUTE) partition by hash(a) partitions 3;
create table ttl_minute_dt(a int primary key, c datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP)
  TTL(c + INTERVAL 5000 MINUTE) partition by hash(a) partitions 3;

create table ttl_hour_ts(a int primary key, c timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP)
  TTL(c + INTERVAL 500 HOUR) partition by hash(a) partitions 3;
create table ttl_hour_dt(a int primary key, c datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP)
  TTL(c + INTERVAL 500 HOUR) partition by hash(a) partitions 3;

create table ttl_day_ts(a int primary key, c timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP)
  TTL(c + INTERVAL 50 DAY) partition by hash(a) partitions 3;
create table ttl_day_dt(a int primary key, c datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP)
  TTL(c + INTERVAL 50 DAY) partition by hash(a) partitions 3;

create table ttl_month_ts(a int primary key, c timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP)
  TTL(c + INTERVAL 5 MONTH) partition by hash(a) partitions 3;
create table ttl_month_dt(a int primary key, c datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP)
  TTL(c + INTERVAL 5 MONTH) partition by hash(a) partitions 3;

create table ttl_year_ts(a int primary key, c timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP)
  TTL(c + INTERVAL 1 YEAR) partition by hash(a) partitions 3;
create table ttl_year_dt(a int primary key, c datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP)
  TTL(c + INTERVAL 1 YEAR) partition by hash(a) partitions 3;

drop procedure if exists insert_data;
delimiter |;
create PROCEDURE insert_data(del_cnt int, no_del_cnt int)
BEGIN
  DECLARE i INT DEFAULT 0;
  DECLARE j INT DEFAULT 0;
	WHILE i < del_cnt do
    insert into ttl_second_ts(a) values (i);
    insert into ttl_second_dt(a) values (i);
    insert into ttl_minute_ts(a) values (i);
    insert into ttl_minute_dt(a) values (i);
    insert into ttl_hour_ts(a) values (i);
    insert into ttl_hour_dt(a) values (i);
    insert into ttl_day_ts(a) values (i);
    insert into ttl_day_dt(a) values (i);
    insert into ttl_month_ts(a) values (i);
    insert into ttl_month_dt(a) values (i);
    insert into ttl_year_ts(a) values (i);
    insert into ttl_year_dt(a) values (i);
		set i = i + 1;
	end while;

	WHILE j < no_del_cnt do
    insert into ttl_second_ts values (i+j, date_add(now(), interval - 50000 SECOND));
    insert into ttl_second_dt values (i+j, date_add(now(), interval - 50000 SECOND));
    insert into ttl_minute_ts values (i+j, date_add(now(), interval - 5000 MINUTE));
    insert into ttl_minute_dt values (i+j, date_add(now(), interval - 5000 MINUTE));
    insert into ttl_hour_ts values (i+j, date_add(now(), interval - 500 HOUR));
    insert into ttl_hour_dt values (i+j, date_add(now(), interval - 500 HOUR));
    insert into ttl_day_ts values (i+j, date_add(now(), interval - 50 DAY));
    insert into ttl_day_dt values (i+j, date_add(now(), interval - 50 DAY));
    insert into ttl_month_ts values (i+j, date_add(now(), interval - 5 MONTH));
    insert into ttl_month_dt values (i+j, date_add(now(), interval - 5 MONTH));
    insert into ttl_year_ts values (i+j, date_add(now(), interval - 1 YEAR));
    insert into ttl_year_dt values (i+j, date_add(now(), interval - 1 YEAR));
		set j = j + 1;
  end while;
END |
delimiter ;| 

call insert_data(1000, 1000);

sleep 5;
alter system trigger ttl;
sleep 70; 
select count(1) from ttl_second_ts;
select count(1) from ttl_second_dt;
select count(1) from ttl_minute_ts;
select count(1) from ttl_minute_dt;
select count(1) from ttl_hour_ts;
select count(1) from ttl_hour_dt;
select count(1) from ttl_day_ts;
select count(1) from ttl_day_dt;
select count(1) from ttl_month_ts;
select count(1) from ttl_month_dt;
select count(1) from ttl_year_ts;
select count(1) from ttl_year_dt;

select TABLE_NAME, TRIGGER_TYPE, STATUS, TTL_DEL_CNT, MAX_VERSION_DEL_CNT, SCAN_CNT, RET_CODE from oceanbase.DBA_OB_KV_TTL_TASK_HISTORY where table_name in ('ttl_second_ts', 'ttl_second_dt', 'ttl_minute_ts', 'ttl_minute_dt', 'ttl_hour_ts', 'ttl_hour_dt', 'ttl_day_ts', 'ttl_day_dt', 'ttl_month_ts', 'ttl_month_dt', 'ttl_year_ts', 'ttl_year_dt') order by table_name, tablet_id;

drop table ttl_second_ts;
drop table ttl_second_dt;
drop table ttl_minute_ts;
drop table ttl_minute_dt;
drop table ttl_hour_ts;
drop table ttl_hour_dt;
drop table ttl_day_ts;
drop table ttl_day_dt;
drop table ttl_month_ts;
drop table ttl_month_dt;
drop table ttl_year_ts;
drop table ttl_year_dt;