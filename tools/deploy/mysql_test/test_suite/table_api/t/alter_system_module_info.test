#owner: xiongliyao.xly
#owner group: shenzhen


connect (obsys, $OBMYSQL_MS0, root@sys,,oceanbase,$OBMYSQL_PORT);
connect (obmysql, $OBMYSQL_MS0, root, , test, $OBMYSQL_PORT);
connection obsys;

--echo 1. normal case
--echo before load, check failed
--echo load succ
alter system load module data module=redis tenant=sys;
--echo ignore command case, load succ
alter system load module data module=ReDiS tenant=sys;

--echo check succ
alter system check module data module=redis tenant=sys;

--echo check manually
connection obmysql;
select command_name, table_name from oceanbase.__all_kv_redis_table;
select count(*) from oceanbase.__all_database where database_name='obkv_redis';
select table_name from oceanbase.__all_table where database_id=
  (select database_id from oceanbase.__all_database where database_name='obkv_redis')
  and table_name like 'obkv_redis_%_table';
connection obsys;

--echo 2. failed case
--echo 2.1. with 'infile' param not supported
--error 4025
alter system load module data module=redis tenant=sys infile='./no-exists-file';
--error 4025
alter system check module data module=redis tenant=sys infile='./no-exists-file';

--echo 2.2. with 'gis/srs' module not supported

alter system load module data module=gis tenant=sys;
--error 1235
alter system check module data module=timezone tenant=sys;
alter system load module data module=timezone tenant=sys;
--error 1210
alter system load module data module=invalidMode tenant=sys;

alter system load module data module=gis tenant=sys infile = 'etc/';

# opensource do not has oracle tenant
#--echo 2.3. with oracle mode not supported
#--error 1235
#alter system load module data module=gis tenant=oracle;

--echo 2.3. with tenant not exists
--error 5160
alter system load module data module=gis tenant=notexists;

--echo 2.4. non-sys tenant failed
connection obmysql;

alter system load module data module=redis tenant=sys;

alter system check module data module=redis tenant=sys;

connection default;
