alter system minor freeze;
alter system set enable_kv_ttl = true;
drop table if exists htable_ttl_trigger_1;
create table if not exists htable_ttl_trigger_1 (K varbinary(1024), Q varbinary(256), T bigint, V varbinary(1024), primary key(K, Q, T)) kv_attributes ='{"Hbase": {"TimeToLive": 5, "MaxVersions": 2}}' partition by range columns(K)
(
partition p1 values less than ('row2'),
partition p2 values less than ('row3'),
partition p3 values less than ('row4'),
partition pm values less than (MAXVALUE)
);
