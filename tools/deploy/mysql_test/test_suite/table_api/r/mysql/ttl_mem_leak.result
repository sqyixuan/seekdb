alter system minor freeze;
alter system set enable_kv_ttl = true;
drop table if exists ttl_table_mem;
drop table if exists ttl_htable_mem;
create table ttl_table_mem(a varchar(1024) primary key, b varchar(1024), c timestamp) TTL(c + INTERVAL 0 SECOND);
create table ttl_htable_mem (
K varbinary(1024), Q varbinary(256), T bigint, V varbinary(1024),
primary key(K, Q, T))
kv_attributes ='{"Hbase": {"TimeToLive": 5, "MaxVersions": 2}}';
drop procedure if exists insert_table_data;
create PROCEDURE insert_table_data(del int, no_del int)
BEGIN
DECLARE i INT DEFAULT 0;
WHILE i < del do
insert into ttl_table_mem(a, b, c) values (concat('big_table_rowekeyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy', cast(i as char)), 'hello world', now());
set i = i + 1;
end while;
while i < del + no_del do
insert into ttl_table_mem(a, b, c) values (concat('row', cast(i as char)), 'hello world', date_add(now(), interval + 1 HOUR));
set i = i + 1;
end while;
END |
drop procedure if exists insert_htable_data;
create PROCEDURE insert_htable_data(cnt int)
BEGIN
DECLARE i INT DEFAULT 0;
WHILE i < cnt do
insert into ttl_htable_mem(K, Q, T, V) values (concat('big_htable_rowekeyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy', cast(i as char)), concat("cq", cast(i as char)), 0, 'hello world');
insert into ttl_htable_mem(K, Q, T, V) values (concat('big_htable_rowekeyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy', cast(i as char)), concat("cq", cast((i+1) as char)), 0, 'hello world');
set i = i + 1;
end while;
END |
call insert_table_data(200001, 100001);
call insert_htable_data(100001);
select tenant_id, ctx_id, label, ctx_name, mod_type, mod_id, mod_name, zone, hold, used, count from oceanbase.__all_virtual_memory_info where (mod_name like '%ttl%' or mod_name like 'ttl%' )and mod_name != 'PurgeThrottle' and tenant_id = 1002 order by tenant_id, label, zone;
tenant_id	ctx_id	label	ctx_name	mod_type	mod_id	mod_name	zone	hold	used	count
1002	0	tenant_ttl_mgr	DEFAULT_CTX_ID	user	0	tenant_ttl_mgr	zone1	960	896	1
1002	0	TTLTaskBucket	DEFAULT_CTX_ID	user	0	TTLTaskBucket	zone1	4704	4632	1
1002	0	TTLTaskBucket	DEFAULT_CTX_ID	user	0	TTLTaskBucket	zone2	4704	4632	1
