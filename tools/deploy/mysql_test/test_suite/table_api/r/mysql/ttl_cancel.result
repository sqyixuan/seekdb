alter system set enable_kv_ttl = true;
drop table if exists htable_ttl_cancel;
create table if not exists htable_ttl_cancel (K varbinary(1024), Q varbinary(256), T bigint, V varbinary(1024), primary key(K, Q, T)) kv_attributes ='{"Hbase": {"TimeToLive": 5, "MaxVersions": 3}}' partition by key(K) partitions 10;
insert into htable_ttl_cancel values("row1", "cq1", 0, "del"),
("row1", "cq1", -truncate(time_to_usec(date_sub(now(), interval -100 hour))/1000, 0), "no del"),
("row1", "cq2", -truncate(time_to_usec(date_sub(now(), interval -101 hour))/1000, 0), "no del"),
("row1", "cq2", 0, "del"),
("row2", "cq1", 0, "del"),
("row2", "cq1", 1, "del"),
("row2", "cq2", -truncate(time_to_usec(date_sub(now(), interval -100 hour))/1000, 0), "no del"),
("row2", "cq2", 0, "del"),
("row3", "cq1", -truncate(time_to_usec(date_sub(now(), interval -101 hour))/1000, 0), "no del"),
("row3", "cq1", 0, "del"),
("row3", "cq2", 0, "del"),
("row3", "cq2", 1, "del"),
("row4", "cq1", -truncate(time_to_usec(date_sub(now(), interval -100 hour))/1000, 0), "no del"),
("row4", "cq1", 0, "del"),
("row4", "cq2", -truncate(time_to_usec(date_sub(now(), interval -101 hour))/1000, 0), "no del"),
("row4", "cq2", -truncate(time_to_usec(date_sub(now(), interval -102 hour))/1000, 0), "no del");
alter system trigger ttl;
alter system cancel ttl;
select if(count(*)>10, 0, 1) from oceanbase.dba_ob_kv_ttl_task_history where table_name = 'htable_ttl_cancel' order by tablet_id asc;
if(count(*)>10, 0, 1)
1
drop table htable_ttl_cancel;
