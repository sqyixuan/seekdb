2. failed case
2.1. with 'infile' param not supported
alter system load module data module=redis tenant=sys infile='./no-exists-file';
ERROR HY000: loading redis module does not need to specify infile
alter system check module data module=redis tenant=sys infile='./no-exists-file';
ERROR HY000: loading redis module does not need to specify infile
2.2. with 'gis/srs' module not supported
alter system load module data module=gis tenant=sys;
alter system check module data module=timezone tenant=sys;
ERROR 0A000: check timezone is not supported
alter system load module data module=timezone tenant=sys;
alter system load module data module=invalidMode tenant=sys;
ERROR HY000: Invalid argument
alter system load module data module=gis tenant=sys infile = 'etc/';
2.3. with tenant not exists
alter system load module data module=gis tenant=notexists;
ERROR HY000: invalid tenant name specified in connection string
2.4. non-sys tenant failed
alter system load module data module=redis tenant=sys;
alter system check module data module=redis tenant=sys;
