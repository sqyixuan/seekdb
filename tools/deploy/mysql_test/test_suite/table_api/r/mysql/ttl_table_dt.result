alter system minor freeze;
alter system set enable_kv_ttl = true;
alter system set ttl_thread_score = 4;
drop table if exists ttl_table_1;
drop table if exists ttl_table_2;
create table ttl_table_1(a varchar(1024) primary key, b varchar(1024), c datetime) TTL(c + INTERVAL 0 SECOND) partition by key(a) partitions 512;
create table ttl_table_2(a varchar(1024) primary key, b varchar(1024), c timestamp) TTL(c + INTERVAL 0 SECOND) partition by key(a) partitions 512;
drop procedure if exists insert_data;
create PROCEDURE insert_data(del int, no_del int)
BEGIN
DECLARE i INT DEFAULT 0;
WHILE i < del do
insert into ttl_table_1(a, b, c) values (concat('row', cast(i as char)), 'hello world', now());
insert into ttl_table_2(a, b, c) values (concat('row', cast(i as char)), 'hello world', now());
set i = i + 1;
end while;
while i < del + no_del do
insert into ttl_table_1(a, b, c) values (concat('row', cast(i as char)), 'hello world', date_add(now(), interval + 1 HOUR));
insert into ttl_table_2(a, b, c) values (concat('row', cast(i as char)), 'hello world', date_add(now(), interval + 1 HOUR));
set i = i + 1;
end while;
END |
call insert_data(1024, 0);
alter system trigger ttl;
select count(*) from ttl_table_1;
count(*)
0
select count(*) from ttl_table_2;
count(*)
0
select TABLE_NAME, TRIGGER_TYPE, STATUS, RET_CODE, count(*) from oceanbase.DBA_OB_KV_TTL_TASK_HISTORY where task_id = (select max(task_id) from oceanbase.DBA_OB_KV_TTL_TASK_HISTORY) and (table_name in ("ttl_table_1", "ttl_table_2") or table_name is NULL) group by table_name, trigger_type, ret_code, status order by table_name;
TABLE_NAME	TRIGGER_TYPE	STATUS	RET_CODE	count(*)
NULL	USER	FINISHED	OB_SUCCESS	1
ttl_table_1	USER	FINISHED	OB_SUCCESS	512
ttl_table_2	USER	FINISHED	OB_SUCCESS	512
call insert_data(1024, 1024);
alter system trigger ttl;
select count(*) from ttl_table_1;
count(*)
1024
select count(*) from ttl_table_2;
count(*)
1024
select TABLE_NAME, TRIGGER_TYPE, STATUS, RET_CODE, count(*) from oceanbase.DBA_OB_KV_TTL_TASK_HISTORY where task_id = (select max(task_id) from oceanbase.DBA_OB_KV_TTL_TASK_HISTORY) and (table_name in ("ttl_table_1", "ttl_table_2") or table_name is NULL) group by table_name, trigger_type, ret_code, status order by table_name;
TABLE_NAME	TRIGGER_TYPE	STATUS	RET_CODE	count(*)
NULL	USER	FINISHED	OB_SUCCESS	1
ttl_table_1	USER	FINISHED	OB_SUCCESS	512
ttl_table_2	USER	FINISHED	OB_SUCCESS	512
drop table ttl_table_1;
drop table ttl_table_2;
