CREATE TABLE `x` (
`master_no` varchar(64) NOT NULL COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`biz_no` varchar(32) NOT NULL COMMENT '关联的业务单号',
`fin_partner_id` varchar(16) NOT NULL COMMENT '金融服务产品签约使用方id',
`fin_product` varchar(32) NOT NULL COMMENT '金融服务业务产品',
`fin_sales_product` varchar(64) DEFAULT NULL COMMENT '金融服务签约产品',
`ext_info` varchar(4000) DEFAULT NULL COMMENT '扩展信息',
`partition_id` varchar(2) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin GENERATED ALWAYS AS (substr(`master_no`,15,2)) VIRTUAL,
PRIMARY KEY (`master_no`),
