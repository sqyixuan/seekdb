drop table if exists t1;
create table t1 (c1 char(20) COLLATE utf8_bin, c2 varchar(20) COLLATE utf8_general_ci);
insert into t1 values ('2012-12-12 12:01:02', '2012-12-12 12:01:02');
insert into t1 values ('2012-12-12', '2012-12-12');
select *, listagg(c1) over (order by c1 range between interval 1 day preceding and interval 2 * 23 hour following) from t1;
ERROR HY000: Window '<unnamed window>' with RANGE N PRECEDING/FOLLOWING frame requires exactly one ORDER BY expression of numeric or temporal type
drop table t1;
