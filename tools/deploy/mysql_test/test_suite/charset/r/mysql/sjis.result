================================================other case=================================================
drop database sjis_db;
create database sjis_db charset sjis;
alter database sjis_db charset sjis;
use sjis_db;
set names utf8mb4;

create table t1(c1 varchar(20)) charset sjis collate sjis_japanese_ci;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` varchar(20) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = sjis COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
alter table t1 charset=sjis;
alter table t1 modify c1 char(4) CHARACTER SET sjis collate sjis_bin;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` char(4) CHARACTER SET sjis COLLATE sjis_bin DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = sjis COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
show variables like '%char%';
Variable_name	Value
character_sets_dir	
character_set_client	utf8mb4
character_set_connection	utf8mb4
character_set_database	sjis
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	utf8mb4
character_set_system	utf8mb4
validate_password_special_char_count	0
insert into t1 values('タ');
insert into t1 values('ち');
insert into t1 values('亂');
create table t2(c1 varchar(100)) charset utf8;
insert into t2 values('ち');
insert into t2 values('亂');

select hex(c1) from t1;
+---------+
| hex(c1) |
+---------+
| 835E    |
| 82BF    |
| 98AA    |
+---------+
select hex(c1) from t2;
+---------+
| hex(c1) |
+---------+
| E381A1  |
| E4BA82  |
+---------+
select hex(t1.c1), hex(t2.c1) from t1 join t2 on t1.c1 = t2.c1;
+------------+------------+
| hex(t1.c1) | hex(t2.c1) |
+------------+------------+
| 82BF       | E381A1     |
| 98AA       | E4BA82     |
+------------+------------+

drop table t1;
drop table t2;

create table t1(c1 varchar(20)) charset sjis collate sjis_japanese_ci;
insert into t1 values('a'),('A');
insert into t1 values('b'),('B');

insert into t1 values('abcdef');
insert into t1 values('中国');
insert into t1 values('哈哈');
insert into t1 values('じす');

select * from t1 order by c1;
+--------+
| c1     |
+--------+
| a      |
| A      |
| abcdef |
| b      |
| B      |
| じす   |
| 中国   |
| 哈哈   |
+--------+
select upper(c1) from t1;
+-----------+
| upper(c1) |
+-----------+
| A         |
| A         |
| B         |
| B         |
| ABCDEF    |
| 中国      |
| 哈哈      |
| じす      |
+-----------+
select lower(c1) from t1;
+-----------+
| lower(c1) |
+-----------+
| a         |
| a         |
| b         |
| b         |
| abcdef    |
| 中国      |
| 哈哈      |
| じす      |
+-----------+
select position('哈' in c1) from t1;
+-----------------------+
| position('哈' in c1)  |
+-----------------------+
|                     0 |
|                     0 |
|                     0 |
|                     0 |
|                     0 |
|                     0 |
|                     1 |
|                     0 |
+-----------------------+

insert into t1 values ('a '), ('a\t'),('a  ');
select hex(c1) from t1;
+--------------+
| hex(c1)      |
+--------------+
| 61           |
| 41           |
| 62           |
| 42           |
| 616263646566 |
| 92868D91     |
| 99FB99FB     |
| 82B682B7     |
| 6120         |
| 6109         |
| 612020       |
+--------------+
select position(' ' in c1) from t1;
+---------------------+
| position(' ' in c1) |
+---------------------+
|                   0 |
|                   0 |
|                   0 |
|                   0 |
|                   0 |
|                   0 |
|                   0 |
|                   0 |
|                   2 |
|                   0 |
|                   2 |
+---------------------+
select position(' ' in c1) from t1 where c1 like 'a%';
+---------------------+
| position(' ' in c1) |
+---------------------+
|                   0 |
|                   0 |
|                   0 |
|                   2 |
|                   0 |
|                   2 |
+---------------------+

drop table t1;
drop database sjis_db;

select collation(concat(convert("abc" using gb18030_2022), convert("cde" using sjis))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (gb18030_2022_chinese_ci,IMPLICIT), (sjis_japanese_ci,IMPLICIT)
select collation(concat(convert("abc" using gb18030), convert("cde" using sjis))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (gb18030_chinese_ci,IMPLICIT), (sjis_japanese_ci,IMPLICIT)
select collation(concat(convert("abc" using utf8), convert("cde" using sjis))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf8mb4_general_ci |
+--------------------+
select collation(concat(convert("abc" using utf16), convert("cde" using sjis))) as combined_string from dual;
+------------------+
| combined_string  |
+------------------+
| utf16_general_ci |
+------------------+
select collation(concat(convert("abc" using tis620), convert("cde" using sjis))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (tis620_thai_ci,IMPLICIT), (sjis_japanese_ci,IMPLICIT)
select collation(concat(convert("abc" using latin1), convert("cde" using sjis))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (latin1_swedish_ci,IMPLICIT), (sjis_japanese_ci,IMPLICIT)
select collation(concat(convert("abc" using ascii), convert("cde" using sjis))) as combined_string from dual;
+------------------+
| combined_string  |
+------------------+
| sjis_japanese_ci |
+------------------+

