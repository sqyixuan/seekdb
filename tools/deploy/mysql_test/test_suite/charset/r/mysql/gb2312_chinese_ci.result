DROP TABLE t1;
CREATE TABLE t1 (
id INT AUTO_INCREMENT PRIMARY KEY,
category VARCHAR(255) CHARACTER SET gb2312 COLLATE gb2312_chinese_ci NOT NULL,
char_value VARCHAR(255) CHARACTER SET gb2312 COLLATE gb2312_chinese_ci NOT NULL
);
