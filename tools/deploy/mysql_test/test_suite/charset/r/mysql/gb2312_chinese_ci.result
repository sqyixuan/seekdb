DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
id INT AUTO_INCREMENT PRIMARY KEY,
str VARCHAR(255) CHARACTER SET gb2312 COLLATE gb2312_chinese_ci NOT NULL
);
INSERT INTO t1 (str) VALUES
('这是一个测试字符串，包含一些特殊汉字：埃，瓣，秉，渤，凑，傣，蝶，鼎，氟，以及组合字符：x埃，x瓣，x秉，x渤，x凑，x傣，x蝶，x鼎，x氟.'),
('只是一段不含特殊汉字的普通文本。');
