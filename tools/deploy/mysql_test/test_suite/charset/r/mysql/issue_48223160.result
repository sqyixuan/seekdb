result_format: 4
drop database if exists db1;
show variables like '%collation%';
Variable_name	Value
collation_connection	utf8mb4_general_ci
collation_database	utf8mb4_general_ci
collation_server	utf8mb4_general_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
create database db1 DEFAULT COLLATE = utf8mb4_bin;
create table db1.t1 (c1_issue_48223160 varchar(10));
select CHARACTER_SET_NAME, COLLATION_NAME from information_schema.columns where column_name = 'c1_issue_48223160';
+--------------------+----------------+
| CHARACTER_SET_NAME | COLLATION_NAME |
+--------------------+----------------+
| utf8mb4            | utf8mb4_bin    |
+--------------------+----------------+
drop database db1;

