================================================other case=================================================
drop database hkscs_db;
create database hkscs_db charset hkscs;
alter database hkscs_db charset hkscs;
use hkscs_db;

drop database hkscs_db;

select collation(concat(convert("abc" using gb18030_2022), convert("cde" using hkscs))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (gb18030_2022_chinese_ci,IMPLICIT), (hkscs_bin,IMPLICIT)
select collation(concat(convert("abc" using gb18030), convert("cde" using hkscs))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (gb18030_chinese_ci,IMPLICIT), (hkscs_bin,IMPLICIT)
select collation(concat(convert("abc" using utf8), convert("cde" using hkscs))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf8mb4_general_ci |
+--------------------+
select collation(concat(convert("abc" using utf16), convert("cde" using hkscs))) as combined_string from dual;
+------------------+
| combined_string  |
+------------------+
| utf16_general_ci |
+------------------+
select collation(concat(convert("abc" using tis620), convert("cde" using hkscs))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (tis620_thai_ci,IMPLICIT), (hkscs_bin,IMPLICIT)
select collation(concat(convert("abc" using latin1), convert("cde" using hkscs))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (latin1_swedish_ci,IMPLICIT), (hkscs_bin,IMPLICIT)
select collation(concat(convert("abc" using ascii), convert("cde" using hkscs))) as combined_string from dual;
+-----------------+
| combined_string |
+-----------------+
| hkscs_bin       |
+-----------------+

