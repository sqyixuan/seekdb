drop table if exists xiaoni_t1, xiaoni_t2, xiaoni_t3;
================ sum(timestamp) ================
create table xiaoni_t1 (id int primary key, c1 timestamp);
insert into xiaoni_t1 values (1, "1991-09-22 21:30:00");
insert into xiaoni_t1 values (2, "1992-09-22 21:30:00");
insert into xiaoni_t1 values (3, "1993-09-22 21:30:00");
select sum(c1) from xiaoni_t1;
sum(c1)
59762766639000
================ timestamp default ================
create table xiaoni_t2 (id int primary key, c1 timestamp, c2 timestamp, c3 timestamp);
desc xiaoni_t2;
Field	Type	Null	Key	Default	Extra
id	int(11)	NO	PRI	NULL	
c1	timestamp	NO		CURRENT_TIMESTAMP	ON UPDATE CURRENT_TIMESTAMP
c2	timestamp	NO		0000-00-00 00:00:00	
c3	timestamp	NO		0000-00-00 00:00:00	
