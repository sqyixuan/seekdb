select ip2int(10);
ip2int(10)
NULL
================ number2int ================
create table xiaoni_t3(a int primary key, b bigint);
insert into xiaoni_t3 values(1,0.4);
insert into xiaoni_t3 values(2,0.5);
insert into xiaoni_t3 values(3,0.6);
insert into xiaoni_t3 values(4,1.6);
insert into xiaoni_t3 values(5,1.5);
insert into xiaoni_t3 values(6,1.2);
select * from xiaoni_t3;
a	b
1	0
2	1
3	1
4	2
5	2
6	1
