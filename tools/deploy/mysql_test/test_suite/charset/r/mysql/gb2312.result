drop table if exists `表1`;
CREATE TABLE `表1` (`列` char(100), INDEX(`列`)) DEFAULT CHARSET = gb2312;
LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/general.dat' INTO TABLE `表1` CHARACTER SET gb2312;
