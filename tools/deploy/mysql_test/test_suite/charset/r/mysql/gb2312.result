drop table if exists gb2312;
create table gb2312(v varchar(10)) character set gb2312;
select _gb2312 '啊';
啊

INSERT INTO gb2312(v) VALUES('、');
INSERT INTO gb2312(v) VALUES('啊');
INSERT INTO gb2312(v) VALUES('あ');
INSERT INTO gb2312(v) VALUES('ㄅ');
INSERT INTO gb2312(v) VALUES('啊');
INSERT INTO gb2312(v) VALUES('齄');
INSERT INTO gb2312(v) VALUES('鼾');
INSERT INTO gb2312(v) VALUES('髯');
INSERT INTO gb2312(v) VALUES('拽');
alter table gb2312 convert to character set gb2312 collate gb2312_bin;
select v, hex(v), hex(weight_string(v)) as hex_weight, conv(hex(weight_string(v)), 16, 10) from gb2312;
