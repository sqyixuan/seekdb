CREATE TABLE t1 (
id INT AUTO_INCREMENT PRIMARY KEY,
text_column VARCHAR(255) CHARACTER SET gb2312 NOT NULL
);
INSERT INTO t1 (text_column) VALUES
('This is a plain string'),
('This is a string with special characters: 啊啊啊, ああ, ㄅㄅ, 髯髯髯髯, 拽, 齄'),
(''),
('啊啊啊, ああ, ㄅㄅ, 髯髯髯髯, 拽, 齄'),
('Another string with special characters: Б, ббб, ┎, ╊');
