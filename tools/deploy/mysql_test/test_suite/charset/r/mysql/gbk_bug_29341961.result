result_format: 4
drop table if exists deergbk;
CREATE TABLE `deergbk` (
  `name` varchar(20) NOT NULL,
  PRIMARY KEY (`name`)
) DEFAULT CHARSET = gbk;
insert into deergbk values('123');
insert into deergbk values('56');
insert into deergbk values('寮犱笁');
insert into deergbk values('鏉庡洓');
insert into deergbk values('鐜嬩簲');
select * from deergbk order by name;
+--------+
| name   |
+--------+
| 123    |
| 56     |
| 鏉庡洓   |
| 鐜嬩簲   |
| 寮犱笁   |
+--------+
select * from deergbk where name = '寮犱笁';
+--------+
| name   |
+--------+
| 寮犱笁   |
+--------+
select * from deergbk where name < '寮犱笁';
+--------+
| name   |
+--------+
| 123    |
| 56     |
| 鏉庡洓   |
| 鐜嬩簲   |
+--------+
select * from deergbk where name > '123' and name <= '寮犱笁';
+--------+
| name   |
+--------+
| 56     |
| 鏉庡洓   |
| 鐜嬩簲   |
| 寮犱笁   |
+--------+
select * from deergbk where name <= '56' and name >= '123';
+------+
| name |
+------+
| 123  |
| 56   |
+------+

drop table deergbk;

