drop table if exists t1;
create table t1(c1 varchar(2) character set utf8 collate utf8_general_ci primary key,c2 varchar(10));
replace into t1 (c1,c2) values ('1','first');
replace into t1 (c1,c2) values (_binary'1','second');
replace into t1 (c1,c2) values (_utf8'1'collate utf8_bin,'second');
select * from t1;
c1	c2
1	second
select replace(_utf8'abcv'collate utf8_general_ci,_utf8'BC'collate utf8_general_ci,_utf8'nan' collate utf8_general_ci);
replace(_utf8'abcv'collate utf8_general_ci,_utf8'BC'collate utf8_general_ci,_utf8'nan' collate utf8_general_ci)
abcv
select replace(_binary'abcv',_binary'bc',_binary'nan');
replace(_binary'abcv',_binary'bc',_binary'nan')
ananv
