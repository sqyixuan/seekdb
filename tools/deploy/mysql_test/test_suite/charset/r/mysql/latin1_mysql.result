# create table for test
result_format: 4
create table latin1_table(c1 char(1) character set latin1);

create procedure build_latin1_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into latin1_table values(unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_latin1_table();
/


SELECT c1,
  hex(c1),
  hex(@u:=convert(c1 using utf8))
  FROM latin1_table;
