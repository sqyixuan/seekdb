drop table if exists latin1_table;
drop procedure if exists build_latin1_table;

padding rule test
drop table t1;
create table t1(`a` text CHARACTER SET latin1);
insert into t1 values ('a'), ('a '), ('a\t'),('a  ');
select a,collation(a),hex(a) from t1 order by a;
+------+-------------------+--------+
| a    | collation(a)      | hex(a) |
+------+-------------------+--------+
| a	   | latin1_swedish_ci | 6109   |
| a    | latin1_swedish_ci | 61     |
| a    | latin1_swedish_ci | 6120   |
| a    | latin1_swedish_ci | 612020 |
+------+-------------------+--------+
drop table t1;

test uppper/lower
SELECT lower('Aliyun');
+-----------------+
| lower('Aliyun') |
+-----------------+
| aliyun          |
+-----------------+
SELECT upper('Aliyun');
+-----------------+
| upper('Aliyun') |
+-----------------+
| ALIYUN          |
+-----------------+

test insert chinese character 
set names utf8;
CREATE TABLE t1 (c1 VARCHAR(255)) default CHARACTER SET latin1;
INSERT INTO t1 VALUES('张三');
ERROR HY000: Incorrect string value

test weight_string 
set names latin1;
select hex(weight_string('a'));
+-------------------------+
| hex(weight_string('a')) |
+-------------------------+
| 41                      |
+-------------------------+

test latin1 parameterize bug 
drop table t1;
create table t1(i0 int,i1 int,i2 int);
set names latin1;
alter system flush plan cache;
select /*+no_rewrite*/ * from t1 where 1=1 and 1*3;
select /*+no_rewrite*/ * from t1 where 1=2 and 3*6;
select /*+no_rewrite*/ * from t1 where 3=1 and 5*3;
select /*+no_rewrite*/ * from t1 where  !2 and !3;
select /*+no_rewrite*/ * from t1 where  !2 and !3;
SELECT a0.i0 + 10+a1.i0 + 100*a2.i0, (a0.i0/-2 + ~10*a1.i0 + 100/a2.i0) % 50, a0.i0 + 10*a1.i0 + 100*a2.i0 FROM t1 AS a0, t1 AS a1, t1 AS a2 where 1&&1 and 1|1;
select hit_count, query_sql, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+no_rewrite*/ * from t1%' or statement like '%SELECT a0.i0%';
+-----------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------+------------------------------------------------------------------------------------------------------------------------------------------------------+
| hit_count | query_sql                                                                                                                                                       | statement                                                                                                                                            |
+-----------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------+------------------------------------------------------------------------------------------------------------------------------------------------------+
|         2 | select /*+no_rewrite*/ * from t1 where 1=1 and 1*3                                                                                                              | select /*+no_rewrite*/ * from t1 where ?=? and ?*?                                                                                                   |
|         1 | select /*+no_rewrite*/ * from t1 where  !2 and !3                                                                                                               | select /*+no_rewrite*/ * from t1 where  !? and !?                                                                                                    |
|         0 | SELECT a0.i0 + 10+a1.i0 + 100*a2.i0, (a0.i0/-2 + ~10*a1.i0 + 100/a2.i0) % 50, a0.i0 + 10*a1.i0 + 100*a2.i0 FROM t1 AS a0, t1 AS a1, t1 AS a2 where 1&&1 and 1|1 | SELECT a0.i0 + ?+a1.i0 + ?*a2.i0, (a0.i0/? + ~?*a1.i0 + ?/a2.i0) % ?, a0.i0 + ?*a1.i0 + ?*a2.i0 FROM t1 AS a0, t1 AS a1, t1 AS a2 where ?&&? and ?|? |
+-----------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------+------------------------------------------------------------------------------------------------------------------------------------------------------+
alter system flush plan cache;
set names utf8;

test space padding, expect 'abc' == 'abc  '
drop table t1;
create table t1(c1 char(5) charset latin1 collate latin1_bin);
insert into t1 values ('abc');
select hex(c1) from t1;
+---------+
| hex(c1) |
+---------+
| 616263  |
+---------+
select * from t1 where c1 = 'abc';
+------+
| c1   |
+------+
| abc  |
+------+
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select hex(c1) from t1;
+------------+
| hex(c1)    |
+------------+
| 6162632020 |
+------------+
select * from t1 where c1 = 'abc';
+-------+
| c1    |
+-------+
| abc   |
+-------+
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";

drop table t1;
create table t1(c1 varchar(5) charset latin1 collate latin1_bin);
insert into t1 values ('abc');
select hex(c1) from t1;
+---------+
| hex(c1) |
+---------+
| 616263  |
+---------+
select * from t1 where c1 = 'abc';
+------+
| c1   |
+------+
| abc  |
+------+
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select hex(c1) from t1;
+---------+
| hex(c1) |
+---------+
| 616263  |
+---------+
select * from t1 where c1 = 'abc';
+------+
| c1   |
+------+
| abc  |
+------+
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";

test hash sort, expect 'abc' == 'abc  '
drop table t1;
create table t1(c1 varchar(5) charset latin1 collate latin1_bin);
insert into t1 values ('abc');
insert into t1 values ('abc  ');
select hex(c1) from t1;
+------------+
| hex(c1)    |
+------------+
| 616263     |
| 6162632020 |
+------------+
select c1 from t1 where c1 = 'abc';
+-------+
| c1    |
+-------+
| abc   |
| abc   |
+-------+
select distinct c1 from t1 where c1 = 'abc';
+------+
| c1   |
+------+
| abc  |
+------+

set names binary;
drop table t1;
create table t1(c1 char(100)) character set latin1 collate latin1_bin partition by key(c1)partitions 3;
insert into t1 values ('฿ Bs Br       ');
when in mysql mode, trailing space will be ignore 
insert into t1 values (' ');
select hex(c1) from t1;
+--------------------+
| hex(c1)            |
+--------------------+
| E0B8BF204273204272 |
|                    |
+--------------------+
set names utf8;
drop table t1;

test instr
set names latin1;
select 'abc' like 'ABC';
+------------------+
| 'abc' like 'ABC' |
+------------------+
|                1 |
+------------------+
select instr('XABC','abc');
+---------------------+
| instr('XABC','abc') |
+---------------------+
|                   2 |
+---------------------+
set names utf8;

bug2024082100104201510
drop table test;
set sql_mode = 'pad_char_to_full_length';
create table test(c1 bigint primary key, c2 bigint, c3 bigint) character set = latin1;
insert into test values(1, 1, 1);
Alter table test drop column c3;
Alter table test add c3 char(33) not null default '3';
Alter table test drop primary key;
drop table test;
