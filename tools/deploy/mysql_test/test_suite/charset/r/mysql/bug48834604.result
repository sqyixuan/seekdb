result_format: 4
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
create table t1 (co1 varchar(10) default '中文') charset gbk;

show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `co1` varchar(10) DEFAULT '中文'
) ORGANIZATION INDEX DEFAULT CHARSET = gbk COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10

create table t2(a varchar(123) charset utf8);
insert into t2 values('12he12');
insert into t2 values('%he%');
select * from t2 where a like '%%he%%' escape '%';
+------+
| a    |
+------+
| %he% |
+------+

create table t3(a varchar(123) charset utf16);
insert into t3 values('12he12');
insert into t3 values('%he%');
select * from t3 where a like '%%he%%' escape '%';
+------+
| a    |
+------+
| %he% |
+------+

select replace(convert('石碶街道' using gbk), 0x5C, '\\\\');
+----------------------------------------------------------+
| replace(convert('石碶街道' using gbk), 0x5C, '\\\\')     |
+----------------------------------------------------------+
| 石碶街道                                                 |
+----------------------------------------------------------+

drop table if exists table1;
drop table if exists table2;
create table table1 (
  id int,
  col_tinytext tinytext,
  col_text text,
  col_mediumtext mediumtext,
  col_longtext longtext,
  col_tinyblob tinyblob,
  index idx3 (col_tinytext(3)),
  index idx4 (col_text(3)),
  index idx5 (col_mediumtext(3)),
  index idx6 (col_longtext(3)),
  index idx9 (col_tinyblob(3)));

INSERT INTO table1 VALUES (12,'col_tinytext1','col_text1','col_mediumtext1','col_longtext1','col_tinyblob1');
INSERT INTO table1 VALUES (13,'col%tinytext1','col%text1','col%mediumtext1','col%longtext1','col%tinyblob1');

select id,col_tinytext from table1 where col_tinytext like '%l%%t%' escape '%' order by 1,2;
+------+--------------+
| id   | col_tinytext |
+------+--------------+
+------+--------------+
select id,col_text from table1 where col_text like '%l%%t%' escape '%' order by 1,2;
+------+----------+
| id   | col_text |
+------+----------+
+------+----------+
select id,col_mediumtext from table1 where col_mediumtext like '%l%%t%' escape '%' order by 1,2;
+------+----------------+
| id   | col_mediumtext |
+------+----------------+
+------+----------------+
select id,col_longtext from table1 where col_longtext like '%l%%t%' escape '%' order by 1,2;
+------+--------------+
| id   | col_longtext |
+------+--------------+
+------+--------------+
select id,col_tinyblob from table1 where col_tinyblob like '%l%%t%' escape '%' order by 1,2;
+------+--------------+
| id   | col_tinyblob |
+------+--------------+
+------+--------------+

create table table2 (
  id int,
  col_varbinary varbinary(20),
  index idx8 (col_varbinary(3))
);
INSERT INTO table2 VALUES (12,'col_varbinary');
INSERT INTO table2 VALUES (13,'col%varbinary');

select col_varbinary from table2 where col_varbinary like '%l__v%' escape '_';
+---------------+
| col_varbinary |
+---------------+
| col_varbinary |
+---------------+
explain select col_varbinary from table2 where col_varbinary like '%l__v%' escape '_';
Query Plan
========================================================
|ID|OPERATOR        |NAME        |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------
|0 |TABLE RANGE SCAN|table2(idx8)|2       |10          |
========================================================
Outputs & filters:
-------------------------------------
  0 - output([table2.col_varbinary]), filter([(T_OP_LIKE, table2.col_varbinary, cast('%l__v%', VARCHAR(1048576)), '_')]), rowset=16
      access([table2.__pk_increment], [table2.col_varbinary]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false], 
      range_key([table2.__substr3_17], [table2.__pk_increment]), range(,MIN ; <FF><repeat 3 times>,MAX), 
      range_cond([(T_OP_LIKE, table2.__substr3_17, prefix_pattern(cast('%l__v%', VARCHAR(1048576)), 3, '_'), '_')])

