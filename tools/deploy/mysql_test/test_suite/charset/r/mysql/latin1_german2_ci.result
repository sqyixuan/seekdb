id INT AUTO_INCREMENT PRIMARY KEY,
category VARCHAR(255) CHARACTER SET latin1 COLLATE latin1_german2_ci NOT NULL,
char_value VARCHAR(255) CHARACTER SET latin1 COLLATE latin1_german2_ci NOT NULL
);
