create procedure build_tis620_bin_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<128
  DO
      insert into tis620_bin_table values(unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_tis620_bin_table();
/

