================================================other case=================================================
drop database tis620_db;
create database tis620_db charset tis620;
alter database tis620_db charset tis620;
use tis620_db;
create table t1(c1 char(1)) charset tis620 collate tis620_thai_ci;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` char(1) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = tis620 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
alter table t1 charset=tis620;
alter table t1 modify c1 char(1) CHARACTER SET tis620 collate tis620_bin;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` char(1) CHARACTER SET tis620 COLLATE tis620_bin DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = tis620 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0

