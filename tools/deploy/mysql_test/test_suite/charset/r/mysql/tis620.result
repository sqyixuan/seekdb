result_format: 4
===================================================test basic code ==================================================
drop table tis620_table;
drop procedure build_tis620_table;
drop table tis620_bin_table;
drop procedure build_tis620_bin_table;
create table tis620_table(c1 char(3) charset tis620 collate tis620_thai_ci);
create table tis620_bin_table(c1 char(3) charset tis620 collate tis620_bin);

create procedure build_tis620_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into tis620_table values(unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_tis620_table();
/
