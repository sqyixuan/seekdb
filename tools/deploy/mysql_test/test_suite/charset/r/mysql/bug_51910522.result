result_format: 4
select cast('我' as nchar);
+----------------------+
| cast('我' as nchar)  |
+----------------------+
| 我                   |
+----------------------+
select cast('我' as national char);
+------------------------------+
| cast('我' as national char)  |
+------------------------------+
| 我                           |
+------------------------------+
select cast('我' as nchar(10));
+--------------------------+
| cast('我' as nchar(10))  |
+--------------------------+
| 我                       |
+--------------------------+
select cast('我' as national char(10));
+----------------------------------+
| cast('我' as national char(10))  |
+----------------------------------+
| 我                               |
+----------------------------------+

select cast(_GBK'我' as nchar);
+--------------------------+
| cast(_GBK'我' as nchar)  |
+--------------------------+
| 鎴                       |
+--------------------------+
Warnings:
Warning	1300	Invalid gbk character string: '91'
select hex(cast(_GBK'我' as nchar));
