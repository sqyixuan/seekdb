drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
create table t2 (c0 char(10) charset utf8mb4, c1 nchar(10), c2 NATIONAL CHARACTER(10), c3 NVARCHAR(10), c4 NATIONAL VARCHAR(10), c5 NATIONAL CHARACTER VARYING(10), c6 NATIONAL CHAR VARYING(10), c7 NCHAR VARCHAR(10)) default charset gbk;
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `c0` char(10) CHARACTER SET utf8mb4 DEFAULT NULL,
  `c1` char(10) CHARACTER SET utf8mb4 DEFAULT NULL,
  `c2` char(10) CHARACTER SET utf8mb4 DEFAULT NULL,
  `c3` varchar(10) CHARACTER SET utf8mb4 DEFAULT NULL,
  `c4` varchar(10) CHARACTER SET utf8mb4 DEFAULT NULL,
  `c5` varchar(10) CHARACTER SET utf8mb4 DEFAULT NULL,
  `c6` varchar(10) CHARACTER SET utf8mb4 DEFAULT NULL,
  `c7` varchar(10) CHARACTER SET utf8mb4 DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = gbk ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
