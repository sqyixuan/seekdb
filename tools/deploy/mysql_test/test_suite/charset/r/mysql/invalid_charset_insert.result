result_format: 4
drop table if exists t1;
create table t1 (c1 int primary key, c2 char(20) collate utf8mb4_general_ci, c3 varchar(20)  collate utf8mb4_general_ci);

set sql_mode = 'STRICT_ALL_TABLES';
insert into t1 (c1, c2, c3) values (1, 'a', 'b');
insert into t1 (c1, c2, c3) values (2, x'adaa', 'b');
ERROR HY000: Incorrect string value
insert into t1 (c1, c2, c3) values (3, 'a', x'adaa');
ERROR HY000: Incorrect string value
update t1 set c2 = x'adaa' where c1 = 1;
ERROR HY000: Incorrect string value

set sql_mode = '';

insert into t1 (c1, c2, c3) values (4, x'adaa', 'b');
insert into t1 (c1, c2, c3) values (5, 'a', x'adaa');
insert into t1 (c1, c2, c3) values (6, x'c3a4adaa', x'c3a4adaa');
update t1 set c2 = x'adaa' where c1 = 1;

select c1, c2, length(c2), hex(c2), c3, length(c3), hex(c3) from t1;
+----+------+------------+---------+------+------------+---------+
| c1 | c2   | length(c2) | hex(c2) | c3   | length(c3) | hex(c3) |
+----+------+------------+---------+------+------------+---------+
|  1 |      |          0 |         | b    |          1 | 62      |
|  4 |      |          0 |         | b    |          1 | 62      |
|  5 | a    |          1 | 61      |      |          0 |         |
|  6 | ä    |          2 | C3A4    | ä    |          2 | C3A4    |
+----+------+------------+---------+------+------------+---------+

