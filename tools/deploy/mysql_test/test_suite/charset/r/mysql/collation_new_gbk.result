set names gbk;
select _gbk 'abc' collate gbk_chinese_ci;
_gbk 'abc' collate gbk_chinese_ci
abc
select coercibility(_gbk 'abc');
coercibility(_gbk 'abc')
4
select coercibility(_gbk 'abc' collate gbk_chinese_ci);
coercibility(_gbk 'abc' collate gbk_chinese_ci)
0
select coercibility('abc' collate gbk_chinese_ci);
coercibility('abc' collate gbk_chinese_ci)
0
set @abc=_gbk 'abc' collate gbk_chinese_ci;
select coercibility(@abc);
coercibility(@abc)
2
drop table if exists coll_table;
create table coll_table(c1 varchar(10) collate gbk_chinese_ci, c2 varchar(10) collate gbk_bin, c3 varchar(10) collate gbk_chinese_ci, primary key(c1));
show create table coll_table;
Table	Create Table
coll_table	CREATE TABLE `coll_table` (
  `c1` varchar(10) CHARACTER SET gbk NOT NULL,
  `c2` varchar(10) CHARACTER SET gbk COLLATE gbk_bin DEFAULT NULL,
  `c3` varchar(10) CHARACTER SET gbk DEFAULT NULL,
  PRIMARY KEY (`c1`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
insert into coll_table value('a', 'A', 'A'), ('b', 'B', 'a'), ('c', 'a', 'B');
select * from coll_table;
c1	c2	c3
a	A	A
b	B	a
c	a	B
select c2 from coll_table order by c2;
c2
A
B
a
select c2 from coll_table order by c2 collate gbk_chinese_ci;
c2
A
a
B
select c2 collate gbk_chinese_ci AS cc from coll_table order by cc;
cc
A
a
B
select c2, max(c3) from coll_table group by c2;
c2	max(c3)
A	A
B	a
a	B
select c2, max(c3) from coll_table group by c2 collate gbk_chinese_ci;
c2	max(c3)
A	B
B	a
select max(c2) from coll_table;
max(c2)
a
select max(c2 collate gbk_chinese_ci) from coll_table;
max(c2 collate gbk_chinese_ci)
B
select distinct c2 from coll_table;
c2
A
B
a
select distinct c2 collate gbk_chinese_ci from coll_table;
c2 collate gbk_chinese_ci
A
B
select * from coll_table where c1 > c3;
c1	c2	c3
b	B	a
c	a	B
select * from coll_table where c1 > c2;
c1	c2	c3
a	A	A
b	B	a
c	a	B
select * from coll_table where c2 collate gbk_chinese_ci > c3 collate gbk_chinese_ci;
c1	c2	c3
b	B	a
select * from coll_table where c2 collate gbk_bin > c3 collate gbk_bin;
c1	c2	c3
c	a	B
select * from coll_table group by c2 having c2 = 'a' collate gbk_chinese_ci;
c1	c2	c3
a	A	A
c	a	B
(select c3 from coll_table) union (select c3 from coll_table);
c3
A
B
drop table coll_table;
