set @@session.explicit_defaults_for_timestamp=off;
drop table if exists t_collation_test;
create table t_collation_test(c1 varchar(100) collate utf8mb4_unicode_ci);
insert into t_collation_test values('abc');
PREPARE pr1 FROM 'select * from t_collation_test where c1 = ?';
PREPARE pr2 FROM 'select collation(?), COERCIBILITY(?) from dual';
set @a = 'abc';
select collation(@a), COERCIBILITY(@a) from dual;
collation(@a)	COERCIBILITY(@a)
utf8mb4_general_ci	2
EXECUTE pr1 USING @a;
c1
abc
EXECUTE pr2 USING @a, @a;
collation(?)	COERCIBILITY(?)
utf8mb4_general_ci	4
drop table t_collation_test;
