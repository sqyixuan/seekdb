drop table if exists test2;
drop table if exists test3;
drop table if exists t1;
drop table if exists t2;
drop table if exists vietnamese_test;
drop table if exists collation_test;
drop database if exists db;
show collation like "utf8mb4_0900_ai_ci";
Collation	Charset	Id	Default	Compiled	Sortlen
utf8mb4_0900_ai_ci	utf8mb4	255		Yes	0
=========================test ordering&where ===========================================
create table test(c1 varchar(100), c2 int) collate=utf8mb4_0900_ai_ci;
insert into test values('ß', 1), ('s', 2), ('ss', 3);
insert into test values('cafe', 4), ('caff', 5), ('café', 6);
select * from test where c1='ß';
c1	c2
ß	1
ss	3
select * from test where c1 like '%ß%';
c1	c2
ß	1
select sum(c2) from test group by c1;
sum(c2)
4
2
10
5
select * from test order by c1;
c1	c2
cafe	4
café	6
caff	5
s	2
ß	1
ss	3
update test set c2 = 100 where c1 = 'ß';
select * from test;
c1	c2
ß	100
s	2
ss	100
cafe	4
caff	5
café	6
