######################## 不同level行为测试  ########################
##1 No collation Concatenation of strings with different collations

SELECT COERCIBILITY(_utf8mb4'A' COLLATE utf8mb4_bin);
+-----------------------------------------------+
| COERCIBILITY(_utf8mb4'A' COLLATE utf8mb4_bin) |
+-----------------------------------------------+
|                                             0 |
+-----------------------------------------------+
select collation(concat(c1, c2)) as collation, coercibility(concat(c1, c2)) from utf8_table;
+-------------+------------------------------+
| collation   | coercibility(concat(c1, c2)) |
+-------------+------------------------------+
| utf8mb4_bin |                            1 |
+-------------+------------------------------+
SELECT COERCIBILITY(c1) from utf8_table;
+------------------+
| COERCIBILITY(c1) |
+------------------+
|                2 |
+------------------+
SELECT COERCIBILITY(VERSION());
+-------------------------+
| COERCIBILITY(VERSION()) |
+-------------------------+
|                       3 |
+-------------------------+
SELECT COERCIBILITY('A');
+-------------------+
| COERCIBILITY('A') |
+-------------------+
|                 4 |
+-------------------+
SELECT COERCIBILITY(1000);
+--------------------+
| COERCIBILITY(1000) |
+--------------------+
|                  5 |
+--------------------+
SELECT COERCIBILITY(NULL);
+--------------------+
| COERCIBILITY(NULL) |
+--------------------+
|                  6 |
+--------------------+

###### 比较操作禁止LEVEL_NONE
select strcmp(c1,c2) from utf8_table;
ERROR HY000: Illegal mix of collations (utf8mb4_unicode_ci,IMPLICIT), (utf8mb4_general_ci,IMPLICIT)
select c1=c2 from utf8_table;
ERROR HY000: Illegal mix of collations (utf8mb4_unicode_ci,IMPLICIT), (utf8mb4_general_ci,IMPLICIT)
select 1 from utf8_table where c1 < c2;
ERROR HY000: Illegal mix of collations (utf8mb4_unicode_ci,IMPLICIT), (utf8mb4_general_ci,IMPLICIT)

select COLLATION(concat(_ascii 'abce' collate ascii_bin, _utf8mb4 'C28F' collate utf8mb4_general_ci ));
ERROR HY000: Illegal mix of collations (ascii_bin,EXPLICIT), (utf8mb4_general_ci,EXPLICIT)
select COLLATION(concat(_utf8mb4'a' ,_ascii 'a' collate ascii_general_ci )),
       COERCIBILITY(concat(_utf8mb4'a' ,_ascii 'a' collate ascii_general_ci ));
+----------------------------------------------------------------------+-------------------------------------------------------------------------+
| COLLATION(concat(_utf8mb4'a' ,_ascii 'a' collate ascii_general_ci )) | COERCIBILITY(concat(_utf8mb4'a' ,_ascii 'a' collate ascii_general_ci )) |
+----------------------------------------------------------------------+-------------------------------------------------------------------------+
| ascii_general_ci                                                     |                                                                       0 |
+----------------------------------------------------------------------+-------------------------------------------------------------------------+
select COLLATION(concat(c1 ,_ascii 'a' collate ascii_general_ci )),
       COERCIBILITY(concat(c1,_ascii 'a' collate ascii_general_ci )) from utf8_table;
ERROR HY000: Illegal mix of collations (utf8mb4_unicode_ci,IMPLICIT), (ascii_general_ci,EXPLICIT)
