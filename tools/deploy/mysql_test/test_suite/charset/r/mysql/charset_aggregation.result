######################## 相同字符集不同序  ########################
select collation(concat(a.c0, b.c0)) as collation, coercibility(concat(a.c0, b.c0)) from non_bin_coll a, bin_coll b;
+-----------+----------------------------------+
| collation | coercibility(concat(a.c0, b.c0)) |
+-----------+----------------------------------+
| binary    |                                2 |
+-----------+----------------------------------+
select collation(concat(a.c1, b.c1)) as collation, coercibility(concat(a.c1, b.c1)) from non_bin_coll a, bin_coll b;
+-------------+----------------------------------+
| collation   | coercibility(concat(a.c1, b.c1)) |
+-------------+----------------------------------+
| utf8mb4_bin |                                2 |
+-------------+----------------------------------+
select collation(concat(a.c2, b.c2)) as collation, coercibility(concat(a.c2, b.c2)) from non_bin_coll a, bin_coll b;
+-----------+----------------------------------+
| collation | coercibility(concat(a.c2, b.c2)) |
+-----------+----------------------------------+
| ascii_bin |                                2 |
+-----------+----------------------------------+
select collation(concat(a.c3, b.c3)) as collation, coercibility(concat(a.c3, b.c3)) from non_bin_coll a, bin_coll b;
+-----------+----------------------------------+
| collation | coercibility(concat(a.c3, b.c3)) |
+-----------+----------------------------------+
| gbk_bin   |                                2 |
+-----------+----------------------------------+
select collation(concat(a.c4, b.c4)) as collation, coercibility(concat(a.c4, b.c4)) from non_bin_coll a, bin_coll b;
+-------------+----------------------------------+
| collation   | coercibility(concat(a.c4, b.c4)) |
+-------------+----------------------------------+
| gb18030_bin |                                2 |
+-------------+----------------------------------+
select collation(concat(a.c5, b.c5)) as collation, coercibility(concat(a.c5, b.c5)) from non_bin_coll a, bin_coll b;
+------------+----------------------------------+
| collation  | coercibility(concat(a.c5, b.c5)) |
+------------+----------------------------------+
| latin1_bin |                                2 |
+------------+----------------------------------+
select collation(concat(a.c6, b.c6)) as collation, coercibility(concat(a.c6, b.c)) from non_bin_coll a, bin_coll b;
+------------+---------------------------------+
| collation  | coercibility(concat(a.c6, b.c)) |
+------------+---------------------------------+
| tis620_bin |                               2 |
+------------+---------------------------------+

select collation(concat(c1, c2)) as collation, coercibility(concat(c1, c2)) from utf8_table;
+-------------+------------------------------+
| collation   | coercibility(concat(c1, c2)) |
+-------------+------------------------------+
| utf8mb4_bin |                            1 |
+-------------+------------------------------+
