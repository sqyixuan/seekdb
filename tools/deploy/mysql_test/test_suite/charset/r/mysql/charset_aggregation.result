ERROR HY000: Illegal mix of collations (utf8mb4_unicode_ci,IMPLICIT), (utf8mb4_general_ci,IMPLICIT)

DROP TABLE table001;
CREATE TABLE table001(
c1 INT UNSIGNED AUTO_INCREMENT,
c2 VARCHAR(101) CHARACTER SET gbk NOT NULL,
c3 VARCHAR(204) CHARACTER SET utf16 NOT NULL,
c4 CHAR(200) CHARACTER SET gbk,
c5 CHAR(200) CHARACTER SET utf16,
c6 varchar(300) generated always as(concat(c2,c4)),
PRIMARY KEY(c1)
)CHARSET=gbk;
insert into table001(c1,c2,c3,c4,c5)values(null,'中国','中国・米国・英国・フランス','China, the United Kingdom, France','Chine États-Unis Royaume-Uni France');
select collation(insert(c2, 3, 4, c3)), coercibility(insert(c2, 3, 4, c3)) from table001;
+---------------------------------+------------------------------------+
| collation(insert(c2, 3, 4, c3)) | coercibility(insert(c2, 3, 4, c3)) |
+---------------------------------+------------------------------------+
| utf16_general_ci                |                                  2 |
+---------------------------------+------------------------------------+
select collation(instr(c3, c2)), coercibility(instr(c3, c2)) from table001;
+--------------------------+-----------------------------+
| collation(instr(c3, c2)) | coercibility(instr(c3, c2)) |
+--------------------------+-----------------------------+
| binary                   |                           5 |
+--------------------------+-----------------------------+
select collation(replace(c2, '中国', 'フランス')), coercibility(replace(c2, '中国', 'フランス')) from table001;
+--------------------------------------------------+-----------------------------------------------------+
| collation(replace(c2, '中国', 'フランス'))       | coercibility(replace(c2, '中国', 'フランス'))       |
+--------------------------------------------------+-----------------------------------------------------+
| gbk_chinese_ci                                   |                                                   2 |
+--------------------------------------------------+-----------------------------------------------------+
######################## enable_old_charset_aggregation  ########################
set  _enable_old_charset_aggregation = true;
select collation(concat(c1,c2)),coercibility(concat(c1,c2)) from utf8_table;
ERROR HY000: Illegal mix of collations (utf8mb4_unicode_ci,IMPLICIT), (utf8mb4_general_ci,IMPLICIT)
select count(1) from utf8_table where c1=c2;
ERROR HY000: Illegal mix of collations (utf8mb4_unicode_ci,IMPLICIT), (utf8mb4_general_ci,IMPLICIT)
set  _enable_old_charset_aggregation = false;
select collation(concat(c1,c2)),coercibility(concat(c1,c2)) from utf8_table;
+--------------------------+-----------------------------+
| collation(concat(c1,c2)) | coercibility(concat(c1,c2)) |
+--------------------------+-----------------------------+
| utf8mb4_bin              |                           1 |
+--------------------------+-----------------------------+
select count(1) from utf8_table where c1=c2;
ERROR HY000: Illegal mix of collations (utf8mb4_unicode_ci,IMPLICIT), (utf8mb4_general_ci,IMPLICIT)
