drop table if exists t1;
create table t1(
sex varchar(10) comment 'зЂЪЭ',
CONSTRAINT t1_cons CHECK(sex='Фа' or sex='ХЎ')
);
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `sex` varchar(10) DEFAULT NULL COMMENT 'зЂЪЭ',
  CONSTRAINT `t1_cons` CHECK (((`sex` = 'Фа') or (`sex` = 'ХЎ')))
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
insert into t1 values ('ХЎ');
insert into t1 values ('Фа');
insert into t1 values (NULL);
select * from t1;
+------+
| sex  |
+------+
| ХЎ   |
| Фа   |
| NULL |
+------+
update t1 set sex = 'Фа' where sex is null;
select * from t1;
