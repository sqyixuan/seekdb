-------------------test lower/upper----------------------
SELECT lower(c1),upper(c1) FROM ascii_table where c1 = 'v';
+-----------+-----------+
| lower(c1) | upper(c1) |
+-----------+-----------+
| v         | V         |
| v         | V         |
+-----------+-----------+
SELECT lower(c1),upper(c1) FROM ascii_bin_table where c1 = 'v';
+-----------+-----------+
| lower(c1) | upper(c1) |
+-----------+-----------+
| v         | V         |
+-----------+-----------+

-------------------test padding rule----------------------
insert into ascii_table values ('a '), ('a\t'),('a  ');
select c1,collation(c1),hex(c1) from ascii_table where c1 like "%a%";
+------+------------------+---------+
| c1   | collation(c1)    | hex(c1) |
+------+------------------+---------+
| A    | ascii_general_ci | 41      |
| a    | ascii_general_ci | 61      |
| a    | ascii_general_ci | 61      |
| a	   | ascii_general_ci | 6109    |
| a    | ascii_general_ci | 61      |
+------+------------------+---------+
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
select c1, hex(c1) from ascii_table where c1 = 'a ';
+------+---------+
| c1   | hex(c1) |
+------+---------+
| A    | 41      |
| a    | 61      |
| a    | 61      |
| a    | 61      |
+------+---------+
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select c1, hex(c1) from ascii_table where c1 = 'a ';
+------+---------+
| c1   | hex(c1) |
+------+---------+
| A    | 412020  |
| a    | 612020  |
| a    | 612020  |
| a    | 612020  |
+------+---------+
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";

insert into ascii_bin_table values ('a '), ('a\t'),('a  ');
select c1,collation(c1),hex(c1) from ascii_bin_table where c1 like "%a%";
+------+---------------+---------+
| c1   | collation(c1) | hex(c1) |
+------+---------------+---------+
| a    | ascii_bin     | 61      |
| a    | ascii_bin     | 61      |
| a	   | ascii_bin     | 6109    |
| a    | ascii_bin     | 61      |
+------+---------------+---------+
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
select c1, hex(c1) from ascii_bin_table where c1 = 'a ';
+------+---------+
| c1   | hex(c1) |
+------+---------+
| a    | 61      |
| a    | 61      |
| a    | 61      |
+------+---------+
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select c1, hex(c1) from ascii_bin_table where c1 = 'a ';
+------+---------+
| c1   | hex(c1) |
+------+---------+
| a    | 612020  |
| a    | 612020  |
| a    | 612020  |
+------+---------+
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
-------------------test insert non-ascii character ----------------------
set names utf8mb4;
INSERT INTO ascii_table VALUES('张三');
ERROR HY000: Incorrect string value
INSERT INTO ascii_table VALUES(0xe5);
ERROR HY000: Incorrect string value

INSERT INTO ascii_bin_table VALUES('张三');
ERROR HY000: Incorrect string value
INSERT INTO ascii_bin_table VALUES(0xe5);
ERROR HY000: Incorrect string value

-------------------test charset function----------------------
select weight_string(_ascii 'a' collate ascii_general_ci), weight_string(_ascii 'A' collate ascii_general_ci);
+----------------------------------------------------+----------------------------------------------------+
| weight_string(_ascii 'a' collate ascii_general_ci) | weight_string(_ascii 'A' collate ascii_general_ci) |
+----------------------------------------------------+----------------------------------------------------+
| A                                                  | A                                                  |
+----------------------------------------------------+----------------------------------------------------+
select weight_string(_ascii 'a' collate ascii_bin), weight_string(_ascii 'A' collate ascii_bin);
+---------------------------------------------+---------------------------------------------+
| weight_string(_ascii 'a' collate ascii_bin) | weight_string(_ascii 'A' collate ascii_bin) |
+---------------------------------------------+---------------------------------------------+
| a                                           | A                                           |
+---------------------------------------------+---------------------------------------------+

set collation_connection = ascii_general_ci;
select 'abc' like 'ABC';
+------------------+
| 'abc' like 'ABC' |
+------------------+
|                1 |
+------------------+
select instr('XABCdfdabc','abc');
+---------------------------+
| instr('XABCdfdabc','abc') |
+---------------------------+
|                         2 |
+---------------------------+
set collation_connection = ascii_bin;
select 'abc' like 'ABC';
+------------------+
| 'abc' like 'ABC' |
+------------------+
|                0 |
+------------------+
select instr('XABCdfdabc','abc');
+---------------------------+
| instr('XABCdfdabc','abc') |
+---------------------------+
|                         8 |
+---------------------------+

SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM ascii_table where c1 = 'v';
+------+---------+---------------------------------+
| c1   | hex(c1) | hex(@u:=convert(c1 using utf8)) |
+------+---------+---------------------------------+
| V    | 56      | 56                              |
| v    | 76      | 76                              |
+------+---------+---------------------------------+
SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM ascii_bin_table where c1 = 'v';
+------+---------+---------------------------------+
| c1   | hex(c1) | hex(@u:=convert(c1 using utf8)) |
+------+---------+---------------------------------+
| v    | 76      | 76                              |
+------+---------+---------------------------------+

SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM ascii_table where c1 like '%v%';
+------+---------+---------------------------------+
| c1   | hex(c1) | hex(@u:=convert(c1 using utf8)) |
+------+---------+---------------------------------+
| V    | 56      | 56                              |
| v    | 76      | 76                              |
+------+---------+---------------------------------+
SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM ascii_bin_table where c1 like '%v%';
+------+---------+---------------------------------+
| c1   | hex(c1) | hex(@u:=convert(c1 using utf8)) |
+------+---------+---------------------------------+
| v    | 76      | 76                              |
+------+---------+---------------------------------+

