result_format: 4

===================================================test basic code ==================================================
drop table ascii_table;
drop procedure build_ascii_table;
drop table ascii_bin_table;
drop procedure build_ascii_bin_table;
create table ascii_table(c1 char(3) charset ascii collate ascii_general_ci);
create table ascii_bin_table(c1 char(3) charset ascii collate ascii_bin);

create procedure build_ascii_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<128
  DO
      insert into ascii_table values(unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_ascii_table();
/
SELECT c1,
  hex(c1),
  hex(@u:=convert(c1 using utf8))
