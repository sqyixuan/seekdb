SET NAMES UTF8;
set sql_mode = '';
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (a CHAR(1) CHARACTER SET utf16le);
INSERT INTO t1 VALUES (0xC000), (0xFF00),(0x00E0), (0xFFFF);
SELECT HEX(a), HEX(@a:=CONVERT(a USING utf8mb4)), HEX(CONVERT(@a USING utf16le)) FROM t1;
HEX(a)	HEX(@a:=CONVERT(a USING utf8mb4))	HEX(CONVERT(@a USING utf16le))
C000	C380	C380
FF00	C3BF	C3BF
00E0	EE8080	00EE8080
FFFF	EFBFBF	00EFBFBF
SELECT HEX(a), HEX(@a:=CONVERT(a USING utf8mb4)), HEX(CONVERT(@a USING utf16le)) FROM t1;
HEX(a)	HEX(@a:=CONVERT(a USING utf8mb4))	HEX(CONVERT(@a USING utf16le))
C000	C380	C000
FF00	C3BF	FF00
00E0	EE8080	00E0
FFFF	EFBFBF	FFFF
SELECT HEX(WEIGHT_STRING(_utf16le 0x00D801DC));
HEX(WEIGHT_STRING(_utf16le 0x00D801DC))
FFFD
SELECT HEX(WEIGHT_STRING(_utf16le 0x00D801DC collate utf16le_bin));
HEX(WEIGHT_STRING(_utf16le 0x00D801DC collate utf16le_bin))
010001
SELECT HEX(WEIGHT_STRING(_utf16 0xD800DC00));
HEX(WEIGHT_STRING(_utf16 0xD800DC00))
FFFD
SELECT HEX(WEIGHT_STRING(_utf16 0xD800DC00 collate utf16_bin));
HEX(WEIGHT_STRING(_utf16 0xD800DC00 collate utf16_bin))
010000
drop table t1;
