set names gbk;
drop table if exists t1;
create table t1(c1 varchar(2) character set gbk collate gbk_chinese_ci primary key,c2 varchar(10));
replace into t1 (c1,c2) values ('1','first');
replace into t1 (c1,c2) values (_binary'1','second');
replace into t1 (c1,c2) values (_gbk'1'collate gbk_bin,'second');
select * from t1;
c1	c2
1	second
select replace(_gbk'abcv'collate gbk_chinese_ci,_gbk'BC'collate gbk_chinese_ci,_gbk'nan' collate gbk_chinese_ci);
replace(_gbk'abcv'collate gbk_chinese_ci,_gbk'BC'collate gbk_chinese_ci,_gbk'nan' collate gbk_chinese_ci)
abcv
select replace(_binary'abcv',_binary'bc',_binary'nan');
replace(_binary'abcv',_binary'bc',_binary'nan')
ananv
