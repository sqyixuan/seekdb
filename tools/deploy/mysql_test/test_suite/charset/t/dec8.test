--echo variables setting
--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
--error 0,1051
drop table t3;
--echo strict mode and non-strict mode
CREATE TABLE t1(
  a CHAR(20) CHARACTER SET dec8,
  b VARCHAR(20) CHARACTER SET dec8,
  c TEXT(20) CHARACTER SET dec8
);
CREATE TABLE t2(
  a CHAR(20) CHARACTER SET dec8 COLLATE dec8_swedish_ci,
  b VARCHAR(20) CHARACTER SET dec8 COLLATE dec8_swedish_ci,
  c TEXT(20) CHARACTER SET dec8 COLLATE dec8_swedish_ci
);
CREATE TABLE t3(
  a CHAR(20) CHARACTER SET dec8 COLLATE dec8_bin,
  b VARCHAR(20) CHARACTER SET dec8 COLLATE dec8_bin,
  c TEXT(20) CHARACTER SET dec8 COLLATE dec8_bin
);

SET SQL_MODE="STRICT_TRANS_TABLES";
INSERT INTO t1 values(x'8142', x'8142', x'8142');
INSERT INTO t1 values(x'6162', x'6162', x'6162');
UPDATE t1 SET a=x'8243' where a=x'6162';
INSERT INTO t2 values(x'8142', x'8142', x'8142');
INSERT INTO t2 values(x'6162', x'6162', x'6162');
UPDATE t2 SET a=x'8243' where a=x'6162';
INSERT INTO t3 values(x'8142', x'8142', x'8142');
INSERT INTO t3 values(x'6162', x'6162', x'6162');
UPDATE t3 SET a=x'8243' where a=x'6162';
SET SQL_MODE="";
INSERT INTO t1 values(x'8142', x'8142', x'8142');
INSERT INTO t1 values(x'6162', x'6162', x'6162');
select * from t1;
select * from t2;
select * from t3;

