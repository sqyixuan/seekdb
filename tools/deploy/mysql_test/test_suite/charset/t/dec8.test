--result_format 4


--echo ===================================================test basic code ==================================================
--error 0,1051
drop table dec8_table;
--error 0,1305
drop procedure build_dec8_table;
--error 0,1051
drop table dec8_bin_table;
--error 0,1305
drop procedure build_dec8_bin_table;
create table dec8_table(c1 char(3) charset dec8 collate dec8_swedish_ci);
create table dec8_bin_table(c1 char(3) charset dec8 collate dec8_bin);

delimiter /;
create procedure build_dec8_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<128
  DO
      insert into dec8_table values(unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_dec8_table();
/
delimiter ;/
SELECT c1,
  hex(c1),
  hex(@u:=convert(c1 using utf8))
  FROM dec8_table order by c1;

delimiter /;
create procedure build_dec8_bin_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<128
  DO
      insert into dec8_bin_table values(unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_dec8_bin_table();
/

delimiter ;/
SELECT c1,
  hex(c1),
  hex(@u:=convert(c1 using utf8))
  FROM dec8_bin_table order by c1;

--echo -------------------test lower/upper----------------------
SELECT lower(c1),upper(c1) FROM dec8_table where c1 = 'v';
SELECT lower(c1),upper(c1) FROM dec8_bin_table where c1 = 'v';

--echo -------------------test padding rule----------------------
insert into dec8_table values ('a '), ('a\t'),('a  ');
select c1,collation(c1),hex(c1) from dec8_table where c1 like "%a%";
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
select c1, hex(c1) from dec8_table where c1 = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select c1, hex(c1) from dec8_table where c1 = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";

insert into dec8_bin_table values ('a '), ('a\t'),('a  ');
select c1,collation(c1),hex(c1) from dec8_bin_table where c1 like "%a%";
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
select c1, hex(c1) from dec8_bin_table where c1 = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select c1, hex(c1) from dec8_bin_table where c1 = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
--echo -------------------test insert non-dec8 character ----------------------
set names utf8mb4;
--error 1366
INSERT INTO dec8_table VALUES('张三');

INSERT INTO dec8_table VALUES(0xe5);

--error 1366
INSERT INTO dec8_bin_table VALUES('张三');
INSERT INTO dec8_bin_table VALUES(0xe5);

--echo -------------------test charset function----------------------
select weight_string(_dec8 'a' collate dec8_swedish_ci), weight_string(_dec8 'A' collate dec8_swedish_ci);
select weight_string(_dec8 'a' collate dec8_bin), weight_string(_dec8 'A' collate dec8_bin);

set collation_connection = dec8_swedish_ci;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');
set collation_connection = dec8_bin;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');

SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM dec8_table where c1 = 'v';
SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM dec8_bin_table where c1 = 'v';

SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM dec8_table where c1 like '%v%';
SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM dec8_bin_table where c1 like '%v%';

SELECT HEX(cx), cy
FROM (SELECT GROUP_CONCAT(c1 ORDER BY binary c1 SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(c1) ORDER BY BINARY c1) AS cy
      FROM dec8_table
      GROUP BY c1
     ) AS dt order by cy;

SELECT HEX(cx), cy
FROM (SELECT GROUP_CONCAT(c1 ORDER BY binary c1 SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(c1) ORDER BY BINARY c1) AS cy
      FROM dec8_bin_table
      GROUP BY c1
     ) AS dt order by cy;


