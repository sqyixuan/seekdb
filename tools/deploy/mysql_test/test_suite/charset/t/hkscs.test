# owner: sanquan.qz
# owner group: sql1
# tags: charset
--result_format 4

--echo ===================================================test basic code ==================================================
--error 0,1051
drop table hkscs_table;
--error 0,1305
drop procedure build_hkscs_table;
--error 0,1051

create table hkscs_table(c1 char(3) charset hkscs collate hkscs_bin);
delimiter /;
create procedure build_hkscs_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<65536
  DO
    IF (i < 128 || ((i & 0xFF00) >= 0x8100 && (i & 0xFF00) <= 0xFE00) && (( (i & 0xFF) >= 0x40 && (i & 0xFF) <= 0x7E ) || ( (i & 0xFF) >= 0xa1 && (i & 0xFF) <= 0xfe ))) THEN
      insert into hkscs_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_hkscs_table();
/


delimiter ;/
SELECT c1,
  hex(c1),
  hex(@u:=convert(c1 using utf8))
  FROM hkscs_table order by c1;

--echo -------------------test lower/upper----------------------
SELECT lower(c1),upper(c1) FROM hkscs_table where c1 = 'v';

--echo -------------------test padding rule----------------------
insert into hkscs_table values ('a '), ('a\t'),('a  ');
select c1,collation(c1),hex(c1) from hkscs_table where c1 like "%a%";
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
select c1, hex(c1) from hkscs_table where c1 = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select c1, hex(c1) from hkscs_table where c1 = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";

--echo -------------------test insert non-hkscs character ----------------------
set names utf8mb4;
--error 1300
INSERT INTO hkscs_table VALUES(_hkscs 0xfffe);

--echo -------------------test charset function----------------------
select weight_string(_hkscs 'a' collate hkscs_bin), weight_string(_hkscs 'A' collate hkscs_bin);

set collation_connection = hkscs_bin;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');

SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM hkscs_table where c1 = 'v';
SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM hkscs_table where c1 like '%v%';

SELECT /*+QUERY_TIMEOUT(60000000)*/ HEX(cx), cy
FROM (SELECT GROUP_CONCAT(c1 ORDER BY binary c1 SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(c1) ORDER BY BINARY c1) AS cy
      FROM hkscs_table
      GROUP BY c1
     ) AS dt order by cy;

