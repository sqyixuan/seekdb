# owner: sanquan.qz
# owner group: sql1
# description: test latin1 in oracle mode
--echo # create table for test
--result_format 4

--error 0,1051
drop table t1;
create table t1(c1 varchar(100) charset utf8mb4, c2 varchar(100) generated always as (c1)) CHARACTER SET = latin1;
--error 1366
insert into t1 (c1) values ('汉字');

--error 0,1051
drop table t2;
create table t2(uid int auto_increment,data varchar(10) character set gbk,primary key(uid))DEFAULT CHARACTER SET = latin1;
insert into t2 values (NULL,'沈阳');
insert into t2 values (NULL,'日本');
alter table t2 add user_name varchar(20) generated always as (data);
--error 1366
insert into t2 (uid,data) values (NULL,'沈阳产');
select * from t2;

--error 0,1051
drop table t3;
create table t3(c1 varchar(100) charset latin1, c2 varchar(100) charset utf8mb4);
insert into t3 values(NULL, '你');
--error 1366
update t3 set c1 = c2;
set sql_mode='';
update t3 set c1 = c2;
select * from t3;