# tags: charset, sjis
--result_format 4

--echo ===================================================test basic code ==================================================
--error 0,1051
drop table sjis_table;
--error 0,1305
drop procedure build_sjis_table;
--error 0,1051
drop table sjis_bin_table;
--error 0,1305
drop procedure build_sjis_bin_table;
create table sjis_table(c1 char(3) charset sjis collate sjis_japanese_ci);
create table sjis_bin_table(c1 char(3) charset sjis collate sjis_bin);

delimiter /;
create procedure build_sjis_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into sjis_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_sjis_table();
/
delimiter ;/
SELECT c1,
  hex(c1),
  hex(@u:=convert(c1 using utf8))
  FROM sjis_table order by c1;

delimiter /;
create procedure build_sjis_bin_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<128
  DO
      insert into sjis_bin_table values(unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_sjis_bin_table();
/

delimiter ;/
SELECT c1,
  hex(c1),
  hex(@u:=convert(c1 using utf8))
  FROM sjis_bin_table order by c1;

--echo -------------------test lower/upper----------------------
SELECT lower(c1),upper(c1) FROM sjis_table where c1 = 'v';
SELECT lower(c1),upper(c1) FROM sjis_bin_table where c1 = 'v';

--echo -------------------test padding rule----------------------
insert into sjis_table values ('a '), ('a\t'),('a  ');
select c1,collation(c1),hex(c1) from sjis_table where c1 like "%a%";
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
select c1, hex(c1) from sjis_table where c1 = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select c1, hex(c1) from sjis_table where c1 = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";

insert into sjis_bin_table values ('a '), ('a\t'),('a  ');
select c1,collation(c1),hex(c1) from sjis_bin_table where c1 like "%a%";
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
select c1, hex(c1) from sjis_bin_table where c1 = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select c1, hex(c1) from sjis_bin_table where c1 = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
--echo -------------------test insert non-sjis character ----------------------
set names utf8mb4;
--error 1366
INSERT INTO sjis_table VALUES('张三');

--error 1366
INSERT INTO sjis_bin_table VALUES('张三');

--echo -------------------test charset function----------------------
select weight_string(_sjis 'a' collate sjis_japanese_ci), weight_string(_sjis 'A' collate sjis_japanese_ci);
select weight_string(_sjis 'a' collate sjis_bin), weight_string(_sjis 'A' collate sjis_bin);

set collation_connection = sjis_japanese_ci;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');
set collation_connection = sjis_bin;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');

SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM sjis_table where c1 = 'v';
SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM sjis_bin_table where c1 = 'v';

SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM sjis_table where c1 like '%v%';
SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM sjis_bin_table where c1 like '%v%';

SELECT HEX(cx), cy
FROM (SELECT GROUP_CONCAT(c1 ORDER BY binary c1 SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(c1) ORDER BY BINARY c1) AS cy
      FROM sjis_table
      GROUP BY c1
     ) AS dt order by cy;

SELECT HEX(cx), cy
FROM (SELECT GROUP_CONCAT(c1 ORDER BY binary c1 SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(c1) ORDER BY BINARY c1) AS cy
      FROM sjis_bin_table
      GROUP BY c1
     ) AS dt order by cy;


