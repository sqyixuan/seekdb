--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: wuyuming.wym
# owner group: SQL1

--result_format 4
--character_set gb18030

set names gb18030;

# issue : 

select '中文字符' as '中文字符' from dual;
select '中文字符' as 中文字符 from dual;


# issue : 
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(
sex varchar(10) comment '注释',
CONSTRAINT t1_cons CHECK(sex='男' or sex='女')
);
show create table t1;
insert into t1 values ('女');
insert into t1 values ('男');
insert into t1 values (NULL);
select * from t1;
update t1 set sex = '男' where sex is null;
select * from t1;

drop table t1;

# issue : 

--disable_warnings
drop table if exists cast_test_table2;
--enable_warnings

set character_set_database = 'gb18030';
set character_set_server = 'gb18030';
show session variables like '%collation%';
show variables like 'character%';

create table cast_test_table2(name varchar(10));
show create table cast_test_table2;
drop table cast_test_table2;

