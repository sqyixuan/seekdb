--disable_warnings
drop table if exists t4,t5;
--enable_warnings

--error 1267
CREATE TABLE t4(c1 VARCHAR(10) CHARACTER SET gb18030, c2 VARCHAR(10)CHARACTER SET gbk, c3 VARCHAR(10) as (concat(c1, c2)));

--error 1267
CREATE TABLE t5(c1 VARCHAR(10) CHARACTER SET gb18030, c2 VARCHAR(10)CHARACTER SET gb18030_2022, c3 VARCHAR(10) as (concat(c1, c2)));


set character_set_database = 'utf8mb4';
set character_set_server = 'utf8mb4';

