# owner: jim.wjh
# owner group: SQL1
# description: test gbk in oracle mode
# tags: cross_validation

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

create table t2 (c0 char(10) charset utf8mb4, c1 nchar(10), c2 NATIONAL CHARACTER(10), c3 NVARCHAR(10), c4 NATIONAL VARCHAR(10), c5 NATIONAL CHARACTER VARYING(10), c6 NATIONAL CHAR VARYING(10), c7 NCHAR VARCHAR(10)) default charset gbk;

show create table t2;

insert into t2 values(N'奥', N'星', N'贝', N'斯', N'数', N'据', N'库', N'数据');
insert into t2(c0, c1) values(_GBK'ABC', _GBK'abc');
insert into t2(c0, c1) values(n'数据', N'数据库');
insert into t2(c0, c1) values(_GBK'奥星', _GBK'贝斯');

--sorted_result
select * from t2;

create table t1 (N int);
insert into t1 values(1);

select N'a' from t1;
select N 'a' from t1;

--error 0, 1300
select N'我'=_UTF16'我';
select N'我'=_UTF8'我';
select N'我'=_UTF8MB4'我';
select N'我我'=_BINARY'我我';
select N'我我'=_GBK'我我';

alter system flush plan cache global;
select N'我';
select N'你';
select N'他';
select N'我你它';
select n'abc';
select hit_count, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select ?';

--error 0, 1054
select N"我";
--error 0, 1054
select N '我';
--error 0, 1054
select N "我";

SELECT CASE _latin1'a' WHEN _utf16'a' THEN 'A' END;

create table t3 (c1 nchar(10) default N'常量', c2 nvarchar(10) default N'常量', c3 int);

insert into t3(c3) values(1);
select * from t3;
alter system flush plan cache global;
select length(N''), concat(N'', 'a'), concat_ws(N'', 'b') from dual;

