#
# 0x81 0x8D 0x8F 0x90 0x9D are undefined in cp1252
#
SELECT
  hex(a),
  hex(@u:=convert(a using utf8mb4)),
  hex(@l:=convert(@u using latin1)),
  a, @u, @l,
  a=@l FROM t1;

# 5. caseup, casedn
select upper(a), lower(a) from t1;
drop table t1;