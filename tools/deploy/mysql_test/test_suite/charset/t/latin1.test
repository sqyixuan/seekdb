alter table latin1 convert to character set latin1 collate latin1_danish_ci;
select v, hex(v), hex(weight_string(v)) as hex_weight, conv(hex(weight_string(v)), 16, 10) from latin1;


alter table latin1 convert to character set latin1 collate latin1_general_ci;
select v, hex(v), hex(weight_string(v)) as hex_weight, conv(hex(weight_string(v)), 16, 10) from latin1;


alter table latin1 convert to character set latin1 collate latin1_general_cs;
select v, hex(v), hex(weight_string(v)) as hex_weight, conv(hex(weight_string(v)), 16, 10) from latin1;


alter table latin1 convert to character set latin1 collate latin1_german1_ci;
select v, hex(v), hex(weight_string(v)) as hex_weight, conv(hex(weight_string(v)), 16, 10) from latin1;


alter table latin1 convert to character set latin1 collate latin1_german2_ci;
select v, hex(v), hex(weight_string(v)) as hex_weight, conv(hex(weight_string(v)), 16, 10) from latin1;


alter table latin1 convert to character set latin1 collate latin1_spanish_ci;
select v, hex(v), hex(weight_string(v)) as hex_weight, conv(hex(weight_string(v)), 16, 10) from latin1;

--disable_warnings
drop table if exists t1;
--enable_warnings

# test charset handler api
CREATE TABLE t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    text_column VARCHAR(255) CHARACTER SET latin1 COLLATE latin1_german2_ci NOT NULL
);
INSERT INTO t1 (text_column) VALUES
('This is a plain string'),
('This is a string with special characters: äää, ö, ü, ß, xä, xö, xü, xß'),
(''),
('äää, ö, ü, ß, xä, xö, xü, xß'),
('Another string with special characters: é, ççç, ñ, €');

# 1. well_formed_len
INSERT INTO t1 (text_column) VALUES(0xFFF);
select * from t1;

# 2. mbcharlen, numchars
select length(text_column), char_length(text_column) from t1;

# 3. charpos
select substr(text_column, 2, 3) from t1;
drop table t1;

# 4. mb_wc, wc_mb
