--disable_warnings
drop table if exists `пјҙпј‘`;
--disable_warnings
drop table if exists `пјҙпј’`;
--enable_warnings
--disable_warnings
drop table if exists `пјҙпј“`;
--enable_warnings

#
# Test INSTR() function with Japanese characters in utf8 encoding
#

SET NAMES utf8;
SET character_set_database = 'utf8';

CREATE TABLE `пјҙпј‘` (`пјЈпј‘` char(5) primary key, INDEX(`пјЈпј‘`)) DEFAULT CHARSET = utf8 ;
CREATE TABLE `пјҙпј’` (`пјЈпј‘` char(5) primary key, INDEX(`пјЈпј‘`)) DEFAULT CHARSET = utf8 ;
CREATE TABLE `пјҙпј“` (`пјЈпј‘` char(5) primary key, INDEX(`пјЈпј‘`)) DEFAULT CHARSET = utf8 ;

INSERT INTO `пјҙпј‘` VALUES ('пҪұпҪІпҪіпҪҙпҪө');
INSERT INTO `пјҙпј’` VALUES ('гҒӮгҒ„гҒҶгҒҲгҒҠ');
INSERT INTO `пјҙпј“` VALUES ('йҫ”йҫ–йҫ—йҫһйҫЎ');

SELECT INSTR('пҪұпҪІпҪіпҪҙпҪө','пҪІ') FROM `пјҙпј‘`;
SELECT INSTR(`пјЈпј‘`,'пҪі') FROM `пјҙпј‘`;
SELECT INSTR(`пјЈпј‘`,'пҪҙ') FROM `пјҙпј‘`;
SELECT INSTR(`пјЈпј‘`,'пҪө') FROM `пјҙпј‘`;
SELECT INSTR(`пјЈпј‘`,'пҫқ') FROM `пјҙпј’`;
SELECT INSTR(`пјЈпј‘`,'гҒӮ') FROM `пјҙпј’`;
SELECT INSTR(`пјЈпј‘`,'гҒ„') FROM `пјҙпј’`;
SELECT INSTR(`пјЈпј‘`,'гҒҶ') FROM `пјҙпј’`;
SELECT INSTR(`пјЈпј‘`,'гҒҲ') FROM `пјҙпј’`;
SELECT INSTR(`пјЈпј‘`,'гҒҠ') FROM `пјҙпј’`;
SELECT INSTR(`пјЈпј‘`,'гӮ“') FROM `пјҙпј’`;
SELECT INSTR(`пјЈпј‘`,'йҫ”') FROM`пјҙпј“`;
SELECT INSTR(`пјЈпј‘`,'йҫ–') FROM`пјҙпј“`;
SELECT INSTR(`пјЈпј‘`,'йҫ—') FROM`пјҙпј“`;
SELECT INSTR(`пјЈпј‘`,'йҫһ') FROM`пјҙпј“`;
SELECT INSTR(`пјЈпј‘`,'йҫЎ') FROM`пјҙпј“`;
SELECT INSTR(`пјЈпј‘`,'дёӮ') FROM`пјҙпј“`;


DROP TABLE `пјҙпј‘`;
DROP TABLE `пјҙпј’`;
DROP TABLE `пјҙпј“`;
