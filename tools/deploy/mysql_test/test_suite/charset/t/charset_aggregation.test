--echo ######################## 表达式测试  ########################

select collation(collation(concat(c1,c2))),coercibility(collation(concat(c1,c2))) from utf8_table;
select collation(coercibility(concat(c1,c2))),coercibility(coercibility(concat(c1,c2))) from utf8_table;
select collation(concat(c1,c2)),coercibility(concat(c1,c2)) from utf8_table;
select collation(concat_ws(c1,c2)),coercibility(concat_ws(c1,c2)) from utf8_table;
select collation(convert(c1 using latin1)),coercibility(convert(c1 using latin1)) from utf8_table;
--error 1267
select collation(field(c1,c2)),coercibility(field(c1,c2)) from utf8_table;
--error 1267
select collation(find_in_set(c1,c2)),coercibility(find_in_set(c1,c2)) from utf8_table;
select collation(ifnull(c1,c2)),coercibility(ifnull(c1,c2)) from utf8_table;
--error 1267
select collation(nullif(c1,c2)),coercibility(nullif(c1,c2)) from utf8_table;
--error 1267
select collation(nvl(c1,c2)),coercibility(nvl(c1,c2)) from utf8_table;
--error 1267
select collation(instr(c1,c2)),coercibility(instr(c1,c2)) from utf8_table;
select collation(left(c1,c2)),coercibility(left(c1,c2)) from utf8_table;
--error 1267
select collation(locate(c1,c2)),coercibility(locate(c1,c2)) from utf8_table;
select collation(date_add(c1,interval 8000 year)),coercibility(date_add(c1,interval 8000 year)) from utf8_table;
select collation(c1+c2),coercibility(c1+c2) from utf8_table;
select collation(c1=1),coercibility(c1=1) from utf8_table;
select collation(c1 is true),coercibility(c1 is true) from utf8_table;
--error 1267
select collation(c1 like c2), coercibility(c1 like c2) from utf8_table;
select collation(lpad(c1,1,c2)),coercibility(lpad(c1,1,c2)) from utf8_table;
select collation(rpad(c2,1,c1)),coercibility(rpad(c2,1,c1)) from utf8_table;
--error 1267
select collation(strcmp(c1,c2)),coercibility(strcmp(c1,c2)) from utf8_table;

--error 0,1051,942
DROP TABLE table001;
CREATE TABLE table001(
c1 INT UNSIGNED AUTO_INCREMENT,
c2 VARCHAR(101) CHARACTER SET gbk NOT NULL,
c3 VARCHAR(204) CHARACTER SET utf16 NOT NULL,
c4 CHAR(200) CHARACTER SET gbk,
c5 CHAR(200) CHARACTER SET utf16,
c6 varchar(300) generated always as(concat(c2,c4)),
PRIMARY KEY(c1)
)CHARSET=gbk; 
insert into table001(c1,c2,c3,c4,c5)values(null,'中国','中国・米国・英国・フランス','China, the United Kingdom, France','Chine États-Unis Royaume-Uni France');
select collation(insert(c2, 3, 4, c3)), coercibility(insert(c2, 3, 4, c3)) from table001;
select collation(instr(c3, c2)), coercibility(instr(c3, c2)) from table001;
select collation(replace(c2, '中国', 'フランス')), coercibility(replace(c2, '中国', 'フランス')) from table001;
--echo ######################## enable_old_charset_aggregation  ########################
set  _enable_old_charset_aggregation = true;
--error 1267
select collation(concat(c1,c2)),coercibility(concat(c1,c2)) from utf8_table;
--error 1267
select count(1) from utf8_table where c1=c2;
set  _enable_old_charset_aggregation = false;
select collation(concat(c1,c2)),coercibility(concat(c1,c2)) from utf8_table;
--error 1267
select count(1) from utf8_table where c1=c2;