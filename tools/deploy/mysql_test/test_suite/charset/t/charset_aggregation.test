# owner: sanquan.qz
# owner group: sql1
# description: test charset aggregation rules
--result_format 4
--error 0,1051,942
drop table non_bin_coll;
--error 0,1051,942
drop table bin_coll;
--error 0,1051,942
drop table utf8_table;
--error 0,1051,942
drop table utf16_table;
--error 0,1051,942
drop table gb18030_2022_table;
create table non_bin_coll(c char(10) character set utf16 collate utf16_general_ci,
                c0 char(10) character set binary,
                c1 char(10) character set utf8mb4 collate utf8mb4_general_ci,
                c2 char(10) character set ascii collate ascii_general_ci,
                c3 char(10) character set gbk collate gbk_chinese_ci,
                c4 char(10) character set gb18030 collate gb18030_chinese_ci,
                c5 char(10) character set latin1 collate latin1_swedish_ci,
                c6 char(10) character set tis620 collate tis620_thai_ci);
insert into non_bin_coll values ('x','y','a','b','c','d','e','f');

create table bin_coll(c char(10) character set utf16 collate utf16_bin,
                    c0 char(10) character set binary,
                    c1 char(10) character set utf8mb4 collate utf8mb4_bin,
                    c2 char(10) character set ascii collate ascii_bin,
                    c3 char(10) character set gbk collate gbk_bin,
                    c4 char(10) character set gb18030 collate gb18030_bin,
                    c5 char(10) character set latin1 collate latin1_bin,
                    c6 char(10) character set tis620 collate tis620_bin);
insert into bin_coll values ('x0','y0','a0','b0','c0','d0','e0','f0');

create table utf16_table(c1 char(10) character set utf16 collate utf16_unicode_ci,
                        c2 char(10) character set utf16 collate utf16_general_ci,
                        c3 char(10) character set utf16 collate utf16_bin);
insert into utf16_table value ('a','b','c');

create table utf8_table(c1 char(10) character set utf8mb4 collate utf8mb4_unicode_ci,
                        c2 char(10) character set utf8mb4 collate utf8mb4_general_ci,
                        c3 char(10) character set utf8mb4 collate utf8mb4_0900_ai_ci,
                        c4 char(10) character set utf8mb4 collate utf8mb4_bin);
insert into utf8_table value ('a','b','c','d');

create table gb18030_2022_table(c1 char(10) character set gb18030_2022 collate gb18030_2022_bin,
                                c2 char(10) character set gb18030_2022 collate gb18030_2022_chinese_ci,
                                c3 char(10) character set gb18030_2022 collate gb18030_2022_radical_ci,
                                c4 char(10) character set gb18030_2022 collate gb18030_2022_chinese_cs,
                                c5 char(10) character set gb18030_2022 collate gb18030_2022_radical_cs,
                                c6 char(10) character set gb18030_2022 collate gb18030_2022_stroke_ci,
                                c7 char(10) character set gb18030_2022 collate gb18030_2022_stroke_cs);
insert into gb18030_2022_table value ('a','b','c','d','e','f','g');

--echo ######################## 不同字符集  ########################

