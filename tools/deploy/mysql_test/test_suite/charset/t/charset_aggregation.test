SELECT COLLATION(CONCAT(_latin1 X'abce', NULL)), COERCIBILITY(CONCAT(_latin1 X'abce', NULL)) FROM utf8_table;
SELECT COLLATION(CONCAT(_latin1 X'abce', version())), COERCIBILITY(CONCAT(_latin1 X'abce', version())) FROM utf8_table;
