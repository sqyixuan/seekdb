#owner: jim.wjh
#owner group: sql3

--disable_warnings
DROP TABLE IF EXISTS t0;
--enable_warnings
create table t0(c1 varchar(100) COLLATE utf8mb4_unicode_ci, key idx (c1));
insert into t0 values('𣓃𤩊㵥㘼𫓩䴗㭎𬣡㬊㠓㸆𬉼𨱇');
select /*+ index(t0 primary) */* from t0 where c1 like '%𣓃𤩊㵥㘼𫓩䴗㭎𬣡㬊㠓㸆𬉼𨱇%';
select /*+ index(t0 idx) */* from t0 where c1 like '%𣓃𤩊㵥㘼𫓩䴗㭎𬣡㬊㠓㸆𬉼𨱇%';
DROP TABLE t0;

