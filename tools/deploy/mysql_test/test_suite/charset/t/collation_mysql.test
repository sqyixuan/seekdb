--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: diqinhao.dqh
# owner group: SQL1

--result_format 4

--disable_warnings
drop table if exists t0, t1;
drop view if exists t2;
--enable_warnings

create table t0(c1 varchar(10));
insert into t0 values('f');

create table t1 as select c1, x'5d80' c2 from t0;
create view v1 as select c1, x'5d80' c2 from t0;

-- disable_warnings
select c1 < c2 as r from t1;
select c1 < c2 as r from v1;
select c1 < c2 as r from (select c1, x'5d80' c2 from t0);

select coercibility(c1), coercibility(c2) from t1;
select coercibility(c1), coercibility(c2) from v1;
select coercibility(c1), coercibility(c2) from (select c1, x'5d80' c2 from t0);
-- enable_warnings

drop table t0, t1;
drop view v1;