#
# Test creating table with Japanese characters in utf8 encoding
#

SET NAMES utf8;
SET character_set_database = 'utf8';

CREATE TABLE `锝憋奖锝盽(`锝讹蕉锝禶 char(1) primary key) DEFAULT CHARSET utf8 ;
CREATE TABLE `锝诧讲锝瞏(`锝凤椒锝穈 char(1) primary key) DEFAULT CHARSET utf8 ;
CREATE TABLE `銇傘亗銇俙(`銇嬨亱銇媊 char(1) primary key) DEFAULT CHARSET utf8 ;
CREATE TABLE `銇勩亜銇刞(`銇嶃亶銇峘 char(1) primary key) DEFAULT CHARSET utf8 ;
CREATE TABLE `榫栭緰榫朻(`涓備競涓俙 char(1) primary key) DEFAULT CHARSET utf8 ;
CREATE TABLE `榫楅緱榫梎(`涓勪竸涓刞 char(1) primary key) DEFAULT CHARSET utf8 ;
# Tables should not be created because table names exist 
