--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL3

--result_format 4

--disable_warnings
drop table if exists deergbk;
--enable_warnings

CREATE TABLE `deergbk` (
  `name` varchar(20) NOT NULL,
  PRIMARY KEY (`name`)
) DEFAULT CHARSET = gbk;
insert into deergbk values('123');
insert into deergbk values('56');
insert into deergbk values('张三');
insert into deergbk values('李四');
insert into deergbk values('王五');
select * from deergbk order by name;
select * from deergbk where name = '张三';
select * from deergbk where name < '张三';
select * from deergbk where name > '123' and name <= '张三';
select * from deergbk where name <= '56' and name >= '123';

drop table deergbk;

