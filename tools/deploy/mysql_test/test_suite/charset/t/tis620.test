drop database tis620_db;
create database tis620_db charset tis620;
alter database tis620_db charset tis620;
use tis620_db;
create table t1(c1 char(1)) charset tis620 collate tis620_thai_ci;
show create table t1;
alter table t1 charset=tis620;
alter table t1 modify c1 char(1) CHARACTER SET tis620 collate tis620_bin;
show create table t1;


