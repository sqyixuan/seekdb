# owner: sanquan.qz
# owner group: sql1
# tags: charset
--result_format 4

--echo ===================================================test basic code ==================================================
--error 0,1051
drop table tis620_table;
--error 0,1305
drop procedure build_tis620_table;
--error 0,1051
drop table tis620_bin_table;
--error 0,1305
drop procedure build_tis620_bin_table;
create table tis620_table(c1 char(3) charset tis620 collate tis620_thai_ci);
create table tis620_bin_table(c1 char(3) charset tis620 collate tis620_bin);

delimiter /;
create procedure build_tis620_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into tis620_table values(unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_tis620_table();
/
delimiter ;/
SELECT c1,
  hex(c1),
  hex(@u:=convert(c1 using utf8))
  FROM tis620_table order by c1;

delimiter /;
create procedure build_tis620_bin_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<128
  DO
      insert into tis620_bin_table values(unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_tis620_bin_table();
/

delimiter ;/
SELECT c1,
  hex(c1),
  hex(@u:=convert(c1 using utf8))
  FROM tis620_bin_table order by c1;

--echo -------------------test lower/upper----------------------
SELECT lower(c1),upper(c1) FROM tis620_table where c1 = 'v';
SELECT lower(c1),upper(c1) FROM tis620_bin_table where c1 = 'v';

--echo -------------------test padding rule----------------------
insert into tis620_table values ('a '), ('a\t'),('a  ');
select c1,collation(c1),hex(c1) from tis620_table where c1 like "%a%";
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
select c1, hex(c1) from tis620_table where c1 = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select c1, hex(c1) from tis620_table where c1 = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";

insert into tis620_bin_table values ('a '), ('a\t'),('a  ');
select c1,collation(c1),hex(c1) from tis620_bin_table where c1 like "%a%";
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
select c1, hex(c1) from tis620_bin_table where c1 = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select c1, hex(c1) from tis620_bin_table where c1 = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
--echo -------------------test insert non-tis620 character ----------------------
set names utf8mb4;
--error 1366
INSERT INTO tis620_table VALUES('张三');

--error 1366
INSERT INTO tis620_bin_table VALUES('张三');

--echo -------------------test charset function----------------------
select weight_string(_tis620 'a' collate tis620_thai_ci), weight_string(_tis620 'A' collate tis620_thai_ci);
select weight_string(_tis620 'a' collate tis620_bin), weight_string(_tis620 'A' collate tis620_bin);

set collation_connection = tis620_thai_ci;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');
set collation_connection = tis620_bin;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');

SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM tis620_table where c1 = 'v';
SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM tis620_bin_table where c1 = 'v';

SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM tis620_table where c1 like '%v%';
SELECT c1, hex(c1), hex(@u:=convert(c1 using utf8)) FROM tis620_bin_table where c1 like '%v%';

SELECT HEX(cx), cy
FROM (SELECT GROUP_CONCAT(c1 ORDER BY binary c1 SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(c1) ORDER BY BINARY c1) AS cy
      FROM tis620_table
      GROUP BY c1
     ) AS dt order by cy;

SELECT HEX(cx), cy
FROM (SELECT GROUP_CONCAT(c1 ORDER BY binary c1 SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(c1) ORDER BY BINARY c1) AS cy
      FROM tis620_bin_table
      GROUP BY c1
     ) AS dt order by cy;


--echo ================================================other case=================================================
