#
# Test collation latin1_german2_ci
#

set names latin1;
--character_set latin1

let $old_collation_schema= `SELECT @@collation_database`;
eval ALTER SCHEMA test COLLATE latin1_german2_ci;
set @@collation_connection=latin1_german2_ci;
select @@collation_connection;

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

# test collation handler api

# 1. test strnncoll, strnncollsp

CREATE TABLE t1 (
s1 CHAR(5) CHARACTER SET latin1 COLLATE latin1_german2_ci
);
show create table t1;
INSERT INTO t1 VALUES ('Ü');
INSERT INTO t1 VALUES ('ue');
SELECT DISTINCT s1 FROM t1;
SELECT s1,COUNT(*) FROM t1 GROUP BY s1;
SELECT COUNT(DISTINCT s1) FROM t1;
SELECT FIELD('ue',s1), FIELD('Ü',s1), s1='ue', s1='Ü' FROM t1;
DROP TABLE t1;

create table t1 (a char (20) not null, b int not null primary key auto_increment, index (a,b)) character set latin1 collate latin1_german2_ci;
insert into t1 (a) values ('ä'),('ac'),('ae'),('ad'),('Äc'),('aeb');
insert into t1 (a) values ('üc'),('uc'),('ue'),('ud'),('Ü'),('ueb'),('uf');
insert into t1 (a) values ('ö'),('oc'),('Öa'),('oe'),('od'),('Öc'),('oeb');
insert into t1 (a) values ('s'),('ss'),('ß'),('ßb'),('ssa'),('ssc'),('ßa');
insert into t1 (a) values ('eä'),('uü'),('öo'),('ää'),('ääa'),('aeae');
insert into t1 (a) values ('q'),('a'),('u'),('o'),('é'),('É'),('a');
select a,b from t1 order by a,b;
select a from t1 order by a desc,b;

create table t2 (a varchar (20) not null, b int not null primary key auto_increment, index (a,b)) character set latin1 collate latin1_german2_ci;
insert into t2 (a) values ('ä'),('ac'),('ae'),('ad'),('Äc'),('aeb');
insert into t2 (a) values ('üc'),('uc'),('ue'),('ud'),('Ü'),('ueb'),('uf');
insert into t2 (a) values ('ö'),('oc'),('Öa'),('oe'),('od'),('Öc'),('oeb');
insert into t2 (a) values ('s'),('ss'),('ß'),('ßb'),('ssa'),('ssc'),('ßa');
insert into t2 (a) values ('eä'),('uü'),('öo'),('ää'),('ääa'),('aeae');
insert into t2 (a) values ('q'),('a'),('u'),('o'),('é'),('É'),('a');
select a,b from t2 order by a,b;
select a from t2 order by a desc,b;
DROP TABLE t2;

# The following should all be true
select strcmp('ä','ae'),strcmp('ae','ä'),strcmp('aeq','äq'),strcmp('äq','aeq');
select strcmp('ss','ß'),strcmp('ß','ss'),strcmp('ßs','sss'),strcmp('ßq','ssq');

# The following should all return -1
select strcmp('ä','af'),strcmp('a','ä'),strcmp('ää','aeq'),strcmp('ää','aeaeq');
select strcmp('ss','ßa'),strcmp('ß','ssa'),strcmp('sßa','sssb'),strcmp('s','ß');
select strcmp('ö','oö'),strcmp('Ü','uü'),strcmp('ö','oeb');

# The following should all return 1
select strcmp('af','ä'),strcmp('ä','a'),strcmp('aeq','ää'),strcmp('aeaeq','ää');
select strcmp('ßa','ss'),strcmp('ssa','ß'),strcmp('sssb','sßa'),strcmp('ß','s');
select strcmp('u','öa'),strcmp('u','ö');

#
# overlapping combo's
#
select strcmp('sä', 'ßa'), strcmp('aä', 'äx');

# 2. test strnxfrm, strnxfrmlen

#
# Test of special character in german collation
#

select hex(weight_string('Ä'));
select hex(weight_string('ä'));
select hex(weight_string('Ö'));
select hex(weight_string('ö'));
select hex(weight_string('Ü'));
select hex(weight_string('ü'));
select hex(weight_string('S'));
select hex(weight_string('s'));
select hex(weight_string('ß'));
select hex(weight_string('ä' as char(1)));
select hex(weight_string('ö' as char(1)));
select hex(weight_string('ü' as char(1)));
select hex(weight_string('ß' as char(1)));
select hex(weight_string('xä' as char(2)));
select hex(weight_string('xö' as char(2)));
select hex(weight_string('xü' as char(2)));
select hex(weight_string('xß' as char(2)));

# 3. test like_range & wildcmp

--sorted_result
select * from t1 where a like "ö%";
--sorted_result
select * from t1 where a like binary "%É%";
--sorted_result
select * from t1 where a like "%Á%";
--sorted_result
select * from t1 where a like "%U%";
--sorted_result
select * from t1 where a like "%ss%";
drop table t1;

# 4. test instr

DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    str VARCHAR(255) CHARACTER SET latin1 COLLATE latin1_german2_ci NOT NULL
);
INSERT INTO t1 (str) VALUES
    ('This is a test string with some special characters: Ä, ä, Ö, ö, Ü, ü, S, s, ß, xä, xö, xü, xß.'),
    ('Just another string without special chars.');
SELECT LOCATE('Ä', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('ä', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('Ö', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('ö', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('Ü', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('ü', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('S', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('s', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('ß', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('xä', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('xö', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('xü', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('xß', str) AS position FROM t1 WHERE id = 1;
SELECT id, LOCATE('xyz', str) FROM t1;
SELECT id, LOCATE('This', str) FROM t1;
drop table t1;

# 5. test hash_sort

