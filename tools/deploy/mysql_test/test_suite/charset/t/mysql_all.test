--echo TEST ISSUE 30975723
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a varchar(10) charset utf16);
insert into t1 values('\\123\''), ('a\ns\\df');
SELECT QUOTE(t1.a) FROM T1;
drop table t1;

--echo TEST FOR ISSUE 31230816
create table t1(c varchar(100) charset utf16 primary key);
insert into t1 values('A');
select c from t1 where c=0xD0B1212223D0B1D0B1D0B1D0B1D0B1;
select c from t1 where c=X'D0B1212223D0B1D0B1D0B1D0B1D0B1';
select c from t1 where c=0x41;
select c from t1 where c=0x61;
drop table t1;
