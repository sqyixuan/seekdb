# owner: jim.wjh
# owner group: SQL2
# description: test case for all charset mysql mode
#
--disable_abort_on_error

--result_format 4

--disable_warnings
drop table if exists t_charset_utf8_unicode_ci;
drop table if exists t_charset_utf8_general_ci;
drop table if exists t_charset_utf8_bin;
drop table if exists t_charset_gbk_chinese_ci;
drop table if exists t_charset_gbk_bin;
drop table if exists t_charset_gb18030_chinese_ci;
drop table if exists t_charset_gb18030_bin;
drop table if exists t_charset_utf16_general_ci;
drop table if exists t_charset_utf16_unicode_ci;
drop table if exists t_charset_utf16_bin;
--enable_warnings

--echo TEST PART1: varchar all collation test

create table t_charset_utf8_unicode_ci(c1 varchar(10) charset utf8mb4 collate utf8mb4_unicode_ci primary key);
insert into t_charset_utf8_unicode_ci values('');
--error 1062
insert into t_charset_utf8_unicode_ci values(X'0000201F00');
insert into t_charset_utf8_unicode_ci values('A');
--error 1062
insert into t_charset_utf8_unicode_ci values('A ');
insert into t_charset_utf8_unicode_ci values(concat('A', char(0)));
insert into t_charset_utf8_unicode_ci values('AZ');
select hex(c1) from t_charset_utf8_unicode_ci order by c1;
drop table t_charset_utf8_unicode_ci;


create table t_charset_utf8_general_ci(c1 varchar(10) charset utf8mb4 collate utf8mb4_general_ci primary key);
insert into t_charset_utf8_general_ci values('A');
--error 1062
insert into t_charset_utf8_general_ci values('A ');
insert into t_charset_utf8_general_ci values(concat('A', char(0)));
insert into t_charset_utf8_general_ci values('AZ');
select hex(c1) from t_charset_utf8_general_ci order by c1;
drop table t_charset_utf8_general_ci;

create table t_charset_utf8_bin(c1 varchar(10) charset utf8mb4 collate utf8mb4_bin primary key);
insert into t_charset_utf8_bin values('A');
--error 1062
insert into t_charset_utf8_bin values('A ');
insert into t_charset_utf8_bin values(concat('A', char(0)));
insert into t_charset_utf8_bin values('AZ');
select hex(c1) from t_charset_utf8_bin order by c1;
drop table t_charset_utf8_bin;

