#
# Test SUBSTRING() function with Japanese character in utf8 encoding
#

SET NAMES utf8;
SET character_set_database = 'utf8';
#CREATE TABLE yiwan(cc char(5) primary key, INDEX(cc)) DEFAULT CHARSET=utf8;
CREATE TABLE `пјҙпј‘` (`пјЈпј‘` char(5) primary key, INDEX(`пјЈпј‘`)) DEFAULT CHARSET = utf8;
CREATE TABLE `пјҙпј’` (`пјЈпј‘` char(5) primary key, INDEX(`пјЈпј‘`)) DEFAULT CHARSET = utf8;
CREATE TABLE `пјҙпј“` (`пјЈпј‘` char(5) primary key, INDEX(`пјЈпј‘`)) DEFAULT CHARSET = utf8;
CREATE TABLE t1(c1 char(5) primary key, INDEX(c1)) DEFAULT CHARSET=utf8;
