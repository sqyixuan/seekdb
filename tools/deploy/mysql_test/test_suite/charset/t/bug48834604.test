--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL3
################################################################

--result_format 4
--disable_abort_on_error

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings
create table t1 (co1 varchar(10) default '中文') charset gbk;

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;


create table t2(a varchar(123) charset utf8);
insert into t2 values('12he12');
insert into t2 values('%he%');
select * from t2 where a like '%%he%%' escape '%';

create table t3(a varchar(123) charset utf16);
insert into t3 values('12he12');
insert into t3 values('%he%');
select * from t3 where a like '%%he%%' escape '%';


select replace(convert('石碶街道' using gbk), 0x5C, '\\\\');

--disable_warnings
drop table if exists table1;
drop table if exists table2;
--enable_warnings

create table table1 (
  id int,
  col_tinytext tinytext,
  col_text text,
  col_mediumtext mediumtext,
  col_longtext longtext,
  col_tinyblob tinyblob,
  index idx3 (col_tinytext(3)),
  index idx4 (col_text(3)),
  index idx5 (col_mediumtext(3)),
  index idx6 (col_longtext(3)),
  index idx9 (col_tinyblob(3)));

INSERT INTO table1 VALUES (12,'col_tinytext1','col_text1','col_mediumtext1','col_longtext1','col_tinyblob1');
INSERT INTO table1 VALUES (13,'col%tinytext1','col%text1','col%mediumtext1','col%longtext1','col%tinyblob1');

select id,col_tinytext from table1 where col_tinytext like '%l%%t%' escape '%' order by 1,2;
select id,col_text from table1 where col_text like '%l%%t%' escape '%' order by 1,2;
select id,col_mediumtext from table1 where col_mediumtext like '%l%%t%' escape '%' order by 1,2;
select id,col_longtext from table1 where col_longtext like '%l%%t%' escape '%' order by 1,2;
select id,col_tinyblob from table1 where col_tinyblob like '%l%%t%' escape '%' order by 1,2;

create table table2 (
  id int,
  col_varbinary varbinary(20),
  index idx8 (col_varbinary(3))
);
INSERT INTO table2 VALUES (12,'col_varbinary');
INSERT INTO table2 VALUES (13,'col%varbinary');

select col_varbinary from table2 where col_varbinary like '%l__v%' escape '_';
explain select col_varbinary from table2 where col_varbinary like '%l__v%' escape '_';

select convert('col%col' using gbk) like '%l%%c%' escape '%';
select convert('col%col' using binary) like '%l%%c%' escape '%';
select convert('col%col' using utf8mb4) like '%l%%c%' escape '%';
select convert('col%col' using utf8) like '%l%%c%' escape '%';
select convert('col%col' using binary) like '%l%%c%' escape '%';
select convert('col%col' using latin1) like '%l%%c%' escape '%';

select convert('l%c' using gbk) like '%l%%c' escape '%';
select convert('l%c' using binary) like '%l%%c' escape '%';
select convert('l%c' using utf8mb4) like '%l%%c' escape '%';
select convert('l%c' using utf8) like '%l%%c' escape '%';
select convert('l%c' using binary) like '%l%%c' escape '%';
select convert('l%c' using latin1) like '%l%%c' escape '%';

select convert('col%c' using gbk) like '%l%%c' escape '%';
select convert('col%c' using binary) like '%l%%c' escape '%';
select convert('col%c' using utf8mb4) like '%l%%c' escape '%';
select convert('col%c' using utf8) like '%l%%c' escape '%';
select convert('col%c' using binary) like '%l%%c' escape '%';
select convert('col%c' using latin1) like '%l%%c' escape '%';

select convert('col%col' using gbk) like '%col%%col' escape '%';
select convert('col%col' using binary) like '%col%%col' escape '%';
select convert('col%col' using utf8mb4) like '%col%%col' escape '%';
select convert('col%col' using utf8) like '%col%%col' escape '%';
select convert('col%col' using binary) like '%col%%col' escape '%';
select convert('col%col' using latin1) like '%col%%col' escape '%';

select convert('col%col' using gbk) like 'col%col' escape '%';
select convert('col%col' using binary) like 'col%col' escape '%';
select convert('col%col' using utf8mb4) like 'col%col' escape '%';
select convert('col%col' using utf8) like 'col%col' escape '%';
select convert('col%col' using binary) like 'col%col' escape '%';
select convert('col%col' using latin1) like 'col%col' escape '%';

select convert('col_col' using gbk) like 'col%_col' escape '%';
select convert('col_col' using binary) like 'col%_col' escape '%';
select convert('col_col' using utf8mb4) like 'col%_col' escape '%';
select convert('col_col' using utf8) like 'col%_col' escape '%';
select convert('col_col' using binary) like 'col%_col' escape '%';
select convert('col_col' using latin1) like 'col%_col' escape '%';


select replace('测试中文','中','文');
select replace('测中文','中','文');
select replace('测中文',0xE4B8AD,'文');
select replace(0xAAAA, 0xAA, 'a');
select replace(convert('石碶街道' using gbk), 0x5C, '\\\\');

set names gbk;
select replace('测试中文','中','文')  c1; 
select replace('测中文','中','文') c1;
select replace('测中文',0xE4B8AD,'文') c1;
select replace(0xAAAA, 0xAA, 'a') c1;

--disable_warnings
drop table if exists test_validate_password;
drop table if exists t1;
--enable_warnings

set names gbk;
create table test_validate_password as SELECT VALIDATE_PASSWORD_STRENGTH(replace('中文测试','中','文'));
