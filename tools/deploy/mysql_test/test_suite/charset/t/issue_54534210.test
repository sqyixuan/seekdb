--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL3
#
--result_format 4

--disable_warnings
drop database if exists db1;
--enable_warnings

#issue 48223160
show variables like '%collation%';
create database db1;
set session sql_mode = concat(@@sql_mode, ',PAD_CHAR_TO_FULL_LENGTH');
CREATE TABLE db1.z0case (
z0_test0 char(99) COLLATE utf16_bin DEFAULT NULL,
z0_test1 mediumblob DEFAULT NULL,
z0_test2 blob GENERATED ALWAYS AS (coalesce(`z0_test0`,`z0_test1`)) VIRTUAL,
UNIQUE KEY INDEX1 (z0_test0),
KEY index_z (z0_test0)
);
INSERT INTO db1.Z0CASE (z0_test0)VALUES(0);
drop database db1;


