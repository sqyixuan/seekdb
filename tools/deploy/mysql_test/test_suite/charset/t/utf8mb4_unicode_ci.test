# owner: jim.wjh
# owner group: SQL1
# description: test utf8mb4_unicode_ci

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists test;
--enable_warnings

## 测试添加utf8mb4_unicode_ci是否成功
show collation;

## 使用utf8mb4_unicode_ci测试比较结果
create table test(c1 varchar(100), c2 int) collate=utf8mb4_unicode_ci;
insert into test values('ß', 1), ('s', 2), ('ss', 3);
insert into test values('cafe', 4), ('caff', 5), ('café', 6);
select * from test where c1='ß';
select * from test where c1 like '%ß%';
select sum(c2) from test group by c1;
select * from test order by c1;

# 测试where语句
update test set c2 = 100 where c1 = 'ß';

select * from test;

## 测试表达式比较是否相同
select 'Œ' collate utf8mb4_unicode_ci = 'OE' collate utf8mb4_unicode_ci;
select 'ÀÁÅåāă' collate utf8mb4_unicode_ci = 'AAAAAA' collate utf8mb4_unicode_ci;

drop table test;

### 测试多种语言的字符排序

create table test(c1 varchar(100)) collate utf8mb4_unicode_ci;
insert into test values('fwefwe');
insert into test values('hello');
insert into test values('go');
insert into test values('a');
insert into test values('中国');
insert into test values('五星红旗');
insert into test values('宇宙');
insert into test values('宇宙');
insert into test values('ッギヂ');
insert into test values('ダヱ');
insert into test values('Wü');
insert into test values('Würzburg');
insert into test values('겄겶');
insert into test values('꒧꒹꒭');
insert into test values('꒞꒰');
insert into test values('⡳⢎');
insert into test values('café');

select * from test order by c1;

insert into test values('龖龖');
insert into test values('かか');
insert into test values('けく');

select * from test order by c1;

drop table test;
