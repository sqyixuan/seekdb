#drop table if exists `Ｔ６`;
#drop table if exists `Ｔ７`;
#drop table if exists `Ｔ８`;
#drop table if exists `Ｔ９`;
--enable_warnings

#
# Test Displaying Japanese charact in utf8 encoding
#

SET NAMES utf8;
SET character_set_database = 'utf8';

CREATE TABLE `Ｔ１` (c1 char(20) primary key, INDEX(c1)) DEFAULT CHARSET = utf8 ;
CREATE TABLE `Ｔ２` (c1 char(20) primary key, INDEX(c1)) DEFAULT CHARSET = utf8 ;
CREATE TABLE `Ｔ３` (c1 char(20) primary key, INDEX(c1)) DEFAULT CHARSET = utf8 ;
#CREATE TABLE `Ｔ４` (c1 char(20), INDEX(c1)) DEFAULT CHARSET = utf8 engine = myisam;
#CREATE TABLE `Ｔ５` (c1 char(20), INDEX(c1)) DEFAULT CHARSET = utf8 engine = myisam;
#CREATE TABLE `Ｔ６` (c1 char(20), INDEX(c1)) DEFAULT CHARSET = utf8 engine = myisam;
#CREATE TABLE `Ｔ７` (c1 char(20), INDEX(c1)) DEFAULT CHARSET = utf8 engine = MEMORY;
#CREATE TABLE `Ｔ８` (c1 char(20), INDEX(c1)) DEFAULT CHARSET = utf8 engine = MEMORY;
#CREATE TABLE `Ｔ９` (c1 char(20), INDEX(c1)) DEFAULT CHARSET = utf8 engine = MEMORY;

