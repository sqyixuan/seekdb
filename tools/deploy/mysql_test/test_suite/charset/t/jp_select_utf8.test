# description: foobar
#--source include/have_utf8.inc
#--source include/have_innodb.inc
--disable_warnings
drop table if exists `Ｔ１`;
--disable_warnings
drop table if exists `Ｔ２`;
--enable_warnings
--disable_warnings
drop table if exists `Ｔ３`;
--enable_warnings
#drop table if exists `Ｔ４`;
