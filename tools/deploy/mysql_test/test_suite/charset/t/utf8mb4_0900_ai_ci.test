# owner: sanquan.qz
# owner group: SQL1
# description: test utf8mb4_0900_ai_ci

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists test;
drop table if exists test1;
drop table if exists test2;
drop table if exists test3;
drop table if exists t1;
drop table if exists t2;
drop table if exists vietnamese_test;
drop table if exists collation_test;
drop database if exists db;
--enable_warnings

show collation like "utf8mb4_0900_ai_ci";

--echo =========================test ordering&where ===========================================

create table test(c1 varchar(100), c2 int) collate=utf8mb4_0900_ai_ci;
insert into test values('ß', 1), ('s', 2), ('ss', 3);
insert into test values('cafe', 4), ('caff', 5), ('café', 6);
select * from test where c1='ß';
select * from test where c1 like '%ß%';
select sum(c2) from test group by c1;
select * from test order by c1;
update test set c2 = 100 where c1 = 'ß';
select * from test;

create table test3(c1 varchar(100)) collate utf8mb4_0900_ai_ci;
insert into test3 values('fwefwe');
insert into test3 values('hello');
insert into test3 values('go');
insert into test3 values('a');
insert into test3 values('中国');
insert into test3 values('五星红旗');
insert into test3 values('宇宙');
insert into test3 values('宇宙');
insert into test3 values('ッギヂ');
insert into test3 values('ダヱ');
insert into test3 values('Wü');
insert into test3 values('Würzburg');
insert into test3 values('겄겶');
insert into test3 values('꒧꒹꒭');
insert into test3 values('꒞꒰');
insert into test3 values('⡳⢎');
insert into test3 values('café');
insert into test3 values('龖龖');
insert into test3 values('かか');
insert into test3 values('けく');

select c1,collation(concat(c1,_utf8mb4'AAAAAA' collate utf8mb4_general_ci)) from test3 where c1="café" ;
select c1,collation(concat(c1,_utf8mb4'AAAAAA' collate utf8mb4_0900_ai_ci)) from test3 where c1="café" ;

select * from test3 order by c1;

CREATE TABLE vietnamese_test (
    id INT AUTO_INCREMENT PRIMARY KEY,
    vietnamese_char VARCHAR(10) COLLATE utf8mb4_0900_ai_ci
);
INSERT INTO vietnamese_test (vietnamese_char) VALUES
('a'), ('ă'), ('â'), ('d'), ('đ'), ('e'), ('ê'), ('o'), ('ô'), ('ơ'), ('u'), ('ư');
SELECT * FROM vietnamese_test ORDER BY vietnamese_char;
INSERT INTO vietnamese_test (vietnamese_char) VALUES
('A'), ('Ă'), ('Â'), ('D'), ('Đ'), ('E'), ('Ê'), ('O'), ('Ô'), ('Ơ'), ('U'), ('Ư');
SELECT * FROM vietnamese_test ORDER BY vietnamese_char;

--echo =========================test aggregation ===========================================
create table test1(c1 varchar(100), c2 int) collate=utf8mb4_general_ci;
create table test2(c1 varchar(100), c2 int) collate=utf8mb4_0900_ai_ci;
insert into test1 values ('ß',1);
insert into test2 values ('ß',2);
select collation(concat(test1.c1,test2.c1)) from test1, test2 limit 1;

--echo =========================test ai_ci comparision ===========================================
select 'Œ' collate utf8mb4_0900_ai_ci = 'OE' collate utf8mb4_0900_ai_ci;
select 'ÀÁÅåāă' collate utf8mb4_0900_ai_ci = 'AAAAAA' collate utf8mb4_0900_ai_ci;

CREATE TABLE collation_test (
    id INT AUTO_INCREMENT PRIMARY KEY,
    text_column VARCHAR(10)
) CHARACTER SET utf8mb4;
INSERT INTO collation_test (text_column) VALUES
('Jose'), ('josé'), ('JOSE'), ('Josef'),    
('café'), ('cafe'), ('CAFÉ'), ('Cafe');
SELECT text_column,
       text_column = 'Jose' COLLATE utf8mb4_0900_ai_ci AS comparison_ai_ci
FROM collation_test;

SELECT text_column
FROM collation_test
ORDER BY text_column COLLATE utf8mb4_0900_ai_ci;

--echo =========================test other ddl ===========================================
create table t1(c1 char(1)) charset utf8mb4 collate utf8mb4_0900_ai_ci;
create table t2(c1 char(1) charset utf8mb4 collate utf8mb4_0900_ai_ci);
alter table t1 charset=utf8mb3;
alter table t2 modify c1 char(1) character set utf8mb3 collate utf8mb4_0900_ai_ci;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;

--echo =========================test utf8mb3 grammar ===========================================
create database db charset=utf8mb3;
alter database db charset utf8mb3;
use db;
create table t1(c1 char(1)) charset utf8mb3;
create table t2(c1 char(1)) charset utf8mb3 collate utf8mb3_general_ci; 
create table t3(c1 char(1) charset latin1 collate latin1_bin);
alter table t3 modify c1 char(1) character set utf8mb3 collate utf8mb3_general_ci;
alter table t1 charset=utf8mb3;
select _utf8mb3 '12' as c from dual;


--echo =========================test default_value_for_utf8mb4 ===========================================
--error 1235
set default_collation_for_utf8mb4 = utf8mb4_0900_ai_ci;
--error 1235
set default_collation_for_utf8mb4 = 255;
--error 1235
set default_collation_for_utf8mb4 = 8;
set default_collation_for_utf8mb4 = 45;
set default_collation_for_utf8mb4 = utf8_general_ci;
show variables like "default_collation_for_utf8mb4";

