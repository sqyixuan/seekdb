# owner: sanquan.qz
# owner group: SQL1
# description: test utf16le

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--disable_warnings

--result_format 4


select length(trim(_utf16le 0x20008286818620002000)) x from dual;

create table t1(c1 varchar(10)) charset utf16le;
insert into t1 values(_utf16le 0x82868186);
select * from t1;
select * from t1 where c1  = _utf16le 0x82868186;
drop table t1;

create table t1(c1 varchar(10) charset utf16);
create table t2(c1 varchar(10) charset utf16le);
insert into t1 values(_utf16 0x86828681);
insert into t2 values(_utf16le 0x82868186);
--error 1267
select t1.c1, t2.c1 from t1,t2 where t1.c1 = t2.c1;
select * from t1;
select * from t2;

create table t3(c1 varchar(10)) charset gbk;
insert into t3 values(_gbk 0xC2ECD2CF);
select t2.c1, t3.c1 from t2, t3 where t2.c1 = t3.c1;

drop table t1, t2, t3;

create table t1(c1 varchar(20)) charset utf16le collate UTF16LE_BIN;
insert into t1 values(_utf16le 0x82868186);
insert into t1 values(_utf16 0x86828681);
insert into t1 values(_utf16le 0x604f7d59);
insert into t1 values('a'),('A');
insert into t1 values('b'),('B');
select * from t1 order by c1;
drop table t1;

create table t1(c1 varchar(20)) charset utf16le collate UTF16LE_GENERAL_CI;
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
insert into t1 values(_utf16 0x86828681);
insert into t1 values(_utf16 0x86828681);
insert into t1 values('a'),('A');
insert into t1 values('b'),('B');

insert into t1 values('abcdef');
insert into t1 values('中国');
insert into t1 values('你');
insert into t1 values('哈哈');
insert into t1 values('匲匳');
insert into t1 values('じす');

select * from t1 order by c1;
select upper(c1) from t1;
select lower(c1) from t1;
select position('哈' in c1) from t1;

insert into t1 values ('a '), ('a\t'),('a  ');
select hex(c1) from t1;
select position(' ' in c1) from t1;
select position(' ' in c1) from t1 where c1 like 'a%';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
drop table t1;

create table t1(c1 varchar(20)) charset utf16 collate UTF16_GENERAL_CI;
insert into t1 values(_utf16 0x86828681);
insert into t1 values(_utf16le 0x604f7d59);
insert into t1 values('a'),('A');
insert into t1 values('b'),('B');
select * from t1 order by c1;
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
insert into t1 values ('a '), ('a\t'),('a  ');
select hex(c1) from t1;
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
drop table t1;

CREATE TABLE t1 (a VARCHAR(10) CHARACTER SET utf16le);
INSERT INTO t1 VALUES ('фыва'),('Фыва'),('фЫва'),('фыВа'),('фывА'),('ФЫВА');
INSERT INTO t1 VALUES ('фывапролдж'),('Фывапролдж'),('фЫвапролдж'),('фыВапролдж');
INSERT INTO t1 VALUES ('фывАпролдж'),('фываПролдж'),('фывапРолдж'),('фывапрОлдж');
INSERT INTO t1 VALUES ('фывапроЛдж'),('фывапролДж'),('фывапролдЖ'),('ФЫВАПРОЛДЖ');
SELECT * FROM t1 WHERE a LIKE '%фЫва%' ORDER BY BINARY a;
SELECT * FROM t1 WHERE a LIKE '%фЫв%' ORDER BY BINARY a;
SELECT * FROM t1 WHERE a LIKE 'фЫва%' ORDER BY BINARY a;
SELECT * FROM t1 WHERE a LIKE _utf16le 'фЫва%' COLLATE utf16le_bin ORDER BY BINARY a;
DROP TABLE t1;

CREATE TABLE t1 (word VARCHAR(64) NOT NULL, PRIMARY KEY (word))
CHARACTER SET utf16le;
INSERT INTO t1 (word) VALUES ("cat");
SELECT hex(word) FROM t1;
SELECT * FROM t1 WHERE word LIKE _utf16le 0x63002500;
SELECT * FROM t1 WHERE word LIKE "c%";
SELECT * FROM t1 WHERE word LIKE "ca_";
SELECT * FROM t1 WHERE word LIKE "cat";
DROP TABLE t1;

CREATE TABLE t1 (
  a VARCHAR(10) CHARACTER SET utf16le,
  b VARCHAR(10) CHARACTER SET utf16le);
INSERT INTO t1 VALUES ('abc', 'def');
SELECT INSERT(a, 10, 2, b) FROM t1;
SELECT INSERT(a, 1, 2, b) FROM t1;
DROP TABLE t1;

CREATE TABLE t1 SELECT
LPAD(_utf16le X'2004',10,_utf16le X'2104') l,
RPAD(_utf16le X'2004',10,_utf16le X'2104') r;
--source mysql_test/include/show_create_table_old_version.inc
SHOW CREATE TABLE t1;
SELECT HEX(l), HEX(r) FROM t1;
DROP TABLE t1;

CREATE TABLE t1 (f1 CHAR(30));
INSERT INTO t1 VALUES ("103000"), ("22720000"), ("3401200"), ("78000");
SELECT LPAD(f1, 12, "-o-/") FROM t1;
DROP TABLE t1;

--echo #
--echo # Check alignment for from-binary-conversion with CAST and CONVERT
--echo #
SELECT HEX(CAST(0xAA as char CHARACTER SET utf16le));
SELECT HEX(CONVERT(0xAA USING utf16le));


--echo #
--echo # Check that INSERT() works fine.
--echo # This invokes charpos() function.
--echo #
CREATE TABLE t1 (
  a VARCHAR(10) CHARACTER SET utf16le,
  b VARCHAR(10) CHARACTER SET utf16le);
INSERT INTO t1 VALUES ('abc', 'def');
SELECT INSERT(a, 10, 2, b) FROM t1;
SELECT INSERT(a, 1, 2, b) FROM t1;
DROP TABLE t1;

--echo #
--echo # Check alignment for string types
--echo #
CREATE TABLE t1 (a CHAR(10) CHARACTER SET utf16le);
INSERT INTO t1 VALUES (0x1),(0x11),(0x111),(0x1111),(0x11111);
SELECT HEX(a) FROM t1;
DROP TABLE t1;

CREATE TABLE t1 (a VARCHAR(10) CHARACTER SET utf16le);
INSERT INTO t1 VALUES (0x1),(0x11),(0x111),(0x1111),(0x11111);
SELECT HEX(a) FROM t1;
DROP TABLE t1;

CREATE TABLE t1 (a TEXT CHARACTER SET utf16le);
INSERT INTO t1 VALUES (0x1),(0x11),(0x111),(0x1111),(0x11111);
SELECT HEX(a) FROM t1;
DROP TABLE t1;

CREATE TABLE t1 (a MEDIUMTEXT CHARACTER SET utf16le);
INSERT INTO t1 VALUES (0x1),(0x11),(0x111),(0x1111),(0x11111);
SELECT HEX(a) FROM t1;
DROP TABLE t1;

CREATE TABLE t1 (a LONGTEXT CHARACTER SET utf16le);
INSERT INTO t1 VALUES (0x1),(0x11),(0x111),(0x1111),(0x11111);
SELECT HEX(a) FROM t1;
DROP TABLE t1;


--echo #
--echo # Bug#5081 : UCS2 fields are filled with '0x2020'
--echo # after extending field length
--echo #

CREATE TABLE t1(a CHAR(1)) DEFAULT CHARSET utf16le;
INSERT INTO t1 VALUES ('a'),('b'),('c');
ALTER TABLE t1 MODIFY a CHAR(5);
SELECT a, HEX(a) FROM t1;
DROP TABLE t1;

--echo #
--echo # Check that utf16le works with ENUM and SET type
--echo #
CREATE TABLE t1 (a ENUM('x','y','z') CHARACTER SET utf16le);
--source mysql_test/include/show_create_table_old_version.inc
SHOW CREATE TABLE t1;
INSERT INTO t1 VALUES ('x');
INSERT INTO t1 VALUES ('y');
INSERT INTO t1 VALUES ('z');
SELECT a, HEX(a) FROM t1 ORDER BY a;
ALTER TABLE t1 CHANGE a a ENUM('x','y','z','d','e','ä','ö','ü') CHARACTER SET utf16le;
--source mysql_test/include/show_create_table_old_version.inc
SHOW CREATE TABLE t1;
INSERT INTO t1 VALUES ('D');
INSERT INTO t1 VALUES ('E ');
INSERT INTO t1 VALUES ('ä');
INSERT INTO t1 VALUES ('ö');
INSERT INTO t1 VALUES ('ü');
SELECT a, HEX(a) FROM t1 ORDER BY a;
DROP TABLE t1;

CREATE TABLE t1 (a set ('x','y','z','ä','ö','ü') CHARACTER SET utf16le);
--source mysql_test/include/show_create_table_old_version.inc
SHOW CREATE TABLE t1;
INSERT INTO t1 VALUES ('x');
INSERT INTO t1 VALUES ('y');
INSERT INTO t1 VALUES ('z');
INSERT INTO t1 VALUES ('x,y');
INSERT INTO t1 VALUES ('x,y,z,ä,ö,ü');
SELECT a, HEX(a) FROM t1 ORDER BY a;
DROP TABLE t1;

