--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: xiaoyi.xy 
#### owner group: sql3
#### description: 测试杂七杂八的bug
# test cases for bugs fixed by Xiaoni(BangyuYe) 
--disable_info
--disable_metadata
--disable_warnings
drop table if exists xiaoni_t1, xiaoni_t2, xiaoni_t3;
--enable_warnings

--echo ================ sum(timestamp) ================
# bug fix for 6313882
create table xiaoni_t1 (id int primary key, c1 timestamp);
insert into xiaoni_t1 values (1, "1991-09-22 21:30:00");
insert into xiaoni_t1 values (2, "1992-09-22 21:30:00");
insert into xiaoni_t1 values (3, "1993-09-22 21:30:00");
select sum(c1) from xiaoni_t1;

--echo ================ timestamp default ================
#bug fix for 6309081
create table xiaoni_t2 (id int primary key, c1 timestamp, c2 timestamp, c3 timestamp);
desc xiaoni_t2;

--echo ================ ip2int ================
#bug fix for 6288710
select ip2int(10);

--echo ================ number2int ================
#bug fix for 6307491
create table xiaoni_t3(a int primary key, b bigint);
insert into xiaoni_t3 values(1,0.4);
insert into xiaoni_t3 values(2,0.5);
insert into xiaoni_t3 values(3,0.6);
insert into xiaoni_t3 values(4,1.6);
insert into xiaoni_t3 values(5,1.5);
insert into xiaoni_t3 values(6,1.2);
select * from xiaoni_t3;
--error 1273
ALTER DATABASE  COLLATE cp1251_general_cs;
# --error 1046
alter database  character set utf8;
--echo ================ teardown ================
# tear down
--disable_warnings
drop table if exists xiaoni_t1, xiaoni_t2, xiaoni_t3;
--enable_warnings
