--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: mingye.swj
# owner group: SQL3
################################################################

--result_format 4
--disable_abort_on_error

select cast('我' as nchar);
select cast('我' as national char);
select cast('我' as nchar(10));
select cast('我' as national char(10));

select cast(_GBK'我' as nchar);
select hex(cast(_GBK'我' as nchar));

--error 1064
select cast('a' as national char(10) binary);
--error 1064
select cast('a' as nchar binary);



