# owner: jim.wjh
# owner group: SQL1

--enable_sorted_result

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--disable_warnings
set _enable_old_charset_aggregation = true;
create table t1(c1 varchar(10)) charset utf8mb4;
# 插入gbk编码的汉字蚂蚁
insert into t1 values(_gbk 0xC2ECD2CF);
select * from t1;
drop table t1;

create table t1(c1 varchar(100)) collate gbk_bin;
# 插入空串
insert into t1 values('');
# 插入NULL值
insert into t1 values(NULL);
# 插入整形，看是否数据类型转换成功
insert into t1 values(1);
# 插入汉字
insert into t1 values('你好');
select * from t1;
drop table t1;

# 判断gbk和utf8mb4编码的汉字是否相等
select '蚂蚁' = _gbk 0xC2ECD2CF;

create table t1(c1 varchar(10) charset utf8mb4);
create table t2(c1 varchar(10) charset gbk);
insert into t1 values('蚂蚁');
insert into t2 values(_gbk 0xC2ECD2CF);
select t1.c1, t2.c1 from t1, t2 where t1.c1 = t2.c1;
select t1.c1 from t1 inner join t2 on t1.c1 = t2.c1;

drop table t1;
drop table t2;

## 测试join的情况
create table t1(c1 int, c2 varchar(100) collate utf8mb4_general_ci);
create table t2(c1 int, c2 varchar(100) collate gbk_chinese_ci);
insert into t1 values(1, '中');
insert into t1 values(2, '你好haa');
insert into t1 values(3, 'hello');
insert into t1 values(4, '今天sfew');
insert into t1 values(5, '月亮');
insert into t2 values(1, '中');
insert into t2 values(2, '你好haa');
insert into t2 values(3, 'hello');
insert into t2 values(4, '太阳');
select t1.c2, t2.c2 from t1 inner join t2 on t1.c2 = t2.c2;

drop table t1;
drop table t2;

## 测试group by行为
create table t1(c1 varchar(100) collate gbk_bin);
insert into t1 values('中'), ('中'), ('国');
select count(*) from t1 group by c1 = '中' collate utf8mb4_general_ci;

drop table t1;

create table t1(c1 varchar(100) collate utf16_bin, c2 varchar(100) collate gbk_bin);
insert into t1 values('中', '中');
insert into t1 values('你', '好啊');
select c1 = c2 from t1;

drop table t1;

create table t1(c1 varchar(100) collate utf16_bin, c2 varchar(100) collate utf8mb4_general_ci);
insert into t1 values('中', '中');
insert into t1 values('你', '好啊');
select c1 = c2 from t1;

drop table t1;

create table t1(c1 varchar(100) collate gbk_bin, c2 varchar(100) collate utf8mb4_general_ci);
insert into t1 values('中', '中');
insert into t1 values('你', '好啊');
select c1 = c2 from t1;

drop table t1;

create table t1(c1 varchar(100) collate utf8mb4_unicode_ci, c2 varchar(100) collate utf8mb4_general_ci);
insert into t1 values('中', '中');
insert into t1 values('你', '好啊');
--error 1267
select c1 = c2 from t1;

drop table t1;

create table t1(c1 varchar(100) collate utf16_unicode_ci, c2 varchar(100) collate utf16_general_ci);
insert into t1 values('中', '中');
insert into t1 values('你', '好啊');
--error 1267
select c1 = c2 from t1;

drop table t1;

## 测试utf8mb4转gbk失败的情况
create table t1(c1 varchar(100));
insert into t1 values('hello');
insert into t1 values('ضﺽ');
insert into t1 values('aﺽﺽb');
insert into t1 values('aﺽbﺽc');
set names gbk;
select * from t1;
drop table t1;

set names utf8mb4;
create table t1(c1 int, c2 varchar(100) default '中文');
insert into t1(c1) values(1);
desc t1;
select * from t1;
drop table t1;
set _enable_old_charset_aggregation = false;


