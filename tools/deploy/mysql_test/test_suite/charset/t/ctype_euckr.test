select _euckr 'abcd_ｶ' collate euckr_bin;
select _euckr 'abcd_ｶ' collate euckr_korean_ci;

# 1. test strnncoll, strnncollsp

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

set names utf8mb4;

CREATE TABLE t1 (
s1 CHAR(5) CHARACTER SET euckr
);

INSERT INTO t1 VALUES
('ㅏ'), ('ㅑ'), ('ㅓ'), ('ㅕ'), ('ㅗ'), ('ㅛ'), ('ㅜ'), ('ㅠ'), ('ㅡ'), ('ㅣ'),
('ㅐ'), ('ㅒ'), ('ㅔ'), ('ㅖ'), ('ㅚ'), ('ㅟ'), ('ㅢ'),
('ㄱ'), ('ㄲ'), ('ㄳ'), ('ㄴ'), ('ㄷ'), ('ㄸ'), ('ㄹ'), ('ㅁ'), ('ㅂ'), ('ㅃ'), ('ㅅ'), ('ㅆ'), ('ㅇ'), ('ㅈ'), ('ㅉ'), ('ㅊ'), ('ㅋ'), ('ㅌ'), ('ㅍ'), ('ㅎ');
INSERT INTO t1 VALUES
('가'), ('각'), ('간'), ('갑'), ('가스'), ('가시'), ('가장'), ('가주'), ('가중'), ('가치');

SELECT DISTINCT s1 FROM t1;
SELECT s1,COUNT(*) FROM t1 GROUP BY s1;
SELECT COUNT(DISTINCT s1) FROM t1;
SELECT FIELD('ᄀ',s1), FIELD('ᇠ',s1), s1='ᄀ', s1='ᇠ' FROM t1;
DROP TABLE t1;

create table t1 (a char (20) not null, b int not null primary key auto_increment, index (a,b)) character set euckr collate euckr_bin;
insert into t1 (a) values ('가'), ('각'), ('간'), ('갑'), ('가스'), ('가시'), ('가장'), ('가주'), ('가중'), ('가치');
select a,b from t1 order by a,b;
select a from t1 order by a desc,b;
drop table t1;

create table t1 (a varchar (20) not null, b int not null primary key auto_increment, index (a,b)) character set euckr collate euckr_bin;
insert into t1 (a) values ('가'), ('각'), ('간'), ('갑'), ('가스'), ('가시'), ('가장'), ('가주'), ('가중'), ('가치');
select a,b from t1 order by a,b;
select a from t1 order by a desc,b;
