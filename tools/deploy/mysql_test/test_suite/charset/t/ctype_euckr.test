create table t2 (a varchar (20) not null, b int not null primary key auto_increment, index (a,b)) character set euckr collate euckr_korean_ci;
insert into t2 (a) values ('가'), ('각'), ('간'), ('갑'), ('가스'), ('가시'), ('가장'), ('가주'), ('가중'), ('가치');
