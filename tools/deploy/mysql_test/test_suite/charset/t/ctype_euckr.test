# 3. test like_range & wildcmp

create table t1 (a varchar (20) not null, b int not null primary key auto_increment, index (a,b)) character set euckr collate euckr_korean_ci;
insert into t1 (a) values ('가'), ('각'), ('간'), ('갑'), ('가스'), ('가시'), ('가장'), ('가주'), ('가중'), ('가치');

--sorted_result
select * from t1 where a like "가%";
--sorted_result
select * from t1 where a like binary "%갑%";
--sorted_result
select * from t1 where a like "%장%";
--sorted_result
select * from t1 where a like "%주%";
--sorted_result
select * from t1 where a like "%가%";
drop table t1;

create table t1 (a varchar (20) not null, b int not null primary key auto_increment, index (a,b)) character set euckr collate euckr_bin;
insert into t1 (a) values ('가'), ('각'), ('간'), ('갑'), ('가스'), ('가시'), ('가장'), ('가주'), ('가중'), ('가치');

--sorted_result
select * from t1 where a like "가%";
--sorted_result
select * from t1 where a like binary "%갑%";
--sorted_result
select * from t1 where a like "%장%";
--sorted_result
select * from t1 where a like "%주%";
--sorted_result
select * from t1 where a like "%가%";
drop table t1;

# 4. test instr
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    str VARCHAR(255) CHARACTER SET euckr COLLATE euckr_korean_ci NOT NULL
);
INSERT INTO t1 (str) VALUES
    ('This is a test string with some special characters: 가,각,간,갑,가스,가시,가장,가주,가중,가치'),
    ('Just another string without special chars: ㅏ,ㅑ,ㅓ,ㅕ,ㅗ,ㅛ,ㅜ,ㅠ,ㅡ,ㅣ');

SELECT LOCATE('가', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('각', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('간', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('갑', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('ㅏ', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('ㅡ', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('가스', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('가시', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('가장', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('가주', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('가중', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('가치', str) AS position FROM t1 WHERE id = 1;

SELECT id, LOCATE('xyz', str) FROM t1;
SELECT id, LOCATE('This', str) FROM t1;

DROP TABLE t1;

CREATE TABLE t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    str VARCHAR(255) CHARACTER SET euckr COLLATE euckr_bin NOT NULL
);
INSERT INTO t1 (str) VALUES
    ('This is a test string with some special characters: 가,각,간,갑,가스,가시,가장,가주,가중,가치'),
    ('Just another string without special chars: ㅏ,ㅑ,ㅓ,ㅕ,ㅗ,ㅛ,ㅜ,ㅠ,ㅡ,ㅣ');

SELECT LOCATE('가', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('각', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('간', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('갑', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('ㅏ', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('ㅡ', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('가스', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('가시', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('가장', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('가주', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('가중', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('가치', str) AS position FROM t1 WHERE id = 1;

SELECT id, LOCATE('xyz', str) FROM t1;
SELECT id, LOCATE('This', str) FROM t1;

DROP TABLE t1;

