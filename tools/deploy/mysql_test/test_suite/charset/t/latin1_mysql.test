# owner: sanquan.qz
# owner group: sql1
# description: test latin1 in oracle mode
--echo # create table for test
--result_format 4

create table latin1_table(c1 char(1) character set latin1);

delimiter /;
create procedure build_latin1_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into latin1_table values(unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_latin1_table();
/

delimiter ;/

SELECT c1,
  hex(c1),
  hex(@u:=convert(c1 using utf8))
  FROM latin1_table;

drop table if exists latin1_table;
drop procedure if exists build_latin1_table;


--echo padding rule test
--error 0,942,1051
drop table t1;
create table t1(`a` text CHARACTER SET latin1);
insert into t1 values ('a'), ('a '), ('a\t'),('a  ');
select a,collation(a),hex(a) from t1 order by a;
drop table t1;


--echo test uppper/lower
SELECT lower('Aliyun');
SELECT upper('Aliyun');

--echo test insert chinese character 
set names utf8;
CREATE TABLE t1 (c1 VARCHAR(255)) default CHARACTER SET latin1;
--error 1366
INSERT INTO t1 VALUES('张三');


--echo test weight_string 
set names latin1;
select hex(weight_string('a'));

--echo test latin1 parameterize bug 
--error 0,942,1051
drop table t1;
create table t1(i0 int,i1 int,i2 int);
set names latin1;
alter system flush plan cache;
--disable_result_log
select /*+no_rewrite*/ * from t1 where 1=1 and 1*3;
select /*+no_rewrite*/ * from t1 where 1=2 and 3*6;
select /*+no_rewrite*/ * from t1 where 3=1 and 5*3;
select /*+no_rewrite*/ * from t1 where  !2 and !3;
select /*+no_rewrite*/ * from t1 where  !2 and !3;
SELECT a0.i0 + 10+a1.i0 + 100*a2.i0, (a0.i0/-2 + ~10*a1.i0 + 100/a2.i0) % 50, a0.i0 + 10*a1.i0 + 100*a2.i0 FROM t1 AS a0, t1 AS a1, t1 AS a2 where 1&&1 and 1|1;
--enable_result_log

#expected hit_count 2,1,0
select hit_count, query_sql, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+no_rewrite*/ * from t1%' or statement like '%SELECT a0.i0%';
alter system flush plan cache;
set names utf8;


--echo test space padding, expect 'abc' == 'abc  '
--error 0,942,1051
drop table t1;
create table t1(c1 char(5) charset latin1 collate latin1_bin);
insert into t1 values ('abc');
select hex(c1) from t1;
select * from t1 where c1 = 'abc';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select hex(c1) from t1;
select * from t1 where c1 = 'abc';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";

--error 0,942,1051
drop table t1;
create table t1(c1 varchar(5) charset latin1 collate latin1_bin);
insert into t1 values ('abc');
select hex(c1) from t1;
select * from t1 where c1 = 'abc';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select hex(c1) from t1;
select * from t1 where c1 = 'abc';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";

--echo test hash sort, expect 'abc' == 'abc  '
--error 0,942,1051
drop table t1;
create table t1(c1 varchar(5) charset latin1 collate latin1_bin);
insert into t1 values ('abc');
insert into t1 values ('abc  ');
select hex(c1) from t1;
select c1 from t1 where c1 = 'abc';
select distinct c1 from t1 where c1 = 'abc';

set names binary;
--error 0,942,1051
drop table t1;
create table t1(c1 char(100)) character set latin1 collate latin1_bin partition by key(c1)partitions 3;
insert into t1 values ('฿ Bs Br       ');
--echo when in mysql mode, trailing space will be ignore 
insert into t1 values (' ');
select hex(c1) from t1;
set names utf8;
drop table t1;

--echo test instr
set names latin1;
select 'abc' like 'ABC';
select instr('XABC','abc');
set names utf8;

