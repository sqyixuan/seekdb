# load data
# Load the following data in table
--source mysql_test/test_suite/charset/include/copy_data_for_direct_load.inc

--disable_warnings
drop table if exists `table1`;
drop table if exists `table2`;
drop table if exists `table3`;

CREATE TABLE `table1` (`col` char(100), INDEX(`col`)) DEFAULT CHARSET = cp932 engine = innodb;
CREATE TABLE `table2` (`col` char(100), INDEX(`col`)) DEFAULT CHARSET = cp932 engine = myisam;
CREATE TABLE `table3` (`col` char(100), INDEX(`col`)) DEFAULT CHARSET = cp932 engine = MEMORY;
--enable_warnings

LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/general.dat' INTO TABLE `table1` CHARACTER SET cp932;
LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/general.dat' INTO TABLE `table2` CHARACTER SET cp932;
LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/general.dat' INTO TABLE `table3` CHARACTER SET cp932;

select * from `table1`;
select * from `table2`;
select * from `table3`;

drop table `table1`;
drop table `table2`;
drop table `table3`;


CREATE TABLE t1 (a VARCHAR(10) COLLATE cp932_bin);
INSERT INTO t1 VALUES('ｶｶ');
SELECT * FROM t1 WHERE a LIKE '%ｶ';
SELECT * FROM t1 WHERE a LIKE '_ｶ';
SELECT * FROM t1 WHERE a LIKE '%_ｶ';

ALTER TABLE t1 MODIFY a VARCHAR(100) COLLATE ujis_bin;
SELECT * FROM t1 WHERE a LIKE '%ｶ';
SELECT * FROM t1 WHERE a LIKE '_ｶ';
SELECT * FROM t1 WHERE a LIKE '%_ｶ';
DROP TABLE t1;


################################
## test collation handler api ##
################################

select _cp932 'abcd_ｶ' collate cp932_bin;
select _cp932 'abcd_ｶ' collate cp932_japanese_ci;

# 1. test strnncoll, strnncollsp

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

CREATE TABLE t1 (
s1 CHAR(5) CHARACTER SET cp932
);
show create table t1;
INSERT INTO t1 VALUES ('ｶ');
INSERT INTO t1 VALUES ('礁');
SELECT DISTINCT s1 FROM t1;
SELECT s1,COUNT(*) FROM t1 GROUP BY s1;
SELECT COUNT(DISTINCT s1) FROM t1;
SELECT FIELD('ｶ',s1), FIELD('粧',s1), s1='ｶ', s1='粧' FROM t1;
DROP TABLE t1;

create table t1 (a char (20) not null, b int not null primary key auto_increment, index (a,b)) character set cp932 collate cp932_bin;
insert into t1 (a) values ('沼'),('消'),('渉'),('湘'),('焼'),('焦'),('章'),('笑');
insert into t1 (a) values ('照'),('症'),('省'),('硝'),('礁'),('祥'),('称'),('粧');
select a,b from t1 order by a,b;
select a from t1 order by a desc,b;
drop table t1;

create table t1 (a varchar (20) not null, b int not null primary key auto_increment, index (a,b)) character set cp932 collate cp932_bin;
insert into t1 (a) values ('沼'),('消'),('渉'),('湘'),('焼'),('焦'),('章'),('笑');
insert into t1 (a) values ('照'),('症'),('省'),('硝'),('礁'),('祥'),('称'),('粧');
select a,b from t1 order by a,b;
select a from t1 order by a desc,b;
drop table t1;

create table t2 (a varchar (20) not null, b int not null primary key auto_increment, index (a,b)) character set cp932 collate cp932_japanese_ci;
insert into t2 (a) values ('沼'),('消'),('渉'),('湘'),('焼'),('焦'),('章'),('笑');
insert into t2 (a) values ('照'),('症'),('省'),('硝'),('礁'),('祥'),('称'),('粧');
select a,b from t2 order by a,b;
select a from t2 order by a desc,b;
drop table t2;

create table t2 (a varchar (20) not null, b int not null primary key auto_increment, index (a,b)) character set cp932 collate cp932_japanese_ci;
insert into t2 (a) values ('沼'),('消'),('渉'),('湘'),('焼'),('焦'),('章'),('笑');
insert into t2 (a) values ('照'),('症'),('省'),('硝'),('礁'),('祥'),('称'),('粧');
select a,b from t2 order by a,b;
select a from t2 order by a desc,b;
drop table t2;

