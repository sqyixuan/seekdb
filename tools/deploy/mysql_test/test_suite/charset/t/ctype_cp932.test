SET @old_character_set_client= @@character_set_client;
SET @old_character_set_connection= @@character_set_connection;
SET @old_character_set_results= @@character_set_results;
SET character_set_client= 'utf8mb3';
SET character_set_connection= 'utf8mb3';
SET character_set_results= 'utf8mb3';

select _cp932 'abcd_ｶ';

################################
## test charset handler api   ##
################################

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    text_column VARCHAR(255) CHARACTER SET cp932
);
INSERT INTO t1 (text_column) VALUES
('This is a plain string'),
('This is a string with special characters: ｧ,ｨ,ｩ,ｪ,ｫ'),
(''),
('沼,消,渉,湘,焼,焦,照,症,省,硝,礁,祥,称,章,笑,粧'),
('Another string with special characters: 奓,奛,奝,奣,妤,妺,孖,寀,甯,寘,寬,尞,岦,岺,峵,崧');

# 1. well_formed_len
INSERT INTO t1 (text_column) VALUES(0x82B0F);
# 2. mbcharlen, numchars
select length(text_column), char_length(text_column) from t1;
# 3. charpos
select substr(text_column, 2, 3) from t1;
drop table t1;
# 4. mb_wc, wc_mb
CREATE TABLE t1 (a char(1) character set cp932);
