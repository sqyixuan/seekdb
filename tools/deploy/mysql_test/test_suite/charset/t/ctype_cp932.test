# 3. test like_range & wildcmp

create table t1 (a varchar (20) not null, b int not null primary key auto_increment, index (a,b)) character set cp932 collate cp932_japanese_ci;
insert into t1 (a) values ('沼沼'),('消消'),('渉'),('湘'),('焼'),('焦'),('章'),('笑');
insert into t1 (a) values ('照'),('症'),('省'),('湘硝渉'),('礁'),('祥'),('称'),('粧');

--sorted_result
select * from t1 where a like "沼%";
--sorted_result
select * from t1 where a like binary "%渉%";
--sorted_result
select * from t1 where a like "%硝%";
--sorted_result
select * from t1 where a like "%焦%";
--sorted_result
select * from t1 where a like "%硝渉%";
drop table t1;

create table t1 (a varchar (20) not null, b int not null primary key auto_increment, index (a,b)) character set cp932 collate cp932_bin;
insert into t1 (a) values ('沼沼'),('消消'),('渉'),('湘'),('焼'),('焦'),('章'),('笑');
insert into t1 (a) values ('照'),('症'),('省'),('湘硝渉'),('礁'),('祥'),('称'),('粧');

--sorted_result
select * from t1 where a like "沼%";
--sorted_result
select * from t1 where a like binary "%渉%";
--sorted_result
select * from t1 where a like "%硝%";
--sorted_result
select * from t1 where a like "%焦%";
--sorted_result
select * from t1 where a like "%硝渉%";
drop table t1;

# 4. test instr
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    str VARCHAR(255) CHARACTER SET cp932 COLLATE cp932_japanese_ci NOT NULL
);
INSERT INTO t1 (str) VALUES
    ('This is a test string with some special characters: 沼,消,渉,湘,焼,焦,照,症,省,硝,礁,祥,称,章,笑,粧'),
    ('Just another string without special chars: 奓,奛,奝,奣,妤,妺,孖,寀,甯,寘,寬,尞,岦,岺,峵,崧');
SELECT LOCATE('沼', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('消', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('焦', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('章', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('奝', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('奣', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('寀', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('岦', str) AS position FROM t1 WHERE id = 1;
SELECT id, LOCATE('xyz', str) FROM t1;
SELECT id, LOCATE('This', str) FROM t1;
drop table t1;

CREATE TABLE t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    str VARCHAR(255) CHARACTER SET cp932 COLLATE cp932_bin NOT NULL
);
INSERT INTO t1 (str) VALUES
    ('This is a test string with some special characters: 沼,消,渉,湘,焼,焦,照,症,省,硝,礁,祥,称,章,笑,粧'),
    ('Just another string without special chars: 奓,奛,奝,奣,妤,妺,孖,寀,甯,寘,寬,尞,岦,岺,峵,崧');
SELECT LOCATE('沼', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('消', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('焦', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('章', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('奝', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('奣', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('寀', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('岦', str) AS position FROM t1 WHERE id = 1;
SELECT id, LOCATE('xyz', str) FROM t1;
SELECT id, LOCATE('This', str) FROM t1;
drop table t1;

