# owner: jim.wjh
# owner group: SQL3
# description: test charset collation varialbes
# character_set_server is only read in OB
# server:character_set_server & collation_server
#
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
set names utf8mb4;
show variables like 'character_set_server';
#set character_set_server='utf8';
#show variables like 'character_set_server';

show variables like'collation_server';
set collation_server='utf8mb4_bin';
show variables like'collation_server';
set collation_server='utf8_bin';
show variables like'collation_server';
set collation_server='utf8_general_ci';
show variables like'collation_server';
set collation_server='gbk_bin';
show variables like'collation_server';
set collation_server='gbk_chinese_ci';
show variables like'collation_server';

#illegal or undefinition
--error 1115
set character_set_server='qa';
show variables like 'character_set_server';
--error 1273
set collation_server='qa_bin';
show variables like'collation_server';

#database：character_set_database & collation
show variables like 'character_set_database';
set character_set_database='utf8';
show variables like 'character_set_database';
set character_set_database='gbk';
show variables like 'character_set_database';

show variables like'collation_database';
set collation_database='utf8mb4_bin';
show variables like'collation_database';
set collation_database='utf8_bin';
show variables like'collation_database';
set collation_database='utf8_general_ci';
show variables like'collation_database';
set collation_database='gbk_bin';
show variables like'collation_database';
set collation_database='gbk_chinese_ci';
show variables like'collation_database';

#illegal or undefinition
--error 1115
set character_set_database='qa';
show variables like 'character_set_database';
--error 1273
set collation_database='qa_bin';
show variables like'collation_database';
set names utf8mb4;
