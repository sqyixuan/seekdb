# owner: wuyuming.wym
# owner group: SQL1

--enable_sorted_result

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--disable_warnings

# 查看目前系统是否支持gb18030_2022
show collation like 'gb18030_2022%';
show charset like 'gb18030_2022%';

create table t1(c1 varchar(100) collate gb18030_bin);
create table t2(c1 varchar(100) collate gb18030_2022_bin);

insert into t1 values('abcdef');
insert into t1 values('中国');
insert into t1 values('你');
insert into t1 values('哈哈');
insert into t1 values('匲匳');
insert into t1 values('じす');
insert into t1 values('ò ū ú ǔ ù ǖ ǘ ǚ ǜ ü ê ɑ');


insert into t2 values('abcdef');
insert into t2 values('中国');
insert into t2 values('你');
insert into t2 values('哈哈');
insert into t2 values('匲匳');
insert into t2 values('じす');
insert into t2 values('ò ū ú ǔ ù ǖ ǘ ǚ ǜ ü ê ɑ');

# 查询t1和t2，结果完全相同
select c1, hex(c1) from t1;
select c1, hex(c1) from t2;

# 插入映射关系交换的字符
insert into t1 values(_gb18030 0xA6D9);
insert into t1 values(_gb18030 0x84318334);
insert into t1 values(_gb18030 0xFE6D);
insert into t1 values(_gb18030 0xA6D9);
insert into t1 values(_gb18030 0x84318334);
insert into t1 values(_gb18030 0xFE6D);

insert into t2 values(_gb18030_2022 0x84318236);
insert into t2 values(_gb18030_2022 0xA6ED);
insert into t2 values(_gb18030_2022 0x82359131);
insert into t2 values(_gb18030_2022 0x84318236);
insert into t2 values(_gb18030_2022 0xA6ED);
insert into t2 values(_gb18030_2022 0x82359131);


# 查询t1和t2，结果完全相同
select c1, hex(convert(c1 using utf8mb4)) from t1;
select c1, hex(convert(c1 using utf8mb4)) from t2;

# 不允许 gb18030 与 gb18030_2022 的隐式转换
--error 1267
select t1.c1, t2.c1 from t1, t2 where t1.c1 = t2.c1;
--error 1267
select t1.c1, t2.c1 from t1, t2 where convert(t1.c1 using gb18030) = t2.c1;
--error 1267
select t1.c1, t2.c1 from t1, t2 where convert(t2.c1 using gb18030_2022) = t1.c1;
--error 1267
insert into t1 select * from t2;
--error 1267
insert into t1 values ((select c1 from t2 limit 1));
--error 1267
insert into t1 values (_gb18030_2022 0xA6ED);
--error 1267
insert into t2 values (_gb18030 0xA6ED);

select t1.c1, t2.c1 from t1, t2 where convert(t1.c1 using gb18030_2022) = t2.c1;
select t1.c1, t2.c1 from t1, t2 where convert(t2.c1 using gb18030) = t1.c1;

# 测试gb18030_2022和utf8mb4一起参与表达式计算
drop table t1;
drop table t2;

create table t1(c1 varchar(100) collate gb18030_2022_chinese_ci);
insert into t1 values('中');
insert into t1 values('过');
# 这里常量是utf8mb4编码
select c1 from t1 where c1 = '中';
select concat('OB宇宙', c1) from t1;

insert into t1 values('A');
insert into t1 values('c');
insert into t1 values('C');
insert into t1 values('F');

# 测试大小写不敏感
select c1 from t1 order by c1;

# 测试插入空串和NULL
insert into t1 values('');
insert into t1 values(NULL);

insert into t1 values('阿');
insert into t1 values('操');
insert into t1 values('植');
insert into t1 values('丕');
insert into t1 values('一');
insert into t1 values('𠆱');
insert into t1 values(_gb18030_2022 0x9939e336);

--disable_sorted_result
select c1, HEX(weight_string(c1)) from t1 order by c1;

create table t2(c1 varchar(100) collate gb18030_2022_bin);
insert into t2 select * from t1;
select c1, HEX(weight_string(c1)) from t2 order by c1;
drop table t2;

create table t2(c1 varchar(100) collate gb18030_2022_chinese_cs);
insert into t2 select * from t1;
select c1, HEX(weight_string(c1)) from t2 order by c1;
drop table t2;

create table t2(c1 varchar(100) collate gb18030_2022_radical_ci);
insert into t2 select * from t1;
select c1, HEX(weight_string(c1)) from t2 order by c1;
drop table t2;

create table t2(c1 varchar(100) collate gb18030_2022_radical_cs);
insert into t2 select * from t1;
select c1, HEX(weight_string(c1)) from t2 order by c1;
drop table t2;

create table t2(c1 varchar(100) collate gb18030_2022_stroke_ci);
insert into t2 select * from t1;
select c1, HEX(weight_string(c1)) from t2 order by c1;
drop table t2;

create table t2(c1 varchar(100) collate gb18030_2022_stroke_cs);
insert into t2 select * from t1;
select c1, HEX(weight_string(c1)) from t2 order by c1;
drop table t2;

# simplify order by
create table t2(c1 varchar(100) collate gb18030_2022_bin, c2 varchar(100) collate gb18030_2022_bin);
insert into t2 select c1,c1 from t1;
explain select c1, HEX(weight_string(c1)) from t2 where c1 = c2 order by c1, c2;
drop table t2;

--enable_sorted_result

# 测试指定表和列的collation
drop table t1;
create table t1(c1 varchar(100) collate gb18030_2022_bin) charset gb18030_2022;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

drop table t1;

--disable_warnings
drop database if exists charset_db1;
--enable_warnings

create database charset_db1 charset gb18030_2022;
use charset_db1;
set character set 'binary';
set character set gb18030_2022;
drop database charset_db1;

create database charset_db1 charset gbk;
use charset_db1;
set character set 'binary';
set character set gb18030_2022;
drop database charset_db1;

set names utf8mb4;


