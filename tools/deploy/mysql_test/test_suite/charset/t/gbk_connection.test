# owner: jim.wjh
# owner group: SQL2
# tags: datatype,charset

--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
SET NAMES gbk;

set character_set_results = utf8mb4;

--disable_warnings
drop view if exists v1;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

--character_set gbk

--disable_query_log
--disable_warnings
drop table if exists 数据表;
--enable_warnings

create table 数据表(列1 int, 列2 date);
insert into 数据表 values(1, '1992-12-12');
insert into 数据表(列2) values('1965-1-30');
select * from 数据表;
select 列1 from 数据表;
drop table 数据表;

--disable_warnings
drop table if exists 数据表123;
drop table if exists `表格`;
drop table if exists `隞嗷`;
--enable_warnings

create table 数据表123 (第一列 int, 第二列 date);
drop table 数据表123;

--echo #Test char U+E5E5 in GBK pua area
create table t_ (c1 int);
drop table t_;

--echo #Test backtick for identifier
create table `表格`(c1 int);
create table `隞嗷`(c1 int);
drop table 表格;
drop table 隞嗷;

--enable_query_log

create table t1(c1 varchar(100), c2 varchar(100), c3 varchar(100), c4 varchar(100)) charset gbk;

--disable_query_log
insert into t1 values('錦田', 'ABC', '錦\田\', 'DEF');
insert into t1 values('\錦\田', 'ABC', '錦田', 'DEF');
insert into t1 values('\\錦田\\\'', 'ABC', '錦\n田', 'DEF');
insert into t1 values('錦\\田', 'ABC', '錦\n田', 'DEF');
insert into t1 values('錦\n田', 'ABC', '錦\\田', 'DEF');
insert into t1 values('錦\田', 'ABC', '\\錦\\田\\', 'DEF');
#insert into t1 values('\錦\', 'ABC', 'A\錦\\田', 'DEF');
insert into t1 values('中国浙江宁波null浙江省宁波市北仑区 新碶镇阿里巴巴网吧','Y','2011-04-23 20:13:19.000000','2011-04-23 20:13:19.000000');
--enable_query_log

select c1, hex(c1) from t1;
select * from t1;

drop table t1;

--echo #issue gbk connection view const value

create table t1(c1 varchar(10)) charset gbk;
insert into t1 values('1');
insert into t1 values('2');
--disable_query_log
--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as select (case when (c1 = '1') then '电子油票' when (c1 = '2') then '优惠' else c1 end) as PAY_OIL_TYPE from t1;
--enable_query_log
select * from v1;
drop table t1;


--echo #issue gbk connection obj print cause fk check failed

create table t1(c1 varchar(100) primary key) charset utf8mb4;
create table t2(c1 int, c2 varchar(100), CONSTRAINT fk1 FOREIGN KEY(c2) REFERENCES t1 (c1));
--disable_query_log
insert into t1 values('上海');
insert into t1 values('北京');
insert into t2 values(1, '上海');
insert into t2 values(1, '北京');
--error 1452
insert into t2 values(1, '杭州');
--enable_query_log
drop table t2;
drop table t1;

--echo #issue 28024142
--disable_warnings
drop table if exists user_test;
--enable_warnings
--disable_query_log
CREATE TABLE user_test
(
id INT(11) PRIMARY KEY,
name VARCHAR(22) character set gbk,
asdfasdf VARCHAR(50) character set gbk DEFAULT '北京'
)DEFAULT CHARACTER SET = gbk;
--enable_query_log

insert into user_test(id) values(1);
select * from user_test;
drop table user_test;
select md5('你好') R from dual;

--echo #issue 
--disable_warnings
drop table if exists 表3;
--enable_warnings
CREATE TABLE 表3(编码 int default 1, 姓名 varchar(10) default '中文', 总体 varchar(20) generated always as (concat(编码,'姓名')) stored not null COMMENT '编码姓名');
INSERT INTO 表3(编码, 姓名) values(1, '你好');
UPDATE 表3 SET 编码=2;
SELECT * FROM 表3;
drop table 表3;

--echo #issue 
--disable_warnings
drop table if exists user_test;
--enable_warnings

CREATE TABLE user_test
(
id INT(11) PRIMARY KEY,
name VARCHAR(22) character set gbk,
location VARCHAR(50) character set gbk DEFAULT '北京'
)DEFAULT CHARACTER SET = gbk;

desc user_test;

