###################################################
#replace
##################################################
--disable_warnings
drop table if exists t1;
--enable_warnings
########################
#use in table
#######################
create table t1(c1 varchar(2) character set utf8 collate utf8_general_ci primary key,c2 varchar(10));
replace into t1 (c1,c2) values ('1','first');
replace into t1 (c1,c2) values (_binary'1','second');
replace into t1 (c1,c2) values (_utf8'1'collate utf8_bin,'second');
select * from t1;



################
#use in string
###############
# replace treat 'a' As 'A' ignore collation
select replace(_utf8'abcv'collate utf8_general_ci,_utf8'BC'collate utf8_general_ci,_utf8'nan' collate utf8_general_ci);

##############
#use different collation in a function
#bug #6357240 暂时不修改了结果集
#--error 1267
#select replace(_utf8'abcv'collate utf8_bin,_utf8'bc'collate utf8_bin,_utf8'nan' collate utf8_general_ci);


#############
#charset binary
#select replace('abcv'collate binary,'bc'collate binary,'nan' collate binary);
select replace(_binary'abcv',_binary'bc',_binary'nan');


########################################################
#operation effected by collation
########################################################
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 varchar(10)) charset utf8mb4 collate utf8mb4_general_ci;
insert into t1 values(1,'a1'),(2,'A2'),(3,'bC'),(4,'bc'),(5,null),(6,'');
select * from t1;

#order by  utf8mb4_bin & utf8mb4_general_ci
select * from t1 order by c2 collate utf8mb4_general_ci;
select * from t1 order by c2 collate utf8mb4_bin;
 
#group by & having  utf8mb4_bin & utf8mb4_general_ci
select *from t1 group by c1 having c2>'a1' collate utf8_general_ci;
select *from t1 group by c1 having c2>'a1' collate utf8_bin;

#max utf8mb4_bin & utf8mb4_general_ci
select max(c2 collate utf8mb4_general_ci) from t1;
select max(c2 collate utf8mb4_bin) from t1;


#distinct utf8mb4_bin & utf8mb4_general_ci
select distinct c2  collate utf8mb4_general_ci from t1;
select distinct c2  collate utf8mb4_bin from t1;

#select utf8mb4_bin & utf8mb4_general_ci
select * from t1 where c2='bc' collate utf8_general_ci;
select * from t1 where c2='bc' collate utf8_bin;

################################################
#AVG COUNT MIN SUM
################################################
#min
select min(c2 collate utf8mb4_general_ci) from t1;
select min(c2 collate utf8mb4_bin) from t1;

#count
select count(c2 collate utf8mb4_general_ci) from t1;
select count(c2 collate utf8mb4_bin) from t1;

#sum
select sum(c2 collate utf8mb4_general_ci) from t1;
select sum(c2 collate utf8mb4_bin) from t1;

#avg
select avg(c2 collate utf8mb4_general_ci) from t1;
select avg(c2 collate utf8mb4_bin) from t1;


#order by
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 binary(10));
insert into t1 values('ADE'),('abc'),('aac');
select hex(c1) from t1 order by binary c1;


