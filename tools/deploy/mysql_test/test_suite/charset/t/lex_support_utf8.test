--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner:dachuan.sdc
# owner group: SQL3
# tags: charset
# description:test support utf-8 characters without quotes
--disable_warnings
drop database if exists 一深;
--enable_warnings
create database 一深;
use 一深;

create table 哈a哈(v1 int);
create table a哈哈(v1 int);
show tables;

create table 蚂蚁金服(工号 int, 部门 varchar(10), 入职日期 date);
insert into 蚂蚁金服 values(10000, 'oceanbase', '2018-7-1');
insert into 蚂蚁金服 values(1024, '风控', '2018-1-1');

create table 阿里巴巴(工号 int, 岗位 varchar(20));
insert into 阿里巴巴 values(10000, '产品经理');

select 工号 from 蚂蚁金服;
select 部门 from 蚂蚁金服;
select 入职日期 from 蚂蚁金服;

alter table 蚂蚁金服 add column 年龄 int;
alter table 蚂蚁金服 drop column 年龄;

select 支付宝.入职日期, 淘宝.岗位 from 蚂蚁金服 支付宝, 阿里巴巴 淘宝 where 支付宝.工号 = 淘宝.工号;
update 蚂蚁金服 set 工号=1025 where 工号=1024;
alter table 阿里巴巴 alter column 岗位 set default '开发';

create table таблица (столбец int, Второй int);
insert into таблица values (1, 1);
select (select 1 from таблица order by столбец) from таблица;
select столбец from таблица where 1 in (select 1 from таблица order by столбец) ;
insert into таблица values(1, 1);
select столбец+1 嘿嘿, Второй+1 哈哈 from таблица;

create table 테이블 (번째 int);
select * from 테이블 order by 번째;
insert into 테이블 values(1);
select 번째+10 from 테이블;

create table ｱｱｱ(ｷｷｷ int);
insert into ｱｱｱ values(1);
insert into ｱｱｱ values(2);
insert into ｱｱｱ values(3);
select あああ.ｷｷｷ from ｱｱｱ あああ;

show tables;
