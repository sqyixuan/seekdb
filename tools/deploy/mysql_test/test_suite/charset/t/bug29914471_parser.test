--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL1
# description: verify bug 
################################################################

--disable_abort_on_error

SELECT *
FROM (SELECT product, channel, amount_sold FROM sales)
PIVOT(SUM(amount_sold)
FOR      CHANNEL IN(3 AS 直营店,
4 AS 电商,
5 AS 自媒体,
9 AS 加盟店))
ORDER BY product;

