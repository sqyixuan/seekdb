--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL3
# description: foobar
#--source include/have_utf8.inc
--disable_warnings
drop database if exists `锞嗭編锞濓胶锞瀈;
drop database if exists `鏃ユ湰瑾瀈;
drop database if exists `榫旈緰榫梎;
--enable_warnings

#
# Test Creating databases using Japanese charact for DB name in utf8 encoding
#

SET NAMES utf8;
SET character_set_database = 'utf8';

CREATE DATABASE `锞嗭編锞濓胶锞瀈;
CREATE DATABASE `鏃ユ湰瑾瀈;
CREATE DATABASE `榫旈緰榫梎;

SELECT schema_name from information_schema.schemata where schema_name <> 'mtr';

USE `锞嗭編锞濓胶锞瀈;
USE `鏃ユ湰瑾瀈;
USE `榫旈緰榫梎;

DROP DATABASE `锞嗭編锞濓胶锞瀈;
DROP DATABASE `鏃ユ湰瑾瀈;
DROP DATABASE `榫旈緰榫梎;
