--disable_warnings
SELECT
  hex(a),
  hex(@u:=convert(a using utf8mb4)),
  hex(@l:=convert(@u using gb2312)),
  a, @u, @l,
  a=@l FROM t1;
--enable_warnings

# 6. caseup, casedn
select upper(a), lower(a) from t1;
--disable_warnings
drop table t1;
--enable_warnings


# load data
# Load the following data in table
--source mysql_test/test_suite/charset/include/copy_data_for_direct_load.inc

--disable_warnings
drop table if exists `表1`;
--enable_warnings

CREATE TABLE `表1` (`列` char(100), INDEX(`列`)) DEFAULT CHARSET = gb2312;
LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/general.dat' INTO TABLE `表1` CHARACTER SET gb2312;
select * from `表1`;
