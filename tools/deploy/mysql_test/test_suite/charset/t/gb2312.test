# owner: wuxiaojia.wxj
# description: test gb2312

--disable_warnings
drop table if exists gb2312;
--enable_warnings

create table gb2312(v varchar(10)) character set gb2312;
# alter table gb2312()

--disable_warnings
select _gb2312 '啊';
--enable_warnings

INSERT INTO gb2312(v) VALUES('、');
INSERT INTO gb2312(v) VALUES('啊');
INSERT INTO gb2312(v) VALUES('あ');
INSERT INTO gb2312(v) VALUES('ㄅ');
INSERT INTO gb2312(v) VALUES('啊');
INSERT INTO gb2312(v) VALUES('齄');
INSERT INTO gb2312(v) VALUES('鼾');
INSERT INTO gb2312(v) VALUES('髯');
INSERT INTO gb2312(v) VALUES('拽');

alter table gb2312 convert to character set gb2312 collate gb2312_bin;
select v, hex(v), hex(weight_string(v)) as hex_weight, conv(hex(weight_string(v)), 16, 10) from gb2312;

alter table gb2312 convert to character set gb2312 collate gb2312_chinese_ci;
select v, hex(v), hex(weight_string(v)) as hex_weight, conv(hex(weight_string(v)), 16, 10) from gb2312;

# test charset handler api
CREATE TABLE t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    text_column VARCHAR(255) CHARACTER SET gb2312 NOT NULL
);
INSERT INTO t1 (text_column) VALUES
('This is a plain string'),
('This is a string with special characters: 啊啊啊, ああ, ㄅㄅ, 髯髯髯髯, 拽, 齄'),
(''),
('啊啊啊, ああ, ㄅㄅ, 髯髯髯髯, 拽, 齄'),
('Another string with special characters: Б, ббб, ┎, ╊');

# 1. well_formed_len
# INSERT INTO t1 (text_column) VALUES(0xFFFFF);
select * from t1;

# 2. mbcharlen, numchars
select length(text_column), char_length(text_column) from t1;

# 3. charpos
select substr(text_column, 2, 3) from t1;
--disable_warnings
drop table t1;
--enable_warnings

# 4. mb_wc, wc_mb
CREATE TABLE t1 (a char(1) character set gb2312);

INSERT INTO t1 VALUES          (0xB0A1),(0xB0A2),(0xB0A3),(0xB0A4),(0xB0A5),(0xB0A6),(0xB0A7);
INSERT INTO t1 VALUES (0xB0A8),(0xB0A9),(0xB0AA),(0xB0AB),(0xB0AC),(0xB0AD),(0xB0AE),(0xB0AF);
