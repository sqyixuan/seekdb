# owner: jim.wjh
# owner group: SQL1

--enable_sorted_result

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--disable_warnings

# 查看目前系统是否支持gb18030
show collation like 'gb18030%';
show charset like 'gb18030%';

# gb18030兼容gbk，这里测试兼容性
create table t1(c1 varchar(100) collate gbk_bin);
create table t2(c1 varchar(100) collate gb18030_bin);

insert into t1 values('abcdef');
insert into t1 values('中国');
insert into t1 values('你');
insert into t1 values('哈哈');
insert into t1 values('匲匳');
insert into t1 values('じす');
insert into t1 values('ò ū ú ǔ ù ǖ ǘ ǚ ǜ ü ê ɑ');

insert into t2 values('abcdef');
insert into t2 values('中国');
insert into t2 values('你');
insert into t2 values('哈哈');
insert into t2 values('匲匳');
insert into t2 values('じす');
insert into t2 values('ò ū ú ǔ ù ǖ ǘ ǚ ǜ ü ê ɑ');

# 查询t1和t2，结果完全相同
select c1, hex(c1) from t1;
select c1, hex(c1) from t2;

# gb18030无法和gbk比较，MySQL比较规决定
--error 1267
select t1.c1, t2.c1 from t1, t2 where t1.c1 = t2.c1;

# 插入gb18030支持的字符，而gbk不支持的字符
--error 1366
insert into t1 values('ȍ');

insert into t2 values('ȍ');
insert into t2 values('ζ');
insert into t2 values('؆');
insert into t2 values('؄');
select c1, hex(c1) from t2;

# 测试gb18030和utf8mb4一起参与表达式计算
drop table t1;
drop table t2;

create table t1(c1 varchar(100) collate gb18030_chinese_ci);
insert into t1 values('中');
insert into t1 values('过');
# 这里常量是utf8mb4编码
select c1 from t1 where c1 = '中';
select concat('OB宇宙', c1) from t1;

insert into t1 values('A');
insert into t1 values('c');
insert into t1 values('C');
insert into t1 values('F');

# 测试大小写不敏感
select c1 from t1 order by c1;

# 测试插入空串和NULL
insert into t1 values('');
insert into t1 values(NULL);

# 测试指定表和列的collation
drop table t1;
create table t1(c1 varchar(100) collate gb18030_bin) charset gb18030;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;


--echo  ##issue[30307361] set character set导致connection collation被修改为gb18030
--disable_warnings
drop database if exists charset_db1;
--enable_warnings

create database charset_db1 charset gb18030;
use charset_db1;
set character set 'binary';
set character set gb18030;
drop database charset_db1;

create database charset_db1 charset gbk;
use charset_db1;
set character set 'binary';
set character set gb18030;
drop database charset_db1;

set names utf8mb4;


