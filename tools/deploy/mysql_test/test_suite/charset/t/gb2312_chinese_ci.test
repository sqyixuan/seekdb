#
# Test collation gb2312_chinese_ci
#
# owner: sanquan.qz
# owner group: SQL3

set names gb2312;
--character_set gb2312

let $old_collation_schema= `SELECT @@collation_database`;
eval ALTER SCHEMA test COLLATE gb2312_chinese_ci;
set @@collation_connection=gb2312_chinese_ci;
select @@collation_connection;

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

# test collation handler api

# 1. test strnncoll, strnncollsp

CREATE TABLE t1 (
s1 CHAR(10) CHARACTER SET gb2312 COLLATE gb2312_chinese_ci
);
show create table t1;
INSERT INTO t1 VALUES ('가');
INSERT INTO t1 VALUES ('간');
INSERT INTO t1 VALUES ('곌');
INSERT INTO t1 VALUES ('깬');
INSERT INTO t1 VALUES ('깻');
INSERT INTO t1 VALUES ('껙');
INSERT INTO t1 VALUES ('닙');
INSERT INTO t1 VALUES ('덕');
INSERT INTO t1 VALUES ('따');
INSERT INTO t1 VALUES ('땋');
INSERT INTO t1 VALUES ('륙');
SELECT DISTINCT s1 FROM t1;
SELECT s1,COUNT(*) FROM t1 GROUP BY s1;
SELECT COUNT(DISTINCT s1) FROM t1;
SELECT FIELD('간',s1), FIELD('껙',s1), s1='간따껙땋', s1='간따껙땋' FROM t1;
--disable_warnings
DROP TABLE t1;
--enable_warnings

create table t1 (a char (20) not null, b int not null primary key auto_increment, index (a,b)) character set gb2312 collate gb2312_chinese_ci;
INSERT INTO t1(a) VALUES('、');
INSERT INTO t1(a) VALUES('가');
INSERT INTO t1(a) VALUES('ㄲ');
INSERT INTO t1(a) VALUES('㉴');
INSERT INTO t1(a) VALUES('가');
INSERT INTO t1(a) VALUES('鈑');
INSERT INTO t1(a) VALUES('辦');
INSERT INTO t1(a) VALUES('通');
INSERT INTO t1(a) VALUES('樓');
select a,b from t1 order by a,b;
select a from t1 order by a desc,b;

create table t2 (a varchar (20) not null, b int not null primary key auto_increment, index (a,b)) character set gb2312 collate gb2312_chinese_ci;
INSERT INTO t1(a) VALUES('、');
INSERT INTO t1(a) VALUES('가');
INSERT INTO t1(a) VALUES('ㄲ');
INSERT INTO t1(a) VALUES('㉴');
INSERT INTO t1(a) VALUES('가');
INSERT INTO t1(a) VALUES('鈑');
INSERT INTO t1(a) VALUES('辦');
INSERT INTO t1(a) VALUES('通');
INSERT INTO t1(a) VALUES('樓');
select a,b from t2 order by a,b;
select a from t2 order by a desc,b;
--disable_warnings
DROP TABLE t2;
--enable_warnings

# 2. test strnxfrm, strnxfrmlen

#
# Test of special character in german collation
#

SELECT HEX(weight_string('간'));
SELECT HEX(weight_string('곌'));
SELECT HEX(weight_string('깬'));
SELECT HEX(weight_string('깻'));
SELECT HEX(weight_string('껙'));
SELECT HEX(weight_string('닙'));
SELECT HEX(weight_string('덕'));
SELECT HEX(weight_string('따'));
SELECT HEX(weight_string('땋'));
SELECT HEX(weight_string('륙'));
SELECT HEX(weight_string('간' as char(1)));
SELECT HEX(weight_string('곌' as char(1)));
SELECT HEX(weight_string('깬' as char(1)));
SELECT HEX(weight_string('깻' as char(1)));
SELECT HEX(weight_string('껙' as char(1)));
SELECT HEX(weight_string('닙' as char(1)));
SELECT HEX(weight_string('덕' as char(1)));
SELECT HEX(weight_string('따' as char(1)));
SELECT HEX(weight_string('땋' as char(1)));
SELECT HEX(weight_string('륙' as char(1)));



# 3. test like_range & wildcmp

--sorted_result
select * from t1 where a like "곌%";
--sorted_result
select * from t1 where a like binary "%껙%";
--sorted_result
select * from t1 where a like "%땋%";
--sorted_result
select * from t1 where a like "%따%";
--disable_warnings
drop table t1;
--enable_warnings

# 4. test instr

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

CREATE TABLE t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    str VARCHAR(255) CHARACTER SET gb2312 COLLATE gb2312_chinese_ci NOT NULL
);

INSERT INTO t1 (str) VALUES
    ('侶角寧몸꿎桿俚륜눔，관벵寧硅景喝볶俚：간，곌，깬，껙，닙，덕，따，땋，륙，鹿섟莉북俚륜：x간，x곌，x깬，x껙，x닙，x덕，x따，x땋，x륙.'),
    ('怜角寧뙈꼇벵景喝볶俚돨팹繫匡굶。');
SELECT LOCATE('간', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('곌', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('깬', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('껙', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('닙', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('덕', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('따', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('땋', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('륙', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('x간', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('x곌', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('x깬', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('x껙', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('x닙', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('x덕', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('x따', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('x땋', str) AS position FROM t1 WHERE id = 1;
SELECT LOCATE('x륙', str) AS position FROM t1 WHERE id = 1;


SELECT id, LOCATE('곌', str) FROM t1;
SELECT id, LOCATE('x', str) FROM t1;

--disable_warnings
DROP TABLE t1;
--enable_warnings


# 5. test hash_sort

CREATE TABLE t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    category VARCHAR(255) CHARACTER SET gb2312 COLLATE gb2312_chinese_ci NOT NULL,
    char_value VARCHAR(255) CHARACTER SET gb2312 COLLATE gb2312_chinese_ci NOT NULL
);

INSERT INTO t1 (category, char_value) VALUES
('땡膠', '챔'),
('땡膠', '뭍'),
('땡膠', '戴'),
('땡膠', '쿰'),
('濂膠', '疳'),
('濂膠', '빻'),
('濂膠', '꿇'),
('濂膠', '벎'),
('鑒俚', '寧'),
('鑒俚', '랗'),
('鑒俚', '힛'),
('鑒俚', '愷'),
('鑒俚', '巧'),
('鑒俚', '짇'),
('鑒俚', '펌'),
('鑒俚', '검'),
('鑒俚', '씽'),
('鑒俚', '枷'),
('깃듐', '！'),
('깃듐', '，'),
('깃듐', '。'),
('깃듐', '？'),
('깃듐', '；'),
('깃듐', '：'),
('깃듐', '“'),
('깃듐', '”'),
('깃듐', '、'),
('깃듐', '『'),
('깃듐', '』'),
('景喝', '≫'),
('景喝', '⊃'),
('景喝', '◑'),
('景喝', '√'),
('景喝', '∽');

SELECT category, COUNT(*) as char_count
FROM t1
GROUP BY category;
--disable_warnings
DROP TABLE t1;
--enable_warnings


# Revert the collation of the 'test' schema
eval ALTER SCHEMA test COLLATE $old_collation_schema;