--disable_warnings
drop table if exists t0;
--enable_warnings
CREATE TABLE IF NOT EXISTS t0(c0 MEDIUMINT(123) ZEROFILL  COMMENT 'asdf'  UNIQUE)  PARTITION BY KEY (c0) partitions 17;
EXPLAIN BASIC DELETE /*+parallel(5) enable_parallel_dml*/  FROM t0 WHERE ( EXISTS (SELECT 1)) AND (( EXISTS (SELECT 1)) IN (t0.c0));
DELETE /*+parallel(5) enable_parallel_dml*/  FROM t0 WHERE ( EXISTS (SELECT 1)) AND (( EXISTS (SELECT 1)) IN (t0.c0));


##bugfix: 
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1(id int, value int);
create table t2(id int, value int);
insert into t1 values(1, 0);
insert into t1 values(1, 1);
explain delete /*+ USE_PX PARALLEL(8) ENABLE_PARALLEL_DML */ t2.* from t1 left join t2 on t1.id = t2.id;
delete /*+ USE_PX PARALLEL(8) ENABLE_PARALLEL_DML */ t2.* from t1 left join t2 on t1.id = t2.id;
select * from t2;

insert into t2 values(1, 10);
explain delete /*+ USE_PX PARALLEL(8) ENABLE_PARALLEL_DML */ t2.* from t1 left join t2 on t1.id = t2.id;
delete /*+ USE_PX PARALLEL(8) ENABLE_PARALLEL_DML */ t2.* from t1 left join t2 on t1.id = t2.id;
select * from t2;
drop table t1, t2;

