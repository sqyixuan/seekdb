#owner: laibingzheng.lbz
#tags: optimizer,dml
#owner group: IMF
#tags: pdml,dml
#description: test if pdml works find with const expr subquery


--result_format 4
--enable_sorted_result

--disable_warnings

--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set _enable_defensive_check = '2';
alter system set_tp tp_no = 308, error_code = 2, frequency = 1;
connection default;
set autocommit= 0;
sleep 5;
--enable_result_log
--enable_query_log

--echo #test partition by hash
drop table if exists t1;
create table if not exists t1(c0 int)  partition by hash (c0) partitions 17;
insert into t1 values(1),(2),(3),(4),(5);
explain basic delete /*+parallel(5) enable_parallel_dml*/  from t1 where ( exists (select 1)) and (( exists (select 1)) in (t1.c0));
delete /*+parallel(5) enable_parallel_dml*/  from t1 where ( exists (select 1)) and (( exists (select 1)) in (t1.c0));
select * from t1 order by c0;
drop table t1;

--echo #test partition by key
drop table if exists t2;
create table if not exists t2(c0 int unique)  partition by key (c0) partitions 17;
insert into t2 values(1),(2),(3),(4),(5);
explain basic delete /*+parallel(5) enable_parallel_dml*/  from t2 where ( exists (select 1)) and (( exists (select 1)) in (t2.c0));
delete /*+parallel(5) enable_parallel_dml*/  from t2 where ( exists (select 1)) and (( exists (select 1)) in (t2.c0));
select * from t2 order by c0;
drop table t2;

drop table if exists t;
drop table if exists pindex;
create table pindex(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create unique index i2 on pindex(c2) global;
insert into pindex(c1,c2) values(1,2),(2,3),(3,4),(4,5);
create table t (c1 int, c2 int);
insert into t values (1,1), (2,2), (3,3);
explain basic delete /*+parallel(2),enable_parallel_dml*/ pindex from pindex,t;
delete /*+parallel(2),enable_parallel_dml*/ pindex from pindex,t;
select * from pindex;
select /*+index (pindex i2)*/ c2 from pindex;
drop table t;
drop table pindex;

connection default;
set autocommit= 1;
connection obsys;
alter system set _enable_defensive_check = '1';
alter system set_tp tp_no = 308, error_code = 0, frequency = 1;

