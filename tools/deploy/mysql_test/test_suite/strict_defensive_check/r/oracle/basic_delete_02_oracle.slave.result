      table_columns([{: ({T1: (.T1.__pk_increment, .C1, .C2, .C3)})}])
  3 - output([.C1], [.C2], [.C3], [.T1.__pk_increment]), filter(nil), rowset=256
      access([.C1], [.C2], [.C3], [.T1.__pk_increment])
  4 - output([T1.C1], [T1.C2], [T1.C3], [T1.__pk_increment]), filter(nil), rowset=256
      sort_keys([T1.C1, ASC])
  5 - output([T1.__pk_increment], [T1.C1], [T1.C2], [T1.C3]), filter([T1.C1 > 2]), rowset=256
      access([T1.__pk_increment], [T1.C1], [T1.C2], [T1.C3]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([T1.__pk_increment]), range(MIN ; MAX)always true
delete from (select * from t1 where t1.c1 > 2 order by c1);
rollback;
