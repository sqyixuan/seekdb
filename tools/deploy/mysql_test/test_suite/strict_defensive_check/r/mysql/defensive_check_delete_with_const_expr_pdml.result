result_format: 4
#test partition by hash
drop table if exists t1;
create table if not exists t1(c0 int)  partition by hash (c0) partitions 17;
insert into t1 values(1),(2),(3),(4),(5);
explain basic delete /*+parallel(5) enable_parallel_dml*/  from t1 where ( exists (select 1)) and (( exists (select 1)) in (t1.c0));
Query Plan
======================================================
|ID|OPERATOR                                |NAME    |
------------------------------------------------------
|0 |PX COORDINATOR                          |        |
|1 |└─EXCHANGE OUT DISTR                    |:EX10001|
|2 |  └─DELETE                              |        |
|3 |    └─EXCHANGE IN DISTR                 |        |
|4 |      └─EXCHANGE OUT DISTR (PKEY RANDOM)|:EX10000|
|5 |        └─PX BLOCK ITERATOR             |        |
|6 |          └─TABLE FULL SCAN             |t1      |
======================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil), rowset=16
  1 - output(nil), filter(nil), rowset=16
      dop=5
  2 - output(nil), filter(nil)
      table_columns([{t1: ({t1: (t1.__pk_increment, t1.c0)})}])
  3 - output([PARTITION_ID], [t1.TRANS_DEBUG_INFO], [t1.__pk_increment], [t1.c0]), filter(nil), rowset=16
  4 - output([PARTITION_ID], [t1.TRANS_DEBUG_INFO], [t1.__pk_increment], [t1.c0]), filter(nil), rowset=16
      (#keys=1, [t1.c0]), dop=5
  5 - output([t1.__pk_increment], [t1.c0], [t1.TRANS_DEBUG_INFO]), filter(nil), rowset=16
  6 - output([t1.__pk_increment], [t1.c0], [t1.TRANS_DEBUG_INFO]), filter([1 = t1.c0]), rowset=16
      access([t1.__pk_increment], [t1.c0]), partitions(p1)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
delete /*+parallel(5) enable_parallel_dml*/  from t1 where ( exists (select 1)) and (( exists (select 1)) in (t1.c0));
select * from t1 order by c0;
+------+
| c0   |
+------+
|    2 |
|    3 |
|    4 |
|    5 |
+------+
drop table t1;

