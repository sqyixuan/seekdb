      update([t1.c3=column_conv(INT,PS:(11,0),NULL,cast(t1.c3 + 100, INT(-1, 0)))], [t2.c4=column_conv(INT,PS:(11,0),NULL,cast(t2.c4 + 100, INT(-1, 0)))])
  1 - output([t1.TRANS_DEBUG_INFO], [t2.TRANS_DEBUG_INFO], [t1.c1], [t1.c2], [t1.c3], [t2.c1], [t2.c2], [t2.c3], [t2.c4]), filter(nil), rowset=16
