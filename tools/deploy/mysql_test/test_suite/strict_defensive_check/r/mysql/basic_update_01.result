      merge_directions([ASC])
  2 - output([t1.c1], [t1.c3], [t1.c2], [t1.TRANS_DEBUG_INFO]), filter(nil), rowset=16
      access([t1.c1], [t1.c3], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(NULL ; 3), 
      range_cond([t1.c1 < 3])
  3 - output([t2.c1], [t2.c4], [t2.c2], [t2.c3], [t2.TRANS_DEBUG_INFO]), filter(nil), rowset=16
      access([t2.c1], [t2.c4], [t2.c2], [t2.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.c1]), range(NULL ; 3), 
      range_cond([t2.c1 < 3])
update t1 left join t2 on t1.c1 = t2.c1 set t1.c3 = t1.c3 + 100, t2.c4 = t2.c4 + 100 where t1.c1 < 3;
