  4 - output([t2.c1], [t2.c2], [t2.c3], [t2.c4]), filter([lnnvl(cast(t2.c2 = 1, TINYINT(-1, 0)))]), rowset=16
      access([t2.c1], [t2.c4], [t2.c2], [t2.c3]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false], 
