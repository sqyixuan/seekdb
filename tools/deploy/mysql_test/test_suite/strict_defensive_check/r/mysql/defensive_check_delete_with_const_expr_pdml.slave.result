      table_columns([{pindex: ({pindex: (pindex.c1, pindex.c2, pindex.c3)}, {i2: (pindex.c2, pindex.c1)}), hash_distinct}])
  1 - output([pindex.TRANS_DEBUG_INFO], [pindex.c1], [pindex.c2], [pindex.c3]), filter(nil), rowset=256
