      access([pindex.c1], [pindex.c2], [pindex.c3]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([pindex.c1]), range(MIN ; MAX)always true
  6 - output(nil), filter(nil), rowset=256
