drop table notify;

drop table if exists t1;
create table t1(c1 int primary key, c2 int ,c3 int) partition by hash(c1) partitions 1;
create index i1 on t1(c2);
insert into t1 values(1,null,null);
SELECT 1
FROM   dual
ORDER  BY (SELECT /*+ordered*/1 from (SELECT 1 FROM   dual) v1,
                                         (SELECT /*+index(t1 i1)*/sum(c3) as s
                                            FROM   t1
                                            WHERE c2 IS NULL)v2);
+---+
| 1 |
+---+
| 1 |
+---+

drop table t1;

alter system set _enable_defensive_check = '1';

