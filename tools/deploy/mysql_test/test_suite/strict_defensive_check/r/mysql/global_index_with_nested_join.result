DROP TABLE IF EXISTS t0,t1,t2,t3,t4,t5,t6,t7,t8,t9;
DROP VIEW IF EXISTS v1,v2,v3,v4,v5,v6;
CREATE TABLE t1 (a int, id int primary key) partition by hash(id) partitions 2;
CREATE TABLE t2 (a int, id int primary key) partition by hash(id) partitions 2;
CREATE TABLE t3 (a int, id int primary key) partition by hash(id) partitions 2;
CREATE INDEX i1 on t1(a) global;
CREATE INDEX i2 on t2(a) global;
CREATE INDEX i3 on t3(a) global;
INSERT INTO t1 VALUES (1, 1);
INSERT INTO t2 VALUES (2, 2);
INSERT INTO t3 VALUES (2, 3);
INSERT INTO t1 VALUES (2, 4);
SELECT /*+index(t1 i1), index(t2 i2), index(t3 i3), use_nl(t2 t3), use_merge((t2, t3), t1), leading((t2, t3), t1)*/ t1.a, t1.id, t2.a, t2.id, t3.a, t3.id FROM t1 LEFT JOIN (t2 LEFT JOIN t3 ON t2.a=t3.a) ON t1.a=t3.a order by t1.id, t2.id, t3.id;
a	id	a	id	a	id
1	1	NULL	NULL	NULL	NULL
2	4	2	2	2	3
DELETE FROM t1 WHERE a=2;
SELECT /*+index(t1 i1), index(t2 i2), index(t3 i3), use_nl(t2 t3), use_merge((t2, t3), t1), leading((t2, t3), t1)*/ * FROM t1 LEFT JOIN (t2 LEFT JOIN t3 ON t2.a=t3.a) ON t1.a=t3.a order by t1.a;
a	id	a	id	a	id
1	1	NULL	NULL	NULL	NULL
DELETE FROM t2;
SELECT /*+index(t1 i1), index(t2 i2), index(t3 i3), use_nl(t2 t3), use_merge((t2, t3), t1), leading((t2, t3), t1)*/ * FROM t1 LEFT JOIN (t2 LEFT JOIN t3 ON t2.a=t3.a) ON t1.a=t3.a order by t1.a;
a	id	a	id	a	id
1	1	NULL	NULL	NULL	NULL
DROP TABLE t1,t2,t3;
CREATE TABLE t1(a int, id int primary key, key (a)) partition by hash(id) partitions 2;
CREATE TABLE t2(b int, id int primary key, key (b)) partition by hash(id) partitions 2;
CREATE TABLE t3(c int, id int primary key, key (c)) partition by hash(id) partitions 2;
