DROP VIEW v1,v2;
DROP TABLE t1,t2,t3,t4;
CREATE TABLE t1 (id1 int PRIMARY KEY, id2 int);
create index i1 on t1(id2) partition by hash(id2) partitions 2;
CREATE TABLE t2 (id1 int PRIMARY KEY, id2 int);
create index i2 on t2(id2) partition by hash(id2) partitions 2;
CREATE TABLE t3 (id1 int PRIMARY KEY, id2 int);
create index i3 on t3(id2) partition by hash(id2) partitions 2;
CREATE TABLE t4 (id1 int PRIMARY KEY, id2 int);
create index i4 on t4(id2) partition by hash(id2) partitions 2;
CREATE TABLE t5 (id1 int PRIMARY KEY, id2 int);
create index i5 on t5(id2) partition by hash(id2) partitions 2;
SELECT t1.id1 AS id, t5.id1 AS ngroupbynsa
FROM t1 INNER JOIN t2 ON t2.id2 = t1.id1
LEFT OUTER JOIN
(t3 INNER JOIN t4 ON t4.id1 = t3.id2 INNER JOIN t5 ON t4.id2 = t5.id1)
ON t3.id2 IS NOT NULL
WHERE t1.id1=2;
id	ngroupbynsa
SELECT t1.id1 AS id, t5.id1 AS ngroupbynsa
FROM t1 INNER JOIN t2 ON t2.id2 = t1.id1
LEFT OUTER JOIN
(t3 INNER JOIN t4 ON t4.id1 = t3.id2 INNER JOIN t5 ON t4.id2 = t5.id1)
ON t3.id2 IS NOT NULL
WHERE t1.id1=2;
id	ngroupbynsa
INSERT INTO t1 VALUES (1,1), (2,1), (3,2);
INSERT INTO t2 VALUES (2,1), (3,2), (4,3);
INSERT INTO t3 VALUES (1,1), (3,2), (2,NULL);
INSERT INTO t4 VALUES (1,1), (2,1), (3,3);
INSERT INTO t5 VALUES (1,1), (2,2), (3,3), (4,3);
SELECT t1.id1 AS id, t5.id1 AS ngroupbynsa
FROM t1 INNER JOIN t2 ON t2.id2 = t1.id1
LEFT OUTER JOIN
(t3 INNER JOIN t4 ON t4.id1 = t3.id2 INNER JOIN t5 ON t4.id2 = t5.id1)
ON t3.id2 IS NOT NULL
WHERE t1.id1=2;
id	ngroupbynsa
2	1
2	1
drop table t1, t2, t3, t4, t5;
CREATE TABLE t1 (
carrier char(2) default NULL,
id int NOT NULL auto_increment PRIMARY KEY
);
create index i1 on t1(carrier) partition by key(carrier) partitions 2;
