result_format: 1
explain_protocol: 2
#########################
###  默认只展示0号算子的op cost
#########################
drop table if exists t1_merge_distinct;
create table t1_merge_distinct(
pk int primary key,
c1 int,
c2 number,
c3 varchar(10),
c4 json,
c5 text);
call dbms_stats.set_table_stats(
NULL,
't1_merge_distinct',
numrows => 1000000,
avgrlen => 100,
nummicroblks => 6000
);
explain select /*+NO_USE_HASH_DISTINCT(@"SEL$1")*/ distinct c1 from t1_merge_distinct;
