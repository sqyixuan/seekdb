#########################
###  展示 -1 号算子的op cost
#########################
drop table if exists t1_subplan_filter;
create table t1_subplan_filter(
pk int primary key,
c1 int,
c2 number,
c3 varchar(10),
c4 json,
c5 text);
create index i1 on t1_subplan_filter(c2);
call dbms_stats.set_table_stats(
NULL,
't1_subplan_filter',
numrows => 1000000,
avgrlen => 100,
nummicroblks => 6000
);
