#########################
###  展示 1 号算子的op cost
#########################
#########################
###  partition sort
#########################
explain select /*+full(A) NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ count(*) from t1_sort A group by c1;
Query Plan
===================================================
|ID|OPERATOR           |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |MERGE GROUP BY     |    |10000   |0           |
|1 |└─PARTITION SORT   |    |1000000 |107138      |
|2 |  └─TABLE FULL SCAN|A   |1000000 |0           |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT(*)]), filter(nil), rowset=256
      group([A.c1]), agg_func([T_FUN_COUNT(*)])
  1 - output([A.c1]), filter(nil), rowset=256
      sort_keys([HASH(A.c1), ASC], [A.c1, ASC])
  2 - output([A.c1]), filter(nil), rowset=256
      access([A.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([A.__pk_increment]), range(MIN ; MAX)always true
#########################
###  展示 2 号算子的op cost
#########################
#########################
###  merge sort
#########################
explain select /*+index(A i1)*/ * from t2_sort A order by c1;
Query Plan
===============================================================
|ID|OPERATOR                   |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------
|0 |PX COORDINATOR MERGE SORT  |        |1000000 |0           |
|1 |└─EXCHANGE OUT DISTR       |:EX10000|1000000 |0           |
|2 |  └─SORT                   |        |1000000 |179444      |
|3 |    └─PX PARTITION ITERATOR|        |1000000 |0           |
|4 |      └─TABLE FULL SCAN    |A(i1)   |1000000 |0           |
===============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(A.c1, A.c2, A.c3, A.c4)]), filter(nil), rowset=256
      sort_keys([A.c1, ASC])
  1 - output([A.c1], [INTERNAL_FUNCTION(A.c1, A.c2, A.c3, A.c4)]), filter(nil), rowset=256
      dop=1
  2 - output([A.c1], [A.c2], [A.c3], [A.c4]), filter(nil), rowset=256
      sort_keys([A.c1, ASC]), local merge sort
  3 - output([A.c1], [A.c2], [A.c3], [A.c4]), filter(nil), rowset=256
      force partition granule
  4 - output([A.c1], [A.c2], [A.c3], [A.c4]), filter(nil), rowset=256
      access([A.__pk_increment], [A.c1], [A.c2], [A.c3], [A.c4]), partitions(p[0-3])
      is_index_back=true, is_global_index=false, 
      range_key([A.c1], [A.c2], [A.__pk_increment]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
