-------------------------------------
  0 - output([INTERNAL_FUNCTION(A.c1, A.c2, A.c3, A.c4)]), filter(nil), rowset=256
  1 - output([INTERNAL_FUNCTION(A.c1, A.c2, A.c3, A.c4)]), filter(nil), rowset=256
      dop=1
  2 - output([A.c2], [A.c1], [A.c3], [A.c4]), filter(nil), rowset=256
      group([A.c2]), agg_func(nil)
