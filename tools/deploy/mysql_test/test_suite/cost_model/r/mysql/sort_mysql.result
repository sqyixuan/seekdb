  4 - output([A.c2], [A.c1], [A.c3], [A.c4]), filter(nil), rowset=256
      (#keys=1, [A.c2]), dop=1
  5 - output([A.c2], [A.c1], [A.c3], [A.c4]), filter(nil), rowset=256
      force partition granule
  6 - output([A.c2], [A.c1], [A.c3], [A.c4]), filter(nil), rowset=256
      group([A.c2]), agg_func(nil)
  7 - output([A.c1], [A.c2], [A.c3], [A.c4]), filter(nil), rowset=256
      access([A.__pk_increment], [A.c1], [A.c2], [A.c3], [A.c4]), partitions(p[0-3])
      is_index_back=true, is_global_index=false, 
