result_format: 1
explain_protocol: 2
#########################
###  默认只展示0号算子的op cost
#########################
drop table if exists t1_sort,t2_sort;
create table t1_sort(
c1 int,
c2 int,
c3 number,
c4 varchar(10));
create index i1 on t1_sort(c1,c2);
create index i2 on t1_sort(c1,c2,c3);
create table t2_sort(
c1 int,
c2 int,
c3 number,
c4 varchar(10)) partition by hash(c1) partitions 4;
create index i1 on t2_sort(c1,c2)local;
create index i2 on t2_sort(c2,c3)local;
call dbms_stats.set_table_stats(
NULL,
't1_sort',
numrows=>1000000,
avgrlen=>256);
call dbms_stats.set_table_stats(
NULL,
't2_sort',
numrows=>1000000,
avgrlen=>256);
#########################
###  normal sort
#########################
explain select /*+full(A)*/ * from t1_sort A order by c2;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |SORT             |    |1000000 |358868      |
|1 |└─TABLE FULL SCAN|A   |1000000 |0           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([A.c1], [A.c2], [A.c3], [A.c4]), filter(nil), rowset=256
      sort_keys([A.c2, ASC])
  1 - output([A.c1], [A.c2], [A.c3], [A.c4]), filter(nil), rowset=256
      access([A.c1], [A.c2], [A.c3], [A.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([A.__pk_increment]), range(MIN ; MAX)always true
