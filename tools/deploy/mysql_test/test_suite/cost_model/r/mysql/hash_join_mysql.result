result_format: 1
explain_protocol: 2
#########################
###  默认只展示0号算子的op cost
#########################
drop table if exists t1_hash_join, t2_hash_join, t3_hash_join;
create table t1_hash_join(
c1 int,
c2 int,
c3 int,
c4 int);
create table t2_hash_join(
c1 int,
c2 int,
c3 int,
c4 int);
create table t3_hash_join(
c1 int,
c2 int,
c3 int,
c4 int)partition by hash(c1) partitions 4;
call dbms_stats.set_table_stats(
NULL,
't1_hash_join',
numrows => 1000000,
avgrlen => 100,
nummicroblks => 6000
);
call dbms_stats.set_table_stats(
NULL,
't2_hash_join',
numrows => 10000000,
avgrlen => 1000,
nummicroblks => 60000
);
call dbms_stats.set_table_stats(
NULL,
't3_hash_join',
numrows => 10000000,
avgrlen => 1000,
nummicroblks => 60000
);
#########################
###  normal hash join
#########################
explain select /*+leading(A B) use_hash(B)*/* from t1_hash_join A inner join t2_hash_join B on A.c1 = B.c1;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |HASH JOIN        |    |98010000|4115313     |
|1 |├─TABLE FULL SCAN|A   |1000000 |0           |
|2 |└─TABLE FULL SCAN|B   |10000000|0           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([A.c1], [A.c2], [A.c3], [A.c4], [B.c1], [B.c2], [B.c3], [B.c4]), filter(nil), rowset=256
      equal_conds([A.c1 = B.c1]), other_conds(nil)
  1 - output([A.c1], [A.c2], [A.c3], [A.c4]), filter(nil), rowset=256
      access([A.c1], [A.c2], [A.c3], [A.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([A.__pk_increment]), range(MIN ; MAX)always true
  2 - output([B.c1], [B.c2], [B.c3], [B.c4]), filter(nil), rowset=256
      access([B.c1], [B.c2], [B.c3], [B.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([B.__pk_increment]), range(MIN ; MAX)always true
