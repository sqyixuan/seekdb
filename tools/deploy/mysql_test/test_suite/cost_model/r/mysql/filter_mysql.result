result_format: 1
explain_protocol: 2
#########################
###  默认只展示0号算子的op cost
#########################
drop table if exists t1_filter;
create table t1_filter(
pk int primary key,
c1 int,
c2 number,
c3 varchar(10),
c4 json,
c5 text);
call dbms_stats.set_table_stats(
NULL,
't1_filter',
numrows => 1000000,
avgrlen => 100,
nummicroblks => 6000
);
explain select 1 from t1_filter where c1 > 1;
