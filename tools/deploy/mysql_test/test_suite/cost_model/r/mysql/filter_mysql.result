-------------------------------------
  0 - output([1]), filter([t1_filter.c1 > 1]), rowset=256
      access([t1_filter.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1_filter.pk]), range(MIN ; MAX)always true
