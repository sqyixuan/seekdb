result_format: 1
explain_protocol: 2
#########################
###  默认只展示0号算子的op cost
#########################
drop table if exists t1_hash_distinct;
create table t1_hash_distinct(
pk int primary key,
c1 int,
c2 number,
c3 varchar(10),
c4 json,
c5 text);
call dbms_stats.set_table_stats(
NULL,
't1_hash_distinct',
numrows => 1000000,
avgrlen => 100,
nummicroblks => 6000
);
explain select /*+USE_HASH_DISTINCT(@"SEL$1")*/ distinct c1 from t1_hash_distinct;
