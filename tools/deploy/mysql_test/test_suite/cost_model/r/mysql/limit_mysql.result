result_format: 1
explain_protocol: 2
#########################
###  默认只展示0号算子的op cost
#########################
drop table if exists t1_limit;
create table t1_limit(c1 int, c2 int, c3 int, c4 int);
call dbms_stats.set_table_stats(
NULL,
't1_limit',
numrows => 1000000,
avgrlen => 100,
nummicroblks => 6000
);
explain select * from (select /*+no_merge*/ * from t1_limit) limit 10;
Query Plan
==============================================================
|ID|OPERATOR           |NAME           |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------
|0 |LIMIT              |               |10      |1           |
|1 |└─SUBPLAN SCAN     |ANONYMOUS_VIEW1|10      |0           |
|2 |  └─TABLE FULL SCAN|t1_limit       |10      |0           |
==============================================================
Outputs & filters:
-------------------------------------
  0 - output([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.c3], [ANONYMOUS_VIEW1.c4]), filter(nil), rowset=16
      limit(10), offset(nil)
  1 - output([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.c3], [ANONYMOUS_VIEW1.c4]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.c3], [ANONYMOUS_VIEW1.c4])
  2 - output([t1_limit.c1], [t1_limit.c2], [t1_limit.c3], [t1_limit.c4]), filter(nil), rowset=16
      access([t1_limit.c1], [t1_limit.c2], [t1_limit.c3], [t1_limit.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1_limit.__pk_increment]), range(MIN ; MAX)always true
