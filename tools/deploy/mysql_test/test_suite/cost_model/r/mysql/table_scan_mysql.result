result_format: 1
explain_protocol: 2
drop table if exists t1_column_store;
drop table if exists t2_row_store;
drop table if exists t1_column_store_part;
drop table if exists t2_row_store_part;
#########################
###  默认只展示0号算子的op cost
#########################
create table t1_column_store(
pk int primary key,
c1 int,
c2 number,
c3 varchar(10),
c4 json,
c5 text) with column group (each column);
create index i1 on t1_column_store(c1);
create index i2 on t1_column_store(c2) 
with column group(each column);
create table t2_row_store(
pk int primary key,
c1 int,
c2 number,
c3 varchar(10),
c4 json,
c5 text);
create index i1 on t2_row_store(c1);
create index i2 on t2_row_store(c2) 
with column group(each column);
call dbms_stats.set_table_stats(
NULL,
't1_column_store',
numrows => 1000000,
avgrlen => 100,
nummicroblks => 6000
);
call dbms_stats.set_table_stats(
NULL,
't2_row_store',
numrows => 1000000,
avgrlen => 100,
nummicroblks => 6000
);
#########################
###  列存全表扫描
#########################
explain select /*+full(A)*/ * from t1_column_store A;
Query Plan
======================================================
|ID|OPERATOR              |NAME|EST.ROWS|EST.TIME(us)|
------------------------------------------------------
|0 |COLUMN TABLE FULL SCAN|A   |1000000 |16225965    |
======================================================
Outputs & filters:
-------------------------------------
  0 - output([A.pk], [A.c1], [A.c2], [A.c3], [A.c4], [A.c5]), filter(nil), rowset=256
      access([A.pk], [A.c1], [A.c2], [A.c3], [A.c4], [A.c5]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([A.pk]), range(MIN ; MAX)always true
