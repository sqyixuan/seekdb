drop table if exists t1_material;
create table t1_material(
pk int primary key,
c1 int,
c2 number,
c3 varchar(10),
c4 json,
c5 text);
call dbms_stats.set_table_stats(
NULL,
't1_material',
numrows => 1000000,
avgrlen => 100,
nummicroblks => 6000
);
explain select /*+blocking('all')*/ c1 from t1_material;
