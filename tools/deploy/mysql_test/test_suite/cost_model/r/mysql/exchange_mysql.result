result_format: 1
explain_protocol: 2
#########################
###  默认只展示0号算子的op cost
#########################
drop table if exists t1_exchange;
create table t1_exchange(
c1 int, c2 int, c3 int, c4 int
)partition by hash(c1) partitions 4;
call dbms_stats.set_table_stats(
NULL,
't1_exchange',
numrows => 1000000,
avgrlen => 100,
nummicroblks => 6000
);
#########################
###  展示 0 号算子的op cost
#########################
#########################
###  SEND TO LOCAL
#########################
explain select c1 from t1_exchange;
Query Plan
================================================================
|ID|OPERATOR                 |NAME       |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------
|0 |PX COORDINATOR           |           |1000000 |153910      |
|1 |└─EXCHANGE OUT DISTR     |:EX10000   |1000000 |0           |
|2 |  └─PX PARTITION ITERATOR|           |1000000 |0           |
|3 |    └─TABLE FULL SCAN    |t1_exchange|1000000 |0           |
================================================================
Outputs & filters:
-------------------------------------
