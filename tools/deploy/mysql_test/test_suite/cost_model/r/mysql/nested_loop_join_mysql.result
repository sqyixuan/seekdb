result_format: 1
explain_protocol: 2
#########################
###  默认只展示0号算子的op cost
#########################
#########################
###  展示 -1 号算子的op cost
#########################
drop table if exists t1_nested_loop_join,t2_nested_loop_join,t3_nested_loop_join,t4_nested_loop_join;
create table t1_nested_loop_join(
c1 int,
c2 int,
c3 int,
c4 int);
create table t2_nested_loop_join(
c1 int,
c2 int,
c3 int,
c4 int);
create index i1 on t2_nested_loop_join(c2);
create table t3_nested_loop_join(
c1 int,
c2 int,
c3 int,
c4 int)partition by hash(c1) partitions 4;
create index i1 on t3_nested_loop_join(c1);
create table t4_nested_loop_join(
c1 int,
c2 int,
c3 int,
c4 int);
call dbms_stats.set_table_stats(
NULL,
't1_nested_loop_join',
numrows => 1000000,
avgrlen => 100,
nummicroblks => 6000
);
call dbms_stats.set_table_stats(
NULL,
't2_nested_loop_join',
numrows => 10000000,
avgrlen => 1000,
nummicroblks => 60000
);
call dbms_stats.set_table_stats(
NULL,
't3_nested_loop_join',
numrows => 1,
avgrlen => 10,
nummicroblks => 6
);
call dbms_stats.set_table_stats(
NULL,
't4_nested_loop_join',
numrows => 1,
avgrlen => 10,
nummicroblks => 6
);
#########################
###  normal NLJ
#########################
explain select /*+leading(A B) NO_USE_NL_MATERIALIZATION(B)*/* from 
t1_nested_loop_join A left join t2_nested_loop_join B on A.c1 != B.c1
where ifnull(A.c2,1) != ifnull(B.c2,1);
Query Plan
=============================================================
|ID|OPERATOR               |NAME|EST.ROWS     |EST.TIME(us) |
-------------------------------------------------------------
|0 |NESTED-LOOP OUTER JOIN |    |9800803980981|1281856983797|
|1 |├─TABLE FULL SCAN      |A   |1000000      |95214        |
|2 |└─TABLE FULL SCAN      |B   |10000000     |952120       |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([A.c1], [A.c2], [A.c3], [A.c4], [B.c1], [B.c2], [B.c3], [B.c4]), filter([ifnull(cast(A.c2, BIGINT(20, 0)), 1) != ifnull(cast(B.c2, BIGINT(20,
       0)), 1)]), rowset=256
      conds([A.c1 != B.c1]), nl_params_(nil), use_batch=false
  1 - output([A.c1], [A.c2], [A.c3], [A.c4]), filter(nil), rowset=256
      access([A.c1], [A.c2], [A.c3], [A.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([A.__pk_increment]), range(MIN ; MAX)always true
  2 - output([B.c1], [B.c2], [B.c3], [B.c4]), filter(nil), rowset=256
      access([B.c1], [B.c2], [B.c3], [B.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([B.__pk_increment]), range(MIN ; MAX)always true
#########################
###  DAS rescan
#########################
explain select /*+leading(A B) use_nl(B) NO_USE_NL_MATERIALIZATION(B) parallel(B 2) pq_distribute(B local local) use_das(B)*/* from 
t1_nested_loop_join A left join t3_nested_loop_join B on A.c1 = B.c1
where ifnull(A.c2,1) != ifnull(B.c2,1);
Query Plan
===============================================================
|ID|OPERATOR                      |NAME |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------
|0 |NESTED-LOOP OUTER JOIN        |     |999900  |73185666    |
|1 |├─TABLE FULL SCAN             |A    |1000000 |95214       |
|2 |└─DISTRIBUTED TABLE RANGE SCAN|B(i1)|1       |73          |
===============================================================
Outputs & filters:
-------------------------------------
  0 - output([A.c1], [A.c2], [A.c3], [A.c4], [B.c1], [B.c2], [B.c3], [B.c4]), filter([ifnull(cast(A.c2, BIGINT(20, 0)), 1) != ifnull(cast(B.c2, BIGINT(20,
       0)), 1)]), rowset=256
      conds(nil), nl_params_([A.c1(:0)]), use_batch=true
  1 - output([A.c1], [A.c2], [A.c3], [A.c4]), filter(nil), rowset=256
      access([A.c1], [A.c2], [A.c3], [A.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([A.__pk_increment]), range(MIN ; MAX)always true
  2 - output([B.c1], [B.c2], [B.c3], [B.c4]), filter(nil), rowset=256
      access([GROUP_ID], [B.__pk_increment], [B.c1], [B.c2], [B.c3], [B.c4]), partitions(p[0-3])
      is_index_back=true, is_global_index=false, 
      range_key([B.c1], [B.__pk_increment]), range(MIN ; MAX), 
      range_cond([:0 = B.c1])
