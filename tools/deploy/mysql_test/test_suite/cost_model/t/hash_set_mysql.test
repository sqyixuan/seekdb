# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--source cost_model_test_begin.inc

--disable_warnings

drop table if exists t1_hash_set;

--enable_warnings


create table t1_hash_set(
  pk int primary key,
  c1 int,
  c2 number,
  c3 varchar(10),
  c4 json,
  c5 text);
  
call dbms_stats.set_table_stats(
  NULL,
  't1_hash_set',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

explain select /*+USE_HASH_SET(@"SET$1")*/ c1 from t1_hash_set union select c1 from t1_hash_set;
explain select /*+USE_HASH_SET(@"SET$1")*/ c2 from t1_hash_set union select c1 from t1_hash_set;
explain select /*+USE_HASH_SET(@"SET$1")*/ c3 from t1_hash_set union select c1 from t1_hash_set;
explain select /*+USE_HASH_SET(@"SET$1")*/ c4 from t1_hash_set union select c1 from t1_hash_set;
explain select /*+USE_HASH_SET(@"SET$1")*/ * from t1_hash_set union select * from t1_hash_set;

explain select /*+USE_HASH_SET(@"SET$1")*/ c1 from t1_hash_set intersect select c1 from t1_hash_set;
explain select /*+USE_HASH_SET(@"SET$1")*/ c2 from t1_hash_set intersect select c1 from t1_hash_set;
explain select /*+USE_HASH_SET(@"SET$1")*/ c3 from t1_hash_set intersect select c1 from t1_hash_set;
explain select /*+USE_HASH_SET(@"SET$1")*/ c4 from t1_hash_set intersect select c1 from t1_hash_set;
explain select /*+USE_HASH_SET(@"SET$1")*/ * from t1_hash_set intersect select * from t1_hash_set;

explain select /*+USE_HASH_SET(@"SET$1")*/ c1 from t1_hash_set except select c1 from t1_hash_set;
explain select /*+USE_HASH_SET(@"SET$1")*/ c2 from t1_hash_set except select c1 from t1_hash_set;
explain select /*+USE_HASH_SET(@"SET$1")*/ c3 from t1_hash_set except select c1 from t1_hash_set;
explain select /*+USE_HASH_SET(@"SET$1")*/ c4 from t1_hash_set except select c1 from t1_hash_set;
explain select /*+USE_HASH_SET(@"SET$1")*/ * from t1_hash_set except select * from t1_hash_set;

--source cost_model_test_end.inc
