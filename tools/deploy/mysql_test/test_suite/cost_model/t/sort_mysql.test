# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--source cost_model_test_begin.inc

--disable_warnings

drop table if exists t1_sort,t2_sort;

--enable_warnings

create table t1_sort(
  c1 int,
  c2 int,
  c3 number,
  c4 varchar(10));

create index i1 on t1_sort(c1,c2);
create index i2 on t1_sort(c1,c2,c3);

create table t2_sort(
  c1 int,
  c2 int,
  c3 number,
  c4 varchar(10)) partition by hash(c1) partitions 4;
  
create index i1 on t2_sort(c1,c2)local;
create index i2 on t2_sort(c2,c3)local;

call dbms_stats.set_table_stats(
  NULL,
  't1_sort',
  numrows=>1000000,
  avgrlen=>256);

call dbms_stats.set_table_stats(
  NULL,
  't2_sort',
  numrows=>1000000,
  avgrlen=>256);
  
--echo #########################
--echo ###  normal sort
--echo #########################
explain select /*+full(A)*/ * from t1_sort A order by c2;
explain select /*+full(A)*/ * from t1_sort A order by c3;
explain select /*+full(A)*/ * from t1_sort A order by c4;

--echo #########################
--echo ###  topN sort
--echo #########################
explain select /*+full(A)*/ * from t1_sort A order by c2 limit 1000;
explain select /*+full(A)*/ * from t1_sort A order by c3 limit 1000;
explain select /*+full(A)*/ * from t1_sort A order by c4 limit 1000;

--echo #########################
--echo ###  prefix sort
--echo #########################
explain select /*+index(A i1)*/ * from t1_sort A order by c1,c2,c3,c4;
explain select /*+index(A i2)*/ * from t1_sort A order by c1,c2,c3,c4;

--echo #########################
--echo ###  prefix topN sort
--echo #########################
explain select /*+index(A i1)*/ * from t1_sort A order by c1,c2,c3,c4 limit 1000;
explain select /*+index(A i2)*/ * from t1_sort A order by c1,c2,c3,c4 limit 1000;

let $op_id = 1;
--source cost_model_change_op_id.inc
--echo #########################
--echo ###  partition sort
--echo #########################
explain select /*+full(A) NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ count(*) from t1_sort A group by c1;

let $op_id = 2;
--source cost_model_change_op_id.inc
--echo #########################
--echo ###  merge sort
--echo #########################
explain select /*+index(A i1)*/ * from t2_sort A order by c1;

let $op_id = 3;
--source cost_model_change_op_id.inc
--echo #########################
--echo ###  topN merge sort
--echo #########################
explain select /*+index(A i1)*/ * from t2_sort A order by c1 limit 1000;

--echo #########################
--echo ###  exchange in merge sort
--echo #########################
explain select /*+index(A i2) no_use_hash_aggregation*/ * from t2_sort A group by c2;

--source cost_model_test_end.inc
