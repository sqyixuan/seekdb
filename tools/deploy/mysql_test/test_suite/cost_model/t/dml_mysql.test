# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--source cost_model_test_begin.inc

--disable_warnings

drop table if exists t1_dml;
drop table if exists t2_dml;
drop table if exists t3_dml;
drop table if exists t4_dml;
drop table if exists t5_dml;
drop table if exists t6_dml;

--enable_warnings

create table t1_dml(
  c1 int,
  c2 int,
  c3 int,
  c4 int);
  
create table t2_dml(
  c1 int unique,
  c2 int,
  c3 int,
  c4 int);

create table t3_dml(
  c1 int,
  c2 int,
  c3 int,
  c4 int);

create index i1 on t3_dml(c1);

create table t4_dml(
  c1 int unique,
  c2 int unique,
  c3 int,
  c4 int);

create table t5_dml(
  c1 int,
  c2 int,
  c3 int,
  c4 int);

create index i1 on t5_dml(c1);
create index i2 on t5_dml(c2);

create table t6_dml(
  c1 int,
  c2 int,
  c3 int unique,
  c4 int unique);

create index i1 on t6_dml(c1);
create index i2 on t6_dml(c2);

call dbms_stats.set_table_stats(
  NULL,
  't1_dml',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

call dbms_stats.set_table_stats(
  NULL,
  't2_dml',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

call dbms_stats.set_table_stats(
  NULL,
  't3_dml',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

call dbms_stats.set_table_stats(
  NULL,
  't4_dml',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

call dbms_stats.set_table_stats(
  NULL,
  't5_dml',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

call dbms_stats.set_table_stats(
  NULL,
  't6_dml',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

explain insert into t1_dml values(1,1,1,1);
explain insert into t2_dml values(1,1,1,1);
explain insert into t3_dml values(1,1,1,1);
explain insert into t4_dml values(1,1,1,1);
explain insert into t5_dml values(1,1,1,1);
explain insert into t6_dml values(1,1,1,1);

explain update t1_dml set c1 = 1;
explain update t2_dml set c1 = 1;
explain update t3_dml set c1 = 1;
explain update t4_dml set c1 = 1;
explain update t5_dml set c1 = 1;
explain update t6_dml set c1 = 1;

explain delete from t1_dml;
explain delete from t2_dml;
explain delete from t3_dml;
explain delete from t4_dml;
explain delete from t5_dml;
explain delete from t6_dml;

--source cost_model_test_end.inc
