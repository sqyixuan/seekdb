# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--source cost_model_test_begin.inc

--disable_warnings

drop table if exists t1_scalar_group;

--enable_warnings

create table t1_scalar_group(c1 int, c2 int, c3 int, c4 int);

call dbms_stats.set_table_stats(
  NULL,
  't1_scalar_group',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

explain select count(c1) from t1_scalar_group;
explain select sum(c1) from t1_scalar_group;
explain select min(c1) from t1_scalar_group;
explain select max(c1) from t1_scalar_group;
explain select count(c1), sum(c1), min(c1), max(c1) from t1_scalar_group;

explain select count(c3) from t1_scalar_group;
explain select sum(c3) from t1_scalar_group;
explain select min(c3) from t1_scalar_group;
explain select max(c3) from t1_scalar_group;
explain select count(c3), sum(c3), min(c3), max(c3) from t1_scalar_group;

explain select count(c4) from t1_scalar_group;
explain select sum(c4) from t1_scalar_group;
explain select min(c4) from t1_scalar_group;
explain select max(c4) from t1_scalar_group;
explain select count(c4), sum(c4), min(c4), max(c4) from t1_scalar_group;

explain select count(distinct c1) from t1_scalar_group;
explain select count(distinct c2) from t1_scalar_group;
explain select count(distinct c3) from t1_scalar_group;
explain select count(distinct c4) from t1_scalar_group;

--source cost_model_test_end.inc
