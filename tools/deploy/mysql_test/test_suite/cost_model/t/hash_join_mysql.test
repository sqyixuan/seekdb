# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--source cost_model_test_begin.inc

--disable_warnings

drop table if exists t1_hash_join, t2_hash_join, t3_hash_join;

--enable_warnings

create table t1_hash_join(
  c1 int,
  c2 int,
  c3 int,
  c4 int);

create table t2_hash_join(
  c1 int,
  c2 int,
  c3 int,
  c4 int);

create table t3_hash_join(
  c1 int,
  c2 int,
  c3 int,
  c4 int)partition by hash(c1) partitions 4;

call dbms_stats.set_table_stats(
  NULL,
  't1_hash_join',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

call dbms_stats.set_table_stats(
  NULL,
  't2_hash_join',
  numrows => 10000000,
  avgrlen => 1000,
  nummicroblks => 60000
  );

call dbms_stats.set_table_stats(
  NULL,
  't3_hash_join',
  numrows => 10000000,
  avgrlen => 1000,
  nummicroblks => 60000
  );

--echo #########################
--echo ###  normal hash join
--echo #########################
explain select /*+leading(A B) use_hash(B)*/* from t1_hash_join A inner join t2_hash_join B on A.c1 = B.c1;
explain select /*+leading(A B) use_hash(B)*/* from t1_hash_join A inner join t2_hash_join B on A.c1 = B.c1 and A.c2 != B.c2;
explain select /*+leading(A B) use_hash(B)*/* from t1_hash_join A inner join t2_hash_join B on A.c1 = B.c1 and A.c2 = B.c2;

--echo #########################
--echo ###  left hash semi join
--echo #########################
explain select /*+LEADING(@"SEL$612EAAC9" ("A"@"SEL$1" "B"@"SEL$2")) USE_HASH("B"@"SEL$2")*/* from t1_hash_join A where exists(select 1 from t2_hash_join B where A.c1 = B.c1);
explain select /*+LEADING(@"SEL$612EAAC9" ("A"@"SEL$1" "B"@"SEL$2")) USE_HASH("B"@"SEL$2")*/* from t1_hash_join A where exists(select 1 from t2_hash_join B where A.c1 = B.c1 and A.c2 != B.c2);
explain select /*+LEADING(@"SEL$612EAAC9" ("A"@"SEL$1" "B"@"SEL$2")) USE_HASH("B"@"SEL$2")*/* from t1_hash_join A where exists(select 1 from t2_hash_join B where A.c1 = B.c1 and A.c2 = B.c2);

--echo #########################
--echo ###  right hash semi join
--echo #########################
explain select /*+LEADING(@"SEL$612EAAC9" ("B"@"SEL$2" "A"@"SEL$1")) USE_HASH("A"@"SEL$1")*/* from t1_hash_join A where exists(select 1 from t2_hash_join B where A.c1 = B.c1);
explain select /*+LEADING(@"SEL$612EAAC9" ("B"@"SEL$2" "A"@"SEL$1")) USE_HASH("A"@"SEL$1")*/* from t1_hash_join A where exists(select 1 from t2_hash_join B where A.c1 = B.c1 and A.c2 != B.c2);
explain select /*+LEADING(@"SEL$612EAAC9" ("B"@"SEL$2" "A"@"SEL$1")) USE_HASH("A"@"SEL$1")*/* from t1_hash_join A where exists(select 1 from t2_hash_join B where A.c1 = B.c1 and A.c2 = B.c2);

--echo #########################
--echo ###  left hash anti join
--echo #########################
explain select /*+LEADING(@"SEL$612EAAC9" ("A"@"SEL$1" "B"@"SEL$2")) USE_HASH("B"@"SEL$2")*/* from t1_hash_join A where not exists(select 1 from t2_hash_join B where A.c1 = B.c1);
explain select /*+LEADING(@"SEL$612EAAC9" ("A"@"SEL$1" "B"@"SEL$2")) USE_HASH("B"@"SEL$2")*/* from t1_hash_join A where not exists(select 1 from t2_hash_join B where A.c1 = B.c1 and A.c2 != B.c2);
explain select /*+LEADING(@"SEL$612EAAC9" ("A"@"SEL$1" "B"@"SEL$2")) USE_HASH("B"@"SEL$2")*/* from t1_hash_join A where not exists(select 1 from t2_hash_join B where A.c1 = B.c1 and A.c2 = B.c2);

--echo #########################
--echo ###  right hash anti join
--echo #########################
explain select /*+LEADING(@"SEL$612EAAC9" ("B"@"SEL$2" "A"@"SEL$1")) USE_HASH("A"@"SEL$1")*/* from t1_hash_join A where not exists(select 1 from t2_hash_join B where A.c1 = B.c1);
explain select /*+LEADING(@"SEL$612EAAC9" ("B"@"SEL$2" "A"@"SEL$1")) USE_HASH("A"@"SEL$1")*/* from t1_hash_join A where not exists(select 1 from t2_hash_join B where A.c1 = B.c1 and A.c2 != B.c2);
explain select /*+LEADING(@"SEL$612EAAC9" ("B"@"SEL$2" "A"@"SEL$1")) USE_HASH("A"@"SEL$1")*/* from t1_hash_join A where not exists(select 1 from t2_hash_join B where A.c1 = B.c1 and A.c2 = B.c2);

let $op_id = 2;
--source cost_model_change_op_id.inc
--echo #########################
--echo ###  join filter cost
--echo #########################
explain select /*+leading(A B) use_hash(B) parallel(2) px_join_filter(B)*/* from t1_hash_join A inner join t2_hash_join B on A.c1 = B.c1;

--echo #########################
--echo ###  part join filter cost
--echo #########################
explain select /*+leading(A B) use_hash(B) parallel(2) px_part_join_filter(B)*/* from t1_hash_join A inner join t3_hash_join B on A.c1 = B.c1;
explain select /*+leading(A B) use_hash(B) parallel(2) px_part_join_filter(B) px_join_filter(B)*/* from t1_hash_join A inner join t3_hash_join B on A.c1 = B.c1;

--source cost_model_test_end.inc
