# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--disable_warnings

drop table if exists t1_column_store;
drop table if exists t2_row_store;

drop table if exists t1_column_store_part;
drop table if exists t2_row_store_part;

--enable_warnings

--source cost_model_test_begin.inc

create table t1_column_store(
  pk int primary key,
  c1 int,
  c2 number,
  c3 varchar(10),
  c4 json,
  c5 text) with column group (each column);

create index i1 on t1_column_store(c1);
create index i2 on t1_column_store(c2) 
with column group(each column);

create table t2_row_store(
  pk int primary key,
  c1 int,
  c2 number,
  c3 varchar(10),
  c4 json,
  c5 text);
  
create index i1 on t2_row_store(c1);
create index i2 on t2_row_store(c2) 
with column group(each column);

call dbms_stats.set_table_stats(
  NULL,
  't1_column_store',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

call dbms_stats.set_table_stats(
  NULL,
  't2_row_store',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

--echo #########################
--echo ###  列存全表扫描
--echo #########################
explain select /*+full(A)*/ * from t1_column_store A;

--echo #########################
--echo ###  列存主表range扫描
--echo #########################
explain select /*+full(A)*/ * from t1_column_store A where pk > 1;

--echo #########################
--echo ###  列存主表过滤
--echo #########################
explain select /*+full(A)*/ * from t1_column_store A where c1 > 1;

--echo #########################
--echo ###  列存主表range扫描+过滤
--echo #########################
explain select /*+full(A)*/ * from t1_column_store A where pk > 1 and c1 > 1;

--echo #########################
--echo ###  列存主表get
--echo #########################
explain select /*+full(A)*/ * from t1_column_store A where pk = 1;

--echo #########################
--echo ###  列存主表multi get
--echo #########################
explain select /*+full(A)*/ * from t1_column_store A where pk in (1,2,3);

--echo #########################
--echo ###  行存索引扫描
--echo #########################
explain select /*+index(A i1)*/ c1 from t1_column_store A;

--echo #########################
--echo ###  列存索引扫描
--echo #########################
explain select /*+index(A i2)*/ c2 from t1_column_store A;

--echo #########################
