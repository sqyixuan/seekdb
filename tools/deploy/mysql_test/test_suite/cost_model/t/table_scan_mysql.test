let $op_id = 3;
--source cost_model_change_op_id.inc
--echo #########################
--echo ###  行存索引扫描
--echo #########################
explain select /*+index(A i1)*/ c1 from t2_row_store_part A where c1+c1 = 1;

--echo #########################
--echo ###  行存全局索引扫描
--echo #########################
explain select /*+index(A i2)*/ c2 from t2_row_store_part A where c2+c2 = 1;

