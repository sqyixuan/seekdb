create table t1_column_store_part(
  pk int primary key,
  c1 int,
  c2 int,
  c3 int,
  c4 int,
  c5 varchar(10),
  c6 json,
  c7 text)
  partition by hash(pk) partitions 4
  with column group (each column);

create index i1 on t1_column_store_part(c1)local;
create index i2 on t1_column_store_part(c2)partition by hash(c2)partitions 2;
create index i3 on t1_column_store_part(c3)local
with column group(each column);
create index i4 on t1_column_store_part(c4)partition by hash(c4)partitions 2
with column group(each column);

create table t2_row_store_part(
  pk int primary key,
  c1 int,
  c2 int,
  c3 int,
  c4 int,
  c5 varchar(10),
  c6 json,
  c7 text)
  partition by hash(pk) partitions 4;

create index i1 on t2_row_store_part(c1)local;
create index i2 on t2_row_store_part(c2)partition by hash(c2)partitions 2;
create index i3 on t2_row_store_part(c3)local
with column group(each column);
create index i4 on t2_row_store_part(c4)partition by hash(c4)partitions 2
with column group(each column);

call dbms_stats.set_table_stats(
  NULL,
  't1_column_store_part',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

call dbms_stats.set_table_stats(
  NULL,
  't2_row_store_part',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

--echo #########################
--echo ###  分布式代价模型
