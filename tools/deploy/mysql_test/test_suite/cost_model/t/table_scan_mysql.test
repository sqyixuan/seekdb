explain select /*+index(A i4)*/ c4 from t2_row_store_part A;

let $op_id = 3;
--source cost_model_change_op_id.inc
--echo #########################
--echo ###  行存索引扫描
--echo #########################
explain select /*+index(A i1)*/ c1 from t2_row_store_part A where c1 = 1;

let $op_id = 0;
