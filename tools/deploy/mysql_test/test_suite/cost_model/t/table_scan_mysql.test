--echo #########################
explain select /*+full(A)*/ * from t2_row_store_part A;

--echo #########################
--echo ###  行存主表range扫描
--echo #########################
explain select /*+full(A)*/ * from t2_row_store_part A where pk > 1;

--echo #########################
--echo ###  行存主表过滤
--echo #########################
explain select /*+full(A)*/ * from t2_row_store_part A where c1 > 1;

--echo #########################
--echo ###  行存主表range扫描+过滤
--echo #########################
explain select /*+full(A)*/ * from t2_row_store_part A where pk > 1 and c1 > 1;

let $op_id = 0;
--source cost_model_change_op_id.inc
--echo #########################
--echo ###  行存主表get
--echo #########################
explain select /*+full(A)*/ * from t2_row_store_part A where pk = 1;

let $op_id = 3;
--source cost_model_change_op_id.inc
--echo #########################
--echo ###  行存主表multi get
--echo #########################
explain select /*+full(A)*/ * from t2_row_store_part A where pk in (1,2,3);

--echo #########################
--echo ###  行存索引扫描
--echo #########################
explain select /*+index(A i1)*/ c1 from t2_row_store_part A;

--echo #########################
--echo ###  行存全局索引扫描
--echo #########################
explain select /*+index(A i2)*/ c2 from t2_row_store_part A;

let $op_id = 3;
