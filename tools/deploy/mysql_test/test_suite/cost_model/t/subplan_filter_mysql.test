# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--source cost_model_test_begin.inc
let $op_id = -1;
--source cost_model_change_op_id.inc

--disable_warnings

drop table if exists t1_subplan_filter;

--enable_warnings

create table t1_subplan_filter(
  pk int primary key,
  c1 int,
  c2 number,
  c3 varchar(10),
  c4 json,
  c5 text);

create index i1 on t1_subplan_filter(c2);
  
call dbms_stats.set_table_stats(
  NULL,
  't1_subplan_filter',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

--echo #########################
--echo ###  onetime subquery
--echo #########################
explain select (select /*+no_unnest*/ count(*) from t1_subplan_filter) as ref from t1_subplan_filter;

--echo #########################
--echo ###  init plan
--echo #########################
explain select /*+no_rewrite*/ 1 from t1_subplan_filter where c1 in (select /*+no_unnest*/ c1 from t1_subplan_filter);

--echo #########################
--echo ###  none batch correlated subquery
--echo #########################
explain select /*+no_rewrite*/ 1 from t1_subplan_filter A where exists(select /*+no_unnest*/ 1 from t1_subplan_filter B where A.c1 = B.c1);

--echo #########################
--echo ###  batch correlated subquery
--echo #########################
explain select /*+no_rewrite*/ 1 from t1_subplan_filter A where exists(select /*+no_unnest*/ 1 from t1_subplan_filter B where A.c1 = B.c2);

explain select 1 from t1_subplan_filter
    where c1 in (select /*+no_unnest*/ c1 from t1_subplan_filter)
    and exists(select /*+no_unnest*/ 1 from t1_subplan_filter);

explain select 1 from t1_subplan_filter A
    where exists(select /*+no_unnest*/ 1 from t1_subplan_filter B where A.c1 = B.c1)
    and exists(select /*+no_unnest*/ 1 from t1_subplan_filter);

explain select 1 from t1_subplan_filter A
    where exists(select /*+no_unnest*/ 1 from t1_subplan_filter B where A.c1 = B.c2)
    and exists(select /*+no_unnest*/ 1 from t1_subplan_filter);

explain select 1 from t1_subplan_filter A
    where c1 in (select /*+no_unnest*/ c1 from t1_subplan_filter)
    and exists(select /*+no_unnest*/ 1 from t1_subplan_filter B where A.c1 = B.c1);

explain select 1 from t1_subplan_filter A
    where c1 in (select /*+no_unnest*/ c1 from t1_subplan_filter)
    and exists(select /*+no_unnest*/ 1 from t1_subplan_filter B where A.c1 = B.c2);

explain select 1 from t1_subplan_filter A
    where exists(select /*+no_unnest*/ 1 from t1_subplan_filter B where A.c1 = B.c1)
    and exists(select /*+no_unnest*/ 1 from t1_subplan_filter B where A.c1 = B.c2);

explain select 1 from t1_subplan_filter A
    where c1 in (select /*+no_unnest*/ c1 from t1_subplan_filter)
    and exists(select /*+no_unnest*/ 1 from t1_subplan_filter)
    and exists(select /*+no_unnest*/ 1 from t1_subplan_filter B where A.c1 = B.c1);

--source cost_model_test_end.inc
