# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--source cost_model_test_begin.inc

--disable_warnings

drop table if exists t1_filter;

--enable_warnings

create table t1_filter(
  pk int primary key,
  c1 int,
  c2 number,
  c3 varchar(10),
  c4 json,
  c5 text);
  
call dbms_stats.set_table_stats(
  NULL,
  't1_filter',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

explain select 1 from t1_filter where c1 > 1;
explain select 1 from t1_filter where c2 > 1;
explain select 1 from t1_filter where c3 > '1';
explain select 1 from t1_filter where JSON_VALID(c4);
explain select 1 from t1_filter where c5 like '1%';
explain select 1 from t1_filter 
where c1 > 1 
  and c2 > 1 
  and c3 > '1' 
  and JSON_VALID(c4)
  and c5 like '1%';

--source cost_model_test_end.inc
