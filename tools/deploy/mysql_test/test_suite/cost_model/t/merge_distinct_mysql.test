# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--source cost_model_test_begin.inc

--disable_warnings

drop table if exists t1_merge_distinct;

--enable_warnings

create table t1_merge_distinct(
  pk int primary key,
  c1 int,
  c2 number,
  c3 varchar(10),
  c4 json,
  c5 text);

call dbms_stats.set_table_stats(
  NULL,
  't1_merge_distinct',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

explain select /*+NO_USE_HASH_DISTINCT(@"SEL$1")*/ distinct c1 from t1_merge_distinct;
explain select /*+NO_USE_HASH_DISTINCT(@"SEL$1")*/ distinct c2 from t1_merge_distinct;
explain select /*+NO_USE_HASH_DISTINCT(@"SEL$1")*/ distinct c3 from t1_merge_distinct;
explain select /*+NO_USE_HASH_DISTINCT(@"SEL$1")*/ distinct c4 from t1_merge_distinct;
explain select /*+NO_USE_HASH_DISTINCT(@"SEL$1")*/ distinct c5 from t1_merge_distinct;
explain select /*+NO_USE_HASH_DISTINCT(@"SEL$1")*/ distinct c1,c2,c3,c4,c5 from t1_merge_distinct;

--source cost_model_test_end.inc
