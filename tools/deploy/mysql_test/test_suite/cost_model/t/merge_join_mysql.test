# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--source cost_model_test_begin.inc

--disable_warnings

drop table if exists t1_merge_join,t2_merge_join;

--enable_warnings

create table t1_merge_join(
  c1 int,
  c2 int,
  c3 int,
  c4 int);

create table t2_merge_join(
  c1 int,
  c2 int,
  c3 int,
  c4 int);

call dbms_stats.set_table_stats(
  NULL,
  't1_merge_join',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

call dbms_stats.set_table_stats(
  NULL,
  't2_merge_join',
  numrows => 10000000,
  avgrlen => 1000,
  nummicroblks => 60000
  );

explain select /*+leading(A B) use_merge(B)*/* from t1_merge_join A inner join t2_merge_join B on A.c1 = B.c1;
explain select /*+leading(A B) use_merge(B)*/* from t1_merge_join A inner join t2_merge_join B on A.c1 = B.c1 and A.c2 != B.c2;
explain select /*+leading(A B) use_merge(B)*/* from t1_merge_join A inner join t2_merge_join B on A.c1 = B.c1 and A.c2 = B.c2;

explain select /*+LEADING(@"SEL$612EAAC9" ("A"@"SEL$1" "B"@"SEL$2")) USE_MERGE("B"@"SEL$2")*/* from t1_merge_join A where exists(select 1 from t2_merge_join B where A.c1 = B.c1);
explain select /*+LEADING(@"SEL$612EAAC9" ("A"@"SEL$1" "B"@"SEL$2")) USE_MERGE("B"@"SEL$2")*/* from t1_merge_join A where exists(select 1 from t2_merge_join B where A.c1 = B.c1 and A.c2 != B.c2);
explain select /*+LEADING(@"SEL$612EAAC9" ("A"@"SEL$1" "B"@"SEL$2")) USE_MERGE("B"@"SEL$2")*/* from t1_merge_join A where exists(select 1 from t2_merge_join B where A.c1 = B.c1 and A.c2 = B.c2);

explain select /*+LEADING(@"SEL$612EAAC9" ("A"@"SEL$1" "B"@"SEL$2")) USE_MERGE("B"@"SEL$2")*/* from t1_merge_join A where not exists(select 1 from t2_merge_join B where A.c1 = B.c1);
explain select /*+LEADING(@"SEL$612EAAC9" ("A"@"SEL$1" "B"@"SEL$2")) USE_MERGE("B"@"SEL$2")*/* from t1_merge_join A where not exists(select 1 from t2_merge_join B where A.c1 = B.c1 and A.c2 != B.c2);
explain select /*+LEADING(@"SEL$612EAAC9" ("A"@"SEL$1" "B"@"SEL$2")) USE_MERGE("B"@"SEL$2")*/* from t1_merge_join A where not exists(select 1 from t2_merge_join B where A.c1 = B.c1 and A.c2 = B.c2);

--source cost_model_test_end.inc
