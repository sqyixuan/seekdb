# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--source cost_model_test_begin.inc

--disable_warnings

drop table if exists t1_exchange;

--enable_warnings

create table t1_exchange(
    c1 int, c2 int, c3 int, c4 int
)partition by hash(c1) partitions 4;

  
call dbms_stats.set_table_stats(
  NULL,
  't1_exchange',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

let $op_id = 0;
--source cost_model_change_op_id.inc
--echo #########################
--echo ###  SEND TO LOCAL
--echo #########################
explain select c1 from t1_exchange;

--echo #########################
--echo ###  SEND TO LOCAL with parallel(2)
--echo #########################
explain select /*+parallel(2)*/ c1 from t1_exchange;

let $op_id = 1;
--source cost_model_change_op_id.inc
--echo #########################
--echo ###  SEND TO LOCAL
--echo #########################
explain select c1 from t1_exchange;

--echo #########################
--echo ###  SEND TO LOCAL
--echo #########################
explain select /*+parallel(2)*/ c1 from t1_exchange;

let $op_id = 3;
--source cost_model_change_op_id.inc
--echo #########################
--echo ###  HASH SHUFFLE
--echo #########################
explain select distinct c2 from t1_exchange;

--echo #########################
--echo ###  HASH SHUFFLE with parallel 2
--echo #########################
explain select /*+parallel(2)*/ distinct c2 from t1_exchange;

--echo #########################
--echo ###  PARTITION SHUFFLE
--echo #########################
explain select /*+leading(A B) use_hash(B) pq_distribute(B PARTITION NONE)*/ 1 from t1_exchange A, t1_exchange B where A.c2 = B.c1;

--echo #########################
--echo ###  PARTITION SHUFFLE with parallel 2
--echo #########################
explain select /*+leading(A B) use_hash(B) pq_distribute(B PARTITION NONE) parallel(2) no_px_part_join_filter(B)*/ 1 from t1_exchange A, t1_exchange B where A.c2 = B.c1;

--echo #########################
--echo ###  BC2HOST SHUFFLE with parallel 2
--echo #########################
explain select /*+leading(A B) use_hash(B) pq_distribute(B BC2HOST NONE) parallel(2)*/ 1 from t1_exchange A, t1_exchange B where A.c2 = B.c1;

--echo #########################
--echo ###  BROADCAST SHUFFLE with parallel 2
--echo #########################
explain select /*+leading(A B) use_hash(B) pq_distribute(B BROADCAST NONE) parallel(2)*/ 1 from t1_exchange A, t1_exchange B where A.c2 = B.c1;

--echo #########################
--echo ###  RANDOM SHUFFLE
--echo #########################
explain select /*+PQ_SET(@"SET$1"  RANDOM NONE)*/ c2 from t1_exchange union all select c2 from t1_exchange;

--echo #########################
--echo ###  RANDOM SHUFFLE with parallel 2
--echo #########################
explain select /*+PQ_SET(@"SET$1"  RANDOM NONE) parallel(2)*/ c2 from t1_exchange union all select c2 from t1_exchange;

let $op_id = 4;
--source cost_model_change_op_id.inc
--echo #########################
--echo ###  HASH SHUFFLE
--echo #########################
explain select distinct c2 from t1_exchange;

--echo #########################
--echo ###  HASH SHUFFLE with parallel 2
--echo #########################
explain select /*+parallel(2)*/ distinct c2 from t1_exchange;

--echo #########################
--echo ###  PARTITION SHUFFLE
--echo #########################
explain select /*+leading(A B) use_hash(B) pq_distribute(B PARTITION NONE)*/ 1 from t1_exchange A, t1_exchange B where A.c2 = B.c1;

--echo #########################
--echo ###  PARTITION SHUFFLE with parallel 2
--echo #########################
explain select /*+leading(A B) use_hash(B) pq_distribute(B PARTITION NONE) parallel(2) no_px_part_join_filter(B)*/ 1 from t1_exchange A, t1_exchange B where A.c2 = B.c1;

--echo #########################
--echo ###  BC2HOST SHUFFLE with parallel 2
--echo #########################
explain select /*+leading(A B) use_hash(B) pq_distribute(B BC2HOST NONE) parallel(2)*/ 1 from t1_exchange A, t1_exchange B where A.c2 = B.c1;

--echo #########################
--echo ###  BROADCAST SHUFFLE with parallel 2
--echo #########################
explain select /*+leading(A B) use_hash(B) pq_distribute(B BROADCAST NONE) parallel(2)*/ 1 from t1_exchange A, t1_exchange B where A.c2 = B.c1;

--echo #########################
--echo ###  RANDOM SHUFFLE
--echo #########################
explain select /*+PQ_SET(@"SET$1"  RANDOM NONE)*/ c2 from t1_exchange union all select c2 from t1_exchange;

--echo #########################
--echo ###  RANDOM SHUFFLE with parallel 2
--echo #########################
explain select /*+PQ_SET(@"SET$1"  RANDOM NONE) parallel(2)*/ c2 from t1_exchange union all select c2 from t1_exchange;

--source cost_model_test_end.inc
