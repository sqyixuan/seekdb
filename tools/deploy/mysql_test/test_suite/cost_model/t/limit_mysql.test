# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--source cost_model_test_begin.inc

--disable_warnings

drop table if exists t1_limit;

--enable_warnings

create table t1_limit(c1 int, c2 int, c3 int, c4 int);

call dbms_stats.set_table_stats(
  NULL,
  't1_limit',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

explain select * from (select /*+no_merge*/ * from t1_limit) limit 10;
explain select * from (select /*+no_merge*/ * from t1_limit) limit 10,100;

--source cost_model_test_end.inc
