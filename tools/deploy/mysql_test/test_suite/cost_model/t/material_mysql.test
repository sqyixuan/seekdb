# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--source cost_model_test_begin.inc

--disable_warnings

drop table if exists t1_material;

--enable_warnings

create table t1_material(
  pk int primary key,
  c1 int,
  c2 number,
  c3 varchar(10),
  c4 json,
  c5 text);
  
call dbms_stats.set_table_stats(
  NULL,
  't1_material',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

explain select /*+blocking('all')*/ c1 from t1_material;
explain select /*+blocking('all')*/ c2 from t1_material;
explain select /*+blocking('all')*/ c3 from t1_material;
explain select /*+blocking('all')*/ c4 from t1_material;
explain select /*+blocking('all')*/ c5 from t1_material;

--source cost_model_test_end.inc
