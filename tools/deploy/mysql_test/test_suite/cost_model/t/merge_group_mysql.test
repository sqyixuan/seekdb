# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--source cost_model_test_begin.inc

--disable_warnings

drop table if exists t1_merge_group;

--enable_warnings

create table t1_merge_group(
  pk int primary key,
  c1 int,
  c2 number,
  c3 varchar(10),
  c4 json,
  c5 text);

call dbms_stats.set_table_stats(
  NULL,
  't1_merge_group',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ count(pk) from t1_merge_group group by c1;
explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ sum(pk) from t1_merge_group group by c1;
explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ min(pk) from t1_merge_group group by c1;
explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ max(pk) from t1_merge_group group by c1;

explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ count(pk) from t1_merge_group group by c3;
explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ sum(pk) from t1_merge_group group by c3;
explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ min(pk) from t1_merge_group group by c3;
explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ max(pk) from t1_merge_group group by c3;

explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ count(pk) from t1_merge_group group by c4;
explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ sum(pk) from t1_merge_group group by c4;
explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ min(pk) from t1_merge_group group by c4;
explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ max(pk) from t1_merge_group group by c4;

explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ count(pk) from t1_merge_group group by c1,c3,c5;
explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ sum(pk) from t1_merge_group group by c1,c3,c5;
explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ min(pk) from t1_merge_group group by c1,c3,c5;
explain select /*+NO_USE_HASH_AGGREGATION(@"SEL$1" PARTITION_SORT)*/ max(pk) from t1_merge_group group by c1,c3,c5;

--source cost_model_test_end.inc
