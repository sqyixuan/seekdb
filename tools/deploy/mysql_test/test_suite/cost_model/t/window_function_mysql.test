# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--source cost_model_test_begin.inc

--disable_warnings

drop table if exists t1_win_func;

--enable_warnings

create table t1_win_func(c1 int, c2 int, c3 int, c4 int);

call dbms_stats.set_table_stats(
  NULL,
  't1_win_func',
  numrows => 1000000,
  avgrlen => 100,
  nummicroblks => 6000
  );

explain select count(*)over() from t1_win_func;
explain select sum(1)over() from t1_win_func;
explain select min(1)over() from t1_win_func;
explain select max(1)over() from t1_win_func;
explain select rank()over() from t1_win_func;
explain select row_number()over() from t1_win_func;
explain select count(*)over(),sum(1)over(),min(1)over(),max(1)over(),rank()over(),row_number()over() from t1_win_func;

explain select count(*)over(partition by c1) from t1_win_func;
explain select sum(1)over(partition by c1) from t1_win_func;
explain select min(1)over(partition by c1) from t1_win_func;
explain select max(1)over(partition by c1) from t1_win_func;
explain select rank()over(partition by c1) from t1_win_func;
explain select row_number()over(partition by c1) from t1_win_func;
explain select count(*)over(partition by c1),
               sum(1)over(partition by c1),
               min(1)over(partition by c1),
               max(1)over(partition by c1),
               rank()over(partition by c1),
               row_number()over(partition by c1) from t1_win_func;

explain select rank()over(order by c1) from t1_win_func;
explain select row_number()over(order by c1) from t1_win_func;

explain select rank()over(partition by c2 order by c1) from t1_win_func;
explain select row_number()over(partition by c2 order by c1) from t1_win_func;

--source cost_model_test_end.inc
