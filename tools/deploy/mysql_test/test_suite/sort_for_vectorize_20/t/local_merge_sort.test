--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# # owner group: SQL2
# # description: test for local merge sort

--disable_warnings
drop database if exists luofan_db;
drop table if exists t1;
--enable_warnings
create database luofan_db;
use luofan_db;

--echo #打开向量化2.0开关
set _enable_rich_vector_format = true;

--disable_abort_on_error
set ob_query_timeout=10000000000;
set ob_trx_timeout=100000000000;


CREATE TABLE `t1` (
  `col_bigint_unsigned` bigint(20) unsigned DEFAULT NULL,
  `col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `col_decimal_20_0_signed` decimal(20,0) DEFAULT NULL,
  `col_datetime` datetime DEFAULT NULL,
  `col_bigint_signed` bigint(20) DEFAULT NULL,
  `col_char_20` char(20) DEFAULT NULL,
  `pk` bigint(20) NOT NULL,
  `col_decimal_20_0_unsigned` decimal(20,0) unsigned DEFAULT NULL,
  `col_decimal_20_0` decimal(20,0) DEFAULT NULL,
  PRIMARY KEY (`pk`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
 partition by key(pk) partitions 16
 ;

