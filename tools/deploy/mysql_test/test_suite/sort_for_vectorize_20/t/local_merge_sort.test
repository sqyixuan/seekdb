explain
SELECT t . col_char_20,t.pk FROM t1 AS t LEFT OUTER JOIN t1 AS table2 USING ( pk ) ORDER BY t.pk, t.col_char_20 ;

SELECT t . col_char_20,t.pk FROM t1 AS t LEFT OUTER JOIN t1 AS table2 USING ( pk ) ORDER BY t.pk, t.col_char_20 ;


drop table if exists t1;
drop database luofan_db;
