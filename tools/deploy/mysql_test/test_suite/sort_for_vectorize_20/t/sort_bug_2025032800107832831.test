explain basic SELECT /*+  ENABLE_PARALLEL_DML LEADING(t1 t2) no_rewrite */ t2.c1 FROM t2 RIGHT OUTER JOIN t1 ON t1.c1 <= t1.c1 AND 'aAvHXIMjgzLnOwOIpJXAYLlyfixdBplxbuIoD' >= 'TfYiErWjpIDwEmImfVkfnWLkwdk' order by 1 limit 2;
