drop table if exists t1,t2;

CREATE TABLE `test` (
  `pk` bigint(20) NOT NULL,
  `col_decimal_20_0` decimal(20,0) DEFAULT NULL,
  PRIMARY KEY (`pk`)
) 
partition by hash(mod(pk, 4))
(partition `p0`,
partition `p1`,
partition `p2`);

insert into test values (1, NULL);
insert into test values (2, NULL);
insert into test values (3, 0);
insert into test values (4, 0);
insert into test values (5, 0);
insert into test values (6, 1);

SELECT col_decimal_20_0 FROM test GROUP BY col_decimal_20_0 HAVING SUM( col_decimal_20_0 ) <> 6 ORDER BY col_decimal_20_0;
SELECT col_decimal_20_0 FROM test GROUP BY col_decimal_20_0 HAVING SUM( col_decimal_20_0 ) <> 6;

drop table if exists test;

