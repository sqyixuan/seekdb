##partition external table
drop table zcext4;
create external table zcext4 (
c1 VARCHAR(50) AS (external$tablecol1),
c2 VARCHAR(50) AS (external$tablecol2),
c3 BIGINT AS (external$tablecol3),
PAR1 VARCHAR(50) AS (metadata$PARTITION_LIST_COL1)
)
AUTO_REFRESH = IMMEDIATE
PROPERTIES =(
type = "odps"
#ODPS_ACCESSID#
#ODPS_ACCESSKEY#
PROJECT_NAME = "mysqltest_regression_sqlqa"
ENDPOINT = "http://service.cn-hangzhou.maxcompute.aliyun.com/api"
TABLE_NAME ="zc_t4"
) PARTITION BY (PAR1);
show create table zcext4;
Table	Create Table
zcext4	CREATE EXTERNAL TABLE `zcext4` (
  `c1` varchar(50) GENERATED ALWAYS AS (external$tablecol1),
  `c2` varchar(50) GENERATED ALWAYS AS (external$tablecol2),
  `c3` bigint(20) GENERATED ALWAYS AS (external$tablecol3),
  `PAR1` varchar(50) GENERATED ALWAYS AS (metadata$PARTITION_LIST_COL1)
) 
AUTO_REFRESH = IMMEDIATE
PROPERTIES (
  TYPE = 'ODPS',
  ACCESSTYPE = '',
  ACCESSID = '********',
  ACCESSKEY = '********',
  ENDPOINT = 'http://service.cn-hangzhou.maxcompute.aliyun.com/api',
  TUNNEL_ENDPOINT = '',
  PROJECT_NAME = 'mysqltest_regression_sqlqa',
  SCHEMA_NAME = '',
  TABLE_NAME = 'zc_t4',
  QUOTA_NAME = '',
  COMPRESSION_CODE = '',
  COLLECT_STATISTICS_ON_CREATE = FALSE,
  REGION = '',
  API_MODE = 'tunnel_api'
) DEFAULT CHARSET = utf8mb4
 partition by (PAR1)
insert into zcext4 partition(dt='partition1') select c23, c24, c4 from zct2;
select * from zcext4;
+------+---------+-------------+------------+
| c1   | c2      | c3          | PAR1       |
+------+---------+-------------+------------+
| NULL | NULL    |        NULL | partition1 |
| a    | varchar | -2147483648 | partition1 |
|      |         |           0 | partition1 |
| a    | varchar |  2147483647 | partition1 |
+------+---------+-------------+------------+
insert overwrite zcext4 partition(dt='partition1') select 'a', 'b', 1 from dual;
select * from zcext4;
+------+------+------+------------+
| c1   | c2   | c3   | PAR1       |
+------+------+------+------------+
| a    | b    |    1 | partition1 |
+------+------+------+------------+
insert overwrite zcext4 partition(dt='partition2') select c24, c23, c2 from zct2;
select * from zcext4;
+---------+------+--------+------------+
| c1      | c2   | c3     | PAR1       |
+---------+------+--------+------------+
| a       | b    |      1 | partition1 |
| NULL    | NULL |   NULL | partition2 |
| varchar | a    | -32768 | partition2 |
|         |      |      0 | partition2 |
| varchar | a    |  32767 | partition2 |
+---------+------+--------+------------+
insert overwrite zcext4 partition(dt='partition2') select c24, c23, c2 from zct2 where c2 is not null;
select * from zcext4;
+---------+------+--------+------------+
| c1      | c2   | c3     | PAR1       |
+---------+------+--------+------------+
| a       | b    |      1 | partition1 |
| varchar | a    | -32768 | partition2 |
|         |      |      0 | partition2 |
| varchar | a    |  32767 | partition2 |
+---------+------+--------+------------+
insert overwrite zcext4 partition(dt='partition2') select c24, c23, c2 from zct2 partition(p1);
select * from zcext4;
+---------+------+--------+------------+
| c1      | c2   | c3     | PAR1       |
+---------+------+--------+------------+
| a       | b    |      1 | partition1 |
| varchar | a    | -32768 | partition2 |
+---------+------+--------+------------+
##overwrite empty
drop table empty_zcext4;
create table empty_zcext4 (c1 VARCHAR(50),c2 VARCHAR(50),c3 BIGINT);
insert overwrite zcext4 partition(dt='partition1') select * from empty_zcext4;
insert overwrite zcext4 partition(dt='partition2') select * from empty_zcext4;
select * from zcext4;
+------+------+------+------+
| c1   | c2   | c3   | PAR1 |
+------+------+------+------+
+------+------+------+------+
