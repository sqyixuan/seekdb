--result_format 4
purge recyclebin;
--disable_query_log
--source mysql_test/include/odps_config_for_cloud.inc
--enable_query_log
let $CASE_TYPE = TIMESTAMP_NTZ;
--source mysql_test/test_suite/extable3_odps_write_sqlqa/include/create_test_data.inc

--disable_abort_on_error


####TIMESTAMP_NTZ
insert into zcext3(c15) select C1 from zct2;
select c15 from zcext3 order by c15;

insert into zcext3(c15) select C2 from zct2;
select c15 from zcext3 order by c15;

