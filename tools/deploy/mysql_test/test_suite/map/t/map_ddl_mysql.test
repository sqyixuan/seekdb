#owner: xuqijia.xqj
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of map ddl/dml.
--echo # ----------------------------------------------------------------------

--disable_warnings
drop table if exists t1, t2, t3, t4, t5, t6, t_vec;
drop materialized view if exists mv1;
drop view if exists v1;
--enable_warnings

create table t1 (id int, c1 map(INT, FLOAT), c2 map(VARCHAR(10), VARCHAR(2)), c3 map(FLOAT UNSIGNED, array(INT)), c4 map(varchar(3), array(array(varchar(20)))));
desc t1;
--error 1235
create table t2 (c1 map(ARRAY(INT),INT));
--error 1235
create table t2 (c1 map(ARRAY(VARCHAR(2)),INT));
--error 1235
create table t2 (c1 map(INT, DATE));
--error 1235
create table t2 (c1 map(JSON, INT));
--error 1235
create table t2 (c1 map(ARRAY(VARCHAR(2)),MAP(INT, DOUBLE)));
--error 1235
create table t2 (c1 array(MAP(INT, DOUBLE)));
create table t2 (c1 MAP(INT, VECTOR(3)));
desc t2;
create table t3 (c1 MAP(INT, ARRAY(VECTOR(3))));
desc t3;

insert into t1 values (1, map(1,1.1,2,2.2), map('11','aa','22','bb'), map(1.1,[1,2],2.2,[3,4]), map('a', [['a','b'],['c']], 'b', [['d'], ['e','f']]));
insert into t1 values (2, map(NULL, NULL, NULL, NULL), map(NULL, NULL, NULL, NULL), map(NULL, array_remove([1],1)), map(NULL, array_remove([['a']],['a'])));
--error 7602 # to solve?
insert into t1(c3) values (map(NULL,NULL)); 
select * from t1;
--error 1235
select c1 into @a from t1 where id = 1;
--error 1235
select id, c1 into @a, @b from t1 where id = 1;

insert into t2 values (map(1,[1,2,3]));
--error 7600
insert into t2 values (map(1,[1,2]));
select * from t2;

insert into t3 values (map(1,[[1,2,3],[4,5,6]]));
--error 7600
insert into t3 values (map(1,[[1,2,3],[4,5]]));
select * from t3;

create table t4(c1 int);
insert into t4 values (1);
alter table t4 add column c2 map(FLOAT, array(VARCHAR(20)));
desc t4;
insert into t4 values (2, map(1.1,[1,2],2.2,[3,4]));
select * from t4;
update t4 set c2 = map(4.4,['a']) where c1=1;
update t4 set c2 ='{5.5:["b"]}' where c1=2;
insert into t4 (c2) values (NULL);
insert into t4 (c1) values (4);
select * from t4;
--error 1235
alter table t4 add column c3 map(array(INT), array(INT));
--error 1235
alter table t4 add column c3 map(INT, array(TIMESTAMP(6)));
alter table t4 drop column c2;
desc t4;
--error 1138
alter table t4 add column c5 map(INT, array(INT)) not null;
select * from t4;

create table t5 (id int, c1 map(int, int) not null);
desc t5;
--error 1364
insert into t5 (id) values (1);
--error 1048
insert into t5 values (1, NULL);

--error 1101
create table t6 (id int, c1 map(int, array(int)) default "{1,[2]}" );
create table t6 (id int primary key, c1 map(int, array(int)) default NULL, c2 map(varchar(20), varchar(20)));
desc t6;
insert into t6 values (1, map(1,[1,2,3]), map('a','aaa'));
insert into t6 values (2, NULL, NULL);
--error 1210
alter table t6 modify c1 vector(4);
--error 1210
alter table t6 modify c1 array(int);
--error 7602
alter table t6 modify c1 map(int, int);
--error 7602
alter table t6 modify c1 map(int, array(array(int)));
alter table t6 modify c1 map(int, array(varchar(20)));
insert into t6 values (3, map(1,['hi']), NULL);
--error 1366
alter table t6 modify c1 map(int, array(int));

drop table t1, t2, t3, t4, t5, t6;


# 创建复制表、对列表
create table if not exists t1 (id int primary key, c1 array(int), c2 map(int,int), c3 float, c4 json) partition by hash(id) partitions 2;

create table if not exists t2 (id int primary key, c1 array(int), c2 map(int,int), c3 float, c4 json) table_mode='queuing' partition by hash(id) partitions 2;

# 插入数据
insert into t1 values (1, [1,2], '{1:11,2:22}', 1.1, '{"1":11,"2":22}');
INSERT IGNORE INTO t1 VALUES (1, [1,22], '{1:111,2:222}', 1.1, '{"1":111,"2":222}');
insert into t1 values (2, '[]', '{}', 0, '{}');
insert into t1 values (3, NULL, NULL, NULL, NULL);
select * from t1;
insert into t2 select * from t1;
select * from t2;
truncate table t2;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t2 select * from t1;
select * from t2;
truncate table t2;
insert /*+ direct(true,100,'inc') enable_parallel_dml parallel(2)*/ into t2 select * from t1;
select * from t2;

drop table t1, t2;
create table t1 (id int primary key, c1 array(int), c2 map(int,int), c3 float, c4 json);
insert into t1 values (1, [1,2], '{1:11,2:22}', 1.1, '{"1":11,"2":22}');
insert into t1 values (2, '[]', '{}', 0, '{}');
insert into t1 values (3, NULL, NULL, NULL, NULL);
# 创建全局、局部索引
create index idx1 on t1(id) local;
create index idx2 on t1(c3) global;
select * from t1 where id = 10;
--error 5083
select distinct c2 from t1;
--sorted_result
select /*+ ENABLE_PARALLEL_DML parallel(2) */  * from t1;

insert into t1 values (1, [3,4,5], '{3:33,4:44}', 3.3, '{"3":33,"4":44}') on duplicate key update id = id * 10;
REPLACE INTO t1 VALUES (1, [3,4,5], '{3:33,4:44}', 3.3, '{"3":33,"4":44}');
REPLACE INTO t1 VALUES (2, [3,4,5], '{3:33,4:44}', 3.3, '{"3":33,"4":44}');
select * from t1;

update /*+ ENABLE_PARALLEL_DML parallel(2) */ t1 set c2 = '{10:20}' where id = 2;
delete /*+ ENABLE_PARALLEL_DML parallel(2) */ from t1 where id = 3;
select * from t1;
insert into t1(id) values (3);

# 删除非多模列
alter table t1 drop c3;
update t1 set c2 = map(4,44) where id=1;
delete from t1 where id = 2;
--sorted_result
select /*+ ENABLE_PARALLEL_DML parallel(2) */  * from t1;
sleep 5;
select /*+read_consistency(weak) */ * from t1;

alter table t1 add c14 INT;
alter table t1 modify c14 INT AUTO_INCREMENT;
alter table t1 add column c15 map(int,int) as (map(1,2)) stored;
select  * from t1;
ALTER TABLE t1 DROP COLUMN c15;
ALTER TABLE t1 DROP PRIMARY KEY;
ALTER TABLE t1 ADD PRIMARY KEY (id);
ALTER TABLE t1 PARTITION BY HASH(id) PARTITIONS 4;
select  * from t1;
--error 1235
ALTER TABLE t1 DROP PARTITION p0;
--error 1235
ALTER TABLE t1 TRUNCATE PARTITION p0;

# ONLINE DDL
ALTER TABLE t1 ADD COLUMN v1 map(int, array(int)) AS (map(1,[2])) VIRTUAL;
select * from t1;
insert into t1(id, c2) values (20, map(20,20));
ALTER TABLE t1 DROP COLUMN v1;
delete from t1 where id = 3;
--error 1138
ALTER TABLE t1 MODIFY c2 map(int,int) NOT NULL;
ALTER TABLE t1 MODIFY c2 map(int,int) NULL;
insert into t1(id) values (3);
select * from t1;
--error 1101
ALTER TABLE t1 ALTER c2 SET DEFAULT (map(2,3));
--error 1101
ALTER TABLE t1 ALTER c2 SET DEFAULT '{1:23}';
select * from t1;
ALTER TABLE t1 AUTO_INCREMENT = 10;
insert into t1(id) values (4);
select * from t1;
ALTER TABLE t1 CHANGE COLUMN c2 c2_n map(int,int);
select * from t1;
alter table t1 add column c5 map(varchar(4),array(varchar(4)));
insert into t1 (id, c5) values (5, map('abcd',['aaaa','bbbb'])), (6, '{}');
--error 1406
alter table t1 modify column c5 map(varchar(2),array(varchar(2)));
alter table t1 modify column c5 map(varchar(6),array(varchar(6)));
select  * from t1;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
CREATE TABLE `t3` (
  `c11` MAP(INT,ARRAY(INT)) DEFAULT NULL,
  `id` int(11) NOT NULL,
  `c1` ARRAY(INT) DEFAULT NULL,
  `c13` MAP(INT,ARRAY(INT)) DEFAULT NULL,
  `c2` MAP(INT,INT) DEFAULT NULL,
  `c12` MAP(INT,ARRAY(INT)) DEFAULT NULL,
  `c4` json DEFAULT NULL,
  `c14` int(11) NOT NULL AUTO_INCREMENT,
  `c15` MAP(INT,INT) GENERATED ALWAYS AS (map(1,2)) STORED,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX AUTO_INCREMENT = 4 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by hash(id)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`);
desc t3;
drop table t1, t3;


# generate column
create table t1(m1 map(int, int), m2 map(varchar(20),varchar(20)) generated always as (m1) stored);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
insert into t1(m1) values(map(1,10,2,20)), (map(11,100,22,200,33,300));
select * from t1;
drop table t1;

CREATE TABLE t1 (c1 smallint(5) unsigned NOT NULL DEFAULT '7252', c2 varbinary(467) NOT NULL, c4 tinyblob DEFAULT NULL);
alter table t1 add column ( c3 map(int, int) GENERATED ALWAYS AS ( ltrim( c1 / c2 ) ) STORED );
--error 1235
alter table t1 modify c3 map(int, int) GENERATED ALWAYS AS ( ltrim( c4 / c2 ) ) STORED;
drop table t1;
