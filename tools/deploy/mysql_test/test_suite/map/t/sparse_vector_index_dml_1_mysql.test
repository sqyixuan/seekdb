#owner: lb446709, qiyu.zd
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of sparse vector index
--echo # ----------------------------------------------------------------------

--disable_warnings
drop table if exists test_sparse_vec_tbl;
--enable_warnings
alter system set ob_vector_memory_limit_percentage =44;

#设置语句级的超时时间为100s
set ob_query_timeout=100000000;

--error 1235
create table test_sparse_vec_tbl (
  id int, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(5), c13 vector(5), c14 vector(5), c15 map(int, int), c16 sparsevector, vector index idx1(c16) with (distance=l2));
--error 1235
create table test_sparse_vec_tbl (
  id int, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(5), c13 vector(5), c14 vector(5), c15 map(int, int), c16 sparsevector, vector index idx1(c16) with (distance=inner_product, type=hnsw));

create table test_sparse_vec_tbl (
  id int, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(5), c13 vector(5), c14 vector(5), c15 map(int, int), c16 sparsevector);
create vector index idx1 on test_sparse_vec_tbl(c16) with (distance=inner_product);
drop table test_sparse_vec_tbl;

# hnsw + spiv
create table test_sparse_vec_tbl (
  id int primary key, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(5), c13 vector(5), c14 vector(5), c15 map(int, int), c16 sparsevector, 
  vector index idx1(c16) with (distance=inner_product));
create vector index idx_c12 on test_sparse_vec_tbl(c12) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=30, ef_search=20);
--source sparse_vector_index_dml.inc

# hash分区
create table test_sparse_vec_tbl (
  id int primary key, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(5), c13 vector(5), c14 vector(5), c15 map(int, int), c16 sparsevector, 
  vector index idx1(c16) with (distance=inner_product)) partition by hash(id) partitions 3;
--source sparse_vector_index_dml.inc

# fulltext + json multivalue + spiv
--disable_warnings
drop table if exists test_sparse_vec_tbl;
--enable_warnings

create table test_sparse_vec_tbl (c1 int primary key, c2 vector(3), c3 text, c4 sparsevector, c5 JSON, 
  vector index idx1(c4) with (distance=inner_product),
  INDEX zips( (CAST(c5->'$.zipcode' AS UNSIGNED ARRAY)) )
);

create fulltext index idx2 on test_sparse_vec_tbl(c3);

insert into test_sparse_vec_tbl values(1, '[0.203846,0.205289,0.880265]', "Gerard A. Gerry Salton (8 March 1927 – 28 August 1995) was a professor of Computer Science at Cornell University. Salton was perhaps the leading computer scientist working in the field of information retrieval during his time, and the father of Information Retrieval", '{1:123, 2:456}', '{"a":"b","zipcode":[94582,94536]}');
insert into test_sparse_vec_tbl values(2, '[0.735541,0.670776,0.903237]', "Edgar Frank Ted Codd (19 August 1923 – 18 April 2003) was an English computer scientist who, while working for IBM, invented the relational model for database management, the theoretical basis for relational databases and relational database management systems. ", '{1:123, 2:456}', '{"c":"d","zipcode":[94581,94530]}');
insert into test_sparse_vec_tbl values(8, '[0.185221,0.315131,0.558301]', "Leslie B. Lamport (born February 7, 1941) is an American computer scientist and mathematician. Lamport is best known for his seminal work in distributed systems, and as the initial developer of the document preparation system LaTeX", '{1:1.23, 2:4.56}', '{"c":"e","zipcode":[94512,94516]}');
--sorted_result
select * from test_sparse_vec_tbl;

# insert on duplicate key
insert into test_sparse_vec_tbl values(1, '[0.327936,0.048756,0.084670]', "Michael Ralph Stonebraker (born October 11, 1943[6]) is a computer scientist specializing in database systems. Through a series of academic prototypes and commercial startups, Stonebraker's research and products are central to many relational databases. ", '{1:123, 2:456}', '{"a":"b"}') on duplicate key update c4 = '{1:3.4, 5:4.5}';
insert into test_sparse_vec_tbl values(1, '[0.148869,0.878546,0.028024]', "Geoffrey Everest Hinton CC FRS FRSC (born 6 December 1947) is a British-Canadian computer scientist and cognitive psychologist, most noted for his work on artificial neural networks.", '{1:123, 2:456}', '{"a":"b"}') on duplicate key update c2 = '[0.327936,0.048756,0.084670]';
--sorted_result
select * from test_sparse_vec_tbl;

# insert IGNORE into
insert IGNORE into test_sparse_vec_tbl values(1, '[0.203846,0.205289,0.880265]', "Gerard A. Gerry Salton (8 March 1927 – 28 August 1995) was a professor of Computer Science at Cornell University. Salton was perhaps the leading computer scientist working in the field of information retrieval during his time, and the father of Information Retrieval", '{1:123, 2:456}', '{"a":"b"}');
--sorted_result
select * from test_sparse_vec_tbl;

# replace into
replace into test_sparse_vec_tbl values(2, '[0.735541,0.670776,0.903237]', "Edgar Frank Ted Codd (19 August 1923 – 18 April 2003) was an English computer scientist who, while working for IBM, invented the relational model for database management, the theoretical basis for relational databases and relational database management systems. ", '{1:123, 2:456}', '{"c":"d"}');
--sorted_result
select * from test_sparse_vec_tbl;

--disable_warnings
drop table if exists test_sparse_vec_tbl_2;
--enable_warnings

create table test_sparse_vec_tbl_2 (c1 int primary key, c2 vector(3), c3 varchar(4096), c4 sparsevector, c5 JSON, vector index idx1(c4) with (distance=inner_product));
insert into test_sparse_vec_tbl_2 select * from test_sparse_vec_tbl;
--sorted_result
select * from test_sparse_vec_tbl;
delete from test_sparse_vec_tbl_2;

# 全量旁路导入
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into test_sparse_vec_tbl_2 select * from test_sparse_vec_tbl;
--sorted_result
select * from test_sparse_vec_tbl;
delete from test_sparse_vec_tbl_2;

# 增量旁路导入
insert /*+ direct(true,100,'inc') enable_parallel_dml parallel(2)*/ into test_sparse_vec_tbl_2 select * from test_sparse_vec_tbl;
--sorted_result
select * from test_sparse_vec_tbl;
delete from test_sparse_vec_tbl_2;

# major freeze
--disable_warnings
alter system major freeze;
--enable_warnings

--sorted_result
select * from test_sparse_vec_tbl;

# update
update test_sparse_vec_tbl set c4 = '{1:1.5, 2:3, 5:6, 100:10}' where c1 = 1;
update /*+ ENABLE_PARALLEL_DML parallel(2) */ test_sparse_vec_tbl set c4 = '{1:1.5, 2:3, 5:6, 10:10}' where c1 = 1;
--sorted_result
select * from test_sparse_vec_tbl;

# delete 
delete from test_sparse_vec_tbl where c1 <= 1;
delete /*+ ENABLE_PARALLEL_DML parallel(2) */ from test_sparse_vec_tbl where c1 <= 2;
--sorted_result
select * from test_sparse_vec_tbl;

# truncate
insert into test_sparse_vec_tbl values(1, '[0.203846,0.205289,0.880265]', "Gerard A. Gerry Salton (8 March 1927 – 28 August 1995) was a professor of Computer Science at Cornell University. Salton was perhaps the leading computer scientist working in the field of information retrieval during his time, and the father of Information Retrieval", '{1:123, 2:456}', '{"a":"b"}');
insert into test_sparse_vec_tbl values(2, '[0.735541,0.670776,0.903237]', "Edgar Frank Ted Codd (19 August 1923 – 18 April 2003) was an English computer scientist who, while working for IBM, invented the relational model for database management, the theoretical basis for relational databases and relational database management systems. ", '{1:123, 2:456}', '{"c":"d"}');
--sorted_result
select * from test_sparse_vec_tbl;
truncate table test_sparse_vec_tbl;

drop table if exists test_sparse_vec_tbl;
CREATE TABLE test_sparse_vec_tbl (c1 int AUTO_INCREMENT PRIMARY KEY, c2 VARCHAR(30),c3 sparsevector not null,VECTOR INDEX vector_idx(c3) WITH (distance=inner_product));
insert into test_sparse_vec_tbl values(1,'{1:2,2:2,3:2}','{}');
insert into test_sparse_vec_tbl values(2,'{1:2,2:2,3:2}','{1:1,}');
-- error 1048
insert into test_sparse_vec_tbl values(3,'{1:2,2:2,3:2}',null);
insert into test_sparse_vec_tbl values(4,'{1:2,2:2,3:2}','{1:true}');
insert into test_sparse_vec_tbl values(5,'{1:2,2:2,3:2}','{1:false}');
insert into test_sparse_vec_tbl values(6,'{1:2,2:2,3:2}','{ }');
insert into test_sparse_vec_tbl values(7,'{1:2,2:2,3:2}','{1:1}');
insert into test_sparse_vec_tbl values(8,'{1:2,2:2,3:2}','{1:1,1:2}');
insert into test_sparse_vec_tbl values(9,'{1:2,2:2,3:2}','{1:1,2:1}');
insert into test_sparse_vec_tbl values(10,'{1:2,2:2,3:2}','{1:1,2:1,2:1}');
insert into test_sparse_vec_tbl values(100,'{1:2,2:2,3:2}','{1:1,2:1,4:1}');
select * from test_sparse_vec_tbl order by c1;
drop table if exists test_sparse_vec_tbl;
alter system set ob_vector_memory_limit_percentage =0;
