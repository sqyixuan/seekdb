## 有主键分区表 spiv+fulltext
#create table test_sparse_vec_tbl (
#  id int primary key, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
#  c6 date, c7 varchar(4096), c8 text, c9 json, c10 GEOMETRY,
#  c11 array(int), c12 vector(3), c13 map(int, float), c14 sparsevector, c15 sparsevector) partition by hash(id) partitions 2;
#
#insert into test_sparse_vec_tbl values(1, true, 1, 1, 1.3, 1, '2020-01-01', 'Gerard A. Gerry Salton (8 March 1927 – 28 August 1995) was a professor of Computer Science at Cornell University. Salton was perhaps the leading computer scientist working in the field of information retrieval during his time, and the father of Information Retrieval', 'abc', '{"user":"Jack","user_id":37,"zipcode":[94582,94536]}', ST_GeomFromText('POINT(1 1)'), [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', '{1:123, 2:456}', '{1:123, 3:456}');
#insert into test_sparse_vec_tbl values(2, true, 1, 1, 1.3, 1, '2020-01-01', 'Edgar Frank Ted Codd (19 August 1923 – 18 April 2003) was an English computer scientist who, while working for IBM, invented the relational model for database management, the theoretical basis for relational databases and relational database management systems.', 'abc', '{"user":"Jill","user_id":22,"zipcode":[94568,94507,94582]}', ST_GeomFromText('POINT(1 1)'), [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', null, null);
#insert into test_sparse_vec_tbl values(3, true, 1, 1, 1.3, 1, '2020-01-01', 'Michael Ralph Stonebraker (born October 11, 1943[6]) is a computer scientist specializing in database systems. Through a series of academic prototypes and commercial startups, Stonebraker\'s research and products are central to many relational databases.', 'abc', '{"user":"Bob","user_id":31,"zipcode":[94477,94507]}', ST_GeomFromText('POINT(1 1)'), [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', '{2:12.3, 4:4.56}', '{2:12.3, 4:4.56}');
#insert into test_sparse_vec_tbl values(4, true, 1, 1, 1.3, 1, '2020-01-01', 'Geoffrey Everest Hinton CC FRS FRSC (born 6 December 1947) is a British-Canadian computer scientist and cognitive psychologist, most noted for his work on artificial neural networks.', 'abc', '{"user":"Mary","user_id":72,"zipcode":[94536]}', ST_GeomFromText('POINT(1 1)'), [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', '{}', '{2:12.3, 4:4.56}');
#insert into test_sparse_vec_tbl values(5, true, 1, 1, 1.3, 1, '2020-01-01', 'Yann André LeCun[1] (born 8 July 1960) is a Turing Award winning French computer scientist working primarily in the fields of machine learning, computer vision, mobile robotics and computational neuroscience.', 'abc', '{"user":"Ted","user_id":56,"zipcode":[94507,94582]}', ST_GeomFromText('POINT(1 1)'), [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', '{1:1.2}', '{}');
#
#create vector index idx1 on test_sparse_vec_tbl(c14) with (distance=inner_product);
#create fulltext index idx2 on test_sparse_vec_tbl(c7);
#
#--replace_regex /_[0-9]+/_xxx/
#show index from test_sparse_vec_tbl;
#
#select * from test_sparse_vec_tbl order by negative_inner_product(c14, '{2:1}') approx limit 2;
#--replace_regex /_[0-9]+/_xxx/
#explain select * from test_sparse_vec_tbl order by negative_inner_product(c14, '{2:1}') approx limit 2;
#
#select id, c7 from test_sparse_vec_tbl where match (c7) against ("distributed database");
#--replace_regex /_[0-9]+/_xxx/
#explain select id, c7 from test_sparse_vec_tbl where match (c7) against ("distributed database");
#
#--disable_warnings
#drop table if exists test_sparse_vec_tbl;
#--enable_warnings
