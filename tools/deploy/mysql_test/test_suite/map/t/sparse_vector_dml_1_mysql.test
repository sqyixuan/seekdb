#owner: lb446709
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of sparse vector dml
--echo # ----------------------------------------------------------------------

--disable_warnings
drop table if exists test_sparse_vec_tbl;
--enable_warnings

# 无主键
create table test_sparse_vec_tbl (
  id int, c1 bool, c2 int, c3 decimal, c4 float, c5 bit,
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(3), c13 map(int, int), c14 sparsevector);
--source sparse_vec_dml.inc

# 带主键
create table test_sparse_vec_tbl (
  id int primary key, c1 bool, c2 int, c3 decimal, c4 float, c5 bit,
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(3), c13 map(int, int), c14 sparsevector);
--source sparse_vec_dml.inc

# hash分区
create table test_sparse_vec_tbl (
  id int primary key, c1 bool, c2 int, c3 decimal, c4 float, c5 bit,
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(3), c13 map(int, int), c14 sparsevector) partition by hash(id) partitions 3;
--source sparse_vec_dml.inc

create table test_sparse_vec_tbl(c1 int, c2 sparsevector);
insert into test_sparse_vec_tbl (c2) values ('{}');
insert into test_sparse_vec_tbl (c2) values ('');
insert into test_sparse_vec_tbl (c2) values (NULL);
insert into test_sparse_vec_tbl (c2) values ('{1:0.1, 1:0.2}');
insert into test_sparse_vec_tbl (c2) values ('{"1":0.1, 2:0.2}');
insert into test_sparse_vec_tbl (c2) values ('{"1":0.1, "2":0.2}');
insert into test_sparse_vec_tbl (c2) values ('{"1":0.1, "2":0.2}  ');

--error 1210
insert into test_sparse_vec_tbl (c2) values ('NULL');
--error 1210
insert into test_sparse_vec_tbl (c2) values ('{a:0.1, 2:0.2}');
--error 1210
insert into test_sparse_vec_tbl (c2) values ('a:0.1, 2:0.2');
--error 1210
insert into test_sparse_vec_tbl (c2) values ('{1.1:0.1, 2:0.2}');
--error 1210
insert into test_sparse_vec_tbl (c2) values ('{-1:0.1, 2:0.2}');
--error 1210
insert into test_sparse_vec_tbl (c2) values ('{1:abc, 2:0.2}');
--error 1210
insert into test_sparse_vec_tbl (c2) values ('{a:abc, 2:0.2}');
--error 1210
insert into test_sparse_vec_tbl (c2) values ('{"-1":0.1, "2":0.2}');
--error 4152
insert into test_sparse_vec_tbl (c2) values ('{null:0.1, "2":0.2}');
--error 4152
insert into test_sparse_vec_tbl (c2) values ('{"null":0.1, 2:0.2}');
--error 1210
insert into test_sparse_vec_tbl (c2) values ('{1:"0.1", 2:0.2}');
--error 1264
insert into test_sparse_vec_tbl (c2) values ('{32141784387374367:0.1, 2:0.2}');

select c2 from test_sparse_vec_tbl;

--disable_warnings
drop table if exists test_sparse_vec_tbl;
--enable_warnings
