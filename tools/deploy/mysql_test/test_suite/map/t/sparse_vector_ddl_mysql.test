#owner: lb446709
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of sparse vector ddl
--echo # ----------------------------------------------------------------------

--disable_warnings
drop table if exists test_sparse_vec_tbl;
--enable_warnings

# sparse vector column DDL
create table test_sparse_vec_tbl (
  id int primary key, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(3), c13 map(int, int), c14 sparsevector);
insert into test_sparse_vec_tbl values(1, true, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', '{"a":1}', ST_GeomFromText('POINT(1 1)'), [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', '{1:123, 2:456}');
insert into test_sparse_vec_tbl values(2, true, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', '{"a":1}', ST_GeomFromText('POINT(1 1)'), [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', null);
insert into test_sparse_vec_tbl values(3, true, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', '{"a":1}', ST_GeomFromText('POINT(1 1)'), [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', '{2:12.3, 4:4.56}');
insert into test_sparse_vec_tbl values(4, true, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', '{"a":1}', ST_GeomFromText('POINT(1 1)'), [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', null);
insert into test_sparse_vec_tbl values(5, true, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', '{"a":1}', ST_GeomFromText('POINT(1 1)'), [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', '{}');

# drop 非稀疏向量列 普通列/多模列
alter table test_sparse_vec_tbl drop column c1;
alter table test_sparse_vec_tbl drop column c9;
alter table test_sparse_vec_tbl drop column c10;
alter table test_sparse_vec_tbl drop column c12;
select id, c11, c13 from test_sparse_vec_tbl order by id;

# ddl
--error 1138
alter table test_sparse_vec_tbl modify c14 sparsevector not null;
insert into test_sparse_vec_tbl(id) values(6);
delete from test_sparse_vec_tbl where c14 is null;
--error 1138
alter table test_sparse_vec_tbl modify c14 sparsevector not null;

# drop 稀疏向量列
alter table test_sparse_vec_tbl drop column c14;
select id, c11, c13 from test_sparse_vec_tbl order by id;

alter table test_sparse_vec_tbl add column c14 sparsevector;
alter table test_sparse_vec_tbl modify c14 sparsevector null;
insert into test_sparse_vec_tbl(id) values(6);
select * from test_sparse_vec_tbl order by id;

--error 1101
alter table test_sparse_vec_tbl alter c14 set default ('{1:1.1}');

--error 5083
alter table test_sparse_vec_tbl modify column c14 int;
--error 1235
alter table test_sparse_vec_tbl modify column c14 map(date, float);
alter table test_sparse_vec_tbl modify column c14 map(int, float);
alter table test_sparse_vec_tbl modify column c14 sparsevector;
alter table test_sparse_vec_tbl modify column c14 map(varchar(20), float);
select * from test_sparse_vec_tbl order by id;

alter table test_sparse_vec_tbl modify column c13 sparsevector;
--error 1235
alter table test_sparse_vec_tbl modify column c13 map(date, float);
alter table test_sparse_vec_tbl modify column c13 map(int, float);

--error 1235
alter table test_sparse_vec_tbl add column c16 map(sparsevector, int);
--error 1235
alter table test_sparse_vec_tbl add column c15 map(int, sparsevector);
--error 1235
alter table test_sparse_vec_tbl add column c17 array(sparsevector);
--error 1235
alter table test_sparse_vec_tbl add column c18 array(map(int, float));
--error 5083
alter table test_sparse_vec_tbl change column c14 c14_n int;
alter table test_sparse_vec_tbl change column c14 c14_n map(int, float);

select id, c11, c13, c14_n from test_sparse_vec_tbl order by id;

alter table test_sparse_vec_tbl add column c19 sparsevector;
delete from test_sparse_vec_tbl where c19 is null;
alter table test_sparse_vec_tbl drop column c14_n;

insert into test_sparse_vec_tbl values(1, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', [1,2,3,4,5], '{1:123, 4:345}', '{1:123, 2:456}');
insert into test_sparse_vec_tbl values(2, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', [1,2,3,4,5], '{1:123, 4:345}', null);
insert into test_sparse_vec_tbl values(3, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', [1,2,3,4,5], '{1:123, 4:345}', '{2:12.3, 4:4.56}');
insert into test_sparse_vec_tbl values(4, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', [1,2,3,4,5], '{1:123, 4:345}', null);
insert into test_sparse_vec_tbl values(5, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', [1,2,3,4,5], '{1:123, 4:345}', '{}');
select id, c11, c13, c19 from test_sparse_vec_tbl order by id;
-- sleep 3
select /*+read_consistency(weak) */ id, c11, c13, c19 from test_sparse_vec_tbl order by id;

alter table test_sparse_vec_tbl partition by hash(id) partitions 3;
--error 1235
alter table test_sparse_vec_tbl drop partition p0;
--error 1235
alter table test_sparse_vec_tbl truncate partition p0;
select id, c11, c13, c19 from test_sparse_vec_tbl order by id;
-- sleep 3
select /*+read_consistency(weak) */ id, c11, c13, c19 from test_sparse_vec_tbl order by id;

drop table test_sparse_vec_tbl;

# generate column
create table test_sparse_vec_tbl(c1 sparsevector, c2 sparsevector generated always as (c1) stored);
insert into test_sparse_vec_tbl(c1) values('{1:1.2}');
select * from test_sparse_vec_tbl;
drop table test_sparse_vec_tbl;

# materialized view 
create table test_sparse_vec_tbl (
  id int primary key, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
  c6 date, c7 varchar(10), c8 text, c9 json, c11 array(int), c12 vector(3), c13 map(int, int), c14 sparsevector);
insert into test_sparse_vec_tbl values(1, true, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', '{"a":1}', [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', '{1:123, 2:456}');
insert into test_sparse_vec_tbl values(2, true, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', '{"a":1}', [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', null);
insert into test_sparse_vec_tbl values(3, true, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', '{"a":1}', [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', '{2:12.3, 4:4.56}');
insert into test_sparse_vec_tbl values(4, true, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', '{"a":1}', [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', null);
insert into test_sparse_vec_tbl values(5, true, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', '{"a":1}', [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', '{}');

--disable_warnings
drop materialized view if exists test_sparse_vec_mv1;
drop view if exists test_sparse_vec_mv2;
--enable_warnings
create materialized view test_sparse_vec_mv1 as select * from test_sparse_vec_tbl;
create view test_sparse_vec_mv2 as select * from test_sparse_vec_tbl;
insert into test_sparse_vec_tbl values(6, true, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', '{"a":1}', [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', '{}');
insert into test_sparse_vec_tbl values(7, true, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', '{"a":1}', [1,2,3,4,5], [1,2,3], '{1:123, 4:345}', '{}');
select * from test_sparse_vec_mv1 order by id;
select * from test_sparse_vec_mv2 order by id;
select * from test_sparse_vec_tbl order by id;
drop materialized view test_sparse_vec_mv1;
drop view test_sparse_vec_mv2;
drop table test_sparse_vec_tbl;

create table test_sparse_vec_tbl (c1 int primary key, c2 sparsevector,c3 sparsevector,c4 sparsevector,c5 sparsevector as (map(1,2)));
insert into test_sparse_vec_tbl(c1,c2,c3,c4) values(1,'{1:1.3,1:2.6}','{1:1.3,1:2.6}','{1:1.3,1:2.6}');
drop table test_sparse_vec_tbl;

create table test_sparse_vec_tbl (c1 int, c2 sparsevector,c3 sparsevector,c4 sparsevector,c5 vector(3) as (array(1,2,3)));
insert into test_sparse_vec_tbl(c1,c2,c3,c4) values(1,'{1:1.3,1:2.6}','{1:1.3,1:2.6}','{1:1.3,1:2.6}');
ALTER TABLE test_sparse_vec_tbl ADD COLUMN c6 int AS (inner_product(c2,c3)) STORED;
alter table test_sparse_vec_tbl partition by hash(c6) partitions 20;
drop table test_sparse_vec_tbl;

create table test_sparse_vec_tbl (c1 int primary key, c2 sparsevector);
insert into test_sparse_vec_tbl(c1,c2) values(1,map(1,2));
drop table test_sparse_vec_tbl;
