SET @geo_py = 'POLYGON((0 0, 5 0, 0 5, 5 5, 0 0))';
drop table if exists t1;
create table t1(c1 int, c2 int, g GEOMETRY NOT NULL SRID 0, v sparsevector, 
primary key(c1), SPATIAL INDEX idxg (g),
vector index idxv(v) with (distance=inner_product));
