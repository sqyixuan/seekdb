alter system set ob_vector_memory_limit_percentage = 44;
drop table if exists test_sparse_vec_tbl;
create table test_sparse_vec_tbl (
id int primary key, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
c11 array(int), c12 vector(3), c13 map(int, int),
c14 sparsevector,
c15 sparsevector,
vector index idx1(c14) with (distance=inner_product),
vector index idx2(c15) with (distance=inner_product)
);
insert into test_sparse_vec_tbl values(1, true, 1, 1, 1.3, 1, '2020-01-01', 'abc', 'abc', '{"a":1}', ST_GeomFromText('POINT(1 1)'),
[1,2,3,4,5], [1,2,3], '{1:123, 4:345}', '{1:123, 2:456}', '{1:123, 2:456}');
