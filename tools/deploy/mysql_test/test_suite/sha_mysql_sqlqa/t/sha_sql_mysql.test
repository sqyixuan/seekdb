# description: mysql加密函数-sql操作，运算符，函数间嵌套
# tags: sha,sh1,sh2
# author: whh01047778


purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 加密函数-sha(str)/sha1(str), sha2(str, hash_length) sql操作 ---------------------------
--echo ### 用例：sha-2  sha(str)/sha1(str)/sha2(str) - Sql
--echo -----------------------------------------------------------------------------------------------------------------

--error 0,1051
DROP TABLE sha_table1;
CREATE TABLE sha_table1(id int, name varchar(100), address varchar(100),sal int, PRIMARY KEY (id));
INSERT INTO sha_table1 VALUES(1,'阿里','杭州',8000);
INSERT INTO sha_table1 VALUES(2,'阿依','广州',7000);
INSERT INTO sha_table1 VALUES(3,'阿布','苏州',6000);
INSERT INTO sha_table1 VALUES(4,'阿珊','苏州',5000);

--error 0,1051
DROP TABLE sha_table2;
CREATE TABLE sha_table2(id int,style varchar(200),price int);
INSERT INTO sha_table2 VALUES(1,'键盘',300);
INSERT INTO sha_table2 VALUES(2,'鼠标',200);
INSERT INTO sha_table2 VALUES(3,'耳机',500);

--error 0,1051
DROP TABLE sha_table3;

--error 0,1051
DROP TABLE sha_table4;
CREATE TABLE sha_table4(id int,c1 varchar(200),c2 varchar(200),c3 varchar(200));


--echo ### 标签：sha-2-1 SELECT
--echo ##多列/单列
SELECT sha(e.id),sha1(e.name),sha2(e.address,224) FROM sha_table1 e ORDER BY e.id;
SELECT CONCAT(e.id,e.name) idname,sha(CONCAT(e.id,e.name)),sha1(CONCAT(e.id,e.name)),sha2(CONCAT(e.id,e.name),0) FROM sha_table1 e ORDER BY e.id;

--echo ##where 子句
SELECT e.id,e.name,sha(e.name) FROM sha_table1 e WHERE sha(e.name) like '%6590ec%';
SELECT e.id,e.name,sha1(e.name) FROM sha_table1 e WHERE sha1(e.name) like '%f4b7ea%';
SELECT e.id,e.name,sha(e.name) FROM sha_table1 e WHERE sha(e.name) > sha('阿布') ORDER BY e.id;
SELECT e.id,e.name,sha1(e.name) FROM sha_table1 e WHERE sha1(e.name) < sha1('阿布') ORDER BY e.id;
SELECT e.id,e.name,sha2(e.name,0) FROM sha_table1 e WHERE sha2(e.name,0) = sha2('阿布',0) ORDER BY e.id;

--echo ##order by 子句
SELECT e.id,sha(e.id) FROM sha_table1 e WHERE sha(e.name) < sha('阿布') ORDER BY sha(e.id);
SELECT e.id,sha(e.id) FROM sha_table1 e WHERE sha(e.name) < sha('阿布') ORDER BY sha(e.id) DESC;
SELECT e.id,sha1(e.id) FROM sha_table1 e WHERE sha1(e.name) < sha1('阿布') ORDER BY sha1(e.id) ;
SELECT e.id,sha2(e.id,0) FROM sha_table1 e WHERE sha2(e.name,0) > sha2('阿布',0) ORDER BY sha2(e.id,0) DESC;

--echo ##group by having 子句
SELECT e.id,e.address,sha(e.address) FROM sha_table1 e LEFT JOIN sha_table2 p ON e.id = p.id GROUP BY sha(e.address),e.id ORDER BY e.id ;
SELECT e.id,e.address,sha1(e.address) FROM sha_table1 e LEFT JOIN sha_table2 p ON e.id = p.id GROUP BY sha1(e.address),e.id HAVING sha1(e.address) <> 0 ORDER BY e.id;
SELECT e.id,e.address,sha2(e.address,512) FROM sha_table1 e  GROUP BY sha2(e.address,512),e.id ORDER BY e.id ;

--echo #DISTINCT
SELECT distinct sha(e.address),e.address FROM sha_table1 e ORDER BY e.id;
SELECT distinct sha1(e.address),e.address FROM sha_table1 e ORDER BY e.id;
SELECT distinct sha2(e.address,384),e.address FROM sha_table1 e ORDER BY e.id;

--echo #CASE WHEN
SELECT e.id,e.name,e.sal,sha(CASE WHEN e.sal < 6000 THEN NULL ELSE e.sal END) sal2 FROM sha_table1 e ORDER BY e.id;
SELECT e.id,e.name,e.sal,CASE sha(e.sal) WHEN sha(5000) THEN '工资低' WHEN sha(6000) THEN '工资一般' ELSE '工资高' END ranks FROM sha_table1 e ORDER BY e.id; 
SELECT e.id,e.name,e.sal,(CASE sha(e.sal) WHEN sha(5000) THEN '工资低' WHEN sha(6000) THEN '工资一般' ELSE '工资高' END) ranks FROM sha_table1 e GROUP BY (CASE sha(e.sal) WHEN sha(5000) THEN '工资低' WHEN sha(6000) THEN '工资一般' ELSE '工资高' END),e.id ORDER BY e.id ; 

--echo ##连接查询
SELECT sha(e.name),sha1(e.address),sha2(p.style,0) FROM sha_table1 e, sha_table2 p WHERE e.id = p.id ORDER BY e.id DESC;
SELECT sha(e.name),sha1(e.address),sha2(p.style,0) FROM sha_table1 e LEFT JOIN sha_table2 p ON e.id = p.id ORDER BY e.id DESC;
SELECT sha(e.name),sha1(e.address),sha2(p.style,0) FROM sha_table1 e RIGHT JOIN sha_table2 p ON e.id = p.id ORDER BY e.id DESC;
SELECT sha(e.name),sha1(e.address),sha2(p.style,0) FROM sha_table1 e INNER JOIN sha_table2 p ON e.id = p.id ORDER BY e.id DESC;

--echo ##select嵌套
--echo #SELECT
select sha(e.id),sha(e.name),sha1(e.address),sha2(e.sal,0) from (select id,name,address,sal from sha_table1 WHERE id =1) e; 

--echo #EXISTS AND NOT EXISTS
SELECT e.id,e.name,sha(e.name) FROM sha_table1 e WHERE EXISTS (SELECT sha(p.id) FROM sha_table2 p ) ORDER BY e.id;
SELECT e.id,e.name,sha1(e.name) FROM sha_table1 e WHERE NOT EXISTS (SELECT sha(p.id) FROM sha_table2 p WHERE p.style like '%whh%' ) ORDER BY e.id;

--echo #ANY
SELECT e.id,e.name,sha(e.name) FROM sha_table1 e WHERE sha(e.id) = ANY (SELECT sha(p.id) FROM sha_table2 p WHERE id = 2) ORDER BY e.id;
SELECT e.id,e.name,sha1(e.name) FROM sha_table1 e WHERE sha1(e.id) < ANY (SELECT sha1(p.id) FROM sha_table2 p WHERE id = 3) ORDER BY e.id;
SELECT e.id,e.name,sha2(e.name,224) FROM sha_table1 e WHERE sha2(e.id,224) > ANY (SELECT sha2(p.id,224) FROM sha_table2 p WHERE id = 3) ORDER BY e.id;

--echo #ALL 
SELECT e.id,e.name,sha(e.name) FROM sha_table1 e WHERE sha(e.id) = ALL (SELECT sha(p.id) FROM sha_table2 p WHERE id = 2) ORDER BY e.id;
SELECT e.id,e.name,sha1(e.name) FROM sha_table1 e WHERE sha1(e.id) < ALL (SELECT sha1(p.id) FROM sha_table2 p WHERE id = 3) ORDER BY e.id;
SELECT e.id,e.name,sha2(e.name,256) FROM sha_table1 e WHERE sha2(e.id,256) > ALL (SELECT sha2(p.id,256) FROM sha_table2 p WHERE id = 3) ORDER BY e.id;

--echo #CREATE AS 
CREATE TABLE sha_table3 AS SELECT id,sha(name) name3,sha1(address) address3,sha2(sal,0) sal3 FROM sha_table1; 
SELECT * FROM sha_table3;

--echo #INSERT INTO AS
INSERT INTO sha_table3 SELECT id,sha(name),sha1(address),sha2(sal,0) FROM sha_table1 WHERE id = 1;
SELECT * FROM sha_table3;

--echo #UPDATE SET
UPDATE sha_table3 e INNER JOIN  sha_table2 p ON e.id = p.id SET e.name3=sha(p.style) where e.id = 1;
select * from sha_table3;

--echo #WITH AS的SELECT
WITH a AS (SELECT id,name,sha(name) name2 FROM sha_table1 ) SELECT a.id,a.name,a.name2 FROM a ORDER BY a.id;
WITH a AS (SELECT id,name,sha1(name) name2 FROM sha_table1 ) SELECT a.id,a.name,a.name2 FROM a ORDER BY a.id;
WITH a AS (SELECT id,name,sha2(name,0) name2 FROM sha_table1 ) SELECT a.id,a.name,a.name2 FROM a ORDER BY a.id;

--echo #模糊查询like 
SELECT e.id,e.name,sha(e.name)  FROM sha_table1 e WHERE sha(e.name) LIKE '%bef%';
SELECT e.id,e.name,sha(e.name) FROM sha_table1 e LEFT JOIN sha_table2 p ON e.id = p.id WHERE sha(e.name) LIKE '%df%';


--echo ### 标签：sha-2-2 insert
INSERT INTO sha_table4 SELECT id,sha(name),sha1(name),sha2(name,0) FROM sha_table1 WHERE sha(name) LIKE '6590ec%';
INSERT INTO sha_table4 SELECT id,sha(name),sha1(name),sha2(name,256) FROM sha_table1 WHERE sha1(name) > sha1('阿布') ORDER BY sha1(id) DESC;
INSERT INTO sha_table4 SELECT id,sha(name),sha1(name),sha2(name,224) FROM sha_table1 WHERE sha2(name,0) > sha2('阿布',0) GROUP BY sha2(name,0),id HAVING id > 2 ;
SELECT * FROM  sha_table4;


--echo ### 标签：sha-2-3 update
UPDATE sha_table1 SET name = '阿里-update' WHERE sha(name) = sha('阿里');
UPDATE sha_table1 SET name = '阿依-update' WHERE sha1(name) = sha1('阿依') ORDER BY sha1(id) DESC;
UPDATE sha_table1 SET address = (SELECT sha2(style,0) FROM sha_table2 GROUP BY sha2(style,0),id HAVING id = 1 ORDER BY sha1(id)) WHERE id = 1 ;
SELECT * FROM  sha_table1;


--echo ### 标签：sha-2-4 delete
SELECT * FROM  sha_table2;
DELETE FROM sha_table2 WHERE sha1(id) = sha1(2) ORDER BY sha1(id) DESC;
SELECT * FROM  sha_table2;


--echo ### 标签：sha-2-5 replace   
replace into sha_table1 values(5,sha('冰墩墩replace1'),sha1('冰墩墩replace1'),5000);
select * from sha_table1 where id = 5;

replace into sha_table1 values(5,sha2('冰墩墩replace2',224),sha2('冰墩墩replace2',256),6000);
select * from sha_table1 where id = 5;



--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 加密函数-sha(str)/sha1(str), sha2(str, hash_length) 运算符 ----------------------------
--echo ### 用例：sha-5  sha(str)/sha1(str)/sha2(str) - 运算符
--echo -----------------------------------------------------------------------------------------------------------------

--echo ### 标签：sha-5-1 算术运算符
SELECT id , sal, sha(sal + 10 - 5 * 3 / 2),sha1(sal + 10 - 5 * 3 / 2),sha2(sal + 10 - 5 * 3 / 2,0) FROM sha_table1 ORDER BY id;
--disable_warnings
SELECT id , sal, sha(sal) + sha(sal), sha1(sal) - sha1(sal), sha2(sal,0) * sha2(sal,0), sha1(sal) / sha1(sal) FROM sha_table1;
SELECT id , sal,sha(sal) MOD (sha1(sal)-2),sha2(sal,0) DIV sha(sal)  FROM sha_table1;
--enable_warnings

--echo ### 标签：sha-5-2 比较运算符
SELECT id,name,sal,sha(sal) FROM sha_table1 WHERE sha(sal) = sha(5000)  ORDER BY sha(id);
SELECT id,name,sal,sha1(sal) FROM sha_table1 WHERE sha1(sal) < sha1(5000)  ORDER BY sha1(id);
SELECT id,name,sal,sha2(sal,0) FROM sha_table1 WHERE sha2(sal,0) > sha2(5000,0)  ORDER BY sha2(id,0);
SELECT id,name,sal,sha2(sal,224) FROM sha_table1 WHERE sha2(sal,0) >= sha2(5000,224)  ORDER BY sha2(id,224);
SELECT id,name,sal,sha2(sal,384) FROM sha_table1 WHERE sha2(sal,384) <= sha2(5000,384)  ORDER BY sha2(id,384);
SELECT id,name,sal,sha2(sal,512) FROM sha_table1 WHERE sha2(sal,512) != sha2(5000,512)  ORDER BY sha2(id,512);
SELECT id,name,sal,sha2(sal,256) FROM sha_table1 WHERE sha2(sal,256) <> 0 ORDER BY sha2(sal,256); 
SELECT id,name,sal,sha(sal) FROM sha_table1 WHERE sha(sal) in (sha(5000),sha(7000),sha(9000)) ORDER BY sha2(id,256); 
SELECT id,name,sal,sha1(sal) FROM sha_table1 WHERE sha1(sal) not in (sha1(5000),sha1(7000),sha1(9000)) ORDER BY sha2(id,256); 
SELECT id,name,sal,sha2(sal,0) FROM sha_table1 WHERE sha2(sal,0) IS NULL ORDER BY sha2(sal,0); 
SELECT id,name,sal,sha2(sal,224) FROM sha_table1 WHERE sha2(sal,224) IS NOT NULL ORDER BY sha2(sal,224); 
SELECT id,name,sal,sha2(sal,0) FROM sha_table1 WHERE sha2(sal,0) BETWEEN sha2(5000,0) AND sha2(6000,0) ORDER BY sha2(id,0); 
SELECT id,name,sal,sha2(sal,224) FROM sha_table1 WHERE sha2(sal,224) NOT BETWEEN sha2(5000,224) AND sha2(6000,224) ORDER BY sha2(id,224); 
SELECT id,name,sal,sha2(sal,NULL) FROM sha_table1 WHERE sha2(sal,NULL) <=> sha2(5000,NULL)  ORDER BY sha(id);
SELECT id,name,sal,sha(sal) FROM sha_table1 WHERE sha(sal) <=> sha2(5000,NULL)  ORDER BY sha(id);
SELECT id,name,sal,sha1(sal) FROM sha_table1 WHERE sha1(sal) LIKE '2DE49AC%' ORDER BY sha1(id);
SELECT id,name,sal,sha1(sal) FROM sha_table1 WHERE sha1(sal) REGEXP '^2DE49AC' ORDER BY sha1(id);
SELECT id,name,sal,sha(sal) FROM sha_table1 WHERE sha(sal) RLIKE '^2D.*F1535$' ORDER BY sha(id);

--echo ### 标签：sha-5-3 逻辑运算符
SELECT id,name,sal,sha2(sal,0) FROM sha_table1 WHERE  not sha2(sal,0) = sha2(6000,0) ORDER BY sha(id);
SELECT id,name,sal,sha(sal) FROM sha_table1 WHERE  sha(sal) = sha(5000)  and sha(sal) RLIKE '^2D.*F1535$' ORDER BY sha(id);
SELECT id,name,sal,sha1(sal) FROM sha_table1 WHERE  sha1(sal) = sha(5000) or sha1(sal) RLIKE '^2D.*F1535$' ORDER BY sha(id);
--disable_warnings
SELECT id,name,sal,sha2(sal,0) FROM sha_table1 WHERE sha2(sal,0) xor sha2(6000,0) ORDER BY sha(id);
--enable_warnings

--echo ### 标签：sha-5-4 位运算符
--disable_warnings
SELECT id,name,sal,sha(sal) & sha(sal) FROM sha_table1 ORDER BY sha(id);
SELECT id,name,sal,sha1(sal) | sha1(sal) FROM sha_table1 ORDER BY sha(id);
SELECT id,name,sal,sha(id)^sha(sal) FROM sha_table1 ORDER BY sha(id);
SELECT id,name,sal,!sha2(sal,224) FROM sha_table1 ORDER BY sha(id);
SELECT id,name,sal,sha(sal)<<1 FROM sha_table1 ORDER BY sha(id);
SELECT id,name,sal,sha1(sal)>>1 FROM sha_table1 ORDER BY sha(id);
--enable_warnings


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 加密函数-sha(str)/sha1(str), sha2(str, hash_length) 函数间嵌套 ------------------------
--echo ### 用例：sha-6  sha(str)/sha1(str)/sha2(str) - 函数间嵌套
--echo -----------------------------------------------------------------------------------------------------------------

--echo ### 标签：sha-6-1,sha-6-3 函数嵌套,被函数嵌套
--echo ##数字函数
--disable_warnings
SELECT ABS(sha(sal)),ABS(sha1(sal)),ABS(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT ABS(sal),sha(ABS(sal)),sha1(ABS(sal)),sha2(ABS(sal),256) FROM sha_table1 ORDER BY id;

SELECT AVG(sha(sal)),AVG(sha1(sal)),AVG(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT AVG(sal),sha(AVG(sal)),sha1(AVG(sal)),sha2(AVG(sal),256) FROM sha_table1 ORDER BY id;

SELECT CEIL(sha(sal)),CEIL(sha1(sal)),CEIL(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT CEIL(sal),sha(CEIL(sal)),sha1(CEIL(sal)),sha2(CEIL(sal),256) FROM sha_table1 ORDER BY id;

SELECT SIN(sha(sal)),SIN(sha1(sal)),SIN(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT SIN(sal),sha(SIN(sal)),sha1(SIN(sal)),sha2(SIN(sal),256) FROM sha_table1 ORDER BY id;

SELECT COS(sha(sal)),COS(sha1(sal)),COS(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT COS(sal),sha(COS(sal)),sha1(COS(sal)),sha2(COS(sal),256) FROM sha_table1 ORDER BY id;

SELECT SIGN(sha(sal)),SIGN(sha1(sal)),SIGN(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT SIGN(sal),sha(SIGN(sal)),sha1(SIGN(sal)),sha2(SIGN(sal),256) FROM sha_table1 ORDER BY id;

SELECT FLOOR(sha(sal)),FLOOR(sha1(sal)),FLOOR(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT FLOOR(sal),sha(FLOOR(sal)),sha1(FLOOR(sal)),sha2(FLOOR(sal),256) FROM sha_table1 ORDER BY id;
--enable_warnings


SELECT POWER(sha(sal),2),POWER(sha1(sal),2),POWER(sha2(sal,224),2) FROM sha_table1 ORDER BY id;
SELECT POWER(sal,2),sha(POWER(sal,2)),sha1(POWER(sal,2)),sha2(POWER(sal,2),256) FROM sha_table1 ORDER BY id;

SELECT MAX(sha(sal)),MAX(sha1(sal)),MAX(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT MAX(sal),sha(MAX(sal)),sha1(MAX(sal)),sha2(MAX(sal),256) FROM sha_table1 ORDER BY id;

SELECT MIN(sha(sal)),MIN(sha1(sal)),MIN(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT MIN(sal),sha(MIN(sal)),sha1(MIN(sal)),sha2(MIN(sal),256) FROM sha_table1 ORDER BY id;

--disable_warnings
SELECT MOD(sha(sal),3),MOD(sha1(sal),3),MOD(sha2(sal,224),3) FROM sha_table1 ORDER BY id;
SELECT MOD(sal,3),sha(MOD(sal,3)),sha1(MOD(sal,3)),sha2(MOD(sal,3),256) FROM sha_table1 ORDER BY id;

SELECT ROUND(sha(sal)),ROUND(sha1(sal)),ROUND(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT ROUND(sal),sha(ROUND(sal)),sha1(ROUND(sal)),sha2(ROUND(sal),256) FROM sha_table1 ORDER BY id;

SELECT TRUNCATE(sha(sal),2),TRUNCATE(sha1(sal),2),TRUNCATE(sha2(sal,224),2) FROM sha_table1 ORDER BY id;
SELECT TRUNCATE(sal,2),sha(TRUNCATE(sal,2)),sha1(TRUNCATE(sal,2)),sha2(TRUNCATE(sal,2),256) FROM sha_table1 ORDER BY id;

SELECT SQRT(sha(sal)),SQRT(sha1(sal)),SQRT(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT SQRT(sal),sha(SQRT(sal)),sha1(SQRT(sal)),sha2(SQRT(sal),256) FROM sha_table1 ORDER BY id;

SELECT SUM(sha(sal)),SUM(sha1(sal)),SUM(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT SUM(sal),sha(SUM(sal)),sha1(SUM(sal)),sha2(SUM(sal),256) FROM sha_table1 ORDER BY id;
--enable_warnings



--echo ##字符函数
SELECT UPPER(sha(sal)),UPPER(sha1(sal)),UPPER(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT UPPER(sal),sha(UPPER(sal)),sha1(UPPER(sal)),sha2(UPPER(sal),256) FROM sha_table1 ORDER BY id;

SELECT LOWER(sha(sal)),LOWER(sha1(sal)),LOWER(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT LOWER(sal),sha(LOWER(sal)),sha1(LOWER(sal)),sha2(LOWER(sal),256) FROM sha_table1 ORDER BY id;

SELECT INSTR(sha(sal),'e'),INSTR(sha1(sal),'e'),INSTR(sha2(sal,224),'e') FROM sha_table1 ORDER BY id;
SELECT INSTR(sal,'e'),sha(INSTR(sal,'e')),sha1(INSTR(sal,'e')),sha2(INSTR(sal,'e'),256) FROM sha_table1 ORDER BY id;

SELECT LENGTH(sha(sal)),LENGTH(sha1(sal)),LENGTH(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT LENGTH(sal),sha(LENGTH(sal)+1),sha1(LENGTH(sal)+2),sha2(LENGTH(sal)+3,256) FROM sha_table1 ORDER BY id;

SELECT REPLACE(sha(sal),'0','$'),REPLACE(sha1(sal),'0','$'),REPLACE(sha2(sal,224),'0','$') FROM sha_table1 ORDER BY id;
SELECT REPLACE(sal,'0','$'),sha(REPLACE(sal,'0','$')),sha1(REPLACE(sal,'0','$')),sha2(REPLACE(sal,'0','$'),256) FROM sha_table1 ORDER BY id;

SELECT SUBSTR(sha(sal),2),SUBSTR(sha1(sal),2),SUBSTR(sha2(sal,224),2) FROM sha_table1 ORDER BY id;
SELECT SUBSTR(sal,1,2),sha(SUBSTR(sal,1,2)),sha1(SUBSTR(sal,1,2)),sha2(SUBSTR(sal,1,2),256) FROM sha_table1 ORDER BY id;

SELECT CONCAT(sha(sal),'$'),CONCAT(sha1(sal),'$'),CONCAT(sha2(sal,224),'$') FROM sha_table1 ORDER BY id;
SELECT CONCAT(sal,'W','H'),sha(CONCAT(sal,NULL)),sha1(CONCAT(sal,'W','H')),sha2(CONCAT(sal,'W','H'),256) FROM sha_table1 ORDER BY id;

--echo ##日期函数
SELECT FROM_DAYS(sha(sal)),FROM_DAYS(sha1(sal)),FROM_DAYS(sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT FROM_DAYS(sal),sha(FROM_DAYS(sal)),sha1(FROM_DAYS(sal)),sha2(FROM_DAYS(sal),256) FROM sha_table1 ORDER BY id;

--echo # 系统时间会变，所以预期执行结果也会不一样，知道sql语句支持就好，暂时注释掉
--echo # SELECT SYSDATE(),sha(SYSDATE()),sha1(SYSDATE()),sha2(SYSDATE(),256) FROM sha_table1 ORDER BY id;

--echo ##通用函数
SELECT IFNULL(NULL,sha1(sal)),IFNULL(sha1(sal),NULL),IFNULL(sha2(sal,NULL),sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT IFNULL(NULL,sal),sha(IFNULL(NULL,sal)),sha1(IFNULL(NULL,sal)),sha2(IFNULL(NULL,sal),256) FROM sha_table1 ORDER BY id;

SELECT COALESCE(NULL,sha1(sal)),COALESCE(sha1(sal),NULL),COALESCE(sha2(sal,NULL),sha2(sal,224)) FROM sha_table1 ORDER BY id;
SELECT COALESCE(NULL,sal),sha(COALESCE(NULL,sal)),sha1(COALESCE(NULL,sal)),sha2(COALESCE(NULL,sal),256) FROM sha_table1 ORDER BY id;

--echo ### 标签：sha-6-2 多级函数嵌套  
--echo #※ mysql输出结果：数字+小写字母，ob输出结果：数字+大写，所以嵌套时需统一转换成小写
select sha2(lower(sha1('a')),0) from dual;
select sha1(lower(sha2('a',0))) from dual;
SELECT id,sal,sha(sal) FROM sha_table1 ORDER BY sha(id);
SELECT id,sal,sha(lower(sha(sal))) FROM sha_table1 ORDER BY sha(id);
SELECT id,sal,sha(lower(sha(lower(sha(sal))))) FROM sha_table1 ORDER BY sha(id);
SELECT id,sal,sha(lower(sha(lower(sha(lower(sha(sal))))))) FROM sha_table1 ORDER BY sha(id);

SELECT id,sal,sha1(sal) FROM sha_table1 ORDER BY sha1(id);
SELECT id,sal,sha1(lower(sha1(sal))) FROM sha_table1 ORDER BY sha1(id);
SELECT id,sal,sha1(lower(sha1(lower(sha1(sal))))) FROM sha_table1 ORDER BY sha1(id);
SELECT id,sal,sha1(lower(sha1(lower(sha1(lower(sha1(sal))))))) FROM sha_table1 ORDER BY sha1(id);

SELECT id,sal,sha2(sal,0) FROM sha_table1 ORDER BY sha1(id);
SELECT id,sal,sha2(lower(sha2(sal,0)),0) FROM sha_table1 ORDER BY sha1(id);
SELECT id,sal,sha2(lower(sha2(lower(sha2(sal,0)),0)),0) FROM sha_table1 ORDER BY sha1(id);
SELECT id,sal,sha2(lower(sha2(lower(sha2(lower(sha2(sal,0)),0)),0)),0) FROM sha_table1 ORDER BY sha1(id);


--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user whh@'%';
--enable_warnings
