purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

DELIMITER //;


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 加密函数-sha(str)/sha1(str), sha2(str, hash_length) pl/sql ----------------------------
--echo ### 用例：sha-3  sha(str)/sha1(str)/sha2(str) - pl/sql
--echo -----------------------------------------------------------------------------------------------------------------

--error 0,1051
DROP TABLE sha_table1;//
CREATE TABLE sha_table1(id int,name varchar(200), addressess varchar(200),sal varchar(200));//
INSERT INTO sha_table1 VALUES(1,'不一','杭州','15000');//
INSERT INTO sha_table1 VALUES(2,'不二','苏州','8000');//
INSERT INTO sha_table1 VALUES(3,'不三','洛阳','6000');//
INSERT INTO sha_table1 VALUES(4,'不四','濮阳','5000');//

--error 0,1051
DROP TABLE sha_table2;//
CREATE TABLE sha_table2(id int,sal_sha varchar(200), sal_sha1 varchar(200),sal_sha2 varchar(200));//


--echo ### 标签：sha-3-1 存储过程
--echo ##无参数的存储过程
--error 0,1305
DROP PROCEDURE p_sha;//
CREATE PROCEDURE p_sha()
begin
	declare a varchar(200);
	declare b varchar(200);
	declare c varchar(200);
	declare i int default 5;
	SELECT sha(sal),sha1(sal),sha2(sal,224) into a,b,c FROM sha_table1 WHERE sha(id) = sha(1);
    INSERT INTO sha_table2 VALUES(1,a,b,c);
	WHILE i <= 7 do
	  INSERT INTO sha_table1 VALUES(i,'不易1','杭州1',sha(9000+i));
	  SET i := i + 1;
	END while;
END;
//

SELECT COUNT(*) FROM sha_table1;//
SELECT COUNT(*) FROM sha_table2;//
CALL p_sha();//
SELECT id,name,addressess,sal FROM sha_table1 ORDER BY id;//
SELECT id,sal_sha,sal_sha1,sal_sha2 FROM sha_table2 ORDER BY id;//


--echo ##只有一个in参数的存储过程
--error 0,1305
DROP PROCEDURE p_sha;//
CREATE PROCEDURE p_sha(in invalue varchar(200))
begin
	declare a varchar(200);
	declare b varchar(200);
	declare c varchar(200);
    declare i int default 8;
	SELECT sha(sal),sha1(sal),sha2(sal,224) into a,b,c FROM sha_table1 WHERE sha1(id) = invalue;
	INSERT INTO sha_table2 VALUES(2,a,b,c);
   	REPEAT
	  INSERT INTO sha_table1 VALUES(i,'不易2','杭州2',sha1(8000+i));
	  SET i := i+1;
	until i > 11	
	END  REPEAT;
END;
//

SELECT COUNT(*) FROM sha_table1;//
SELECT COUNT(*) FROM sha_table2;//
CALL p_sha(sha1(2));//
SELECT id,name,addressess,sal FROM sha_table1 ORDER BY id;//
SELECT id,sal_sha,sal_sha1,sal_sha2 FROM sha_table2 ORDER BY id;//


--echo ##包含out参数的存储过程
--error 0,1305
DROP PROCEDURE p_sha;//
CREATE  PROCEDURE p_sha(out outa varchar(200),OUT outb varchar(200),OUT outc varchar(200))
begin
    declare i int default 11;
	SELECT sha(sal),sha1(sal),sha2(sal,224) into outa,outb,outc FROM sha_table1 WHERE sha1(id) like '%3BABBB%';
	WHILE i <= 13 do
	   INSERT INTO sha_table1 VALUES(i,'不易3','杭州3',sha2(7000+i,0));
	SET i := i + 1;
	END WHILE;
END;
//

SELECT COUNT(*) FROM sha_table1;//
CALL p_sha(@outa,@outb,@outc);//
SELECT id,name,addressess,sal FROM sha_table1 ORDER BY id;//
SELECT @outa,@outb,@outc;//


--echo ##包含inout参数的存储过程
--error 0,1305
DROP PROCEDURE p_sha;//
CREATE  PROCEDURE p_sha(OUT outa varchar(200),OUT outb varchar(200),INOUT inoutc varchar(200))
begin
    declare invalue varchar(200);
    declare i int default 14;
	set invalue := inoutc;
	SELECT sha(sal),sha1(sal),sha2(sal,224) into outa,outb,inoutc FROM sha_table1 WHERE sha2(id,0) = invalue;
	WHILE i <= 16 do
	  INSERT INTO sha_table1 VALUES(i,'不易4','杭州4',sha2(6000+i,224));
	  set i := i+1;
	END WHILE;
END;
//

SELECT COUNT(*) FROM sha_table1;//
SET @inoutc := sha2(3,0);//
CALL p_sha(@outa,@outb,@inoutc);//
SELECT id,name,addressess,sal FROM sha_table1 ORDER BY id;//
SELECT @outa,@outb,@outc;//


--echo ##dml语句
--echo #条件语句
--error 0,1305
DROP PROCEDURE p_sha;//
CREATE PROCEDURE p_sha(IN invalue varchar(200),IN ina varchar(200),IN inb varchar(200),IN inc varchar(200))
begin
    IF invalue = sha1('sha_table1') THEN 
	   INSERT INTO sha_table1 VALUES(17,'PROCEDURE-If条件','杭州5',sha2(ina+inb+inc,512));
    ELSE 
	   INSERT INTO sha_table2 VALUES(3,sha(ina),sha1(inb),sha2(inb,512));
    END IF;
END;
//

SELECT COUNT(*) FROM sha_table1;//
SELECT COUNT(*) FROM sha_table2;//
SET @invalue := sha1('sha_table1');//
SET @ina := '1';//
SET @inb := '2';//
SET @inc := '3';//
CALL p_sha(@invalue,@ina,@inb,@inc);//
SELECT id,name,addressess,sal FROM sha_table1 ORDER BY id;//

SET @invalue := sha1('sha_table2');//
SET @ina := '1';//
SET @inb := '2';//
SET @inc := '3';//
CALL p_sha(@invalue,@ina,@inb,@inc);//
SELECT id,sal_sha,sal_sha1,sal_sha2 FROM sha_table2 ORDER BY id;//


--echo #循环语句
--error 0,1305
DROP PROCEDURE p_sha;//
CREATE PROCEDURE p_sha()
begin
    declare i int default 18;
    WHILE i <= 20 do
      INSERT INTO sha_table1 VALUES(i,'PROCEDURE-While循环','杭州5',sha(6000+i));
      set i := i+1;
    END WHILE;

    loop_name:LOOP
      INSERT INTO sha_table1 VALUES(i,'PROCEDURE-Loop循环','杭州6',sha1(6000+i));
      SET i := i+1;
      IF i > 23 THEN 
	    LEAVE loop_name;
      END IF;
    END LOOP loop_name;

    REPEAT
      INSERT INTO sha_table1 VALUES(i,'PROCEDURE-Repeat循环','杭州7',sha2(8000+i,224));
      SET i := i+1;
      until i > 26	
    END  REPEAT;
END;
//

SELECT COUNT(*) FROM sha_table1;//
SELECT COUNT(*) FROM sha_table2;//
CALL p_sha();//
SELECT id,name,addressess,sal FROM sha_table1 ORDER BY id;//
SELECT id,sal_sha,sal_sha1,sal_sha2 FROM sha_table2 ORDER BY id;//


--echo ##游标
--error 0,1305
DROP PROCEDURE test_pro;//
CREATE PROCEDURE test_pro()
BEGIN
	DECLARE a varchar(200);
	DECLARE b varchar(200);
	DECLARE done INT DEFAULT 0;
	DECLARE sha_cursor CURSOR FOR SELECT id,sha(sal) FROM sha_table1 WHERE id < 4 GROUP BY id HAVING sha1(id) like '%cd%';
	DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
	OPEN sha_cursor;
	FETCH sha_cursor INTO a,b;
	WHILE done<>1 DO
      INSERT INTO sha_table2 VALUES(a,b,sha1(lower(b)),sha2(lower(b),384));
      FETCH sha_cursor INTO a,b;
	END WHILE;
	CLOSE sha_cursor;
END;
//

SELECT COUNT(*) FROM sha_table2;//
CALL test_pro();//
SELECT id,sal_sha,sal_sha1,sal_sha2 FROM sha_table2 ORDER BY id;//


--echo ##动态sql
--error 0,1305
DROP PROCEDURE p_sha;//
CREATE PROCEDURE p_sha()
BEGIN
  SET @s = 'INSERT INTO sha_table1 VALUES(?,"动态sql插入的数据","杭州8",?);';
  PREPARE stmsha_table1 FROM @s;
  SET @a = 26;
  SET @b = sha(10000);
  EXECUTE stmsha_table1 USING @a,@b;

  SET @s = 'SELECT id,name,sha(name),addressess,sal FROM sha_table1 WHERE sal = ?';
  PREPARE stmt2 FROM @s;
  SET @a = sha(10000);
  EXECUTE stmt2 USING @a; 
END;
//

SELECT * FROM sha_table1 ORDER BY id;//
CALL p_sha();//


--error 0,1305
DROP PROCEDURE p_sha;//
CREATE PROCEDURE p_sha()
BEGIN
  SET @s = 'update sha_table1 set name = ? WHERE sha(id) = ?;';
  PREPARE stmsha_table1 FROM @s;
  SET @a = '动态sql更新数据';
  SET @b = sha(26);
  EXECUTE stmsha_table1 USING @a,@b;

  SET @s = 'SELECT id,name,addressess,sal FROM sha_table1 WHERE sha(id) = ?';
  PREPARE stmt2 FROM @s;
  SET @a = sha(26);
  EXECUTE stmt2 USING @a; 
  
  SET @s = 'delete FROM sha_table1 WHERE sha(id) = ?;';
  PREPARE stmsha_table1 FROM @s;
  SET @a = sha(26);
  EXECUTE stmsha_table1 USING @a;

  SET @s = 'SELECT id,name,addressess,sal FROM sha_table1 WHERE sha(id) = ?';
  PREPARE stmt2 FROM @s;
  SET @a = sha(26);
  EXECUTE stmt2 USING @a;  
END;
//

CALL p_sha();//


--echo ##函数返回值作为存储过程的参数传递
--error 0,1305
DROP FUNCTION f_sha;//
CREATE FUNCTION f_sha() RETURNS varchar(200) READS SQL DATA 
BEGIN
	declare a varchar(200);
	SELECT sha(sal) into a FROM sha_table1 WHERE sha2(id,384) = sha2(3,384);
	RETURN a;
END;
//

--error 0,1305
drop procedure p_sha;//
create  PROCEDURE p_sha(in infun varchar(200))
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int;
	set a := '变量1';
	set b := '变量2';
  	INSERT INTO sha_table2 VALUES(4,infun,sha1(a),sha2(b,512));
END;
//

SELECT COUNT(*) FROM sha_table2;//
CALL p_sha(f_sha());//
SELECT id,sal_sha,sal_sha1,sal_sha2 FROM sha_table2 ORDER BY id;//


-- echo #自定义变量，全局变量，in 参数作为sha函数的参数
--error 0,1051
DROP TABLE sha_table3;//
CREATE TABLE sha_table3(id int,c1 varchar(200), c2 varchar(200),c3 varchar(200),c4 varchar(200));//

DROP PROCEDURE p_sha;//
CREATE PROCEDURE p_sha(IN ina varchar(200),IN inb varchar(200),IN inc varchar(200))
begin
  declare a varchar(200) default '1';
  declare b varchar(200) default '2';
  declare c varchar(200) default '3';
  INSERT INTO sha_table3 VALUES(1,'自定义变量',sha(a),sha1(b),sha2(c,0));
  INSERT INTO sha_table3 VALUES(2,'全局变量',sha(@mya),sha1(@myb),sha2(@myc,0));
  INSERT INTO sha_table3 VALUES(3,'参数变量',sha(ina),sha1(inb),sha2(inc,0));
END;
//

SET @mya := '1';//
SET @myb := '2';//
SET @myc := '3';//
CALL p_sha('1','2','3');//
SELECT * FROM sha_table3 ORDER BY id;//


--echo ### 标签：sha-3-2 函数      
--echo #定义一个无参的函数
--error 0,1305
drop function f_sha;//
CREATE FUNCTION f_sha() returns varchar(200) READS SQL DATA 
begin
	declare a varchar(200);
	SELECT sha(sal) into a FROM sha_table1 WHERE sha1(id) = sha1(4);
	return a;
END;
//

SELECT  f_sha();//


--echo #定义一个有参的函数
--error 0,1305
DROP FUNCTION f_sha;//
CREATE FUNCTION f_sha(invalue varchar(200)) returns  varchar(200) READS SQL DATA 
begin
	declare a varchar(200);
	SELECT sha1(sal) into a FROM sha_table1 WHERE sha1(id) = invalue;
	return a;
END ;
//

SELECT f_sha(sha1(3));//


--echo ##dml语句
--echo #条件语句
--error 0,1305
DROP FUNCTION f_sha;//
CREATE FUNCTION f_sha(invalue varchar(200),ina varchar(200),inb varchar(200),inc varchar(200))returns varchar(200) DETERMINISTIC
begin
    IF invalue = sha('sha_table1') THEN 
	   INSERT INTO sha_table1 VALUES(26,'FUNCTION-If条件','杭州7',sha2(ina+inb+inc,512));
    ELSE 
	   INSERT INTO sha_table2 VALUES(4,sha(ina),sha1(inb),sha2(inb,512));
    END IF;
    return sha2(ina+inb+inc,512);
END;
//

SELECT COUNT(*) FROM sha_table1;//
SELECT COUNT(*) FROM sha_table2;//
SET @invalue := sha1('sha_table1');//
SET @ina := '1';//
SET @inb := '2';//
SET @inc := '3';//
SELECT f_sha(@invalue,@ina,@inb,@inc);//
SELECT id,name,addressess,sal FROM sha_table1 ORDER BY id;//

SET @invalue := sha1('sha_table2');//
SET @ina := '1';//
SET @inb := '2';//
SET @inc := '3';//
SELECT f_sha(@invalue,@ina,@inb,@inc);//
SELECT id,sal_sha,sal_sha1,sal_sha2 FROM sha_table2 ORDER BY id;//


--echo #循环语句
--error 0,1305
DROP FUNCTION f_sha;//
CREATE  FUNCTION f_sha(invalue varchar(200)) returns varchar(200) DETERMINISTIC
begin
	declare a varchar(200);
    declare i int default 27;
	SELECT sha1(sal) into a FROM sha_table1 WHERE sha2(name,256) = invalue;
	
    WHILE i <= 29 do
      INSERT INTO sha_table1 VALUES(i,'FUNCTION-While循环','杭州8',sha(8000+i));
      set i := i+1;
    END WHILE;

    loop_name:LOOP
      INSERT INTO sha_table1 VALUES(i,'FUNCTION-Loop循环','杭州9',sha1(8000+i));
      SET i := i+1;
      IF i > 32 THEN 
	    LEAVE loop_name;
      END IF;
    END LOOP loop_name;

    REPEAT
      INSERT INTO sha_table1 VALUES(i,'FUNCTION-Repeat循环','杭州10',sha2(8000+i,224));
      SET i := i+1;
      until i > 34	
    END  REPEAT;
	return a;
END;
//

SELECT COUNT(*) FROM sha_table1;//
SELECT f_sha(sha2('不三',256));//
SELECT id,name,addressess,sal FROM sha_table1 ORDER BY id;//


--echo ### 标签：sha-3-3 触发器    
--error 0,1360
DROP TRIGGER base_pl;//
CREATE TRIGGER base_pl BEFORE INSERT
ON sha_table1 FOR EACH ROW
BEGIN
	DECLARE a int;
	DECLARE b VARCHAR(20);
	set a=10;
	set b='insert';
	loop1: LOOP
	  if a < 15 then
	    INSERT INTO sha_table2 VALUES(a,'触发器-插入数据 insert',sha1(b),sha2(b,0));
	  elseif a = 16 then
	    update sha_table2 set sal_sha = '触发器-更新数据 update',sal_sha1=sha1('update'),sal_sha2=sha2('update',0)  WHERE id >= 12;
	    LEAVE loop1;
	  else
	    delete FROM sha_table2 WHERE sha(id) = sha(14);	
	  end if;
	  set a = a + 1;
	end LOOP loop1;
END;
//

SELECT * FROM sha_table1 ORDER BY id;//
SELECT * FROM sha_table2 ORDER BY id;//
INSERT INTO sha_table1 VALUES(34,'触发触发器-插入数据','杭州9',sha(8000));//
SELECT * FROM sha_table1 ORDER BY id;//
SELECT * FROM sha_table2 ORDER BY id;//


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 加密函数-sha(str)/sha1(str), sha2(str, hash_length) 视图，索引，约束 ------------------
--echo ### 用例：sha-4  sha(str)/sha1(str)/sha2(str) - 视图，索引，约束
--echo -----------------------------------------------------------------------------------------------------------------

--echo #################################################################################
--echo ### 表，视图创建

DELIMITER ;//

--error 0,1051
DROP TABLE sha_table1;
CREATE TABLE sha_table1(id int,name varchar(200), address varchar(200),sal varchar(200));
INSERT INTO sha_table1 VALUES(1,'阿里','杭州','15000');
INSERT INTO sha_table1 VALUES(2,'阿依','广州','8000');
INSERT INTO sha_table1 VALUES(3,'阿布','苏州','6000');
INSERT INTO sha_table1 VALUES(4,'阿珊','苏州','5000');

--error 0,1051
DROP TABLE sha_table2;
CREATE TABLE sha_table2(id int,style varchar(200),price int);
INSERT INTO sha_table2 VALUES(1,'键盘',300);
INSERT INTO sha_table2 VALUES(2,'鼠标',200);
INSERT INTO sha_table2 VALUES(3,'耳机',500);

--error 0,1051
DROP TABLE sha_table4;
CREATE TABLE sha_table4(id int,c1 varchar(200),c2 varchar(200),c3 varchar(200));

--error 0,1051
DROP VIEW sha_table1_view;
CREATE VIEW sha_table1_view AS SELECT * FROM sha_table1 WHERE sha(id) >= sha(4);

--error 0,1051
DROP VIEW t2_view;
CREATE VIEW t2_view AS SELECT * FROM sha_table2 WHERE sha(id) like '%A%';

--error 0,1051
DROP TABLE t3_view;

SELECT * FROM sha_table1_view ORDER BY id;
SELECT * FROM t2_view ORDER BY id;

--echo #################################################################################


--echo ### 标签：sha-4-1 视图
--echo ### SELECT
--echo ##多列/单列
SELECT id,sha(e.id),sha1(e.name),sha2(e.address,224) FROM sha_table1_view e ORDER BY e.id;
SELECT CONCAT(e.id,e.name) idname,sha(CONCAT(e.id,e.name)),sha1(CONCAT(e.id,e.name)),sha2(CONCAT(e.id,e.name),0) FROM sha_table1_view e ORDER BY e.id;

--echo ##WHERE 子句
SELECT e.id,e.name,sha(e.name) FROM sha_table1_view e WHERE sha(e.name) like '%6590ec%';
SELECT e.id,e.name,sha1(e.name) FROM sha_table1_view e WHERE sha1(e.name) like '%f4b7ea%';
SELECT e.id,e.name,sha(e.name) FROM sha_table1_view e WHERE sha(e.name) > sha('阿布') ORDER BY e.id;
SELECT e.id,e.name,sha1(e.name) FROM sha_table1_view e WHERE sha1(e.name) < sha1('阿布') ORDER BY e.id;
SELECT e.id,e.name,sha2(e.name,0) FROM sha_table1_view e WHERE sha2(e.name,0) = sha2('阿布',0) ORDER BY e.id;

--echo ##order by 子句
SELECT e.id,sha(e.id) FROM sha_table1_view e WHERE sha(e.name) < sha('阿布') ORDER BY sha(e.id);
SELECT e.id,sha(e.id) FROM sha_table1_view e WHERE sha(e.name) < sha('阿布') ORDER BY sha(e.id) DESC;
SELECT e.id,sha1(e.id) FROM sha_table1_view e WHERE sha1(e.name) < sha1('阿布') ORDER BY sha1(e.id) ;
SELECT e.id,sha2(e.id,0) FROM sha_table1_view e WHERE sha2(e.name,0) > sha2('阿布',0) ORDER BY sha2(e.id,0) DESC;

--echo ##group by having 子句
SELECT e.id,e.address,sha(e.address) FROM sha_table1_view e LEFT JOIN t2_view p ON e.id = p.id GROUP BY sha(e.address),e.id ORDER BY e.id ;
SELECT e.id,e.address,sha1(e.address) FROM sha_table1_view e LEFT JOIN t2_view p ON e.id = p.id GROUP BY sha1(e.address),e.id HAVING SUM(sha1(e.address)) > 0 ORDER BY e.id;
SELECT e.id,e.address,sha2(e.address,512) FROM sha_table1_view e  GROUP BY sha2(e.address,512),e.id ORDER BY e.id ;

--echo #DISTINCT
SELECT distinct sha(e.address),e.address FROM sha_table1_view e ORDER BY e.id;
SELECT distinct sha1(e.address),e.address FROM sha_table1_view e ORDER BY e.id;
SELECT distinct sha2(e.address,384),e.address FROM sha_table1_view e ORDER BY e.id;

--echo #CASE WHEN
SELECT e.id,e.name,e.sal,sha(CASE WHEN e.sal < 6000 THEN NULL ELSE e.sal END) sal2 FROM sha_table1_view e ORDER BY e.id;
SELECT e.id,e.name,e.sal,CASE sha(e.sal) WHEN sha(5000) THEN '工资低' WHEN sha(6000) THEN '工资一般' ELSE '工资高' END ranks FROM sha_table1_view e ORDER BY e.id; 
SELECT e.id,e.name,e.sal,(CASE sha(e.sal) WHEN sha(5000) THEN '工资低' WHEN sha(6000) THEN '工资一般' ELSE '工资高' END) ranks FROM sha_table1_view e GROUP BY (CASE sha(e.sal) WHEN sha(5000) THEN '工资低' WHEN sha(6000) THEN '工资一般' ELSE '工资高' END),e.id ORDER BY e.id ; 

--echo ##连接查询
SELECT sha(e.name),sha1(e.address),sha2(p.style,0) FROM sha_table1_view e, t2_view p WHERE e.id = p.id ORDER BY e.id DESC;
SELECT sha(e.name),sha1(e.address),sha2(p.style,0) FROM sha_table1_view e LEFT JOIN t2_view p ON e.id = p.id ORDER BY e.id DESC;
SELECT sha(e.name),sha1(e.address),sha2(p.style,0) FROM sha_table1_view e RIGHT JOIN t2_view p ON e.id = p.id ORDER BY e.id DESC;
SELECT sha(e.name),sha1(e.address),sha2(p.style,0) FROM sha_table1_view e INNER JOIN t2_view p ON e.id = p.id ORDER BY e.id DESC;

--echo ##SELECT嵌套
--echo #SELECT
SELECT sha(e.id),sha(e.name),sha1(e.address),sha2(e.sal,0) FROM (SELECT id,name,address,sal FROM sha_table1_view WHERE id =1) e; 

--echo #EXISTS AND NOT EXISTS
SELECT e.id,e.name,sha(e.name) FROM sha_table1_view e WHERE EXISTS (SELECT sha(p.id) FROM t2_view p ) ORDER BY e.id;
SELECT e.id,e.name,sha1(e.name) FROM sha_table1_view e WHERE NOT EXISTS (SELECT sha(p.id) FROM t2_view p WHERE p.style like '%whh%' ) ORDER BY e.id;

--echo #ANY
SELECT e.id,e.name,sha(e.name) FROM sha_table1_view e WHERE sha(e.id) = ANY (SELECT sha(p.id) FROM t2_view p WHERE id = 2) ORDER BY e.id;
SELECT e.id,e.name,sha1(e.name) FROM sha_table1_view e WHERE sha1(e.id) < ANY (SELECT sha1(p.id) FROM t2_view p WHERE id = 3) ORDER BY e.id;
SELECT e.id,e.name,sha2(e.name,224) FROM sha_table1_view e WHERE sha2(e.id,224) > ANY (SELECT sha2(p.id,224) FROM t2_view p WHERE id = 3) ORDER BY e.id;

--echo #ALL 
SELECT e.id,e.name,sha(e.name) FROM sha_table1_view e WHERE sha(e.id) = ALL (SELECT sha(p.id) FROM t2_view p WHERE id = 2) ORDER BY e.id;
SELECT e.id,e.name,sha1(e.name) FROM sha_table1_view e WHERE sha1(e.id) < ALL (SELECT sha1(p.id) FROM t2_view p WHERE id = 3) ORDER BY e.id;
SELECT e.id,e.name,sha2(e.name,256) FROM sha_table1_view e WHERE sha2(e.id,256) > ALL (SELECT sha2(p.id,256) FROM t2_view p WHERE id = 3) ORDER BY e.id;

--echo #CREATE AS  mysql 执行失败，Ob执行成功
--echo #原因：5.6及以上的版本内，开启了 enforce_gtid_consistency=true 功能导致的，MySQL官方解释说当启用 enforce_gtid_consistency 功能的时候，MySQL只允许能够保障事务安全，并且能够被日志记录的SQL语句被执行，像create table … SELECT 和 create temporarytable语句，以及同时更新事务表和非事务表的SQL语句或事务都不允许执行。 
--error 0,1051
DROP VIEW t3_view;
CREATE VIEW t3_view AS SELECT id,sha(name) name3,sha1(address) address3,sha2(sal,0) sal3 FROM sha_table1_view; 
SELECT * FROM t3_view;

--echo #WITH AS的SELECT
WITH a AS (SELECT id,name,sha(name) name2 FROM sha_table1_view ) SELECT a.id,a.name,a.name2 FROM a ORDER BY a.id;
WITH a AS (SELECT id,name,sha1(name) name2 FROM sha_table1_view ) SELECT a.id,a.name,a.name2 FROM a ORDER BY a.id;
WITH a AS (SELECT id,name,sha2(name,0) name2 FROM sha_table1_view ) SELECT a.id,a.name,a.name2 FROM a ORDER BY a.id;

--echo #模糊查询like 
SELECT e.id,e.name,sha(e.name)  FROM sha_table1_view e WHERE sha(e.name) LIKE '%bef%';
SELECT e.id,e.name,sha(e.name) FROM sha_table1_view e LEFT JOIN t2_view p ON e.id = p.id WHERE sha(e.name) LIKE '%df%';


--echo ###  update
UPDATE sha_table1_view SET name = '阿里-update' WHERE sha(name) = sha('阿里');
UPDATE sha_table1_view SET name = '阿依-update' WHERE sha1(name) = sha1('阿依') ORDER BY sha1(id) DESC;
UPDATE sha_table1_view SET address = (SELECT sha2(style,0) FROM t2_view GROUP BY sha2(style,0),id HAVING id = 1 ORDER BY sha1(id)) WHERE id = 1 ;
SELECT * FROM  sha_table1_view;


--echo ###  delete
SELECT * FROM  t2_view ORDER BY sha1(id);
DELETE FROM t2_view WHERE sha1(id) = sha1(2) ORDER BY sha1(id) DESC;
SELECT * FROM  t2_view ORDER BY sha1(id);


--echo ### 标签：sha-4-2 索引
--error 0,1091
DROP INDEX `sha_index1` ON sha_table1;
--error 0,1091
DROP INDEX `sha_index2` ON sha_table1;

CREATE INDEX sha_index1 ON sha_table1(id);
ALTER TABLE sha_table1 ADD INDEX sha_index2 (name);

--echo #insert 
insert into sha_table1 SELECT * FROM sha_table1 e WHERE sha(e.id) = sha(3);
SELECT *  FROM sha_table1 ORDER BY sha1(id);

--echo #update 
UPDATE sha_table1 set name = '索引-update' WHERE sha1(id) = sha1(4);
SELECT *  FROM sha_table1 ORDER BY sha1(id);
UPDATE sha_table1 set address = sha('索引-update') WHERE sha2(id,0) = sha2(4,0);
SELECT *  FROM sha_table1 ORDER BY sha1(id);

--echo #SELECT 
SELECT id,sha(e.id),sha1(e.name),sha2(e.name,0) FROM sha_table1 e WHERE sha(e.id) < sha(2) ORDER BY e.id;
SELECT id,sha(e.id),sha1(e.name),sha2(e.name,224) FROM sha_table1 e WHERE sha(e.name) like '%f1%' order by sha(e.id) desc;

--echo #delete 
DELETE FROM sha_table1 WHERE address = sha('索引-update');
SELECT *  FROM sha_table1 ORDER BY sha1(id);


--echo ### 标签：sha-4-3 约束
--error 0,1051
DROP TABLE sha_table1;
CREATE TABLE sha_table1(
  id int PRIMARY KEY,
  name char(200) UNIQUE, 
  grade varchar(200) NOT NULL,
  ranks varchar(200)
);

INSERT INTO sha_table1 VALUES(1,'楠楠','100','1');
INSERT INTO sha_table1 VALUES(2,'看看','90','3');
INSERT INTO sha_table1 VALUES(3,'青青','95','2');
INSERT INTO sha_table1 VALUES(4,'慧慧','88','4');

--echo #insert 
INSERT INTO sha_table1 VALUES(5,'洋洋',sha('100'),sha2('1',0));
SELECT *  FROM sha_table1 ORDER BY sha1(id);

--echo #update 
UPDATE sha_table1 set name = '洋洋-update' WHERE sha1(id) = sha1(5);
SELECT *  FROM sha_table1 ORDER BY sha1(id);

--echo #SELECT 
SELECT id,sha(e.id),sha1(e.name),sha2(e.name,0) FROM sha_table1 e WHERE sha(e.id) < sha(2) ORDER BY e.id;
SELECT id,sha(e.id),sha1(e.name),sha2(e.name,224) FROM sha_table1 e  order by sha(e.id) desc;

--echo #delete 
DELETE FROM sha_table1 WHERE sha1(id) = sha1(5);
SELECT *  FROM sha_table1 ORDER BY sha1(id);


