purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 加密函数-sha(str)/sha1(str), sha2(str, hash_length) -----------------------------------
--echo ### 用例：sha-1 sha(str)/sha1(str)/sha2(str) - 参数 - 参数个数
--echo -----------------------------------------------------------------------------------------------------------------

--echo ### 标签：sha-1-1  sha(str)/sha1(str)
--echo ## 参数 - 参数个数-0个参数
--error 1582
select sha() from dual;
--error 1582
select sha1() from dual;


--echo ## 参数 - 参数个数-1个参数
select sha(null),sha1(null) from dual;
select sha('null'),sha1('null') from dual;
select sha('Null'),sha1('Null') from dual;

--echo ## issue: 40122921 bug1: 加密函数sha()/sha1()/sha1(),参数是空字符('')时，mysql成功，ob失败。
--echo Fixed
select sha('') from dual;
select sha1('') from dual;

select sha(' '),sha1(' ') from dual;
select sha('　'),sha1('　') from dual;
select sha('!@#$%^&*''()_+-=?:;"<>/\{}[]~'),sha1('!@#$%^&*''()_+-=?:;"<>/\{}[]~') from dual;
select sha('……——，。 ?‘’'),sha1('……——，。 ?‘’') from dual;
select sha('true'),sha1('true') from dual;
select sha('false'),sha1('false') from dual;
select sha(true),sha1(true) from dual;
select sha(false),sha1(false) from dual;
select sha(' a王 '),sha1(' a王 ') from dual;
select sha(' ａ王 '),sha1(' ａ王 ') from dual;
select sha(' 123 '),sha1(' 123 ') from dual;
select sha(' １２３ '),sha1(' １２３ ') from dual;
select sha('_φ(?_?? 人丑就要多读书'),sha1('_φ(?_?? 人丑就要多读书') from dual;
select sha(' !@#$%^&*()_+ '),sha1(' !@#$%^&*()_+ ') from dual;
select sha(' ！＠＃＄％＾＆＊（）＿＋ '),sha1(' ！＠＃＄％＾＆＊（）＿＋ ') from dual;
select sha('▲▼●◆■★????????????♂??????√▉▓'),sha('▲▼●◆■★????????????♂??????√▉▓') from dual;


--echo ## issue: 40266365 bug2: 加密函数sha()/sha1()/sha2(),参数是制表符时，mysql成功，ob失败，但在mysqltest自动化中成功，其结果和mysql不一致。
--echo ## Invalid: 测试方法不正确

select sha('	') from dual;

select sha1('	') from dual;

select sha('
') from dual;
select sha1('
') from dual;

select sha('\n'),sha1('\n') from dual;
select sha('\r'),sha1('\r') from dual;
select sha('\t'),sha1('\t') from dual;
select sha("中國"),sha1("中國") from dual;
select sha('中国'),sha1('中国') from dual;
select sha("中国"),sha1("中国") from dual;
--error 1054
select sha(中国),sha1(中国) from dual;
select sha('加密函数:
md5(data) 返回32位的消息摘要(Message Digest)，由数字+小写字母组成。
sha(data) 返回40位的、经安全哈希算法(Security Hash Algorithm)计算出的结果值数字+小写字母。
password(data) 返回41位，由*开头的字符串(从第二位开始由数值与大写字母组成)。
MySQL账户密码(mysql库.user表.password列)用函数password(data)进行处理
MySQL的加密和解密函数个人分为两类：
1.只支持正向加密不支持反向解密的函数：
MD5()、SHA1()|SHA()、SHA2()
针对此类加密的算法MySQL不提供解密，

但是我们可以通过网站
http://www.cmd5.com/ 反向解密。
改网站支持MD5、SHA、SHA256、SHA512等解密。') sha,sha1('加密函数:
md5(data) 返回32位的消息摘要(Message Digest)，由数字+小写字母组成。
sha(data) 返回40位的、经安全哈希算法(Security Hash Algorithm)计算出的结果值数字+小写字母。
password(data) 返回41位，由*开头的字符串(从第二位开始由数值与大写字母组成)。
MySQL账户密码(mysql库.user表.password列)用函数password(data)进行处理
MySQL的加密和解密函数个人分为两类：
1.只支持正向加密不支持反向解密的函数：
MD5()、SHA1()|SHA()、SHA2()
针对此类加密的算法MySQL不提供解密，

但是我们可以通过网站
http://www.cmd5.com/ 反向解密。
改网站支持MD5、SHA、SHA256、SHA512等解密。') sha1 from dual;
select sha(rpad('10000个中文',10000,'good')),sha1(rpad('1',4194304,'0')) from dual;
select sha('https://dev.mysql.com/doc/refman/5.7/en/drop-index.html') from dual;
select sha1('https://dev.mysql.com/doc/refman/5.7/en/drop-index.html') from dual;
select sha(' abcd '),sha1(' abcd ') from dual;
select sha(' ABCD '),sha1(' ABCD ') from dual;
select sha('wanghuanhuan 1994'),sha1('wanghuanhuan 1994') from dual;
--error 1054
select sha(abc123),sha1(abc123) from dual;
select sha(0),sha1(0) from dual;
select sha(123),sha1(123) from dual;
select sha(3.1415926),sha1(3.1415926) from dual;
select sha(-123456),sha1(-123456) from dual;
select sha("-123456.789456465"),sha1("-123456.789456465") from dual;
select sha('1.99714E13'),sha1('1.99714E13') from dual;
select sha(1.99714E13),sha1(1.99714E13) from dual;
select sha(-1.23-1),sha1(-1.23-1) from dual;
select sha(+1.23-1),sha1(+1.23-1) from dual;
select sha(10),sha1(10) from dual;
select sha(1+2+3+4),sha1(1+2+3+4) from dual;
select sha(11-1),sha1(11-1) from dual;
select sha(2*5),sha1(2*5) from dual;
select sha(20/2),sha1(20/2) from dual;
select sha(1 & 2 | !3 ),sha1(1 & 2 | !3 ) from dual;
select sha('ab'),sha1('ab') from dual;

--disable_warnings
select sha('a' || 'b'),sha1('a' || 'b') from dual;
--enable_warnings

select sha(1 and 0 or not 2),sha1(1 and 0 or not 2) from dual;
select sha(4>=2),sha1(4>=2) from dual;
select sha(4<=2),sha1(4<=2) from dual;
select sha(4<>2),sha1(4<>2) from dual;
select sha(4!=2),sha1(4!=2) from dual;
select sha(6^3),sha1(6^3),sha(6>>3),sha1(6<<3) from dual;
select sha('12:00'),sha1('12:00') from dual;
select sha('20220311'),sha1('20220311') from dual;
select sha('2022-03-11 15:32:22'),sha1('2022-03-11 15:32:22') from dual;
--echo # 系统时间会变，所以预期执行结果也会不一样，知道sql语句支持就好，暂时注释掉
--echo # select sha(sysdate()),sha1(sysdate()) from dual;
select sha('你好'),sha1('你好') from dual;
select sha('hello'),sha1('hello') from dual;
select sha('こんにちは'),sha1('こんにちは') from dual;
select sha('안녕하세요'),sha1('안녕하세요') from dual;


--echo ## 参数 - 参数个数-多个参数
--error 1582
select sha('','a'),sha1('','a') from dual;
--error 1582
select sha('a',''),sha1('a','') from dual;
--error 1582
select sha(' ',' '),sha1(' ',' ') from dual;
--error 1582
select sha('a','b'),sha1('a','b') from dual;
--error 1582
select sha(1,2),sha1(1,2) from dual;
--error 1582
select sha('a','b','c'),sha1('a','b','c') from dual;
--error 1582
select sha('a','b','c','d'),sha1('a','b','c','d') from dual;
--error 1064
select sha('a',),sha1('a',) from dual;
--error 1064
select sha('a',,),sha1('a',,) from dual;


--echo ### 标签：sha-1-2  sha2(str, hash_length)
--echo ## 参数 - 参数个数-0个参数
--error 1582
select sha2() from dual;


--echo ## 参数 - 参数个数-1个参数
--error 1582
select sha2('abcd') from dual;
--error 1582
select sha2(1234) from dual;


--echo ## 参数个数-2个参数-str-参数值
select sha2(null,0),sha2(NULL,0) from dual;
select sha2('null',0),sha2('NULL',0)from dual;


