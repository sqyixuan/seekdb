CREATE TABLE sha_table1( 
  c1 CHAR(10), 
  c2 VARCHAR(100), 
  c3 BLOB(100), 
  c4 TEXT, 
  c5 BINARY(100),
  c6 VARBINARY(100), 
  c7 ENUM('星期一', '星期二', '星期三', '星期四', '星期五', '星期六'), 
  c8 SET('a', 'b', 'c', 'd', 'e')
)default character set = 'utf8mb4';

