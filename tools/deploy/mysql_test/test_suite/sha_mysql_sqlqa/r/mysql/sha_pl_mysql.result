#CASE WHEN
SELECT e.id,e.name,e.sal,sha(CASE WHEN e.sal < 6000 THEN NULL ELSE e.sal END) sal2 FROM sha_table1_view e ORDER BY e.id;
+------+--------+-------+------------------------------------------+
| id   | name   | sal   | sal2                                     |
+------+--------+-------+------------------------------------------+
|    1 | 阿里   | 15000 | 271593a69439c052d4de63e50c569060dcd78e91 |
|    2 | 阿依   | 8000  | 2de49ac0fce223dbdd31d2b8b3b3710582ef1535 |
|    3 | 阿布   | 6000  | 31d9ddeaa80bc88c1f3117b9724726ebcc7fc72d |
|    4 | 阿珊   | 5000  | NULL                                     |
+------+--------+-------+------------------------------------------+
SELECT e.id,e.name,e.sal,CASE sha(e.sal) WHEN sha(5000) THEN '工资低' WHEN sha(6000) THEN '工资一般' ELSE '工资高' END ranks FROM sha_table1_view e ORDER BY e.id;
+------+--------+-------+--------------+
| id   | name   | sal   | ranks        |
+------+--------+-------+--------------+
|    1 | 阿里   | 15000 | 工资高       |
|    2 | 阿依   | 8000  | 工资高       |
|    3 | 阿布   | 6000  | 工资一般     |
|    4 | 阿珊   | 5000  | 工资低       |
+------+--------+-------+--------------+
SELECT e.id,e.name,e.sal,(CASE sha(e.sal) WHEN sha(5000) THEN '工资低' WHEN sha(6000) THEN '工资一般' ELSE '工资高' END) ranks FROM sha_table1_view e GROUP BY (CASE sha(e.sal) WHEN sha(5000) THEN '工资低' WHEN sha(6000) THEN '工资一般' ELSE '工资高' END),e.id ORDER BY e.id ;
+------+--------+-------+--------------+
| id   | name   | sal   | ranks        |
+------+--------+-------+--------------+
|    1 | 阿里   | 15000 | 工资高       |
|    2 | 阿依   | 8000  | 工资高       |
|    3 | 阿布   | 6000  | 工资一般     |
|    4 | 阿珊   | 5000  | 工资低       |
+------+--------+-------+--------------+
