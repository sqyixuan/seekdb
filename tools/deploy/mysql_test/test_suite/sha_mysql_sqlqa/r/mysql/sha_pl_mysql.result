### 标签：sha-3-3 触发器    
DROP TRIGGER base_pl;//
CREATE TRIGGER base_pl BEFORE INSERT
ON sha_table1 FOR EACH ROW
BEGIN
	DECLARE a int;
	DECLARE b VARCHAR(20);
	set a=10;
	set b='insert';
	loop1: LOOP
	  if a < 15 then
	    INSERT INTO sha_table2 VALUES(a,'触发器-插入数据 insert',sha1(b),sha2(b,0));
	  elseif a = 16 then
	    update sha_table2 set sal_sha = '触发器-更新数据 update',sal_sha1=sha1('update'),sal_sha2=sha2('update',0)  WHERE id >= 12;
	    LEAVE loop1;
	  else
	    delete FROM sha_table2 WHERE sha(id) = sha(14);	
	  end if;
	  set a = a + 1;
	end LOOP loop1;
END;
//
