##游标
DROP PROCEDURE test_pro;//
CREATE PROCEDURE test_pro()
BEGIN
	DECLARE a varchar(200);
	DECLARE b varchar(200);
	DECLARE done INT DEFAULT 0;
	DECLARE sha_cursor CURSOR FOR SELECT id,sha(sal) FROM sha_table1 WHERE id < 4 GROUP BY id HAVING sha1(id) like '%cd%';
	DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
	OPEN sha_cursor;
	FETCH sha_cursor INTO a,b;
	WHILE done<>1 DO
      INSERT INTO sha_table2 VALUES(a,b,sha1(lower(b)),sha2(lower(b),384));
      FETCH sha_cursor INTO a,b;
	END WHILE;
	CLOSE sha_cursor;
END;
//
SELECT COUNT(*) FROM sha_table2;//
+----------+
| COUNT(*) |
+----------+
|        3 |
+----------+
CALL test_pro();//
