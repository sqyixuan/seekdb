#循环语句
DROP FUNCTION f_sha;//
CREATE  FUNCTION f_sha(invalue varchar(200)) returns varchar(200) DETERMINISTIC
begin
	declare a varchar(200);
    declare i int default 27;
	SELECT sha1(sal) into a FROM sha_table1 WHERE sha2(name,256) = invalue;
	
    WHILE i <= 29 do
      INSERT INTO sha_table1 VALUES(i,'FUNCTION-While循环','杭州8',sha(8000+i));
      set i := i+1;
    END WHILE;

    loop_name:LOOP
      INSERT INTO sha_table1 VALUES(i,'FUNCTION-Loop循环','杭州9',sha1(8000+i));
      SET i := i+1;
      IF i > 32 THEN 
	    LEAVE loop_name;
      END IF;
    END LOOP loop_name;

    REPEAT
      INSERT INTO sha_table1 VALUES(i,'FUNCTION-Repeat循环','杭州10',sha2(8000+i,224));
      SET i := i+1;
      until i > 34	
    END  REPEAT;
	return a;
END;
//
SELECT COUNT(*) FROM sha_table1;//
+----------+
| COUNT(*) |
+----------+
|       27 |
+----------+
