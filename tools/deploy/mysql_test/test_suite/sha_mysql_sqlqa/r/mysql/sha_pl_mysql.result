###  update
UPDATE sha_table1_view SET name = '阿里-update' WHERE sha(name) = sha('阿里');
UPDATE sha_table1_view SET name = '阿依-update' WHERE sha1(name) = sha1('阿依') ORDER BY sha1(id) DESC;
UPDATE sha_table1_view SET address = (SELECT sha2(style,0) FROM t2_view GROUP BY sha2(style,0),id HAVING id = 1 ORDER BY sha1(id)) WHERE id = 1 ;
SELECT * FROM  sha_table1_view;
+------+---------------+------------------------------------------------------------------+-------+
| id   | name          | address                                                          | sal   |
+------+---------------+------------------------------------------------------------------+-------+
|    1 | 阿里-update   | 864200bbb241e06718231abc10232c338a8277208b746ae02e3bd83e8df72c4d | 15000 |
|    2 | 阿依-update   | 广州                                                             | 8000  |
|    3 | 阿布          | 苏州                                                             | 6000  |
|    4 | 阿珊          | 苏州                                                             | 5000  |
+------+---------------+------------------------------------------------------------------+-------+
###  delete
SELECT * FROM  t2_view ORDER BY sha1(id);
+------+--------+-------+
| id   | style  | price |
+------+--------+-------+
|    1 | 键盘   |   300 |
|    3 | 耳机   |   500 |
|    2 | 鼠标   |   200 |
+------+--------+-------+
DELETE FROM t2_view WHERE sha1(id) = sha1(2) ORDER BY sha1(id) DESC;
SELECT * FROM  t2_view ORDER BY sha1(id);
+------+--------+-------+
| id   | style  | price |
+------+--------+-------+
|    1 | 键盘   |   300 |
|    3 | 耳机   |   500 |
+------+--------+-------+
