##动态sql
DROP PROCEDURE p_sha;//
CREATE PROCEDURE p_sha()
BEGIN
  SET @s = 'INSERT INTO sha_table1 VALUES(?,"动态sql插入的数据","杭州8",?);';
  PREPARE stmsha_table1 FROM @s;
  SET @a = 26;
  SET @b = sha(10000);
  EXECUTE stmsha_table1 USING @a,@b;

  SET @s = 'SELECT id,name,sha(name),addressess,sal FROM sha_table1 WHERE sal = ?';
  PREPARE stmt2 FROM @s;
  SET @a = sha(10000);
  EXECUTE stmt2 USING @a; 
END;
