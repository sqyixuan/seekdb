### 标签：sha-4-3 约束
DROP TABLE sha_table1;
CREATE TABLE sha_table1(
  id int PRIMARY KEY,
  name char(200) UNIQUE, 
  grade varchar(200) NOT NULL,
  ranks varchar(200)
);
INSERT INTO sha_table1 VALUES(1,'楠楠','100','1');
INSERT INTO sha_table1 VALUES(2,'看看','90','3');
INSERT INTO sha_table1 VALUES(3,'青青','95','2');
INSERT INTO sha_table1 VALUES(4,'慧慧','88','4');
#insert 
INSERT INTO sha_table1 VALUES(5,'洋洋',sha('100'),sha2('1',0));
