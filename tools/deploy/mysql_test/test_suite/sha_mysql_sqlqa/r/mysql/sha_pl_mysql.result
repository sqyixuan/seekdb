### 标签：sha-3-2 函数      
#定义一个无参的函数
drop function f_sha;//
CREATE FUNCTION f_sha() returns varchar(200) READS SQL DATA 
begin
	declare a varchar(200);
	SELECT sha(sal) into a FROM sha_table1 WHERE sha1(id) = sha1(4);
	return a;
END;
