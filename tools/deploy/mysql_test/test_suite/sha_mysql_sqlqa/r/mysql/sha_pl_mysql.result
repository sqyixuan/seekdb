##WHERE 子句
SELECT e.id,e.name,sha(e.name) FROM sha_table1_view e WHERE sha(e.name) like '%6590ec%';
+------+--------+------------------------------------------+
| id   | name   | sha(e.name)                              |
+------+--------+------------------------------------------+
|    1 | 阿里   | 6590ec95970ed3bef369b239b44ce608889f17b5 |
+------+--------+------------------------------------------+
SELECT e.id,e.name,sha1(e.name) FROM sha_table1_view e WHERE sha1(e.name) like '%f4b7ea%';
+------+--------+------------------------------------------+
| id   | name   | sha1(e.name)                             |
+------+--------+------------------------------------------+
|    2 | 阿依   | f4b7ea6fd2116531aa725a6e36d5752ae3ed7daf |
+------+--------+------------------------------------------+
SELECT e.id,e.name,sha(e.name) FROM sha_table1_view e WHERE sha(e.name) > sha('阿布') ORDER BY e.id;
+------+--------+------------------------------------------+
| id   | name   | sha(e.name)                              |
+------+--------+------------------------------------------+
|    2 | 阿依   | f4b7ea6fd2116531aa725a6e36d5752ae3ed7daf |
+------+--------+------------------------------------------+
SELECT e.id,e.name,sha1(e.name) FROM sha_table1_view e WHERE sha1(e.name) < sha1('阿布') ORDER BY e.id;
+------+--------+------------------------------------------+
| id   | name   | sha1(e.name)                             |
+------+--------+------------------------------------------+
|    1 | 阿里   | 6590ec95970ed3bef369b239b44ce608889f17b5 |
|    4 | 阿珊   | 57b7fa2df7239a2f1468a2720c4be5e9c3a4b913 |
+------+--------+------------------------------------------+
SELECT e.id,e.name,sha2(e.name,0) FROM sha_table1_view e WHERE sha2(e.name,0) = sha2('阿布',0) ORDER BY e.id;
+------+--------+------------------------------------------------------------------+
| id   | name   | sha2(e.name,0)                                                   |
+------+--------+------------------------------------------------------------------+
|    3 | 阿布   | 4760eef88a5334c94fa67a33746dd3c31dbf4d2f729813d4903bf9b9cc814ed9 |
+------+--------+------------------------------------------------------------------+
##order by 子句
SELECT e.id,sha(e.id) FROM sha_table1_view e WHERE sha(e.name) < sha('阿布') ORDER BY sha(e.id);
+------+------------------------------------------+
| id   | sha(e.id)                                |
+------+------------------------------------------+
|    4 | 1b6453892473a467d07372d45eb05abc2031647a |
|    1 | 356a192b7913b04c54574d18c28d46e6395428ab |
+------+------------------------------------------+
SELECT e.id,sha(e.id) FROM sha_table1_view e WHERE sha(e.name) < sha('阿布') ORDER BY sha(e.id) DESC;
+------+------------------------------------------+
| id   | sha(e.id)                                |
+------+------------------------------------------+
|    1 | 356a192b7913b04c54574d18c28d46e6395428ab |
|    4 | 1b6453892473a467d07372d45eb05abc2031647a |
+------+------------------------------------------+
SELECT e.id,sha1(e.id) FROM sha_table1_view e WHERE sha1(e.name) < sha1('阿布') ORDER BY sha1(e.id) ;
+------+------------------------------------------+
| id   | sha1(e.id)                               |
+------+------------------------------------------+
|    4 | 1b6453892473a467d07372d45eb05abc2031647a |
|    1 | 356a192b7913b04c54574d18c28d46e6395428ab |
+------+------------------------------------------+
SELECT e.id,sha2(e.id,0) FROM sha_table1_view e WHERE sha2(e.name,0) > sha2('阿布',0) ORDER BY sha2(e.id,0) DESC;
+------+------------------------------------------------------------------+
| id   | sha2(e.id,0)                                                     |
+------+------------------------------------------------------------------+
|    2 | d4735e3a265e16eee03f59718b9b5d03019c07d8b6c51f90da3a666eec13ab35 |
|    4 | 4b227777d4dd1fc61c6f884f48641d02b4d121d3fd328cb08b5531fcacdabf8a |
+------+------------------------------------------------------------------+
##group by having 子句
SELECT e.id,e.address,sha(e.address) FROM sha_table1_view e LEFT JOIN t2_view p ON e.id = p.id GROUP BY sha(e.address),e.id ORDER BY e.id ;
+------+---------+------------------------------------------+
| id   | address | sha(e.address)                           |
+------+---------+------------------------------------------+
|    1 | 杭州    | c2d2d67e9afbca8ad8f4a7ae1dd8b782683cd438 |
|    2 | 广州    | d03d2f65a5ab57980517c9579251f710a4e4c18a |
|    3 | 苏州    | 855f21547c2192ca266a39ff717eb768366f7976 |
|    4 | 苏州    | 855f21547c2192ca266a39ff717eb768366f7976 |
+------+---------+------------------------------------------+
SELECT e.id,e.address,sha1(e.address) FROM sha_table1_view e LEFT JOIN t2_view p ON e.id = p.id GROUP BY sha1(e.address),e.id HAVING SUM(sha1(e.address)) > 0 ORDER BY e.id;
+------+---------+------------------------------------------+
| id   | address | sha1(e.address)                          |
+------+---------+------------------------------------------+
|    3 | 苏州    | 855f21547c2192ca266a39ff717eb768366f7976 |
|    4 | 苏州    | 855f21547c2192ca266a39ff717eb768366f7976 |
+------+---------+------------------------------------------+
