-----------------------------------------------------------------------------------------------------------------
------------------------- 加密函数-sha(str)/sha1(str), sha2(str, hash_length) 视图，索引，约束 ------------------
### 用例：sha-4  sha(str)/sha1(str)/sha2(str) - 视图，索引，约束
-----------------------------------------------------------------------------------------------------------------
#################################################################################
### 表，视图创建
DROP TABLE sha_table1;
CREATE TABLE sha_table1(id int,name varchar(200), address varchar(200),sal varchar(200));
INSERT INTO sha_table1 VALUES(1,'阿里','杭州','15000');
INSERT INTO sha_table1 VALUES(2,'阿依','广州','8000');
INSERT INTO sha_table1 VALUES(3,'阿布','苏州','6000');
INSERT INTO sha_table1 VALUES(4,'阿珊','苏州','5000');
DROP TABLE sha_table2;
CREATE TABLE sha_table2(id int,style varchar(200),price int);
INSERT INTO sha_table2 VALUES(1,'键盘',300);
INSERT INTO sha_table2 VALUES(2,'鼠标',200);
INSERT INTO sha_table2 VALUES(3,'耳机',500);
DROP TABLE sha_table4;
CREATE TABLE sha_table4(id int,c1 varchar(200),c2 varchar(200),c3 varchar(200));
DROP VIEW sha_table1_view;
CREATE VIEW sha_table1_view AS SELECT * FROM sha_table1 WHERE sha(id) >= sha(4);
DROP VIEW t2_view;
CREATE VIEW t2_view AS SELECT * FROM sha_table2 WHERE sha(id) like '%A%';
DROP TABLE t3_view;
SELECT * FROM sha_table1_view ORDER BY id;
+------+--------+---------+-------+
| id   | name   | address | sal   |
+------+--------+---------+-------+
|    1 | 阿里   | 杭州    | 15000 |
|    2 | 阿依   | 广州    | 8000  |
|    3 | 阿布   | 苏州    | 6000  |
|    4 | 阿珊   | 苏州    | 5000  |
+------+--------+---------+-------+
SELECT * FROM t2_view ORDER BY id;
+------+--------+-------+
| id   | style  | price |
+------+--------+-------+
|    1 | 键盘   |   300 |
|    2 | 鼠标   |   200 |
|    3 | 耳机   |   500 |
+------+--------+-------+
#################################################################################
### 标签：sha-4-1 视图
### SELECT
##多列/单列
