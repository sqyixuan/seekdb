##包含inout参数的存储过程
DROP PROCEDURE p_sha;//
CREATE  PROCEDURE p_sha(OUT outa varchar(200),OUT outb varchar(200),INOUT inoutc varchar(200))
begin
    declare invalue varchar(200);
    declare i int default 14;
	set invalue := inoutc;
	SELECT sha(sal),sha1(sal),sha2(sal,224) into outa,outb,inoutc FROM sha_table1 WHERE sha2(id,0) = invalue;
	WHILE i <= 16 do
	  INSERT INTO sha_table1 VALUES(i,'不易4','杭州4',sha2(6000+i,224));
	  set i := i+1;
	END WHILE;
END;
//
SELECT COUNT(*) FROM sha_table1;//
+----------+
| COUNT(*) |
+----------+
|       14 |
+----------+
SET @inoutc := sha2(3,0);//
CALL p_sha(@outa,@outb,@inoutc);//
