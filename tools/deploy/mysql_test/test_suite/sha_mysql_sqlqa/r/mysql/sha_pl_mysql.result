##dml语句
#条件语句
DROP PROCEDURE p_sha;//
CREATE PROCEDURE p_sha(IN invalue varchar(200),IN ina varchar(200),IN inb varchar(200),IN inc varchar(200))
begin
    IF invalue = sha1('sha_table1') THEN 
	   INSERT INTO sha_table1 VALUES(17,'PROCEDURE-If条件','杭州5',sha2(ina+inb+inc,512));
    ELSE 
	   INSERT INTO sha_table2 VALUES(3,sha(ina),sha1(inb),sha2(inb,512));
    END IF;
END;
//
SELECT COUNT(*) FROM sha_table1;//
+----------+
| COUNT(*) |
+----------+
|       17 |
+----------+
SELECT COUNT(*) FROM sha_table2;//
+----------+
| COUNT(*) |
+----------+
|        2 |
+----------+
SET @invalue := sha1('sha_table1');//
SET @ina := '1';//
SET @inb := '2';//
SET @inc := '3';//
CALL p_sha(@invalue,@ina,@inb,@inc);//
SELECT id,name,addressess,sal FROM sha_table1 ORDER BY id;//
