+------------------------------------------+
| f8237d8959e03355010bb85cc3dc46a46fb31110 |
+------------------------------------------+
#定义一个有参的函数
DROP FUNCTION f_sha;//
CREATE FUNCTION f_sha(invalue varchar(200)) returns  varchar(200) READS SQL DATA 
begin
	declare a varchar(200);
	SELECT sha1(sal) into a FROM sha_table1 WHERE sha1(id) = invalue;
	return a;
END ;
//
SELECT f_sha(sha1(3));//
+------------------------------------------+
| f_sha(sha1(3))                           |
+------------------------------------------+
| 31d9ddeaa80bc88c1f3117b9724726ebcc7fc72d |
+------------------------------------------+
##dml语句
#条件语句
DROP FUNCTION f_sha;//
CREATE FUNCTION f_sha(invalue varchar(200),ina varchar(200),inb varchar(200),inc varchar(200))returns varchar(200) DETERMINISTIC
begin
    IF invalue = sha('sha_table1') THEN 
	   INSERT INTO sha_table1 VALUES(26,'FUNCTION-If条件','杭州7',sha2(ina+inb+inc,512));
    ELSE 
	   INSERT INTO sha_table2 VALUES(4,sha(ina),sha1(inb),sha2(inb,512));
    END IF;
    return sha2(ina+inb+inc,512);
END;
//
