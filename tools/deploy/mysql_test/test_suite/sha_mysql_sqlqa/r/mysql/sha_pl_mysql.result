#循环语句
DROP PROCEDURE p_sha;//
CREATE PROCEDURE p_sha()
begin
    declare i int default 18;
    WHILE i <= 20 do
      INSERT INTO sha_table1 VALUES(i,'PROCEDURE-While循环','杭州5',sha(6000+i));
      set i := i+1;
    END WHILE;

    loop_name:LOOP
      INSERT INTO sha_table1 VALUES(i,'PROCEDURE-Loop循环','杭州6',sha1(6000+i));
      SET i := i+1;
      IF i > 23 THEN 
	    LEAVE loop_name;
      END IF;
    END LOOP loop_name;

    REPEAT
      INSERT INTO sha_table1 VALUES(i,'PROCEDURE-Repeat循环','杭州7',sha2(8000+i,224));
      SET i := i+1;
      until i > 26	
    END  REPEAT;
END;
//
SELECT COUNT(*) FROM sha_table1;//
+----------+
| COUNT(*) |
+----------+
|       18 |
+----------+
SELECT COUNT(*) FROM sha_table2;//
+----------+
| COUNT(*) |
+----------+
|        3 |
+----------+
CALL p_sha();//
