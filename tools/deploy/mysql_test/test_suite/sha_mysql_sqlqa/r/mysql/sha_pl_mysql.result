#自定义变量，全局变量，in 参数作为sha函数的参数
DROP TABLE sha_table3;//
CREATE TABLE sha_table3(id int,c1 varchar(200), c2 varchar(200),c3 varchar(200),c4 varchar(200));//
DROP PROCEDURE p_sha;//
CREATE PROCEDURE p_sha(IN ina varchar(200),IN inb varchar(200),IN inc varchar(200))
begin
  declare a varchar(200) default '1';
  declare b varchar(200) default '2';
  declare c varchar(200) default '3';
  INSERT INTO sha_table3 VALUES(1,'自定义变量',sha(a),sha1(b),sha2(c,0));
  INSERT INTO sha_table3 VALUES(2,'全局变量',sha(@mya),sha1(@myb),sha2(@myc,0));
  INSERT INTO sha_table3 VALUES(3,'参数变量',sha(ina),sha1(inb),sha2(inc,0));
END;
//
SET @mya := '1';//
SET @myb := '2';//
SET @myc := '3';//
CALL p_sha('1','2','3');//
SELECT * FROM sha_table3 ORDER BY id;//
