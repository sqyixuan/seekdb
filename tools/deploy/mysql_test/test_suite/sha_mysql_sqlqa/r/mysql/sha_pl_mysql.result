purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


-----------------------------------------------------------------------------------------------------------------
------------------------- 加密函数-sha(str)/sha1(str), sha2(str, hash_length) pl/sql ----------------------------
### 用例：sha-3  sha(str)/sha1(str)/sha2(str) - pl/sql
-----------------------------------------------------------------------------------------------------------------
DROP TABLE sha_table1;//
CREATE TABLE sha_table1(id int,name varchar(200), addressess varchar(200),sal varchar(200));//
INSERT INTO sha_table1 VALUES(1,'不一','杭州','15000');//
INSERT INTO sha_table1 VALUES(2,'不二','苏州','8000');//
INSERT INTO sha_table1 VALUES(3,'不三','洛阳','6000');//
INSERT INTO sha_table1 VALUES(4,'不四','濮阳','5000');//
DROP TABLE sha_table2;//
CREATE TABLE sha_table2(id int,sal_sha varchar(200), sal_sha1 varchar(200),sal_sha2 varchar(200));//
### 标签：sha-3-1 存储过程
##无参数的存储过程
DROP PROCEDURE p_sha;//
CREATE PROCEDURE p_sha()
begin
	declare a varchar(200);
	declare b varchar(200);
	declare c varchar(200);
	declare i int default 5;
	SELECT sha(sal),sha1(sal),sha2(sal,224) into a,b,c FROM sha_table1 WHERE sha(id) = sha(1);
    INSERT INTO sha_table2 VALUES(1,a,b,c);
	WHILE i <= 7 do
	  INSERT INTO sha_table1 VALUES(i,'不易1','杭州1',sha(9000+i));
	  SET i := i + 1;
	END while;
END;
//
SELECT COUNT(*) FROM sha_table1;//
+----------+
| COUNT(*) |
+----------+
|        4 |
+----------+
SELECT COUNT(*) FROM sha_table2;//
+----------+
| COUNT(*) |
+----------+
|        0 |
+----------+
CALL p_sha();//
SELECT id,name,addressess,sal FROM sha_table1 ORDER BY id;//
+------+---------+------------+------------------------------------------+
| id   | name    | addressess | sal                                      |
+------+---------+------------+------------------------------------------+
|    1 | 不一    | 杭州       | 15000                                    |
|    2 | 不二    | 苏州       | 8000                                     |
|    3 | 不三    | 洛阳       | 6000                                     |
|    4 | 不四    | 濮阳       | 5000                                     |
|    5 | 不易1   | 杭州1      | c4528b12c0581e2d63285f369dd6eb97a1dc4364 |
|    6 | 不易1   | 杭州1      | 9131555c6f4b67152897a8fc66b7bcd2de2e5891 |
|    7 | 不易1   | 杭州1      | 5fa0f837dcfe808e7f8a5c22c8549588ea868c44 |
+------+---------+------------+------------------------------------------+
SELECT id,sal_sha,sal_sha1,sal_sha2 FROM sha_table2 ORDER BY id;//
+------+------------------------------------------+------------------------------------------+----------------------------------------------------------+
| id   | sal_sha                                  | sal_sha1                                 | sal_sha2                                                 |
+------+------------------------------------------+------------------------------------------+----------------------------------------------------------+
|    1 | 271593a69439c052d4de63e50c569060dcd78e91 | 271593a69439c052d4de63e50c569060dcd78e91 | 00874d5a05f6bc2112ebf308bd11671b46bb4715d9fd90295bc3fc59 |
+------+------------------------------------------+------------------------------------------+----------------------------------------------------------+
##只有一个in参数的存储过程
DROP PROCEDURE p_sha;//
CREATE PROCEDURE p_sha(in invalue varchar(200))
begin
	declare a varchar(200);
	declare b varchar(200);
	declare c varchar(200);
    declare i int default 8;
	SELECT sha(sal),sha1(sal),sha2(sal,224) into a,b,c FROM sha_table1 WHERE sha1(id) = invalue;
	INSERT INTO sha_table2 VALUES(2,a,b,c);
   	REPEAT
	  INSERT INTO sha_table1 VALUES(i,'不易2','杭州2',sha1(8000+i));
	  SET i := i+1;
	until i > 11	
	END  REPEAT;
END;
//
SELECT COUNT(*) FROM sha_table1;//
+----------+
| COUNT(*) |
+----------+
|        7 |
+----------+
SELECT COUNT(*) FROM sha_table2;//
+----------+
| COUNT(*) |
+----------+
|        1 |
+----------+
CALL p_sha(sha1(2));//
SELECT id,name,addressess,sal FROM sha_table1 ORDER BY id;//
+------+---------+------------+------------------------------------------+
| id   | name    | addressess | sal                                      |
+------+---------+------------+------------------------------------------+
|    1 | 不一    | 杭州       | 15000                                    |
|    2 | 不二    | 苏州       | 8000                                     |
|    3 | 不三    | 洛阳       | 6000                                     |
|    4 | 不四    | 濮阳       | 5000                                     |
|    5 | 不易1   | 杭州1      | c4528b12c0581e2d63285f369dd6eb97a1dc4364 |
|    6 | 不易1   | 杭州1      | 9131555c6f4b67152897a8fc66b7bcd2de2e5891 |
|    7 | 不易1   | 杭州1      | 5fa0f837dcfe808e7f8a5c22c8549588ea868c44 |
|    8 | 不易2   | 杭州2      | 84304dedd765b959d054ed4333448d60ad5e6b8e |
|    9 | 不易2   | 杭州2      | 27529aa462f33715b44be8935c3887a4825fe289 |
|   10 | 不易2   | 杭州2      | d239a9839404faf538e085739173bad0a2b9bda6 |
|   11 | 不易2   | 杭州2      | 982906af37623afd726ed6eac797c1030e3c00d1 |
