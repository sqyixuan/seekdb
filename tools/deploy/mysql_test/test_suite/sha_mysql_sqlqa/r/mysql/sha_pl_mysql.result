##包含out参数的存储过程
DROP PROCEDURE p_sha;//
CREATE  PROCEDURE p_sha(out outa varchar(200),OUT outb varchar(200),OUT outc varchar(200))
begin
    declare i int default 11;
	SELECT sha(sal),sha1(sal),sha2(sal,224) into outa,outb,outc FROM sha_table1 WHERE sha1(id) like '%3BABBB%';
	WHILE i <= 13 do
	   INSERT INTO sha_table1 VALUES(i,'不易3','杭州3',sha2(7000+i,0));
	SET i := i + 1;
	END WHILE;
END;
//
SELECT COUNT(*) FROM sha_table1;//
+----------+
| COUNT(*) |
+----------+
|       11 |
+----------+
CALL p_sha(@outa,@outb,@outc);//
SELECT id,name,addressess,sal FROM sha_table1 ORDER BY id;//
