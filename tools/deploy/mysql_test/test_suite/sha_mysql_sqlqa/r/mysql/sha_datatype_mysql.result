### 标签：sha-1-1，sha-1-2  sha(str)/sha1(str), sha2(str, hash_length)
## 参数 - 参数类型 - 字符串类型
DROP TABLE sha_table1;
CREATE TABLE sha_table1( 
  c1 CHAR(10), 
  c2 VARCHAR(100), 
  c3 BLOB(100), 
  c4 TEXT, 
  c5 BINARY(100),
  c6 VARBINARY(100), 
  c7 ENUM('星期一', '星期二', '星期三', '星期四', '星期五', '星期六'), 
  c8 SET('a', 'b', 'c', 'd', 'e')
)default character set = 'utf8mb4';
insert into sha_table1 values('char-类型','VARCHAR-类型',0x01020304FFFFFFFF0000000CAACB0000,'TEXT-类型','BINARY-类型','VARBINARY-类型','星期一','a,b,c');
select sha(c1),sha1(c1) from sha_table1;
