------------------------- 加密函数-sha(str), sha1(str), sha2(str, hash_length) ----------------------------------
### 用例：sha(str)/sha1(str)/sha2(str, hash_length) - 参数 - 参数类型，字符集
-----------------------------------------------------------------------------------------------------------------
### 标签：sha-1-1，sha-1-2  sha(str)/sha1(str), sha2(str, hash_length)
## 参数 - 参数类型 - 数值类型
DROP TABLE sha_table1;
CREATE TABLE sha_table1( 
  c1 tinyint, 
  c2 smallint,
  c3 mediumint, 
  c4 int, 
  c5 bigint, 
  c6 float, 
  c7 double, 
  c8 DECIMAL(5,2), 
  c9 bit(10)
);
insert into sha_table1 values(127,32767,8388607,2147483647,12345678912345678,1.1111,123.1231123,1.1,b'1000001');
select sha(c1),sha1(c1) from sha_table1;
