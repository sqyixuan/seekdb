purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


-----------------------------------------------------------------------------------------------------------------
------------------------- 加密函数-sha(str)/sha1(str), sha2(str, hash_length) -----------------------------------
### 用例：sha-1 sha(str)/sha1(str)/sha2(str) - 参数 - 参数个数
-----------------------------------------------------------------------------------------------------------------
### 标签：sha-1-1  sha(str)/sha1(str)
## 参数 - 参数个数-0个参数
select sha() from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'sha'
select sha1() from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'sha1'
## 参数 - 参数个数-1个参数
select sha(null),sha1(null) from dual;
+-----------+------------+
| sha(null) | sha1(null) |
+-----------+------------+
| NULL      | NULL       |
+-----------+------------+
select sha('null'),sha1('null') from dual;
+------------------------------------------+------------------------------------------+
| sha('null')                              | sha1('null')                             |
+------------------------------------------+------------------------------------------+
| 2be88ca4242c76e8253ac62474851065032d6833 | 2be88ca4242c76e8253ac62474851065032d6833 |
+------------------------------------------+------------------------------------------+
select sha('Null'),sha1('Null') from dual;
+------------------------------------------+------------------------------------------+
| sha('Null')                              | sha1('Null')                             |
+------------------------------------------+------------------------------------------+
| 109085beaaa80ac89858b283a64f7c75d7e5bb12 | 109085beaaa80ac89858b283a64f7c75d7e5bb12 |
+------------------------------------------+------------------------------------------+
