### 标签：sha-2-2 insert
INSERT INTO sha_table4 SELECT id,sha(name),sha1(name),sha2(name,0) FROM sha_table1 WHERE sha(name) LIKE '6590ec%';
INSERT INTO sha_table4 SELECT id,sha(name),sha1(name),sha2(name,256) FROM sha_table1 WHERE sha1(name) > sha1('阿布') ORDER BY sha1(id) DESC;
INSERT INTO sha_table4 SELECT id,sha(name),sha1(name),sha2(name,224) FROM sha_table1 WHERE sha2(name,0) > sha2('阿布',0) GROUP BY sha2(name,0),id HAVING id > 2 ;
SELECT * FROM  sha_table4;
+------+------------------------------------------+------------------------------------------+------------------------------------------------------------------+
| id   | c1                                       | c2                                       | c3                                                               |
+------+------------------------------------------+------------------------------------------+------------------------------------------------------------------+
|    1 | 6590ec95970ed3bef369b239b44ce608889f17b5 | 6590ec95970ed3bef369b239b44ce608889f17b5 | 1d99cc69a8ba22eb7d7175853076fe9dcebfa8b97bb915b7df1f4f976c4ccaa3 |
|    2 | f4b7ea6fd2116531aa725a6e36d5752ae3ed7daf | f4b7ea6fd2116531aa725a6e36d5752ae3ed7daf | e0ca09be4491800241ee221d403fa19010e476cf906f956f85b9a6921d0b21fd |
|    4 | 57b7fa2df7239a2f1468a2720c4be5e9c3a4b913 | 57b7fa2df7239a2f1468a2720c4be5e9c3a4b913 | 766d9ff91d90860b39282020aebe0f251d0bb02073325f98c0e1a2dc         |
+------+------------------------------------------+------------------------------------------+------------------------------------------------------------------+
### 标签：sha-2-3 update
UPDATE sha_table1 SET name = '阿里-update' WHERE sha(name) = sha('阿里');
UPDATE sha_table1 SET name = '阿依-update' WHERE sha1(name) = sha1('阿依') ORDER BY sha1(id) DESC;
UPDATE sha_table1 SET address = (SELECT sha2(style,0) FROM sha_table2 GROUP BY sha2(style,0),id HAVING id = 1 ORDER BY sha1(id)) WHERE id = 1 ;
SELECT * FROM  sha_table1;
+----+---------------+------------------------------------------------------------------+------+
| id | name          | address                                                          | sal  |
+----+---------------+------------------------------------------------------------------+------+
|  1 | 阿里-update   | 864200bbb241e06718231abc10232c338a8277208b746ae02e3bd83e8df72c4d | 8000 |
|  2 | 阿依-update   | 广州                                                             | 7000 |
|  3 | 阿布          | 苏州                                                             | 6000 |
|  4 | 阿珊          | 苏州                                                             | 5000 |
+----+---------------+------------------------------------------------------------------+------+
### 标签：sha-2-4 delete
SELECT * FROM  sha_table2;
+------+--------+-------+
| id   | style  | price |
+------+--------+-------+
|    1 | 键盘   |   300 |
|    2 | 鼠标   |   200 |
|    3 | 耳机   |   500 |
+------+--------+-------+
DELETE FROM sha_table2 WHERE sha1(id) = sha1(2) ORDER BY sha1(id) DESC;
SELECT * FROM  sha_table2;
+------+--------+-------+
| id   | style  | price |
+------+--------+-------+
|    1 | 键盘   |   300 |
|    3 | 耳机   |   500 |
+------+--------+-------+
### 标签：sha-2-5 replace   
replace into sha_table1 values(5,sha('冰墩墩replace1'),sha1('冰墩墩replace1'),5000);
select * from sha_table1 where id = 5;
+----+------------------------------------------+------------------------------------------+------+
| id | name                                     | address                                  | sal  |
+----+------------------------------------------+------------------------------------------+------+
|  5 | 27f93cdcf64a1707a8accb421be1457cfcfaf108 | 27f93cdcf64a1707a8accb421be1457cfcfaf108 | 5000 |
+----+------------------------------------------+------------------------------------------+------+
replace into sha_table1 values(5,sha2('冰墩墩replace2',224),sha2('冰墩墩replace2',256),6000);
select * from sha_table1 where id = 5;
+----+----------------------------------------------------------+------------------------------------------------------------------+------+
| id | name                                                     | address                                                          | sal  |
+----+----------------------------------------------------------+------------------------------------------------------------------+------+
|  5 | c8ab59341bdb6dc2aa3c9886e4efe58a7a9791345ebe3f49ad53e060 | fadb6916dd30a626b6ae5542a7cdbca59ba4e2755e96efd89085514f81b07d31 | 6000 |
+----+----------------------------------------------------------+------------------------------------------------------------------+------+
-----------------------------------------------------------------------------------------------------------------
------------------------- 加密函数-sha(str)/sha1(str), sha2(str, hash_length) 运算符 ----------------------------
### 用例：sha-5  sha(str)/sha1(str)/sha2(str) - 运算符
-----------------------------------------------------------------------------------------------------------------
### 标签：sha-5-1 算术运算符
SELECT id , sal, sha(sal + 10 - 5 * 3 / 2),sha1(sal + 10 - 5 * 3 / 2),sha2(sal + 10 - 5 * 3 / 2,0) FROM sha_table1 ORDER BY id;
+----+------+------------------------------------------+------------------------------------------+------------------------------------------------------------------+
| id | sal  | sha(sal + 10 - 5 * 3 / 2)                | sha1(sal + 10 - 5 * 3 / 2)               | sha2(sal + 10 - 5 * 3 / 2,0)                                     |
+----+------+------------------------------------------+------------------------------------------+------------------------------------------------------------------+
|  1 | 8000 | 57bbf0ddd92e4d60d828138ca7acdbf7e8d62c80 | 57bbf0ddd92e4d60d828138ca7acdbf7e8d62c80 | 55bc14365cf03711208e58e72035bc1fa14daa461c0783f95866198d281b88c8 |
|  2 | 7000 | 43e1be2925b93c782656b50a069d5480237edd92 | 43e1be2925b93c782656b50a069d5480237edd92 | 29bc0cdb3a9395a4aa7886dd8b9c02d99ec766fe6e8d9de1b05d68fc8d6401a9 |
|  3 | 6000 | fc77ab446879a3457722d19f93530c8c8891376e | fc77ab446879a3457722d19f93530c8c8891376e | dc1b98144b2c05f40e6e03bfddb7493e19a256329c0ae08e46012fda2b81c883 |
|  4 | 5000 | 820f2407ac55f8c2ac04dd8745cf8ed823cb91a8 | 820f2407ac55f8c2ac04dd8745cf8ed823cb91a8 | f9689bed3f68ee11bd03533b4aea39b0dea00bc352dae4e9318bbb4377e35891 |
|  5 | 6000 | fc77ab446879a3457722d19f93530c8c8891376e | fc77ab446879a3457722d19f93530c8c8891376e | dc1b98144b2c05f40e6e03bfddb7493e19a256329c0ae08e46012fda2b81c883 |
+----+------+------------------------------------------+------------------------------------------+------------------------------------------------------------------+
SELECT id , sal, sha(sal) + sha(sal), sha1(sal) - sha1(sal), sha2(sal,0) * sha2(sal,0), sha1(sal) / sha1(sal) FROM sha_table1;
+----+------+---------------------+-----------------------+---------------------------+-----------------------+
| id | sal  | sha(sal) + sha(sal) | sha1(sal) - sha1(sal) | sha2(sal,0) * sha2(sal,0) | sha1(sal) / sha1(sal) |
+----+------+---------------------+-----------------------+---------------------------+-----------------------+
|  1 | 8000 |                   4 |                     0 |                         0 |                     1 |
|  2 | 7000 |                   0 |                     0 |                         0 |                  NULL |
|  3 | 6000 |                  62 |                     0 |                        64 |                     1 |
|  4 | 5000 |                   0 |                     0 |                         0 |                  NULL |
|  5 | 6000 |                  62 |                     0 |                        64 |                     1 |
+----+------+---------------------+-----------------------+---------------------------+-----------------------+
SELECT id , sal,sha(sal) MOD (sha1(sal)-2),sha2(sal,0) DIV sha(sal)  FROM sha_table1;
+----+------+----------------------------+--------------------------+
| id | sal  | sha(sal) MOD (sha1(sal)-2) | sha2(sal,0) DIV sha(sal) |
+----+------+----------------------------+--------------------------+
|  1 | 8000 |                       NULL |                        0 |
|  2 | 7000 |                          0 |                     NULL |
|  3 | 6000 |                          2 |                        0 |
|  4 | 5000 |                          0 |                     NULL |
|  5 | 6000 |                          2 |                        0 |
+----+------+----------------------------+--------------------------+
