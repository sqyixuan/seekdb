##select嵌套
#SELECT
select sha(e.id),sha(e.name),sha1(e.address),sha2(e.sal,0) from (select id,name,address,sal from sha_table1 WHERE id =1) e;
+------------------------------------------+------------------------------------------+------------------------------------------+------------------------------------------------------------------+
| sha(e.id)                                | sha(e.name)                              | sha1(e.address)                          | sha2(e.sal,0)                                                    |
