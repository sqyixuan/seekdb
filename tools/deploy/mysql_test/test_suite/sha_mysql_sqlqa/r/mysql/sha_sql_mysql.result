| 104ea37dcef1c0648d875bb54d423412b845f34fe78d07d3bfe5ef1897325b04315ba764136ae92309aacb6ef5953cdd | 广州    |
| 87b119ad8420c5d2d2bfe8f2603889d786ef8fcca268e7292d173ede57604531092c3b433da1c89b3e3076e772424d11 | 苏州    |
+--------------------------------------------------------------------------------------------------+---------+
#CASE WHEN
SELECT e.id,e.name,e.sal,sha(CASE WHEN e.sal < 6000 THEN NULL ELSE e.sal END) sal2 FROM sha_table1 e ORDER BY e.id;
+----+--------+------+------------------------------------------+
| id | name   | sal  | sal2                                     |
+----+--------+------+------------------------------------------+
|  1 | 阿里   | 8000 | 2de49ac0fce223dbdd31d2b8b3b3710582ef1535 |
|  2 | 阿依   | 7000 | b7525fa5653c5b45f75d490825626e0880b394f4 |
|  3 | 阿布   | 6000 | 31d9ddeaa80bc88c1f3117b9724726ebcc7fc72d |
|  4 | 阿珊   | 5000 | NULL                                     |
+----+--------+------+------------------------------------------+
SELECT e.id,e.name,e.sal,CASE sha(e.sal) WHEN sha(5000) THEN '工资低' WHEN sha(6000) THEN '工资一般' ELSE '工资高' END ranks FROM sha_table1 e ORDER BY e.id;
+----+--------+------+--------------+
| id | name   | sal  | ranks        |
+----+--------+------+--------------+
|  1 | 阿里   | 8000 | 工资高       |
|  2 | 阿依   | 7000 | 工资高       |
|  3 | 阿布   | 6000 | 工资一般     |
|  4 | 阿珊   | 5000 | 工资低       |
+----+--------+------+--------------+
SELECT e.id,e.name,e.sal,(CASE sha(e.sal) WHEN sha(5000) THEN '工资低' WHEN sha(6000) THEN '工资一般' ELSE '工资高' END) ranks FROM sha_table1 e GROUP BY (CASE sha(e.sal) WHEN sha(5000) THEN '工资低' WHEN sha(6000) THEN '工资一般' ELSE '工资高' END),e.id ORDER BY e.id ;
+----+--------+------+--------------+
| id | name   | sal  | ranks        |
+----+--------+------+--------------+
|  1 | 阿里   | 8000 | 工资高       |
|  2 | 阿依   | 7000 | 工资高       |
|  3 | 阿布   | 6000 | 工资一般     |
|  4 | 阿珊   | 5000 | 工资低       |
+----+--------+------+--------------+
