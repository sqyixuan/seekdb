CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_uniform_T1 ON lyq_test_uniform(c1);
select /*+ index (t1 INDEX_lyq_test_uniform_T1) */ t1.c1 from lyq_test_uniform t1 where c1 < 8 order by c1;
