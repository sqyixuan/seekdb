create-1-6 全局分区索引
DROP INDEX INDEX_lyq_test_uniform_T6 ON lyq_test_uniform;
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_uniform_T6 ON lyq_test_uniform(c1)
GLOBAL   PARTITION BY RANGE (c1)(
PARTITION less_3 VALUES less than (2),
PARTITION b_3_8 VALUES less than (5),
PARTITION b_8_2000 VALUES less than (2000),
PARTITION greater_2000 VALUES less than MAXVALUE);
select /*+ index (lyq_test_uniform INDEX_lyq_test_uniform_T6) */ c1 from lyq_test_uniform where c2 < 6  order by c1;
DROP TABLE lyq_test_uniform;
DROP PROCEDURE get_uniform;
