purge recyclebin;
因数据量大， 执行结果不写入result
DROP TABLE lyq_test_uniform;
CREATE TABLE lyq_test_uniform(  
c1 int primary key,  
c2 float, 
c3 DECIMAL(5,2) DEFAULT null, 
c4 VARCHAR(100), 
c5 bit(10),
c6 datetime, 
c7 json NOT NULL,
c8 SET('a', 'b', 'c', 'd'),
c9 date,
c10 varchar(100) GENERATED ALWAYS AS(c7) VIRTUAL COMMENT '生成列');
DROP PROCEDURE get_uniform;
CREATE  PROCEDURE get_uniform(in i int)
begin
while i <= 10000 DO
insert into lyq_test_uniform(c1,c2,c3,c4,c5,c6,c7,c8,c9) values(6*(i-1)+0,6*(i-1)+0,2.2,MD5(6*(i-1)+0),b'1000001',
ADDDATE('2018-12-22 22:22:22', 6*(i-1)+0) ,'[{"abs":123},"汉字123！@#$%^&*()_+",[0]]','b,d',ADDDATE('2018-12-22 22:22:22', 6*(i-1)+0));
insert into lyq_test_uniform(c1,c2,c3,c4,c5,c6,c7,c8,c9) values(6*(i-1)+1,6*(i-1)+1,3.2,MD5(6*(i-1)+1),b'01',
ADDDATE('2018-12-22 22:22:22', 6*(i-1)+1),'[{"abs":123},"汉字123！@#$%^&*()_+"]','b',ADDDATE('2018-12-22 22:22:22', 6*(i-1)+1));
insert into lyq_test_uniform(c1,c2,c3,c4,c5,c6,c7,c8,c9) values(6*(i-1)+2,6*(i-1)+2,4.2,MD5(6*(i-1)+2),b'100001',
ADDDATE('2018-12-22 22:22:22', 6*(i-1)+2),'[{"abs":123},"汉字123！@#$%^&*()_+",[2]]','d',ADDDATE('2018-12-22 22:22:22', 6*(i-1)+2));
insert into lyq_test_uniform(c1,c2,c3,c4,c5,c6,c7,c8,c9) values(6*(i-1)+3,6*(i-1)+3,5.2,MD5(6*(i-1)+3),b'10001',
ADDDATE('2018-12-22 22:22:22', 6*(i-1)+3),'[{"abs":123},"汉字123！@#$%^&*()_+",[4]]','b,d,a',ADDDATE('2018-12-22 22:22:22', 6*(i-1)+3));
insert into lyq_test_uniform(c1,c2,c3,c4,c5,c6,c7,c8,c9) values(6*(i-1)+4,6*(i-1)+4,6.2,MD5(6*(i-1)+4),b'10001',
ADDDATE('2018-12-22 22:22:22', 6*(i-1)+4),'[{"abs":123},"汉字123！@#$%^&*()_+",[6]]','b,d,c',ADDDATE('2018-12-22 22:22:22', 6*(i-1)+4));
insert into lyq_test_uniform(c1,c2,c3,c4,c5,c6,c7,c8,c9) values(6*(i-1)+5,6*(i-1)+5,7.2,MD5(6*(i-1)+5),b'1001',
ADDDATE('2018-12-22 22:22:22', 6*(i-1)+5),'[{"abs":123},"汉字123！@#$%^&*()_+",[8]]','b,d,a,c',ADDDATE('2018-12-22 22:22:22', 6*(i-1)+5));
set i = i + 1;
end WHILE;
end;
//
call get_uniform(1);
create-1-1 普通索引
