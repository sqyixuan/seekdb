result_format: 4
create-1 单分区表 + 约束 + 索引
DROP TABLE lyq_test;
CREATE TABLE lyq_test(  
  c1 int primary key,  
  c2 float unique, 
  c3 DECIMAL(5,2) DEFAULT null, 
  c4 VARCHAR(100), 
  c5 bit(10),
  c6 datetime, 
  c7 json NOT NULL,
  c8 SET('a', 'b', 'c', 'd'),
  c9 timestamp,
  c10 varchar(100) GENERATED ALWAYS AS(c7) VIRTUAL COMMENT '生成列');
