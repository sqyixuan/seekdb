select /*+ index (t1 INDEX_LYQ_TEST_T1) */ t1.c1 from lyq_test t1 order by t1.c1;

--error 0,1091
DROP INDEX INDEX_LYQ_TEST_T1 ON lyq_test;

CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T1 ON lyq_test(c2);

select /*+ index (t1 INDEX_LYQ_TEST_T1) */ t1.c1,t1.c2 from lyq_test t1 where t1.c2 < 6  order by t1.c1;

