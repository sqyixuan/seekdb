purge recyclebin;

--result_format 4

--echo create-1 单分区表 + 约束 + 索引

--error 0,1051
DROP TABLE lyq_test;
CREATE TABLE lyq_test(  
  c1 int primary key,  
  c2 float unique, 
  c3 DECIMAL(5,2) DEFAULT null, 
  c4 VARCHAR(100), 
  c5 bit(10),
  c6 datetime, 
  c7 json NOT NULL,
  c8 SET('a', 'b', 'c', 'd'),
  c9 timestamp,
  c10 varchar(100) GENERATED ALWAYS AS(c7) VIRTUAL COMMENT '生成列');

--echo create-1-1 普通索引
--error 0,1091
DROP INDEX INDEX_LYQ_TEST_T1 ON lyq_test;

CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T1 ON lyq_test(c1);

--echo create-1-2 唯一索引
--error 0,1091
DROP INDEX INDEX_lyq_test_T2 ON lyq_test;
CREATE /*+ parallel(5) */ UNIQUE INDEX INDEX_lyq_test_T2 ON lyq_test(c2);

--echo create-1-3 组合索引
--error 0,1091
DROP INDEX INDEX_lyq_test_T3 ON lyq_test;
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T3 ON lyq_test(c3, c4,c5);


--echo create-1-4 hash索引
--error 0,1091
DROP INDEX INDEX_lyq_test_T4 ON lyq_test;
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T4 USING HASH ON lyq_test(c6);
  
