disconnect lyq_test;
connect(lyq_test,$OBMYSQL_MS0,lyq_test,123456,test,$OBMYSQL_PORT);

--echo 设置会话变量
--error 1231
SET sql_mode=(SELECT 'aaa' from dual);
SET sql_mode=(SELECT 123456 from dual);
SET sql_mode=(SELECT '' from dual);
SET sql_mode=(SELECT null from dual);
--echo ob可以执行，mysql 报Variable 'sql_mode' can't be set to the value of 'NULL'
SET sql_mode=null;
SHOW VARIABLES LIKE 'sql_mode';


--error 0,1051
drop table t1;
CREATE TABLE t1 (
  c1 INT,
  c2 INT,
  c3 VARCHAR(20)
) PARTITION BY RANGE COLUMNS(c1) (
  PARTITION p0 VALUES LESS THAN (1),
  PARTITION p1 VALUES LESS THAN (10),
  PARTITION p2 VALUES LESS THAN (MAXVALUE)
);

INSERT INTO t1 (c1, c2, c3) VALUES(1, 23456, '+08:00'),(2, 123456, '+00:00'),(3, 3456, '+08:30');

--error 0,1051
drop table t2;
CREATE TABLE t2 (
  c1 INT,
  c2 INT
);

INSERT INTO t2 (c1, c2) VALUES(1, 23456),(2, 123456),(3, 3456);

SET sql_mode=(SELECT CONCAT(@@sql_mode, ',PIPES_AS_CONCAT,NO_ENGINE_SUBSTITUTION')),time_zone=(SELECT DISTINCT c3 AS time_zone FROM t1 AS a
INNER JOIN t2 AS b ON a.c1 = b.c1
WHERE a.c1 IS NOT NULL and b.c1 = 2);

SHOW VARIABLES LIKE 'sql_mode';
SHOW VARIABLES LIKE 'time_zone';


SET @@GLOBAL.sql_mode = (SELECT CONCAT(@@sql_mode, ',STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION')),time_zone=(SELECT DISTINCT c3 AS time_zone FROM t1 AS a
INNER JOIN t2 AS b ON a.c1 = b.c1
WHERE a.c1 IS NOT NULL and b.c1 = 1);

SHOW VARIABLES LIKE 'sql_mode';
SHOW VARIABLES LIKE 'time_zone';
SELECT @@global.sql_mode;
SELECT @@global.time_zone;






