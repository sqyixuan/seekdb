stmt 1
stmt 2 non terminated, comment
stmt 1
stmt 2 non terminated, comment
select "stmt 1";select "stmt 2 terminated, comment"; /* comment */$$
stmt 1
stmt 2 terminated, comment
stmt 1
stmt 2 terminated, comment
select "stmt 1";             select "space, stmt 2"$$
stmt 1
space, stmt 2
stmt 1
space, stmt 2
select "stmt 1";/* comment */select "comment, stmt 2"$$
stmt 1
comment, stmt 2
stmt 1
comment, stmt 2
