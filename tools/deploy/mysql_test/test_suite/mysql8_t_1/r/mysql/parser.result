stmt 1
stmt 2 non terminated, space
stmt 1
stmt 2 non terminated, space
select "stmt 1";select "stmt 2 terminated, space";      $$
stmt 1
stmt 2 terminated, space
stmt 1
stmt 2 terminated, space
