ALTER VIEW v1 AS SELECT /*+ QB_NAME(a) */ 1;
SELECT * FROM v1;
1
1
DROP VIEW v1;
# The "Hints aren't supported in CREATE or ALTER VIEW" warning is masked:
CREATE VIEW v1 AS SELECT /*+ BAD_HINT */ 1;
ALTER VIEW v1 AS SELECT /*+ BAD_HINT */ 1;
SELECT * FROM v1;
1
1
DROP VIEW v1;
