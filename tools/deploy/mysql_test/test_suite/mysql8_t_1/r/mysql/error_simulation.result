WITH qn (z) AS
(
SELECT 1 FROM t1, t1 t2, t1 t3, t1 t4 LIMIT 100000000
)
SELECT * FROM qn qn0 WHERE z = (SELECT z FROM qn qn1 LIMIT 1);
