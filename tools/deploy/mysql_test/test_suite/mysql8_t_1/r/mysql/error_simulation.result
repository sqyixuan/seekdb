SELECT * FROM t1 LEFT JOIN t2 ON ( t2.a < 10 OR t2.b < 10 );
a	a	b	filler
0	1	1	data
1	1	1	data
2	1	1	data
3	1	1	data
4	1	1	data
5	1	1	data
6	1	1	data
7	1	1	data
8	1	1	data
9	1	1	data
DROP TABLE t1, t2;
