# Bug#19656296 FIND_ALL_KEYS SPAMS SERVER ERROR LOG WITH 
# DEADLOCK/LOCK WAIT ERRORS
#
create table t1(a int) ;
insert into t1 values(1),(2),(3);
select * from t1 order by a;
a
1
2
3
drop table t1;
