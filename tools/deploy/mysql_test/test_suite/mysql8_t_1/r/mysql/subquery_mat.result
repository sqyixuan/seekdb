FROM t2 AS outr2
JOIN t4 AS outr
ON (outr2.col_varchar_nokey > outr.col_varchar_nokey)
WHERE
outr.col_varchar_nokey IN (
SELECT innr.col_varchar_nokey
FROM t3 AS innr2
LEFT JOIN t1 AS innr
ON (innr2.col_int_key >= innr.pk)
)
XOR outr.pk < 6
;
