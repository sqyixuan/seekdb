1	4	4	0
2	FFFFFFFFFFFFFFFF	0	0
3	4	4	4
4	4	4	0
5	0	0	0
SELECT group_id, HEX(BIT_AND(a)), BIT_AND(192), BIT_AND(0x303233), BIT_AND(binary "foo")
FROM t
GROUP BY group_id;
