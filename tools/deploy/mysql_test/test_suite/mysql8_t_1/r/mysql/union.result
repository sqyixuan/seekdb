2
3
#
# WL#11350 bug: upper level ALL in nesting context, e.g. ORDER
# BY: non-first lower level operand with DISTINCT incorrectly
# merged.
#
(SELECT 1 UNION SELECT 2) UNION ALL (SELECT 1 UNION SELECT 1) ORDER BY 1;
1
1
1
2
#
# WL#11350 bug: upper level ALL in nesting context, e.g ORDER
# BY: first operand lower level with DISTINCT can be merged,
# but last_distinct was clobbered if right hand side contains a
# nest that could not be merged.
#
(SELECT 1 UNION SELECT 1) UNION ALL (SELECT 1 UNION SELECT 1) ORDER BY 1;
1
