#
# WL#11350 bug: lower level ALL not quenched when merging, giving
# rise to duplicates: upper DISTINCT must be heeded
#
(SELECT 1 AS col1 UNION SELECT 2) UNION
(SELECT 1 UNION SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 3);
