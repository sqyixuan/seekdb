a	bigint(20)	YES		NULL	
b	bigint(20)	YES		NULL	
c	bigint(20)	YES		NULL	
1	bigint(1)	NO			
Name_exp_1	bigint(1)	NO			
Name_exp_1_1	bigint(1)	NO			
DESCRIBE v2;
Field	Type	Null	Key	Default	Extra
1	bigint(1)	NO			
Name_exp_1	bigint(1)	NO			
Name_exp_1_1	bigint(1)	NO			
-1	bigint(2)	NO			
Name_exp_-1	bigint(2)	NO			
Name_exp_1_-1	bigint(2)	NO			
DESCRIBE v3;
