INSERT INTO t2 VALUES (100,0),(150,200),(999, 0),(999, NULL);

# t2b is NULL-able

SELECT * FROM t1 LEFT JOIN t2 force index (idx) ON t2.t2b = t1.t1b;
t1a	t1b	t2a	t2b
99	0	100	0
99	0	999	0
99	3	NULL	NULL
99	NULL	NULL	NULL

SELECT * FROM t1 LEFT JOIN t2 force index (idx) ON t2.t2b <=> t1.t1b;
t1a	t1b	t2a	t2b
99	0	100	0
99	0	999	0
99	3	NULL	NULL
99	NULL	999	NULL

DROP TABLE t2;
CREATE TABLE t2 (t2a int, t2b int NOT NULL, KEY idx (t2b));
INSERT INTO t2 VALUES (100,0),(150,200),(999, 0);

# t2b is NOT NULL

SELECT * FROM t1 LEFT JOIN t2 force index (idx) ON t2.t2b = t1.t1b;
t1a	t1b	t2a	t2b
99	0	100	0
99	0	999	0
99	3	NULL	NULL
99	NULL	NULL	NULL

SELECT * FROM t1 LEFT JOIN t2 force index (idx) ON t2.t2b <=> t1.t1b;
t1a	t1b	t2a	t2b
99	0	100	0
99	0	999	0
99	3	NULL	NULL
99	NULL	NULL	NULL

DROP TABLE t1,t2;
