SELECT id, (
SELECT GROUP_CONCAT(id) FROM (
SELECT table_user.id FROM table_user WHERE id IN (
SELECT user FROM table_city_user WHERE table_city_user.city = table_city.id
)
GROUP BY table_user.id
) AS d
) AS users FROM table_city;
