#
# BUG#40827 - Killing insert-select to MyISAM can cause table corruption
#
drop table t1;
CREATE TABLE `t1` (
`id` BIGINT(20) ,
`id1` BIGINT(20) AUTO_INCREMENT,
KEY(id1), KEY(id)
) ENGINE=MyISAM;
Warnings:
Warning	1286	Unknown storage engine 'MyISAM'
drop table t2;
CREATE TABLE `t2` (
`id` BIGINT(20) ,
`id1` BIGINT(20) AUTO_INCREMENT,
KEY (id1), KEY(id)
) ENGINE=MyISAM;
Warnings:
Warning	1286	Unknown storage engine 'MyISAM'
INSERT INTO t2 (id) VALUES (123);
INSERT INTO t2 (id) SELECT id  FROM t2;
# Switch to insert Connection
