#
# WL#12108: Inject type cast nodes into the item tree to avoid data
# type mismatches.
#
drop table dt_t;
drop table n_t;
CREATE TABLE dt_t (dt DATETIME, d DATE, t TIME);
CREATE TABLE n_t (i INT, d DECIMAL, f FLOAT, dc DECIMAL);
#
# DATETIME + NUMERICS
#
#
# DATE + NUMERICS
#
#
# TIME + NUMERICS
#
#
# DATETIME + DATE
#
#
# DATETIME + TIME
#
#
# DATE + TIME
#
DROP TABLE dt_t, n_t;
