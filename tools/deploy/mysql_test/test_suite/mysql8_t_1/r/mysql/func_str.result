SELECT CONCAT(a, x'ff') FROM t1;
CONCAT(a, x'ff')
a˙
SELECT CONCAT_WS(',', a, x'ff') FROM t1;
CONCAT_WS(',', a, x'ff')
a,˙
SELECT CONCAT_WS(x'ff', a, a) FROM t1;
CONCAT_WS(x'ff', a, a)
a˙a
SELECT INSERT(a, 1, 1, x'ff') FROM t1;
INSERT(a, 1, 1, x'ff')
˙
DROP TABLE t1;
