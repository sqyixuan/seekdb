FROM mysql.indexes i JOIN mysql.tables t ON i.TABLE_ID = t.ID
WHERE t.NAME='t1_normal_table'  ORDER BY i.ORDINAL_POSITION;
ERROR 42S02: Table 'mysql.indexes' doesn't exist
