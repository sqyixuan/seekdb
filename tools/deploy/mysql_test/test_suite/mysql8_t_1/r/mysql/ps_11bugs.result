#
# Test that when Item_cache wraps a PS parameter, it is reset
# between executions
#
create table t6(a decimal(3,2));
prepare s from 'select a<cast(? as signed) from t6';
insert into t6 values(6.2);
set @a=8;
execute s using @a;
a<cast(? as signed)
1
set @a=5;
execute s using @a;
a<cast(? as signed)
0
drop table t6;
#
# Bug#31769242 DUPLICATE WARNING WITH PS-PROTOCOL FOR
#              CREATE TABLE ... SELECT READING ACL TABLE
#
# This test uses ACL table for read purpose in SELECT, DDL and DML's
# in prepared statement and make sure we do not see warning during
# PREPARE.
#
SET SESSION TRANSACTION ISOLATION LEVEL SERIALIZABLE;
PREPARE stmt FROM "SELECT * FROM mysql.user LIMIT 0";
EXECUTE stmt;
host	user	password	select_priv	insert_priv	update_priv	delete_priv	create_priv	drop_priv	reload_priv	shutdown_priv	process_priv	file_priv	grant_priv	references_priv	index_priv	alter_priv	show_db_priv	super_priv	create_tmp_table_priv	lock_tables_priv	execute_priv	repl_slave_priv	repl_client_priv	create_view_priv	show_view_priv	create_routine_priv	alter_routine_priv	create_user_priv	event_priv	trigger_priv	create_tablespace_priv	ssl_type	ssl_cipher	x509_issuer	x509_subject	max_questions	max_updates	max_connections	max_user_connections	plugin	authentication_string	password_expired	account_locked	drop_database_link_priv	create_database_link_priv	create_role_priv	drop_role_priv
DEALLOCATE PREPARE stmt;
PREPARE stmt FROM "CREATE TABLE t1 AS SELECT * FROM mysql.user LIMIT 0";
EXECUTE stmt;
DEALLOCATE PREPARE stmt;
PREPARE stmt FROM "INSERT INTO t1 SELECT * FROM mysql.user LIMIT 1";
EXECUTE stmt;
DEALLOCATE PREPARE stmt;
PREPARE stmt FROM "UPDATE t1 SET user='mno'
                   WHERE EXISTS (SELECT * FROM mysql.user LIMIT 1)";
EXECUTE stmt;
DEALLOCATE PREPARE stmt;
PREPARE stmt FROM "DELETE FROM t1
                   WHERE EXISTS (SELECT * FROM mysql.user LIMIT 1)";
EXECUTE stmt;
DEALLOCATE PREPARE stmt;
DROP TABLE t1;
SET SESSION TRANSACTION ISOLATION LEVEL READ COMMITTED;
# Make sure that we do not get warning during PREPARE phase even with
# SELECT ... LOCK IN SHARE MODE.
PREPARE stmt FROM "SELECT * FROM mysql.user LIMIT 0 LOCK IN SHARE MODE";
EXECUTE stmt;
ERROR HY000: cannot select FOR UPDATE from view with DISTINCT, GROUP BY, etc.
DEALLOCATE PREPARE stmt;
End of 8.0 tests.
