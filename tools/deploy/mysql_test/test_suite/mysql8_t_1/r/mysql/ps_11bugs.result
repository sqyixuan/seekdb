DROP FUNCTION IF EXISTS p1;
CREATE FUNCTION p1(i INT) RETURNS INT
BEGIN
SET @@sort_buffer_size= i;
RETURN i + 1;
END|
DROP TABLE t2;
SELECT CONCAT(@@sort_buffer_size);
CONCAT(@@sort_buffer_size)
262144
