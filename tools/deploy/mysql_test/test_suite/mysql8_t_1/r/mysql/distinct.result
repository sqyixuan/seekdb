a INT,
b INT NOT NULL
);
INSERT INTO t1 VALUES (1,2), (3,3);

SELECT DISTINCT subselect.b
FROM t1 LEFT JOIN 
(SELECT it_b.* FROM t1 as it_a LEFT JOIN t1 as it_b ON true) AS subselect 
ON t1.a = subselect.b
;
b
3
NULL
DROP TABLE t1;
