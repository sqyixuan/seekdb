pk integer,
f2 integer,
f3 integer
);
INSERT INTO t3 VALUES (56,0,4);
INSERT INTO t3 VALUES (97,3,4);
SELECT /*+JOIN_ORDER(t2,t3,t1) */ DISTINCT t2.pk FROM t1 LEFT JOIN t2 RIGHT OUTER JOIN t3 ON t2.f1 = t3.f3 ON t1.pk = t3.f2 WHERE t3.pk <> t2.pk;
pk
