INSERT INTO t1 SELECT RAND() FROM t1 AS t1, t1 AS t2;
INSERT INTO t1 SELECT RAND() FROM t1 AS t1, t1 AS t2;
INSERT INTO t1 SELECT RAND() FROM t1 AS t1, t1 AS t2;
INSERT INTO t1 SELECT RAND() FROM t1;
INSERT INTO t1 SELECT RAND() FROM t1;
SELECT DISTINCT COUNT(*) AS num FROM t1 GROUP BY f HAVING num=1;
num
1
