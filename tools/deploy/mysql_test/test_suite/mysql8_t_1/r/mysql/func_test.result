LEAST('11', '5', '2')
11
SELECT LEAST('11', 5, 2);
LEAST('11', 5, 2)
2
SELECT LEAST(11, 5, 2);
LEAST(11, 5, 2)
2
SELECT GREATEST(date '2005-05-05', 20010101, 20040404, 20030303);
