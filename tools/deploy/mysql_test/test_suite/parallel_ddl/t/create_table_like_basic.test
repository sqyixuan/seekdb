#owner: fanfangzhou.ffz
#owner group: RS
#tags: rs
#description: test parallel create table like basic

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
alter system set _enable_add_fulltext_index_to_existing_table = true;
connect (mysql,$OBMYSQL_MS0,root@mysql,,oceanbase,$OBMYSQL_PORT);

set @@session.recyclebin = off;
let $orig_value = `select value from __all_virtual_tenant_parameter_stat where name = '_enable_parallel_table_creation' limit 1`;
alter system set _enable_parallel_table_creation = true;
alter system set ob_vector_memory_limit_percentage =44;
sleep 5;

use test;
--disable_warnings
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

# simple table
create table t1 (col1 int);
create table t2 like t1;

show create table t1;
show create table t2;

drop table t1;
drop table t2;

# table with partition
create table t1 (col1 int, col2 int) partition by hash(col1) partitions 2;
create table t2 like t1;
show create table t1;
show create table t2;

drop table t1;
drop table t2;

# table add/drop column
create table t1(col1 int, col2 int);
alter table t1 add column col3 int ;
alter table t1 add column col4 int  before col2;
alter table t1 add column col5 int  before col1;
alter table t1 add column col6 int  after col4;
create table t2 like t1;

show create table t1;
show create table t2;

drop table t1;
drop table t2;

# table with index
create table t1(col1 int, col2 int, col3 int, c1 int, c2 varchar(255), c3 json, c4 vector(3), primary key(c1));
create index i1 on t1(col1) local;
create unique index i2 on t1(col1) local;
create index i3 on t1(col2) global;
create unique index i4 on t1(col2) global;
create fulltext index idx1 on t1(c2);
create index idx2 on t1 ( (CAST(c3->'$.zipcode' AS UNSIGNED ARRAY)) );
CREATE VECTOR INDEX vector_idx_c4  ON t1 (c4)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
create table t2 like t1;

show create table t1;
show create table t2;

drop table t1;
drop table t2;

# table with foreign key
create table t1(col1 int, primary key (col1));
create table t2(col1 int, col2 int, foreign key (col2) references t1(col1) on delete cascade);
create table t3 like t1;
create table t4 like t2;

show create table t1;
--replace_regex /K_[0-9]*/K_/g
show create table t2;
show create table t3;
--replace_regex /K_[0-9]*/K_/g
show create table t4;

drop table t4;
drop table t3;
drop table t2;
drop table t1;
# table with constraint
create table t1(col1 int, col2 int check (col2 > 0), col3 int NOT NULL, col4 int unique, constraint t1_uk unique(col1));
create table t2 like t1;

--replace_regex /K_[0-9]*/K_/g
show create table t1;
--replace_regex /K_[0-9]*/K_/g
show create table t2;

drop table t1;
drop table t2;

connection mysql;
set @@session.recyclebin = off;
--enable_warnings
eval alter system set _enable_parallel_table_creation = '$orig_value';
