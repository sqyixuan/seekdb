#owner: fanfangzhou.ffz 
#owner group: RS
#tags: rs
#description:
# test parallel create table with foreign key (foreign_key_checks = on)

# setup
connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

#connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

set @@session.recyclebin = off;
set @@session.foreign_key_checks = off;
let $orig_value = `select value from __all_virtual_tenant_parameter_stat where name = '_enable_parallel_table_creation' limit 1`;
alter system set _enable_parallel_table_creation = true;
sleep 5;

--disable_warnings
drop database if exists yanmu_parallel_ddl;
--enable_warnings

create database yanmu_parallel_ddl;
use yanmu_parallel_ddl;

# case 1: create
create table c1(c1 int, c2 int, constraint foreign key(c1, c2) references p1(c1, c2));
insert into c1 values(1, 1);
select * from c1;

# case 2: update (version)
create table c2_1(c1 int, c2 int, constraint foreign key(c1, c2) references p2(c1, c2));
create table c2_2(c1 int, c2 int, constraint foreign key(c1, c2) references p2(c1, c2));

insert into c2_1 values(1, 1);
insert into c2_2 values(1, 1);
select * from c2_1;
select * from c2_2;

# case 2: add (column)
create table c3_1(c1 int, c2 int, constraint foreign key(c1, c2) references p3(c1, c2));
create table c3_2(c1 int, c2 int, constraint foreign key(c1, c2) references p3(c3, c1));

insert into c3_1 values(1, 1);
insert into c3_2 values(1, 1);
select * from c3_1;
select * from c3_2;

# case 3: replace
create table c4_1(c1 int, c2 varchar(20), constraint foreign key(c1, c2) references `p4_1`(c1, c2));
insert into c4_1 values(1, "1");
select * from c4_1;
# case compare + primary/uniq key not matched
--error 1215
create table `p4_1`(c1 int, c2 int);
--error 1215
create table `p4_1`(c1 int, c2 varchar(20));
--error 1215
create table `p4_1`(c1 varchar(20), c2 int);
--error 1215
create table `p4_1`(c1 int, c2 varchar(20), c3 int, primary key(c1, c2, c3));
--error 1215
create table `p4_1`(c1 int, c2 int, unique key(c1, c2));
--error 1215
create table `p4_1`(c1 varchar(20), c2 int, unique key(c1, c2));
--error 1215
create table `p4_1`(c1 int, c2 varchar(20), c3 int, unique key(c1, c2, c3));

create table `p4_1`(c1 int, c2 varchar(20), primary key(c1, c2));
# won't check foreign key
insert into p4_1 values(1, "2");
select * from p4_1;

set @@session.foreign_key_checks=on;
--error 1452
insert into c4_1 values(1, "3");
set @@session.foreign_key_checks=off;
insert into c4_1 values(1, "3");

create table c4_2(c1 int, c2 varchar(20), constraint foreign key(c1, c2) references `p4_2`(c1, c2));
insert into c4_2 values(1, "1");
select * from c4_2;
create table `p4_2`(c1 int, c2 varchar(20), unique key(c1, c2));
# won't check foreign key
insert into p4_2 values(1, "2");
select * from p4_2;

set @@session.foreign_key_checks=on;
--error 1452
insert into c4_2 values(1, "3");
set @@session.foreign_key_checks=off;
insert into c4_2 values(1, "3");

# case 4: update + update
create table c5_1(c1 int primary key, c2 int, constraint foreign key(c2) references p5(c2));
# same mock fk parent table
create table c5_2(c1 int primary key, c2 int, c3 int, constraint foreign key(c2) references p5(c2), constraint foreign key(c3) references p5(c2));

insert into c5_1 values(1, 1);
select * from c5_1;
insert into c5_2 values(1, 1, 1);
select * from c5_2;

create table c5_3(c1 int primary key, c2 int, constraint foreign key(c2) references p5_1(c2));
create table c5_4(c1 int primary key, c2 int, constraint foreign key(c2) references p5_2(c2));
# different mock fk parent table
create table c5_5(c1 int primary key, c2 int, c3 int, constraint foreign key(c2) references p5_1(c2), constraint foreign key(c3) references p5_2(c2));

insert into c5_3 values(1, 1);
select * from c5_3;
insert into c5_4 values(1, 1);
select * from c5_4;
insert into c5_5 values(1, 1, 1);
select * from c5_5;

# case 5: update + add
create table c6_1(c1 int primary key, c2 int, constraint foreign key(c2) references p6(c2));
# same mock fk parent table
create table c6_2(c1 int primary key, c2 int, c3 int, constraint foreign key(c2) references p6(c2), constraint foreign key(c3) references p6(c1));

insert into c6_1 values(1, 1);
select * from c6_1;
insert into c6_2 values(1, 1, 1);
select * from c6_2;

create table c6_3(c1 int primary key, c2 int, constraint foreign key(c2) references p6_1(c2));
create table c6_4(c1 int primary key, c2 int, constraint foreign key(c2) references p6_2(c2));
# different mock fk parent table
create table c6_5(c1 int primary key, c2 int, c3 int, constraint foreign key(c2) references p6_1(c2), constraint foreign key(c3) references p6_2(c1));

insert into c6_3 values(1, 1);
select * from c6_3;
insert into c6_4 values(1, 1);
select * from c6_4;
insert into c6_5 values(1, 1, 1);
select * from c6_5;

# case 6: add + add
create table c7_1(c1 int primary key, c2 int, constraint foreign key(c2) references p7(c2));
# same mock fk parent table
create table c7_2(c1 int primary key, c2 int, c3 int, constraint foreign key(c2) references p7(c1), constraint foreign key(c3) references p7(c3));

insert into c7_1 values(1, 1);
select * from c7_1;
insert into c7_2 values(1, 1, 1);
select * from c7_2;

create table c7_3(c1 int primary key, c2 int, constraint foreign key(c2) references p7_1(c2));
create table c7_4(c1 int primary key, c2 int, constraint foreign key(c2) references p7_2(c2));
# different mock fk parent table
create table c7_5(c1 int primary key, c2 int, c3 int, constraint foreign key(c2) references p7_1(c1), constraint foreign key(c3) references p7_2(c1));

insert into c7_3 values(1, 1);
select * from c7_3;
insert into c7_4 values(1, 1);
select * from c7_4;
insert into c7_5 values(1, 1, 1);
select * from c7_5;

# case 7: create + update
# same mock fk parent table
create table c8_1(c1 int primary key, c2 int, c3 int, constraint foreign key(c2) references p8(c1), constraint foreign key(c3) references p8(c1));

insert into c8_1 values(1, 1, 1);
select * from c8_1;

create table c8_2(c1 int primary key, c2 int, constraint foreign key(c2) references p8_1(c2));
# different mock fk parent table
create table c8_3(c1 int primary key, c2 int, c3 int, constraint foreign key(c2) references p8_2(c1), constraint foreign key(c3) references p8_1(c2));

insert into c8_2 values(1, 1);
select * from c8_2;
insert into c8_3 values(1, 1, 1);
select * from c8_3;

# case 8: create + add
# same mock fk parent table
create table c9_1(c1 int primary key, c2 int, c3 int, constraint foreign key(c2) references p9(c1), constraint foreign key(c3) references p9(c2));

insert into c9_1 values(1, 1, 1);
select * from c9_1;

create table c9_2(c1 int primary key, c2 int, constraint foreign key(c2) references p9_1(c2));
# different mock fk parent table
create table c9_3(c1 int primary key, c2 int, c3 int, constraint foreign key(c2) references p9_2(c1), constraint foreign key(c3) references p9_1(c1));

insert into c9_2 values(1, 1);
select * from c9_2;
insert into c9_3 values(1, 1, 1);
select * from c9_3;

# case 9: create + update + add
# same mock fk parent table
create table c10_1(c1 int primary key, c2 int, c3 int, c4 int, constraint foreign key(c2) references p10(c1), constraint foreign key(c3) references p10(c1), constraint foreign key(c4) references p10(c2));

insert into c10_1 values(1, 1, 1, 1);
select * from c10_1;

create table c10_2(c1 int primary key, c2 int, constraint foreign key(c2) references p10_2(c1));
create table c10_3(c1 int primary key, c2 int, constraint foreign key(c2) references p10_3(c1));
# different mock fk parent table
create table c10_4(c1 int primary key, c2 int, c3 int, c4 int, constraint foreign key(c2) references p10_1(c1), constraint foreign key(c3) references p10_2(c1), constraint foreign key(c4) references p10_3(c2));

insert into c10_2 values(1, 1);
select * from c10_2;
insert into c10_3 values(1, 1);
select * from c10_3;
insert into c10_4 values(1, 1, 1, 1);
select * from c10_4;

# case 10: replace + create + update + add
# same mock fk parent table
create table c11_1(c1 int primary key, c2 int, constraint foreign key(c2) references p11_1(c1));
create table c11_2(c1 int primary key, c2 int, constraint foreign key(c2) references p11_1(c2));

insert into c11_1 values(1, 1);
select * from c11_1;
insert into c11_2 values(1, 1);
select * from c11_2;

create table p11_1(c1 int primary key, c2 int, c3 int, c4 int, c5 int, unique key(c2), constraint foreign key(c3) references p11_2(c1), constraint foreign key(c4) references p11_2(c1), constraint foreign key(c5) references p11_2(c2));

insert into p11_1 values(1, 1, 1, 1, 1);
select * from p11_1;

set @@session.foreign_key_checks=on;
--error 1452
insert into c11_1 values(2, 2);
--error 1452
insert into c11_2 values(2, 2);

set @@session.foreign_key_checks=off;
insert into c11_1 values(2, 2);
insert into c11_2 values(2, 2);

# different mock fk parent table
create table c11_3(c1 int primary key, c2 int, c3 int, constraint foreign key(c2) references p11_3(c1), constraint foreign key(c3) references p11_4(c1));
create table c11_4(c1 int primary key, c2 int, c3 int, constraint foreign key(c2) references p11_3(c2), constraint foreign key(c3) references p11_5(c1));

insert into c11_3 values(1, 1, 1);
select * from c11_3;
insert into c11_4 values(1, 1, 1);
select * from c11_4;

create table p11_3(c1 int primary key, c2 int, c3 int, c4 int, c5 int, unique key(c2), constraint foreign key(c3) references p11_6(c1), constraint foreign key(c4) references p11_4(c1), constraint foreign key(c5) references p11_5(c2));

insert into p11_3 values(1, 1, 1, 1, 1);
select * from p11_3;

set @@session.foreign_key_checks=on;
--error 1452
insert into c11_3 values(2, 2, 2);
--error 1452
insert into c11_4 values(2, 2, 2);

set @@session.foreign_key_checks=off;
insert into c11_3 values(2, 2, 2);
insert into c11_4 values(2, 2, 2);

select * from c11_3;
select * from c11_4;

# case 11: replace + self reference
create table c12_1(c1 int primary key, c2 int, constraint foreign key(c2) references p12_1(c1));
create table c12_2(c1 int primary key, c2 int, constraint foreign key(c2) references p12_1(c2));

insert into c12_1 values(1, 1);
select * from c12_1;
insert into c12_2 values(1, 1);
select * from c12_2;

create table p12_1(c1 int primary key, c2 int, unique key(c2), constraint foreign key(c2) references p12_1(c1));

insert into p12_1 values(1, 1);
select * from p12_1;


# clean & recovery
connection sys;
set @@session.foreign_key_checks = on;
set @@session.recyclebin = off;
--disable_warnings
drop database if exists yanmu_parallel_ddl;
--enable_warnings
eval alter system set _enable_parallel_table_creation = '$orig_value';
