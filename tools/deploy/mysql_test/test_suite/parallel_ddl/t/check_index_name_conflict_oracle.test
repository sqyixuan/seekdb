# owner: fanfangzhou.ffz
# owner group: RS
# tags: rs
# description
# test parallel create index name conflict in oracle

connect (oracle1,$OBMYSQL_MS0,SYS@oracle,,SYS,$OBMYSQL_PORT);
connect (oracle2,$OBMYSQL_MS0,SYS@oracle,,SYS,$OBMYSQL_PORT);
connect (oracle3,$OBMYSQL_MS0,SYS@oracle,,SYS,$OBMYSQL_PORT);

--disable_query_log
--disable_warnings
--disable_result_log
--disable_abort_on_error
drop table t1;
drop table t2;
drop table t3;
drop index i1;
drop index 'i1';
drop index i2;
--enable_query_log
--enable_warnings
--enable_result_log
--enable_abort_on_error

create table t1 (col1 int, col2 int);
create table t2 (col1 int, col2 int);
create table t3 (col1 int, col2 int);
create index i1 on t1(col1);

# oracle name duplicate in database space
--error 600
create index i1 on t2(col1);

# oracle is case sensitive
--error 955
create index "I1" on t1 (col2);
create index "i1" on t1 (col2);


# check index name cache rebuild correctly
connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '1000s';
sleep 2;
set ob_global_debug_sync = 'BEFORE_REFRESH_SCHEMA wait_for signal execute 1';
sleep 2;
connection oracle1;
send create index i2 on t2(col2);
connection oracle2;
sleep 2;
send drop table t1;
connection oracle3;
sleep 2;
send create index i2 on t3(col1);
connection sys;
sleep 1;
set ob_global_debug_sync = 'now signal signal';
sleep 1;
connection oracle1;
reap;
connection oracle2;
reap;
connection oracle3;
--error 600
reap;

connection oracle1;
--disable_query_log
--disable_warnings
--disable_result_log
drop table t2;
drop table t3;
--enable_query_log
--enable_warnings
--enable_result_log
