#owner: fanfangzhou.ffz 
#owner group: RS
#tags: rs
#description:
# test parallel create table with duplicate name

--source mysql_test/include/external_table/copy_data_for_external_table.inc

# setup
connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

--disable_warnings
drop table if exists oceanbase.t1;
drop table if exists information_schema.t1;
drop table if exists mysql.t1;
--enable_warnings

#connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
#connect (mysql_2,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

connection sys;
set @@session.recyclebin = off;
show variables like "collation_%";
show variables like "character_%";
let $orig_value = `select value from __all_virtual_tenant_parameter_stat where name = '_enable_parallel_table_creation' limit 1`;
alter system set _enable_parallel_table_creation = true;
sleep 5;

--disable_warnings
drop database if exists yanmu_parallel_ddl;
drop table if exists test.yanmu_tb;
drop tablegroup if exists yanmu_tg;
drop database if exists `Öceanbase`;
drop database if exists `öceanbase`;
--enable_warnings

create database yanmu_parallel_ddl;
use yanmu_parallel_ddl;

# case 0: create database
create database `Öceanbase`;
--error 1007
create database `öceanbase`;

# case 1: inner table/db

# sys tenant has privilege to create table in system db
connection sys;
create table `t1`(c1 int primary key);
use test;
--error 1050
create table oceanbase.`T1`(c1 int primary key);
drop table oceanbase.`t1`;

use information_schema;
create table `t1`(c1 int primary key);
--error 1050
create table `T1`(c1 int primary key);
drop table information_schema.`t1`;

use mysql;
create table `t1`(c1 int primary key);
--error 1050
create table `T1`(c1 int primary key);
drop table mysql.`t1`;

# duplicate table name with existed inner table
use oceanbase;
--error 1050
create table `__ALL_CORE_TABLE`(c1 int primary key);
--error 1050
create table `__ALL_TABLE`(c1 int primary key);
--error 1050
create table `__ALL_TABLE_HISTORY`(c1 int primary key);
--error 1050
create table `__ALL_VIRTUAL_TABLE`(c1 int primary key);
--error 1050
create table `cdb_tables`(c1 int primary key);

use information_schema;
--error 1050
create table `session_variables`(c1 int primary key);
--error 1050
create table `schemata`(c1 int primary key);

use mysql;
--error 1050
create table `HELP_TOPIC`(c1 int primary key);
--error 1050
create table `USER`(c1 int primary key);
--error 1050
create table `TIME_ZONE`(c1 int primary key);

# other tenant has no privilege to do ddl on sys db(oceanbase/information_schema)
connection mysql;
use oceanbase;
--error 1044
create table `t1`(c1 int primary key);
use information_schema;
--error 1044
create table `session_variables`(c1 int primary key);

use mysql;
--error 1050
create table `HELP_TOPIC`(c1 int primary key);
--error 1050
create table `USER`(c1 int primary key);
--error 1050
create table `TIME_ZONE`(c1 int primary key);

# case 2: basic
connection mysql;
use yanmu_parallel_ddl;
# create table
create table `yanmu_tb`(c1 int primary key);
--error 1050
create table `YANMU_PARALLEL_DDL`.`yanmu_tb`(c1 int primary key);
--error 1050
create table `YANMU_TB`(c1 int primary key);
create table if not exists `YANMU_TB`(c1 int primary key);
create table test.`yanmu_tb`(c1 int primary key);
# create view
--error 1050
create view `yanmu_tb` as select effective_tenant_id();
create view `yanmu_view` as select * from yanmu_tb;
--error 1050
create view `YANMU_VIEW` as select * from yanmu_tb;
--error 1050
create table `yanmu_view`(c1 int primary key);
# create external table
--error 1050
create external table `yanmu_tb`(c1 int,c2 int,c3 int) location='mysqltest_data_for_external_table/external_table_lineitem' format ( type = 'csv');
create external table `yanmu_external_tb`(c1 int,c2 int,c3 int) location='mysqltest_data_for_external_table/external_table_lineitem' format ( type = 'csv');
--error 1050
create external table `YANMU_EXTERNAL_TB`(c1 int,c2 int,c3 int) location='mysqltest_data_for_external_table/external_table_lineitem' format ( type = 'csv');
--error 1050
create table `YANMU_EXTERNAL_TB`(c1 int,c2 int,c3 int);
# create tablegroup(tablgroup name comparsion is case sensitive)
create tablegroup `yanmu_tg`;
--error 5151
create table `tb_with_tg`(c1 int primary key) tablegroup = `YANMU_TG`;
create table `tb_with_tg`(c1 int primary key) tablegroup = `yanmu_tg`;
drop table tb_with_tg;
drop tablegroup yanmu_tg;
# synonym in mysql mode is not supported
--error 1064
create synonym yanmu_synonym for yanmu_tb;
# create ctas table
create table `yanmu_t1`(c1 int primary key, c2 int);
insert into `yanmu_t1` values(1,1);
create table `ctas_1` as select c1 from yanmu_t1;
--error 1050
create table `CTAS_1` as select c1 from yanmu_t1;
--error 1050
create table `CTAS_1`(c1 int primary key);

create table `ctas_2`(c1 int primary key);
--error 1050
create table `CTAS_2` as select c1 from yanmu_t1;

## case 3: mysql tmp table
## mysql tmp table won't be duplicated with normal use table or other session's tmp table.
