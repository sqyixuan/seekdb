#drop temporary table yanmu_parallel_ddl.`YANMU_TMP_TB_1`;
#select table_name from oceanbase.__all_table where tenant_id = 0 and table_name = 'yanmu_tmp_tb_1' order by table_id asc;
#
#connection mysql;
#use yanmu_parallel_ddl;
#create temporary table `yanmu_tmp_tb_2`(c1 int primary key);
#--error 1050
#create temporary table `YANMU_TMP_TB_2`(c1 int primary key);
#create table `YANMU_TMP_TB_2`(c1 int primary key);
#--error 1050
#create table `yanmu_tmp_tb_2`(c1 int primary key);

# case 4: foreign key/constraint (uniq in db & comparsion is case insensitive)
connection mysql;
use yanmu_parallel_ddl;
# foreign key name is duplicated
create table `parent_tb`(c1 int primary key);
--error 1215
create table `tb_with_fk`(c1 int primary key, c2 int, c3 int, constraint `fk1` foreign key (c2) references `parent_tb`(c1), constraint `FK1` foreign key (c3) references `parent_tb`(c1));
create table `tb_with_fk`(c1 int primary key, c2 int, constraint `fk1` foreign key (c2) references `parent_tb`(c1));
--error 1022
create table `tb_with_fk_1`(c1 int primary key, c2 int, constraint `FK1` foreign key (c2) references `parent_tb`(c1));

# constraint name is duplicated
--error 3822
create table `tb_with_cst`(c1 int primary key, c2 int, c3 int, constraint `cst1` check (c2 < 100), constraint `CST1` check (c3 < 100));
create table `tb_with_cst`(c1 int primary key, c2 int, constraint `cst1` check (c2 < 100));
--error 3822
create table `tb_with_cst_1`(c1 int primary key, c2 int, constraint `CST1` check (c2 < 100));

# constraint name and foreign key name are in different namespace in mysql
create table `tb_with_cst_1`(c1 int primary key, c2 int, constraint `fk1` check (c2 < 100));
create table `tb_with_fk_1`(c1 int primary key, c2 int, constraint `cst1` foreign key (c2) references `parent_tb`(c1));

# case 5: specail character in table name
connection mysql;
use yanmu_parallel_ddl;

create table `yanmu_a'b`(c1 int primary key);
--error 1050
create table `yanmu_a'b`(c1 int primary key);
--error 1050
create table `YANMU_A'B`(c1 int primary key);

create table `yanmu_a\b`(c1 int primary key);
--error 1050
create table `yanmu_a\b`(c1 int primary key);
--error 1050
create table `YANMU_A\B`(c1 int primary key);

create table `yanmu_a"b`(c1 int primary key);
--error 1050
create table `yanmu_a"b`(c1 int primary key);
--error 1050
create table `YANMU_A"B`(c1 int primary key);

create table `o`(c1 int primary key);
--error 1050
create table `Ö` (c1 int primary key);
--error 1050
create table `ö` (c1 int primary key);


# clean & recovery
connection mysql;
set @@session.recyclebin = off;
--disable_warnings
drop database if exists yanmu_parallel_ddl;
drop database if exists `Öceanbase`;
drop database if exists `öceanbase`;
--enable_warnings
eval alter system set _enable_parallel_table_creation = '$orig_value';
