#select table_name, if(session_id > 0, 1, 0) as session_id_valid from oceanbase.__all_table where tenant_id = 0 and table_name = 'yanmu_tmp_tb' order by table_id asc;
#
## create tmp table first
#connection mysql_2;
#use yanmu_parallel_ddl;
#create temporary table `yanmu_tmp_tb_1`(c1 int primary key);
#--error 1050
#create temporary table `YANMU_TMP_TB_1`(c1 int primary key);
#
#connection mysql;
#use yanmu_parallel_ddl;
#create table `yanmu_tmp_tb_1`(c1 int primary key);
