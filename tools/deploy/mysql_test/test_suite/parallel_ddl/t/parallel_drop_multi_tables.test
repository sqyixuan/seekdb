#owner: zhaoziqian.zzq
#owner group: RS
#tags: rs
#description:
# test parallel drop multiple tables in mysql mode

###################### init #####################

connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
set @@session.recyclebin = off;
--disable_warnings
drop database if exists ziqian_parallel_drop_table;
--enable_warnings
create database ziqian_parallel_drop_table;
use ziqian_parallel_drop_table;


###################### recyclebin off ######################

set @@session.recyclebin = off;

# case 1: drop multiple existing tables
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int);
create table t3 (c1 int primary key, c2 int);
drop table t1, t2, t3;

# case 2: drop multiple non-existing tables
--error 1051
drop table t1, t2, t3;

# case 3: drop multiple tables, some of which exist
create table t1 (c1 int primary key, c2 int);
insert into t1 values (1, 10);
--error 1051
drop table t1, t2, t3;
select * from t1;
drop table t1;

# case 4: drop multiple existing tables with if exists flag
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int);
create table t3 (c1 int primary key, c2 int);
drop table if exists t1, t2, t3;

# case 5: drop multiple non-existing tables with if exists flag
drop table if exists t1, t2, t3;

# case 6: drop multiple tables with if exists flag, some of which exist
create table t1 (c1 int primary key, c2 int);
insert into t1 values (1, 10);
drop table if exists t1, t2, t3;
--error 1146
select * from t1;

# case 7: drop multiple tables, one of which is fk parent table, and its child table is NOT dropped in this statement
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, constraint fk1 foreign key (c2) references t1(c1));
create table t3 (c1 int primary key, c2 int);
--error 3730
drop table t1, t3;
drop table t1, t2, t3;

# case 8: drop multiple tables, one of which is fk parent table, and its child table is dropped in this statement
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, constraint fk1 foreign key (c2) references t1(c1));
create table t3 (c1 int primary key, c2 int);
drop table t1, t2, t3;

# case 9: foreign_key_checks off, drop multiple tables, one of which is fk parent table, and its child table is NOT dropped in this statement
set foreign_key_checks = off;
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, constraint fk1 foreign key (c2) references t1(c1));
create table t3 (c1 int primary key, c2 int);
--error 1235
drop table t1, t3;
drop table t1, t2, t3;
set foreign_key_checks = on;

# case 10: drop multiple tables, one of which is fk parent table, one of which is non-existing
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, constraint fk1 foreign key (c2) references t1(c1));
--error 1051
drop table t2, t3;
drop table t1, t2;

# case 11: drop multiple tables, one of which has mock fk parent table
set foreign_key_checks = off;
create table t2 (c1 int primary key, c2 int, constraint fk1 foreign key (c2) references t1(c1));
create table t3 (c1 int primary key, c2 int);
--error 1235
drop table t2, t3;
drop table t2;
drop table t3;
set foreign_key_checks = on;

# case 12: drop multiple tables in different databases
create database ziqian_parallel_drop_table1;
create database ziqian_parallel_drop_table2;
create table ziqian_parallel_drop_table1.t1 (c1 int primary key, c2 int);
create table ziqian_parallel_drop_table2.t1 (c1 int primary key, c2 int);
drop table ziqian_parallel_drop_table1.t1, ziqian_parallel_drop_table2.t1;
drop database ziqian_parallel_drop_table1;
drop database ziqian_parallel_drop_table2;

# case 13: drop multiple tables with same name
create table t1 (c1 int primary key, c2 int);
--error 1066
drop table t1, t1;
drop table t1;


###################### recyclebin on ######################

set @@session.recyclebin = on;

# case 1: drop multiple existing tables
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int);
create table t3 (c1 int primary key, c2 int);
drop table t1, t2, t3;

# case 2: drop multiple non-existing tables
--error 1051
drop table t1, t2, t3;

# case 3: drop multiple tables, some of which exist
create table t1 (c1 int primary key, c2 int);
insert into t1 values (1, 10);
--error 1051
drop table t1, t2, t3;
select * from t1;
drop table t1;

# case 4: drop multiple existing tables with if exists flag
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int);
create table t3 (c1 int primary key, c2 int);
drop table if exists t1, t2, t3;

# case 5: drop multiple non-existing tables with if exists flag
drop table if exists t1, t2, t3;

# case 6: drop multiple tables with if exists flag, some of which exist
create table t1 (c1 int primary key, c2 int);
insert into t1 values (1, 10);
drop table if exists t1, t2, t3;
--error 1146
select * from t1;

# case 7: drop multiple tables, one of which is fk parent table, and its child table is NOT dropped in this statement
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, constraint fk1 foreign key (c2) references t1(c1));
create table t3 (c1 int primary key, c2 int);
--error 3730
drop table t1, t3;
drop table t1, t2, t3;

# case 8: drop multiple tables, one of which is fk parent table, and its child table is dropped in this statement
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, constraint fk1 foreign key (c2) references t1(c1));
create table t3 (c1 int primary key, c2 int);
drop table t1, t2, t3;

# case 9: foreign_key_checks off, drop multiple tables, one of which is fk parent table, and its child table is NOT dropped in this statement
set foreign_key_checks = off;
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, constraint fk1 foreign key (c2) references t1(c1));
create table t3 (c1 int primary key, c2 int);
--error 1235
drop table t1, t3;
drop table t1, t2, t3;
set foreign_key_checks = on;

# case 10: drop multiple tables, one of which is fk parent table, one of which is non-existing
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, constraint fk1 foreign key (c2) references t1(c1));
--error 1051
drop table t2, t3;
drop table t1, t2;

# case 11: drop multiple tables, one of which has mock fk parent table
set foreign_key_checks = off;
create table t2 (c1 int primary key, c2 int, constraint fk1 foreign key (c2) references t1(c1));
create table t3 (c1 int primary key, c2 int);
--error 1235
drop table t2, t3;
drop table t2;
drop table t3;
set foreign_key_checks = on;

# case 12: drop multiple tables in different databases
create database ziqian_parallel_drop_table1;
create database ziqian_parallel_drop_table2;
create table ziqian_parallel_drop_table1.t1 (c1 int primary key, c2 int);
create table ziqian_parallel_drop_table2.t1 (c1 int primary key, c2 int);
drop table ziqian_parallel_drop_table1.t1, ziqian_parallel_drop_table2.t1;
drop database ziqian_parallel_drop_table1;
drop database ziqian_parallel_drop_table2;

# case 13: drop multiple tables with same name
create table t1 (c1 int primary key, c2 int);
--error 1066
drop table t1, t1;
drop table t1;


###################### clear & recovery ######################

purge recyclebin;
set @@session.recyclebin = off;
drop database ziqian_parallel_drop_table;
