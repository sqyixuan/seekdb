create table t1(col1 int, col2 int);
alter table t1 add column col3 int ;
alter table t1 add column col4 int  before col2;
alter table t1 add column col5 int  before col1;
alter table t1 add column col6 int  after col4;
create table t2 like t1;
show create table t1;
