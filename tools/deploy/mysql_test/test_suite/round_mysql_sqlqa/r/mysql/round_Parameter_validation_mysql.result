表字符集测试
set names binary;
select round('');
round('')
0
select round('0');
round('0')
0
select round(0);
round(0)
0
select round(+1);
round(+1)
1
select round(-1);
round(-1)
-1
select round(-false,-1);
round(-false,-1)
0
select round(-true,1.9);
round(-true,1.9)
-1
select round(-9.99,0);
round(-9.99,0)
-10
select round(null);
round(null)
NULL
select round(round(1.1));
round(round(1.1))
1
select round(9999-12-31,9.9);
round(9999-12-31,9.9)
9956
select round(1000-01-01,1);
round(1000-01-01,1)
998
drop table t1;
CREATE TABLE t1(c1 int unsigned DEFAULT null,
c2 float,
c3 double,
c4 varchar(20)) default charset=binary;
INSERT INTO t1 VALUES(round(1.23,-1),1.235622,1.92569,round(10,9.9));
INSERT INTO t1 VALUES(round(3.1223365,1),3.4486223,round(9.123456,123.1),round(9.9));
INSERT INTO t1 VALUES(round(9.022125,round(1/3)),9.9865523,1.995666,round(3.6667,round(3.6667,2)));
select c1,round(c1,-9.9) from t1 ;
c1	round(c1,-9.9)
0	0
3	0
9	0
create table t2 as select c1,round(c1,-9.9) from t1 ;
desc t2;
Field	Type	Null	Key	Default	Extra
c1	int(10) unsigned	YES		NULL	
round(c1,-9.9)	bigint(20) unsigned	YES		NULL	
select c2,round(c2,-1) from t1 ;
c2	round(c2,-1)
1.23562	0
3.44862	0
9.98655	10
create table t3 as select c1,round(c2,-1) from t1 ;
desc t3;
Field	Type	Null	Key	Default	Extra
c1	int(10) unsigned	YES		NULL	
round(c2,-1)	double(17,0)	YES		NULL	
select c3,round(c3,9.99) from t1 ;
c3	round(c3,9.99)
1.92569	1.9256900000
9.123456	9.1234560000
1.995666	1.9956660000
create table t4 as select c1,round(c3,9.99) from t1 ;
desc t4;
Field	Type	Null	Key	Default	Extra
c1	int(10) unsigned	YES		NULL	
round(c3,9.99)	double(27,10)	YES		NULL	
select c4,round(c4,0) from t1 ;
c4	round(c4,0)
10	10
10	10
3.6667	4
create table t5 as select c1,round(c4,0) from t1 ;
desc t5;
Field	Type	Null	Key	Default	Extra
c1	int(10) unsigned	YES		NULL	
round(c4,0)	double(17,0)	YES		NULL	
drop table t1;
drop table t2;
drop table t3;
drop table t4;
drop table t5;
