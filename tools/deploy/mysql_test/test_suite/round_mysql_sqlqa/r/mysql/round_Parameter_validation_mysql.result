drop database  IF EXISTS  db1;
create database db1;
use db1;
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';
##参数验证
select round();
ERROR 42000: Incorrect parameter count in the call to native function 'round'
select round(" ");
round(" ")
0
select round("null");
round("null")
0
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'null'
select round(null);
round(null)
NULL
select round(1,2);
round(1,2)
1
select round(true);
round(true)
1
select round(false);
round(false)
0
select round(false,-1);
round(false,-1)
0
select round(1,2,3);
