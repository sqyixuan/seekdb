##PL块
drop table t1;
drop table t2;
DROP PROCEDURE pro1;
CREATE  PROCEDURE pro1( out a int)
begin
select round('1.999999999','9')/round('1.999999999','9') into a;
end;
//
CALL pro1(@aa);
select @aa;
@aa
1
DROP PROCEDURE pro1;
DROP PROCEDURE pro2;
CREATE  PROCEDURE pro2( out b varchar(30))
begin
select round(2022-09-14) into b;
end;
//
CALL pro2(@bb);
select @bb;
@bb
1999
DROP PROCEDURE pro2;
drop table t1;
create table t1(c1 int,c2 varchar(20));
DROP PROCEDURE pro3;
CREATE PROCEDURE pro3(in a int)
begin
declare i int;
set i=3.9;
while i <=20  DO
if a > i then
select round(i,9.9);
end if;
insert into t1 values(i,round(i,9.9));
set i = i + 1;
end WHILE;
end;
//
CALL pro3(round(12));
round(i,9.9)
round(i,9.9)
round(i,9.9)
round(i,9.9)
round(i,9.9)
round(i,9.9)
round(i,9.9)
round(i,9.9)
4
5
6
7
8
9
10
11
DROP PROCEDURE pro3;
drop table t1;
create table t1(c1 int,c2 varchar(30));
DROP PROCEDURE pro4;
CREATE PROCEDURE pro4(in a int)
begin
declare i int;
declare b int;
set i=round(3.9,9.9);
while i <=round(8.888,3)  DO
if a =round(15,null) then
select round(a);
end if;
insert into t1 values(a ,round(a));
set i = i + 1;
end WHILE;
select a into b;
end;
//
CALL pro4(15);
select * from t1;
c1	c2
15	15
15	15
15	15
15	15
15	15
DROP PROCEDURE pro4;
drop table t1;
create table t1(c1 int,c2 varchar(30));
drop function  f1;
create function f1(aa  int) returns varchar(30)
begin
return round(aa,9.9);
end;
//
select f1(round('9.99',9.9));
f1(round('9.99',9.9))
10
drop table t1;
drop function  f1;
