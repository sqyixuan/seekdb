##约束
drop table t1;
create table t1(c1 float(20,10) primary key,c2 int default '10');
drop table t2;
create table t2(a1 int unique key ,a2 varchar(20),a3 float(30,10),CONSTRAINT for_key FOREIGN KEY (a3) REFERENCES  t1 (c1));
drop table t3;
create table t3(b1 int not null ,b2 float not null);
