--error 0,1051
drop view v1;
create view v1 as select * from t1 where c3<round('');
select * from v1 order by round(c1,9.9);
select v1.*, round(c3,9.9) from v1 where round(c3)=round(-1);
select v1.*, round(c3,9.9) from v1 where round(c3)>=round(-2.1,9.9) order by round(c1) limit 1;
select v1.*, round(c3,9.9) from v1 where round(c3,9.9)<=round(-3.1,9.9) order by round(c1) limit 1;
select v1.*, round(c3,9.9) from v1 where round(c3)=round(-1,9.9);
select v1.*, round(c3,9.9) from v1 where round(c3)<round(-2,9.9);
select v1.*, round(c3,9.9) from v1 where round(c3)>round(-3,9.9);
select v1.*, round(c3,9.9) from v1 where round(c3) between round(-3,9.9) and round(-1,9.9) order by round(c1) limit 1;
select v1.*, round(c3,9.9) from v1 where round(c3) like '%1%';
select v1.*, round(c3,9.9),max(round(c3,9.9))+min(round(c3,9.9)) from v1 where exists (select round(c3),round(c3));
select v1.*, round(c3,9.9) from v1 where round(-1,9) in  (select round(c3));
select v1.*, round(c3,9.9) from v1 where round(-3,9) > all(select round(c3));
select v1.*, round(c3,9.9) from v1 where c1 =2 or c2 ='test03';
select v1.*, round(c3,9.9) from v1 where c1 =2 and c2 ='test02';
insert into v1(c3) values(round('2022.09167',8.9));
insert into v1(c1,c2,c3) values(0,round('200914'),20.0914);
insert into v1(c1,c2,c3) values(6,round('200918'),20.0918);
delete from t1 where c2 is null;
delete from t1 where c2=round(200918);
delete from t1 where c3=round(-1.123);

