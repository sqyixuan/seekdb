--error 0,1051
drop table t1;
create table t1(c1 int,c2 varchar(20));
--error 0,1305
DROP PROCEDURE pro3;
DELIMITER //;
CREATE PROCEDURE pro3(in a int)
begin
declare i int;
set i=3.9;
while i <=20  DO
if a > i then
select round(i,9.9);
end if;
insert into t1 values(i,round(i,9.9));
set i = i + 1;
end WHILE;
end;
//
DELIMITER ;//

CALL pro3(round(12));
DROP PROCEDURE pro3;


--error 0,1051
drop table t1;
create table t1(c1 int,c2 varchar(30));
--error 0,1305
DROP PROCEDURE pro4;
DELIMITER //;
CREATE PROCEDURE pro4(in a int)
begin
declare i int;
declare b int;
set i=round(3.9,9.9);
while i <=round(8.888,3)  DO
if a =round(15,null) then
select round(a);
end if;
insert into t1 values(a ,round(a));
set i = i + 1;
end WHILE;
select a into b;
end;
//
DELIMITER ;//
CALL pro4(15);
select * from t1;
DROP PROCEDURE pro4;

