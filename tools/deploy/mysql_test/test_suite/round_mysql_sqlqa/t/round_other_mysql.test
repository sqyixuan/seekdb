DROP PROCEDURE pro1;
DELIMITER //;
CREATE  PROCEDURE pro1( out a int)
begin
select round('1.999999999','9')/round('1.999999999','9') into a;
end;
//
DELIMITER ;//
CALL pro1(@aa);
select @aa;
DROP PROCEDURE pro1;

