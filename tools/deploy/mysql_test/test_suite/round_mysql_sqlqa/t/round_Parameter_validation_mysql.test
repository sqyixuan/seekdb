--error 0,1051
drop table t1;
CREATE TABLE t1(c1 int unsigned DEFAULT null,
                c2 float,
                c3 double,
                c4 varchar(20)) default charset=binary;
INSERT INTO t1 VALUES(round(1.23,-1),1.235622,1.92569,round(10,9.9));
INSERT INTO t1 VALUES(round(3.1223365,1),3.4486223,round(9.123456,123.1),round(9.9));
INSERT INTO t1 VALUES(round(9.022125,round(1/3)),9.9865523,1.995666,round(3.6667,round(3.6667,2)));
select c1,round(c1,-9.9) from t1 ;
create table t2 as select c1,round(c1,-9.9) from t1 ;
desc t2;
select c2,round(c2,-1) from t1 ;
create table t3 as select c1,round(c2,-1) from t1 ;
desc t3;
select c3,round(c3,9.99) from t1 ;
create table t4 as select c1,round(c3,9.99) from t1 ;
desc t4;
select c4,round(c4,0) from t1 ;
create table t5 as select c1,round(c4,0) from t1 ;
desc t5;

drop table t1;
drop table t2;
drop table t3;
drop table t4;
drop table t5;
