--echo ## update
--error 0,1051
drop table t1;
create table t1 (c1 int ,c2 varchar(20),c3 float);
insert into t1 values(1,'test01',round(2.55552,3));
insert into t1 values(2,'test02',round(3.555523,9.9));
insert into t1 values(3,'test03',round(5.222229,9.9));
insert into t1 values(4,'test04',round(1.1235557777111,9.9));
update t1 set c3= round(-1.123456589,9.9) where c2='test01';
update t1 set c3= round(-2.123456587,9.9)+0 where c2='test01';
update t1 set c3= round(-3.12345658,9.9) where c2 in ('test01','test02');
update t1 set c3= round(-4.12345658,9.9) where c1 in (round(1.0,4));
update t1 set c1= round(1.2345678,9),c3=round(null) where c2 in ('test01');
update t1 set c1= round(3.123456,8),c3=3.12345925 where c3 is null;
update t1 set c3= round(-9.9,9.2229)  where c1<round(2.99,9.9);
update t1 set c3= round(6.99,-9.9) where c3 between round('') and round(1.12356,6) ;
update t1 set c3= round(3/round(3),1)+0 where c3 = round('')  or c1>round(3,1) ;
update t1 set c1= round(20220811)+0 where c2 like '%4%' ;
update t1 set c3= round(20220812) where c3>any(select round(null));
update t1 set c1= round(20220811)+1 where c3<all(select round(20220811));
update t1 set c1= abs(round(20220811));
update t1 set c1= TO_DAYS(round(20220811));
update t1 set c1= LOCATE(round(20220811)-1,round(20220811));
select * from t1;
--error 0,1051
drop table t1;

--echo ##delete
create table t1 (c1 int ,c2 varchar(20),c3 float);
insert into t1 values(1,round(20220907),-1.123456589);
insert into t1 values(2,round(20220909),-2.123456587);
insert into t1 values(3,round(2022-08-20),-3.12345658);
insert into t1 values(4,round(2022-09-15),-4.12345658);
insert into t1 values(5,round(2022-09-16),3.123456);
delete from t1 where c2 = round(2022-09-16);
delete from t1 where c3 = round(-4.12345658,5);
select * from t1;

--error 0,1051
drop table t1;
create table t1(c1 int, c2 float);
--error 1064
alter  table t1 modify  column c1 int(round(2022-09-13));
--error 1064
alter  table t1 modify  column c2 double  DEFAULT round(1.1111,3);
--echo 目前 OB 不支持这样改变列类型。小类型可以改大，大的不能改小。也不能跨大类型改。
--error 3106
alter  table t1 modify  column c2 double  GENERATED ALWAYS AS (round(9.9,9.9)) STORED NOT NULL COMMENT '日期';



