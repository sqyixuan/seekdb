--disable_warnings
drop database  IF EXISTS  db1;
--enable_warnings
create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';

--echo ##使用场景 
--echo ##表table
--echo ##create as select
create table t1 (c1 int primary key,c2 varchar(20),c3 float(10,3) not null);
insert into t1 values(1,'test01',1.123456231);
insert into t1 values(2,'test02',3.12);
insert into t1 values(3,'test03',4.123);
insert into t1 values(4,'test04',8.999);
insert into t1 values(5,'test05',8.998);
insert into t1 values(8,'test06',round(false,false));
select round(c3) as a from t1 order by round(a);
create table t2 as select round(c3) a from t1;
select * from t2 order by round(a);
--error 0,1051
drop table t2;
select DATEDIFF(round(c3)-1,round(c3)) from t1;
select MOD(round(c3)+5,round(c1)) from t1;
select time(round(c3)),COALESCE(round(c1)) from t1;
SELECT INSTR(round(c3,c1),round(c1)) from t1;
select LENGTH(round(c3))+1,LENGTH(round(c3)) from t1;
SELECT LOCATE(2,round(c3)+0,round(c1)-2) from t1;
select MD5(round(c1)),MD5(round(c3)+1) from t1;

--echo ##聚合函数
select count(round(c3)) from t1;
select sum(round(c3)) from t1;
select avg(round(c3)) from t1;
select min(round(c3)) from t1;
select max(round(c3)) from t1;
select GROUP_CONCAT(round(c3)) from t1;

--echo ##where子句
select t1.*, round(c3) from t1 where round(c1)=8 order by round(c3,3);
select t1.*, round(c3) from t1 where round(c3,2)>=8.99 order by round(c3,3);
select t1.*, round(c3) from t1 where round(c3,2)<=8.99 order by round(c3,3);
select t1.*, round(c3) from t1 where round(c3,3)=8.998 order by round(c3,3);
select t1.*, round(c3) from t1 where round(c3,2)<8 order by round(c3,3);
select t1.*, round(c3) from t1 where round(c3,2)>8 order by round(c3,3);
select t1.*, round(c3) from t1 where round(c3,2) between 9 and 7 order by round(c3,3);
select t1.*, round(c3) from t1 where round(c3,2) like '7%' order by round(c3,3);
select t1.*, round(c3) from t1 where exists (select round(c3)) order by round(c3,3);
select t1.*, round(c3) from t1 where 7 in  (select round(c3)) order by round(c3,3);
select t1.*, round(c3) from t1 where 50 > all(select round(c3)) order by round(c3,3);
select t1.*, round(c3) from t1 where c1 =2 or c2 ='test03' order by round(c3,3);
select t1.*, round(c3) from t1 where c1 =2 and c2 ='test02' order by round(c3,3);
create table t2(a1 int ,a2 int);
insert into t2 values(1,1);
insert into t2 values(2,2);
insert into t2 values(3,3);
select t1.*,round(c3) from t1 inner join t2 on round(t1.c1)=round(t2.a1) order by round(c3,3);
select t1.*,round(c3) from t1 left join t2 on round(t1.c1)=round(t2.a1) order by round(c3,3);
select t1.*,round(c3) from t1 right join t2 on round(t1.c1)=round(t2.a1) order by round(c3,3);

--echo mysql5.7不支持
with tt as (select round(c3)  from t1)  select * from tt;

select round(c3)+round(c3) from t1 where c1>3;
select round(c3)-round(c3) from t1;
select round(c3)*round(c3) from t1;
select round(c3)/round(c3) from t1;
select round(c3)%round(c3) from t1;
select round(c3) div round(c3) from t1;
select round(c3) mod round(c3) from t1;
select -round(c3) from t1;
select +round(c3) from t1;

select round(c3)+0+round(c3) from t1 where c1>3;
select round(c3)-round(c3)+0 from t1;
select round(c3)*round(c3)+0 from t1;
select round(c3)+0/round(c3) from t1;
select round(c3)%round(c3)+0 from t1;
select round(c3)+0 div round(c3) from t1;
select round(c3) mod round(c3)+0 from t1;
select -round(c3)+0 from t1;
select +round(c3)+0 from t1;

select round(c3)+0+round(c3)+0 from t1 where c1=3;
select round(c3)+0-round(c3)+0 from t1;
select round(c3)+0*round(c3)+0 from t1;
select round(c3)+0/round(c3)+0 from t1;
select round(c3)+0%round(c3)+0 from t1;
select round(c3)+0 div round(c3)+0 from t1;
select round(c3)+0 mod round(c3)+0 from t1;
 
select distinct round(c3) from t1;
select distinct round(c3)+20 from t1;
select  round(c3) from t1;
select  round(c3)+1 from t1;
select t1.*,round(c3)-0, round(c3) from t1 group by c1;
select t1.*,round(c3)-0, round(c3) from t1 group by round(c3),round(c3)+0;
select t1.*,round(c3)-0, round(c3) from t1 group by round(c3) having round(c3)>=5;
select t1.*,round(c3)-0, round(c3) from t1 group by round(c3) having round(c3)-0>=3;
select t1.*,round(c3)-0, round(c3) from t1 order by round(c3);
select t1.*,round(c3)-0, round(c3) from t1 order by round(c3)+0;
select t1.*,round(c3)-0, round(c3) from t1  where 9 =round(c3) order by round(c3);
select t1.*,round(c3)-0, round(c3) from t1 where 9 =round(c3)+0 order by round(c3)+0;

select t1.* , case round(c3)  when round(c3)  then round(c3)  when round(c3)+1  then    round(c3)+1  end as a  from t1;
select t1.* , case round(c3)+1  when round(c3)  then round(c3)  when round(c3)+1  then    round(c3)+1  end as a  from t1;
select count(round(c3,c1)) from t1;
select count(round(c3,c1)+0) from t1;
select sum(round(c3,c1)) from t1;
select sum(round(c3,c1)+0) from t1;
select avg(round(c3,c1)) from t1;
select avg(round(c3,c1)) from t1;
select min(round(c3,c1)) from t1;
select min(round(c3,c1)+0) from t1;
select max(round(c3,c1)) from t1;
select max(round(c3,c1)+0) from t1;
select GROUP_CONCAT(round(c3)) from t1;
select GROUP_CONCAT(round(c3)+0) from t1;
--error 0,1051
drop table t2;
--error 0,1051
drop table t1;
create table t1(c1 int,c2 varchar(20),c3 float);
create table t2(a1 int,a2 varchar(20),a3 float);
insert into t1 values(1,'1.99',1.99);
insert into t1 values(2,'2.99',2.99);
insert into t1 values(3,'3.99',3.99);
insert into t2 values(1,'3.99',3.99);
select round(c3,c1),round(c1)+0 from t1 union select round(a3),round(a1)+0 from t2;
select round(c3,c1),round(c1)+0 from t1 union all select round(a3),round(a1)+0 from t2;
select round(c3,c1),round(c1)+0 from t1 intersect select round(a3),round(a1)+0 from t2;
select round(c3,c1),round(c1)+1 from t1 except select round(a3),round(a1)+0 from t2;
select round(c3,c1),round(c1)+2 from t1 minus select round(a3),round(a1)+0 from t2;


