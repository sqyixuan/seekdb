result_format: 4
alter system flush plan cache global;
drop database if exists cmp_type_db;
create database cmp_type_db;
use cmp_type_db;

time compare with date/datetime
alter system set _enable_decimal_int_type = false;
create table t1 (c1 decimal(10, 2));
insert into t1 values (1.23), (0), (null), (-1.23), (99999999.99), (-99999999.99);

explain_protocol: 2
no_type_demotion
EXPLAIN select * from t1 where c1 = 1;
