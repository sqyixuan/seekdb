result_format: 4
alter system flush plan cache global;
drop database if exists cmp_type_db;
create database cmp_type_db;
use cmp_type_db;

basic int with different const type
create table t1 (c1 int, c2 bigint unsigned);
insert into t1 values (1, 1);
insert into t1 values (2, 2);
insert into t1 values (0, 0);
insert into t1 values (-1, 18446744073709551615);

check plan hit
select * from t1 where c1 = '1';
+------+------+
| c1   | c2   |
+------+------+
|    1 |    1 |
+------+------+
select * from t1 where c1 = '1.2';
+------+------+
| c1   | c2   |
+------+------+
+------+------+
select * from t1 where c1 = '1.0000000';
+------+------+
| c1   | c2   |
+------+------+
|    1 |    1 |
+------+------+
SELECT statement, hit_count, query_sql
FROM oceanbase.gv$ob_plan_cache_plan_stat
WHERE statement = 'select * from t1 where c1 = ?'
  AND query_sql != 'select * from t1 where c1 = ?';
+-------------------------------+-----------+-----------------------------------+
| statement                     | hit_count | query_sql                         |
+-------------------------------+-----------+-----------------------------------+
| select * from t1 where c1 = ? |         1 | select * from t1 where c1 = '1'   |
| select * from t1 where c1 = ? |         0 | select * from t1 where c1 = '1.2' |
+-------------------------------+-----------+-----------------------------------+

explain_protocol: 2
int column with string constant
EXPLAIN select * from t1 where c1 = '1';
Query Plan
===============================================
|ID|OPERATOR       |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------
|0 |TABLE FULL SCAN|t1  |1       |3           |
===============================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2]), filter([t1.c1 = demote_cast('1', INT(11, 0))]), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
