result_format: 4
alter system flush plan cache global;
drop database if exists cmp_type_db;
create database cmp_type_db;
use cmp_type_db;

mysql_date column compare with date constant
create table t1 (c1 date, c2 datetime);
insert into t1 values (20200101, '2020-01-01'),
(20200102, '2020-01-01 01:01:01'),
(20200220, '2020-02-20 12:34:56'),
(20240501, '2024-05-01 00:00:00'),
(20251230, '2025-12-30 23:59:59');

alter system set _enable_mysql_compatible_dates = false;
select @@sql_mode;
+-------------------------------------------------------+
| @@sql_mode                                            |
+-------------------------------------------------------+
| STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER |
+-------------------------------------------------------+
explain_protocol: 2
EXPLAIN select * from t1 where c1 = date'2020-01-01';
Query Plan
===============================================
|ID|OPERATOR       |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------
|0 |TABLE FULL SCAN|t1  |1       |3           |
===============================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2]), filter([t1.c1 = cast('2020-01-01', MYSQL_DATE(-1, -1))]), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select * from t1 where c1 = date'2020-01-01';
