result_format: 4
alter system flush plan cache global;
drop database if exists cmp_type_db;
create database cmp_type_db;
use cmp_type_db;

year type compare with temporal type
create table t1 (c1 year, c2 date);
insert into t1 values ('2088', '2088-03-05');
insert into t1 values ('0', '0000-00-00');
insert into t1 values ('1901', '1901-01-02');
insert into t1 values ('2155', '2155-12-02');

explain_protocol: 2
EXPLAIN select * from t1 where c1 = c2;
