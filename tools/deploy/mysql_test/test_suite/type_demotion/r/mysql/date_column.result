==================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{t1: ({t1: (t1.__pk_increment, t1.c1)})}]), 
      column_values([T_HIDDEN_PK], [column_conv(MYSQL_DATE,PS:(10,0),NULL,__values.c1)])
  1 - output([__values.c1]), filter(nil)
      values({cur_date()})
