EXPLAIN SELECT
  p_id,
  date_str,
  category_list,
  SUM(visitor_filter_uv),
  SUM(delivery_pv)
FROM
  visittor_poi_pv_uv_nocoefficient_d2
WHERE
  p_id in (4783093, '')
  AND (
    pn_id = 54
    OR pn_id = 87
  )
  AND (
    date_str between '2024-08-01'
    and '2024-08-31'
  )
GROUP BY
  date_str,
  p_id,
  category_list
ORDER BY
  date_str,
  p_id;
