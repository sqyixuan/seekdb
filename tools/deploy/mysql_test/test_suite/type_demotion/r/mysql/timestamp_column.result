result_format: 4
alter system flush plan cache global;
drop database if exists cmp_type_db;
create database cmp_type_db;
use cmp_type_db;

time type
create table t1 (c1 timestamp(6));
insert into t1 values ('2020-01-01 12:34:56');
insert into t1 values (0);
insert into t1 values ('9999-12-31 23:59:59.499999');
insert into t1 values ('2020-01-01');
