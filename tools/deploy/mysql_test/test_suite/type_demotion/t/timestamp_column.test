# owner: zuojiao.hzj
# owner group: sql2
# tags: type_demotion, timestamp
# description: 
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
alter system flush plan cache global;
drop database if exists cmp_type_db;
--enable_warnings

create database cmp_type_db;
use cmp_type_db;

--echo time type
create table t1 (c1 timestamp(6));
insert into t1 values ('2020-01-01 12:34:56');
insert into t1 values (0);
insert into t1 values ('9999-12-31 23:59:59.499999');
insert into t1 values ('2020-01-01');
select * from t1;

--echo datetime constant
--explain_protocol 2
select * from t1 where c1 = '2020-01-01 00:00:01';
select * from t1 where c1 = '2020-01-01 12:34:56';
select * from t1 where c1 = '2020-01-01 12:34:56.000001';

select * from t1 where c1 = timestamp'2020-01-01 00:00:01';
select * from t1 where c1 = timestamp'2020-01-01 12:34:56';
select * from t1 where c1 = timestamp'2020-01-01 12:34:56.000001';

select * from t1 where c1 = cast('2020-01-01 00:00:01' as datetime);
select * from t1 where c1 = cast('2020-01-01 12:34:56' as datetime);
select * from t1 where c1 = cast('2020-01-01 12:34:56.000001' as datetime);

select * from t1 where c1 = timestamp'0000-00-00';
select * from t1 where c1 = timestamp'9999-12-31 23:59:59.499999';

set time_zone = '+4:00';
select * from t1 where c1 = timestamp'9999-12-31 23:59:59.499999';
select * from t1 where c1 = timestamp'9999-12-31 19:59:59.499999';

set time_zone = '-4:00';
select * from t1 where c1 = timestamp'9999-12-31 23:59:59.499999';
select * from t1 where c1 = timestamp'9999-12-31 11:59:59.499999';

set time_zone = '+8:00';

--echo date constant
select @@sql_mode;
select * from t1 where c1 = date'2020-01-01';
--error 1525
select * from t1 where c1 = date'2020-00-01';
--error 1525
select * from t1 where c1 = date'2020-01-00';
--error 1525
select * from t1 where c1 = date'2020-02-30';
select * from t1 where c1 = date'0000-01-01';

set sql_mode = 'allow_invalid_dates';
select * from t1 where c1 = date'2020-01-01';
select * from t1 where c1 = date'2020-00-01';
select * from t1 where c1 = date'2020-01-00';
select * from t1 where c1 = date'2020-02-30';
select * from t1 where c1 = date'0000-01-01';

drop table t1;
create table t1(col_year year);

EXPLAIN SELECT /*+NO_REWRITE +opt_param('enable_constant_type_demotion', 'true')*/ * FROM t1 WHERE col_year BETWEEN TIMESTAMP'2012-10-31 17:23:34' and cast('1998-08-30 00:01:01' as DATETIME) ;  
select TIMESTAMP'2012-10-31 17:23:34';
drop table t1;

drop database cmp_type_db;
