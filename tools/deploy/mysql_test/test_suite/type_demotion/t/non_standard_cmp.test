# owner: zuojiao.hzj
# owner group: sql2
# tags: comparison_type, type_demotion
# description: 
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
alter system flush plan cache global;
drop database if exists cmp_type_db;
--enable_warnings

create database cmp_type_db;
use cmp_type_db;

create table t1 (c1 char(10), c2 varchar(10) charset utf16, c3 int, c4 int);
insert into t1 values ('202001', '202001', 202001, 202001);
insert into t1 values ('202002', '202002', 202002, 202002);
insert into t1 values ('2020020', '2020020', 2020020, 2020020);
insert into t1 values ('202003', '202003', 202003, 202003);

alter system set _non_standard_comparison_level = 'none';
--sleep 3
--disable_warnings
alter system flush plan cache global;
--enable_warnings

--explain_protocol 2
select * from t1 where c1 = 202001;
select * from t1 where c1 in (202001, 202003);
select * from t1 where c1 between 202001 and 202003;

select /*+opt_param('non_standard_comparison_level', 'equal')*/ * from t1 where c1 = 202001;
select /*+opt_param('non_standard_comparison_level', 'equal')*/ * from t1 where c1 in (202001, 202003);
select /*+opt_param('non_standard_comparison_level', 'equal')*/ * from t1 where c1 between 202001 and 202003;

select /*+opt_param('non_standard_comparison_level', 'range')*/ * from t1 where c1 = 202001;
select /*+opt_param('non_standard_comparison_level', 'range')*/ * from t1 where c1 in (202001, 202003);
select /*+opt_param('non_standard_comparison_level', 'range')*/ * from t1 where c1 between 202001 and 202003;

--explain_protocol 0
explain extended_noaddr select * from t1 where c1 = 202001;

alter system set _non_standard_comparison_level = 'equal';
--sleep 3
--disable_warnings
alter system flush plan cache global;
--enable_warnings

--explain_protocol 2
select * from t1 where c1 = 202001;
select * from t1 where c1 in (202001, 202003);
select * from t1 where c1 between 202001 and 202003;

select /*+opt_param('non_standard_comparison_level', 'none')*/ * from t1 where c1 = 202001;
select /*+opt_param('non_standard_comparison_level', 'none')*/ * from t1 where c1 in (202001, 202003);
select /*+opt_param('non_standard_comparison_level', 'none')*/ * from t1 where c1 between 202001 and 202003;

select /*+opt_param('non_standard_comparison_level', 'range')*/ * from t1 where c1 = 202001;
select /*+opt_param('non_standard_comparison_level', 'range')*/ * from t1 where c1 in (202001, 202003);
select /*+opt_param('non_standard_comparison_level', 'range')*/ * from t1 where c1 between 202001 and 202003;

--explain_protocol 0
explain extended_noaddr select * from t1 where c1 = 202001;

alter system set _non_standard_comparison_level = 'range';
--sleep 3
--disable_warnings
alter system flush plan cache global;
--enable_warnings

--explain_protocol 2
select * from t1 where c1 = 202001;
select * from t1 where c1 in (202001, 202003);
select * from t1 where c1 between 202001 and 202003;

select /*+opt_param('non_standard_comparison_level', 'none')*/ * from t1 where c1 = 202001;
select /*+opt_param('non_standard_comparison_level', 'none')*/ * from t1 where c1 in (202001, 202003);
select /*+opt_param('non_standard_comparison_level', 'none')*/ * from t1 where c1 between 202001 and 202003;

select /*+opt_param('non_standard_comparison_level', 'equal')*/ * from t1 where c1 = 202001;
select /*+opt_param('non_standard_comparison_level', 'equal')*/ * from t1 where c1 in (202001, 202003);
select /*+opt_param('non_standard_comparison_level', 'equal')*/ * from t1 where c1 between 202001 and 202003;


--echo character_set
select * from t1 where c2 = 202001;
select * from t1 where c2 in (202001, 202003);
select * from t1 where c2 between 202001 and 202003;

--echo column comparison
select * from t1 where c2 = c3;
select * from t1 where c2 between c3 and c4;

--echo vector
select * from t1 where (c1, c2) = (202001, 202001);
select * from t1 where (c1, c2) < (202001, 202001);
--explain_protocol 0

--echo constraint
explain extended_noaddr select * from t1 where c1 = 202001;
explain extended_noaddr select * from t1 where c1 in (202001, 202003);
explain extended_noaddr select * from t1 where c1 between 202001 and 202003;

--echo note by hint
explain extended_noaddr select /*+opt_param('non_standard_comparison_level', 'none')*/ * from t1 where c1 = 202001;
explain extended_noaddr select /*+opt_param('non_standard_comparison_level', 'equal')*/ * from t1 where c1 = 202001;
explain extended_noaddr select /*+opt_param('non_standard_comparison_level', 'range')*/ * from t1 where c1 = 202001;

--echo create view
create view v1 as select * from t1 where c1 = 202001;
show create view v1;
explain select * from v1;
select * from v1;
drop table t1;
drop view v1;

alter system set _non_standard_comparison_level = 'none';
--sleep 3

drop database cmp_type_db;
