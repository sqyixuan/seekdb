# owner: zuojiao.hzj
# owner group: sql2
# tags: type_demotion, year
# description: 
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
alter system flush plan cache global;
drop database if exists cmp_type_db;
--enable_warnings

create database cmp_type_db;
use cmp_type_db;

--echo year type compare with temporal type
create table t1 (c1 year, c2 date);
insert into t1 values ('2088', '2088-03-05');
insert into t1 values ('0', '0000-00-00');
insert into t1 values ('1901', '1901-01-02');
insert into t1 values ('2155', '2155-12-02');

--explain_protocol 2
select * from t1 where c1 = c2;
select * from t1 where c1 = date'2088-03-05';
select * from t1 where c1 = date'0000-00-00';
select * from t1 where c1 = date'9999-12-01';

select * from t1 where c1 = timestamp'2088-03-05 12:32:45';
select * from t1 where c1 = timestamp'0000-00-00 00:00:00';
select * from t1 where c1 = timestamp'9999-12-01 12:32:45';

select * from t1 where c1 = cast('2088-03-05 12:32:45' as datetime);
select * from t1 where c1 = cast('0000-00-00 00:00:00' as datetime);
select * from t1 where c1 = cast('9999-12-01 12:32:45' as datetime);
--explain_protocol 0
drop table t1;

--echo year type compare with time type
create table t1 (c1 year);
insert into t1 values (curdate());
explain select * from t1 where c1 = time'12:34:56.123456';
select count(*) from t1 where c1 = time'12:34:56.123456';
drop table t1;

--echo year type compare with int
create table t1 (c1 year);
insert into t1 values (1901), (2155), (2024), (0), (1), ('0');
select * from t1;
--explain_protocol 2
select * from t1 where c1 = 0;
select * from t1 where c1 = 1;
select * from t1 where c1 = -1;
select * from t1 where c1 = 2001;
select * from t1 where c1 = 9999;
select * from t1 where c1 = -9999;
select * from t1 where c1 = -9223372036854775808;
select * from t1 where c1 =  9223372036854775807;
select * from t1 where c1 =  18446744073709551615;

--echo year type compare with decimal
select * from t1 where c1 = 0.0;
select * from t1 where c1 = 1.1;
select * from t1 where c1 = -1.2;
select * from t1 where c1 = 2001.3;
select * from t1 where c1 = 2001.5;
select * from t1 where c1 = 9999.4;
select * from t1 where c1 = -9999.5;
select * from t1 where c1 = -9223372036854775808.6;
select * from t1 where c1 =  9223372036854775807.7;
select * from t1 where c1 =  18446744073709551615.8;
select * from t1 where c1 =  1844674407370955161590;

--echo year type compare with real
select * from t1 where c1 = 0e1;
select * from t1 where c1 = 11e-1;
select * from t1 where c1 = -12e1;
select * from t1 where c1 = 20013e-1;
select * from t1 where c1 = 99994e-1;
select * from t1 where c1 = -99995e-1;
select * from t1 where c1 = -9223372036854775808.6e0;
select * from t1 where c1 =  9223372036854775807.7e10;
select * from t1 where c1 =  18446744073709551615.8e20;
select * from t1 where c1 =  1844674407370955161590e-20;

--echo year type compare with string;
select * from t1 where c1 = 'fdsfdsafdas';
select * from t1 where c1 = '1af';
select * from t1 where c1 = '0.0';
select * from t1 where c1 = '1.1';
select * from t1 where c1 = '-1.2';
select * from t1 where c1 = '2001.3';
select * from t1 where c1 = '2001.5';
select * from t1 where c1 = '9999.4';
select * from t1 where c1 = '-9999.5';
select * from t1 where c1 = '-9223372036854775808.6';
select * from t1 where c1 =  '9223372036854775807.7';
select * from t1 where c1 =  '18446744073709551615.8';
select * from t1 where c1 =  '1844674407370955161590';
select * from t1 where c1 = '11e-1';
select * from t1 where c1 = '-12e1';

-- echo year type compare with truncated string
select * from t1 where c1 = '2001-02-30';
select * from t1 where c1 = '2001-22-22';
select * from t1 where c1 = '9999-99-99';
select * from t1 where c1 = '2001a';
select * from t1 where c1 = '20010a';
select * from t1 where c1 = '01:00:00';
select * from t1 where c1 = '22:00:00';
select * from t1 where c1 = '189:00:00';

--explain_protocol 0
drop table t1;

drop database cmp_type_db;
