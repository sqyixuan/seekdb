# owner: zuojiao.hzj
# owner group: sql2
# tags: type_demotion, date
# description: 
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
alter system flush plan cache global;
drop database if exists cmp_type_db;
--enable_warnings

create database cmp_type_db;
use cmp_type_db;

create table t1 (c1 date);
insert into t1 values (0);
insert into t1 values (20200101);
insert into t1 values (20200131);

--echo date type compare with string
--explain_protocol 2
select * from t1 where c1 = '20200101';
select * from t1 where c1 between '20200101' and '20200201';
select * from t1 where c1 = '2020-01-01 00:00:00';
select * from t1 where c1 = '2020-01-01 00:00:00.000001';

--echo date type compare with datetime
select * from t1 where c1 = timestamp'2020-01-01 00:00:00.000001';
select * from t1 where c1 = timestamp'2020-01-01 00:00:00.000000';
select * from t1 where c1 = timestamp'2020-01-01';
select * from t1 where c1 = cast('2020-01-01 00:00:00.000001' as datetime);
select * from t1 where c1 = cast('2020-01-01 00:00:00.000000' as datetime);
select * from t1 where c1 = cast('2020-01-01' as datetime);

--echo date type compare with function result
select * from t1 where c1 = substr('20200101', 1, 100);
select * from t1 where c1 between substr('20200101', 1, 100) and substr('20200201', 1, 1000);
drop table t1;

--echo date type compare with time type
create table t1 (c1 date);
insert into t1 values (curdate());
--explain_protocol 2
select count(*) from t1 where c1 = time'12:34:56.123456';
select count(*) from t1 where c1 = time'01:00:00.000000';
select count(*) from t1 where c1 = time'00:01:00.000000';
select count(*) from t1 where c1 = time'00:00:01.000000';
select count(*) from t1 where c1 = time'00:00:00.000001';
select count(*) from t1 where c1 = time'00:00:00.000000';
--explain_protocol 0
drop table t1;

drop database cmp_type_db;
