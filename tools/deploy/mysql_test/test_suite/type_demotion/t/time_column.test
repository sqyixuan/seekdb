# owner: zuojiao.hzj
# owner group: sql2
# tags: type_demotion, time
# description: 
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
alter system flush plan cache global;
drop database if exists cmp_type_db;
--enable_warnings

create database cmp_type_db;
use cmp_type_db;

--echo time type
create table t1 (c1 time, c2 time);
insert into t1 values (1, 2);
insert into t1 values (0, -1);
--explain_protocol 2
select * from t1 where c1 = date'2020-01-01';
select * from t1 where c2 = date'2020-01-01';
select * from t1 where c1 > date'2020-01-01';
select * from t1 where c2 < date'2020-01-01';

select * from t1 where c1 = timestamp'2020-01-01 00:00:01';
select * from t1 where c2 = timestamp'2020-01-01 00:00:02';
select * from t1 where c1 > timestamp'2020-01-01 00:00:00.132456';
select * from t1 where c2 < timestamp'2020-01-01 00:00:00.132456';

select * from t1 where c1 between timestamp'2020-01-01 00:00:01' and timestamp'2020-01-01 00:01:00';
select * from t1 where c1 >= timestamp'2020-01-01 00:00:01' and c1 <= timestamp'2020-01-01 00:00:01';
select * from t1 where c1 between timestamp'2020-02-01 00:00:01' and timestamp'2020-01-01 00:01:00';
select * from t1 where c1 >= timestamp'2020-02-01 00:00:01' and c1 <= timestamp'2020-01-01 00:00:01';
select * from t1 where c1 in (timestamp'2020-01-01 00:00:01');
select * from t1 where c1 in (timestamp'2020-01-01 00:00:01', timestamp'2020-01-01 00:01:00');

--explain_protocol 0
explain extended_noaddr select * from t1 where c1 = date'2020-01-01' and c2 = timestamp'2020-01-01 00:00:01';
drop table t1;

drop database cmp_type_db;
