# owner: zuojiao.hzj
# owner group: sql2
# tags: type_demotion, time
# description: 
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
alter system flush plan cache global;
drop database if exists cmp_type_db;
--enable_warnings

create database cmp_type_db;
use cmp_type_db;

-- echo mysql_date column compare with date constant
create table t1 (c1 date, c2 datetime);
insert into t1 values (20200101, '2020-01-01'),
(20200102, '2020-01-01 01:01:01'),
(20200220, '2020-02-20 12:34:56'),
(20240501, '2024-05-01 00:00:00'),
(20251230, '2025-12-30 23:59:59');

alter system set _enable_mysql_compatible_dates = false;
--sleep 5

select @@sql_mode;
--explain_protocol 2
select * from t1 where c1 = date'2020-01-01';
--error 1525
select * from t1 where c1 = date'2020-00-01';
--error 1525
select * from t1 where c1 = date'2020-01-00';
--error 1525
select * from t1 where c1 = date'2020-02-30';

select * from t1 where c2 = date'2020-01-01';
--error 1525
select * from t1 where c2 = date'2020-00-01';
--error 1525
select * from t1 where c2 = date'2020-01-00';
--error 1525
select * from t1 where c2 = date'2020-02-30';

select * from t1 where c1 = cast('2020-01-01' as datetime);
select * from t1 where c1 = cast('2020-01-01 01:01:01' as datetime);
select * from t1 where c1 = cast('2020-00-01' as datetime);
select * from t1 where c1 = cast('2020-01-00' as datetime);
select * from t1 where c1 = cast('2020-02-30' as datetime);

select * from t1 where c2 = cast('2020-01-01' as datetime);
select * from t1 where c2 = cast('2020-01-01 01:01:01' as datetime);
select * from t1 where c2 = cast('2020-00-01' as datetime);
select * from t1 where c2 = cast('2020-01-00' as datetime);
select * from t1 where c2 = cast('2020-02-30' as datetime);

set sql_mode = 'allow_invalid_dates';

select * from t1 where c1 = date'2020-01-01';
--error 1525
select * from t1 where c1 = date'2020-00-01';
--error 1525
select * from t1 where c1 = date'2020-01-00';
select * from t1 where c1 = date'2020-02-30';

select * from t1 where c2 = date'2020-01-01';
--error 1525
select * from t1 where c2 = date'2020-00-01';
--error 1525
select * from t1 where c2 = date'2020-01-00';
select * from t1 where c2 = date'2020-02-30';

select * from t1 where c1 = cast('2020-01-01' as datetime);
select * from t1 where c1 = cast('2020-01-01 01:01:01' as datetime);
select * from t1 where c1 = cast('2020-00-01' as datetime);
select * from t1 where c1 = cast('2020-01-00' as datetime);
select * from t1 where c1 = cast('2020-02-30' as datetime);

select * from t1 where c2 = cast('2020-01-01' as datetime);
select * from t1 where c2 = cast('2020-01-01 01:01:01' as datetime);
select * from t1 where c2 = cast('2020-00-01' as datetime);
select * from t1 where c2 = cast('2020-01-00' as datetime);
select * from t1 where c2 = cast('2020-02-30' as datetime);

--explain_protocol 0
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER';
drop table t1;
-- echo date column compare with mysql date constant
create table t1 (c1 date, c2 datetime);
insert into t1 values (20200101, '2020-01-01'),
(20200102, '2020-01-01 01:01:01'),
(20200220, '2020-02-20 12:34:56'),
(20240501, '2024-05-01 00:00:00'),
(20251230, '2025-12-30 23:59:59');

alter system set _enable_mysql_compatible_dates = true;
--sleep 5

--explain_protocol 2
select * from t1 where c1 = date'2020-01-01';
--error 1525
select * from t1 where c1 = date'2020-00-01';
--error 1525
select * from t1 where c1 = date'2020-01-00';
--error 1525
select * from t1 where c1 = date'2020-02-30';

select * from t1 where c2 = date'2020-01-01';
--error 1525
select * from t1 where c2 = date'2020-00-01';
--error 1525
select * from t1 where c2 = date'2020-01-00';
--error 1525
select * from t1 where c2 = date'2020-02-30';

select * from t1 where c1 = cast('2020-01-01' as datetime);
select * from t1 where c1 = cast('2020-01-01 01:01:01' as datetime);
select * from t1 where c1 = cast('2020-00-01' as datetime);
select * from t1 where c1 = cast('2020-01-00' as datetime);
select * from t1 where c1 = cast('2020-02-30' as datetime);

select * from t1 where c2 = cast('2020-01-01' as datetime);
select * from t1 where c2 = cast('2020-01-01 01:01:01' as datetime);
select * from t1 where c2 = cast('2020-00-01' as datetime);
select * from t1 where c2 = cast('2020-01-00' as datetime);
select * from t1 where c2 = cast('2020-02-30' as datetime);

set sql_mode = 'allow_invalid_dates';

select * from t1 where c1 = date'2020-01-01';
select * from t1 where c1 = date'2020-00-01';
select * from t1 where c1 = date'2020-01-00';
select * from t1 where c1 = date'2020-02-30';

select * from t1 where c2 = date'2020-01-01';
select * from t1 where c2 = date'2020-00-01';
select * from t1 where c2 = date'2020-01-00';
select * from t1 where c2 = date'2020-02-30';

select * from t1 where c1 = cast('2020-01-01' as datetime);
select * from t1 where c1 = cast('2020-01-01 01:01:01' as datetime);
select * from t1 where c1 = cast('2020-00-01' as datetime);
select * from t1 where c1 = cast('2020-01-00' as datetime);
select * from t1 where c1 = cast('2020-02-30' as datetime);

select * from t1 where c2 = cast('2020-01-01' as datetime);
select * from t1 where c2 = cast('2020-01-01 01:01:01' as datetime);
select * from t1 where c2 = cast('2020-00-01' as datetime);
select * from t1 where c2 = cast('2020-01-00' as datetime);
select * from t1 where c2 = cast('2020-02-30' as datetime);

--explain_protocol 0

drop database cmp_type_db;
