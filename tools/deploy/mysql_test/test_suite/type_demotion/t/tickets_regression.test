# owner: zuojiao.hzj
# owner group: sql2
# tags: comparison_type, type_demotion
# description: 
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
alter system flush plan cache global;
drop database if exists cmp_type_db;
--enable_warnings

create database cmp_type_db;
use cmp_type_db;

--echo int cmp string
create table t1 (test2 int, test3 int);
explain SELECT * FROM t1  WHERE test2 = '50' AND test3 = '500'  limit 100;

--echo int in string
alter system set _inlist_rewrite_threshold = 10000;
explain (SELECT * FROM t1
WHERE test2 IN ( '53','84','454','457','745','1184','1185','1186','1187','1188','1189','1190','1191','1192','1194','1197','1199','1200','1201','1202','1203','1204','1206','1207','1208','1212','1213','1214','1215','1216','1217','1218','1219','1220','1221','1222','1223','1224','1225','1226','1227','1228','1230','1231','1232','1233','1234','1235','1236','1237','1238','1239','1242','1243','1245','1246','1247','1248','1249','1250','1251','1252','1253','1254','1255','1256','1258','1259','1260','1262','1263','1264','1265','1266','1268','1269','1270','1271','1272','1273','1274','1275','1276','1277','1278','1279','1280','1281','1282','1283','1284','1285','1286','1289','1290','1291','1292','1293','1294','1295','1296','1297','1298','1300','1301','1302','1304','1306','1307','1308','1309','1310','1311','1313','1314','1315','1316','1317','1318','1319','1321','1322','1323','1325','1327','1328','1330','1332','1333','1334','1337','1340','1341','1342','1343','1344','1345','1346','1347','1348','1349','1350','1351','1353','1355','1357','1358','1359','1360','1361','1363','1364','1365','1366','1367','1368','1369','1370','1371','1372','1373','1374','1376','1378','1379','1380','1381','1382','1383','1384','1385','1387','1388','1389','1391','1395','1396','1397','1398','1399','1403','1405','1406','1407','1409','1410','1411','1413','1414','1419','1420','1421','1422','1423','1426','1427','1428','1429','1430','1431','1432','1433','1435','1437','1438','1439','1440','1442','1443','1444','1445','1447','1448','1449','1450','1454','1456','1458','1459','1460','1461','1462','1463','1464','1465','1466','1467','1468','1469','1470','1472','1473','1474','1475','1477','1478','1480','1481','1482','1483','1484','1485','1486','1487','1488','1489','1491','1492','1493','1495','1496','1497','1498','1499','1500','1501','1502','1503','1504','1505','1506','1507','1508','1509','1510','1511','1512','1513','1514','1515','1516','1517','1519','1520','1521','1522','1523','1524','1525','1531','1533','1538','1544','1547','1