--echo date cmp string
CREATE TABLE `visittor_poi_pv_uv_nocoefficient_d2` (
  `date_str` date DEFAULT NULL,
  `p_id` varchar(65533) DEFAULT NULL COMMENT 'poi_id 明文',
  `pn_id` int(11) DEFAULT NULL COMMENT '渠道(package_name) id, 0带表全部渠道',
  `category_list` varchar(65533) DEFAULT NULL COMMENT '场景类型',
  `visitor_pv` int(11) DEFAULT NULL COMMENT '访客pv',
  `visitor_uv` int(11) DEFAULT NULL COMMENT '访客uv',
  `visitor_filter_pv` int(11) DEFAULT NULL COMMENT '访客过滤之后的pv',
  `visitor_filter_uv` int(11) DEFAULT NULL COMMENT '访客过滤之后的uv',
  `visitor_filter_10min` int(11) DEFAULT NULL COMMENT '10min的访客量',
  `delivery_pv` int(11) DEFAULT NULL COMMENT '外卖员到访量',
  `staff_uv` int(11) DEFAULT NULL COMMENT '员工数量',
  `agent_uv` int(11) DEFAULT NULL COMMENT '房产中介数量'
) partition by range columns(`date_str`)
(partition `p202307` values less than ('2023-08-01'),
partition `p202308` values less than ('2023-09-01'),
partition `p202309` values less than ('2023-10-01'),
partition `p202310` values less than ('2023-11-01'),
partition `p202311` values less than ('2023-12-01'),
partition `p202312` values less than ('2024-01-01'),
partition `p202401` values less than ('2024-02-01'),
partition `p202402` values less than ('2024-03-01'),
partition `p202403` values less than ('2024-04-01'),
partition `p202404` values less than ('2024-05-01'),
partition `p202405` values less than ('2024-06-01'),
partition `p202406` values less than ('2024-07-01'),
partition `p202407` values less than ('2024-08-01'),
partition `p202408` values less than ('2024-09-01'),
partition `p202409` values less than ('2024-10-01'),
partition `p202410` values less than ('2024-11-01'),
partition `p202411` values less than ('2024-12-01'),
partition `p202412` values less than ('2025-01-01'));

--explain_protocol 2
SELECT
  p_id,
  date_str,
  category_list,
  SUM(visitor_filter_uv),
  SUM(delivery_pv)
FROM
  visittor_poi_pv_uv_nocoefficient_d2
WHERE
  p_id in (4783093, '')
  AND (
    pn_id = 54
    OR pn_id = 87
  )
  AND (
    date_str between '2024-08-01'
    and '2024-08-31'
  )
GROUP BY
  date_str,
  p_id,
  category_list
ORDER BY
  date_str,
  p_id;

--explain_protocol 0

CREATE TABLE `hj_rating_detail_0804` (
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime DEFAULT NULL,
  `user_id` bigint(20) NOT NULL,
  `p_trade_id` bigint(20) NOT NULL,
  `trade_id` bigint(20) NOT NULL,
  `id` bigint(20) NOT NULL,
  `user_nick` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL,
  `mes_id` bigint(20) DEFAULT NULL,
  `event_type` varchar(192) COLLATE utf8mb4_bin DEFAULT NULL,
  `biz_id` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL,
  `index_num` bigint(20) DEFAULT NULL,
