# owner: zuojiao.hzj
# owner group: sql2
# tags: comparison_type, type_demotion
# description: 
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
alter system flush plan cache global;
drop database if exists cmp_type_db;
--enable_warnings

create database cmp_type_db;
use cmp_type_db;

CREATE TABLE `t0` (
  `c0` datetime DEFAULT NULL,
  `c1` bigint(20) DEFAULT NULL COMMENT 'asdf'
) ;

explain SELECT * FROM t0 WHERE ((t0.c1) NOT IN ('2025-02-12 04:14:45', t0.c0, '419386677')) IN (t0.c1);
SELECT * FROM t0 WHERE ((t0.c1) NOT IN ('2025-02-12 04:14:45', t0.c0, '419386677')) IN (t0.c1);
drop table t0;

create table t1 (c1 int, c2 int);
create view v1 as select * from t1 where c1 = 'AB';
--error 1054
select * from t1 where v1 = 'ABC';
drop view v1;
drop table t1;


--disable_warnings
drop database if exists cmp_type_db1;
--enable_warnings
create database cmp_type_db1;
USE cmp_type_db1;
CREATE TABLE t0(c0 DATETIME  COMMENT 'asdf'  NULL, c1 MEDIUMTEXT , c2 INT(189)  UNIQUE COMMENT 'asdf'  NOT NULL , PRIMARY KEY(c2))   PARTITION BY RANGE (c2)(partition p0 VALUES LESS THAN(0), partition p1 VALUES LESS THAN(1000000000), partition p2 VALUES LESS THAN(maxvalue));
CREATE TABLE t1 LIKE t0;
CREATE TABLE t2 LIKE t0;
CREATE TABLE IF NOT EXISTS t3 LIKE t1;
CREATE TABLE IF NOT EXISTS t4 PARTITION BY KEY (c2) SUBPARTITION BY RANGE (c2) subpartition template (subpartition sp0 VALUES LESS THAN(0), subpartition sp1 VALUES LESS THAN(1000000000), subpartition sp2 VALUES LESS THAN(maxvalue)) partitions 12 AS SELECT * FROM t2;
CREATE MATERIALIZED VIEW LOG on t0 parallel 9 with rowid, sequence(c0) including new values;
CREATE MATERIALIZED VIEW LOG on t1 parallel 9 with rowid, sequence(c0) including new values;
CREATE MATERIALIZED VIEW LOG on t2 parallel 9 with rowid, sequence(c0) including new values;
CREATE MATERIALIZED VIEW LOG on t3 parallel 9 with rowid, sequence(c0) including new values;
CREATE MATERIALIZED VIEW LOG on t4 parallel 9 with rowid, sequence(c0, c2) including new values;
CREATE MATERIALIZED VIEW mv_t0 parallel 9 refresh fast on demand enable on QUERY computation enable QUERY rewrite AS SELECT ALL t3.c2 AS C0, t0.c2 AS C1 FROM t0, t3 WHERE (("784118038") = (t3.c2)) IN ((t3.c2) IN (t3.c2), CAST(t0.c2 AS SIGNED), NULL);
CREATE MATERIALIZED VIEW mv_t4 parallel 9 refresh fast on demand enable on QUERY computation enable QUERY rewrite AS select c0, c2,count(*) as c from t4 group by c0, c2;
SELECT /*+  USE_MERGE(mv_t0, mv_t4) */ ALL mv_t0.C0 AS C0, mv_t0.C1 AS C1, mv_t4.c0 AS C2, mv_t4.c2 AS C3, mv_t4.c AS C4, ROW_NUMBER() over( order by mv_t0.C0, mv_t0.C1, mv_t4.c0, mv_t4.c2, mv_t4.c desc) AS WF0, DENSE_RANK() over( order by mv_t4.c0, mv_t0.C0, mv_t0.C1, mv_t4.c asc) AS WF1 FROM  mv_t0 CROSS JOIN mv_t4 ON (('I') NOT IN ("2025-02-20 16:48:49")) || (NULL) WHERE (1842261) < (7004336);

set sql_mode = 'ALLOW_INVALID_DATES';
DROP TABLE if exists table_2_false; 
CREATE TABLE table_2_false (
col_datetime_1 datetime(1),
col_timestamp_3 timestamp(6) NULL DEFAULT NULL,
col_timestamp_5 timestamp(5) NULL DEFAULT NULL,
ob_sub_partition_name timestamp(3) NULL DEFAULT NULL) ; 


SELECT *
FROM   table_2_false
WHERE  ( col_timestamp_5, col_datetime_1,  col_datetime_1 ) = 
       (ob_sub_partition_name, '2000-11-11', ob_sub_partition_name ); 

DROP TABLE table_2_false; 

use cmp_type_db;
drop database cmp_type_db1;

drop database cmp_type_db;
