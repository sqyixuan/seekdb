# owner: zuojiao.hzj
# owner group: sql2
# tags: type_demotion, decimal
# description: 
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
alter system flush plan cache global;
drop database if exists cmp_type_db;
--enable_warnings

create database cmp_type_db;
use cmp_type_db;

--echo time compare with date/datetime
alter system set _enable_decimal_int_type = false;
--sleep 5

create table t1 (c1 decimal(10, 2));
insert into t1 values (1.23), (0), (null), (-1.23), (99999999.99), (-99999999.99);

--explain_protocol 2
--echo no_type_demotion
select * from t1 where c1 = 1;
select * from t1 where c1 = 1.234;
select * from t1 where c1 = 1.230;

--echo type demotion when constant type is real
select * from t1 where c1 = 123e-2;
select * from t1 where c1 = 1234e-2;

select * from t1 where c1 = 123e-100;
select * from t1 where c1 = 123e100;

select * from t1 where c1 > 123e-100;
select * from t1 where c1 < 123e100;

select * from t1 where c1 = -123e-2;
select * from t1 where c1 = -1234e-2;

select * from t1 where c1 = -123e-100;
select * from t1 where c1 = -123e100;

select * from t1 where c1 > -123e-100;
select * from t1 where c1 < -123e100;

select * from t1 where c1 = 99999999.990e0;
select * from t1 where c1 = -99999999.990e0;

select * from t1 where c1 = 99999999.999e0;
select * from t1 where c1 = -99999999.999e0;

select * from t1 where c1 = 100000000e0;
select * from t1 where c1 = -100000000e0;

--explain_protocol 0
drop table t1;

alter system set _enable_decimal_int_type = true;
--sleep 5

create table t1 (c1 decimal(10, 2));
insert into t1 values (1.23), (0), (null), (-1.23), (99999999.99), (-99999999.99);

--explain_protocol 2
--echo no_type_demotion
select * from t1 where c1 = 1;
select * from t1 where c1 = 1.234;
select * from t1 where c1 = 1.230;

--echo type demotion when constant type is real
select * from t1 where c1 = 123e-2;
select * from t1 where c1 = 1234e-2;

select * from t1 where c1 = 123e-100;
select * from t1 where c1 = 123e100;

select * from t1 where c1 > 123e-100;
select * from t1 where c1 < 123e100;

select * from t1 where c1 = -123e-2;
select * from t1 where c1 = -1234e-2;

select * from t1 where c1 = -123e-100;
select * from t1 where c1 = -123e100;

select * from t1 where c1 > -123e-100;
select * from t1 where c1 < -123e100;

select * from t1 where c1 = 99999999.990e0;
select * from t1 where c1 = -99999999.990e0;

select * from t1 where c1 = 99999999.999e0;
select * from t1 where c1 = -99999999.999e0;

select * from t1 where c1 = 100000000e0;
select * from t1 where c1 = -100000000e0;

--explain_protocol 0
drop table t1;

drop database cmp_type_db;
