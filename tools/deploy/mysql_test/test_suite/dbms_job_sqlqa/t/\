delimiter //;
--echo # 测试首次submit时, job是否立刻执行
create or replace procedure my_pro is
begin
  insert into t_table(c1,c2) values(tab_seq.nextval,'第一个job');
  commit;
end;
//


declare
  job_id number;
begin
  dbms_job.submit(job_id,'my_pro;', sysdate, 'sysdate+1/24/60');
  commit;
end;
//


