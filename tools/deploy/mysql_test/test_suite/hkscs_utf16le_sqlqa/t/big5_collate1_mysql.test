--echo #Environmental cleaning
connection default;
purge recyclebin;

--disable_query_log
connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;
--disable_warnings
call oceanbase.drop_tenant('tenant_charset_test');
--enable_warnings
