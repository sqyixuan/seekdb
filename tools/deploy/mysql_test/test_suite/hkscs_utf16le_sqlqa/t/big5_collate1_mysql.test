--error 0,1051
drop table test_big5_bak;

CREATE TABLE test_big5_bak(
    c0 TEXT COLLATE big5_chinese_ci ,
    c1 TEXT COLLATE big5_bin,
    c2 TEXT COLLATE big5_chinese_ci ,
    c3 TEXT COLLATE big5_bin,
    c4 TEXT COLLATE utf8mb4_unicode_ci,
    c5 TEXT COLLATE big5_chinese_ci ,
    c6 TEXT COLLATE big5_bin,
    sal INT,
    id INT
) CHARACTER SET big5;

--error 0,1305
drop procedure test_big5_bak_ascii_pro;

delimiter /;
CREATE PROCEDURE test_big5_bak_ascii_pro()
BEGIN
  DECLARE i INT DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO test_big5_bak(c0, c1, c2, c3, c4, c5, c6, sal, id)
    VALUES(CONVERT(CHAR(i) USING big5), CONVERT(CHAR(i) USING big5), CONVERT(CHAR(i) USING big5), CONVERT(CHAR(i) USING big5), CONVERT(CHAR(i) USING big5), CONVERT(CHAR(i) USING big5), CONVERT(CHAR(i) USING big5), i, i);
    SET i = i + 1;
  END WHILE;
  COMMIT;
END /
DELIMITER ;/
CALL test_big5_bak_ascii_pro();
