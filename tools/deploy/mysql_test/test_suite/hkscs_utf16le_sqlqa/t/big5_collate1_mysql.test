  hex(c1),
  hex(@u:=convert(c1 using utf8mb4))
  FROM big5_bin_table order by c1;

--error 0,1051
drop table test_big5_bak;
create table test_big5_bak(c0 varchar(100) collate big5_chinese_ci ,c1 varchar(100) collate big5_bin,c2 varchar(100) collate big5_chinese_ci ,c3 varchar(100) collate big5_bin,c4 varchar(100) collate utf8mb4_unicode_ci,c5 varchar(100) collate big5_chinese_ci ,c6 varchar(100) collate big5_bin,sal int,id int) character set big5;

--error 0,1305
drop procedure test_big5_bak_ascii_pro;

delimiter /;
create procedure test_big5_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_big5_bak values(char(i),char(i),char(i),char(i),char(i),char(i),char(i),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call test_big5_bak_ascii_pro();
/

delimiter ;/
SELECT c1,
  hex(c1),
  hex(@u:=convert(c1 using utf8))
  FROM test_big5_bak order by c1;

