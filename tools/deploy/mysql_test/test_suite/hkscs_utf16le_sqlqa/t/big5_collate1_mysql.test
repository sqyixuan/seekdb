--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET big5;
use db1;

--error 0,1051
drop table big5_table;
--error 0,1305
drop procedure build_big5_table;
--error 0,1051
drop table big5_bin_table;
--error 0,1305
drop procedure build_big5_bin_table;

create table big5_table(c1 char(30) charset big5 collate big5_chinese_ci );
create table big5_bin_table(c1 char(30) charset big5 collate big5_bin);

--error 0,1305
DROP PROCEDURE build_big5_table;

delimiter /;
create procedure build_big5_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into big5_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_big5_table();
/
