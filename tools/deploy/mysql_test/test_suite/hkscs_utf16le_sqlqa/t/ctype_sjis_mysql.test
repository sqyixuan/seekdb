### --source include/ctype_inet.inc

### --disable_warnings ER_WRONG_VALUE_FOR_TYPE
--disable_warnings 
SELECT is_ipv4(inet_ntoa('1'));
SELECT is_ipv6(inet_ntoa('1'));
SELECT HEX(inet6_aton(inet_ntoa('1')));
SELECT inet6_ntoa(inet_ntoa('1'));

