purge recyclebin;

--result_format 4
--echo #Environmental cleaning

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##设置并查看当前字符集设置
set names 'dec8';
set character_set_database = 'dec8';
set character_set_server = 'dec8';
set character_set_results = 'utf8mb4';
show character set where Charset = 'dec8';
show variables like 'character_set%';
--enable_sorted_result

--echo ############################# 字符类型 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET dec8;
use db1;

--error 0,1051
drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(100),
    nchar_column NATIONAL CHAR(100),
    varchar_column VARCHAR(100),
    nvarchar_column NATIONAL VARCHAR(100),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = dec8;

--error 0,1305
DROP PROCEDURE build_dec8_table;

delimiter /;
create procedure build_dec8_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128|| (i >= 0xA1 && i < 0xE0) ) THEN
      insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

--error 1366
call build_dec8_table();
/

--error 0,1305
DROP PROCEDURE build_dec8_table;
/

create procedure build_dec8_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128) THEN
      insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_dec8_table();
/

delimiter ;/

