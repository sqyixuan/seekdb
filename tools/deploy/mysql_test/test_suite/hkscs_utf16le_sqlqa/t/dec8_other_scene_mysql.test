--echo #### 正交数据类型 ### 
drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(1),
    nchar_column NATIONAL CHAR(1),
    varchar_column VARCHAR(1),
    nvarchar_column NATIONAL VARCHAR(1),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = dec8;

--error 0,1305
DROP PROCEDURE build_dec8_table;
delimiter /;
create procedure build_dec8_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128|| (i >= 0xA1 && i < 0xE0) ) THEN
      insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_dec8_table();
/
delimiter ;/
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (_dec8 0x878A,_dec8 0x878A,_dec8 0x878A,_dec8 0x878A,_dec8 0x878A,_dec8 0x878A);
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (0x9373,0x9373,0x9373,0x9373,0x9373,0x9373);
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (0xF1F2,0xF1F2,0xF1F2,0xF1F2,0xF1F2,0xF1F2);

SET @longdec8String = REPEAT(_dec8 0x878A, 255); 
SET @longBlobData = REPEAT(_dec8 0x9373, 1024*1024); 

UPDATE t1
SET 
    char_column = _dec8 0x878A,       
    nchar_column = _dec8 0x878A,      
    varchar_column = @longdec8String, 
    nvarchar_column = @longdec8String,
    text_column = @longdec8String,    
    blob_column = @longBlobData;      
    
--disable_result_log
SELECT * FROM t1;
--enable_result_log

