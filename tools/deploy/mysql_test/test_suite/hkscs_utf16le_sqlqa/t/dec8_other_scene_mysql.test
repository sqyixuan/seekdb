CREATE TABLE t1 AS
SELECT concat(head, tail) AS code
FROM head, tail
WHERE (head BETWEEN 'D9' AND 'DB')
AND   (tail BETWEEN 'FA' AND 'FF')
ORDER BY head, tail;
