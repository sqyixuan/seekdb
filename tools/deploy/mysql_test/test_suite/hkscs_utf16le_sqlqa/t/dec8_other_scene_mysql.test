select * from t1 order by id;
SELECT CONVERT(blob_column USING dec8) AS char_value FROM t1;
SELECT CAST(blob_column AS CHAR CHARSET dec8) AS string_value FROM t1;
SELECT CAST(blob_column AS CHAR CHARSET UTF8) AS string_value FROM t1;
SELECT CONVERT(text_column USING dec8) AS char_value FROM t1;
SELECT CAST(text_column AS CHAR CHARSET dec8) AS string_value FROM t1;
SELECT CAST(text_column AS CHAR CHARSET UTF8) AS string_value FROM t1;
--error 1051
