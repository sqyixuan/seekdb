purge recyclebin;
### --source mysql_test/test_suite/hkscs_utf16le_sqlqa/include/big_test.inc
#
# Tests with the sjis character set
#
--disable_warnings
drop table if exists t1;
--enable_warnings

set names sjis;
### --character_set sjis

#
# Test problem with LEFT()
#
--error 0,1051
drop table t1;
create table t1 (c text character set sjis);
insert into t1 values (0xa4a2),(0xa4a3);
select hex(left(c,1)) from t1 group by c;
drop table t1;

#
#
#
select locate(0xa2a1,0xa1a2a1a3);
select locate(_sjis 0xa2a1,_sjis 0xa1a2a1a3);
select locate(_sjis 0xa2a1,_sjis 0xa1a2a1a3 collate sjis_bin);
select locate('he','hello');
select locate('he','hello',2);
select locate('lo','hello',2);
select locate('HE','hello');
select locate('HE','hello',2);
select locate('LO','hello',2);
select locate('HE','hello' collate sjis_bin);
select locate('HE','hello' collate sjis_bin,2);
select locate('LO','hello' collate sjis_bin,2);
select locate(_sjis 0xa1a3,_sjis 0xa1a2a1a3);

select 0xa1a2a1a3 like concat(_binary'%',0xa2a1,_binary'%');
select _sjis 0xa1a2a1a3 like concat(_sjis'%',_sjis 0xa2a1, _sjis'%');

### ˝áąű˛»Ň»ÖÂˇŁ´ýČ·ČĎˇŁ
select _sjis 0xa1a2a1a3 like concat(_sjis'%',_sjis 0xa2a1, _sjis'%') collate sjis_bin;
select 'a' like 'a';
select 'A' like 'a';
select 'A' like 'a' collate sjis_bin;

#
# Bug 3290: Hald-width Katakana conversion problem.
# Check sjis-utf8-sjis round trip.
#
set @sjis1= _sjis     0x8EA18EA28EA38EA48EA58EA68EA78EA88EA98EAA8EAB8EAC8EAD8EAE8EAF;
set @sjis2= _sjis 0x8EB08EB18EB28EB38EB48EB58EB68EB78EB88EB98EBA8EBB8EBC8EBD8EBE8EBF;
set @sjis3= _sjis 0x8EC08EC18EC28EC38EC48EC58EC68EC78EC88EC98ECA8ECB8ECC8ECD8ECE8ECF;
set @sjis4= _sjis 0x8ED08ED18ED28ED38ED48ED58ED68ED78ED88ED98EDA8EDB8EDC8EDD8EDE8EDF;

select hex(@utf81:= CONVERT(@sjis1 USING utf8));
select hex(@utf82:= CONVERT(@sjis2 USING utf8));
select hex(@utf83:= CONVERT(@sjis3 USING utf8));
select hex(@utf84:= CONVERT(@sjis4 USING utf8));

select @sjis1 = CONVERT(@utf81 USING sjis);
select @sjis2 = CONVERT(@utf82 USING sjis);
select @sjis3 = CONVERT(@utf83 USING sjis);
select @sjis4 = CONVERT(@utf84 USING sjis);

#
# Testing with '%' and index (Bug #3438)
#

drop table if exists t1;
create table t1 (c1 varchar(8)) default character set 'sjis';
insert into t1 values (0xA4A2),(0xA2A2),(0xA4A2);
select c1 as 'no index' from t1 where c1 like cast(concat(0xA4A2, '%') as char character set sjis);
create index idx_c1 on t1(c1);
select c1 as 'using index' from t1 where c1 like cast(concat(0xA4A2, '%') as char character set sjis);
select c1 as 'no index' from t1 where c1 like cast(concat('%',0xA4A2, '%') as char character set sjis);
drop table t1;

