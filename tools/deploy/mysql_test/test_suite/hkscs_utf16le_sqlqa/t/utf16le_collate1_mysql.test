drop procedure build_utf16le_table;

delimiter /;
create procedure build_utf16le_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_utf16le_bak(c0,c1) values(unhex(hex(i)),unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

