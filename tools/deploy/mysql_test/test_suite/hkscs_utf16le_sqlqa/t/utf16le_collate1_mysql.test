purge recyclebin;
--result_format 4
--echo #Environmental cleaning

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##设置并查看当前字符集设置
### set names 'utf16le';
set character_set_database = 'utf16le';
set character_set_server = 'utf16le';
set character_set_results = 'utf8mb4';
show character set where Charset = 'utf16le';
show variables like 'character_set%';

--echo ###### all expr
--echo # create table for test
--result_format 4
show variables like '%char%';
show variables like '%coll%';

--echo ===================================================test basic code ==================================================

--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf16le;
use db1;

--error 0,1051
drop table utf16le_table;
--error 0,1305
drop procedure build_utf16le_table;
--error 0,1051
drop table utf16le_bin_table;
--error 0,1305
drop procedure build_utf16le_bin_table;

create table utf16le_table(c1 char(30) charset utf16le collate utf16le_general_ci);
create table utf16le_bin_table(c1 char(30) charset utf16le collate utf16le_bin);

--error 0,1305
DROP PROCEDURE build_utf16le_table;

delimiter /;
create procedure build_utf16le_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into utf16le_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_utf16le_table();
/
delimiter ;/

