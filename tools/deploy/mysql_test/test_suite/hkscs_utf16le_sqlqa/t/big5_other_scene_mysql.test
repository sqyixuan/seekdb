purge recyclebin;
--result_format 4
--echo #Environmental cleaning

###?置超???
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##?置并查看?前字符集?置
set names 'big5';
set character_set_database = 'big5';
set character_set_server = 'big5';
set character_set_results = 'UTF8MB4';
show character set where Charset = 'big5';
show variables like 'character_set%';
--enable_sorted_result

--echo ############################# 字符?型 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET big5;
use db1;

--error 0,1051
drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(100),
    nchar_column NATIONAL CHAR(100),
    varchar_column VARCHAR(100),
    nvarchar_column NATIONAL VARCHAR(100),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = big5;

--error 0,1305
DROP PROCEDURE build_big5_table;

delimiter /;

create procedure build_big5_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128) THEN
      insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_big5_table();
/

delimiter ;/

insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (_big5 0x44,_big5 0x44,_big5 0x44,_big5 0x44,_big5 0x44,_big5 0x44);
