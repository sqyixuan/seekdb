--echo ### 常用函??? ### 

SELECT CONVERT(code USING utf8) FROM T_TEST ORDER BY 1;
SELECT CONVERT(code USING big5) FROM T_TEST ORDER BY 1;
SELECT BINARY code FROM T_TEST ORDER BY 1;
SELECT ASCII(code) FROM T_TEST ORDER BY 1;

SELECT CODE,CHAR(CODE USING big5) FROM T_TEST ORDER BY 1;
SELECT HEX(CODE),HEX(CHAR(CODE USING big5)) FROM T_TEST ORDER BY 1;
SELECT UNHEX(HEX(CODE)),UNHEX(HEX(CHAR(CODE USING big5))) FROM T_TEST ORDER BY 1;

SELECT CHAR(CODE USING big5) FROM T_TEST ORDER BY 1;

SELECT CAST(code AS CHAR CHARSET utf8) FROM T_TEST ORDER BY 1;
SELECT CAST(code AS CHAR CHARSET big5) FROM T_TEST ORDER BY 1;
SELECT LOCATE('substr', code) FROM T_TEST ORDER BY 1;
SELECT LOCATE('substr', code, 3) FROM T_TEST ORDER BY 1;
SELECT SUBSTR(code, 2, 5) FROM T_TEST ORDER BY 1;
SELECT LTRIM(code) FROM T_TEST ORDER BY 1;
SELECT RTRIM(code) FROM T_TEST ORDER BY 1;

