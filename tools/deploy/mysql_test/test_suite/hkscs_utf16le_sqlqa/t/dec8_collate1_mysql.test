--error 0,1051
drop table test_dec8_bak;
create table test_dec8_bak(c0 varchar(100) collate dec8_swedish_ci,c1 varchar(100) collate dec8_bin,c2 varchar(100) collate dec8_swedish_ci,c3 varchar(100) collate dec8_bin,c4 varchar(100) collate utf8mb4_unicode_ci,c5 varchar(100) collate dec8_swedish_ci,c6 varchar(100) collate dec8_bin,sal int,id int) character set dec8;

--error 0,1305
drop procedure test_dec8_bak_ascii_pro;

delimiter /;
create procedure test_dec8_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_dec8_bak values(char(i),char(i),char(i),char(i),char(i),char(i),char(i),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call test_dec8_bak_ascii_pro();
/

delimiter ;/
