--echo #Environmental cleaning
connection default;
purge recyclebin;

--disable_query_log
connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;
--disable_warnings
#call oceanbase.drop_tenant('tenant_charset_test');
--enable_warnings
#call oceanbase.create_mysql_tenant_1c2g_with_arg('tenant_charset_test','charset=dec8');
--source mysql_test/test_suite/hkscs_utf16le_sqlqa/include/conn_tenant_mysql.inc
--result_format 4
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
SET sql_mode = '';

###?置并查看?前字符集?置
set names 'dec8';
set character_set_database = 'dec8';
set character_set_server = 'dec8';
set character_set_results = 'utf8mb4';
show character set where Charset = 'dec8';
show variables like 'character_set%';
--enable_query_log

--echo ===================================================test basic code ==================================================

--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET dec8;
use db1;

--error 0,1051
drop table dec8_table;
--error 0,1305
drop procedure build_dec8_table;
--error 0,1051
drop table dec8_bin_table;
--error 0,1305
drop procedure build_dec8_bin_table;

create table dec8_table(c1 char(30) charset dec8 collate dec8_swedish_ci);
create table dec8_bin_table(c1 char(30) charset dec8 collate dec8_bin);

--error 0,1305
DROP PROCEDURE build_dec8_table;

delimiter /;
create procedure build_dec8_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128|| (i >= 0xA1 && i < 0xE0) ) THEN
      insert into dec8_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_dec8_table();
/
delimiter ;/

