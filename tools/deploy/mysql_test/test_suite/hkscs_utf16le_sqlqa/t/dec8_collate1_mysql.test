CREATE TABLE test_dec8_bak(
    c0 TEXT COLLATE dec8_swedish_ci,
    c1 TEXT COLLATE dec8_bin,
    c2 TEXT COLLATE dec8_swedish_ci,
    c3 TEXT COLLATE dec8_bin,
    c4 TEXT COLLATE utf8mb4_unicode_ci,
    c5 TEXT COLLATE dec8_swedish_ci,
    c6 TEXT COLLATE dec8_bin,
    sal INT,
    id INT
) CHARACTER SET dec8;

--error 0,1305
drop procedure test_dec8_bak_ascii_pro;

delimiter /;
CREATE PROCEDURE test_dec8_bak_ascii_pro()
BEGIN
  DECLARE i INT DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO test_dec8_bak(c0, c1, c2, c3, c4, c5, c6, sal, id)
    VALUES(CONVERT(CHAR(i) USING dec8), CONVERT(CHAR(i) USING dec8), CONVERT(CHAR(i) USING dec8), CONVERT(CHAR(i) USING dec8), CONVERT(CHAR(i) USING dec8), CONVERT(CHAR(i) USING dec8), CONVERT(CHAR(i) USING dec8), i, i);
    SET i = i + 1;
  END WHILE;
  COMMIT;
END /
DELIMITER ;/

CALL test_dec8_bak_ascii_pro();
