--error 0,1305
DROP PROCEDURE build_dec8_bin_table;

delimiter /;
create procedure build_dec8_bin_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128|| (i >= 0xA1 && i < 0xE0) ) THEN
      insert into dec8_bin_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_dec8_bin_table();
/
