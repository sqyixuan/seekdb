--error 0,1305
DROP PROCEDURE create_big5;
delimiter //;
CREATE PROCEDURE create_big5()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a like char(i) order by t1.id;
    set i = i + 1;
  END WHILE;
END;
//
delimiter ;//

call create_big5();

#与函?的嵌套使用??
