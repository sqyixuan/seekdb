DROP TABLE t1;

--echo #
--echo # Check prepare statement from an dec8 string
--echo #
SET NAMES latin1;
SET @ivar= 1234;
SET @str1 = 'SELECT ?';
SET @str2 = CONVERT(@str1 USING dec8);
PREPARE stmt1 FROM @str2;
EXECUTE stmt1 USING @ivar;

--echo #
--echo # Check that dec8 works with ENUM and SET type
--echo #
SET NAMES utf8, collation_connection=dec8_swedish_ci;
CREATE TABLE t1 (a ENUM('x','y','z') CHARACTER SET dec8);
SHOW CREATE TABLE t1;
INSERT INTO t1 VALUES ('x');
INSERT INTO t1 VALUES ('y');
INSERT INTO t1 VALUES ('z');
SELECT a, HEX(a) FROM t1 ORDER BY a;

--error 1366
