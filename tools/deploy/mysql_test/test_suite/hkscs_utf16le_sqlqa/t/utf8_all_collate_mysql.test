SELECT * FROM UTF16_VIETNAMESE_CI ORDER BY c1 COLLATE UTF16_VIETNAMESE_CI;
SELECT c1, HEX(c1), HEX(@u:=CONVERT(c1 USING utf8mb4)) FROM UTF16_VIETNAMESE_CI ORDER BY c1;
SELECT DISTINCT c1 FROM UTF16_VIETNAMESE_CI ORDER BY 1;
SELECT COUNT(*), c1 FROM UTF16_VIETNAMESE_CI GROUP BY c1 ORDER BY 2, 1;
SELECT COUNT(*), c1 FROM UTF16_VIETNAMESE_CI GROUP BY c1 HAVING c1 > 'null' ORDER BY 2, 1;
SELECT * FROM UTF16_VIETNAMESE_CI ORDER BY 1;
SELECT * FROM UTF16_VIETNAMESE_CI ORDER BY 1 DESC;
SELECT c1 FROM UTF16_VIETNAMESE_CI WHERE c1 LIKE '%N%' ORDER BY 1;
SELECT c1 FROM UTF16_VIETNAMESE_CI WHERE c1 LIKE '%12%' ORDER BY c1;
SELECT c1 FROM UTF16_VIETNAMESE_CI WHERE c1 LIKE '%abc%' ORDER BY c1;
SELECT c1 FROM UTF16_VIETNAMESE_CI WHERE c1 LIKE '%中文abc%' ORDER BY c1;
SELECT c1 FROM UTF16_VIETNAMESE_CI WHERE c1 NOT LIKE '%N%' ORDER BY c1;
SELECT c1 FROM UTF16_VIETNAMESE_CI WHERE c1 NOT LIKE '%12%' ORDER BY c1;
SELECT c1 FROM UTF16_VIETNAMESE_CI WHERE c1 NOT LIKE '%abc%' ORDER BY c1;
SELECT c1 FROM UTF16_VIETNAMESE_CI WHERE c1 NOT LIKE '%中文abc%' ORDER BY c1;
SELECT c1 FROM UTF16_VIETNAMESE_CI WHERE c1 IN ('A', 'abc&ABC', 'ABC ABC', 'B', '123') ORDER BY c1;
SELECT c1 FROM UTF16_VIETNAMESE_CI WHERE c1 NOT IN ('A', 'abc&ABC', 'ABC ABC', 'B', '123') ORDER BY c1;
SELECT c1 FROM UTF16_VIETNAMESE_CI WHERE c1 = '' ORDER BY c1;
SELECT c1 FROM UTF16_VIETNAMESE_CI WHERE c1 = 'null' ORDER BY c1;

