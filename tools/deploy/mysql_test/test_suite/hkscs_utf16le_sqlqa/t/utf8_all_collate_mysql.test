purge recyclebin;
--result_format 4
--echo #Environmental cleaning
###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--echo ===================================================test basic code ==================================================
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET UTF8MB4;
use db1;

--error 0,1051
drop table UTF8_table;
create table UTF8_table(c1 char(100) charset utf8mb4 collate utf8mb4_general_ci);
INSERT INTO UTF8_table(c1) VALUES (QUOTE('僜'));
INSERT INTO UTF8_table(c1) VALUES (_utf8mb4 0x44);
INSERT INTO UTF8_table(c1) VALUES (_utf8mb4 0x3344);
INSERT INTO UTF8_table(c1) VALUES (_utf8mb4 0x113344);
INSERT INTO UTF8_table(c1) VALUES (0x44);
INSERT INTO UTF8_table(c1) VALUES ('фывАпролдж');
INSERT INTO UTF8_table(c1) VALUES (0x1);
INSERT INTO UTF8_table(c1) VALUES (0x111);
INSERT INTO UTF8_table(c1) VALUES (0x2020);
INSERT INTO UTF8_table(c1) VALUES ('ä');
INSERT INTO UTF8_table(c1) VALUES (HEX(SOUNDEX('#3556 in bugdb')));
INSERT INTO UTF8_table(c1) VALUES (_utf8mb4 0x041004110412);
INSERT INTO UTF8_table(c1) VALUES (HEX(CONV(CONVERT('123' USING utf8mb4), -10, 16)));
INSERT INTO UTF8_table(c1) VALUES ('1.2xxx');
INSERT INTO UTF8_table(c1) VALUES ('abc');
INSERT INTO UTF8_table(c1) VALUES ('匲匳');
INSERT INTO UTF8_table(c1) VALUES ("3401200");
INSERT INTO UTF8_table(c1) VALUES (HEX(CONVERT(0xAA USING utf8mb4)));
INSERT INTO UTF8_table(c1) VALUES ('中文字符123');
INSERT INTO UTF8_table(c1) VALUES ('中文abc字符');
INSERT INTO UTF8_table(c1) VALUES ('abc中文字符123');
INSERT INTO UTF8_table(c1) VALUES ('ABC中文字符123');
INSERT INTO UTF8_table(c1) VALUES ('中文ABC字符');
INSERT INTO UTF8_table(c1) VALUES ('');
INSERT INTO UTF8_table(c1) VALUES ('$');
INSERT INTO UTF8_table(c1) VALUES ('Y');
INSERT INTO UTF8_table(c1) VALUES ('123');
INSERT INTO UTF8_table(c1) VALUES ('Null');
INSERT INTO UTF8_table(c1) VALUES ('null');
INSERT INTO UTF8_table(c1) VALUES ('123.1');
INSERT INTO UTF8_table(c1) VALUES ('abc ABC');
INSERT INTO UTF8_table(c1) VALUES ('abc&ABC');
INSERT INTO UTF8_table(c1) VALUES ('2010-11-11');

select * from UTF8_table order by c1 collate utf8mb4_general_ci;
SELECT c1,hex(c1),hex(@u:=convert(c1 using utf8mb4)) FROM UTF8_table order by c1;
select distinct c1 from UTF8_table order by 1;
select count(*),c1 from UTF8_table group by c1 order by 2,1;
select count(*),c1 from UTF8_table group by c1 having c1 > 'null' order by 2,1;
select * from UTF8_table order by 1;
select * from UTF8_table order by 1 desc;
select c1 from UTF8_table where c1 like '%N%' order by c1;
select c1 from UTF8_table where c1 like '%12%' order by c1;
select c1 from UTF8_table where c1 like '%abc%' order by c1;
select c1 from UTF8_table where c1 like '%中文abc%' order by c1;
select c1 from UTF8_table where c1 not like '%N%' order by c1;
select c1 from UTF8_table where c1 not like '%12%' order by c1;
select c1 from UTF8_table where c1 not like '%abc%' order by c1;
select c1 from UTF8_table where c1 not like '%中文abc%' order by c1;
select c1 from UTF8_table where c1 in ('A','abc&ABC','ABC ABC','B','123') order by c1;
select c1 from UTF8_table where c1 not in ('A','abc&ABC','ABC ABC','B','123') order by c1;
select c1 from UTF8_table where c1 = '' order by c1;
select c1 from UTF8_table where c1 = 'null' order by c1;

