purge recyclebin;

# Test takes long time to run on valgrind due to Bug#17022890
# Run on valgrind only if --big-test is specified
# This has to be removed along with the fix for Bug#17022890
### --source mysql_test/test_suite/hkscs_utf16le_sqlqa/include/no_valgrind_without_big.inc

#
# Tests with the big5 character set
#
--disable_warnings
drop table if exists t1;
--enable_warnings

SET @test_character_set= 'big5';
SET @test_collation= 'big5_chinese_ci';
--source mysql_test/test_suite/hkscs_utf16le_sqlqa/include/ctype_common.inc

SET NAMES big5;
### --character_set big5

SET collation_connection='big5_chinese_ci';
--source mysql_test/test_suite/hkscs_utf16le_sqlqa/include/ctype_filesort.inc
--source mysql_test/test_suite/hkscs_utf16le_sqlqa/include/ctype_innodb_like.inc
--source mysql_test/test_suite/hkscs_utf16le_sqlqa/include/ctype_like_escape.inc
--source mysql_test/test_suite/hkscs_utf16le_sqlqa/include/ctype_like_range_f1f2.inc
--source mysql_test/test_suite/hkscs_utf16le_sqlqa/include/ctype_ascii_order.inc
SET collation_connection='big5_bin';
--source mysql_test/test_suite/hkscs_utf16le_sqlqa/include/ctype_filesort.inc
--source mysql_test/test_suite/hkscs_utf16le_sqlqa/include/ctype_innodb_like.inc
--source mysql_test/test_suite/hkscs_utf16le_sqlqa/include/ctype_like_escape.inc
--source mysql_test/test_suite/hkscs_utf16le_sqlqa/include/ctype_like_range_f1f2.inc

#
# Bugs#9357: TEXT columns break string with special word in BIG5 charset.
#
SET NAMES big5;
CREATE TABLE t1 (a text) character set big5;

INSERT INTO t1 VALUES ('ùØ');
SELECT * FROM t1;
DROP TABLE t1;

