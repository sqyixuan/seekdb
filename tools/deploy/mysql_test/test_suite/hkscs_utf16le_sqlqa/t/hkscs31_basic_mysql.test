set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";

--echo -------------------test charset function----------------------
--error 1273
select weight_string(_hkscs31 'a' collate hkscs31_chinese_ci ), weight_string(_hkscs31 'A' collate hkscs31_chinese_ci );
select weight_string(_hkscs31 'a' collate hkscs31_bin), weight_string(_hkscs31 'A' collate hkscs31_bin);

set collation_connection = hkscs31_bin;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');

SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a = 'v';
SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a like '%v%';
SELECT HEX(cx), cy
FROM (SELECT GROUP_CONCAT(a ORDER BY binary a SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(a) ORDER BY BINARY a) AS cy
      FROM t1
      GROUP BY a
     ) AS dt order by cy;

set names hkscs31;
--error 0,1051
drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100) charset hkscs31 collate hkscs31_bin);

--error 0,1305
DROP PROCEDURE build_hkscs31_table;

delimiter /;
create procedure build_hkscs31_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_hkscs31_table();
/
