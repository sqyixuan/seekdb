# 原生MYSQL 迁移 case，dec8相关。
# Tests with the dec8 character set
#
### --source include/no_valgrind_without_big.inc
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET dec8;
use db1;
set names dec8;

select 'a' like 'a';
select 'A' like 'a';
select 'A' like 'a' collate dec8_bin;

### OB必现丢失连接，bug/57696740# 《【TIS620】set names 'utf8mb4';时SET变量值为_tis620值，OB必现丢失连接（无core），MYSQL正常无报错。》
### set @dec81= _dec8   0xa1a2a3a4a5a6a7a8a9aaabacadaeaf;
### set @dec82= _dec8 0xb0b1b2b3b4b5b6b7b8b9babbbcbdbebf;
### set @dec83= _dec8 0xc0c1c2c3c4c5c6c7c8c9cacbcccdcecf;
### set @dec84= _dec8 0xd0d1d2d3d4d5d6d7d8d9dadbdcdddedf;
### 
### set @utf81= CONVERT(@dec81 USING utf8);
### set @utf82= CONVERT(@dec82 USING utf8);
### set @utf83= CONVERT(@dec83 USING utf8);
### set @utf84= CONVERT(@dec84 USING utf8);
### 
### select hex(@utf81);
### select hex(@utf82);
### select hex(@utf83);
### select hex(@utf84);
### 
### select hex(CONVERT(@utf81 USING dec8));
### select hex(CONVERT(@utf82 USING dec8));
### select hex(CONVERT(@utf83 USING dec8));
### select hex(CONVERT(@utf84 USING dec8));

SET NAMES dec8;
SELECT 'a' LIKE 'a';
SELECT 'A' LIKE 'a';
SELECT 'A' LIKE 'a';
SET @dec8_1 = CHAR(161, 162, 163, 164, 165, 166, 167, 168, 169, 170, 171, 172, 173, 174, 175, 176);
SET @dec8_2 = CHAR(177, 178, 179, 180, 181, 182, 183, 184, 185, 186, 187, 188, 189, 190, 191, 192);
SET @dec8_3 = CHAR(193, 194, 195, 196, 197, 198, 199, 200, 201, 202, 203, 204, 205, 206, 207, 208);
SET @dec8_4 = CHAR(209, 210, 211, 212, 213, 214, 215, 216, 217, 218, 219, 220, 221, 222, 223, 224);

SET @utf8_1 = CONVERT(@dec8_1 USING utf8);
SET @utf8_2 = CONVERT(@dec8_2 USING utf8);
SET @utf8_3 = CONVERT(@dec8_3 USING utf8);
SET @utf8_4 = CONVERT(@dec8_4 USING utf8);

SELECT HEX(@utf8_1);
SELECT HEX(@utf8_2);
SELECT HEX(@utf8_3);
SELECT HEX(@utf8_4);

SELECT HEX(CONVERT(@utf8_1 USING dec8));
SELECT HEX(CONVERT(@utf8_2 USING dec8));
SELECT HEX(CONVERT(@utf8_3 USING dec8));
SELECT HEX(CONVERT(@utf8_4 USING dec8));

set names dec8;
select 'a' like 'a';
select 'A' like 'a';
select 'A' like 'a' collate dec8_bin;

