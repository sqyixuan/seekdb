--echo #
--echo # Testing WL#4583 Case conversion in Asian character sets 
--echo #
#
# Populate t1 with all hex digits
#
SET NAMES utf8;
SET collation_connection=dec8_swedish_ci;
CREATE TABLE t1 (b VARCHAR(2));
INSERT INTO t1 VALUES ('0'),('1'),('2'),('3'),('4'),('5'),('6'),('7');
INSERT INTO t1 VALUES ('8'),('9'),('A'),('B'),('C'),('D'),('E'),('F');
#
# Populate tables head and tail with values '00'-'FF'
#
--ERROR 0,1051
DROP TABLE head;
--ERROR 0,1051
DROP TABLE tail;

CREATE  TABLE head AS SELECT concat(b1.b, b2.b) AS head FROM t1 b1, t1 b2;
CREATE  TABLE tail AS SELECT concat(b1.b, b2.b) AS tail FROM t1 b1, t1 b2;
DROP TABLE t1;
#
# Populate table t1 with all codes [80..FF][20..FF]
# excluding Half Width Kana [A1..DF]
# Expected valid dec8 codes:
# [81..9F,E0..FC][40..7E,80..fC]  (60x188=11280 characters)
#
CREATE TABLE t1 AS
SELECT concat(head, tail) AS code, ' ' AS a
FROM head, tail
WHERE (head BETWEEN '80' AND 'FF') AND (head NOT BETWEEN 'A1' AND 'DF')
AND   (tail BETWEEN '20' AND 'FF')
ORDER BY head, tail;
#
# Populate Half Width Kana: [A1..DF]
# 
INSERT t1 (code) SELECT head FROM head WHERE (head BETWEEN 'A1' AND 'DF');
DROP TABLE head, tail;

--disable_result_log
SHOW CREATE TABLE t1;
--enable_result_log
# Set max_error_count to contain number of warnings in result file.
### SET @@session.max_error_count = 64;

### UPDATE IGNORE t1 SET a=unhex(code) ORDER BY code;
### SET @@session.max_error_count = DEFAULT;
SELECT COUNT(*) FROM t1;
SELECT COUNT(*) FROM t1 WHERE a<>'' AND OCTET_LENGTH(a)=1;
SELECT COUNT(*) FROM t1 WHERE a<>'' AND OCTET_LENGTH(a)=2;
#
# Display all characters that have upper or lower case mapping.
#
SELECT code, hex(upper(a)), hex(lower(a)),a, upper(a), lower(a)
FROM t1
WHERE hex(a)<>hex(upper(a)) OR hex(a)<>hex(lower(a))
ORDER BY code;
#
# Make sure all possible conversion happened
#
# Expect U+212B ANGSTROM SIGN
#
SELECT * FROM t1
WHERE HEX(CAST(LOWER(a) AS CHAR CHARACTER SET utf8)) <>
      HEX(LOWER(CAST(a AS CHAR CHARACTER SET utf8))) ORDER BY code;
#
# Expect no results
#
SELECT * FROM t1
WHERE HEX(CAST(UPPER(a) AS CHAR CHARACTER SET utf8)) <>
      HEX(UPPER(CAST(a AS CHAR CHARACTER SET utf8))) ORDER BY code;

--echo #
--echo # WL#3090 Japanese Character Set adjustments
--echo # Test dec8->Unicode conversion
--echo #
SELECT HEX(a), HEX(CONVERT(a USING utf8)) as b FROM t1 ORDER BY 1;
SELECT HEX(a), HEX(CONVERT(a USING utf8)) as b FROM t1
WHERE a<>'' ORDER BY 1;

SELECT HEX(a), HEX(CONVERT(a USING utf8)) as b FROM t1
WHERE a<>'' HAVING b<>'3F' ORDER BY code;
SELECT HEX(a), HEX(CONVERT(a USING utf8mb4)) as b FROM t1
WHERE a<>'' HAVING b='3F' ORDER BY code;
SELECT a,HEX(a), HEX(CONVERT(a USING utf8mb4)) as b FROM t1
WHERE a<>'' HAVING HEX(a)='FF' ORDER BY code;

DROP TABLE t1;

--echo #
--echo # WL#3090 Japanese Character Set adjustments
--echo # Test Unicode->dec8 conversion
--echo #
### --source include/ctype_utf8_table.inc

CREATE TABLE t1 (a CHAR(1)) CHARACTER SET utf8;
INSERT INTO t1 VALUES ('0'),('1'),('2'),('3'),('4'),('5'),('6'),('7');
INSERT INTO t1 VALUES ('8'),('9'),('A'),('B'),('C'),('D'),('E'),('F');

--disable_warnings
#
# Populate tables head and tail with values '00'-'FF'
#

--ERROR 0,1051
DROP TABLE head;
--ERROR 0,1051
DROP TABLE tail;
--ERROR 0,1051
DROP TABLE middle;

CREATE  TABLE head   AS SELECT concat(b1.a, b2.a) AS head   FROM t1 b1, t1 b2;
CREATE  TABLE tail   AS SELECT concat(b1.a, b2.a) AS tail   FROM t1 b1, t1 b2;
CREATE  TABLE middle AS SELECT concat(b1.a, b2.a) AS middle FROM t1 b1, t1 b2;
DROP TABLE t1;

CREATE TABLE t1 (a varchar(1)) CHARACTER SET utf8;

#
# Populate single byte characters
#

INSERT INTO t1 SELECT UNHEX(head)
FROM head WHERE (head BETWEEN '00' AND '7F') ORDER BY head;

#
# Populate 2-byte byte characters: U+80..U+7FF:  [C2-DF][80-BF]
#
INSERT INTO t1
SELECT UNHEX(CONCAT(head,tail))
FROM head, tail
WHERE (head BETWEEN 'C2' AND 'DF') AND (tail BETWEEN '80' AND 'BF')
ORDER BY head, tail;

# 
# Populate 3-byte characters: U+800..U+FFFF: [E0-EF][80-BF][80-BF] 
# excluding overlong [E0][80-9F][80-BF] and surrogate code points
# [ED][A0-BF][80-BF]
#
INSERT INTO t1
SELECT UNHEX(CONCAT(head, middle, tail))
FROM head, middle, tail
WHERE (head BETWEEN 'E0' AND 'EF') 
AND (middle BETWEEN '80' AND 'BF')
AND (tail BETWEEN '80' AND 'BF')
AND NOT (head='E0' AND middle BETWEEN '80' AND '9F')
AND NOT (head='ED' AND middle BETWEEN 'A0' AND 'BF')
ORDER BY head, middle, tail;
--enable_warnings

SELECT count(*) FROM t1;

SELECT HEX(a), HEX(CONVERT(a using dec8)) as b FROM t1 HAVING b<>'3F' ORDER BY BINARY a;
DROP TABLE t1;

--ERROR 0,1051
DROP TABLE head;
--ERROR 0,1051
DROP TABLE tail;
--ERROR 0,1051
DROP TABLE middle;

### dec8再次验证
--ERROR 0,1051
DROP TABLE t1;

CREATE TABLE t1 (a CHAR(1)) CHARACTER SET utf8;
INSERT INTO t1 VALUES ('0'),('1'),('2'),('3'),('4'),('5'),('6'),('7');
INSERT INTO t1 VALUES ('8'),('9'),('A'),('B'),('C'),('D'),('E'),('F');

DROP TABLE IF EXISTS head;
DROP TABLE IF EXISTS tail;
DROP TABLE IF EXISTS middle;

CREATE TABLE head   AS SELECT concat(b1.a, b2.a) AS head   FROM t1 b1, t1 b2;
CREATE TABLE tail   AS SELECT concat(b1.a, b2.a) AS tail   FROM t1 b1, t1 b2;
CREATE TABLE middle AS SELECT concat(b1.a, b2.a) AS middle FROM t1 b1, t1 b2;

DROP TABLE t1;
CREATE TABLE t1 (a varchar(1)) CHARACTER SET utf8;

--error 1366
INSERT INTO t1 SELECT UNHEX(head)
FROM head WHERE (head BETWEEN '00' AND '9F') ORDER BY head;
--error 1366
INSERT INTO t1 
SELECT UNHEX(CONCAT(head, tail))
FROM head, tail
WHERE (head BETWEEN 'C0' AND 'DF') AND (tail BETWEEN '80' AND 'BF')
ORDER BY head, tail;

INSERT INTO t1 
SELECT UNHEX(CONCAT(head, middle, tail))
FROM head, middle, tail
WHERE (head BETWEEN 'E0' AND 'EF') 
AND (middle BETWEEN '80' AND 'BF')
AND (tail BETWEEN '80' AND 'BF')
AND NOT (head='E0' AND middle BETWEEN '80' AND '9F')
AND NOT (head='ED' AND middle BETWEEN 'A0' AND 'BF')
ORDER BY head, middle, tail;

SELECT count(*) FROM t1;
SELECT HEX(a), HEX(CONVERT(a USING dec8)) as b FROM t1 HAVING b<>'3F' ORDER BY BINARY a;

DROP TABLE t1;
DROP TABLE head;
DROP TABLE tail;
DROP TABLE middle;

### dec8再次验证，独有字符。
--ERROR 0,1051
DROP TABLE t1;

CREATE TABLE t1 (a CHAR(1)) CHARACTER SET utf8;
INSERT INTO t1 VALUES ('0'),('1'),('2'),('3'),('4'),('5'),('6'),('7');
INSERT INTO t1 VALUES ('8'),('9'),('A'),('B'),('C'),('D'),('E'),('F');

DROP TABLE IF EXISTS head;
DROP TABLE IF EXISTS tail;
DROP TABLE IF EXISTS middle;

CREATE TABLE head   AS SELECT concat(b1.a, b2.a) AS head   FROM t1 b1, t1 b2;
CREATE TABLE tail   AS SELECT concat(b1.a, b2.a) AS tail   FROM t1 b1, t1 b2;
CREATE TABLE middle AS SELECT concat(b1.a, b2.a) AS middle FROM t1 b1, t1 b2;

DROP TABLE t1;
CREATE TABLE t1 (a varchar(20)) CHARACTER SET dec8; 
INSERT INTO t1 SELECT UNHEX(head)
FROM head WHERE (head BETWEEN '20' AND '7F') ORDER BY head;

INSERT INTO t1
SELECT UNHEX(CONCAT(head, tail))
FROM head, tail
WHERE (head BETWEEN '80' AND 'FF') AND (tail BETWEEN '20' AND '7F')
ORDER BY head, tail;

INSERT INTO t1
SELECT UNHEX(CONCAT(head, middle, tail))
FROM head, middle, tail
WHERE (head BETWEEN '80' AND 'FF') 
AND (middle BETWEEN '20' AND '7F')
AND (tail BETWEEN '20' AND '7F')
ORDER BY head, middle, tail LIMIT 100;

SELECT count(*) FROM t1;
--disable_result_log
SELECT HEX(a), HEX(CONVERT(a USING dec8)) as b FROM t1 HAVING b<>'3F' ORDER BY BINARY a;
--enable_result_log

DROP TABLE t1;
DROP TABLE head;
DROP TABLE tail;
DROP TABLE middle;

--echo #
--echo # End of 5.5 tests
