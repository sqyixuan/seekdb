purge recyclebin;

--result_format 4
--echo #Environmental cleaning

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##设置并查看当前字符集设置
set names 'sjis';
set character_set_database = 'sjis';
set character_set_server = 'sjis';
set character_set_results = 'utf8mb4';
show character set where Charset = 'sjis';
show variables like 'character_set%';
--enable_sorted_result

--echo # 创建租户时指定字符集，验证当前系统字符集
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET sjis;
use db1;

--error 0,1051
drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(1));

--error 0,1305
DROP PROCEDURE build_sjis_table;

delimiter /;
create procedure build_sjis_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_sjis_table();
/
delimiter ;/

INSERT INTO T1(a) VALUES (_sjis 0x878A);
INSERT INTO T1(a) VALUES (_sjis 0x9353);
INSERT INTO T1(a) VALUES (_sjis 0x9373);
INSERT INTO T1(a) VALUES (0x878A);
INSERT INTO T1(a) VALUES (0x9353);
INSERT INTO T1(a) VALUES (0x9373);
INSERT INTO T1(a) VALUES (0xb1);
INSERT INTO T1(a) VALUES (0xb2);
INSERT INTO T1(a) VALUES (0xb3);
INSERT INTO T1(a) VALUES (0xF1F2);
--error 1406
INSERT INTO T1(a) VALUES (0x8372835E);
--error 1406
INSERT INTO T1(a) VALUES (0x8352835E);
INSERT INTO T1(a) VALUES (QUOTE('僜'));

select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t1;
select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t1 order by a;

--echo -------------------test padding rule----------------------

### OB  使用MYSQL客户端连接OB，使用终端sjis字符集配置，均有同样报错1406
### bug/57949440# 《【sjis】OB 在sjis字符集链路中，向char(1)中插入1个字符+制表符报错1406》
--error 1406
insert into t1(a) values ('a\t');

insert into t1(a) values ('a '),('a  ');
select a,collation(a),hex(a) from t1 where a like "%a%";
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
select a, hex(a) from t1 where a = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select a, hex(a) from t1 where a = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";

--echo -------------------test charset function----------------------
select weight_string(_sjis 'a' collate sjis_japanese_ci), weight_string(_sjis 'A' collate sjis_japanese_ci);
select weight_string(_sjis 'a' collate sjis_bin), weight_string(_sjis 'A' collate sjis_bin);

set collation_connection = sjis_japanese_ci;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');
set collation_connection = sjis_bin;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');

SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a = 'v';
SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a like '%v%';
SELECT HEX(cx), cy
FROM (SELECT GROUP_CONCAT(a ORDER BY binary a SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(a) ORDER BY BINARY a) AS cy
      FROM t1
      GROUP BY a
     ) AS dt order by cy;

