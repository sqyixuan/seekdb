    c0 ENUM('$', 'Y', '123', '123.1', 'abc ABC', 'abc&ABC', '2010-11-11', 'A', 'B') COLLATE utf16le_general_ci,
    c1 ENUM('$', 'Y', '123', '123.1', 'abc ABC', 'abc&ABC', '2010-11-11', 'A', 'B') COLLATE utf16le_bin,
    c2 ENUM('$', 'Y', '123', '123.1', 'abc ABC', 'abc&ABC', '2010-11-11', 'A', 'B') COLLATE utf16le_general_ci,
