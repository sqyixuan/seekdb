### SELECT c1,
###   hex(c1),
###   hex(@u:=convert(c1 using utf8mb4))
###   FROM utf16le_bin_table order by c1;
drop table test_utf16le_bak;
create table test_utf16le_bak(c0 varchar(100) collate utf16le_general_ci,c1 varchar(100) collate utf16le_bin,c2 varchar(100) collate utf16le_general_ci,c3 varchar(100) collate utf16le_bin,c4 varchar(100) collate utf8mb4_unicode_ci,c5 varchar(100) collate utf16le_general_ci,c6 varchar(100) collate utf16le_bin,sal int,id int) character set utf16le;

drop procedure test_utf16le_bak_ascii_pro;

create procedure test_utf16le_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_utf16le_bak values(char(i),char(i),char(i),char(i),char(i),char(i),char(i),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call test_utf16le_bak_ascii_pro();
/
