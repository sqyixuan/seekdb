DROP PROCEDURE build_utf16le_bin_table;

create procedure build_utf16le_bin_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into utf16le_bin_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_utf16le_bin_table();
/

