Table	Create Table
test_utf16le_bak	CREATE TABLE `test_utf16le_bak` (
  `c0` varchar(100) CHARACTER SET utf16le COLLATE utf16le_bin DEFAULT '中文',
  `c1` varchar(100) DEFAULT '字符',
  `c2` varchar(100) DEFAULT NULL,
  `c3` varchar(100) CHARACTER SET utf16le COLLATE utf16le_bin DEFAULT NULL,
  `c4` varchar(100) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `c5` varchar(100) DEFAULT NULL,
  `c6` varchar(100) CHARACTER SET utf16le COLLATE utf16le_bin DEFAULT NULL,
  `sal` int(11) DEFAULT NULL,
  `id` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf16le ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0

