### 字符序补充测试 
DROP database testob;
create database testob;
show create database testob;
Database	Create Database
testob	CREATE DATABASE `testob` DEFAULT CHARACTER SET = utf16le REPLICA_NUM = 1
use testob;
drop table cast_test_table2;
create table cast_test_table2(name varchar(10));
show create table cast_test_table2;
Table	Create Table
cast_test_table2	CREATE TABLE `cast_test_table2` (
  `name` varchar(10) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf16le ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0

use test;
drop table t1;
create table t1(c0 varchar(100) collate utf16le_general_ci) character set utf16le;
insert into t1 values('a');
insert into t1 values('A');
drop table t2;
create table t2(c0 varchar(100) collate utf16le_general_ci primary key) character set utf16le;
insert into t2 values('a');

select p.c0,e.c0 from t2 e inner join t1 p on e.c0 = p.c0 order by p.c0;
+------+----+
| c0   | c0 |
+------+----+
| a    | a  |
| A    | a  |
+------+----+
alter table t1 add constraint foreignconst1 foreign key (c0) references t2(c0);
select p.c0,e.c0 from t2 e inner join t1 p on e.c0 = p.c0 order by p.c0;
+------+----+
| c0   | c0 |
+------+----+
| a    | a  |
| A    | a  |
+------+----+
drop table t1;
drop table t2;

drop table test_utf16le_bak;
create table test_utf16le_bak(c0 char(100) collate utf16le_general_ci,c1 char(100) collate utf16le_bin,c2 char(100) collate utf16le_general_ci,c3 char(100) collate utf16le_bin,c4 char(100) collate utf8mb4_unicode_ci,c5 char(100) collate utf16le_general_ci,c6 char(100) collate utf16le_bin,sal int,id int) character set utf16le;

drop procedure test_utf16le_bak_ascii_pro;

create procedure test_utf16le_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_utf16le_bak values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
/
call test_utf16le_bak_ascii_pro();
/
