drop table test_utf16le_bak;

CREATE TABLE test_utf16le_bak(
    c0 TEXT COLLATE utf16le_general_ci,
    c1 TEXT COLLATE utf16le_bin,
    c2 TEXT COLLATE utf16le_general_ci,
    c3 TEXT COLLATE utf16le_bin,
    c4 TEXT COLLATE utf8mb4_unicode_ci,
    c5 TEXT COLLATE utf16le_general_ci,
    c6 TEXT COLLATE utf16le_bin,
    sal INT,
    id INT
) CHARACTER SET utf16le;

drop procedure test_utf16le_bak_ascii_pro;

CREATE PROCEDURE test_utf16le_bak_ascii_pro()
BEGIN
  DECLARE i INT DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO test_utf16le_bak(c0, c1, c2, c3, c4, c5, c6, sal, id)
    VALUES(CONVERT(CHAR(i) USING utf16le), CONVERT(CHAR(i) USING utf16le), CONVERT(CHAR(i) USING utf16le), CONVERT(CHAR(i) USING utf16le), CONVERT(CHAR(i) USING utf16le), CONVERT(CHAR(i) USING utf16le), CONVERT(CHAR(i) USING utf16le), i, i);
    SET i = i + 1;
  END WHILE;
  COMMIT;
END /
CALL test_utf16le_bak_ascii_pro();
