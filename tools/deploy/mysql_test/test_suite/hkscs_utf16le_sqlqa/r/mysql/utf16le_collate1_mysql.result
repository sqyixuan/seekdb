alter table test_utf16le_bak charset = gbk;
show create table test_utf16le_bak;
Table	Create Table
test_utf16le_bak	CREATE TABLE `test_utf16le_bak` (
  `c0` varchar(100) CHARACTER SET utf16le DEFAULT NULL,
  `c1` varchar(100) CHARACTER SET utf16le DEFAULT NULL,
  `full` varchar(100) CHARACTER SET utf16le COLLATE utf16le_bin GENERATED ALWAYS AS (concat(`c0`,`c1`)) VIRTUAL
) ORGANIZATION INDEX DEFAULT CHARSET = gbk ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
