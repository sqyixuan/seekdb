drop table test_utf16le_bak;

CREATE TABLE test_utf16le_bak(
    c0 SET('$', 'A', 'B') COLLATE utf16le_general_ci,
    c1 SET('$', 'A', 'B') COLLATE utf16le_bin,
    c2 SET('$', 'A', 'B') COLLATE utf16le_general_ci,
    c3 SET('$', 'A', 'B') COLLATE utf16le_bin,
    c4 SET('$', 'A', 'B') COLLATE utf8mb4_unicode_ci,
    c5 SET('$', 'A', 'B') COLLATE utf16le_general_ci,
    c6 SET('$', 'A', 'B') COLLATE utf16le_bin,
    sal INT,
    id INT
) CHARACTER SET utf16le;

INSERT INTO test_utf16le_bak (c0,c1,c2,c3,c4,c5,c6,sal) VALUES 
('A', 'A', 'A', 'A', 'A', 'A', 'A', 2300),
