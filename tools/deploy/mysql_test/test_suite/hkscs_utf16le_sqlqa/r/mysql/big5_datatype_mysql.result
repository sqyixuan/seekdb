DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    BOOL_column BOOL ,
    SMALLINT_column SMALLINT,
    BIT_column BIT
)DEFAULT CHARACTER SET = big5;

DROP PROCEDURE build_big5_table;

create procedure build_big5_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128|| (i >= 0xA1 && i < 0xE0) ) THEN
      insert into t2(BOOL_column,SMALLINT_column,BIT_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_big5_table();
/
insert into t2(BOOL_column,SMALLINT_column,BIT_column) values(1,1,1);
