DROP table t6;
CREATE TABLE t6 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    c_char char(20),
    c_int int(1),
    c_float float
)DEFAULT CHARACTER SET = big5;
select * from t6 order by id;
