purge recyclebin;
result_format: 4
#Environmental cleaning
###‰z¸m¶W??ڑV
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##‰z¸m¦}¬d¬ف?«e¦r²إ¶°‰z¸m
set names 'hkscs';
set character_set_database = 'hkscs';
set character_set_server = 'hkscs';
set character_set_results = utf8mb4;
show character set where Charset = 'hkscs';
Charset	Description	Default collation	Maxlen
hkscs	HKSCS	hkscs_bin	2
show variables like 'character_set%';
Variable_name	Value
character_sets_dir	
character_set_client	hkscs
character_set_connection	hkscs
character_set_database	hkscs
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	hkscs
character_set_system	utf8mb4
# ?«ط¯²‹ü?«ü©w¦r²إ¶°،A???«e¨t‰s¦r²إ¶°
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET hkscs;
use db1;

drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100));

DROP PROCEDURE build_hkscs_table;

create procedure build_hkscs_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<65536
  DO
    IF (i < 128 || ((i & 0xFF00) >= 0x8100 && (i & 0xFF00) <= 0xFE00) && (( (i & 0xFF) >= 0x40 && (i & 0xFF) <= 0x7E ) || ( (i & 0xFF) >= 0xa1 && (i & 0xFF) <= 0xfe ))) THEN
      insert into db1.t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_hkscs_table();
/
select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t1;
select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t1 order by a;
TRUNCATE TABLE t1;

