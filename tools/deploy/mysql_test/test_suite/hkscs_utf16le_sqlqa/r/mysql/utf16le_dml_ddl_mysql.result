########################## еӯ—з¬ҰиҪ¬жҚўдёәе…¶д»–еӯ—з¬ҰйӣҶ ########################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf16le;
use db1;
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(10)
)DEFAULT CHARACTER SET = utf16le;

DROP PROCEDURE build_utf16le_table;

create procedure build_utf16le_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_utf16le_table();
/

