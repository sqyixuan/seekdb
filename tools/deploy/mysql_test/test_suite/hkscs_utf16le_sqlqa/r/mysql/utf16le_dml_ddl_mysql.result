DROP table db2.t2;
CREATE TABLE db2.t2 (
    a char(100)
)DEFAULT CHARACTER SET = utf16le;

DROP PROCEDURE build_utf16le_table;

create procedure build_utf16le_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_utf16le_table();
/

