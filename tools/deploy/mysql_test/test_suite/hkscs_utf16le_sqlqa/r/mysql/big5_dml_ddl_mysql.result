#Environmental cleaning
purge recyclebin;
result_format: 4
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
SET sql_mode = '';

###?╕mж}мdм▌?лeжr▓┼╢░?╕m
set names 'big5';
set character_set_database = 'big5';
set character_set_server = 'big5';
set character_set_results = 'utf8mb4';
show character set where Charset = 'big5';
Charset	Description	Default collation	Maxlen
big5	BIG5	big5_chinese_ci	2
show variables like 'character_set%';
Variable_name	Value
character_sets_dir	
character_set_client	big5
character_set_connection	big5
character_set_database	big5
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	big5
character_set_system	utf8mb4
########################## select ########################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET big5;
use db1;

DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(100)
)DEFAULT CHARACTER SET = big5;

DROP PROCEDURE build_big5_table;

create procedure build_big5_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_big5_table();
/

