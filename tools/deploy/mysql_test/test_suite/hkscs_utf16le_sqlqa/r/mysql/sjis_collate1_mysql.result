DROP database testob;
create database testob;
show create database testob;
Database	Create Database
testob	CREATE DATABASE `testob` DEFAULT CHARACTER SET = sjis REPLICA_NUM = 1
use testob;
drop table cast_test_table2;
create table cast_test_table2(name varchar(10));
show create table cast_test_table2;
Table	Create Table
cast_test_table2	CREATE TABLE `cast_test_table2` (
  `name` varchar(10) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = sjis ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0

use test;
drop table t1;
create table t1(c0 varchar(100) collate sjis_japanese_ci) character set sjis;
insert into t1 values('a');
insert into t1 values('A');
drop table t2;
create table t2(c0 varchar(100) collate sjis_japanese_ci primary key) character set sjis;
insert into t2 values('a');

select p.c0,e.c0 from t2 e inner join t1 p on e.c0 = p.c0 order by p.c0;
+------+----+
| c0   | c0 |
+------+----+
| a    | a  |
| A    | a  |
+------+----+
alter table t1 add constraint foreignconst1 foreign key (c0) references t2(c0);
select p.c0,e.c0 from t2 e inner join t1 p on e.c0 = p.c0 order by p.c0;
+------+----+
| c0   | c0 |
+------+----+
| a    | a  |
| A    | a  |
+------+----+
drop table t1;
drop table t2;

drop table test_sjis_bak;
create table test_sjis_bak(c0 char(100) collate sjis_japanese_ci,c1 char(100) collate utf16le_bin,c2 char(100) collate sjis_japanese_ci,c3 char(100) collate sjis_bin,c4 char(100) collate utf8mb4_unicode_ci,c5 char(100) collate sjis_japanese_ci,c6 char(100) collate utf16le_bin,sal int,id int) character set sjis;

drop procedure test_sjis_bak_ascii_pro;

create procedure test_sjis_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_sjis_bak values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
/
call test_sjis_bak_ascii_pro();
/
