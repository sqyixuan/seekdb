drop table test_sjis_bak;
create table test_sjis_bak(c0 varchar(100),c1 varchar(100),full varchar(100) collate sjis_bin generated always as(concat(c0,c1)) ) character set sjis;

drop procedure build_sjis_table;

create procedure build_sjis_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_sjis_bak(c0,c1) values(unhex(hex(i)),unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_sjis_table();
/
