drop table test_sjis_bak;
create table test_sjis_bak(c0 varchar(100) collate utf16le_general_ci,c1 varchar(100) collate utf16le_bin,c2 varchar(100) collate sjis_japanese_ci,c3 varchar(100) collate sjis_bin,c4 varchar(100) collate utf8mb4_unicode_ci,c5 varchar(100) collate utf16le_general_ci,c6 varchar(100) collate utf16le_bin,sal int,id int) character set sjis;

drop procedure test_sjis_bak_ascii_pro;

create procedure test_sjis_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_sjis_bak values(char(i),char(i),char(i),char(i),char(i),char(i),char(i),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call test_sjis_bak_ascii_pro();
/
