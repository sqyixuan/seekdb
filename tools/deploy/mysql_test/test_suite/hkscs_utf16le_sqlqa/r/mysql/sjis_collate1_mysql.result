INSERT INTO sjis_table(c1) VALUES (0xb2);
INSERT INTO sjis_table(c1) VALUES (0xb3);
INSERT INTO sjis_table(c1) VALUES (0xF1F2);
INSERT INTO sjis_table(c1) VALUES (0x8372835E);
INSERT INTO sjis_table(c1) VALUES (0x8352835E);
