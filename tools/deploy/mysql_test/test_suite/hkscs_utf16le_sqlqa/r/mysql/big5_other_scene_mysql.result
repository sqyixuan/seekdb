select
    t1.id,hex(t1.char_column),t1.char_column,ascii(t1.char_column)
from db1.t1 t1 ,db1.t2 t2 where t1.char_column=t2.char_column
and ascii(t1.char_column)='00'
order by id;
+----+---------------------+-------------+-----------------------+
| id | hex(t1.char_column) | char_column | ascii(t1.char_column) |
+----+---------------------+-------------+-----------------------+
|  1 | 00                  |             |                     0 |
| 33 |                     |             |                     0 |
+----+---------------------+-------------+-----------------------+

