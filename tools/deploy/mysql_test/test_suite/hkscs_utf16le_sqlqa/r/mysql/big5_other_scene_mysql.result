select
    t1.id,hex(t1.char_column),t1.char_column,t1.nchar_column,t1.varchar_column,t1.nvarchar_column,t1.text_column,t1.blob_column,
    t2.char_column,t2.varchar_column,t2.text_column,t2.blob_column
