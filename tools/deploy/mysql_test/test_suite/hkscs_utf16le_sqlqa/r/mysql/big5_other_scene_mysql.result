    t1.id,t1.char_column,t1.nchar_column,t1.varchar_column,t1.nvarchar_column,t1.text_column,t1.blob_column,
    t2.char_column,t2.varchar_column,t2.text_column,t2.blob_column
from db1.t1 t1 ,db1.t2 t2 where t1.id=t2.id order by t1.id;
