purge recyclebin;
result_format: 4
#Environmental cleaning
###и®ҫзҪ®и¶…ж—¶ж—¶й—ҙ
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##и®ҫзҪ®е№¶жҹҘзңӢеҪ“еүҚеӯ—з¬ҰйӣҶи®ҫзҪ®
### set names 'utf16le';
set character_set_database = 'utf16le';
set character_set_server = 'utf16le';
set character_set_results = 'utf8mb4';
show character set where Charset = 'utf16le';
Charset	Description	Default collation	Maxlen
utf16le	UTF-16LE Unicode	utf16le_general_ci	4
show variables like 'character_set%';
Variable_name	Value
character_sets_dir	
character_set_client	utf8mb4
character_set_connection	utf8mb4
character_set_database	utf16le
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	utf16le
character_set_system	utf8mb4
############################# еӯ—з¬Ұзұ»еһӢ #############################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf16le;
use db1;

drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(100),
    nchar_column NATIONAL CHAR(100),
    varchar_column VARCHAR(100),
    nvarchar_column NATIONAL VARCHAR(100),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = utf16le;

DROP PROCEDURE build_utf16le_table;

create procedure build_utf16le_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_utf16le_table();
/

insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (_utf16le 0x878A,_utf16le 0x878A,_utf16le 0x878A,_utf16le 0x878A,_utf16le 0x878A,_utf16le 0x878A);
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (_utf16le 0x44,_utf16le 0x44,_utf16le 0x44,_utf16le 0x44,_utf16le 0x44,_utf16le 0x44);
