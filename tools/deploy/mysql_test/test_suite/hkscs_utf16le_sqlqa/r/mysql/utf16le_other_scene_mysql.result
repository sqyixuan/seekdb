TRUNCATE TABLE t2;
select * from db1.t2;
+----+-------------+--------------+----------------+-----------------+-------------+-------------+
| id | char_column | nchar_column | varchar_column | nvarchar_column | text_column | blob_column |
+----+-------------+--------------+----------------+-----------------+-------------+-------------+
+----+-------------+--------------+----------------+-----------------+-------------+-------------+

PLжҸ’е…Ҙ
DROP PROCEDURE build_utf16le_table;

create procedure build_utf16le_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t2(char_column,varchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_utf16le_table();
/

