DROP USER 'someuser_with_utf16leзү№ж®Ҡеӯ—з¬Ұ_123456789012345678901234567890123456789012345678901234567890';
CREATE USER 'someuser_with_utf16leзү№ж®Ҡеӯ—з¬Ұ_123456789012345678901234567890123456789012345678901234567890'@'localhost' IDENTIFIED BY 'YourPassword';
ERROR HY000: String 'someuser_with_utf16leзү№ж®Ҡеӯ—з¬Ұ_123456789012345678901234567890123456789012345678901234567890' is too long for user name (should be no longer than 64)
DROP USER 'someuser_with_utf16leзү№ж®Ҡеӯ—з¬Ұ_123456789012345678901234567890123456789012345678901234567890';

DROP TABLE t_utf16le_usernames;
CREATE TABLE t_utf16le_usernames (
    id INT AUTO_INCREMENT PRIMARY KEY,
    simulated_username CHAR(255) CHARSET utf16le COLLATE utf16le_general_ci
);
INSERT INTO t_utf16le_usernames (simulated_username)
VALUES (
    CONCAT(
        REPEAT(CONVERT('гҒӮ', CHAR CHARACTER SET utf16le), 32), -- йҮҚеӨҚ32ж¬ЎпјҢзӨәдҫӢзү№ж®Ҡеӯ—з¬Ұ
        REPEAT(CONVERT('пј ', CHAR CHARACTER SET utf16le), 16), -- utf16leдёӯзҡ„зү№ж®Ҡеӯ—з¬Ұ'@'
        REPEAT(CONVERT('гғ»', CHAR CHARACTER SET utf16le), 16)  -- utf16leдёӯзҡ„зү№ж®Ҡеӯ—з¬Ұ'гғ»'
    )
);

CREATE TABLE `table_utf16leзү№ж®Ҡеӯ—з¬Ұ___________________________________________________________________` (
  `id` INT
);
