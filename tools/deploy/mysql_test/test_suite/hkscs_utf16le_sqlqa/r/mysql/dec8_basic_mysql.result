### DB????????????????
DROP DATABASE db2;
CREATE DATABASE db2;
use db2;
drop table db2.t1;
CREATE TABLE db2.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100));
DROP PROCEDURE build_dec8_table;

create procedure build_dec8_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128|| (i >= 0xA1 && i < 0xE0) ) THEN
      insert into db2.t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_dec8_table();
/


