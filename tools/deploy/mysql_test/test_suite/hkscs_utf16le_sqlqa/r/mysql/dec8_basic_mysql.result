drop database dec8_db;

set names dec8;

select collation(concat(convert("abc" using gb18030_2022), convert("cde" using dec8))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (gb18030_2022_chinese_ci,IMPLICIT), (dec8_swedish_ci,IMPLICIT)
select collation(concat(convert("abc" using gb18030), convert("cde" using dec8))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (gb18030_chinese_ci,IMPLICIT), (dec8_swedish_ci,IMPLICIT)

select collation(concat(convert("abc" using utf8), convert("cde" using dec8))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf8mb4_general_ci |
+--------------------+
select collation(concat(convert("abc" using utf16), convert("cde" using dec8))) as combined_string from dual;
+------------------+
| combined_string  |
+------------------+
| utf16_general_ci |
+------------------+
select collation(concat(convert("abc" using tis620), convert("cde" using dec8))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (tis620_thai_ci,IMPLICIT), (dec8_swedish_ci,IMPLICIT)
select collation(concat(convert("abc" using latin1), convert("cde" using dec8))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (latin1_swedish_ci,IMPLICIT), (dec8_swedish_ci,IMPLICIT)
select collation(concat(convert("abc" using ascii), convert("cde" using dec8))) as combined_string from dual;
+-----------------+
| combined_string |
+-----------------+
| dec8_swedish_ci |
+-----------------+

set names utf8mb4;
select collation(concat(convert("abc" using gb18030_2022), convert("cde" using dec8))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (gb18030_2022_chinese_ci,IMPLICIT), (dec8_swedish_ci,IMPLICIT)
select collation(concat(convert("abc" using gb18030), convert("cde" using dec8))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (gb18030_chinese_ci,IMPLICIT), (dec8_swedish_ci,IMPLICIT)

select collation(concat(convert("abc" using utf8), convert("cde" using dec8))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf8mb4_general_ci |
+--------------------+
select collation(concat(convert("abc" using utf16), convert("cde" using dec8))) as combined_string from dual;
+------------------+
| combined_string  |
+------------------+
| utf16_general_ci |
+------------------+

select collation(concat(convert("abc" using tis620), convert("cde" using dec8))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (tis620_thai_ci,IMPLICIT), (dec8_swedish_ci,IMPLICIT)
select collation(concat(convert("abc" using latin1), convert("cde" using dec8))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (latin1_swedish_ci,IMPLICIT), (dec8_swedish_ci,IMPLICIT)
select collation(concat(convert("abc" using ascii), convert("cde" using dec8))) as combined_string from dual;
