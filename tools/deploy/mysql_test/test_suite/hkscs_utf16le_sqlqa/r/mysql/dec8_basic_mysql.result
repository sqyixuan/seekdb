-------------------test charset function----------------------
select weight_string(_dec8 'a' collate dec8_swedish_ci), weight_string(_dec8 'A' collate dec8_swedish_ci);
+--------------------------------------------------+--------------------------------------------------+
| weight_string(_dec8 'a' collate dec8_swedish_ci) | weight_string(_dec8 'A' collate dec8_swedish_ci) |
+--------------------------------------------------+--------------------------------------------------+
| A                                                | A                                                |
+--------------------------------------------------+--------------------------------------------------+
select weight_string(_dec8 'a' collate dec8_bin), weight_string(_dec8 'A' collate dec8_bin);
+-------------------------------------------+-------------------------------------------+
| weight_string(_dec8 'a' collate dec8_bin) | weight_string(_dec8 'A' collate dec8_bin) |
+-------------------------------------------+-------------------------------------------+
| a                                         | A                                         |
+-------------------------------------------+-------------------------------------------+

set collation_connection = dec8_swedish_ci;
select 'abc' like 'ABC';
+------------------+
| 'abc' like 'ABC' |
+------------------+
|                1 |
+------------------+
select instr('XABCdfdabc','abc');
+---------------------------+
| instr('XABCdfdabc','abc') |
+---------------------------+
|                         2 |
+---------------------------+

set collation_connection = dec8_bin;
select 'abc' like 'ABC';
+------------------+
| 'abc' like 'ABC' |
+------------------+
|                0 |
+------------------+
select instr('XABCdfdabc','abc');
+---------------------------+
| instr('XABCdfdabc','abc') |
+---------------------------+
|                         8 |
+---------------------------+

SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a = 'v';
+------+--------+--------------------------------+
| a    | hex(a) | hex(@u:=convert(a using utf8)) |
+------+--------+--------------------------------+
| V    | 56     | 56                             |
| v    | 76     | 76                             |
+------+--------+--------------------------------+
SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a like '%v%';
+------+--------+--------------------------------+
| a    | hex(a) | hex(@u:=convert(a using utf8)) |
+------+--------+--------------------------------+
| V    | 56     | 56                             |
| v    | 76     | 76                             |
+------+--------+--------------------------------+
SELECT HEX(cx), cy
FROM (SELECT GROUP_CONCAT(a ORDER BY binary a SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(a) ORDER BY BINARY a) AS cy
