-------------------test charset function----------------------
select weight_string(_big5 'a' collate big5_chinese_ci ), weight_string(_big5 'A' collate big5_chinese_ci );
+---------------------------------------------------+---------------------------------------------------+
| weight_string(_big5 'a' collate big5_chinese_ci ) | weight_string(_big5 'A' collate big5_chinese_ci ) |
+---------------------------------------------------+---------------------------------------------------+
| A                                                 | A                                                 |
+---------------------------------------------------+---------------------------------------------------+
select weight_string(_big5 'a' collate big5_bin), weight_string(_big5 'A' collate big5_bin);
+-------------------------------------------+-------------------------------------------+
| weight_string(_big5 'a' collate big5_bin) | weight_string(_big5 'A' collate big5_bin) |
+-------------------------------------------+-------------------------------------------+
| a                                         | A                                         |
+-------------------------------------------+-------------------------------------------+

set collation_connection = big5_chinese_ci ;
select 'abc' like 'ABC';
+------------------+
| 'abc' like 'ABC' |
+------------------+
|                1 |
+------------------+
select instr('XABCdfdabc','abc');
+---------------------------+
| instr('XABCdfdabc','abc') |
+---------------------------+
|                         2 |
+---------------------------+

set collation_connection = big5_bin;
select 'abc' like 'ABC';
+------------------+
| 'abc' like 'ABC' |
+------------------+
|                0 |
+------------------+
select instr('XABCdfdabc','abc');
+---------------------------+
| instr('XABCdfdabc','abc') |
+---------------------------+
|                         8 |
+---------------------------+

SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a = 'v';
+------+--------+--------------------------------+
| a    | hex(a) | hex(@u:=convert(a using utf8)) |
+------+--------+--------------------------------+
| V    | 56     | 56                             |
| V    | 56     | 56                             |
| v    | 76     | 76                             |
| v    | 76     | 76                             |
+------+--------+--------------------------------+
SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a like '%v%';
+------+--------+--------------------------------+
| a    | hex(a) | hex(@u:=convert(a using utf8)) |
+------+--------+--------------------------------+
| V    | 56     | 56                             |
| V    | 56     | 56                             |
| v    | 76     | 76                             |
| v    | 76     | 76                             |
+------+--------+--------------------------------+
SELECT HEX(cx), cy
FROM (SELECT GROUP_CONCAT(a ORDER BY binary a SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(a) ORDER BY BINARY a) AS cy
      FROM t1
      GROUP BY a
     ) AS dt order by cy;
