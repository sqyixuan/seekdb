#
# Bug#32393 Character sets: illegal characters in dec8 columns
#
# Tests that cs->cset->wc_mb() doesn't accept surrogate parts
#
# via ALTER
#
SET sql_mode = '';
CREATE TABLE t1 (s1 VARCHAR(50) CHARACTER SET dec8);
INSERT INTO t1 VALUES (0xDF84);
ALTER TABLE t1 MODIFY column s1 VARCHAR(50) CHARACTER SET dec8;
SELECT HEX(s1) FROM t1;
HEX(s1)
DF84
DROP TABLE t1;
#
# via UPDATE
#
CREATE TABLE t1 (s1 VARCHAR(5) CHARACTER SET dec8, s2 VARCHAR(5) CHARACTER SET dec8);
INSERT INTO t1 (s1) VALUES (0xdf84);
UPDATE t1 set s2 = s1;
SELECT HEX(s2) FROM t1;
HEX(s2)
DF84
DROP TABLE t1;
SET sql_mode = default;
