purge recyclebin;
#
# Start of 5.6 tests
#
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET dec8;
use db1;
set names dec8;
SET collation_connection=dec8_swedish_ci;
SELECT HEX('a'), HEX('a ');
HEX('a')	HEX('a ')
61	6120
select 'a' = 'a', 'a' = 'a ', 'a ' = 'a';
'a' = 'a'	'a' = 'a '	'a ' = 'a'
1	1	1
select 'a\0' = 'a', 'a\0' < 'a', 'a\0' > 'a';
'a\0' = 'a'	'a\0' < 'a'	'a\0' > 'a'
0	1	0
select 'a' = 'a\0', 'a' < 'a\0', 'a' > 'a\0';
'a' = 'a\0'	'a' < 'a\0'	'a' > 'a\0'
0	0	1
select 'a\0' = 'a ', 'a\0' < 'a ', 'a\0' > 'a ';
'a\0' = 'a '	'a\0' < 'a '	'a\0' > 'a '
0	1	0
select 'a ' = 'a\0', 'a ' < 'a\0', 'a ' > 'a\0';
'a ' = 'a\0'	'a ' < 'a\0'	'a ' > 'a\0'
0	0	1
select 'a  a' > 'a', 'a  \0' < 'a';
'a  a' > 'a'	'a  \0' < 'a'
1	1
select binary 'a  a' > 'a', binary 'a  \0' > 'a', binary 'a\0' > 'a';
binary 'a  a' > 'a'	binary 'a  \0' > 'a'	binary 'a\0' > 'a'
1	1	1
#
# Check that incomplete dec8 characters in HEX notation
# are left-padded with zeros
#
SELECT HEX(_dec8 0x44);
HEX(_dec8 0x44)
44
SELECT HEX(_dec8 0x3344);
HEX(_dec8 0x3344)
3344
SELECT HEX(_dec8 0x113344);
HEX(_dec8 0x113344)
113344
#
# Check that 0x20 is only trimmed when it is
# a part of real SPACE character, not just a part
# of a multibyte sequence.
# Note, CYRILLIC LETTER ER is used as an example, which
# is stored as 0x0420 in dec8, thus contains 0x20 in the
# low byte. The second character is THREE-PER-M, U+2004,
# which contains 0x20 in the high byte.
#
DROP TABLE t1;
CREATE TABLE t1 (word VARCHAR(64), word2 CHAR(64)) CHARACTER SET dec8;
INSERT INTO t1 VALUES (_dec8 0xF2, _dec8 0xF2), (_dec8 X'2004',_dec8 X'2004');
SELECT HEX(word) FROM t1 ORDER BY word;
HEX(word)
2004
F2
SELECT HEX(word2) FROM t1 ORDER BY word2;
HEX(word2)
2004
F2
DELETE FROM t1;
#
# Check that real spaces are correctly trimmed.
#
DROP TABLE t1;
CREATE TABLE t1 SELECT
LPAD(_dec8 X'2004',10,_dec8 X'2104') l,
RPAD(_dec8 X'2004',10,_dec8 X'2104') r;
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `l` varchar(10) DEFAULT NULL,
  `r` varchar(10) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = dec8 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
SELECT HEX(l), HEX(r) FROM t1;
HEX(l)	HEX(r)
21042104210421042004	20042104210421042104
DROP TABLE t1;
CREATE TABLE t1 (f1 CHAR(30) charset dec8);
INSERT INTO t1 VALUES ("103000"), ("22720000"), ("3401200"), ("78000");
SELECT LPAD(f1, 12, "-o-/") FROM t1;
LPAD(f1, 12, "-o-/")
-o-/-o103000
-o-/22720000
-o-/-3401200
-o-/-o-78000
DROP TABLE t1;
