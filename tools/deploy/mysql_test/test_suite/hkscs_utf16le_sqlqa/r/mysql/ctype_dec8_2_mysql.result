#
# Check that INSERT() works fine.
# This invokes charpos() function.
#
CREATE TABLE t1 (
a VARCHAR(10) CHARACTER SET dec8,
b VARCHAR(10) CHARACTER SET dec8);
INSERT INTO t1 VALUES ('abc', 'def');
SELECT INSERT(a, 10, 2, b) FROM t1;
INSERT(a, 10, 2, b)
abc
SELECT INSERT(a, 1, 2, b) FROM t1;
INSERT(a, 1, 2, b)
defc
DROP TABLE t1;
#
# Check alignment for from-binary-conversion with CAST and CONVERT
#
SELECT HEX(CAST(0xAA as char CHARACTER SET dec8));
HEX(CAST(0xAA as char CHARACTER SET dec8))
AA
SELECT HEX(CONVERT(0xAA USING dec8));
HEX(CONVERT(0xAA USING dec8))
AA
