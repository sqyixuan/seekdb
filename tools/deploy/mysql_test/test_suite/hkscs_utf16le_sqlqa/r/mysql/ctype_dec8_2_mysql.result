#
# Problem found by Roy during review
# MY_CS_BINSORT was not set for dec8_bin,
# so filesort did not work well
# 
SET NAMES utf8, @@collation_connection=dec8_bin;
CREATE TABLE t1 AS SELECT REPEAT(' ', 10) as c LIMIT 0;
ALTER TABLE t1 ADD PRIMARY KEY(c);
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c` varchar(512) CHARACTER SET dec8 COLLATE dec8_bin NOT NULL,
  PRIMARY KEY (`c`)
) ORGANIZATION INDEX DEFAULT CHARSET = dec8 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
INSERT INTO t1 VALUES ('abc'),('zyx'),('acb');
SELECT UPPER(c) FROM t1 ORDER BY 1 DESC;
UPPER(c)
ZYX
ACB
ABC
DROP TABLE t1;
#
# WL#3664 WEIGHT_STRING
#
SET NAMES utf8, collation_connection=dec8_swedish_ci;
select @@collation_connection;
@@collation_connection
dec8_swedish_ci
select hex(weight_string('a'));
hex(weight_string('a'))
41
select hex(weight_string('A'));
hex(weight_string('A'))
41
select hex(weight_string('abc'));
hex(weight_string('abc'))
414243
select hex(weight_string('abc' as char(2)));
hex(weight_string('abc' as char(2)))
4142
select hex(weight_string('abc' as char(3)));
hex(weight_string('abc' as char(3)))
414243
select hex(weight_string('abc' as char(5)));
hex(weight_string('abc' as char(5)))
4142432020
SELECT HEX(WEIGHT_STRING(_dec8 0x00D800DC));
HEX(WEIGHT_STRING(_dec8 0x00D800DC))
00D80059
SELECT HEX(WEIGHT_STRING(_dec8 0x00D801DC));
HEX(WEIGHT_STRING(_dec8 0x00D801DC))
00D80159
SET NAMES utf8, collation_connection=dec8_bin;
select @@collation_connection;
@@collation_connection
dec8_bin
select hex(weight_string('a'));
hex(weight_string('a'))
61
select hex(weight_string('A'));
hex(weight_string('A'))
41
select hex(weight_string('abc'));
