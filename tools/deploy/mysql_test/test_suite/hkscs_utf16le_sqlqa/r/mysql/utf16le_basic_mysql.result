ERROR HY000: Illegal mix of collations (utf16_general_ci,IMPLICIT), (utf16le_general_ci,IMPLICIT)

select collation(concat(convert("abc" using tis620), convert("cde" using utf16le))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf16le_general_ci |
+--------------------+
select collation(concat(convert("abc" using latin1), convert("cde" using utf16le))) as combined_string from dual;
