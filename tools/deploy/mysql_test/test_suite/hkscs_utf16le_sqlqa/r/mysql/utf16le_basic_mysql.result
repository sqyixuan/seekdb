### set names utf16le;
select collation(concat(convert("abc" using gb18030_2022), convert("cde" using utf16le))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf16le_general_ci |
+--------------------+
select collation(concat(convert("abc" using gb18030), convert("cde" using utf16le))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf16le_general_ci |
+--------------------+

### OBжЧ†жК•йФЩпЉМMYSQLжЬЙжК•йФЩгАВ
select collation(concat(convert("abc" using utf8), convert("cde" using utf16le))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf8mb4_general_ci |
+--------------------+
select collation(concat(convert("abc" using utf16), convert("cde" using utf16le))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (utf16_general_ci,IMPLICIT), (utf16le_general_ci,IMPLICIT)

select collation(concat(convert("abc" using tis620), convert("cde" using utf16le))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf16le_general_ci |
+--------------------+
select collation(concat(convert("abc" using latin1), convert("cde" using utf16le))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf16le_general_ci |
+--------------------+
select collation(concat(convert("abc" using ascii), convert("cde" using utf16le))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf16le_general_ci |
+--------------------+

set names utf8mb4;
select collation(concat(convert("abc" using gb18030_2022), convert("cde" using utf16le))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf16le_general_ci |
+--------------------+
select collation(concat(convert("abc" using gb18030), convert("cde" using utf16le))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf16le_general_ci |
+--------------------+

### OBжЧ†жК•йФЩпЉМMYSQLжЬЙжК•йФЩгАВ
