# owner: sean.yyj
# owner group: SQL1
# tags: optimizer
#description: 测试order by bug：

--disable_warnings
--error 0, 942
drop table if exists t1;
--error 0, 942
drop table if exists t2;
--error 0, 942
drop table if exists t3;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int);
create table t2 (c1 int, c2 int, c3 int) partition by hash(c3) partitions 3;
create table t3 (c1 int, c2 int, c3 int);

--disable_query_log
insert into t1 values (1, 1, 1);
insert into t1 values (1, 2, 2);
insert into t1 values (1, 1, 8);
insert into t1 values (1, 2, null);
insert into t2 values (2, 1, 1);
insert into t2 values (2, 3, 1);
insert into t2 values (2, 1, null);
insert into t2 values (2, null, 1);
insert into t3 values (3, 1, 8);
insert into t3 values (3, 3, 3);
insert into t3 values (3, 1, 3);
insert into t3 values (3, null, 10);

--disable_result_log
select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
--enable_result_log
--enable_query_log

--explain_protocol 2
--result_format 4

select c1 from t2 union select c1 from t1 order by length(c1);
select c1 from t1 union all select c1 from t2 order by length(c1);
select c1 from t1 union select c2 from t2 union select c3 from t3 order by c1+1;
select * from t1 union select * from t2 union all select * from t3 order by c1*c2+length(c2)+c3+1;

--disable_warnings
drop table t1, t2, t3;
--enable_warnings
