drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
create table t1 (c1 int, c2 int, c3 int);
create table t2 (c1 int, c2 int, c3 int) partition by hash(c3) partitions 3;
create table t3 (c1 int, c2 int, c3 int);
explain_protocol: 2
result_format: 4
EXPLAIN select c1 from t2 union select c1 from t1 order by length(c1);
Query Plan
===================================================================
|ID|OPERATOR                       |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------
|0 |SORT                           |        |8       |15          |
|1 |└─HASH UNION DISTINCT          |        |8       |14          |
|2 |  ├─PX COORDINATOR             |        |4       |10          |
|3 |  │ └─EXCHANGE OUT DISTR       |:EX10000|4       |9           |
|4 |  │   └─HASH DISTINCT          |        |4       |8           |
|5 |  │     └─PX PARTITION ITERATOR|        |4       |7           |
|6 |  │       └─TABLE FULL SCAN    |t2      |4       |7           |
|7 |  └─TABLE FULL SCAN            |t1      |4       |3           |
===================================================================
