--ECHO # 游标 ，OB 不支持，mysql 支持
CREATE TABLE t1(
    stuId int primary key auto_increment,
    stuName varchar(20),
    stuSex varchar(2),
    stuAge int
);
INSERT INTO T1(STUNAME,STUSEX,STUAGE) VALUES ('小明','男',20),('小花','女',19),('大赤','男',20),('可乐','男',19),('莹莹','女',19);

DELIMITER //;
--ERROR 0,1064
CREATE PROCEDURE p1()
BEGIN
    declare id int;
    declare name varchar(100) character set utf8;
    declare done int default 0;
    declare "mc" cursor for select stuId,stuName from t1 where stuAge >19;
    declare continue handler for not found set done = 1;
    open "mc";
repeat 
    fetch mc into id,name;
	if done != 1 then
    select id,name;
	end if; 
until done end repeat;
    close "mc";
end;
//
DELIMITER ;//

# CALL p1();
# DROP PROCEDURE p1;
DROP TABLE T1;


--ECHO # 窗口函数(部分)
CREATE TABLE T1( STU_ID INT, LESSON VARCHAR(30), NAME VARCHAR(30), SCORE INT);
INSERT INTO T1 VALUES (1,'L1001','小明',90);
INSERT INTO T1 VALUES (1,'L1002','小明',80);
INSERT INTO T1 VALUES (1,'L1003','小明',88);
INSERT INTO T1 VALUES (2,'L1001','小红',50);
INSERT INTO T1 VALUES (2,'L1002','小红',66);
INSERT INTO T1 VALUES (2,'L1003','小红',68.5);
INSERT INTO T1 VALUES (3,'L1002','小紫',92);
INSERT INTO T1 VALUES (4,'L1002','小吕',95);
INSERT INTO T1 VALUES (5,'L1001','小黄',70);
INSERT INTO T1 VALUES (6,'L1001','小黑',50);
INSERT INTO T1 VALUES (1,'L1004','小明',80);
INSERT INTO T1 VALUES (1,'L1005','小明',88);

SELECT * FROM (SELECT "STU_ID", ROW_NUMBER() OVER (PARTITION BY "STU_ID" ORDER BY "SCORE" DESC) AS "score_order", LESSON, NAME, SCORE FROM T1) t WHERE t."score_order" <= 3;
SELECT * FROM (SELECT "STU_ID", DENSE_RANK() OVER (PARTITION BY "STU_ID" ORDER BY "SCORE" DESC) AS "score_order" FROM T1) t WHERE t."score_order" <= 3;
SELECT * FROM (SELECT "STU_ID", DENSE_RANK() OVER "w" AS "score_order" FROM T1 WINDOW "w" AS (PARTITION BY stu_id ORDER BY score DESC)) t WHERE t."score_order" <= 3 ; 
SELECT * FROM (SELECT ROW_NUMBER() OVER "w" AS 'rn', PERCENT_RANK() OVER "w" AS "prk", "lesson", name, score FROM T1 WINDOW "w" AS (PARTITION BY stu_id ORDER BY SCORE DESC)) t ;

DROP TABLE T1;



