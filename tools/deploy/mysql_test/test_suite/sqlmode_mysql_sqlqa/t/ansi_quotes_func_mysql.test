--ECHO # SQL 常用语法
CREATE TABLE `t1` (
  `id` int NOT NULL AUTO_INCREMENT,
  `consumer` char(20) DEFAULT NULL,
  `brand` varchar(20) DEFAULT NULL,
  `sal` int DEFAULT NULL,
  PRIMARY KEY (`id`)
);

INSERT INTO t1 VALUES(1,'书局','apple',5000);
INSERT INTO t1 VALUES(2,'微山','xiaomi',-4000);
INSERT INTO t1 VALUES(3,'深咖','oppo',0);
INSERT INTO t1 VALUES(4,'流苏','huawei',NULL);
INSERT INTO t1 VALUES(5,'玻璃','LG',6000);
INSERT INTO t1 VALUES(6,'钛钢','HTC',8000);
INSERT INTO t1 VALUES(7,'合金','VIVO',3500);

CREATE TABLE `t2` (
  `id` int NOT NULL AUTO_INCREMENT,
  `model` varchar(200) DEFAULT NULL,
  `Price` int DEFAULT NULL,
  PRIMARY KEY (`id`)
);

INSERT INTO t2 VALUES(1,'apple 12',7000);
INSERT INTO t2 VALUES(2,'xiaomi 9',0);
INSERT INTO t2 VALUES(3,'oppo findx',-6000);
INSERT INTO t2 VALUES(4,'huawei mata30',8000);
INSERT INTO t2 VALUES(5,'huawei mata30',NULL);
INSERT INTO t2 VALUES(6,'htc cc30',26.44);
INSERT INTO t2 VALUES(7,'shumei xi2',-26.44);

#SELECT
SELECT sign("e"."id") FROM t1 e;
SELECT sign(e."consumer") FROM t1 e;
SELECT sign(`e`."brand") FROM t1 e;

SELECT sign(e.sal) sal,sign(p.Price) FROM t1 e LEFT JOIN t2 "p" ON e.id = "p"."id" ORDER BY e."sal" DESC;
SELECT sign("e".sal) sal,sign(p.Price) FROM t1 "e" RIGHT JOIN t2 p ON "e".id = p.id ORDER BY e.sal DESC;
SELECT sign("e".sal) sal,sign(p.Price) FROM t1 "e" INNER JOIN t2 p ON "e".id = p.id ORDER BY e.sal DESC;
SELECT * FROM (SELECT e.id,sign(e.sal) sal,sign(p.Price) FROM t1 e LEFT JOIN t2 p ON "e".id = "p".id ) e ORDER BY "e".sal;

#ANY
SELECT *  FROM t1 e WHERE sign(e.sal) = ANY (SELECT sign("p".Price) FROM t2 "p" ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE sign(e.sal) < ANY (SELECT sign("p".Price) FROM t2 `p` ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE sign(e.sal) > ANY (SELECT sign("p".Price) FROM t2 "p" ) ORDER BY e.id;

#ALL
SELECT *  FROM t1 e WHERE sign("e".sal) < ALL (SELECT sign("p".Price) FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE sign("e".sal) > ALL (SELECT sign("p".Price) FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE sign("e".sal) = ALL (SELECT sign("p".Price) FROM t2 p WHERE p.model = 'oppo findx') ORDER BY e.id;

#EXISTS AND NOT EXISTS
SELECT *  FROM t1 "e" WHERE EXISTS (SELECT sign("p".Price) FROM t2 p ) ORDER BY e.id;
SELECT sign("e".sal)  FROM t1 "e" WHERE NOT EXISTS (SELECT p.id,"p".price FROM t2 "p" WHERE sign("p".Price)=7500 ) ORDER BY "e".id;


#CREATE AS
CREATE TABLE t3 AS SELECT * FROM t1 "e" WHERE sign("e".sal) = 1;
SELECT * FROM "t3";
drop TABLE "t3";

CREATE TABLE t3 AS SELECT * FROM t1 "e" WHERE sign("e"."sal") = 0;
SELECT *  FROM "t3";
DROP TABLE "t3";

CREATE TABLE "t3" AS SELECT * FROM t1 "e" WHERE sign("e"."sal") = NUll;
SELECT *  FROM "t3";
DROP TABLE "t3";


# LIKE
SELECT brand, sign(brand) FROM t1 e WHERE "e"."brand" LIKE '%a%';
SELECT sal, sign(sal) FROM t1 e LEFT JOIN t2 p ON "e"."id" = "p"."id" WHERE "e"."sal" LIKE '%00%';


# WHERE
SELECT * FROM t1 e WHERE sign(e."sal") = 0;
SELECT * FROM t1 e WHERE sign("e".sal) = 1;
SELECT * FROM t1 e WHERE sign(e."sal") = NULL;
SELECT * FROM t1 e WHERE sign(e."sal") > 0 ORDER BY e."id";
SELECT * FROM t1 e WHERE sign("e".sal) >= 0 ORDER BY e."id";
SELECT * FROM t1 e WHERE sign(e."sal") < 0 ORDER BY e."id";
SELECT * FROM t1 e WHERE sign("e".sal) <= 0 ORDER BY "e".id;
SELECT * FROM t1 e WHERE sign("e".sal) = 1 ORDER BY "e"."id";
SELECT * FROM t1 e WHERE sign(e."sal") <> 0 ORDER BY "e"."id";


# ORDER BY
SELECT e.id, e.sal, sign(e."sal") FROM t1 "e" WHERE `e`."id" > 0 ORDER BY sign("e".`sal`);
SELECT e.id, e.sal, sign(e.sal) FROM t1 "e" WHERE "e".id > 0 ORDER BY sign(`e`."sal") DESC;
SELECT e.id, e.sal, sign(e."brand") FROM t1 e WHERE `e`."id" > 0 ORDER BY sign("e".`brand`) ASC;
SELECT e.id, e.sal, sign(e."brand") FROM t1 e WHERE "e".`id` > 0 ORDER BY sign("e".`brand`) DESC;


#GROUP BY HAVING
SELECT e.id, sign(e.sal), SUM(e.sal+p.Price) FROM t1 e ,t2 p WHERE e.id=p.id GROUP BY "e"."id", sign("e"."sal")  ORDER BY e.id;
SELECT e.id, sign(e.sal) `tt`, SUM(e.sal+p.Price) FROM t1 e ,t2 p WHERE e.id=p.id GROUP BY "e"."id", sign("e"."sal") HAVING "tt" > -1 ORDER BY "e"."id";


#CASE WHEN
select "id", "sal", sign(case when "sal"=0 then 200 else "sal" end ) FROM t1 ORDER BY id;
select "id", `sal`, sign(case when `sal`>0 then 200 else "sal" end ) FROM t1 order by id;
select "id", `sal`, sign(case when "sal"=0 then 200 else `sal` end ), COUNT(*) FROM "t1" GROUP by sign(case when `sal`=0 then 200 else "sal" end ),`id` ORDER BY `id`;

DROP TABLE T2;
DROP TABLE T1;


--ECHO # 函数
CREATE TABLE `t1` (
  `id` int NOT NULL AUTO_INCREMENT,
  `consumer` char(20) DEFAULT NULL,
  `brand` varchar(20) DEFAULT NULL,
  `sal` int DEFAULT NULL,
  PRIMARY KEY (`id`)
);
INSERT INTO t1 VALUES(1,'书局','apple',5000);
INSERT INTO t1 VALUES(2,'微山','xiaomi',-4000);
INSERT INTO t1 VALUES(3,'深咖','oppo',0);
INSERT INTO t1 VALUES(4,'流苏','huawei',NULL);

SELECT CONCAT("CONSUMER","BRAND") FROM T1;
SELECT CONCAT(`e`."CONSUMER",`e`."BRAND") FROM T1 e;
SELECT CONCAT_WS(' ', `e`."CONSUMER",`e`."BRAND") FROM T1 e;
SELECT CONCAT_WS("e"."id", `e`."CONSUMER",`e`."BRAND") FROM T1 e;
SELECT SUBSTR("e"."brand", 2, 5) FROM T1 e;
SELECT SUBSTR("e"."brand", 2, "sal") FROM T1 e;
SELECT SUBSTRING("e"."brand", 2, "sal") FROM T1 e;
SELECT TRIM( BOTH 'i' FROM "e"."brand") FROM T1 "e";
SELECT TRIM( LEADING 'a' FROM "e"."brand") FROM T1 "e";
SELECT TRIM( TRAILING 'i' FROM "e"."brand") FROM T1 "e";
SELECT LTRIM( "e"."brand" ) FROM T1 "e";
SELECT LTRIM( '  xiaomi  ' ) FROM DUAL;
SELECT ASCII( "e"."brand"  ) FROM T1 "e";
SELECT ORD( "e"."brand"  ) FROM T1 "e";
SELECT LENGTH( "e"."brand"  ) FROM T1 "e";
SELECT CHAR_LENGTH( "e"."brand"  ) FROM T1 "e";
SELECT HEX( "e"."brand"  ) FROM T1 "e";
SELECT UPPER( "e"."brand"  ) FROM T1 "e";
SELECT LOWER( "e"."brand"  ) FROM T1 "e";
SELECT UNHEX( "e"."brand"  ) FROM T1 "e";
SELECT MD5( "e"."brand" ) FROM T1 "e";
SELECT MD5( "e"."brand"  ) FROM T1 "e" WHERE  "e"."brand" REGEXP 'ap[1,2]?.*';
SELECT REPEAT( "e"."brand", 2) FROM T1 "e";
SELECT SUBSTRING_INDEX( "e"."brand", 'o',2) FROM T1 "e";
SELECT LOCATE('o',"e"."brand") FROM T1 "e";
SELECT INSTR("e"."brand",'o') FROM T1 "e";
SELECT REPLACE("e"."brand",'a','www') FROM T1 "e";
SELECT FIELD("e"."brand",'a','app','xiaomi') FROM T1 "e";
SELECT ELT(1,"e"."brand",'a','app','xiaomi') FROM T1 "e";
SELECT LPAD("e"."brand",6,"sal") FROM T1 "e";
SELECT RPAD("e"."brand",6,"sal") FROM T1 "e";
SELECT REGEXP_SUBSTR("e"."brand", 'ap[1,2]?.*' ,1,1) FROM T1 "e";
SELECT QUOTE("e"."brand") FROM T1 "e";
SELECT QUOTE('Don\'t touch me') FROM DUAL;
SELECT IF("e"."brand" = 'apple', e."sal", e."id") FROM T1 "e"; 
SELECT ORA_DECODE(SIGN(10-20),-1,"e"."brand",20) FROM T1 "e"; 
SELECT GREATEST("e"."brand",'apple','aqple') FROM T1 "e"; 
SELECT ISNULL("e"."brand") FROM T1 "e"; 
