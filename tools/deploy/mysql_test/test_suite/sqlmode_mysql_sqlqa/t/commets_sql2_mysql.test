--ECHO # COMMENT 1-5
--ECHO # 创建虚拟列
CREATE TABLE t1 (
    a INT AUTO_INCREMENT PRIMARY KEY,
	c_time datetime(6),
    d_time varchar(101) /*! GENERATED ALWAYS AS (time_format(c_time,'%k:%i:%s.%f')) */
);
INSERT INTO t1(a,c_time) VALUES(1, '2000-01-01 12:15:18');
INSERT INTO t1(a,c_time) VALUES(2, '2002-02-02 13:25:41');
DROP TABLE t1;


CREATE TABLE t1 (
    a INT AUTO_INCREMENT PRIMARY KEY,
	c_time datetime(6),
    d_time varchar(101)  GENERATED ALWAYS /*!10000 AS*/ (time_format(c_time,'%k:%i:%s.%f')) 
);
INSERT INTO t1(a,c_time) VALUES(1, '2000-01-01 12:15:18');
INSERT INTO t1(a,c_time) VALUES(2, '2002-02-02 13:25:41');
SELECT * FROM T1;
DROP TABLE t1;


CREATE TABLE t1 (
    a INT AUTO_INCREMENT PRIMARY KEY,
	c_time datetime(6),
    d_time varchar(101)  GENERATED ALWAYS  AS(/*!10000time_format(c_time,'%k:%i:%s.%f')*/ ) 
);
INSERT INTO t1(a,c_time) VALUES(1, '2000-01-01 12:15:18');
INSERT INTO t1(a,c_time) VALUES(2, '2002-02-02 13:25:41');
SELECT * FROM T1;
DROP TABLE t1;


CREATE TABLE t1 (
    a INT AUTO_INCREMENT PRIMARY KEY,
	c_time datetime(6),
    d_time varchar(101)  /*!10000 GENERATED */  ALWAYS  AS(time_format(c_time,'%k:%i:%s.%f')) 
);
INSERT INTO t1(a,c_time) VALUES(1, '2000-01-01 12:15:18');
INSERT INTO t1(a,c_time) VALUES(2, '2002-02-02 13:25:41');
SELECT * FROM T1;
DROP TABLE t1;


--ECHO # 创建分区表
CREATE TABLE T1(
    a bigint,
	b varchar(30),
	c timestamp
)/*!PARTITION BY RANGE(a)*/
(
	PARTITION id_part1 values less than (3),
	PARTITION id_part2 values less than (8),
	PARTITION id_part3 values less than (MAXVALUE)
);
INSERT INTO T1 VALUES(1,'养乐多','2017-09-06 18:36:38');
SELECT * FROM T1;
DROP TABLE t1;


CREATE TABLE T1(
    a bigint,
	b varchar(30),
	c timestamp
)PARTITION BY RANGE(a)
(
	/*!PARTITION id_part1 values less than (3)*/,
	PARTITION id_part2 values less than (8),
	PARTITION id_part3 values less than (MAXVALUE)
);
INSERT INTO T1 VALUES(1,'养乐多','2017-09-06 18:36:38');
SELECT * FROM T1;
DROP TABLE t1;


CREATE TABLE T1(
    a bigint,
	b varchar(30),
	c timestamp
)PARTITION BY RANGE(a)
(
	/*!10001 PARTITION id_part1 values less than (3)*/,
	PARTITION id_part2 values less than (8),
	PARTITION id_part3 values less than (MAXVALUE)
);
INSERT INTO T1 VALUES(1,'养乐多','2017-09-06 18:36:38');
SELECT * FROM T1;
DROP TABLE t1;


CREATE TABLE T1(
    a bigint,
	b varchar(30),
	c timestamp
)PARTITION BY RANGE(a)
(
	PARTITION id_part1 values less than /*!10001 (3) */,
	PARTITION id_part2 values less than (8),
	PARTITION id_part3 values less than (MAXVALUE)
);
INSERT INTO T1 VALUES(1,'养乐多','2017-09-06 18:36:38');
SELECT * FROM T1;
DROP TABLE t1;


CREATE TABLE T1(
    a bigint,
	b varchar(30),
	c timestamp
)PARTITION BY RANGE(a)
(
	PARTITION id_part1 values less than (3) ,
	PARTITION id_part2 values less than (8),
	PARTITION id_part3 values less than /*!10001 (MAXVALUE)*/
);
INSERT INTO T1 VALUES(1,'养乐多','2017-09-06 18:36:38');
SELECT * FROM T1;
DROP TABLE t1;


CREATE TABLE t1(a INT , b VARCHAR(50)) /*!PARTITION BY LIST columns(b)(*/
	PARTITION p0 VALUES IN ('abc\def','中国\人民'),
	PARTITION p1 VALUES IN ('hig\多多','klm \ \ ')
);
DROP TABLE t1;


CREATE TABLE T1(
    a bigint,
	b datetime
)partition by range columns(b) /*!20000SUBPARTITION by hash(a) subpartitions*/ 2
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);
INSERT INTO T1 VALUES(1,'2017-09-06 18:36:38');
ALTER TABLE T1 DROP PARTITION /*!part_2*/;
SELECT * FROM T1;
DROP TABLE t1;


CREATE TABLE t1(
	a INT , 
	b VARCHAR(50) PRIMARY KEY, 
	c VARCHAR(50) 
) PARTITION BY LIST columns(b) SUBPARTITION BY KEY(B) SUBPARTITIONS 2(
	PARTITION /*!p0 VALUES IN ('abc\def','中国\人民')*/
);
INSERT INTO T1 VALUES(1,'abc\def','刘备');
SELECT * FROM T1;
DROP TABLE t1;


CREATE TABLE t1(
	a INT , 
	b VARCHAR(50) PRIMARY KEY, 
	c VARCHAR(50) 
) PARTITION BY LIST columns(b) SUBPARTITION BY KEY(B) SUBPARTITIONS 2(
	PARTITION p0 VALUES IN ('abc\def','中国\人民'));
INSERT INTO T1 VALUES/*!(1,'abc\def','刘备')*/;
INSERT INTO T1 VALUES (2,/*!'中国\人民','张飞')*/;
SELECT * FROM T1;
DROP TABLE t1;


--ECHO # COMMENTS 1-7
--ECHO # 创建不同数据类型表
CREATE TABLE t1(a /*! tinyint*/,a1 /*!12345 smallint*/,a2 /*!mediumint*/);
INSERT INTO t1 VALUES(56,-451,547),(0,-959,1245),(95,599,-432);
SELECT * FROM t1;
DROP TABLE t1;

CREATE TABLE t1(a /*! tinyint*/,a1 /*!12345 smallint*/,a2 /*!mediumint*/);
INSERT INTO t1 VALUES(56,-451,547),(0,-959,1245),(95,599,-432);
SELECT * FROM t1;
DROP TABLE t1;

CREATE TABLE t1(/*!a3 int*/,a4 /*!bigint*/,/*!a5 float,a6 double*/);
INSERT INTO t1 VALUES(262,498,121.6598,13.596),(-1233,899,236.785,237.966),(5955,4452,0.123,15.293);
SELECT * FROM t1;
DROP TABLE t1;

CREATE TABLE t1(b /*!char(20)*/,b1 /*!varchar(20)*/,b2 /*!tinytext*/,b3 /*!text*/, b4 /*!mediumtext*/, b5 /*!mediumtext*/);
INSERT INTO t1 VALUES('尔晴看','快递','秦岭路','反馈卡','#$%咖啡','01223555'),('##@$`12`','fsf231','疯狂起来','#付款卡#','过滤器','18u8328'),('蔻千人','3可可粉','呸呸呸','￥@#','料工费','59595分');
SELECT * FROM t1;
DROP TABLE t1;

CREATE TABLE t1(c /*!date*/,c1 /*!time*/,c2 /*!datetime*/,c3 /*!timestamp*/);
INSERT INTO t1 VALUES('2020-01-12','23:59:59','2020-01-23 21:29:31','2020-01-13 21:29:31');
INSERT INTO t1 VALUES('2019-01-12','21:00:00','2018-11-13 17:16:25','2015-07-05 20:18:18');
INSERT INTO t1 VALUES('2019-05-23','11:29:29','2012-12-19 01:59:03','2008-05-13 10:25:19');
SELECT * FROM t1;
DROP TABLE t1;


--ECHO # 事务使用 COMMENTS
CREATE TABLE t1 (
  id int NOT NULL,
  consumer char(20) DEFAULT NULL,
  price varchar(20) DEFAULT NULL,
  sal int DEFAULT NULL,
  datetime1 DATE,
  datetime2 bigint
);
INSERT INTO t1 VALUES(1,'书局','7000',5000,'2020-09-22',20200923121200);
INSERT INTO t1 VALUES(7,'合金','VIVO',3500,'2020-02-29',20200228101159);

SET ob_trx_timeout = 10000000000;
SET ob_query_timeout = 10000000000;
SET ob_trx_idle_timeout = 1200000000;
SET autocommit = FALSE;

START TRANSACTION;
UPDATE t1 SET consumer='钢铁之躯' WHERE id=7;
SAVEPOINT /*!10000 save1*/;
UPDATE t1 SET consumer='钢铁之躯2' WHERE id=7;
SAVEPOINT /*! save2 */;
ROLLBACK TO /*! save1 */;
COMMIT;
SELECT * FROM T1;
SET autocommit = TRUE;
DROP TABLE T1;


CREATE TABLE t1 (
  id int NOT NULL,
  consumer char(20) DEFAULT NULL,
  price varchar(20) DEFAULT NULL,
  sal int DEFAULT NULL,
  datetime1 DATE,
  datetime2 bigint
);
INSERT INTO t1 VALUES(1,'书局','7000',5000,'2020-09-22',20200923121200);
INSERT INTO t1 VALUES(7,'合金','VIVO',3500,'2020-02-29',20200228101159);
SET autocommit = FALSE;
SET autocommit = /*!10000 TRUE */;
DROP TABLE T1;


--ECHO # 左右连接中使用 comments
CREATE TABLE t2(a INTEGER, b VARCHAR(100), c VARCHAR(50) );
INSERT INTO t2 VALUES(1,'1001','周星驰');
INSERT INTO t2 VALUES(2,'1002','李健');
INSERT INTO t2 VALUES(3,'1003','周杰伦');

CREATE TABLE T3(
    t3_id INTEGER PRIMARY KEY,
    first_name VARCHAR(50),
    last_name VARCHAR(50),
	sex VARCHAR(20) DEFAULT '女'
)PARTITION BY RANGE(t3_id)
(
	PARTITION id_part1 values less than (3),
	PARTITION id_part2 values less than (8),
	PARTITION id_part3 values less than (MAXVALUE)
);
INSERT INTO T3 VALUES (1,'张','三','男');
INSERT INTO T3 VALUES (2,'李','四','男');
INSERT INTO t2 VALUES ( /*!
(SELECT t_group2.id from (SELECT t_group.t3_id AS id, t_group.c AS name,
(CASE 
	WHEN t_group.t3_id = 1 THEN 'good'
	WHEN t_group.t3_id = 2 THEN 'not bad'
	WHEN t_group.t3_id = NULL THEN 'oh!!'
	ELSE NULL 
END) AS comm
FROM (
SELECT t2.c, t3.t3_id, count(*) AS counter
FROM t2
	FULL JOIN t3 ON t2.a = t3.t3_id
GROUP BY t2.c, t3.t3_id
ORDER BY t2.c DESC
) t_group) t_group2 LIMIT 1 ),
(SELECT t_group2.name from (SELECT t_group.t3_id AS id, t_group.c AS name,
(CASE 
	WHEN t_group.t3_id = 1 THEN 'good'
