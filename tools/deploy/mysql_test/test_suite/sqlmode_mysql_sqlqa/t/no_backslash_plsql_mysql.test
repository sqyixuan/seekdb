########## 测试用例 ##########
--ECHO # NO_BACKSLASH-4
CREATE TABLE t1 (
  id int NOT NULL,
  consumer char(20) DEFAULT NULL,
  price varchar(20) DEFAULT NULL,
  sal int DEFAULT NULL,
  `datetime1` DATE,
  `datetime2` bigint
);
INSERT INTO t1 VALUES(1,'书局','7000',5000,'2020-09-22',20200923121200);
INSERT INTO t1 VALUES(2,'微山','3000',-4000,'2020-09-21',20200921101159);
INSERT INTO t1 VALUES(3,'深咖','5000',0,'2020-08-21',20190821101159);
INSERT INTO t1 VALUES(4,'流苏','0',NULL,'2020-02-29',20200228101159);
INSERT INTO t1 VALUES(5,'玻璃','3200',6000,'2020-02-29',20200228101159);
INSERT INTO t1 VALUES(6,'\n',NULL,8000,'2020-02-29',20200228101159);
INSERT INTO t1 VALUES(7,'\t','VIVO',3500,'2020-02-29',20200228101159);


--ECHO # 定义一个无参的函数
DELIMITER //;
CREATE FUNCTION f_test()
returns varchar(200)
begin
	declare a varchar(200);
	SELECT sign('\t') FROM t1 as e WHERE sign(sal)=0 INTO a;
	return a;
END;
//
DELIMITER ;//
SELECT f_test();
DROP FUNCTION f_test;


DELIMITER //;
CREATE FUNCTION f_test()
returns varchar(200)
begin
	declare a varchar(200);
	SELECT CONCAT('\N\n\t','\0','\\') FROM DUAL INTO a;
	return a;
END;
//
DELIMITER ;//
SELECT f_test();
DROP FUNCTION f_test;


--ECHO # 定义一个有参的函数
DELIMITER //;
CREATE FUNCTION f_test(samplename varchar(200))
returns varchar(200)
begin
	declare a varchar(200);
	SELECT CONCAT(samplename) FROM DUAL INTO a;
	return a;
END;
//
DELIMITER ;//

SELECT f_test('\n');
SELECT f_test('\t\n');
DROP FUNCTION f_test;


--ECHO # 定义函数用while循环
DELIMITER //;
CREATE FUNCTION f_test(samplename varchar(200), samplename1 varchar(200))
returns varchar(200)
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename1 into b;
WHILE i <= 1 do
	INSERT INTO t1 VALUES(0,a,'\n',7000,'2020-12-31 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(0,b,'\t',90000,'2020-12-30 10:11:59',20200228101159);
	set i := i + 1;
END WHILE;
	return a+b;
END;
//
DELIMITER ;//
SELECT f_test(0,-1) FROM dual;
SELECT f_test(0,-1) FROM dual;
DELETE FROM t1 WHERE price LIKE '\t' escape ' ';
DELETE FROM t1 WHERE price LIKE '\n' escape ' ';
DROP FUNCTION f_test;


--ECHO # REPEAT 循环
DELIMITER //;
CREATE  FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
BEGIN
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename1 into b;
REPEAT
	INSERT INTO t1 VALUES(0,a,'repeat插入\n数据',7000,'2020-08-21 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(0,b,'repeat插入\t数据',90000,'2020-02-29 10:11:59',20200228101159);
	set i := i + 1;
	until i  >= 1
END REPEAT;
return a+b;
END;
//
DELIMITER ;//

SELECT COUNT(*) FROM t1;
SELECT f_test(0,-1) FROM dual;
SELECT COUNT(*) FROM t1;
DELETE FROM t1 WHERE price LIKE '%插入%';
DROP FUNCTION f_test;


--ECHO # loop 标签
DELIMITER //;
CREATE FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns varchar(200)
BEGIN
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename1 into b;
lp1:loop
	set i := i + 1;
	INSERT INTO t1 VALUES(0,a,'\n',7000,'2020-08-21 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(0,b,'\t',90000,'2020-02-29 10:11:59',20200228101159);
	if i > 1 then leave lp1;
	end if;
end Loop lp1;
	return a+b;
END;
//
DELIMITER ;//

SELECT COUNT(*) FROM t1;
SELECT f_test(0,-1) FROM dual;
SELECT COUNT(*) FROM t1;
DELETE FROM t1 WHERE price IN ('\n','\t');
DROP FUNCTION f_test;


--ECHO # 存储过程
DELIMITER //;
CREATE PROCEDURE p_test()
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = 0 into a;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = -1 into b;
WHILE i <= 1 do
	INSERT INTO t1 VALUES(0,a,concat('\n',i,'次'),7000,'2020-08-21 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(0,b,concat('\t',i,'次'),90000,'2020-02-29 10:11:59',20200228101159);
	set i := i + 1;
	END while;
END;
//
DELIMITER ;//

SELECT COUNT(*) FROM t1;
CALL p_test();
SELECT COUNT(*) FROM t1;
SELECT * FROM t1;
DELETE FROM t1 WHERE price LIKE '\t%' escape ' ';
DELETE FROM t1 WHERE price LIKE '\n%' escape ' ';
DROP PROCEDURE p_test;



