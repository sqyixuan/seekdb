--ECHO # 定义一个有参的函数
--ECHO # 内部参数使用 版本号 + SQL 语句，均支持
DELIMITER //;
CREATE FUNCTION f_test(samplename varchar(200))
returns varchar(200)
begin
	declare a varchar(200);
	SELECT  sign(/*!20000 samplename */) FROM t1 e WHERE sign(sal)=0 INTO a ;
	return a;
END;
//
DELIMITER ;//

SELECT /*! f_test */(-100);
SELECT /*! f_test */(-0.1);
DROP FUNCTION f_test;


--ECHO # 定义函数用while循环
--ECHO # INSERT 使用变量，变量 comment，OB 支持
DELIMITER //;
CREATE FUNCTION f_test(samplename varchar(200), samplename1 varchar(200))
returns varchar(200)
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename1 into b;
WHILE i <= 1 do
	INSERT INTO t1 VALUES(0,/*!a*/,'while插入a数据',7000,'2020-12-31 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(0,/*!b*/,'while插入b数据',90000,'2020-12-30 10:11:59',20200228101159);
	set i := i + 1;
END WHILE;
	return a+b;
END;
//
DELIMITER ;//
SELECT f_test(0,-1) FROM dual;
DELETE FROM t1 WHERE price LIKE '%插入%';
DROP FUNCTION f_test;


--ECHO # WHILE 变量使用 comment 功能，OB 报错，mysql 正常
--disable_warnings
DELIMITER //;
CREATE FUNCTION f_test(samplename varchar(200), samplename1 varchar(200))
returns varchar(200)
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename1 into b;
WHILE /*! i */ <= 1 do
	INSERT INTO t1 VALUES(0,"a",'while插入a数据',7000,'2020-12-31 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(0,"b",'while插入b数据',90000,'2020-12-30 10:11:59',20200228101159);
	set i := i + 1;
END WHILE;
	return a+b;
END;
//
DELIMITER ;//
# SELECT f_test(0,-1) FROM dual;
# DELETE FROM t1 WHERE price LIKE '%插入%';
DROP FUNCTION f_test;


--ECHO # until 变量，使用 commit，OB 报错，mysql 正常
DELIMITER //;
CREATE  FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
BEGIN
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename1 into b;
REPEAT
	INSERT INTO t1 VALUES(0,a,'repeat插入a数据',7000,'2020-08-21 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(0,b,'repeat插入b数据',90000,'2020-02-29 10:11:59',20200228101159);
	set i := i + 1;
	until /*! i */ >= 1
END REPEAT;
return a+b;
END;
//
DELIMITER ;//

SELECT COUNT(*) FROM t1;
SELECT f_test(0,-1) FROM dual;
SELECT COUNT(*) FROM t1;
DELETE FROM t1 WHERE price LIKE '%插入%';
DROP FUNCTION f_test;
--enable_warnings


--ECHO # 返回值运算，使用 " 字符， OB不支持，Mysql 支持
DELIMITER //;
--ERROR 0,1064
CREATE  FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
BEGIN
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename1 into b;
REPEAT
	INSERT INTO t1 VALUES(0,a,'repeat插入a数据',7000,'2020-08-21 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(0,b,'repeat插入b数据',90000,'2020-02-29 10:11:59',20200228101159);
	set i := i + 1;
	until i >= 1
END REPEAT;
return /*! a */+/*!b*/;
END;
//
DELIMITER ;//

