########## 测试用例 ##########
--ECHO # COMMENTS 1-1
--ECHO # 创建普通表
CREATE TABLE t1( STU_ID INT, LESSON VARCHAR(30), NAME VARCHAR(30) /*!, SCORE INT */);
INSERT INTO t1 VALUES (1,'L1001','小明',90);
INSERT INTO t1 VALUES (1,'L1002','小明',80);
SELECT * FROM t1;
DROP TABLE t1;


--ECHO # 不同模式下建表，段描述
CREATE TABLE t1(
	a INT, 
	b VARCHAR(50) /*! comment '段描述' */
);
INSERT INTO t1 VALUES(1,  'abcef');
INSERT INTO t1 VALUES(2,  '中国人民');
SELECT * FROM t1;
SHOW CREATE TABLE t1;
DROP TABLE t1;


--ECHO # 不同模式下建表，表字段
SET sql_mode = 'NO_BACKSLASH_ESCAPES';
SET sql_mode = 'ANSI_QUOTES';
CREATE TABLE t1(
	a INT, 
	b VARCHAR(50)  
) /*! comment='\n 表描述 \t' */ ;
--ERROR 0,1054
INSERT INTO t1 VALUES(1 /*!, "abc\def" */);
INSERT INTO t1 VALUES(1 /*!, 'abc\def' */);
INSERT INTO t1 VALUES(2,  '中国\人民');
SELECT * FROM t1;
SET sql_mode = '';
SHOW CREATE TABLE t1;
DROP TABLE t1;


--ECHO # 批量建表
CREATE TABLE t1(STU_ID INT, LESSON VARCHAR(30), NAME VARCHAR(30), SCORE INT);
INSERT INTO T1 VALUES (1,'L1001','小明',90);
INSERT INTO T1 VALUES (1,'L1002','小明',80);
INSERT INTO T1 VALUES (1,'L1003','小明',88);
INSERT INTO T1 VALUES (2,'L1001','小红',50);
CREATE TABLE t2 AS SELECT * FROM t1 /*! e */ WHERE e.STU_ID=1 /*! OR e.NAME='小红' */;
SELECT * FROM t2;
DROP TABLE t1;
DROP TABLE t2;


--ECHO # OB 独占，主租户
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 VARCHAR(50))/*!  REPLICA_NUM = 3, PRIMARY_ZONE = 'zone1' */ ;
DROP TABLE /*! t1 */;


--ECHO # TABLEGROUP
