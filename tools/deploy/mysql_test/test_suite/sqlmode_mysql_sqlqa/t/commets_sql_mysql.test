INSERT INTO t1 VALUES(2, '王五');
UPDATE t1 SET c2 = '李四' /*!WHERE c1 = 2 */;
SELECT * FROM t1;
DROP TABLE t1;


--ECHO # UPDATE 字段更新数值数据
