INSERT INTO t1 VALUES(1, '张三');
INSERT INTO t1 VALUES(2, '李四');
DROP TABLE t1;
DROP TABLEGROUP tgp;


--ECHO # 普通表，创建副本
CREATE TABLE t1(id INT, name VARCHAR(10));
INSERT INTO t1 VALUES(1, '张三');
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # 普通表，创建索引
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 varchar(20)  /*!  , INDEX i1 (c2) */ );
INSERT INTO t1 VALUES(1, '张三');
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # 分区表
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT)  /*!  PARTITION BY HASH(c1) PARTITIONS 8 */ ;
INSERT INTO t1 VALUES(1, 11);
INSERT INTO t1 VALUES(2, 22);
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # 复合分区表
CREATE TABLE t1 (c1 INT, c2 INT, c3 INT) PARTITION BY RANGE(c1)
	/*! SUBPARTITION BY KEY(c2, c3) SUBPARTITIONS 5 */
(PARTITION p0 VALUES LESS THAN(0), PARTITION p1 VALUES LESS THAN(100));
INSERT INTO t1 VALUES(1, 11, 111);
INSERT INTO t1 VALUES(2, 22, 222);
INSERT INTO t1 VALUES(3, 33, 333);
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # 视图
CREATE TABLE t2 (ID INT UNIQUE NOT NULL, NAME VARCHAR(20), AGE INT);
INSERT INTO t2 VALUES (1,'T2B',18);
INSERT INTO t2 VALUES (2,'T2C',20);
CREATE VIEW T2_VIEW AS /*! SELECT * FROM T2 */;
SELECT ID FROM /*! T2_VIEW */ WHERE T2_VIEW.NAME = /*!'T2C'*/;
DROP TABLE T2;
DROP VIEW T2_VIEW;

--ECHO 外键表
CREATE TABLE t1 (a int unique, b varchar(20), c int);
CREATE TABLE t2 (ID INT NOT NULL, NAME VARCHAR(20), AGE INT);
