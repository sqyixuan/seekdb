INSERT /*! INTO */ t2 VALUES (1,'T2B', 20);
DROP TABLE T2;
DROP TABLE T1;



--ECHO # COMMENTS 1-2
--ECHO # 版本号 + 普通表，创建副本
CREATE TABLE t1(id INT, name VARCHAR(10));
INSERT INTO t1 VALUES(1, '张三');
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # 版本号 + 普通表，创建索引
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 varchar(20)  /*!10000  , INDEX i1 (c2) */ );
INSERT INTO t1 VALUES(1, '张三');
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # 版本号 + 分区表
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT)  /*!10000 PARTITION BY HASH(c1) PARTITIONS 8 */ ;
INSERT INTO t1 VALUES(1, 11);
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # NULL版本号
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 varchar(20)  /*!NULL  , INDEX i1 (c2) */ );
SHOW INDEX FROM T1;
INSERT INTO t1 VALUES(1, '张三');
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # 版本号 + , 
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 varchar(20)  /*!00005  , INDEX i1 (c2) */ );
INSERT INTO t1 VALUES(1, '张三');
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # 6个0的版本号
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 varchar(20)  /*!00000  , INDEX i1 (c2) */ );
INSERT INTO t1 VALUES(1, '张三');
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # ** 无版本号，均不支持内部sql语句实现，未报错
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 varchar(20)  /**!  , INDEX i1 (c2) */ );
SHOW INDEX FROM T1;
INSERT INTO t1 VALUES(1, '张三');
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # 均不支持嵌套注释  /*! 数量未作限制， */ 只能有一个
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 varchar(20)  /*!10000,INDEX i1 (c2) */ );
/*!10000SHOW INDEX FROM T1*/;
INSERT INTO t1 VALUES(/*!1*/, '张三');
INSERT INTO t1 VALUES/*!(2*/, '李四');
INSERT INTO t1 VALUES/*!50000(3*/, '王五');
--ERROR 0,1064
INSERT INTO t1 VALUES /*!50000(4 /*! , '赵六' */ */ );
INSERT INTO t1 VALUES /*!50000(4 /*! , '赵六' */ );
INSERT INTO t1 VALUES /*!50000(5 /*! , /*! '钱七' */ );
SELECT * FROM t1;
DROP TABLE t1;


--ECHO # 无版本号
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 varchar(20)  /*!,INDEX i1 (c2) */ );
SHOW INDEX FROM t1;
SHOW CREATE TABLE t1;
INSERT INTO t1 VALUES(1, '张三');
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # 只有版本号，正常
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 varchar(20)  /*!10000 */ );
INSERT INTO t1 VALUES(1, '张三');
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # 版本号大于当前版本，Mysql 不支持，OB 直接执行，已知正常
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 varchar(20)  /*!58260 , INDEX i1 (c2) */ );
SHOW INDEX FROM t1;
SHOW CREATE TABLE t1;
INSERT INTO t1 VALUES(1, '张三');
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # comment字符串，支持
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 varchar(20));
