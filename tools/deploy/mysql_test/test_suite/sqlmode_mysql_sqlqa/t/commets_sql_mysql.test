UPDATE t1 SET c2 = /*!'李四'*/ WHERE c1 =/*!30 */;
UPDATE t1 SET c2 = /*!'李四'*/ WHERE c1 =/*!400 */;
UPDATE t1 SET c2 = /*!'李四'*/ WHERE c1 =/*!5000 */;
--error 0,1064
UPDATE t1 SET c2 = /*!'李四'*/ WHERE c1 =/*!60000 */;
