--ECHO # 对 INSERT 语句进行注释
CREATE TABLE t2 (c1 INT PRIMARY KEY, c2 varchar(20));
INSERT INTO t2 VALUES(111, '张三');
INSERT INTO t2 VALUES(222, '张三');

CREATE TABLE t1 (c1 float primary key, c2 varchar(20));
INSERT INTO /*!t1*/ VALUES(0.15, '张三');
/*!INSERT INTO */ t1 VALUES(1.15, '王五');
INSERT INTO t1 /*! VALUES */ (10.15,'李四');
INSERT INTO t1 VALUES (10.15,'李四') /*! ON DUPLICATE KEY UPDATE c1=11.15 */;
INSERT INTO t1 VALUES (10.15,'李四') ON DUPLICATE KEY /*! UPDATE c1=12.15 */;
INSERT INTO t1 VALUES (10.15,'李四') ON DUPLICATE KEY UPDATE c1 /*! =13.15 */;
INSERT INTO t1 VALUES (10.15,'李四') ON DUPLICATE KEY UPDATE c1  = /*!14.15 */;
INSERT INTO t1 VALUES (10.15,'李四') ON DUPLICATE KEY UPDATE c1  = /*!15.15 */;
INSERT INTO t1 SELECT * FROM t2 /*! WHERE t2.c1=111 */;
INSERT INTO t1 SELECT * FROM t2 WHERE t2.c1=/*! 222 */;
DELETE FROM t1 WHERE t1.c1 in /*! (111,222) */ ;
SELECT * FROM t1;
DROP TABLE t1;
DROP TABLE t2;


