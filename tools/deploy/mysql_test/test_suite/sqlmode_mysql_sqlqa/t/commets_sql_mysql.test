SELECT * FROM t1;
DROP TABLE t1;

CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 varchar(20));
INSERT INTO t1 VALUES(1, /*! "张三" */);
SELECT * FROM t1;
DROP TABLE t1;

--ECHO # 注释在字符双/单引号内，均不支持
