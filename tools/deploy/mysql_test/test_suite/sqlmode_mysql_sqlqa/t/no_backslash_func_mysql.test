########## 测试用例 ##########
--echo # NOBACKSLASH_ESCAPE-3
--echo # 字符串函数
##### CONCAT ##### 
CREATE TABLE t1 (A INT, B VARCHAR(50));
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
INSERT INTO t1 VALUES(3,  'hig\多多');
INSERT INTO t1 VALUES(4,  'klm \ \ ');
INSERT INTO t1 VALUES(5,  'xiaofeng\n\t');
INSERT INTO t1 VALUES(6,  '\0');
INSERT INTO t1 VALUES(7,  '\x32');
INSERT INTO t1 VALUES(8,  '$$\#_#\ ');
INSERT INTO t1 VALUES(9,  ' \\ \\ 济公');
INSERT INTO t1 VALUES(10, ' \v ');
INSERT INTO t1 VALUES(11, ' \\" ');
INSERT INTO t1 VALUES(12, '\332');
INSERT INTO t1 VALUES(13, '\t');
INSERT INTO t1 VALUES(14, '\r\f');
INSERT INTO t1 VALUES(15, ' \b ');
INSERT INTO t1 VALUES(16, ' \\b ');
INSERT INTO t1 VALUES(17, ' \\ b');
INSERT INTO t1 VALUES(18,  ' \ \ 济公');
INSERT INTO t1 VALUES(19,CONCAT('\N\n\t','\0'));
INSERT INTO t1 VALUES(20,CONCAT('\\\n\t','\\'));
INSERT INTO t1 VALUES(21,CONCAT('\\\n\t','\\'));

CREATE TABLE t2 (A INT, B VARCHAR(50));
INSERT INTO t2 VALUES(1,  'abc\def');
INSERT INTO t2 VALUES(2,  '中国\人民');
INSERT INTO t2 VALUES(3,  'hig\多多');
INSERT INTO t2 VALUES(4,  'klm \ \ ');

SELECT CONCAT('\N\n\t','\0','\\') FROM DUAL;
SELECT CONCAT('\n',b) FROM t1 ;
SELECT CONCAT('\ ',b) FROM t1 ;
SELECT CONCAT('\\ ',b) FROM t1 ;
SELECT '\N' BETWEEN CONCAT('\N\n\t') AND '\N';
SELECT '\N' BETWEEN '\N' AND CONCAT('\N\n\t');
SELECT '\n\t' BETWEEN '\n\t' AND '\t\n';
SELECT '\n\t' BETWEEN '\t\n' AND '\n\t';
SELECT * FROM t1 WHERE b=('\t');
SELECT * FROM t1 WHERE b=CONCAT('\N','\n','\t','\0');
SELECT * FROM t1 WHERE b IN ('\n','\t',CONCAT('\N','\n','\t','\0'));
SELECT * FROM t1 WHERE b IN ('\N','\n','\t');
SELECT * FROM t1 WHERE b IN (SELECT b FROM t2 );
SELECT * FROM t1 WHERE b NOT IN (SELECT b FROM t2 );
SELECT * FROM t1 WHERE EXISTS (SELECT * FROM t2 WHERE t2.b=t1.b);
SELECT * FROM t1 WHERE NOT EXISTS (SELECT * FROM t2 WHERE t2.b=t1.b);
SELECT * FROM t1 WHERE b = (SELECT a FROM t2 WHERE t2.b='klm \ \ ');
SELECT * FROM t1 WHERE b = (SELECT b FROM t2 WHERE t2.b='klm \ \ ');
SELECT * FROM t1 WHERE b = (SELECT CONCAT('\N\n\t','\0') FROM DUAL);
SELECT * FROM t1 WHERE b = (SELECT CONCAT('\N\n\t','\0') FROM DUAL);

--disable_warnings
SELECT CONCAT('\N\n\t','\0') AND t1.b FROM t1;
SELECT CAST(CONCAT('\N\n\t','\0') as char(50)) AND CAST(t1.b as char(50)) FROM t1;
SELECT CONCAT('\N\n\t','\0') AND CAST(t1.b as char) FROM t1;
SELECT CONCAT('\N\n\t') AND b FROM t1;
SELECT CONCAT('\N\n\t','\0') OR t1.b FROM t1;
SELECT CONCAT('\N\n\t') AND b FROM t1;
SELECT CONCAT('\f\b\n\t') < '\n' FROM DUAL;
SELECT CONCAT('\f\b\n\t') = '\n' FROM DUAL;
SELECT CONCAT('\f\b\n\t') > '\n' FROM DUAL;
SELECT CONCAT('\f\b\n\t') <=> NULL FROM DUAL;
SELECT CONCAT(NULL,' ') <=> NULL FROM DUAL;
SELECT CONCAT(NULL,'\n') <=> NULL FROM DUAL;
SELECT CONCAT('\f\b\n\t') <> '\v' FROM DUAL;
SELECT NOT CONCAT('\N\n\t') FROM t1;
SELECT NOT CONCAT('\N\n\t') FROM DUAL;
SELECT A,CAST(T1.B AS CHAR) XOR CAST(CONCAT('\N\n\t') AS CHAR) FROM T1;
SELECT CAST('\332' AS CHAR) XOR CAST(CONCAT('\N\n\t') AS CHAR) FROM DUAL;
SELECT CAST('\332' AS CHAR(50)) XOR CAST(CONCAT('\n\t') AS CHAR(50)) FROM DUAL;
SELECT CAST('\x332' AS CHAR(50)) XOR CAST(CONCAT('\n\t') AS CHAR(50)) FROM DUAL;
--enable_warnings

SELECT * FROM T1 WHERE b IS NULL;
SELECT * FROM T1 WHERE b IS NOT NULL;
SELECT * FROM T1 WHERE b <> '\r\f';
SELECT t1.a, CONCAT(t1.b,'\n') FROM t1 WHERE t1.a > 10 GROUP BY CONCAT(t1.b,'\n') ORDER BY CONCAT(t1.b,'\n') DESC;
SELECT t1.a, CONCAT(t1.b,'\n') FROM t1 WHERE t1.a > 10 GROUP BY CONCAT(t1.b,'\n') ORDER BY A DESC;
SELECT t1.a, CONCAT(t1.b,'\n') tt, count(*) FROM t1 WHERE t1.a != '\t' GROUP BY CONCAT(t1.b,'\n')  ORDER BY A DESC;
SELECT t1.a, CONCAT(t1.b,'\n') tt, count(*) FROM t1 WHERE t1.a != '\t' GROUP BY CONCAT(t1.b,'\n') HAVING count(*)>1 ORDER BY A DESC;
SELECT t1.a, CONCAT(t1.b,'\n') tt, count(*) FROM t1 WHERE t1.a > 10 GROUP BY CONCAT(t1.b,'\n') HAVING tt>'\n' ORDER BY A DESC;
SELECT * FROM (SELECT CONCAT('\N\n\t','\0') a, CONCAT('\n\n\t','\0','\\') b, '\n' c, '\t' d FROM DUAL) AS tt WHERE tt.b < '\\' AND tt.a> '\0' ;
SELECT * FROM (SELECT CONCAT('\N\n\t','\0') a, CONCAT('\n\n\t','\0','\\') b, '\n' c, '\t' d FROM DUAL) AS tt WHERE tt.b < '\\';
SELECT * FROM (SELECT CONCAT('\N\n\t','\0') a, CONCAT('\n\n\t','\0','\\') b, '\n' c, '\t' d FROM DUAL) AS tt WHERE  tt.a > '\0' ;
SELECT * FROM (SELECT CONCAT('\N\n\t','\0') a, CONCAT('\n\n\t','\0','\\') b, '\n' c, '\t' d, '\0' e, ' ' f, tt2.a aa, tt2.b bb FROM (SELECT * FROM T2) AS tt2) AS tt WHERE  tt.f <=> ' ' ;
SELECT * FROM (SELECT ' ' a, tt2.a aa, tt2.b bb FROM (SELECT * FROM T2) AS tt2) AS tt WHERE  tt.a = 0;

DROP TABLE t1;
DROP TABLE t2;


##### LIKE ##### 
CREATE TABLE t1 (A INT, B VARCHAR(50));
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
INSERT INTO t1 VALUES(3,  'hig\多多');
INSERT INTO t1 VALUES(4,  'kLm \ \ ');
INSERT INTO t1 VALUES(5,  'xiaoFENG\n\t');
INSERT INTO t1 VALUES(6,  '\0');
INSERT INTO t1 VALUES(7,  '\x32');
INSERT INTO t1 VALUES(8,  '$$\#_#\ ');
INSERT INTO t1 VALUES(9,  ' \\ \\ 济公');
INSERT INTO t1 VALUES(10, ' \v ');

CREATE TABLE t2 (A INT, B VARCHAR(50));
INSERT INTO t2 VALUES(1,  'abC\def');
INSERT INTO t2 VALUES(2,  '中国\人民');
INSERT INTO t2 VALUES(3,  'hiG\多多');
INSERT INTO t2 VALUES(4,  'klM \ \ ');
INSERT INTO t2 VALUES(5,  'SiM');

SELECT t1.b FROM t1 WHERE t1.b like '% \ \ ';
SELECT t1.b FROM t1 WHERE t1.b like '% \ \ ' escape '#';
SELECT t1.b FROM t1 WHERE t1.b like '% \\ \\ ';
SELECT t1.b FROM t1 WHERE t1.b like '% \\ ';
SELECT * FROM t1 WHERE t1.b LIKE BINARY '%lm%';
SELECT * FROM t1 WHERE t1.b LIKE BINARY '%Lm%';
SELECT * FROM t1 WHERE t1.b LIKE '%Lm%';
SELECT * FROM t1 WHERE t1.b LIKE '%lm%';
SELECT * FROM t1 WHERE t1.b LIKE LOWER(CONCAT('\v'));
SELECT * FROM t1 WHERE t1.b LIKE LOWER(CONCAT(' \v ')) escape '#';
SELECT * FROM t1 WHERE t1.b LIKE LOWER(CONCAT(' ','\v',' ')) escape '#';
SELECT * FROM t1 WHERE t1.b LIKE LOWER(CONCAT(' ','\\v',' ')) ;
SELECT * FROM t1 WHERE t1.b NOT LIKE LOWER(CONCAT(' ','\\v',' ')) ;
SELECT * FROM t1 WHERE t1.b NOT LIKE UPPER(CONCAT(' ','\\v',' ')) ;
SELECT * FROM t2 WHERE t2.b LIKE LOWER(CONCAT('abC','\def'));
SELECT * FROM t2 WHERE t2.b LIKE BINARY 'abC\def';
SELECT * FROM t2 WHERE t2.b LIKE 'abC\def';
SELECT '\V' LIKE LOWER(CONCAT('\v'));
SELECT '\V' LIKE UPPER(CONCAT('\v'));
SELECT '\0' LIKE UPPER(CONCAT('\0',' '));
SELECT '\0' LIKE UPPER(CONCAT('\0'));
SELECT '\0' LIKE CONCAT('\0');
SELECT '\n' LIKE CONCAT('\n');
SELECT SUBSTR('\n\t\0',2) FROM DUAL;
SELECT SUBSTR('水杯 \n\t\0',-3) FROM DUAL;

DROP TABLE t1;
DROP TABLE t2;


##### CONCAT_WS ##### 
CREATE TABLE t1 (A INT, B VARCHAR(50));
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2, CONCAT_WS('\ ','\n'));
INSERT INTO t1 VALUES(3, CONCAT_WS('\ ','\t'));
INSERT INTO t1 VALUES(4, CONCAT_WS('0','\ ',' '));
INSERT INTO t1 VALUES(5, CONCAT_WS('/','kLm \ \ ','\ '));
INSERT INTO t1 VALUES(6, SUBSTR('\n\t\0',2));
INSERT INTO t1 VALUES(7, SUBSTR('水杯 \n\t\0',3));
INSERT INTO t1 SELECT 8, '\n\0' FROM DUAL;

CREATE TABLE t2 (c INT, d VARCHAR(50));
INSERT INTO t2 VALUES(1,  'abC\def');
INSERT INTO t2 VALUES(2,  '中国\人民');
INSERT INTO t2 VALUES(3,  'hiG\多多');
INSERT INTO t2 VALUES(4,  'klM \ \ ');
INSERT INTO t2 VALUES(5,  'SiM');

# -- SELECT CONCAT_WS('\n','\','\ ') FROM DUAL;
SELECT CONCAT_WS('\n',b) FROM t1 ;
SELECT CONCAT_WS('\ ',b) FROM t1 ;
SELECT CONCAT_WS('\\ ',b) FROM t1 ;
SELECT * FROM t1 WHERE b = CONCAT_WS('\ ','\n');
SELECT * FROM t1 WHERE b=CONCAT_WS('\N','\n','\t','\0');
SELECT * FROM t1 WHERE b IN ('\n','\t', CONCAT_WS('\ ','\n'));
SELECT * FROM t1 WHERE b = (SELECT CONCAT_WS('\ ','\n') FROM DUAL);
--ERROR 0,1242
SELECT * FROM t1 WHERE b = (SELECT CONCAT_WS('\ ','\n') FROM t2);
SELECT * FROM (SELECT '\0' a FROM dual ) tt where tt.a = 0;
SELECT a, CONCAT_WS('\n',b,'\\') tt FROM t1 WHERE a<8 GROUP BY CONCAT_WS('\n',b,'\\') HAVING tt NOT IN ('\n\n\\', ' \ 0 ') ORDER BY A DESC;
SELECT a, CONCAT_WS('\n',b,'\\') tt FROM t1 WHERE a<8 GROUP BY CONCAT_WS('\n',b,'\\') HAVING tt NOT IN ('\n\n\\', ' \ 0 ','kLm \ \ /\ \n\\') ORDER BY A DESC;
SELECT * FROM t1 LEFT JOIN t2 ON t1.a=t2.c ORDER BY t1.b ;
SELECT * FROM t1 LEFT JOIN (SELECT * FROM t2) tt2 ON t1.a=tt2.c ORDER BY t1.b ;
SELECT * FROM t1 RIGHT JOIN (SELECT * FROM t2 WHERE t2.c <2 ) tt2 ON t1.a=tt2.c ORDER BY t1.b ;
SELECT * FROM t1 WHERE t1.b IN ((SELECT CONCAT_WS('\ ','\n') FROM DUAL), ' \n\t\0');
SELECT '\N' BETWEEN CONCAT_WS('\n\t',1) AND '\N';
SELECT '\N' BETWEEN '\N' AND CONCAT_WS('\n\t',1);
SELECT CONCAT_WS(NULL,'\n') <=> NULL FROM DUAL;
SELECT CONCAT_WS(NULL,'\n') <=> '\n' FROM DUAL;

DROP TABLE t1;
DROP TABLE t2;


##### REGEXP ##### 
CREATE TABLE t1 (A INT, B VARCHAR(50));
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
INSERT INTO t1 VALUES(3,  'hig\多多');
INSERT INTO t1 VALUES(4,  'kLm \ \ ');
INSERT INTO t1 VALUES(5,  'xiaoFENG\n\t');
INSERT INTO t1 VALUES(6,  '\0');
INSERT INTO t1 VALUES(7,  '\x32');
INSERT INTO t1 VALUES(8,  '$$\#_#\ ');
INSERT INTO t1 VALUES(9,  ' \\ \\ 济公');
INSERT INTO t1 VALUES(10, ' \v ');
INSERT INTO t1 VALUES(11, 'hig菲利');
INSERT INTO t1 VALUES(12, '\n');
--ERROR 0,5812
SELECT * FROM t1 WHERE B REGEXP 'hig[\].*';
SELECT * FROM t1 WHERE B REGEXP 'hig[\\]?.*';
SELECT * FROM t1 WHERE B REGEXP 'hig[\\]?.*';
SELECT * FROM t1 WHERE B REGEXP 'hig[\s]*';
--error 0,5811
SELECT * FROM t1 WHERE B REGEXP '^\0';
SELECT * FROM t1 WHERE B REGEXP '^\\n';
DROP TABLE T1;


CREATE TABLE t1(a int, b varchar(50));
INSERT INTO t1 VALUES(1,'qqqqqqqdqqqqq');
INSERT INTO t1 VALUES(2,'(020)12345678');
INSERT INTO t1 VALUES(3,'192.168.0.1');
INSERT INTO t1 VALUES(4,'123a34cc');
INSERT INTO t1 VALUES(5,'DNF*cf（QQ华夏');
INSERT INTO t1 VALUES(6,'\n换行符');
INSERT INTO t1 VALUES(7,'  (⊙o⊙)？');
INSERT INTO t1 VALUES(8,'http');
INSERT INTO t1 VALUES(9,'ftp');
INSERT INTO t1 VALUES(10,'https');
INSERT INTO t1 VALUES(11,'ftps');
SELECT * FROM t1 WHERE b REGEXP '[1-9]{1,5}';
SELECT * FROM t1 WHERE b REGEXP '[^,]';
SELECT * FROM t1 WHERE b REGEXP '[\\n]';
SELECT * FROM t1 WHERE b REGEXP '\\[n]';
SELECT * FROM t1 WHERE b REGEXP '[d-f]*$';
SELECT * FROM t1 WHERE b REGEXP '[1-9]+';
SELECT * FROM t1 WHERE b REGEXP '(q).*(d)';
DROP TABLE t1;


CREATE TABLE t1(a int, b varchar(50));
INSERT INTO t1 VALUES(1,'ab cd ef');
INSERT INTO t1 VALUES(2,'ghijkl');
INSERT INTO t1 VALUES(3,'fo\r\nfo');
INSERT INTO t1 VALUES(4,'opq \r');
INSERT INTO t1 VALUES(5,'12/31/2020');
INSERT INTO t1 VALUES(6,'cfddns');
INSERT INTO t1 VALUES(7,'MM');
SELECT * FROM t1 WHERE b REGEXP '99';
SELECT * FROM t1 WHERE b REGEXP '\d';
SELECT * FROM t1 WHERE b REGEXP '^f.*$';
SELECT * FROM t1 WHERE b REGEXP '[.cd.]';
SELECT * FROM t1 WHERE b REGEXP '[= =]';
DROP TABLE t1;


