SELECT ID AS "T2_ID", NAME AS `T2_NAME` FROM "T2";
SELECT ID AS "T2_ID", NAME AS `T2_NAME` FROM `T2`;
SELECT "TT2".ID AS "T2_ID", "T_T2".NAME AS `T2_NAME` FROM `T2` AS "TT2" LEFT JOIN "T2" AS "T_T2" ON "TT2".`ID`="T_T2"."AGE";
DROP TABLE T2;


