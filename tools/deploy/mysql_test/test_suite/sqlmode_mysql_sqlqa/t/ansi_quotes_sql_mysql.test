CREATE tablegroup "tgp" PARTITION BY hash partitions 2 ;
CREATE TABLE T1(
    t1_id INT NOT NULL,
    first_name VARCHAR(50),
    last_name VARCHAR(50),
	sex VARCHAR(20)
) tablegroup "tgp" partition by hash (ABS(t1_id))
(
	partition part_1,
	partition part_2
);
INSERT INTO T1 VALUES (1,'张','三','男');
--ERROR 0,1054
INSERT INTO T1 VALUES (2,'李','四',"男");
INSERT INTO T1 VALUES (3,'ve2l2i22t','id','女');
INSERT INTO T1 VALUES (4,'dolor','ut','男');
DROP TABLE t1;
DROP TABLEGROUP "tgp";


CREATE tablegroup `tgp` PARTITION BY hash partitions 2 ;
CREATE TABLE T1(
    `t1_id` INT NOT NULL,
    "first_name" VARCHAR(50),
    `last_name` VARCHAR(50),
	sex VARCHAR(20)
) tablegroup `tgp` partition by hash (ABS("t1_id"))
(
	partition part_1,
	partition part_2
);
INSERT INTO T1 VALUES (1,'张','三','男');
--ERROR 0,1054
INSERT INTO T1 VALUES (2,'李','四',"男");
INSERT INTO T1 VALUES (3,'ve2l2i22t','id','女');
SELECT * FROM T1 PARTITION ("part_2");
SELECT * FROM "T1" PARTITION ("part_2");
SELECT * FROM `T1` PARTITION (`part_2`);
DROP TABLE t1;
DROP TABLEGROUP "tgp";


CREATE tablegroup `tgp` PARTITION BY hash partitions 2 ;
CREATE TABLE T1(
    `t1_id` INT NOT NULL,
    "first_name" VARCHAR(50),
    `last_name` VARCHAR(50),
	sex VARCHAR(20)
) tablegroup `tgp` partition by hash (ABS("t1_id"))
(
	partition "part_1",
	partition `part_2`
);
INSERT INTO T1 VALUES (1,'张','三','男');
INSERT INTO T1 VALUES (2,'李','四','男');
SELECT * FROM T1 PARTITION ("part_2");
SELECT * FROM "T1" PARTITION ("part_1");
SELECT * FROM `T1` PARTITION (`part_2`);
DROP TABLE t1;
DROP TABLEGROUP "tgp";


