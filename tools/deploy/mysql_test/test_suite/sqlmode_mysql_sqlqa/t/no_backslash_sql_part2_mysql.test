--ECHO #Environmental cleaning
--disable_warnings
--ERROR 0,1396
DROP USER wmj456@'%';
--enable_warnings
--ERROR 0,1008
DROP DATABASE obwmjtest;
CREATE DATABASE obwmjtest;
--enable_warnings
CREATE USER wmj456 IDENTIFIED BY 'wmj456';
GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,wmj456,wmj456,obwmjtest,$OBMYSQL_PORT);
connection conn;



########## 配置环境 ##########

SET sql_mode = 'NO_BACKSLASH_ESCAPES';
--ERROR 0,1051
DROP TABLE t2;
--ERROR 0,1051
DROP TABLE t1;
--ERROR 0,1051
DROP TABLE `t\n1\t`;
--ERROR 0,1051
DROP TABLE `t1\n2_3`;
--ERROR 0,1051
DROP VIEW T1_VIEW;
--ERROR 0,1008
DROP DATABASE `ob\nwb_test`;


########## 测试用例 ##########
--ECHO # NOBACKSLASH_ESCAPE-5
--ECHO # 唯一约束 + no_backslash_escape + comment
CREATE TABLE t1(
	a INT, 
	b VARCHAR(50),
	CONSTRAINT /*! uniq\nkey */ UNIQUE KEY (b)
);
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
SELECT * FROM t1;
DROP TABLE t1;


--ECHO # 默认约束
CREATE TABLE t1(
	a INT, 
	b VARCHAR(50),
	c CHAR(3) DEFAULT '\\n'
);
INSERT INTO t1(a,b) VALUES(1,  'abc\def');
INSERT INTO t1(a,b) VALUES(2,  '中国\人民');
SELECT * FROM t1;
DROP TABLE t1;


CREATE TABLE t1(
	a INT, 
	b VARCHAR(50),
	c CHAR(3) DEFAULT '\n'
);
INSERT INTO t1(a,b) VALUES(1,  'abc\def');
INSERT INTO t1(a,b) VALUES(2,  '中国\人民');
SELECT * FROM t1;
DROP TABLE t1;


--ECHO # 外键约束
CREATE TABLE t1 (a int unique, b varchar(20), c int);
CREATE TABLE t2 (ID INT NOT NULL, NAME VARCHAR(20), AGE INT);
ALTER TABLE t2 ADD CONSTRAINT `fk\nid` FOREIGN KEY (id) REFERENCES t1(a) ON UPDATE CASCADE;
INSERT INTO t1 VALUES(1, '张三', 2);
INSERT INTO t2 VALUES (1,'T2B',20);
UPDATE T1 SET A='\1';
DROP TABLE T2;
DROP TABLE T1;


CREATE TABLE t1 (A int , B varchar(20) unique, C int);
CREATE TABLE t2 (ID INT , NAME VARCHAR(20), AGE INT);
ALTER TABLE t2 ADD CONSTRAINT fk_b FOREIGN KEY (name) REFERENCES t1(b) ON UPDATE CASCADE;
INSERT INTO t1 VALUES(1, '张三', 2);
INSERT INTO t2 VALUES(1,'张三',20);
UPDATE T1 SET B='\n';
DROP TABLE T2;
DROP TABLE T1;


CREATE TABLE t1 (A INT, B VARCHAR(20) UNIQUE , C int);
CREATE TABLE t2 (ID INT, NAME VARCHAR(20) NOT NULL DEFAULT 'XX', AGE INT );
ALTER TABLE t2 ADD CONSTRAINT fk_b FOREIGN KEY (NAME) REFERENCES t1(B) ON UPDATE RESTRICT;
INSERT INTO t1 VALUES(1, '张三', 2);
INSERT INTO t2 VALUES(1,'张三',20);
--ERROR 0,1451
UPDATE T1 SET B='\n';
DROP TABLE T2;
DROP TABLE T1;


--ECHO # NO_BACKSLASH_ESCAPES-6
--ECHO # 不同数据类型
CREATE TABLE T1(A INT);
INSERT INTO T1 VALUES('\1');
INSERT INTO T1 VALUES('\211');
SELECT * FROM T1;
DROP TABLE T1;


CREATE TABLE T1(A float, B double);
INSERT INTO T1 VALUES('\1','\1.11');
INSERT INTO T1 VALUES('\22.22','\0.555');
SELECT * FROM T1;
DROP TABLE T1;


CREATE TABLE T1(A char(20), B varchar(20), C tinytext);
INSERT INTO T1 VALUES('\n','\t','\v' );
INSERT INTO T1 VALUES('\n','\t','\r' );
SELECT * FROM T1;
DROP TABLE T1;


CREATE TABLE T1(b3 text(20), b4 mediumtext, b5 mediumtext);
INSERT INTO T1 VALUES('\n','\t','\v' );
INSERT INTO T1 VALUES('\n','\t','\r' );
SELECT * FROM T1;
DROP TABLE T1;


CREATE TABLE T1(c date,c1 time);
INSERT INTO T1 VALUES('\2020-01-12','23:59:59');
INSERT INTO T1 VALUES('\2019-02-23','\21:01:01');
SELECT * FROM T1;
DROP TABLE T1;


CREATE TABLE T1(c2 datetime,c3 timestamp);
INSERT INTO T1 VALUES('\2020-01-23 21:29:31','2020-01-13 21:29:31');
INSERT INTO T1 VALUES('2020-01-23 21:29:31','\2020-01-13 21:29:31');
SELECT * FROM T1;
DROP TABLE T1;


CREATE TABLE T1(c2 blob(20),c3 LONGBLOB);
INSERT INTO T1 VALUES('\n','\t');
INSERT INTO T1 VALUES('\n','\t');
SELECT * FROM T1;
DROP TABLE T1;


--ECHO # 不同参数类型
SELECT CONCAT(1.145, '\n') FROM DUAL;
SELECT CONCAT(-10000, '\n') FROM DUAL;
SELECT CONCAT(-1.175494351E-38, '\n') FROM DUAL;
SELECT CONCAT(-1.7976931348623157E+308, '\n') FROM DUAL;
SELECT CONCAT('00:00:00', '\n') FROM DUAL;
SELECT CONCAT("2020 NULL wmj456", '\n') FROM DUAL;
SELECT CONCAT("2020 NULL wmj456", '\"') FROM DUAL;
SELECT CONCAT('∑ΤΥΦΧΨΩ', '\n') FROM DUAL;


--ECHO # 事务SAVAPOINT
CREATE TABLE t1 (
  id int NOT NULL,
  consumer char(20) DEFAULT NULL,
  price varchar(20) DEFAULT NULL,
  sal int DEFAULT NULL,
  datetime1 DATE,
  datetime2 bigint
);
INSERT INTO t1 VALUES(1,'书局','7000',5000,'2020-09-22',20200923121200);
INSERT INTO t1 VALUES(7,'合金','VIVO',3500,'2020-02-29',20200228101159);

SET ob_trx_timeout = 10000000000;
SET ob_query_timeout = 10000000000;
SET ob_trx_idle_timeout = 1200000000;
SET autocommit = FALSE;

START TRANSACTION;
UPDATE t1 SET consumer='钢铁之躯' WHERE id=7;
SAVEPOINT `save\n`;
UPDATE t1 SET consumer='钢铁之躯2' WHERE id=7;
SAVEPOINT save2;
ROLLBACK TO `save\n`;
COMMIT;
SELECT * FROM T1;
SET autocommit = TRUE;
DROP TABLE T1;


--ECHO # TABLEGROUP
CREATE tablegroup tgp;
CREATE TABLE t1 (a int, b varchar(20)) tablegroup tgp;
INSERT INTO t1 VALUES(1, '\n');
INSERT INTO t1 VALUES(2, '\t');
SELECT * FROM T1;
DROP TABLE t1;
DROP TABLEGROUP tgp;


--ECHO # DML 操作补充用例
--ECHO # SELECT / UPDATE / DELETE
CREATE TABLE t1 (A INT, B VARCHAR(50));
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
INSERT INTO t1 VALUES(3,  'hig\多多');
INSERT INTO t1 VALUES(4,  'klm \ \ ');
INSERT INTO t1 VALUES(5,  'xiaofeng\n\t');
INSERT INTO t1 VALUES(6,  '\0');
INSERT INTO t1 VALUES(7,  '\x32');
INSERT INTO t1 VALUES(8,  '$$\#_#\ ');
INSERT INTO t1 VALUES(9,  ' \\ \\ 济公');
INSERT INTO t1 VALUES(10, ' \v ');
INSERT INTO t1 VALUES(11, ' \\" ');
INSERT INTO t1 VALUES(12, '\332');
INSERT INTO t1 VALUES(13, '\t');
INSERT INTO t1 VALUES(14, '\r\f');
INSERT INTO t1 VALUES(15, ' \b ');
INSERT INTO t1 VALUES(16, ' \\b ');

CREATE TABLE t2 (A INT, B VARCHAR(50));
INSERT INTO t2 VALUES(1,  'hig\多多');
INSERT INTO t2 VALUES(2,  '中国\人民');
INSERT INTO t2 VALUES(3,  '$$\#_#\ ');
INSERT INTO t2 VALUES(4,  ' \\ \\ 济公');

# SELECT
SELECT t1.b FROM t1 ORDER BY T1.A;
SELECT aa.b FROM t1 as aa ORDER BY aa.a;
SELECT t1.b FROM t1 WHERE t1.b='\0' ORDER BY T1.A;
SELECT * FROM t1 e LEFT JOIN t2 p ON e.b = p.b ORDER BY e.a DESC;
SELECT * FROM t1 e RIGHT JOIN t2 p ON e.b = p.b ORDER BY e.a;
SELECT * FROM t1 e INNER JOIN t2 p ON e.b = p.b ORDER BY e.a;
SELECT * FROM (SELECT '\n' a FROM dual ) tt where tt.a = '\n';
SELECT '\0' IS NOT NULL FROM DUAL ;
SELECT '\t' IS NOT NULL FROM DUAL ;
SELECT '\0' = 0 FROM DUAL ;

# ANY
SELECT *  FROM t1 e WHERE e.b = ANY (SELECT p.b FROM t2 p ) ORDER BY e.a;
SELECT *  FROM t1 e WHERE e.b < ANY (SELECT p.b FROM t2 p ) ORDER BY e.a;
SELECT *  FROM t1 e WHERE e.b > ANY (SELECT p.b FROM t2 p ) ORDER BY e.a;

# UPDATE
UPDATE t2 SET B = '\n' WHERE t2.B = ' \\ \\ 济公';
SELECT * FROM t2 ORDER BY T2.A;

UPDATE t2 SET B = ' \\ \\ 济公' WHERE B = '\n';
SELECT * FROM t2 ORDER BY T2.A;

UPDATE t2 SET B = (SELECT b FROM t1 WHERE b = '\r\f' ) WHERE a = 1 ;
SELECT * FROM t2 ORDER BY T2.A;

UPDATE t2, (SELECT * FROM t1) AS tb1 SET t2.a=tb1.a WHERE t2.b=tb1.b;
SELECT * FROM t2 ORDER BY T2.A;

# ALL
SELECT *  FROM t1 e WHERE e.b < ALL (SELECT p.b FROM t2 p ) ORDER BY e.a;
SELECT *  FROM t1 e WHERE e.b > ALL (SELECT p.b FROM t2 p ) ORDER BY e.a;
SELECT *  FROM t1 e WHERE e.b = ALL (SELECT p.b FROM t2 p WHERE p.b='中国\人民') ORDER BY e.a;

# EXISTS AND NOT EXISTS
SELECT * FROM t1 e WHERE EXISTS (SELECT p.b FROM t2 p ) ORDER BY e.a;
SELECT e.b  FROM t1 e WHERE NOT EXISTS (SELECT p.a,p.b FROM t2 p WHERE p.b=' \\ \\ 济公' ) ORDER BY e.a;

# GROUP BY HAVING
SELECT e.a, e.b, SUM(e.a+p.a) FROM t1 e ,t2 p WHERE e.a=p.a GROUP BY e.b ORDER BY e.a;
SELECT e.a, e.b tt, SUM(e.a+p.a) FROM t1 e ,t2 p WHERE e.a!=p.a GROUP BY tt HAVING tt = '$$\#_#\ ' ORDER BY e.a;

DROP TABLE t1;
DROP TABLE t2;



--ECHO # Clean up users
connection default;
