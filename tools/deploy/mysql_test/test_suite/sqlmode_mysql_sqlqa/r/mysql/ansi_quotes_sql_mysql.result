INSERT INTO "t2'" VALUES (1,'尔康','vivo');
INSERT INTO `t2'` VALUES (2,'微山','oneplus');
SELECT * FROM `t2'` ;
a	b	c
1	尔康	vivo
2	微山	oneplus
DROP TABLE "t2'";
CREATE TABLE "t2'" (a int, b char(20), c varchar(20));
INSERT INTO `t2'` VALUES (1,'微山','oneplus');
SELECT * FROM "t2'" ;
a	b	c
1	微山	oneplus
DROP TABLE `t2'`;
