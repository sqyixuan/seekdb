INSERT INTO `t1` VALUES(1,'书局','apple',5000);
INSERT INTO `t1` VALUES(2,'微山','xiaomi',-4000);
SELECT * FROM `t1`;
id	consumer	brand	sal
1	书局	apple	5000
2	微山	xiaomi	-4000
DROP TABLE `t1`;
CREATE TABLE "t2" (a int, b char(20), c varchar(20));
INSERT INTO "t2" VALUES (1,'尔康','vivo');
SELECT * FROM "t2" ;
a	b	c
1	尔康	vivo
DROP TABLE "t2";
