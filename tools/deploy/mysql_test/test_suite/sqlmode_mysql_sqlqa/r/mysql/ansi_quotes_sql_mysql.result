# ANSI_QUOTES 1-2
# 创建不同格式列名
# tab.col
CREATE TABLE t1(`a` int, `b` char(20), `c` varchar(20)) ;
INSERT INTO `t1`("a",`b`) VALUES (1,'尔康') ;
INSERT INTO "t1"(`b`,"c") VALUES (2,'微星') ;
SELECT * FROM "t1" ;
a	b	c
1	尔康	NULL
NULL	2	微星
SELECT * FROM `t1` ;
a	b	c
1	尔康	NULL
NULL	2	微星
DROP TABLE "t1" ;
# select db.tab.col - 1
CREATE TABLE t1(`a` int, `b` char(20), `c` varchar(20)) ;
INSERT INTO `t1`(t1."a",`b`) VALUES (1,'尔康') ;
INSERT INTO `t1`(t1."a","t1".`b`) VALUES (1,'微星') ;
SELECT `t1`.`a`, `t1`."a", "t1"."b", "t1".`b` FROM "t1" ;
a	a	b	b
1	1	尔康	尔康
1	1	微星	微星
SELECT `obwmjtest`.`t1`.`a`, `obwmjtest`.`t1`."a" FROM `t1`;
a	a
1	1
1	1
SELECT "obwmjtest"."t1"."b", "obwmjtest"."t1".`b` FROM "t1" ;
b	b
尔康	尔康
微星	微星
SELECT "obwmjtest".t1."b" FROM `t1` ;
b
尔康
微星
DROP TABLE `obwmjtest`.t1;
# create db.tab.col - 2
CREATE TABLE t1(`a` int, `b` char(20), `c` varchar(20)) ;
INSERT INTO `t1`(`obwmjtest`.t1."a", "obwmjtest"."t1".`b`) VALUES (1,'尔康') ;
INSERT INTO `t1`("obwmjtest".`t1`."a", `obwmjtest`."t1".`b`) VALUES (1,'微星') ;
SELECT `t1`.`a`, `t1`."a", "t1"."b", "t1".`b` FROM "t1" ;
a	a	b	b
1	1	尔康	尔康
1	1	微星	微星
DROP TABLE `obwmjtest`.t1;
# create tab - 3
CREATE TABLE "t1" (  
"id" BIGINT UNSIGNED  PRIMARY KEY AUTO_INCREMENT,  
"brand" VARCHAR(255) NOT NULL,  
`color` ENUM('RED','GREEN','BLUE')
);
INSERT INTO "t1" VALUES(1, 'vivo', 'RED');
ALTER TABLE "t1" MODIFY COLUMN "color" set ('ddd') ;
ALTER TABLE "t1" MODIFY COLUMN "color" set ('aaa','ddd','eee') ;
INSERT INTO t1 VALUES(2,  'OPPO', 'aaa,ddd,eee');
ALTER TABLE "T1" ADD COLUMN COM varchar(255) not null;
UPDATE "T1" SET "BRAND"='APPLE' WHERE "ID"=2;
DROP TABLE T1;
CREATE TABLE t1 (a INT, b SET('abc', '中国人民'));
INSERT INTO t1 VALUES(1,  'abc');
INSERT INTO t1 VALUES(2,  '中国人民');
INSERT INTO t1 VALUES(3,  'abc,中国人民');
ALTER TABLE "t1" MODIFY COLUMN "b" set ('ddd') ;
ALTER TABLE "t1" MODIFY COLUMN "b" set ('aaa','ddd','eee') ;
UPDATE "T1" SET "b"='abc' WHERE "a"=2;
DROP TABLE T1;
# 列名同函数名
CREATE TABLE t1(count int, `b` char(20), `c` varchar(20)) ;
INSERT INTO `t1`(t1."COUNT",`b`) VALUES (1,'尔康') ;
INSERT INTO "t1"(`COUNT`,"c") VALUES (2,'微星') ;
SELECT COUNT FROM T1;
COUNT
1
2
SELECT `COUNT` FROM T1;
COUNT
1
2
SELECT "COUNT" FROM T1;
COUNT
1
2
DROP TABLE T1;
