# 正常报错
CREATE TABLE `t1` (
`t1_id` int(11) NOT NULL,
`first_name` varchar(50) DEFAULT NULL,
`last_name` varchar(50) DEFAULT NULL,
`sex` varchar(20) DEFAULT NULL
) DEFAULT CHARSET = `utf8` ROW_FORMAT = default COMPRESSION = "snappy_1.0";
CREATE TABLE `t1` (
`t1_id` int(11) NOT NULL,
`first_name` varchar(50) DEFAULT NULL,
`last_name` varchar(50) DEFAULT NULL,
`sex` varchar(20) DEFAULT NULL
) DEFAULT CHARSET = "gb18030" ROW_FORMAT = default COMPRESSION = 'snappy_1.0';
