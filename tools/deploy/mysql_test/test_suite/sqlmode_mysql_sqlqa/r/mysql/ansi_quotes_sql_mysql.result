ALTER TABLE `t1` ADD CONSTRAINT "aa_aa" UNIQUE KEY ("a");
ALTER TABLE `t1` ADD CONSTRAINT "aa_aa" UNIQUE KEY (`a`);
ALTER TABLE `t1` ADD CONSTRAINT `aa_aa` UNIQUE KEY ("a");
DROP TABLE T1;
# ANSI_QUOTES 1-4
# 表组名
CREATE tablegroup "tgp";
CREATE TABLE t1 (a int, b varchar(20)) tablegroup "tgp";
INSERT INTO t1 VALUES(1, "张三");
INSERT INTO t1 VALUES(2, '李四');
INSERT INTO t1 VALUES(3, '王五');
DROP TABLE t1;
DROP TABLEGROUP "tgp";
CREATE tablegroup "tgp" PARTITION BY hash partitions 2 ;
Warnings:
Warning	1235	create tablegroup with partition not supported
CREATE TABLE T1(
t1_id INT NOT NULL,
first_name VARCHAR(50),
last_name VARCHAR(50),
sex VARCHAR(20)
) tablegroup "tgp" partition by hash (ABS(t1_id))
(
partition part_1,
partition part_2
);
INSERT INTO T1 VALUES (1,'张','三','男');
INSERT INTO T1 VALUES (2,'李','四',"男");
INSERT INTO T1 VALUES (3,'ve2l2i22t','id','女');
INSERT INTO T1 VALUES (4,'dolor','ut','男');
DROP TABLE t1;
DROP TABLEGROUP "tgp";
CREATE tablegroup `tgp` PARTITION BY hash partitions 2 ;
Warnings:
Warning	1235	create tablegroup with partition not supported
