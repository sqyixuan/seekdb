# 修改约束名
CREATE TABLE t1(a int, b char(20), c varchar(20)) ;
INSERT INTO "t1" VALUES (1,'尔康','vivo');
ALTER TABLE `t1` ADD CONSTRAINT `aa_aa` UNIQUE KEY (`a`);
ALTER TABLE "t1" ADD CONSTRAINT "bb_bb" PRIMARY KEY ("b");
SELECT * FROM T1;
a	b	c
1	尔康	vivo
DROP TABLE T1;
# 修改约束名
CREATE TABLE t1(a int, b char(20), c varchar(20)) ;
INSERT INTO "t1" VALUES (1,'尔康','vivo');
ALTER TABLE `t1` ADD CONSTRAINT `aa_aa` UNIQUE KEY (`a`);
ALTER TABLE "t1" RENAME INDEX "aa_aa" TO `aa_a2`;
ALTER TABLE "t1" RENAME INDEX `aa_a2` TO "aa_a3";
ALTER TABLE "t1" RENAME INDEX "aa_a3" TO "aa_a4";
ALTER TABLE `t1` DROP KEY "aa_a4";
SELECT * FROM T1;
a	b	c
1	尔康	vivo
DROP TABLE T1;
# 修改约束名
CREATE TABLE t1(a int, b char(20), c varchar(20)) ;
INSERT INTO "t1" VALUES (1,'尔康','vivo');
ALTER TABLE "t1" ADD COLUMN `d` varchar(25) not null;
ALTER TABLE `t1` ADD COLUMN "e" varchar(25) not null;
ALTER TABLE "t1" ADD COLUMN "f" varchar(25) not null AFTER "d";
ALTER TABLE "t1" MODIFY COLUMN "f" varchar(25) NOT NULL ;
SELECT * FROM T1;
a	b	c	d	f	e
1	尔康	vivo			
DROP TABLE T1;
