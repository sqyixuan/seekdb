INSERT INTO t2 VALUES (1,'T2B',18);
INSERT INTO t2 VALUES (2,'T2C',20);
CREATE VIEW "T2_VIEW" AS SELECT * FROM "T2";
SELECT "ID" FROM "T2_VIEW" WHERE "T2_VIEW"."NAME" = 'T2C';
ID
2
SELECT "ID" FROM "T2_VIEW" WHERE "T2_VIEW"."NAME" = "T2C";
DROP TABLE T2;
DROP VIEW T2_VIEW;
