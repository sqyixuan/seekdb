3	ve2l2i22t	id	女
SELECT * FROM "T1" PARTITION ("part_2");
t1_id	first_name	last_name	sex
1	张	三	男
3	ve2l2i22t	id	女
SELECT * FROM `T1` PARTITION (`part_2`);
t1_id	first_name	last_name	sex
1	张	三	男
3	ve2l2i22t	id	女
