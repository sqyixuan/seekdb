# ANSI_QUOTES 1-5
# 分区表，正常报错
CREATE TABLE T1(
a bigint,
b varchar(30),
c timestamp
)PARTITION BY RANGE(a)
(
PARTITION id_part1 values less than (3),
PARTITION id_part2 values less than (8),
PARTITION id_part3 values less than (MAXVALUE)
);
INSERT INTO t1 VALUES ("1", CAST(makedate(2012,10) AS UNSIGNED INTEGER), '2013-05-22 18:32:37.000');
INSERT INTO t1 VALUES (2, "null" , '1992-01-02 23:51:32.000');
INSERT INTO t1 VALUES (3, null , "1992-01-02 23:51:32.000");
DROP TABLE t1;
# 分区表，正常报错
CREATE TABLE T1(
a bigint,
b varchar(30),
c timestamp
)PARTITION BY RANGE("a")
(
PARTITION "id_part1" values less than ("3"),
PARTITION id_part2 values less than ('8'),
PARTITION id_part3 values less than (MAXVALUE)
);
# 分区表，正常插入数据
CREATE TABLE T1(
a bigint,
b varchar(30),
c timestamp
)PARTITION BY RANGE("a")
(
PARTITION "id_part1" values less than (3),
PARTITION id_part2 values less than (8),
PARTITION id_part3 values less than (MAXVALUE)
);
INSERT INTO t1 VALUES (1, date(makedate('1980',10)), '1980-12-03 01:08:01.000');
SELECT * FROM T1;
a	b	c
1	1980-01-10	1980-12-03 01:08:01
DROP TABLE t1;
# 分区表，正常报错
CREATE TABLE "T1"(
"a" bigint,
`b` datetime
)partition by range columns("b") subpartition by hash("a") subpartitions 2
( 
partition "part_1" values less than ('2016-09-01'),
partition `part_2` values less than ("2020-09-01"),
partition "part_3" values less than ('2021-09-01')
);
# 分区表，函数不支持 "
CREATE TABLE "T1"(
"a" bigint,
`b` datetime
)partition by range columns("b") subpartition by hash("a") subpartitions 2
( 
partition "part_1" values less than ('2016-09-01'),
partition `part_2` values less than ('2020-09-01'),
partition "part_3" values less than ('2021-09-01')
);
INSERT INTO t1 VALUES(LENGTH(makedate("1995",10)),'1995-12-02 22:30:27');
DROP TABLE t1;
# ANSI_QUOTES 1-6
# 外键表
CREATE TABLE t1 (a int unique, b varchar(20), c int);
CREATE TABLE t2 (ID INT NOT NULL,NAME VARCHAR(20), AGE INT);
ALTER TABLE `t2` ADD CONSTRAINT "fk_user_id" FOREIGN KEY ("id") REFERENCES t1("a");
INSERT INTO t1 VALUES(1, '张三', 2);
INSERT INTO t2 VALUES (1,'T2B',20);
INSERT INTO t1 VALUES(2, "李四", 1);
ALTER TABLE t2 DROP FOREIGN KEY "fk_user_id";
DROP TABLE T2;
DROP TABLE T1;
CREATE TABLE t2 ("ID" INT UNIQUE NOT NULL, "NAME" VARCHAR(20), "AGE" INT);
ALTER TABLE t2 ADD FOREIGN KEY ("AGE") REFERENCES t2("ID") ;
INSERT INTO t2 VALUES (1,'T2B',null);
INSERT INTO t2 VALUES (2,'T2C',1);
INSERT INTO t2 VALUES (3,"T2D",2);
DROP TABLE T2;
# ANSI_QUOTES 1-7
# 别名
CREATE TABLE t1 (a int unique, b varchar(20), c int comment 'xxxx');
DROP TABLE T1;
CREATE TABLE "t1" (a INT, "b" VARCHAR(50)) comment='xxxx' ;
SELECT * FROM .t1;
a	b
DROP TABLE T1;
CREATE TABLE t2 ("ID" INT UNIQUE NOT NULL, "NAME" VARCHAR(20), "AGE" INT);
INSERT INTO t2 VALUES (1,'T2B',null);
INSERT INTO t2 VALUES (2,'T2C',1);
SELECT ID AS "T2_ID", NAME AS `T2_NAME` FROM T2;
T2_ID	T2_NAME
1	T2B
2	T2C
SELECT ID AS "T2_ID", NAME AS `T2_NAME` FROM "T2";
T2_ID	T2_NAME
1	T2B
2	T2C
SELECT ID AS "T2_ID", NAME AS `T2_NAME` FROM `T2`;
T2_ID	T2_NAME
1	T2B
2	T2C
SELECT "TT2".ID AS "T2_ID", "T_T2".NAME AS `T2_NAME` FROM `T2` AS "TT2" LEFT JOIN "T2" AS "T_T2" ON "TT2".`ID`="T_T2"."AGE";
T2_ID	T2_NAME
1	T2C
2	NULL
DROP TABLE T2;
