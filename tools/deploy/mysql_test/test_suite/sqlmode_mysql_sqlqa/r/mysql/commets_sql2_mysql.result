# 创建分区表
CREATE TABLE T1(
a bigint,
b varchar(30),
c timestamp
)/*!PARTITION BY RANGE(a)*/
(
PARTITION id_part1 values less than (3),
PARTITION id_part2 values less than (8),
PARTITION id_part3 values less than (MAXVALUE)
);
INSERT INTO T1 VALUES(1,'养乐多','2017-09-06 18:36:38');
SELECT * FROM T1;
a	b	c
1	养乐多	2017-09-06 18:36:38
DROP TABLE t1;
