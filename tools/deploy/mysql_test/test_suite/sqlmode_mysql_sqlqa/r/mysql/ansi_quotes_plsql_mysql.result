# 定义一个有参的函数
# 入口参数使用 "
CREATE FUNCTION f_test("samplename" varchar(200))
returns varchar(200)
begin
declare a varchar(200);
SELECT  sign(samplename) FROM t1 e WHERE sign(sal)=0 INTO a ;
return a;
END;
//
DROP FUNCTION f_test;
# 内部参数使用 "
CREATE FUNCTION f_test(samplename varchar(200))
returns varchar(200)
begin
declare a varchar(200);
SELECT  sign("samplename") FROM t1 e WHERE sign(sal)=0 INTO a ;
return a;
END;
//
SELECT "f_test"(-100);
"f_test"(-100)
-1
SELECT `f_test`(-0.1);
`f_test`(-0.1)
-1
SELECT "f_test"(-0.1);
"f_test"(-0.1)
-1
SELECT "f_test"(0);
"f_test"(0)
0
SELECT "f_test"(0.22222);
"f_test"(0.22222)
1
SELECT "f_test"(NULL);
"f_test"(NULL)
NULL
DROP FUNCTION f_test;
# 定义函数用while循环
# INSERT 使用变量，变量使用 " 字符
CREATE FUNCTION f_test(samplename varchar(200), samplename1 varchar(200))
returns varchar(200)
begin
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename1 into b;
WHILE i <= 1 do
INSERT INTO t1 VALUES(0,"a",'while插入a数据',7000,'2020-12-31 10:11:59',20190821101159);
INSERT INTO t1 VALUES(0,"b",'while插入b数据',90000,'2020-12-30 10:11:59',20200228101159);
set i := i + 1;
END WHILE;
return a+b;
END;
//
SELECT f_test(0,-1) FROM dual;
f_test(0,-1)
-1
DELETE FROM t1 WHERE price LIKE '%插入%';
DROP FUNCTION f_test;
# WHILE 变量使用 " 字符
CREATE FUNCTION f_test(samplename varchar(200), samplename1 varchar(200))
returns varchar(200)
begin
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename1 into b;
WHILE "i" <= 1 do
INSERT INTO t1 VALUES(0,"a",'while插入a数据',7000,'2020-12-31 10:11:59',20190821101159);
INSERT INTO t1 VALUES(0,"b",'while插入b数据',90000,'2020-12-30 10:11:59',20200228101159);
set i := i + 1;
END WHILE;
return a+b;
END;
//
SELECT f_test(0,-1) FROM dual;
f_test(0,-1)
-1
DELETE FROM t1 WHERE price LIKE '%插入%';
DROP FUNCTION f_test;
# until 变量，使用 " 字符
CREATE  FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
BEGIN
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename1 into b;
REPEAT
INSERT INTO t1 VALUES(0,a,'repeat插入a数据',7000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(0,b,'repeat插入b数据',90000,'2020-02-29 10:11:59',20200228101159);
set i := i + 1;
until "i" >= 1
END REPEAT;
return a+b;
END;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
7
SELECT f_test(0,-1) FROM dual;
f_test(0,-1)
-1
SELECT f_test(NULL,-1) FROM dual;
f_test(NULL,-1)
NULL
SELECT f_test(-1,0) FROM dual;
f_test(-1,0)
-1
SELECT COUNT(*) FROM t1;
COUNT(*)
13
DELETE FROM t1 WHERE price LIKE '%插入%';
DROP FUNCTION f_test;
# 返回值运算，使用 " 字符
CREATE  FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
BEGIN
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename1 into b;
REPEAT
INSERT INTO t1 VALUES(0,a,'repeat插入a数据',7000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(0,b,'repeat插入b数据',90000,'2020-02-29 10:11:59',20200228101159);
set i := i + 1;
until i >= 1
END REPEAT;
return "a"+"b";
END;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
7
SELECT f_test(0,-1) FROM dual;
f_test(0,-1)
-1
SELECT f_test(NULL,-1) FROM dual;
f_test(NULL,-1)
NULL
SELECT f_test(-1,0) FROM dual;
f_test(-1,0)
-1
SELECT COUNT(*) FROM t1;
COUNT(*)
13
DELETE FROM t1 WHERE price LIKE '%插入%';
DROP FUNCTION f_test;
# 函数中 INSERT 语句插入 " 符号
CREATE FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
BEGIN
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename1 into b;
REPEAT
INSERT INTO t1 VALUES(0,a,'repeat插入a数据',7000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(0,b,'repeat插入b数据',90000,'2020-02-29 10:11:59',20200228101159);
set i := i + 1;
until i >= 1
END REPEAT;
return a+b;
END;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
7
SELECT f_test(0,-1) FROM dual;
f_test(0,-1)
-1
SELECT COUNT(*) FROM t1;
COUNT(*)
9
DELETE FROM t1 WHERE price LIKE '%插入%';
DROP FUNCTION f_test;
# loop 标签使用 "
CREATE FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns varchar(200)
BEGIN
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename1 into b;
"lp1":loop
set i := i + 1;
INSERT INTO t1 VALUES(0,a,'110',7000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(0,b,'120',90000,'2020-02-29 10:11:59',20200228101159);
if i > 1 then leave "lp1";
end if;
end Loop lp1;
return a+b;
END;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
7
SELECT f_test(0,-1) FROM dual;
f_test(0,-1)
-1
SELECT f_test(NULL,-1) FROM dual;
f_test(NULL,-1)
NULL
SELECT f_test(-1,0) FROM dual;
f_test(-1,0)
-1
SELECT f_test(-1,-1) FROM dual;
f_test(-1,-1)
-2
SELECT COUNT(*) FROM t1;
COUNT(*)
23
DELETE FROM t1 WHERE price IN ('110','120');
DROP FUNCTION f_test;
# 存储过程名使用 " 符号
CREATE PROCEDURE "p_test"()
begin
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = 0 into a;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = -1 into b;
WHILE i <= 1 do
INSERT INTO t1 VALUES(0,a,concat('无参存储过程a参数第',i,'次'),7000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(0,b,concat('无参存储过程b参数第',i,'次'),90000,'2020-02-29 10:11:59',20200228101159);
set i := i + 1;
END while;
END;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
7
CALL p_test();
SELECT COUNT(*) FROM t1;
COUNT(*)
11
DELETE FROM t1 WHERE price LIKE '%存储%';
DROP PROCEDURE p_test;
# in参数使用 " 符号
CREATE PROCEDURE p_test(in "samplename"  varchar(200))
begin
declare i int;
declare a varchar(200);
declare b varchar(200);
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into b;
set i := 1;
repeat
INSERT INTO t1 VALUES(0,a,concat('in存储过程a参数第',i,'次'),7000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(0,b,concat('in存储过程b参数第',i,'次'),90000,'2020-02-29 10:11:59',20200228101159);
set i := i+1; until i >= 2
end	 repeat;
END ;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
7
CALL p_test(500);
SELECT COUNT(*) FROM t1;
COUNT(*)
9
DELETE FROM t1 WHERE price LIKE '%存储%';
DROP PROCEDURE p_test;
# 调用存储过程使用 " 符号
CREATE PROCEDURE p_test(in samplename  varchar(200))
begin
declare i int;
declare a varchar(200);
declare b varchar(200);
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into b;
set i := 1;
repeat
INSERT INTO t1 VALUES(0,a,concat('in存储过程a参数第',i,'次'),7000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(0,b,concat('in存储过程b参数第',i,'次'),90000,'2020-02-29 10:11:59',20200228101159);
set i := i+1; until i >= 2
end	 repeat;
END ;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
7
CALL "p_test"(500);
SELECT COUNT(*) FROM t1;
COUNT(*)
9
DELETE FROM t1 WHERE price LIKE '%存储%';
DROP PROCEDURE p_test;
# OUT 参数使用 " 符号
CREATE PROCEDURE p_test(out "wb" varchar(200), out wb1  varchar(200))
begin
declare i int;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = 0 into wb;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = -1 into wb1;
set i :=  1;
while i <= 10 do
INSERT INTO t1 VALUES(0,'哈哈哈',concat('存储过程out第',i,'次'),7000,'2020-08-21 10:11:59',20190821101159);
set i := i + 1;
end while;
END;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
7
call p_test(@wb,@wb1);
SELECT COUNT(*) FROM t1;
COUNT(*)
17
DELETE FROM t1 WHERE price LIKE '%存储%';
DROP PROCEDURE p_test;
# 用户变量使用 " 符号
CREATE PROCEDURE p_test(out wb varchar(200), out wb1  varchar(200))
begin
declare i int;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = 0 into wb;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = -1 into wb1;
set i :=  1;
while i <= 10 do
INSERT INTO t1 VALUES(0,'哈哈哈',concat('存储过程out第',i,'次'),7000,'2020-08-21 10:11:59',20190821101159);
set i := i + 1;
end while;
END;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
7
call p_test(@"wb",@wb1);
SELECT COUNT(*) FROM t1;
COUNT(*)
17
DELETE FROM t1 WHERE price LIKE '%存储%';
DROP PROCEDURE p_test;
# inout 参数使用 " 符号
CREATE PROCEDURE p_test( out wb varchar(200),inout "wb1" varchar(200))
begin
declare i int;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = 0 into wb;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = -1 into wb1;
set i := 1;
WHILE i <= 10 do
INSERT INTO t1 VALUES(0,'哈哈哈',concat('存储过程第',i,'次'),7000,'2020-08-21 10:11:59',20190821101159);
set i := i+1;
END while;
END;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
7
call p_test(@wb,@"wb1");
SELECT COUNT(*) FROM t1;
COUNT(*)
17
DELETE FROM t1 WHERE price LIKE '%存储%';
DROP PROCEDURE p_test;
# 存储过程和函数的结果作为参数传递
CREATE FUNCTION f_test()
returns int
begin
declare a int;
SELECT  sign(sal) FROM t1 e WHERE sign(sal) = -1 into a ;
RETURN a;
END;
//
SELECT f_test() FROM  dual;
f_test()
-1
CREATE  PROCEDURE p_test(in wb int)
begin
declare i int;
set i := 1;
WHILE i <= 1 do
INSERT INTO t1 VALUES(0,'哈哈哈','600',wb+100,'2021-01-01 10:11:59',20190821101159);
INSERT INTO t1 VALUES(0,'哦哦哦','19111',wb+200,'2021-01-01 10:11:59',20200228101159);
set i := i+1;
END while;
END;
//
CALL p_test("f_test"());
SELECT COUNT(*) FROM t1;
COUNT(*)
9
DELETE FROM t1 WHERE price IN ('600','19111');
DROP PROCEDURE p_test;
DROP FUNCTION f_test;
