#Environmental cleaning
DROP USER wmj456@'%';
DROP DATABASE obwmjtest;
CREATE DATABASE obwmjtest;
CREATE USER wmj456 IDENTIFIED BY 'wmj456';
GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;
SET sql_mode = 'ANSI_QUOTES';
DROP TABLE t1;
DROP TABLE t2;
DROP TRIGGER "demo";
SET autocommit = TRUE;
# ANSI_QUOTES 2-1
# 事务使用 " 字符，OB 支持
CREATE TABLE "t1" (
"id" int NOT NULL,
"consumer" char(20) DEFAULT NULL,
"price" varchar(20) DEFAULT NULL,
"sal" int DEFAULT NULL,
"datetime1" DATE,
"datetime2" bigint
);
INSERT INTO t1 VALUES(1,'书局','7000',5000,'2020-09-22',20200923121200);
INSERT INTO t1 VALUES(7,'合金','VIVO',3500,'2020-02-29',20200228101159);
SET ob_trx_timeout = 10000000000;
SET ob_query_timeout = 10000000000;
SET ob_trx_idle_timeout = 1200000000;
SET autocommit = FALSE;
START TRANSACTION;
UPDATE "t1" SET "consumer"='钢铁之躯' WHERE "id"=7;
SAVEPOINT "save1";
UPDATE "t1" SET "consumer"='钢铁之躯2' WHERE "id"=7;
SAVEPOINT "save2";
ROLLBACK TO "save1";
COMMIT;
