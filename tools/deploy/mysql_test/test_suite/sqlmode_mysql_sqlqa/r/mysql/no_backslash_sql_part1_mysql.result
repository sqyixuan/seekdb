# 分区普通索引
CREATE TABLE t1(a INT , b VARCHAR(50)) PARTITION BY LIST columns(b)(
PARTITION p0 VALUES IN ('abc\def','中国\人民'),
PARTITION p1 VALUES IN ('hig\多多','klm \ \ '),
PARTITION p2 VALUES IN ('xiaofeng\n\t','\0')
);
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
INSERT INTO t1 VALUES(3,  'hig\多多');
INSERT INTO t1 VALUES(4,  'klm \ \ ');
INSERT INTO t1 VALUES(5,  'xiaofeng\n\t');
INSERT INTO t1 VALUES(6,  '\0');
CREATE INDEX `T1_\n\t_01` ON t1(b);
DROP INDEX `T1_\n\t_01` ON T1;
DROP TABLE t1;
# NO_BACKSLASH-3
# 普通生成列表
CREATE TABLE t1 (
a INT AUTO_INCREMENT PRIMARY KEY,
b VARCHAR(50),
c VARCHAR(100) GENERATED ALWAYS AS (b)
);
INSERT INTO t1(a,b) VALUES(1, '\n');
INSERT INTO t1(a,b) VALUES(2, '\t');
INSERT INTO t1(a,b) VALUES(3, '\0');
INSERT INTO t1(a,b) VALUES(4, '\t\t');
INSERT INTO t1(a,b) VALUES(5, '\\');
INSERT INTO t1(a,b) VALUES(6, '中国\人民');
SELECT * FROM t1;
a	b	c
1	\n	\n
2	\t	\t
3	\0	\0
4	\t\t	\t\t
5	\\	\\
6	中国\人民	中国\人民
DROP TABLE t1;
# CONCAT 生成列表
CREATE TABLE t1 (
a INT AUTO_INCREMENT PRIMARY KEY,
b VARCHAR(50),
c VARCHAR(100) GENERATED ALWAYS AS (CONCAT(b,'\n'))
);
INSERT INTO t1(a,b) VALUES(1, '\n');
INSERT INTO t1(a,b) VALUES(2, '\t');
INSERT INTO t1(a,b) VALUES(3, '\0');
INSERT INTO t1(a,b) VALUES(4, '\t\t');
INSERT INTO t1(a,b) VALUES(5, '\\');
INSERT INTO t1(a,b) VALUES(6, '中国\人民');
SELECT * FROM t1;
a	b	c
1	\n	\n\\n
2	\t	\t\\n
3	\0	\0\\n
4	\t\t	\t\t\\n
5	\\	\\\\n
6	中国\人民	中国\人民\\n
DROP TABLE t1;
# CASE WHEN 生成列表
CREATE TABLE T1 (
a INT AUTO_INCREMENT PRIMARY KEY,
c_time varchar(50),
d_time varchar(50) GENERATED ALWAYS AS (CASE WHEN timestamp(c_time) > "2021-07-06" THEN "\n\n" WHEN timestamp(c_time) <= "2021-07-06" then '\t\t\t rr' end)
);
INSERT INTO T1(A,C_TIME) VALUES(1,'2020-02-29 10:11:59');
INSERT INTO T1(A,C_TIME) VALUES(2,'09:10:05');
INSERT INTO T1(A,C_TIME) VALUES(3,NULL);
INSERT INTO T1(A,C_TIME) VALUES(4,'2022\08\24 21:10:45');
INSERT INTO T1(A,C_TIME) VALUES(5,'2022\08\24 21:10:45');
INSERT INTO T1(A,C_TIME) VALUES(6,'2022-02-28 10:11:59');
INSERT INTO T1(A,C_TIME) VALUES(7,'2022-02-28 10:11:59');
INSERT INTO T1(A,C_TIME) VALUES(8,'2022-02-29 10:11:59');
INSERT INTO T1(A,C_TIME) VALUES(9,' ');
SELECT * FROM T1;
a	c_time	d_time
1	2020-02-29 10:11:59	\\t\\t\\t rr
2	09:10:05	\\t\\t\\t rr
3	NULL	NULL
4	2022\08\24 21:10:45	\\n\\n
5	2022\08\24 21:10:45	\\n\\n
6	2022-02-28 10:11:59	\\n\\n
7	2022-02-28 10:11:59	\\n\\n
8	2022-02-29 10:11:59	NULL
9	 	NULL
DROP TABLE T1;
