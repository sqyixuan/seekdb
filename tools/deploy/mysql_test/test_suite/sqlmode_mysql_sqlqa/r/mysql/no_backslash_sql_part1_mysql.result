# 普通表
CREATE TABLE t1 (a INT, b SET('abc\def', '中国\人民', '\n', 'klm \ \ ', '\0'));
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
INSERT INTO t1 VALUES(3,  '\n,klm \ \,中国\人民');
INSERT INTO t1 VALUES(4,  'abc\def,klm \ \ ');
INSERT INTO t1 VALUES(5,  '\0');
INSERT INTO t1 VALUES(6,  '中国\人民 \0 \n');
SELECT * FROM T1;
a	b
1	abc\def
2	中国\人民
3	中国\人民,\n,klm \ \
4	abc\def,klm \ \
5	\0
6	
DROP TABLE T1;
# LIST 分区
CREATE TABLE t1(a INT , b VARCHAR(50)) PARTITION BY LIST columns(b)(
PARTITION p0 VALUES IN ('abc\def','中国\人民'),
PARTITION p1 VALUES IN ('hig\多多','klm \ \ '),
PARTITION p2 VALUES IN ('xiaofeng\n\t','\0')
);
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
INSERT INTO t1 VALUES(3,  'hig\多多');
INSERT INTO t1 VALUES(4,  'klm \ \ ');
INSERT INTO t1 VALUES(5,  'xiaofeng\n\t');
INSERT INTO t1 VALUES(6,  '\0');
SELECT * FROM T1;
a	b
1	abc\def
2	中国\人民
3	hig\多多
4	klm \ \ 
5	xiaofeng\n\t
6	\0
DROP TABLE t1;
# KEY 分区
CREATE TABLE t1(
a INT , 
b VARCHAR(50) UNIQUE KEY NOT NULL
) PARTITION BY KEY(B) PARTITIONS 5;
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
INSERT INTO t1 VALUES(3,  'hig\多多');
INSERT INTO t1 VALUES(4,  'klm \ \ ');
INSERT INTO t1 VALUES(5,  'xiaofeng\n\t');
INSERT INTO t1 VALUES(6,  '\0');
SELECT * FROM T1;
a	b
1	abc\def
2	中国\人民
3	hig\多多
4	klm \ \ 
5	xiaofeng\n\t
6	\0
DROP TABLE t1;
# LIST-KEY 分区
CREATE TABLE t1(
a INT , 
b VARCHAR(50) PRIMARY KEY
) PARTITION BY LIST columns(b) SUBPARTITION BY KEY(B) SUBPARTITIONS 2(
PARTITION p0 VALUES IN ('abc\def','中国\人民'),
PARTITION p1 VALUES IN ('hig\多多','klm \ \ '),
PARTITION p2 VALUES IN ('xiaofeng\n\t','\0')
);
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
INSERT INTO t1 VALUES(3,  'hig\多多');
INSERT INTO t1 VALUES(4,  'klm \ \ ');
INSERT INTO t1 VALUES(5,  'xiaofeng\n\t');
INSERT INTO t1 VALUES(6,  '\0');
SELECT * FROM T1;
a	b
2	中国\人民
1	abc\def
3	hig\多多
4	klm \ \ 
5	xiaofeng\n\t
6	\0
DROP TABLE t1;
# duplicate key 
# bug: 36538912
CREATE TABLE t1 (A INT, B VARCHAR(50) UNIQUE);
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
INSERT INTO t1 VALUES(3,  'hig\多多');
INSERT INTO t1 VALUES(4,  'klm \ \ ');
INSERT INTO t1 VALUES(5,  'abc\def') ON DUPLICATE KEY UPDATE B=CONCAT(B,'\n');
INSERT INTO t1 VALUES(6,  'abc\def') ON DUPLICATE KEY UPDATE B=CONCAT('\n','\t');
INSERT INTO t1 VALUES(7,  'abc\def') ON DUPLICATE KEY UPDATE B=CONCAT('\n','\t');
SELECT * FROM t1;
A	B
1	abc\def\n
2	中国\人民
3	hig\多多
4	klm \ \ 
6	\n\t
DROP TABLE t1;
# 视图
CREATE TABLE t1 (A INT, B VARCHAR(50));
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
INSERT INTO t1 VALUES(3,  '\n,klm \ \,中国\人民');
INSERT INTO t1 VALUES(4,  'abc\def,klm \ \ ');
INSERT INTO t1 VALUES(5,  '\0');
INSERT INTO t1 VALUES(6,  '中国\人民 \0 \n');
CREATE VIEW t1_view AS SELECT *  FROM t1;
INSERT INTO t1_view VALUES (7, '\t');
INSERT INTO t1_view VALUES (8, '\n');
UPDATE t1_view SET B = '\n\t' WHERE A=7;
UPDATE t1_view SET B = '\n\n' WHERE A=8;
SELECT * FROM t1_view;
A	B
1	abc\def
2	中国\人民
3	\n,klm \ \,中国\人民
4	abc\def,klm \ \ 
5	\0
6	中国\人民 \0 \n
7	\n\t
8	\n\n
DROP TABLE t1;
DROP VIEW  t1_view;
# 需要用到本地文件, 注释用例
# SQLMODE-2
# 创建数据库
CREATE DATABASE `ob\nwb_test`;
USE `ob\nwb_test`;
USE `obwb_test`;
USE `obwmjtest`;
DROP DATABASE `ob\nwb_test`;
# 创建普通表
CREATE TABLE `t1\n2_3` (A INT, B VARCHAR(50));
INSERT INTO `t1\n2_3` VALUES(1,  'abc\def');
INSERT INTO `t1\n2_3` VALUES(2,  '中国\人民');
INSERT INTO `t1\n2_3` VALUES(3,  'hig\多多');
INSERT INTO `t1\n2_3` VALUES(4,  'klm \ \ ');
SELECT * FROM `t1\n2_3`;
A	B
1	abc\def
2	中国\人民
3	hig\多多
4	klm \ \ 
DROP TABLE `t1\n2_3`;
CREATE TABLE `t1\n2_3`(`A\n_B` INT, `B\t_C` VARCHAR(50));
INSERT INTO `t1\n2_3` VALUES(1,  'abc\def');
INSERT INTO `t1\n2_3`(`A\n_B`) VALUES(2);
INSERT INTO `t1\n2_3`(`A\n_b`) VALUES(3);
INSERT INTO `t1\n2_3` VALUES(4,  'klm \ \ ');
SELECT * FROM `t1\n2_3`;
A\n_B	B\t_C
1	abc\def
2	NULL
3	NULL
4	klm \ \ 
DROP TABLE `t1\n2_3`;
# 创建外键表
CREATE TABLE t2 (C INT, D VARCHAR(50) PRIMARY KEY);
INSERT INTO t2 VALUES(1,  'abc\def');
INSERT INTO t2 VALUES(2,  '中国\人民');
INSERT INTO t2 VALUES(3,  'hig\多多');
CREATE TABLE t1 (A INT, B VARCHAR(50) PRIMARY KEY, FOREIGN KEY (b) REFERENCES t2(d) ON UPDATE CASCADE);
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
INSERT INTO t1 VALUES(3,  'hig\多多');
DROP TABLE t1;
DROP TABLE t2;
# 创建分区表
CREATE TABLE `t\n1\t`(
a INT , 
b VARCHAR(50) PRIMARY KEY
) PARTITION BY LIST columns(b) SUBPARTITION BY KEY(B) SUBPARTITIONS 2(
PARTITION p0 VALUES IN ('abc\def','中国\人民'),
PARTITION p1 VALUES IN ('hig\多多','klm \ \ '),
PARTITION p2 VALUES IN ('xiaofeng\n\t','\0')
);
INSERT INTO `t\n1\t` VALUES(1,  'abc\def');
INSERT INTO `t\n1\t` VALUES(2,  '中国\人民');
INSERT INTO `t\n1\t` VALUES(3,  'hig\多多');
INSERT INTO `t\n1\t` VALUES(4,  'klm \ \ ');
DROP TABLE `t\n1\t`;
CREATE TABLE t1(
`a\n\t_1` INT , 
`b\n\t_2` VARCHAR(50) PRIMARY KEY
) PARTITION BY LIST columns(`b\n\t_2`) SUBPARTITION BY KEY(`b\n\t_2`) SUBPARTITIONS 2(
PARTITION p0 VALUES IN ('abc\def','中国\人民'),
PARTITION p1 VALUES IN ('hig\多多','klm \ \ '),
PARTITION p2 VALUES IN ('xiaofeng\n\t','\0')
);
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
INSERT INTO t1 VALUES(3,  'hig\多多');
SELECT * FROM t1;
a\n\t_1	b\n\t_2
2	中国\人民
1	abc\def
3	hig\多多
DROP TABLE t1;
CREATE TABLE t1(
a INT, 
b VARCHAR(50) PRIMARY KEY
) PARTITION BY LIST columns(b) SUBPARTITION BY KEY(b) SUBPARTITIONS 2(
PARTITION `p\n0` VALUES IN ('abc\def','中国\人民'),
PARTITION `p\n1` VALUES IN ('hig\多多','klm \ \ '),
PARTITION `p\n2` VALUES IN ('xiaofeng\n\t','\0')
);
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
INSERT INTO t1 VALUES(3,  'hig\多多');
SELECT * FROM t1;
a	b
2	中国\人民
1	abc\def
3	hig\多多
DROP TABLE t1;
# CONSTRAINT
CREATE TABLE t1(
a INT, 
b VARCHAR(50),
CONSTRAINT `uniq_\t\n_key` UNIQUE KEY (b)
);
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
SELECT * FROM t1;
a	b
1	abc\def
2	中国\人民
DROP TABLE t1;
# 表 / 字段 Comment
CREATE TABLE t1(
a INT, 
b VARCHAR(50) comment '\n 段描述 \t' 
);
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
SELECT * FROM t1;
a	b
1	abc\def
2	中国\人民
DROP TABLE t1;
CREATE TABLE t1(
a INT, 
b VARCHAR(50)  
) comment='\n 表描述 \t' ;
INSERT INTO t1 VALUES(1,  'abc\def');
INSERT INTO t1 VALUES(2,  '中国\人民');
SELECT * FROM t1;
a	b
1	abc\def
2	中国\人民
DROP TABLE t1;
# 多列普通索引
CREATE TABLE T1(
t1_id INT NOT NULL,
first_name VARCHAR(50),
last_name VARCHAR(50),
sex VARCHAR(20)
);
INSERT INTO T1 VALUES (1,'张','三','男');
INSERT INTO T1 VALUES (2,'李','四','男');
INSERT INTO T1 VALUES (3,NULL,'id','女');
INSERT INTO T1 VALUES (4,'dolor','ut','男');
INSERT INTO T1 VALUES (5,'sed','dolore ','女');
INSERT INTO T1 VALUES (6,'eiusmod','enim','男');
CREATE INDEX `T1_\t_01` ON T1(t1_id,sex);
DROP INDEX `T1_\t_01` ON T1;
DROP TABLE T1;
# 主键索引
CREATE TABLE T1(
t1_id INT NOT NULL,
first_name VARCHAR(50),
last_name VARCHAR(50),
sex VARCHAR(20)
);
INSERT INTO T1 VALUES (1,'张','三','男');
INSERT INTO T1 VALUES (2,'李','四','男');
INSERT INTO T1 VALUES (3,NULL,'id','女');
INSERT INTO T1 VALUES (4,'dolor','ut','男');
INSERT INTO T1 VALUES (5,'sed','dolore ','女');
INSERT INTO T1 VALUES (6,'eiusmod','enim','男');
ALTER TABLE T1 ADD PRIMARY KEY ( t1_id );
DROP TABLE T1;
