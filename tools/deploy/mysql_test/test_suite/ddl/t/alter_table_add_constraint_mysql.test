--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: dachuan.sdc
# owner group: SQL2
# description: 测试 ALTER TABLE ADD CONSTRAINT UNIQUE (暂时不支持 PRIMARY KEY 和 FOREIGN KEY) 在 mysql 兼容模式下不受 oracle 兼容模式的影响
# tags: ddl

--disable_warnings
drop database if exists xiaofeng_db;
create database xiaofeng_db;
use xiaofeng_db;
--enable_warnings

# 在 xf1 和 xf2 这两张表上分别用 oracle 支持的两种语法进行 alter table add uk
create table xf(c1 int);
alter table xf add unique (c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf;
drop table xf;
create table xf(c1 int, c2 int);
alter table xf add unique (c1, c2);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf;
drop table xf;
create table xf2(c1 int);
alter table xf2 add constraint cons unique (c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf2;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf2;
drop table xf2;
create table xf2(c1 int, c2 int);
alter table xf2 add constraint cons unique (c1, c2);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf2;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf2;
drop table xf2;

# 在 xf3 上测试 mysql 语法支持，但 oracle 语法不支持的 sql 语句
create table xf3(c1 int);
alter table xf3 add constraint unique (c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf3;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf3;
alter table xf3 drop key c1;
alter table xf3 add unique key (c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf3;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf3;
alter table xf3 drop key c1;
alter table xf3 add unique key ind_name (c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf3;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf3;
alter table xf3 drop key ind_name;
alter table xf3 add unique index (c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf3;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf3;
alter table xf3 drop key c1;
alter table xf3 add unique index ind_name (c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf3;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf3;
alter table xf3 drop key ind_name;
alter table xf3 add constraint cons unique key (c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf3;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf3;
alter table xf3 drop key cons;
alter table xf3 add constraint cons unique key ind_name (c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf3;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf3;
alter table xf3 drop key ind_name;
alter table xf3 add constraint cons unique index (c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf3;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf3;
alter table xf3 drop key cons;
alter table xf3 add constraint cons unique index ind_name (c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf3;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf3;
alter table xf3 drop key ind_name;
drop table xf3;

# mysql mode 下允许在同样的列（族）上重复建普通索引或者唯一索引，在 xf4 上进行测试
create table xf4(c1 int);
alter table xf4 add index(c1);
alter table xf4 add index(c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf4;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf4;
alter table xf4 add unique(c1);
alter table xf4 add unique(c1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf4;
--source mysql_test/include/check_all_idx_ok.inc
show index from xf4;
drop table xf4;

drop database xiaofeng_db;
