--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: sean.yyj
# owner group: SQL3
# description: 测试 collate定义顺序，为int等data type定义collate， 为primary key命名
# tags: ddl

--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_result_log
drop table if exists t1;
drop table if exists t2;
--enable_result_log

create table t1(c1 int collate utf8_bin, 
                c2 char collate utf8_bin, 
                c3 char character set utf8 collate utf8_unicode_ci,
                c4 double collate gbk_chinese_ci,
                c5 decimal collate gbk_chinese_ci,
                c6 text character set utf8 not null comment 'abc' collate utf8_bin not null collate utf8_bin not null,
                c7 enum('a', 'b') character set utf8 collate utf8_bin not null collate utf8_bin not null not null comment 'abc' collate utf8_bin,
                c8 number collate utf8_bin, 
                c9 varchar(10) not null unique default 'abc' comment 'abc' collate utf8_bin not null collate utf8_bin not null,
                primary key idx(c1,c2,c3));

show full columns from t1;
show indexes from t1;
drop table t1;

create table t1(c1 int default null collate utf8_bin, 
                c2 char collate utf8_bin default 'a' not null, 
                c3 char character set utf8 default null collate utf8_unicode_ci,
                c4 double null unique key collate gbk_chinese_ci,
                c5 decimal unique collate gbk_chinese_ci key,
                c6 char(10) collate utf8_bin as (c2 || 'c3'),
                c7 varchar(10) character set gbk collate gbk_chinese_ci as (c2 || c3),
                unique key idx(c2));

show full columns from t1;
show indexes from t1;
drop table t1;

create table t1 (c1 int unique collate utf8_bin key);
drop table t1;

create table t1 (c1 int, primary key idx(c1), unique key idx(c1));
show indexes from t1;
drop table t1;

--error 1064
create table t1 (c1 int character set utf8 collate utf8_bin);

--error 1064
create table t1 (c1 int collate utf8_bin character set utf8);

create table t1 (c1 varchar(10) character set utf8 collate utf8mb4_bin);
show full columns from t1;
drop table t1;

--error 1064
create table t1 (c1 varchar(10) collate utf8mb4_bin character set utf8);

--error 1253
create table t1 (c1 varchar(10) character set gbk collate utf8mb4_bin);

--error 1253
create table t1 (c1 varchar(10) character set utf8 collate gbk_chinese_ci);

create table t1 (c1 varchar(10) character set utf8 collate utf8mb4_bin collate utf8_unicode_ci);
show full columns from t1;
drop table t1;

#mysql5.7 succeed
create table t1(c1 int default 1 default 2);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

create table t1(c1 varchar(10) character set utf8 comment 'test2' not null comment 'test' collate utf8_unicode_ci default 'abc' collate utf8_bin comment 'agc');
show full columns from t1;
drop table t1;

create table t2 (c1 int);
alter table t2 add primary key p_name(c1);
show indexes from t2;

explain select /*+index(t2 p_name)*/ * from t2;

#mysql will report an error now.
create table t1(  c4 int collate utf8_bin collate gbk_chinese_ci );
drop table t1;

create table t1(  c4 int collate utf8_bin as (1+1));
drop table t1;

--error 1064
create table t1(  c4 int collate utf8_bin collate utf8_bin as (1+1));

--error 1253
create table t1(c4 blob collate gbk_chinese_ci );

--error 1253
create table t1(c4 varbinary(10) collate gbk_chinese_ci );


