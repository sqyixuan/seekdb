--echo bugfix 
create table Z0CASE (Z0_TEST0 blob, Z0_TEST1 int);
--error 1659
alter table Z0CASE partition by key(Z0_TEST0) partitions 2;
drop table if exists Z0CASE;

--echo bugfix 
create table Z0CASE (Z0_TEST0 int,Z0_TEST1 bigint )partition by range (Z0_TEST0)
(
partition part_1 values less than (20 ),
partition part_2 values less than (100 ),
partition part_3 values less than ( maxvalue )
);
--error 1659
alter table Z0CASE modify Z0_TEST0 CHAR(99);
drop table if exists Z0CASE;

--echo to test alter part key column.
# range part and hash subpart.
drop table if exists z0case;
create table z0case (z0_test0 int, z0_test1 int) partition by range (z0_test0) subpartition by hash(z0_test0) subpartitions 2 (
  partition p0 values less than(0),
  partition p1 values less than(2150));

insert into z0case values(2002, 2002);
insert into z0case (z0_test1)values (2022);
insert into z0case (z0_test0) values (2020);

alter table z0case modify z0_test0 bigint;
alter table z0case modify z0_test0 mediumint;
--error 1264
alter table z0case modify z0_test0 tinyint;
drop table z0case;

# range part and range subpart.
create table z0case (z0_test0 int, z0_test1 int) partition by range (z0_test0) subpartition by range(z0_test0) (
  partition p0 values less than(0) (subpartition subpart00 values less than (0), subpartition subpart01 values less than (2150)),
  partition p1 values less than(2150) (subpartition subpart10 values less than (0), subpartition subpart11 values less than (2150)));

insert into z0case values(2002, 2002);
insert into z0case (z0_test1)values (2022);
insert into z0case (z0_test0) values (2020);

alter table z0case modify z0_test0 bigint;
alter table z0case modify z0_test0 mediumint;
--error 1264
alter table z0case modify z0_test0 tinyint;
drop table z0case;

--echo to test alter part key to different categories type.
# range part and hash subpart.
create table z0case (z0_test0 year, z0_test1 int) partition by range (z0_test0) subpartition by hash(z0_test0) subpartitions 2 (
  partition p0 values less than(0),
  partition p1 values less than(2150));

insert into z0case values(2002, 2002);
insert into z0case (z0_test1)values (2022);
insert into z0case (z0_test0) values (2020);

alter table z0case modify z0_test0 int;
--error 1659
alter table z0case modify z0_test0 date;
--error 1659
alter table z0case modify z0_test0 timestamp;
--error 1659
alter table z0case modify z0_test0 time;
alter table z0case modify z0_test0 year;
alter table z0case modify z0_test0 bigint;
--error 1659
alter table z0case modify z0_test0 char(100);
alter table z0case modify z0_test0 bit(50);
alter table z0case modify z0_test0 year;
select * from z0case order by z0_test0;
drop table z0case;

# to test part and subpart defined on different column.
create table z0case (z0_test0 year, z0_test1 int) partition by range (z0_test0) subpartition by hash(z0_test1) subpartitions 2 (
  partition p0 values less than(0),
  partition p1 values less than(2150));

