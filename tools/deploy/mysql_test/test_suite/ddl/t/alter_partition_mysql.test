# description : 测试mysql模式下alter partition by
# tags: ddl 

--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_result_log
drop table if exists Z0CASE;
--enable_result_log

create table Z0CASE (Z0_TEST0 blob,Z0_TEST1 int);

--error 1659
alter table Z0CASE partition by range(Z0_TEST0)(partition part_1 values less than (1), partition part_2 values less than (100), partition part_3 values less than (maxvalue));
--error 1697
alter table Z0CASE partition by range(Z0_TEST0+1)(partition part_1 values less than (1), partition part_2 values less than (100), partition part_3 values less than (maxvalue));
--error 1697
alter table Z0CASE partition by range(1+Z0_TEST0+1)(partition part_1 values less than (1), partition part_2 values less than (100), partition part_3 values less than (maxvalue));
--error 1697
alter table Z0CASE partition by range(1+1+Z0_TEST0+1)(partition part_1 values less than (1), partition part_2 values less than (100), partition part_3 values less than (maxvalue));
drop table if exists Z0CASE;


--error 1659
create table Z0CASE (Z0_TEST0 blob,Z0_TEST1 int) partition by range(Z0_TEST0)(partition part_1 values less than (1), partition part_2 values less than (100), partition part_3 values less than (maxvalue));
--error 1697
create table Z0CASE (Z0_TEST0 blob,Z0_TEST1 int) partition by range(Z0_TEST0+1)(partition part_1 values less than (1), partition part_2 values less than (100), partition part_3 values less than (maxvalue));
--error 1697
create table Z0CASE (Z0_TEST0 blob,Z0_TEST1 int) partition by range(1+Z0_TEST0+1)(partition part_1 values less than (1), partition part_2 values less than (100), partition part_3 values less than (maxvalue));
--error 1697
create table Z0CASE (Z0_TEST0 blob,Z0_TEST1 int) partition by range(1+1+Z0_TEST0+1)(partition part_1 values less than (1), partition part_2 values less than (100), partition part_3 values less than (maxvalue));
drop table if exists Z0CASE;

--echo bugfix 
create table Z0CASE (Z0_TEST0 int ,Z0_TEST1 int);
alter table Z0CASE partition by list(Z0_TEST0)
subpartition by range(Z0_TEST0)
(
partition part_1 values in ( 1, 2 ,-1,0),
partition part_2 values in ( 30, 111 )
);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table Z0CASE;
drop table if exists Z0CASE;

--echo bugfix 
create table Z0CASE (Z0_TEST0 int ,Z0_TEST1 int);
INSERT INTO Z0CASE(Z0_TEST0,Z0_TEST1)values('1','111');
INSERT INTO Z0CASE(Z0_TEST0,Z0_TEST1)values('1','111');
INSERT INTO Z0CASE(Z0_TEST0,Z0_TEST1)values('1','111');
--error 1493
alter table Z0CASE
partition by range(Z0_TEST0)
(
  partition part_1 values less than (-1 ),
  partition part_2 values less than (maxvalue ),
  partition part_3 values less than ( maxvalue )
);
drop table if exists Z0CASE;

--echo bugfix 
create table Z0CASE (Z0_TEST0 blob,Z0_TEST1 int);
--error 1697
alter table Z0CASE
partition by range(Z0_TEST0+0000)
(
  partition part_1 values less than (1),
  partition part_2 values less than (100),
  partition part_3 values less than (maxvalue)
);
drop table if exists Z0CASE;

--echo bugfix 
create table Z0CASE (Z0_TEST0 TINYBLOB,Z0_TEST1 BLOB);
--error 1659
alter table Z0CASE partition by key(Z0_TEST0) partitions 3;
drop table if exists Z0CASE;

--echo bugfix 
CREATE TABLE Z0CASE(Z0_TEST0 int);
INSERT INTO Z0CASE(z0_test0)values('1111.111');
INSERT INTO Z0CASE(z0_test0)values('1111.111');
INSERT INTO Z0CASE(z0_test0)values('1111.111');
ALTER TABLE Z0CASE PARTITION BY key(Z0_TEST0) PARTITIONS 2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table Z0CASE;
ALTER TABLE Z0CASE PARTITION BY range(Z0_TEST0) (PARTITION p1 VALUES LESS THAN (10),PARTITION p2 VALUES LESS THAN (100),PARTITION p3 VALUES LESS THAN MAXVALUE);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table Z0CASE;
drop table if exists Z0CASE;

--echo bugfix 
create table Z0CASE(Z0_TEST0 int, Z0_TEST1 int);
