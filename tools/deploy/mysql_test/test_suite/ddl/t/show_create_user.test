--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: sean.yyj
# owner group: SQL1
# tags: ddl
# description: show create user

--disable_warnings
drop user if exists u1;
drop user if exists u2;
drop user if exists u3@`127.0.0.1`;
drop user if exists u4;
drop user if exists u5;
drop user if exists u6;
drop user if exists u7;
drop user if exists u8;
drop procedure if exists my_proc1;
drop procedure if exists my_proc2;

# 正常功能测试
CREATE USER u1;
CREATE USER u2@`%` IDENTIFIED BY '123456' REQUIRE NONE WITH MAX_CONNECTIONS_PER_HOUR 20;
CREATE USER u3@`127.0.0.1` IDENTIFIED WITH 'mysql_native_password' BY 'abcdef' REQUIRE SSL WITH MAX_USER_CONNECTIONS 40;
CREATE USER u4 REQUIRE X509 WITH MAX_CONNECTIONS_PER_HOUR 60 MAX_USER_CONNECTIONS 80;
CREATE USER u5 REQUIRE CIPHER 'AES128-SHA';
CREATE USER u6 REQUIRE ISSUER '/CN=MySQL_Server_5.7.24_Auto_Generated_CA_Certificate';
CREATE USER u7 REQUIRE SUBJECT '/CN=MySQL_Server_5.7.24_Auto_Generated_CA_Certificate';
CREATE USER u8 REQUIRE CIPHER 'AES128-SHA' ISSUER '/CN=MySQL_Server_5.7.24_Auto_Generated_CA_Certificate' SUBJECT '/CN=MySQL_Server_5.7.24_Auto_Generated_CA_Certificate';

--result_format 4
let $show_1 = query_get_value(SHOW CREATE USER u1, CREATE USER for u1@%, 1);
let $show_2 = query_get_value(SHOW CREATE USER u2@`%`, CREATE USER for u2@%, 1);
let $show_3 = query_get_value(SHOW CREATE USER u3@`127.0.0.1`, CREATE USER for u3@127.0.0.1, 1);
let $show_4 = query_get_value(SHOW CREATE USER u4, CREATE USER for u4@%, 1);
let $show_5 = query_get_value(SHOW CREATE USER u5, CREATE USER for u5@%, 1);
let $show_6 = query_get_value(SHOW CREATE USER u6, CREATE USER for u6@%, 1);
let $show_7 = query_get_value(SHOW CREATE USER u7, CREATE USER for u7@%, 1);
let $show_8 = query_get_value(SHOW CREATE USER u8, CREATE USER for u8@%, 1);
let $show_9 = query_get_value(SHOW CREATE USER admin, CREATE USER for admin@%, 1);
let $show_10 = query_get_value(SHOW CREATE USER CURRENT_USER, CREATE USER for admin@%, 1);
let $show_11 = query_get_value(SHOW CREATE USER CURRENT_USER(), CREATE USER for admin@%, 1);
--sorted_result
select 1 as tenant_id, user_name, host, passwd, is_locked, ssl_type, ssl_cipher, x509_issuer, x509_subject, type, max_connections, max_user_connections from oceanbase.__all_user where user_name regexp '^u[1-8]$';
drop user u1;
drop user u2;
drop user u3@`127.0.0.1`;
drop user u4;
drop user u5;
drop user u6;
drop user u7;
drop user u8;

eval $show_1;
eval $show_2;
eval $show_3;
eval $show_4;
eval $show_5;
eval $show_6;
eval $show_7;
eval $show_8;
eval $show_9;
eval $show_10;
eval $show_11;
--sorted_result
select 1 as tenant_id, user_name, host, passwd, is_locked, ssl_type, ssl_cipher, x509_issuer, x509_subject, type, max_connections, max_user_connections from oceanbase.__all_user where user_name regexp '^u[1-8]$';

delimiter //;
CREATE definer = 'u1' PROCEDURE my_proc1 ()
BEGIN
  show create user current_user();
END
//
delimiter ;//

delimiter //;
CREATE PROCEDURE my_proc2 ()
BEGIN
  show create user current_user();
END
//
delimiter ;//
--error 1370
call my_proc1();
call my_proc2();

# 异常测试
grant select on test.* to u2;
--error 1396
SHOW CREATE USER u9;
--error 1396
SHOW CREATE USER u3;
--error 1396
SHOW CREATE USER u2@`127.0.0.1`;

connect(conn_u2,$OBMYSQL_MS0,u2,'123456',test,$OBMYSQL_PORT);
connection conn_u2;
SHOW CREATE USER CURRENT_USER;
SHOW CREATE USER u2;
--error 1044
SHOW CREATE USER u9;
--error 1044
SHOW CREATE USER u1;
--error 1044
SHOW CREATE USER u3@`127.0.0.1`;
--error 1370
call my_proc1();
--error 1370
call my_proc2();

disconnect conn_u2;
connection default;
grant select on oceanbase.* to u2;
grant execute on PROCEDURE test.my_proc1 to u1;
grant execute on PROCEDURE test.my_proc1 to u2;
grant execute on PROCEDURE test.my_proc2 to u2;
connect(conn_u2,$OBMYSQL_MS0,u2,'123456',test,$OBMYSQL_PORT);
connection conn_u2;

SHOW CREATE USER u1;
SHOW CREATE USER u2;
SHOW CREATE USER u3@`127.0.0.1`;
call my_proc1();
call my_proc2();

disconnect conn_u2;
connection default;
revoke select on oceanbase.* from u2;
grant select on mysql.* to u2;
connect(conn_u2,$OBMYSQL_MS0,u2,'123456',test,$OBMYSQL_PORT);
connection conn_u2;

SHOW CREATE USER u1;
SHOW CREATE USER u2;
SHOW CREATE USER u3@`127.0.0.1`;

disconnect conn_u2;
connection default;
revoke select on mysql.* from u2;
grant select on mysql.user to u2;
connect(conn_u2,$OBMYSQL_MS0,u2,'123456',test,$OBMYSQL_PORT);
connection conn_u2;

--error 1044
SHOW CREATE USER u1;
SHOW CREATE USER u2;
--error 1044
SHOW CREATE USER u3@`127.0.0.1`;

disconnect conn_u2;
connection default;
revoke select on mysql.user from u2;
grant select on oceanbase.__all_user to u2;
connect(conn_u2,$OBMYSQL_MS0,u2,'123456',test,$OBMYSQL_PORT);
connection conn_u2;

--error 1044
SHOW CREATE USER u1;
SHOW CREATE USER u2;
--error 1044
SHOW CREATE USER u3@`127.0.0.1`;

connection default;
drop user u1;
drop user u2;
drop user u3@`127.0.0.1`;
drop user u4;
drop user u5;
drop user u6;
drop user u7;
drop user u8;
drop procedure my_proc1;
drop procedure my_proc2;