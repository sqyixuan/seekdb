--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# owner group: SQL2
# description: Verify sql mode

--disable_warnings
drop database if exists luofan_db;
create database luofan_db;
--enable_warnings

use luofan_db;
create table t1 (c1 int primary key auto_increment, c2 int zerofill, c3 varchar(64) CHARACTER SET utf8 collate utf8_unicode_ci, c4 int not null, c5 int default 10, c6 timestamp ON UPDATE CURRENT_TIMESTAMP, c7 varchar(64) comment 'is comment', c8 varchar(64) generated always as (c3)) CHARACTER SET gbk;
show create table t1;
set sql_mode = 'NO_FIELD_OPTIONS';
show create table t1;
set sql_mode = 'NO_KEY_OPTIONS';
show create table t1;
set sql_mode = 'NO_TABLE_OPTIONS';
show create table t1;
set sql_mode = 'NO_FIELD_OPTIONS,NO_KEY_OPTIONS,NO_TABLE_OPTIONS';
show create table t1;
drop table t1;
set sql_mode = '';

create table t1 (c1 int primary key, c2 int, c3 int);
create unique index idx1 on t1 (c2) storing (c3);
show create table t1;
set sql_mode = 'NO_FIELD_OPTIONS';
show create table t1;
set sql_mode = 'NO_KEY_OPTIONS';
show create table t1;
set sql_mode = 'NO_TABLE_OPTIONS';
show create table t1;
set sql_mode = 'NO_FIELD_OPTIONS,NO_KEY_OPTIONS,NO_TABLE_OPTIONS';
show create table t1;
drop table t1;
set sql_mode = '';

create table t1 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 5;
create unique index idx1 on t1 (c2) storing (c3) global;
show create table t1;
set sql_mode = 'NO_FIELD_OPTIONS';
show create table t1;
set sql_mode = 'NO_KEY_OPTIONS';
show create table t1;
set sql_mode = 'NO_TABLE_OPTIONS';
show create table t1;
set sql_mode = 'NO_FIELD_OPTIONS,NO_KEY_OPTIONS,NO_TABLE_OPTIONS';
show create table t1;
drop table t1;
set sql_mode = '';

create table t1 (c1 int primary key, c2 int unique, c3 int);
create table t2 (c1 int primary key, c2 int unique, c3 int, c4 int, foreign key(c2) references t1(c2));
alter table t2 add constraint cst check(c3 = c4);
show create table t1;
set sql_mode = 'NO_FIELD_OPTIONS';
show create table t1;
set sql_mode = 'NO_KEY_OPTIONS';
show create table t1;
set sql_mode = 'NO_TABLE_OPTIONS';
show create table t1;
set sql_mode = 'NO_FIELD_OPTIONS,NO_KEY_OPTIONS,NO_TABLE_OPTIONS';
show create table t1;
drop table t2;
drop table t1;
set sql_mode = '';

--echo # Clean
drop database luofan_db;
