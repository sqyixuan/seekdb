# involving foreign key 
--disable_warnings
drop table if exists t1_decimal;
drop sequence if exists s1;
--enable_warnings
create table t1_decimal (a decimal(10,2) unique);
create table t2_decimal (a decimal(10,2), foreign key (a) references t1_decimal(a));
create index tdx_t1_decimal on t1_decimal(a);
create sequence s1 cache 1000000 noorder;
insert into t1_decimal select s1.nextval from table(generator(62));
--error 1235 
alter table t1_decimal change column a a decimal(18,2);
--error 1235 
alter table t2_decimal change column a a decimal(18,2);
insert into t1_decimal select s1.nextval from table(generator(2000));
select count(*) from t1_decimal;
drop table if exists t2_decimal;

# generated column stored and virtual
--disable_warnings
drop table if exists t1_decimal;
drop sequence if exists s1;
--enable_warnings
create table t1_decimal (a decimal(10,2), b decimal(10,2) generated always as (a*2) STORED);
create sequence s1 cache 1000000 noorder;
insert into t1_decimal(a) select s1.nextval from table(generator(2000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_decimal', table_id, 1);
alter table t1_decimal change column a a decimal(18,2);
--error 3106
alter table t1_decimal change column b b decimal(18,2);
--error 3106
alter table t1_decimal change column b b decimal(18,2) generated always as (a*2) VIRTUAL;
alter table t1_decimal change column b b decimal(18,2) generated always as (a*2) STORED;
insert into t1_decimal(a) select s1.nextval from table(generator(2000));
select count(*) from t1_decimal;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_decimal', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}
--disable_warnings
drop table if exists t1_decimal;
drop sequence if exists s1;
--enable_warnings
create table t1_decimal (a decimal(10,2), b decimal(10,2) generated always as (a*2) VIRTUAL);
create sequence s1 cache 1000000 noorder;
insert into t1_decimal(a) select s1.nextval from table(generator(2000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_decimal', table_id, 1);
alter table t1_decimal change column a a decimal(18,2);
--error 3106
alter table t1_decimal change column b b decimal(18,2);
--error 3106
alter table t1_decimal change column b b decimal(18,2) generated always as (a*2) STORED;
alter table t1_decimal change column b b decimal(18,2) generated always as (a*2) VIRTUAL;
insert into t1_decimal(a) select s1.nextval from table(generator(2000));
select count(*) from t1_decimal;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_decimal', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}

