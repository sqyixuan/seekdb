insert into t1_decimal select s1.nextval from table(generator(2000));
select count(*) from t1_decimal;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_decimal', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}
--disable_warnings
drop table if exists t1_decimal;
drop sequence if exists s1;
--enable_warnings
create table t1_decimal (a decimal(39,2));
create sequence s1 cache 1000000 noorder;
insert into t1_decimal select s1.nextval from table(generator(62));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_decimal', table_id, 1);
alter table t1_decimal change column a a decimal(65,2);
insert into t1_decimal select s1.nextval from table(generator(2000));
select count(*) from t1_decimal;
