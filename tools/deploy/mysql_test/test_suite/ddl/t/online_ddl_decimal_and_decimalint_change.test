# owner: gaishun.gs
# owner group: storage : index and ddl
# description: 向上列类型转换
# note: ob do mysqltest --suite=ddl --test_set=online_ddl_decimal_and_decimalint_change -n 43_int2bigint
# note: ob do mysqltest --suite=ddl --test_set=online_ddl_decimal_and_decimalint_change -n 43base
 
--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
 
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

# check the alter correction of type change
# common column decimal(x1, y) -> decimal(x2, y); x2>=x1 && in the same range: online
--disable_warnings
drop table if exists t1_decimal;
drop sequence if exists s1;
--enable_warnings
create table t1_decimal (a decimal(1,0));
create sequence s1 cache 1000000 noorder;
insert into t1_decimal select s1.nextval from table(generator(1));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_decimal', table_id, 1);
alter table t1_decimal change column a a decimal(9,0);
insert into t1_decimal select s1.nextval from table(generator(2000));
select count(*) from t1_decimal;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_decimal', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}
--disable_warnings
drop table if exists t1_decimal;
drop sequence if exists s1;
--enable_warnings
create table t1_decimal (a decimal(10,2));
create sequence s1 cache 1000000 noorder;
insert into t1_decimal select s1.nextval from table(generator(62));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_decimal', table_id, 1);
alter table t1_decimal change column a a decimal(18,2);
insert into t1_decimal select s1.nextval from table(generator(2000));
select count(*) from t1_decimal;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_decimal', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}
--disable_warnings
drop table if exists t1_decimal;
drop sequence if exists s1;
--enable_warnings
create table t1_decimal (a decimal(19,2));
create sequence s1 cache 1000000 noorder;
insert into t1_decimal select s1.nextval from table(generator(62));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_decimal', table_id, 1);
