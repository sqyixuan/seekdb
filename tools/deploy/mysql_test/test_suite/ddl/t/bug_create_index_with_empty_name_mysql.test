# owner : dachuan.sdc
# owner group : SQL1
# description : 测试 mysql 模式下不允许创建名字为空串或以空格结尾的索引和表
# tags: ddl 

--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_result_log
drop table if exists t1;
drop table if exists `li bo yang`;
--enable_result_log

--error 1280
create table t1(c1 int, index `` (c1));
--error 1280
create table t1(c1 int, unique key `` (c1));

create table t1(c1 int);
--error 1280
create index `` on t1(c1);
--error 1280
create unique index `` on t1(c1);
--error 1280
alter table t1 add index `` (c1);
--error 1280
alter table t1 add unique index `` (c1);
drop table t1;

## 测试 mysql 模式下不支持 index 名以空格结尾
create table t1(c1 int, c2 int);
--error 1280
create index ` ` on t1(c1);
--error 1280
create unique index `a ` on t1(c2);

## 测试 mysql 模式下不支持 table 名以空格结尾
--error 1103
create table `` (c1 int, c2 int, c3 int);
--error 1103
create table ` ` (c1 int, c2 int, c3 int);
--error 1103
create table `li bo yang  ` (c1 int, c2 int, c3 int);
create table `li bo yang` (c1 int, c2 int, c3 int);
--error 1050
create table `li bo yang` (c1 int, c2 int, c3 int);
--error 1103
drop table `li bo yang  `;
drop table `li bo yang`;

# clean up
drop table t1;