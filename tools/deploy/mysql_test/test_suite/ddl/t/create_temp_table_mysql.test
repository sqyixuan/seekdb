create temporary table temp_pq(c int);
--error 1050
create table temp_pq as select 1 as x, 2 as y from dual;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table temp_pq;
drop table temp_pq;
##bug19839990, mysql模式下视图和临时表解析存在的报错问题
drop table t1;
create table t1 (c int);
insert into t1 values(5);

create view v_t1 as select * from t1;

create temporary table t1 (a int, b int);
insert into t1 values(56, 77);
commit;

select * from v_t1;

#issue 48098793
SELECT  TABLE_NAME, TABLE_SCHEMA FROM information_schema.columns WHERE TABLE_SCHEMA = 't1';

drop view v_t1;
drop temporary table t1;
drop table t1;


drop database create_temp_table_db;
drop database oc1;

connection my_obsys;

--disable_query_log
call oceanbase.drop_tenant_force('tenant_test');
--enable_query_log

disconnect my_obsys;
