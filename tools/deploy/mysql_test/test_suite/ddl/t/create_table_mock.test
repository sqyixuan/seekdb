# mock
drop table if exists tmock, tmock1;
create table tmock (c1 text column_format fixed storage memory)
CONNECTION = '123@123'
data directory = '/tmp/mock_data'
delay_key_write = 10
ENCRYPTION = 'enrypt'
insert_method = first
MAX_ROWS = 100000000
MIN_ROWS = 100
PASSWORD = '123'
PACK_KEYS = DEFAULT
STATS_AUTO_RECALC = DEFAULT
STATS_PERSISTENT = DEFAULT
STATS_SAMPLE_PAGES = DEFAULT
UNION = (t1, t2);

