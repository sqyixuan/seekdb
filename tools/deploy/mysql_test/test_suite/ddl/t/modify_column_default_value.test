--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# owner group: SQL2
# description:
#
--disable_abort_on_error

--disable_warnings
drop database if exists luofan_db;
--enable_warnings
create database luofan_db;
use luofan_db;

create table t1 (c1 char(64));
show create table t1;
alter table t1 modify c1 char(0) default '   ';
show create table t1;
alter table t1 modify c1 char(3) default '   ';
show create table t1;
drop table t1;

create table t1 (c1 char(64));
show create table t1;
alter table t1 change column c1 c1 char(0) default '   ';
show create table t1;
alter table t1 change column c1 c1 char(3) default '   ';
show create table t1;
drop table t1;
drop database luofan_db;