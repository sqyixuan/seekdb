# owner: zhaoziqian.zzq
# owner group: rs
# tags: ddl
# description: test dbms_partition.manage_dynamic_partition() with mock current_time in mysql mode

connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection mysql;
set recyclebin = off;
--disable_warnings
drop database if exists ziqian_dynamic_part;
--enable_warnings
create database ziqian_dynamic_part;
use ziqian_dynamic_part;

# +8:00 time zone
set time_zone = '+8:00';

# turn off scheduled manage dynamic partition
CALL DBMS_SCHEDULER.DISABLE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY');
CALL DBMS_SCHEDULER.DISABLE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY');

# case 1: non-integer-hour time
let mock_current_timestamp = query_get_value(select unix_timestamp('2025-02-04 05:06:07') * 1000000 as ts, ts, 1);
connection sys;
eval alter system set_tp tp_name = ERRSIM_DYNAMIC_PARTITION_MOCK_TIME, error_code = $mock_current_timestamp, frequency = 1;
connection mysql;
create table t1 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'hour',
  precreate_time = '3hour'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-02-04')
);
call dbms_partition.manage_dynamic_partition();
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;
create table t1 (c1 timestamp)
dynamic_partition_policy
(
  time_unit = 'hour',
  precreate_time = '3hour'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-02-04')
);
call dbms_partition.manage_dynamic_partition();
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;
create table t1 (c1 date)
dynamic_partition_policy
(
  time_unit = 'day',
  precreate_time = '3day'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-02-04')
);
call dbms_partition.manage_dynamic_partition();
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;
create table t1 (c1 year)
dynamic_partition_policy
(
  time_unit = 'year',
  precreate_time = '3year'
)
partition by range columns (c1)
(
  partition p0 values less than (2025)
);
call dbms_partition.manage_dynamic_partition();
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;
let timestamp = query_get_value(select unix_timestamp('2025-02-04 05:06:07') as ts, ts, 1);
eval create table t1 (c1 bigint)
dynamic_partition_policy
(
  time_unit = 'hour',
  precreate_time = '3hour',
  bigint_precision = 's'
)
partition by range columns (c1)
(
  partition p0 values less than ($timestamp)
);
call dbms_partition.manage_dynamic_partition();
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;


