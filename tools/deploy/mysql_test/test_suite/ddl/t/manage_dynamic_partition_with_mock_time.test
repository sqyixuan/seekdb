# case 7: backfill history partitions when scheduling is missed
let mock_current_timestamp = query_get_value(select unix_timestamp('2025-02-10 00:00:00') * 1000000 as ts, ts, 1);
connection sys;
eval alter system set_tp tp_name = ERRSIM_DYNAMIC_PARTITION_MOCK_TIME, error_code = $mock_current_timestamp, frequency = 1;
connection mysql;
create table t7 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'day',
  precreate_time = '3day'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-02-01')
);
call dbms_partition.manage_dynamic_partition();
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t7;
drop table t7;


# recover & clear
drop database ziqian_dynamic_part;
CALL DBMS_SCHEDULER.ENABLE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY');
CALL DBMS_SCHEDULER.ENABLE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY');
connection sys;
eval alter system set_tp tp_name = ERRSIM_DYNAMIC_PARTITION_MOCK_TIME, error_code = 0, frequency = 0;
