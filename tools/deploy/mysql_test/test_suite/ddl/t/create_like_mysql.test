--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL1
# description: Verify create table T like ..., 
# results should be the same as mysql(verified on 5.6.35)
--disable_warnings
drop database if exists create_like_db;
--enable_warnings
create database create_like_db;

--result_format 4

use create_like_db;
create table t1(c1 int, c2 varchar(10), c3 date);
insert into t1 values(5236, 'scott', '2018-5-8');
insert into t1 values(1024, '中', '2018-1-1');
commit;

## set @@session.ob_enable_transformation = 0;
--echo ### Q1 最基本测试
create table t1_x11 like t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1_x11;

create table t_hash(
c_0_bZ8 int(255) NOT NULL default 0,
c_1_5fyep1 date NOT NULL default '2015-09-22',
c_2_vSZK4t tinyint(255) NOT NULL default 0,
c_3_t varchar(255) NOT NULL default 'abcd0000',
c_4_k4SL varchar(255) NULL default 'abcd0000',
c_5_75kpqT varbinary(255) NULL default 'abcd0000',
primary key(c_0_bZ8,c_1_5fyep1,c_2_vSZK4t),
index i_0_7(c_0_bZ8,c_2_vSZK4t,c_3_t,c_4_k4SL,c_5_75kpqT) LOCAL )
partition by hash(c_0_bZ8*c_2_vSZK4t) partitions 27;

create table t_list(
c_0_V1pX bigint(255) NOT NULL default 0,
c_1_j6Rr varbinary(255) NOT NULL default 'abcd0000',
c_2_5tLecd char(255) NOT NULL default 'abcd0000',
c_3_Jlu varbinary(255) NOT NULL default 'abcd0000',
c_4_rE tinyint(255) auto_increment NOT NULL,
c_5_gLO1 bigint(255) NULL default 0,
c_6_bN float NULL default 0.70007,
c_7_zRES0y double NOT NULL default 0.700007,
c_8_Q binary(255) NULL default NULL,
primary key(c_0_V1pX,c_1_j6Rr,c_2_5tLecd,c_3_Jlu,c_4_rE))
partition by range(c_0_V1pX)
 (PARTITION p0 VALUES LESS THAN (67),
 PARTITION p1 VALUES LESS THAN (1500),
 PARTITION p2 VALUES LESS THAN (2500),
 PARTITION p3 VALUES LESS THAN MAXVALUE);

create table t_hash_like like t_hash;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_hash_like;

create table t_list_like like t_list;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_list_like;

drop database create_like_db;
