CREATE TABLE `ocean base` (col1 INT,col2 INT) 
PARTITION BY KEY (col1) 
SUBPARTITION BY KEY (col2) (
    PARTITION p1 (
        SUBPARTITION p1_h1,
        SUBPARTITION p1_h2
    ),
