#owner: luofan.zp
#owner group: sql2
#description: test obj dependency

--result_format 4

--disable_warnings
drop table if exists luofan_t1, luofan_t2, luofan_t3;
drop view if exists luofan_v1, luofan_v2, luofan_v3, luofan_v4;
--enable_warnings

create table luofan_t1 (c1 int, c2 int, c3 int, c4 int);
create table luofan_t2 (c1 int, c2 int, c3 int, c4 int);
create table luofan_t3 (c1 int, c2 int, c3 int, c4 int);
create view luofan_v1 as select t.c1 as c1, t.c2 as c2 from luofan_t1 t where t.c1 > 10;
create view luofan_v2 as select * from luofan_t2;
create view luofan_v3 as select * from luofan_v1;
create view luofan_v4 as select t.c1, t.c2, t.c3 from luofan_t3 t, luofan_v3 v where t.c1 = v.c2;

select * from information_schema.VIEW_TABLE_USAGE where VIEW_NAME in ('LUOFAN_V1', 'LUOFAN_V2', 'LUOFAN_V3', 'LUOFAN_V4') order by VIEW_NAME;

drop table luofan_t1;
sleep 5;
select VIEW_CATALOG, VIEW_SCHEMA, VIEW_NAME, TABLE_SCHEMA, substring(TABLE_NAME, 1, 9), TABLE_CATALOG from information_schema.VIEW_TABLE_USAGE where VIEW_NAME in ('LUOFAN_V1', 'LUOFAN_V2', 'LUOFAN_V3', 'LUOFAN_V4') order by VIEW_NAME;

--error 1356
select * from luofan_v1;
sleep 5;
select VIEW_CATALOG, VIEW_SCHEMA, VIEW_NAME, TABLE_SCHEMA, substring(TABLE_NAME, 1, 9) AS TABLE_NAME, TABLE_CATALOG from information_schema.VIEW_TABLE_USAGE where VIEW_NAME in ('LUOFAN_V1', 'LUOFAN_V2', 'LUOFAN_V3', 'LUOFAN_V4') order by VIEW_NAME, TABLE_NAME;

create table luofan_t1 (c1 int, c2 int, c3 int, c4 int);
select * from luofan_v1;
sleep 5;
select VIEW_CATALOG, VIEW_SCHEMA, VIEW_NAME, TABLE_SCHEMA, substring(TABLE_NAME, 1, 9) AS TABLE_NAME, TABLE_CATALOG from information_schema.VIEW_TABLE_USAGE where VIEW_NAME in ('LUOFAN_V1', 'LUOFAN_V2', 'LUOFAN_V3', 'LUOFAN_V4') order by VIEW_NAME, TABLE_NAME;

create or replace view luofan_v1 as select t.c1 as c1, t.c2 as c2 from luofan_t1 t where t.c1 > 1;
sleep 5;
select VIEW_CATALOG, VIEW_SCHEMA, VIEW_NAME, TABLE_SCHEMA, substring(TABLE_NAME, 1, 9) AS TABLE_NAME, TABLE_CATALOG from information_schema.VIEW_TABLE_USAGE where VIEW_NAME in ('LUOFAN_V1', 'LUOFAN_V2', 'LUOFAN_V3', 'LUOFAN_V4') order by VIEW_NAME, TABLE_NAME;

drop table luofan_t2;
--error 1356
select * from luofan_v2;
sleep 5;
select VIEW_CATALOG, VIEW_SCHEMA, VIEW_NAME, TABLE_SCHEMA, substring(TABLE_NAME, 1, 9) AS TABLE_NAME, TABLE_CATALOG from information_schema.VIEW_TABLE_USAGE where VIEW_NAME in ('LUOFAN_V1', 'LUOFAN_V2', 'LUOFAN_V3', 'LUOFAN_V4') order by VIEW_NAME, TABLE_NAME;

drop view luofan_v3;
select VIEW_CATALOG, VIEW_SCHEMA, VIEW_NAME, TABLE_SCHEMA, substring(TABLE_NAME, 1, 9) AS TABLE_NAME, TABLE_CATALOG from information_schema.VIEW_TABLE_USAGE where VIEW_NAME in ('LUOFAN_V1', 'LUOFAN_V2', 'LUOFAN_V3', 'LUOFAN_V4') order by VIEW_NAME, TABLE_NAME;

drop view luofan_v1;
drop view luofan_v2;
drop view luofan_v4;
select * from information_schema.VIEW_TABLE_USAGE where VIEW_NAME in ('LUOFAN_V1', 'LUOFAN_V2', 'LUOFAN_V3', 'LUOFAN_V4') order by VIEW_NAME, TABLE_NAME;

create database luofan_db;
use luofan_db;
create table luofan_t1 (c1 int, c2 int, c3 int, c4 int);
create table luofan_t2 (c1 int, c2 int, c3 int, c4 int);
create table luofan_t3 (c1 int, c2 int, c3 int, c4 int);
create view luofan_v1 as select t.c1 as c1, t.c2 as c2 from luofan_t1 t where t.c1 > 10;
create view luofan_v2 as select * from luofan_t2;
create view luofan_v3 as select * from luofan_v1;
create view luofan_v4 as select t.c1, t.c2, t.c3 from luofan_t3 t, luofan_v3 v where t.c1 = v.c2;

sleep 5;
select * from information_schema.VIEW_TABLE_USAGE where VIEW_NAME in ('LUOFAN_V1', 'LUOFAN_V2', 'LUOFAN_V3', 'LUOFAN_V4') order by VIEW_NAME, TABLE_NAME;

drop database luofan_db;
sleep 5;
select * from information_schema.VIEW_TABLE_USAGE where VIEW_NAME in ('LUOFAN_V1', 'LUOFAN_V2', 'LUOFAN_V3', 'LUOFAN_V4') order by VIEW_NAME, TABLE_NAME;
