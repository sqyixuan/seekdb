# owner: gaishun.gs
# owner group: storage : index and ddl
# description: 向上列类型转换 update shadow column schema of index table
# note: ob do mysqltest --suite=ddl --test_set=online_ddl_column_change_bug_53867642 -n 43_int2bigint
# bug url 
 
--disable_warnings
drop table if exists t1;
drop sequence if exists s1;
--enable_warnings
 
create table t1(c1 int primary key, c2 tinyint unsigned);
insert into t1(c1, c2) values (0, 2);
insert into t1(c1, c2) values (1, 12);
insert into t1(c1, c2) values (6, 32);
insert into t1(c1, c2) values (2147483644, 2);
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc 
 
insert into t1(c1, c2) values (7, 25);
insert into t1(c1, c2) values (8, 26);
insert into t1(c1, c2) values (2147483645, 2);
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
 
insert into t1(c1, c2) values (2147483647, 72);
# int -> bigint
alter table t1 modify column c1 bigint default 4523;
# utinyint -> bigint
alter table t1 modify column c2 bigint default 4523;
insert into t1(c1, c2) values (214749000000, -21474900000);
insert into t1(c1, c2) values (7324, 11444);
insert into t1(c1, c2) values (5867, 2);
insert into t1(c1, c2) values (5288, 2);
insert into t1(c1, c2) values (1137, 2);
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
insert into t1(c1, c2) values (1199, 2);
insert into t1(c1, c2) values (11804, 2);
insert into t1(c1, c2) values (214749000080, 2);
insert into t1(c1, c2) values (17608, 2);
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc 
 
select c1, c2 from t1; 
 