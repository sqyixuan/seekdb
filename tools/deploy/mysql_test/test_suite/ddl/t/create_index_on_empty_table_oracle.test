--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: buming.lj
#owner group: ddl
#description: test create index on empty table with special table name 


ALTER SYSTEM SET "_parallel_ddl_control" = 'CREATE_INDEX:ON';

--error 0,942
DROP TABLE "ocean base@ob";
--error 0,942

CREATE TABLE "ocean base@ob" (
col_int INT,
col_bool NUMBER(1),
pk INT
) partition by hash(col_int) partitions 128;

create index idx1 on "ocean base@ob"(col_int) local;

create index idx2 on "ocean base@ob"(col_bool) global;

drop table "ocean base@ob";

ALTER SYSTEM SET "_parallel_ddl_control" = 'CREATE_INDEX:OFF';

--error 0,942
DROP TABLE "user";
--error 0,942

CREATE TABLE "user" (
col_int INT,
col_bool NUMBER(1),
pk INT,
CONSTRAINT pk_ocean_base PRIMARY KEY (pk)
);

create index idx1 on "user" (col_int);

drop table "user";

