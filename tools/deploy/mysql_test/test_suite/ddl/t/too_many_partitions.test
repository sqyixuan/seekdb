# owner: zhaoziqian.zzq
# owner group: rs
# tags: ddl
# description: test add too many partitions in mysql mode

connect (mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
set recyclebin = off;

let old_val = query_get_value("select value from oceanbase.__all_virtual_tenant_parameter_stat where name like 'max_partition_num' group by name", value, 1);
alter system set max_partition_num = 65536;
--disable_warnings
drop table if exists ziqian_too_many_partition_table;
--enable_warnings
CREATE TABLE ziqian_too_many_partition_table (
  id1 INT,
  id2 INT
)
PARTITION BY RANGE (id1)
SUBPARTITION BY HASH(id2) SUBPARTITIONS 256
(
  PARTITION p1 VALUES LESS THAN (1000)
);

--error 1499
