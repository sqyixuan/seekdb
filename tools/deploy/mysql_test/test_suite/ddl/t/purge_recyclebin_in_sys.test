--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
 
#owner: xingrui.cwh
#owner group: rs
#description
# The case is to verify the recyclebin in sys
connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connection sys_conn;
 
--disable_warnings
--disable_query_log
--disable_result_log
drop database if exists xingrui_database;
drop table if exists xingrui_table;
--enable_warnings
--enable_query_log
--enable_result_log
 
SET @@recyclebin = on;
 
# case 1 purge table in sys
create table xingrui_table(id int); insert into xingrui_table values(1);
drop table xingrui_table;
 
purge table xingrui_table;
 
# case 2 purge empty database in sys
create database xingrui_database;
drop database xingrui_database;
 
let $database = query_get_value(select object_name from __all_recyclebin where original_name = "xingrui_database", object_name, 1);
--disable_query_log
eval purge database $database;
--enable_query_log
 
# case 3 purge not empty database in sys
create database xingrui_database;
use xingrui_database;
create table xingrui_table(id int); insert into xingrui_table values(1);
drop table xingrui_table;
drop database xingrui_database;
 
use oceanbase;
let $database = query_get_value(select object_name from __all_recyclebin where original_name = "xingrui_database", object_name, 1);
--disable_query_log
eval purge database $database;
--enable_query_log
 
SET @@recyclebin = off;