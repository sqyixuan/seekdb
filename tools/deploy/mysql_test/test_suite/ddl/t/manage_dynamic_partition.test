# owner: zhaoziqian.zzq
# owner group: rs
# tags: ddl
# description: test dbms_partition.manage_dynamic_partition() in mysql mode

connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection mysql;
set recyclebin = off;
--disable_warnings
drop database if exists ziqian_dynamic_part;
--enable_warnings
create database ziqian_dynamic_part;
use ziqian_dynamic_part;

# turn off scheduled manage dynamic partition
CALL DBMS_SCHEDULER.DISABLE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY');
CALL DBMS_SCHEDULER.DISABLE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY');

let now = '2025-03-01 01:02:03';
set time_zone = '+8:00';
let mock_current_timestamp = query_get_value(select unix_timestamp($now) * 1000000 as ts, ts, 1);

connection sys;
eval alter system set_tp tp_name = ERRSIM_DYNAMIC_PARTITION_MOCK_TIME, error_code = $mock_current_timestamp, frequency = 1;
connection mysql;

# case 1: partition key column type

# case 1.1: date
let $two_day_ago = query_get_value(SELECT $now - INTERVAL 2 DAY AS two_day_ago, two_day_ago, 1);
--disable_query_log
eval create table t11 (c1 date)
dynamic_partition_policy
(
  time_unit = 'day',
  precreate_time = '3day',
  expire_time = '1day'
)
partition by range columns (c1)
(
  partition p0 values less than ('$two_day_ago')
);
--enable_query_log
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't11' and table_owner = 'ziqian_dynamic_part';
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't11' and table_owner = 'ziqian_dynamic_part';
drop table t11;
let $two_day_later = query_get_value(SELECT $now + INTERVAL 2 DAY AS two_day_later, two_day_later, 1);
--disable_query_log
eval create table t11 (c1 date)
dynamic_partition_policy
(
  time_unit = 'day',
  precreate_time = '3day',
  expire_time = '1day'
)
partition by range columns (c1)
(
  partition p0 values less than ('$two_day_later')
);
--enable_query_log
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't11' and table_owner = 'ziqian_dynamic_part';
drop table t11;

