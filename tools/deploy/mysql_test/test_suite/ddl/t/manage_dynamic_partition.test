# case 2.3: precreate_time
let $two_hour_ago = query_get_value(SELECT $now - INTERVAL 2 HOUR AS two_hour_ago, two_hour_ago, 1);
--disable_query_log
eval create table t23 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'hour',
  precreate_time = '-1'
)
partition by range columns (c1)
(
  partition p0 values less than ('$two_hour_ago')
);
--enable_query_log
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't23' and table_owner = 'ziqian_dynamic_part';
alter table t23 set dynamic_partition_policy (precreate_time = '0');
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't23' and table_owner = 'ziqian_dynamic_part';
alter table t23 set dynamic_partition_policy (precreate_time = '1hour');
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't23' and table_owner = 'ziqian_dynamic_part';
alter table t23 set dynamic_partition_policy (precreate_time = '1day');
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't23' and table_owner = 'ziqian_dynamic_part';
alter table t23 set dynamic_partition_policy (precreate_time = '1week');
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't23' and table_owner = 'ziqian_dynamic_part';
alter table t23 set dynamic_partition_policy (precreate_time = '1month');
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't23' and table_owner = 'ziqian_dynamic_part';
# alter table t23 set dynamic_partition_policy (precreate_time = '1year');
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't23' and table_owner = 'ziqian_dynamic_part';
drop table t23;

# case 2.4: expire_time
let $current_time = query_get_value(SELECT $now as now, now, 1);
let $two_minute_ago = query_get_value(SELECT $now - INTERVAL 2 MINUTE AS two_minute_ago, two_minute_ago, 1);
let $two_hour_ago = query_get_value(SELECT $now - INTERVAL 2 HOUR AS two_hour_ago, two_hour_ago, 1);
let $two_day_ago = query_get_value(SELECT $now - INTERVAL 2 DAY AS two_day_ago, two_day_ago, 1);
let $two_week_ago = query_get_value(SELECT $now - INTERVAL 2 WEEK AS two_week_ago, two_week_ago, 1);
let $two_month_ago = query_get_value(SELECT $now - INTERVAL 2 MONTH AS two_month_ago, two_month_ago, 1);
let $two_year_ago = query_get_value(SELECT $now - INTERVAL 2 YEAR AS two_year_ago, two_year_ago, 1);
--disable_query_log
eval create table t24 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'hour',
  expire_time = '-1'
)
partition by range columns (c1)
(
  partition p0 values less than ('$two_year_ago'),
  partition p1 values less than ('$two_month_ago'),
  partition p2 values less than ('$two_week_ago'),
  partition p3 values less than ('$two_day_ago'),
  partition p4 values less than ('$two_hour_ago'),
  partition p5 values less than ('$two_minute_ago'),
  partition p6 values less than ('$current_time')
);
--enable_query_log
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't24' and table_owner = 'ziqian_dynamic_part';
alter table t24 set dynamic_partition_policy (expire_time = '1year');
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't24' and table_owner = 'ziqian_dynamic_part';
alter table t24 set dynamic_partition_policy (expire_time = '1month');
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't24' and table_owner = 'ziqian_dynamic_part';
alter table t24 set dynamic_partition_policy (expire_time = '1week');
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't24' and table_owner = 'ziqian_dynamic_part';
alter table t24 set dynamic_partition_policy (expire_time = '1day');
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't24' and table_owner = 'ziqian_dynamic_part';
alter table t24 set dynamic_partition_policy (expire_time = '1hour');
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't24' and table_owner = 'ziqian_dynamic_part';
alter table t24 set dynamic_partition_policy (expire_time = '0');
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't24' and table_owner = 'ziqian_dynamic_part';
drop table t24;

# case 2.5: time_zone
let $orig_time_zone = query_get_value(select @@session.time_zone as time_zone, time_zone, 1);
set time_zone = '+8:00';
let $current_time = query_get_value(SELECT $now as now, now, 1);
--disable_query_log
eval create table t25 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'hour',
  precreate_time = '3hour',
  time_zone = '+6:00'
)
partition by range columns (c1)
(
  partition p0 values less than ('$current_time')
);
--enable_query_log
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't25' and table_owner = 'ziqian_dynamic_part';
--disable_query_log
eval set time_zone = '$orig_time_zone';
--enable_query_log
drop table t25;

# case 2.6: bigint_precision
let $two_day_ago = query_get_value(SELECT CAST(UNIX_TIMESTAMP($now - INTERVAL 2 DAY) * 1000000 AS UNSIGNED) AS two_day_ago, two_day_ago, 1);
--disable_query_log
eval create table t26 (c1 bigint)
dynamic_partition_policy
(
  time_unit = 'hour',
  precreate_time = '3hour',
  bigint_precision = 'us'
)
partition by range columns (c1)
(
  partition p0 values less than ($two_day_ago)
);
--enable_query_log
let $current_time = query_get_value(SELECT CAST(UNIX_TIMESTAMP($now) AS UNSIGNED) as now, now, 1);
call dbms_partition.manage_dynamic_partition();
--disable_query_log
eval select floor((cast(high_value as signed)/1000000-$current_time)/3600) as precreate_num from oceanbase.dba_tab_partitions where table_name = 't26' and table_owner = 'ziqian_dynamic_part' order by partition_position desc limit 1;
--enable_query_log
drop table t26;
let $two_day_ago = query_get_value(SELECT CAST(UNIX_TIMESTAMP($now - INTERVAL 2 DAY) * 1000 AS UNSIGNED) AS two_day_ago, two_day_ago, 1);
--disable_query_log
eval create table t26 (c1 bigint)
dynamic_partition_policy
(
  time_unit = 'hour',
  precreate_time = '3hour',
  bigint_precision = 'ms'
)
partition by range columns (c1)
(
  partition p0 values less than ($two_day_ago)
);
--enable_query_log
let $current_time = query_get_value(SELECT CAST(UNIX_TIMESTAMP($now) AS UNSIGNED) as now, now, 1);
call dbms_partition.manage_dynamic_partition();
--disable_query_log
eval select floor((cast(high_value as signed)/1000-$current_time)/3600) as precreate_num from oceanbase.dba_tab_partitions where table_name = 't26' and table_owner = 'ziqian_dynamic_part' order by partition_position desc limit 1;
--enable_query_log
drop table t26;
let $two_day_ago = query_get_value(SELECT CAST(UNIX_TIMESTAMP($now - INTERVAL 2 DAY) AS UNSIGNED) AS two_day_ago, two_day_ago, 1);
--disable_query_log
eval create table t26 (c1 bigint)
dynamic_partition_policy
(
  time_unit = 'hour',
  precreate_time = '3hour',
  bigint_precision = 's'
)
partition by range columns (c1)
(
  partition p0 values less than ($two_day_ago)
);
--enable_query_log
let $current_time = query_get_value(SELECT CAST(UNIX_TIMESTAMP($now) AS UNSIGNED) as now, now, 1);
call dbms_partition.manage_dynamic_partition();
--disable_query_log
eval select floor((cast(high_value as signed)-$current_time)/3600) as precreate_num from oceanbase.dba_tab_partitions where table_name = 't26' and table_owner = 'ziqian_dynamic_part' order by partition_position desc limit 1;
--enable_query_log
drop table t26;


# case 3: manage dynamic partition procedure params

let $two_day_ago = query_get_value(SELECT $now - INTERVAL 2 DAY AS two_day_ago, two_day_ago, 1);

# case 3.1: precreate_time
--disable_query_log
eval create table t31 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'day',
  precreate_time = '3day'
)
partition by range columns (c1)
(
  partition p0 values less than ('$two_day_ago')
);
--enable_query_log
call dbms_partition.manage_dynamic_partition('1day');
select count(*) from oceanbase.dba_tab_partitions where table_name = 't31' and table_owner = 'ziqian_dynamic_part';
call dbms_partition.manage_dynamic_partition('1week');
select count(*) from oceanbase.dba_tab_partitions where table_name = 't31' and table_owner = 'ziqian_dynamic_part';
call dbms_partition.manage_dynamic_partition('1month');
select count(*) from oceanbase.dba_tab_partitions where table_name = 't31' and table_owner = 'ziqian_dynamic_part';
call dbms_partition.manage_dynamic_partition('1year');
select count(*) from oceanbase.dba_tab_partitions where table_name = 't31' and table_owner = 'ziqian_dynamic_part';
drop table t31;

--error 1210
call dbms_partition.manage_dynamic_partition(123);
--error 1210
call dbms_partition.manage_dynamic_partition('');
--error 1210
call dbms_partition.manage_dynamic_partition('-1');
call dbms_partition.manage_dynamic_partition('0');
--error 1210
call dbms_partition.manage_dynamic_partition('abcd');

