# case 2: dynamic partition policy params

# case 2.1: enable
let $three_day_ago = query_get_value(SELECT $now - INTERVAL 3 DAY AS three_day_ago, three_day_ago, 1);
let $two_day_ago = query_get_value(SELECT $now - INTERVAL 2 DAY AS two_day_ago, two_day_ago, 1);
--disable_query_log
eval create table t21 (c1 datetime)
dynamic_partition_policy
(
  enable = false,
  time_unit = 'day',
  precreate_time = '3day',
  expire_time = '1day'
)
partition by range columns (c1)
(
  partition p0 values less than ('$three_day_ago'),
  partition p1 values less than ('$two_day_ago')
);
--enable_query_log
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't21' and table_owner = 'ziqian_dynamic_part';
alter table t21 set dynamic_partition_policy (enable = true);
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't21' and table_owner = 'ziqian_dynamic_part';
drop table t21;

