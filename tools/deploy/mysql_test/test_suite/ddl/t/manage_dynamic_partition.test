call dbms_partition.manage_dynamic_partition(null, 'day');
select table_name, count(*) from oceanbase.dba_tab_partitions where table_name like 't32%' and table_owner = 'ziqian_dynamic_part' group by table_name order by table_name;
call dbms_partition.manage_dynamic_partition(null, 'week');
select table_name, count(*) from oceanbase.dba_tab_partitions where table_name like 't32%' and table_owner = 'ziqian_dynamic_part' group by table_name order by table_name;
call dbms_partition.manage_dynamic_partition(null, 'month');
select table_name, count(*) from oceanbase.dba_tab_partitions where table_name like 't32%' and table_owner = 'ziqian_dynamic_part' group by table_name order by table_name;
call dbms_partition.manage_dynamic_partition(null, 'year');
select table_name, count(*) from oceanbase.dba_tab_partitions where table_name like 't32%' and table_owner = 'ziqian_dynamic_part' group by table_name order by table_name;
call dbms_partition.manage_dynamic_partition('1year', 'day,week,month');
select table_name, count(*) from oceanbase.dba_tab_partitions where table_name like 't32%' and table_owner = 'ziqian_dynamic_part' group by table_name order by table_name;
drop table t321, t322, t323, t324, t325;

--error 1210
call dbms_partition.manage_dynamic_partition(NULL, 123);
--error 1210
call dbms_partition.manage_dynamic_partition(NULL, '');
--error 1210
call dbms_partition.manage_dynamic_partition(NULL, ',');
--error 1210
call dbms_partition.manage_dynamic_partition(NULL, ',,');
--error 1210
call dbms_partition.manage_dynamic_partition(NULL, 'a,b');
--error 1210
call dbms_partition.manage_dynamic_partition(NULL, ',hour,');
--error 1210
call dbms_partition.manage_dynamic_partition(NULL, 'hour,abcd');


# case 4: maxvalue
--disable_query_log
eval create table t4 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'hour',
  precreate_time = '3hour',
  expire_time = '3hour'
)
partition by range columns (c1)
(
  partition p0 values less than ('$two_day_ago'),
  partition p1 values less than (MAXVALUE)
);
--enable_query_log
call dbms_partition.manage_dynamic_partition();
select count(*) from oceanbase.dba_tab_partitions where table_name = 't4' and table_owner = 'ziqian_dynamic_part';
drop table t4;

# recover & clear
drop database ziqian_dynamic_part;
purge recyclebin;
CALL DBMS_SCHEDULER.ENABLE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY');
CALL DBMS_SCHEDULER.ENABLE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY');
connection sys;
eval alter system set_tp tp_name = ERRSIM_DYNAMIC_PARTITION_MOCK_TIME, error_code = 0, frequency = 0;
