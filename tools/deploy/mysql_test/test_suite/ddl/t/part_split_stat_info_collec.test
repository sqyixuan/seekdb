#### owner: gaishun.gs
#### owner group: storage: index and ddl
#### description: check the statistical information in inner_table during partition splitting.
#### ob do mysqltest --suite ddl --test-set=part_split_stat_info_collec -n feidu_collect
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--result_format 3
connect (obsys,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

--disable_info
--disable_metadata

######################### without local index ###################
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (id int, dob date, primary key(id)) partition by range(id) (partition p0 values less than (30), partition p1 values less than (40), partition p2 values less than (50));
insert into t1 values (22, '2023-06-12'), (33, '2023-06-12'), (46, '2023-06-13');
let $table_id = query_get_value(select table_id from __all_table where table_name='t1', table_id, 1);
let $part_id = query_get_value(select part_id from __all_part where table_id=$table_id and part_name='p2', part_id, 1);

call dbms_stats.gather_table_stats('oceanbase', 't1', method_opt=>'FOR ALL COLUMNS SIZE 4');
--disable_query_log
eval select count(*) from __all_table_stat where table_id=$table_id and partition_id=$part_id;
eval select count(*) from __all_column_stat where table_id=$table_id and partition_id=$part_id;
eval select count(*) from __all_histogram_stat where table_id=$table_id and partition_id=$part_id;
--enable_query_log

alter table t1 reorganize partition p2 into ( partition p2_1 values less than (45), partition p2_2 values less than (50));
--disable_query_log
eval select count(*) from __all_table_stat where table_id=$table_id and partition_id=$part_id;
eval select count(*) from __all_column_stat where table_id=$table_id and partition_id=$part_id;
eval select count(*) from __all_histogram_stat where table_id=$table_id and partition_id=$part_id;
--enable_query_log


######################### with local index ###################
--disable_warnings
drop table if exists t1;
--enable_warnings

# local index is true;
create table t1 (id int, dob date, primary key(id)) partition by range(id) (partition p0 values less than (30), partition p1 values less than (40), partition p2 values less than (50));
create index tbl1_h_idx1 on t1(id) local;
insert into t1 values (22, '2023-06-12'), (33, '2023-06-12'), (46, '2023-06-13');
let $table_id = query_get_value(select table_id from __all_table where table_name='t1', table_id, 1);
let $part_id = query_get_value(select part_id from __all_part where table_id=$table_id and part_name='p2', part_id, 1);
let $index_table_id = query_get_value(select table_id from __all_table where data_table_id=$table_id, table_id, 1);
let $index_part_id = query_get_value(select part_id from __all_part where table_id=$index_table_id and part_name='p2', part_id, 1);

call dbms_stats.gather_table_stats('oceanbase', 't1', method_opt=>'FOR ALL COLUMNS SIZE 4');
--disable_query_log
eval select count(*) from __all_table_stat where table_id=$table_id and partition_id=$part_id;
eval select count(*) from __all_table_stat where table_id=$index_table_id and partition_id=$index_part_id;
eval select count(*) from __all_column_stat where table_id=$table_id and partition_id=$part_id;
eval select count(*) from __all_histogram_stat where table_id=$table_id and partition_id=$part_id;

eval select object_type,sstable_row_cnt,sstable_avg_row_len,macro_blk_cnt,micro_blk_cnt,memtable_row_cnt,memtable_avg_row_len,row_cnt,avg_row_len,global_stats,user_stats,stattype_locked,stale_stats,spare1,spare2,spare3,spare4,spare5,spare6,index_type from __all_table_stat where table_id=$table_id order by table_id;
eval select object_type,sstable_row_cnt,sstable_avg_row_len,macro_blk_cnt,micro_blk_cnt,memtable_row_cnt,memtable_avg_row_len,row_cnt,avg_row_len,global_stats,user_stats,stattype_locked,stale_stats,spare1,spare2,spare3,spare4,spare5,spare6,index_type from __all_table_stat where table_id=$index_table_id order by table_id;
eval select column_id,object_type,distinct_cnt,null_cnt,max_value,b_max_value,min_value,b_min_value,avg_len,distinct_cnt_synopsis,distinct_cnt_synopsis_size,sample_size,density,bucket_cnt,histogram_type,global_stats,user_stats,spare1,spare2,spare3,spare4,spare5,spare6,cg_macro_blk_cnt,cg_micro_blk_cnt,cg_skip_rate from __all_column_stat where table_id=$table_id order by table_id;
eval select column_id,endpoint_num,object_type,endpoint_normalized_value,endpoint_value,b_endpoint_value,endpoint_repeat_cnt from __all_histogram_stat where table_id=$table_id order by table_id;
--enable_query_log

alter table t1 reorganize partition p2 into ( partition p2_1 values less than (45), partition p2_2 values less than (50));
--disable_query_log
eval select count(*) from __all_table_stat where table_id=$table_id and partition_id=$part_id;
eval select count(*) from __all_table_stat where table_id=$index_table_id and partition_id=$index_part_id;
eval select count(*) from __all_column_stat where table_id=$table_id and partition_id=$part_id;
eval select count(*) from __all_histogram_stat where table_id=$table_id and partition_id=$part_id;
# after split, dest partition will copy the stat_info of src partition
eval select object_type,sstable_row_cnt,sstable_avg_row_len,macro_blk_cnt,micro_blk_cnt,memtable_row_cnt,memtable_avg_row_len,row_cnt,avg_row_len,global_stats,user_stats,stattype_locked,stale_stats,spare1,spare2,spare3,spare4,spare5,spare6,index_type from __all_table_stat where table_id=$table_id order by table_id;
eval select object_type,sstable_row_cnt,sstable_avg_row_len,macro_blk_cnt,micro_blk_cnt,memtable_row_cnt,memtable_avg_row_len,row_cnt,avg_row_len,global_stats,user_stats,stattype_locked,stale_stats,spare1,spare2,spare3,spare4,spare5,spare6,index_type from __all_table_stat where table_id=$index_table_id order by table_id;
eval select column_id,object_type,distinct_cnt,null_cnt,max_value,b_max_value,min_value,b_min_value,avg_len,distinct_cnt_synopsis,distinct_cnt_synopsis_size,sample_size,density,bucket_cnt,histogram_type,global_stats,user_stats,spare1,spare2,spare3,spare4,spare5,spare6,cg_macro_blk_cnt,cg_micro_blk_cnt,cg_skip_rate from __all_column_stat where table_id=$table_id order by table_id;
eval select column_id,endpoint_num,object_type,endpoint_normalized_value,endpoint_value,b_endpoint_value,endpoint_repeat_cnt from __all_histogram_stat where table_id=$table_id order by table_id;
--enable_query_log


######################### with two local index ###################
--disable_warnings
drop table if exists t1;
--enable_warnings

# local index is true;
create table t1 (id int, nid int, dob date, primary key(id)) partition by range(id) (partition p0 values less than (30), partition p1 values less than (40), partition p2 values less than (50));
create index tbl1_h_idx1 on t1(id) local;
create index tbl1_h_idx2 on t1(nid) local;
insert into t1 values (22, 23, '2023-06-12'), (33, 34, '2023-06-12'), (46, 47, '2023-06-13');
let $table_id = query_get_value(select table_id from __all_table where table_name='t1', table_id, 1);
let $part_id = query_get_value(select part_id from __all_part where table_id=$table_id and part_name='p2', part_id, 1);
let $index_table_id = query_get_value(select table_id from __all_table where data_table_id=$table_id, table_id, 1);
let $index_part_id = query_get_value(select part_id from __all_part where table_id=$index_table_id and part_name='p2', part_id, 1);
let $next_index_table_id = query_get_value(select table_id from __all_table where data_table_id=$table_id, table_id, 2);
let $next_index_part_id = query_get_value(select part_id from __all_part where table_id=$next_index_table_id and part_name='p2', part_id, 1);

call dbms_stats.gather_table_stats('oceanbase', 't1', method_opt=>'FOR ALL COLUMNS SIZE 4');
--disable_query_log
eval select count(*) from __all_table_stat where table_id=$table_id and partition_id=$part_id;
eval select count(*) from __all_table_stat where table_id=$index_table_id and partition_id=$index_part_id;
eval select count(*) from __all_table_stat where table_id=$next_index_table_id and partition_id=$next_index_part_id;
eval select count(*) from __all_column_stat where table_id=$table_id and partition_id=$part_id;
eval select count(*) from __all_histogram_stat where table_id=$table_id and partition_id=$part_id;
--enable_query_log

alter table t1 reorganize partition p2 into ( partition p2_1 values less than (45), partition p2_2 values less than (50));
--disable_query_log
eval select count(*) from __all_table_stat where table_id=$table_id and partition_id=$part_id;
eval select count(*) from __all_table_stat where table_id=$index_table_id and partition_id=$index_part_id;
eval select count(*) from __all_table_stat where table_id=$next_index_table_id and partition_id=$next_index_part_id;
eval select count(*) from __all_column_stat where table_id=$table_id and partition_id=$part_id;
eval select count(*) from __all_histogram_stat where table_id=$table_id and partition_id=$part_id;
--enable_query_log

######################### auto split none-partitioned table ###################
connection conn1;
--disable_warnings
drop table if exists t1;
--enable_warnings
set session ob_query_timeout=1000000000000;	
create table t1(a int, b VARCHAR(150), c int, d VARCHAR(4000),primary key(a,b,c))  partition by range(a) size('128MB');
let $tablet_id = query_get_value(select tablet_id from oceanbase.__all_table where table_name='t1', tablet_id, 1);
let $table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='t1', table_id, 1);


call dbms_stats.gather_table_stats('test', 't1', method_opt=>'FOR ALL COLUMNS SIZE 4');
--disable_query_log
eval select count(*) from oceanbase.__all_table_stat where table_id=$table_id and partition_id = $table_id;
eval select count(*) from oceanbase.__all_column_stat where table_id=$table_id and partition_id = $table_id;
eval select count(*) from oceanbase.__all_histogram_stat where table_id=$table_id and partition_id = $table_id;
--enable_query_log


let $times_insert = 0;
while ($times_insert < 10)
{
  --inc $times_insert
  insert into t1(a,b,c,d) select 
    uniform(1, 100000000, random()),
    randstr(150, random()) c1,
    uniform(1, 1000, random()),
    randstr(4000, random()) c1
  from 
    table(generator(8000));
}


let $times_check = 0;
while ($times_check < 10)
{
  sleep 15;
  --inc $times_check
  let $partition_count = query_get_value(select count(1) as count from (select dest_tablet_id from oceanbase.__all_tablet_reorganize_history where src_tablet_id = $tablet_id), count, 1);
  if ($partition_count == 2) 
  {
    let $times_check = 11;
  }
}

call dbms_stats.gather_table_stats('test', 't1', method_opt=>'FOR ALL COLUMNS SIZE 4');
--disable_query_log
#and partition_id = $table_id
eval select count(*) from oceanbase.__all_table_stat where table_id=$table_id and partition_id = $table_id;
eval select count(*) from oceanbase.__all_column_stat where table_id=$table_id and partition_id = $table_id;
eval select count(*) from oceanbase.__all_histogram_stat where table_id=$table_id and partition_id = $table_id;
--enable_query_log

drop table t1;
