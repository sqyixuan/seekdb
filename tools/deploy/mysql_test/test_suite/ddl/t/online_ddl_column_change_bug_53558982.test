# owner: gaishun.gs
# owner group: storage : index and ddl
# description: 向上列类型转换 update shadow column schema of index table
# note: ob do mysqltest --suite=ddl --test_set=online_ddl_column_change_bug_53558982 -n 422_int2bigint
# bug url: 
 
--result_format  4
 
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
 
--disable_warnings
--disable_query_log
#call oceanbase.drop_tenant_force('tenant1');
#call oceanbase.create_mysql_tenant_mini('tenant1');
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_warnings
 
let $tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);
 
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn1;
 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk mediumint unsigned, c1 int, primary key (pk), unique i1 (c1));
alter table t1 modify column pk int;
insert into t1 values(-1, null);
connection obsys;
let $data_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and tenant_id= $tenant_id, table_id, 1);
let $index_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where data_table_id = $data_table_id  and table_name like '__idx%' and tenant_id = $tenant_id , table_id, 1);
let $count = query_get_value(select count(*) as count from oceanbase.__all_virtual_column where table_id= $index_table_id and tenant_id = $tenant_id and data_type != 4, count, 1);
--echo $count
connection conn1;
 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk mediumint unsigned, c1 int, primary key (pk), unique i1 (c1));
alter table t1 modify column pk int;
insert into t1 values(-1, 1);
insert into t1 values(2, null);
connection obsys;
let $data_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and tenant_id= $tenant_id, table_id, 1);
let $index_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where data_table_id = $data_table_id  and table_name like '__idx%' and tenant_id = $tenant_id , table_id, 1);
let $count = query_get_value(select count(*) as count from oceanbase.__all_virtual_column where table_id= $index_table_id and tenant_id = $tenant_id and data_type != 4, count, 1);
--echo $count
connection conn1;
 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(test1 int, test2 int not null, pk mediumint unsigned, c1 int, primary key (pk), unique i1 (c1));
alter table t1 modify column pk int;
insert into t1 values(-1, 1, 1, null);
connection obsys;
let $data_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and tenant_id= $tenant_id, table_id, 1);
let $index_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where data_table_id = $data_table_id  and table_name like '__idx%' and tenant_id = $tenant_id , table_id, 1);
let $count = query_get_value(select count(*) as count from oceanbase.__all_virtual_column where table_id= $index_table_id and tenant_id = $tenant_id and data_type != 4, count, 1);
--echo $count
connection conn1;
 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(test1 int, test2 int not null, pk mediumint unsigned, c1 int, primary key (pk), unique i1 (c1));
alter table t1 modify column pk int;
insert into t1 values(-1, 1, 2, 1);
insert into t1 values(-1, 1, 1, null);
connection obsys;
let $data_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and tenant_id= $tenant_id, table_id, 1);
let $index_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where data_table_id = $data_table_id  and table_name like '__idx%' and tenant_id = $tenant_id , table_id, 1);
let $count = query_get_value(select count(*) as count from oceanbase.__all_virtual_column where table_id= $index_table_id and tenant_id = $tenant_id and data_type != 4, count, 1);
--echo $count
connection conn1;
 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(test1 smallint unsigned, test2 int not null, pk mediumint unsigned, c1 int, primary key (test1, test2, pk), unique i1 (c1));
alter table t1 modify column pk int;
alter table t1 modify column test1 int;
insert into t1 values(-1, 1, -1, null);
connection obsys;
let $data_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and tenant_id= $tenant_id, table_id, 1);
let $index_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where data_table_id = $data_table_id  and table_name like '__idx%' and tenant_id = $tenant_id , table_id, 1);
let $count = query_get_value(select count(*) as count from oceanbase.__all_virtual_column where table_id= $index_table_id and tenant_id = $tenant_id and data_type != 4, count, 1);
--echo $count
connection conn1;
 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(test1 int, test2 int not null, pk mediumint unsigned, c1 int, primary key (test1, pk), unique i1 (c1));
alter table t1 modify column pk bigint;
insert into t1 values(-1, 1, -2, 1);
insert into t1 values(-1, 1, -1, null);
connection obsys;
let $data_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and tenant_id= $tenant_id, table_id, 1);
let $index_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where data_table_id = $data_table_id  and table_name like '__idx%' and tenant_id = $tenant_id , table_id, 1);
let $count = query_get_value(select count(*) as count from oceanbase.__all_virtual_column where table_id= $index_table_id and tenant_id = $tenant_id and data_type != 4, count, 1);
--echo $count
connection conn1;
 
disconnect obsys;
disconnect conn1;
