let $__all_virtual_data_type_class_table_id =query_get_value(select a.table_id from oceanbase.__all_virtual_table a inner join oceanbase.__all_virtual_database b where a.tenant_id = 1 and b.database_name = 'oceanbase' and a.table_name = '__all_virtual_data_type_class', table_id, 1);
let $session_variables_table_id = query_get_value(select a.table_id from oceanbase.__all_virtual_table a inner join oceanbase.__all_virtual_database b where a.tenant_id = 1 and b.database_name = 'oceanbase' and a.table_name = 'session_variables', table_id, 1);
let $schemata_table_id =  query_get_value(select a.table_id from oceanbase.__all_virtual_table a inner join oceanbase.__all_virtual_database b where a.tenant_id = 1 and b.database_name = 'oceanbase' and table_name = 'schemata', table_id, 1);
let $__tenant_virtual_database_status_table_id = query_get_value(select a.table_id from oceanbase.__all_virtual_table a inner join oceanbase.__all_virtual_database b where a.tenant_id = 1 and b.database_name = 'oceanbase' and a.table_name = '__tenant_virtual_database_status', table_id, 1);

