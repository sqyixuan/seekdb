alter table t1 add primary key(c1);
select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where data_table_id = (select table_id from __all_table where table_name = 't1') and table_name like "%idx1") order by __all_column_group.column_group_name, __all_column.column_name;

alter table t1 drop primary key;
select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where data_table_id = (select table_id from __all_table where table_name = 't1') and table_name like "%idx1") order by __all_column_group.column_group_name, __all_column.column_name;


drop table t1;
select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table_history where data_table_id = (select max(table_id) from __all_table_history where table_name = 't1') and table_name like "%idx1") order by __all_column_group.column_group_name, __all_column.column_name;