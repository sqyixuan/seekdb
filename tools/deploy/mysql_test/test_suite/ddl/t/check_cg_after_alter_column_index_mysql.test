# owner: zhuoran.zzr
# owner group: storage
# description: to support column store index, some ddl action that related to the index has to be changed, in test test, we are mainly concerned about the innert table state, since now column index only support (all columns, each column) appear at the same, the situation is simple in some sence, the action we concerns are
# create index
# drop index
# drop column
# rename column
# drop/add primary key

--result_format 4
connect (obsys,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);

connection obsys;
--disable_info
--disable_metadata
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int, c2 varchar(30), c3 varchar(30), c4 varchar(40), c5 int generated  always as (c1+1)) 
                partition by range(c1)
                (partition p_0 values less than(10),
                 partition p_1 values less than(20),
                 partition p_2 values less than(30)
                );


# check create and drop index
create index idx1 on t1(c2, c3) global storing (c4, c1) with column group(all columns, each column);
select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table_history where data_table_id = (select max(table_id) from __all_table_history where table_name = 't1') and table_name like "%idx1") order by __all_column_group.column_group_name, __all_column.column_name;

drop index idx1 on t1;
select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table_history where data_table_id = (select max(table_id) from __all_table_history where table_name = 't1') and table_name like "%idx1") order by __all_column_group.column_group_name, __all_column.column_name;

alter table t1 add index idx1(c1, c4) local storing (c2, c3) with column group(all columns, each column);
select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table_history where data_table_id = (select max(table_id) from __all_table_history where table_name = 't1') and table_name like "%idx1") order by __all_column_group.column_group_name, __all_column.column_name;

drop index idx1 on t1;
