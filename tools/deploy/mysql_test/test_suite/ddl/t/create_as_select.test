INSERT IGNORE INTO t61 VALUES ('-1234.1e2xxxx');

create table t62 as select c1,null as x, 1 + null as y from t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t62;
insert into t62 values(1,null, null);

create table t63 as select @a;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t63;
drop table t63;

create table t63 as select cast(@a as signed), null, 1+5 from dual;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t63;

#Q7 非sys租户查询建表报错的问题
use test;
--disable_warnings
drop table if exists sx1;
drop table if exists sx2;
--enable_warnings
create table sx1(c int);
insert into sx1 values(5),(8),(824),(2018);
create table sx2 select * from sx1;
select * from sx2;
drop table sx1;
drop table sx2;

--disable_warnings
--disable_result_log
drop table if exists t1;
--enable_warnings
--enable_result_log
--error 1054
create table t1 as select user as abc from dual;
drop table if exists t1;
create table t1 as select user() as abc from dual;
drop table if exists t1;
--error 1054
create table t1 as select sysdate as abc from dual;
drop table if exists t1;
create table t1 as select sysdate() as abc from dual;
drop table if exists t1;

