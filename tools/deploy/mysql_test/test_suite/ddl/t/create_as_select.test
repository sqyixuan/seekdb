--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yibo.tyf
# owner group: SQL1
# description: Verify create table T as select ...
# results should be the same as mysql(verified on 5.6.35)
--disable_warnings
drop database if exists create_as_select_db;
--enable_warnings
create database create_as_select_db;

--result_format 4

use create_as_select_db;
create table t1(c1 int, c2 varchar(10), c3 date);
insert into t1 values(5236, 'scott', '2018-5-8');
insert into t1 values(1024, '中', '2018-1-1');
commit;

## set @@session.ob_enable_transformation = 0;
--echo ### Q1 最基本测试
create table t1_x11 as select * from t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1_x11;

insert into t1_x11 values(1, 'x', '2018-5-12'), (11, 'x2', '2018-5-12'), (31, 'x4', '2018-5-12'),
 (13, '44x', '2018-5-12'), (1, '5x', '2018-5-12'), (1, 'xz', '2018-5-12'), (1, 'x6', '2018-5-12'),
 (31, 'x44', '2018-5-12');

let $wait_timeout= 8; # Override default of 30 seconds with 8.

create table t1_x11_copy as select a.* from t1_x11 a, t1_x11 b;
create table t1_x11_copy2 as select a.* from t1_x11_copy a, t1_x11_copy b limit 10000;

--error 1146
alter table xy add column c12 int;

create table xy as select a.* from t1_x11_copy a, t1_x11_copy b limit 10000;

select * from xy;
--error 1146
select * from _xy;

create table t1_x12 as select c3, c1, c2 from t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1_x12;

create table t1_x13 as select c1 as d1, c2 as d2 from t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1_x13;

create table t1_x132 select c1 as d1, c2 as d2 from t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1_x132;

create table t1_x133(d1 int default 100, d3 int default 20) select c1 as d1, c2 as d2 from t1;
select * from t1_x133;


create table t1_x14 as select c1 * (c1 + 5), concat(c2, c2), c3 as "hello" from t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1_x14;
select * from t1_x14;

create table t2(c1 int, c2 varchar(19)) default charset=binary;
insert into t2 values(54, 'xyz_hello');
create table t2_x1 as select * from t2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2_x1;

create table t2_x2(x int default 777) as select c1 y, c2 as z from t2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2_x2;
select * from t2_x2;

--echo ### Q1.2 表定义和查询项重名, 应当使用定义中的类型(c1,c2)
create table t1_x2 (c1 char(10)) as select c1,c2 from t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1_x2;

--echo ### Q1.3 表定义和查询项完全重合且类型无变化, 但顺序调整了; 期望最终(c1,c3,c2)
create table t1_y (c1 int, c2 varchar(10), c3 date) as select c1, c3, c2 from t1;
select * from t1_y;

--echo ### Q1.4 表定义和查询项有重合, 但类型不同; mysql为(c2 int,c4 int,c1 date,c3 char(100))
create table t1_z (c2 int, c3 char(100), c4 int) as
    select c3 as c1, cast(c1 as char(40)) as c3 from t1;

select * from t1_z;

--echo ### Q2 复杂的例子
#Q2.1 表定义复杂, 跨分区插入目前不支持
create table t1_complex(c1 int default 555, c2 varchar(100), c3 bigint, c4 date, c5 int, c6 double)
 partition by hash(c3) partitions 2
 as select c1 as x, c2 , c1 * 100, c3, c1 - 1 as y, c1 / 3.1 as z from t1;
select * from t1_complex order by c1 , c2;

#Q2.2 上述出错后简化的例子, 会报错不支持跨分区插入
create table t1_complex2(c3 bigint) partition by hash(c3) partitions 2
 as select 5 as c3 from t1;
select * from t1_complex2 order by c3;

#Q2.2.1 表定义包含约束
select count(1) from t1 where c1 != length(c2);
--error 3819
create table t1_complex3 (c1 int, c2 int, constraint chk check (c1 = c2)) select c1, length(c2) as c2 from t1;
create table t1_complex3 (c1 int, c2 int, constraint chk check (1 = 1)) select c1, length(c2) as c2 from t1;

#Q2.2.2  查询语句复杂
create table t1_complex_query as
select min(c1), max(c2), c3 from t1 group by c3
 union all
 select * from t1 x where x.c1 in (select y.c1 from t1 y where x.c2 = y.c2 and x.c3 <> y.c3) and
  length(x.c2) > (select count(*) from t1 aa left join t1 bb on aa.c1 = bb.c1 where aa.c1 - bb.c1 < x.c1 - x.c1*1.5)
 union all
 select a.* from t1 a, t1 b where a.c1 = 1 or length(a.c2) > (select count(*) from t1 c where c.c1 = b.c1 or c.c2 > concat(b.c2 , a.c2))
 and not exists (select 1 from t1 d where d.c1 = a.c1 and d.c2 < (select '1' from t1 where c1+length(c2) in (1,2,3)));

select * from t1_complex_query ;


