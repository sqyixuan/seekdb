drop table if exists t1bug;
--enable_warnings
create table if not exists t1bug select 1 as i;
create table if not exists t1bug select 2 as i;
create table if not exists t1bug select 3 as i;
create table if not exists t1bug select 4 as i;

select * from t1bug;
drop table t1bug;

# fix bug#22798665
# 测试通过查询建表建出的表中列属性会保留基表中列的 not null 属性
--disable_warnings
drop table if exists t_xiaofeng_1;
drop table if exists t_xiaofeng_2;
--enable_warnings
create table t_xiaofeng_1(c1 int unique, c2 int primary key, c3 int, c4 int not null);
create table t_xiaofeng_2 as select * from t_xiaofeng_1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_xiaofeng_1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_xiaofeng_2;
drop table t_xiaofeng_1, t_xiaofeng_2;

--echo #bugfix 
drop table if exists t1;
create table t1 as select cast(2023 as YEAR) from dual;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table if exists t1;

drop database create_as_select_db;

--echo #bugfix 
--disable_warnings
drop table if exists hbyd_t10;
drop table if exists hbyd_t11;
drop table if exists hbyd_t20;
drop table if exists hbyd_t21;
drop table if exists hbyd_t22;
drop table if exists sub_part_t1;
--enable_warnings

create table hbyd_t10 (d1 int) partition by range(d1)
(partition `111` values less than (1),
partition `222` values less than (2),
partition `333` values less than (3));

show create table hbyd_t10;

create  table  hbyd_t11  as  select  *  from  hbyd_t10  partition(`222`);

create table hbyd_t20 (d1 int) partition by range(d1)
(partition aaa values less than (4),
partition bbb values less than (5),
partition ccc values less than (6));

show create table hbyd_t20;

create  table  hbyd_t21  as  select  *  from  hbyd_t20  partition(`bbb`);
create  table  hbyd_t22  as  select  *  from  hbyd_t20  partition(ccc);

create table sub_part_t1 (d1 int, d2 int) 
partition by range(d1) 
subpartition by hash(d2)  subpartitions 2
(partition `111` values less than (1),
partition `222` values less than (2),
partition `333` values less than (3));

show create table sub_part_t1;

drop table hbyd_t10;
drop table hbyd_t11;
drop table hbyd_t20;
drop table hbyd_t21;
drop table hbyd_t22;
drop table if exists sub_part_t1;


connection default;
--disable_warnings
drop database if exists ruinao_db;
--error 0,1396
drop user u1;
--enable_warnings
create database ruinao_db;
create user u1 identified by '123';
grant create view, select, insert, drop on test.* to u1;
use ruinao_db;
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);

connect (conn_u1,$OBMYSQL_MS0,u1,'123',test,$OBMYSQL_PORT);
connection conn_u1;
--disable_warnings
drop view if exists v1;
drop view if exists v2;
drop view if exists v3;
--enable_warnings

# has no privilege
--error 1142
create view v1 as select * from ruinao_db.t1;
--error 1142
create view v1 as select * from ruinao_db.t2;

disconnect conn_u1;
connection default;
grant insert on ruinao_db.t1 to u1;
grant select on ruinao_db.t2 to u1;
connect (conn_u1,$OBMYSQL_MS0,u1,'123',test,$OBMYSQL_PORT);
connection conn_u1;

# only has insert on t1, select on t2;
create view v1 as select * from ruinao_db.t1;
create view v2 as select * from ruinao_db.t2;
create or replace view v3 as select a.c1, b.c2 from ruinao_db.t1 a, ruinao_db.t2 b where 1 = 1;
--error 1142
create or replace view v3 as select * from ruinao_db.t1 a where a.c1 in (select b.c1 from ruinao_db.t2 b);  # elsewhere as child_stmt
create or replace view v3 as select * from ruinao_db.t1 a where 1 in (select b.c1 from ruinao_db.t2 b);  # elsewhere as child_stmt
--error 1142
create or replace view v3 as select a.c1 from ruinao_db.t2 a, (select 1 from ruinao_db.t1); # generated table as child_stmt
create or replace view v3 as select a.c1 from ruinao_db.t1 a, (select 1 from ruinao_db.t2); # generated table as child_stmt
--error 1142
create or replace view v3 as select (select max(c1) from ruinao_db.t1); # child_stmt
create or replace view v3 as select (select max(c1) from ruinao_db.t2); # child_stmt
--error 1142
create or replace view v3 as select a.c1, b.c2 from ruinao_db.t1 a, ruinao_db.t2 b where a.c1 = 1;
create or replace view v3 as select a.c1, b.c2 from ruinao_db.t1 b, ruinao_db.t2 a where a.c1 = 1;
--error 1142
create or replace view v3 as select a.c1 + 1 from ruinao_db.t1 a;
create or replace view v3 as select a.c1 + 1 from ruinao_db.t2 a;

disconnect conn_u1;
connection default;
grant select on ruinao_db.t1 to u1;
connect (conn_u1,$OBMYSQL_MS0,u1,'123',test,$OBMYSQL_PORT);
connection conn_u1;
create or replace view v3 as select * from ruinao_db.t1 a where a.c1 in (select b.c1 from ruinao_db.t2 b);
create or replace view v3 as select a.c1 + 1 from ruinao_db.t1 a;
create or replace view v3 as select a.c1, b.c2 from ruinao_db.t1 a, ruinao_db.t2 b where a.c1 = 1;
create or replace view v3 as select (select max(c1) from ruinao_db.t1);
create or replace view v3 as select a.c1 from ruinao_db.t2 a, (select 1 from ruinao_db.t1);

drop view v1;
drop view v2;
drop view v3;

disconnect conn_u1;
connection default;
drop database ruinao_db;
drop user u1;