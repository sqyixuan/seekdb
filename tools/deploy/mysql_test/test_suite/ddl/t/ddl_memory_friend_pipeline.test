# owner: youchuan.yc
# owner group: storage
# description: 

connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);

connection sys_conn;
set @@ob_query_timeout = 10000000000;

--disable_warnings
drop table if exists t1;
drop sequence if exists s1;
--enable_warnings
create table t1 (c1 int primary key, c2 int) with column group (all columns, each column);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

create sequence s1 cache 1000000 noorder;
Insert into t1 select s1.nextval, s1.nextval from table(generator(1234));

--disable_query_log

alter table t1 drop primary key;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
select count(*) from t1;
alter table t1 add primary key(c1);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
select count(*) from t1;

alter /*+parallel(4)*/ table t1 drop primary key;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
select count(*) from t1;
alter /*+parallel(4)*/ table t1 add primary key(c1);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
select count(*) from t1;

drop table t1;

