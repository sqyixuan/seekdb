#owner: zhaoziqian.zzq
#owner group: RS
#tags: rs
#description:
# change partition, then show create table

connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
set @@session.recyclebin = off;
--disable_warnings
drop database if exists ziqian_show_create_table;
--enable_warnings
create database ziqian_show_create_table;
use ziqian_show_create_table;

# case 1: add partition without subpartition specified
create table t1 (c1 int, c2 int)
partition by range (c1)
subpartition by range (c2)
subpartition template
(
  subpartition p0 values less than (1000),
  subpartition p1 values less than (2000)
)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
alter table t1 add partition
(
  partition p2 values less than (300)
);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

# case 2: add partition with subpartition specified, and subpartition is different from template
create table t2 (c1 int, c2 int)
partition by range (c1)
subpartition by range (c2)
subpartition template
(
  subpartition p0 values less than (1000),
  subpartition p1 values less than (2000)
)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);
alter table t2 add partition
(
  partition p2 values less than (300)
  (
    subpartition p2sp0 values less than (1000)
  )
);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;

# case 3: add partition with subpartition specified, and subpartition is the same with template
create table t3 (c1 int, c2 int)
partition by range (c1)
subpartition by range (c2)
subpartition template
(
  subpartition p0 values less than (1000),
  subpartition p1 values less than (2000)
)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);
alter table t3 add partition 
(
  partition p2 values less than (300)
  (
    subpartition p2sp0 values less than (1000),
    subpartition p2sp1 values less than (2000)
  )
);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t3;

# case 4: add subpartition
create table t4 (c1 int, c2 int)
partition by range (c1)
subpartition by range (c2)
subpartition template
(
  subpartition p0 values less than (1000),
  subpartition p1 values less than (2000)
)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);
alter table t4 modify partition p0 add subpartition
(
  subpartition p0sp2 values less than (3000)
);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t4;

# case 5: drop subpartition
create table t5 (c1 int, c2 int)
partition by range (c1)
subpartition by range (c2)
subpartition template
(
  subpartition p0 values less than (1000),
  subpartition p1 values less than (2000)
)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);
alter table t5 drop subpartition p0sp0;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;

# case 6: add multi partitions, with some subpartitions specified, some not specified
create table t6 (c1 int, c2 int)
partition by range (c1)
subpartition by range (c2)
subpartition template
(
  subpartition p0 values less than (1000),
  subpartition p1 values less than (2000)
)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);
--error 1235
alter table t6 add partition
(
  partition p2 values less than (100),
  partition p3 values less than (200)
  (
    subpartition p3sp0 values less than (1000)
  )
);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t6;

# case 7: create subpartition template table, with some subpartitions specified
--error 1064
create table t7 (c1 int, c2 int)
partition by range (c1)
subpartition by range (c2)
subpartition template
(
  subpartition p0 values less than (1000),
  subpartition p1 values less than (2000)
)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
  (
    subpartition p1sp0 values less than (1000)
  )
);
# t7 can not be created now
# --error 1146
# show create table t7;

# case 8: drop partition
create table t8 (c1 int, c2 int)
partition by range (c1)
subpartition by range (c2)
subpartition template
(
  subpartition p0 values less than (1000),
  subpartition p1 values less than (2000)
)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);
alter table t8 drop partition p0;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t8;

# case 9: truncate partition
create table t9 (c1 int, c2 int)
partition by range (c1)
subpartition by range (c2)
subpartition template
(
  subpartition p0 values less than (1000),
  subpartition p1 values less than (2000)
)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);
alter table t9 truncate partition p0;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t9;

# case 10: truncate subpartition
create table t10 (c1 int, c2 int)
partition by range (c1)
subpartition by range (c2)
subpartition template
(
  subpartition p0 values less than (1000),
  subpartition p1 values less than (2000)
)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);
alter table t10 truncate subpartition p0sp0;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t10;


drop database ziqian_show_create_table;
