# owner: gaishun.gs
# owner group: storage : index and ddl
# description: 向上列类型转换
# note: ob do mysqltest --suite=ddl --test_set=online_ddl_bit_column_change -n 43_int2bigint
# note: ob do mysqltest --suite=ddl --test_set=online_ddl_bit_column_change -n 43base
 
--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
 
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

# check the alter correction of type change
# common bit(x1) -> bit(x2); x2>=x1 and convert over 255: online
--disable_warnings
drop table if exists t2_bit;
drop table if exists t1_bit;
drop sequence if exists s1;
--enable_warnings
create table t1_bit (a bit(20));
create sequence s1 cache 1000000 noorder;
insert into t1_bit select s1.nextval from table(generator(2000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_bit', table_id, 1);
alter table t1_bit change column a a bit(30);
insert into t1_bit select s1.nextval from table(generator(2000));
select count(*) from t1_bit;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_bit', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}

# primary key bit(x1) -> bit(x2); x2>=x1 and convert over 255: online
--disable_warnings
drop table if exists t1_bit;
drop sequence if exists s1;
--enable_warnings
create table t1_bit (a bit(20) primary key);
create sequence s1 cache 1000000 noorder;
insert into t1_bit select s1.nextval from table(generator(2000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_bit', table_id, 1);
alter table t1_bit change column a a bit(30);
insert into t1_bit select s1.nextval from table(generator(2000));
select count(*) from t1_bit;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_bit', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}

# index key bit(x1) -> bit(x2); x2>=x1 and convert over 255: online
--disable_warnings
drop table if exists t1_bit;
drop sequence if exists s1;
--enable_warnings
create table t1_bit (a bit(20));
create sequence s1 cache 1000000 noorder;
create index idx_t1_bit on t1_bit(a);
insert into t1_bit select s1.nextval from table(generator(2000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_bit', table_id, 1);
alter table t1_bit change column a a bit(30);
insert into t1_bit select s1.nextval from table(generator(2000));
select count(*) from t1_bit;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_bit', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}

# foreign key bit(x1) -> bit(x2); x2>=x1 and convert over 255: online
--disable_warnings
drop table if exists t2_bit;
drop table if exists t1_bit;
drop sequence if exists s1;
drop sequence if exists s2;
--enable_warnings
create table t1_bit (a bit(20) unique);
create table t2_bit (a bit(20), foreign key(a) references t1_bit(a));
create sequence s1 cache 1000000 noorder;
create sequence s2 cache 1000000 noorder;
insert into t1_bit select s1.nextval from table(generator(2000));
insert into t2_bit select s2.nextval from table(generator(2000));
--error 1235
alter table t1_bit change column a a bit(30);
--error 1235
alter table t2_bit change column a a bit(30);
insert into t1_bit select s1.nextval from table(generator(2000));
insert into t2_bit select s2.nextval from table(generator(2000));
select count(*) from t1_bit;
drop table if exists t2_bit;


# generated column stored and virtual
--disable_warnings
drop table if exists t1_bit;
drop sequence if exists s1;
--enable_warnings
create table t1_bit (a bit(10), b bit(20) generated always as (a*2) STORED);
create sequence s1 cache 1000000 noorder;
insert into t1_bit(a) select s1.nextval from table(generator(1000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_bit', table_id, 1);
alter table t1_bit change column a a bit(20);
--error 3106
alter table t1_bit change column b b bit(40);
--error 3106
alter table t1_bit change column b b bit(40) generated always as (a*2) VIRTUAL;
alter table t1_bit change column b b bit(40) generated always as (a*2) STORED;
insert into t1_bit(a) select s1.nextval from table(generator(2000));
select count(*) from t1_bit;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_bit', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}
