--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: xingrui.cwh
#owner group: rs
#description
#   The case is meant to verify tablegroup with level one/two partition
#
#    CASE 1: verify tablegroup sharding with 'NONE'
#         1.1 alter tablegroup sharding into other when tablegroup is empty
#    CASE 2: verify tablegroup sharding with 'PARTITION'
#         2.1 add same level one partition table into tablegroup
#    CASE 3: verify tablegroup sharding with 'ADAPTIVE'
#         3.1 add same level one partition table into tablegroup
#    CASE 4: verify add different level one partition into tablegroup
#    CASE 5: verify tablegroup sharding with 'NONE'
#    CASE 6: verify tablegroup sharding with 'PARTITION'
#         6.1 add same level two partition table into tablegroup
#    CASE 7: verify tablegroup sharding with 'ADAPTIVE'
#         7.1 add same level two partition table into tablegroup
#    CASE 8:verify subpartition num\character\subpartition type

connect (con1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection con1;

--disable_warnings
--disable_query_log
--disable_result_log
DROP TABLE IF EXISTS xingrui_tbl1_r,xingrui_tbl2_r,xingrui_tbl1_l,xingrui_tbl2_l,xingriu_tbl3_l,xingrui_tbl1_k,xingrui_tbl2_k,xingrui_tbl1_h,xingrui_tbl2_h,xingrui_llc1,xingrui_llc2,xingrui_llc3,xingrui_llc4,xingrui_llc5,xingrui_llc6;
DROP TABLE IF EXISTS xingrui_tbl1_rr,xingrui_tbl2_rr,xingrui_tbl3_rr,xingrui_tbl1_rl,xingrui_tbl2_rl,xingrui_tbl1_rh,xingrui_tbl2_rh,xingrui_tbl1_hl,xingrui_tbl2_hl,xingrui_tbl1_hk,xingrui_tbl2_hk,xingrui_tbl1_m_kk,xingrui_tbl2_m_kk;
DROP TABLE IF EXISTS xingrui_t_m_rcrc1,xingrui_t_m_rcrc2,xingrui_t_m_rch1,xingrui_t_m_rch2,xingrui_t_m_rck1,xingrui_t_m_rck2,xingrui_t_m_lcrc1,xingrui_t_m_lcrc2,xingrui_t_m_lclc1,xingrui_t_m_lclc2,xingrui_tbl1_m_kh,xingrui_tbl2_m_kh;
DROP TABLE IF EXISTS xingrui_t_m_lch1,xingrui_t_m_lch2,xingrui_t_m_lck1,xingrui_t_m_lck2,xingrui_tbl1_m_hr,xingrui_tbl2_m_hr,xingrui_tbl1_m_hh,xingrui_tbl2_m_hh,xingrui_tbl1_m_krc,xingrui_tbl2_m_krc,xingrui_tbl1_m_klc,xingrui_tbl2_m_klc;
let $GROUP_CNT = 1;
while ($GROUP_CNT != 8 )
{
    eval DROP TABLEGROUP IF EXISTS xingrui_tg$GROUP_CNT;
    inc $GROUP_CNT;
}
let $GROUP_CNT = 51;
while ($GROUP_CNT != 55 )
{
    eval DROP TABLEGROUP IF EXISTS xingrui_tg$GROUP_CNT;
    inc $GROUP_CNT;
}
let $GROUP_CNT = 61;
while ($GROUP_CNT != 65 )
{
    eval DROP TABLEGROUP IF EXISTS xingrui_tg$GROUP_CNT;
    inc $GROUP_CNT;
}
--enable_warnings
--enable_result_log
--enable_query_log

CREATE TABLEGROUP xingrui_tg1 sharding = 'NONE';
CREATE TABLEGROUP xingrui_tg2 sharding = 'PARTITION';
CREATE TABLEGROUP xingrui_tg3 sharding = 'ADAPTIVE';
CREATE TABLEGROUP xingrui_tg4 sharding = 'NONE';
CREATE TABLEGROUP xingrui_tg5 sharding = 'PARTITION';
CREATE TABLEGROUP xingrui_tg51 sharding = 'PARTITION';
CREATE TABLEGROUP xingrui_tg52 sharding = 'PARTITION';
CREATE TABLEGROUP xingrui_tg53 sharding = 'PARTITION';
CREATE TABLEGROUP xingrui_tg54 sharding = 'PARTITION';
CREATE TABLEGROUP xingrui_tg6 sharding = 'ADAPTIVE';
CREATE TABLEGROUP xingrui_tg61 sharding = 'ADAPTIVE';
CREATE TABLEGROUP xingrui_tg62 sharding = 'ADAPTIVE';
CREATE TABLEGROUP xingrui_tg63 sharding = 'ADAPTIVE';
CREATE TABLEGROUP xingrui_tg64 sharding = 'ADAPTIVE';
CREATE TABLEGROUP xingrui_tg7 sharding = 'ADAPTIVE';
# 1.range
CREATE TABLE xingrui_tbl1_r (log_id BIGINT NOT NULL,log_value VARCHAR(50),log_date TIMESTAMP NOT NULL) PARTITION BY RANGE(UNIX_TIMESTAMP(log_date))
        (PARTITION M197001 VALUES LESS THAN(UNIX_TIMESTAMP('1970/02/01'))
       , PARTITION M197002 VALUES LESS THAN(UNIX_TIMESTAMP('1970/03/01'))
       , PARTITION M197003 VALUES LESS THAN(UNIX_TIMESTAMP('1970/04/01'))
        );
CREATE TABLE xingrui_tbl2_r (log_id BIGINT NOT NULL,log_value VARCHAR(50),log_date TIMESTAMP NOT NULL)
       PARTITION BY RANGE(UNIX_TIMESTAMP(log_date))
        (PARTITION M197001 VALUES LESS THAN(UNIX_TIMESTAMP('1970/02/01'))
       , PARTITION M197002 VALUES LESS THAN(UNIX_TIMESTAMP('1970/03/01'))
       , PARTITION M197003 VALUES LESS THAN(UNIX_TIMESTAMP('1970/04/01'))
       , PARTITION M197004 VALUES LESS THAN(UNIX_TIMESTAMP('1970/05/01'))
        );
# 2.list
CREATE TABLE xingrui_tbl1_l (col1 BIGINT PRIMARY KEY,col2 VARCHAR(50))
       PARTITION BY LIST(col1)
        (PARTITION p0 VALUES IN (1, 2, 3),
         PARTITION p1 VALUES IN (5, 6),
         PARTITION p2 VALUES IN (DEFAULT)
        );
# different value
CREATE TABLE xingrui_tbl2_l (col1 BIGINT PRIMARY KEY,col2 VARCHAR(50))
       PARTITION BY LIST(col1)
        (PARTITION p0 VALUES IN (1, 2, 3),
         PARTITION p1 VALUES IN (5, 7),
         PARTITION p2 VALUES IN (DEFAULT)
        );
# different order
CREATE TABLE xingrui_tbl3_l (col1 BIGINT PRIMARY KEY,col2 VARCHAR(50))
       PARTITION BY LIST(col1)
        (PARTITION p0 VALUES IN (3, 2, 1),
         PARTITION p1 VALUES IN (6, 5),
         PARTITION p2 VALUES IN (DEFAULT)
        );
# 3.key
CREATE TABLE xingrui_tbl1_k(id INT,gmt_create DATETIME,info VARCHAR(20))
       PARTITION BY KEY(id,gmt_create) PARTITIONS 10;
CREATE TABLE xingrui_tbl2_k(id INT,gmt_create DATETIME,info VARCHAR(20))
       PARTITION BY KEY(id,gmt_create) PARTITIONS 5;

# 4.hash
CREATE TABLE xingrui_tbl1_h(col1 INT,col2 VARCHAR(50))
       PARTITION BY HASH(col1) PARTITIONS 60;
CREATE TABLE xingrui_tbl2_h(col1 INT,col2 VARCHAR(50))
       PARTITION BY HASH(col1) PARTITIONS 50;

# 1.range+range
CREATE TABLE xingrui_tbl1_rr(col1 INT,col2 TIMESTAMP)
       PARTITION BY RANGE(col1)
       SUBPARTITION BY RANGE(UNIX_TIMESTAMP(col2))
        (PARTITION p0 VALUES LESS THAN(100)
           (SUBPARTITION sp0 VALUES LESS THAN(UNIX_TIMESTAMP('1971/04/01')),
            SUBPARTITION sp1 VALUES LESS THAN(UNIX_TIMESTAMP('1971/07/01')),
            SUBPARTITION sp2 VALUES LESS THAN(UNIX_TIMESTAMP('1971/10/01')),
            SUBPARTITION sp3 VALUES LESS THAN(UNIX_TIMESTAMP('1972/01/01'))
           ),
         PARTITION p1 VALUES LESS THAN(200)
           (SUBPARTITION sp4 VALUES LESS THAN(UNIX_TIMESTAMP('1971/04/01')),
            SUBPARTITION sp5 VALUES LESS THAN(UNIX_TIMESTAMP('1971/07/01')),
            SUBPARTITION sp6 VALUES LESS THAN(UNIX_TIMESTAMP('1971/10/01')),
            SUBPARTITION sp7 VALUES LESS THAN(UNIX_TIMESTAMP('1972/01/01'))
            )
         );
# level two partition num not equal
CREATE TABLE xingrui_tbl2_rr(col1 INT,col2 TIMESTAMP)
       PARTITION BY RANGE(col1)
        (PARTITION p0 VALUES LESS THAN(100),
         PARTITION p1 VALUES LESS THAN(200)
         );
# level two partition value not equal
CREATE TABLE xingrui_tbl3_rr(col1 INT,col2 TIMESTAMP)
       PARTITION BY RANGE(col1)
       SUBPARTITION BY RANGE(UNIX_TIMESTAMP(col2))
        (PARTITION p0 VALUES LESS THAN(100)
           (SUBPARTITION sp0 VALUES LESS THAN(UNIX_TIMESTAMP('1971/04/01')),
            SUBPARTITION sp1 VALUES LESS THAN(UNIX_TIMESTAMP('1971/07/01')),
            SUBPARTITION sp2 VALUES LESS THAN(UNIX_TIMESTAMP('1971/11/01')),
            SUBPARTITION sp3 VALUES LESS THAN(UNIX_TIMESTAMP('1972/01/01'))
           ),
         PARTITION p1 VALUES LESS THAN(200)
           (SUBPARTITION sp4 VALUES LESS THAN(UNIX_TIMESTAMP('1971/04/01')),
            SUBPARTITION sp5 VALUES LESS THAN(UNIX_TIMESTAMP('1971/08/01')),
            SUBPARTITION sp6 VALUES LESS THAN(UNIX_TIMESTAMP('1971/10/01')),
            SUBPARTITION sp7 VALUES LESS THAN(UNIX_TIMESTAMP('1972/01/01'))
            )
         );
# 2.range columns+list columns
CREATE TABLE xingrui_tbl1_rl (col1 INT,col2 INT)
       PARTITION BY RANGE COLUMNS(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
       (PARTITION p0 VALUES LESS THAN(100)
         (SUBPARTITION sp0 VALUES IN(1,3),
          SUBPARTITION sp1 VALUES IN(4,6),
          SUBPARTITION sp2 VALUES IN(7,9)),
        PARTITION p1 VALUES LESS THAN(200)
         (SUBPARTITION sp3 VALUES IN(1,3),
          SUBPARTITION sp4 VALUES IN(4,6),
          SUBPARTITION sp5 VALUES IN(7,9))
       );
CREATE TABLE xingrui_tbl2_rl (col1 INT,col2 INT)
        PARTITION BY RANGE COLUMNS(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
       (PARTITION p0 VALUES LESS THAN(100)
         (SUBPARTITION sp0 VALUES IN(1,3),
          SUBPARTITION sp1 VALUES IN(4,6),
          SUBPARTITION sp2 VALUES IN(8,9)),
        PARTITION p1 VALUES LESS THAN(200)
         (SUBPARTITION sp3 VALUES IN(1,3),
          SUBPARTITION sp4 VALUES IN(4,6),
          SUBPARTITION sp5 VALUES IN(8,9))
       );
# 3.range columns+range columns
CREATE TABLE xingrui_t_m_rcrc1(col1 INT,col2 INT)
       PARTITION BY RANGE COLUMNS(col1)
       SUBPARTITION BY RANGE COLUMNS(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION mp0 VALUES LESS THAN(1000),
         SUBPARTITION mp1 VALUES LESS THAN(2000),
         SUBPARTITION mp2 VALUES LESS THAN(3000)
        )
        (PARTITION p0 VALUES LESS THAN(100),
         PARTITION p1 VALUES LESS THAN(200),
         PARTITION p2 VALUES LESS THAN(300)
        );
CREATE TABLE xingrui_t_m_rcrc2(col1 INT,col2 INT)
       PARTITION BY RANGE COLUMNS(col1)
       SUBPARTITION BY RANGE COLUMNS(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION mp0 VALUES LESS THAN(1000),
         SUBPARTITION mp1 VALUES LESS THAN(2000)
        )
        (PARTITION p0 VALUES LESS THAN(100),
         PARTITION p1 VALUES LESS THAN(200),
         PARTITION p2 VALUES LESS THAN(300)
        );
# 4.range colums+hash
CREATE TABLE xingrui_t_m_rch1(col1 INT,col2 INT)
       PARTITION BY RANGE COLUMNS(col1)
       SUBPARTITION BY HASH(col2) SUBPARTITIONS 5
        (PARTITION p0 VALUES LESS THAN(100),
         PARTITION p1 VALUES LESS THAN(200),
         PARTITION p2 VALUES LESS THAN(300)
        );
CREATE TABLE xingrui_t_m_rch2(col1 INT,col2 INT)
       PARTITION BY RANGE COLUMNS(col1)
       SUBPARTITION BY HASH(col2) SUBPARTITIONS 4
        (PARTITION p0 VALUES LESS THAN(100),
         PARTITION p1 VALUES LESS THAN(200),
         PARTITION p2 VALUES LESS THAN(300)
        );
#5.Range Columns+Key
CREATE TABLE xingrui_t_m_rck1(col1 INT,col2 INT)
       PARTITION BY RANGE COLUMNS(col1)
       SUBPARTITION BY KEY(col2) SUBPARTITIONS 3
        (PARTITION p0 VALUES LESS THAN(100),
         PARTITION p1 VALUES LESS THAN(200),
         PARTITION p2 VALUES LESS THAN(300)
        );
CREATE TABLE xingrui_t_m_rck2(col1 INT,col2 INT)
       PARTITION BY RANGE COLUMNS(col1)
       SUBPARTITION BY KEY(col2) SUBPARTITIONS 2
        (PARTITION p0 VALUES LESS THAN(100),
         PARTITION p1 VALUES LESS THAN(200),
         PARTITION p2 VALUES LESS THAN(300)
        );
# 6.Range + Hash
CREATE TABLE xingrui_tbl1_rh (col1 INT,col2 INT)
       PARTITION BY RANGE(col1)
       SUBPARTITION BY HASH(col2)
       (PARTITION p0 VALUES LESS THAN(100)
         (SUBPARTITION sp0,
          SUBPARTITION sp1,
          SUBPARTITION sp2),
        PARTITION p1 VALUES LESS THAN(200)
         (SUBPARTITION sp3,
          SUBPARTITION sp4,
          SUBPARTITION sp5)
       );
CREATE TABLE xingrui_tbl2_rh (col1 INT,col2 INT)
       PARTITION BY RANGE(col1)
       SUBPARTITION BY HASH(col2)
       (PARTITION p0 VALUES LESS THAN(100)
         (SUBPARTITION sp0,
          SUBPARTITION sp1,
          SUBPARTITION sp2),
        PARTITION p1 VALUES LESS THAN(200)
         (SUBPARTITION sp3,
          SUBPARTITION sp4)
       );
# 7.List Columns + Range Columns
CREATE TABLE xingrui_t_m_lcrc1(col1 INT,col2 INT)
       PARTITION BY LIST COLUMNS(col1)
       SUBPARTITION BY RANGE COLUMNS(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION mp0 VALUES LESS THAN(100),
         SUBPARTITION mp1 VALUES LESS THAN(200),
         SUBPARTITION mp2 VALUES LESS THAN(300)
        )
        (PARTITION p0 VALUES IN(1,3),
         PARTITION p1 VALUES IN(4,6),
         PARTITION p2 VALUES IN(7,9)
        );
CREATE TABLE xingrui_t_m_lcrc2(col1 INT,col2 INT)
       PARTITION BY LIST COLUMNS(col1)
       SUBPARTITION BY RANGE COLUMNS(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION mp0 VALUES LESS THAN(100),
         SUBPARTITION mp1 VALUES LESS THAN(200)
        )
        (PARTITION p0 VALUES IN(1,3),
         PARTITION p1 VALUES IN(4,6),
         PARTITION p2 VALUES IN(7,9)
        );
# 8.List Columns + List Columns
 CREATE TABLE xingrui_t_m_lclc1(col1 INT,col2 INT)
       PARTITION BY LIST COLUMNS(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION mp0 VALUES IN(2),
         SUBPARTITION mp1 VALUES IN(5),
         SUBPARTITION mp2 VALUES IN(8)
        )
        (PARTITION p0 VALUES IN(1,3),
         PARTITION p1 VALUES IN(4,6),
         PARTITION p2 VALUES IN(7,9)
        );
 CREATE TABLE xingrui_t_m_lclc2(col1 INT,col2 INT)
       PARTITION BY LIST COLUMNS(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION mp0 VALUES IN(2),
         SUBPARTITION mp1 VALUES IN(5)
        )
        (PARTITION p0 VALUES IN(1,3),
         PARTITION p1 VALUES IN(4,6),
         PARTITION p2 VALUES IN(7,9)
        );
# 9.List Columns + Hash
CREATE TABLE xingrui_t_m_lch1(col1 INT,col2 INT)
       PARTITION BY LIST COLUMNS(col1)
       SUBPARTITION BY HASH(col2) SUBPARTITIONS 5
        (PARTITION p0 VALUES IN(100),
         PARTITION p1 VALUES IN(200),
         PARTITION p2 VALUES IN(300)
        );
CREATE TABLE xingrui_t_m_lch2(col1 INT,col2 INT)
       PARTITION BY LIST COLUMNS(col1)
       SUBPARTITION BY HASH(col2) SUBPARTITIONS 4
        (PARTITION p0 VALUES IN(100),
         PARTITION p1 VALUES IN(200),
         PARTITION p2 VALUES IN(300)
        );
# 10.List Columns + Key
CREATE TABLE xingrui_t_m_lck1(col1 INT,col2 INT)
       PARTITION BY LIST COLUMNS(col1)
       SUBPARTITION BY KEY(col2)
        SUBPARTITIONS 3
        (PARTITION p0 VALUES IN(100),
         PARTITION p1 VALUES IN(200),
         PARTITION p2 VALUES IN(300)
        );
CREATE TABLE xingrui_t_m_lck2(col1 INT,col2 INT)
       PARTITION BY LIST COLUMNS(col1)
       SUBPARTITION BY KEY(col2)
        SUBPARTITIONS 2
        (PARTITION p0 VALUES IN(100),
         PARTITION p1 VALUES IN(200),
         PARTITION p2 VALUES IN(300)
        );
# 11.Hash + List
CREATE TABLE xingrui_tbl1_hl (col1 INT,col2 INT)
       PARTITION BY HASH(col1)
       SUBPARTITION BY LIST(col2)
        (PARTITION p1
          (SUBPARTITION sp0 VALUES IN (1970)
          ,SUBPARTITION sp1 VALUES IN (1971)
          ,SUBPARTITION sp2 VALUES IN (1972)
          ,SUBPARTITION sp3 VALUES IN (1973)
           ),
         PARTITION p2
          (SUBPARTITION sp4 VALUES IN (1970)
          ,SUBPARTITION sp5 VALUES IN (1971)
          ,SUBPARTITION sp6 VALUES IN (1972)
          ,SUBPARTITION sp7 VALUES IN (1973)
           )
        );
CREATE TABLE xingrui_tbl2_hl (col1 INT,col2 INT)
       PARTITION BY HASH(col1)
       SUBPARTITION BY LIST(col2)
        (PARTITION p1
          (SUBPARTITION sp0 VALUES IN (1970)
          ,SUBPARTITION sp1 VALUES IN (1971)
           ),
         PARTITION p2
          (SUBPARTITION sp2 VALUES IN (1970)
          ,SUBPARTITION sp3 VALUES IN (1971)
           )
        );
# 12.Hash + Key
 CREATE TABLE xingrui_tbl1_hk (col1 INT,col2 INT)
       PARTITION BY HASH(col1)
       SUBPARTITION BY KEY(col2)
        (PARTITION p1
         (SUBPARTITION sp0
         ,SUBPARTITION sp1
         ,SUBPARTITION sp2
         ,SUBPARTITION sp3
         ),
         PARTITION p2
         (SUBPARTITION sp4
         ,SUBPARTITION sp5
         ,SUBPARTITION sp6
         ,SUBPARTITION sp7
         )
        );
 CREATE TABLE xingrui_tbl2_hk (col1 INT,col2 INT)
       PARTITION BY HASH(col1)
       SUBPARTITION BY KEY(col2)
        (PARTITION p1
         (SUBPARTITION sp0
         ,SUBPARTITION sp1
         ),
         PARTITION p2
         (SUBPARTITION sp2
         ,SUBPARTITION sp3
         )
        );
# 13.Hash + Range
 CREATE TABLE xingrui_tbl1_m_hr(col1 INT,col2 INT,col3 INT)
       PARTITION BY HASH(col1)
       SUBPARTITION BY RANGE(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION p0 VALUES LESS THAN(100),
         SUBPARTITION p1 VALUES LESS THAN(200),
         SUBPARTITION p2 VALUES LESS THAN(300)
         )
        PARTITIONS 5;
 CREATE TABLE xingrui_tbl2_m_hr(col1 INT,col2 INT,col3 INT)
       PARTITION BY HASH(col1)
       SUBPARTITION BY RANGE(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION p0 VALUES LESS THAN(100),
         SUBPARTITION p1 VALUES LESS THAN(200)
         )
        PARTITIONS 5;
#14.Hash + Hash
CREATE TABLE xingrui_tbl1_m_hh(col1 INT,col2 INT,col3 INT)
       PARTITION BY HASH(col1)
       SUBPARTITION BY HASH(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION sp0,
         SUBPARTITION sp1,
         SUBPARTITION sp2
         )
        PARTITIONS 5;
CREATE TABLE xingrui_tbl2_m_hh(col1 INT,col2 INT,col3 INT)
       PARTITION BY HASH(col1)
       SUBPARTITION BY HASH(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION sp0,
         SUBPARTITION sp1
         )
        PARTITIONS 5;
# 15.Key + Range Columns
CREATE TABLE xingrui_tbl1_m_krc(col1 INT,col2 INT,col3 INT)
       PARTITION BY KEY(col1)
       SUBPARTITION BY RANGE COLUMNS(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION sp0 VALUES LESS THAN(100),
         SUBPARTITION sp1 VALUES LESS THAN(200),
         SUBPARTITION sp2 VALUES LESS THAN(300)
         )
        (PARTITION p0,
         PARTITION p1,
         PARTITION p2
         );
CREATE TABLE xingrui_tbl2_m_krc(col1 INT,col2 INT,col3 INT)
       PARTITION BY KEY(col1)
       SUBPARTITION BY RANGE COLUMNS(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION sp0 VALUES LESS THAN(100),
         SUBPARTITION sp1 VALUES LESS THAN(200)
         )
        (PARTITION p0,
         PARTITION p1,
         PARTITION p2
         );
# 16.Key + List Columns
CREATE TABLE xingrui_tbl1_m_klc(col1 INT,col2 INT,col3 INT)
       PARTITION BY KEY(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION p0 VALUES IN(1,3),
         SUBPARTITION p1 VALUES IN(4,6),
         SUBPARTITION p2 VALUES IN(7,9)
        )
       PARTITIONS 5;
CREATE TABLE xingrui_tbl2_m_klc(col1 INT,col2 INT,col3 INT)
       PARTITION BY KEY(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION p0 VALUES IN(1,3),
         SUBPARTITION p1 VALUES IN(4,6)
        )
       PARTITIONS 5;
# 17.Key + Hash
 CREATE TABLE xingrui_tbl1_m_kh(col1 INT,col2 INT,col3 INT)
       PARTITION BY KEY(col1)
       SUBPARTITION BY HASH(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION sp0,
         SUBPARTITION sp1,
         SUBPARTITION sp2
         )
        PARTITIONS 5;
 CREATE TABLE xingrui_tbl2_m_kh(col1 INT,col2 INT,col3 INT)
       PARTITION BY KEY(col1)
       SUBPARTITION BY HASH(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION sp0,
         SUBPARTITION sp1
         )
        PARTITIONS 5;
# 18.Key + Key
CREATE TABLE xingrui_tbl1_m_kk(col1 INT,col2 INT,col3 INT)
       PARTITION BY KEY(col1)
       SUBPARTITION BY KEY(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION sp0,
         SUBPARTITION sp1,
         SUBPARTITION sp2
         )
        PARTITIONS 5;
CREATE TABLE xingrui_tbl2_m_kk(col1 INT,col2 INT,col3 INT)
       PARTITION BY KEY(col1)
       SUBPARTITION BY KEY(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION sp0,
         SUBPARTITION sp1
         )
        PARTITIONS 5;
# 19.list + list colums
CREATE TABLE xingrui_llc1(col1 INT,col2 varchar(50))
       PARTITION BY LIST(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
        (PARTITION p0 VALUES in (01)
       (SUBPARTITION mp0 VALUES in ('01'),
        SUBPARTITION mp1 VALUES in ('02'),
        SUBPARTITION mp2 VALUES in ('03')
        ),
       PARTITION p1 VALUES in (02)
        (SUBPARTITION mp3 VALUES in ('01'),
         SUBPARTITION mp4 VALUES in ('02'),
         SUBPARTITION mp5 VALUES in ('03'))
        );
# different sub partition num
CREATE TABLE xingrui_llc2(col1 INT,col2 varchar(50))
       PARTITION BY LIST(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
        (PARTITION p0 VALUES in (01)
       (SUBPARTITION mp0 VALUES in ('01'),
        SUBPARTITION mp1 VALUES in ('02')
        ),
       PARTITION p1 VALUES in (02)
        (SUBPARTITION mp3 VALUES in ('01'),
         SUBPARTITION mp4 VALUES in ('02'))
        );
# different character
CREATE TABLE xingrui_llc3(col1 INT,col2 varchar(50) CHARACTER SET GBK COLLATE gbk_chinese_ci)
       PARTITION BY LIST(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
        (PARTITION p0 VALUES in (01)
       (SUBPARTITION mp0 VALUES in ('01'),
        SUBPARTITION mp1 VALUES in ('02'),
        SUBPARTITION mp2 VALUES in ('03')
        ),
       PARTITION p1 VALUES in (02)
        (SUBPARTITION mp3 VALUES in ('01'),
         SUBPARTITION mp4 VALUES in ('02'),
         SUBPARTITION mp5 VALUES in ('03'))
        );
# different type
CREATE TABLE xingrui_llc4(col1 INT,col2 INT)
       PARTITION BY LIST(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
        (PARTITION p0 VALUES in (01)
       (SUBPARTITION mp0 VALUES in (01),
        SUBPARTITION mp1 VALUES in (02),
        SUBPARTITION mp2 VALUES in (03)
        ),
       PARTITION p1 VALUES in (02)
        (SUBPARTITION mp3 VALUES in (01),
         SUBPARTITION mp4 VALUES in (02),
         SUBPARTITION mp5 VALUES in (03))
        );
# different value
CREATE TABLE xingrui_llc5(col1 INT,col2 varchar(50))
       PARTITION BY LIST(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
        (PARTITION p0 VALUES in (01)
       (SUBPARTITION mp0 VALUES in ('01'),
        SUBPARTITION mp1 VALUES in ('02'),
        SUBPARTITION mp2 VALUES in ('04')
        ),
       PARTITION p1 VALUES in (02)
        (SUBPARTITION mp3 VALUES in ('01'),
         SUBPARTITION mp4 VALUES in ('02'),
         SUBPARTITION mp5 VALUES in ('03'))
        );
# different order
CREATE TABLE xingrui_llc6(col1 INT,col2 varchar(50))
       PARTITION BY LIST(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
        (PARTITION p0 VALUES in (01)
       (SUBPARTITION mp0 VALUES in ('02'),
        SUBPARTITION mp1 VALUES in ('01'),
        SUBPARTITION mp2 VALUES in ('03')
        ),
       PARTITION p1 VALUES in (02)
        (SUBPARTITION mp3 VALUES in ('01'),
         SUBPARTITION mp4 VALUES in ('03'),
         SUBPARTITION mp5 VALUES in ('02'))
        );

# CASE 1.sharding = ‘NONE’ levle one
