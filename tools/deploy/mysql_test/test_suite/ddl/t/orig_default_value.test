--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# group: SQL2
# description: 验证备份恢复和drc特殊的语法, 这里用__oceanbase_inner_drc_user来进行测试
# tags: ddl

#非__oceanbase_inner_drc_user验证orig_default_value
use test;
--error 1149
create table t2(c1 int orig_default 2);
--error 1149
create table t3(c1 int default 100 orig_default 2);

#创建__oceanbase_inner_drc_user
--disable_warnings
create user if not exists __oceanbase_inner_drc_user;
grant all privileges on *.* to __oceanbase_inner_drc_user; 
--enable_warnings

--source mysql_test/include/check_schema_sync.inc
connect (conn_jx_drc,$OBMYSQL_MS0,__oceanbase_inner_drc_user,,test,$OBMYSQL_PORT);
connection conn_jx_drc;
use test;
--disable_warnings
drop table if exists orig_t1;
drop table if exists orig_t2;
drop table if exists orig_t3;
drop table if exists orig_t4;
--enable_warnings

create table orig_t1(c1 int default 100);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table orig_t1;
create table orig_t2(c1 int orig_default 2);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table orig_t2;
create table orig_t3(c1 int default 100 orig_default 2);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table orig_t3;

create table orig_t4(c1 int orig_default 2 default 100);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table orig_t4;

--error 1149
create table fail_t(c1 int orig_default 3 default 100 orig_default 2);

--error 1149
create table fail_t(c1 int default 3 orig_default 100 default 2);

--error 1149
create table fail_t(c1 int default 3 default 100 default 2);

connect (jx_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection jx_obsys;
select column_name, orig_default_value, cur_default_value, orig_default_value_v2, cur_default_value_v2 from oceanbase.__all_virtual_column where column_name != '__pk_cluster_id' and table_id = (select table_id from oceanbase.__all_virtual_table where table_name='orig_t1' order by schema_version desc limit 1);
select column_name, orig_default_value, cur_default_value, orig_default_value_v2, cur_default_value_v2 from oceanbase.__all_virtual_column where column_name != '__pk_cluster_id' and table_id = (select table_id from oceanbase.__all_virtual_table where table_name='orig_t2' order by schema_version desc limit 1);
select column_name, orig_default_value, cur_default_value, orig_default_value_v2, cur_default_value_v2 from oceanbase.__all_virtual_column where column_name != '__pk_cluster_id' and table_id = (select table_id from oceanbase.__all_virtual_table where table_name='orig_t3' order by schema_version desc limit 1);
select column_name, orig_default_value, cur_default_value, orig_default_value_v2, cur_default_value_v2 from oceanbase.__all_virtual_column where column_name != '__pk_cluster_id' and table_id = (select table_id from oceanbase.__all_virtual_table where table_name='orig_t4' order by schema_version desc limit 1);

connection conn_jx_drc;
drop table orig_t1, orig_t2, orig_t3, orig_t4;

disconnect conn_jx_drc;
disconnect jx_obsys;

connection default;

--echo ##bugfix: 
--disable_warnings
drop table if exists t;
--enable_warnings
create table t(c1 int);
insert into t values(1);
alter table t add column c2 timestamp(0) default '2012-12-02 12:01:02.123';
alter table t add column c3 datetime(0) default '2012-12-02 12:01:02.123';
alter table t add column c4 time(0) default '12:01:02.123';

alter table t add column c5 timestamp(0) default timestamp '2012-12-02 12:01:02.123';
alter table t add column c6 datetime(0) default timestamp '2012-12-02 12:01:02.123';
alter table t add column c7 time(0) default time '12:01:02.123';

select * from t;

alter table t modify c2 timestamp(6);
alter table t modify c3 datetime(6);
alter table t modify c4 time(6);

alter table t modify c5 timestamp(6);
alter table t modify c6 datetime(6);
alter table t modify c7 time(6);

select * from t;
drop table t;



