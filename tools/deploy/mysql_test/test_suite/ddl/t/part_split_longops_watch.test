# owner: feidu
# owner group: storage => index and ddl
# description: test GV$SESSION_LONGOPS when partition splitting
# ob do mysqltest --suite=ddl --test-set=part_split_longops_watch -n server_display


--result_format 4

--disable_warnings
drop table if exists t_part_split_sync_debug;
drop sequence if exists s1;
drop sequence if exists s2;
--enable_warnings

################## PARTITION SPLIT PROGRESS####################################

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
sleep 5;

create table t_part_split_sync_debug (id bigint, nid bigint, dob text, primary key(id)) partition by range(id) (partition p0 values less than (100), partition p1 values less than (1500), partition p2 values less than (10000000));
create sequence s1 cache 1000000 noorder;
create sequence s2 cache 1000000 noorder;
CREATE INDEX tbl1_h_idx1 ON t_part_split_sync_debug(id) LOCAL;
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
insert into t_part_split_sync_debug select s1.nextval, s2.nextval, repeat('a', 10000) from table(generator(400));
select count(*) from t_part_split_sync_debug;

sleep 5;

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '10000s';
sleep 5;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for signal1 execute 10000';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_COMPACTION_END wait_for signal2 execute 10000';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_DATA_TABLET_SPLIT_END wait_for signal3 execute 10000';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_LOCAL_INDEX_SPLIT_END wait_for signal4 execute 10000';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_LOB_TABLET_SPLIT_END wait_for signal5 execute 10000';
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
send alter table t_part_split_sync_debug reorganize partition p2 into ( partition p1_2 values less than (5000000), partition p2_2 values less than (10000000));
sleep 5;

connection conn2;
SELECT OPNAME FROM oceanbase.GV$SESSION_LONGOPS ORDER BY OPNAME;
connection obsys;
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END clear';
set ob_global_debug_sync = 'now signal signal1';
sleep 5;

connection conn2;
SELECT OPNAME FROM oceanbase.GV$SESSION_LONGOPS ORDER BY OPNAME;
connection obsys;
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_COMPACTION_END clear';
set ob_global_debug_sync = 'now signal signal2';
sleep 5;

connection conn2;
SELECT OPNAME FROM oceanbase.GV$SESSION_LONGOPS ORDER BY OPNAME;
connection obsys;
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_DATA_TABLET_SPLIT_END clear';
set ob_global_debug_sync = 'now signal signal3';
sleep 5;

connection conn2;
SELECT OPNAME FROM oceanbase.GV$SESSION_LONGOPS ORDER BY OPNAME;
connection obsys;
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_LOCAL_INDEX_SPLIT_END clear';
set ob_global_debug_sync = 'now signal signal4';
sleep 5;

connection conn2;
SELECT OPNAME FROM oceanbase.GV$SESSION_LONGOPS ORDER BY OPNAME;
connection obsys;
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_LOB_TABLET_SPLIT_END clear';
set ob_global_debug_sync = 'now signal signal5';
sleep 5;

connection conn1;
reap;
