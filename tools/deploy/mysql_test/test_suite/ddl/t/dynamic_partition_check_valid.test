# owner: zhaoziqian.zzq
# owner group: rs
# tags: ddl
# description: test dynamic partition limitation in mysql mode

connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
--disable_warnings
drop database if exists ziqian_dynamic_part;
--enable_warnings
create database ziqian_dynamic_part;
use ziqian_dynamic_part;
set recyclebin = off;
#sys tenant do not support dynamic partitioning functionality
--disable_parsing
# 1. part level: could not specify dynamic partition policy on non-partitioned table 
--error 1235
create table t1 (c1 int)
dynamic_partition_policy
(
  time_unit = 'day'
);
create table t1 (c1 int);
--error 1235
alter table t1 set
dynamic_partition_policy
(
  precreate_time = '3day'
);

# 2. part func type: only support range columns and range
--error 1235
create table t2 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'hour'
)
partition by list columns (c1)
(
  partition p0 values in ('2025-01-01 00:00:00')
);

## 2.1 range columns: only support date, datetime, timestamp, year, bigint as part key
--error 1235
create table t21 (c1 int)
dynamic_partition_policy
(
  time_unit = 'hour'
)
partition by range columns (c1)
(
  partition p0 values less than (100)
);

### 2.1.1 date: time_unit should not be hour
--error 1210
create table t211 (c1 date)
dynamic_partition_policy
(
  time_unit = 'hour'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01')
);
create table t211 (c1 date)
dynamic_partition_policy
(
  time_unit = 'day'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01')
);

### 2.1.2 datetime
create table t212 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'hour'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);

### 2.1.3 timestamp
create table t213 (c1 timestamp)
dynamic_partition_policy
(
  time_unit = 'hour'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);

### 2.1.4 year: time_unit must be year
--error 1210
create table t214 (c1 year)
dynamic_partition_policy
(
  time_unit = 'month'
)
partition by range columns (c1)
(
  partition p0 values less than (2025)
);
create table t214 (c1 year)
dynamic_partition_policy
(
  time_unit = 'year'
)
partition by range columns (c1)
(
  partition p0 values less than (2025)
);

### 2.1.5 bigint: bigint_precision must be specified
--error 1210
create table t215 (c1 bigint)
dynamic_partition_policy
(
  time_unit = 'day'
)
partition by range columns (c1)
(
  partition p0 values less than (1735689600)
);
create table t215 (c1 bigint)
dynamic_partition_policy
(
  time_unit = 'day',
  bigint_precision = 's'
)
partition by range columns (c1)
(
  partition p0 values less than (1735689600)
);

## 2.2 range: only support year, bigint as part key
--error 1659
create table t22 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'hour'
)
partition by range (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);

### 2.2.1 year
create table t221 (c1 year)
dynamic_partition_policy
(
  time_unit = 'year'
)
partition by range (c1)
(
  partition p0 values less than (2025)
);

### 2.2.2 bigint
create table t222 (c1 bigint)
dynamic_partition_policy
(
  time_unit = 'day',
  bigint_precision = 's'
)
partition by range (c1)
(
  partition p0 values less than (1735689600)
);

### 2.2.3 not support part key with function
--error 1235
create table t223 (c1 timestamp)
dynamic_partition_policy
(
  time_unit = 'day'
)
partition by range (unix_timestamp(c1))
(
  partition p0 values less than (0)
);

# 3. part key num: only support one part key
--error 1235
create table t3 (c1 datetime, c2 datetime)
dynamic_partition_policy
(
  time_unit = 'hour'
)
partition by range columns (c1, c2)
(
  partition p0 values less than ('2025-01-01 00:00:00', '2025-01-01 00:00:00')
);

# 4. dynamic partition policy params

## 4.1 enable:
##     - true / false
--error 1064
create table t41 (c1 datetime)
dynamic_partition_policy
(
  enable = abcd
  time_unit = 'hour'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);
create table t41 (c1 datetime)
dynamic_partition_policy
(
  enable = true,
  time_unit = 'hour'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);
alter table t41 set
dynamic_partition_policy
(
  enable = false
);

## 4.2 time_unit:
##     - must specify when set dynamic partition policy at first time
##     - hour / day / week / month / year
##     - can not be altered once specified
--error 1210
create table t42 (c1 datetime)
dynamic_partition_policy
(
  enable = true
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);
create table t42 (c1 datetime)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);
--error 1210
alter table t42 set
dynamic_partition_policy
(
  enable = false
);
alter table t42 set
dynamic_partition_policy
(
  time_unit = 'hour'
);
--error 1235
alter table t42 set
dynamic_partition_policy
(
  time_unit = 'day'
);
drop table t42;
create table t42 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'hour'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);
--error 1235
alter table t42 set
dynamic_partition_policy
(
  time_unit = 'day'
);
drop table t42;
create table t42 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'day'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);
drop table t42;
create table t42 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'week'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);
drop table t42;
create table t42 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'month'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);
drop table t42;
create table t42 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'year'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);
drop table t42;
--error 1210
create table t42 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'abcd'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);

## 4.3 precreate_time:
##     - n hour/day/week/month/year, -1, 0
##     - precreate part num <= MAX_PRECREATE_PART_NUM
create table t43 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'day',
  precreate_time = '-1'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);
alter table t43 set
dynamic_partition_policy
(
  precreate_time = '0'
);
alter table t43 set
dynamic_partition_policy
(
  precreate_time = '1day'
);
alter table t43 set
dynamic_partition_policy
(
  precreate_time = '1week'
);
alter table t43 set
dynamic_partition_policy
(
  precreate_time = '1month'
);
alter table t43 set
dynamic_partition_policy
(
  precreate_time = '1year'
);
--error 1210
alter table t43 set
dynamic_partition_policy
(
  precreate_time = '1000year'
);
--error 1210
alter table t43 set
dynamic_partition_policy
(
  precreate_time = 'abcd'
);
--error 1210
alter table t43 set
dynamic_partition_policy
(
  precreate_time = '-1day'
);
--error 1210
alter table t43 set
dynamic_partition_policy
(
  precreate_time = '0day'
);
--error 1210
alter table t43 set
dynamic_partition_policy
(
  precreate_time = '9223372036854775807day'
);

## 4.4 expire_time:
##     - n hour/day/week/month/year, -1, 0
create table t44 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'day',
  expire_time = '-1'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);
alter table t44 set
dynamic_partition_policy
(
  expire_time = '0'
);
alter table t44 set
dynamic_partition_policy
(
  expire_time = '1hour'
);
alter table t44 set
dynamic_partition_policy
(
  expire_time = '1day'
);
alter table t44 set
dynamic_partition_policy
(
  expire_time = '1week'
);
alter table t44 set
dynamic_partition_policy
(
  expire_time = '1day'
);
alter table t44 set
dynamic_partition_policy
(
  expire_time = '1year'
);
--error 1210
alter table t44 set
dynamic_partition_policy
(
  expire_time = 'abcd'
);

## 4.5 time_zone:
##     - default / +-n:00
##     - timestamp / bigint can not specify time_zone
##     - can not be altered once specified
create table t45 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'day',
  time_zone = '+6:00'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);
--error 1235
alter table t45 set
dynamic_partition_policy
(
  time_zone = '+7:00'
);
drop table t45;
--error 1210
create table t45 (c1 timestamp)
dynamic_partition_policy
(
  time_unit = 'day',
  time_zone = '+6:00'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);
--error 1210
create table t45 (c1 bigint)
dynamic_partition_policy
(
  time_unit = 'day',
  time_zone = '+6:00',
  bigint_precision = 's'
)
partition by range columns (c1)
(
  partition p0 values less than (1735689600)
);
--error 1298
create table t45 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'day',
  time_zone = '+20:00'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);

## 4.6 bigint_precision:
##     - s / ms / us
##     - only bigint can specify bigint_precision
##     - can not be altered once specified
--error 1210
create table t46 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'day',
  bigint_precision = 's'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);
create table t46 (c1 bigint)
dynamic_partition_policy
(
  time_unit = 'day',
  bigint_precision = 's'
)
partition by range columns (c1)
(
  partition p0 values less than (1735689600)
);
--error 1235
alter table t46 set
dynamic_partition_policy
(
  bigint_precision = 'ms'
);

drop database ziqian_dynamic_part;

connect (sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);

# 5. sys tenant do not support dynamic partition
--disable_warnings
drop table if exists ziqian_dynamic_part_t1;
--enable_warnings
--error 1235
create table ziqian_dynamic_part_t1 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'day',
  precreate_time = '3day'
)
partition by range columns (c1)
(
  partition p0 values less than ('2000-01-01')
);

create table ziqian_dynamic_part_t1 (c1 datetime)
partition by range columns (c1)
(
  partition p0 values less than ('2000-01-01')
);
--error 1235
alter table ziqian_dynamic_part_t1 set
dynamic_partition_policy
(
  time_unit = 'day',
  precreate_time = '3day'
);
drop table ziqian_dynamic_part_t1;
--enable_parsing

