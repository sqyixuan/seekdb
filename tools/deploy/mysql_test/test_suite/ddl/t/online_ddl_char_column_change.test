# owner: gaishun.gs
# owner group: storage : index and ddl
# description: 向上列类型转换
# note: ob do mysqltest --suite=ddl --test_set=online_ddl_char_column_change -n 43_int2bigint
# note: ob do mysqltest --suite=ddl --test_set=online_ddl_char_column_change -n 43base
 
--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
 
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

# check the alter correction of type change
# common char(x1) -> char(x2); x2>=x1 and convert over 255: online
--disable_warnings
drop table if exists t2_char;
drop table if exists t1_char;
drop sequence if exists s1;
--enable_warnings
create table t1_char (a char(20));
create sequence s1 cache 1000000 noorder;
insert into t1_char select s1.nextval from table(generator(2000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_char', table_id, 1);
alter table t1_char change column a a char(30);
insert into t1_char select s1.nextval from table(generator(2000));
select count(*) from t1_char;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_char', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}

# primary key char(x1) -> char(x2); x2>=x1 and convert over 255: online
--disable_warnings
drop table if exists t1_char;
drop sequence if exists s1;
--enable_warnings
create table t1_char (a char(20) primary key);
create sequence s1 cache 1000000 noorder;
insert into t1_char select s1.nextval from table(generator(2000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_char', table_id, 1);
alter table t1_char change column a a char(30);
insert into t1_char select s1.nextval from table(generator(2000));
select count(*) from t1_char;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_char', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}

# index key char(x1) -> char(x2); x2>=x1 and convert over 255: online
--disable_warnings
drop table if exists t1_char;
--enable_warnings
drop sequence if exists s1;
create table t1_char (a char(20));
create sequence s1 cache 1000000 noorder;
create index idx_t1_char on t1_char(a);
insert into t1_char select s1.nextval from table(generator(2000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_char', table_id, 1);
alter table t1_char change column a a char(30);
insert into t1_char select s1.nextval from table(generator(2000));
select count(*) from t1_char;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_char', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}

# foreign key char(x1) -> char(x2); x2>=x1 and convert over 255: online
--disable_warnings
drop table if exists t2_char;
drop table if exists t1_char;
drop sequence if exists s1;
drop sequence if exists s2;
--enable_warnings
create table t1_char (a char(20) unique);
create table t2_char (a char(20), foreign key(a) references t1_char(a));
create sequence s1 cache 1000000 noorder;
create sequence s2 cache 1000000 noorder;
insert into t1_char select s1.nextval from table(generator(2000));
insert into t2_char select s2.nextval from table(generator(2000));
--error 1235
alter table t1_char change column a a char(30);
--error 1235
alter table t2_char change column a a char(30);
insert into t1_char select s1.nextval from table(generator(2000));
insert into t2_char select s2.nextval from table(generator(2000));
select count(*) from t1_char;
drop table if exists t2_char;


# generated column stored and virtual
--disable_warnings
drop table if exists t1_char;
drop sequence if exists s1;
--enable_warnings
create table t1_char (a char(10), b char(20) generated always as (a*2) STORED);
create sequence s1 cache 1000000 noorder;
insert into t1_char(a) select s1.nextval from table(generator(1000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_char', table_id, 1);
