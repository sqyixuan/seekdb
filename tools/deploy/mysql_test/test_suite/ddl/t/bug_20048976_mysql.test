# owner : dachuan.sdc
# owner group : SQL2
# description : 在用户试图创建逆序索引时报错
# tags: ddl 

--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_result_log
drop table if exists t1;
--enable_result_log

create table t1(c1 int, c2 int, c3 int, c4 int, constraint t1_c1_bug_20048976_1 unique(c1 desc));
drop table t1;
create table t1(c1 int, c2 int, c3 int, c4 int, constraint t1_c1_bug_20048976_1 unique(c1));
alter table t1 add constraint t1_c1_bug_20048976_2 unique(c2 desc);
alter table t1 add constraint t1_c1_bug_20048976_3 unique(c2);
create index t1_c1_bug_20048976_4 on t1(c3 desc);
create index t1_c1_bug_20048976_5 on t1(c3);
alter table t1 add index t1_c1_bug_20048976_6(c4 desc);
alter table t1 add index t1_c1_bug_20048976_7(c4);

# clean up
drop table t1;

