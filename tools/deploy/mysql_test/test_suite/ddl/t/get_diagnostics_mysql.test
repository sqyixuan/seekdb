CREATE PROCEDURE p1()
BEGIN
   DECLARE numbers1,numbers2 INT;
   DECLARE rowcount1,rowcount2 INT;  
   DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
    GET CURRENT DIAGNOSTICS numbers1 = NUMBER,rowcount1 = ROW_COUNT;
    GET STACKED DIAGNOSTICS numbers2 = NUMBER,rowcount2 = ROW_COUNT;
    SELECT numbers1,rowcount1,numbers2,rowcount2;
    IF numbers1 = 0 THEN
      SELECT 'IF 分支,numbers1=',numbers1;
    ELSE
      SELECT 'ELSE 分支,numbers1=',numbers1;
    END IF ;
  END;
  SELECT * FROM tt1;
END;/

CALL p1()/

drop procedure p1/

CREATE TABLE t1(int_col int NOT NULL);/

CREATE PROCEDURE p1(value INT)
BEGIN
  DECLARE code1,code2 CHAR(5) DEFAULT '00000';
  DECLARE msg1,msg2 TEXT;
  DECLARE nrows,errno1,errno2 INT;
  DECLARE result TEXT;

  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
    GET CURRENT DIAGNOSTICS CONDITION 1 code1 = RETURNED_SQLSTATE, msg1 = MESSAGE_TEXT, errno1 = MYSQL_ERRNO;
    GET STACKED DIAGNOSTICS CONDITION 1 code2 = RETURNED_SQLSTATE, msg2 = MESSAGE_TEXT, errno2 = MYSQL_ERRNO;	
  END;

  INSERT INTO t1 (int_col) VALUES(value);
  
  select 'IF语句前 code1 = ',code1;
  
  IF code1 = '00000' THEN
    SELECT 'IF 分支';
    GET DIAGNOSTICS nrows = ROW_COUNT;
    SELECT 'insert succeeded, ',nrows;
  ELSE
    SELECT 'ELSE 分支';
    SELECT 'insert failed, ',code1,msg1,errno1;
  END IF;
  if errno1 = 1048 THEN
    select 'number type is ok';
  else
    select 'number type is not ok';
  end if;
END;/

CALL p1(NULL)/

drop procedure p1/

CREATE PROCEDURE p1(value INT)
BEGIN
  DECLARE code1,code2 varchar(5) DEFAULT '00000';
  DECLARE msg1,msg2 varchar(50);
  DECLARE nrows,errno1,errno2 decimal(5);
  DECLARE result TEXT;

  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
    GET CURRENT DIAGNOSTICS CONDITION 1 code1 = RETURNED_SQLSTATE, msg1 = MESSAGE_TEXT, errno1 = MYSQL_ERRNO;
    GET STACKED DIAGNOSTICS CONDITION 1 code2 = RETURNED_SQLSTATE, msg2 = MESSAGE_TEXT, errno2 = MYSQL_ERRNO;	
  END;

  INSERT INTO t1 (int_col) VALUES(value);
  
  select 'IF语句前 code1 = ',code1;
  
  IF code1 = '00000' THEN
    SELECT 'IF 分支';
    GET DIAGNOSTICS nrows = ROW_COUNT;
    SELECT 'insert succeeded, ',nrows;
  ELSE
    SELECT 'ELSE 分支';
    SELECT 'insert failed, ',code1,msg1,errno1;
  END IF;

  if errno1 = 1048 THEN
    select 'number type is ok';
  else
    select 'number type is not ok';
  end if;
END;/

call p1(null)/

drop procedure p1/

CREATE PROCEDURE p1(value INT)
BEGIN
  DECLARE code1,code2 varchar(5) DEFAULT '00000';
  DECLARE msg1,msg2 varchar(50);
  DECLARE nrows,errno1,errno2 smallint;
  DECLARE result TEXT;

  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
    GET CURRENT DIAGNOSTICS CONDITION 1 code1 = RETURNED_SQLSTATE, msg1 = MESSAGE_TEXT, errno1 = MYSQL_ERRNO;
    GET STACKED DIAGNOSTICS CONDITION 1 code2 = RETURNED_SQLSTATE, msg2 = MESSAGE_TEXT, errno2 = MYSQL_ERRNO;	
  END;

  INSERT INTO t1 (int_col) VALUES(value);
  
  select 'IF语句前 code1 = ',code1;
  
  IF code1 = '00000' THEN
    SELECT 'IF 分支';
    GET DIAGNOSTICS nrows = ROW_COUNT;
    SELECT 'insert succeeded, ',nrows;
  ELSE
    SELECT 'ELSE 分支';
    SELECT 'insert failed, ',code1,msg1,errno1;
  END IF;

  if errno1 = 1048 THEN
    select 'number type is ok';
  else
    select 'number type is not ok';
  end if;
END;/

