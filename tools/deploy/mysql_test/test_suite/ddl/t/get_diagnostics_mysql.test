--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop procedure if exists c_var;
DROP PROCEDURE IF EXISTS p;
DROP TABLE IF EXISTS t1;
--enable_warnings

CREATE TABLE t1 (c1 TEXT NOT NULL);

--error 1064
a;
get diagnostics condition 1 @p = MESSAGE_TEXT;
get diagnostics @r=ROW_COUNT, @p2=NUMBER;
select @p, @r, @p2;

--error 3004
get stacked diagnostics @t=ROW_COUNT;

--error 1064
get stacked diagnostics @t=MESSAGE_TEXT;

--error 1064
get diagnostics @t=MESSAGE_TEXT;

--error 1064
get current diagnostics @t=1;
get current diagnostics condition 1 @t1=MYSQL_ERRNO;
get current diagnostics condition 1 @t2=RETURNED_SQLSTATE;
select @t1,@t2;

--error 1064
x;
get diagnostics condition 1 @t1=CLASS_ORIGIN, @t2=SUBCLASS_ORIGIN, @t3=MYSQL_ERRNO, @t4=RETURNED_SQLSTATE, @t5=MESSAGE_TEXT;
select @t1,@t2,@t3,@t4,@t5;

delimiter /;

create procedure c_var() 
begin 
declare exit handler for sqlexception
begin
      GET stacked DIAGNOSTICS CONDITION 1 @msg1 = MESSAGE_TEXT;
      GET stacked DIAGNOSTICS @msg2 = NUMBER;
      GET DIAGNOSTICS CONDITION 1 @msg3 = MESSAGE_TEXT;
      GET DIAGNOSTICS @msg4 = NUMBER;
      select @msg1, @msg2, @msg3, @msg4; -- b not existed
end;
select x;
end;/

CREATE PROCEDURE p()
BEGIN
  -- Declare variables to hold diagnostics area information
  DECLARE errcount INT;
  DECLARE errno INT;
  DECLARE msg TEXT;
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    GET CURRENT DIAGNOSTICS CONDITION 1
      errno = MYSQL_ERRNO, msg = MESSAGE_TEXT;
    SELECT '1current DA before mapped insert' AS op, errno, msg;
    GET STACKED DIAGNOSTICS CONDITION 1
      errno = MYSQL_ERRNO, msg = MESSAGE_TEXT;
    SELECT '2stacked DA before mapped insert' AS op, errno, msg;
  END;
  INSERT INTO t1 (c1) VALUES('string 1');
  INSERT INTO t1 (c1) VALUES(NULL);
END;/

delimiter ;/

show warnings;

call c_var();

call p();

--disable_warnings
drop procedure c_var;
drop procedure if exists p1;
--enable_warnings

set @@sql_notes=1;
set @@sql_notes=0;

--error 1231
set @@sql_notes=2;

select @@sql_notes;

select @@global.sql_notes;

select @@session.sql_notes;

delimiter /;

create procedure p1()
begin
  declare msg varchar(200);
  declare a tinyint unsigned;
  declare exit handler for  sqlexception
  begin
    GET DIAGNOSTICS a = NUMBER;
    get stacked diagnostics condition a msg = MESSAGE_TEXT;
    select msg, a;
  end;
  select x;
end/

call p1()/

drop procedure p1/

create procedure p1()
begin
  declare continue handler for sqlexception
  begin
    declare continue handler for sqlexception
    begin
      GET STACKED DIAGNOSTICS CONDITION 1 @msg1 = MESSAGE_TEXT;
      select @msg1;
    end;
    select * from b;
    GET STACKED DIAGNOSTICS CONDITION 1 @msg2 = MESSAGE_TEXT;
    select @msg2;
  end;
  select x;
end/

