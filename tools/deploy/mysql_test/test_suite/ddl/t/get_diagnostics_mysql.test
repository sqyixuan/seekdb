CALL p1();
select @num1,@num2;/

drop procedure p1/

CREATE PROCEDURE p1()
BEGIN
declare a int;
declare continue handler for sqlexception
begin
 get DIAGNOSTICS @num1=number;
 select '123';
end;
set a='aaaa';
END;/

set @num1=0;
CALL p1();
select @num1;/

drop procedure p1/

CREATE PROCEDURE p1()
BEGIN
declare a condition for sqlstate '22001';
declare continue handler for a
begin
 get DIAGNOSTICS @num=number;
 get DIAGNOSTICS condition @num @a = MESSAGE_TEXT, @b=returned_sqlstate, @c=mysql_errno;
 select @num, @a,@b,@c;
end;
  begin
  declare a varchar(2) default 'aaaaa';
  end;
END;/


set @num=0,@a=null,@b=null,@c=null;
CALL p1();/

drop procedure p1/


create procedure p2(a int)
begin
  select a;
end;/

create procedure p1()
begin
  declare a int DEFAULT 0;
  declare continue handler for SQLException
  begin
    get DIAGNOSTICS @num1=number;
    get diagnostics condition 1  @msg = message_text;
  end;
  call p2(a + 'd');
END;/

drop procedure p1/
drop procedure p2/

#

--disable_warnings
drop function if exists f1/
--enable_warnings

create function f1(a varchar(2))returns int
begin
return 1;
end;/

CREATE procedure p1()
begin
   declare a varchar(2);
   declare out_code varchar(10);
   declare out_msg varchar(100);
   declare continue handler for SQLEXCEPTION
   begin
        show warnings;
        get diagnostics condition 1
          out_code=returned_sqlstate,out_msg=message_text;
        select 'error:',out_code,out_msg;
   end;
   set a=f1('aaaa');
end;/

call p1()/

drop function f1/
drop procedure p1/

