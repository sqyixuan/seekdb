# owner : gaishun.gs
# owner group : storage
# description : test the table_option micro_index_clustered
# tags: ddl
# note: ob do mysqltest --suite=ddl --test_set=create_table_micro_index_clustered -n table_option

--result_format 4

--disable_warnings
drop table if exists t1_micro_index_clustered;
--enable_warnings

--error 1064
create table t1_micro_index_clustered (a int, b text, index(a) MICRO_INDEX_CLUSTERED = FALSE) MICRO_INDEX_CLUSTERED = FALSE;
create table t1_micro_index_clustered (a int, b text, index(a)) MICRO_INDEX_CLUSTERED = FALSE;
create index idx_a_twice on t1_micro_index_clustered(a);
--error 1064
create index idx_a_third on t1_micro_index_clustered(a) MICRO_INDEX_CLUSTERED = TRUE;
show create table t1_micro_index_clustered;
select 
  micro_index_clustered 
from 
  oceanbase.__all_table 
where 
  table_name = 't1_micro_index_clustered' 
  or 
  data_table_id = 
    (select table_id from oceanbase.__all_table where table_name='t1_micro_index_clustered');

--disable_warnings
drop table if exists t1_micro_index_clustered;
--enable_warnings

--error 1064
create table t1_micro_index_clustered (a int, b text, index(a) MICRO_INDEX_CLUSTERED = TRUE) MICRO_INDEX_CLUSTERED = TRUE;
create table t1_micro_index_clustered (a int, b text, index(a)) MICRO_INDEX_CLUSTERED = TRUE;
create index idx_a_twice on t1_micro_index_clustered(a);
--error 1064
create index idx_a_third on t1_micro_index_clustered(a) MICRO_INDEX_CLUSTERED = FALSE;
show create table t1_micro_index_clustered;
select 
  micro_index_clustered 
from 
  oceanbase.__all_table 
where 
  table_name = 't1_micro_index_clustered' 
  or 
  data_table_id = 
    (select table_id from oceanbase.__all_table where table_name='t1_micro_index_clustered');