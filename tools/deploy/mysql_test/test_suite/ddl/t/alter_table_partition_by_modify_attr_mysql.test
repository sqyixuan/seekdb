--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : yangjiali.yjl
#owner group: auto split partition
#description: basic alter table partition by size

connect (conn_sys,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn_sys;

--disable_warnings
drop database if exists yjl_auto_split;
create database yjl_auto_split;
use yjl_auto_split;

let $database_id=query_get_value(select database_id from oceanbase.__all_database where database_name='yjl_auto_split', database_id, 1);

--echo #测试 alter table t_split partition by range() size('xxx');
# 非自动分区，非分区表
echo "001--------------------------------------------------------------------------------------------------------";
drop table if exists t_split;
create table t_split(c1 int, c2 int, primary key(c1));
let $old_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='t_split' and database_id=$database_id, table_id, 1);
alter table t_split partition by range() size('20GB');
let $new_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='t_split' and database_id=$database_id, table_id, 1);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_split;
if ($old_table_id == $new_table_id)
{
  echo "success!";
}

# 非自动分区，分区表
echo "002--------------------------------------------------------------------------------------------------------";
drop table if exists t_split;
create table t_split(c1 int, c2 int, primary key(c1)) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (maxvalue));
let $old_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='t_split' and database_id=$database_id, table_id, 1);
alter table t_split partition by range() size('20GB');
let $new_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='t_split' and database_id=$database_id, table_id, 1);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_split;
if ($old_table_id == $new_table_id)
{
  echo "success!";
}

