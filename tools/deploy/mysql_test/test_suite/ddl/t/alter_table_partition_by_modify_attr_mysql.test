# partition by range columns
echo "024--------------------------------------------------------------------------------------------------------";
drop table if exists t_split;
create table t_split(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (maxvalue));
--error 1235
alter table t_split partition by range columns(c1, c2) size('20GB');
# expected error, because alter partition key is not equal to old partition key

drop table if exists t_split;
create table t_split(c1 int, c2 int, primary key(c1,c2)) partition by range columns (c1, c2) (partition p0 values less than (10, 10), partition p1 values less than (maxvalue, maxvalue));
