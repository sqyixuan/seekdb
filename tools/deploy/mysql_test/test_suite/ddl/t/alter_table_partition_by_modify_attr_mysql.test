select owner, auto_split, auto_split_tablet_size from oceanbase.CDB_TABLES where table_name='t_split' and owner='yjl_auto_split';

# 自动分区表和table group：1）如果table属于tablegroup，那么这个表不能修改为自动分区表 2）如果创建表为自动分区表，或者现存的表为自动分区表时，都不能加入tablegroup，
echo "042--------------------------------------------------------------------------------------------------------";
drop table if exists t_split;
create tablegroup tbg1 sharding='NONE';
create table t_split(c1 int, c2 int, primary key(c1)) tablegroup=tbg1;
#--error 1235
alter table t_split partition by range() size('10GB');
drop table t_split;
create table t_split(c1 int, c2 int, primary key(c1));
alter table t_split partition by range() size('10GB');
#--error 1235
alter tablegroup tbg1 add t_split;
drop table t_split;
#--error 1235
create table t_split(c1 int, c2 int, primary key(c1)) tablegroup=tbg1 partition by range(c1) size('10GB') (partition p0 values less than (10), partition p1 values less than (100));
drop table if exists t_split;
create table t_split(c1 int, c2 int, primary key(c1)) tablegroup=tbg1;
#--error 1235
alter table t_split partition by range(c1) size('10GB') (partition p0 values less than(10), partition p1 values less than (100));
drop table t_split;
create table t_split(c1 int, c2 int, primary key(c1)) partition by range();
#--error 1235
alter table t_split set tablegroup=tbg1;
--error 4615
drop tablegroup tbg1;

# ddl operationb
echo "043--------------------------------------------------------------------------------------------------------";
drop table if exists t_split;
let $cur_time=query_get_value(select CURRENT_TIMESTAMP(6) as cur_time, cur_time, 1);
create table t_split(c1 int, c2 int, primary key(c1));
create index auto_split_index on t_split(c1) global;
alter table t_split partition by range() size('10GB');
--disable_query_log
eval select operation_type, ddl_stmt_str from oceanbase.__all_ddl_operation where gmt_create >= '$cur_time' and table_id != 0;
--enable_query_log

# check resolver coredump issue
echo "044--------------------------------------------------------------------------------------------------------";
drop table if exists t_split;
create table t_split(c1 int, c2 int, primary key(c1));
alter table t_split partition by key(c1);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_split;
drop table t_split;
drop tablegroup tbg1;

drop table if exists t_split;
drop database if exists yjl_auto_split;
