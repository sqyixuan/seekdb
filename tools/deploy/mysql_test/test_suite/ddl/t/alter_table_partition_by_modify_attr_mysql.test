drop table if exists t_split;
create table t_split(c1 int, c2 int, primary key(c1,c2));
select auto_split, auto_split_tablet_size from information_schema.TABLES where table_name='t_split' and table_schema='yjl_auto_split';
select owner, auto_split, auto_split_tablet_size from oceanbase.CDB_TABLES where table_name='t_split' and owner='yjl_auto_split';
alter table t_split partition by range() size('10GB');
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
