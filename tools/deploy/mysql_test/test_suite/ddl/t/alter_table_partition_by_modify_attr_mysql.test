# 全局分区索引表， offline修改主表为自动分区表, 需要满足分区键是索引键前缀的前提才能开启自动分区
echo "035--------------------------------------------------------------------------------------------------------";
drop table if exists t_split;
create table t_split(c1 int, c2 int, c3 int, primary key(c1)) partition by range(c1) (partition p0 values less than(10), partition p1 values less than(100));
let $old_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='t_split' and database_id=$database_id, table_id, 1);
create index idx1 on t_split(c1,c2) global partition by range(c1) (partition p0 values less than (10), partition p1 values less than (100));
alter table t_split partition by range(c1) size('10GB') (partition p0 values less than (20), partition p1 values less than (200));
let $auto_part = query_get_value(select auto_part from oceanbase.__all_table where table_name like '%idx1%' and database_id=$database_id, auto_part, 1);
if ($auto_part == 1) 
{
  echo "success!";
}
let $auto_part_size = query_get_value(select auto_part_size from oceanbase.__all_table where table_name like '%idx1%' and database_id=$database_id, auto_part_size, 1);
if ($auto_part_size == 10737418240) 
{
  echo "success!";
}
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_split;
let $new_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='t_split' and database_id=$database_id, table_id, 1);
if ($old_table_id != $new_table_id)
{
  echo "success!";
}

# 关闭自动分区，清理 part_func_expr，part_func_type
echo "036--------------------------------------------------------------------------------------------------------";
drop table if exists t_split;
create table t_split(c1 int, c2 int, primary key(c1));
let $old_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='t_split' and database_id=$database_id, table_id, 1);
alter table t_split partition by range(c1);
alter table t_split partition by range() size('unlimited');
let $part_func_expr = query_get_value(select part_func_expr from oceanbase.__all_table where table_name='t_split' and database_id=$database_id, part_func_expr, 1);
let $part_func_type = query_get_value(select part_func_type from oceanbase.__all_table where table_name='t_split' and database_id=$database_id, part_func_type, 1);
let $new_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='t_split' and database_id=$database_id, table_id, 1);
if ($part_func_expr == "") 
{
  echo "success!";
}
if ($part_func_type == 0) 
{
  echo "success!";
}
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_split;
if ($old_table_id == $new_table_id)
{
  echo "success!";
}

# 分区表/非分区表变成自动分区后，自动分区键必须要满足主键前缀的约束
echo "037--------------------------------------------------------------------------------------------------------";
drop table if exists t_split;
create table t_split(c1 int, c2 int, c3 int, primary key(c1,c2,c3));
alter table t_split partition by range() size('10GB');
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_split;
alter table t_split partition by range(c1) size('10GB');
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_split;
alter table t_split partition by range columns (c1,c2) size('10GB');
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_split;
drop table t_split;
create table t_split(c1 int, c2 int, c3 int, primary key(c1,c2,c3)) partition by range columns (c1,c3) (partition p0 values less than (10,10), partition p1 values less than (100,100));
--error 1235
alter table t_split partition by range() size('10GB');
--error 1235
alter table t_split partition by range(c1) size('10GB');
--error 1235
alter table t_split partition by range columns (c1,c3) size('10GB');


# 分区表变成自动分区表后，自动分区键必须和旧表分区键一致
echo "038--------------------------------------------------------------------------------------------------------";
drop table if exists t_split;
create table t_split(c1 int, c2 int, c3 int, primary key(c1,c2,c3)) partition by range columns (c1,c2) (partition p0 values less than (10,10), partition p1 values less than (100,100));
alter table t_split partition by range() size('10GB');
--error 1235
alter table t_split partition by range(c1) size('10GB');
--error 1235
alter table t_split partition by range columns (c1,c3) size('10GB');
alter table t_split partition by range columns (c1,c2) size('10GB');
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_split;

