#非分区表，修改为自动分区，主要是几种场景 
# 1）不指定分区键，默认是主表主键，分区类型为range columns
# 2）不指定size，默认为128M
# 3）指定分区键c1，分区类型变更为range。
echo "040--------------------------------------------------------------------------------------------------------";
drop table if exists t_split;
create table t_split(c1 int, c2 int, primary key(c1,c2));
alter table t_split partition by range() size('10GB');
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_split;
alter table t_split partition by range();
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_split;
alter table t_split partition by range(c1);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_split;

# check information_schema.TABLES, CDB_TABLES
