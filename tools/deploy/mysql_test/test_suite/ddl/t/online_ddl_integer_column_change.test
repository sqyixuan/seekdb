# owner: gaishun.gs
# owner group: storage : index and ddl
# description: 向上列类型转换
# note: ob do mysqltest --suite=ddl --test_set=online_ddl_integer_column_change -n 43_int2bigint
# note: ob do mysqltest --suite=ddl --test_set=online_ddl_integer_column_change -n 43base
 
--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
 
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);

# check the alter correction of type change
# primary key signed integer -> signed integer: online
connection conn1;
--disable_warnings
drop table if exists t2;
drop table if exists t1_int_int;
drop sequence if exists s1_bit_int;
--enable_warnings
create table t1_int_int (a tinyint primary key);
create sequence s1_bit_int cache 1000000 noorder;
insert into t1_int_int select s1_bit_int.nextval from table(generator(62));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_int_int', table_id, 1);
alter table t1_int_int change column a a smallint;
insert into t1_int_int select s1_bit_int.nextval from table(generator(2000));
select count(*) from t1_int_int;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_int_int', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}
connection conn1;
