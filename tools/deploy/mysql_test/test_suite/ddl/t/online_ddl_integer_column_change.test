# generated column
--disable_warnings
drop table if exists t1_int_int;
drop sequence if exists s1_bit_int;
--enable_warnings
create table t1_int_int (a int, b int generated always as (a*2) STORED);
create sequence s1_bit_int cache 1000000 noorder;
insert into t1_int_int(a) select s1_bit_int.nextval from table(generator(2000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_int_int', table_id, 1);
alter table t1_int_int change column a a bigint;
--error 3106
alter table t1_int_int change column b b bigint;
--error 3106
alter table t1_int_int change column b b bigint generated always as (a*2) VIRTUAL;
alter table t1_int_int change column b b bigint generated always as (a*2) STORED;
insert into t1_int_int(a) select s1_bit_int.nextval from table(generator(2000));
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_int_int', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}

