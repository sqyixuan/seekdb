# foreign key forbidden
--disable_warnings
drop table if exists t2;
drop table if exists t1_int_int;
drop sequence if exists s1_bit_int;
drop sequence if exists s2_bit_int;
drop sequence if exists s3_bit_int;
--enable_warnings
create table t1_int_int (a int unique);
create sequence s1_bit_int cache 1000000 noorder;
create sequence s2_bit_int cache 1000000 noorder;
create sequence s3_bit_int cache 1000000 noorder;
create table t2 (a int, b int, foreign key (b) references t1_int_int(a));
insert into t1_int_int select s1_bit_int.nextval from table(generator(2000));
insert into t2(a,b) select s2_bit_int.nextval, s3_bit_int.nextval from table(generator(2000));
--error 5320
alter table t1_int_int change column a a bigint unique;
--error 5320
alter table t2 change column b b bigint;
insert into t1_int_int select s1_bit_int.nextval from table(generator(2000));
insert into t2(a,b) select s2_bit_int.nextval, s3_bit_int.nextval from table(generator(2000));
--disable_warnings
drop table if exists t2;
--enable_warnings

