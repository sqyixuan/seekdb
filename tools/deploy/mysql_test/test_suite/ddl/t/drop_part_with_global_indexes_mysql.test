# owner: fanfangzhou.ffz 
# owner group: RS
# description: drop/truncate分区支持全局索引
# tags: ddl

--disable_warnings
--error 0,1396
drop user subpart_mgr@'%';
--enable_warnings
create user subpart_mgr identified by '123';
grant all on *.* to subpart_mgr WITH GRANT OPTION;

set @@recyclebin = off;

--result_format 4

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,subpart_mgr,'123',test,$OBMYSQL_PORT);

connection conn1;
let $base_schema_version = `select schema_version from oceanbase.__all_virtual_ddl_operation order by schema_version desc limit 1`;

connection conn2;
# create table
create table t_range_range (c1 int, c2 int, c3 int, c4 int)
partition by range(c1)
subpartition by range(c2)
(
  partition rp0 values less than (100)
  (
    subpartition rp0sp0 values less than (100),
    subpartition rp0sp1 values less than (200),
    subpartition rp0sp2 values less than (300)
  ),
  partition rp1 values less than (200)
  (
    subpartition rp1sp0 values less than (100),
    subpartition rp1sp1 values less than (200),
    subpartition rp1sp2 values less than (300)
  ),
  partition rp2 values less than (300)
  (
    subpartition rp2sp0 values less than (100),
    subpartition rp2sp1 values less than (200),
    subpartition rp2sp2 values less than (300)
  )
);

# create index
create index idx_t_range_range on t_range_range(c1) global;

# insert row
insert into t_range_range values(1,2,3,4);
insert into t_range_range values(1,100,3,4);
insert into t_range_range values(1,200,3,4);
insert into t_range_range values(100,2,3,4);
insert into t_range_range values(100,100,3,4);
insert into t_range_range values(100,200,3,4);
insert into t_range_range values(200,2,3,4);
insert into t_range_range values(200,100,3,4);
insert into t_range_range values(200,200,3,4);

# truncate

## with update global indexes

### truncate subpartition with update global indexes
--error 1064
alter table t_range_range
truncate subpartition 
rp0sp1 
update global indexes;
explain basic select /*+index(t_range_range idx_t_range_range)*/ * from t_range_range;

connection conn1;
select index_status from oceanbase.__all_virtual_table where table_name like '%idx_t_range_range%';
connection conn2;

### truncate partition with update global indexes
--error 1064
alter table t_range_range
truncate partition 
rp0
update global indexes; 
explain basic select /*+index(t_range_range idx_t_range_range)*/ * from t_range_range;

connection conn1;
select index_status from oceanbase.__all_virtual_table where table_name like '%idx_t_range_range%';
connection conn2;

## without update global indexes

### truncate subpartition without update global indexes
alter table t_range_range
truncate subpartition 
rp1sp1;
explain basic select /*+index(t_range_range idx_t_range_range)*/ * from t_range_range;

connection conn1;
select index_status from oceanbase.__all_virtual_table where table_name like '%idx_t_range_range%';
connection conn2;

# rebuild index
drop index idx_t_range_range on t_range_range;
create index idx_t_range_range on t_range_range(c1) global;

### truncate partition without update global indexes
alter table t_range_range
truncate partition 
rp1;
explain basic select /*+index(t_range_range idx_t_range_range)*/ * from t_range_range;

connection conn1;
select index_status from oceanbase.__all_virtual_table where table_name like '%idx_t_range_range%';
connection conn2;

### rebuild index
drop index idx_t_range_range on t_range_range;
create index idx_t_range_range on t_range_range(c1) global;

# drop
## with update global indexes
### drop subpartition with update global indexes
--error 1064
alter table t_range_range
drop subpartition 
rp0sp1 
update global indexes;
explain basic select /*+index(t_range_range idx_t_range_range)*/ * from t_range_range;

connection conn1;
select index_status from oceanbase.__all_virtual_table where table_name like '%idx_t_range_range%';
connection conn2;

### drop partition with update global indexes
--error 1064
alter table t_range_range drop partition rp0 update global indexes;
explain basic select /*+index(t_range_range idx_t_range_range)*/ * from t_range_range;

connection conn1;
select index_status from oceanbase.__all_virtual_table where table_name like '%idx_t_range_range%';
connection conn2;

## without update global indexes
### drop subpartition without update global indexes
alter table t_range_range
drop subpartition 
rp1sp1;
explain basic select /*+index(t_range_range idx_t_range_range)*/ * from t_range_range;

connection conn1;
select index_status from oceanbase.__all_virtual_table where table_name like '%idx_t_range_range%';
connection conn2;

### rebuild index
drop index idx_t_range_range on t_range_range;
create index idx_t_range_range on t_range_range(c1) global;

### drop partition without update global indexes
alter table t_range_range drop partition rp1;
explain basic select /*+index(t_range_range idx_t_range_range)*/ * from t_range_range;

connection conn1;
select index_status from oceanbase.__all_virtual_table where table_name like '%idx_t_range_range%';

let $table_id = `select table_id from oceanbase.__all_virtual_table where table_name='t_range_range'`;

# select systable after drop

--disable_query_log
echo "query all_table";
eval select is_deleted, part_level, part_func_type, part_func_expr, part_num, sub_part_func_type, sub_part_func_expr, sub_part_num, partition_status, case when partition_schema_version > 0 then 1 else 0 end, sub_part_template_flags from oceanbase.__all_virtual_table_history where table_id = $table_id;

echo "query all_part";
eval select is_deleted, part_name, sub_part_num, high_bound_val, sub_part_num, list_val, part_idx from oceanbase.__all_virtual_part_history where table_id = $table_id;

echo "query all_sub_part";
eval select is_deleted, sub_part_name, high_bound_val, list_val, sub_part_idx from oceanbase.__all_virtual_sub_part_history where table_id = $table_id;



# drop table
connection default;

drop table t_range_range;
drop user subpart_mgr@'%';
