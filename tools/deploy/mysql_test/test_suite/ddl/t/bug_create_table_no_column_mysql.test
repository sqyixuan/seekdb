# owner : dachuan.sdc
# owner group : SQL2
# description : 禁止创建没有列的表，
# tags: ddl

--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_result_log
drop table if exists t1;
--enable_result_log

--error 1064
create table t1();

--error 4028
create table t1(check(1 = 1));

create table t1(c1 int generated always as (1 + 1));
insert into t1 values();
select * from t1;

# clean up
drop table t1;
