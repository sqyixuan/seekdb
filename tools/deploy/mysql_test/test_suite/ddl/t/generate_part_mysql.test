insert into t_2_level_A2(first_name) values('sxxxxxx') on duplicate key update first_name='way';
insert into t_2_level_A2(first_name) values('sxxxxxx') on duplicate key update first_name='way';
--error 1062
insert into t_2_level_A2(first_name) values('sxxxxxx') on duplicate key update first_name='way';
select * from t_2_level_A2 order by first_name;

