drop database generate_part_oracle_db ;
--enable_warnings
create database generate_part_oracle_db;
use generate_part_oracle_db;
--result_format 4

--echo #Q1 原始语句
create table TT(
    first_name varchar(50),
    primary key(first_name),
    fullname varchar(200) collate 'utf8mb4_bin'
    generated always as (substr (first_name, 3)) stored)
    partition by range columns(fullname)
    (partition p1 values less than ('xxx'),
     partition p2 values less than ('zzz'));

insert into TT(first_name) values('sxxxxxx') on duplicate key update first_name='way';
insert into TT(first_name) values('sxxxxxx') on duplicate key update first_name='way';
insert into TT(first_name) values('sxxxxxx') on duplicate key update first_name='way';
--error 1062
insert into TT(first_name) values('sxxxxxx') on duplicate key update first_name='way';
select * from TT order by first_name;

--echo #Q1.1 增加几列
create table TTA(
    c varchar(10) default 'xx',
    first_name varchar(50),
    primary key(first_name),
    c2 varchar(10) default 'yy',
    fullname varchar(200) collate 'utf8mb4_bin'
    generated always as (substr(first_name, 3)) stored,
    c3 varchar(10) default 'zz')
    partition by range columns (fullname)
    (partition p1 values less than ('xxx'),
     partition p2 values less than ('zzz'));

insert into TTA(first_name) values('sxxxxxx') on duplicate key update first_name='way';
insert into TTA(first_name) values('sxxxxxx') on duplicate key update first_name='way';
insert into TTA(first_name) values('sxxxxxx') on duplicate key update first_name='way';
--error 1062
insert into TTA(first_name) values('sxxxxxx') on duplicate key update first_name='way';
select * from TTA order by first_name;

--echo #Q2 改为虚拟生成列
create table TT2(
    first_name varchar(50),
    primary key(first_name),
    fullname varchar(10) collate 'utf8mb4_bin'
    generated always as (substring(first_name, 3)))
    partition by range columns(fullname)
    (partition p1 values less than ('xxx'),
     partition p2 values less than ('zzz'));
####insert duplicate禁止，需求 
insert into TT2(first_name) values('sxxxxxx') on duplicate key update first_name='way';
insert into TT2(first_name) values('sxxxxxx') on duplicate key update first_name='way';
insert into TT2(first_name) values('sxxxxxx') on duplicate key update first_name='way';
--error 1062
insert into TT2(first_name) values('sxxxxxx') on duplicate key update first_name='way';
select * from TT2 order by first_name;

--echo #Q2.1 多几列
create table TT2B(
    c varchar(10) default 'xx',
    first_name varchar(50),
    primary key(first_name),
    c2 varchar(10) default 'yy',
    fullname varchar(200) collate 'utf8mb4_bin'
    generated always as (substr(first_name, 3)),
    c3 varchar(10) default 'zz')
    partition by range columns(fullname)
    (partition p1 values less than ('xxx'),
     partition p2 values less than ('zzz'));

insert into TT2B(first_name) values('sxxxxxx') on duplicate key update first_name='way';
insert into TT2B(first_name) values('sxxxxxx') on duplicate key update first_name='way';
insert into TT2B(first_name) values('sxxxxxx') on duplicate key update first_name='way';
--error 1062
insert into TT2B(first_name) values('sxxxxxx') on duplicate key update first_name='way';
select * from TT2B order by first_name;

### 二级分区中
--echo #Q3 二级分区 + stored + 一级key
create table t_2_level_A
(first_name varchar(50) collate 'utf8mb4_bin',
 primary key(first_name),
 fullname varchar(200) collate 'utf8mb4_bin' generated always as (substr(first_name, 3)) stored )
 partition by range columns(first_name)
 subpartition by key(fullname)
 subpartitions 2 (partition p0 values less than ('x'),
  partition p1 values less than ('zzz'));
insert into t_2_level_A(first_name) values('sxxxxxx') on duplicate key update first_name='way';
insert into t_2_level_A(first_name) values('sxxxxxx') on duplicate key update first_name='way';
insert into t_2_level_A(first_name) values('sxxxxxx') on duplicate key update first_name='way';
--error 1062
insert into t_2_level_A(first_name) values('sxxxxxx') on duplicate key update first_name='way';
select * from t_2_level_A;

