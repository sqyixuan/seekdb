--echo #测试设置配置项 tenant=all
echo "0017--------------------------------------------------------------------------------------------------------";
connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set default_table_organization='HEAP' tenant = all_user;
sleep 5;
let $meta_tenant_id = query_get_value(select tenant_id - 1 as meta_tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', meta_tenant_id, 1);
let $meta_tenant_table_organization = query_get_value(select value from oceanbase.__all_virtual_tenant_parameter_info where tenant_id = $meta_tenant_id and name = 'default_table_organization', value, 1);
let $oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);
let $oracle_tenant_table_organization = query_get_value(select value from oceanbase.__all_virtual_tenant_parameter_info where tenant_id = $oracle_tenant_id and name = 'default_table_organization', value, 1);
let $sys_tenant_table_organization = query_get_value(select value from oceanbase.__all_virtual_tenant_parameter_info where tenant_id = 1 and name = 'default_table_organization', value, 1);
if ($meta_tenant_table_organization == 'INDEX') 
{
  echo "success to not set meta tenant config!";
}
if ($oracle_tenant_table_organization == 'INDEX') 
{
  echo "success to not set sys tenant config!";
}
if ($oracle_tenant_table_organization == 'INDEX') 
{
  echo "success to not set sys tenant config!";
}
--disable_warnings
alter system set default_table_organization='HEAP' tenant = sys;
--enable_warnings
--error 1235
alter system set default_table_organization='HEAP' tenant = all_meta;

let $oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);
let $oracle_tenant_table_organization = query_get_value(select value from oceanbase.__all_virtual_tenant_parameter_info where tenant_id = $oracle_tenant_id and name = 'default_table_organization', value, 1);
if ($oracle_tenant_table_organization == 'INDEX') 
{
  echo "success to not set oracle tenant config!";
}
connection default;
--disable_warnings
drop table if exists test;
--enable_warnings
create table test (c1 int, c2 int, c3 varchar(10), c4 int, c5 int, primary key(c1, c2, c3));
SET _show_ddl_in_compat_mode = 1;
show create table test;
SET _show_ddl_in_compat_mode = 0;
show create table test;
drop table test;

connect (oracle,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
connection oracle;
--disable_warnings
--error 0,942
drop table if exists test;
--enable_warnings
--disable_warnings
create table test (c1 int, c2 int, c3 varchar(10), c4 int, c5 int, primary key(c1, c2, c3));
show create table test;
drop table test;
--disable_warnings
alter system set default_table_organization='HEAP';
--enable_warnings
connection syscon;
let $oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);
let $oracle_default_table_organization = query_get_value(select value from oceanbase.__all_virtual_tenant_parameter_info where tenant_id = $oracle_tenant_id and name = 'default_table_organization', value, 1);
if ($oracle_default_table_organization == 'INDEX') 
{
  echo "success; tenant config not work in oracle tenant!";
}
alter system set default_table_organization='INDEX' tenant = all_user;
sleep 5;

