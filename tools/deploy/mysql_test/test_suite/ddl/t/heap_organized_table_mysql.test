--echo #测试show create table 主键顺序展示正确
echo "0019--------------------------------------------------------------------------------------------------------";
--disable_warnings
drop table if exists test_show_create_table;
--enable_warnings

create table test_show_create_table (
    id int,
    name varchar(50),
    age int,
    address varchar(100),
    primary key (address, name, age),
    unique key uk_age_address (address, age)
) ORGANIZATION HEAP;

SET _show_ddl_in_compat_mode = 1;
show create table test_show_create_table;
SET _show_ddl_in_compat_mode = 0;
show create table test_show_create_table;
