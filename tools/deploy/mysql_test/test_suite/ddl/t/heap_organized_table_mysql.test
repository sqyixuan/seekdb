#owner: xf375358
#owner group: opensource

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connection sys_conn;
alter system set default_table_organization = 'INDEX' tenant = all;
sleep 5;

connection default;

--echo #测试视图展示堆表表组织模式organization
echo "000--------------------------------------------------------------------------------------------------------";
--disable_warnings
drop database if exists lanyi_heap_table;
create database lanyi_heap_table;
use lanyi_heap_table;

--disable_warnings
drop table if exists test;
--enable_warnings
create table test (c1 int, c2 int, c3 varchar(10), c4 int, c5 int, primary key(c1, c2, c3)) ORGANIZATION HEAP;
alter system set _enable_parallel_table_creation = false;
create table test_not_parallel (c1 int, c2 int, c3 varchar(10), c4 int, c5 int, primary key(c1, c2, c3)) ORGANIZATION HEAP;
alter system set _enable_parallel_table_creation = true;
--error 1062
create table test(c1 int primary key, c2 int, primary key (c1,c2)) ORGANIZATION HEAP;
SET _show_ddl_in_compat_mode = 1;
show create table test;
SET _show_ddl_in_compat_mode = 0;
show create table test;
--source mysql_test/include/check_all_idx_ok.inc

--disable_warnings
drop table if exists test_idx;
--enable_warnings
create table test_idx (c1 int, c2 int, c3 varchar(10), c4 int, c5 int, primary key(c1, c2, c3));
show create table test_idx;
let $heap_organization = query_get_value(select ORGANIZATION from information_schema.TABLES where TABLE_NAME = 'test' and TABLE_SCHEMA = 'lanyi_heap_table', ORGANIZATION, 1);
let $index_organization = query_get_value(select ORGANIZATION from information_schema.TABLES where TABLE_NAME = 'test_idx' and TABLE_SCHEMA = 'lanyi_heap_table', ORGANIZATION, 1);

if ($heap_organization != $index_organization) 
{
  echo "success! two tables have different organization";
}

connection sys_conn;
let $heap_organization = query_get_value(select IOT_TYPE from CDB_TABLES where TABLE_NAME = 'test' and OWNER = 'lanyi_heap_table', IOT_TYPE, 1);
let $index_organization = query_get_value(select IOT_TYPE from CDB_TABLES where TABLE_NAME = 'test_idx' and OWNER = 'lanyi_heap_table', IOT_TYPE, 1);

if ($heap_organization != $index_organization) 
{
  echo "success!";
}

connection default;
use lanyi_heap_table;
