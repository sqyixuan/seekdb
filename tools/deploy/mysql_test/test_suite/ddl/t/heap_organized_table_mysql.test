let $tenant_id=query_get_value(select tenant_id from oceanbase.__all_virtual_table where table_name = 'pt1_o_with_pk', tenant_id, 1);
let $table_id=query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'pt1_o_with_pk', table_id, 1);
