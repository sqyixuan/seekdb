--echo #heap模式表调整binlog_row_image
echo "0015--------------------------------------------------------------------------------------------------------";
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(c1 int primary key, c2 int default 2, c3 int ,c4 int, c5 int,  unique key(c4,c5) global) ORGANIZATION HEAP partition by hash(c1) partitions 2;

insert into test values(1,1,1,1,1);
insert into test values(2,2,2,2,2);

select * from test;

#replace into normal row
replace into test (c1, c4,c5) values (3,1,2);
select * from test;
replace into test (c1, c4,c5) values (1,4,4);
select * from test;
replace into test (c1,c4,c5) values (2,1,2),(1,1,2);
select * from test;

#conflict row
replace into test (c1, c4,c5) values (4,4,4);
select * from test;
replace into test(c1,c4,c5) values(2,4,4);
select * from test;
drop table test;

create table test(c1 int primary key, c2 int, c3 int, c4 int, c5 int, unique key(c2,c3) global) ORGANIZATION HEAP partition by hash(c1) partitions 2;
insert into test values(2,1,1,1,1),(3,3,3,3,3) on duplicate key update c2=9;
select * from test;
insert into test values(2,1,1,1,1),(3,3,3,3,3),(4,4,4,4,4) on duplicate key update c2=10;
select * from test;
insert into test values(5,4,4,4,4) on duplicate key update c2=10;
select * from test;
insert into test values(2,1,1,1,1) on duplicate key update c2=10;
insert into test values(4,10,4,3,2) on duplicate key update c3=10;
select * from test;
insert into test values(2,10,10,10,10) on duplicate key update c3 = c3+1,c4=c4+1;
select * from test;
drop table test;

--echo #heap表模式测试物化视图
echo "0016--------------------------------------------------------------------------------------------------------";
connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--disable_query_log
let $current_tenant_id = query_get_value(select effective_tenant_id() x, x, 1);
set ob_query_timeout = 1000 * 1000 * 1000;
use test;
--source mysql_test/include/ignore_drop_mlog_err_mysql.inc
drop materialized view log on t1;
--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
drop materialized view if exists mv2;
drop sequence if exists s1;
--enable_warnings
--enable_query_log

create table t1(c1 int primary key, c2 int, c3 int, c4 int) ORGANIZATION HEAP;
create materialized view log on t1 with primary key, sequence (c2, c3) including new values;
create materialized view mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
create materialized view mv2 as select * from t1;
create sequence s1 cache 1000000 noorder;
call dbms_mview_stats.set_mvref_stats_params('mv1', 'NONE', 31);
call dbms_mview_stats.set_mvref_stats_params('mv2', 'NONE', 31);
show create table mv1;
show create table mv2;

--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2(c1 int, c2 int, c3 int, c4 int) ORGANIZATION HEAP;
create materialized view log on t2 with rowid, sequence (c2, c3) including new values;
--disable_result_log
select OWNER,MVIEW_NAME,CONTAINER_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL from oceanbase.DBA_MVIEWS where OWNER = 'test' AND MVIEW_NAME IN ('mv1', 'mv2') ORDER BY MVIEW_NAME;
connection sys;
--echo select OWNER,MVIEW_NAME,CONTAINER_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL from oceanbase.CDB_MVIEWS where OWNER = 'test' AND MVIEW_NAME IN ('mv1', 'mv2') ORDER BY MVIEW_NAME;
--disable_query_log
eval select OWNER,MVIEW_NAME,CONTAINER_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL from oceanbase.CDB_MVIEWS where TENANT_ID = $current_tenant_id AND OWNER = 'test' AND MVIEW_NAME IN ('mv1', 'mv2') ORDER BY MVIEW_NAME;
--enable_query_log
--enable_result_log
connection default;

# issue/54620448
insert into t1 select s1.nextval, s1.nextval, s1.nextval, s1.nextval from table(generator(100000));
call dbms_mview.refresh('mv1');
call dbms_mview.refresh('mv2');
--disable_result_log
select OWNER,MVIEW_NAME,CONTAINER_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL,TIMESTAMPDIFF(SECOND, LAST_REFRESH_DATE, LAST_REFRESH_END_TIME) < 10 from oceanbase.DBA_MVIEWS where OWNER = 'test' AND MVIEW_NAME IN ('mv1', 'mv2') ORDER BY MVIEW_NAME;
connection sys;
--echo select OWNER,MVIEW_NAME,CONTAINER_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL,TIMESTAMPDIFF(SECOND, LAST_REFRESH_DATE, LAST_REFRESH_END_TIME) < 10 from oceanbase.CDB_MVIEWS where OWNER = 'test' AND MVIEW_NAME IN ('mv1', 'mv2') ORDER BY MVIEW_NAME;
--disable_query_log
eval select OWNER,MVIEW_NAME,CONTAINER_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL,TIMESTAMPDIFF(SECOND, LAST_REFRESH_DATE, LAST_REFRESH_END_TIME) < 10 from oceanbase.CDB_MVIEWS where TENANT_ID = $current_tenant_id AND OWNER = 'test' AND MVIEW_NAME IN ('mv1', 'mv2') ORDER BY MVIEW_NAME;
--enable_query_log
--enable_result_log
connection default;

drop materialized view log on t1;
drop table t1;
drop materialized view log on t2;
drop table t2;
drop materialized view mv1;
drop materialized view mv2;
drop sequence s1;

