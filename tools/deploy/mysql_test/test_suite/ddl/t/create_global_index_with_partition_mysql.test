--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql2
#description: test for create global index with partition info
#
#tags: ddl

## 为避免对象名冲突，不使用默认的 test 库作为测试环境，在新建的库 xiaofeng_db 中进行测试
--disable_warnings
drop database if exists xiaofeng_db;
create database xiaofeng_db;
use xiaofeng_db;
--enable_warnings


## 测试在 MySQL 模式下在 create table、alter table、create index 三种场景下创建显式指定了分区信息的索引


### 测试正常情况
#### 测试 create table 场景下创建显式指定了分区信息的索引
create table t1(
  c1 int, c2 int, c3 int, c4 int, c5 int,
  index idx_t1_c1(c1) local,
  index idx_t1_c2(c2) global,
  index idx_t1_c3(c3) partition by hash(c3),
  index idx_t1_c4(c4) partition by range(c4)(partition p0 values less than maxvalue),
  index idx_t1_c5(c5) partition by list(c5) (partition p0 values in (1,2,3,4,5), partition p1 values in (default))
);
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop table t1;

#### 测试 alter table 场景下创建显式指定了分区信息的索引
create table t2(c1 int, c2 int, c3 int, c4 int, c5 int);
alter table t2 add index idx_t2_c1 (c1) local;
alter table t2 add index idx_t2_c2 (c2) global;
alter table t2 add index idx_t2_c3 (c3) partition by hash(c3);
alter table t2 add index idx_t2_c4(c4) partition by range(c4)(partition p0 values less than maxvalue);
alter table t2 add index idx_t2_c5(c5) partition by list(c5) (partition p0 values in (1,2,3,4,5), partition p1 values in (default));
--source mysql_test/include/show_create_table_old_version.inc
show create table t2;
drop table t2;

#### 测试 create index 场景下创建显式指定了分区信息的索引
create table t3(c1 int, c2 int, c3 int, c4 int, c5 int);
create index idx_t3_c1 on t3(c1) local;
create index idx_t3_c2 on t3(c2) global;
create index idx_t3_c3 on t3(c3) partition by hash(c3);
create index idx_t3_c4 on t3(c4) partition by range(c4)(partition p0 values less than maxvalue);
create index idx_t3_c5 on t3(c5) partition by list(c5) (partition p0 values in (1,2,3,4,5), partition p1 values in (default));
--source mysql_test/include/show_create_table_old_version.inc
show create table t3;
drop table t3;


### 测试异常情况
#### 创建显式指定了分区信息的索引时：
#### 可以不显式指定索引的 global/local 属性（此时会默认为 global）或者显式指定 global 属性
#### 如果显式指定了 local 属性，将会报错：specify partition option of local index not supported

#### 测试 create table 场景
--error 1235
create table t1(
  c1 int, c2 int, c3 int, c4 int, c5 int,
  index idx_t1_c1(c1),
  index idx_t1_c2(c2) global,
  index idx_t1_c3(c3) local partition by hash(c3),
  index idx_t1_c4(c4) local partition by range(c4) (partition p0 values less than maxvalue),
  index idx_t1_c5(c5) local partition by list(c5) (partition p0 values in (1,2,3,4,5), partition p1 values in (default))
);
create table t1(
  c1 int, c2 int, c3 int, c4 int, c5 int,
  index idx_t1_c1(c1),
  index idx_t1_c2(c2) global,
  index idx_t1_c3(c3) global partition by hash(c3),
  index idx_t1_c4(c4) global partition by range(c4) (partition p0 values less than maxvalue),
  index idx_t1_c5(c5) global partition by list(c5) (partition p0 values in (1,2,3,4,5), partition p1 values in (default))
);
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop table t1;


#### 测试 alter table 场景
create table t2(c1 int, c2 int, c3 int, c4 int, c5 int);
alter table t2 add index idx_t2_c1 (c1);
alter table t2 add index idx_t2_c2 (c2) global;
--error 1235
alter table t2 add index idx_t2_c3 (c3) local partition by hash(c3);
--error 1235
alter table t2 add index idx_t2_c4(c4) local partition by range(c4)(partition p0 values less than maxvalue);
--error 1235
alter table t2 add index idx_t2_c5(c5) local partition by list(c5) (partition p0 values in (1,2,3,4,5), partition p1 values in (default));
alter table t2 add index idx_t2_c3 (c3) global partition by hash(c3);
alter table t2 add index idx_t2_c4(c4) global partition by range(c4)(partition p0 values less than maxvalue);
alter table t2 add index idx_t2_c5(c5) global partition by list(c5) (partition p0 values in (1,2,3,4,5), partition p1 values in (default));
--source mysql_test/include/show_create_table_old_version.inc
show create table t2;
drop table t2;

#### 测试 create index 场景
create table t3(c1 int, c2 int, c3 int, c4 int, c5 int);
create index idx_t3_c1 on t3(c1);
create index idx_t3_c2 on t3(c2) global;
--error 1235
create index idx_t3_c3 on t3(c3) local partition by hash(c3);
--error 1235
create index idx_t3_c4 on t3(c4) local partition by range(c4)(partition p0 values less than maxvalue);
--error 1235
create index idx_t3_c5 on t3(c5) local partition by list(c5) (partition p0 values in (1,2,3,4,5), partition p1 values in (default));
create index idx_t3_c3 on t3(c3) global partition by hash(c3);
create index idx_t3_c4 on t3(c4) global partition by range(c4)(partition p0 values less than maxvalue);
create index idx_t3_c5 on t3(c5) global partition by list(c5) (partition p0 values in (1,2,3,4,5), partition p1 values in (default));
--source mysql_test/include/show_create_table_old_version.inc
show create table t3;
drop table t3;


## clean up
drop database if exists xiaofeng_db;
