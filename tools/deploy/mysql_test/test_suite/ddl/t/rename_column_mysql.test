#owner: zongmei.zzm
#owner group: SQL2
#tags: ddl

--result_format 4
--disable_query_log
--disable_warnings
drop table if exists rename_t;
--enable_warnings
--enable_query_log

--echo >>>> basic rename cases:
create table rename_t (a int, b int, c int);

insert into rename_t values (1, 2, 3), (4, 5, 6), (7, 8, 9);

alter table rename_t rename column a to b, rename column b to c, rename column c to a;
desc rename_t;

select * from rename_t;

drop table rename_t;

--echo >>>> rename column with index
create table rename_t(a int, b int);

create index idx_rename_t on rename_t(a);

insert into rename_t values (1, 1), (2, 2);

alter table rename_t rename column a to c;

desc rename_t;
show index from rename_t;

explain select c from rename_t;

drop table rename_t;

--echo >>>> rename column with foreign key
create table rename_t (a int primary key, b int);
create table foreign_t (c int, foreign key (c) references rename_t(a));

#show create table foreign_t;

insert into rename_t values (1, 1);
insert into foreign_t values (1);
--error 1452
insert into foreign_t values (2);

alter table rename_t rename column a to c;

#show create table foreign_t;
--error 1452
insert into foreign_t values (3);
insert into rename_t values (3, 3);
insert into foreign_t values (3);

select * from foreign_t;

drop table foreign_t;
drop table rename_t;

--echo >>>> rename column with view
--disable_warnings
drop view if exists rename_v;
--enable_warnings
create table rename_t (a int, b int);

insert into rename_t values (1, 1), (2, 2);
create view rename_v as select a + 1 as a0 from rename_t;
select * from rename_v;

alter table rename_t rename column a to c;
desc rename_t;
--error 1356
select * from rename_v;

drop table rename_t;
drop view rename_v;

--echo >>>> rename column with procedure
drop procedure if exists rename_fn;
create table rename_t (a int, b int);
insert into rename_t values (1, 1), (2, 2);

create procedure rename_fn() select a + 1 from rename_t;
call rename_fn();

alter table rename_t rename column a to c;
desc rename_t;

--error 1054
call rename_fn();

drop table rename_t;
drop procedure rename_fn;

--echo >>>> not supported scenarios

create table rename_t (a int, b int as (a + 1), c int) partition by hash(c + 1) partitions 2;

--error 3108
alter table rename_t rename column a to c;

--error 3855
alter table rename_t rename column c to d;

drop table rename_t;

--echo >>>> offline ddl with renaming columns
create table rename_t (a int, b int, c int);

insert into rename_t values (1, 1, 1);

alter table rename_t drop column a, rename column c to d;

desc rename_t;
select * from rename_t;

alter table rename_t add column d double, rename column d to c;
desc rename_t;
select * from rename_t;

drop table rename_t;

create table rename_t (a int, b int, c int, d int as (a + 1)) partition by hash(c + 1) partitions 2;

--error 3108
alter table rename_t drop column b, rename column a to e;

--error 3855
alter table rename_t drop column b, rename column c to e;

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (`c1_ a` INT PRIMARY KEY, `c2_ b` INT, `c4_ d` int);
alter table t1 rename column `c1_ a` to `c1_ a`;
desc t1;

drop table t1;
CREATE TABLE t1 (col1 INT,  col3 INT, CONSTRAINT equal_check1 CHECK(col1 = col3 * 2));
insert into t1 values(2,1);
--error 3959
alter table t1 rename column col1 to col3,rename column col3 to col1;

drop table t1;
CREATE TABLE t1 (`c1_a` INT PRIMARY KEY, c2_B INT, c4_d int);
--error 1054
alter table t1 rename column `c1_a`  to cc,rename column `c1_a`  to cc,rename column `c1_a`  to cc,rename column `c1_a`  to cc;

drop table t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 INT,  INDEX i1 (c1,c2,c3));
alter table t1 rename column c2 to c3,rename column c3 to c1,rename column c1 to c2;
desc t1;
show index from t1;

drop table t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 BLOB, c3 INT, INDEX i1 (c2(10)));
alter table t1 rename column c2 to c2_,rename column c1 to c2_1;
desc t1;
show index from t1;

drop table t1;
CREATE TABLE t1 (col1 INT , col2 INT,c3 int );
ALTER TABLE t1 CHANGE COLUMN col1  c6 VARCHAR(50) primary key;
desc t1;

drop table t1;
CREATE TABLE t1 (
    log_id      bigint NOT NULL 
    , log_value varchar(50)
    , log_date  timestamp NOT NULL  
) PARTITION BY RANGE(UNIX_TIMESTAMP(log_date)) 
(
    PARTITION M202001 VALUES LESS THAN(UNIX_TIMESTAMP('2020/02/01'))
    , PARTITION M202002 VALUES LESS THAN(UNIX_TIMESTAMP('2020/03/01'))
    , PARTITION M202003 VALUES LESS THAN(UNIX_TIMESTAMP('2020/04/01'))
    , PARTITION M202004 VALUES LESS THAN(UNIX_TIMESTAMP('2020/05/01'))
    , PARTITION M202005 VALUES LESS THAN(UNIX_TIMESTAMP('2020/06/01'))
);

insert into t1 values(1,'zz','2020/05/01');
insert into t1 values(1,'zz','2020/01/01');

SELECT * FROM t1 PARTITION (M202001);
SELECT * FROM t1 PARTITION (M202005);

ALTER TABLE t1 truncate PARTITION M202001;
select * from t1;

--error 1064
ALTER TABLE t1 rename column log_id to log_value, rename column log_value to log_id,truncate PARTITION M202001;
--error 1064
ALTER TABLE t1 rename column log_id to log_value, rename column log_value to log_id,drop PARTITION M202001;
--error 1064
ALTER TABLE t1 rename column log_id to log_value, rename column log_value to log_id, ADD PARTITION (PARTITION M202006 VALUES LESS THAN(UNIX_TIMESTAMP('2020/07/01')));
--error 1064
ALTER TABLE t1 rename column log_id to log_value, rename column log_value to log_id, PARTITION BY HASH( year(log_value) ) PARTITIONS 8;

drop table t1;
CREATE TABLE t1 (c1_a INT PRIMARY KEY, c2_b INT unique, c3_c INT unique,c5_e VARCHAR(312),c4_d int,check(c4_d>0));
alter table t1 rename column c1_a to c2_b,rename column c2_b to c3_c ,rename column c3_c  to c1_a,rename column c5_e  to `aaa`;
desc t1;

drop table t1;
CREATE TABLE t1 (col1 INT primary key, col2 INT);
ALTER TABLE t1 ADD CONSTRAINT my_check CHECK (col1> col2);
ALTER TABLE t1 drop CONSTRAINT my_check, rename column col2 to col1,rename column col1 to col2;  
desc t1;
insert into t1 values (1, 2), (2, 1);

drop table t1;
CREATE TABLE t1 (col1 varchar(50), col2 varchar(50),c5 varchar(50),c3 varchar(50) ,c4 varchar(50) primary key,c8 int);
# FIXME:
--error 1060
ALTER TABLE t1 add c5 int,drop c3,rename column c5 to c3;
desc t1;

--disable_warnings
drop table if exists t2;
drop table if exists t1;
--enable_warnings

CREATE TABLE  t2(
logindate DATE,
uid VARCHAR(225),
new_user INT,
PRIMARY KEY(logindate,uid)
);

CREATE TABLE   t1(c1 int primary key auto_increment,
c2 DATE unique,
c3 DATETIME default'2022-12-12 12:12:12',
c4 int not null default'1',
c5 varchar(300),
uid VARCHAR(225),
money FLOAT,index(c1,c2),unique(c3,c4),unique index (c3),
FOREIGN KEY(c2,uid) REFERENCES t2(logindate,uid)
);

# FIXME:
--error 1060
ALTER TABLE t1  rename column money to uid,rename column uid to money,rename column c4 to c2,rename column c2 to c4,rename column c1 to c0,
add c5 int,drop c3,rename column c5 to c3;
desc t1;

drop table t1;
drop table t2;

create table t1(a int primary key, b int, c int);
--error 1064
alter table t1 rename t2, rename column t2.a to d;

alter table t1 rename t2, rename column a to d;
desc t2;

drop table t2;


create table t1 (a int, b int);
# FIXME: should report unknwon column 'a'
alter table t1 change b b1 int after a, rename column a to c;

drop table t1;
create table t1(a int, b int, c int);
alter table t1 change c c1 int after b, rename column a to b, rename column b to a;
# FIXME:
desc t1;

drop table t1;

CREATE TABLE t1 (col1 INT primary key, col2 INT);
ALTER TABLE t1 ADD CONSTRAINT my_check3 CHECK (col1+col2> col1+1);
ALTER TABLE t1 drop CONSTRAINT my_check3, rename column col2 to col3,rename column col1 to col5;

desc t1;

drop table t1;

CREATE TABLE t1 (col1 INT, col2 INT, INDEX func_index ((ABS(col1+col2))));
show index from t1;
# FIXME: should succeed
--error 3837
ALTER TABLE t1 rename column col1 to col3,rename column col2 to col4,drop INDEX func_index ;
desc t1;
show index from t1;

--disable_warnings
drop table if exists t;
--enable_warnings
create table t(i int, index ((i+1)));
--error 3837
alter table t rename column i to j;

drop table t;