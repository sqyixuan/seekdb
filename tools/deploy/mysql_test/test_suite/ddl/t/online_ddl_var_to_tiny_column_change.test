# owner: gaishun.gs
# owner group: storage : index and ddl
# description: 向上列类型转换
# note: ob do mysqltest --suite=ddl --test_set=online_ddl_var_to_tiny_column_change -n 43_int2bigint
# note: ob do mysqltest --suite=ddl --test_set=online_ddl_var_to_tiny_column_change -n 43base
 
--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
 
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

# common varchar -> tinytext; : online
--disable_warnings
drop table if exists t1_var_tiny;
drop sequence if exists s1_var_tiny;
--enable_warnings
create table t1_var_tiny (a varchar(255));
create sequence s1_var_tiny cache 1000000 noorder;
insert into t1_var_tiny select s1_var_tiny.nextval from table(generator(2000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_var_tiny', table_id, 1);
alter table t1_var_tiny change column a a tinytext;
insert into t1_var_tiny select s1_var_tiny.nextval from table(generator(2000));
select count(*) from t1_var_tiny;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_var_tiny', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}
