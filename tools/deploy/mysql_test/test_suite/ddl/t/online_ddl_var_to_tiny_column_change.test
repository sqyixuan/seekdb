# index
--disable_warnings
drop table if exists t1_var_tiny;
drop sequence if exists s1_var_tiny;
--enable_warnings
create table t1_var_tiny (a varchar(255));
create index t1_var_tiny_idx on t1_var_tiny(a);
create sequence s1_var_tiny cache 1000000 noorder;
insert into t1_var_tiny select s1_var_tiny.nextval from table(generator(2000));
--error 1167
alter table t1_var_tiny change column a a tinytext;


# generated column
--disable_warnings
drop table if exists t1_var_tiny;
drop sequence if exists s1_var_tiny;
--enable_warnings
create table t1_var_tiny (a varchar(255), b varchar(255) generated always as (concat(a)) STORED);
create sequence s1_var_tiny cache 1000000 noorder;
insert into t1_var_tiny(a) select s1_var_tiny.nextval from table(generator(2000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_var_tiny', table_id, 1);
alter table t1_var_tiny change column a a tinytext;
--error 3106
alter table t1_var_tiny change column b b tinytext;
--error 3106
alter table t1_var_tiny change column b b tinytext generated always as (concat(a)) VIRTUAL;
alter table t1_var_tiny change column b b tinytext generated always as (concat(a)) STORED;
insert into t1_var_tiny(a) select s1_var_tiny.nextval from table(generator(2000));
select count(*) from t1_var_tiny;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_var_tiny', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}



