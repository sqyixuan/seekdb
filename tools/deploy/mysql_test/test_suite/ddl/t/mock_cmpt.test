# owner: sanquan.qz
# owner group: sql1

--result_format 4
install plugin x soname 'x.so';
uninstall plugin x;
show plugins;


# flush table t1;
# flush table t1 with read lock;
# flush table t1 for export;
# flush tables t1, t2;
# flush local tables t1, t2 with read lock;
# flush local table t1;
# flush no_write_to_binlog table t1;

flush local error logs;
flush no_write_to_binlog error logs;
flush engine logs;
flush general logs;
flush slow logs;
flush binary logs;
flush relay logs;
flush query cache;
flush hosts;
flush logs;
flush status;
flush des_key_file;
flush user_resources;
flush optimizer_costs;
flush privileges;
flush slow logs, hosts, slow logs, binary logs, general logs;

handler t1 open;
handler t1 open t11;
handler t1 read first;
handler t1 read next;
handler t1 read c1 first;
handler t1 read c1 next;
handler t1 read c1 last;
handler t1 read c1 prev;
handler t1 read i1 = (1);
handler t1 read c1 first where i1 = (1);
handler t1 read i1 = (1) where i2 = 10 && i3 = 10 limit 1;
handler t1 read c1 first limit 1;
handler t1 read i1 = (1) limit 1;
handler t1 close;

