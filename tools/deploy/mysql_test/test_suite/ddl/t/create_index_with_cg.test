# owner: jianyun.sjy
# owner group: ddl
# description: check syntax of index with column group

--result_format 4
connect (obsys,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);

connection obsys;
--disable_info
--disable_metadata
--disable_warnings
drop table if exists t1;
--enable_warnings

# default table with index
create table t1 (c1 int, c2 int, index idx1(c1) storing(c2));

select column_group_id, column_group_name, column_group_type, block_size, compressor_type, row_store_type from __all_column_group where table_id = (select table_id from __all_table where table_name ='t1') order by column_group_id;
select column_group_id, column_id from __all_column_group_mapping where table_id = (select table_id from __all_table where table_name ='t1') order by column_group_id;
select column_group_id, column_group_name, column_group_type, block_size, compressor_type, row_store_type from __all_column_group where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
select column_group_id, column_id from __all_column_group_mapping where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;

drop table t1;

# table with index
create table t1 (c1 int, c2 int, index idx1(c1) storing(c2) with column group (all columns, each column)) with column group (all columns, each column);
select column_group_id, column_group_name, column_group_type, block_size, compressor_type, row_store_type from __all_column_group where table_id = (select table_id from __all_table where table_name ='t1') order by column_group_id;
select column_group_id, column_id from __all_column_group_mapping where table_id = (select table_id from __all_table where table_name ='t1') order by column_group_id;
select column_group_id, column_group_name, column_group_type, block_size, compressor_type, row_store_type from __all_column_group where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
select column_group_id, column_id from __all_column_group_mapping where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
drop table t1;

create table t1 (c1 int, c2 int, index idx1(c1) storing(c2) with column group (each column)) with column group (all columns, each column);
select column_group_id, column_group_name, column_group_type, block_size, compressor_type, row_store_type from __all_column_group where table_id = (select table_id from __all_table where table_name ='t1') order by column_group_id;
select column_group_id, column_id from __all_column_group_mapping where table_id = (select table_id from __all_table where table_name ='t1') order by column_group_id;
select column_group_id, column_group_name, column_group_type, block_size, compressor_type, row_store_type from __all_column_group where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
select column_group_id, column_id from __all_column_group_mapping where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
drop table t1;




# compatible with table creation behavior, must exist each cg
--error 1235
create table t1 (c1 int, c2 int, index idx1(c1) storing(c2) with column group (cg1(c1)));

# add index after create table
create table t1 (c1 int, c2 int) with column group(all columns,each column);
create index idx1 on t1(c2) storing(c1) with column group(all columns, each column);
select column_group_id, column_group_name, column_group_type, block_size, compressor_type, row_store_type from __all_column_group where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
select column_group_id, column_id from __all_column_group_mapping where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
drop table t1;

create table t1 (c1 int, c2 int) with column group(each column);
create index idx1 on t1(c2) storing(c1) with column group(each column);
select column_group_id, column_group_name, column_group_type, block_size, compressor_type, row_store_type from __all_column_group where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
select column_group_id, column_id from __all_column_group_mapping where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
drop table t1;


create table t1 (c1 int, c2 int) with column group(all columns,each column);
alter table t1 add index idx1 (c2) storing(c1) with column group(all columns, each column);
select column_group_id, column_group_name, column_group_type, block_size, compressor_type, row_store_type from __all_column_group where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
select column_group_id, column_id from __all_column_group_mapping where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
drop table t1;

create table t1 (c1 int, c2 int) with column group(all columns,each column);
alter table t1 add index idx1 (c2) storing(c1) with column group(each column);
select column_group_id, column_group_name, column_group_type, block_size, compressor_type, row_store_type from __all_column_group where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
select column_group_id, column_id from __all_column_group_mapping where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
drop table t1;



# check unique index
create table t1(c1 int, c2 int, unique index idx1(c2) storing(c1) with column group(all columns, each column));
select column_group_id, column_group_name, column_group_type, block_size, compressor_type, row_store_type from __all_column_group where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
select column_group_id, column_id from __all_column_group_mapping where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
drop table t1;

create table t1 (c1 int, c2 int) with column group(all columns,each column);
create unique index idx1 on t1(c2) storing(c1) with column group(all columns, each column);
select column_group_id, column_group_name, column_group_type, block_size, compressor_type, row_store_type from __all_column_group where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
select column_group_id, column_id from __all_column_group_mapping where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
drop table t1;

create table t1 (c1 int, c2 int) with column group(all columns,each column);
alter table t1 add unique index idx1 (c2) storing(c1) with column group(all columns, each column);
select column_group_id, column_group_name, column_group_type, block_size, compressor_type, row_store_type from __all_column_group where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
select column_group_id, column_id from __all_column_group_mapping where table_id = ((select table_id from __all_table where table_name ='t1') + 1) order by column_group_id;
drop table t1;
connection default;