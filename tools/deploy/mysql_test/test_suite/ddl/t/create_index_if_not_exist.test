--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql2
#description: todo

#部分字段是索引，部分不是
--disable_warnings
DROP TABLE IF EXISTS table1_int;
--enable_warnings
CREATE TABLE table1_int (
col_int int,
col_bool bool,
pk int,
col_bool_index bool,
col_int_index int,
col_varchar_500 varchar(500),
col_char_20 char(20),
col_varchar_500_index varchar(500),
col_timestamp timestamp NULL DEFAULT NULL,
col_char_20_index char(20),
col_timestamp_index timestamp NULL DEFAULT NULL,
/*Indices*/
primary key (pk),
index idx3(col_bool_index ),
index idx1(col_int_index ),
index idx9(col_varchar_500_index ),
index idx7(col_char_20_index ),
index idx5(col_timestamp_index )) ;
--error 1061
create index idx3 on table1_int (col_int);
--error 1061
create index idx1 on table1_int (col_int);
--error 1061
create index idx9 on table1_int (col_int);

create index if not exists idx3 on table1_int (col_int);
create index if not exists idx1 on table1_int (col_int);
create index if not exists idx9 on table1_int (col_int);

create index if not exists new_idx3 on table1_int (col_int);
create index if not exists new_idx1 on table1_int (col_int);
create index if not exists new_idx9 on table1_int (col_int);

drop table table1_int;
