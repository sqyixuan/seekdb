# owner : dachuan.sdc
# owner group : SQL2
# description : test parallel ddl
# tags: ddl

--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log


# 测试 alter table

## 1. 测试重试之后能成功的场景

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection obsys;
alter system set debug_sync_timeout = '100000s';
alter system change tenant sys;
set ob_global_debug_sync = 'HANG_BEFORE_RESOLVER_FINISH wait_for continue_signal';

connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

connection conn1;
set ob_global_debug_sync = 'HANG_BEFORE_RESOLVER_FINISH wait_for continue_signal';
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk int primary key, b int);
### 这条 SQL 在 resolver 的时候用的是上面那个有 pk 列的 t1 去解析的，现在给 alter table 加了 debug_sync 让它卡在了 resolver 结束的点上，模拟并发 ddl 的场景
send alter table t1 add column c int;

connection conn2;
drop table t1;
create table t1(a int, b int);

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';

connection conn1;
reap;
### resolver 结束之后那条 alter table 的 SQL 会在 RS 检查 t1 是不是变化了，如果变化了的话就说明有其他 ddl 比自己先发到了 RS，自己 resolver 的时候还没有刷新到，然后就会去重试
### 重试的时候会刷到新 t1 的 schema，然后就会在新 t1 上执行加列的动作
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;


### 2. 测试重试之后会失败的场景

connection obsys;
alter system change tenant sys;
set ob_global_debug_sync = 'HANG_BEFORE_RESOLVER_FINISH wait_for continue_signal';

connection conn1;
set ob_global_debug_sync = 'HANG_BEFORE_RESOLVER_FINISH wait_for continue_signal';
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk int primary key, b int);
### 这条 SQL 在 resolver 的时候用的是上面那个有 pk 列的 t1 去解析的，现在给 alter table 加了 debug_sync 让它卡在了 resolver 结束的点上，模拟并发 ddl 的场景
send alter table t1 modify b int default 1;

connection conn2;
drop table t1;
create table t1(c int, d int);

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';

connection conn1;
--error 1054
reap;
### resolver 结束之后那条 alter table 的 SQL 会在 RS 检查 t1 是不是变化了，如果变化了的话就说明有其他 ddl 比自己先发到了 RS，自己 resolver 的时候还没有刷新到，然后就会去重试
### 重试的时候会刷到新 t1 的 schema，然后就会在新 t1 上执行 modify 列的动作，然后会发现列 b 不存在了，最后失败掉
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;


## 3. 测试 DDL 会失败回滚的情况

connection obsys;
alter system change tenant sys;
set ob_global_debug_sync = 'HANG_BEFORE_RESOLVER_FINISH wait_for continue_signal';

connection conn1;
set ob_global_debug_sync = 'HANG_BEFORE_RESOLVER_FINISH wait_for continue_signal';
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int, b int);
### 现在给 alter table 加了 debug_sync 让它卡在了 resolver 结束的点上，模拟并发 ddl 的场景
send alter table t1 add unique idx1(a), add unique idx2(b);

connection conn2;
drop table t1;
create table t1(a varchar(10), b varchar(10));
insert into t1 values('aaa', 'bbb');
insert into t1 values('aaa', 'bbb');

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';

connection conn1;
--error 1062
reap;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
show index from t1;
drop table t1;




# 测试 create index
# bug 链接：

## 1. 测试重试之后能成功的场景

connection obsys;
alter system change tenant sys;
set ob_global_debug_sync = 'HANG_BEFORE_RESOLVER_FINISH wait_for continue_signal';

connection conn1;
set ob_global_debug_sync = 'HANG_BEFORE_RESOLVER_FINISH wait_for continue_signal';
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk int primary key, a int);
### 这条 SQL 在 resolver 的时候用的是上面那个有 pk 列的 t1 去解析的，现在给 create index 加了 debug_sync 让它卡在了 resolver 结束的点上，模拟并发 ddl 的场景
send create index t1_idx on t1(a);

connection conn2;
drop table t1;
create table t1(a int, b int) partition by hash(b) partitions 5;

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';

connection conn1;
reap;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;

## 2. 测试重试之后会失败的场景
connection obsys;
alter system change tenant sys;
set ob_global_debug_sync = 'HANG_BEFORE_RESOLVER_FINISH wait_for continue_signal';

connection conn1;
set ob_global_debug_sync = 'HANG_BEFORE_RESOLVER_FINISH wait_for continue_signal';
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk int primary key, a int);
### 这条 SQL 在 resolver 的时候用的是上面那个有 pk 列的 t1 去解析的，现在给 create index 加了 debug_sync 让它卡在了 resolver 结束的点上，模拟并发 ddl 的场景
send create index t1_idx on t1(a);

connection conn2;
drop table t1;
create table t1(c int, b int) partition by hash(b) partitions 5;

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';

connection conn1;
--error 1072
reap;
### resolver 结束之后那条 alter table 的 SQL 会在 RS 检查 t1 是不是变化了，如果变化了的话就说明有其他 ddl 比自己先发到了 RS，自己 resolver 的时候还没有刷新到，然后就会去重试
### 重试的时候会刷到新 t1 的 schema，然后就会在新 t1 上执行加列的动作
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop table t1;