# owner: wenduo.swd
# owner group: RS
# description: 一个租户拥有多个资源池
#

# setup
connect (sysc,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sysc;
alter system set resource_hard_limit =1000;
--disable_query_log
--disable_warnings
drop tenant if exists yzf force;
drop resource pool if exists yzf_pool1;
drop resource pool if exists yzf_pool2;
drop resource pool if exists yzf_pool3;

eval create resource unit if not exists test_unit max_cpu 1, memory_size='1G';

# pre
select distinct zone from oceanbase.__all_zone order by zone;
create resource pool yzf_pool1 unit='test_unit', unit_num=1, zone_list=('zone1');
create resource pool yzf_pool3 unit='test_unit', unit_num=1, zone_list=('zone1');

# case 1: intersect
--error 4624 
create tenant yzf resource_pool_list=('yzf_pool1', 'yzf_pool3') set ob_tcp_invited_nodes='%';

# case 2: zone list
--error 4624
create tenant yzf zone_list=('zone1', 'zone2'), resource_pool_list=('yzf_pool1', 'yzf_pool3') set ob_tcp_invited_nodes='%';

drop resource pool if exists yzf_pool3;
create resource pool yzf_pool2 unit='test_unit', unit_num=1, zone_list=('zone2');

# case 3: success
create tenant yzf resource_pool_list=('yzf_pool1', 'yzf_pool2') set ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create tenant yzf;

# teardown
drop tenant if exists yzf force;
drop resource pool if exists yzf_pool1;
drop resource pool if exists yzf_pool2;
