--disable_warnings
drop table if exists t1;
--enable_warnings

##bugfix: 
create table t1 (word varchar(64) collate utf16_general_ci);
insert into t1 values('111');
alter TABLE t1 add column c4 varchar(100) collate utf16_general_ci default 'abc';
select *, hex(c4), length(c4) from t1;
drop table if exists t1;