#owner: zhaoziqian.zzq
#owner group: rs
#description:
#  allow tables in different databases to be added into the same tablegroup


-- echo ####################### MYSQL TENANT TEST #######################

connect(mysql_conn,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connection mysql_conn;

--disable_warnings
drop table if exists d1.tbl1, d2.tbl2, d3.tbl3, d4.tbl4;
drop database if exists d1;
drop database if exists d2;
drop database if exists d3;
drop database if exists d4;
drop tablegroup if exists test_different_databases;
--enable_warnings

create database d1;
create database d2;
create database d3;
create database d4;
create tablegroup test_different_databases;

# 1.a init. 
create table d1.tbl1 (c1 int) tablegroup = test_different_databases;

# 1.b test create table
create table d2.tbl2 (c1 int) tablegroup = test_different_databases;

# 1.c test alter table
create table d3.tbl3 (c1 int);
alter table d3.tbl3 tablegroup = test_different_databases;

# 1.d test alter tablegroup
create table d4.tbl4 (c1 int);
alter tablegroup test_different_databases add d4.tbl4;

drop table d1.tbl1, d2.tbl2, d3.tbl3, d4.tbl4;
drop database d1;
drop database d2;
drop database d3;
drop database d4;
drop tablegroup test_different_databases;



-- echo ####################### SYS TABLEGROUP TEST #######################

--disable_warnings
drop table if exists d1.tbl1, d2.tbl2, d3.tbl3;
drop database if exists d1;
drop database if exists d2;
drop database if exists d3;
--enable_warnings

create database d1;
create database d2;
create database d3;

# 2.a test create table
--error 4179
create table d1.tbl1 (c1 int) tablegroup = oceanbase;

# 2.b test alter table
create table d2.tbl2 (c1 int);
--error 4179
alter table d2.tbl2 tablegroup = oceanbase;

# 2.c test alter tablegroup
create table d3.tbl3 (c1 int);
--error 4179
alter tablegroup oceanbase add d3.tbl3;

--disable_warnings
drop table if exists d1.tbl1, d2.tbl2, d3.tbl3;
drop database if exists d1;
drop database if exists d2;
drop database if exists d3;
--enable_warnings



-- echo ####################### SYS TENANT TEST #######################

connect(sys_conn,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection sys_conn;

--disable_warnings
drop table if exists d1.tbl1, d2.tbl2, d3.tbl3, d4.tbl4;
drop database if exists d1;
drop database if exists d2;
drop database if exists d3;
drop database if exists d4;
drop tablegroup if exists test_different_databases;
--enable_warnings

create database d1;
create database d2;
create database d3;
create database d4;
create tablegroup test_different_databases;

# 3.a init. 
create table d1.tbl1 (c1 int) tablegroup = test_different_databases;

# 3.b test create table
create table d2.tbl2 (c1 int) tablegroup = test_different_databases;

# 3.c test alter table
create table d3.tbl3 (c1 int);
alter table d3.tbl3 tablegroup=test_different_databases;

# 3.d test alter tablegroup
create table d4.tbl4 (c1 int);
alter tablegroup test_different_databases add d4.tbl4;

drop table d1.tbl1, d2.tbl2, d3.tbl3, d4.tbl4;
drop database d1;
drop database d2;
drop database d3;
drop database d4;
drop tablegroup test_different_databases;
