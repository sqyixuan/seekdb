# owner : gongyusen.gys
# owner group : SQL2
# description : test DEFAULT value expression in create TABLE statement
# tags: ddl
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop TABLE if exists t1;
drop TABLE if exists t2;
drop TABLE if exists t3;
drop TABLE if exists t4;
drop TABLE if exists t6;
drop TABLE if exists t7;
drop TABLE if exists t8;
drop TABLE if exists t9;
drop TABLE if exists t10;
drop table if exists add_column_bug;
drop TABLE if exists t_default_value_test;
--enable_warnings
--error 1305
CREATE TABLE t1 (
  pk int primary key,
  b BINARY(36) DEFAULT(UUID_TO_BINARY(UUID())),
  d DATE DEFAULT(CURRENT_TIMESTAMP + INTERVAL 1 YEAR),
  i INT DEFAULT 0,
  f float DEFAULT(rand() * rand()),
  t TIMESTAMP(0) DEFAULT CURRENT_TIMESTAMP,
  v VARCHAR(20) DEFAULT ''
);

CREATE TABLE t1 (
  pk int primary key,
  b BINARY(36) DEFAULT(UUID()),
  d DATE DEFAULT(CURRENT_TIMESTAMP + INTERVAL 1 YEAR),
  i INT DEFAULT 0,
  f float DEFAULT(rand() * rand()),
  t TIMESTAMP(0) DEFAULT CURRENT_TIMESTAMP,
  v VARCHAR(20) DEFAULT '',
  init_date INT NOT NULL DEFAULT (DATE_FORMAT(sysdate() ,'%Y%m%d'))
);
DESC t1;

CREATE TABLE `t2` (
`col_42617` ENUM('Alice','Bob','Charlie','David') CHARACTER SET gbk COLLATE gbk_bin DEFAULT NULL,
`col_30515` ENUM('Alice','Bob','Charlie','David') CHARACTER SET utf16 DEFAULT NULL,
`col_67` text CHARACTER SET utf8mb4 NOT NULL,
`col_457` char(191) CHARACTER SET utf8mb4 GENERATED ALWAYS AS (space((`col_67` + `col_67`))) STORED,
`col_3607` float DEFAULT NULL,
`col_11695` binary(151) GENERATED ALWAYS AS (hex((`col_30515` + `col_3607`))) VIRTUAL,
`col_26487` bit(47) GENERATED ALWAYS AS (lower((`col_30515` - `col_30515`))) STORED,
`col_46493` year(4) DEFAULT '2029',
`col_47339` json DEFAULT NULL
);
DESC t2;
INSERT INTO t2(col_3607, col_67) VALUES(31, 30);
SELECT * FROM t2;

alter TABLE t2 CHANGE column col_46493 col_44973 bigint  DEFAULT (round(null)) FIRST;
DESC t2;
INSERT INTO t2(col_3607, col_67) VALUES(31, 30);
SELECT * FROM t2;

CREATE TABLE `t3` (
  `col_26754` float NOT NULL DEFAULT (lower((5296.727537850211 / 5178.542905148395)))
);
DESC t3;
INSERT INTO t3() VALUES();
SELECT * FROM t3;
alter TABLE t3 alter column col_26754 set DEFAULT 3951183980;
INSERT INTO t3() VALUES();
SELECT * FROM t3;

CREATE TABLE t4 (
  id INT AUTO_INCREMENT PRIMARY KEY,
  int_col INT DEFAULT (10 * 2),
  enum_col ENUM('Value1', 'Value2', 'Value3') DEFAULT (IF(1=1, 'Value1', 'Value2'))
);
DESC t4;
INSERT INTO t4(int_col) VALUES(1);
SELECT * FROM t4;

CREATE TABLE t6 (
  id INT PRIMARY KEY AUTO_INCREMENT,
  grade_level ENUM('Freshman', 'Sophomore', 'Junior', 'Senior') DEFAULT (ELT(FLOOR(1 + RAND() * 4), 'Freshman', 'Sophomore', 'Junior', 'Senior')),
  price_discounted FLOAT DEFAULT (IF(MONTH(CURDATE()) = 12, 0.9, 1.0) * 100)
);
DESC t6;

--error 1067
create TABLE t7 (
  col_2540 text (235), 
  col_2541 varchar (446) not null, 
  col_2543 decimal (34, 30) not null, 
  col_2544 json not null, 
  col_2545 int not null, 
  col_2546 json, 
  col_2547 json, 
  col_2548 char (97) DEFAULT 'Dr蟘', 
  col_2549 json not null, 
  col_2550 json not null, 
  col_2551 year not null, 
  col_2553 mediumint DEFAULT (
    ceil(4438410)
  ), 
  col_2554 bit (14), 
  col_2555 ENUM ('Alice', 'Bob', 'Charlie', 'David') not null DEFAULT (bit_length('Charlie'))
);

create TABLE t7 (
  col_2540 text (235), 
  col_2541 varchar (446) not null, 
  col_2543 decimal (34, 30) not null, 
  col_2544 json not null, 
  col_2545 int not null, 
  col_2546 json, 
  col_2547 json, 
  col_2548 char (97) DEFAULT 'Dr蟘', 
  col_2549 json not null, 
  col_2550 json not null, 
  col_2551 year not null, 
  col_2553 mediumint DEFAULT (ceil(4438410))
);
