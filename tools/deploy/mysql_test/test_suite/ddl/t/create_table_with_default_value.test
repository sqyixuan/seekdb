create TABLE t8 (
  col_1969 set ('Alice','Bob','Charlie','David') DEFAULT (ltrim( 'Charlie' )) 
);
DESC t8;
INSERT INTO t8() VALUES();
SELECT * FROM t8;
--error 1101
CREATE TABLE t (
  i INT         DEFAULT 0,
  c VARCHAR(10) DEFAULT '',
  f FLOAT       DEFAULT (RAND() * RAND()),
  b BINARY(16)  DEFAULT (UUID_TO_BIN(UUID())),
  d DATE        DEFAULT (CURRENT_DATE + INTERVAL 1 YEAR),
  p POINT       DEFAULT (Point(0,0))
);

CREATE TABLE t9 (
  id INT AUTO_INCREMENT PRIMARY KEY,
  int_col_with_expression_default INT DEFAULT (5 * 10),
  float_col_with_expression_default FLOAT DEFAULT (RAND() * 100),
  double_col_with_expression_default DOUBLE DEFAULT (3.14159 / 2.0),
  decimal_col_with_expression_default DECIMAL(10,2) DEFAULT (ROUND(123.4567, 1)),
  date_col_with_expression_default DATE DEFAULT (CURDATE()),
  time_col_with_expression_default TIME DEFAULT (CURTIME()),
  datetime_col_with_expression_default DATETIME DEFAULT (NOW() + INTERVAL 1 DAY),
  weekday_name VARCHAR(9) DEFAULT (DAYNAME(CURRENT_DATE)),
  first_day_of_current_year DATE DEFAULT (STR_TO_DATE(CONCAT(YEAR(NOW()), '-01-01'), '%Y-%m-%d'))
);
DESC t9;

--error 1067
CREATE TABLE t10 (
  d DATE NOT NULL DEFAULT NOW()
);

CREATE TABLE t10 (
  d DATE NOT NULL DEFAULT (NOW())
);
ALTER TABLE t10 CHANGE d d datetime not null default current_timestamp;

--error 1067
ALTER TABLE t10 CHANGE d d date not null default current_timestamp;
ALTER TABLE t10 CHANGE d d date not null default (current_timestamp);

--error 1067
ALTER TABLE t10 MODIFY COLUMN d date not null default current_timestamp;
ALTER TABLE t10 MODIFY COLUMN d date not null default (current_timestamp);

ALTER TABLE t10 ALTER COLUMN d SET DEFAULT (now());

CREATE TABLE t_default_value_test (
    id INT PRIMARY KEY AUTO_INCREMENT,
    bit_mask TINYINT DEFAULT (1 | 2)
);
DESC t_default_value_test;
INSERT INTO t_default_value_test() VALUES();

ALTER TABLE t_default_value_test ADD default_1 varchar(20) DEFAULT (DATE_FORMAT(sysdate() ,'%Y%m%d')) FIRST;
DESC t_default_value_test;

ALTER TABLE t_default_value_test DROP column bit_mask;
DESC t_default_value_test;
INSERT INTO t_default_value_test() VALUES();

ALTER TABLE t_default_value_test MODIFY COLUMN default_1 int DEFAULT (1 | 2);
DESC t_default_value_test;
INSERT INTO t_default_value_test() VALUES();

ALTER TABLE t_default_value_test CHANGE default_1 default_2 double DEFAULT(rand() * rand());
DESC t_default_value_test;
ALTER TABLE t_default_value_test ALTER COLUMN default_2 SET DEFAULT (3.14159 / 2.0);
DESC t_default_value_test;
INSERT INTO t_default_value_test() VALUES();

ALTER TABLE t_default_value_test ALTER COLUMN default_2 SET DEFAULT '0.0';
DESC t_default_value_test;
INSERT INTO t_default_value_test() VALUES();

ALTER TABLE t_default_value_test ALTER COLUMN default_2 DROP DEFAULT;
DESC t_default_value_test;
INSERT INTO t_default_value_test() VALUES();
SELECT table_name, operation_type, ddl_stmt_str FROM oceanbase.__all_ddl_operation WHERE table_id = (SELECT table_id FROM oceanbase.__all_table WHERE table_name = 't_default_value_test' AND database_id = (SELECT database_id FROM oceanbase.__all_database WHERE database_name=(SELECT database() FROM DUAL)));
ALTER TABLE t_default_value_test ADD COLUMN default_set SET ( 'Alice','Bob','Charlie','David' )  NOT NULL DEFAULT (nvl('David' , 3)) BEFORE default_2;
DESC t_default_value_test;
INSERT INTO t_default_value_test() VALUES();
SELECT table_name, operation_type, ddl_stmt_str FROM oceanbase.__all_ddl_operation WHERE table_id = (SELECT table_id FROM oceanbase.__all_table WHERE table_name = 't_default_value_test' AND database_id = (SELECT database_id FROM oceanbase.__all_database WHERE database_name=(SELECT database() FROM DUAL)));

CREATE TABLE add_column_bug(a int not null);
replace into add_column_bug (a) values (2008);
alter table add_column_bug add column b set ('Alice','Bob','Charlie','David') not null default (nvl('David', 3));
select * from add_column_bug;
update add_column_bug set add_column_bug.a = 1981;

alter table add_column_bug add column c varchar(20) not null default (TIMESTAMPADD(MONTH, '^BtNJ' , 'O)Wp*v*' ));
select c from add_column_bug;

