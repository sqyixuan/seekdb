# index key varchar(x1) -> varchar(x2); x2>=x1 and convert over 255: online
--disable_warnings
drop table if exists t1_varchar;
drop sequence if exists s1;
--enable_warnings
create table t1_varchar (a varchar(200));
create sequence s1 cache 1000000 noorder;
create index idx_t1_varchar on t1_varchar(a);
insert into t1_varchar select s1.nextval from table(generator(2000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_varchar', table_id, 1);
alter table t1_varchar change column a a varchar(300);
insert into t1_varchar select s1.nextval from table(generator(2000));
select count(*) from t1_varchar;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_varchar', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}

# foreign key varchar(x1) -> varchar(x2); x2>=x1 and convert over 255: online
--disable_warnings
drop table if exists t2_varchar;
drop table if exists t1_varchar;
drop sequence if exists s1;
drop sequence if exists s2;
--enable_warnings
create table t1_varchar (a varchar(200) unique);
create table t2_varchar (a varchar(200), foreign key(a) references t1_varchar(a));
create sequence s1 cache 1000000 noorder;
create sequence s2 cache 1000000 noorder;
insert into t1_varchar select s1.nextval from table(generator(2000));
insert into t2_varchar select s2.nextval from table(generator(2000));
let $t_id_origin_1 = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_varchar', table_id, 1);
let $t_id_origin_2 = query_get_value(select table_id from oceanbase.__all_table where table_name = 't2_varchar', table_id, 1);
alter table t1_varchar change column a a varchar(300);
alter table t2_varchar change column a a varchar(300);
insert into t1_varchar select s1.nextval from table(generator(2000));
insert into t2_varchar select s2.nextval from table(generator(2000));
select count(*) from t1_varchar;
let $t_id_alterred_1 = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_varchar', table_id, 1);
let $t_id_alterred_2 = query_get_value(select table_id from oceanbase.__all_table where table_name = 't2_varchar', table_id, 1);
if ($t_id_alterred_1 == $t_id_origin_1)
{
--echo online
}
if ($t_id_alterred_1 != $t_id_origin_1)
{
--echo offline
}
if ($t_id_alterred_2 == $t_id_origin_2)
{
--echo online
}
if ($t_id_alterred_2 != $t_id_origin_2)
{
--echo offline
}
--disable_warnings
drop table if exists t2_varchar;


# generated column stored and virtual
drop table if exists t1_varchar;
drop sequence if exists s1;
--enable_warnings
create table t1_varchar (a varchar(100), b varchar(200) generated always as (concat(a,a)) STORED);
create sequence s1 cache 1000000 noorder;
insert into t1_varchar(a) select s1.nextval from table(generator(2000));
