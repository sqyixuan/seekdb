# owner: zhaoziqian.zzq
# owner group: rs
# tags: ddl
# description: test dynamic partition grammar & schema

connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
--disable_warnings
drop database if exists ziqian_dynamic_part;
--enable_warnings
create database ziqian_dynamic_part;
use ziqian_dynamic_part;
set recyclebin = off;
let $database_id = query_get_value(select database_id from oceanbase.__all_database where database_name='ziqian_dynamic_part', database_id, 1);

# parallel create table
alter system set _enable_parallel_table_creation = true;
# sys不支持动态分区相关内容注释
--disable_parsing
create table t1 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'day'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);

--disable_query_log
eval select dynamic_partition_policy from oceanbase.__all_table where table_name = 't1' and database_id = $database_id;
--enable_query_log

alter table t1 set
dynamic_partition_policy
(
  enable = false
);

--disable_query_log
eval select dynamic_partition_policy from oceanbase.__all_table where table_name = 't1' and database_id = $database_id;
--enable_query_log

alter table t1 set
dynamic_partition_policy
(
  precreate_time = '3day'
);

--disable_query_log
eval select dynamic_partition_policy from oceanbase.__all_table where table_name = 't1' and database_id = $database_id;
--enable_query_log

alter table t1 set
dynamic_partition_policy
(
  expire_time = '1month'
);

--disable_query_log
eval select dynamic_partition_policy from oceanbase.__all_table where table_name = 't1' and database_id = $database_id;
--enable_query_log

alter table t1 set
dynamic_partition_policy
(
  enable = true,
  precreate_time = '1day',
  expire_time = '-1'
);

--disable_query_log
eval select dynamic_partition_policy from oceanbase.__all_table where table_name = 't1' and database_id = $database_id;
--enable_query_log

# serial create table
alter system set _enable_parallel_table_creation = false;
create table t2 (c1 datetime)
dynamic_partition_policy
(
  time_unit = 'day'
)
partition by range columns (c1)
(
  partition p0 values less than ('2025-01-01 00:00:00')
);

--disable_query_log
eval select dynamic_partition_policy from oceanbase.__all_table where table_name = 't2' and database_id = $database_id;
--enable_query_log
--enable_parsing
drop database ziqian_dynamic_part;
alter system set _enable_parallel_table_creation = true;
