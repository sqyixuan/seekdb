--error 1526
insert into t_range_range_columns_template values (150, 2500, 1);
alter table t_range_range_columns_template modify partition p1 add subpartition
(
  subpartition p1sp2 values less than (3000),
  subpartition p1sp3 values less than (4000)
);
insert into t_range_range_columns_template values (150, 2500, 1);
alter table t_range_range_columns_template drop partition p0;
alter table t_range_range_columns_template drop subpartition p1sp0;
