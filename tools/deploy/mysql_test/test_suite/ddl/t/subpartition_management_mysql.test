# owner: zhaoziqian.zzq
# owner group: rs
# tags: ddl
# description: subpartition management in mysql mode, add/drop partition/subpartition with different types of partitioned table

# RULES:

# partitioned table:
# +---------------------+-----------+--------------+
# | type                | partition | subpartition |
# +---------------------+-----------+--------------+
# | range/range_columns | add/drop  | -            |
# | list/list_columns   | add/drop  | -            |
# | hash/key            | -         | -            |
# +---------------------+-----------+--------------+

# template subpartitioned table:
# +-------------------------------------------+-----------+--------------+
# | type                                      | partition | subpartition |
# +-------------------------------------------+-----------+--------------+
# | range/range_columns + range/range_columns | add/drop  | add/drop     |
# | range/range_columns + list/list_columns   | add/drop  | add/drop     |
# | range/range_columns + hash/key            | add/drop  | -            |
# | list/list_columns + range/range_columns   | add/drop  | add/drop     |
# | list/list_columns + list/list_columns     | add/drop  | add/drop     |
# | list/list_columns + hash/key              | add/drop  | -            |
# | hash/key + range/range_columns            | -         | add/drop     |
# | hash/key + list/list_columns              | -         | add/drop     |
# | hash/key + hash/key                       | -         | -            |
# +-------------------------------------------+-----------+--------------+

# non template subpartitioned table
# +-------------------------------------------+-----------+--------------+
# | type                                      | partition | subpartition |
# +-------------------------------------------+-----------+--------------+
# | range/range_columns + range/range_columns | add/drop  | add/drop     |
# | range/range_columns + list/list_columns   | add/drop  | add/drop     |
# | range/range_columns + hash/key            | add/drop  | -            |
# | list/list_columns + range/range_columns   | add/drop  | add/drop     |
# | list/list_columns + list/list_columns     | add/drop  | add/drop     |
# | list/list_columns + hash/key              | add/drop  | -            |
# | hash/key + range/range_columns            | -         | add/drop     |
# | hash/key + list/list_columns              | -         | add/drop     |
# | hash/key + hash/key                       | -         | -            |
# +-------------------------------------------+-----------+--------------+


connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
--disable_warnings
drop database if exists ziqian_subpart_mgr;
--enable_warnings
create database ziqian_subpart_mgr;
use ziqian_subpart_mgr;
set recyclebin = off;
--disable_query_log
let $database_id = query_get_value(select database_id from oceanbase.__all_database where database_name='ziqian_subpart_mgr', database_id, 1);
--enable_query_log


# non partitioned table does not support add/drop partition/subpartition
create table t_no_part (c1 int, c2 int, c3 int);
--error 1505
alter table t_no_part add partition (partition p0 values less than (100));
--error 1505
alter table t_no_part drop partition p0;
--error 1505
alter table t_no_part modify partition p0 add subpartition (subpartition p0sp0 values less than (100));
--error 1505
alter table t_no_part drop subpartition p0sp0;
--disable_query_log
let $table_id = query_get_value(select table_id from oceanbase.__all_table where database_id = $database_id and table_name='t_no_part', table_id, 1);
--echo t_no_part partition count
eval select count(*) from oceanbase.__all_part where table_id = $table_id;
--echo t_no_part subpartition count
eval select count(*) from oceanbase.__all_sub_part where table_id = $table_id;
--enable_query_log


########################### partitioned table ###########################

# +---------------------+-----------+--------------+
# | type                | partition | subpartition |
# +---------------------+-----------+--------------+
# | range/range_columns | add/drop  | -            |
# | list/list_columns   | add/drop  | -            |
# | hash/key            | -         | -            |
# +---------------------+-----------+--------------+

create table t_range (c1 int, c2 int, c3 int) partition by range (c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);
alter table t_range add partition (partition p2 values less than (300));
alter table t_range drop partition p2;
--error 5875
alter table t_range modify partition p0 add subpartition (subpartition p0sp0 values less than (100));
--error 5875
alter table t_range drop subpartition p0sp0;
--disable_query_log
let $table_id = query_get_value(select table_id from oceanbase.__all_table where database_id = $database_id and table_name='t_range', table_id, 1);
--echo t_range partition count
eval select count(*) from oceanbase.__all_part where table_id = $table_id;
--echo t_range subpartition count
eval select count(*) from oceanbase.__all_sub_part where table_id = $table_id;
--enable_query_log

create table t_range_columns (c1 int, c2 int, c3 int) partition by range columns (c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);
alter table t_range_columns add partition (partition p2 values less than (300));
alter table t_range_columns drop partition p2;
--error 5875
alter table t_range_columns modify partition p0 add subpartition (subpartition p0sp0 values less than (100));
--error 5875
alter table t_range_columns drop subpartition p0sp0;
--disable_query_log
let $table_id = query_get_value(select table_id from oceanbase.__all_table where database_id = $database_id and table_name='t_range_columns', table_id, 1);
--echo t_range_columns partition count
eval select count(*) from oceanbase.__all_part where table_id = $table_id;
--echo t_range_columns subpartition count
eval select count(*) from oceanbase.__all_sub_part where table_id = $table_id;
--enable_query_log

create table t_list (c1 int, c2 int, c3 int) partition by list (c1)
(
  partition p0 values in (1, 2, 3),
  partition p1 values in (4, 5, 6)
);
alter table t_list add partition (partition p2 values in (7, 8, 9));
alter table t_list drop partition p2;
--error 5875
alter table t_list modify partition p0 add subpartition (subpartition p0sp0 values in (7, 8, 9));
--error 5875
alter table t_list drop subpartition p0sp0;
--disable_query_log
let $table_id = query_get_value(select table_id from oceanbase.__all_table where database_id = $database_id and table_name='t_list', table_id, 1);
--echo t_list partition count
eval select count(*) from oceanbase.__all_part where table_id = $table_id;
--echo t_list subpartition count
eval select count(*) from oceanbase.__all_sub_part where table_id = $table_id;
--enable_query_log

create table t_list_columns (c1 int, c2 int, c3 int) partition by list columns (c1)
(
  partition p0 values in (1, 2, 3),
  partition p1 values in (4, 5, 6)
);
alter table t_list_columns add partition (partition p2 values in (7, 8, 9));
alter table t_list_columns drop partition p2;
--error 5875
alter table t_list_columns modify partition p0 add subpartition (subpartition p0sp0 values in (7, 8, 9));
--error 5875
alter table t_list_columns drop subpartition p0sp0;
--disable_query_log
let $table_id = query_get_value(select table_id from oceanbase.__all_table where database_id = $database_id and table_name='t_list_columns', table_id, 1);
--echo t_list_columns partition count
eval select count(*) from oceanbase.__all_part where table_id = $table_id;
--echo t_list_columns subpartition count
eval select count(*) from oceanbase.__all_sub_part where table_id = $table_id;
--enable_query_log

create table t_hash (c1 int, c2 int, c3 int) partition by hash (c1) partitions 2;
--error 1064
alter table t_hash add partition (partition p2);
--error 1235
alter table t_hash drop partition p0;
--error 5875
alter table t_hash modify partition p1 add subpartition (subpartition p1sp0 values less than (100));
--error 5875
alter table t_hash drop subpartition p1sp0;
--disable_query_log
let $table_id = query_get_value(select table_id from oceanbase.__all_table where database_id = $database_id and table_name='t_hash', table_id, 1);
--echo t_hash partition count
eval select count(*) from oceanbase.__all_part where table_id = $table_id;
--echo t_hash subpartition count
eval select count(*) from oceanbase.__all_sub_part where table_id = $table_id;
--enable_query_log

create table t_key (c1 int, c2 int, c3 int) partition by key (c1) partitions 2;
--error 1064
alter table t_key add partition (partition p2);
--error 1235
alter table t_key drop partition p0;
--error 5875
alter table t_key modify partition p1 add subpartition (subpartition p1sp0 values less than (100));
--error 5875
alter table t_key drop subpartition p1sp0;
--disable_query_log
let $table_id = query_get_value(select table_id from oceanbase.__all_table where database_id = $database_id and table_name='t_key', table_id, 1);
--echo t_key partition count
eval select count(*) from oceanbase.__all_part where table_id = $table_id;
--echo t_key subpartition count
eval select count(*) from oceanbase.__all_sub_part where table_id = $table_id;
--enable_query_log

########################### template subpartitioned table ###########################

# +-------------------------------------------+-----------+--------------+
# | type                                      | partition | subpartition |
# +-------------------------------------------+-----------+--------------+
# | range/range_columns + range/range_columns | add/drop  | add/drop     |
# | range/range_columns + list/list_columns   | add/drop  | add/drop     |
# | range/range_columns + hash/key            | add/drop  | -            |
# | list/list_columns + range/range_columns   | add/drop  | add/drop     |
# | list/list_columns + list/list_columns     | add/drop  | add/drop     |
# | list/list_columns + hash/key              | add/drop  | -            |
# | hash/key + range/range_columns            | -         | add/drop     |
# | hash/key + list/list_columns              | -         | add/drop     |
# | hash/key + hash/key                       | -         | -            |
# +-------------------------------------------+-----------+--------------+

# ------------------------- range + x -------------------------
create table t_range_range_template (c1 int, c2 int, c3 int) partition by range (c1)
subpartition by range (c2)
subpartition template
(
  subpartition p0 values less than (1000),
  subpartition p1 values less than (2000)
)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);
alter table t_range_range_template add partition (partition p2 values less than (300));
--error 1526
insert into t_range_range_template values (150, 2500, 0);
alter table t_range_range_template modify partition p1 add subpartition
(
  subpartition p1sp2 values less than (3000),
  subpartition p1sp3 values less than (4000)
);
insert into t_range_range_template values (150, 2500, 0);
alter table t_range_range_template drop partition p0;
alter table t_range_range_template drop subpartition p1sp0;
--disable_query_log
let $table_id = query_get_value(select table_id from oceanbase.__all_table where database_id = $database_id and table_name='t_range_range_template', table_id, 1);
--echo t_range_range_template partition count
eval select count(*) from oceanbase.__all_part where table_id = $table_id;
--echo t_range_range_template subpartition count
eval select count(*) from oceanbase.__all_sub_part where table_id = $table_id;
--enable_query_log

create table t_range_range_columns_template (c1 int, c2 int, c3 int) partition by range (c1)
subpartition by range columns (c2)
subpartition template
(
  subpartition p0 values less than (1000),
  subpartition p1 values less than (2000)
)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);
