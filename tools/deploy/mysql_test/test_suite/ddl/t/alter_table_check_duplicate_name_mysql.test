# owner: xingrui.cwh
# owner group: RS
# description:  检查mysql下，新加列是否重名
# case 1.新加列的列名集合重名
# case 2.新加列和已有列列名重名

connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connect(mysql_conn, $OBMYSQL_MS0, root,,test, $OBMYSQL_PORT);
--disable_warnings
--disable_query_log
--disable_result_log
connection sys_conn;
drop table if exists xingrui_mysql_normal;
drop table if exists xingrui_mysql_json;
connection mysql_conn;
drop table if exists xingrui_mysql_normal;
drop table if exists xingrui_mysql_json;
--enable_query_log
--enable_warnings
--enable_result_log

connection sys_conn;
#1.add column normal in sys tenant
#mysql大小写不敏感
create table xingrui_mysql_normal(col1 int, cafe int);
#1.1 新增多列,列内重名
#1.1.1 不带字符集
--error 1060
alter table xingrui_mysql_normal add column cafe1 int, add column cafe1 int;
--error 1060
alter table xingrui_mysql_normal add column cafe1 int, add column CaFe1 int;
--error 1060
alter table xingrui_mysql_normal add column cafe int, add column CaFe int;

--error 1060
alter table xingrui_mysql_normal add column `cafe1` int, add column `cafe1` int;
--error 1060
alter table xingrui_mysql_normal add column `cafe1` int, add column `CaFe1` int;
--error 1060
alter table xingrui_mysql_normal add column `cafe` int, add column `CaFe` int;

#1.1.2 带字符集
#mysql带字符集，认为cafe和café是相等的
--error 1060
alter table xingrui_mysql_normal add column café1 int, add column cafe1 int;
--error 1060
alter table xingrui_mysql_normal add column café1 int, add column CaFe1 int;
--error 1060
alter table xingrui_mysql_normal add column café int, add column CaFe int;

--error 1060
alter table xingrui_mysql_normal add column `café1` int, add column `cafe1` int;
--error 1060
alter table xingrui_mysql_normal add column `café1` int, add column `CaFe1` int;
--error 1060
alter table xingrui_mysql_normal add column `café` int, add column `CaFe` int;

#1.2 新增列与已有列重名
#1.2.1 不带字符集
--error 1060
alter table xingrui_mysql_normal add column cafe int;
--error 1060
alter table xingrui_mysql_normal add column CaFe int;
--error 1060
alter table xingrui_mysql_normal add column `CaFe` int;

#1.2.2 带字符集
--error 1060
alter table xingrui_mysql_normal add column café int;
--error 1060
alter table xingrui_mysql_normal add column CaFé int;
--error 1060
alter table xingrui_mysql_normal add column `CaFé` int;

#2.add column with json in sys tenant
#mysql大小写不敏感
create table xingrui_mysql_json(col1 int, cafe int);
#2.1 新增多列,列内重名
#2.1.1 不带字符集
--error 1060
alter table xingrui_mysql_json add column (cafe1 json) json(cafe1) store as (chunk '1k'),
                               add column (cafe1 json) json(cafe1) store as (chunk '1k');
--error 1060
alter table xingrui_mysql_json add column (cafe1 json) json(cafe1) store as (chunk '1k'),
                               add column (CaFe1 json) json(CaFe1) store as (chunk '1k');
--error 1060
alter table xingrui_mysql_json add column (cafe json) json(cafe) store as (chunk '1k'),
                               add column (CaFe json) json(CaFe) store as (chunk '1k');

--error 1060
alter table xingrui_mysql_json add column (`cafe1` json) json(`cafe1`) store as (chunk '1k'),
                               add column (`cafe1` json) json(`cafe1`) store as (chunk '1k');
--error 1060
alter table xingrui_mysql_json add column (`cafe1` json) json(`cafe1`) store as (chunk '1k'),
                               add column (`CaFe1` json) json(`CaFe1`) store as (chunk '1k');
--error 1060
alter table xingrui_mysql_json add column (`cafe` json) json(`cafe`) store as (chunk '1k'),
                               add column (`CaFe` json) json(`CaFe`) store as (chunk '1k');

#2.1.2 带字符集
--error 1060
alter table xingrui_mysql_json add column (café1 json) json(café1) store as (chunk '1k'),
                               add column (cafe1 json) json(cafe1) store as (chunk '1k');
--error 1060
alter table xingrui_mysql_json add column (café1 json) json(café1) store as (chunk '1k'),
                               add column (CaFe1 json) json(CaFe1) store as (chunk '1k');
--error 1060
alter table xingrui_mysql_json add column (café json) json(café) store as (chunk '1k'),
                               add column (CaFe json) json(CaFe) store as (chunk '1k');

--error 1060
alter table xingrui_mysql_json add column (`café1` json) json(`café1`) store as (chunk '1k'),
                               add column (`cafe1` json) json(`cafe1`) store as (chunk '1k');
--error 1060
alter table xingrui_mysql_json add column (`café1` json) json(`café1`) store as (chunk '1k'),
                               add column (`CaFe1` json) json(`CaFe1`) store as (chunk '1k');
--error 1060
alter table xingrui_mysql_json add column (`café` json) json(`café`) store as (chunk '1k'),
                               add column (`CaFe` json) json(`CaFe`) store as (chunk '1k');

#2.2 新增列与已有列重名
#2.2.1 不带字符集
--error 1060
alter table xingrui_mysql_json add column (cafe json) json(cafe) store as (chunk '1k');
--error 1060
alter table xingrui_mysql_json add column (CaFe json) json(CaFe) store as (chunk '1k');
--error 1060
alter table xingrui_mysql_json add column (`CaFe` json) json(`CaFe`) store as (chunk '1k');

#2.2.2 带字符集
--error 1060
alter table xingrui_mysql_json add column (café json) json(café) store as (chunk '1k');
--error 1060
alter table xingrui_mysql_json add column (CaFé json) json(CaFé) store as (chunk '1k');
--error 1060
alter table xingrui_mysql_json add column (`CaFé` json) json(`CaFé`) store as (chunk '1k');

drop table xingrui_mysql_normal;
drop table xingrui_mysql_json;

connection mysql_conn;
#3.add column normal in mysql tenant
#mysql大小写不敏感
create table xingrui_mysql_normal(col1 int, cafe int);
