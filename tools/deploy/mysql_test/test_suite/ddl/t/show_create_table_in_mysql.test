--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: wuyuming.wym
# owner group: SQL1
# description: Strictly compatible show create table with MySQL

--disable_warnings
drop database if exists showtest_db;
create database showtest_db;
--enable_warnings

use showtest_db;
set _show_ddl_in_compat_mode = 1;

--result_format 4

# table option and index option

CREATE TABLE t1 (c1 INT, c2 INT, c3 INT)
     PARALLEL 3
     PARTITION BY RANGE(c1) 
     SUBPARTITION BY KEY(c2, c3) SUBPARTITIONS 5
     (PARTITION p0 VALUES LESS THAN(0), PARTITION p1 VALUES LESS THAN(100));
CREATE UNIQUE INDEX i1_1 on t1(c3, c2) global;

show create table t1;

CREATE TABLE t2(inv_id BIGINT NOT NULL AUTO_INCREMENT,c1 BIGINT, 
    PRIMARY KEY (inv_id) ) PARTITION BY HASH(inv_id) PARTITIONS 8;

show create table t2;

CREATE TABLE t3 (col1 INT, col2 INT, col3 INT, CONSTRAINT equal_check1 CHECK(col1 = col3 * 2)) 
    COMPRESSION = 'none';
CREATE UNIQUE INDEX i3_1 on t3(col1, col2); 
CREATE UNIQUE INDEX i3_2 on t3(col2, col1) local; 
CREATE INDEX i3_3 on t3(col3) storing (col2) local; 
CREATE UNIQUE INDEX i3_4 on t3(col1, col2) global partition by hash (col2); 

show create table t3;

CREATE TABLE t4 (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `class` varchar(20) NOT NULL,
  PRIMARY KEY (`id`)
) AUTO_INCREMENT = 4 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

show create table t4;

CREATE TABLE t5 (c1 INT, c2 INT, c3 INT)
     PARTITION BY HASH(c1) PARTITIONS 4;
CREATE UNIQUE INDEX i5_1 on t5(c3, c2) global;
CREATE UNIQUE INDEX i5_2 on t5(c3, c1) LOCAL;
CREATE INDEX i5_3 on t5(c2, c3) LOCAL;

show create table t5;

# partition table

CREATE TABLE tbl1_l (col1 BIGINT PRIMARY KEY,col2 VARCHAR(50))
       PARTITION BY LIST(col1) 
        (PARTITION p0 VALUES IN (1, 2, 3),
         PARTITION p1 VALUES IN (5, 6),
         PARTITION p2 VALUES IN (DEFAULT)
        );

show create table tbl1_l;

CREATE TABLE tbl1_lc (id INT,partition_id VARCHAR(2))
       PARTITION BY LIST COLUMNS(partition_id)
        (PARTITION p0 VALUES IN ('00','01'),
         PARTITION p1 VALUES IN ('02','03'),
         PARTITION p2 VALUES IN (DEFAULT)
        );

show create table tbl1_lc;

CREATE TABLE tbl1_h(col1 INT,col2 VARCHAR(50))
       PARTITION BY HASH(col1) PARTITIONS 60;

show create table tbl1_h;

CREATE TABLE tbl1_k(id INT,gmt_create DATETIME,info VARCHAR(20))
       PARTITION BY KEY(id,gmt_create) PARTITIONS 10;

show create table tbl1_k;

CREATE TABLE tbl1_r (log_id BIGINT NOT NULL,log_value VARCHAR(50),log_date TIMESTAMP NOT NULL)
       PARTITION BY RANGE(UNIX_TIMESTAMP(log_date)) 
        (PARTITION M202001 VALUES LESS THAN(UNIX_TIMESTAMP('2020/02/01'))
       , PARTITION M202002 VALUES LESS THAN(UNIX_TIMESTAMP('2020/03/01'))
       , PARTITION M202003 VALUES LESS THAN(UNIX_TIMESTAMP('2020/04/01'))
       , PARTITION M202004 VALUES LESS THAN(UNIX_TIMESTAMP('2020/05/01'))
       , PARTITION M202005 VALUES LESS THAN(UNIX_TIMESTAMP('2020/06/01'))
       , PARTITION M202006 VALUES LESS THAN(UNIX_TIMESTAMP('2020/07/01'))
       , PARTITION M202007 VALUES LESS THAN(UNIX_TIMESTAMP('2020/08/01'))
       , PARTITION M202008 VALUES LESS THAN(UNIX_TIMESTAMP('2020/09/01'))
       , PARTITION M202009 VALUES LESS THAN(UNIX_TIMESTAMP('2020/10/01'))
       , PARTITION M202010 VALUES LESS THAN(UNIX_TIMESTAMP('2020/11/01'))
       , PARTITION M202011 VALUES LESS THAN(UNIX_TIMESTAMP('2020/12/01'))
       , PARTITION M202012 VALUES LESS THAN(UNIX_TIMESTAMP('2021/01/01'))
        );

show create table tbl1_r;

CREATE TABLE tbl1_rc (log_id BIGINT NOT NULL,log_value VARCHAR(50),log_date DATE NOT NULL)
       PARTITION BY RANGE COLUMNS(log_date) 
        (PARTITION M202001 VALUES LESS THAN('2020/02/01')
       , PARTITION M202002 VALUES LESS THAN('2020/03/01')
       , PARTITION M202003 VALUES LESS THAN('2020/04/01')
       , PARTITION M202004 VALUES LESS THAN('2020/05/01')
       , PARTITION M202005 VALUES LESS THAN('2020/06/01')
       , PARTITION M202006 VALUES LESS THAN('2020/07/01')
       , PARTITION M202007 VALUES LESS THAN('2020/08/01')
       , PARTITION M202008 VALUES LESS THAN('2020/09/01')
       , PARTITION M202009 VALUES LESS THAN('2020/10/01')
       , PARTITION M202010 VALUES LESS THAN('2020/11/01')
       , PARTITION M202011 VALUES LESS THAN('2020/12/01')
       , PARTITION M202012 VALUES LESS THAN('2021/01/01')
       , PARTITION MMAX VALUES LESS THAN MAXVALUE
        );

show create table tbl1_rc;

# template subpartitions

CREATE TABLE t2_m_rcr (col1 INT NOT NULL,col2 varchar(50),col3 INT NOT NULL) 
    PARTITION BY RANGE COLUMNS(col1)
    SUBPARTITION BY RANGE(col3)
    SUBPARTITION TEMPLATE 
    (SUBPARTITION mp0 VALUES LESS THAN(1000),
    SUBPARTITION mp1 VALUES LESS THAN(2000),
    SUBPARTITION mp2 VALUES LESS THAN(3000)
    )
    (PARTITION p0 VALUES LESS THAN(100),
    PARTITION p1 VALUES LESS THAN(200),
    PARTITION p2 VALUES LESS THAN(300)
    ); 

show create table t2_m_rcr;

CREATE TABLE t2_m_rch(col1 INT,col2 INT) 
       PARTITION BY RANGE COLUMNS(col1)
       SUBPARTITION BY HASH(col2) SUBPARTITIONS 5
        (PARTITION p0 VALUES LESS THAN(100),
         PARTITION p1 VALUES LESS THAN(200),
         PARTITION p2 VALUES LESS THAN(300)
        ); 

show create table t2_m_rch;

CREATE TABLE t_m_rclc(col1 INT,col2 INT) 
       PARTITION BY RANGE COLUMNS(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
       SUBPARTITION TEMPLATE 
        (SUBPARTITION mp0 VALUES IN(1,3),
         SUBPARTITION mp1 VALUES IN(4,6),
         SUBPARTITION mp2 VALUES IN(7)
        )
        (PARTITION p0 VALUES LESS THAN(100),
         PARTITION p1 VALUES LESS THAN(200),
         PARTITION p2 VALUES LESS THAN(300)
        ); 

show create table t_m_rclc;

CREATE TABLE t2_m_lr(col1 INT,col2 INT) 
       PARTITION BY LIST (col1)
       SUBPARTITION BY RANGE(col2)
       SUBPARTITION TEMPLATE 
        (SUBPARTITION mp0 VALUES LESS THAN(100),
         SUBPARTITION mp1 VALUES LESS THAN(200),
         SUBPARTITION mp2 VALUES LESS THAN(300)
        )
        (PARTITION p0 VALUES IN(1,3),
         PARTITION p1 VALUES IN(4,6),
         PARTITION p2 VALUES IN(7,9)
        );

show create table t2_m_lr;

CREATE TABLE t2_m_lh (col1 INT NOT NULL,col2 varchar(50),col3 INT NOT NULL) 
    PARTITION BY LIST (col1)
    SUBPARTITION BY HASH(col3) SUBPARTITIONS 3
    (PARTITION p0 VALUES IN(100),
    PARTITION p1 VALUES IN(200),
    PARTITION p2 VALUES IN(300),
    PARTITION p3 VALUES IN(DEFAULT)
    ); 

show create table t2_m_lh;

CREATE TABLE tbl2_m_hrc(col1 INT,col2 INT,col3 INT) 
    PARTITION BY HASH(col1)
    SUBPARTITION BY RANGE COLUMNS(col2)
    SUBPARTITION TEMPLATE
    (SUBPARTITION p0 VALUES LESS THAN(100),
    SUBPARTITION p1 VALUES LESS THAN(200),
    SUBPARTITION p2 VALUES LESS THAN(300)
    );

show create table tbl2_m_hrc;

CREATE TABLE tbl2_m_hlc(col1 INT,col2 INT,col3 INT) 
    PARTITION BY HASH(col1)
    SUBPARTITION BY LIST COLUMNS(col2)
    SUBPARTITION TEMPLATE
    (SUBPARTITION p0 VALUES IN(1,3),
    SUBPARTITION p1 VALUES IN(4,6),
    SUBPARTITION p2 VALUES IN(7,9)
    )
    PARTITIONS 5; 

show create table tbl2_m_hlc;

CREATE TABLE tbl2_m_hh(col1 INT,col2 INT,col3 INT) 
       PARTITION BY HASH(col1)
       SUBPARTITION BY HASH(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION sp0,
         SUBPARTITION sp1,
         SUBPARTITION sp2
         )
        PARTITIONS 5;

show create table tbl2_m_hh;

CREATE TABLE tbl2_m_hk(col1 INT,col2 INT,col3 INT) 
       PARTITION BY HASH(col1)
       SUBPARTITION BY KEY(col2)
       SUBPARTITION TEMPLATE
        (SUBPARTITION sp0,
         SUBPARTITION sp1,
         SUBPARTITION sp2
         )
        PARTITIONS 5;

show create table tbl2_m_hk;

# subpartitions

CREATE TABLE t2_f_rr(col1 INT,col2 TIMESTAMP) 
       PARTITION BY RANGE(col1)
       SUBPARTITION BY RANGE(UNIX_TIMESTAMP(col2))
        (PARTITION p0 VALUES LESS THAN(100)
           (SUBPARTITION sp0 VALUES LESS THAN(UNIX_TIMESTAMP('2021/04/01')),
            SUBPARTITION sp1 VALUES LESS THAN(UNIX_TIMESTAMP('2021/07/01')),
            SUBPARTITION sp2 VALUES LESS THAN(UNIX_TIMESTAMP('2021/10/01')),
            SUBPARTITION sp3 VALUES LESS THAN(UNIX_TIMESTAMP('2022/01/01'))
           ),
         PARTITION p1 VALUES LESS THAN(200)
           (SUBPARTITION sp4 VALUES LESS THAN(UNIX_TIMESTAMP('2021/04/01')),
            SUBPARTITION sp5 VALUES LESS THAN(UNIX_TIMESTAMP('2021/07/01')),
            SUBPARTITION sp6 VALUES LESS THAN(UNIX_TIMESTAMP('2021/10/01')),
            SUBPARTITION sp7 VALUES LESS THAN(UNIX_TIMESTAMP('2022/01/01'))
            )
         );

show create table t2_f_rr;

CREATE TABLE t2_f_rclc (col1 INT,col2 INT) 
       PARTITION BY RANGE COLUMNS(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
       (PARTITION p0 VALUES LESS THAN(100)
         (SUBPARTITION sp0 VALUES IN(1,3),
          SUBPARTITION sp1 VALUES IN(4,6),
          SUBPARTITION sp2 VALUES IN(7,9)),
        PARTITION p1 VALUES LESS THAN(200)
         (SUBPARTITION sp3 VALUES IN(1,3),
          SUBPARTITION sp4 VALUES IN(4,6),
          SUBPARTITION sp5 VALUES IN(7,9))
       ); 

show create table t2_f_rclc;

CREATE TABLE t2_f_rch (col1 INT,col2 INT) 
       PARTITION BY RANGE COLUMNS(col1)
       SUBPARTITION BY HASH(col2)
       (PARTITION p0 VALUES LESS THAN(100)
         (SUBPARTITION sp0,
          SUBPARTITION sp1,
          SUBPARTITION sp2),
        PARTITION p1 VALUES LESS THAN(200)
         (SUBPARTITION sp3,
          SUBPARTITION sp4,
          SUBPARTITION sp5)
       ); 

show create table t2_f_rch;

CREATE TABLE t2_f_rck (col1 INT NOT NULL,col2 varchar(50),col3 INT NOT NULL) 
    PARTITION BY RANGE COLUMNS(col1)
    SUBPARTITION BY KEY(col3)
    (PARTITION p0 VALUES LESS THAN(100)
      (SUBPARTITION sp0,
      SUBPARTITION sp1,
      SUBPARTITION sp2),
    PARTITION p1 VALUES LESS THAN(200)
      (SUBPARTITION sp3,
      SUBPARTITION sp4,
      SUBPARTITION sp5)
    ); 

show create table t2_f_rck;

CREATE TABLE t2_f_ll(col1 INT,col2 TIMESTAMP) 
       PARTITION BY LIST(col1)
       SUBPARTITION BY LIST(UNIX_TIMESTAMP(col2))
        (PARTITION p0 VALUES IN(100)
           (SUBPARTITION sp0 VALUES IN(UNIX_TIMESTAMP('2021/04/01')),
            SUBPARTITION sp1 VALUES IN(UNIX_TIMESTAMP('2021/07/01')),
            SUBPARTITION sp2 VALUES IN(UNIX_TIMESTAMP('2021/10/01')),
            SUBPARTITION sp3 VALUES IN(UNIX_TIMESTAMP('2022/01/01'))
           ),
         PARTITION p1 VALUES IN(200)
           (SUBPARTITION sp4 VALUES IN(UNIX_TIMESTAMP('2021/04/01')),
            SUBPARTITION sp5 VALUES IN(UNIX_TIMESTAMP('2021/07/01')),
            SUBPARTITION sp6 VALUES IN(UNIX_TIMESTAMP('2021/10/01')),
            SUBPARTITION sp7 VALUES IN(UNIX_TIMESTAMP('2022/01/01'))
            )
         );

show create table t2_f_ll;

CREATE TABLE t2_f_lch (col1 INT NOT NULL,col2 varchar(50),col3 INT NOT NULL) 
    PARTITION BY LIST COLUMNS(col1)
    SUBPARTITION BY HASH(col3)
    (PARTITION p0 VALUES IN(100)
      (SUBPARTITION sp0,
      SUBPARTITION sp1,
      SUBPARTITION sp2),
    PARTITION p1 VALUES IN(200)
      (SUBPARTITION sp3,
      SUBPARTITION sp4,
      SUBPARTITION sp5)
    ); 

show create table t2_f_lch;

CREATE TABLE t2_f_lch2 (col1 INT NOT NULL,col2 varchar(50),col3 INT NOT NULL) 
    PARTITION BY LIST COLUMNS(col1, col2)
    SUBPARTITION BY HASH(col3)
    (PARTITION p0 VALUES IN((100, '1'), (200, '1'))
      (SUBPARTITION sp0,
      SUBPARTITION sp1,
      SUBPARTITION sp2),
    PARTITION p1 VALUES IN((300, '2'))
      (SUBPARTITION sp3,
      SUBPARTITION sp4),
    PARTITION p2 VALUES IN(default)
      (SUBPARTITION sp5,
      SUBPARTITION sp6)
    ); 

show create table t2_f_lch2;

CREATE TABLE t2_f_lh (col1 INT NOT NULL,col2 INT,col3 INT NOT NULL) 
    PARTITION BY LIST(col1 + col3)
    SUBPARTITION BY HASH(col2)
    (PARTITION p0 VALUES IN(100)
      (SUBPARTITION sp0,
      SUBPARTITION sp1,
      SUBPARTITION sp2),
    PARTITION p1 VALUES IN(default)
      (SUBPARTITION sp3,
      SUBPARTITION sp4,
      SUBPARTITION sp5)
    ); 

show create table t2_f_lh;


# check index invisible 
create table t_show_index(c1 int, c2 int);
create index idx1 on t_show_index(c1);
show create table t_show_index;
alter table t_show_index alter index idx1 invisible;
show create table t_show_index;
drop table t_show_index;

