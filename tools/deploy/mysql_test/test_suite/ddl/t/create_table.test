# owner : dachuan.sdc
# owner group : SQL2
# description : test show create table
# tags: ddl
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--echo ##bugfix: 
--disable_warnings
drop table if exists t;
--enable_warnings
create table t(c1 datetime, c2 datetime(0), c3 timestamp, c4 timestamp(0), c5 time, c6 time(0));
show create table t;
insert into t values('2020-01-01 12:34:56.123456789','2020-01-01 12:34:56.123456789', '2020-01-01 12:34:56.123456789', '2020-01-01 12:34:56.123456789', '12:34:56.123456789', '12:34:56.123456789');
select * from t;
drop table t;

--disable_warnings
--error 0,1396
drop user u1;
drop database if exists db_test;
drop table if exists t2, t3;
--enable_warnings

create user u1 identified by '123';
grant select, create on test.* to u1;
create database db_test;
use db_test;
create table t1 (c1 int);

connect (conn_u1,$OBMYSQL_MS0,u1,'123',test,$OBMYSQL_PORT);
create table t2 (c1 int);
--error 1142
create table t3 as select * from db_test.t1;

connection default;
grant insert on test.* to u1;
show grants for u1;
disconnect conn_u1;
connect (conn_u1,$OBMYSQL_MS0,u1,'123',test,$OBMYSQL_PORT);
--error 1142
create table t3 as select * from db_test.t1;

connection default;
grant select on db_test.t1 to u1;
insert into db_test.t1 values(1), (2), (3);
disconnect conn_u1;
connect (conn_u1,$OBMYSQL_MS0,u1,'123',test,$OBMYSQL_PORT);
create table t3 as select * from db_test.t1;
select * from t3;

connection default;
drop database db_test;
use test;
drop table t2;
drop table t3;


