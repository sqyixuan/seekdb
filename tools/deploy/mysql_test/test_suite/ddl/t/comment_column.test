--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: luofan.zp
#owner group : sql2
--disable_warnings
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t1_toupg;
--enable_warnings
create table t1 (c1 VARCHAR(10) NOT NULL COMMENT '', c2 INTEGER COMMENT '',c3 INTEGER COMMENT '', c4 INTEGER, c5 INTEGER, c6 INTEGER, c7 INTEGER, INDEX i1 (c1) COMMENT 'i1 comment',INDEX i2(c2) 
) COMMENT='';
SELECT table_comment,char_length(table_comment) FROM information_schema.tables WHERE table_name='t1';
SELECT column_comment,char_length(column_comment) FROM information_schema.columns WHERE table_name='t1';
SELECT comment,index_comment,char_length(index_comment) FROM information_schema.statistics WHERE table_name='t1';
--source mysql_test/include/show_create_table_old_version.inc
SHOW CREATE TABLE t1;

ALTER TABLE t1 ADD COLUMN c8 INTEGER COMMENT '';
SELECT table_comment,char_length(table_comment) FROM information_schema.tables WHERE table_name='t1';
SELECT column_comment,char_length(column_comment) FROM information_schema.columns WHERE table_name='t1';
SELECT comment,index_comment,char_length(index_comment) FROM information_schema.statistics WHERE table_name='t1';
--source mysql_test/include/show_create_table_old_version.inc
SHOW CREATE TABLE t1;


