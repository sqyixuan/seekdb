--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql2
#description: todo

####和expireinfo一起使用
--enable_abort_on_error
--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings
create table t2(c1 int primary key,c2  timestamp(6) default "2012-01-01 12:00:00",c3 int,index idx(c2))EXPIRE_INFO=(c2='2013-12-1200:00:00' or c2 is null);
create table t1(c1 int primary key,c2  timestamp(6) default "2012-01-01 12:00:00",c3 int,index idx(c3))EXPIRE_INFO=(c2='2013-12-1200:00:00' or c2 is null);

####其他选项
--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1067
create table if not exists t1
(
c1 TINYINT not null default 0 auto_increment primary key,
c2 SMALLINT not null default 0,
c3 MEDIUMINT not null default 0,
c4 INT not null default 0,
c5 INTEGER not null default 0,
c6 BIGINT not null default 0,
c7 REAL not null default 1.5,
c8 DOUBLE ,
c9 FLOAT ,
c10 TIMESTAMP ,
c11 DATETIME,
c12 CHAR(100),
c13 VARCHAR(20),
c14 BINARY,
c16 datetime default now(),
c17 datetime default now(),
key idx(c16,c17)
)USE_BLOOM_FILTER=false,COMMENT='this is comment';
###comment 选项
--disable_warnings
drop table if exists t1;
--enable_warnings
create table if not exists t1
(
c1 TINYINT not null  auto_increment comment 'abcd' ,
c2 SMALLINT not null default 0 comment 'now',
c3 MEDIUMINT not null default 0,
key idx(c2,c3),
primary key(c1)
)USE_BLOOM_FILTER=false,COMMENT='this is comment';
###对索引列rename
alter table t1 change c2 c20 SMALLINT not null default 0 comment 'now';
sleep 1;
select * from t1;
insert into t1 values(1,1,1);
select * from t1;
###列有comment,验证唯一索引是否保证了唯一性
--disable_warnings
drop table if exists lla;
--enable_warnings
create table lla (c1 int, c2 varchar(30), cc varchar(256), c3 int not null comment 'comment by zhuweng', c4 bool comment 'a flag', primary          key(c1, c2),unique index idx(cc,c3)) comment = 'created at 2014/2/10';
insert into lla values(1,'a','ab',1,'1');
--error 1062
insert into lla values(1,'a','ab',1,'1');
####和storing连用
--disable_warnings
drop table if exists llab;
--enable_warnings
create table llab (c1 int, c2 varchar(30), cc varchar(256), c3 int not null comment 'comment by weng', c4 bool comment 'a flag',                   primary          key(c1, c2),unique index idx(cc,c3) storing (c4)) comment = 'created at 2015/3/111';
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table llab;
--replace_column 3  index_name
show index from llab;
--error 1061
create unique index idx on llab(cc);

drop table if exists llab;
drop table if exists lla;

