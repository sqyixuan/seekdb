CREATE TABLE `t_card_number_abnormal_info` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键ID',
`card_no` varchar(100) DEFAULT NULL COMMENT '卡号',
`count_date` varchar(100) DEFAULT NULL COMMENT '统计日期',
`push_time` varchar(100) DEFAULT NULL COMMENT '推送时间',
`risk_control_type` varchar(100) DEFAULT NULL COMMENT '风控类型',
`start_date` varchar(20) DEFAULT NULL COMMENT '异常开始日期',
`end_date` varchar(20) DEFAULT NULL COMMENT '异常结束日期',
`number_count` int(11) DEFAULT NULL COMMENT '统计次数',
`create_time` datetime DEFAULT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建日期',
`update_time` datetime DEFAULT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '跟新日期',
`is_del` tinyint(2) NOT NULL DEFAULT '1' COMMENT '数据状态，1，正常；2、删除',
PRIMARY KEY (`id`)
) AUTO_INCREMENT=1 COMMENT='卡号异常清单表';
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_card_number_abnormal_info;
drop table t_card_number_abnormal_info;
