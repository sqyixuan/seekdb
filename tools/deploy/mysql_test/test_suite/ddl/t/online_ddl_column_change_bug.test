# owner: gaishun.gs
# owner group: storage : index and ddl
# description: 向上列类型转换
# note: ob do mysqltest --suite=ddl --test_set=online_ddl_column_change_bug -n 43_int2bigint
# note: ob do mysqltest --suite=ddl --test_set=online_ddl_column_change_bug -n 43base
 
--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
 
# for bug 53772243
# url 
--disable_warnings
drop table if exists t1;
drop sequence if exists s1_int;
--enable_warnings
create table t1(c1 int unique, c2 int);
create sequence s1_int cache 1000000 noorder;
insert into t1(c1, c2) select s1_int.nextval, 2 from table(generator(2000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1', table_id, 1);
alter table t1 modify c2 bigint;
insert into t1(c1, c2) select s1_int.nextval, 2 from table(generator(2000));
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}
