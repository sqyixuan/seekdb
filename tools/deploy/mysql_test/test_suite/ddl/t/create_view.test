##bugfix: 
create table if not exists nullable_test (c1 int primary key,c2 int);
--disable_warnings
drop view if exists v1;
create view v1 as select * from nullable_test;

select column_name, IS_NULLABLE from  information_schema.columns where table_name = 'nullable_test';
select column_name, IS_NULLABLE from  information_schema.columns where table_name = 'V1';
desc nullable_test;
desc v1;

drop table nullable_test;
create table if not exists nullable_test (c1 int, c2 int primary key);

select column_name, IS_NULLABLE from  information_schema.columns where table_name = 'nullable_test';
select column_name, IS_NULLABLE from  information_schema.columns where table_name = 'V1';
desc nullable_test;
desc v1;


drop table nullable_test;
drop view v1;