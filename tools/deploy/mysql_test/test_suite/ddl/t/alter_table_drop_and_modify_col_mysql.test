# owner : dachuan.sdc
# owner group : SQL1
# description : 测试用同一条 alter table 的语句同时 drop column，并在 drop column 后 modify 被 drop 的 column 的后面一列
# tags: ddl 

--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_result_log
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_result_log

# test drop column + modify column
create table t1(c1 int, c2 int, c3 char(1));
alter table t1 drop column c2, modify column c3 char(2);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

# test drop column + alter column
create table t2(c1 int, c2 int, c3 char(1));
alter table t2 drop column c2;
alter table t2 alter column c3 set default '1';
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;

# test drop column + change column
create table t3(c1 int, c2 int, c3 char(1));
# change column name along with other ddl not supported
alter table t3 drop column c2, change column c3 c33 char(1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t3;

# clean up
drop table t1;
drop table t2;
drop table t3;

--disable_warnings
drop table if exists t;
--enable_warnings

create table t(c1 int, c2 varchar(10));
alter table t add c3 int;
alter table t drop c3;
alter table t add t.c3 int;
alter table t drop t.c3;
alter table t add column c3 int;
alter table t drop column c3;
alter table t add column t.c3 int;
alter table t drop column t.c3;


alter table t change c2 c3 varchar(10);
alter table t change t.c3 c3 varchar(10);
alter table t change c3 t.c3 varchar(10);
alter table t change t.c3 t.c3 varchar(10);

alter table t change column c3 c3 varchar(10);
alter table t change column t.c3 c3 varchar(10);
alter table t change column c3 t.c3 varchar(10);
alter table t change column t.c3 t.c3 varchar(10);

alter table t modify c3 varchar(10);
alter table t modify t.c3 varchar(10);
alter table t modify column c3 varchar(10);
alter table t modify column t.c3 varchar(10);

alter table t alter column c3 set default '1';
alter table t alter column c3 drop default;
alter table t alter column t.c3 set default '1';
alter table t alter column t.c3 drop default;

--error 1103
create table t1(t.c1 int);
--error 1064
create view v(v.c1) as select c1 from t;
--error 1103
alter table t add t1.c5 int;
--error 1103
alter table t add column t1.c5 int;
--error 1103
alter table t drop t1.c1;
--error 1103
alter table t drop column t1.c1;

--error 1103
alter table t change c3 t1.c3 float;
--error 1103
alter table t change t1.c3 c3 float;
--error 1103
alter table t change column c3 t1.c3 float;
--error 1103
alter table t change column t1.c3 c3 float;

--error 1103
alter table t modify t1.c3 float;
--error 1103
alter table t modify column t1.c3 float;

--error 1103
alter table t alter column t1.c3 set default 1;
--error 1103
alter table t alter column t1.c3 drop default;
drop table t;

## bugfix: 
--error 1171
create table t(c1 int null primary key);
--error 1171
create table t(c1 int primary key null);
--error 1171
create table t(c1 int null default 1 primary key);
--error 1171
create table t(c1 int primary key null default 1);

create table t(c1 int primary key);
--error 1171
alter table t modify c1 int null;
--error 1171
alter table t modify c1 int null default 1;
--error 1171
alter table t change c1 c1 int null;
--error 1171
alter table t change c1 c1 int null default 1;
drop table t;

##bugfix: 
create table t(c1 int(10) unsigned zerofill default null);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t;
alter table t modify c1 int(10) unsigned default null;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t;
alter table t modify c1 int(10) zerofill default null;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t;

alter table t change c1 c1 int(10) unsigned default null;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t;
alter table t change c1 c1 int(10) zerofill default null;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t;
drop table t;

create table t1 (c1 int, c2 int, c3 int, c4 int);
--error 1054
alter table t1 add c6 int as (c2 + 1), drop c2;
drop table t1;

# drop hash key
create table t1(c1 int, c2 int, c3 varchar(30)) partition by hash(c1) partitions 10;
--error 3855
alter table t1 drop column c1;
drop table t1;

create table t1(col1 int,col2 int) partition by range(col1)
       subpartition by range(col2)
       subpartition template
       (subpartition mp1 values less than(100),
        subpartition mp2 values less than(200),
        subpartition mp3 values less than(300)
        )
       (partition p0 values less than(2020),
        partition p1 values less than(2021),
        partition p2 values less than(2022)
        );
--error 3855
alter table t1 drop column col1;
--error 3855
alter table t1 drop column col2;
drop table t1;