# owner: feidu
# owner group: storage => index and ddl
# description: test GV$SESSION_LONGOPS when partition splitting
# ob do mysqltest --suite=ddl --test-set=drop_column_longops_watch -n server_display


--result_format 4

--disable_warnings
drop table if exists t_drop_column_sync_debug;
drop sequence if exists s1;
--enable_warnings

let $UINT64_MAX = 18446744073709551615;

################## DROP COLUMN PROGRESS ####################################

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
sleep 5;

eval create table t_drop_column_sync_debug (id bigint, work text, c1 int auto_increment, dob bigint, primary key(id)) partition by range(id) (partition p0 values less than (100), partition p1 values less than (1500), partition p2 values less than ($UINT64_MAX));
create sequence s1 cache 1000000 noorder;
CREATE INDEX tbl1_h_idx1 ON t_drop_column_sync_debug(id) LOCAL;
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
insert into t_drop_column_sync_debug (id, work, dob) select s1.nextval, repeat('a', 100), random() from table(generator(20));
select count(*) from t_drop_column_sync_debug;

sleep 5;

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '10000s';
sleep 5;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'TABLE_REDEFINITION_REPLICA_BUILD wait_for signal1 execute 10000';
set ob_global_debug_sync = 'TABLE_REDEFINITION_COPY_TABLE_INDEXES wait_for signal2 execute 10000';
set ob_global_debug_sync = 'TABLE_REDEFINITION_COPY_TABLE_CONSTRAINTS wait_for signal3 execute 10000';
set ob_global_debug_sync = 'TABLE_REDEFINITION_COPY_TABLE_FOREIGN_KEYS wait_for signal4 execute 10000';
set ob_global_debug_sync = 'TABLE_REDEFINITION_TAKE_EFFECT wait_for signal5 execute 10000';
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
send alter table t_drop_column_sync_debug drop column c1;
sleep 5;

connection conn2;
SELECT OPNAME FROM oceanbase.GV$SESSION_LONGOPS ORDER BY OPNAME;
sleep 5;
connection obsys;
set ob_global_debug_sync = 'TABLE_REDEFINITION_REPLICA_BUILD clear';
set ob_global_debug_sync = 'now signal signal1';
sleep 5;

connection conn2;
SELECT OPNAME FROM oceanbase.GV$SESSION_LONGOPS ORDER BY OPNAME;
sleep 5;
connection obsys;
set ob_global_debug_sync = 'TABLE_REDEFINITION_COPY_TABLE_INDEXES clear';
set ob_global_debug_sync = 'now signal signal2';
sleep 5;

connection conn2;
SELECT OPNAME FROM oceanbase.GV$SESSION_LONGOPS ORDER BY OPNAME;
sleep 5;
connection obsys;
set ob_global_debug_sync = 'TABLE_REDEFINITION_COPY_TABLE_CONSTRAINTS clear';
set ob_global_debug_sync = 'now signal signal3';
sleep 5;

connection conn2;
SELECT OPNAME FROM oceanbase.GV$SESSION_LONGOPS ORDER BY OPNAME;
sleep 5;
connection obsys;
set ob_global_debug_sync = 'TABLE_REDEFINITION_COPY_TABLE_FOREIGN_KEYS clear';
set ob_global_debug_sync = 'now signal signal4';
sleep 5;

connection conn2;
SELECT OPNAME FROM oceanbase.GV$SESSION_LONGOPS ORDER BY OPNAME;
sleep 5;
connection obsys;
set ob_global_debug_sync = 'TABLE_REDEFINITION_TAKE_EFFECT clear';
set ob_global_debug_sync = 'now signal signal5';
sleep 5;

connection conn1;
reap;
select count(*) from t_drop_column_sync_debug;
