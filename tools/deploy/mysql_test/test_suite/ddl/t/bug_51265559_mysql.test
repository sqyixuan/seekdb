--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: lihongqin.lhq
# owner group: storage
# description: fix bug: Offline DDL can't handle the situation when the column ddl type is OB_DDL_ALTER_COLUMN.
#

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '60s';
sleep 3;
set ob_global_debug_sync = 'reset';
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 100000000;

connection default;
let $tenant_id = query_get_value(select effective_tenant_id() as id, id, 1);

--disable_warnings
drop database if exists tmp_db;
create database tmp_db;
use tmp_db;
drop table if exists foo;

--enable_warnings
create table foo (aa blob, bb longblob, cc tinyblob, dd mediumblob, aaa varchar(12), bbb varbinary(20), ccc varchar(50), ddd varchar(3000));
--error 1067
alter table foo alter column cc set default 101010;
--error 1067
alter table foo alter column cc set default 101010, drop column aa;
--error 1067
alter table foo alter column aaa set default "1010101010101010";

--echo
--echo # parallel offline ddl
connection conn1;
use tmp_db;
sleep 1;
alter table foo drop column bb;
alter table foo alter column ccc set default 202020;
alter table foo alter column aaa set default "1010", drop column ddd, drop column ccc, drop column aaa;
connection default;
drop table if exists foo;
drop database tmp_db;
