# owner : xiaoqiu.wy
# owner group : SQL2
# description : test for invisible column in oracle mode
# tags: ddl

--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_result_log
drop table if exists test_invisible_t1, t2, t3, t4, t5, t6, t7, temp_t1;
drop view if exists v1, v2;
--enable_result_log

# 测试 invisible 列定义为 not null 属性的情况
create table test_invisible_t1(c1 int not null invisible, c2 int);
--error 1136
insert into test_invisible_t1 values(1, 2);
--error 1364
insert into test_invisible_t1 values(2);
insert into test_invisible_t1(c1, c2) values(1, 2);
desc test_invisible_t1;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='test_invisible_t1' and table_schema = 'test';
select * from test_invisible_t1;
select c1, c2 from test_invisible_t1;
# show create table 的时候会展示出 invisible 列
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table test_invisible_t1;

# 测试 invisible 列不为 not null （default null）的情况
create table t2(c1 int invisible, c2 int);
insert into t2 values(2);
insert into t2(c1, c2) values(1, 2);
desc t2;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t2' and table_schema = 'test';
select * from t2;
select c1, c2 from t2;
# show create table 的时候会展示出 invisible 列
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;

# 测试视图的定义是 select * from 一张包含 invisible 列的表
create view v1 as select c1, c2 from test_invisible_t1;
select * from v1;
desc v1;
select c1, c2 from v1;
create view v2 as select * from test_invisible_t1;
select * from v2;
desc v2;
--error 1054
select c1, c2 from v2;

# 测试一张表至少有一个非 invisible 列
--error 4028
create table t3(c1 int invisible, c2 int invisible);
create table t3(c1 int invisible, c2 int);
desc t3;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t3' and table_schema = 'test';
--error 4028
alter table t3 modify c2 int invisible;
--error 4028
alter table t3 drop column c2;
alter table t3 modify c2 int invisible, modify c1 int visible;
desc t3;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t2' and table_schema = 'test';
alter table t3 modify c2 int visible, modify c1 int invisible;
desc t3;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t2' and table_schema = 'test';

# 与oracle不同，测试 alter table 如果要 modify 列的 invisible 属性，可以同时 modify 这一个属性和其他属性
create table t4(c1 int invisible, c2 char(10));
desc t4;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t4' and table_schema = 'test';
alter table t4 modify c1 int visible;
desc t4;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t4' and table_schema = 'test';
alter table t4 modify c2 char(20) invisible;
desc t4;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t4' and table_schema = 'test';

alter table t4 modify c1 int visible, add c3 int;
desc t4;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t4' and table_schema = 'test';

alter table t4 add c4 int, modify c1 int visible;
desc t4;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t4' and table_schema = 'test';

alter table t4 drop column c2, modify c1 int visible;
desc t4;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t4' and table_schema = 'test';

alter table t4 modify c1 int visible, modify c3 char(30);
desc t4;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t4' and table_schema = 'test';

alter table t4 modify c1 int visible, modify c3 int invisible;
desc t4;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t4' and table_schema = 'test';

# 测试 alter table add/drop invisible column 
alter table t4 add c5 int invisible default 123;
alter table t4 add c6 int default 123 invisible;
alter table t4 add c7 int invisible;
desc t4;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t4' and table_schema = 'test';

drop table t4;
create table t4(c1 int, c2 char(10) invisible);
alter table t4 add c3 int invisible default 123;
alter table t4 add c4 int invisible;
desc t4;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t4' and table_schema = 'test';
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t4;
insert into t4 values(1);
insert into t4 values(2);
insert into t4(c1, c2, c3) values(3, 456, 78910);
select * from t4;
select c1, c2, c3 from t4;
alter table t4 drop column c3;
--error 4028
alter table t4 drop column c1;
desc t4;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t4' and table_schema = 'test';
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t4;

# 测试 create table as select xxx
create table t5(c1 int invisible, c2 int);
create table t6 as select * from test_invisible_t1;
desc t6;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t6' and table_schema = 'test';
--error 1054
insert into t6(c1, c2) values(1, 2);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t6;

create table t7(c1 int, c2 int generated always as (c1 + 1) stored invisible);
desc t7;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t7' and table_schema = 'test';
--error 3106
alter table t7 add column c3 int generated always as (c2 + 1) stored invisible;
alter table t7 add column c3 int generated always as (c1 + 2) stored invisible;
alter table t7 modify c3 int generated always as (c1 + 2) stored visible;
desc t7;
select extra, length(extra), table_name, column_name, table_schema FROM information_schema.columns where table_name='t7' and table_schema = 'test';

# 测试临时表，由于ob mysql模式暂时未支持临时表，所以这里先不测试
# --error 1064
# CREATE GLOBAL TEMPORARY TABLE temp_t1(c1 int, c2 int invisible);
# --error 1064
# CREATE GLOBAL TEMPORARY TABLE temp_t1(c1 int, c2 int visible) ON COMMIT PRESERVE ROWS;

# CREATE GLOBAL TEMPORARY TABLE temp_t1 SELECT * FROM t4;
# --error 54042
# alter table temp_t1 add c3 int invisible;
# alter table temp_t1 add c3 int visible;
# --error 54042
# alter table temp_t1 modify c3 invisible;

# clean up
drop table if exists test_invisible_t1, t2, t3, t4, t5, t6, t7, temp_t1;
drop view if exists v1, v2;