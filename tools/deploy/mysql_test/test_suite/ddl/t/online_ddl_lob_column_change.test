# generated column
--disable_warnings
drop table if exists t1_lob;
drop sequence if exists s1;
--enable_warnings
create table t1_lob (a text, b text generated always as (concat(a,a)) STORED);
create sequence s1 cache 1000000 noorder;
insert into t1_lob(a) select s1.nextval from table(generator(2000));
let $t_id_origin = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_lob', table_id, 1);
alter table t1_lob change column a a longtext;
--error 3106
alter table t1_lob change column b b longtext;
--error 3106
alter table t1_lob change column b b longtext generated always as (concat(a,a)) VIRTUAL;
alter table t1_lob change column b b longtext generated always as (concat(a,a)) STORED;
insert into t1_lob(a) select s1.nextval from table(generator(2000));
select count(*) from t1_lob;
let $t_id_alterred = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1_lob', table_id, 1);
if ($t_id_alterred == $t_id_origin)
{
--echo online
}
if ($t_id_alterred != $t_id_origin)
{
--echo offline
}

