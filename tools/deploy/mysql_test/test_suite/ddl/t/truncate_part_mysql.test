# owner: xingrui.cwh 
# owner group: RS 
# description: 非模版二级分区下truncate一级分区
# tags: ddl

--disable_warnings
--error 0,1396
drop user subpart_mgr@'%';
--enable_warnings
create user subpart_mgr identified by '123';
grant all on *.* to subpart_mgr WITH GRANT OPTION;


set @@recyclebin = off;

--result_format 4

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,subpart_mgr,'123',test,$OBMYSQL_PORT);

connection conn1;
let $base_schema_version = `select schema_version from oceanbase.__all_virtual_ddl_operation order by schema_version desc limit 1`;

# 1. hash_range
connection conn2;
# create table
create table t_hash_range (c1 int, c2 int, c3 int, c4 int)
partition by hash(c1)
subpartition by range(c2)
subpartition template
(
  subpartition rsp0 values less than (100),
  subpartition rsp1 values less than (200),
  subpartition rsp2 values less than (300)
)
partitions 3;

# insert row
insert into t_hash_range values(1,2,3,4);
insert into t_hash_range values(1,100,3,4);
insert into t_hash_range values(1,200,3,4);
insert into t_hash_range values(100,2,3,4);
insert into t_hash_range values(100,100,3,4);
insert into t_hash_range values(100,200,3,4);
insert into t_hash_range values(200,2,3,4);
insert into t_hash_range values(200,100,3,4);
insert into t_hash_range values(200,200,3,4);
select * from t_hash_range;

# truncate partitions in same partition
--error 1235
alter table t_hash_range
truncate partition 
hp0,hp1;
select * from t_hash_range;

connection conn1;
let $table_id = `select table_id from oceanbase.__all_virtual_table where table_name='t_hash_range'`;
--disable_query_log
echo "query all_table";
eval select is_deleted, part_level, part_func_type, part_func_expr, part_num, sub_part_func_type, sub_part_func_expr, sub_part_num, partition_status, case when partition_schema_version > 0 then 1 else 0 end, sub_part_template_flags from oceanbase.__all_virtual_table_history where table_id = $table_id;

echo "query all_part";
eval select is_deleted, part_name, sub_part_num, high_bound_val, sub_part_num, list_val, part_idx from oceanbase.__all_virtual_part_history where table_id = $table_id;

echo "query all_sub_part";
eval select is_deleted, sub_part_name, high_bound_val, list_val, sub_part_idx from oceanbase.__all_virtual_sub_part_history where table_id = $table_id;

# 2. range_hash
connection conn2;
# create table
create table t_range_hash (c1 int, c2 int, c3 int, c4 int)
partition by range(c1)
subpartition by hash(c2)
subpartitions 3
(
  partition rp0 values less than (100),
  partition rp1 values less than (200),
  partition rp2 values less than (300)
);

# insert row
insert into t_range_hash values(1,2,3,4);
insert into t_range_hash values(1,100,3,4);
insert into t_range_hash values(1,200,3,4);
insert into t_range_hash values(100,2,3,4);
insert into t_range_hash values(100,100,3,4);
insert into t_range_hash values(100,200,3,4);
insert into t_range_hash values(200,2,3,4);
insert into t_range_hash values(200,100,3,4);
insert into t_range_hash values(200,200,3,4);
select * from t_range_hash;

# truncate partitions in same partition
alter table t_range_hash
truncate partition 
rp0,rp1;
select * from t_range_hash;

connection conn1;
let $table_id = `select table_id from oceanbase.__all_virtual_table where table_name='t_range_hash'`;
--disable_query_log
echo "query all_table";
eval select is_deleted, part_level, part_func_type, part_func_expr, part_num, sub_part_func_type, sub_part_func_expr, sub_part_num, partition_status, case when partition_schema_version > 0 then 1 else 0 end, sub_part_template_flags from oceanbase.__all_virtual_table_history where table_id = $table_id;

echo "query all_part";
eval select is_deleted, part_name, sub_part_num, high_bound_val, sub_part_num, list_val, part_idx from oceanbase.__all_virtual_part_history where table_id = $table_id;

echo "query all_sub_part";
eval select is_deleted, sub_part_name, high_bound_val, list_val, sub_part_idx from oceanbase.__all_virtual_sub_part_history where table_id = $table_id;


# 3. range_range
connection conn2;
# create table
create table t_range_range (c1 int, c2 int, c3 int, c4 int)
partition by range(c1)
subpartition by range(c2)
subpartition template
(
  subpartition rsp0 values less than (100),
  subpartition rsp1 values less than (200),
  subpartition rsp2 values less than (300)
)
(
  partition rp0 values less than (100),
  partition rp1 values less than (200),
  partition rp2 values less than (300)
);

# insert row
insert into t_range_range values(1,2,3,4);
insert into t_range_range values(1,100,3,4);
insert into t_range_range values(1,200,3,4);
insert into t_range_range values(100,2,3,4);
insert into t_range_range values(100,100,3,4);
insert into t_range_range values(100,200,3,4);
insert into t_range_range values(200,2,3,4);
insert into t_range_range values(200,100,3,4);
insert into t_range_range values(200,200,3,4);
select * from t_range_range;

# truncate partitions in same partition
alter table t_range_range
truncate partition 
rp0,rp1;
select * from t_range_range;

connection conn1;
let $table_id = `select table_id from oceanbase.__all_virtual_table where table_name='t_range_range'`;
--disable_query_log
echo "query all_table";
eval select is_deleted, part_level, part_func_type, part_func_expr, part_num, sub_part_func_type, sub_part_func_expr, sub_part_num, partition_status, case when partition_schema_version > 0 then 1 else 0 end, sub_part_template_flags from oceanbase.__all_virtual_table_history where table_id = $table_id;

echo "query all_part";
eval select is_deleted, part_name, sub_part_num, high_bound_val, sub_part_num, list_val, part_idx from oceanbase.__all_virtual_part_history where table_id = $table_id;

echo "query all_sub_part";
eval select is_deleted, sub_part_name, high_bound_val, list_val, sub_part_idx from oceanbase.__all_virtual_sub_part_history where table_id = $table_id;

# drop table
connection default;

drop table t_range_range;
drop table t_hash_range;
drop table t_range_hash;
drop user subpart_mgr@'%';
