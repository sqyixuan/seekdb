--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL2
# description: 验证同步建索引
# tags: ddl

# (1) 卷雪最初加的一波 case
--error 0,1051
drop table t_sync_idx;
create table t_sync_idx(c1 int, c2 int, c3 int);

create index idx_1 on t_sync_idx(c1);
show index from t_sync_idx;

insert into t_sync_idx values(1, 2, 3);
insert into t_sync_idx values(1, 2, 3);
insert into t_sync_idx values(11, 22, 33);

--error 1062
create unique index uk_idx on t_sync_idx(c2);
show index from t_sync_idx;

delete from t_sync_idx where c2=2;
create unique index uk_idx on t_sync_idx(c2);
show index from t_sync_idx;

### 不带索引名
alter table t_sync_idx add index(c1,c2);
show index from t_sync_idx;

#冲突数据
insert into t_sync_idx values(111, 222, 33);
--error 1062
alter table t_sync_idx add unique index(c3);
show index from t_sync_idx;

#
create index if not exists idx_1 on t_sync_idx(c1);


# (2) 允许 alter table 可以同时建多个索引，并可以同时与其他 alter table 的动作在一条 sql 中进行
--error 0,1051
drop table t1;
create table t1(c1 int, c2 int, c3 int);
insert into t1 values(1, 2, 3);
insert into t1 values(2, 4, 3);
--error 1062
alter table t1 add column c4 int, add unique(c1), add unique(c3), add unique(c2);
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
alter table t1 add index(c2), add index(c3);
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop table t1;

#（3）补充测试，alter table 中同时有增列、删列、改列和建索引
--error 0,1051
drop table t1;
create table t1(c1 int, c2 int);
alter table t1 drop column c2;
--error 1072
alter table t1 add index(c2);
alter table t1 add index(c3), add column c3 int;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop table t1;
create table t1(c1 varchar(10), c2 varchar(10));
alter table t1 add index(c1), modify c1 varchar(20);
# 不支持同时建索引并改列类型
--error 1167
alter table t1 add index(c2), modify c2 longtext;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop table t1;

#（3）补充测试，alter table 中同时有增、删前缀索引，曾经有过 bug，
create table t1(c1 varchar(1000), c2 int, key prefix_idx1(c1(255), c2));
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
show index from t1;
# add + drop
alter system set _enable_drop_and_add_index = true;
sleep 2;
alter table t1 add key prefix_idx2(c1(255)), drop key prefix_idx1;
alter system set _enable_drop_and_add_index = false;
sleep 2;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
show index from t1;
# drop + add
alter system set _enable_drop_and_add_index = true;
sleep 2;
alter table t1 drop index prefix_idx2, add key prefix_idx1(c1(255));
alter system set _enable_drop_and_add_index = false;
sleep 2;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
show index from t1;
# add + add
alter table t1 add key prefix_idx2(c1(255)), add key prefix_idx3(c1(255));
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
show index from t1;
# drop + drop
alter table t1 drop index prefix_idx2, drop index prefix_idx3;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
show index from t1;
# add + add + drop
alter system set _enable_drop_and_add_index = true;
sleep 2;
alter table t1 add key prefix_idx2(c1(255)), add key prefix_idx3(c1(255)), drop index prefix_idx1;
alter system set _enable_drop_and_add_index = false;
sleep 2;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
show index from t1;
# drop + drop + add
alter system set _enable_drop_and_add_index = true;
sleep 2;
alter table t1 drop index prefix_idx2, drop index prefix_idx3, add key prefix_idx1(c1(255));
alter system set _enable_drop_and_add_index = false;
sleep 2;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
show index from t1;
drop table t1;
