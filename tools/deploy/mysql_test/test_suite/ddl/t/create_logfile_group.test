# tag: ddl

create logfile group xx1 ADD UNDOFILE 'filename';
create logfile group xx1 ADD UNDOFILE 'filename' INITIAL_SIZE = 100 UNDO_BUFFER_SIZE = 10, NODEGROUP = 1;

alter logfile group xx1 ADD UNDOFILE 'filename';
alter logfile group xx1 ADD UNDOFILE 'filename' INITIAL_SIZE = 100 STORAGE ENGINE=abc NO_WAIT;
alter logfile group xx1 ADD UNDOFILE 'filename' INITIAL_SIZE = 100 STORAGE ENGINE='abc' NO_WAIT;

drop logfile group xx1;
drop logfile group xx1 STORAGE ENGINE='abc' WAIT;
