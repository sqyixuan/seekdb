--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
#description: create index on no primary key partitioned table, we will storing partition column in index

--enable_abort_on_error
--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings
# create index during create table
create table t1(c1 int,c2 int, c3 int, c4 int, c5 int,
                index idxt1_1(c2) local,
                unique index idxt1_2(c3) global,
                index idxt1_3(c4) local storing(c1),
                index idxt1_4(c5) global storing(c1))
partition by hash (c1) partitions 3;
show create table t1;
select column_name, is_hidden from oceanbase.__all_column c, oceanbase.__all_table t 
where t.table_name like '%idxt1_1' and t.table_id = c.table_id;
select column_name, is_hidden from oceanbase.__all_column c, oceanbase.__all_table t 
where t.table_name like '%idxt1_2' and t.table_id = c.table_id;
select column_name, is_hidden from oceanbase.__all_column c, oceanbase.__all_table t 
where t.table_name like '%idxt1_3' and t.table_id = c.table_id;
select column_name, is_hidden from oceanbase.__all_column c, oceanbase.__all_table t 
where t.table_name like '%idxt1_4' and t.table_id = c.table_id;

# create index after create table
create table t2(c1 int,c2 int, c3 int, c4 int, c5 int) partition by hash (c1) partitions 3;
create index idxt2_1 on t2 (c2) local;
create index idxt2_2 on t2 (c3) global;
create index idxt2_3 on t2 (c4) local storing(c1);
create unique index idxt2_4 on t2 (c5) global storing(c1);
show create table t2;
select column_name, is_hidden from oceanbase.__all_column c, oceanbase.__all_table t 
where t.table_name like '%idxt2_1' and t.table_id = c.table_id;
select column_name, is_hidden from oceanbase.__all_column c, oceanbase.__all_table t 
where t.table_name like '%idxt2_2' and t.table_id = c.table_id;
select column_name, is_hidden from oceanbase.__all_column c, oceanbase.__all_table t 
where t.table_name like '%idxt2_3' and t.table_id = c.table_id;
select column_name, is_hidden from oceanbase.__all_column c, oceanbase.__all_table t 
where t.table_name like '%idxt2_4' and t.table_id = c.table_id;

# create index in alter table
create table t3(c1 int,c2 int, c3 int, c4 int, c5 int) partition by hash (c1) partitions 3;
alter table t3 add index idxt3_1 (c2) local;
alter table t3 add index idxt3_2 (c3) global;
alter table t3 add index idxt3_3 (c4) local storing(c1);
alter table t3 add index idxt3_4 (c5) global storing(c1);
show create table t3;
select column_name, is_hidden from oceanbase.__all_column c, oceanbase.__all_table t 
where t.table_name like '%idxt3_1' and t.table_id = c.table_id;
select column_name, is_hidden from oceanbase.__all_column c, oceanbase.__all_table t 
where t.table_name like '%idxt3_2' and t.table_id = c.table_id;
select column_name, is_hidden from oceanbase.__all_column c, oceanbase.__all_table t 
where t.table_name like '%idxt3_3' and t.table_id = c.table_id;
select column_name, is_hidden from oceanbase.__all_column c, oceanbase.__all_table t 
where t.table_name like '%idxt3_4' and t.table_id = c.table_id;

drop table t1,t2,t3;
