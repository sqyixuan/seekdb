--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: xingrui.cwh
#owner group: rs
#description
#   The case is meant to verify tablegroup with sharding attribution
#    CASE 1: verify tablegroup sharding with 'NONE'
#         1.1 alter tablegroup sharding into other when tablegroup is empty
#         1.2 add different level partition table into tablegroup
#    CASE 2: verify tablegroup sharding with 'PARTITION'
#         2.1 add different level partition table into tablegroup
#         2.2 alter table partition when table are more than two in tablegroup
#    CASE 3: verify tablegroup sharding with 'ADAPTIVE'
#         3.1 add different level partition table into tablegroup
#         3.2 alter table partition when table are more than two in tablegroup
#    CASE 4.verify can not modify sys tablegroup oceanbase
#    CASE 5.avoid level one table's subpart num is not zero
#    CASE 6.template table and template table add tabelgroup
#    CASE 7.level one value/character/parition key not the same
#    CASE 8.alter partitioned/non-partitioned table in tablegroup to non-partitioned/partitioned table
#    CASE 9.add extra case
#    CASE 10.verify sys tablegroup and user tablegroup
connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connection sys_conn;

--disable_warnings
--disable_query_log
--disable_result_log
let $TABLE_CNT = 1;
while ($TABLE_CNT != 13 )
{
  eval DROP TABLE IF EXISTS xingrui_table$TABLE_CNT;
  inc $TABLE_CNT;
}
let $GROUP_CNT = 1;
while ($GROUP_CNT != 7)
{
  eval DROP TABLE IF EXISTS xingrui_test$GROUP_CNT;
  inc $GROUP_CNT;
}
DROP TABLE IF EXISTS xingrui_tbl1_h,xingrui_tbl2_h;
let $GROUP_CNT = 1;
while ($GROUP_CNT != 11)
{
  eval DROP TABLEGROUP IF EXISTS xingrui_tg$GROUP_CNT;
  inc $GROUP_CNT;
}
--enable_warnings
--enable_query_log
--enable_result_log

# 1、sharding = ‘NONE’
CREATE TABLE xingrui_test1(col int);
CREATE TABLE xingrui_table1(col1 int,col2 int) PARTITION BY RANGE(col1) SUBPARTITION BY RANGE(col2) SUBPARTITION TEMPLATE (SUBPARTITION mp0 VALUES LESS THAN(2020), SUBPARTITION mp1 VALUES LESS THAN(2021), SUBPARTITION mp2 VALUES LESS THAN(2022)) (PARTITION p0 VALUES LESS THAN(100), PARTITION p1 VALUES LESS THAN(200));
CREATE TABLE xingrui_table2(col1 int,col2 int) PARTITION BY RANGE(col1) SUBPARTITION BY RANGE(col2) SUBPARTITION TEMPLATE (SUBPARTITION mp0 VALUES LESS THAN(2020), SUBPARTITION mp1 VALUES LESS THAN(2021), SUBPARTITION mp2 VALUES LESS THAN(2022)) (PARTITION p0 VALUES LESS THAN(100), PARTITION p1 VALUES LESS THAN(200));
CREATE TABLEGROUP xingrui_tg1 sharding = 'NONE';

# 1.1
ALTER TABLEGROUP xingrui_tg1 sharding = 'PARTITION';
ALTER TABLEGROUP xingrui_tg1 sharding = 'ADAPTIVE';
ALTER TABLEGROUP xingrui_tg1 sharding = 'NONE';

# 1.2
ALTER TABLEGROUP xingrui_tg1 add xingrui_test1,xingrui_table1,xingrui_table2;
# can not change sharding from 'NONE' to other type when tablegroup has level zero and other level tables
--error 4179
ALTER TABLEGROUP xingrui_tg1 sharding = 'PARTITION';
--error 4179
ALTER TABLEGROUP xingrui_tg1 sharding = 'ADAPTIVE';

# 2、sharding = 'PARTITION'
# 2.1
ALTER TABLE xingrui_test1 tablegroup = '';
ALTER TABLE xingrui_table1 tablegroup = '';
ALTER TABLE xingrui_table2 tablegroup = '';
ALTER TABLEGROUP xingrui_tg1 sharding = 'PARTITION';
ALTER TABLEGROUP xingrui_tg1 ADD xingrui_table1,xingrui_table2;

# 2.2
# can not add level zero table to not 'NONE' tablegroup when other tables' level is not zero in tablegroup
--error 4179
ALTER TABLEGROUP xingrui_tg1 add xingrui_test1;
ALTER TABLE xingrui_table1 ADD PARTITION (PARTITION p3 VALUES LESS THAN(400), PARTITION p4 VALUES LESS THAN(500));
ALTER TABLE xingrui_table2 DROP SUBPARTITION p0smp0,p0smp1;
# after add partition,try to add new table
CREATE TABLE xingrui_table5(col1 int,col2 int) PARTITION BY RANGE(col1) SUBPARTITION BY RANGE(col2) SUBPARTITION TEMPLATE (SUBPARTITION mp0 VALUES LESS THAN(2020), SUBPARTITION mp1 VALUES LESS THAN(2021), SUBPARTITION mp2 VALUES LESS THAN(2022)) (PARTITION p0 VALUES LESS THAN(100), PARTITION p1 VALUES LESS THAN(200));
--error 4179
ALTER TABLEGROUP xingrui_tg1 ADD xingrui_table5;
# table1 and table2 is not the same at level one and level two partition, so it can not change to 'ADAPTIVE'
--error 4179
ALTER TABLEGROUP xingrui_tg1 sharding = 'ADAPTIVE';
ALTER TABLEGROUP xingrui_tg1 sharding = 'NONE';

# 3、sharding = 'ADAPTIVE'
# 3.1
DROP table xingrui_table1;
DROP table xingrui_table2;
ALTER TABLEGROUP xingrui_tg1 sharding = 'ADAPTIVE';

CREATE TABLE xingrui_table1(col1 int,col2 int) PARTITION BY RANGE(col1) SUBPARTITION BY RANGE(col2) SUBPARTITION TEMPLATE (SUBPARTITION mp0 VALUES LESS THAN(2020), SUBPARTITION mp1 VALUES LESS THAN(2021), SUBPARTITION mp2 VALUES LESS THAN(2022)) (PARTITION p0 VALUES LESS THAN(100), PARTITION p1 VALUES LESS THAN(200));
CREATE TABLE xingrui_table2(col1 int,col2 int) PARTITION BY RANGE(col1) SUBPARTITION BY RANGE(col2) SUBPARTITION TEMPLATE (SUBPARTITION mp0 VALUES LESS THAN(2020), SUBPARTITION mp1 VALUES LESS THAN(2021), SUBPARTITION mp2 VALUES LESS THAN(2022)) (PARTITION p0 VALUES LESS THAN(100), PARTITION p1 VALUES LESS THAN(200));
ALTER TABLEGROUP xingrui_tg1 ADD xingrui_table1,xingrui_table2;

# 3.2
ALTER TABLE xingrui_table2 DROP SUBPARTITION p0smp0,p0smp1;
# can not add level zero table
--error 4179
ALTER TABLE xingrui_test1 tablegroup = 'xingrui_tg1';
ALTER TABLEGROUP xingrui_tg1 sharding = 'PARTITION';
ALTER TABLEGROUP xingrui_tg1 sharding = 'NONE';

# 4.can not modify sys tablegroup oceanbase
--error 4179
ALTER table xingrui_test1 tablegroup = 'oceanbase';

--error 4179
ALTER tablegroup oceanbase ADD xingrui_test1;

# 5.avoid level one table's subpart num is not zero
CREATE TABLEGROUP xingrui_tg2;
CREATE TABLE xingrui_tbl1_h(col1 INT,col2 VARCHAR(50)) tablegroup = xingrui_tg2
       PARTITION BY HASH(col1) PARTITIONS 60;
CREATE TABLE xingrui_tbl2_h(col1 INT,col2 VARCHAR(50)) tablegroup = xingrui_tg2
       PARTITION BY HASH(col1) PARTITIONS 60;

# 6.template table and template table add tabelgroup
# 6.1 same table in template and not template
CREATE TABLEGROUP xingrui_tg3;
CREATE TABLE xingrui_table3(col1 int,col2 int) PARTITION BY RANGE(col1) SUBPARTITION BY RANGE(col2)
        (PARTITION p0 VALUES LESS THAN(100)
           (SUBPARTITION mp0 VALUES LESS THAN(2020),
            SUBPARTITION mp1 VALUES LESS THAN(2021),
            SUBPARTITION mp2 VALUES LESS THAN(2022)
           ),
         PARTITION p1 VALUES LESS THAN(200)
           (SUBPARTITION mp3 VALUES LESS THAN(2020),
            SUBPARTITION mp4 VALUES LESS THAN(2021),
            SUBPARTITION mp5 VALUES LESS THAN(2022)
            )
         );
ALTER TABLEGROUP xingrui_tg3 ADD xingrui_table1;
ALTER TABLEGROUP xingrui_tg3 ADD xingrui_table3;

# 6.2 different table in template and not template
ALTER TABLE xingrui_table3 tablegroup = '';
CREATE TABLE xingrui_table4(col1 int,col2 int) PARTITION BY RANGE(col1) SUBPARTITION BY RANGE(col2)
        (PARTITION p0 VALUES LESS THAN(100)
           (SUBPARTITION mp0 VALUES LESS THAN(2021),
            SUBPARTITION mp1 VALUES LESS THAN(2022),
            SUBPARTITION mp2 VALUES LESS THAN(2023)
           ),
         PARTITION p1 VALUES LESS THAN(200)
           (SUBPARTITION mp3 VALUES LESS THAN(2021),
            SUBPARTITION mp4 VALUES LESS THAN(2022),
            SUBPARTITION mp5 VALUES LESS THAN(2023)
            )
         );
#same table in tablegroup will ignore
ALTER TABLEGROUP xingrui_tg3 ADD xingrui_table1;
--error 4179
ALTER TABLEGROUP xingrui_tg3 ADD xingrui_table4;

# 7.level one value/parition key count not the same
DROP TABLE xingrui_tbl1_h,xingrui_tbl2_h;
CREATE TABLEGROUP xingrui_tg4 sharding = 'PARTITION';
CREATE TABLE xingrui_table6(col1 varchar(50),col2 varchar(50)) tablegroup = xingrui_tg4
       PARTITION BY LIST COLUMNS(col2)
        (PARTITION p0 VALUES in ('01','02'),
         PARTITION p1 VALUES in ('03','04')
        );
# different character
CREATE TABLE xingrui_table7(col1 varchar(50),col2 varchar(50) CHARACTER SET GBK COLLATE gbk_chinese_ci)
       PARTITION BY LIST COLUMNS(col2)
        (PARTITION p0 VALUES in ('01','02'),
         PARTITION p1 VALUES in ('03','04')
        );
# different value count
CREATE TABLE xingrui_table8(col1 varchar(50),col2 varchar(50))
       PARTITION BY LIST COLUMNS(col2)
        (PARTITION p0 VALUES in ('01'),
         PARTITION p1 VALUES in ('03')
        );
# different value order
CREATE TABLE xingrui_table9(col1 varchar(50),col2 varchar(50))
       PARTITION BY LIST COLUMNS(col2)
        (PARTITION p0 VALUES in ('02','01'),
         PARTITION p1 VALUES in ('04','03')
        );
# different value
CREATE TABLE xingrui_table10(col1 varchar(50),col2 varchar(50))
       PARTITION BY LIST COLUMNS(col2)
        (PARTITION p0 VALUES in ('01','03'),
         PARTITION p1 VALUES in ('04','05')
        );
# different partition count
CREATE TABLE xingrui_table11(col1 varchar(50),col2 varchar(50))
       PARTITION BY LIST COLUMNS(col2)
        (PARTITION p0 VALUES in ('01','02'),
         PARTITION p1 VALUES in ('03','04'),
         PARTITION p2 VALUES in ('05','06')
        );
# different partition key count
CREATE TABLE xingrui_table12(col1 varchar(50),col2 varchar(50))
       PARTITION BY LIST COLUMNS(col1,col2)
        (PARTITION p0 VALUES in (('01','02')),
         PARTITION p1 VALUES in (('03','04'))
        );
--error 4179
ALTER TABLEGROUP xingrui_tg4 ADD xingrui_table7;
--error 4179
ALTER TABLEGROUP xingrui_tg4 ADD xingrui_table8;
ALTER TABLEGROUP xingrui_tg4 ADD xingrui_table9;
--error 4179
ALTER TABLEGROUP xingrui_tg4 ADD xingrui_table10;
--error 4179
ALTER TABLEGROUP xingrui_tg4 ADD xingrui_table11;
--error 4179
ALTER TABLEGROUP xingrui_tg4 ADD xingrui_table12;

# 8
# 8.1 alter non-partitioned table to partitioned table
CREATE TABLEGROUP xingrui_tg5;
ALTER TABLE xingrui_test1 tablegroup = 'xingrui_tg5';
--error 4179
ALTER TABLE xingrui_test1 partition by hash(col) partitions 4;

# 8.2 alter parition level
DROP TABLE xingrui_test1;
CREATE TABLE xingrui_test1(c1 int primary key, c2 int) tablegroup = "xingrui_tg5" partition by range(c1) subpartition by hash(c1)
subpartitions 2 (
partition p0 values less than (100),
partition p1 values less than (maxvalue));
--error 4179
ALTER TABLE xingrui_test1 partition by hash(c1) partitions 4;

# 9 extra addition
# 9.1 different sharding add non-partitioned table
DROP TABLE xingrui_test1;
CREATE TABLE xingrui_test1(col int);
CREATE TABLEGROUP xingrui_tg6 sharding = "PARTITION";
ALTER TABLE xingrui_test1 tablegroup = 'xingrui_tg6';
CREATE TABLE xingrui_test2(col int) tablegroup = 'xingrui_tg6';

CREATE TABLEGROUP xingrui_tg7 sharding = "ADAPTIVE";
ALTER TABLE xingrui_test1 tablegroup = 'xingrui_tg7';
CREATE TABLE xingrui_test3(col int) tablegroup = 'xingrui_tg7';

# 9.2 ADAPTIVE add one level and cannot add two level/non-paritioned
CREATE TABLEGROUP xingrui_tg8 sharding = "ADAPTIVE";
CREATE TABLE xingrui_test4(col1 varchar(50),col2 varchar(50))
      tablegroup = 'xingrui_tg8'
       PARTITION BY LIST COLUMNS(col2)
        (PARTITION p0 VALUES in ('01','02'),
         PARTITION p1 VALUES in ('03','04'),
         PARTITION p2 VALUES in ('05','06')
        );

--error 4179
ALTER TABLE xingrui_test1 tablegroup = 'xingrui_tg8';
CREATE TABLE xingrui_test5(c1 int primary key, c2 int) tablegroup = "xingrui_tg5" partition by range(c1) subpartition by hash(c1)
subpartitions 2 (
partition p0 values less than (100),
partition p1 values less than (maxvalue));

--error 4179
ALTER TABLE xingrui_test5 tablegroup = 'xingrui_tg8';

# 9.3 ADAPTIVE add tow level and cannot add one level/non-partitioned
CREATE TABLEGROUP xingrui_tg9 sharding = "ADAPTIVE";
ALTER TABLE xingrui_test5 tablegroup = 'xingrui_tg9';

--error 4179
ALTER TABLE xingrui_test4 tablegroup = 'xingrui_tg9';
--error 4179
ALTER TABLE xingrui_test1 tablegroup = 'xingrui_tg9';

# 10.verify sys tablegroup and user tablegroup
CREATE TABLEGROUP xingrui_tg10 sharding = "ADAPTIVE";
# 10.1 user table cannot add to sys tablegroup
--error 4179
CREATE TABLE xingrui_test6(col int) tablegroup = 'oceanbase';
CREATE TABLE xingrui_test6(col int);
--error 4179
ALTER TABLE xingrui_test6 tablegroup = 'oceanbase';

# 10.2 alter inner table cannot add to user tablegroup
--error 4179
ALTER TABLE __all_table tablegroup = 'xingrui_tg10';

# 10.3 alter sys tablegroup cannot add user table
--error 4179
ALTER TABLEGROUP oceanbase add xingrui_test6;

# 10.4 alter user tablegroup cannot add sys table
--error 4179
ALTER TABLEGROUP xingrui_tg10 add __all_table;

let $TABLE_CNT = 1;
while ($TABLE_CNT != 7 )
{
  eval DROP TABLE xingrui_test$TABLE_CNT;
  inc $TABLE_CNT;
}
let $TABLE_CNT = 1;
while ($TABLE_CNT != 13 )
{
  eval DROP TABLE xingrui_table$TABLE_CNT;
  inc $TABLE_CNT;
}
let $GROUP_CNT = 1;
while ($GROUP_CNT != 11 )
{
  eval DROP TABLEGROUP xingrui_tg$GROUP_CNT;
  inc $GROUP_CNT;
}
