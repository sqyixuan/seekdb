drop user subpart_mgr@'%';
create user subpart_mgr identified by '123';
grant all on *.* to subpart_mgr WITH GRANT OPTION;
set @@recyclebin = off;
result_format: 4




create table t_hash_range (c1 int, c2 int, c3 int, c4 int)
partition by hash(c1)
subpartition by range(c2)
(
  partition hp0
  (
    subpartition hp0sp0 values less than (100),
    subpartition hp0sp1 values less than (200),
    subpartition hp0sp2 values less than (300)
  ),
  partition hp1
  (
    subpartition hp1sp0 values less than (100),
    subpartition hp1sp1 values less than (200),
    subpartition hp1sp2 values less than (300)
  ),
  partition hp2
  (
    subpartition hp2sp0 values less than (100),
    subpartition hp2sp1 values less than (200),
    subpartition hp2sp2 values less than (300)
  ),
  partition hp3
  (
    subpartition hp3sp0 values less than (100),
    subpartition hp3sp1 values less than (200),
    subpartition hp3sp2 values less than (300)
  )
);

insert into t_hash_range values(1,2,3,4);
insert into t_hash_range values(1,100,3,4);
insert into t_hash_range values(1,200,3,4);
insert into t_hash_range values(100,2,3,4);
insert into t_hash_range values(100,100,3,4);
insert into t_hash_range values(100,200,3,4);
insert into t_hash_range values(200,2,3,4);
insert into t_hash_range values(200,100,3,4);
insert into t_hash_range values(200,200,3,4);
select * from t_hash_range;
+------+------+------+------+
| c1   | c2   | c3   | c4   |
+------+------+------+------+
|  100 |    2 |    3 |    4 |
|  200 |    2 |    3 |    4 |
|  100 |  100 |    3 |    4 |
|  200 |  100 |    3 |    4 |
|  100 |  200 |    3 |    4 |
|  200 |  200 |    3 |    4 |
|    1 |    2 |    3 |    4 |
|    1 |  100 |    3 |    4 |
|    1 |  200 |    3 |    4 |
+------+------+------+------+

alter table t_hash_range
truncate subpartition 
hp0sp0,hp0sp1;
select * from t_hash_range;
+------+------+------+------+
| c1   | c2   | c3   | c4   |
+------+------+------+------+
|  100 |  200 |    3 |    4 |
|  200 |  200 |    3 |    4 |
|    1 |    2 |    3 |    4 |
|    1 |  100 |    3 |    4 |
|    1 |  200 |    3 |    4 |
+------+------+------+------+

alter table t_hash_range
truncate subpartition 
hp1sp1,hp2sp1,hp1sp2,hp2sp2;
select * from t_hash_range;
