create table t_range_hash (c1 int, c2 int, c3 int, c4 int)
partition by range(c1)
subpartition by hash(c2)
(
  partition rp0 values less than (100)
  (
    subpartition rp0sp0,
    subpartition rp0sp1,
    subpartition rp0sp2,
    subpartition rp0sp3
  ),
  partition rp1 values less than (200)
  (
    subpartition rp1sp0,
    subpartition rp1sp1,
    subpartition rp1sp2,
    subpartition rp1sp3
  ),
  partition rp2 values less than (300)
  (
    subpartition rp2sp0,
    subpartition rp2sp1,
    subpartition rp2sp2,
    subpartition rp2sp3
  )
);

