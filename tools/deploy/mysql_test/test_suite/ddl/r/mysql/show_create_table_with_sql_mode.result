drop database if exists luofan_db;
create database luofan_db;
use luofan_db;
create table t1 (c1 int primary key auto_increment, c2 int zerofill, c3 varchar(64) CHARACTER SET utf8 collate utf8_unicode_ci, c4 int not null, c5 int default 10, c6 timestamp ON UPDATE CURRENT_TIMESTAMP, c7 varchar(64) comment 'is comment', c8 varchar(64) generated always as (c3)) CHARACTER SET gbk;
