drop database if exists ziqian_subpart_add_dup_name;
create database ziqian_subpart_add_dup_name;
use ziqian_subpart_add_dup_name;
set recyclebin = off;
create table t1 (c1 int, c2 int)
partition by range(c1)
subpartition by range(c2)
(
partition p0 values less than (100)
(
subpartition sp0 values less than (2020),
subpartition sp1 values less than (2021)
),
partition p1 values less than (200)
(
subpartition sp0 values less than (2022),
subpartition sp1 values less than (2023)
)
);
ERROR HY000: Duplicate partition name sp0
create table t2 (c1 int, c2 int)
partition by range(c1)
subpartition by range(c2)
(
partition p0 values less than (100)
(
subpartition sp0 values less than (2020),
subpartition sp1 values less than (2021)
),
partition p1 values less than (200)
(
subpartition sp2 values less than (2022),
subpartition sp3 values less than (2023)
)
);
alter table t2 modify partition p0 add subpartition
(
subpartition sp0 values less than (2024)
);
ERROR HY000: Duplicate partition name sp0
alter table t2 modify partition p1 add subpartition
(
subpartition sp0 values less than (2025)
);
ERROR HY000: Duplicate partition name sp0
create table t3 (c1 int, c2 int)
partition by range(c1)
subpartition by range(c2)
subpartition template
(
subpartition p0 values less than (2020),
subpartition p1 values less than (2021)
)
(
partition p0 values less than (100),
partition p1 values less than (200)
);
alter table t3 modify partition p0 add subpartition
(
subpartition p0sp0 values less than (2024)
);
ERROR HY000: Duplicate partition name p0sp0
alter table t3 modify partition p1 add subpartition
(
subpartition p0sp0 values less than (2025)
);
ERROR HY000: Duplicate partition name p0sp0
drop database ziqian_subpart_add_dup_name;
