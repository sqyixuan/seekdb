drop table if exists t;
drop table if exists t1;
create table t (c1 int, c2 int, c3 int, c4 int, c5 int, c6 varchar(20), c7 int, c8 int, c9 int generated always as (c7+c8) stored, primary key(c1, c2, c3));
create table t1(a int, b int, primary key(a));
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
create index t_c4 on t (c4) storing(c5);
create index t_c9 on t (c9);
create index t_c6 on t (c6);
alter table t modify column c1 bigint;
alter table t change column c1 c10 bigint;
alter table t1 change column a c bigint;
alter table t modify column c4 bigint;
alter table t change column c4 c4 bigint;
alter table t modify column c5 bigint;
alter table t change column c5 c5 bigint;
alter table t modify column c7 bigint;
alter table t change column c7 c7 bigint;
alter table t modify column c6 varchar(30);
alter table t modify column c6 varchar(16385);
ERROR 42000: Specified key was too long; max key length is 16384 bytes
drop table t;
drop table t1;
