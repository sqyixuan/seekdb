drop database if exists luofan_db;
create database luofan_db;
use luofan_db;
#测试alter table table_name character set = charset_name COLLATE = collation_name;
#修改表的collation和字符集，只对修改之后新加的列生效，不改变已有的列(online的方式)
create table luofan_t1 (c1 varchar(64), c2 varchar(64), c3 enum('a', 'b'), c4 set('a', 'b'), c5 int);
insert into luofan_t1 values ('aa', 'bb', 'a', 'b', 1);
insert into luofan_t1 values ('aa', 'bb', 'a', 'b', 1);
insert into luofan_t1 values ('aa', 'bb', 'a', 'b', 1);
select table_name, collation_type from oceanbase.__all_table where table_name = 'luofan_t1';
table_name	collation_type
luofan_t1	45
select column_name, collation_type from oceanbase.__all_column where table_id = (select table_id from oceanbase.__all_table where table_name = 'luofan_t1') order by 1 asc;
column_name	collation_type
c1	45
c2	45
c3	45
c4	45
c5	63
__pk_increment	63
alter table luofan_t1 character set = utf8mb4 COLLATE = utf8mb4_bin;
#预期表级collation_type发生变化
select table_name, collation_type from oceanbase.__all_table where table_name = 'luofan_t1';
table_name	collation_type
luofan_t1	46
#预期已经存在的列collation_type不发生变化
select column_name, collation_type from oceanbase.__all_column where table_id = (select table_id from oceanbase.__all_table where table_name = 'luofan_t1') order by 1 asc;
column_name	collation_type
c1	45
c2	45
c3	45
c4	45
c5	63
__pk_increment	63
#添加新的列，预期新添加的列collation_type发生变化跟表级一致
alter table luofan_t1 add column c6 varchar(64);
select column_name, collation_type from oceanbase.__all_column where table_id = (select table_id from oceanbase.__all_table where table_name = 'luofan_t1') order by 1 asc;
column_name	collation_type
c1	45
c2	45
c3	45
c4	45
c5	63
c6	46
__pk_increment	63
drop table luofan_t1;
#测试alter table table_name CONVERT TO CHARACTER SET charset_name COLLATE collation_name;
#修改表中已有数据的字符集和collation，并修改对应的设置(offline的方式)
create table luofan_t1 (c1 varchar(64), c2 varchar(64), c3 enum('a', 'b'), c4 set('a', 'b'), c5 int);
insert into luofan_t1 values ('aa', 'bb', 'a', 'b', 1);
insert into luofan_t1 values ('aa', 'bb', 'a', 'b', 1);
insert into luofan_t1 values ('aa', 'bb', 'a', 'b', 1);
select table_name, collation_type from oceanbase.__all_table where table_name = 'luofan_t1';
table_name	collation_type
luofan_t1	45
select column_name, collation_type from oceanbase.__all_column where table_id = (select table_id from oceanbase.__all_table where table_name = 'luofan_t1') order by 1 asc;
column_name	collation_type
c1	45
c2	45
c3	45
c4	45
c5	63
__pk_increment	63
alter table luofan_t1 convert to character set "binary" collate "binary";
alter table luofan_t1 convert to character set utf8mb4 collate utf8mb4_bin;
#预期表级collation_type发生变化
select table_name, collation_type from oceanbase.__all_table where table_name = 'luofan_t1';
table_name	collation_type
luofan_t1	46
# binary相关的列不会变化collation
select column_name, collation_type from oceanbase.__all_column where table_id = (select table_id from oceanbase.__all_table where table_name = 'luofan_t1') order by 1 asc;
column_name	collation_type
c1	63
c2	63
c3	63
c4	63
c5	63
__pk_increment	63
#添加新的列，预期新添加的列collation_type发生变化跟表级一致
alter table luofan_t1 add column c6 varchar(64);
select column_name, collation_type from oceanbase.__all_column where table_id = (select table_id from oceanbase.__all_table where table_name = 'luofan_t1') order by 1 asc;
column_name	collation_type
c1	63
c2	63
c3	63
c4	63
c5	63
c6	46
__pk_increment	63
alter table luofan_t1 convert to character set 'binary';
drop table luofan_t1;
#测试修改表中已有数据的字符集和collation，表中外键列不是string类型，修改成功
create table luofan_t1 (c1 int primary key, c2 varchar(64));
create table luofan_t2 (c1 int primary key, c2 varchar(64), constraint fk_1 foreign key(c1) references luofan_t1(c1));
insert into luofan_t1 values (1, '1');
insert into luofan_t2 values (1, '1');
alter table luofan_t2 convert to character set "binary" collate "binary";
drop table luofan_t2;
drop table luofan_t1;
#测试修改列已有数据的字符集和collation，修改列不是外键列，修改成功
create table luofan_t1 (c1 int primary key, c2 varchar(64));
create table luofan_t2 (c1 int primary key, c2 varchar(64), constraint fk_1 foreign key(c1) references luofan_t1(c1));
insert into luofan_t1 values (1, '1');
insert into luofan_t2 values (1, '1');
alter table luofan_t2 modify c2 varchar(64) character set "binary" collate "binary";
drop table luofan_t2;
drop table luofan_t1;
#测试修改表中已有数据的字符集和collation，表中外键列是string类型，应该修改失败
create table luofan_t1 (c1 int, c2 varchar(64) unique);
create table luofan_t2 (c1 int, c2 varchar(64) unique, constraint fk_1 foreign key(c2) references luofan_t1(c2));
insert into luofan_t1 values (1, '1');
insert into luofan_t2 values (1, '1');
alter table luofan_t2 convert to character set "binary" collate "binary";
ERROR 0A000: Alter column charset or collation with foreign key not supported
drop table luofan_t2;
drop table luofan_t1;
#测试修改列已有数据的字符集和collation，修改列是外键列并且是string类型，应该修改失败
create table luofan_t1 (c1 int, c2 varchar(64) unique);
create table luofan_t2 (c1 int, c2 varchar(64) unique, constraint fk_1 foreign key(c2) references luofan_t1(c2));
insert into luofan_t1 values (1, '1');
insert into luofan_t2 values (1, '1');
alter table luofan_t2 modify c2 varchar(64) character set "binary" collate "binary";
ERROR 0A000: Alter column charset or collation with foreign key not supported
drop table luofan_t2;
drop table luofan_t1;
drop database luofan_db;
