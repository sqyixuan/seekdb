>>>> rename column with foreign key
create table rename_t (a int primary key, b int);
create table foreign_t (c int, foreign key (c) references rename_t(a));

insert into rename_t values (1, 1);
insert into foreign_t values (1);
insert into foreign_t values (2);
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails

alter table rename_t rename column a to c;

insert into foreign_t values (3);
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
insert into rename_t values (3, 3);
insert into foreign_t values (3);

select * from foreign_t;
+------+
| c    |
+------+
|    1 |
|    3 |
+------+

drop table foreign_t;
drop table rename_t;

>>>> rename column with view
drop view if exists rename_v;
create table rename_t (a int, b int);

insert into rename_t values (1, 1), (2, 2);
create view rename_v as select a + 1 as a0 from rename_t;
select * from rename_v;
+------+
| a0   |
+------+
|    2 |
|    3 |
+------+

alter table rename_t rename column a to c;
desc rename_t;
+-------+---------+------+-----+---------+-------+
| Field | Type    | Null | Key | Default | Extra |
+-------+---------+------+-----+---------+-------+
| c     | int(11) | YES  |     | NULL    |       |
| b     | int(11) | YES  |     | NULL    |       |
+-------+---------+------+-----+---------+-------+
select * from rename_v;
ERROR 42S22: View 'test.rename_v' references invalid table(s) or column(s) or function(s) or definer/invoker of view lack rights to use them

drop table rename_t;
drop view rename_v;

>>>> rename column with procedure
drop procedure if exists rename_fn;
create table rename_t (a int, b int);
insert into rename_t values (1, 1), (2, 2);

create procedure rename_fn() select a + 1 from rename_t;
call rename_fn();
+-------+
| a + 1 |
+-------+
|     2 |
|     3 |
+-------+

alter table rename_t rename column a to c;
desc rename_t;
+-------+---------+------+-----+---------+-------+
| Field | Type    | Null | Key | Default | Extra |
+-------+---------+------+-----+---------+-------+
| c     | int(11) | YES  |     | NULL    |       |
| b     | int(11) | YES  |     | NULL    |       |
+-------+---------+------+-----+---------+-------+

call rename_fn();
ERROR 42S22: Unknown column 'a' in 'field list'

drop table rename_t;
drop procedure rename_fn;

