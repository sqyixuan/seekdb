CREATE PROCEDURE p1()
BEGIN
   DECLARE numbers1,numbers2 INT;
   DECLARE rowcount1,rowcount2 INT;  
   DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
    GET CURRENT DIAGNOSTICS numbers1 = NUMBER,rowcount1 = ROW_COUNT;
    GET STACKED DIAGNOSTICS numbers2 = NUMBER,rowcount2 = ROW_COUNT;
    SELECT numbers1,rowcount1,numbers2,rowcount2;
    IF numbers1 = 0 THEN
      SELECT 'IF 分支,numbers1=',numbers1;
    ELSE
      SELECT 'ELSE 分支,numbers1=',numbers1;
    END IF ;
  END;
  SELECT * FROM tt1;
END;/

