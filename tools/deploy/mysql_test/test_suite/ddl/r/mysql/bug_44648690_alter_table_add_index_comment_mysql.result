result_format: 4
drop table if exists t1;
create table t1(c1 int, c2 int) comment 'table comment';
create index idx1 on t1(c1) comment 'index comment 1 ';
alter table t1 add index idx2(c2) comment 'index comment 2 ';
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  KEY `idx1` (`c1`) BLOCK_SIZE 16384 LOCAL COMMENT 'index comment 1 ',
  KEY `idx2` (`c2`) BLOCK_SIZE 16384 LOCAL COMMENT 'index comment 2 '
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10 COMMENT = 'table comment'
drop table t1;
