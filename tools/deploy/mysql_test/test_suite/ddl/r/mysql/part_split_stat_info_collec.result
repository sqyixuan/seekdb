drop table if exists t1;
create table t1 (id int, nid int, dob date, primary key(id)) partition by range(id) (partition p0 values less than (30), partition p1 values less than (40), partition p2 values less than (50));
create index tbl1_h_idx1 on t1(id) local;
create index tbl1_h_idx2 on t1(nid) local;
insert into t1 values (22, 23, '2023-06-12'), (33, 34, '2023-06-12'), (46, 47, '2023-06-13');
call dbms_stats.gather_table_stats('oceanbase', 't1', method_opt=>'FOR ALL COLUMNS SIZE 4');
