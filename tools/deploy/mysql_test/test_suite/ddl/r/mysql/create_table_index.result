drop table if exists contacts;
CREATE TABLE contacts (
id INT AUTO_INCREMENT PRIMARY KEY,
first_name VARCHAR(50) NOT NULL,
last_name VARCHAR(50) NOT NULL,
fullname varchar(101) GENERATED ALWAYS AS (CONCAT(first_name,' ',last_name)),
email VARCHAR(100) NOT NULL
);
insert into contacts(first_name, last_name, email) values('lemon', 'wonder', '163.com');
alter table contacts change first_name xing varchar(50);
insert into contacts(xing, last_name, email) values('happy', 'coding', 'outlook.com');
select * from contacts;
id	xing	last_name	fullname	email
1	lemon	wonder	lemon wonder	163.com
2	happy	coding	happy coding	outlook.com
drop table contacts;
drop table if exists employees;
CREATE TABLE employees (
id INT NOT NULL, 
fname VARCHAR(30), 
lname VARCHAR(30), 
hired DATE NOT NULL DEFAULT '1970-01-01', 
separated DATE NOT NULL DEFAULT '9999-12-31', 
job_code INT, 
store_id INT
)
PARTITION BY HASH(YEAR(hired)) 
PARTITIONS 4;
insert into employees(id, fname, lname, hired, separated, job_code, store_id) values(2, 'go', 'home', '1234-12-14', '4333-01-02', 3, 3);
update employees set store_id = 2 where hired = '1234-12-14';
alter table employees change column hired ruzhi DATE;
insert into employees(id, fname, lname, ruzhi, separated, job_code, store_id) values(1, 'lemon', 'tree', '1989-12-12', '9999-12-31', 1, 1);
update employees set fname = 'hello' where ruzhi = '1234-12-14';
replace into employees(id, fname, lname, ruzhi, separated, job_code, store_id) values(3, 'fse', 'fewfwe', '2002-09-14', '3333-08-24', 3, 3);
select * from employees;
id	fname	lname	ruzhi	separated	job_code	store_id
1	lemon	tree	1989-12-12	9999-12-31	1	1
2	hello	home	1234-12-14	4333-01-02	3	2
3	fse	fewfwe	2002-09-14	3333-08-24	3	3
