CREATE TABLE t1 (
pk int primary key,
b BINARY(36) DEFAULT(UUID_TO_BINARY(UUID())),
d DATE DEFAULT(CURRENT_TIMESTAMP + INTERVAL 1 YEAR),
i INT DEFAULT 0,
f float DEFAULT(rand() * rand()),
t TIMESTAMP(0) DEFAULT CURRENT_TIMESTAMP,
v VARCHAR(20) DEFAULT ''
);
