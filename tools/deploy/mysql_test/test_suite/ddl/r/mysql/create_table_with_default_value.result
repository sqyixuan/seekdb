decimal_col_with_expression_default DECIMAL(10,2) DEFAULT (ROUND(123.4567, 1)),
date_col_with_expression_default DATE DEFAULT (CURDATE()),
time_col_with_expression_default TIME DEFAULT (CURTIME()),
datetime_col_with_expression_default DATETIME DEFAULT (NOW() + INTERVAL 1 DAY),
weekday_name VARCHAR(9) DEFAULT (DAYNAME(CURRENT_DATE)),
first_day_of_current_year DATE DEFAULT (STR_TO_DATE(CONCAT(YEAR(NOW()), '-01-01'), '%Y-%m-%d'))
);
