"success!"
use lanyi_heap_table;
#测试修改主键列为null
"001--------------------------------------------------------------------------------------------------------"
ALTER TABLE test MODIFY c2 INT NULL;
ERROR 0A000: performing offline DDL operations on primary key columns or changing primary key columns to be NOT NULL in a heap table is not supported
#测试堆表drop主键
"002--------------------------------------------------------------------------------------------------------"
ALTER TABLE test drop primary key;
ERROR 0A000: can't DROP 'PRIMARY', DROP 'PRIMARY' in the heap organized table not supported
#测试堆表添加主键
"003--------------------------------------------------------------------------------------------------------"
ALTER TABLE test ADD PRIMARY KEY(c5, c2);
ERROR 0A000: add primary key in heap organized table not supported
#测试堆表drop主键列
"004--------------------------------------------------------------------------------------------------------"
alter table test drop column c1;
ERROR 0A000: dropping primary key columns in a heap table is not supported
#测试堆表修改主键列为自增列
"005--------------------------------------------------------------------------------------------------------"
alter table test modify column c1 int not null AUTO_INCREMENT;
ERROR 0A000: adding an autoincrement attribute to primary key column in a heap table is not supported
#测试堆表自动分裂
"006--------------------------------------------------------------------------------------------------------"
create table t1 (c1 int primary key, c2 int) ORGANIZATION HEAP partition by range();
ERROR 0A000: using auto-partition clause for heap organizated table is not supported
create table t1 (c1 int primary key, c2 int) ORGANIZATION HEAP partition by range('c1') size('128MB');
ERROR 0A000: using auto-partition clause for heap organizated table is not supported
create table t1 (c1 int primary key, c2 int) ORGANIZATION HEAP partition by range('c1');
ERROR 0A000: using auto-partition clause for heap organizated table is not supported
create table t1 (c1 int primary key, c2 int) ORGANIZATION HEAP partition by range();
ERROR 0A000: using auto-partition clause for heap organizated table is not supported
#测试修改主键列类型(非小改大)
"007--------------------------------------------------------------------------------------------------------"
alter table test modify column c1 BIGINT NOT NULL;
alter table test modify column c1 INT NOT NULL;
ERROR 0A000: performing offline DDL operations on primary key columns or changing primary key columns to be NOT NULL in a heap table is not supported
#测试修改主键列字符集或者字符顺序
"008--------------------------------------------------------------------------------------------------------"
alter table test modify c3 varchar(10) CHARACTER SET gbk COLLATE gbk_chinese_ci;
ERROR 0A000: performing offline DDL operations on primary key columns or changing primary key columns to be NOT NULL in a heap table is not supported
#测试列为主键
"009--------------------------------------------------------------------------------------------------------"
drop table if exists test_t;
create table test_t (c1 int, c2 int, c3 varchar(10), c4 int, c5 int) ORGANIZATION HEAP;
alter table test_t modify column c1 int PRIMARY KEY;
ERROR 0A000: performing offline DDL operations on primary key columns or changing primary key columns to be NOT NULL in a heap table is not supported
alter table test_t add primary key(c1);
ERROR 0A000: add primary key in heap organized table not supported
drop table test_t;
drop table test_idx;
#测试添加索引名与主键名重名或者rename重名
"009-1-------------------------------------------------------------------------------------------------------"
create index c1 on test(c1,c2) LOCAL;
ERROR 42000: Duplicate key name 'c1'
create index c1 on test(c1,c2) GLOBAL;
ERROR 42000: Duplicate key name 'c1'
alter table test add index c1(c1);
ERROR 0A000: can't add index 'c1'; add index with a name that is reserved by heap table is not supported
alter table test add index c1(c1);
ERROR 0A000: can't add index 'c1'; add index with a name that is reserved by heap table is not supported
alter table test drop index c1;
ERROR 0A000: can't drop index 'c1'; drop index with a name that is reserved by heap table is not supported
alter table test rename index c1 to c2;
ERROR 0A000: can't RENAME 'c1'; RENAME from a column/key that is reserved by heap table is is not supported
alter table test rename index c2 to c1;
ERROR 0A000: switch to another name; RENAME a column/key to a name that is reserved by heap table is not supported
drop index c1 on test;
ERROR 0A000: dropping index with a name reserved by the heap table is not supported
#堆表旁路导入测试
"0010--------------------------------------------------------------------------------------------------------"
use test;
alter system set direct_load_allow_fallback=False;
drop table if exists lineitem;
create table lineitem(
l_orderkey           bigint NOT NULL ,
l_partkey            bigint NOT NULL ,
l_suppkey            bigint NOT NULL ,
l_linenumber         bigint NOT NULL ,
l_quantity           bigint NOT NULL ,
l_extendedprice      decimal(10,2) NOT NULL ,
l_discount           decimal(10,2) NOT NULL ,
l_tax                decimal(10,2) NOT NULL ,
l_returnflag         char(1) ,
l_linestatus         char(1) ,
l_shipdate           date ,
l_commitdate         date ,
l_receiptdate        date ,
l_shipinstruct       char(25) ,
l_shipmode           char(10) ,
l_comment            varchar(44),
primary key(L_ORDERKEY, L_LINENUMBER)
) ORGANIZATION HEAP partition by hash(l_orderkey) partitions 10;
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
select count(*) from lineitem;
count(*)
100000
truncate table lineitem;
set autocommit = off;
insert into lineitem values (1,1,1,1,1,0,0,0,'a','b',0,0,0,1,1,'c');
set @@ob_query_timeout = 1000000*30, @@ob_trx_timeout=1000000*30;
ERROR HY000: Timeout
rollback;
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
select count(*) from lineitem;
count(*)
100000
drop table lineitem;
alter system set direct_load_allow_fallback=True;
use lanyi_heap_table;
