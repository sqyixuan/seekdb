alter system set default_table_organization = 'INDEX' tenant = all;
#测试视图展示堆表表组织模式organization
"000--------------------------------------------------------------------------------------------------------"
drop database if exists lanyi_heap_table;
create database lanyi_heap_table;
use lanyi_heap_table;
drop table if exists test;
create table test (c1 int, c2 int, c3 varchar(10), c4 int, c5 int, primary key(c1, c2, c3)) ORGANIZATION HEAP;
alter system set _enable_parallel_table_creation = false;
create table test_not_parallel (c1 int, c2 int, c3 varchar(10), c4 int, c5 int, primary key(c1, c2, c3)) ORGANIZATION HEAP;
alter system set _enable_parallel_table_creation = true;
create table test(c1 int primary key, c2 int, primary key (c1,c2)) ORGANIZATION HEAP;
ERROR 23000: Duplicated primary key
SET _show_ddl_in_compat_mode = 1;
show create table test;
Table	Create Table
test	CREATE TABLE `test` (
  `c1` int(11) NOT NULL,
  `c2` int(11) NOT NULL,
  `c3` varchar(10) NOT NULL,
  `c4` int(11) DEFAULT NULL,
  `c5` int(11) DEFAULT NULL,
  PRIMARY KEY (`c1`, `c2`, `c3`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC
SET _show_ddl_in_compat_mode = 0;
show create table test;
Table	Create Table
test	CREATE TABLE `test` (
  `c1` int(11) NOT NULL,
  `c2` int(11) NOT NULL,
  `c3` varchar(10) NOT NULL,
  `c4` int(11) DEFAULT NULL,
  `c5` int(11) DEFAULT NULL,
  PRIMARY KEY (`c1`, `c2`, `c3`)
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
drop table if exists test_idx;
create table test_idx (c1 int, c2 int, c3 varchar(10), c4 int, c5 int, primary key(c1, c2, c3));
show create table test_idx;
Table	Create Table
test_idx	CREATE TABLE `test_idx` (
  `c1` int(11) NOT NULL,
  `c2` int(11) NOT NULL,
