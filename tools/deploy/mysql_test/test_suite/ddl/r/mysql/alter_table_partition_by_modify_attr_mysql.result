#测试 alter table t_split partition by range() size('xxx');
"001--------------------------------------------------------------------------------------------------------"
drop table if exists t_split;
create table t_split(c1 int, c2 int, primary key(c1));
alter table t_split partition by range() size('20GB');
show create table t_split;
