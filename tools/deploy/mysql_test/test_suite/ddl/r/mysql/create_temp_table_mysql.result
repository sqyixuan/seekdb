drop database if exists create_temp_table_db;
drop database if exists oc1;
create database create_temp_table_db;
use create_temp_table_db;
result_format: 4
create table t1(c1 int, c2 varchar(10), c3 date);
insert into t1 values(5236, 'scott', '2018-5-8');
insert into t1 values(1024, '中', '2018-1-1');
commit;

show tables like 't1';
Tables_in_create_temp_table_db (t1)
t1

## set @@session.ob_enable_transformation = 0;
#Q1 基本测试
#Q1.1 支持create table like
create temporary table tmp_10 like t1;
show create table tmp_10;
