#Q7 bug16818793, 

create table f71 ( x int, y int);
create table mm(cc int);
insert into f71 values(5,6);
create view f71 as select * from mm;
ERROR 42S01: Table 'f71' already exists

CREATE VIEW t71 AS SELECT 10 AS f71;
create table t71 (x int);
ERROR 42S01: Table 't71' already exists
CREATE TEMPORARY TABLE t71 (f1 INT);
insert into t71 values(100);

show create table t71;
Table	Create Table
t71	CREATE TEMPORARY TABLE `t71` (
  `f1` int(11) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10

show create view t71;
View	Create View	character_set_client	collation_connection
t71	CREATE VIEW `t71` AS select 10 AS `f71`	utf8mb4	utf8mb4_general_ci
select * from t71;
+------+
| f1   |
+------+
|  100 |
+------+
drop view t71;
drop table t71;

CREATE TEMPORARY TABLE t71 (f1 INT);
CREATE VIEW t71 AS SELECT 10 AS f71;
insert into t71 values(0);
select * from t71;
+------+
| f1   |
+------+
|    0 |
+------+
drop table t71;
drop view t71;

