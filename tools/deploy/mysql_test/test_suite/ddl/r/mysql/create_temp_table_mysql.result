#Q1.2 包含约束的临时表
create temporary table tmp_12(c1 int not null, c2 int, c3 date unique, c4 int default 55);
insert into tmp_12 values(10, 55, '2010-1-1', 66);
insert into tmp_12(c1,c2,c3) values(10, 111, '2010-1-1');
ERROR 23000: Duplicate entry '2010-01-01' for key 'c3'
insert into tmp_12(c1,c2,c3) values(null, 111, '2014-1-1');
ERROR 23000: Column 'c1' cannot be null
insert into tmp_12(c1,c3,c2) values(10, '2011-1-1', 666);
select * from tmp_12;
+----+------+------------+------+
| c1 | c2   | c3         | c4   |
+----+------+------------+------+
| 10 |   55 | 2010-01-01 |   66 |
| 10 |  666 | 2011-01-01 |   55 |
+----+------+------------+------+
show create table tmp_12;
Table	Create Table
tmp_12	CREATE TEMPORARY TABLE `tmp_12` (
  `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` date DEFAULT NULL,
  `c4` int(11) DEFAULT '55',
  UNIQUE KEY `c3` (`c3`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10

