#Q3.2 create/drop index
create temporary table tmp_32(x int, y int);
insert into tmp_32 values(10, 20),(50, 100), (1, 2);
create index idx_tmp_32 on tmp_32(x);
select x from tmp_32 where x = 10;
+------+
| x    |
+------+
|   10 |
+------+
drop index idx_tmp_32 on tmp_32;
drop index idx_tmp_32 on tmp_32;
ERROR 42000: Can't DROP 'idx_tmp_32'; check that column/key exists

#Q3.3 create temporary table不引发commit
set autocommit = off;
create table t33(c int);
insert into t33 values(10),(100),(200);
commit;
insert into t33 values(4),(44),(444);
create temporary table tmp_33 (d1 int);
insert into tmp_33 values(5);
rollback;
select * from t33;
+------+
| c    |
+------+
|   10 |
|  100 |
|  200 |
+------+
select * from tmp_33;
+------+
| d1   |
+------+
+------+
set autocommit = on;

#Q3.4 flashback table, 临时表不支持进回收站
set recyclebin=on;

create table t340000(c int);
create temporary table tmp_34000(x int);
insert into t340000 values(5),(6),(7),(8);
insert into tmp_34000 select * from t340000 where c <> 7 and c <> 5;
select * from t340000 union all select x * 100 from tmp_34000;
+------+
| c    |
+------+
|    5 |
|    6 |
|    7 |
|    8 |
|  600 |
|  800 |
+------+
drop table t340000;
drop table tmp_34000;
select 1 from dual where exists (select 1 from oceanbase.__all_virtual_recyclebin where original_name = 't340000');
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual where exists (select 1 from oceanbase.__all_virtual_recyclebin where original_name = 'tmp_34000');
+---+
| 1 |
+---+
+---+

#Q3.5 flashback index, 临时表上索引不支持进回收站
create table t35(x int, y int);
create index idx_35000 on t35(x);
drop index idx_35000 on t35;
select 1 from dual where exists (select 1 from oceanbase.__all_virtual_recyclebin where original_name like '%idx_35000');
+---+
| 1 |
+---+
+---+

create temporary table tmp_35(x int, y int);
create index idx_tmp_35000 on tmp_35(x);
drop index idx_tmp_35000 on tmp_35;
select 1 from dual where exists (select 1 from oceanbase.__all_virtual_recyclebin where original_name like '%idx_tmp_35000');
+---+
| 1 |
+---+
+---+

drop table tmp_35;

set recyclebin=off;

