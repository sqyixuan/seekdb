result_format: 4
drop sequence if exists s1;
drop table if exists t1;
create sequence s1 cache 1000000 noorder;
create table t1(id int primary key, name varchar(20), age bigint, description varchar(65535)) tablet_size=104857600 compression='none';
alter tenant sys set primary_zone = "zone1";

set ob_query_timeout = 1000000000;
insert /*+ append enable_parallel_dml parallel(8) */ into t1 select s1.nextval, 'oceanbase', random(), randstr(3000, random()) from table(generator(10000));
set ob_query_timeout = 10000000;

alter system set debug_sync_timeout = '60s';
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'AFTER_DDL_WRITE_MACRO_BLOCK wait_for signal1 execute 10000';
create index idx1 on t1(age);
alter tenant sys set primary_zone = "zone1";
set ob_global_debug_sync = 'AFTER_DDL_WRITE_MACRO_BLOCK clear';
set ob_global_debug_sync = 'now signal signal1';


+----------+
| count(*) |
+----------+
|        1 |
+----------+
drop table t1;
drop sequence s1;
