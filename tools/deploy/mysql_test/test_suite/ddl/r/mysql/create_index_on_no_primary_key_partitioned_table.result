drop table if exists t1,t2,t3;
create table t1(c1 int,c2 int, c3 int, c4 int, c5 int,
index idxt1_1(c2) local,
unique index idxt1_2(c3) global,
index idxt1_3(c4) local storing(c1),
index idxt1_4(c5) global storing(c1))
partition by hash (c1) partitions 3;
show create table t1;
