alter system set debug_sync_timeout = '60s';
set ob_global_debug_sync = 'reset';
set ob_query_timeout = 100000000;
drop database if exists tmp_db;
create database tmp_db;
use tmp_db;
drop table if exists foo;
create table foo (aa blob, bb longblob, cc tinyblob, dd mediumblob, aaa varchar(12), bbb varbinary(20), ccc varchar(50), ddd varchar(3000));
alter table foo alter column cc set default 101010;
ERROR 42000: Invalid default value for 'cc'
alter table foo alter column cc set default 101010, drop column aa;
ERROR 42000: Invalid default value for 'cc'
alter table foo alter column aaa set default "1010101010101010";
ERROR 42000: Invalid default value for 'aaa'

# parallel offline ddl
use tmp_db;
alter table foo drop column bb;
alter table foo alter column ccc set default 202020;
alter table foo alter column aaa set default "1010", drop column ddd, drop column ccc, drop column aaa;
drop table if exists foo;
drop database tmp_db;
