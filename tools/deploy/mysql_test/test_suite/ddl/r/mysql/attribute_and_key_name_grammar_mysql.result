create table t1(c1 int default null collate utf8_bin, 
                c2 char collate utf8_bin default 'a' not null, 
                c3 char character set utf8 default null collate utf8_unicode_ci,
                c4 double null unique key collate gbk_chinese_ci,
                c5 decimal unique collate gbk_chinese_ci key,
                c6 char(10) collate utf8_bin as (c2 || 'c3'),
                c7 varchar(10) character set gbk collate gbk_chinese_ci as (c2 || c3),
                unique key idx(c2));

