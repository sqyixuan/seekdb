t_show_index	CREATE TABLE `t_show_index` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  KEY `idx1` (`c1`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC
alter table t_show_index alter index idx1 invisible;
show create table t_show_index;
Table	Create Table
t_show_index	CREATE TABLE `t_show_index` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  KEY `idx1` (`c1`) /*!80000 INVISIBLE */
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC
drop table t_show_index;

