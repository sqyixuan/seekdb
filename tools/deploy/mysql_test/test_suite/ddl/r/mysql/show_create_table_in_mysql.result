drop database if exists showtest_db;
create database showtest_db;
use showtest_db;
set _show_ddl_in_compat_mode = 1;
result_format: 4
CREATE TABLE t1 (c1 INT, c2 INT, c3 INT)
     PARALLEL 3
     PARTITION BY RANGE(c1) 
     SUBPARTITION BY KEY(c2, c3) SUBPARTITIONS 5
     (PARTITION p0 VALUES LESS THAN(0), PARTITION p1 VALUES LESS THAN(100));
CREATE UNIQUE INDEX i1_1 on t1(c3, c2) global;

show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC
 partition by range(c1) subpartition by key(c2, c3)
(partition `p0` values less than (0) (
subpartition `p0sp0`,
subpartition `p0sp1`,
subpartition `p0sp2`,
subpartition `p0sp3`,
subpartition `p0sp4`),
partition `p1` values less than (100) (
subpartition `p1sp0`,
subpartition `p1sp1`,
subpartition `p1sp2`,
subpartition `p1sp3`,
subpartition `p1sp4`))

CREATE TABLE t2(inv_id BIGINT NOT NULL AUTO_INCREMENT,c1 BIGINT, 
    PRIMARY KEY (inv_id) ) PARTITION BY HASH(inv_id) PARTITIONS 8;

show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `inv_id` bigint(20) NOT NULL AUTO_INCREMENT,
  `c1` bigint(20) DEFAULT NULL,
  PRIMARY KEY (`inv_id`)
) AUTO_INCREMENT = 1 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC
 partition by hash(inv_id)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`,
partition `p5`,
partition `p6`,
partition `p7`)

CREATE TABLE t3 (col1 INT, col2 INT, col3 INT, CONSTRAINT equal_check1 CHECK(col1 = col3 * 2)) 
    COMPRESSION = 'none';
CREATE UNIQUE INDEX i3_1 on t3(col1, col2);
CREATE UNIQUE INDEX i3_2 on t3(col2, col1) local;
CREATE INDEX i3_3 on t3(col3) storing (col2) local;
CREATE UNIQUE INDEX i3_4 on t3(col1, col2) global partition by hash (col2);

show create table t3;
Table	Create Table
t3	CREATE TABLE `t3` (
  `col1` int(11) DEFAULT NULL,
  `col2` int(11) DEFAULT NULL,
  `col3` int(11) DEFAULT NULL,
  UNIQUE KEY `i3_1` (`col1`, `col2`),
  UNIQUE KEY `i3_2` (`col2`, `col1`),
  KEY `i3_3` (`col3`),
  CONSTRAINT `equal_check1` CHECK ((`col1` = (`col3` * 2)))
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC

CREATE TABLE t4 (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `class` varchar(20) NOT NULL,
  PRIMARY KEY (`id`)
) AUTO_INCREMENT = 4 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

