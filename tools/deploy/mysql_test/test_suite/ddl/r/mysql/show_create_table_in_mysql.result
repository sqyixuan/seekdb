) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC
 partition by list columns(col1, col2) subpartition by hash(col3)
(partition `p0` values in ((100,'1'),(200,'1')) (
subpartition `sp0`,
subpartition `sp1`,
subpartition `sp2`),
partition `p1` values in ((300,'2')) (
subpartition `sp3`,
subpartition `sp4`))

CREATE TABLE t2_f_lh (col1 INT NOT NULL,col2 INT,col3 INT NOT NULL) 
    PARTITION BY LIST(col1 + col3)
    SUBPARTITION BY HASH(col2)
    (PARTITION p0 VALUES IN(100)
      (SUBPARTITION sp0,
      SUBPARTITION sp1,
      SUBPARTITION sp2),
    PARTITION p1 VALUES IN(default)
      (SUBPARTITION sp3,
      SUBPARTITION sp4,
      SUBPARTITION sp5)
    );

