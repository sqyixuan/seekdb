alter system set debug_sync_timeout = '100000s';
drop table if exists t1;
create table t1 (c1 int primary key, c2 varchar(4096), c3 varchar(4096));
select /*+ index(t1 primary)*/ count(*) from t1;
count(*)
199990
set ob_global_debug_sync = 'BEFORE_DDL_CHECKPOINT wait_for signal_cp execute 100000';
set ob_global_debug_sync = 'BEFORE_REPLAY_DDL_PREPRARE wait_for signal_prepare execute 100000';
set ob_global_debug_sync = 'BEFORE_REPLAY_DDL_COMMIT wait_for signal_commit execute 100000';
set ob_global_debug_sync = 'BEFORE_REPLAY_DDL_MACRO_BLOCK wait_for signal_macro execute 1';
alter system minor freeze;
create index idx1 on t1 (c2);
set ob_global_debug_sync = 'now signal signal_cp';
set ob_global_debug_sync = 'BEFORE_DDL_CHECKPOINT clear';
set ob_global_debug_sync = 'now signal signal_prepare';
set ob_global_debug_sync = 'now signal signal_commit';
set ob_global_debug_sync = 'BEFORE_REPLAY_DDL_PREPRARE clear';
set ob_global_debug_sync = 'BEFORE_REPLAY_DDL_COMMIT clear';
set ob_global_debug_sync = 'now signal signal_macro';
set ob_global_debug_sync = 'BEFORE_REPLAY_DDL_MACRO_BLOCK clear';
select /*+ read_consistency(weak) index(t1 idx1)*/ count(*) from t1;
count(*)
199990
