create table if not exists t1
(
c1 TINYINT not null  auto_increment comment 'abcd' ,
c2 SMALLINT not null default 0 comment 'now',
c3 MEDIUMINT not null default 0,
key idx(c2,c3),
primary key(c1)
)USE_BLOOM_FILTER=false,COMMENT='this is comment';
