| column_group_name | column_group_type | column_id | is_deleted |
+-------------------+-------------------+-----------+------------+
|                   |                 0 |         1 |          1 |
|                   |                 0 |        16 |          1 |
|                   |                 0 |        17 |          1 |
|                   |                 0 |        18 |          1 |
|                   |                 0 |        19 |          1 |
|                   |                 0 |        21 |          1 |
| __co_default      |                 0 |         1 |          0 |
| __co_default      |                 0 |        16 |          0 |
| __co_default      |                 0 |        17 |          0 |
| __co_default      |                 0 |        18 |          0 |
| __co_default      |                 0 |        19 |          0 |
| __co_default      |                 0 |        21 |          0 |
+-------------------+-------------------+-----------+------------+
create table t1(c1 int primary key);
insert into t1 values(1),(2),(3);
alter table t1 add column group(all columns, each column);
select column_group_name, column_group_id from __all_column_group where table_id in (select max(table_id) from __all_table where table_name like "t1");
+-------------------+-----------------+
| column_group_name | column_group_id |
+-------------------+-----------------+
| __co_default      |               1 |
| __co_all          |            1001 |
| __cg_c1           |            1003 |
+-------------------+-----------------+
alter system major freeze;

select c1 from t1 where c1 < 2;
