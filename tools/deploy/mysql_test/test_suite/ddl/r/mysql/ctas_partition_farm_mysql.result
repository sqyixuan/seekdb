result_format: 4
drop table t1;
drop table t1_x11;

create table t1(c1 int, c2 varchar(10), c3 date);
insert into t1 values(5236, 'scott', '2018-5-8');
insert into t1 values(1024, '中', '2018-1-1');
commit;

###Q1 ctas
create table t1_x11 as select * from t1;
show create table t1_x11;
Table	Create Table
t1_x11	CREATE TABLE `t1_x11` (
  `c1` int(11) DEFAULT NULL,
  `c2` varchar(10) DEFAULT NULL,
  `c3` date DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10

select * from t1_x11 order by 1;
+------+-------+------------+
| c1   | c2    | c3         |
+------+-------+------------+
| 1024 | 中    | 2018-01-01 |
| 5236 | scott | 2018-05-08 |
+------+-------+------------+

###Q2 临时表
drop table t1_x11;

###HASH分区表
drop table t_q312;
create table t_q312(c1 decimal(16,5), c2 int) partition by key(c1) partitions 5;
show create table t_q312;
Table	Create Table
t_q312	CREATE TABLE `t_q312` (
  `c1` decimal(16,5) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by key(c1)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`)

insert into t_q312 values(0,20);
insert into t_q312 values(null,200);
insert into t_q312 values(-454.44,66);
insert into t_q312 values(888888.99999,66);

select 1,c1,c2 from t_q312 partition (p0)
union all
select 2,c1,c2 from t_q312 partition (p1)
union all
select 3,c1,c2 from t_q312 partition (p2)
union all
select 4,c1,c2 from t_q312 partition (p3)
union all
select 5,c1,c2 from t_q312 partition (p4)
order by 1,2;
+------+--------------+------+
| 1    | c1           | c2   |
+------+--------------+------+
|    1 |         NULL |  200 |
|    1 |      0.00000 |   20 |
|    4 | 888888.99999 |   66 |
|    5 |   -454.44000 |   66 |
+------+--------------+------+

drop table t_q312;
create table t_q312(c1 varchar(15), c2 int) partition by key(c1) partitions 5;
show create table t_q312;
Table	Create Table
t_q312	CREATE TABLE `t_q312` (
  `c1` varchar(15) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by key(c1)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`)

insert into t_q312 values('',20);
insert into t_q312 values(null,200);
insert into t_q312 values('songxin',66);
insert into t_q312 values('数据库',66);

select 1,c1,c2 from t_q312 partition (p0)
union all
select 2,c1,c2 from t_q312 partition (p1)
union all
select 3,c1,c2 from t_q312 partition (p2)
union all
select 4,c1,c2 from t_q312 partition (p3)
union all
select 5,c1,c2 from t_q312 partition (p4)
order by 1,2;
+------+-----------+------+
| 1    | c1        | c2   |
+------+-----------+------+
|    1 | NULL      |  200 |
|    1 |           |   20 |
|    3 | 数据库    |   66 |
|    4 | songxin   |   66 |
+------+-----------+------+

drop table t_q312;
create table t_q312(c1 char(55), c2 int) partition by key(c1) partitions 5;
show create table t_q312;
Table	Create Table
t_q312	CREATE TABLE `t_q312` (
  `c1` char(55) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by key(c1)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`)

insert into t_q312 values('',20);
insert into t_q312 values(null,200);
insert into t_q312 values('songxin',66);
insert into t_q312 values('数据库',66);

select 1,c1,c2 from t_q312 partition (p0)
union all
select 2,c1,c2 from t_q312 partition (p1)
union all
select 3,c1,c2 from t_q312 partition (p2)
union all
select 4,c1,c2 from t_q312 partition (p3)
union all
select 5,c1,c2 from t_q312 partition (p4)
order by 1,2;
+------+-----------+------+
| 1    | c1        | c2   |
+------+-----------+------+
|    1 | NULL      |  200 |
|    1 |           |   20 |
|    3 | 数据库    |   66 |
|    4 | songxin   |   66 |
+------+-----------+------+

drop table t_q312;

## 验证 MySQL 模式下不能通过 ctas 创建分区表问题的修复
## 
drop table t3;
drop table t2;
drop table t1;
create table t1(c1 int) partition by key(c1);
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by key(c1)
(partition `p0`)
create table t2 partition by key(c1) as select c1 from t1;
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `c1` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by key(c1)
(partition `p0`)
create table t3 COMMENT 'hello ctas' partition by key(c1) as select c1 from t1;
show create table t3;
Table	Create Table
t3	CREATE TABLE `t3` (
  `c1` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10 COMMENT = 'hello ctas'
 partition by key(c1)
(partition `p0`)
create table if not exists t3 COMMENT 'hello ctas' partition by key(c1) as select c1 from t1;
drop table t3;
drop table t2;
drop table t1;
