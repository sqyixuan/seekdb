drop database if exists shanting1;
drop database if exists shanting2;
create database shanting1;
create database shanting2;
use shanting1;
create view v1 as select 1 c1 from dual;
create or replace view v1 as select * from v1;
ERROR 42S02: 'shanting1.v1' contains view recursion
create view v2 as select * from v1;
select * from v2;
c1
1
create or replace view v1 as select * from v2;
ERROR 42S02: 'shanting1.v1' contains view recursion
create view v3 as select * from v2;
select * from v3;
c1
1
create or replace view v1 as select * from v3;
ERROR 42S02: 'shanting1.v1' contains view recursion
use shanting2;
create view v1 as select * from shanting1.v1;
select * from v1;
c1
1
use shanting1;
create or replace view v1 as select * from shanting2.v1;
ERROR 42S02: 'shanting1.v1' contains view recursion
## make sure date keyword is not swallowed
create table t_date (a date);
create view v_date as select * from t_date where a > date '1997-03-01';
show create view v_date;
View	Create View	character_set_client	collation_connection
v_date	CREATE VIEW `v_date` AS select `shanting1`.`t_date`.`a` AS `a` from `shanting1`.`t_date` where (`shanting1`.`t_date`.`a` > DATE '1997-03-01')	utf8mb4	utf8mb4_general_ci
drop view if exists v_date;
## no date keyword case
create view v_date as select * from t_date where a > '1997-03-01';
show create view v_date;
View	Create View	character_set_client	collation_connection
v_date	CREATE VIEW `v_date` AS select `shanting1`.`t_date`.`a` AS `a` from `shanting1`.`t_date` where (`shanting1`.`t_date`.`a` > '1997-03-01')	utf8mb4	utf8mb4_general_ci
drop view if exists v_date;
drop view if exists v;
create view v as select cast('2020-01-01 12:34:56.123456789' as datetime(3)) c1, cast('12:34:56.123456789' as time(3)) c2;
show create view v;
View	Create View	character_set_client	collation_connection
v	CREATE VIEW `v` AS select cast('2020-01-01 12:34:56.123456789' as datetime(3)) AS `c1`,cast('12:34:56.123456789' as time(3)) AS `c2`	utf8mb4	utf8mb4_general_ci
select * from v;
c1	c2
2020-01-01 12:34:56.123	12:34:56.123
drop view v;
# Clean
drop database shanting1;
drop database shanting2;
use test;
drop table if exists t;
create table t(c1 int);
insert into t values(0);
create or replace view v as select 1 from dual where 1 > (select `abs(c1)` from (select abs(c1) from t));
show create view v;
View	Create View	character_set_client	collation_connection
v	CREATE VIEW `v` AS select 1 AS `1` from DUAL where (1 > (select `ANONYMOUS_VIEW1`.`abs(c1)` from (select abs(`test`.`t`.`c1`) AS `abs(c1)` from `test`.`t`) `ANONYMOUS_VIEW1`))	utf8mb4	utf8mb4_general_ci
desc v;
Field	Type	Null	Key	Default	Extra
1	bigint(1)	NO			
select * from v;
1
1
drop view v;
drop table t;
##bug51302234
CREATE OR REPLACE VIEW VIEW_TEST as SELECT 'p' , 'p' UNION SELECT 'k', 's';
select * from VIEW_TEST order by 1;
p	p
k	s
p	p
CREATE OR REPLACE VIEW VIEW_TEST as SELECT 'p' as p, 'p' UNION SELECT 'k', 's';
select * from VIEW_TEST order by 1;
p	p
k	s
p	p
CREATE OR REPLACE VIEW VIEW_TEST as SELECT 'p', 'p' as p UNION SELECT 'k', 's';
select * from VIEW_TEST order by 1;
p	p
k	s
p	p
CREATE OR REPLACE VIEW VIEW_TEST as SELECT 'p' as p, 'p' as p UNION SELECT 'k', 's';
ERROR 42S21: Duplicate column name 'p'
DROP VIEW VIEW_TEST;
##bug46870007
drop database  IF EXISTS  obyx5493;
drop table if exists user_test;
drop view if exists user_test_view;
drop view if exists user_test_view2;
create database obyx5493  charset = latin1;
use obyx5493;
set names gbk;
create table user_test(uid int auto_increment,data varchar(10) character set gbk,primary key(uid))DEFAULT CHARACTER SET = latin1;
insert into user_test values (NULL,'沈阳');
insert into user_test values (NULL,'日本');
alter table user_test add user_name varchar(20) generated always as (data);
create view user_test_view as select * from user_test;
select * from user_test;
uid	data	user_name
1	沈阳	???
2	日本	???
select * from user_test_view;
uid	data	user_name
1	沈阳	???
2	日本	???
