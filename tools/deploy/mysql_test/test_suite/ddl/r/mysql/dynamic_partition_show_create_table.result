set recyclebin = off;
drop database if exists ziqian_dynamic_part;
create database ziqian_dynamic_part;
use ziqian_dynamic_part;
CALL DBMS_SCHEDULER.DISABLE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY');
CALL DBMS_SCHEDULER.DISABLE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY');
set time_zone = '+8:00';
alter system set_tp tp_name = ERRSIM_DYNAMIC_PARTITION_MOCK_TIME, error_code = 1740762123000000, frequency = 1;
create table t1 (c1 datetime) partition by range columns (c1) (partition p0 values less than ('2025-02-27 01:02:03'));
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` datetime DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by range columns(c1)
(partition `p0` values less than ('2025-02-27 01:02:03'))
set _show_ddl_in_compat_mode = 0;
alter table t1 set dynamic_partition_policy (time_unit = 'day', precreate_time = '1week', expire_time = '1year');
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` datetime DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10 DYNAMIC_PARTITION_POLICY = (ENABLE = TRUE, TIME_UNIT = 'DAY', PRECREATE_TIME = '1WEEK', EXPIRE_TIME = '1YEAR', TIME_ZONE = 'DEFAULT', BIGINT_PRECISION = 'NONE')
 partition by range columns(c1)
(partition `p0` values less than ('2025-02-27 01:02:03'))
set _show_ddl_in_compat_mode = 1;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` datetime DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 
