####################### MYSQL TENANT TEST #######################
drop table if exists d1.tbl1, d2.tbl2, d3.tbl3, d4.tbl4;
drop database if exists d1;
drop database if exists d2;
drop database if exists d3;
drop database if exists d4;
drop tablegroup if exists test_different_databases;
create database d1;
create database d2;
create database d3;
create database d4;
create tablegroup test_different_databases;
create table d1.tbl1 (c1 int) tablegroup = test_different_databases;
create table d2.tbl2 (c1 int) tablegroup = test_different_databases;
create table d3.tbl3 (c1 int);
alter table d3.tbl3 tablegroup = test_different_databases;
create table d4.tbl4 (c1 int);
alter tablegroup test_different_databases add d4.tbl4;
drop table d1.tbl1, d2.tbl2, d3.tbl3, d4.tbl4;
drop database d1;
drop database d2;
drop database d3;
drop database d4;
drop tablegroup test_different_databases;
####################### SYS TABLEGROUP TEST #######################
drop table if exists d1.tbl1, d2.tbl2, d3.tbl3;
drop database if exists d1;
drop database if exists d2;
drop database if exists d3;
create database d1;
create database d2;
create database d3;
create table d1.tbl1 (c1 int) tablegroup = oceanbase;
ERROR HY000: user table add to sys tablegroup not allowed
create table d2.tbl2 (c1 int);
alter table d2.tbl2 tablegroup = oceanbase;
ERROR HY000: user table add to sys tablegroup not allowed
create table d3.tbl3 (c1 int);
alter tablegroup oceanbase add d3.tbl3;
ERROR HY000: user table add to sys tablegroup not allowed
drop table if exists d1.tbl1, d2.tbl2, d3.tbl3;
drop database if exists d1;
drop database if exists d2;
drop database if exists d3;
