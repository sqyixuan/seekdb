ALTER SYSTEM SET "_parallel_ddl_control" = 'CREATE_INDEX:ON';
DROP TABLE "ocean base@ob";
CREATE TABLE "ocean base@ob" (
col_int INT,
col_bool NUMBER(1),
pk INT
) partition by hash(col_int) partitions 128;
create index idx1 on "ocean base@ob"(col_int) local;
create index idx2 on "ocean base@ob"(col_bool) global;
drop table "ocean base@ob";
ALTER SYSTEM SET "_parallel_ddl_control" = 'CREATE_INDEX:OFF';
DROP TABLE "user";
CREATE TABLE "user" (
col_int INT,
col_bool NUMBER(1),
pk INT,
