purge recyclebin;
drop database if exists db1;
create database db1;
use db1;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
drop user root1;
create user 'root1' identified by '123';
GRANT ALL PRIVILEGES ON *.* TO 'root1'@'%' WITH GRANT OPTION;
#root1
use db1;
select current_user();
current_user()
root1@%
set global automatic_sp_privileges = 1;
select @@automatic_sp_privileges;
@@automatic_sp_privileges
1
drop user zwc;
create user 'zwc' identified by '123';
grant create on *.* to zwc;
GRANT CREATE ROUTINE ON db1.* to zwc;
#zwc
use db1;
select current_user();
current_user()
zwc@%
show grants for zwc;
Grants for zwc@%
GRANT CREATE ON *.* TO 'zwc'
GRANT CREATE ROUTINE ON `db1`.* TO 'zwc'
#创建procedure，查看权限是否自动添加 execute，和alter routine
create  procedure p1()
begin
select 1 from dual;
end;
/
show grants for zwc;
Grants for zwc@%
GRANT CREATE ON *.* TO 'zwc'
GRANT CREATE ROUTINE ON `db1`.* TO 'zwc'
GRANT EXECUTE, ALTER ROUTINE ON PROCEDURE `db1`.`p1` TO 'zwc'
#执行验证
call p1();
1
1
#修改验证  bug:
ALTER PROCEDURE p1 LANGUAGE SQL READS SQL DATA  SQL SECURITY INVOKER COMMENT 'SQL SECURITY=INVOKER';
#删除
drop procedure p1;
#修改 set global automatic_sp_privileges = 0
#root
select @@automatic_sp_privileges;
@@automatic_sp_privileges
1
set global automatic_sp_privileges = 0;
#zwc
create  procedure p1()
begin
select 1 from dual;
end;
/
show grants for zwc;
Grants for zwc@%
GRANT CREATE ON *.* TO 'zwc'
GRANT CREATE ROUTINE ON `db1`.* TO 'zwc'
#权限验证，预期报错
call p1;
ERROR 42000: EXECUTE command denied to user 'zwc'@'%' for routine 'p1'
ALTER PROCEDURE p1 LANGUAGE SQL READS SQL DATA  SQL SECURITY DEFINER COMMENT 'SQL SECURITY=DEFINER';
ERROR 42000: ALTER ROUTINE command denied to user 'zwc'@'%' for routine 'p1'
drop procedure p1;
ERROR 42000: ALTER ROUTINE command denied to user 'zwc'@'%' for routine 'p1'
#root1
set global automatic_sp_privileges = 1;
select @@automatic_sp_privileges;
@@automatic_sp_privileges
1
#创建 prcedure定义SQL SECURITY
#zwc
CREATE DEFINER = zwc PROCEDURE p2()
SQL SECURITY INVOKER
BEGIN
select 2 from dual;
END;
/
CREATE DEFINER = zwc PROCEDURE p3()
SQL SECURITY DEFINER
BEGIN
select 2 from dual;
END;
/
#definer指定 用户
#root1
drop user zwc2;
create user 'zwc2' identified by '123';
grant create on *.* to zwc2;
GRANT CREATE ROUTINE ON db1.* to zwc2;
show grants for zwc2;
Grants for zwc2@%
GRANT CREATE ON *.* TO 'zwc2'
GRANT CREATE ROUTINE ON `db1`.* TO 'zwc2'
#指定definer 为zwc2用户,并进行权限验证
#在zwc用户下执行，报错
#zwc
use db1;
CREATE DEFINER = zwc2 PROCEDURE p2()
BEGIN
select 2 from dual;
END;
/
ERROR 42501: Access denied
#在zwc2用户下执行 ,指定当前用户应该执行成功，bug：
#zwc2;
CREATE DEFINER = zwc2 PROCEDURE p2()
BEGIN
select 2 from dual;
END;
/
ERROR 42501: Access denied
#执行验证
#zwc用户下，调用p2
#创建者zwc2用户下 验证。
#zwc2
#普通用户zwc 指定definer其他用户
#zwc;
CREATE DEFINER = '张三' PROCEDURE p1()
BEGIN
select 1 from dual;
END;
/
ERROR 42501: Access denied
CREATE DEFINER = aabb PROCEDURE p1()
BEGIN
select 1 from dual;
END;
/
ERROR 42501: Access denied
CREATE DEFINER = zwc2 PROCEDURE p1()
BEGIN
select 1 from dual;
END;
/
ERROR 42501: Access denied
#root用户下 definer指定其他用户
#root1
drop procedure if exists p1;
drop procedure if exists p2;
drop procedure if exists p3;
CREATE DEFINER = '张三' PROCEDURE p1()
BEGIN
select 1 from dual;
END;
/
Warnings:
Warning	1449	User 张三 not exist
CREATE DEFINER = aabb PROCEDURE p2()
BEGIN
select 1 from dual;
END;
/
Warnings:
Warning	1449	User aabb not exist
CREATE DEFINER = zwc2 PROCEDURE p3()
BEGIN
select 1 from dual;
END;
/
call p3;
ERROR 42000: EXECUTE command denied to user 'zwc2'@'%' for routine 'p3'
show grants for zwc2;
Grants for zwc2@%
GRANT CREATE ON *.* TO 'zwc2'
GRANT CREATE ROUTINE ON `db1`.* TO 'zwc2'
drop procedure p1;
drop procedure p2;
drop procedure p3;
#root下 定义definer一个不存在用户
CREATE DEFINER = zwc3 PROCEDURE p3()
BEGIN
select 1 from dual;
END;
/
Warnings:
Warning	1449	User zwc3 not exist
drop user zwc3;
create user 'zwc3' identified by '123';
Warnings:
Warning	4005	User 'zwc3'@'%' is referenced as a definer account in a stored routine.
grant create on *.* to zwc3;
GRANT CREATE ROUTINE ON db1.* to zwc3;
show grants for zwc3;
Grants for zwc3@%
GRANT CREATE ON *.* TO 'zwc3'
GRANT CREATE ROUTINE ON `db1`.* TO 'zwc3'
#zwc3
use db1;
call p3;
ERROR 42000: EXECUTE command denied to user 'zwc'@'%' for routine 'p3'
alter PROCEDURE  p3 SQL SECURITY DEFINER;
ERROR 42000: ALTER ROUTINE command denied to user 'zwc'@'%' for routine 'p3'
drop procedure p3;
ERROR 42000: ALTER ROUTINE command denied to user 'zwc'@'%' for routine 'p3'
#definer 指定user 删除后在创建，权限验证
#zwc
CREATE DEFINER =zwc PROCEDURE p1()
BEGIN
select 1 from dual;
END;
/
#再创建 进行权限验证
#root
drop user zwc1;
#rename user后进行权限验证
#zwc
show grants;
Grants for zwc@%
GRANT CREATE ON *.* TO 'zwc'
GRANT CREATE ROUTINE ON `db1`.* TO 'zwc'
GRANT EXECUTE, ALTER ROUTINE ON PROCEDURE `db1`.`p1` TO 'zwc'
drop procedure p1;
create  procedure p1()
BEGIN
select 1 from dual;
END;
/
show grants for zwc;
Grants for zwc@%
GRANT CREATE ON *.* TO 'zwc'
GRANT CREATE ROUTINE ON `db1`.* TO 'zwc'
GRANT EXECUTE, ALTER ROUTINE ON PROCEDURE `db1`.`p1` TO 'zwc'
#root
rename user zwc to zwc1;
Warnings:
Warning	4005	User 'zwc'@'%' is referenced as a definer account in a stored routine.
#zwc
call p1();
ERROR HY000: User not exist
ALTER PROCEDURE p1 LANGUAGE SQL READS SQL DATA  SQL SECURITY INVOKER COMMENT 'SQL SECURITY=INVOKER';
drop procedure p1;
#创建的user为 definer定义的孤儿对象
#root
CREATE DEFINER =zz1 PROCEDURE p6()
BEGIN
select 1 from dual;
END;
/
Warnings:
Warning	1449	User zz1 not exist
drop user zz1;
create user 'zz1' identified by '123';
Warnings:
Warning	4005	User 'zz1'@'%' is referenced as a definer account in a stored routine.
grant create on *.* to zz1;
GRANT CREATE ROUTINE ON db1.* to zz1;
show grants for zz1;
Grants for zz1@%
GRANT CREATE ON *.* TO 'zz1'
GRANT CREATE ROUTINE ON `db1`.* TO 'zz1'
#zz1
use db1;
call p6;
ERROR 42000: EXECUTE command denied to user 'zz1'@'%' for routine 'p6'
#root1
GRANT EXECUTE, ALTER ROUTINE ON PROCEDURE db1.p6 TO zz1;
#zz1
ALTER PROCEDURE p6 LANGUAGE SQL READS SQL DATA  SQL SECURITY INVOKER COMMENT 'SQL SECURITY=INVOKER';
drop procedure p6;
#rename user 目标是一个definer
#root
drop user rn1;
drop user rn2;
create user 'rn1' identified by '123';
grant create on *.* to rn1;
GRANT CREATE ROUTINE ON db1.* to rn1;
show grants for rn1;
Grants for rn1@%
GRANT CREATE ON *.* TO 'rn1'
GRANT CREATE ROUTINE ON `db1`.* TO 'rn1'
#root下执行 
use db1;
CREATE DEFINER =rn2 PROCEDURE p1()
BEGIN
select 1 from dual;
END;
/
Warnings:
Warning	1449	User rn2 not exist
rename user rn1 to rn2;
Warnings:
Warning	4005	User 'rn2'@'%' is referenced as a definer account in a stored routine.
#rn2下执行
call p1;
ERROR 42000: EXECUTE command denied to user 'rn2'@'%' for routine 'p1'
ALTER PROCEDURE p1 LANGUAGE SQL READS SQL DATA  SQL SECURITY INVOKER COMMENT 'SQL SECURITY=INVOKER';
ERROR 42000: ALTER ROUTINE command denied to user 'rn1'@'%' for routine 'p1'
drop procedure p1;
ERROR 42000: ALTER ROUTINE command denied to user 'rn1'@'%' for routine 'p1'
#create user 用户是任意一个stored object的definer
#Root
use db1;
drop procedure p1;
CREATE DEFINER =zz2 PROCEDURE p10()
BEGIN
select 1 from dual;
END;
/
Warnings:
Warning	1449	User zz2 not exist
drop user zz2;
create user 'zz2' identified by '123';
Warnings:
Warning	4005	User 'zz2'@'%' is referenced as a definer account in a stored routine.
grant create on *.* to zz2;
GRANT CREATE ROUTINE ON db1.* to zz2;
GRANT EXECUTE, ALTER ROUTINE ON PROCEDURE db1.p10 TO zz2;
show grants for zz2;
Grants for zz2@%
GRANT CREATE ON *.* TO 'zz2'
GRANT CREATE ROUTINE ON `db1`.* TO 'zz2'
GRANT EXECUTE, ALTER ROUTINE ON PROCEDURE `db1`.`p10` TO 'zz2'
#zz2
use db1;
CALL p10();
