purge recyclebin;
drop database if exists db1;
create database db1;
use db1;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
drop user root1;
create user 'root1' identified by '123';
GRANT ALL PRIVILEGES ON *.* TO 'root1'@'%' WITH GRANT OPTION;
#root1
use db1;
select current_user;
current_user
root1@%
#function
#创建create outine function
#root下
drop user zwc;
create user 'zwc' identified by '123';
grant create on *.* to zwc;
grant insert on *.* to zwc;
GRANT CREATE ROUTINE ON db1.* to zwc;
show grants for zwc;
Grants for zwc@%
GRANT CREATE, INSERT ON *.* TO 'zwc'
GRANT CREATE ROUTINE ON `db1`.* TO 'zwc'
#创建者 
#验证 create function后自动添加 execute和alter routine权限
use db1;
CREATE TABLE t1 (c1 int);
create function f1() returns int deterministic
begin
INSERT INTO t1 VALUES(1);
return 1;
END;
/
show grants for zwc;
Grants for zwc@%
GRANT CREATE, INSERT ON *.* TO 'zwc'
GRANT CREATE ROUTINE ON `db1`.* TO 'zwc'
GRANT EXECUTE, ALTER ROUTINE ON FUNCTION `db1`.`f1` TO 'zwc'
#execute权限
SELECT f1();
f1()
1
#alter routine权限
ALTER FUNCTION f1 SQL SECURITY INVOKER;
ALTER FUNCTION f1 COMMENT 'f1 验证权限';
DROP FUNCTION f1;
#验证revoke excute 和 revoke alter routine
create function f2() returns int deterministic
begin
INSERT INTO t1 VALUES(1);
return 2;
END;
/
show grants FOR zwc ;
Grants for zwc@%
GRANT CREATE, INSERT ON *.* TO 'zwc'
GRANT CREATE ROUTINE ON `db1`.* TO 'zwc'
GRANT EXECUTE, ALTER ROUTINE ON FUNCTION `db1`.`f2` TO 'zwc'
select f2();
f2()
2
#revoke execute (root下执行)
revoke execute on function db1.f2 from zwc;
#创建者验证权限
SELECT f2();
ERROR 42000: EXECUTE command denied to user 'zwc'@'%' for routine 'f2'
show grants FOR zwc;
Grants for zwc@%
GRANT CREATE, INSERT ON *.* TO 'zwc'
GRANT CREATE ROUTINE ON `db1`.* TO 'zwc'
GRANT ALTER ROUTINE ON FUNCTION `db1`.`f2` TO 'zwc'
#revoke alter routine (root下执行)
revoke ALTER ROUTINE  on function db1.f2 from zwc;
#创建者验证权限
show grants;
Grants for zwc@%
GRANT CREATE, INSERT ON *.* TO 'zwc'
GRANT CREATE ROUTINE ON `db1`.* TO 'zwc'
ALTER FUNCTION f2 SQL SECURITY INVOKER;
