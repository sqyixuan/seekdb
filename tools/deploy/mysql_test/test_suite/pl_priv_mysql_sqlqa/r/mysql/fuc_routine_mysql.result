#security type
#root下创建
CREATE database db1;
drop user user1;
create user 'user1' identified by '123';
grant CREATE on *.* to user1;
grant insert on *.* to user1;
grant SELECT  on *.* to user1;
GRANT CREATE ROUTINE ON db1.* to user1;
show grants for user1;
Grants for user1@%
GRANT CREATE, INSERT, SELECT ON *.* TO 'user1'
GRANT CREATE ROUTINE ON `db1`.* TO 'user1'
#user1 
use db1;
CREATE TABLE t1(c1 int);
create procedure p1() 
begin 
INSERT INTO t1 VALUES(1); 	
END;
/
#root下 创建user2 
#security type=definer 验证无insert 权限调用 user1.p1，预期调用成功。
drop user user2;
create user 'user2' identified by '123';
GRANT EXECUTE ON PROCEDURE  db1.p1 TO user2;
grant SELECT  on *.* to user2;
show grants for user2;
Grants for user2@%
GRANT SELECT ON *.* TO 'user2'
GRANT EXECUTE ON PROCEDURE `db1`.`p1` TO 'user2'
#user2
use db1;
CALL p1;
SELECT * FROM t1;
c1
1
#security type= invoker时, user2 调用user1.p1 ，预期报错无insert权限
#user1
alter procedure p1 SQL SECURITY INVOKER ;
#user2
#ERROR 1142 (42000): INSERT command denied to user 'user2'@'%' for table 't1'
CALL p1;
#security type= invoker时,  user1的 权限被回收，user2调用 user1.p1
#root
REVOKE INSERT ON *.* from user1;
revoke execute on procedure db1.p1 from user1;
#user1
show grants for user1;
Grants for user1@%
GRANT CREATE, SELECT ON *.* TO 'user1'
GRANT CREATE ROUTINE ON `db1`.* TO 'user1'
GRANT ALTER ROUTINE ON PROCEDURE `db1`.`p1` TO 'user1'
CALL p1;
ERROR 42000: EXECUTE command denied to user 'user1'@'%' for routine 'p1'
#user2     
CALL p1;
#给user2 添加insert 权限，调用 user1.p1
#root
grant insert on db1.* to user2;
#user2 
show grants FOR user2;
Grants for user2@%
GRANT SELECT ON *.* TO 'user2'
GRANT INSERT ON `db1`.* TO 'user2'
GRANT EXECUTE ON PROCEDURE `db1`.`p1` TO 'user2'
CALL p1;
#恢复user1 execute和insert权限，user2调用p1
#root
GRANT EXECUTE ON PROCEDURE db1.p1 to  user1;
GRANT INSERT ON db1.* to user1;
#user1
show grants FOR user1;
Grants for user1@%
GRANT CREATE, SELECT ON *.* TO 'user1'
GRANT INSERT, CREATE ROUTINE ON `db1`.* TO 'user1'
GRANT EXECUTE, ALTER ROUTINE ON PROCEDURE `db1`.`p1` TO 'user1'
CALL p1;
#user2
#缺少insert权限
CALL p1;
#drop user1, user2调用 p1. 预期成功。
#root
grant insert  on *.* to user2;
DROP USER user1;
Warnings:
Warning	4005	User 'user1'@'%' is referenced as a definer account in a stored routine.
#user2
use db1;
CALL p1;
#root
use db1;
DROP PROCEDURE p1;
#user2
CALL p1;
ERROR 42000: procedure db1.p1 does not exist
#root
DROP USER user2;
DROP database db1;
