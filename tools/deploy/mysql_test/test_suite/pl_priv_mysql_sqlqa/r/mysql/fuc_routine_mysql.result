DROP FUNCTION f2;
#不自动创建权限   set global automatic_sp_privileges = 0;
#root下设置
set global automatic_sp_privileges = 0;
#创建者下执行 验证 是否自动添加 execute和alter routine权限
select @@automatic_sp_privileges;
@@automatic_sp_privileges
0
create function f3() returns int deterministic
begin
INSERT INTO t1 VALUES(1);
return 3;
END;
/
