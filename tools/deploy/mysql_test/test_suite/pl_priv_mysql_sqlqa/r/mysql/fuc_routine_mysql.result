ALTER FUNCTION f2 COMMENT 'f2 revoke 验证权限!!!!!!';
ERROR 42000: ALTER ROUTINE command denied to user 'zwc'@'%' for routine 'f2'
DROP FUNCTION f2;
ERROR 42000: ALTER ROUTINE command denied to user 'zwc'@'%' for routine 'f2'
