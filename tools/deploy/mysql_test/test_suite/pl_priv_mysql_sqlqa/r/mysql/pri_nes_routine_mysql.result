purge recyclebin;
drop database if exists db1;
create database db1;
use db1;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
drop user root1;
create user 'root1' identified by '123';
GRANT ALL PRIVILEGES ON *.* TO 'root1'@'%' WITH GRANT OPTION;
#root1
use db1;
select user();
user()
root1@127.0.0.1
drop database if exists db3;
CREATE database db3;
#嵌套
#root
set global automatic_sp_privileges = 1;
drop user oer1;
create user 'oer1' identified by '123';
grant CREATE,INSERT,SELECT,DELETE,update on *.* to oer1;
GRANT CREATE ROUTINE ON db3.* to oer1;
grant INSERT,select on *.* to oer1;
show grants for oer1;
Grants for oer1@%
GRANT CREATE, DELETE, INSERT, UPDATE, SELECT ON *.* TO 'oer1'
GRANT CREATE ROUTINE ON `db3`.* TO 'oer1'
#oer1
use db3;
CREATE TABLE t1(c1 int);
CREATE TABLE t2(c2 int);
INSERT INTO t2 values(6),(6),(6),(6),(6);
CREATE PROCEDURE p1()
begin
INSERT INTO t1 VALUES(1);
SELECT f2();
END;
/
CREATE PROCEDURE p2()
begin
INSERT INTO t1 VALUES(1);
DELETE FROM t2 WHERE c2 = f2();
END;
/
show grants FOR oer1;
Grants for oer1@%
GRANT CREATE, DELETE, INSERT, UPDATE, SELECT ON *.* TO 'oer1'
GRANT CREATE ROUTINE ON `db3`.* TO 'oer1'
GRANT EXECUTE, ALTER ROUTINE ON PROCEDURE `db3`.`p2` TO 'oer1'
GRANT EXECUTE, ALTER ROUTINE ON PROCEDURE `db3`.`p1` TO 'oer1'
#root
drop user oer2;
create user 'oer2' identified by '123';
grant CREATE,INSERT,SELECT,DELETE,update on *.* to oer2;
GRANT CREATE ROUTINE ON db3.* to oer2;
grant INSERT,select on *.* to oer2;
show grants for oer2;
Grants for oer2@%
GRANT CREATE, DELETE, INSERT, UPDATE, SELECT ON *.* TO 'oer2'
GRANT CREATE ROUTINE ON `db3`.* TO 'oer2'
#oer2
use db3;
CREATE  function f2() returns int
begin
UPDATE t1 SET c1 = 6 WHERE c1 = 1;
return 6;
END;
/
show grants FOR oer2;
Grants for oer2@%
GRANT CREATE, DELETE, INSERT, UPDATE, SELECT ON *.* TO 'oer2'
GRANT CREATE ROUTINE ON `db3`.* TO 'oer2'
GRANT EXECUTE, ALTER ROUTINE ON FUNCTION `db3`.`f2` TO 'oer2'
#root
drop user oer3;
create user 'oer3' identified by '123';
grant CREATE,INSERT,SELECT,DELETE,update on *.* to oer3;
GRANT CREATE ROUTINE ON db3.* to oer3;
grant INSERT,select on *.* to oer3;
show grants for oer3;
Grants for oer3@%
GRANT CREATE, DELETE, INSERT, UPDATE, SELECT ON *.* TO 'oer3'
GRANT CREATE ROUTINE ON `db3`.* TO 'oer3'
#oer3
use db3;
CREATE  function f3() returns int DETERMINISTIC
begin
CALL p1();
return 10;
END;
/
CREATE  function f4() returns int DETERMINISTIC
begin
CALL p2();
return 20;
END;
/
show grants FOR oer3;
Grants for oer3@%
GRANT CREATE, DELETE, INSERT, UPDATE, SELECT ON *.* TO 'oer3'
GRANT CREATE ROUTINE ON `db3`.* TO 'oer3'
GRANT EXECUTE, ALTER ROUTINE ON FUNCTION `db3`.`f3` TO 'oer3'
GRANT EXECUTE, ALTER ROUTINE ON FUNCTION `db3`.`f4` TO 'oer3'
#oer3
#oer3调用 p1 ,p1包含 f2(),需要有p1,f2的执行权限
CALL p1();
ERROR 42000: EXECUTE command denied to user 'oer3'@'%' for routine 'p1'
#root
GRANT EXECUTE  ON PROCEDURE `db3`.`p1` TO 'oer3';
#oer3 预期报错缺少 f2 execute权限
CALL p1();
ERROR 42000: EXECUTE command denied to user 'oer1'@'%' for routine 'f2'
#root
GRANT EXECUTE ON FUNCTION `db3`.`f2` TO 'oer3';
#oer3 预期报错  oer1缺少对 f2的execute权限
CALL p1();
ERROR 42000: EXECUTE command denied to user 'oer1'@'%' for routine 'f2'
#root
GRANT EXECUTE ON FUNCTION `db3`.`f2` TO 'oer1';
#oer3
CALL p1();
f2()
6
SELECT f2();
f2()
6
#不允许返回结果集
SELECT f3();
ERROR 0A000: Not allowed to return a result set from a function
SELECT f4();
ERROR 42000: EXECUTE command denied to user 'oer3'@'%' for routine 'p2'
#root
GRANT EXECUTE  ON PROCEDURE `db3`.`p2` TO 'oer3';
#oer3
SELECT f4();
f4()
20
#oer2
call p1();
ERROR 42000: EXECUTE command denied to user 'oer2'@'%' for routine 'p1'
CALL p2();
ERROR 42000: EXECUTE command denied to user 'oer2'@'%' for routine 'p2'
#root
GRANT EXECUTE  ON PROCEDURE db3.p1,db3.p2 TO 'oer2';
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near ',db3.p2 TO 'oer2'' at line 1
GRANT EXECUTE  ON PROCEDURE db3.p1 TO 'oer2';
GRANT EXECUTE  ON PROCEDURE db3.p2 TO 'oer2';
#oer2
CALL p1();
f2()
6
CALL p2();
SELECT f2();
f2()
6
#oer2需要有 f3,f4的执行权限
SELECT f3();
ERROR 42000: EXECUTE command denied to user 'oer2'@'%' for routine 'f3'
SELECT f4();
ERROR 42000: EXECUTE command denied to user 'oer2'@'%' for routine 'f4'
#root
GRANT EXECUTE ON FUNCTION `db3`.`f3` TO 'oer2';
GRANT EXECUTE ON FUNCTION `db3`.`f4` TO 'oer2';
#oer2
SELECT f3();
ERROR 0A000: Not allowed to return a result set from a function
SELECT f4();
f4()
20
#oer1
CALL p1;
f2()
6
CALL p2;
SELECT f2();
f2()
6
SELECT f3();
ERROR 42000: EXECUTE command denied to user 'oer1'@'%' for routine 'f3'
SELECT f4();
ERROR 42000: EXECUTE command denied to user 'oer1'@'%' for routine 'f4'
#root
#oer1需要 f3 ,f4 execute权限
GRANT EXECUTE ON FUNCTION `db3`.`f3` TO 'oer1';
GRANT EXECUTE ON FUNCTION `db3`.`f4` TO 'oer1';
#oer1
SELECT f3();
ERROR 0A000: Not allowed to return a result set from a function
SELECT f4();
f4()
20
#alter routine
#oer1 
ALTER  PROCEDURE p1 SQL SECURITY INVOKER;
#oer2
CALL p1;
f2()
6
ALTER  PROCEDURE p1 SQL SECURITY DEFINER;
ERROR 42000: ALTER ROUTINE command denied to user 'oer2'@'%' for routine 'p1'
#oer3
CALL p1;
f2()
6
ALTER  PROCEDURE p1 SQL SECURITY DEFINER;
ERROR 42000: ALTER ROUTINE command denied to user 'oer3'@'%' for routine 'p1'
#root 
#p1 为invoker 收回 f2 执行权限，其他用户调用 只需要又 p1,f2 执行权限就能调用。
show grants for oer1;
Grants for oer1@%
GRANT CREATE, DELETE, INSERT, UPDATE, SELECT ON *.* TO 'oer1'
GRANT CREATE ROUTINE ON `db3`.* TO 'oer1'
GRANT EXECUTE, ALTER ROUTINE ON PROCEDURE `db3`.`p2` TO 'oer1'
GRANT EXECUTE, ALTER ROUTINE ON PROCEDURE `db3`.`p1` TO 'oer1'
GRANT EXECUTE ON FUNCTION `db3`.`f2` TO 'oer1'
GRANT EXECUTE ON FUNCTION `db3`.`f3` TO 'oer1'
GRANT EXECUTE ON FUNCTION `db3`.`f4` TO 'oer1'
REVOKE EXECUTE ON PROCEDURE  `db3`.`p1` FROM  'oer1';
#oer2 拥有oer1 p1执行权限，拥有 oer2 f2 执行权限。 
CALL p1();
f2()
6
#oer3 拥有oer1 p1执行权限，拥有 oer2 f2 执行权限。 
CALL p1();
f2()
6
#root 
use db3;
GRANT EXECUTE ON PROCEDURE db3.p1 TO oer1;
ALTER  PROCEDURE p1 SQL SECURITY DEFINER;
#修改 f3 为 invoker f3的 执行权限（oer3）
ALTER  FUNCTION  f3 SQL SECURITY INVOKER;
REVOKE EXECUTE ON FUNCTION  `db3`.`f3` FROM  'oer3';
ALTER  FUNCTION  f4 SQL SECURITY INVOKER;
REVOKE EXECUTE ON FUNCTION  `db3`.`f4` FROM  'oer3';
#oer3
SELECT f3;
Got one of the listed errors
SELECT f4;
ERROR 42000: EXECUTE command denied to user 'oer3'@'%' for routine 'f4'
#oer2
SELECT f3;
ERROR 0A000: Not allowed to return a result set from a function
SELECT f4;
f4
20
#oer1
SELECT f3;
ERROR 0A000: Not allowed to return a result set from a function
SELECT f4;
f4
20
#root
#给oer1 添加 修改 f3,f4权限，修改 SQL SECUITY 为 definer， 验证执行。
GRANT  ALTER ROUTINE ON FUNCTION `db3`.`f3` TO 'oer1';
GRANT  ALTER ROUTINE ON FUNCTION `db3`.`f4` TO 'oer1';
#oer1
ALTER  FUNCTION  f3,f4  SQL SECURITY DEFINER;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near ',' at line 1
ALTER  FUNCTION  f3 SQL SECURITY DEFINER;
ALTER  FUNCTION  f4 SQL SECURITY DEFINER;
SELECT f3;
Got one of the listed errors
SELECT f4;
ERROR 42000: EXECUTE command denied to user 'oer3'@'%' for routine 'f4'
#oer3
SELECT f3;
Got one of the listed errors
SELECT f4;
ERROR 42000: EXECUTE command denied to user 'oer3'@'%' for routine 'f4'
#drop 
#oer1
DROP PROCEDURE p1;
DROP FUNCTION f2;
ERROR 42000: ALTER ROUTINE command denied to user 'oer1'@'%' for routine 'f2'
DROP PROCEDURE p2;
DROP FUNCTION f3;
DROP FUNCTION f4;
#root
GRANT  ALTER ROUTINE ON FUNCTION `db3`.`f2` TO 'oer1';
#oer1
DROP FUNCTION f2;
#root
DROP TABLE t1;
DROP TABLE t2;
