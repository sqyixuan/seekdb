set global automatic_sp_privileges = 1;
 
 
 
--echo	#root下，definer定义为 NULL 为空
delimiter /;
--error 1064
CREATE DEFINER= null function f3_definer() returns int deterministic
begin
  INSERT INTO t1 VALUES(1);
  return 3;
END;
/
delimiter ;/
 
delimiter /;
--error 1064
CREATE DEFINER is null function f3_definer() returns int deterministic
begin
  INSERT INTO t1 VALUES(1);
  return 3;
END;
/
delimiter ;/
 
 
delimiter /;
--error 1064
CREATE DEFINER = ' ' null function f3_definer() returns int deterministic
begin
  INSERT INTO t1 VALUES(1);
  return 3;
END;
/
delimiter ;/
 
 
 
 
 
 
 
--echo	#删除user后再创建，权限验证
--echo	#创建者下执行
connection zwc;
 
delimiter /;
CREATE  function f4_drop_user() returns int deterministic
begin
  INSERT INTO t1 VALUES(1);
  return 10;
END;
/
delimiter ;/
 
show grants FOR zwc;
 
SELECT f4_drop_user();
 
ALTER FUNCTION f4_drop_user SQL SECURITY INVOKER;
 
ALTER FUNCTION f4_drop_user COMMENT 'f4 删除user';
 
#show function status like '%f4_drop_user%';
 
 
--echo	#root下删除 创建者
connection root1;
DROP USER zwc;
 
--echo	#创建者下执行验证权限
connection zwc;
 
--error 1133
SELECT f4_drop_user();
 
--error 1133
ALTER FUNCTION f4_drop_user SQL SECURITY INVOKER;
 
--error 1133
ALTER FUNCTION f4_drop_user COMMENT 'f4 删除user';
 
#show function status like '%f4_drop_user%';
 
--error 1133
show grants FOR zwc;
 
 
--echo	#root下创建zwc
connection root1;
 
create user 'zwc' identified by '123';
grant create on *.* to zwc;
grant insert on *.* to zwc;
 
GRANT CREATE ROUTINE ON db1.* to zwc;
show grants for zwc;
 
 
 
 
--echo	#连接创建者下执行
connection zwc;
 
--error 1133
SELECT f4_drop_user();
 
--error 1133
ALTER FUNCTION f4_drop_user SQL SECURITY INVOKER;
 
--error 1133
ALTER FUNCTION f4_drop_user COMMENT 'f4 删除user';
 
#show function status like '%f4_drop_user%';
 
--error 1133
show grants FOR zwc;
 
--echo	#root下
connection root1;
 
DROP FUNCTION f4_drop_user;
DROP database db1;
DROP USER zwc;
 
 
 
 
--echo	#rename user后权限验证
--disable_warnings
drop database if exists db2;
--enable_warnings
 
create database db2;
use db2;
 
--disable_warnings
--error 0,1396
drop user zwc2;
--enable_warnings
 
create user 'zwc2' identified by '123';
grant create on *.* to zwc2;
grant insert on *.* to zwc2;
 
GRANT CREATE ROUTINE ON db2.* to zwc2;
show grants for zwc2;
 
--source mysql_test/include/check_schema_sync.inc
connect (zwc2,$OBMYSQL_MS0,zwc2,123,db2,$OBMYSQL_PORT);
 
 
 
 
 
--echo	#创建者 
connection zwc2;
use db2;
 
CREATE TABLE t2 (c2 int);
 
delimiter /;
CREATE  function f4_rename_user() returns int deterministic
begin
  INSERT INTO t1 VALUES(1);
  return 10;
END;
/
delimiter ;/
 
show grants for zwc2;
 
 
--echo	#root下 rename user
connection root1;
 
--disable_warnings
--error 0,1396
rename user zwc2 to zwc3;
--enable_warnings
 
--echo	#创建者下执行权限验证  bug: 
