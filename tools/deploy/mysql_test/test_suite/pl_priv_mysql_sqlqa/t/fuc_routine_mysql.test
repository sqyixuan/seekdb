purge recyclebin;
--disable_warnings
drop database if exists db1;
--enable_warnings
 
create database db1;
use db1;
 
 
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
 
--error 0,1396
drop user root1;
create user 'root1' identified by '123';
GRANT ALL PRIVILEGES ON *.* TO 'root1'@'%' WITH GRANT OPTION;
 
 
--source mysql_test/include/check_schema_sync.inc
connect (root1,$OBMYSQL_MS0,root1,123,db1,$OBMYSQL_PORT);
 
--echo	#root1
connection root1;
use db1;
select current_user;
 
 
 
 
--echo	#function
--echo	#创建create outine function
--echo	#root下
connection root1;
 
--error 0,1396
drop user zwc;
create user 'zwc' identified by '123';
grant create on *.* to zwc;
grant insert on *.* to zwc;
 
GRANT CREATE ROUTINE ON db1.* to zwc;
show grants for zwc;
 
--source mysql_test/include/check_schema_sync.inc
connect (zwc,$OBMYSQL_MS0,zwc,123,db1,$OBMYSQL_PORT);
 
 
 
 
--echo	#创建者 
--echo	#验证 create function后自动添加 execute和alter routine权限
connection zwc;
use db1;
 
CREATE TABLE t1 (c1 int);
delimiter /;
create function f1() returns int deterministic
begin
  INSERT INTO t1 VALUES(1);
  return 1;
END;
/
delimiter ;/
 
show grants for zwc;
 
#show function status like '%f1%';
 
 
--echo	#execute权限
SELECT f1();
 
--echo	#alter routine权限
ALTER FUNCTION f1 SQL SECURITY INVOKER;
 
ALTER FUNCTION f1 COMMENT 'f1 验证权限';
 
#show function status like '%f1%';
 
DROP FUNCTION f1;
 
 
--echo	#验证revoke excute 和 revoke alter routine
 
delimiter /;
create function f2() returns int deterministic
begin
  INSERT INTO t1 VALUES(1);
  return 2;
END;
/
delimiter ;/
 
show grants FOR zwc ;
 
select f2();
 
 
 
--echo	#revoke execute (root下执行)
connection root1;

#--error 5362
revoke execute on function db1.f2 from zwc;
 
 
--echo	#创建者验证权限
connection zwc;
--error 1370
SELECT f2();
 
show grants FOR zwc;
 
 
--echo	#revoke alter routine (root下执行)
connection root1;
#--error 5362
revoke ALTER ROUTINE  on function db1.f2 from zwc;
 
--echo	#创建者验证权限
connection zwc;
show grants;

--error 1370
ALTER FUNCTION f2 SQL SECURITY INVOKER;
 
--error 1370
ALTER FUNCTION f2 COMMENT 'f2 revoke 验证权限!!!!!!';
 
#show function status like '%f2%';
 
--error 1370
DROP FUNCTION f2;
 
--echo	#root
connection root1;
 
#--error 1305
DROP FUNCTION f2;
 
 
 
 
 
 
 
--echo	#不自动创建权限   set global automatic_sp_privileges = 0;
--echo	#root下设置
connection root1;
 
set global automatic_sp_privileges = 0;
 
--echo	#创建者下执行 验证 是否自动添加 execute和alter routine权限
connection zwc;
 
select @@automatic_sp_privileges;
 
delimiter /;
create function f3() returns int deterministic
begin
  INSERT INTO t1 VALUES(1);
  return 3;
END;
/
delimiter ;/
 
show grants FOR zwc;
 
--echo	#execute权限 预期报错，
--error 1370
SELECT f3();
 
--echo	#alter routine权限，预期报错
--error 1370
ALTER FUNCTION f3 SQL SECURITY INVOKER;
 
--error 1370
ALTER FUNCTION f3 COMMENT 'f3 revoke 验证权限';
 
#show function status like '%f3%';
 
 
--echo	#root下
connection root1;
 
DROP FUNCTION f3;
 
set global automatic_sp_privileges = 1;
 
 
--echo	#definer定义。
--echo	#指定user下 权限验证
 
--echo	#root下执行
delimiter /;
CREATE DEFINER= zwc function f1_definer() returns int deterministic
begin
  INSERT INTO t1 VALUES(1);
  return 3;
END;
/
delimiter ;/
 
#show function status like '%f1_definer%';
 
--echo	#创建者zwc下 验证权限 报错。
connection zwc;
 
show grants FOR zwc;
 
--error 1370
SELECT f1_definer();
 
--error 1370
ALTER FUNCTION f1_definer SQL SECURITY INVOKER;
 
--error 1370
DROP FUNCTION f1_definer;
 
--echo	#root下
connection root1;
 
DROP FUNCTION f1_definer;
 
 
 
--echo	#当前用户创建者下验证 bug:
