##show function status like '%f4_rename_user%';
##--error 1133
##show grants FOR zwc;
 
 
--echo	#root
connection root1;
 
DROP database db2;
DROP USER zwc3;
 
 
 
 
 
 
--echo	#创建user ，user为definer定义的孤儿对象
--echo	#root下创建 function定义一个孤儿对象
connection root1;
 
drop database if exists db3;
CREATE database db3;
use db3;
 
CREATE TABLE t3(c3 int);
 
delimiter /;
CREATE  DEFINER = 'gr' function f1_gr() returns int deterministic
begin
  INSERT INTO t1 VALUES(1);
  return 10;
END;
/
delimiter ;/
 
#show function status like '%f1_gr%';
 
--error 0,1396
drop user gr;
 
create user 'gr' identified by '123';
grant create on *.* to gr;
grant insert on *.* to gr;
 
GRANT CREATE ROUTINE ON db3.* to gr;
show grants for gr;
 
 
--echo	#连接 创建者gr
--source mysql_test/include/check_schema_sync.inc
connect (gr,$OBMYSQL_MS0,gr,123,db3,$OBMYSQL_PORT);
 
connection gr;
 
--error 1370
SELECT f1_gr();
 
--error 1370
ALTER FUNCTION f1_gr SQL SECURITY INVOKER;
 
--error 1370
ALTER FUNCTION f1_gr COMMENT 'f1 f1_gr u';
 
--error 1370
DROP FUNCTION f1_gr;
 
show grants FOR gr;
 
 
--echo	#root
connection root1;
 
DROP database db3;
DROP USER gr;
 
 
 
 
 
--echo	#security type
--echo	#root下创建
connection root1;
 
CREATE database db1;
 
--error 0,1396
drop user user1;
create user 'user1' identified by '123';
grant CREATE on *.* to user1;
grant insert on *.* to user1;
grant SELECT  on *.* to user1;
 
GRANT CREATE ROUTINE ON db1.* to user1;
show grants for user1;
 
 
--source mysql_test/include/check_schema_sync.inc
connect (user1,$OBMYSQL_MS0,user1,123,db1,$OBMYSQL_PORT);
 
--echo	#user1 
connection user1;
use db1;
 
CREATE TABLE t1(c1 int);
 
delimiter /;
create procedure p1() 
begin 
	INSERT INTO t1 VALUES(1); 	
END;
/
delimiter ;/
 
#show procedure status like '%p1%';
 
 
--echo	#root下 创建user2 
--echo	#security type=definer 验证无insert 权限调用 user1.p1，预期调用成功。
connection root1;
 
--error 0,1396
drop user user2;
create user 'user2' identified by '123';
GRANT EXECUTE ON PROCEDURE  db1.p1 TO user2;
grant SELECT  on *.* to user2;
show grants for user2;
 
--echo	#user2
--source mysql_test/include/check_schema_sync.inc
connect (user2,$OBMYSQL_MS0,user2,123,db1,$OBMYSQL_PORT);
 
connection user2;
use db1;
 
CALL p1;
SELECT * FROM t1;
 
 
 
--echo	#security type= invoker时, user2 调用user1.p1 ，预期报错无insert权限
--echo	#user1
connection user1;
 
alter procedure p1 SQL SECURITY INVOKER ;
 
#show procedure status like '%p1%';
 
 
 
--echo	#user2
--echo	#ERROR 1142 (42000): INSERT command denied to user 'user2'@'%' for table 't1'
connection user2;
 
--error 0,1142
CALL p1;
 
 
--echo	#security type= invoker时,  user1的 权限被回收，user2调用 user1.p1
 
--echo	#root
connection root1;
 
REVOKE INSERT ON *.* from user1;
#--error 5362
revoke execute on procedure db1.p1 from user1;
 
--echo	#user1
connection user1;
 
show grants for user1;
--error 1370
CALL p1;
 
--echo	#user2     
connection user2;
 
--error 0,1142
CALL p1;
 
--echo	#给user2 添加insert 权限，调用 user1.p1
--echo	#root
connection root1;
 
grant insert on db1.* to user2;
 
 
--echo	#user2 
connection user2;
 
show grants FOR user2;
 
--error 0,1142
CALL p1;
 
 
--echo	#恢复user1 execute和insert权限，user2调用p1
--echo	#root
connection root1;
 
GRANT EXECUTE ON PROCEDURE db1.p1 to  user1;
GRANT INSERT ON db1.* to user1;
 
 
--echo	#user1
connection user1;
 
show grants FOR user1;
CALL p1;
 
 
--echo	#user2
connection user2;
 
--echo	#缺少insert权限
--error 0,1142
CALL p1;
 
 
--echo #drop user1, user2调用 p1. 预期成功。
--echo	#root
connection root1;
grant insert  on *.* to user2;
 
DROP USER user1;
 
--echo	#user2
connection user2;
use db1;
 
CALL p1;
 
 
--echo	#root
connection root1;
use db1;
 
DROP PROCEDURE p1;
 
--echo #user2
--error 1305
CALL p1;
 
 
--echo	#root
DROP USER user2;
DROP database db1;
 
 
 
 
 
 
 
--echo	#function  security type =INVOKER
--echo	#root
connection root1;
create database db1;
use db1;
 
 
--error 0,1396
drop user test1;
create user 'test1' identified by '123';
grant CREATE on *.* to test1;
grant insert on *.* to test1;
grant SELECT  on *.* to test1;
 
GRANT CREATE ROUTINE ON db1.* to test1;
show grants for test1;
 
--echo	#连接test1
--source mysql_test/include/check_schema_sync.inc
connect (test1,$OBMYSQL_MS0,test1,123,db1,$OBMYSQL_PORT);
 
connection test1;
use db1;
 
CREATE TABLE t2(c2 int);
 
 
delimiter /;
CREATE  function test1_f1() returns int DETERMINISTIC
SQL SECURITY INVOKER
begin
  INSERT INTO t2 VALUES(1);
  return 10;
END;
/
delimiter ;/
 
SELECT test1_f1();
SELECT * FROM t2;
 
#show function status like '%test1_f1%';
 
 
 
--echo	#root
connection root1;
 
--error 0,1396
drop user test2;
create user 'test2' identified by '123';
GRANT EXECUTE ON function  db1.test1_f1 TO test2;
grant insert on db1.* to test2;
grant SELECT  on *.* to test2;
show grants for test2;
 
 
--echo	#test2 
--source mysql_test/include/check_schema_sync.inc
connect (test2,$OBMYSQL_MS0,test2,123,db1,$OBMYSQL_PORT);
 
connection test2;
 
use db1;
 
--echo	#test2调用test1_f1。预期成功。
SELECT test1_f1();
 
SELECT * FROM t2;
 
 
--echo	#收回test1 execute权限，test2调用test1_f1,预期执行成功，security type =INVOKER时，只看当前用户执行权限。 
--echo	#root
connection root1;
 
#--error 5362
revoke execute on function db1.test1_f1 from test1;
 
--echo	#test1
connection test1;
 
show grants FOR test1;
 
--error 1370
SELECT test1_f1();
 
--echo	#test2
connection test2;
 
SELECT test1_f1();
SELECT * FROM t2;
 
 
 
--echo	#收回test1 insert权限，test2调用test_f1, 预期执行成功
--echo	#root
connection root1;
 
REVOKE INSERT ON *.* FROM  test1;
 
--echo	#test1
connection test1;
 
show grants FOR test1;
 
--echo	#test2
connection test2;
 
SELECT test1_f1();
SELECT * FROM t2;
 
 
--echo	#收回test2 execute权限
--echo	#root
connection root1;

show grants for test2;
#--error 5362 
REVOKE EXECUTE ON FUNCTION db1.test1_f1 FROM test2;
 
--echo	#test2
connection test2;
 
show grants FOR test2;
 
--error 1370
SELECT test1_f1();
 
 
--echo	#给user2 添加 ALTER ROUTINE 权限。修改 security type =definer
--echo	#root 
connection root1;
 
GRANT ALTER ROUTINE ON FUNCTION db1.test1_f1 TO test2;
 
--echo	#test2
connection test2;
 
show grants FOR test2;
 
alter FUNCTION  test1_f1 SQL SECURITY DEFINER ;
 
--echo	#调用test1_f1; 预期报错，user1没有执行权限。
--error 1370, 1142
SELECT test1_f1();
 
 
--echo	#给user1 添加执行权限 再 用test2 去验证 
--echo	#root
connection root1;
 
GRANT EXECUTE ON PROCEDURE db1.test1_f1 TO test1;
 
--echo	#test1
connection test1;
 
show grants FOR test1;
 
SELECT test1_f1();
SELECT * FROM t2;
 
 
--echo	#test2
connection test2;
 
--error 1142,1370 
SELECT test1_f1();
SELECT * FROM t2;
 
 
--echo	#root
connection root1;
 
DROP database db1;
DROP USER test1;
DROP USER test2;
 
