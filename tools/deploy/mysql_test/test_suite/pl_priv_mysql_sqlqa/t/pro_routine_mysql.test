--disable_warnings
--error 0,1396
drop user zwc1;
--enable_warnings
 
 
--echo	#rename user后进行权限验证
--echo	#zwc
connection zwc;

show grants;
drop procedure p1; 
 
delimiter /;
create  procedure p1()
BEGIN
    select 1 from dual;
END;
/
delimiter ;/
 
show grants for zwc;
 
 
--echo	#root
connection root1;
 
rename user zwc to zwc1;
 
 
--echo	#zwc
connection zwc;
 
 
--error 1449
call p1();
 
 
ALTER PROCEDURE p1 LANGUAGE SQL READS SQL DATA  SQL SECURITY INVOKER COMMENT 'SQL SECURITY=INVOKER';
 
drop procedure p1;
 
 
 
--echo	#创建的user为 definer定义的孤儿对象
--echo	#root
connection root1;
 
delimiter /;
CREATE DEFINER =zz1 PROCEDURE p6()
BEGIN
    select 1 from dual;
END;
/
delimiter ;/
 
#show procedure status like '%p6%';
 
--disable_warnings
--error 0,1396
drop user zz1;
--enable_warnings
 
create user 'zz1' identified by '123';
grant create on *.* to zz1;
GRANT CREATE ROUTINE ON db1.* to zz1;
show grants for zz1;
 
--source mysql_test/include/check_schema_sync.inc
connect (zz1,$OBMYSQL_MS0,zz1,123,db1,$OBMYSQL_PORT);
 
--echo	#zz1
connection zz1;
use db1;
 
 
--error 1370
call p6;
 
 
--echo	#root1
connection root1;
GRANT EXECUTE, ALTER ROUTINE ON PROCEDURE db1.p6 TO zz1;
 
 
--echo	#zz1
connection zz1;
ALTER PROCEDURE p6 LANGUAGE SQL READS SQL DATA  SQL SECURITY INVOKER COMMENT 'SQL SECURITY=INVOKER';
#show procedure status like '%p1%';
 
drop procedure p6;
 
 
 
 
 
--echo	#rename user 目标是一个definer
--echo	#root
connection root1;
 
--disable_warnings
--error 0,1396
drop user rn1;
--enable_warnings
 
--disable_warnings
--error 0,1396
drop user rn2;
--enable_warnings
 
 
create user 'rn1' identified by '123';
grant create on *.* to rn1;
GRANT CREATE ROUTINE ON db1.* to rn1;
show grants for rn1;
 
--source mysql_test/include/check_schema_sync.inc
connect (rn1,$OBMYSQL_MS0,rn1,123,db1,$OBMYSQL_PORT);
 
 
 
--echo	#root下执行 
connection root1;
use db1;
 
delimiter /;
CREATE DEFINER =rn2 PROCEDURE p1()
BEGIN
    select 1 from dual;
END;
/
delimiter ;/
 
#show procedure status like '%p1%';
 
rename user rn1 to rn2;
 
 
 
--echo	#rn2下执行
connection rn1;
 
--error 1370
call p1;
 
--error 1370
ALTER PROCEDURE p1 LANGUAGE SQL READS SQL DATA  SQL SECURITY INVOKER COMMENT 'SQL SECURITY=INVOKER';
 
#show procedure status like '%p1%';
 
--error 1370
drop procedure p1;
 
 
 
 
--echo	#create user 用户是任意一个stored object的definer
--echo	#Root
CONNECTION root1;
use db1;
drop procedure p1;
 
delimiter /;
CREATE DEFINER =zz2 PROCEDURE p10()
BEGIN
    select 1 from dual;
END;
/
delimiter ;/
 
 
--disable_warnings
--error 0,1396
drop user zz2;
--enable_warnings
 
create user 'zz2' identified by '123';
grant create on *.* to zz2;
GRANT CREATE ROUTINE ON db1.* to zz2;
GRANT EXECUTE, ALTER ROUTINE ON PROCEDURE db1.p10 TO zz2;
show grants for zz2;
 
 
 
--source mysql_test/include/check_schema_sync.inc
connect (zz2,$OBMYSQL_MS0,zz2,123,db1,$OBMYSQL_PORT);
 
 
--echo	#zz2
connection zz2;
use db1;
 
CALL p10();
 
ALTER PROCEDURE p10 LANGUAGE SQL READS SQL DATA  SQL SECURITY INVOKER COMMENT 'SQL SECURITY=INVOKER';
 
ALTER PROCEDURE  p10 SQL SECURITY INVOKER;
 
#show procedure status like '%p10%';
 
drop procedure p10;
 
 
 
 
 
 
 
--echo	#root1
connection root1;
drop database db1;
 
 