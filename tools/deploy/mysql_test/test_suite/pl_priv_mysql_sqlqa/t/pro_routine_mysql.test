purge recyclebin;
--disable_warnings
drop database if exists db1;
--enable_warnings
 
create database db1;
use db1;
 
 
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
 
--error 0,1396
drop user root1;
create user 'root1' identified by '123';
GRANT ALL PRIVILEGES ON *.* TO 'root1'@'%' WITH GRANT OPTION;
 
 
--source mysql_test/include/check_schema_sync.inc
connect (root1,$OBMYSQL_MS0,root1,123,db1,$OBMYSQL_PORT);
 
--echo	#root1
connection root1;
 
use db1;
 
select current_user();
 
set global automatic_sp_privileges = 1;
 
select @@automatic_sp_privileges;
 
 
 
 
--disable_warnings
--error 0,1396
drop user zwc;
--enable_warnings
 
create user 'zwc' identified by '123';
grant create on *.* to zwc;
GRANT CREATE ROUTINE ON db1.* to zwc;
 
--source mysql_test/include/check_schema_sync.inc
connect (zwc,$OBMYSQL_MS0,zwc,123,db1,$OBMYSQL_PORT);
 
--echo	#zwc
connection zwc;
use db1;
select current_user();
show grants for zwc;
 
 
--echo	#创建procedure，查看权限是否自动添加 execute，和alter routine
delimiter /;
create  procedure p1()
begin
select 1 from dual;
 end;
/
delimiter ;/
 
show grants for zwc;
 
--echo	#执行验证
call p1();
 
--echo	#修改验证  bug:
ALTER PROCEDURE p1 LANGUAGE SQL READS SQL DATA  SQL SECURITY INVOKER COMMENT 'SQL SECURITY=INVOKER';
#show procedure status like '%p1%';
 
--echo	#删除
drop procedure p1;
 
 
--echo	#修改 set global automatic_sp_privileges = 0
--echo	#root
 
connection root1;
 
select @@automatic_sp_privileges;
 
set global automatic_sp_privileges = 0;
 
 
--echo	#zwc
connection zwc;
delimiter /;
create  procedure p1()
begin
select 1 from dual;
 end;
/
delimiter ;/
 
show grants for zwc;
 
 
--echo	#权限验证，预期报错
 
--error 1370
call p1;
 
--error 1370
ALTER PROCEDURE p1 LANGUAGE SQL READS SQL DATA  SQL SECURITY DEFINER COMMENT 'SQL SECURITY=DEFINER';
 
--error 1370
drop procedure p1;
 
 
--echo	#root1
connection root1;
 
set global automatic_sp_privileges = 1;
 
select @@automatic_sp_privileges;
 
 
--echo	#创建 prcedure定义SQL SECURITY
--echo	#zwc
connection zwc;
 
 
delimiter /;
#--error 1227
CREATE DEFINER = zwc PROCEDURE p2()
SQL SECURITY INVOKER
BEGIN
    select 2 from dual;
END;
/
delimiter ;/
#show procedure status like '%p2%';
 
##drop procedure p2;
 
 
delimiter /;
#--error 1227
CREATE DEFINER = zwc PROCEDURE p3()
SQL SECURITY DEFINER
BEGIN
    select 2 from dual;
END;
/
delimiter ;/
#show procedure status like '%p3%';
 
 
 
##ALTER PROCEDURE p3 LANGUAGE SQL READS SQL DATA  SQL SECURITY INVOKER COMMENT 'SQL SECURITY=INVOKER';
 
##show procedure status like '%p3%';
 
##DROP PROCEDURE p3;
 
 
