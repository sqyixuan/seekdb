--enable_sorted_result
purge recyclebin;
--disable_warnings
drop database if exists db1;
--enable_warnings
 
create database db1;
use db1;
 
 
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
 
 
 
 
--error 0,1396
drop user root1;
create user 'root1' identified by '123';
GRANT ALL PRIVILEGES ON *.* TO 'root1'@'%' WITH GRANT OPTION;
 
 
--source mysql_test/include/check_schema_sync.inc
connect (root1,$OBMYSQL_MS0,root1,123,db1,$OBMYSQL_PORT);
 
--echo	#root1
connection root1;
use db1;
select current_user;
 
 
--echo	#trigger 定义SQL SECURITY INVOKER  预期报错
 
--error 0,1396
drop user zz1;
 
create user 'zz1' identified by '123';
grant CREATE,INSERT,select on *.* to zz1;
GRANT CREATE ROUTINE ON db1.* to zz1;
grant INSERT,select on *.* to zz1;
 
show grants for zz1;
 
--source mysql_test/include/check_schema_sync.inc
connect (zz1,$OBMYSQL_MS0,zz1,123,db1,$OBMYSQL_PORT);
 
 
use db1;
CREATE TABLE t4(c1 int);
CREATE TABLE t5(c1 int);
 
 
DELIMITER /;
--error 1064
CREATE TRIGGER trg1
AFTER INSERT ON t4 
FOR EACH ROW 
SQL SECURITY DEFINER  
BEGIN
INSERT INTO t5 values(1);
END; 
/
DELIMITER ;/
 
--echo	#root
 
connection root1;
DROP USER zz1;
 
 
--disable_warnings
drop database if exists db2;
--enable_warnings
 
 
--echo	#grant create赋予user routine权限
--echo	#root
--echo	#创建用户 
connection root1;
 
 
--error 0,1396
drop user pp1;
 
create user 'pp1' identified by '123';
grant CREATE,INSERT,SELECT,DELETE,update on *.* to pp1;
GRANT CREATE ROUTINE ON *.* to pp1;
show grants for pp1;
 
 
--source mysql_test/include/check_schema_sync.inc
connect (pp1,$OBMYSQL_MS0,pp1,123,db1,$OBMYSQL_PORT);
 
--echo	#pp1
connection pp1;
 
use db1;
 
delimiter /;
create  procedure p1()
begin
select 1 from dual;
 end;
/
delimiter ;/
 
 
show grants FOR pp1;
 
 
 
CREATE database db2;
use db2;
 
 
delimiter /;
create  procedure p2()
begin
select 1 from dual;
 end;
/
delimiter ;/
 
--error 1305
CALL p1();
 
--error 1305
ALTER PROCEDURE  p1 SQL SECURITY DEFINER;
 
--error 1370
DROP PROCEDURE p1;
show grants;

CALL p2();

ALTER PROCEDURE  p2 SQL SECURITY DEFINER;
 
use db1;
 
--error 1305
CALL p2();
 
#--error 1370
ALTER PROCEDURE  p1 SQL SECURITY DEFINER;
 
 
 
 
show grants FOR pp1;
 
--echo	#revoke收回 create routine db2权限
connection root1;
 
--error 1064
REVOKE  CREATE ROUTINE ON db2 to  pp1;
 
--error 1144
REVOKE  CREATE ROUTINE ON db2 FROM  pp1;
 
--error 1064
REVOKE  CREATE ROUTINE ON db2.p2 to  pp1;
 
--error 1144
REVOKE  CREATE ROUTINE ON db2.p2 FROM  pp1;
 
--error 1064
REVOKE CREATE ROUTINE ON *.* TO 'pp1';
 
REVOKE CREATE ROUTINE ON *.* from 'pp1';
 
drop procedure if exists db2_p1;
 
 
--echo	#重连用户pp1才报错
--echo	#pp1
connection pp1;
show grants FOR pp1;
use db2;
 
delimiter /;
--error 0,1370
create  procedure db2_p1()
begin
select 1 from dual;
 end;
/
delimiter ;/
 
 
 
use db1;
delimiter /;
--error 0,1370
create  procedure db1_p1()
begin
select 1 from dual;
 end;
/
delimiter ;/
 
 
--echo	#root
connection root1;
 
grant create routine on db1.* to pp1;
 
 
use db1;
 
drop procedure if exists db1_p1;
drop procedure if exists p2;
drop procedure if exists db2_p2;
drop procedure if exists p3;
drop procedure if exists db2_pp1;
 
 
 
 
delimiter /;
create  procedure db1_p1()
begin
select 1 from dual;
 end;
/
delimiter ;/
 
 
--error 1144
grant create routine on db2 to pp1;
 
--error 1064
grant create routine on db2.* FROM  pp1;
 
--error 1144
grant create routine on db2.p1 to pp1;
 
--error 1305
grant create routine ON procedure db2.p1 to pp1;
 
--error 1144
grant create routine ON procedure db2.p2 to pp1;
 
 
--echo	#pp1
connection pp1;
 
use db2;
show grants;
#--error 1370
DROP PROCEDURE p2;
 
delimiter /;
#--error 1304
create  procedure p2()
begin
select 1 from dual;
 end;
/
delimiter ;/
 
 
--echo	#root
connection root1;
 
grant create routine on db2.* to pp1;
 
 
--echo	#pp1
connection pp1;
 
use db2;
 
delimiter /;
create  procedure db2_p2()
begin
select 'db2_p2' from dual;
 end;
/
delimiter ;/
 
#--error 1370
CALL db2_p2();
 
 
delimiter /;
create  procedure p3()
begin
select 'p3' from dual;
 end;
/
delimiter ;/
#--error 1370
CALL p3;
 
 
delimiter /;
--error 1304
create  procedure db2.p3()
begin
select 'db2.p3' from dual;
 end;
/
delimiter ;/
#--error 1370 
CALL db2.p3;
 
 
--echo	#root
connection root1;
 
--error 1064
REVOKE CREATE ROUTINE ON `db2`.* TO 'pp1';
--error 1064
REVOKE CREATE ROUTINE ON db2.* TO pp1;
 
 
REVOKE CREATE ROUTINE ON db2.* FROM  pp1;
 
GRANT CREATE ROUTINE ON db2.* to  pp1;
 
REVOKE CREATE ROUTINE ON `db2`.* from 'pp1';
 
show grants FOR pp1;
 
--echo	#pp1
connection pp1;
 
use db2;
 
 
delimiter /;
create  procedure db2_pp1()
begin
select 'db2_pp1' from dual;
 end;
/
delimiter ;/
 
 
--echo	#root
connection root1;
 
#--error 5362
REVOKE EXECUTE ON PROCEDURE `db1`.`p1` FROM  'pp1';
 
--echo	#pp1
connection pp1;
 
use db1;
--error 1370
CALL p1;
 
 show grants;
#--error 1370
ALTER PROCEDURE  p1 SQL SECURITY DEFINER;
show grants FOR pp1;
 
 
--echo	#root
connection root1;
 
--error 5362
REVOKE ALTER ROUTINE ON PROCEDURE db1 FROM pp1;
--error 1144
REVOKE ALTER ROUTINE ON PROCEDURE db1.* FROM pp1;
 
#--error 5362
REVOKE ALTER ROUTINE ON PROCEDURE db1.p1 FROM pp1;
 
--echo	#pp1
connection pp1;
 
use db1;
    
--error 1370
CALL p1;
 
--error 1370
ALTER PROCEDURE  p1 SQL SECURITY DEFINER;
 
show grants FOR pp1;
 
 
--echo	#root
connection root1;
 
GRANT EXECUTE,ALTER ROUTINE  ON PROCEDURE `db1`.`p1` to  'pp1';
select @@automatic_sp_privileges;
set global automatic_sp_privileges = 0;
 
#--error 5362
REVOKE EXECUTE ON PROCEDURE `db1`.`p1` FROM  'pp1';
 
--echo	#pp1
connection pp1;
 
use db1;
 
--error 1370
CALL p1;
 
ALTER PROCEDURE  p1 SQL SECURITY DEFINER;
show grants FOR pp1;
 
--echo	#root
connection root1;
 
REVOKE ALTER ROUTINE ON PROCEDURE db1.p1 FROM pp1;
 
--echo	#pp1
connection pp1;
 
use db1;
 
--error 1370
CALL p1;
 
--error 1370
ALTER PROCEDURE  p1 SQL SECURITY DEFINER;
 
show grants FOR pp1;
 
 
--echo	#root
connection root1;
set global automatic_sp_privileges = 1;
 
 
 
 
 
 
 
--echo	#root1
connection root1;
drop database db1;