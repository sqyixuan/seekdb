create table t1(c1 varchar(10));
insert into t1 values('EUR');
insert into t1 values('INTERNAL');
insert into t1 values('ISO');
insert into t1 values('JIS');
insert into t1 values('USA');
insert into t1 values('');
insert into t1 values('A');
insert into t1 values('123');
select c1, get_format(DATE, c1), get_format(TIME, c1), get_format(DATETIME, c1) from t1;
c1	get_format(DATE, c1)	get_format(TIME, c1)	get_format(DATETIME, c1)
EUR	%d.%m.%Y	%H.%i.%s	%Y-%m-%d %H.%i.%s
INTERNAL	%Y%m%d	%H%i%s	%Y%m%d%H%i%s
ISO	%Y-%m-%d	%H:%i:%s	%Y-%m-%d %H:%i:%s
JIS	%Y-%m-%d	%H:%i:%s	%Y-%m-%d %H:%i:%s
USA	%m.%d.%Y	%h:%i:%s %p	%Y-%m-%d %H.%i.%s
	NULL	NULL	NULL
A	NULL	NULL	NULL
123	NULL	NULL	NULL
create view v1 as select c1, get_format(DATE, c1) c2, get_format(TIME, c1) c3, get_format(DATETIME, c1) c4 from t1;
create table t2 as select c1, get_format(DATE, c1) c2, get_format(TIME, c1) c3, get_format(DATETIME, c1) c4 from t1;
desc v1;
Field	Type	Null	Key	Default	Extra
c1	varchar(10)	YES		NULL	
c2	varchar(17)	YES		NULL	
c3	varchar(17)	YES		NULL	
c4	varchar(17)	YES		NULL	
desc t2;
Field	Type	Null	Key	Default	Extra
c1	varchar(10)	YES		NULL	
c2	varchar(17)	YES		NULL	
c3	varchar(17)	YES		NULL	
c4	varchar(17)	YES		NULL	
show create view v1;
View	Create View	character_set_client	collation_connection
v1	CREATE VIEW `v1` AS select `test`.`t1`.`c1` AS `c1`,get_format(date, `test`.`t1`.`c1`) AS `c2`,get_format(time, `test`.`t1`.`c1`) AS `c3`,get_format(datetime, `test`.`t1`.`c1`) AS `c4` from `test`.`t1`	utf8mb4	utf8mb4_general_ci
drop table t1;
drop view v1;
set collation_connection = 'utf8_general_ci';
