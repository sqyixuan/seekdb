get_format(DATETIME, 'EUR')	get_format(DATETIME, 'INTERNAL')	get_format(DATETIME, 'ISO')	get_format(DATETIME, 'JIS')	get_format(DATETIME, 'USA')
%Y-%m-%d %H.%i.%s	%Y%m%d%H%i%s	%Y-%m-%d %H:%i:%s	%Y-%m-%d %H:%i:%s	%Y-%m-%d %H.%i.%s
