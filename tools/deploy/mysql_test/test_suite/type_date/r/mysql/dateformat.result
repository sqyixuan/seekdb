get_format(TIMESTAMP, 'EUR')	get_format(TIMESTAMP, 'INTERNAL')	get_format(TIMESTAMP, 'ISO')	get_format(TIMESTAMP, 'JIS')	get_format(TIMESTAMP, 'USA')
%Y-%m-%d %H.%i.%s	%Y%m%d%H%i%s	%Y-%m-%d %H:%i:%s	%Y-%m-%d %H:%i:%s	%Y-%m-%d %H.%i.%s
