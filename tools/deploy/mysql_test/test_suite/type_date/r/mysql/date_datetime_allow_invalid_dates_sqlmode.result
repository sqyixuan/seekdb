ERROR 42000: Invalid default value for 'c1'
create table t1(c1 date default '2021-2-28', c2 datetime default '2021-2-28 00:00:00', c3 timestamp default '2021-2-28 00:00:00');
desc t1;
+-------+-----------+------+-----+---------------------+-------+
| Field | Type      | Null | Key | Default             | Extra |
+-------+-----------+------+-----+---------------------+-------+
| c1    | date      | YES  |     | 2021-02-28          |       |
| c2    | datetime  | YES  |     | 2021-02-28 00:00:00 |       |
| c3    | timestamp | NO   |     | 2021-02-28 00:00:00 |       |
