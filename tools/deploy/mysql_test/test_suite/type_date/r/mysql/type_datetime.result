# Test for bug#11747847 - 34280: create table fails if NO_ZERO_DATE
# or NO_ZERO_IN_DATE SQL mode is set.
SELECT STR_TO_DATE('10:00 PM', '%h:%i %p');
STR_TO_DATE('10:00 PM', '%h:%i %p')
22:00:00
SELECT STR_TO_DATE('10:00 AM', '%h:%i %p');
STR_TO_DATE('10:00 AM', '%h:%i %p')
10:00:00
SELECT STR_TO_DATE('20:00 AM', '%h:%i %p');
STR_TO_DATE('20:00 AM', '%h:%i %p')
NULL
