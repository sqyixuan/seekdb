Table	Create Table
test	CREATE TABLE `test` (
  `c1` varchar(100) DEFAULT NULL,
  `c3` timestamp NOT NULL DEFAULT '2012-12-02 12:01:02',
  `c4` decimal(10,2) DEFAULT '123.46',
  `c5` timestamp NOT NULL DEFAULT '2012-12-02 12:01:02',
  `c6` decimal(10,2) DEFAULT '123.46',
  KEY `i3` (`c3`) BLOCK_SIZE 16384 LOCAL,
  KEY `i4` (`c4`) BLOCK_SIZE 16384 LOCAL,
  KEY `i5` (`c5`) BLOCK_SIZE 16384 LOCAL,
  KEY `i6` (`c6`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
