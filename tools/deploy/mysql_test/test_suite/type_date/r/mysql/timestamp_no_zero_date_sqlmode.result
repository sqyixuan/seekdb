drop table if exists test, test2;
create table test (c1 int primary key, c2 timestamp, c3 timestamp, c4 timestamp default current_timestamp);
insert into test (c1) values(1);
select c3, c2 = c4 from test;
c3	c2 = c4
0000-00-00 00:00:00	1
update test set c2= 0;
update test set c3 = 0;
insert into test values(2, now(), 0, 0);
select c3, c2 = c4, c3=c4 from test;
c3	c2 = c4	c3=c4
0000-00-00 00:00:00	0	0
0000-00-00 00:00:00	0	1
