SELECT COUNT(*) FROM t1 WHERE a = NOW();
COUNT(*)
0
EXPLAIN BASIC SELECT COUNT(*) FROM t1 WHERE a = NOW();
INSERT INTO t1 VALUES (NOW(), 2);
SELECT COUNT(*) FROM t1 WHERE a = NOW();
COUNT(*)
0
EXPLAIN BASIC SELECT COUNT(*) FROM t1 WHERE a = NOW();
SELECT COUNT(*) FROM t1 WHERE a = NOW() AND b = 1;
COUNT(*)
0
EXPLAIN BASIC SELECT COUNT(*) FROM t1 WHERE a = NOW() AND b = 1;
DROP TABLE t1;
