drop table if exists t1,t2;
create table t1 (a char(16), b date, c datetime,id int primary key);
insert into t1 values ('test 2000-01-01', '2000-01-01', '2000-01-01',1);
select * from t1 where c = '2000-01-01';
a	b	c	id
test 2000-01-01	2000-01-01	2000-01-01 00:00:00	1
select * from t1 where b = '2000-01-01';
a	b	c	id
test 2000-01-01	2000-01-01	2000-01-01 00:00:00	1
drop table t1;
CREATE TABLE t1 (name char(6),cdate date,id int primary key auto_increment);
INSERT INTO t1 VALUES ('name1','1998-01-01',1);
INSERT INTO t1 VALUES ('name2','1998-01-01',2);
INSERT INTO t1 VALUES ('name1','1998-01-02',3);
INSERT INTO t1 VALUES ('name2','1998-01-02',4);
CREATE TABLE t2 (cdate date, note char(6),id int primary key);
INSERT INTO t2 VALUES ('1998-01-01','note01',1);
INSERT INTO t2 VALUES ('1998-01-02','note02',2);
select name,t1.cdate,note from t1,t2 where t1.cdate=t2.cdate and t1.cdate='1998-01-01';
name	cdate	note
name1	1998-01-01	note01
name2	1998-01-01	note01
drop table t1,t2;
CREATE TABLE t1 ( datum DATE primary key);
INSERT INTO t1 VALUES ( '2000-1-1' );
INSERT INTO t1 VALUES ( '2000-1-2' );
INSERT INTO t1 VALUES ( '2000-1-3' );
INSERT INTO t1 VALUES ( '2000-1-4' );
INSERT INTO t1 VALUES ( '2000-1-5' );
SELECT * FROM t1 WHERE datum BETWEEN cast('2000-1-2' as date) AND cast('2000-1-4' as date);
datum
2000-01-02
2000-01-03
2000-01-04
SELECT * FROM t1 WHERE datum BETWEEN cast('2000-1-2' as date) AND datum - INTERVAL 100 DAY;
datum
DROP TABLE t1;
CREATE TABLE t1 (
user_id char(10),
summa int(11),
rdate date,
id int primary key
);
INSERT INTO t1 VALUES ('aaa',100,'1998-01-01',1);
INSERT INTO t1 VALUES ('aaa',200,'1998-01-03',2);
INSERT INTO t1 VALUES ('bbb',50,'1998-01-02',3);
INSERT INTO t1 VALUES ('bbb',200,'1998-01-04',4);
select max(rdate) as s from t1 where rdate < '1998-01-03' having s> '1998-01-01';
s
1998-01-02
select max(rdate) as s from t1 having s='1998-01-04';
s
1998-01-04
select max(rdate+0) as s from t1 having s='19980104';
s
19980104
drop table t1;
create table t1 (date1 date primary key);
insert into t1 values ('2000-08-10'),('2000-08-11');
select date_add(date1,INTERVAL 1 DAY),date_add(date1,INTERVAL 1 SECOND) from t1;
date_add(date1,INTERVAL 1 DAY)	date_add(date1,INTERVAL 1 SECOND)
2000-08-11	2000-08-10 00:00:01
2000-08-12	2000-08-11 00:00:01
drop table t1;
CREATE TABLE t1(AFIELD INT ,id int primary key);
INSERT INTO t1 VALUES(1,1);
CREATE TABLE t2(GMT  VARCHAR(32) primary key);
INSERT INTO t2 VALUES('GMT-0800');
SELECT DATE_FORMAT('2002-03-06 10:11:12', CONCAT('%a, %d %M %Y %H:%i:%s ', t2.GMT))
FROM t1, t2 GROUP BY t1.AFIELD;
DATE_FORMAT('2002-03-06 10:11:12', CONCAT('%a, %d %M %Y %H:%i:%s ', t2.GMT))
Wed, 06 March 2002 10:11:12 GMT-0800
INSERT INTO t1 VALUES(1,2);
SELECT DATE_FORMAT('2002-03-06 10:11:12', CONCAT('%a, %d %M %Y %H:%i:%s ', t2.GMT)),
DATE_FORMAT('2002-03-06 10:11:12', CONCAT('%a, %d %M %Y %H:%i:%s ', t2.GMT))
FROM t1,t2 GROUP BY t1.AFIELD;
DATE_FORMAT('2002-03-06 10:11:12', CONCAT('%a, %d %M %Y %H:%i:%s ', t2.GMT))	DATE_FORMAT('2002-03-06 10:11:12', CONCAT('%a, %d %M %Y %H:%i:%s ', t2.GMT))
Wed, 06 March 2002 10:11:12 GMT-0800	Wed, 06 March 2002 10:11:12 GMT-0800
drop table t1,t2;
CREATE TABLE t1 (f1 time default NULL, f2 time default NULL,id int primary key auto_increment);
INSERT INTO t1 (f1, f2) VALUES ('09:00', '12:00');
SELECT DATE_FORMAT(f1, '%l.%i %p') , DATE_FORMAT(f2, '%l.%i %p') FROM t1;
DATE_FORMAT(f1, '%l.%i %p')	DATE_FORMAT(f2, '%l.%i %p')
9.00 AM	12.00 PM
DROP TABLE t1;
create table t1(start_date date, end_date date primary key);
insert into t1 values ('2000-01-01','2000-01-02');
select 1 from t1 where cast('2000-01-01 12:01:01' as datetime) between start_date and end_date;
1
1
