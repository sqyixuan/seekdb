--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
# tags: datatype
# 测试timestamp列设置成NULL的效果:not null时，NULL被重置成NOW();否则还是null;(通过nvl函数实现的)


--disable_warnings
drop table if exists test;
--enable_warnings

#default current_timestamp
create table test(c1 int primary key, c2 timestamp, c3 timestamp default now());
insert into test values(1, NULL, now());
select c2 = c3 from test;
update test set c1 = 2, c2 = NULL, c3 = now();
select c2 = c3 from test;
insert into test values(2, now(), now()) on duplicate key update c2=NULL, c3= now();
select c2 = c3 from test;
replace into test values(2, NULL, now());
select c2 = c3 from test;

# default 0
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(c1 int primary key, c2 timestamp default 0, c3 timestamp);
insert into test values(1, NULL, now());
select c2 = c3 from test;
update test set c1 = 2, c2 = NULL, c3 = now();
select c2 = c3 from test;
insert into test values(2, now(), now()) on duplicate key update c2=NULL, c3= now();
select c2 = c3 from test;
replace into test values(2, NULL, now());
select c2 = c3 from test;

# defautlt '2010-03-24'
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(c1 int primary key, c2 timestamp default '2010-03-24', c3 timestamp);
insert into test values(1, NULL, now());
select c2 = c3 from test;
update test set c1 = 2, c2 = NULL, c3 = now();
select c2 = c3 from test;
insert into test values(2, now(), now()) on duplicate key update c2=NULL, c3= now();
select c2 = c3 from test;
replace into test values(2, NULL, now());
select c2 = c3 from test;

# nullable
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(c1 int primary key, c2 timestamp NULL , c3 timestamp);
insert into test values(1, NULL, NULL);
select c2, c2 = c3 from test;
update test set c1 = 2, c2 = NULL, c3 = now();
select c2, c2 = c3 from test;
insert into test values(2, now(), now()) on duplicate key update c2=NULL, c3= now();
select c2 = c3 from test;
replace into test values(2, NULL, now());
select c2 = c3 from test;

#nullable && default 0
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(c1 int primary key, c2 timestamp NULL default '2013-03-12', c3 timestamp);
insert into test values(1, NULL, NULL);
select c2, c2 = c3 from test;
update test set c1 = 2, c2 = NULL, c3 = now();
select c2, c2 = c3 from test;
insert into test values(2, now(), now()) on duplicate key update c2=NULL, c3= now();
select c2 = c3 from test;
replace into test values(2, NULL, now());
select c2 = c3 from test;

drop table test;
