# owner: dachuan.sdc
# owner group: SQL1
# tags: datatype

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(pk int primary key, c1  timestamp(6) default "2012-01-01 12:00:00");
insert into t1 values(1,timestamp'2014-10-10 10:00:00.123456');
--enable_info
set @a=timestamp'2014-10-10 10:00:00.123457';
prepare stmt from update t1 set c1=? where pk=1;
execute stmt using @a;
set @a=timestamp'2014-10-10 10:00:00.123458';
execute stmt using @a;
select * from t1;
prepare stmt2 from select * from  t1  where pk=?;
set @b=1;
execute stmt2 using @b;

