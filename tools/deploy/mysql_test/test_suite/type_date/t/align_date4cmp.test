# test column with column
insert into t2 values(7, "1998-11-30");
insert into t2 values(8, "1998-12-01");
select * from t2;
# datetime column compares with const date
select * from t2 where t2.c2 > (select t1.c2 from t1 where t1.c2 = "1998-12-01");
select * from t2 where t2.c2 >= (select t1.c2 from t1 where t1.c2 = "1998-12-01");
select * from t2 where t2.c2 < (select t1.c2 from t1 where t1.c2 = "1998-12-01");
select * from t2 where t2.c2 <= (select t1.c2 from t1 where t1.c2 = "1998-12-01");
select * from t2 where t2.c2 = (select t1.c2 from t1 where t1.c2 = "1998-12-01");
select * from t2 where t2.c2 != (select t1.c2 from t1 where t1.c2 = "1998-12-01");
select * from t2 where t2.c2 <=> (select t1.c2 from t1 where t1.c2 = "1998-12-01");

# date column compares with const datetime
select * from t1 where t1.c2 > (select t2.c2 from t2 where t2.c2 = "1998-12-01");
select * from t1 where t1.c2 >= (select t2.c2 from t2 where t2.c2 = "1998-12-01");
select * from t1 where t1.c2 < (select t2.c2 from t2 where t2.c2 = "1998-12-01");
select * from t1 where t1.c2 <= (select t2.c2 from t2 where t2.c2 = "1998-12-01");
select * from t1 where t1.c2 = (select t2.c2 from t2 where t2.c2 = "1998-12-01");
select * from t1 where t1.c2 != (select t2.c2 from t2 where t2.c2 = "1998-12-01");
select * from t1 where t1.c2 <=> (select t2.c2 from t2 where t2.c2 = "1998-12-01");

