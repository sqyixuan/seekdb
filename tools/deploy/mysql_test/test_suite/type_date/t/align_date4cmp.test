--disable_warnings
drop database if exists align_date4cmp_test;
--enable_warnings
create database align_date4cmp_test;
use align_date4cmp_test;

set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,ALLOW_INVALID_DATES';

# test column with const or const with column
# prepare date column table and data
--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings
CREATE TABLE t1(c1 int primary key, c2 date);
insert into t1 values(1, '2000-09-09');
insert into t1 values(2, '1900-09-09');
insert into t1 values(3, '1998-11-30');
insert into t1 values(4, '1998-12-01');
select * from t1;

# test varchar
# day over limit
select * from t1 where c2 > '1998-11-31';
select * from t1 where c2 >= '1998-11-31';
select * from t1 where c2 < '1998-11-31';
select * from t1 where c2 <= '1998-11-31';
select * from t1 where c2 = '1998-11-31';
select * from t1 where c2 != '1998-11-31';
select * from t1 where c2 <=> '1998-11-31';

select * from t1 where '1998-11-31' > c2;
select * from t1 where '1998-11-31' >= c2;
select * from t1 where '1998-11-31' < c2;
select * from t1 where '1998-11-31' <= c2;
select * from t1 where '1998-11-31' = c2;
select * from t1 where '1998-11-31' != c2;
select * from t1 where '1998-11-31'<=> c2;


# test integer
# day over limit
select * from t1 where c2 > 19981131;
select * from t1 where c2 >= 19981131;
select * from t1 where c2 < 19981131;
select * from t1 where c2 <= 19981131;
select * from t1 where c2 = 19981131;
select * from t1 where c2 != 19981131;
select * from t1 where c2 <=> 19981131;

select * from t1 where 19981131 > c2;
select * from t1 where 19981131 >= c2;
select * from t1 where 19981131 < c2;
select * from t1 where 19981131 <= c2;
select * from t1 where 19981131 = c2;
select * from t1 where 19981131 != c2;
select * from t1 where 19981131 <=> c2;

# test double
# day over limit
select * from t1 where c2 > 19981131.1;
select * from t1 where c2 >= 19981131.1;
select * from t1 where c2 < 19981131.1;
select * from t1 where c2 <= 19981131.1;
select * from t1 where c2 = 19981131.1;
select * from t1 where c2 != 19981131.1;
select * from t1 where c2 <=> 19981131.1;

select * from t1 where 19981131.1 > c2;
select * from t1 where 19981131.1 >= c2;
select * from t1 where 19981131.1 < c2;
select * from t1 where 19981131.1 <= c2;
select * from t1 where 19981131.1 = c2;
select * from t1 where 19981131.1 != c2;
select * from t1 where 19981131.1 <=> c2;

