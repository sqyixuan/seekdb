# bug/52220603
connect (conn_sys,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
--disable_warnings
drop database if exists align_date4cmp_test;
--enable_warnings
create database align_date4cmp_test;
use align_date4cmp_test;

set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,ALLOW_INVALID_DATES';

--disable_warnings
DROP TABLE IF EXISTS bug_52220603_t;
--enable_warnings
create table bug_52220603_t(c1 datetime);
insert into bug_52220603_t values("2000-11-30");
insert into bug_52220603_t values("2000-12-01");
select * from bug_52220603_t where c1 > "2000-11-31";

--error 0, 1396
DROP USER 'align_date4cmp_user';
CREATE USER 'align_date4cmp_user' IDENTIFIED BY '123456';
GRANT ALL ON *.* TO 'align_date4cmp_user';

--disable_warnings
#DROP database link IF EXISTS my_link1;
--enable_warnings
--disable_query_log
#eval create database link my_link1 connect to align_date4cmp_user@sys database align_date4cmp_test identified by "123456" host '$OBMYSQL_MS0:$OBMYSQL_PORT';
--enable_query_log
#select * from bug_52220603_t@my_link1 where c1 > "2000-11-31";
#explain select * from bug_52220603_t@my_link1 where c1 > "2000-11-31";

--disable_warnings
DROP TABLE IF EXISTS multi_t;
--enable_warnings
CREATE TABLE `multi_t` (
  `c1` datetime DEFAULT NULL,
  `c2` varchar(100) DEFAULT NULL
);
insert into multi_t (c1, c2) values ('1999-12-01', '0');
insert into multi_t (c1, c2) values ('1999-11-30', '0');
insert into multi_t (c1, c2) values ('1999-12-02', '0');
explain select * from multi_t where (c2, c1) < ('0', '1999-11-31');
select * from multi_t where (c2, c1) < ('0', '1999-11-31');
explain select * from multi_t where (1, c2, c1) < (1, '0', '1999-11-31');
select * from multi_t where (1, c2, c1) < (1, '0', '1999-11-31');
explain select * from multi_t where (c1, c2) < ('1999-11-31', '0');
# The MySQL 5.7 result is: 1999-11-30 00:00:00 | 0, but ob is temporarily incompatible.
select * from multi_t where (c1, c2) < ('1999-11-31', '0');
