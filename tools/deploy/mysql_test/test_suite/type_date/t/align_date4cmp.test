# view
create view v_datetime_varchar as select * from t_datetime_varchar where c1 > c2;
select * from v_datetime_varchar;
drop view v_datetime_varchar;
create view v_datetime_varchar as select * from t_datetime_varchar where c1 >= c2;
select * from v_datetime_varchar;
drop view v_datetime_varchar;
create view v_datetime_varchar as select * from t_datetime_varchar where c1 < c2;
select * from v_datetime_varchar;
drop view v_datetime_varchar;
create view v_datetime_varchar as select * from t_datetime_varchar where c1 <= c2;
select * from v_datetime_varchar;
drop view v_datetime_varchar;
create view v_datetime_varchar as select * from t_datetime_varchar where c1 = c2;
select * from v_datetime_varchar;
drop view v_datetime_varchar;
create view v_datetime_varchar as select * from t_datetime_varchar where c1 != c2;
select * from v_datetime_varchar;
drop view v_datetime_varchar;
create view v_datetime_varchar as select * from t_datetime_varchar where c1 <=> c2;
select * from v_datetime_varchar;
drop view v_datetime_varchar;

create view v_datetime_int as select * from t_datetime_int where c1 > c2;
select * from v_datetime_int;
drop view v_datetime_int;
create view v_datetime_int as select * from t_datetime_int where c1 >= c2;
select * from v_datetime_int;
drop view v_datetime_int;
create view v_datetime_int as select * from t_datetime_int where c1 < c2;
select * from v_datetime_int;
drop view v_datetime_int;
create view v_datetime_int as select * from t_datetime_int where c1 <= c2;
