--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
#### description: unix_timestamp
--disable_warnings
drop table if exists tbl1,tbl2;
--enable_warnings
create table tbl1(a datetime(5),b date,c timestamp, d double);
set time_zone='-3:00';
insert into tbl1 values("2010-01-01 11:22:33","2010-10-01","2010-01-01 11:22:33",3302747.4167);
insert into tbl1 values(20100101112233,20101001,20100101112233,3302747.4167);
set time_zone='+4:00';
select UNIX_TIMESTAMP(a),UNIX_TIMESTAMP(b),UNIX_TIMESTAMP(c),UNIX_TIMESTAMP(d) from tbl1;
select UNIX_TIMESTAMP(1);
select UNIX_TIMESTAMP("1");
select UNIX_TIMESTAMP("2010-01-01 11:22:33");
select UNIX_TIMESTAMP(20100101112233);
create table tbl2(a decimal(30,1));
--disable_result_log
--error 1292
insert into tbl2 values(UNIX_TIMESTAMP(1));
--error S22007
insert into tbl2 values(UNIX_TIMESTAMP(1));
--error 1292
insert into tbl2 values(UNIX_TIMESTAMP("1"));
--error S22007
insert into tbl2 values(UNIX_TIMESTAMP("1"));
--enable_result_log
insert into tbl2 values(UNIX_TIMESTAMP("2010-01-01 11:22:33"));
insert into tbl2 values(UNIX_TIMESTAMP(20100101112233));
set @origin_sql_mode = @@sql_mode;
set @@sql_mode = '';
insert into tbl2 values(UNIX_TIMESTAMP(1));
insert into tbl2 values(UNIX_TIMESTAMP("1"));
select * from tbl2;
set @@sql_mode = @origin_sql_mode;
drop table tbl1,tbl2;

select unix_timestamp('2023-09-01 12:00:00') from dual union all select unix_timestamp('2023-09-01 12:00:00') from dual;
select unix_timestamp('2023-09-01 12:00:00.32784') from dual union all select unix_timestamp('2023-09-01 12:00:00.32') from dual;
select unix_timestamp('2023-09-01 12:00:00.32784') from dual union all select unix_timestamp('2023-09-01 12:00:00') from dual;

select unix_timestamp('20230901120000') from dual union all select unix_timestamp('20230901120000') from dual;
select unix_timestamp('20230901120000.123') from dual union all select unix_timestamp('20230901120000.2') from dual;
select unix_timestamp('20230901120000.123') from dual union all select unix_timestamp('20230901120000') from dual;