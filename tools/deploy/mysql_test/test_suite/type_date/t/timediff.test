--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: dachuan.sdc
#### owner group: sql3
#### description: test for timediff
# tags: datatype

select timediff("2010-10-01","2011-11-02");
select timediff("2010-10-01","2011-11-02 12:34:56");
select timediff("2010-10-01","12:34:56");
select timediff("2010-10-01 12:34:56","2011-11-02");
select timediff("2010-10-01 12:34:56","2011-11-02 12:34:56");
select timediff("2010-10-01 10:32:54","12:34:56");
select timediff("12:34:56","2011-11-02");
select timediff("12:34:56","2011-11-02 12:34:56");
select timediff("13:35:57","12:34:56");
--disable_warnings
drop table if exists sb;
--enable_warnings
create table sb(a time not null);
INSERT INTO sb VALUES('00:00:00');
INSERT INTO sb VALUES('23:59:59');
--disable_result_log
--error 1292
INSERT INTO sb VALUES('99:99:99');
--error S22007
INSERT INTO sb VALUES('99:99:99');
--enable_result_log
INSERT INTO sb VALUES('12:00:00');
INSERT INTO sb VALUES('13:13:13');
select timediff(a,"12:34:56") from sb;
--disable_warnings
drop table if exists sb;
--enable_warnings
