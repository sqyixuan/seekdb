--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
# tags: datatype
# Test of datetime functions

--disable_warnings
set sql_mode='';
--disable_warnings
drop table if exists dt;
--enable_warnings
create table dt(id int primary key auto_increment, str_val varchar(100), dt_val datetime(3), ts_val timestamp(3) default '2012-12-12 00:00:00', d_val date, t_val time(3));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table dt;
desc dt;
set time_zone='+8:00';
insert into dt(str_val) values
  ('2015-05-30 11:12:13.1413'),
  ('2015.05.30 11.12.13.1414'),
  ('2015/05/30 11/12/13.1415'),
  ('2015+05=30 11*12&13.1416'),
  ('2015^05%30 11$12#13.1417'),
  ('2015@05!30 11~12`13.1418'),
  ('1000-01-01 00:00:00'),
  ('1969-12-31 23:59:59'),
  ('1970-01-01 00:00:00'),
  ('9999-12-31 23:59:59'),
  ('101112'),
  ('101112131415'),
  ('10111213141516'),
  ('101112131415.789'),
  ('1011121314151.789'),
  ('10111213141516.789');
select * from dt;
update dt set dt_val = str_val;
update dt set ts_val = str_val;
update dt set d_val = str_val;
update dt set t_val = str_val;
select str_val, dt_val, ts_val, d_val, t_val from dt order by dt_val, ts_val, d_val, t_val, str_val;
set time_zone='-8:00';
select str_val, ts_val from dt order by ts_val, str_val;

drop table dt;
create table dt(id int primary key auto_increment, str varchar(100), t_val time(3)  default '2012-12-12 00:00:00');
insert into dt(str) values
  ('12:34:56'),
  ('12:34:56.7891'),
  ('11 12:34:56'),
  ('11 12:34:56.7899'),
  ('838:59:59'),
  ('838:59:59.001'),
  ('1011:12:13'),
  ('123 12:34:56.7899');
update dt set t_val = str;
select str, t_val from dt order by t_val, str;

--disable_warnings
drop table if exists dt;
--enable_warnings
create table dt(id int primary key auto_increment, int_val bigint, dt_val datetime(6)  default '2012-12-12 00:00:00', d_val date, t_val time);
insert into dt(int_val) values
  (101112),
  (1011121),
  (101112131415),
  (10111213141516);
update dt set dt_val = int_val;
update dt set d_val = int_val;
update dt set t_val = int_val;
select int_val, dt_val, d_val, t_val from dt order by dt_val, d_val, t_val, int_val;
select datediff(20080701, "2008-08-01");
select datediff("20080701", "2012-05-25");
select datediff("2012-05-25","20080701");
select datediff(null,null);
select datediff(null,"2012-05-25");
select datediff("2012-05-25","0000-00-00");

select extract(microsecond from '2015-01-01 01:01:01.9999');
select extract(second from '2015-01-01 01:01:01.9999');
select extract(minute from '2015-01-01 01:01:01.9999');
select extract(hour from '2015-01-01 01:01:01.9999');
select extract(day from '2015-01-01 01:01:01.9999');
select extract(week from '2015-01-01 01:01:01.9999');
select extract(month from '2015-01-01 01:01:01.9999');
select extract(year from '2015-01-01 01:01:01.9999');
select extract(quarter from '2015-01-01 01:01:01.9999');
select extract(quarter from '2015-02-01 01:01:01.9999');
select extract(quarter from '2015-03-01 01:01:01.9999');
select extract(quarter from '2015-05-01 01:01:01.9999');
select extract(quarter from '2015-06-01 01:01:01.9999');
select extract(year from '2015-01-12 01:01:01.9999');
select extract(second_microsecond from '2015-01-01 01:01:01.9999');
select extract(minute_microsecond from '2015-01-01 01:01:01.9999');
select extract(minute_second from '2015-01-01 01:01:01.9999');
select extract(hour_microsecond from '2015-01-01 01:01:01.9999');
select extract(hour_second from '2015-01-01 01:01:01.9999');
select extract(hour_minute from '2015-01-01 01:01:01.9999');
select extract(day_microsecond from '2015-01-01 01:01:01.9999');
select extract(day_second from '2015-01-01 01:01:01.9999');
select extract(day_minute from '2015-01-01 01:01:01.9999');
select extract(day_hour from '2015-01-01 01:01:01.9999');
select extract(year_month from '2015-01-01 01:01:01.9999');
select extract(week from '2015-12-31 01:01:01.9999');
select extract(week from '2000-12-31 01:01:01.9999');
select extract(hour from null);
--disable_warnings
drop table if exists dt;
--enable_warnings

--disable_warnings
drop table if exists table_time;
--enable_warnings
create table table_time(c1 time);
insert into table_time values ('838:59:59');
insert into table_time values ('20:00:00');
insert into table_time values ('-838:59:59');
--replace_column 2 cast_datetime
select c1, cast (c1 as datetime) from table_time;
drop table table_time;

--enable_warnings

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a time);
insert into t1 values('-10  1:22:33.45');
insert into t1 values('10  1:22:33.45');
INSERT INTO t1 VALUES ('-11:22:33.123456');
INSERT INTO t1 VALUES ('11:22:33.123456');

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a time(4));
INSERT INTO t1 VALUES('-10  1:22:33.45');
INSERT INTO t1 VALUES('10  1:22:33.45');
INSERT INTO t1 VALUES ('-11:22:33.123456');
INSERT INTO t1 VALUES ('11:22:33.123456');
INSERT INTO t1 VALUES('1000-01-01 00:00:00');
INSERT INTO t1 VALUES('1999-12-31 23:59:59');
INSERT INTO t1 VALUES('2000-01-01 00:00:00');
INSERT INTO t1 VALUES('2008-02-29 13:13:13');
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1(c1 DATE,c2 DATETIME,c3 TIMESTAMP);
##insert date
INSERT INTO t1 VALUES('1000-01-01 00:00:00',NULL,NULL);
INSERT INTO t1 VALUES('1999-12-31 23:59:59',NULL,NULL);
INSERT INTO t1 VALUES('2000-01-01 00:00:00',NULL,NULL);
INSERT INTO t1 VALUES('2008-02-29 13:13:13',NULL,NULL);
##insert datetime
INSERT INTO t1 VALUES(NULL,'1000-01-01 00:00:00',NULL);
INSERT INTO t1 VALUES(NULL,'1999-12-31 23:59:59',NULL);
INSERT INTO t1 VALUES(NULL,'2000-01-01 00:00:00',NULL);
INSERT INTO t1 VALUES(NULL,'2008-02-29 13:13:13',NULL);
##insert timestamp
INSERT INTO t1 VALUES(NULL,NULL,'1000-01-01 00:00:00');
INSERT INTO t1 VALUES(NULL,NULL,'1999-12-31 23:59:59');
INSERT INTO t1 VALUES(NULL,NULL,'2000-01-01 00:00:00');
INSERT INTO t1 VALUES(NULL,NULL,'2008-02-29 13:13:13');
--disable_warnings
drop table if exists t1;
--enable_warnings 
set @@sql_mode='strict_all_tables';
CREATE TABLE t1(c1 datetime);
INSERT INTO t1 VALUES ('9999-12-31 23:59:59.999999');
--error 1441 
INSERT INTO t1 VALUES ('9999-12-31 23:59:59.9999997');
--error 1292
INSERT INTO t1 VALUES ('10000-01-01 00:00:00.000000');
set @@sql_mode=default;
