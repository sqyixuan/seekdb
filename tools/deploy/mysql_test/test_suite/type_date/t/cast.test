# owner: dachuan.sdc
# owner group: SQL2
# Test cast between datetime/timestamp and other datatype
# tags: datatype, expr

--disable_warnings
drop table if exists t, t1, t2, t3;
--enable_warnings

create table t as select cast(123.456 as datetime(6));
create table t1(c1 datetime(6));
--error 1292
insert into t1 values(123.456);
insert into t1 values(cast(123.456 as datetime(6)));
--error 1292
insert into t1 select 123.456;
insert into t1 select cast(123.456 as datetime(6));

create table t2(c1 decimal(10,3), c2 datetime generated always as (c1));
--error 1292
insert into t2(c1) select 123.456;

create table t3(c1 decimal(10,3), c2 datetime generated always as (cast(c1 as datetime(6))));
insert into t3(c1) select 123.456;

set timestamp = 1600000000;
set time_zone = '+00:00';
select cast(time '00:00:00' as date);
select cast(time '00:00:01' as date);
select cast(time '12:00:00' as date);
select cast(time '23:59:59' as date);
select cast(time '24:00:00' as date);
select cast(time '1 00:00:00' as date);
select cast(time '24:00:01' as date);
select cast(time '10 00:00:00' as date);
select cast(time '30 00:00:00' as date);
select cast(time '-00:00:00' as date);
select cast(time '-00:00:01' as date);
select cast(time '-12:00:00' as date);
select cast(time '-23:59:59' as date);
select cast(time '-24:00:00' as date);
select cast(time '-1 00:00:00' as date);
select cast(time '-24:00:01' as date);
select cast(time '-10 00:00:00' as date);
select cast(time '-30 00:00:00' as date);

set time_zone = '+12:00';
select cast(time '00:00:00' as date);
select cast(time '00:00:01' as date);
select cast(time '12:00:00' as date);
select cast(time '23:59:59' as date);
select cast(time '24:00:00' as date);
select cast(time '1 00:00:00' as date);
select cast(time '24:00:01' as date);
select cast(time '10 00:00:00' as date);
select cast(time '30 00:00:00' as date);
select cast(time '-00:00:00' as date);
select cast(time '-00:00:01' as date);
select cast(time '-12:00:00' as date);
select cast(time '-23:59:59' as date);
select cast(time '-24:00:00' as date);
select cast(time '-1 00:00:00' as date);
select cast(time '-24:00:01' as date);
select cast(time '-10 00:00:00' as date);
select cast(time '-30 00:00:00' as date);

set time_zone = '-12:00';
select cast(time '00:00:00' as date);
select cast(time '00:00:01' as date);
select cast(time '12:00:00' as date);
select cast(time '23:59:59' as date);
select cast(time '24:00:00' as date);
select cast(time '1 00:00:00' as date);
select cast(time '24:00:01' as date);
select cast(time '10 00:00:00' as date);
select cast(time '30 00:00:00' as date);
select cast(time '-00:00:00' as date);
select cast(time '-00:00:01' as date);
select cast(time '-12:00:00' as date);
select cast(time '-23:59:59' as date);
select cast(time '-24:00:00' as date);
select cast(time '-1 00:00:00' as date);
select cast(time '-24:00:01' as date);
select cast(time '-10 00:00:00' as date);
select cast(time '-30 00:00:00' as date);

drop table t, t1, t2, t3;
create table t as select timestamp(123.456);
create table t1(c1 timestamp(6));
--error 1292
insert into t1 values(123.456);
insert into t1 values(timestamp(123.456));
--error 1292
insert into t1 select 123.456;
insert into t1 select timestamp(123.456);

create table t2(c1 decimal(10,3), c2 timestamp generated always as (c1));
--error 1292
insert into t2(c1) select 123.456;

create table t3(c1 decimal(10,3), c2 timestamp generated always as (timestamp(c1)));
insert into t3(c1) select 123.456;
drop table t, t1, t2;

##zero datetime cast to timestamp
create table t(c1 datetime, c2 timestamp);
insert into t(c2) values('0000-00-00');
insert into t(c2) values(cast('0000-00-00' as datetime));
update t set c1 = c2;
select * from t;
drop table t;


--echo bugfix: 
## cast string to time
select cast(' 002000 ' as time);
select cast('002000 ' as time);
select cast('002000  ' as time);
select cast('002000   ' as time);
select cast('002000  1' as time);
select cast('002000  12' as time);
select cast('002000  123' as time);
select cast('002000  .1' as time);
select cast('002000  .12' as time);
## bug: 
select cast('002000  .123' as time);
select cast('002000  12:12:12' as time);
select cast('002000  12:12:12:' as time);
select cast('002000  12:12:12.' as time);
select cast('002000  12:12:12.123' as time);

select cast('2 ' as time);
select cast('2  ' as time);
select cast('2   ' as time);
select cast('2  1' as time);
select cast('2  12' as time);
select cast('2  123' as time);
select cast('2  .1' as time);
select cast('2  .12' as time);
select cast('2  .123' as time);
select cast('2  12:12:12' as time);
select cast('2  12:12:12:' as time);
select cast('2  12:12:12.' as time);
select cast('2  12:12:12.123' as time);


create table t(c1 time);
insert into t values(' 002000 ');
insert ignore into t values(' 002000 ');
select * from t;
drop table t;

##zero string to year
create table t(pk int, c1 year);
insert into t values(0, 0);
insert into t values(1, '0');
insert into t values(2, '00');
insert into t values(3, '000');
insert into t values(4, '0000');
--error 1366
insert into t values(5, 'a');
set @tmp_sql_mode = @@sql_mode;
set sql_mode = '';
insert into t values(5, 'a');
insert into t values(6, 'ab');
insert into t values(7, 'abc');
insert into t values(8, 'abcd');
set sql_mode = @tmp_sql_mode;
select * from t;
drop table t;
