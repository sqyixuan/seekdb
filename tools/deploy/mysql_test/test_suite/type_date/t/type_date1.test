#test datetime
create table t1(pk int primary key,c_datetime datetime);
insert into t1 values(1,'2015-05-12 13:50:03');
insert into t1 values(2,'2015-05-12T13:50:03');
insert into t1 values(3,'15-5-2 13:5:03');
insert into t1 values(4,20150512135003);
insert into t1 values(5,'20150512135003');
insert into t1 values(6,'150512135003');
insert into t1 values(7,20150512);
insert into t1 values(8,'150512');
insert into t1 values(9,'1000-01-01 00:00:00');
insert into t1 values(10,'9999-12-31 23:59:59');
--error 1292 
insert into t1 values(11,1505);
insert into t1 values(12,'2015a05b12');
--error 1292
insert into t1 values(13,'2015-03-32');
--error 1292
insert into t1 values(14,'2015-03-20 13:61:00');
select * from t1;
drop table t1;

#test timestamp
create table t1(pk int primary key,c_timestamp timestamp);
insert into t1 values(1,'2015-05-12 13:50:03');
insert into t1 values(2,'2015-05-12T13:50:03');
insert into t1 values(3,'15-5-2 13:5:03');
insert into t1 values(4,20150512135003);
insert into t1 values(5,'20150512135003');
insert into t1 values(6,'150512135003');
#--error 1264
insert into t1 values(7,'150512');
insert into t1 values(8,'2038-01-19 03:14:07');
#--error 1264
#insert into t1 values(9,'1970-01-01 00:00:00');
--error 1292
insert into t1 values(10,'1999');
select * from t1;
drop table t1;
