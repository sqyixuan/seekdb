--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
# tags: datatype
# Test of date functions

--disable_warnings
drop table if exists t1;
--enable_warnings

#test date 
create table t1(pk int primary key,c_date date);
insert into t1 values(1,'2015-05-12');
insert into t1 values(2,'20150512');
insert into t1 values(3,20150512);
insert into t1 values(4,'15-5-3');
insert into t1 values(5,150512);
insert into t1 values(6,0512);
insert into t1 values(7,'2000-1-1');
insert into t1 values(8,'2015-05-12 13:50:03');
--error 1292 
insert into t1 values(9,'2015-13-20');
#--error 1264
#insert into t1 values(10,'2015-02-30');
--error 1292 
insert into t1 values(11,12);
--error 1064
insert into t1 values(12,15:03:20);
select * from t1;
drop table t1;

#test time
create table t1(pk int primary key ,c_time time);
insert into t1 values(1,'13:20:50');
insert into t1 values(2,'132050');
insert into t1 values(3,132050);
insert into t1 values(4,2050);
insert into t1 values(5,'50');
insert into t1 values(6,'300:30:30');
#insert into t1 values(7,3003030);
#insert into t1 values(8,'-838:00:00');
insert into t1 values(9,'838:59:59');
insert into t1 values(10,'2015-05-12 13:50:03');
--error 1292 
insert into t1 values(11,'10:61:20');
--error 1292
insert into t1 values(12,8390000);
select * from t1;
drop table t1;

create table t1(c1 time(3),c2 time(6) primary key);
insert into t1 values(0,0);
insert into t1 values('13:20:00.123','13:20:00.123456');
insert into t1 values('13:20:00.123456','13:20:00.12345678');
select * from t1;
drop table t1;


