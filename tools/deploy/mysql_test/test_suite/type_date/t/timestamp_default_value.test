drop table test;

# 
create TABLE test (c1 varchar(100), c3 timestamp(0) default Timestamp '2012-12-02 12:01:02.123', c4 number(10, 2) default 123.456789);
insert into test (c1) values ('1');
alter table test add column c5 timestamp(0) default Timestamp '2012-12-02 12:01:02.123';
alter table test add column c6 number(10, 2) default 123.456789;
create index i3 on test(c3);
create index i4 on test(c4);
create index i5 on test(c5);
create index i6 on test(c6);
--source mysql_test/include/show_create_table_old_version.inc
show create table test;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
drop table test;

## 
create table test(c1 int, c2 timestamp default current_timestamp);
insert into test values(1, default);
insert into test(c1, c2) values(2, default);
insert into test(c1) values(3);
insert into test(c2) values(default);

insert into test set c1 = 4, c2 = default;
insert into test set c1 = 5;
insert into test set c2 = default;
select current_timestamp, c1, c2 from test;

update test set c2 = default;
select current_timestamp, c1, c2 from test;
drop table test;

create table test(c1 int, c2 timestamp default now());
insert into test values(1, default);
insert into test(c1, c2) values(2, default);
insert into test(c1) values(3);
insert into test(c2) values(default);

insert into test set c1 = 4, c2 = default;
insert into test set c1 = 5;
insert into test set c2 = default;
select now(), c1, c2 from test;

update test set c2 = default;
select now(), c1, c2 from test;
