--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
# 在dml语句中将timestamp设置成default/default(),或者不直接指定值时的效果
# tags : timestamp, dml,default_value, datatype
--disable_warnings

set timestamp = 1600000000;
set time_zone = '+08:00';
#default 0
drop table if exists test;
create table test (c1 int primary key, c2 timestamp default 0);
insert into test (c1) values (1);
select * from test;

#第一列default null
drop table if exists test;
--error 1067
create table test (c1 int primary key, c2 timestamp default NULL);

#第二列default null
drop table if exists test;
--error 1067
create table test (c1 int primary key, c2 timestamp, c3 timestamp default NULL);

# default '2013-01-01'
drop table if exists test;
create table test (c1 int primary key, c2 timestamp default '2013-01-01');
insert into test (c1) values (1);
select * from test;

#第一列无default值；
drop table if exists test;
create table test (c1 int primary key, c2 timestamp, c3 timestamp);
insert into test (c1,c3) values (1, now());
select c2=c3 from test;

#第一列NULL属性；
drop table if exists test;
create table test (c1 int primary key, c2 timestamp NULL, c3 timestamp);
insert into test (c1,c3) values (1, now());
select c2=c3 from test;

#第一列on update current_timestamp
drop table if exists test;
create table test (c1 int primary key, c2 timestamp on update current_timestamp, c3 timestamp);
insert into test (c1) values (1);
select c2=c3 from test;

#第二列
drop table if exists test;
create table test (c1 int primary key, c2 timestamp, c3 timestamp);
insert into test (c1) values (1);
select c3 from test;

#主动插入值为default;
drop table if exists test;
create table test (c1 int primary key, c2 timestamp, c3 timestamp, c4 int);
insert into test (c1, c2, c3) values (1, default, default);
select c3, c2 = c3 from test;
update test set c4 = 1, c2 = default, c3 = default;
select c3, c2 = c3 from test;

#主动插入值为default();
drop table if exists test;
create table test (c1 int primary key, c2 timestamp, c3 timestamp, c4 int);
insert into test (c1, c2, c3) values (1, default(c2), default(c3));
select c3, c2 = c3 from test;
update test set c4 = 1, c2 = default(c2), c3 = default(c3);
select c3, c2 = c3 from test;

drop table if exists test;
create table test (c1 int primary key, c2 timestamp, c3 timestamp, c4 int);
insert into test set c1 = 1, c2 = c2, c3 = c3;
select * from test;

echo 'timestamp column has default now(), c1 = c1 return 0';
drop table test;
create table test(c1 int primary key, c2 timestamp, c3 timestamp default now());
insert into test set c1=1,c2=c2,c3=c3;
select * from test;
insert into test set c1 = 2, c2 = default(c2), c3 = default(c3);
select * from test;
insert into test set c1 = 3, c2 = default, c3 =default;
select c2=c3,c2=0,c3=0,datediff(c2,now())<0,datediff(c3,now())<0 from test where c1 = 3;
delete from test;
insert into test values(4, c2,c3);
select * from test;
insert into test values(5, default, default);
select c2=c3,c2=0,c3=0,datediff(c2,now())<0,datediff(c3,now())<0 from test where c1 = 5;
select * from test;
delete from test;

insert into test values(6, default(c2), default(c3));
select * from test;
insert into test values(7, '2011-01-01 11:11:11', '2011-01-01 11:11:11');
update test set c2=default, c3=default where c1 = 7;
select c2=c3,c2=0,c3=0,datediff(c2,now())<0,datediff(c3,now())<0 from test where c1 = 7;
delete from test;
insert into test values(8, '2011-01-01 11:11:11', '2011-01-01 11:11:11');
update test set c2=default(c2), c3=default(c3) where c1 = 8;
select * from test;

echo 'timestamp column has default not now(), c1 = c1 return default_value';
drop table test;
create table test(c1 int primary key, c2 timestamp default '2011-01-21 12:12:12', c3 timestamp default '2011-01-21 12:12:12');
insert into test set c1=1,c2=c2,c3=c3;
select * from test;
insert into test set c1 = 2, c2 = default(c2), c3 = default(c3);
select * from test;
insert into test set c1 = 3, c2 = default, c3 =default;
select c2=c3,c2=0,c3=0,datediff(c2,now())<0,datediff(c3,now())<0 from test where c1 = 3;
delete from test;

insert into test values(4, c2,c3);
select * from test;
insert into test values(5, default, default);
select c2=c3,c2=0,c3=0,datediff(c2,now())<0,datediff(c3,now())<0 from test where c1 = 5;
delete from test;


insert into test values(6, default(c2), default(c3));
select * from test;
insert into test values(7, '2011-01-01 11:11:11', '2011-01-01 11:11:11');
update test set c2=default, c3=default where c1 = 7;
select c2=c3,c2=0,c3=0,datediff(c2,now())<0,datediff(c3,now())<0 from test where c1 = 7;
delete from test;

insert into test values(8, '2011-01-01 11:11:11', '2011-01-01 11:11:11');
update test set c2=default(c2), c3=default(c3) where c1 = 8;
select * from test;



