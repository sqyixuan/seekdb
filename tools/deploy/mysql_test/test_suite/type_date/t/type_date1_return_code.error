# Test of date functions
# tags: datatype

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(pk int primary key,c_year year );

--error 1265
insert into t1 values(13,'2015-05-12 13:50:03');
drop table t1;

--error 1292
insert into t1 values(12,'2015a05b12');
create table t1(pk int primary key,c_datetime datetime);
