--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
# tags: datatype
# description: 本case是为了DATE/DATETIME类型在is null中的表现
# date/datetime带not null属性时，全0值使is null为true

--disable_warnings
drop table if exists test;
--enable_warnings

#走query_range, 带not null属性
create table test(c1 date primary key);
insert into test values('0000-00-00');
select * from test where c1 is null;
select * from test where c1 <=> null;
select * from test where c1 = null;
drop table test;

create table test(c1 datetime primary key);
insert into test values('0000-00-00');
select * from test where c1 is null;
select * from test where c1 <=> null;
select * from test where c1 = null;
drop table test;

#不走query_range, 带not null属性
create table test(pk int primary key, c1 date not null);
insert into test values(1, '0000-00-00');
select * from test where c1 is null;
select * from test where c1 <=> null;
select * from test where c1 = null;

drop table test;
create table test(pk int primary key, c1 datetime not null);
insert into test values(1, '0000-00-00');
select * from test where c1 is null;
select * from test where c1 <=> null;
select * from test where c1 = null;

drop table test;
#走query_range,不带not null属性；
create table test(pk int primary key, c1 date unique);
insert into test values(1, '0000-00-00');
insert into test values(2,  null);
select * from test where c1 is null;
select * from test where c1 <=> null;
select * from test where c1 = null;

drop table test;
create table test(pk int primary key, c1 datetime unique);
insert into test values(1, '0000-00-00');
insert into test values(2,  null);
select * from test where c1 is null;
select * from test where c1 <=> null;
select * from test where c1 = null;

drop table test;
#不走query_range, 不带not null属性
create table test(pk int primary key, c1 date);
insert into test values(1, '0000-00-00');
insert into test values(2,  null);
select * from test where c1 is null;
select * from test where c1 <=> null;
select * from test where c1 = null;

drop table test;
create table test(pk int primary key, c1 datetime);
insert into test values(1, '0000-00-00');
insert into test values(2,  null);
select * from test where c1 is null;
select * from test where c1 <=> null;
select * from test where c1 = null;

# 主键自带not null属性，is 后面的参数不是null、而是true、false的情况
drop table test;
CREATE TABLE test(c0 DATETIME  UNIQUE PRIMARY KEY )partition by key(c0) partitions 2;
insert into test values(20221111171322);
select c0, c0 is true FROM test WHERE (c0) && 1;
select c0 FROM test WHERE (c0) && (c0 is true);
select c0, c0 is false FROM test WHERE (c0) && 1;
select c0 FROM test WHERE (c0) && (c0 is false);
drop table test;
