--disable_query_log
##set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: dachuan.sdc
#### owner group: sql3
#### description: time
# tags: datatype

--disable_warnings
drop table if exists sb;
set @@time_zone = '+8:00';
select time(NULL);
select time("2010-01-01");
select time("2010-01-01 11:11:11");
select time("2010-01-01 11:11:11.12345");
select time("abc");
select time(1024);
select time(20240101112233);
select time(cast('2006-04-22 03:29:33' as datetime));
select time(cast('2006-04-22 03:29:33.123' as datetime(3)));
select time(cast('2006-04-22' as datetime));
set @@time_zone = '-2:00';
create table sb(a datetime(5), b timestamp(5));
insert into sb values("2010-12-31 23:59:59.99999", "2010-12-31 23:59:59.99999");
set @@time_zone = '+11:00';
select time(a) from sb;
select time(b) from sb;
set @@time_zone = '-6:00';
select time(a) from sb;
select time(b) from sb;
set @@time_zone = '+8:00';
insert into sb values("2010-12-31 23:59:59.99999", "2010-12-31 23:59:59.99999");
set @@time_zone = '+8:00';
select time(a) from sb;
select time(b) from sb;
set @@time_zone = '-11:00';
select time(a) from sb;
select time(b) from sb;
set @@time_zone = '+11:00';
select time(a) from sb;
select time(b) from sb;
## restore time zone
set @@time_zone = '+8:00';
drop table sb;
set @@sql_mode = '';
create table sb(a time);
insert into sb values(time("abc"));
insert into sb values(time("2010-01-01 11:11:11"));
insert into sb values(time(NULL));
insert into sb values(time(2014));
select * from sb;
drop table sb;
create table sb(a varchar(234));
insert into sb values("2010-01-01 11:11:11");
insert into sb values("2010-01-01 11:11:11.1234");
select time(a) from sb;
drop table sb;


--echo #bugfix: 
set timestamp = 1600000000;
create table sb(c1 int);
insert into sb values(1);
select CURRENT_TIMESTAMP(1) from sb group by CURRENT_TIMESTAMP(3);
select LOCALTIME(1) from sb group by LOCALTIME(3);
select LOCALTIMESTAMP(1) from sb group by LOCALTIMESTAMP(3);
select NOW(1) from sb group by NOW(3);
select length(c1) from (select SYSDATE(1) c1 from sb group by SYSDATE(3));
select CURTIME(1) from sb group by CURTIME(3);
select CURRENT_TIME(1) from sb group by CURRENT_TIME(3);
select UTC_TIMESTAMP(1) from sb group by UTC_TIMESTAMP(3);
select UTC_TIME(1) from sb group by UTC_TIME(3);