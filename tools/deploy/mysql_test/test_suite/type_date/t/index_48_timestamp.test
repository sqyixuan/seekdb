--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# tags: datatype
# owner: dachuan.sdc
# owner group: SQL1
#### description: 用于测试timestamp上的索引相关
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1
(
  pk1 int primary key,
  key1 int,
  key2 varchar(20),
  key3  timestamp(6) default "2012-01-01 12:00:00",
  key4 timestamp
);

insert into t1 values
(1,12,'a','2013-12-11 08:00:00','2013-12-07 08:10:00'),
(2,11,'b','2013-12-10 08:10:00','2013-12-07 08:00:00'),
(3,10,'b','2013-12-10 08:00:00','2013-12-08 08:10:00'),
(4,9,'c','2013-12-09 08:00:00','2013-12-08 08:00:00'),
(5,8,'d','2013-12-09 08:10:00','2013-12-09 08:10:00'),
(6,7,'a','2013-12-08 08:00:00','2013-12-09 08:00:00'),
(7,7,'c','2013-12-08 08:10:00','2013-12-10 08:10:00'),
(8,5,'b','2013-12-07 08:00:00','2013-12-10 08:00:00'),
(9,5,'e','2013-12-07 08:10:00','2013-12-11 08:00:00');

create index i1 on t1(key3) storing (key2);
create index i2 on t1(key4,key1);

--source mysql_test/include/check_all_idx_ok.inc


##
select * from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-09 00:00:00' order by pk1;
select pk1,key2,key3 from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-09 00:00:00' order by pk1;
select count(*) from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-09 00:00:00';
select * from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-09 00:00:00' order by key2;
select max(key2) from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-09 00:00:00';

##
select * from t1 where key4>'2013-12-09 00:10:00' and key4<'2013-12-12 00:00:00' and key1>0 and key1<8 order by pk1;
select pk1,key4,key1 from t1 where key4>'2013-12-09 00:10:00' and key4<'2013-12-12 00:00:00' and key1>0 and key1<8 order by pk1;
select count(*) from t1 where key4>'2013-12-09 00:10:00' and key4<'2013-12-12 00:00:00' and key1>0 and key1<8;
select min(key1) from t1 where key4>'2013-12-09 00:10:00' and key4<'2013-12-12 00:00:00' and key1>0 and key1<8;
select * from t1 where key4>'2013-12-09 00:10:00' and key4<'2013-12-12 00:00:00' and key1>0 and key1<8 order by key1;

##
select * from t1 where key3>'2013-12-08 00:00:00' and key3<'2013-12-10 00:00:00' and key4>'2013-12-09 00:00:00' and key4<'2013-12-11 00:00:00' order by pk1;
select count(*) from t1 where key3>'2013-12-08 00:00:00' and key3<'2013-12-10 00:00:00' and key4>'2013-12-09 00:00:00' and key4<'2013-12-11 00:00:00';
select max(key2) from t1 where key3>'2013-12-08 00:00:00' and key3<'2013-12-10 00:00:00' and key4>'2013-12-09 00:00:00' and key4<'2013-12-11 00:00:00';
select * from t1 where key3>'2013-12-08 00:00:00' and key3<'2013-12-10 00:00:00' and key4>'2013-12-09 00:00:00' and key4<'2013-12-11 00:00:00' order by key3;
select * from t1 where key3>'2013-12-08 00:00:00' and key3<'2013-12-10 00:00:00' and key4>'2013-12-09 00:00:00' and key4<'2013-12-11 00:00:00' order by key4;

##
select * from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and key4>'2013-12-09 00:00:00' and key4<'2013-12-12 00:00:00' and key1>0 and key1<9 order by pk1;
select count(*) from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and key4>'2013-12-09 00:00:00' and key4<'2013-12-12 00:00:00' and key1>0 and key1<9;
select distinct key1 from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and key4>'2013-12-09 00:00:00' and key4<'2013-12-12 00:00:00' and key1>0 and key1<9 order by key1;
select max(key1) from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and key4>'2013-12-09 00:00:00' and key4<'2013-12-12 00:00:00' and key1>0 and key1<9;
select max(key2) from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and key4>'2013-12-09 00:00:00' and key4<'2013-12-12 00:00:00' and key1>0 and key1<9;
select * from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and key4>'2013-12-09 00:00:00' and key4<'2013-12-12 00:00:00' and key1>0 and key1<9 order by key3;
select * from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and key4>'2013-12-09 00:00:00' and key4<'2013-12-12 00:00:00' and key1>0 and key1<9 order by key4;
select * from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and key4>'2013-12-09 00:00:00' and key4<'2013-12-12 00:00:00' and key1>0 and key1<9 order by pk1;

##
select * from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and pk1>4 and pk1<10 order by pk1;
select count(*) from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and pk1>4 and pk1<10;
select pk1,key2 from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and pk1>4 and pk1<10 order by pk1;
select * from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and pk1>4 and pk1<10 order by key2;
select * from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and pk1>4 and pk1<10 order by key4;
select * from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and pk1>4 and pk1<10 order by pk1;
select max(key2) from t1 where key3>'2013-12-07 00:00:00' and key3<'2013-12-10 00:00:00' and pk1>4 and pk1<10;

