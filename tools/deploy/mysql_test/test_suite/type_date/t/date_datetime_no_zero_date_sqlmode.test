# owner: dachuan.sdc
# owner group: SQL2
# tags: datatype
## test NO_ZERO_DATE sql_mode.
--result_format 4

--disable_warnings
drop table if exists t1_date, t2_date;
drop table if exists t1_datetime, t2_datetime;
drop table if exists t1_timestamp, t2_timestamp;
drop table if exists t_date, t_datetime, t_timestamp;
--enable_warnings



#################################### sql_mode with NO_ZERO_DATE ###################################

set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_DATE';

############## test select ############
--error 1525
select date '0000-00-00';
--error 1525
select timestamp '0000-00-00';
--error 1525
select timestamp '0000-00-00 00:00:00';
--error 1525
select date_add(date'0000-00-00', interval 1 second);
--error 1525
select date_format(date'0000-00-00', "%Y-%m-%d");
--error 1525
select to_seconds(date'0000-00-00') from dual;
--error 1525
select round(date'0000-00-00');
--error 1525
select weekofyear(date'0000-00-00') from dual;
--error 1525
select weekday(date'0000-00-00') from dual;
--error 1525
select week(date'0000-00-00') from dual;
--error 1525
select yearweek(date'0000-00-00') from dual;
--error 1525
select extract(year from date'0000-00-00');
--error 1525
select extract(month from date'0000-00-00');
--error 1525
select extract(day from date'0000-00-00');
--error 1525
select quarter(date'0000-00-00') from dual;

select str_to_date('00.00.0000', '%m.%d.%Y');



############## test create ############

--error 1067
create table t1_date(c date default '0000-00-00');
--error 1067
create table t2_date(c date default '0000-00-00 00:00:00');
--error 1067
create table t1_datetime(c datetime default '0000-00-00');
--error 1067
create table t2_datetime(c datetime default '0000-00-00 00:00:00');
--error 1067
create table t1_timestamp(c timestamp default '0000-00-00');
--error 1067
create table t2_timestamp(c timestamp default '0000-00-00 00:00:00');

create table t_part (id int, data date)
  partition by list(id) (
    partition p0 values in (1, year('0000-00-00')),
    partition p1 values in (2, 3, 4, 5, 6, 7, 8, 9)
);
drop table t_part;



############## test insert ############

create table t_date(c date);
--error 1292
insert into t_date values('0000-00-00');
--error 1292
insert into t_date values('0000-00-00 00:00:00');
insert ignore into t_date values('0000-00-00');
insert ignore into t_date values('0000-00-00 00:00:00');
select * from t_date;

create table t_datetime(c date);
--error 1292
insert into t_datetime values('0000-00-00');
--error 1292
insert into t_datetime values('0000-00-00 00:00:00');
insert ignore into t_datetime values('0000-00-00');
insert ignore into t_datetime values('0000-00-00 00:00:00');
select * from t_datetime;

create table t_timestamp(c timestamp);
--error 1292
insert into t_timestamp values('0000-00-00');
--error 1292
insert into t_timestamp values('0000-00-00 00:00:00');
insert ignore into t_timestamp values('0000-00-00');
insert ignore into t_timestamp values('0000-00-00 00:00:00');
select * from t_timestamp;



############## test update ############

delete from t_date;
insert into t_date values('2020-10-01');
--error 1292
update t_date set c = '0000-00-00';
--error 1292
update t_date set c = '0000-00-00 00:00:00';
select * from t_date;

update ignore t_date set c = '0000-00-00';
update ignore t_date set c = '0000-00-00 00:00:00';
select * from t_date;

delete from t_datetime;
insert into t_datetime values('2020-10-01');
--error 1292
update t_datetime set c = '0000-00-00';
--error 1292
update t_datetime set c = '0000-00-00 00:00:00';
select * from t_datetime;

update ignore t_datetime set c = '0000-00-00';
update ignore t_datetime set c = '0000-00-00 00:00:00';
select * from t_datetime;

delete from t_timestamp;
insert into t_timestamp values('2020-10-01');
--error 1292
update t_timestamp set c = '0000-00-00';
--error 1292
update t_timestamp set c = '0000-00-00 00:00:00';
select * from t_timestamp;

update ignore t_timestamp set c = '0000-00-00';
update ignore t_timestamp set c = '0000-00-00 00:00:00';
select * from t_timestamp;



############## drop table #############

--disable_warnings
drop table if exists t1_date, t2_date;
drop table if exists t1_datetime, t2_datetime;
drop table if exists t1_timestamp, t2_timestamp;
drop table if exists t_date, t_datetime, t_timestamp;
--enable_warnings





#################################### sql_mode without NO_ZERO_DATE ################################

set sql_mode = 'STRICT_ALL_TABLES';

############## test select ############

select date '0000-00-00';
select timestamp '0000-00-00';
select timestamp '0000-00-00 00:00:00';
select date_add(date'0000-00-00', interval 1 second);
select date_format(date'0000-00-00', "%Y-%m-%d");
select to_seconds(date'0000-00-00') from dual;
select round(date'0000-00-00');
select weekofyear(date'0000-00-00') from dual;
select weekday(date'0000-00-00') from dual;
select week(date'0000-00-00') from dual;
select yearweek(date'0000-00-00') from dual;
select extract(year from date'0000-00-00');
select extract(month from date'0000-00-00');
select extract(day from date'0000-00-00');
select quarter(date'0000-00-00') from dual;

select str_to_date('00.00.0000', '%m.%d.%Y');



############## test create ############

create table t1_date(c date default '0000-00-00');
create table t2_date(c date default '0000-00-00 00:00:00');
create table t1_datetime(c datetime default '0000-00-00');
create table t2_datetime(c datetime default '0000-00-00 00:00:00');
create table t1_timestamp(c timestamp default '0000-00-00');
create table t2_timestamp(c timestamp default '0000-00-00 00:00:00');



############## test insert ############

create table t_date(c date);
insert into t_date values('0000-00-00');
insert into t_date values('0000-00-00 00:00:00');
insert ignore into t_date values('0000-00-00');
insert ignore into t_date values('0000-00-00 00:00:00');
select * from t_date;

create table t_datetime(c datetime);
insert into t_datetime values('0000-00-00');
insert into t_datetime values('0000-00-00 00:00:00');
insert ignore into t_datetime values('0000-00-00');
insert ignore into t_datetime values('0000-00-00 00:00:00');
select * from t_datetime;

create table t_timestamp(c timestamp);
insert into t_timestamp values('0000-00-00');
insert into t_timestamp values('0000-00-00 00:00:00');
insert ignore into t_timestamp values('0000-00-00');
insert ignore into t_timestamp values('0000-00-00 00:00:00');
select * from t_timestamp;



############## test update ############

delete from t_date;
insert into t_date values('2020-10-01');
update t_date set c = '0000-00-00';
update t_date set c = '0000-00-00 00:00:00';
select * from t_date;

delete from t_datetime;
insert into t_datetime values('2020-10-01');
update t_datetime set c = '0000-00-00';
update t_datetime set c = '0000-00-00 00:00:00';
select * from t_datetime;

delete from t_timestamp;
insert into t_timestamp values('2020-10-01');
update t_timestamp set c = '0000-00-00';
update t_timestamp set c = '0000-00-00 00:00:00';
select * from t_timestamp;



############## drop table #############

--disable_warnings
drop table if exists t1_date, t2_date;
drop table if exists t1_datetime, t2_datetime;
drop table if exists t1_timestamp, t2_timestamp;
drop table if exists t_date, t_datetime, t_timestamp;
--enable_warnings





#################################### reset sql mode ###############################################

set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
