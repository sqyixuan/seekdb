--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# Test of functions select_timestamp
# owner: dachuan.sdc
# owner group: SQL1
# tags: datatype

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

create table t1(i int primary key, c1 char(255), c256 char(255), dt datetime(6), d  datetime(6));
create table t2(i int primary key, c1 char(255), c256 char(255), dt  timestamp(6) default "2012-01-01 12:00:00", d   timestamp(6) default "2012-01-01 12:00:00");
create table t3(i int primary key,  gmt_create datetime default now(), gmt_modify datetime default now());

--disable_query_log
--disable_result_log

#insert
let $i=0;
while($i < 180000)
{
    #eval replace into t1(i,c1,c256,dt,d) values($i,'1','$i','2012-10-10 12:00:00.000001','2012-10-10 13:00:00.000003');
    #eval replace into t2(i,c1,c256,dt,d) values($i,'1','$i','2012-10-10 12:00:00.000002','2012-10-10 14:00:00.000004');
    eval replace into t3(i) values($i);
    inc $i;
}

--enable_query_log

select * from t1 where i<120000;
select * from t2 where i<120000;
select * from t3 where i<120000;
select dt,d from t2 where i<120000;
select dt,d from t1 where i<120000;
select gmt_create, gmt_modify from t3 where i<180000;

drop table t1,t2,t3;
