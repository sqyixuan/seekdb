--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
# tags: datatype
# 测试timestamp列的特性；
# 每个表中第一个timestamp列，如果不带NULL和default_value， 则自动拥有on update current_timestamp的功能

--disable_abort_on_error
--disable_warnings
drop table if exists test;
--enable_warnings

#1.第一个timestamp列指定了NULL属性，则不带on update current_timestamp的功能
create table test (c1 int primary key, c2 timestamp NULL, c3 timestamp default current_timestamp, c4 int, c5 timestamp default current_timestamp on update current_timestamp, c6 timestamp);
insert into test (c1, c4) values(1,1);
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

sleep 1;
#更新其他列
update test set c4 = 5;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;
#没有更新
update test set c4 = 5;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;

#主动更新成now,和c5相等
update test set c2 = now();
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;

#2. 第一个timestamp列指定了default_value， 则不带on update current_timestamp的功能
drop table if exists test;
create table test (c1 int primary key, c2 timestamp default '2011-01-01', c3 timestamp default current_timestamp, c4 int, c5 timestamp default current_timestamp on update current_timestamp,c6 timestamp);
insert into test (c1, c4) values(1,1);
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;
#更新其他列
update test set c4 = 5;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;
#没有更新
update test set c4 = 5;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;

#主动更新成now,和c5相等
update test set c2 = now();
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

#3. 第一个timestamp 列指定default value为0；
drop table if exists test;
create table test (c1 int primary key, c2 timestamp default 0, c3 timestamp default current_timestamp, c4 int, c5 timestamp default current_timestamp on update current_timestamp, c6 timestamp);
insert into test (c1, c4) values(1,1);
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;
#更新其他列
update test set c4 = 5;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;
#没有更新
update test set c4 = 5;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;

#主动更新成now,和c5相等
update test set c2 = now();
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

#4. 第一个timestamp列指定default value 为now()；
create table test (c1 int primary key, c2 timestamp default now(), c3 timestamp default current_timestamp, c4 int, c5 timestamp default current_timestamp on update current_timestamp, c6 timestamp);
insert into test (c1, c4) values(1,1);
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;
#更新其他列
update test set c4 = 5;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;
#没有更新
update test set c4 = 5;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;

#主动更新成now,和c5相等
update test set c2 = now();
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

#5. 第一个timestamp列不指定default_value, 但是指定on update current_timestamp的功能
drop table if exists test;
create table test (c1 int primary key, c2 timestamp on update current_timestamp, c3 timestamp default current_timestamp, c4 int, c5 timestamp default current_timestamp on update current_timestamp, c6 timestamp);
insert into test (c1, c4) values(1,1);
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;
#更新其他列
update test set c4 = 5;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;
#没有更新
update test set c4 = 5;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;

#主动更新成now,和c5相等
update test set c2 = now();
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

# 6.第一个timestamp类型默认为default current_timestamp on update current_timestamp
#   结果变化类型和C3列一致；
drop table test;
create table test(c1 int primary key, c2 timestamp, c3 timestamp default current_timestamp on update current_timestamp, c4 int, c5 timestamp, c6 timestamp);
insert into test (c1,c4) values(1,1);
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;
sleep 1;
update test set c4= 2;
select c2 = c3 from test where c1 = 1;

sleep 1;
update test set c5 = c2, c1=1,c4=2;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

sleep 1;
insert into test (c1) values(1) on duplicate key update c4 = 4, c5 = c2;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

sleep 1;
insert into test (c1) values(1) on duplicate key update c4 = 4;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

sleep 1;
replace into test (c1,c4) values(1,4);
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

sleep 1;
insert into test(c1,c2,c4) values(2, NULL, 3);
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

sleep 1;
insert into test (c1, c5) values(3, now());
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

sleep 1;
update test set c2 = c4+1 where c1 = 3;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

sleep 1;
insert into test (c1) value (3) on duplicate key update c5 = c2, c2=c4+1;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

sleep 1;
insert into test(c1,c2, c5) values(5,NULL, NULL);
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

sleep 1;
update test set c2 = c4+1 , c5 = c2 where c1= 5;
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

sleep 1;
replace into test(c1,c2, c5) values(4, NULL, now());
select c2 = c3, c2 = c5, c2 = c6, c3 = c5, c3 = c6, c5 = c6 from test;

drop table test;
