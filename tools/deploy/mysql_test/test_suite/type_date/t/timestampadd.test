set time_zone='-5:00';
create table sb(a timestamp);
insert into sb values ("2010-01-01 00:00:00");
set time_zone='-5:00';
select timestampadd(hour,1,a) from sb;
select timestampadd(hour,-1,a) from sb;
drop table sb;
set time_zone='+6:00';
create table sb(a datetime);
insert into sb values ("2010-08-06 12:34:56");
set time_zone='-7:00';
select timestampadd(hour,1,a) from sb;
select timestampadd(hour,-1,a) from sb;
drop table sb;

