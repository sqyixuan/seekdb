--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#description: test for usec_to_time input valid check
#tags: funcs
# owner: dachuan.sdc
# owner group: SQL1
# tags: funcs, datatype

select usec_to_time(0);

select usec_to_time(1);

--error 1441
## for bug 12477437
select usec_to_time(1505227352838001000);

## normal test
select usec_to_time(0);

--error 1441
## UTC+8 MAX + 1s
select usec_to_time(253402300799999999 - 28800000000 + 1);

## UTC+8 MAX
select usec_to_time(253402300799999999 - 28800000000);

--error 1441
## UTC+8 MIN - 1s
select usec_to_time(-62167132800000000 - 28800000000 - 1);

## UTC+8 MIN
select usec_to_time(-62167132800000000 - 28800000000);

## ZERO
select usec_to_time(-9223372022400000000);
