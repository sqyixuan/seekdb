--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
# Test of strict time functions
# tags: datatype

--disable_query_log
--replace_column 1 time
select current_timestamp();      
--replace_column 1 time
select now();
--replace_column 1 time
select current_timestamp();
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(a int primary key,b  timestamp(6) default "2012-01-01 12:00:00");
insert into test values(1,current_timestamp());
replace into test values(2,current_timestamp());
update test set b=current_timestamp();

