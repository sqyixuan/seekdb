--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
# Test of time functions
# tags: datatype
# 检测插入timestamp列值的有效性
--disable_abort_on_error
--disable_warnings
drop table if exists test_table;
--enable_warnings

create table test_table(id int, name varchar(64), age int,  birth datetime(6), school_date  timestamp(6) default "2012-01-01 12:00:00", height float, weight double, home varchar(64), description varchar(64), primary key(id,age));

replace into test_table values(1,'abc', 38, '1988-01-29', '1993-09-01', 158.778, 50.06432, 'shiyan', 'rd'),(2,'yy', 30, '1984-3-16', '1990-09-01', 165.624, 59.870, 'shanghai', 'dba'),(3,'cm', 18, '1987-01-12', '1992-09-01', 160.234, 51.364, 'hangzhou', 'qa'),(4,'my', 26, '1987-06-29', '1994-09-01', 159.008, 48.786, 'beijing', 'sa');
select @@session.sql_mode;
--error 1292
insert into test_table(id, age, school_date) values(100,100,'2012-10-01 24:00:00'),(101,100,'2012-10-01 25:61:62');
--error 1292
insert into test_table(id, age, school_date) values(100,100,'2013-02-29 23:00:00');
--error 1292
insert into test_table(id, age, school_date) values(100,100,'2013-01-32 23:00:00');
--error 1292
insert into test_table(id, age, school_date) values(100,100,'2013-04-31 23:00:00');

select * from test_table;
--disable_warnings
drop table if exists t_range;
--enable_warnings
create table t_range (t int primary key,c2  timestamp(6) default "2012-01-01 12:00:00",c3 datetime(6));
insert into t_range values(1, '0000-01-01 00:00:00', '0000-01-01 00:00:00');
insert into t_range values(1, '0000-01-03 00:00:00', '0000-01-01 00:00:00');
insert into t_range values(2, '0001-01-01 00:00:00', '0001-01-01 00:00:00');
insert into t_range values(13, '1-01-01 00:00:00', '1-01-01 00:00:00');
insert into t_range values(14, '2-01-01 00:00:00', '2-01-01 00:00:00');
insert into t_range values(3, '-0001-01-01 00:00:00', '-0001-01-01 00:00:00');
--error 1292
insert into t_range values(4, '-4713-01-01 00:00:00', '-4713-01-01 00:00:00');
--error 1292
insert into t_range values(5, '-4714-01-01 00:00:00', '-4714-01-01 00:00:00');
insert into t_range values(6, '9999-01-01 00:00:00', '9999-01-01 00:00:00');
--error 1292
insert into t_range values(7, '10000-01-01 00:00:00', '10000-01-01 00:00:00');
--error 1292
insert into t_range values(9, '-1-01-01 00:00:00', '-1-01-01 00:00:00');
select * from t_range;

set timestamp = 100;
select now(),now(1),now(2),now(3),now(4),now(5),now(6),current_time(),current_date();
select @@timestamp;
set timestamp = 133.345;
select @@timestamp;
select now(),now(1),now(2),now(3),now(4),now(5),now(6),current_time(),current_date();
set timestamp = 0;

set timestamp = 133.3451111111;
select @@timestamp;
select now(),now(1),now(2),now(3),now(4),now(5),now(6),current_time(),current_date();
set timestamp = 0;

set timestamp = 133.3456666666;
select @@timestamp;
select now(),now(1),now(2),now(3),now(4),now(5),now(6),current_time(),current_date();
set timestamp = 0;

set timestamp = 0;
--error 1231
set timestamp = -100;
set timestamp = 100;
--error 1231
set timestamp = -100.123;
set timestamp = 100.123;
select @@timestamp;
--error 1231
set timestamp = 253402272000;
set timestamp = 0;
set timestamp = 1600000000;

###### test for bug #########
--disable_warnings
drop table if exists t_refered,t_h5_r4_int_int_datetime;
--enable_warnings
create table t_refered(a int, aa bigint, b int unsigned, bb bigint unsigned, c datetime, d date, e timestamp,  primary key (a));
create table t_h5_r4_int_int_datetime(a int, b int, c datetime, primary key (a, b, c));
insert into t_refered values ( 1,  1, 1, 1, 20161101, 20161101, 20161101), ( 2,  2, 2, 2, 20161101, 20161102, 20161102), ( 3,  3, 3, 3, 20161103, 20161101, 20161103), ( 4,  4, 4, 4, 20161104, 20161101, 20161104);
insert into t_h5_r4_int_int_datetime values ( 1,  1, 20161101), ( 2,  2, 20161102), ( 3,  3, 20161103), ( 4,  4, 20161104);
select * from t_h5_r4_int_int_datetime t1, t_refered as t2 where t1.a = t2.a and t1.b=t2.a and t1.c = t2.e;
drop table if exists t_refered,t_h5_r4_int_int_datetime;

--disable_warnings
drop table if exists t;
set time_zone = '+8:00';
create table t(c1 timestamp);
insert into t values('0000-01-02 07:59:59');
insert into t values('0000-01-02 08:00:00');
select * from t;
drop table t;

##bugfix: 
create table t(c1 timestamp, c2 datetime, c3 int);
insert into t(c2) values('0000-01-01 00:00:00');
update t set c1 = c2;
select * from t;
update t set c2 = '0000-01-01 07:59:59';
update t set c1 = c2;
select * from t;
update t set c2 = '0000-01-02 08:00:00';
update t set c1 = c2;
select * from t;

delete from t;
insert into t(c2) values('9999-12-31 23:00:00');
update t set c1 = c2;
select * from t;
delete from t;

set time_zone = '-8:00';
insert into t(c2) values('0000-01-01 00:00:00');
update t set c1 = c2;
select * from t;
update t set c2 = '0000-01-01 08:00:00';
update t set c1 = c2;
select * from t;

delete from t;
insert into t(c2) values('9999-12-31 23:00:00');
update t set c1 = c2;
select c1 from t;

drop table t;



## test function timestamp
set timestamp = 1600000000;
select timestamp(123);
select timestamp(123.456);
select timestamp('2020-01-01');
select timestamp(date '2020-01-01');
select timestamp(timestamp '2020-01-01 10:00:00');
select timestamp(time '12:34:56.123');
create table t as select timestamp(123) c1, timestamp(123.456) c2, timestamp('2020-01-01') c3,
    timestamp(date '2020-01-01') c4, timestamp(timestamp '2020-01-01 10:00:00') c5, timestamp(time '12:34:56.123') c6;
desc t;
select * from t;
drop table t;


create table t(c1 int, c2 float, c3 decimal(12,3), c4 varchar(20), c5 date, c6 time,
  c7 time(3), c8 datetime, c9 datetime(3), c10 timestamp, c11 timestamp(3));
insert into t values(123, 123, 123, '123', '2020-01-01', '12:34:56', '12:34:56.123456',
  '2020-01-01 12:34:56', '2020-01-01 12:34:56.123456', '2020-01-01 12:34:56', '2020-01-01 12:34:56.123456');
insert into t values(123123, 123.123, 123.123, '123.123', '2020-01-01', '12:34:56', '12:34:56.123456',
  '2020-01-01 12:34:56', '2020-01-01 12:34:56.123456', '2020-01-01 12:34:56', '2020-01-01 12:34:56.123456');
select c1, timestamp(c1) from t;
select c2, timestamp(c2) from t;
select c3, timestamp(c3) from t;
select c4, timestamp(c4) from t;
select c5, timestamp(c5) from t;
select c6, timestamp(c6) from t;
select c7, timestamp(c7) from t;
select c8, timestamp(c8) from t;
select c9, timestamp(c9) from t;
select c10, timestamp(c10) from t;
select c11, timestamp(c11) from t;


##test function timestamp with two parameters
select timestamp(null, '00:00:01');
select timestamp('2020-01-01 12:34:56', null);
select timestamp(null, null);
--disable_warnings
drop table if exists t_time, t1;
--enable_warnings
create table t_time (c1 time, c2 time(4), c3 decimal(15,8), c4 varchar(100));
insert into t_time values('00:00:01', '00:00:01', 1, '00:00:01');
insert into t_time values('00:00:11.123456', '00:00:11.123456', 11.123456, '00:00:11.123456');
insert into t_time values('100:22:11.123456', '100:22:11.123456', 1002211.123456, '100:22:11.123456');
insert into t_time values('-00:00:11.123456', '-00:00:11.123456', -11.123456, '-00:00:11.123456');
create table t1 as select timestamp(a.c8, b.c1) c1, timestamp(a.c8, b.c2) c2, timestamp(a.c8, b.c3) c3, timestamp(a.c8, b.c4) c4 from t a, t_time b;
desc t1;
select * from t1;

drop table t1;
create table t1(c1 datetime);
explain select * from t1 where c1 < TIMESTAMP'1990-02-01';
