--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
#description: test <= 2M transaction data whether can be commited
# tags: datatype

--disable_warnings
--disable_result_log
drop table if exists t1;
--source mysql_test/include/index_quick_major.inc
--enable_warnings
--enable_result_log
#create table t1(pk timestamp(6) primary key, c1  timestamp(6) default "2012-01-01 12:00:00",c2 timestamp ,c3 timestamp , c4  timestamp(6) default "2012-01-01 12:00:00", c5  timestamp(6) default "2012-01-01 12:00:00",c6  timestamp(6) default "2012-01-01 12:00:00",c7  timestamp(6) default "2012-01-01 12:00:00");
create table t1(a varchar(65536), b varchar(65536), c varchar(65536), d varchar(65536));
#--disable_query_log
set autocommit=0;
#when fixed bug 6606504,please set cnt=40000
#let $cnt=20000
let $cnt=8;
while($cnt)
{
 # eval insert into t1 values(usec_to_time($cnt),usec_to_time($cnt),usec_to_time($cnt),usec_to_time($cnt),usec_to_time($cnt),usec_to_time($cnt),usec_to_time($cnt),usec_to_time($cnt));
 insert into t1 values(repeat('a', 65536), repeat('a', 65536), repeat('a', 65536), repeat('a', 65536));  
 dec $cnt;
}
commit;
#--enable_query_log

set autocommit=1;
select count(*) from t1;
#select pk,c1,c2,c3,c4,c5,c6,c7 from t1;
