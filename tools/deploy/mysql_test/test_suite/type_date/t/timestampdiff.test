--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: dachuan.sdc
#### owner group: sql3
#### description: test for timestampdiff
# tags: datatype

--disable_warnings
drop table if exists sb;
--enable_warnings
select timestampdiff(second,"2012-04-08 12:34:56","2011-05-09 13:45:55");
select timestampdiff(second,"2012-04-08 12:34:56","2010-05-09 13:45:55");
select timestampdiff(minute,"2012-04-08 12:34:56","2011-05-09 13:45:55");
select timestampdiff(minute,"2012-04-08 12:34:56","2010-05-09 13:45:55");
select timestampdiff(hour,"2012-04-08 23:59:59","2011-05-09 00:00:00");
select timestampdiff(hour,"2011-05-09 00:00:00","2012-04-08 23:59:59");
select timestampdiff(day,"2012-04-08 23:59:59","2011-05-09 00:00:00");
select timestampdiff(day,"2011-05-09 00:00:00","2012-04-08 23:59:59");
select timestampdiff(week,"2012-04-08 23:59:59","2011-05-09 00:00:00");
select timestampdiff(week,"2011-05-09 00:00:00","2012-04-08 23:59:59");
select timestampdiff(month,"2012-04-08 01:00:00","2011-05-07 02:00:00");
select timestampdiff(month,"2012-04-08 02:00:12","2011-10-07 01:11:11");
select timestampdiff(month,"2012-04-08 01:00:00","2015-09-07 02:00:00");
select timestampdiff(month,"2012-04-08 02:00:12","2011-10-08 01:11:11");
select timestampdiff(month,"2012-04-08 01:00:00","2015-09-08 00:00:00");
select timestampdiff(month,"2012-04-08 01:00:00","2011-05-09 00:00:00");
select timestampdiff(month,"2012-04-08","2011-04-07");
select timestampdiff(month,"2012-04-08","2011-05-07");
select timestampdiff(month,"2012-04-08","2011-10-07");
select timestampdiff(month,"2012-04-08","2015-09-07");
select timestampdiff(month,"2012-04-08","2011-10-08");
select timestampdiff(month,"2012-04-08","2015-09-08");
select timestampdiff( month, '2001-12-01 01:00:00', '2001-12-14 00:00:00');
select timestampdiff( month, '2001-12-14 00:00:00', '2001-12-01 01:00:00');
select timestampdiff( month, '2000-02-01 00:00:00', '2000-03-01 00:00:00');
select timestampdiff( month, '2000-02-02 00:00:00', '2000-03-01 00:00:00');
select timestampdiff( month, '2000-02-02 00:00:00', '2000-02-28 00:00:00');
select timestampdiff( month, '2000-02-28 00:00:00', '2012-02-28 00:00:00');
select timestampdiff(quarter,"2012-04-08","2015-05-09");
select timestampdiff(quarter,"2012-04-08","2015-04-07");
select timestampdiff(quarter,"2012-04-08","2015-05-07");
select timestampdiff(quarter,"2012-04-08","2015-10-07");
select timestampdiff(quarter,"2012-04-08","2015-09-07");
select timestampdiff(quarter,"2012-04-08","2015-10-08");
select timestampdiff(quarter,"2012-04-08","2015-09-08");
set time_zone='-5:00';
create table sb(a timestamp,b timestamp);
insert into sb values ("2010-08-06 12:34:56","2010-09-06 13:45:56");
set time_zone='-5:00';
select timestampdiff(hour,a,b) from sb;
drop table sb;
set time_zone='+6:00';
create table sb(a datetime,b timestamp);
insert into sb values ("2010-08-06 12:34:56","2010-09-06 13:45:56");
set time_zone='-4:00';
select timestampdiff(hour,a,b) from sb;
drop table sb;
