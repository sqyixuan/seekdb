# expr_date_format
# owner: dachuan.sdc
# owner group: SQL1
# tags: datatype

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1(c2 DATETIME(6));
INSERT INTO t1 VALUES('1000-01-01 00:00:00.123');
INSERT INTO t1 VALUES('1999-12-31 23:59:59.456');
INSERT INTO t1 VALUES('2000-01-01 00:00:00.7896');
INSERT INTO t1 VALUES('2008-02-29 13:13:13.44444');
select date_format(c2,"%Y") from t1;
select date_format(c2,"%a") from t1;
select date_format(c2,"%b") from t1;
select date_format(c2,"%c") from t1;
select date_format(c2,"%D") from t1;
select date_format(c2,"%d") from t1;
select date_format(c2,"%e") from t1;
select date_format(c2,"%f") from t1;
select date_format(c2,"%H") from t1;
select date_format(c2,"%h") from t1;
select date_format(c2,"%i") from t1;
select date_format(c2,"%j") from t1;
select date_format(c2,"%k") from t1;
select date_format(c2,"%l") from t1;
select date_format(c2,"%M") from t1;
select date_format(c2,"%p") from t1;
select date_format(c2,"%r") from t1;
select date_format(c2,"%S") from t1;
select date_format(c2,"%T") from t1;
select date_format(c2,"%W") from t1;
select date_format(c2,"%w") from t1;
select date_format(c2,"%y") from t1;
select date_format(c2,"%Y%d%m") from t1;
drop table t1;

--echo ##bugfix: 
set timestamp = 1600000000;
select DATE_FORMAT(utc_time(),GET_FORMAT(DATE,'JIS'));
select DATE_FORMAT(utc_time(),GET_FORMAT(DATETIME,'internal'));
set timestamp = 0;

--disable_warnings
drop view if exists v1;
drop table if exists t2;
--enable_warnings
select get_format(DATE, 'EUR'), get_format(DATE, 'INTERNAL'), get_format(DATE, 'ISO'), get_format(DATE, 'JIS'), get_format(DATE, 'USA');
select get_format(TIME, 'EUR'), get_format(TIME, 'INTERNAL'), get_format(TIME, 'ISO'), get_format(TIME, 'JIS'), get_format(TIME, 'USA');
select get_format(DATETIME, 'EUR'), get_format(DATETIME, 'INTERNAL'), get_format(DATETIME, 'ISO'), get_format(DATETIME, 'JIS'), get_format(DATETIME, 'USA');
select get_format(TIMESTAMP, 'EUR'), get_format(TIMESTAMP, 'INTERNAL'), get_format(TIMESTAMP, 'ISO'), get_format(TIMESTAMP, 'JIS'), get_format(TIMESTAMP, 'USA');
select get_format(DATE, ''), get_format(DATE, 'A'), get_format(DATE, 123), get_format(DATE, NULL);
select get_format(TIME, ''), get_format(TIME, 'A'), get_format(TIME, 123), get_format(TIME, NULL);
select get_format(DATETIME, ''), get_format(DATETIME, 'A'), get_format(DATETIME, 123), get_format(DATETIME, NULL);
select get_format(TIMESTAMP, ''), get_format(TIMESTAMP, 'A'), get_format(TIMESTAMP, 123), get_format(TIMESTAMP, NULL);
create table t1(c1 varchar(10));
insert into t1 values('EUR');
insert into t1 values('INTERNAL');
insert into t1 values('ISO');
insert into t1 values('JIS');
insert into t1 values('USA');
insert into t1 values('');
insert into t1 values('A');
insert into t1 values('123');
select c1, get_format(DATE, c1), get_format(TIME, c1), get_format(DATETIME, c1) from t1;
create view v1 as select c1, get_format(DATE, c1) c2, get_format(TIME, c1) c3, get_format(DATETIME, c1) c4 from t1;
create table t2 as select c1, get_format(DATE, c1) c2, get_format(TIME, c1) c3, get_format(DATETIME, c1) c4 from t1;
desc v1;
desc t2;
show create view v1;
drop table t1;
drop view v1;

set collation_connection = 'utf8_general_ci';
select collation(get_format(DATE, 'EUR'));
select collation(get_format(DATE, 'EUR' collate utf8_bin));
select collation(get_format(TIME, 'EUR'));
select collation(get_format(TIME, 'EUR' collate utf8_bin));
select collation(get_format(DATETIME, 'EUR'));
select collation(get_format(DATETIME, 'EUR' collate utf8_bin));

set collation_connection = 'gbk_chinese_ci';
select collation(get_format(DATE, 'EUR'));
select collation(get_format(DATE, 'EUR' collate gbk_bin));
select collation(get_format(TIME, 'EUR'));
select collation(get_format(TIME, 'EUR' collate gbk_bin));
select collation(get_format(DATETIME, 'EUR'));
select collation(get_format(DATETIME, 'EUR' collate gbk_bin));
