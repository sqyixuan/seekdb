# description: 本case是为了测试系统变量explicit_default_for_timestamp被修改成ON的表现
# owner: dachuan.sdc
# owner group: SQL1
# tags: datatype

--disable_warnings
drop table if exists test, test2;
--enable_warnings

show variables like 'explicit_defaults_for_timestamp';

create table test(c1 int, c2 timestamp, c3 timestamp);
desc test;
insert into test values(1, null, null);
select * from test;
update test set c1 = 2, c3 = null;
select * from test;
drop table test;
create table test(c1 int, c2 timestamp, c3 timestamp not null);
desc test;
--error 1048
insert into test values(1, null, null);
set @@session.explicit_defaults_for_timestamp=OFF;
drop table test;
create table test(c1 int, c2 timestamp, c3 timestamp);
desc test;
insert into test values(1, null, null);
select c1 from test where c2 is null;
drop table test;
create table test(c1 int, c2 timestamp, c3 timestamp not null);
desc test;
insert into test values(1, null, null);
#修改系统变量，之前生效的表已经生效，新建的表则不生效
set @@session.explicit_defaults_for_timestamp=ON;
--error 1048
insert into test values(3, null, null);
create table test2(c1 int, c2 timestamp, c3 timestamp);
desc test2;
insert into test2 values(1, null, null);
select * from test2;
--error 1048
insert into test values(11,null, null);
select c1 from test where c2 is null;
alter table test add column c4 timestamp;
desc test;
--error 1048
insert into test values(4,null,null,null);
select c1 from test where c2 is null;

drop table test;
drop table test2;
