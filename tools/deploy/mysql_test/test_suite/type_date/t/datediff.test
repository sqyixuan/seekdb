--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
# tags: datatype
#### description: test for datediff

--disable_warnings
drop table if exists sb;
--enable_warnings
create table sb(a double,b double);

insert into sb values(20101011,20101111);

select datediff(a,b) from sb;

select datediff(NULL,NULL);

select datediff("2010-01-01","2010-02-01");

select datediff("2010-01-01",2010-02-01);

select datediff("2010-01-01",NULL);

--disable_warnings

drop table if exists sb;
