# owner group: sql2
# tags: year, cast
# description: 

connect (mysql, $OBMYSQL_MS0, root, , test, $OBMYSQL_PORT);
connection mysql;
alter system flush sql audit global;
alter system flush plan cache global;

--disable_warnings
drop table if exists t_year, t_tinyint, t_utinyint;
--disable_warnings

create table t_year(c year);
insert into t_year values(2000);

create table t_tinyint(c tinyint);
--error 1264
insert into t_tinyint values(2000);
--error 1264
insert into t_tinyint select * from t_year;

create table t_utinyint(c tinyint unsigned);
--error 1264
insert into t_utinyint values(2000);
--error 1264
insert into t_utinyint select * from t_year;

--disable_warnings
drop table if exists t_year, t_tinyint, t_utinyint;
--enable_warnings

## test cast between year and time
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 time, c2 year);
insert into t1(c1) values('00:00:00'), ('00:00:01'), ('00:00:10'), ('00:01:00'), ('00:10:00'), ('01:00:00'), ('10:00:00'), ('100:00:00');
set sql_mode = '';
update t1 set c2 = c1;
select * from t1;

delete from  t1;
insert into t1(c2) values(0), (10), (100), (1000), (1901), (2000);
update t1 set c1 = c2;
select * from t1;
set sql_mode = default;
drop table t1;

CREATE TABLE t1(Z0_TEST0 year);
INSERT INTO t1 VALUES('1920');
INSERT INTO t1 VALUES(NULL);
ALTER TABLE t1 MODIFY column z0_test0 TIME;
select * from t1;
drop table t1;