--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
# tags: datatype
#### description: 用于计算绝对值
--disable_warnings
drop table if exists sb;
--enable_warnings
##backup something...
set @tmp_sql_mode = @@sql_mode;
set @tmp_time_zone = @@time_zone;
set @@sql_mode = 'STRICT_TRANS_TABLES';
set @@time_zone = '+7:00';
select from_unixtime(0);
select from_unixtime(0.0);
select from_unixtime("0");
select from_unixtime("0.0");
select from_unixtime(123456789);
select from_unixtime(123456789.123);
select from_unixtime("123456789.123");
select from_unixtime(-123456789);
select from_unixtime(-123456789.123);
select from_unixtime("-123456789.123");
select from_unixtime(null);
select from_unixtime(null,null);
select from_unixtime("123456789.123",null);
select from_unixtime(null,"123456789.123");
select from_unixtime("123456789.123",1234);
select from_unixtime("123456789.123","1234");
select from_unixtime(1234567890, '%Y-%m-%d %H:%i:%S');
create table sb(a int,b bigint, c decimal(20,10), d datetime(3), g varchar(256));
insert into sb values(123456789, 1234567890, 1234567890, "2010-01-01 11:11:11", "1234567890");
insert into sb values(-123456789, -1234567890, -1234567890, "2010-01-01 11:11:11","2010-01-01 11:23:34");
select from_unixtime(a) from sb;
select from_unixtime(b) from sb;
select from_unixtime(c) from sb;
select from_unixtime(d) from sb;
select from_unixtime(g) from sb;
insert into sb values(NULL, NULL, NULL, from_unixtime(NULL), NULL);
insert into sb values(NULL, NULL, NULL, from_unixtime(1234567890), NULL);
insert into sb values(NULL, NULL, NULL, from_unixtime("1234567890"), NULL);
--error 1292
insert into sb values(NULL, NULL, NULL, from_unixtime(9999999999999999999999), NULL);
insert into sb values(NULL, NULL, NULL, from_unixtime("1234567890"), NULL);
set @@time_zone = '-5:00';
insert into sb values(123456789, 1234567890, 1234567890, "2010-01-01 11:11:11", "1234567890");
insert into sb values(-123456789, -1234567890, -1234567890, "2010-01-01 11:11:11", "2010-01-01 11:23:34");
select from_unixtime(a) from sb;
select from_unixtime(b) from sb;
select from_unixtime(c) from sb;
select from_unixtime(d) from sb;
select from_unixtime(g) from sb;
set @@sql_mode = '';
select from_unixtime(0);
select from_unixtime(0.0);
select from_unixtime("0");
select from_unixtime("0.0");
select from_unixtime(123456789);
select from_unixtime(123456789.123);
select from_unixtime("123456789.123");
select from_unixtime(-123456789);
select from_unixtime(-123456789.123);
select from_unixtime("-123456789.123");
select from_unixtime(null);
select from_unixtime(null,null);
select from_unixtime("123456789.123",null);
select from_unixtime(null,"123456789.123");
select from_unixtime("123456789.123",1234);
select from_unixtime("123456789.123","1234");
select from_unixtime(1234567890, '%Y-%m-%d %H:%i:%S');
select from_unixtime("2010-01-01 11:23:34", '%Y-%m-%d %H:%i:%S');
select from_unixtime(999999999999999999, '%Y-%m-%d %H:%i:%S');
drop table sb;
create table sb(a int,b bigint, c decimal(20,10), d datetime, g varchar(256));
insert into sb values(123456789, 1234567890, 1234567890, "2010-01-01 11:11:11", "1234567890");
insert into sb values(-123456789, -1234567890, -1234567890, "2010-01-01 11:11:11", "2010-01-01 11:23:34");
insert into sb values(NULL, NULL, NULL, from_unixtime(NULL), NULL);
insert into sb values(NULL, NULL, NULL, from_unixtime(1234567890), NULL);
insert into sb values(NULL, NULL, NULL, from_unixtime("1234567890"), NULL);
insert into sb values(NULL, NULL, NULL, from_unixtime(999999999999), NULL);
insert into sb values(NULL, NULL, NULL, from_unixtime(9999999999999999999), NULL);
insert into sb values(NULL, NULL, NULL, from_unixtime("abcdefg"), NULL);
insert into sb values(NULL, NULL, NULL, from_unixtime("2010-01-01 11:23:34"), NULL);
select from_unixtime(a) from sb;
select from_unixtime(b) from sb;
select from_unixtime(c) from sb;
select from_unixtime(d) from sb;
select from_unixtime(g) from sb;
drop table sb;
##restore the original sql mode and timezone
set @@sql_mode = @tmp_sql_mode;
set @@time_zone = @tmp_time_zone;

