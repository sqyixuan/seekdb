f_test(100)
1
DROP FUNCTION f_test;
CREATE DEFINER = 'wmj456'@'%' FUNCTION f_test( samplename varchar(200), samplename1 varchar(200)) returns varchar(200) SQL SECURITY DEFINER 
begin
declare a varchar(200);
declare b varchar(200);
SELECT sign(samplename) FROM t1 WHERE consumer='书局' INTO a;
SELECT sign(samplename1) FROM t1 WHERE sign(t1.sal) = samplename1 into b;
return a+b;
END;
//
SELECT f_test(100,-1);
f_test(100,-1)
0
DROP FUNCTION f_test;
CREATE USER 'TEST_A1'@'%' IDENTIFIED BY 'testa1';
