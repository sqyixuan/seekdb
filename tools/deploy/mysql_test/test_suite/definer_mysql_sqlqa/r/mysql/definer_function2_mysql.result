begin
declare a varchar(200);
declare b varchar(200);
SELECT sign(samplename) FROM t1 WHERE consumer='书局' INTO a;
SELECT sign(samplename1) FROM t1 WHERE sign(t1.sal) = samplename1 into b;
return a+b;
END;
