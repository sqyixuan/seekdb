GRANT ALL ON *.* TO 'TEST_A1'@'%' WITH GRANT OPTION;
CREATE DEFINER = 'TEST_A1'@'%' PROCEDURE p_test(out wb  varchar(200)) SQL SECURITY DEFINER
BEGIN
declare a varchar(200);
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = 0 into wb;
END;
//
CALL p_test(@wb);
DROP PROCEDURE p_test;
SELECT COUNT(*) FROM t1;
COUNT(*)
6
DROP USER TEST_A1@'%';
CREATE USER 'TEST_A1'@'%' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO 'TEST_A1'@'%' WITH GRANT OPTION;
CREATE DEFINER = 'TEST_A1'@'%' PROCEDURE p_test( out wb varchar(200), inout wb1 varchar(200))
begin
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = 0 into wb;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = -1 into wb1;
END;
//
call p_test(@wb,@wb1);
SELECT COUNT(*) FROM t1;
COUNT(*)
6
DROP USER TEST_A1@'%';
Warnings:
Warning	4005	User 'TEST_A1'@'%' is referenced as a definer account in a stored routine.
