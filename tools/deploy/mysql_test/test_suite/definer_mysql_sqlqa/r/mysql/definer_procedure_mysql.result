CREATE DEFINER = 'TEST_A1'@'%' PROCEDURE p_test(in samplename  varchar(200)) SQL SECURITY DEFINER
BEGIN
declare a varchar(200);
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
INSERT INTO t1 VALUES(0, a, concat('in存储过程a参数第', 1, '次'),7000,'2020-08-21 10:11:59',20190821101159);
END;
//
CALL p_test(500);
DROP PROCEDURE p_test;
