############################## TEST CASES  ##############################
## DEFINER用户不存在，执行函数，正常

--disable_warnings
DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' FUNCTION f_test()
returns varchar(200) SQL SECURITY INVOKER 
BEGIN
	declare a varchar(200) default '饿了么';
	UPDATE t1 SET consumer = a WHERE consumer='玻璃';
	return a;
END;
//
DELIMITER ;//
--enable_warnings

SELECT f_test();
DROP FUNCTION f_test;


############################## TEST CASES  ##############################
## DEFINER有权限，移除INVOKER的DELETE权限，执行函数，报错

CREATE USER 'TEST_A1'@'%' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO 'TEST_A1'@'%' WITH GRANT OPTION;
REVOKE delete ON *.* FROM wmj456@'%';
sleep 3;
connection default;  
sleep 4;
connection conn;  
sleep 4;

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' FUNCTION f_test()
returns varchar(200) SQL SECURITY INVOKER 
BEGIN
	declare a varchar(200) default '饿了么';
	delete from t1 WHERE consumer = a;
	return a;
END;
//
DELIMITER ;//

--ERROR 0,1142
SELECT f_test();
DROP FUNCTION f_test;
DROP USER 'TEST_A1'@'%';

sleep 3;
connection default;  
GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;
sleep 4;
connection conn;  
sleep 6;


############################## TEST CASES  ##############################
## DEFINER=CURRENT_USER，移除INVOKER的DELETE权限，执行函数，报错

CREATE VIEW t1_view AS SELECT * FROM t1 ;
CREATE USER TEST_A1@'%' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO TEST_A1@'%' WITH GRANT OPTION;
REVOKE delete ON *.* FROM wmj456@'%';
sleep 3;
connection default;  
sleep 4;
connection conn;  
sleep 4;

DELIMITER //;
CREATE DEFINER = CURRENT_USER FUNCTION f_test()
returns varchar(200) SQL SECURITY INVOKER 
BEGIN
	declare a varchar(200) default '饿了么';
	delete from t1 WHERE consumer = a;
	return a;
END;
//
DELIMITER ;//

--ERROR 0,1142
SELECT f_test();
DROP FUNCTION f_test;


## 移除INVOKER的delete视图权限，执行函数

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' FUNCTION f_test()
returns varchar(200) SQL SECURITY INVOKER
BEGIN
	declare a varchar(200) default '饿了么';
	delete from t1_view WHERE consumer = a;
	return a;
END;
//
DELIMITER ;//

--ERROR 0,1142
SELECT f_test();
DROP FUNCTION f_test;
DROP VIEW t1_view;
DROP USER TEST_A1@'%';

sleep 3;
connection default;  
GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;
sleep 4;
connection conn;  
sleep 4;


