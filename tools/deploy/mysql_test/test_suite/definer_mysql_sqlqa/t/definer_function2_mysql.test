CREATE USER 'TEST_A1'@'%' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO 'TEST_A1'@'%' WITH GRANT OPTION;

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' FUNCTION f_test( samplename varchar(200)) returns varchar(200) SQL SECURITY DEFINER 
begin
	declare a varchar(200);
	SELECT sign(samplename) FROM t1 WHERE consumer='书局' INTO a;
	return a;
END;
//
DELIMITER ;//

DROP USER 'TEST_A1'@'%';
