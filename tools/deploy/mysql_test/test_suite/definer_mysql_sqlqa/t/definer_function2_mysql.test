############################## TEST CASES  ##############################
## 含有一个参数函数时，执行函数，正常

DELIMITER //;
CREATE DEFINER = 'wmj456'@'%' FUNCTION f_test(samplename varchar(200))
returns varchar(200) SQL SECURITY DEFINER 
begin
	declare a varchar(200);
	SELECT sign(samplename) FROM t1 WHERE consumer='书局' INTO a;
	return a;
END;
//
DELIMITER ;//

SELECT f_test(100);
DROP FUNCTION f_test;


############################## TEST CASES  ##############################
## 含有多个参数函数时，执行函数，正常

DELIMITER //;
CREATE DEFINER = 'wmj456'@'%' FUNCTION f_test( samplename varchar(200), samplename1 varchar(200)) returns varchar(200) SQL SECURITY DEFINER 
begin
	declare a varchar(200);
	declare b varchar(200);
	SELECT sign(samplename) FROM t1 WHERE consumer='书局' INTO a;
	SELECT sign(samplename1) FROM t1 WHERE sign(t1.sal) = samplename1 into b;
	return a+b;
END;
//
DELIMITER ;//

SELECT f_test(100,-1);
DROP FUNCTION f_test;


############################## TEST CASES  ##############################
## 修改函数SQL SECURITY INVOKE 为 DEFINER=B，B用户无权限，报错

CREATE USER 'TEST_A1'@'%' IDENTIFIED BY 'testa1';

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' FUNCTION f_test( samplename varchar(200), samplename1 varchar(200)) returns varchar(200) SQL SECURITY INVOKER 
begin
	declare a varchar(200);
	declare b varchar(200);
	SELECT sign(samplename) FROM t1 WHERE consumer='书局' INTO a;
	SELECT sign(samplename1) FROM t1 WHERE sign(t1.sal) = samplename1 into b;
	return a+b;
END;
//
DELIMITER ;//

ALTER FUNCTION f_test SQL SECURITY DEFINER;
--error 1142, 1370
SELECT f_test(100,-1);
DROP FUNCTION f_test;
DROP USER 'TEST_A1'@'%';


############################## TEST CASES  ##############################
