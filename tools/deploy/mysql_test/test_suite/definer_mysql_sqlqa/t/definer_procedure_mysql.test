############################## TEST CASES  ##############################
## 显示定义SQL SECURITY DEFINER

CREATE USER TEST_A1 IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO TEST_A1 WITH GRANT OPTION;

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' PROCEDURE p_test() SQL SECURITY DEFINER
begin
	declare a varchar(200);
	declare i int default 1;
	SELECT ID FROM t1  WHERE consumer='书局' INTO a;
WHILE i <= 1 do
	INSERT INTO t1 VALUES(0,a,concat('无参存储过程a参数第',i,'次'),7000,'2020-08-21 10:11:59',20190821101159);
	set i := i + 1;
	END while;
END;
//
DELIMITER ;//

SELECT COUNT(*) FROM t1;
CALL p_test();
SELECT COUNT(*) FROM t1;

DELETE FROM t1 WHERE price LIKE '%存储%';
DROP USER TEST_A1;
DROP PROCEDURE p_test;


############################## TEST CASES  ##############################
## DEFINER用户不存在，执行存储过程，正常

--disable_warnings
DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' PROCEDURE p_test() SQL SECURITY INVOKER
begin
	declare a varchar(200);
	declare i int default 1;
	SELECT ID FROM t1  WHERE consumer='书局' INTO a;
WHILE i <= 1 do
	INSERT INTO t1 VALUES(0,a,concat('无参存储过程a参数第',i,'次'),7000,'2020-08-21 10:11:59',20190821101159);
	set i := i + 1;
	END while;
END;
//
DELIMITER ;//
--enable_warnings

SELECT COUNT(*) FROM t1;
CALL p_test();
SELECT COUNT(*) FROM t1;

DELETE FROM t1 WHERE price LIKE '%存储%';
DROP PROCEDURE p_test;


############################## TEST CASES  ##############################
## DEFINER有权限，移除INVOKER的SELECT权限，执行函数，报错

CREATE USER 'TEST_A1'@'%' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO 'TEST_A1'@'%' WITH GRANT OPTION;
REVOKE SELECT ON *.* FROM wmj456@'%';
REVOKE Delete ON *.* FROM wmj456@'%';
REVOKE INSERT ON *.* FROM wmj456@'%';
REVOKE UPDATE ON *.* FROM wmj456@'%';

sleep 3;
connection default;  
sleep 4;
connection conn;  
sleep 4;

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' PROCEDURE p_test() SQL SECURITY INVOKER
begin
	declare a varchar(200);
	declare i int default 1;
	SELECT ID FROM t1  WHERE consumer='书局' INTO a;
END;
//
DELIMITER ;//

--ERROR 0,1142
CALL p_test();
DROP PROCEDURE p_test;

sleep 3;
connection default;  
GRANT SELECT ON *.* TO wmj456 WITH GRANT OPTION;
sleep 4;
connection conn;  
sleep 4;


## DEFINER有权限，移除INVOKER的UPDATE权限，执行函数，报错

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' PROCEDURE p_test() SQL SECURITY INVOKER
begin
	declare a varchar(200) default '饿了么';
	UPDATE t1 SET consumer = a WHERE consumer='玻璃';
END;
//
DELIMITER ;//

SELECT COUNT(*) FROM t1;
--ERROR 0,1142
CALL p_test();
SELECT COUNT(*) FROM t1;
DROP PROCEDURE p_test;


## DEFINER有权限，移除INVOKER的DELETE权限，执行函数，报错

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' PROCEDURE p_test() SQL SECURITY INVOKER
begin
	declare a varchar(200) default '饿了么';
	delete from t1 WHERE consumer = a;
END;
//
DELIMITER ;//

SELECT COUNT(*) FROM t1;
--ERROR 0,1142
CALL p_test();
SELECT COUNT(*) FROM t1;
DROP PROCEDURE p_test;


## DEFINER有权限，移除INVOKER的UPDATE权限，执行函数，报错

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' PROCEDURE p_test() SQL SECURITY INVOKER
begin
	declare a varchar(200) default '饿了么';
	UPDATE t1 SET consumer = a WHERE consumer='玻璃';
END;
//
DELIMITER ;//

SELECT COUNT(*) FROM t1;
--ERROR 0,1142
CALL p_test();
SELECT COUNT(*) FROM t1;
DROP PROCEDURE p_test;


## 移除INVOKER的delete视图权限，执行过程，报错

DELIMITER //;
CREATE VIEW t1_view AS SELECT * FROM t1 ;

CREATE DEFINER = 'TEST_A1'@'%' FUNCTION f_test()
returns varchar(200) SQL SECURITY INVOKER
BEGIN
	declare a varchar(200) default '饿了么';
	delete from t1_view WHERE consumer = a;
	return a;
END;
//
DELIMITER ;//

--ERROR 0,1142
SELECT f_test();
DROP FUNCTION f_test;
DROP USER TEST_A1@'%';
DROP VIEW t1_view;


sleep 3;
connection default;  
GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;
sleep 4;
connection conn;  
sleep 4;


############################## TEST CASES  ##############################
## 修改存储过程SECURITY INVOKER 为 DEFINER=B，B用户不存在，报错

--disable_warnings
DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' PROCEDURE p_test() SQL SECURITY INVOKER
BEGIN
	declare a varchar(200) default '饿了么';
	UPDATE t1 SET consumer = a WHERE consumer='玻璃';
END;
//
DELIMITER ;//
--enable_warnings

ALTER PROCEDURE p_test SQL SECURITY DEFINER;
# 有报错
--error 1449
CALL p_test();
SELECT COUNT(*) FROM t1;
DROP PROCEDURE p_test;


