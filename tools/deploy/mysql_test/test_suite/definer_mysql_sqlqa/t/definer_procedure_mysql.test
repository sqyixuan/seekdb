--enable_warnings

CREATE USER wmj456 IDENTIFIED BY 'wmj456';
GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,wmj456,wmj456,obwmjtest,$OBMYSQL_PORT);
connection conn;


############### Initialize_Environment ###############

--error 0,1051
DROP TABLE t1;
--error 0,1051
DROP TABLE t2;
--error 0,1051
DROP TABLE t3;
--error 0,1305
DROP FUNCTION f_test;
--error 0,1305
DROP PROCEDURE p_test;
--error 0,1360
DROP TRIGGER demo;



################## Test Environment ##################
CREATE TABLE t1 (
  id int NOT NULL,
  consumer char(20) DEFAULT NULL,
  price varchar(20) DEFAULT NULL,
  sal int DEFAULT NULL,
  datetime1 DATE,
  `datetime2` bigint
);
INSERT INTO t1 VALUES(1,'书局','7000',5000,'2020-09-22',20200923121200);
INSERT INTO t1 VALUES(2,'微山','3000',-4000,'2020-09-21',20200921101159);
INSERT INTO t1 VALUES(3,'深咖','5000',0,'2020-08-21',20190821101159);
INSERT INTO t1 VALUES(4,'流苏','0',NULL,'2020-02-29',20200228101159);
INSERT INTO t1 VALUES(5,'玻璃','3200',6000,'2020-02-29',20200228101159);
INSERT INTO t1 VALUES(6,'\n',NULL,8000,'2020-02-29',20200228101159);
INSERT INTO t1 VALUES(7,'\t','VIVO',3500,'2020-02-29',20200228101159);

CREATE TABLE t2(c3 timestamp);
INSERT INTO t2 VALUES('2020-01-13 21:29:31');

CREATE TABLE t3(d1 varchar(20));


############################## TEST CASES  ##############################
## 使用definer定义过程，正常

DELIMITER //;
CREATE DEFINER = 'wmj456'@'%' PROCEDURE p_test()
begin
	declare a varchar(200);
	declare i int default 1;
	SELECT ID FROM t1  WHERE consumer='书局' INTO a;
WHILE i <= 1 do
	INSERT INTO t1 VALUES(0,a,concat('无参存储过程a参数第',i,'次'),7000,'2020-08-21 10:11:59',20190821101159);
	set i := i + 1;
	END while;
END;
//
DELIMITER ;//

SELECT COUNT(*) FROM t1;
CALL p_test();
SELECT COUNT(*) FROM t1;

DELETE FROM t1 WHERE price LIKE '%存储%';
DROP PROCEDURE p_test;


############################## TEST CASES  ##############################
## 当前用户与定义用户不同，正常

