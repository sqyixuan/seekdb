############################## TEST CASES  ##############################
## 含有 in 参数过程，执行过程，正常

CREATE USER 'TEST_A1'@'%' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO 'TEST_A1'@'%' WITH GRANT OPTION;

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' PROCEDURE p_test(in samplename  varchar(200)) SQL SECURITY DEFINER
BEGIN
	declare a varchar(200);
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
	INSERT INTO t1 VALUES(0, a, concat('in存储过程a参数第', 1, '次'),7000,'2020-08-21 10:11:59',20190821101159);
END;
//
DELIMITER ;//

CALL p_test(500);
DROP PROCEDURE p_test;
SELECT COUNT(*) FROM t1;
delete from t1 where price like '%存储%';
DROP USER TEST_A1@'%';


############################## TEST CASES  ##############################
## 含有 out 参数过程，执行过程，正常

CREATE USER 'TEST_A1'@'%' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO 'TEST_A1'@'%' WITH GRANT OPTION;

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' PROCEDURE p_test(out wb  varchar(200)) SQL SECURITY DEFINER
BEGIN
	declare a varchar(200);
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = 0 into wb;
END;
//
DELIMITER ;//

CALL p_test(@wb);
DROP PROCEDURE p_test;
SELECT COUNT(*) FROM t1;
DROP USER TEST_A1@'%';


############################## TEST CASES  ##############################
## 含有 inout 参数过程，执行过程，正常

CREATE USER 'TEST_A1'@'%' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO 'TEST_A1'@'%' WITH GRANT OPTION;

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' PROCEDURE p_test( out wb varchar(200), inout wb1 varchar(200))
begin
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = 0 into wb;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = -1 into wb1;
END;
//
DELIMITER ;//

call p_test(@wb,@wb1);
SELECT COUNT(*) FROM t1;
DROP USER TEST_A1@'%';
DROP PROCEDURE p_test;


############################## TEST CASES  ##############################
## 修改存储过程 SQL SECURITY DEFINER 为 INVOKE，正常

--disable_warnings
DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'192.168.0.1' PROCEDURE p_test( out wb varchar(200), inout wb1 varchar(200)) SQL SECURITY DEFINER
begin
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = 0 into wb;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = -1 into wb1;
END;
//
DELIMITER ;//
--enable_warnings

ALTER PROCEDURE p_test SQL SECURITY INVOKER;
--error 0,1449
call p_test(@wb,@wb1);
SELECT COUNT(*) FROM t1;
DROP PROCEDURE p_test;


############################## TEST CASES  ##############################
## 创建definer=B过程，删除用户B，执行存储过程

CREATE USER 'TEST_A1'@'%' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO 'TEST_A1'@'%' WITH GRANT OPTION;

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' PROCEDURE p_test( out wb varchar(200), inout wb1 varchar(200)) SQL SECURITY DEFINER
begin
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = 0 into wb;
	SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = -1 into wb1;
END;
//
DELIMITER ;//

DROP USER TEST_A1@'%';
--ERROR 0,1449
call p_test(@wb,@wb1);
DROP PROCEDURE p_test;


