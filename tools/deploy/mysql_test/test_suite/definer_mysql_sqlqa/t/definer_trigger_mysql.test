--echo #Environmental cleaning
--disable_warnings
--error 0,1396
DROP USER wmj456@'%';
--error 0,1396
DROP USER TEST_A1@'%';
--error 0,1396
DROP USER TEST_A2@'%';
--error 0,1008
DROP DATABASE obwmjtest;
CREATE DATABASE obwmjtest;
--enable_warnings

CREATE USER wmj456 IDENTIFIED BY 'wmj456';
GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,wmj456,wmj456,obwmjtest,$OBMYSQL_PORT);
connection conn;

############### Initialize_Environment ###############

--error 0,1051
DROP TABLE t1;
--error 0,1051
DROP TABLE t2;
--error 0,1051
DROP TABLE t3;
--error 0,1305
DROP FUNCTION f_test;
--error 0,1360
DROP TRIGGER demo;



################## Test Environment ##################
CREATE TABLE t1 (
  id int NOT NULL,
  consumer char(20) DEFAULT NULL,
  price varchar(20) DEFAULT NULL,
  sal int DEFAULT NULL,
  datetime1 DATE,
  `datetime2` bigint
);
INSERT INTO t1 VALUES(1,'书局','7000',5000,'2020-09-22',20200923121200);
INSERT INTO t1 VALUES(2,'微山','3000',-4000,'2020-09-21',20200921101159);
INSERT INTO t1 VALUES(3,'深咖','5000',0,'2020-08-21',20190821101159);
INSERT INTO t1 VALUES(4,'流苏','0',NULL,'2020-02-29',20200228101159);
INSERT INTO t1 VALUES(5,'玻璃','3200',6000,'2020-02-29',20200228101159);
INSERT INTO t1 VALUES(6,'\n',NULL,8000,'2020-02-29',20200228101159);
INSERT INTO t1 VALUES(7,'\t','VIVO',3500,'2020-02-29',20200228101159);

CREATE TABLE t2(c3 timestamp);
INSERT INTO t2 VALUES('2020-01-13 21:29:31');

CREATE TABLE t3(d1 varchar(20));


############################## TEST CASES  ##############################
## Create 未指定 definer ，正常

DELIMITER //;
CREATE TRIGGER demo BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2022-01-13 21:29:31';
END;
//
DELIMITER ;//

TRUNCATE TABLE t2;
SELECT COUNT(*) FROM t2;
INSERT INTO t2 VALUES ('1990-03-23 21:29:31');
SELECT COUNT(*) FROM t2;
DROP TRIGGER demo;



############################## TEST CASES  ##############################
## Create 后指定 definer ，正常

DELIMITER //;
CREATE DEFINER = 'wmj456'@'%' TRIGGER demo BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2022-01-13 21:29:31';
END;
//
DELIMITER ;//

TRUNCATE TABLE t2;
SELECT COUNT(*) FROM t2;
INSERT INTO t2 VALUES ('1990-03-23 21:29:31');
SELECT * FROM t2;
DROP TRIGGER demo;


############################## TEST CASES  ##############################
## Create 后指定 definer 用户不存在,报错

--disable_warnings
DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' TRIGGER demo BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2022-01-13 21:29:31';
END;
//
DELIMITER ;//
--enable_warnings

TRUNCATE TABLE t2;
SELECT COUNT(*) FROM t2;
--error 0,1449
INSERT INTO t2 VALUES ('1990-03-23 21:29:31');
SELECT * FROM t2;
DROP TRIGGER demo;


############################## TEST CASES  ##############################
## Create 后指定 其他definer 用户，正常

CREATE USER TEST_A1 IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO TEST_A1 WITH GRANT OPTION;

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' TRIGGER demo BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2022-01-13 21:29:31';
END;
//
DELIMITER ;//

TRUNCATE TABLE t2;
SELECT COUNT(*) FROM t2;
INSERT INTO t2 VALUES ('1990-03-23 21:29:31');
SELECT * FROM t2;
DROP TRIGGER demo;
DROP USER TEST_A1;


############################## TEST CASES  ##############################
## Create 后指定 definer 空，正常

CREATE USER ' ' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO ' '@'%' WITH GRANT OPTION;

DELIMITER //;
CREATE DEFINER = ' '@'%' TRIGGER demo BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2022-01-13 21:29:31';
END;
//
DELIMITER ;//

TRUNCATE TABLE t2;
INSERT INTO t2 VALUES ('1990-03-23 21:29:31');
SELECT * FROM t2;
DROP TRIGGER demo;
DROP USER ' ';


############################## TEST CASES  ##############################
## Create 后指定 definer 空用户无权限，报错

CREATE USER ' ' IDENTIFIED BY 'testa1';

DELIMITER //;
CREATE DEFINER = ' '@'%' TRIGGER demo BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2022-01-13 21:29:31';
END;
//
DELIMITER ;//

TRUNCATE TABLE t2;
--error 1142
INSERT INTO t2 VALUES ('1990-03-23 21:29:31');
SELECT * FROM t2;
DROP TRIGGER demo;
DROP USER ' ';


############################## TEST CASES  ##############################
## Create 后指定 definer current_user

DELIMITER //;
CREATE DEFINER = current_user TRIGGER demo BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2022-01-13 21:29:31';
END;
//
DELIMITER ;//

TRUNCATE TABLE t2;
INSERT INTO t2 VALUES ('1990-03-23 21:29:31');
SELECT * FROM t2;
DROP TRIGGER demo;


############################## TEST CASES  ##############################
