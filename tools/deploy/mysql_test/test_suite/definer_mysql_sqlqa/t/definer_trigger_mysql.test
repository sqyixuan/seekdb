GRANT ALL ON *.* TO 'TEST_A1'@'192.222.11.11' WITH GRANT OPTION;

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'192.222.11.11' TRIGGER demo BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2022-01-13 21:29:31';
END;
//
DELIMITER ;//

TRUNCATE TABLE t2;
INSERT INTO t2 VALUES ('1990-03-23 21:29:31');
SELECT * FROM t2;
DROP TRIGGER demo;
DROP USER 'TEST_A1'@'192.222.11.11';



############################## TEST CASES  ##############################
## 创建update触发器，使用definer，正常

DELIMITER //;
CREATE DEFINER = 'wmj456'@'%' TRIGGER demo BEFORE UPDATE ON t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2022-01-13 21:29:31';
END;
//
DELIMITER ;//

TRUNCATE TABLE t2;
INSERT INTO t2 VALUES ('1990-03-23 21:29:31');
INSERT INTO t2 VALUES ('1991-03-23 21:29:31');
UPDATE t2 SET C3='2000-03-23 21:29:31' WHERE C3='1991-03-23 21:29:31';
SELECT * FROM t2;
DROP TRIGGER demo;


############################## TEST CASES  ##############################
## 创建update触发器，使用definer其他用户，正常

DELIMITER //;
CREATE USER TEST_A1 IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO TEST_A1 WITH GRANT OPTION;

CREATE DEFINER = 'TEST_A1'@'%' TRIGGER demo BEFORE UPDATE ON t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2022-01-13 21:29:31';
END;
//
DELIMITER ;//

TRUNCATE TABLE t2;
INSERT INTO t2 VALUES ('1990-03-23 21:29:31');
INSERT INTO t2 VALUES ('1991-03-23 21:29:31');
UPDATE t2 SET C3='2000-03-23 21:29:31' WHERE C3='1991-03-23 21:29:31';
SELECT * FROM t2;
DROP TRIGGER demo;
DROP USER TEST_A1;


############################## TEST CASES  ##############################
## 创建delete触发器，使用definer，正常

DELIMITER //;

CREATE DEFINER = 'wmj456'@'%' TRIGGER demo before delete ON t2 FOR EACH ROW
BEGIN
	INSERT INTO t3 VALUES(old.c3);
END;
//
DELIMITER ;//

TRUNCATE TABLE t2;
INSERT INTO t2 VALUES ('1990-03-23 21:29:31');
INSERT INTO t2 VALUES ('1991-03-23 21:29:31');
DELETE FROM t2 WHERE C3='1991-03-23 21:29:31';
SELECT * FROM t2;
SELECT * FROM t3;
TRUNCATE TABLE t3;
DROP TRIGGER demo;


############################## TEST CASES  ##############################
## 创建INSERT触发器，使用definer，正常

DELIMITER //;
CREATE DEFINER = 'wmj456'@'%' TRIGGER demo BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2022-01-13 21:29:31';
END;
//
DELIMITER ;//

TRUNCATE TABLE t2;
SELECT COUNT(*) FROM t2;
INSERT INTO t2 VALUES ('1990-03-23 21:29:31');
SELECT * FROM t2;
DROP TRIGGER demo;


############################## TEST CASES  ##############################
## 创建INSERT触发器，使用FOLLOWS

DELIMITER //;
CREATE DEFINER = 'wmj456'@'%' TRIGGER demo BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2022-01-13 21:29:31';
END;
//

CREATE DEFINER = 'TEST_A1'@'%' TRIGGER demo2 BEFORE INSERT ON t2 FOR EACH ROW FOLLOWS demo
BEGIN
	SET NEW.C3='2024-01-13 21:29:31';
END;
//
DELIMITER ;//

DROP TRIGGER demo;
DROP TRIGGER demo2;


############################## TEST CASES  ##############################
## 创建INSERT触发器，使用PRECEDES 

DELIMITER //;
CREATE DEFINER = 'wmj456'@'%' TRIGGER demo BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2022-01-13 21:29:31';
END;
//

--ERROR 0,1064
CREATE DEFINER = 'TEST_A1'@'%' TRIGGER demo2 BEFORE INSERT ON t2 FOR EACH ROW PRECEDES demo
BEGIN
	SET NEW.C3='2024-01-13 21:29:31';
END;
//
DELIMITER ;//

DROP TRIGGER demo;
DROP TRIGGER demo2;


############################## TEST CASES  ##############################
## 表锁可写定义definer

LOCK TABLES t2 WRITE ;

DELIMITER //;
--ERROR 0,1235
CREATE DEFINER = 'wmj456'@'%' TRIGGER demo2 BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2024-01-13 21:29:31';
END;
//
DELIMITER ;//
UNLOCK TABLES;
DROP TRIGGER demo2;


############################## TEST CASES  ##############################
## 移除触发器 INSERT 权限，报错

CREATE USER TEST_A1@'%' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO TEST_A1@'%' WITH GRANT OPTION;
REVOKE INSERT ON *.* FROM TEST_A1@'%';

DELIMITER //;
CREATE DEFINER = TEST_A1@'%' TRIGGER demo BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	INSERT INTO t3 VALUES(new.c3);
END;
//
DELIMITER ;//
TRUNCATE TABLE t2;
--ERROR 0,1142
INSERT INTO t2 VALUES ('1990-03-23 21:29:31');
SELECT * FROM t3;
DROP TRIGGER demo;
DROP USER TEST_A1@'%';


############################## TEST CASES  ##############################
## 移除触发器 UPDATE 权限，报错

CREATE USER TEST_A1@'%' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO TEST_A1@'%' WITH GRANT OPTION;
REVOKE UPDATE ON *.* FROM TEST_A1@'%';

DELIMITER //;
CREATE DEFINER = TEST_A1@'%' TRIGGER demo BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	INSERT INTO t3 VALUES('1991-03-23 21:29:31');
	update t3 set d1='2000-03-23 21:29:31';
END;
//
DELIMITER ;//
TRUNCATE TABLE t2;
--ERROR 0,1142
INSERT INTO t2 VALUES ('1990-03-23 21:29:31');
SELECT * FROM t3;
DROP TRIGGER demo;
DROP USER TEST_A1@'%';


############################## TEST CASES  ##############################
## 移除触发器 DELETE 权限，报错

CREATE USER TEST_A1@'%' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO TEST_A1@'%' WITH GRANT OPTION;
REVOKE delete ON *.* FROM TEST_A1@'%';

DELIMITER //;
CREATE DEFINER = TEST_A1@'%' TRIGGER demo BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	INSERT INTO t3 VALUES('1991-03-23 21:29:31');
	delete from t3 where d1='1991-03-23 21:29:31';
END;
//
DELIMITER ;//
TRUNCATE TABLE t2;
--ERROR 0,1142
INSERT INTO t2 VALUES ('1991-03-23 21:29:31');
SELECT * FROM t3;
DROP TRIGGER demo;
DROP USER TEST_A1@'%';




--echo # Clean up users
connection default;
--error 0,1008
DROP DATABASE obwmjtest;

--disable_warnings

--error 0,1396
DROP USER wmj456@'%' ;
--error 0,1396
DROP USER TEST_A1@'%';
--error 0,1396
DROP USER TEST_A2@'%';
