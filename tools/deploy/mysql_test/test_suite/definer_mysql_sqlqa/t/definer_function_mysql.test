############################## TEST CASES  ##############################
## definer=B，B用户有EXECUTE权限无SELECT权限，A用户执行函数，报错

CREATE USER TEST_A1 IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO TEST_A1 WITH GRANT OPTION;
REVOKE SELECT ON *.* FROM TEST_A1;

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' FUNCTION f_test()
returns varchar(200) SQL SECURITY DEFINER
BEGIN
	declare a varchar(200);
	SELECT ID FROM t1  WHERE consumer='书局' INTO a;
	return a;
END;
//
DELIMITER ;//

--ERROR 0,1142,1370
SELECT f_test();
DROP FUNCTION f_test;
DROP USER TEST_A1@'%';


############################## TEST CASES  ##############################
## definer=B，B用户有EXECUTE权限无INSERT权限，A用户执行函数，报错

CREATE USER TEST_A1@'%' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO TEST_A1@'%' WITH GRANT OPTION;
REVOKE INSERT ON *.* FROM TEST_A1@'%';

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' FUNCTION f_test()
returns varchar(200) SQL SECURITY DEFINER
BEGIN
	declare a varchar(200) default '饿了么';
	INSERT INTO t1 VALUES(0,a,'while插入a数据',7000,'2020-12-31 10:11:59',20190821101159);
	return a;
END;
//
DELIMITER ;//

--ERROR 0,1142,1370
SELECT f_test();
DROP FUNCTION f_test;
DROP USER TEST_A1@'%';


############################## TEST CASES  ##############################
## definer=B，B用户有EXECUTE权限无UPDATE权限，A用户执行函数，报错

CREATE USER TEST_A1@'%' IDENTIFIED BY 'testa1';
GRANT ALL ON *.* TO TEST_A1@'%' WITH GRANT OPTION;
REVOKE UPDATE ON *.* FROM TEST_A1@'%';

DELIMITER //;
CREATE DEFINER = 'TEST_A1'@'%' FUNCTION f_test()
returns varchar(200) SQL SECURITY DEFINER
BEGIN
	declare a varchar(200) default '饿了么';
	UPDATE t1 SET consumer = a WHERE consumer='玻璃';
	return a;
END;
//
DELIMITER ;//

--ERROR 0,1142,1370
SELECT f_test();
DROP FUNCTION f_test;
DROP USER TEST_A1@'%';


