SELECT /*+ parallel(6) */ count(distinct (c3 - c3 * c4)) from test1;

SELECT /*+ parallel(6) */ count(distinct (c2 * c4 * c4)) from test1;
SELECT /*+ parallel(6) */ avg(distinct (c2 + c4 * c2 / c2)) from test1;
SELECT /*+ parallel(6) */ sum(distinct (c4 - c2 * c3)) from test1;
SELECT /*+ parallel(6) */ sum(distinct (c2 + c2 - c4 / c2)) from test1;
SELECT /*+ parallel(6) */ sum(distinct (c2 + c3 + c3 - c3)) from test1;
SELECT /*+ parallel(6) */ avg(distinct (c4 - c3 + c2 - c4)) from test1;

SELECT /*+ parallel(6) */ count(distinct (c4 - c3 - c4)) from test1;
SELECT /*+ parallel(6) */ avg(distinct (c4 * c3 - c3 + c4)) from test1;
SELECT /*+ parallel(6) */ avg(distinct (c4 * c2 / c4)) from test1;
SELECT /*+ parallel(6) */ count(distinct (c3 + c2)) from test1;
SELECT /*+ parallel(6) */ avg(distinct (c3 + c3 / c4 * c3)) from test1;
SELECT /*+ parallel(6) */ avg(distinct (c3 - c3 * c3)) from test1;

SELECT /*+ parallel(6) */ sum(distinct (c4 / c3 * c2 * c2)) from test1;
SELECT /*+ parallel(6) */ avg(distinct (c2 + c3 - c4)) from test1;
SELECT /*+ parallel(6) */ avg(distinct (c2 / c4)) from test1;
SELECT /*+ parallel(6) */ count(distinct (c2 + c4 - c3)) from test1;
SELECT /*+ parallel(6) */ sum(distinct (c2 * c4)) from test1;
SELECT /*+ parallel(6) */ sum(distinct (c4 - c2 - c3 * c2)) from test1;

SELECT /*+ parallel(6) */ avg(distinct (c2 + c4 / c3 + c3)) from test1;
