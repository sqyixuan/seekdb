--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);


--echo   #Hash Group By-5    嵌套子查询
--echo   #Hash Group By-6    混合运算符




--echo   #Hash Group By-5    嵌套子查询
--error 0,1051
DROP TABLE test1;
CREATE TABLE test1(c1 bigint(100) PRIMARY key AUTO_INCREMENT not null,c2 bigint(100) not null,c3 FLOAT,c4 char(20),c5 year,
CONSTRAINT yy unique(c2,c3,c4,c5));
insert into test1(c2,c3,c4,c5) values(99999,0.5,'11','2001');
insert into test1(c2,c3,c4,c5) values(99999,0.1,'12','2002');
insert into test1(c2,c3,c4,c5) values(0.00001,0.2,'13','2003');
insert into test1(c2,c3,c4,c5) values(0.00001,0.3,'14','2004');
insert into test1(c2,c3,c4,c5) values(50,0.4,'15','2005');
insert into test1(c2,c3,c4,c5) values(-50,0.4,'15','2000');
insert into test1(c2,c3,c4,c5) values(-40.5,0.3,'14','2001');
insert into test1(c2,c3,c4,c5) values(40.5,0.2,'13','2002');
insert into test1(c2,c3,c4,c5) values(50,0.1,'12','2003');
insert into test1(c2,c3,c4,c5) values(-40,0.2,'11','2004');
insert into test1(c2,c3,c4,c5) values(25,0.4,'aa','2005');
select * from test1 order by 1;


--echo  #not in\in
select /*+ parallel(6) */
sum(distinct c2 not in(50,-40)),
min(distinct c2 in(99999,0.00001)),
avg(distinct c2 not in(50,-40)),
count(distinct c2 in(99999,0.00001)),
max(distinct c2 not in(50,-40))
from test1;


select /*+ parallel(6) */
sum(distinct c3 not in(0.1)),
min(distinct c3 in(0.4,0.2)),
avg(distinct c3 not in(0.4,0.2)),
count(distinct c3 in(0.1)),
max(distinct c3 not in(0.4,0.2))
from test1;

select /*+ parallel(6) */
sum(distinct c4 not in('aa')),
min(distinct c4 in('11','14','13')),
avg(distinct c4 not in('aa')),
count(distinct c4 in('11','14','13')),
max(distinct c4 not in('aa'))
from test1;


select /*+ parallel(6) */
sum(distinct c5 not in('2005')),
min(distinct c5 in('2003','2004')),
avg(distinct c5 not in('2001','2002')),
count(distinct c5 in('2005')),
max(distinct c5 not in('2003','2002'))
from test1;

select * from test1 order by 1;
select /*+ parallel(6) */ sum(distinct (c2) not in(50,-40)) from test1;
--error 0,1064
select /*+ parallel(6) */ sum(ATAN2(distinct (c2) not in(50,-40),distinct (c3) not in(0.1))) from test1;
select /*+ parallel(6) */ sum(distinct(ATAN2(c2 not in(50,-40),c3 not in(0.1)))) from test1;
select /*+ parallel(6) */ count(distinct(ATAN2(c2 not in(50,-40),c3 not in(0.1)))) from test1;
select /*+ parallel(6) */ max(distinct(ATAN2(c2 not in(50,-40),c3 not in(0.1)))) from test1;
select /*+ parallel(6) */ min(distinct(ATAN2(c2 not in(50,-40),c3 not in(0.1)))) from test1;
select /*+ parallel(6) */ avg(distinct(ATAN2(c2 not in(50,-40),c3 not in(0.1)))) from test1;


select /*+ parallel(6) */ ATAN2(max(distinct c2 not in(50,-40)),sum(distinct c3 not in(0.1))) from test1;
select /*+ parallel(6) */ ATAN2(sum(distinct c2 not in(50,-40)),avg(distinct c4 not in(13,15))) from test1;
select /*+ parallel(6) */ ATAN2(avg(distinct c2 not in(50,-40)),count(distinct c5 not in(2005))) from test1;
select /*+ parallel(6) */ ATAN2(count(distinct c2 not in(50,-40)),min(distinct c5 not in(2005))) from test1;
select /*+ parallel(6) */ ATAN2(max(distinct c2 not in(50,-40)),min(distinct c5 not in(2005))) from test1;


--echo   #exists、not exists
select /*+parallel(6) */ sum(distinct c2) from test1 where EXISTS(select c2 from test1);
select /*+parallel(6) */ sum(distinct(select c2 from test1 where EXISTS(select c2 from test1) order by c2 LIMIT 1)) from test1;
select /*+parallel(6) */ sum(distinct(select c2 from test1 where not EXISTS(select c3 from test1) order by c2 LIMIT 1)) from test1;
select /*+parallel(6) */ sum((select distinct(c2) from test1 where EXISTS(select distinct(c2) from test1) order by c2 LIMIT 1)) from test1;
select /*+parallel(6) */ (select sum(distinct(c2)) from test1 where EXISTS(select c2 from test1)order by c2 LIMIT 1) from test1;


--echo   #any\all\some\like
select /*+ parallel(6) */ sum(distinct c2) from test1 where c2 >any(select avg(distinct c3) from test1);
select /*+ parallel(6) */ sum(distinct c2) from test1 where c2 <any(select avg(distinct c3) from test1);
select /*+ parallel(6) */ sum(distinct c2),max(distinct c5) from test1 where c2 =any(select count(distinct c3) from test1);
select /*+ parallel(6) */ sum(distinct c2) from test1 where c2 >all(select avg(distinct c3) from test1);
select /*+ parallel(6) */ sum(distinct c2) from test1 where c2 <all(select avg(distinct c3) from test1);
select /*+ parallel(6) */ sum(distinct c2) from test1 where c2 =all(select avg(distinct c3) from test1);
select /*+ parallel(6) */ sum(distinct c2) from test1 where c2 >some(select avg(distinct c3) from test1);
select /*+ parallel(6) */ sum(distinct c2) from test1 where c2 <some(select avg(distinct c3) from test1);
select /*+ parallel(6) */ sum(distinct c2) from test1 where c2 =some(select avg(distinct c3) from test1);
select /*+ parallel(6) */ sum(distinct c4 like '%1%'),avg(distinct c2 like '%0%') from test1;
select /*+ parallel(6) */ sum(distinct c4 like '%1%'),avg(distinct c2 like '%a%') from test1;
select /*+ parallel(6) */ sum(distinct c4 like '%null%'),avg(distinct c2 like '%a%') from test1;
select * from (select /*+ parallel(6) */ sum(distinct c4 like '%null%'),avg(distinct c2 like '%a%') from test1) as test1;
select * from (select /*+ parallel(6) */ sum(distinct c2) from test1 where c2 >any(select avg(distinct c3) from test1)) as test1;
--error 0,1054
select sum(distinct c2) from (select /*+ parallel(6) */ sum(distinct c2) from test1 where c2 >any(select avg(distinct c3) from test1)) as test1;
--error 0,1064
select /*+ parallel(6) */ sum(distinct c2 as a) from test1 where c2 =some(select avg(distinct c3) from test1);
select /*+ parallel(6) */ sum(distinct (c2 + c5)) from test1 where c2 =some(select avg(distinct c3) from test1);
drop table test1;






--echo   #Hash Group By-6    混合运算符
--echo   #混合运算符=====>算术运算符
--error 0,1051
DROP TABLE test1;
CREATE TABLE test1(c1 bigint(100) PRIMARY key AUTO_INCREMENT not null,
c2 SMALLINT not null,c3 FLOAT not null,c4 TINYINT,
c5 char(20) not null,c6 TINYTEXT not null,c7 TEXT,
c8 DATE not null,c9 TIME not null,c10 YEAR,
CONSTRAINT yy unique(c2,c3,c4,c5,c8,c9,c10));
insert into test1(c2,c3,c4,c5,c6,c7,c8,c9,c10) values(-0.00001,0.00001,null,'aa','111','null','2022-08-22','07:00:01','2000');
insert into test1(c2,c3,c4,c5,c6,c7,c8,c9,c10) values(-50.1,0.00001,null,'ab','111','null','2023-03-22','00:01:01','2010');
insert into test1(c2,c3,c4,c5,c6,c7,c8,c9,c10) values(-50.9,10.11,null,'ac','111','null','2024-08-22','00:58:01','2020');
insert into test1(c2,c3,c4,c5,c6,c7,c8,c9,c10) values(50.1,0.00001,null,'cb','222','null','2025-01-22','00:00:01','2040');
insert into test1(c2,c3,c4,c5,c6,c7,c8,c9,c10) values(50.9,-12,null,'de','-111','null','2025-08-22','00:02:01','2000');
insert into test1(c2,c3,c4,c5,c6,c7,c8,c9,c10) values(0.001,10.11,null,'ee','333','null','2024-05-22','00:00:01','2030');
insert into test1(c2,c3,c4,c5,c6,c7,c8,c9,c10) values(1.001,0.00001,null,'dd','333','null','2023-06-22','04:00:01','2010');
insert into test1(c2,c3,c4,c5,c6,c7,c8,c9,c10) values(50,0.00001,null,'er','111','null','2022-08-22','00:00:01','2050');
insert into test1(c2,c3,c4,c5,c6,c7,c8,c9,c10) values(60,12,null,'rr','-111','null','2021-05-22','00:59:01','2010');
select * from test1 order by 1;

--echo   #同类型+-*/     数值类型
SELECT /*+ parallel(6) */ avg(distinct (c4 / c2)) from test1;
SELECT /*+ parallel(6) */ sum(distinct (c2 - c3)) from test1;
SELECT /*+ parallel(6) */ avg(distinct (c3 / c4 * c4)) from test1;
SELECT /*+ parallel(6) */ avg(distinct (c2 * c4)) from test1;
SELECT /*+ parallel(6) */ sum(distinct (c3 / c4 - c3 - c4)) from test1;
SELECT /*+ parallel(6) */ count(distinct (c4 * c4 / c3)) from test1;

SELECT /*+ parallel(6) */ sum(distinct (c3 - c4)) from test1;
SELECT /*+ parallel(6) */ count(distinct (c2 / c2 / c3)) from test1;
SELECT /*+ parallel(6) */ count(distinct (c4 + c4)) from test1;
SELECT /*+ parallel(6) */ count(distinct (c4 - c2 * c3)) from test1;
SELECT /*+ parallel(6) */ sum(distinct (c3 * c3 / c3)) from test1;
