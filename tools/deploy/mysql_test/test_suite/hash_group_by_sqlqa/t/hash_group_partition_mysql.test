--echo   #Hash Group By-10   分区表=====>range分区
--error 0,1051
drop table test1;
create table test1(c1 int AUTO_INCREMENT,c2 bigint not null,
c3 FLOAT not null,c4 char(20) not null,c5 year not null,PRIMARY key(c1,c2,c3,c4,c5))
partition by range (c2)(partition p0 values less than (100),partition p1 values less than(200));
