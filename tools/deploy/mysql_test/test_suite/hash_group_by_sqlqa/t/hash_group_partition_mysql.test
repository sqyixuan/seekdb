SELECT /*+ parallel(6) */ sin(min(distinct tan(c2))) * abs(count(distinct c5)) - cos(min(distinct c2)) from test1;
SELECT /*+ parallel(6) */ sin(sum(distinct tan(c4))) * abs(count(distinct c5)) * cos(count(distinct c5)) from test1;
SELECT /*+ parallel(6) */ sin(sum(distinct tan(c4))) / abs(sum(distinct c3)) * cos(count(distinct c2)) from test1;
SELECT /*+ parallel(6) */ sin(avg(distinct tan(c2))) - abs(count(distinct c5)) / cos(min(distinct c4)) from test1;
SELECT /*+ parallel(6) */ sin(min(distinct tan(c3))) + abs(avg(distinct c3)) / cos(max(distinct c2)) from test1;

SELECT /*+ parallel(6) */ sin(avg(distinct tan(c3))) / abs(avg(distinct c3)) - cos(min(distinct c5)) from test1;
SELECT /*+ parallel(6) */ sin(sum(distinct tan(c4))) / abs(sum(distinct c4)) + cos(avg(distinct c4)) from test1;
SELECT /*+ parallel(6) */ sin(max(distinct tan(c3))) * abs(count(distinct c5)) * cos(max(distinct c4)) from test1;
SELECT /*+ parallel(6) */ sin(sum(distinct tan(c3))) * abs(sum(distinct c4)) / cos(avg(distinct c3)) from test1;
#SELECT /*+ parallel(6) */ sin(avg(distinct tan(c5))) * abs(count(distinct c4)) / cos(avg(distinct c4)) from test1;
SELECT /*+ parallel(6) */ sin(max(distinct tan(c3))) - abs(sum(distinct c5)) * cos(count(distinct c2)) from test1;
SELECT /*+ parallel(6) */ sin(max(distinct tan(c3))) + abs(sum(distinct c5)) - cos(sum(distinct c2)) from test1;
SELECT /*+ parallel(6) */ sin(count(distinct tan(c3))) + abs(sum(distinct c5)) - cos(count(distinct c5)) from test1;
SELECT /*+ parallel(6) */ sin(avg(distinct tan(c4))) / abs(avg(distinct c4)) - cos(max(distinct c4)) from test1;
SELECT /*+ parallel(6) */ sin(count(distinct tan(c3))) - abs(sum(distinct c3)) / cos(max(distinct c3)) from test1;
drop table test1;










