select /*+ parallel(6) */ sum(distinct c2) from view_1 where c2 <some(select avg(distinct c3) from view_1);
select /*+ parallel(6) */ sum(distinct c2) from view_1 where c2 =some(select avg(distinct c3) from view_1);
select /*+ parallel(6) */ sum(distinct c4 like '%1%'),avg(distinct c2 like '%0%') from view_1;
select /*+ parallel(6) */ sum(distinct c4 like '%1%'),avg(distinct c2 like '%a%') from view_1;
select /*+ parallel(6) */ sum(distinct c4 like '%null%'),avg(distinct c2 like '%a%') from view_1;
select * from (select /*+ parallel(6) */ sum(distinct c4 like '%null%'),avg(distinct c2 like '%a%') from view_1) as view_1;
