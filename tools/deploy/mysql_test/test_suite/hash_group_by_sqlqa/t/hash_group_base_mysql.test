SELECT /*+ parallel(6) */ case when c4 then sum(distinct c5) else c2 end c4, case when c2 then min(distinct c4) else c4 end c3 from test1;
SELECT /*+ parallel(6) */ case when c5 then count(distinct c3) else c4 end c2, case when c5 then avg(distinct c5) else c4 end c4 from test1;
