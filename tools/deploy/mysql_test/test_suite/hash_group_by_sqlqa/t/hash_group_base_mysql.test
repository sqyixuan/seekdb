drop procedure procedure_1;
delimiter /;
create procedure procedure_1(i int,k int)
begin
	declare i int default 1;
	while i<k do
		insert into test1 values(i-90,i+0.50,i+1.5,i+9.6,i+25.5);
		set i=i+1;
	end while;
	commit;
end;
/
delimiter ;/
