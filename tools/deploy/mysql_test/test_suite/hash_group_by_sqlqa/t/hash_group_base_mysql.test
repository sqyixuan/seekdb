--echo   #Hash Group By-2   去重列=====>单列
--error 0,1051
DROP TABLE test1;
CREATE TABLE test1(c1 int,c2 bigint(50),c3 TINYINT(50),c4 FLOAT not null,primary key(c1,c2),CONSTRAINT yy unique(c3));

--error 0,1305
drop procedure procedure_1;
delimiter /;
create procedure procedure_1(i int,k int)
begin
	declare i int default 1;
	while i<k do
		insert into test1 values(i-500,i+0.88,i+1.4,i+9.6);
		set i=i+1;
	end while;
	commit;
end;
/
delimiter ;/
call procedure_1(1,101);
select * from test1 ORDER BY 1;


SELECT /*+ parallel(6) */ count(distinct c1),count(distinct c4) from test1;
SELECT /*+ parallel(6) */ max(distinct c3),max(distinct c3) from test1;
SELECT /*+ parallel(6) */ max(distinct c1),sum(distinct c1) from test1;
SELECT /*+ parallel(6) */ sum(distinct c3),sum(distinct c1) from test1;
SELECT /*+ parallel(6) */ sum(distinct c3),count(distinct c2) from test1;
SELECT /*+ parallel(6) */ max(distinct c2),min(distinct c2) from test1;
