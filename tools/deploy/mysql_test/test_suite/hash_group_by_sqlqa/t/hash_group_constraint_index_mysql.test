--echo  #Hash Group By-11-1	约束=====>primary key
--error 0,1051
DROP table test1;
create table test1(c1 int AUTO_INCREMENT,c2 bigint,c3 FLOAT,c4 char(10),c5 year,PRIMARY key(c1,c2,c3,c4,c5));
insert into test1(c2,c3,c4,c5) values(22,33,'44','1996');
insert into test1(c2,c3,c4,c5) values(-11,66,'55','1997');
insert into test1(c2,c3,c4,c5) values(44,99,'66','1998');
insert into test1(c2,c3,c4,c5) values(-44,00,'77','1999');
insert into test1(c2,c3,c4,c5) values(0,-33,'88','2000');
select * from test1 order by 1;


