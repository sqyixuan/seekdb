--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);



--echo   #Hash Group By-9    多表



--echo   #Hash Group By-9    多表
--error 0,1051
DROP table test1;
--error 0,1051
DROP table test2;

create table test1 (c1 int PRIMARY key AUTO_INCREMENT,c2 bigint not null,c3 FLOAT not null);
create table test2 (h1 int PRIMARY key AUTO_INCREMENT,h2 char(20) not null,h3 year not null);
insert into test1(c2,c3) values(50,-50.5);
insert into test1(c2,c3) values(0,30);
insert into test1(c2,c3) values(-20,-40);
insert into test2(h2,h3) values('asgdsga','2025');
insert into test2(h2,h3) values('f w w w','1996');
insert into test2(h2,h3) values('sfwwefwf','2020');
select * from test1 order by 1;
select * from test2 order by 1;


--echo   #left join=====>结合计算运算符
SELECT /*+ parallel(6) */ avg(distinct test2.h2) / test1.c2 from test1 left join test2 on test1.c1=test2.h1;
SELECT /*+ parallel(6) */ sum(distinct test2.h2) - test2.h2 from test1 left join test2 on test1.c1=test2.h1;
SELECT /*+ parallel(6) */ sum(distinct test1.c2) / test1.c3 from test1 left join test2 on test1.c1=test2.h1;
SELECT /*+ parallel(6) */ count(distinct test1.c3),min(distinct test2.h2),count(distinct test2.h2,test1.c3) from test1 left join test2 on test1.c1=test2.h1;
