drop table test1;
create table test1(c1 int AUTO_INCREMENT,c2 bigint not null,
c3 FLOAT not null,c4 char(20) not null,c5 year not null,PRIMARY key(c1,c2,c3,c4,c5))
partition by key(c2)(partition p0,partition p1);
insert into test1(c2,c3,c4,c5) values(1,0.5,'12','2001');
insert into test1(c2,c3,c4,c5) values(50,0.1,'assdgwqw','2002');
insert into test1(c2,c3,c4,c5) values(70,0.2,'???????','2003');
