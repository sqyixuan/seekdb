#Environmental cleaning
drop user hjw@'%';
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
#Hash Group By-1   并行hint
#Hash Group By-2   去重列
#Hash Group By-3   数据类型
#Hash Group By-4   结合case when
#Hash Group By-1   并行hint
#select /*+ parallel(3) */ c1, sum(distinct c2),count(distinct c3) from table_name;
#Hash Group By-2   去重列=====>单列
DROP TABLE test1;
CREATE TABLE test1(c1 int,c2 bigint(50),c3 TINYINT(50),c4 FLOAT not null,primary key(c1,c2),CONSTRAINT yy unique(c3));
drop procedure procedure_1;
create procedure procedure_1(i int,k int)
begin
declare i int default 1;
while i<k do
insert into test1 values(i-500,i+0.88,i+1.4,i+9.6);
set i=i+1;
end while;
commit;
end;
/
call procedure_1(1,101);
