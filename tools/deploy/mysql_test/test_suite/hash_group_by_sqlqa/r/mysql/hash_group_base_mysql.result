drop table test1;
CREATE TABLE test1(c1 int AUTO_INCREMENT ,c2 bigint(50),c3 TINYINT(50),c4 FLOAT not null,c5 char(20),
c6 date default '2022-08-16',c7 varchar(20),c8 YEAR default 2000,primary key(c1,c2,c4,c5,c6,c7,c8));
