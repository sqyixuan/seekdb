#Hash Group By-3   数据类型
#数据类型=====>数值类型
DROP TABLE test1;
CREATE TABLE test1(c1 bigint not null,c2 bit(20) not null,c3 double not null,c4 FLOAT not null,c5 decimal not null,
primary key(c1,c2,c3,c4,c5),CONSTRAINT yy unique(c1,c2,c3,c4,c5));
insert into test1 values(1,33,4,6,8);
drop procedure procedure_1;
create procedure procedure_1(i int,k int)
begin
declare i int default 1;
while i<k do
insert into test1 values(i-90,i+0.50,i+1.5,i+9.6,i+25.5);
set i=i+1;
end while;
commit;
end;
/
call procedure_1(1,1000);
