#Environmental cleaning
drop user hjw@'%';
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
#Hash Group By-9    多表
#Hash Group By-9    多表
DROP table test1;
DROP table test2;
create table test1 (c1 int PRIMARY key AUTO_INCREMENT,c2 bigint not null,c3 FLOAT not null);
create table test2 (h1 int PRIMARY key AUTO_INCREMENT,h2 char(20) not null,h3 year not null);
insert into test1(c2,c3) values(50,-50.5);
insert into test1(c2,c3) values(0,30);
insert into test1(c2,c3) values(-20,-40);
insert into test2(h2,h3) values('asgdsga','2025');
insert into test2(h2,h3) values('f w w w','1996');
insert into test2(h2,h3) values('sfwwefwf','2020');
select * from test1 order by 1;
c1	c2	c3
1	50	-50.5
2	0	30
3	-20	-40
select * from test2 order by 1;
h1	h2	h3
1	asgdsga	2025
2	f w w w	1996
3	sfwwefwf	2020
