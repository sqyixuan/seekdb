#log-9-4  select
drop table test1;
CREATE TABLE test1(f1 varchar(30),f2 varchar(30));
INSERT INTO test1 VALUES('20.1','30');
INSERT INTO test1 VALUES('20.1','40');
INSERT INTO test1 VALUES('0.1','30');
INSERT INTO test1 VALUES('0.1','40');
#9-4-1      select
SELECT log(f1,f2) FROM test1;
log(f1,f2)
1.1334604999062354
1.2293315209217535
-1.4771212547196626
-1.6020599913279625
#9-4-2      from
SELECT log(m+10,n+5),log(n+5,m+10) FROM (SELECT log(f1,f2) m,log(f2,f1) n FROM test1);
log(m+10,n+5)	log(n+5,m+10)
0.7352585372977971	1.3600658125986185
0.7277870397898952	1.3740283150531092
0.6832101257595342	1.4636785409002626
0.6936558275860951	1.441637135061598
#9-4-3      where
SELECT * FROM test1 WHERE log(f1,f2)>log(f2,f1) AND log(f1,f2) IN (log(20.1,40),log(0.1,30));
f1	f2
20.1	40
#9-4-4      group by having
SELECT * FROM test1 GROUP by f2;
f1	f2
20.1	30
20.1	40
SELECT * FROM test1 HAVING f2;
f1	f2
20.1	30
20.1	40
0.1	30
0.1	40
SELECT * FROM test1 GROUP BY f1,f2 HAVING log(round(f1,3),f2)*log(round(f2,3),f2)<>0;
f1	f2
20.1	30
20.1	40
0.1	30
0.1	40
#9-4-5      order by
SELECT f1,log(f2,f1) FROM test1 ORDER BY log(f1,f2) DESC;
f1	log(f2,f1)
20.1	0.8134502231344394
20.1	0.8822539471668613
0.1	-0.6769924925288454
0.1	-0.6241963505817848
#9-4-6      case when
SELECT sum(CASE WHEN log(f1,f2)>0 THEN 2 ELSE 1 END ) FROM test1;
sum(CASE WHEN log(f1,f2)>0 THEN 2 ELSE 1 END )
6
SELECT sum(log(CASE WHEN  log(f1,f2)>0 THEN 2 ELSE 3 END,10)/log(f2,f1)) FROM test1;
sum(log(CASE WHEN  log(f1,f2)>0 THEN 2 ELSE 3 END,10)/log(f2,f1))
1.3953591406424972
SELECT sum(log(CASE f2 WHEN '30' THEN log(f1,f2+11) WHEN '40' THEN log(f1+100,f2) ELSE 10 END,55)/log(f1,f2)) t1 FROM  test1 WHERE f1>1;
t1
4.091132050434389
SELECT sum(log(CASE log(f2,f1) WHEN log(30,0.1) THEN 2 ELSE 3 END,555)) FROM test1;
sum(log(CASE log(f2,f1) WHEN log(30,0.1) THEN 2 ELSE 3 END,555))
26.371661908046068
#9-4-7      distinct
SELECT DISTINCT log(f1,f2) FROM test1;
log(f1,f2)
1.1334604999062354
1.2293315209217535
-1.4771212547196626
-1.6020599913279625
DROP TABLE test1;
