#log-10-2  insert
drop table b;
drop view shitu;
CREATE TABLE b(f1 int(10),f2 int(10));
INSERT INTO b VALUES(20.1,10);
INSERT INTO b VALUES(20.1,40);
INSERT INTO b VALUES(20.1,30);
INSERT INTO b VALUES(20.1,40);
CREATE OR REPLACE VIEW shitu AS SELECT * FROM b;
DELETE FROM b WHERE 1=1;
INSERT INTO shitu VALUE(f1(log(2,88),7),f1(log(7,20),5)||'123');
INSERT INTO shitu(f1) VALUE(f1(log(2,30)*10-log(55,1),7));
INSERT INTO shitu(f1) SELECT f1 FROM shitu WHERE f1>1 GROUP BY f1 HAVING log(5,f1) IS NOT NULL;
SELECT * FROM shitu;
f1	f2
drop view shitu;
drop table b;
#log-10-3   update
drop table b;
drop view shitu;
CREATE TABLE b(f1 int(10),f2 int(10));
INSERT INTO b VALUES(20.1,10);
INSERT INTO b VALUES(20.1,40);
INSERT INTO b VALUES(20.1,30);
INSERT INTO b VALUES(20.1,40);
CREATE OR REPLACE VIEW shitu AS SELECT * FROM b;
select * from shitu;
f1	f2
20	10
20	40
20	30
20	40
UPDATE shitu set f1=20.999 where f1=20.1;
select * from shitu;
f1	f2
20	10
20	40
20	30
20	40
UPDATE shitu SET f1 = log(6,20),f2=log(1.5,f2)/10 WHERE f1<log(10,1000);
select * from shitu;
f1	f2
20	10
20	40
20	30
20	40
UPDATE shitu SET f1 = log((SELECT sum(log(f2,10)) FROM shitu WHERE f1>0),3);
select * from shitu;
f1	f2
1	10
1	40
1	30
1	40
UPDATE shitu SET f1 = log((SELECT f2 FROM shitu WHERE f1>0 GROUP BY f2 HAVING log(f2,100) IS NOT NULL),3);
UPDATE shitu SET f1 = log((SELECT * FROM (SELECT log(f2,100) FROM shitu WHERE f2 BETWEEN log(0.1,1) AND log(3,1e20) ORDER BY log(f1,100) DESC)),3);
drop view shitu;
drop table b;
