#log-9   sql静态 单列/多列的查询
#log-9-1  insert  
#log-9-1-1  value
drop table a;
create table a(id int(2),name varchar(20));
insert into a (id,name)value (1,"zhangsan");
insert into a (id,name)value (2,"lisi");
select * from a;
id	name
1	zhangsan
2	lisi
insert into a (id,name)values (3,"log");
SELECT (SELECT log(6))from a;
(SELECT log(6))
1.791759469228055
1.791759469228055
1.791759469228055
select * from a;
id	name
1	zhangsan
2	lisi
3	log
insert into a (id,name)value (SELECT log(6),"xiaobai");
insert into a (id,name)value (SELECT log(6)),select log("xiaocai");
insert into a (id,name)value (SELECT log(6,'8'),select log('jiugui'));
insert into a (id)value (SELECT log2(7,*));
insert into a (id,name)value (SELECT log2('7',*),select log2(4,'*'));
insert into a (id,name)value (SELECT log2(^,*));
insert into a (id)value (SELECT log(a));
insert into a (id,name)value (SELECT log(a),select log('b'));
drop table a;
#9-1-2   insert into
drop table a;
create table a(id int(2),name varchar(20));
insert into a (id,name)value (1,"zhangsan");
insert into a (id,name)value (2,"lisi");
DELETE FROM a WHERE 1=1;
INSERT INTO a VALUE(0.6931471,1.94591123);
INSERT INTO a(id) VALUE(6.9314718);
INSERT INTO a(id) SELECT id FROM a WHERE id<>1 GROUP BY id,name HAVING log(id,name) IS NOT NULL;
SELECT * FROM a;
id	name
1	1.94591123
7	NULL
drop table a;
#log-9-2 update
drop table test1;
create table test1(f1 int(10),f2 int(10));
DELETE FROM test1 WHERE 1=1;
INSERT INTO test1 VALUE('20.1','30');
UPDATE test1 SET f1 = log(5,55) WHERE f1>log(10,111);
SELECT * FROM test1;
f1	f2
2	30
UPDATE test1 SET f1 = log(6,425d),f2=log(f2,5f)/10 WHERE f1>log(10,99);
SELECT * FROM test1;
f1	f2
2	30
DELETE FROM test1 WHERE 1=1;
INSERT INTO test1 VALUES('20.1','30');
INSERT INTO test1 VALUES('20.2',NULL);
INSERT INTO test1 VALUES(5.5,99);
UPDATE test1 SET f1 = '5' WHERE f1=55;
SELECT * FROM test1;
f1	f2
20	30
20	NULL
6	99
drop table test1;
