--error 0,1305
DROP FUNCTION test_func;
drop procedure if exists test;
delimiter //;
create procedure test()
begin
    declare i int;
    set i = LOG(10);
    repeat
        insert into test values (i);
        set i = i + 1;
    until i > 10 end repeat;
    select * from test;
end
