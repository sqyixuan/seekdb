--echo #log-13-2-1-3     LOOP循环
--error 0,1051
DROP TABLE test1;
--error 0,1051
DROP TABLE test2;
CREATE TABLE test1(f1 decimal(5,1), f2 decimal(5,1));
INSERT INTO test1 VALUES(50,100);
INSERT INTO test1 VALUES(2.7,2);
INSERT INTO test1 VALUES(exp(1),2.8);
INSERT INTO test1(f1) VALUES(10.1);
INSERT INTO test1(f2) VALUES(10.1);
CREATE TABLE test2(f1 decimal(5,1),f2 decimal(5,1));
--error 0,1305
DROP FUNCTION test_func;
delimiter //;
CREATE FUNCTION test_func() RETURNS int
BEGIN
        DECLARE v_in int DEFAULT 2;
        loop1:LOOP
                IF v_in<0 THEN
                        UPDATE test1 SET f2=11 WHERE log(f2)<2 AND f1 IS NOT NULL;
                        LEAVE loop1;
                END IF;
                SET v_in = v_in-2;
        END LOOP;
        RETURN 5;
END;
//
delimiter ;//
SELECT  test_func();
SELECT * FROM test1;
drop FUNCTION test_func;

--echo #log-13-2-2       if条件语句
DELETE FROM test2 WHERE 1=1;
--error 0,1305
DROP FUNCTION test_func;
delimiter //;
CREATE FUNCTION test_func() RETURNS int
BEGIN
        DECLARE i int;
        IF log(i)<1 THEN
                INSERT INTO test2 VALUES(1,2);
        END IF;
        RETURN 5;
END;
//
delimiter ;//
SELECT  test_func();
SELECT * FROM test2;

--echo #log-13-2-3       游标
DELETE FROM test1 WHERE 1=1;
DELETE FROM test2 WHERE 1=1;
INSERT INTO test1 VALUE(50,100);
INSERT INTO test1 VALUE(2.7,2);
INSERT INTO test1 VALUE(exp(1),2.8);
INSERT INTO test1(f1) VALUE(10.1);
INSERT INTO test1(f2) VALUE(10.1);
--error 0,1305
DROP FUNCTION test_func;
delimiter //;
CREATE FUNCTION test_func() RETURNS int
BEGIN
        DECLARE out_1 decimal(5,1);
	DECLARE out_2 decimal(5,1);
        DECLARE done int DEFAULT 0;
        DECLARE result_cursor CURSOR FOR SELECT f1 a,(CASE WHEN log(f2)>10 THEN 1 WHEN log(f2)>30 THEN 2 ELSE 3 END) b FROM test1;
        DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
        OPEN result_cursor;
        FETCH result_cursor INTO out_1,out_2;
        WHILE done<>1 DO
                INSERT INTO test2 VALUES(out_1,out_2);
                FETCH result_cursor INTO out_1,out_2;
        END WHILE;
        CLOSE result_cursor;
        RETURN 5;
END;
//
delimiter ;//
SELECT  test_func();
SELECT * FROM test1;
SELECT * FROM test2;
drop table test1;
drop table test2;
drop FUNCTION test_func;


