--echo #log-13-1-1     循环语句
--echo #log-13-1-1-1     while循环
--error 0,1051
DROP TABLE test1;
create table test1(id int(5) ,name varchar(20));
select * from test1;
drop procedure if exists test_process;
delimiter //;
create procedure test_process()
begin
	declare i int default 1;
	while i<log(999)
	do
		insert into test1 values(i,concat('hangzhou',i));
		set i=i+1;
	end while;
	commit;
end //
delimiter ;//
select * from test1;
call test_process();
select * from test1;
drop PROCEDURE test_process;
drop table test1;

--echo #log-13-1-1-2     repeat循环
--error 0,1051
drop table test;
create table test(id int(5));
--error 0,1051
drop procedure if exists test;
delimiter //;
create procedure test()
begin
    declare i int;
    set i = log(1);
    repeat
        insert into test values (i);
        set i = i + 1;
    until i > 10 end repeat;
    select * from test;
end
//
delimiter ;//
call test();
SELECT * from test;
drop PROCEDURE test;
drop tables test;

--echo #log-13-1-1-2     loop循环
--error 0,1051
DROP TABLE test3;
create table test3(id int(5));
drop procedure if exists test3;
delimiter //;
create procedure test3()
begin
    declare i int;
    set i = log(200);
    lp : loop
        insert into test3 values (i);
        set i = i + 1;
        if i > 10 then
            leave lp;
        end if; 
    end loop;
    select * from test3;
end
//
delimiter ;//
select * from test3;
call test3(); 
select * from test3;
drop PROCEDURE test3;
drop tables test3;



--echo #log-13-1-2     if条件语句
--error 0,1051
DROP TABLE test4;
create table test4(id int(10),fenshu int(10));
insert into test4 value (5,6);
insert into test4 value (7,2);
select * from test4;
--error 0,1305
DROP FUNCTION test4;
delimiter //;
CREATE FUNCTION test4() RETURNS int
BEGIN
        DECLARE i int;
        IF log(i<1) THEN
                INSERT INTO test4 VALUES(1,2);
        END IF;
        RETURN 5;
END;
//
delimiter ;//
#SELECT test4();
SELECT * FROM test4;
drop FUNCTION test4;
drop tables test4;

--echo #log-13-1-3     游标
--error 0,1051
DROP TABLE test5;
CREATE TABLE test5(f1 decimal(5,1),f2 decimal(5,1));
INSERT INTO test5 VALUES('20.1','10');
INSERT INTO test5 VALUES('20.1','30');
INSERT INTO test5 VALUES('20.1','40');
INSERT INTO test5 VALUES(NULL,NULL);
CREATE TABLE test6(f1 decimal(5,1),f2 decimal(5,1));
--error 0,1305
DROP PROCEDURE test5_pro;
delimiter //;
create procedure test5_pro()
begin
	DECLARE v1 decimal(5,1);
	DECLARE v2 decimal(5,1);
	DECLARE done INT DEFAULT 0;
	DECLARE youbiao CURSOR FOR SELECT avg(f2),f1 from test5 GROUP by f1;
	DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
	OPEN youbiao;
	FETCH youbiao INTO v1,v2;
	WHILE done<>1 DO
		INSERT INTO test5 VALUES(log(35),log(99));
		FETCH youbiao INTO v1,v2;
	END WHILE;
	CLOSE youbiao;
END;
//
delimiter ;//
SELECT* from test5;
CALL test5_pro();
SELECT * FROM test5;
SELECT * FROM test6;
drop PROCEDURE test5_pro;
drop tables test5;
drop tables test6;


--echo #log-13-2  函数
--echo #log-13-2-1  	 循环函数
--echo #log-13-2-2       if条件语句
--echo #log-13-2-3       游标
--echo #log-13-2-1-1  	 while函数
--error 0,1051
DROP TABLE test1;
--error 0,1051
DROP TABLE test2;
CREATE TABLE test1(f1 decimal(5,1), f2 decimal(5,1));
INSERT INTO test1 VALUE(50,100);
INSERT INTO test1 VALUE(2.7,2);
INSERT INTO test1 VALUE(log(1),2.8);
INSERT INTO test1(f1) VALUE(10.1);
INSERT INTO test1(f2) VALUE(10.1);
CREATE TABLE test2(f1 decimal(5,1),f2 decimal(5,1));
--error 0,1305
drop FUNCTION test_func;
delimiter //;
CREATE FUNCTION test_func() RETURNS int
begin
	DECLARE v1 decimal(5,1);
	DECLARE v2 decimal(5,1);
	DECLARE done INT DEFAULT 0;
	DECLARE result_cursor CURSOR FOR SELECT f1,f2 FROM test1;
	DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
	OPEN result_cursor;
      FETCH result_cursor INTO v1,v2;
      WHILE done<>1 DO
		IF v1>10 THEN
			INSERT INTO test2 SELECT * FROM test1 WHERE log(f2 is null);
		ELSEIF v1<10 THEN
			INSERT INTO test2(f2) SELECT f1 FROM test1 WHERE log(f2 IS NULL) GROUP BY f1 HAVING log(f1<3);
		ELSE
			INSERT INTO test2 VALUES(v1||'1234567890',v2);
		END IF;
		FETCH result_cursor INTO v1,v2;
        END WHILE;
        CLOSE result_cursor;
        RETURN 5;
END;
//
delimiter ;//
SELECT * FROM test1;
SELECT * FROM test2;
DELETE FROM test2 WHERE 1=1;
--error 0,1305
DROP FUNCTION test_func;
delimiter //;
CREATE FUNCTION test_func() RETURNS int
BEGIN
        DECLARE v1 decimal(5,1) DEFAULT 20;
        WHILE log(v1>30) DO
                INSERT INTO test2 VALUES(1,2);
                SET v1=v1+5;
        END WHILE;
        RETURN 5;
END;
//
delimiter ;//
SELECT  test_func();
SELECT * FROM test2;
drop FUNCTION test_func;
drop table test1;
drop table test2;


