#owner:dingjincheng.djc
#owner group:sql2
#description:log
--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);



--echo  #参数个数要求
--echo  #log-1 单个参数类型
--echo  #log-2 两个参数类型
--echo  #log-3 以2为底的单个参数类型
--echo  #log-4 以10为底的单个参数类型
--echo  #log-5 单个参数/单个参数类型

--echo  #参数个数要求
SELECT log('1234',1.55);
SELECT log('125');
--error 0,1064
SELECT log((10,3),123,12);
--error 0,1064
SELECT log(125,12,18);


--echo  #log-1 单个参数类型
SELECT log(0);
SELECT log('0');
SELECT log(+6);
SELECT log(6);
SELECT log('6');
SELECT log(-8);
SELECT log(-0.0088);
SELECT log('-0.0088');
SELECT log(0.55);
SELECT log(+0.55);
SELECT log('+0.55');
SELECT log(0.55565465646);
--error 0,1064
SELECT log();

--echo  #log-2 两个参数类型 
SELECT log(6,0);
SELECT log('6',0);
SELECT log(6,'0');
SELECT log('6','0');
SELECT log(0,0);
SELECT log(6,6);
SELECT log('6','6');
SELECT log('6',6);
SELECT log(6,'6');
SELECT log(+6,+0);
SELECT log(6,-8);
SELECT log(-6,-8);
SELECT log('-6','-8');
SELECT log('-6',-8);
SELECT log(-6,'-8');
SELECT log(-6,8);
SELECT log(6,0.55);
SELECT log(0,0.55);
SELECT log(0.25,0.55);
SELECT log(-0.25,0.55);
SELECT log('-0.2',0.5);
SELECT log(-0.2,'0.5');
SELECT log('-0.2','0.5');
SELECT log(-0.25,+0.55);
SELECT log(-0.25,"+0.55");

--echo  ##log-5 单个参数/单个参数类型
SELECT log(6)/log(0);
SELECT log(6)/log(6);
SELECT log(0)/log(0);
SELECT log(6)/log(6);
SELECT log(6)/log(-8);
SELECT log(-6)/log(-8);
SELECT log(+6)/log(-8);
SELECT log(6)/log(0.55);
SELECT log(0.6)/log(0.55);
SELECT log(+0.6)/log(-0.55);
SELECT log(-0.6)/log(+0.55);

--echo  ##log-3  以2为底的单个参数类型
SELECT log2(0);
SELECT log2(12);
SELECT log2(99);
SELECT log2(6);
SELECT log2(+6);
SELECT log2(99);
SELECT log2(-8);
SELECT log2(-6);
SELECT log2(-0.1);
SELECT log2(+0.1);
SELECT log2(0.55);

--echo  ##log-4  以10为底的单个参数类型
SELECT log10(0);
SELECT log10(12);
SELECT log10(99);
SELECT log10(100);
SELECT log10(-1);
SELECT log10(-100);
SELECT log10(-50);
SELECT log10(0.55);
SELECT log10(-0.55);
SELECT log10(0.0007);

--echo  #虚数参数类型
SELECT log('i');   
SELECT log(6,'i');   
SELECT log(6)/log('i');
SELECT log2('i');
SELECT log10('i');


--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user hjw@'%' ;
--enable_warnings
