--echo  #log-9   sql静态 单列/多列的查询
--echo  #log-9-1  insert  
--echo  #log-9-1-1  value
--error 0,1051
drop table a;
create table a(id int(2),name varchar(20));
insert into a (id,name)value (1,"zhangsan");
insert into a (id,name)value (2,"lisi");
select * from a; 
insert into a (id,name)values (3,"log");
SELECT (SELECT log(6))from a;
select * from a;
--error 0,1064
insert into a (id,name)value (SELECT log(6),"xiaobai");
--error 0,1064
insert into a (id,name)value (SELECT log(6)),select log("xiaocai");
--error 0,1064
insert into a (id,name)value (SELECT log(6,'8'),select log('jiugui'));
--error 0,1064
insert into a (id)value (SELECT log2(7,*));
--error 0,1064
insert into a (id,name)value (SELECT log2('7',*),select log2(4,'*'));
--error 0,1064
insert into a (id,name)value (SELECT log2(^,*));
--error 0,1064
insert into a (id)value (SELECT log(a));
--error 0,1064
insert into a (id,name)value (SELECT log(a),select log('b'));
drop table a;

--echo #9-1-2   insert into
--error 0,1051
drop table a;
create table a(id int(2),name varchar(20));
insert into a (id,name)value (1,"zhangsan");
insert into a (id,name)value (2,"lisi");
DELETE FROM a WHERE 1=1;
INSERT INTO a VALUE(0.6931471,1.94591123);
INSERT INTO a(id) VALUE(6.9314718);
INSERT INTO a(id) SELECT id FROM a WHERE id<>1 GROUP BY id,name HAVING log(id,name) IS NOT NULL;
SELECT * FROM a;
drop table a;

--echo  #log-9-2 update
--error 0,1051
drop table test1;
create table test1(f1 int(10),f2 int(10));
DELETE FROM test1 WHERE 1=1;
INSERT INTO test1 VALUE('20.1','30');
UPDATE test1 SET f1 = log(5,55) WHERE f1>log(10,111);
SELECT * FROM test1;
--error 0,1054
UPDATE test1 SET f1 = log(6,425d),f2=log(f2,5f)/10 WHERE f1>log(10,99);
SELECT * FROM test1;
DELETE FROM test1 WHERE 1=1;
INSERT INTO test1 VALUES('20.1','30');
INSERT INTO test1 VALUES('20.2',NULL);
INSERT INTO test1 VALUES(5.5,99);
UPDATE test1 SET f1 = '5' WHERE f1=55;
SELECT * FROM test1;
drop table test1;

--echo  #log-9-3
--error 0,1051
drop table test1;
create table test1(f1 int(10),f2 int(10));
DELETE FROM test1 WHERE 1=1;
INSERT INTO test1 VALUES('20.1','30');
DELETE FROM test1 WHERE log(f1,f2)<>1;
SELECT * FROM test1;
INSERT INTO test1 VALUES('20.1','30');
DELETE FROM test1 WHERE f1=20.1>0;
SELECT * FROM test1;
INSERT INTO test1 VALUES('20.1','30');
SELECT * FROM test1;
DELETE FROM test1 WHERE f1=20.1 >= 0;
INSERT INTO test1 VALUES('20.1','30');
DELETE FROM test1 WHERE f2=30<0;
SELECT * FROM test1;
INSERT INTO test1 VALUES('20.1','30');
DELETE FROM test1 WHERE f2=30 <= 0;
SELECT * FROM test1;
INSERT INTO test1 VALUES('20.1','30');
DELETE FROM test1 WHERE f1=30 = 30;
SELECT * FROM test1;
INSERT INTO test1 VALUES('20.1','30');
DELETE FROM test1 WHERE f1=30 != 30;
SELECT * FROM test1;
DROP TABLE test1;

--echo  #log-9-4  select
--error 0,1051
drop table test1;
CREATE TABLE test1(f1 varchar(30),f2 varchar(30));
INSERT INTO test1 VALUES('20.1','30');
INSERT INTO test1 VALUES('20.1','40');
INSERT INTO test1 VALUES('0.1','30');
INSERT INTO test1 VALUES('0.1','40');
--echo #9-4-1      select
SELECT log(f1,f2) FROM test1;
--echo #9-4-2      from
SELECT log(m+10,n+5),log(n+5,m+10) FROM (SELECT log(f1,f2) m,log(f2,f1) n FROM test1);
--echo #9-4-3      where
SELECT * FROM test1 WHERE log(f1,f2)>log(f2,f1) AND log(f1,f2) IN (log(20.1,40),log(0.1,30));
--echo #9-4-4      group by having
SELECT * FROM test1 GROUP by f2;
SELECT * FROM test1 HAVING f2;
SELECT * FROM test1 GROUP BY f1,f2 HAVING log(round(f1,3),f2)*log(round(f2,3),f2)<>0;
--echo #9-4-5      order by
SELECT f1,log(f2,f1) FROM test1 ORDER BY log(f1,f2) DESC;
--echo #9-4-6      case when
SELECT sum(CASE WHEN log(f1,f2)>0 THEN 2 ELSE 1 END ) FROM test1;
SELECT sum(log(CASE WHEN  log(f1,f2)>0 THEN 2 ELSE 3 END,10)/log(f2,f1)) FROM test1;
SELECT sum(log(CASE f2 WHEN '30' THEN log(f1,f2+11) WHEN '40' THEN log(f1+100,f2) ELSE 10 END,55)/log(f1,f2)) t1 FROM  test1 WHERE f1>1;
SELECT sum(log(CASE log(f2,f1) WHEN log(30,0.1) THEN 2 ELSE 3 END,555)) FROM test1;
--echo #9-4-7      distinct
SELECT DISTINCT log(f1,f2) FROM test1;
DROP TABLE test1;



--echo  #log-10  视图的增删改查
--error 0,1051
drop table b;
--error 0,1051
drop view shitu;
CREATE TABLE b(f1 int(10),f2 int(10));
INSERT INTO b VALUES(20.1,10);
INSERT INTO b VALUES(20.1,40);
INSERT INTO b VALUES(20.1,30);
INSERT INTO b VALUES(20.1,40);
CREATE OR REPLACE VIEW shitu AS SELECT * FROM b;
--echo #log-10-1  select
SELECT log(f1,33),log(f2,33) FROM shitu;
SELECT * FROM shitu GROUP BY f1,f2 HAVING log(3333333333333333333333333333333333333,round(f1,3))*log(3,round(f2,3))<>0;
SELECT f1,log(f2,50) FROM shitu ORDER BY log(f2,22222222222222222222222222222222222222222222222222) DESC;
SELECT sum(CASE WHEN log(5,f1)>0 THEN 2 ELSE 1 END ) FROM shitu;
SELECT sum(log((CASE WHEN  log(3,f1)>0 THEN 2 ELSE 1 END),50)/log(f2,60)) FROM shitu;
SELECT sum(log(2.8,(CASE f2 WHEN 10 THEN log(f1,20) WHEN 30 THEN log(f1+100,30) ELSE 10 END))/log(f1,55)) t1 FROM  shitu;
--error 0,1146
SELECT sum(log(9,(CASE log(f2,20) WHEN log(f2,20) THEN 1 ELSE 2 END))) FROM shitut;
SELECT DISTINCT log(f1,100) FROM shitu;
--error 0,1064
SELECT log(10,f1) FROM shitu WHERE log(2.5,f1)>log(2.5,f2) AND log(5.5,f1)=SOME(log(5.5,f1),log(5.5,f2)) GROUP BY log(10,f1) HAVING log(10,f1)>0;
--error 0,1064
SELECT b(log(3,f1)),shitu.* FROM shitu WHERE table(log(3,f1*f2),5)!=log(3,f1+f2) GROUP BY f1,f2 HAVING log(3,f1)>0;
--error 0,1064
--sorted_result
WITH a AS (SELECT log(f2,100) m FROM shitu), b AS (SELECT log(f2,100) n,log(f2,20)*12 FROM shitu) SELECT a.*,b.* FROM a INNER JOIN b ON a.m=b.n;

