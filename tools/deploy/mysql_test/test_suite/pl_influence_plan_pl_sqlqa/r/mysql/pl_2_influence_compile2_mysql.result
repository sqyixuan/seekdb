#### 19、 parallel_degree_limit （影响plan计划，不影响pl缓存，不影响pl编译结果）
drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 10;
insert /*+parallel(8) enable_parallel_dml*/ into t1 
(with recursive cte as ( select 1 as c1 union all select c1+1 from cte where c1 < 1000)
 select c1 % 2, c1, c1, c1 from cte);
insert /*+parallel(8) enable_parallel_dml*/ into t1 select * from t1;
select count(1) from t1;
+----------+
| count(1) |
+----------+
|     2000 |
+----------+

drop PROCEDURE my_pro01;

create procedure my_pro01()
begin
  explain basic select * from t1;
  explain basic select /*+parallel(auto)*/* from t1;
end;
$

alter system flush pl cache global;
alter system flush plan cache global;

set parallel_min_scan_time_threshold = 10;
set @@session.parallel_degree_limit =  256;
select @@session.parallel_degree_limit from dual;
+---------------------------------+
| @@session.parallel_degree_limit |
+---------------------------------+
|                             256 |
+---------------------------------+

call my_pro01();
+---------------------------------------------------------------------------+
| Query Plan                                                                |
+---------------------------------------------------------------------------+
+---------------------------------------------------------------------------+
| Query Plan                                                                |
+---------------------------------------------------------------------------+
| =======================================                                   |
| |ID|OPERATOR                 |NAME    |                                   |
| ---------------------------------------                                   |
| |0 |PX COORDINATOR           |        |                                   |
| |1 |└─EXCHANGE OUT DISTR     |:EX10000|                                   |
| |2 |  └─PX PARTITION ITERATOR|        |                                   |
| |3 |    └─TABLE FULL SCAN    |t1      |                                   |
| =======================================                                   |
| Outputs & filters:                                                        |
| -------------------------------------                                     |
|   0 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256 |
|   1 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256 |
|       dop=1                                                               |
|   2 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256 |
|       force partition granule                                             |
|   3 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256 |
