#### 24、 cardinality_estimation_model （影响plan计划，不影响pl缓存，不影响pl编译结果）

drop table if exists t1,t2;
create table t1(pk int, c1 int, c2 decimal(12, 5), c3 int, c4 int, c5 int);
create table t2(pk int, c1 int, c2 decimal(12, 5), c3 int, c4 int, c5 int);

insert into t1 
select v1.id, v1.num, v2.num / 100.0, v1.id % 100, v1.id % 10, 0
from 
(select row_number() over () as id, num from (select row_number() over () % 10000 as num from table(generator(20000)) order by random(1))) v1,
(select row_number() over () as id, num from (select row_number() over () % 1000 as num from table(generator(20000)) order by random(2))) v2
where v1.id = v2.id;

insert into t2
select v1.id, v1.num, v2.num / 100.0, v1.id % 100, v1.id % 10, 0
from 
(select row_number() over () as id, num from (select row_number() over () % 2000 as num from table(generator(20000)) order by random(3))) v1,
(select row_number() over () as id, num from (select row_number() over () % 1000 as num from table(generator(20000)) order by random(4))) v2
where v1.id = v2.id;

drop PROCEDURE my_pro01;/
CREATE PROCEDURE my_pro01()
BEGIN
  select count(1) from t1 where c3 = 1 and c4 = 1 and c1 < 5000;
  select count(1) from t1 where c1 < 5000 or c2 < 5;
  select count(1) from t1 where (c3, 1) != (1, c4);
END ;
/

