#### 21、 runtime_filter_type （影响plan计划，不影响pl缓存，不影响pl编译结果）
drop table if exists t1,t2;
create table t1(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 10;
create table t2(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 10;
insert /*+parallel(8) enable_parallel_dml*/ into t1 
(with recursive cte as ( select 1 as c1 union all select c1+1 from cte where c1 < 1000)
 select c1 % 2, c1, c1, c1 from cte);
insert /*+parallel(8) enable_parallel_dml*/ into t2 
(with recursive cte as ( select 1 as c1 union all select c1+1 from cte where c1 < 1000)
 select c1 % 2, c1, c1, c1 from cte);
select count(1) from t1;
+----------+
| count(1) |
+----------+
|     1000 |
+----------+
select count(1) from t2;
+----------+
| count(1) |
+----------+
|     1000 |
+----------+

drop PROCEDURE my_pro01;

create procedure my_pro01()
begin
  select /*+ pq_distribute(t2 none none) leading(t1 t2) px_join_filter(t2)  parallel(2)*/ count(1) from t1,t2 where t1.c1 = t2.c1;
  select /*+ pq_distribute(t2 none none) leading(t1 t2) px_join_filter(t2)  parallel(2)*/ count(1) from t1,t2 where t1.c1 = t2.c1;
  select /*+ pq_distribute(t2 none none) leading(t1 t2) px_join_filter(t2)  parallel(2)*/ count(1) from t1,t2 where t1.c1 = t2.c1;
end;
$

alter system flush pl cache global;
alter system flush plan cache global;

set @@session.runtime_filter_type =  'BLOOM_FILTER';
select @@session.runtime_filter_type from dual;
