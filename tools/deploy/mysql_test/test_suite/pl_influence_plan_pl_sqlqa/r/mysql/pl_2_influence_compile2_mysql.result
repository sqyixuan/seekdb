#### 22、 _enable_rich_vector_format （影响plan计划，不影响pl缓存，不影响pl编译结果）
drop table if exists t1;
drop table if exists t2;
create table t1 (a int);
insert into t1 values (1), (2), (3);

drop PROCEDURE my_pro01;

create procedure my_pro01()
begin
  select /*+ monitor opt_param('enable_rich_vector_format', 'true')*/ sum(a) from t1;
  #select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;
end;
|

alter system flush pl cache global;
alter system flush plan cache global;

set @@session._enable_rich_vector_format = 0;
select @@session._enable_rich_vector_format from dual;
+--------------------------------------+
| @@session._enable_rich_vector_format |
+--------------------------------------+
|                                    0 |
+--------------------------------------+

call my_pro01();
+--------+
| sum(a) |
+--------+
