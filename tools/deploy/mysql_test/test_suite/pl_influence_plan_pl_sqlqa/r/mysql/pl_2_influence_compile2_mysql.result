#### 18、 parallel_degree_policy （影响plan计划，不影响pl缓存，不影响pl编译结果）
drop table t1;
create table t1(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 2;
INSERT INTO t1 VALUES (1,5,6,7),(2,5,6,7),(3,5,6,7),(4,5,6,7),(5,5,6,7),(6,5,6,7),(7,5,6,7);

drop PROCEDURE my_pro01;

create procedure my_pro01()
begin
  select count(1)  from t1;
  select /*+parallel(auto)*/ count(1) from t1;
  select /*+parallel(manual)*/ count(1)  from t1;
  select /*+parallel(auto) parallel(3)*/ count(1)  from t1;
  select /*+parallel(manual)  parallel(3)*/ count(1) from t1;
end;
$

alter system flush pl cache global;
alter system flush plan cache global;

set @@session.parallel_degree_policy =  auto;
select @@session.parallel_degree_policy from dual;
