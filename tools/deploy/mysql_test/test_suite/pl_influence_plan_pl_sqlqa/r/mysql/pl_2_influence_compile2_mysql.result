#### 17、 _force_order_preserve_set（影响plan计划，不影响pl缓存，不影响pl编译结果）
drop table t1;
drop table t2;
drop table t3;
drop table t4;
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
create table t3(c1 int, c2 int, c3 int);
create table t4(c1 int, c2 int, c3 int);

INSERT INTO t1 VALUES (5,6,7);
INSERT INTO t1 VALUES (7,5,9);
INSERT INTO t1 VALUES (9,4,11);
INSERT INTO t1 VALUES (12,12,3);
INSERT INTO t2 VALUES (2,3,4);
INSERT INTO t2 VALUES (4,5,6);
INSERT INTO t2 VALUES (5,6,7);
INSERT INTO t2 VALUES (9,3,11);
INSERT INTO t3 VALUES (1,2,3);
INSERT INTO t3 VALUES (10,11,12);
INSERT INTO t3 VALUES (3,4,5);
INSERT INTO t3 VALUES (5,6,7);
INSERT INTO t3 VALUES (9,4,11);
INSERT INTO t4 VALUES (1,2,3);
INSERT INTO t4 VALUES (10,11,12);
INSERT INTO t4 VALUES (3,4,5);
INSERT INTO t4 VALUES (5,6,7);
INSERT INTO t4 VALUES (9,4,11);

drop PROCEDURE my_pro01;

create procedure my_pro01()
begin
  select count(1) from (select /*+parallel(2)*/ * from t1 union all select * from t2 union all select * from (select * from t4 order by c3 ASC)) t;
  select count(1) from (select /*+parallel(2)NO_USE_HASH_SET(@"SET$1") NO_SIMPLIFY_ORDER_BY(@"SET$1")*/ * from (select c1,c2,c3 from t1 order by c3,c2,c1) union select c1,c2,c3 from t2 order by c2) t;
end;
$

alter system flush pl cache global;
alter system flush plan cache global;

set @@session._force_order_preserve_set =  1;
select @@session._force_order_preserve_set from dual;
+-------------------------------------+
| @@session._force_order_preserve_set |
+-------------------------------------+
|                                   0 |
+-------------------------------------+

call my_pro01();
