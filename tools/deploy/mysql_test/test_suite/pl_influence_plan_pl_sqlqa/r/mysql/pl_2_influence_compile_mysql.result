#### 13ŃĆü _force_parallel_query_dop’╝łÕĮ▒ÕōŹplanĶ«ĪÕłÆ’╝īõĖŹÕĮ▒ÕōŹplń╝ōÕŁś’╝īõĖŹÕĮ▒ÕōŹplń╝¢Ķ»æń╗ōµ×£’╝ē
alter system flush pl cache global;
alter system flush plan cache global;

drop table if exists t1;
create table t1(a int primary key, b int, c int) partition by hash(a) partitions 4;
create index i1 on t1(b) global partition by hash(b) partitions 4;
create index i2 on t1(b) global partition by key(b) partitions 17;
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3), (4, 4, 4), (5, 4, 4), (6, 4, 4), (7, 4, 4), (8, 4, 4);

drop PROCEDURE my_pro01;$
CREATE PROCEDURE my_pro01()
BEGIN
  delete /*+index(t1 i1)*/ from t1 where b = 1;
  select /*+index(t1 i1)*/ * from t1 where b>1 and b <10 order by 1,2,3;
  select /*+index(t1 i1), parallel(3)*/ * from t1 where b>1 and b<10 order by 1,2,3;
END ;
$

