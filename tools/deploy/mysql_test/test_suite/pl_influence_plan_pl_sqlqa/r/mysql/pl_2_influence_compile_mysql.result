#### 15ŃĆü _enable_parallel_ddl ’╝łõĖŹÕĮ▒ÕōŹplń╝ōÕŁś’╝īõĖŹÕĮ▒ÕōŹplń╝¢Ķ»æń╗ōµ×£’╝ē
drop table tab2;
drop PROCEDURE my_pro;
drop function my_fun;

CREATE PROCEDURE my_pro()
begin
  PREPARE stmt FROM 'CREATE TABLE tab2 (c1 INT, c2 INT) PARALLEL = 3';
  EXECUTE stmt;
  PREPARE stmt FROM 'insert into tab2 values(1,1)';
  EXECUTE stmt;
  DEALLOCATE PREPARE stmt;
end;
$
create function my_fun() returns varchar(200)
begin
  declare res1 INT;
  declare res2 INT;
  SELECT c1,c2 into res1,res2 FROM tab2 where c1 = 1 limit 1;
  return concat('ŃĆÉMY_FUNŃĆæ',res1,res2);
end;
$

