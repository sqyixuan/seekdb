#### 3ŃĆüexplicit_defaults_for_timestamp(õĖŹÕĮ▒ÕōŹplń╝ōÕŁś’╝īõĖŹÕĮ▒ÕōŹplń╝¢Ķ»æń╗ōµ×£)
drop table tab11;
create table tab11(id int AUTO_INCREMENT PRIMARY KEY,c1 varchar(2000),c2 timestamp,c3 timestamp null);
INSERT INTO tab11(id,c1) values(1,' ŃĆÉńö©µłĘ1 ĶĪ©tab1ŃĆæ');
commit;

drop table tab22;
create table tab22(id int,c1 varchar(2000),c2 timestamp,c3 timestamp null);
INSERT INTO tab22(id,c1) values(2,' ŃĆÉńö©µłĘ1 ĶĪ©tab2ŃĆæ');
commit;

drop PROCEDURE my_pro1;
drop FUNCTION my_fun1;
drop TRIGGER my_tri1;

CREATE TRIGGER my_tri1 AFTER INSERT ON tab11 FOR EACH ROW
BEGIN
    INSERT INTO tab22 VALUES (NEW.id,new.c1,new.c2,new.c3);
END;
$

CREATE PROCEDURE my_pro1()
begin
  insert into tab11 values(null,'my_pro ĶĪ©µÅÆÕģźµĢ░µŹ« ',null,null);
end;
$

create function my_fun1() returns varchar(2000)
begin
  declare res1 varchar(2000);
  declare res2 timestamp;
  declare res3 timestamp;
  SELECT c1,c2,c3 into res1,res2,res3 FROM tab11 order by id desc limit 1;
  set @a = res2;
  set @b = res3;
  return concat(CURRENT_USER(),'MY_FUN’╝Ü',upper(res1),(99/5));
end;
$

