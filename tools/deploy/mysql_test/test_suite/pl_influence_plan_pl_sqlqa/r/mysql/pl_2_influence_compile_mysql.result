#### 12ŃĆü _enable_parallel_query ’╝łÕĮ▒ÕōŹplanĶ«ĪÕłÆ’╝īõĖŹÕĮ▒ÕōŹplń╝ōÕŁś’╝īõĖŹÕĮ▒ÕōŹplń╝¢Ķ»æń╗ōµ×£’╝ē
alter system flush pl cache global;
alter system flush plan cache global;

drop table if exists p1, p2, p3, p4;
create table p1(c1 int primary key, c2 int) parallel 1;
create table p2(c1 int primary key, c2 int) parallel 1 partition by hash(c1) partitions 4;
create table p3(c1 int primary key, c2 int) parallel 3;
create table p4(c1 int primary key, c2 int) parallel 4;

drop PROCEDURE my_pro01;$
CREATE PROCEDURE my_pro01()
BEGIN
  select /*+leading(p2,p1,p3,p4)*/ * from p1,p2,p3,p4 where p1.c1 = p2.c1 and p2.c1 = p3.c1 and p3.c1 = p4.c1;
  select * from t1,t2 where t1.c1 = t2.c1;
  #insert /*+use_px*/ into t2 select * from t1;
  select /*+index (t1 t1_i1)*/ c2 from t1;
END;
$

