result_format: 4
alter system flush pl cache global;
alter system flush plan cache global;


# ◆ 准备测试用户
drop user if exists whh_test0;
drop database if exists whh_test0;
create user 'whh_test0' identified by 'whh_test0';
create database whh_test0 character set utf8;
grant all on *.* to 'whh_test0'@'%' with grant option;



set global ob_plan_cache_percentage = 50;


alter system flush pl cache global;
alter system flush plan cache global;

set @save_sqlmode = @@global.sql_mode;

#################################################################
############ 影响pl缓存的参数
drop table tab1;
create table tab1(id int,c1 varchar(2000));
INSERT INTO tab1 values(1,' 【用户1 表tab1】');
commit;

drop table tab2;
create table tab2(id int,c1 varchar(2000));
INSERT INTO tab1 values(2,' 【用户1 表tab2】');
commit;

drop PROCEDURE my_pro;
drop FUNCTION my_fun;
drop TRIGGER my_tri;

CREATE TRIGGER my_tri AFTER INSERT ON tab1 FOR EACH ROW
BEGIN
    INSERT INTO tab2 VALUES (NEW.id,new.c1);
END;
$

CREATE PROCEDURE my_pro()
begin
  declare res1 varchar(2000);
  PREPARE stmt FROM 'insert into tab1 values(2,concat(CURRENT_USER(),''my_pro 表插入数据 ''))';
  EXECUTE stmt;
  DEALLOCATE PREPARE stmt;
end;
$

create function my_fun() returns varchar(2000)
begin
  declare res1 varchar(2000);
  SELECT c1 into res1 FROM tab1 where id = 2 limit 1;
  return concat(CURRENT_USER(),'MY_FUN：',upper(res1),(99/5));
end;
$

call my_pro();
select my_fun() from dual;
+---------------------------------------------------+
| my_fun()                                          |
+---------------------------------------------------+
| whh_test0@%MY_FUN： 【用户1 表TAB2】19.8000       |
+---------------------------------------------------+

select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_FUN'and OBJECT_TYPE = 'FUNCTION';
+------------------+-------------+-----------+
| STATEMENT        | OBJECT_TYPE | hit_count |
+------------------+-------------+-----------+
| whh_test0.my_fun | FUNCTION    |         0 |
+------------------+-------------+-----------+
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_PRO'and OBJECT_TYPE = 'PROCEDURE';
+------------------+-------------+-----------+
| STATEMENT        | OBJECT_TYPE | hit_count |
+------------------+-------------+-----------+
| whh_test0.my_pro | PROCEDURE   |         0 |
+------------------+-------------+-----------+
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_TRI'and OBJECT_TYPE = 'TRIGGER';
+------------------+-------------+-----------+
| STATEMENT        | OBJECT_TYPE | hit_count |
+------------------+-------------+-----------+
| whh_test0.my_tri | TRIGGER     |         0 |
+------------------+-------------+-----------+

