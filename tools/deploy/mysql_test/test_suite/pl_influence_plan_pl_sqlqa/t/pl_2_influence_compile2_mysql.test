--error 0,1305
drop PROCEDURE my_pro01;

delimiter $;
create procedure my_pro01()
begin
  select count(1)  from t1;
  select /*+parallel(auto)*/ count(1) from t1;
  select /*+parallel(manual)*/ count(1)  from t1;
  select /*+parallel(auto) parallel(3)*/ count(1)  from t1;
  select /*+parallel(manual)  parallel(3)*/ count(1) from t1;
end;
$
delimiter ;$

