--error 0,1305
drop PROCEDURE my_pro01;

delimiter $;
create procedure my_pro01()
begin
  select count(1) from (select /*+parallel(2)*/ * from t1 union all select * from t2 union all select * from (select * from t4 order by c3 ASC)) t;
  select count(1) from (select /*+parallel(2)NO_USE_HASH_SET(@"SET$1") NO_SIMPLIFY_ORDER_BY(@"SET$1")*/ * from (select c1,c2,c3 from t1 order by c3,c2,c1) union select c1,c2,c3 from t2 order by c2) t;
end;
$
delimiter ;$

