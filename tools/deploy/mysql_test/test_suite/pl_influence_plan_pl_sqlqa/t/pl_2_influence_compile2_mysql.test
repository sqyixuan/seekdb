--echo #### 24、 cardinality_estimation_model （影响plan计划，不影响pl缓存，不影响pl编译结果）
connect (conn_user1,$OBMYSQL_MS0,whh_test0,whh_test0,whh_test0,$OBMYSQL_PORT);
connection conn_user1;

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(pk int, c1 int, c2 decimal(12, 5), c3 int, c4 int, c5 int);
create table t2(pk int, c1 int, c2 decimal(12, 5), c3 int, c4 int, c5 int);

insert into t1 
select v1.id, v1.num, v2.num / 100.0, v1.id % 100, v1.id % 10, 0
from 
(select row_number() over () as id, num from (select row_number() over () % 10000 as num from table(generator(20000)) order by random(1))) v1,
(select row_number() over () as id, num from (select row_number() over () % 1000 as num from table(generator(20000)) order by random(2))) v2
where v1.id = v2.id;

insert into t2
select v1.id, v1.num, v2.num / 100.0, v1.id % 100, v1.id % 10, 0
from 
(select row_number() over () as id, num from (select row_number() over () % 2000 as num from table(generator(20000)) order by random(3))) v1,
(select row_number() over () as id, num from (select row_number() over () % 1000 as num from table(generator(20000)) order by random(4))) v2
where v1.id = v2.id;

DELIMITER /;
--error 0,1305
drop PROCEDURE my_pro01;/
CREATE PROCEDURE my_pro01()
BEGIN
  select count(1) from t1 where c3 = 1 and c4 = 1 and c1 < 5000;
  select count(1) from t1 where c1 < 5000 or c2 < 5;
  select count(1) from t1 where (c3, 1) != (1, c4);
END ;
/
DELIMITER ;/

connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;
connection conn_user1;

set @@session.cardinality_estimation_model =  'FULL';
select @@session.cardinality_estimation_model from dual;

call my_pro01();
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_PRO01'and OBJECT_TYPE = 'PROCEDURE';

set @@session.cardinality_estimation_model =  'FULL';
select @@session.cardinality_estimation_model from dual;

call my_pro01();
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_PRO01'and OBJECT_TYPE = 'PROCEDURE';

set @@session.cardinality_estimation_model =  'INDEPENDENT';
select @@session.cardinality_estimation_model from dual;

call my_pro01();
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_PRO01'and OBJECT_TYPE = 'PROCEDURE';

set @@session.cardinality_estimation_model =  'PARTIAL';
select @@session.cardinality_estimation_model from dual;

call my_pro01();
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_PRO01'and OBJECT_TYPE = 'PROCEDURE';

--echo #### 25、 query_rewrite_enabled （不影响pl缓存，不影响pl编译结果）
--error 0, 1146, 9755
drop materialized view log on t1;
--error 0, 1051
drop table t1;
--error 0, 1146, 9755
drop materialized view log on t2;
--error 0, 1051
drop table t2;
--error 0, 1146, 9755
drop materialized view log on t3;
--error 0, 1051
drop table t3;
--error 0, 9757
drop materialized view t1_mv1;
--error 0, 9757
drop materialized view t1_mv2;
--error 0, 9757
drop materialized view t1_rt_mav;
--error 0, 9757
drop materialized view t1_t2_mv1;
--error 0, 9757
drop materialized view t1_t2_mv2;
--error 0, 9757
drop materialized view t1_t2_rt_mjv;
--error 0, 9757
drop materialized view t2_mv1;
--error 0, 9757
drop materialized view t2_mv2;
--error 0, 9757
drop materialized view t2_mv3;
--error 0, 9757
drop materialized view t2_mv4;
--error 0, 9757
drop materialized view t3_mv1;

create table t1 (c1 int primary key, c2 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
insert into t1 values (3,4);

create table t2 (c1 int primary key, c2 int);
insert into t2 values (1,2);
insert into t2 values (2,4);

create table t3 (c1 int primary key, c2 int, c3 int, c4 int);
insert into t3 values (1,2,3,4);
insert into t3 values (2,4,6,8);

create materialized view log on t1 with primary key, rowid, sequence (c2) including new values;
create materialized view log on t2 with primary key, rowid, sequence (c2) including new values;
create materialized view log on t3 with primary key, rowid, sequence (c2,c3,c4) including new values;
create materialized view t1_mv1 as select * from t1;
create materialized view t1_mv2 NEVER REFRESH enable query rewrite as select * from t1;
create materialized view t1_rt_mav refresh fast on demand enable on query computation enable query rewrite as select count(*) cnt, c1 c1 from t1 group by c1;
create materialized view t2_mv1 NEVER REFRESH enable query rewrite as select * from t2 where t2.c1 > 1 order by t2.c2;
create materialized view t2_mv2 NEVER REFRESH enable query rewrite as select * from t2 where exists(select 1 from t3 where t3.c1 > 1);
create materialized view t2_mv3 NEVER REFRESH enable query rewrite as select * from t2 where exists(select 1 from t3 where t3.c1 > t2.c1);
create materialized view t2_mv4 NEVER REFRESH enable query rewrite as select * from t2 where t2.c1 >= 2;
create materialized view t1_t2_mv1 NEVER REFRESH enable query rewrite as select t1.c1 t1c1, t1.c2 t1c2, t2.c2 t2c2 from t1, t2 where t1.c1 = t2.c2;
create materialized view t1_t2_mv2 NEVER REFRESH enable query rewrite as select t1.c1 t1c1, t1.c2 t1c2, t2.c2 t2c2 from t1 join t2 on t1.c1 = t2.c2 where t1.c1 > 1;
create materialized view t1_t2_rt_mjv never refresh enable on query computation enable query rewrite as select t1.c1 t1c1, t2.c1 t2c1, t2.c2 t2c2 from t1, t2 where t1.c1 = t2.c2;
create materialized view t3_mv1 NEVER REFRESH enable query rewrite as select c1 c1, c2+c3 c2p3, c3+1 c31, 5*c4 c4t5 from t3;

--error 0,1305
drop PROCEDURE my_pro01;

delimiter |;
create procedure my_pro01()
begin
  select t1.c1, t2.c2 from t1, t2 where t1.c1 = t2.c2 and t1.c1 in (1,3,5);
  select /*+mv_rewrite(t2_mv1)*/ * from t2 where t2.c1 in (select /*+no_mv_rewrite*/ t1.c1 from t1 where t1.c1 > 1); # not support now
  select /*+mv_rewrite(t2_mv1)*/ * from t2 where t2.c1 > 1 and exists(select /*+no_mv_rewrite*/ t1.c1 from t1 where t1.c1 > t2.c1); # not support now
end;
|
delimiter ;|

connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;
connection conn_user1;

set @@session.query_rewrite_enabled =  'true';
select @@session.query_rewrite_enabled from dual;

call my_pro01();
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_PRO01'and OBJECT_TYPE = 'PROCEDURE';

set @@session.query_rewrite_enabled =  'true';
select @@session.query_rewrite_enabled from dual;

call my_pro01();
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_PRO01'and OBJECT_TYPE = 'PROCEDURE';

set @@session.query_rewrite_enabled =  'force';
select @@session.query_rewrite_enabled from dual;

call my_pro01();
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_PRO01'and OBJECT_TYPE = 'PROCEDURE';

set @@session.query_rewrite_enabled =  'FALSE';
select @@session.query_rewrite_enabled from dual;

call my_pro01();
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_PRO01'and OBJECT_TYPE = 'PROCEDURE';

