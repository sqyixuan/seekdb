--echo #### 5、nls_date_format(不影响pl缓存，不影响pl编译结果)
###### 该变量仅适用于 OceanBase 数据库 Oracle 模式。
--error 0,1051
drop table tab1;
create table tab1(id int,c1 varchar(200),c2 date,c3 DATETIME,c4 TIMESTAMP);

--error 0,1305
drop PROCEDURE my_pro;
--error 0,1305
drop FUNCTION my_fun;

delimiter $;
CREATE PROCEDURE my_pro(p0 int,p1 varchar(200),p2 date,p3 DATETIME,p4 TIMESTAMP)
begin
  insert into tab1 values(p0,p1,p2,p3,p4);
end;
$

create function my_fun(p0 int) returns varchar(200)
begin
  declare res1 varchar(200);
  declare res2 date;
  declare res3 DATETIME;
  declare res4 TIMESTAMP;

  SELECT c1,c2,c3,c4 into res1,res2,res3,res4 FROM tab1 where id = p0 limit 1;
  return concat('【MY_FUN】',upper(res1),res2,res3,res4,(99/5));
end;
$
delimiter ;$

call my_pro(2,'my_pro ','2025-03-25','2025-03-25 12:30:00','2025-03-25 12:30:00.123456');
select my_fun(2) from dual;

connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;
connection conn_user1;

