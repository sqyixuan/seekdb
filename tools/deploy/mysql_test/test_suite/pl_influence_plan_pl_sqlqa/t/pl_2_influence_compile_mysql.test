--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;

connection default;

--disable_warnings
drop user if exists whh_test0;
drop user if exists u2;
drop database if exists whh_test0;

create user 'whh_test0' identified by 'whh_test0';
create database whh_test0 character set utf8;
grant all on *.* to 'whh_test0'@'%' with grant option;

create user u2 identified by '123';
grant all on *.* to u2;
revoke trigger ON *.* FROM u2;
--enable_warnings

--source mysql_test/include/check_schema_sync.inc
connect (conn_user1,$OBMYSQL_MS0,whh_test0,whh_test0,whh_test0,$OBMYSQL_PORT);
connect (conn_user2, $OBMYSQL_MS0,u2,123,whh_test0, $OBMYSQL_PORT);
connection conn_user1;

set global ob_plan_cache_percentage = 50;

disconnect conn_user1;
connect (conn_user1,$OBMYSQL_MS0,whh_test0,whh_test0,whh_test0,$OBMYSQL_PORT);
connection conn_user1;

set @save_sqlmode = @@global.sql_mode;

--echo #################################################################
--echo ############ pl 编译
--error 0,1051
drop table tab1;
create table tab1(id int,c1 varchar(2000));
INSERT INTO tab1 values(1,' 【用户1 表tab1】');
commit;

--error 0,1051
drop table tab2;
create table tab2(id int,c1 varchar(2000));
INSERT INTO tab1 values(2,' 【用户1 表tab2】');
commit;

--error 0,1305
drop PROCEDURE my_pro;
--error 0,1305
drop FUNCTION my_fun;
--error 0,1360
drop TRIGGER my_tri;

delimiter $;
CREATE TRIGGER my_tri AFTER INSERT ON tab1 FOR EACH ROW
BEGIN
    INSERT INTO tab2 VALUES (NEW.id,new.c1);
END;
$

CREATE PROCEDURE my_pro()
begin
  declare res1 varchar(2000);
  PREPARE stmt FROM 'insert into tab1 values(2,concat(CURRENT_USER(),''my_pro 表插入数据 ''))';
  EXECUTE stmt;
  DEALLOCATE PREPARE stmt;
end;
$

create function my_fun() returns varchar(2000)
begin
  declare res1 varchar(2000);
  SELECT c1 into res1 FROM tab1 where id = 2 limit 1;
  return concat(CURRENT_USER(),'MY_FUN：',upper(res1),(99/5));
end;
$
delimiter ;$

--echo #### 1、character_set_results(不影响pl缓存，不影响pl编译结果)
DELIMITER /;
--error 0,1305
drop PROCEDURE my_pro01;/
CREATE PROCEDURE my_pro01()
BEGIN
  DECLARE c1 CHAR(100);
  DECLARE c2 VARCHAR(100);
  SET c1 = 'Hello World!';
  SET c2 = 'ऊँचाई ताप प्रदूषण में बिंदु पचास सेंटीमीटर';
  IF c1 > c2 THEN
  SELECT CONCAT('output:', c1);
  ELSEIF c1 < c2 THEN
  SELECT CONCAT('output:', c2);
  ELSE
  SELECT 'output: 相等';
  END IF;
END ;
/
DELIMITER ;/

connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;
connection conn_user1;

set @@session.character_set_results = binary;
select @@session.character_set_results from dual;

call my_pro01();
sleep 3;
select my_fun() from dual;
sleep 3;

select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_FUN'and OBJECT_TYPE = 'FUNCTION';
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_PRO01'and OBJECT_TYPE = 'PROCEDURE';
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_TRI'and OBJECT_TYPE = 'TRIGGER';

set @@session.character_set_results = gbk;
select @@session.character_set_results from dual;

call my_pro01();
select my_fun() from dual;

select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_FUN'and OBJECT_TYPE = 'FUNCTION';
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_PRO01'and OBJECT_TYPE = 'PROCEDURE';
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_TRI'and OBJECT_TYPE = 'TRIGGER';

set @@session.character_set_results = utf8mb4;
select @@session.character_set_results from dual;

call my_pro01();
select my_fun() from dual;

select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_FUN'and OBJECT_TYPE = 'FUNCTION';
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_PRO01'and OBJECT_TYPE = 'PROCEDURE';
select STATEMENT,OBJECT_TYPE,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where upper(STATEMENT) = 'WHH_TEST0.MY_TRI'and OBJECT_TYPE = 'TRIGGER';

