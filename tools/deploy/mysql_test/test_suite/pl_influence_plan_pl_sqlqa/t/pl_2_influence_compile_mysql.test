--error 0,1305
drop PROCEDURE my_pro;
--error 0,1305
drop FUNCTION my_fun;

delimiter $;
CREATE PROCEDURE my_pro()
begin
  declare res1 varchar(2000);
  insert into tab1 values(2,concat(CURRENT_USER(),'my_pro 表插入数据 '));
  select /*+use_merge(t1 t2) leading(t1 t2)*/ * from t1, t2 where t1.c1 = t2.c2 order by 1,2;
  select /*+use_merge(t1 t2) leading(t1 t2)*/ * from t1 left join t2 on t1.c1 = t2.c2 order by 1,2;
  select /*+use_merge(t1 t2) leading(t1 t2)*/ * from t1 right join t2 on t1.c1 = t2.c2 order by 1,2;
  select /*+use_merge(t1 t2) leading(t1 t2)*/ * from t1 full join t2 on t1.c1 = t2.c2 order by 1,2;
  select /*+use_merge(t1, t2)*/ * from t1 where exists (select 1 from t2 where t1.c1 =  t2.c1) order by 1,2;
  select /*+use_merge(t1, t2)*/ * from t1 where not exists (select 1 from t2 where t1.c1 =  t2.c1) order by 1,2;
end;
$

create function my_fun() returns varchar(2000)
begin
  declare res1 varchar(2000);
  SELECT tab1.c1 into res1 FROM tab1,tab2 where tab1.id=tab2.id and tab1.id = 2 limit 1;
  return concat(CURRENT_USER(),'MY_FUN：',upper(res1),(99/5));
end;
$
delimiter ;$

