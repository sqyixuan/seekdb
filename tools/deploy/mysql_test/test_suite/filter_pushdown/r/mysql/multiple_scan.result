drop table if exists t0,t1,t2,t3;
create table t0(a int);
create table t1(a int, b int, c varchar(100), primary key(a,b)) block_size = 2048;
create table t2(c1 int primary key, c2 int);
create table t3(c1 int primary key, c2 int, c3 varchar(20));
delete from t2 where c1 = 3;
delete from t3 where c1 > 850 and c1 < 950;
select count(*) from t3 where c1 not in (900) order by c1 desc;
count(*)
901
select count(*) from t3 where c1 not in (900) order by c1 asc;
count(*)
901
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
