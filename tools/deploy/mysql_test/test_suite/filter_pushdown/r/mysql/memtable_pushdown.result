set SESSION ob_query_timeout = 5 * 3600 * 1000 * 1000;
set SESSION ob_trx_timeout = 5 * 3600 * 1000 * 1000;
set SESSION ob_trx_idle_timeout = 5 * 3600 * 1000 * 1000;
alter system set writing_throttling_trigger_percentage = 99;
create table memtable_scan_t (col_0 bigint primary key, col_1 bigint, col_2 bigint, col_3 bigint, col_4 bigint, col_5 varchar(20)) merge_engine = delete_insert;
create sequence s1 cache 1000000 noorder;
alter system set freeze_trigger_percentage = 80;
INSERT INTO memtable_scan_t SELECT 
s1.nextval col_0,
abs(random(269381) % 10000) col_1,
zipf(1, 100, random(269381)) col_2,
normal(0, 1, random(269381)) col_3,
uniform(1, 100, random(269381)) col_4,
randstr(1+zipf(1, 20, random(269381)), random(269381)) col_5
FROM 
table(generator(1000));
SELECT  
*, 
col_1 < 100 condition_1, 
col_5 = 'G' and col_3 * col_2 < 1000 condition_2, 
col_1 > 9000 and (col_2 * col_3 + col_4 < 100) condition_3 
FROM memtable_scan_t 
WHERE 
(col_1 < 100) 
or (col_5 = 'G' and col_3 * col_2 < 1000) 
or (col_1 > 9000 and (col_2 * col_3 + col_4 < 30));
