# owner: dengzhi.ldz
#tags: optimizer
# description: filter test for filter pushdown correctness

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

create table t1 (a int auto_increment primary key, b bigint, c char(100), d varchar(1000)) row_format = dynamic block_size = 2048;
insert into t1 (b, c, d) values(1, "a", repeat('a', 1000));
insert into t1 (b, c, d) values(2, "ab", repeat("ab", 500));
insert into t1 (b, c, d) values(3, "abc", repeat("ab", 500));
insert into t1 (b, c, d) values(4, "abcd", repeat("ab", 500));
insert into t1 (b, c, d) values(5, "ab", repeat("a", 1000));
insert into t1 (b, c, d) values(6, "abc", repeat("abcd", 250));
insert into t1 (b, c, d) values(7, "abcd", repeat("abbb", 250));
insert into t1 (b, c, d) values(8, "ab", repeat("accc", 250));
--let $loop=6
while($loop > 0)
{
  insert into t1 (b, c, d) select b, c, d from t1;
  dec $loop;
}
select count(1) from t1;

create table t2 (a int auto_increment primary key, b bigint, c char(100), d varchar(1000)) row_format = dynamic block_size = 2048;
insert into t2 (b, c, d) values(1, "a", repeat('a', 1000));
insert into t2 (b, c, d) values(2, "ab", repeat("ab", 500));
insert into t2 (b, c, d) values(3, "abc", repeat("ab", 500));
insert into t2 (b, c, d) values(4, "abcd", repeat("ab", 500));
insert into t2 (b, c, d) values(5, "ab", repeat("a", 1000));
insert into t2 (b, c, d) values(6, "abc", repeat("abcd", 250));
insert into t2 (b, c, d) values(7, "abcd", repeat("abbb", 250));
insert into t1 (b, c, d) values(8, "ab", repeat("accc", 250));
--let $loop=6
while($loop > 0)
{
  insert into t1 (b, c, d) select b, c, d from t1;
  dec $loop;
}

CREATE TABLE t3 (`c0` double DEFAULT NULL,`c1` tinyint(4) DEFAULT NULL);
INSERT INTO `t3` VALUES (6,0),(0,NULL),(NULL,NULL),(-4,NULL),(3,NULL),(6,0),(3,NULL),(0,NULL),(0,NULL),(NULL,NULL),(NULL,NULL),(NULL,NULL),(2,NULL),(2,NULL),(-6,NULL),(2,NULL),(7,NULL),(-5,NULL),(6,NULL),(-3,NULL),(-5,NULL),(-5,NULL),(-5,NULL),(6,NULL),(-6,0),(4,NULL),(-5,NULL),(-5,NULL),(-8,0),(-8,0),(-2,NULL),(5,1),(-4,1),(5,1),(NULL,-1),(NULL,-1),(-3,-1),(0,1),(-6,-1),(-6,2),(2,-3),(4,3),(-8,-3),(-5,-4),(-5,-4),(-4,-4),(-2,-4),(5,4),(-2,-4),(NULL,-4),(NULL,-4),(NULL,-4),(-3,5),(-3,-5),(NULL,5),(6,-5),(-6,5),(7,5),(-8,-6),(-4,-6),(5,6),(0,6),(NULL,-7),(NULL,7),(NULL,-7),(-7,7),(NULL,-8);

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

alter system major freeze tenant sys;
alter system major freeze tenant all_user;
alter system major freeze tenant all_meta;
alter system flush plan cache global;
--source mysql_test/include/wait_daily_merge.inc
--enable_query_log

connection default;

select A.b, (select /*+ use_1hash_aggregation */ DISTINCT P.b  FROM t1 P WHERE P.b = A.b) b FROM t2 A  where A.c = 'abcd'  and A.b in (4, 7);
select * from t3 where t3.c1 in (0|1);
--disable_warnings
SELECT * FROM t3 WHERE ((((t3.c0) = (t3.c0)) IN ((t3.c1) <= (t3.c0), LEAST('00000000000000', t3.c1, t3.c1))) || ((t3.c1) IN (((CAST("00000000000000" AS SIGNED)) | (CAST("t\\exSK/REOvg)" AS SIGNED)))))) || ((("2024-11-10 05:15:49") NOT IN (7, NULL)) NOT IN ((t3.c1) > (-1379902375), (t3.c0) XOR ("N")));
--enable_warnings
drop table t1;
drop table t2;
drop table t3;

--disable_query_log
set global max_allowed_packet=16777216;
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log
