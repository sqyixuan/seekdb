# owner: dengzhi.ldz
#tags: optimizer
# description: basic test for filter pushdown correctness

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
DROP TABLE IF EXISTS `table100_bigint`;
--enable_warnings

CREATE TABLE `table100_bigint` (
  `col_tinyint_unsigned` tinyint(3) unsigned DEFAULT NULL,
