# owner: houhaojun.hhj
# tags: storage
# description: test black filter monotonicity

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
alter system set _enable_skip_index=true;
alter system set _pushdown_storage_level=4;

set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
sleep 1;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1 (c1 varchar(10), c2 double, c3 int, c4 date);

insert into t1 values ("bbb", 1.11, 1, '1997-07-07'), ("ccc", 2.22, 2, '1998-07-07'), ("ddd", 3.33, 3, '1999-07-07'), ("eee", 4.44, 4, '2000-07-07'), ("FFF", 5.55, 5, '2001-07-07'), ("GGG", 6.66, 6, '2002-07-07'), ("HHH", 7.77, 7, '2003-07-07'), ("III", 8.88, 8, '2004-07-07');

create table t2 (c1 varchar(10), c2 varchar(10), c3 varchar(128));

insert into t2 values ("bbb", NULL, repeat("b", 100)), ("ccc", NULL, repeat("c", 100)), (NULL, NULL, repeat("d", 100)), ("eee", NULL, NULL), ("FFF", NULL, repeat("F", 100)), (NULL, NULL, repeat("G", 100)), ("HHH", NULL, NULL), ("III", NULL, NULL);

--let $count = 1
while($count < 14)
{
  insert into t1 select * from t1;
  insert into t2 select * from t2;
  inc $count;
}

--enable_query_log

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

--result_format 4

# UPPER
select count(*) from t1 where UPPER(c1) < "AA";
select count(*) from t1 where UPPER(c1) <= "AA";
select count(*) from t1 where UPPER(c1) > "AA";
select count(*) from t1 where UPPER(c1) >= "AA";

select count(*) from t1 where UPPER(c1) < "ZZ";
select count(*) from t1 where UPPER(c1) <= "ZZ";
select count(*) from t1 where UPPER(c1) > "ZZ";
select count(*) from t1 where UPPER(c1) >= "ZZ";

select count(*) from t1 where UPPER(c1) < "DD";
select count(*) from t1 where UPPER(c1) <= "DD";
select count(*) from t1 where UPPER(c1) > "DD";
select count(*) from t1 where UPPER(c1) >= "DD";

select count(*) from t1 where UPPER(c1) = "AAA";
select count(*) from t1 where UPPER(c1) = "BBB";

# LOWER
select count(*) from t1 where LOWER(c1) < "aa";
select count(*) from t1 where LOWER(c1) <= "aa";
select count(*) from t1 where LOWER(c1) > "aa";
select count(*) from t1 where LOWER(c1) >= "aa";

select count(*) from t1 where LOWER(c1) < "zz";
select count(*) from t1 where LOWER(c1) <= "zz";
select count(*) from t1 where LOWER(c1) > "zz";
select count(*) from t1 where LOWER(c1) >= "zz";

select count(*) from t1 where LOWER(c1) < "ee";
select count(*) from t1 where LOWER(c1) <= "ee";
select count(*) from t1 where LOWER(c1) > "ee";
select count(*) from t1 where LOWER(c1) >= "ee";

select count(*) from t1 where LOWER(c1) = "aaa";
select count(*) from t1 where LOWER(c1) = "eee";

# SUBSTR(col, 1, x)
select count(*) from t1 where SUBSTR(c1, 1, 2) < "aa";
select count(*) from t1 where SUBSTR(c1, 1, 2) <= "aa";
select count(*) from t1 where SUBSTR(c1, 1, 2) > "aa";
select count(*) from t1 where SUBSTR(c1, 1, 2) >= "aa";

select count(*) from t1 where SUBSTR(c1, 1, 2) < "ZZ";
select count(*) from t1 where SUBSTR(c1, 1, 2) <= "ZZ";
select count(*) from t1 where SUBSTR(c1, 1, 2) > "ZZ";
select count(*) from t1 where SUBSTR(c1, 1, 2) >= "ZZ";

select count(*) from t1 where SUBSTR(c1, 1, 2) < "FF";
select count(*) from t1 where SUBSTR(c1, 1, 2) <= "FF";
select count(*) from t1 where SUBSTR(c1, 1, 2) > "FF";
select count(*) from t1 where SUBSTR(c1, 1, 2) >= "FF";

select count(*) from t1 where SUBSTR(c1, 1, 2) = "AA";
select count(*) from t1 where SUBSTR(c1, 1, 2) = "FF";

# SUBSTR(col, not 1, x)
select count(*) from t1 where SUBSTR(c1, 1.2345, 2) < "aa";
select count(*) from t1 where SUBSTR(c1, 2, 2) < "aa";
select count(*) from t1 where SUBSTR(c1, 2, 2) <= "aa";
select count(*) from t1 where SUBSTR(c1, 2, 2) > "aa";
select count(*) from t1 where SUBSTR(c1, 2, 2) >= "aa";

select count(*) from t1 where SUBSTR(c1, 2, 2) < "ZZ";
select count(*) from t1 where SUBSTR(c1, 2, 2) <= "ZZ";
select count(*) from t1 where SUBSTR(c1, 2, 2) > "ZZ";
select count(*) from t1 where SUBSTR(c1, 2, 2) >= "ZZ";

select count(*) from t1 where SUBSTR(c1, 2, 2) < "FF";
select count(*) from t1 where SUBSTR(c1, 2, 2) <= "FF";
select count(*) from t1 where SUBSTR(c1, 2, 2) > "FF";
select count(*) from t1 where SUBSTR(c1, 2, 2) >= "FF";

select count(*) from t1 where SUBSTR(c1, 2, 2) = "AA";
select count(*) from t1 where SUBSTR(c1, 2, 2) = "FF";

# LEFT
select count(*) from t1 where LEFT(c1, 2) < "aa";
select count(*) from t1 where LEFT(c1, 2) <= "aa";
select count(*) from t1 where LEFT(c1, 2) > "aa";
select count(*) from t1 where LEFT(c1, 2) >= "aa";

select count(*) from t1 where LEFT(c1, 2) < "ZZ";
select count(*) from t1 where LEFT(c1, 2) <= "ZZ";
select count(*) from t1 where LEFT(c1, 2) > "ZZ";
select count(*) from t1 where LEFT(c1, 2) >= "ZZ";

select count(*) from t1 where LEFT(c1, 2) < "GG";
select count(*) from t1 where LEFT(c1, 2) <= "GG";
select count(*) from t1 where LEFT(c1, 2) > "GG";
select count(*) from t1 where LEFT(c1, 2) >= "GG";

select count(*) from t1 where LEFT(c1, 2) = "AA";
select count(*) from t1 where LEFT(c1, 2) = "GG";

# CEIL
select count(*) from t1 where CEIL(c2) < 1;
select count(*) from t1 where CEIL(c2) <= 1;
select count(*) from t1 where CEIL(c2) > 1;
select count(*) from t1 where CEIL(c2) >= 1;

select count(*) from t1 where CEIL(c2) < 10;
select count(*) from t1 where CEIL(c2) <= 10;
select count(*) from t1 where CEIL(c2) > 10;
select count(*) from t1 where CEIL(c2) >= 10;

select count(*) from t1 where CEIL(c2) < 6;
select count(*) from t1 where CEIL(c2) <= 6;
select count(*) from t1 where CEIL(c2) > 6;
select count(*) from t1 where CEIL(c2) >= 6;

select count(*) from t1 where CEIL(c2) = 10;
select count(*) from t1 where CEIL(c2) = 4;

# FLOOR
select count(*) from t1 where FLOOR(c2) < 0;
select count(*) from t1 where FLOOR(c2) <= 0;
select count(*) from t1 where FLOOR(c2) > 0;
select count(*) from t1 where FLOOR(c2) >= 0;

select count(*) from t1 where FLOOR(c2) < 10;
select count(*) from t1 where FLOOR(c2) <= 10;
select count(*) from t1 where FLOOR(c2) > 10;
select count(*) from t1 where FLOOR(c2) >= 10;

select count(*) from t1 where FLOOR(c2) < 6;
select count(*) from t1 where FLOOR(c2) <= 6;
select count(*) from t1 where FLOOR(c2) > 6;
select count(*) from t1 where FLOOR(c2) >= 6;

select count(*) from t1 where FLOOR(c2) = 10;
select count(*) from t1 where FLOOR(c2) = 5;

# ADD
select count(*) from t1 where c3 + 1 < 0;
select count(*) from t1 where c3 + 1 <= 0;
select count(*) from t1 where c3 + 1 > 0;
select count(*) from t1 where c3 + 1 >= 0;

select count(*) from t1 where c3 + 1 < 100;
select count(*) from t1 where c3 + 1 <= 100;
select count(*) from t1 where c3 + 1 > 100;
select count(*) from t1 where c3 + 1 >= 100;

select count(*) from t1 where c3 + 1 < 6;
select count(*) from t1 where c3 + 1 <= 6;
select count(*) from t1 where c3 + 1 > 6;
select count(*) from t1 where c3 + 1 >= 6;

select count(*) from t1 where c3 + 1 = 100;
select count(*) from t1 where c3 + 1 = 7;

# MINUS
select count(*) from t1 where 7 - c3 < -10;
select count(*) from t1 where 7 - c3 <= -10;
select count(*) from t1 where 7 - c3 > -10;
select count(*) from t1 where 7 - c3 >= -10;

select count(*) from t1 where 7 - c3 < 7;
select count(*) from t1 where 7 - c3 <= 7;
select count(*) from t1 where 7 - c3 > 7;
select count(*) from t1 where 7 - c3 >= 7;

select count(*) from t1 where 7 - c3 < 0;
select count(*) from t1 where 7 - c3 <= 0;
select count(*) from t1 where 7 - c3 > 0;
select count(*) from t1 where 7 - c3 >= 0;

select count(*) from t1 where 7 - c3 = 7;
select count(*) from t1 where 7 - c3 = 0;

# CAST
select count(*) from t1 where cast (c4 as year) < 1996;
select count(*) from t1 where cast (c4 as year) <= 1996;
select count(*) from t1 where cast (c4 as year) > 1996;
select count(*) from t1 where cast (c4 as year) >= 1996;

select count(*) from t1 where cast (c4 as year) < 2008;
select count(*) from t1 where cast (c4 as year) <= 2008;
select count(*) from t1 where cast (c4 as year) > 2008;
select count(*) from t1 where cast (c4 as year) >= 2008;

select count(*) from t1 where cast (c4 as year) < 1997;
select count(*) from t1 where cast (c4 as year) <= 1997;
select count(*) from t1 where cast (c4 as year) > 1997;
select count(*) from t1 where cast (c4 as year) >= 1997;

select count(*) from t1 where cast (c4 as year) = 2002;
select count(*) from t1 where cast (c4 as year) = 2008;

# has null column
select count(*) from t2 where LEFT(c1, 2) < "aa";
select count(*) from t2 where LEFT(c1, 2) <= "aa";
select count(*) from t2 where LEFT(c1, 2) > "aa";
select count(*) from t2 where LEFT(c1, 2) >= "aa";

select count(*) from t2 where LEFT(c1, 2) < "ZZ";
select count(*) from t2 where LEFT(c1, 2) <= "ZZ";
select count(*) from t2 where LEFT(c1, 2) > "ZZ";
select count(*) from t2 where LEFT(c1, 2) >= "ZZ";

select count(*) from t2 where LEFT(c1, 2) < "GG";
select count(*) from t2 where LEFT(c1, 2) <= "GG";
select count(*) from t2 where LEFT(c1, 2) > "GG";
select count(*) from t2 where LEFT(c1, 2) >= "GG";

select count(*) from t2 where LEFT(c1, 2) = "AA";
select count(*) from t2 where LEFT(c1, 2) = "GG";

# all null column
select count(*) from t2 where LEFT(c2, 2) < "aa";
select count(*) from t2 where LEFT(c2, 2) <= "aa";
select count(*) from t2 where LEFT(c2, 2) > "aa";
select count(*) from t2 where LEFT(c2, 2) >= "aa";

select count(*) from t2 where LEFT(c2, 2) < "ZZ";
select count(*) from t2 where LEFT(c2, 2) <= "ZZ";
select count(*) from t2 where LEFT(c2, 2) > "ZZ";
select count(*) from t2 where LEFT(c2, 2) >= "ZZ";

select count(*) from t2 where LEFT(c2, 2) < "GG";
select count(*) from t2 where LEFT(c2, 2) <= "GG";
select count(*) from t2 where LEFT(c2, 2) > "GG";
select count(*) from t2 where LEFT(c2, 2) >= "GG";

select count(*) from t2 where LEFT(c2, 2) = "AA";
select count(*) from t2 where LEFT(c2, 2) = "GG";

# null min/max
select count(*) from t2 where LEFT(c3, 2) < "aa";
select count(*) from t2 where LEFT(c3, 2) <= "aa";
select count(*) from t2 where LEFT(c3, 2) > "aa";
select count(*) from t2 where LEFT(c3, 2) >= "aa";

select count(*) from t2 where LEFT(c3, 2) < "ZZ";
select count(*) from t2 where LEFT(c3, 2) <= "ZZ";
select count(*) from t2 where LEFT(c3, 2) > "ZZ";
select count(*) from t2 where LEFT(c3, 2) >= "ZZ";

select count(*) from t2 where LEFT(c3, 2) < "GG";
select count(*) from t2 where LEFT(c3, 2) <= "GG";
select count(*) from t2 where LEFT(c3, 2) > "GG";
select count(*) from t2 where LEFT(c3, 2) >= "GG";

select count(*) from t2 where LEFT(c3, 2) = "AA";
select count(*) from t2 where LEFT(c3, 2) = "GG";

# disable skip index
--disable_query_log
alter system set _enable_skip_index=false;
alter system flush plan cache;
sleep 2;
--enable_query_log

# column store dict encoding
# SUBSTR(col, 1, x)
select count(*) from t1 where SUBSTR(c1, 1, 2) < "aa";
select count(*) from t1 where SUBSTR(c1, 1, 2) <= "aa";
select count(*) from t1 where SUBSTR(c1, 1, 2) > "aa";
select count(*) from t1 where SUBSTR(c1, 1, 2) >= "aa";

select count(*) from t1 where SUBSTR(c1, 1, 2) < "ZZ";
select count(*) from t1 where SUBSTR(c1, 1, 2) <= "ZZ";
select count(*) from t1 where SUBSTR(c1, 1, 2) > "ZZ";
select count(*) from t1 where SUBSTR(c1, 1, 2) >= "ZZ";

select count(*) from t1 where SUBSTR(c1, 1, 2) < "FF";
select count(*) from t1 where SUBSTR(c1, 1, 2) <= "FF";
select count(*) from t1 where SUBSTR(c1, 1, 2) > "FF";
select count(*) from t1 where SUBSTR(c1, 1, 2) >= "FF";

select count(*) from t1 where SUBSTR(c1, 1, 2) = "AA";
select count(*) from t1 where SUBSTR(c1, 1, 2) = "FF";

# column store dict encoding, has null column
