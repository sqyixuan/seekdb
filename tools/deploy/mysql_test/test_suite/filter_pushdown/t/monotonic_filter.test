select count(*) from t2 where SUBSTR(c1, 1, 2) < "aa";
select count(*) from t2 where SUBSTR(c1, 1, 2) <= "aa";
select count(*) from t2 where SUBSTR(c1, 1, 2) > "aa";
select count(*) from t2 where SUBSTR(c1, 1, 2) >= "aa";

select count(*) from t2 where SUBSTR(c1, 1, 2) < "ZZ";
select count(*) from t2 where SUBSTR(c1, 1, 2) <= "ZZ";
select count(*) from t2 where SUBSTR(c1, 1, 2) > "ZZ";
select count(*) from t2 where SUBSTR(c1, 1, 2) >= "ZZ";

select count(*) from t2 where SUBSTR(c1, 1, 2) < "FF";
select count(*) from t2 where SUBSTR(c1, 1, 2) <= "FF";
select count(*) from t2 where SUBSTR(c1, 1, 2) > "FF";
select count(*) from t2 where SUBSTR(c1, 1, 2) >= "FF";

select count(*) from t2 where SUBSTR(c1, 1, 2) = "AA";
