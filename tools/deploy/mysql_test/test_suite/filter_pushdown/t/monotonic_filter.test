# column store dict encoding, all null column
# SUBSTR(col, 1, x)
select count(*) from t2 where SUBSTR(c2, 1, 2) < "aa";
select count(*) from t2 where SUBSTR(c2, 1, 2) <= "aa";
select count(*) from t2 where SUBSTR(c2, 1, 2) > "aa";
select count(*) from t2 where SUBSTR(c2, 1, 2) >= "aa";

select count(*) from t2 where SUBSTR(c2, 1, 2) < "ZZ";
select count(*) from t2 where SUBSTR(c2, 1, 2) <= "ZZ";
select count(*) from t2 where SUBSTR(c2, 1, 2) > "ZZ";
select count(*) from t2 where SUBSTR(c2, 1, 2) >= "ZZ";

select count(*) from t2 where SUBSTR(c2, 1, 2) < "FF";
select count(*) from t2 where SUBSTR(c2, 1, 2) <= "FF";
select count(*) from t2 where SUBSTR(c2, 1, 2) > "FF";
select count(*) from t2 where SUBSTR(c2, 1, 2) >= "FF";

select count(*) from t2 where SUBSTR(c2, 1, 2) = "AA";
