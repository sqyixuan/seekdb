# owner: yht146439
# description: pushdown with ora_rowscn

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists reverse_scn_t;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, c6 varchar(20), primary key(c1,c2));
create table t2(c1 int, c2 int, c3 int, c4 int, c5 int, c6 varchar(20), primary key(c1,c2)) ROW_FORMAT = COMPRESSED;
create table t3(c1 int, c2 int, c3 int, c4 int, c5 int, c6 varchar(20), primary key(c1,c2)) ROW_FORMAT = COMPRESSED WITH COLUMN GROUP(all columns, each column);
create table reverse_scn_t(c1 int primary key, c2 int ,c3 varchar(20));

--let $count = 0
while($count < 1000)
{
  eval insert into t1 values 
                  ($count * 10 + 1 ,$count * 10 + 1 ,$count * 10 + 1, $count * 10 + 1, $count * 10 + 1, concat('abc',$count * 10 + 1)),
                  ($count * 10 + 2 ,$count * 10 + 2 ,$count * 10 + 2, $count * 10 + 2, $count * 10 + 2, concat('abc',$count * 10 + 2)),
                  ($count * 10 + 3 ,$count * 10 + 3 ,$count * 10 + 3, $count * 10 + 3, $count * 10 + 3, concat('abc',$count * 10 + 3)),
                  ($count * 10 + 4 ,$count * 10 + 4 ,$count * 10 + 4, $count * 10 + 4, $count * 10 + 4, concat('abc',$count * 10 + 4)),
                  ($count * 10 + 5 ,$count * 10 + 5 ,$count * 10 + 5, $count * 10 + 5, $count * 10 + 5, concat('abc',$count * 10 + 5)),
                  ($count * 10 + 6 ,$count * 10 + 6 ,$count * 10 + 6, $count * 10 + 6, $count * 10 + 6, concat('abc',$count * 10 + 6)),
                  ($count * 10 + 7 ,$count * 10 + 7 ,$count * 10 + 7, $count * 10 + 7, $count * 10 + 7, concat('abc',$count * 10 + 7)),
                  ($count * 10 + 8 ,$count * 10 + 8 ,$count * 10 + 8, $count * 10 + 8, $count * 10 + 8, concat('abc',$count * 10 + 8)),
                  ($count * 10 + 9 ,$count * 10 + 9 ,$count * 10 + 9, $count * 10 + 9, $count * 10 + 9, concat('abc',$count * 10 + 9)),
                  ($count * 10 + 10 ,$count * 10 + 10 ,$count * 10 + 10, $count * 10 + 10, $count * 10 + 10, concat('abc',$count * 10 + 10));
  --inc $count
}
insert into reverse_scn_t select c1,c1,concat('abc',c1) from t1;
delete from reverse_scn_t;
insert into t1 select 10000+c1,10000+c2,10000+c3,c4,c5,c6 from t1;
insert into t1 select -1 * (20000+c1),20000+c2,20000+c3,-c4,c5,c6 from t1;
insert into t1 select 40000+c1,40000+c2,-1 * (40000+c3),c4,-c5,c6 from t1;
insert into t2 select * from t1;
insert into t3 select * from t1;

select count(ora_rowscn) from t1 where ora_rowscn > 0;
select count(ora_rowscn) from t1 where ora_rowscn + 1 > 0;
select count(ora_rowscn) from t2 where ora_rowscn < 0;
select count(ora_rowscn) from t2 where ora_rowscn - 1 < 0;
select count(ora_rowscn) from t3 where ora_rowscn > 0;

select c1 from t1 where ora_rowscn > 0 and c2 > 10 limit 5;
select c1 from t2 where c2 > 10 and c3 > 1000 and ora_rowscn < 0 limit 5;
select c1 from t3 where c3 + c4 > 1000 and ora_rowscn > 0 and c5 > 1000 limit 5;

select * from t1 where c2 > 10 and c3 < 60 and c4 > 40 and ora_rowscn > 0 and c3 > 30 limit 10;
select * from t2 where c2 > 10 and c3 < 60 and c4 > 40 and ora_rowscn > 0 and c3 > 30 limit 10;
select * from t3 where c2 > 10 and c3 < 60 and c4 > 40 and ora_rowscn > 0 and c3 > 30 limit 10;

select * from t1 where c1+c2 > 1000 and ora_rowscn + 1 > 0 and c3+c5 > 2000 limit 10;
select * from t2 where c1+c2 > 1000 and ora_rowscn + 1 > 0 and c3+c5 > 2000 limit 10;
select * from t3 where c1+c2 > 1000 and ora_rowscn + 1 > 0 and c3+c5 > 2000 limit 10;

select c1 from t1 where ora_rowscn > 0 and c2 > 10 order by c1 desc limit 5;
select * from t2 where c2 > 10 and c3 < 60 and c4 > 40 and ora_rowscn > 0 and c3 > 30 order by c1 desc limit 10;
select * from t3 where c1+c2 > 1000 and ora_rowscn + 1 > 0 and c3+c5 > 2000 order by c1 desc limit 10;

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

select c1,ora_rowscn from reverse_scn_t order by c1 desc limit 10;
select count(ora_rowscn) from t1 where ora_rowscn > 0;
select count(ora_rowscn) from t1 where ora_rowscn + 1 > 0;
select count(ora_rowscn) from t2 where ora_rowscn < 0;
select count(ora_rowscn) from t2 where ora_rowscn - 1 < 0;
select count(ora_rowscn) from t3 where ora_rowscn > 0;

select c1 from t1 where ora_rowscn > 0 and c2 > 10 limit 5;
select c1 from t2 where c2 > 10 and c3 > 1000 and ora_rowscn < 0 limit 5;
select c1 from t3 where c3 + c4 > 1000 and ora_rowscn > 0 and c5 > 1000 limit 5;

select * from t1 where c2 > 10 and c3 < 60 and c4 > 40 and ora_rowscn > 0 and c3 > 30 limit 10;
select * from t2 where c2 > 10 and c3 < 60 and c4 > 40 and ora_rowscn > 0 and c3 > 30 limit 10;
select * from t3 where c2 > 10 and c3 < 60 and c4 > 40 and ora_rowscn > 0 and c3 > 30 limit 10;

select * from t1 where c1+c2 > 1000 and ora_rowscn + 1 > 0 and c3+c5 > 2000 limit 10;
select * from t2 where c1+c2 > 1000 and ora_rowscn + 1 > 0 and c3+c5 > 2000 limit 10;
select * from t3 where c1+c2 > 1000 and ora_rowscn + 1 > 0 and c3+c5 > 2000 limit 10;

select c1 from t1 where ora_rowscn > 0 and c2 > 10 order by c1 desc limit 5;
select * from t2 where c2 > 10 and c3 < 60 and c4 > 40 and ora_rowscn > 0 and c3 > 30 order by c1 desc limit 10;
select * from t3 where c1+c2 > 1000 and ora_rowscn + 1 > 0 and c3+c5 > 2000 order by c1 desc limit 10;

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

select count(ora_rowscn) from t1 where ora_rowscn > 0;
select count(ora_rowscn) from t1 where ora_rowscn + 1 > 0;
select count(ora_rowscn) from t2 where ora_rowscn < 0;
select count(ora_rowscn) from t2 where ora_rowscn - 1 < 0;
select count(ora_rowscn) from t3 where ora_rowscn > 0;

select c1 from t1 where ora_rowscn > 0 and c2 > 10 limit 5;
select c1 from t2 where c2 > 10 and c3 > 1000 and ora_rowscn < 0 limit 5;
select c1 from t3 where c3 + c4 > 1000 and ora_rowscn > 0 and c5 > 1000 limit 5;

select * from t1 where c2 > 10 and c3 < 60 and c4 > 40 and ora_rowscn > 0 and c3 > 30 limit 10;
select * from t2 where c2 > 10 and c3 < 60 and c4 > 40 and ora_rowscn > 0 and c3 > 30 limit 10;
select * from t3 where c2 > 10 and c3 < 60 and c4 > 40 and ora_rowscn > 0 and c3 > 30 limit 10;

select * from t1 where c1+c2 > 1000 and ora_rowscn + 1 > 0 and c3+c5 > 2000 limit 10;
select * from t2 where c1+c2 > 1000 and ora_rowscn + 1 > 0 and c3+c5 > 2000 limit 10;
select * from t3 where c1+c2 > 1000 and ora_rowscn + 1 > 0 and c3+c5 > 2000 limit 10;

select c1 from t1 where ora_rowscn > 0 and c2 > 10 order by c1 desc limit 5;
select * from t2 where c2 > 10 and c3 < 60 and c4 > 40 and ora_rowscn > 0 and c3 > 30 order by c1 desc limit 10;
select * from t3 where c1+c2 > 1000 and ora_rowscn + 1 > 0 and c3+c5 > 2000 order by c1 desc limit 10;

drop table t1;
drop table t2;
drop table t3;
drop table reverse_scn_t;