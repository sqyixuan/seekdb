# owner: dengzhi.ldz
# description: basic test for filter pushdown on writting and query correctness

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (a int auto_increment primary key, b bigint, c char(100), d varchar(1000)) row_format = compressed block_size = 2048;
insert into t1 (b, c, d) values(1, "a", repeat('a', 1000));
insert into t1 (b, c, d) values(2, "ab", repeat("ab", 500));
insert into t1 (b, c, d) values(3, "ab ", repeat("ab ", 300));
insert into t1 (b, c, d) values(4, "ab c", repeat("ab c", 250));
insert into t1 (b, c, d) values(5, "ab c ", repeat("ab c ", 200));
insert into t1 (b, c, d) values(6, "abc ", repeat("abc ", 250));
insert into t1 (b, c, d) values(7, "abcd", repeat("abcd", 250));
insert into t1 (b, c, d) values(8, "abcde", repeat("abcde", 200));
insert into t1 (b, c, d) values(9, "ab c", repeat('ab c', 250));
--let $loop=5
while($loop > 0)
{
  insert into t1 (b, c, d) select b + 1, c, d from t1;
  dec $loop;
}

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--enable_query_log

alter system major freeze tenant all;
--source mysql_test/include/wait_daily_merge.inc

select count(1) from t1;
select count(1) from t1 where c < "ab ";
select count(1) from t1 where c = "ab ";
select count(1) from t1 where c > "ab " order by b desc;
select count(1) from t1 where c > "ab a" order by a;
select count(1) from t1 where c IN ("ab c", "abc");
select count(1) from t1 where c between "abaaa" and "abccc";
select count(1) from t1 where b = 2 and c < "ab ";
select count(1) from t1 where b != 2 and c = "ab " order by b;
select count(1) from t1 where b > 4 and c > "ab ";
select count(1) from t1 where b between 1 and 5 and c > "ab a" order by c;
select count(1) from t1 where a < 100 and b = 9 and c IN ("ab c", "abc");
select count(1) from t1 where b * 2 > 10 and c between "abaaa" and "abccc";
select count(1) from t1 where d between "abaaa" and "abccc";
select b, c from t1 where b = 9 order by a;
select b, c from t1 where c IN ("ab", "abc") order by a desc;

--let $loop=10
while($loop > 0)
{
  insert into t1 (b, c, d) values(9, "ab", repeat("ab", 500));
  dec $loop;
}
insert into t1 (b, c, d) select b, c, d from t1;
insert into t1 (b, c, d) select b + 1, c, d from t1;

select count(1) from t1;
select count(1) from t1 where c < "ab ";
select count(1) from t1 where c = "ab ";
select count(1) from t1 where c > "ab " order by b desc;
select count(1) from t1 where c > "ab a" order by a;
select count(1) from t1 where c IN ("ab c", "abc");
select count(1) from t1 where c between "abaaa" and "abccc";
select count(1) from t1 where b = 2 and c < "ab ";
select count(1) from t1 where b != 2 and c = "ab " order by b;
select count(1) from t1 where b > 4 and c > "ab ";
select count(1) from t1 where b between 1 and 5 and c > "ab a" order by c;
select count(1) from t1 where a < 100 and b = 9 and c IN ("ab c", "abc");
select count(1) from t1 where b * 2 > 10 and c between "abaaa" and "abccc";
select count(1) from t1 where d between "abaaa" and "abccc";
select b, c from t1 where b = 9 order by a;
select b, c from t1 where c IN ("ab", "abc") order by a desc;

connection obsys;
alter system minor freeze tenant = all;
--source mysql_test/include/wait_minor_merge.inc

select count(1) from t1;
select count(1) from t1 where c < "ab ";
select count(1) from t1 where c = "ab ";
select count(1) from t1 where c > "ab " order by b desc;
select count(1) from t1 where c > "ab a" order by a;
select count(1) from t1 where c IN ("ab c", "abc");
select count(1) from t1 where c between "abaaa" and "abccc";
select count(1) from t1 where b = 2 and c < "ab ";
select count(1) from t1 where b != 2 and c = "ab " order by b;
select count(1) from t1 where b > 4 and c > "ab ";
select count(1) from t1 where b between 1 and 5 and c > "ab a" order by c;
select count(1) from t1 where a < 100 and b = 9 and c IN ("ab c", "abc");
select count(1) from t1 where b * 2 > 10 and c between "abaaa" and "abccc";
select count(1) from t1 where d between "abaaa" and "abccc";
select b, c from t1 where b = 9 order by a;
select b, c from t1 where c IN ("ab", "abc") order by a desc;

connection obsys;
alter system major freeze tenant all;
--source mysql_test/include/wait_daily_merge.inc

select count(1) from t1;
select count(1) from t1 where c < "ab ";
select count(1) from t1 where c = "ab ";
select count(1) from t1 where c > "ab " order by b desc;
select count(1) from t1 where c > "ab a" order by a;
select count(1) from t1 where c IN ("ab c", "abc");
select count(1) from t1 where c between "abaaa" and "abccc";
select count(1) from t1 where b = 2 and c < "ab ";
select count(1) from t1 where b != 2 and c = "ab " order by b;
select count(1) from t1 where b > 4 and c > "ab ";
select count(1) from t1 where b between 1 and 5 and c > "ab a" order by c;
select count(1) from t1 where a < 100 and b = 9 and c IN ("ab c", "abc");
select count(1) from t1 where b * 2 > 10 and c between "abaaa" and "abccc";
select count(1) from t1 where d between "abaaa" and "abccc";
select b, c from t1 where b = 9 order by a;
select b, c from t1 where c IN ("ab", "abc") order by a desc;

drop table t1;

--disable_query_log
set global max_allowed_packet=16777216;
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log
