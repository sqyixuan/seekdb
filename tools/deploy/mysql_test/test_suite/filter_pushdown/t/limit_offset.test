# owner: yht146439
# description: pushdown with limit offset

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1 (c1 int auto_increment primary key, c2 bigint, c3 char(100), c4 varchar(1000)) row_format = compressed block_size = 2048;
create table t2 (c1 int auto_increment primary key, c2 bigint, c3 char(100), c4 varchar(1000)) row_format = compressed block_size = 2048 with column group (each column);
insert into t1 (c2,c3,c4) values(1, "a", repeat('a', 1000));
insert into t1 (c2,c3,c4) values(2, "ab", repeat("ab", 500));
insert into t1 (c2,c3,c4) values(3, "ab ", repeat("ab ", 300));
insert into t1 (c2,c3,c4) values(4, "ab c", repeat("ab c", 250));
insert into t1 (c2,c3,c4) values(5, "ab c ", repeat("ab c ", 200));
insert into t1 (c2,c3,c4) values(6, "abc ", repeat("abc ", 250));
insert into t1 (c2,c3,c4) values(7, "abcd", repeat("abcd", 250));
insert into t1 (c2,c3,c4) values(8, "abcde", repeat("abcde", 200));
insert into t1 (c2,c3,c4) values(9, "ab c", repeat('ab c', 250));
--let $loop=4
while($loop > 0)
{
  insert into t1 (c2,c3,c4) select c2 + 1, c3, c4 from t1;
  dec $loop;
}
insert into t2 select * from t1;

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

select c1,c2,c3 from t1 limit 1;
select c1,c2,c3 from t1 limit 1 offset 1;
select c1,c2,c3 from t1 limit 100 offset 100;
# 9223372036854775807 == INT64_MAX
select c1,c2,c3 from t1 limit 9223372036854775807;
select c1,c2,c3 from t1 limit 9223372036854775808;
select c1,c2,c3 from t1 limit 9223372036854775806 offset 1;
select c1,c2,c3 from t1 limit 9223372036854775807 offset 1;
select c1,c2,c3 from t1 limit 9223372036854775807 offset 5;
select c1,c2,c3 from t1 limit 1 offset 9223372036854775806;
select c1,c2,c3 from t1 limit 1 offset 9223372036854775807;
select c1,c2,c3 from t1 limit 5 offset 9223372036854775807;

select c1,c2,c3 from t2 limit 1;
select c1,c2,c3 from t2 limit 1 offset 1;
select c1,c2,c3 from t2 limit 100 offset 100;
select c1,c2,c3 from t2 limit 9223372036854775807;
select c1,c2,c3 from t2 limit 9223372036854775808;
select c1,c2,c3 from t2 limit 9223372036854775806 offset 1;
select c1,c2,c3 from t2 limit 9223372036854775807 offset 1;
select c1,c2,c3 from t2 limit 9223372036854775807 offset 5;
select c1,c2,c3 from t2 limit 1 offset 9223372036854775806;
select c1,c2,c3 from t2 limit 1 offset 9223372036854775807;
select c1,c2,c3 from t2 limit 5 offset 9223372036854775807;

drop table t1;
drop table t2;