# owner: yht146439
#tags: optimizer
# description: test for pushdown multiviersion sst

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

--disable_query_log
create table t1(a int primary key, b int, c date, d varchar(10)) row_format = dynamic block_size = 2048;
create table t2(a int primary key, b int) row_format = compact block_size = 2048;
--let $count = 1
while($count < 2001)
{
  --let $stmt1=insert into t1(a,b,c,d) values ($count,$count,'2022-03-10','aaa');
  --let $stmt2=insert into t2(a,b) values($count,$count);
  eval $stmt1;
  eval $stmt2;
  inc $count;
}
while($count < 4001)
{
  --let $stmt1=insert into t1(a,b,c,d) values ($count,$count,'2022-03-11','bbb');
  --let $stmt2=insert into t2(a,b) values($count,$count);
  eval $stmt1;
  eval $stmt2;
  inc $count;
}

--enable_query_log
select count(1) from t1;
select count(1) from t1 where b > 998;
select count(1) from t1 where a < 20001 and b > 998;
select count(1) from t1 where b/2 > 998;
select count(1) from t1 where c = '2022-03-11';
select count(1) from t1 where d > 'aa';
select count(1) from t1 where b > 500 or c = '2022-03-11';
select count(1) from t1 where b > 500 and d > 'bb';
select count(1) from t2;
select count(1) from t2 where b > 500;
select count(b) from t2 where a < 900 and b > 500;
select count(b) from t2 where a < 100 or b > 990;

alter system minor freeze tenant sys;
--source mysql_test/include/wait_minor_merge.inc

