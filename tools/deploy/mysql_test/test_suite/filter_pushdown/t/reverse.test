# owner: yht146439
#tags: optimizer
# description: test for pushdown in reverse scan

--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_query_log
create table t1(a int primary key, b int, c date, d varchar(10)) row_format = dynamic block_size = 2048;
--let $count = 1
while($count < 2001)
{
  --let $stmt=insert into t1(a,b,c,d) values ($count,$count,'2022-03-10','aaa');
  eval $stmt;
  inc $count;
}
while($count < 3001)
{
  --let $stmt=insert into t1(a,b,c,d) values ($count,$count,'2022-03-11','bbb');
  eval $stmt;
  inc $count;
}

--enable_query_log
select count(1) from t1;
select count(1) from t1 where b > 998;
select count(1) from t1 where a < 20001 and b > 998;
select count(1) from t1 where b/2 > 998;
select count(1) from t1 where c = '2022-03-11';
select count(1) from t1 where d > 'aa';

explain select count(1) from t1 order by a desc;
select count(1) from t1 order by a desc;
select count(1) from t1 where b > 998 order by a desc;
select count(1) from t1 where a < 20001 and b > 998 order by a desc;
select count(1) from t1 where b/2 > 998 order by a desc;
select count(1) from t1 where c = '2022-03-11' order by a desc;
select count(1) from t1 where d > 'aa' order by a desc;

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

--enable_query_log
alter system major freeze tenant sys;
alter system major freeze tenant all_user;
alter system major freeze tenant all_meta;
--source mysql_test/include/wait_daily_merge.inc

select count(1) from t1 order by a desc;
select count(1) from t1 where b > 998 order by a desc;
select count(1) from t1 where a < 20001 and b > 998 order by a desc;
select count(1) from t1 where b/2 > 998 order by a desc;
select count(1) from t1 where c = '2022-03-11' order by a desc;
select count(1) from t1 where d > 'aa' order by a desc;

--disable_query_log
while($count < 4001)
{
  --let $stmt=insert into t1(a,b,c,d) values ($count,$count,'2022-03-12','ccc');
  eval $stmt;
  inc $count;
}

--enable_query_log
select count(1) from t1;
select count(1) from t1 where b > 998;
select count(1) from t1 where a < 20001 and b > 998;
select count(1) from t1 where b/2 > 998;
select count(1) from t1 where c = '2022-03-11';
select count(1) from t1 where d > 'bb';

select count(1) from t1 order by a desc;
select count(1) from t1 where b > 998 order by a desc;
select count(1) from t1 where a < 20001 and b > 998 order by a desc;
select count(1) from t1 where b/2 > 998 order by a desc;
select count(1) from t1 where c = '2022-03-11' order by a desc;
select count(1) from t1 where d > 'bb' order by a desc;

alter system minor freeze tenant sys;
--source mysql_test/include/wait_minor_merge.inc

select count(1) from t1 order by a desc;
select count(1) from t1 where b > 998 order by a desc;
select count(1) from t1 where a < 20001 and b > 998 order by a desc;
select count(1) from t1 where b/2 > 998 order by a desc;
select count(1) from t1 where c = '2022-03-11' order by a desc;
select count(1) from t1 where d > 'bb' order by a desc;

select * from t1 where a > 3500 and b < 3600;
select * from t1 where b > 3900;
select * from t1 where a > 3500 and b < 3600 order by a desc;
select * from t1 where b > 3900 order by a desc;

drop table t1;
