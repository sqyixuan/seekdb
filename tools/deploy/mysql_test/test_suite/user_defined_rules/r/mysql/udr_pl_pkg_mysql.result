result_format: 4
DROP DATABASE IF EXISTS luofan_db;
call dbms_udr.remove_rule('luofan test1');

create database luofan_db;
use luofan_db;
create table t1 (c1 int, c2 int);
insert into t1 values (1, 2);
insert into t1 values (1, 3);
insert into t1 values (2, 1);
insert into t1 values (3, 1);

***************** case 1 test create rule *****************
PROCEDURE CREATE_RULE (
rule_name          VARCHAR(256),
rule_owner_name    VARCHAR(128),
pattern            LONGTEXT,
replacement        LONGTEXT,
enabled            BOOLEAN DEFAULT TRUE
);
call dbms_udr.create_rule('luofan test1',
                          'luofan_db',
                          'select * from t1 where c1 = :A',
                          'select * from t1 where c1 = :A + :A');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;
+-----------+--------------+--------------------------------+-------------------------------------+-------------------------------+--------+----------------------+
| DB_NAME   | RULE_NAME    | PATTERN                        | REPLACEMENT                         | NORMALIZED_PATTERN            | STATUS | PATTERN_DIGEST       |
+-----------+--------------+--------------------------------+-------------------------------------+-------------------------------+--------+----------------------+
| luofan_db | luofan test1 | select * from t1 where c1 = :A | select * from t1 where c1 = :A + :A | select * from t1 where c1 = ? | ENABLE | 14130884354988097567 |
+-----------+--------------+--------------------------------+-------------------------------------+-------------------------------+--------+----------------------+

***************** case 1 test disable rule *****************
PROCEDURE DISABLE_RULE (
rule_name          VARCHAR(256)
);
call dbms_udr.disable_rule('luofan test1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;
+-----------+--------------+--------------------------------+-------------------------------------+-------------------------------+---------+----------------------+
| DB_NAME   | RULE_NAME    | PATTERN                        | REPLACEMENT                         | NORMALIZED_PATTERN            | STATUS  | PATTERN_DIGEST       |
+-----------+--------------+--------------------------------+-------------------------------------+-------------------------------+---------+----------------------+
| luofan_db | luofan test1 | select * from t1 where c1 = :A | select * from t1 where c1 = :A + :A | select * from t1 where c1 = ? | DISABLE | 14130884354988097567 |
+-----------+--------------+--------------------------------+-------------------------------------+-------------------------------+---------+----------------------+

***************** case 1 test enable rule *****************
PROCEDURE ENABLE_RULE (
rule_name          VARCHAR(256)
);
call dbms_udr.enable_rule('luofan test1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;
+-----------+--------------+--------------------------------+-------------------------------------+-------------------------------+--------+----------------------+
| DB_NAME   | RULE_NAME    | PATTERN                        | REPLACEMENT                         | NORMALIZED_PATTERN            | STATUS | PATTERN_DIGEST       |
+-----------+--------------+--------------------------------+-------------------------------------+-------------------------------+--------+----------------------+
| luofan_db | luofan test1 | select * from t1 where c1 = :A | select * from t1 where c1 = :A + :A | select * from t1 where c1 = ? | ENABLE | 14130884354988097567 |
+-----------+--------------+--------------------------------+-------------------------------------+-------------------------------+--------+----------------------+

***************** case 1 test remove rule *****************
PROCEDURE REMOVE_RULE (
rule_name          VARCHAR(256)
);
call dbms_udr.remove_rule('luofan test1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;
+---------+-----------+---------+-------------+--------------------+--------+----------------+
| DB_NAME | RULE_NAME | PATTERN | REPLACEMENT | NORMALIZED_PATTERN | STATUS | PATTERN_DIGEST |
+---------+-----------+---------+-------------+--------------------+--------+----------------+
+---------+-----------+---------+-------------+--------------------+--------+----------------+

DROP DATABASE IF EXISTS luofan_db;

