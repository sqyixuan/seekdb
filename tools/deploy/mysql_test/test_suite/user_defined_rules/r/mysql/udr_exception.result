result_format: 4
alter system flush plan cache global;
alter system set enable_user_defined_rewrite_rules = 'True';

DROP DATABASE IF EXISTS luofan_db1;
call dbms_udr.remove_rule('luofan test1');

create database luofan_db1;
use luofan_db1;
create table t1 (c1 int, c2 int);
insert into t1 values (1, 2);
insert into t1 values (1, 3);
insert into t1 values (2, 1);
insert into t1 values (3, 1);

#***************** 创建规则时?跟:{num}混用 *****************
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select ?, :1 from dual',
                          'select ?, :1 + 1 from dual');
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use

#***************** 规则支持的SQL类型 *****************
#支持SELECT,INSERT,REPLACE,MERGE,DELETE,UPDATE,VARIABLE_SET
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'commit',
                          'set autocommit = 1');
ERROR 0A000: SQL types in user defined rule not supported

#***************** 创建规则时pattern:{num} *****************
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select :1, :1, :2 from dual',
                          'select :1 + 1, :1 + 1, :2 + 1 from dual');
ERROR 0A000: binding methods not supported

#***************** pattern跟replacement参数个数不匹配 ***********
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select :A, :A, :B from dual',
                          'select :A + 1, :A + 1, :B + 1, :C from dual');
ERROR 0A000: the number of question marks is not equal not supported
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select ?, ?, ? from dual',
                          'select ?, ?, ?, ? from dual');
ERROR 0A000: the number of question marks is not equal not supported
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select ?, ?, ? from dual',
                          'select ?, ? from dual');
ERROR 0A000: the number of question marks is not equal not supported

#***************** pattern定义中包含-?或者-{:num} ***************
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - ? + ? from dual',
                          'select ?, ? from dual');
ERROR 0A000: template statement type not supported

call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - ? * 3 from dual',
                          'select ?, 1 from dual');
ERROR 0A000: template statement type not supported
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - ? / 3 from dual',
                          'select ?, 1 from dual');
ERROR 0A000: template statement type not supported

call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - ? / 3 / 4 from dual',
                          'select ?, 1 from dual');
ERROR 0A000: template statement type not supported
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - :1 + :2 from dual',
                          'select :1, :2 from dual');
ERROR 0A000: template statement type not supported

call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - :1 * 3 from dual',
                          'select :1, 1 from dual');
ERROR 0A000: template statement type not supported
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - :A / 3 from dual',
                          'select :A, 1 from dual');
ERROR 0A000: template statement type not supported

call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - :A / 3 / 4 from dual',
                          'select :A, 1 from dual');
ERROR 0A000: template statement type not supported

#***************** 规则名称重复 *****************
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select ?, ? from dual',
                          'select ?, ? + 1 from dual');

call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select ?, ? + 1 from dual',
                          'select ?, ? + 2 from dual');
ERROR 23000: Duplicate entry 'luofan test1' for key 'PRIMARY'

call dbms_udr.remove_rule('luofan test1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;
+---------+-----------+---------+-------------+--------------------+--------+----------------+
| DB_NAME | RULE_NAME | PATTERN | REPLACEMENT | NORMALIZED_PATTERN | STATUS | PATTERN_DIGEST |
+---------+-----------+---------+-------------+--------------------+--------+----------------+
+---------+-----------+---------+-------------+--------------------+--------+----------------+

alter system set enable_user_defined_rewrite_rules = false;

DROP DATABASE IF EXISTS luofan_db1;
