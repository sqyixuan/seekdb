result_format: 4
alter system flush plan cache global;
alter system set enable_user_defined_rewrite_rules = true;
DROP DATABASE IF EXISTS luofan_db1;
DROP DATABASE IF EXISTS luofan_db2;
call dbms_udr.remove_rule('luofan test1');

create database luofan_db1;
create database luofan_db2;
use luofan_db1;
create table t1 (c1 int, c2 int);
insert into t1 values (1, 2);
insert into t1 values (1, 3);
insert into t1 values (2, 1);
insert into t1 values (3, 1);

***************** create rule *****************
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select c1, :A + 1, 1 from t1 where c1 = :B',
                          'select c1, :A + 2, :B + 1 from t1 where c1 = :B + 1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;
+------------+--------------+--------------------------------------------+-----------------------------------------------------+------------------------------------------+--------+----------------------+
| DB_NAME    | RULE_NAME    | PATTERN                                    | REPLACEMENT                                         | NORMALIZED_PATTERN                       | STATUS | PATTERN_DIGEST       |
+------------+--------------+--------------------------------------------+-----------------------------------------------------+------------------------------------------+--------+----------------------+
| luofan_db1 | luofan test1 | select c1, :A + 1, 1 from t1 where c1 = :B | select c1, :A + 2, :B + 1 from t1 where c1 = :B + 1 | select c1, ? + ?, ? from t1 where c1 = ? | ENABLE | 13362529231556223759 |
+------------+--------------+--------------------------------------------+-----------------------------------------------------+------------------------------------------+--------+----------------------+

select c1, c2 from t1;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    2 |
|    1 |    3 |
|    2 |    1 |
|    3 |    1 |
+------+------+
#测试命中改写规则
select c1, 1 + 1, 1 from t1 where c1 = 0;
+------+--------+--------+
| c1   | :A + 2 | :B + 1 |
+------+--------+--------+
|    1 |      3 |      1 |
|    1 |      3 |      1 |
+------+--------+--------+
select c1, 1 + 1, 1 from t1 where c1 = 1;
+------+--------+--------+
| c1   | :A + 2 | :B + 1 |
+------+--------+--------+
|    2 |      3 |      2 |
+------+--------+--------+
select c1, 1 + 1, 1 from t1 where c1 = 2;
+------+--------+--------+
| c1   | :A + 2 | :B + 1 |
+------+--------+--------+
|    3 |      3 |      3 |
+------+--------+--------+
select c1, 1 + 1, 1 from t1 where c1 = 3;
+------+--------+--------+
| c1   | :A + 2 | :B + 1 |
+------+--------+--------+
+------+--------+--------+

#测试规则匹配常量值
select c1, 1 + 1, 2 from t1 where c1 = 0;
+------+-------+---+
| c1   | 1 + 1 | 2 |
+------+-------+---+
+------+-------+---+
select c1, 1 + 1, 3 from t1 where c1 = 1;
+------+-------+---+
| c1   | 1 + 1 | 3 |
+------+-------+---+
|    1 |     2 | 3 |
|    1 |     2 | 3 |
+------+-------+---+
select c1, 1 + 1, 4 from t1 where c1 = 2;
+------+-------+---+
| c1   | 1 + 1 | 4 |
+------+-------+---+
|    2 |     2 | 4 |
+------+-------+---+
select c1, 1 + 1, 5 from t1 where c1 = 3;
+------+-------+---+
| c1   | 1 + 1 | 5 |
+------+-------+---+
|    3 |     2 | 5 |
+------+-------+---+

#测试匹配rule_owner_name
use luofan_db2;
create table t1 (c1 int, c2 int);
insert into t1 values (1, 2);
insert into t1 values (1, 3);
insert into t1 values (2, 1);
insert into t1 values (3, 1);
select c1, c2 from t1;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    2 |
|    1 |    3 |
|    2 |    1 |
|    3 |    1 |
+------+------+

#测试因为rule_owner_name不同，不能命中改写规则
select c1, 1 + 1, 1 from t1 where c1 = 0;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
+------+-------+---+
select c1, 1 + 1, 1 from t1 where c1 = 1;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
|    1 |     2 | 1 |
|    1 |     2 | 1 |
+------+-------+---+
select c1, 1 + 1, 1 from t1 where c1 = 2;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
|    2 |     2 | 1 |
+------+-------+---+
select c1, 1 + 1, 1 from t1 where c1 = 3;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
|    3 |     2 | 1 |
+------+-------+---+

***************** disable rule *****************
use luofan_db1;
call dbms_udr.disable_rule('luofan test1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;
+------------+--------------+--------------------------------------------+-----------------------------------------------------+------------------------------------------+---------+----------------------+
| DB_NAME    | RULE_NAME    | PATTERN                                    | REPLACEMENT                                         | NORMALIZED_PATTERN                       | STATUS  | PATTERN_DIGEST       |
+------------+--------------+--------------------------------------------+-----------------------------------------------------+------------------------------------------+---------+----------------------+
| luofan_db1 | luofan test1 | select c1, :A + 1, 1 from t1 where c1 = :B | select c1, :A + 2, :B + 1 from t1 where c1 = :B + 1 | select c1, ? + ?, ? from t1 where c1 = ? | DISABLE | 13362529231556223759 |
+------------+--------------+--------------------------------------------+-----------------------------------------------------+------------------------------------------+---------+----------------------+
select c1, c2 from t1;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    2 |
|    1 |    3 |
|    2 |    1 |
|    3 |    1 |
+------+------+
#测试disable规则之后不能命中改写规则
select c1, 1 + 1, 1 from t1 where c1 = 0;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
+------+-------+---+
select c1, 1 + 1, 1 from t1 where c1 = 1;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
|    1 |     2 | 1 |
|    1 |     2 | 1 |
+------+-------+---+
select c1, 1 + 1, 1 from t1 where c1 = 2;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
|    2 |     2 | 1 |
+------+-------+---+
select c1, 1 + 1, 1 from t1 where c1 = 3;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
|    3 |     2 | 1 |
+------+-------+---+

***************** enable rule *****************
call dbms_udr.enable_rule('luofan test1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;
+------------+--------------+--------------------------------------------+-----------------------------------------------------+------------------------------------------+--------+----------------------+
| DB_NAME    | RULE_NAME    | PATTERN                                    | REPLACEMENT                                         | NORMALIZED_PATTERN                       | STATUS | PATTERN_DIGEST       |
+------------+--------------+--------------------------------------------+-----------------------------------------------------+------------------------------------------+--------+----------------------+
| luofan_db1 | luofan test1 | select c1, :A + 1, 1 from t1 where c1 = :B | select c1, :A + 2, :B + 1 from t1 where c1 = :B + 1 | select c1, ? + ?, ? from t1 where c1 = ? | ENABLE | 13362529231556223759 |
+------------+--------------+--------------------------------------------+-----------------------------------------------------+------------------------------------------+--------+----------------------+
select c1, c2 from t1;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    2 |
|    1 |    3 |
|    2 |    1 |
|    3 |    1 |
+------+------+
#测试enable规则之后命中改写规则
select c1, 1 + 1, 1 from t1 where c1 = 0;
+------+--------+--------+
| c1   | :A + 2 | :B + 1 |
+------+--------+--------+
|    1 |      3 |      1 |
|    1 |      3 |      1 |
+------+--------+--------+
select c1, 1 + 1, 1 from t1 where c1 = 1;
+------+--------+--------+
| c1   | :A + 2 | :B + 1 |
+------+--------+--------+
|    2 |      3 |      2 |
+------+--------+--------+
select c1, 1 + 1, 1 from t1 where c1 = 2;
+------+--------+--------+
| c1   | :A + 2 | :B + 1 |
+------+--------+--------+
|    3 |      3 |      3 |
+------+--------+--------+
select c1, 1 + 1, 1 from t1 where c1 = 3;
+------+--------+--------+
| c1   | :A + 2 | :B + 1 |
+------+--------+--------+
+------+--------+--------+

alter system set enable_user_defined_rewrite_rules = false;
***************** disable udr *****************
#测试disable udr之后不能命中改写规则
select c1, 1 + 1, 1 from t1 where c1 = 0;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
+------+-------+---+
select c1, 1 + 1, 1 from t1 where c1 = 1;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
|    1 |     2 | 1 |
|    1 |     2 | 1 |
+------+-------+---+
select c1, 1 + 1, 1 from t1 where c1 = 2;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
|    2 |     2 | 1 |
+------+-------+---+
select c1, 1 + 1, 1 from t1 where c1 = 3;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
|    3 |     2 | 1 |
+------+-------+---+

alter system set enable_user_defined_rewrite_rules = true;
***************** enable udr *****************
#测试enable udr之后命中改写规则
select c1, 1 + 1, 1 from t1 where c1 = 0;
+------+--------+--------+
| c1   | :A + 2 | :B + 1 |
+------+--------+--------+
|    1 |      3 |      1 |
|    1 |      3 |      1 |
+------+--------+--------+
select c1, 1 + 1, 1 from t1 where c1 = 1;
+------+--------+--------+
| c1   | :A + 2 | :B + 1 |
+------+--------+--------+
|    2 |      3 |      2 |
+------+--------+--------+
select c1, 1 + 1, 1 from t1 where c1 = 2;
+------+--------+--------+
| c1   | :A + 2 | :B + 1 |
+------+--------+--------+
|    3 |      3 |      3 |
+------+--------+--------+
select c1, 1 + 1, 1 from t1 where c1 = 3;
+------+--------+--------+
| c1   | :A + 2 | :B + 1 |
+------+--------+--------+
+------+--------+--------+

***************** remove rule *****************
call dbms_udr.remove_rule('luofan test1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;
+---------+-----------+---------+-------------+--------------------+--------+----------------+
| DB_NAME | RULE_NAME | PATTERN | REPLACEMENT | NORMALIZED_PATTERN | STATUS | PATTERN_DIGEST |
+---------+-----------+---------+-------------+--------------------+--------+----------------+
+---------+-----------+---------+-------------+--------------------+--------+----------------+
select c1, c2 from t1;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    2 |
|    1 |    3 |
|    2 |    1 |
|    3 |    1 |
+------+------+
#测试删除规则之后不能命中改写规则
select c1, 1 + 1, 1 from t1 where c1 = 0;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
+------+-------+---+
select c1, 1 + 1, 1 from t1 where c1 = 1;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
|    1 |     2 | 1 |
|    1 |     2 | 1 |
+------+-------+---+
select c1, 1 + 1, 1 from t1 where c1 = 2;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
|    2 |     2 | 1 |
+------+-------+---+
select c1, 1 + 1, 1 from t1 where c1 = 3;
+------+-------+---+
| c1   | 1 + 1 | 1 |
+------+-------+---+
|    3 |     2 | 1 |
+------+-------+---+

alter system set enable_user_defined_rewrite_rules = false;

DROP DATABASE IF EXISTS luofan_db1;
DROP DATABASE IF EXISTS luofan_db2;
