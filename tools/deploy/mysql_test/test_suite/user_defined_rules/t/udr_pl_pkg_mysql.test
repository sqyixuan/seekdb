--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: luofan.zp
#owner group: SQL2
#description:
#
#tags: user defined rules pl pkg

--result_format 4

--disable_warnings
DROP DATABASE IF EXISTS luofan_db;
--enable_warnings
call dbms_udr.remove_rule('luofan test1');

create database luofan_db;
use luofan_db;
create table t1 (c1 int, c2 int);
insert into t1 values (1, 2);
insert into t1 values (1, 3);
insert into t1 values (2, 1);
insert into t1 values (3, 1);

--echo ***************** case 1 test create rule *****************
--echo  PROCEDURE CREATE_RULE (
--echo    rule_name          VARCHAR(256),
--echo    rule_owner_name    VARCHAR(128),
--echo    pattern            LONGTEXT,
--echo    replacement        LONGTEXT,
--echo    enabled            BOOLEAN DEFAULT TRUE
--echo  );
call dbms_udr.create_rule('luofan test1',
                          'luofan_db',
                          'select * from t1 where c1 = :A',
                          'select * from t1 where c1 = :A + :A');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;


--echo ***************** case 1 test disable rule *****************
--echo  PROCEDURE DISABLE_RULE (
--echo    rule_name          VARCHAR(256)
--echo  );
call dbms_udr.disable_rule('luofan test1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;

--echo ***************** case 1 test enable rule *****************
--echo  PROCEDURE ENABLE_RULE (
--echo    rule_name          VARCHAR(256)
--echo  );
call dbms_udr.enable_rule('luofan test1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;


--echo ***************** case 1 test remove rule *****************
--echo  PROCEDURE REMOVE_RULE (
--echo    rule_name          VARCHAR(256)
--echo  );
call dbms_udr.remove_rule('luofan test1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;


--disable_warnings
DROP DATABASE IF EXISTS luofan_db;
--enable_warnings


