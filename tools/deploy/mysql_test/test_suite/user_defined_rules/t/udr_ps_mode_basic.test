--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: luofan.zp
#owner group: SQL2
#description:
#
#tags: user defined rules basic

connect(obsys, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, oceanbase, $OBMYSQL_PORT);

--result_format 4
connection obsys;
alter system flush plan cache global;
connection default;
alter system set enable_user_defined_rewrite_rules = 'True';

--disable_warnings
DROP DATABASE IF EXISTS luofan_db1;
DROP DATABASE IF EXISTS luofan_db2;
--enable_warnings
call dbms_udr.remove_rule('luofan test1');
call dbms_udr.remove_rule('luofan test2');

create database luofan_db1;
create database luofan_db2;
use luofan_db1;
create table t1 (c1 int, c2 int);
insert into t1 values (1, 2);
insert into t1 values (1, 3);
insert into t1 values (2, 1);
insert into t1 values (3, 1);

--echo ***************** create rule *****************
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select c1, :A + 1, 1 from t1 where c1 = :B',
                          'select c1, :A + 2, :B + 1 from t1 where c1 = :B + 1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;

--sleep 8
select c1, c2 from t1;
--echo #测试命中改写规则
prepare stmt from 'select c1, ? + 1, 1 from t1 where c1 = ?';
set @i1 = 1;
set @i2 = 0;
execute stmt using @i1, @i2;
set @i2 = 1;
execute stmt using @i1, @i2;
set @i2 = 2;
execute stmt using @i1, @i2;
set @i2 = 3;
execute stmt using @i1, @i2;


--echo #测试规则匹配常量值
prepare stmt from 'select c1, ? + 1, 2 from t1 where c1 = ?';
set @i1 = 1;
set @i2 = 0;
execute stmt using @i1, @i2;
set @i2 = 1;
execute stmt using @i1, @i2;
set @i2 = 2;
execute stmt using @i1, @i2;
set @i2 = 3;
execute stmt using @i1, @i2;

--echo #测试匹配rule_owner_name
use luofan_db2;
create table t1 (c1 int, c2 int);
insert into t1 values (1, 2);
insert into t1 values (1, 3);
insert into t1 values (2, 1);
insert into t1 values (3, 1);
select c1, c2 from t1;

--echo #测试因为rule_owner_name不同，不能命中改写规则
prepare stmt from 'select c1, ? + 1, 1 from t1 where c1 = ?';
set @i1 = 1;
set @i2 = 0;
execute stmt using @i1, @i2;
set @i2 = 1;
execute stmt using @i1, @i2;
set @i2 = 2;
execute stmt using @i1, @i2;
set @i2 = 3;
execute stmt using @i1, @i2;


--echo ***************** disable rule *****************
use luofan_db1;
call dbms_udr.disable_rule('luofan test1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;
--sleep 8
select c1, c2 from t1;
--echo #测试disable规则之后不能命中改写规则
prepare stmt from 'select c1, ? + 1, 1 from t1 where c1 = ?';
set @i1 = 1;
set @i2 = 0;
execute stmt using @i1, @i2;
set @i2 = 1;
execute stmt using @i1, @i2;
set @i2 = 2;
execute stmt using @i1, @i2;
set @i2 = 3;
execute stmt using @i1, @i2;

--echo ***************** enable rule *****************
call dbms_udr.enable_rule('luofan test1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;
--sleep 8
select c1, c2 from t1;
--echo #测试enable规则之后命中改写规则
prepare stmt from 'select c1, ? + 1, 1 from t1 where c1 = ?';
set @i1 = 1;
set @i2 = 0;
execute stmt using @i1, @i2;
set @i2 = 1;
execute stmt using @i1, @i2;
set @i2 = 2;
execute stmt using @i1, @i2;
set @i2 = 3;
execute stmt using @i1, @i2;



--echo ***************** remove rule *****************
call dbms_udr.remove_rule('luofan test1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;
--sleep 8
select c1, c2 from t1;
--echo #测试删除规则之后不能命中改写规则
prepare stmt from 'select c1, ? + 1, 1 from t1 where c1 = ?';
set @i1 = 1;
set @i2 = 0;
execute stmt using @i1, @i2;
set @i2 = 1;
execute stmt using @i1, @i2;
set @i2 = 2;
execute stmt using @i1, @i2;
set @i2 = 3;
execute stmt using @i1, @i2;


--echo ***************** create rule *****************
call dbms_udr.create_rule('luofan test2',
                          'luofan_db1',
                          'select ?, 1 from dual',
                          'select ? * 10, 2 from dual');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;

--echo #测试能命中规则
prepare stmt from 'select 2, 1 from dual';
execute stmt;
prepare stmt from 'select 3, 1 from dual';
execute stmt;
--echo #测试匹配常量不能命中规则
prepare stmt from 'select 2, 2 from dual';
execute stmt;
prepare stmt from 'select 3, 2 from dual';
execute stmt;

--enable_warnings
call dbms_udr.remove_rule('luofan test1');
call dbms_udr.remove_rule('luofan test2');

connection obsys;
alter system set enable_user_defined_rewrite_rules = false;

connection default;
alter system set enable_user_defined_rewrite_rules = false;
--disable_warnings
DROP DATABASE IF EXISTS luofan_db1;
DROP DATABASE IF EXISTS luofan_db2;
--enable_warnings
