--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: luofan.zp
#owner group: SQL2
#description:
#
#tags: user defined rules exception

connect(obsys, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, oceanbase, $OBMYSQL_PORT);

--result_format 4
connection obsys;
alter system flush plan cache global;
connection default;
alter system set enable_user_defined_rewrite_rules = 'True';

--disable_warnings
DROP DATABASE IF EXISTS luofan_db1;
--enable_warnings
call dbms_udr.remove_rule('luofan test1');

create database luofan_db1;
use luofan_db1;
create table t1 (c1 int, c2 int);
insert into t1 values (1, 2);
insert into t1 values (1, 3);
insert into t1 values (2, 1);
insert into t1 values (3, 1);

--echo #***************** 创建规则时?跟:{num}混用 *****************
--error 1149
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select ?, :1 from dual',
                          'select ?, :1 + 1 from dual');

--echo #***************** 规则支持的SQL类型 *****************
--echo #支持SELECT,INSERT,REPLACE,MERGE,DELETE,UPDATE,VARIABLE_SET
--error 1235
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'commit',
                          'set autocommit = 1');

--echo #***************** 创建规则时pattern:{num} *****************
--error 1235
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select :1, :1, :2 from dual',
                          'select :1 + 1, :1 + 1, :2 + 1 from dual');


--echo #***************** pattern跟replacement参数个数不匹配 ***********
--error 1235
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select :A, :A, :B from dual',
                          'select :A + 1, :A + 1, :B + 1, :C from dual');
--error 1235
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select ?, ?, ? from dual',
                          'select ?, ?, ?, ? from dual');
--error 1235
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select ?, ?, ? from dual',
                          'select ?, ? from dual');


--echo #***************** pattern定义中包含-?或者-{:num} ***************
--error 1235
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - ? + ? from dual',
                          'select ?, ? from dual');

--error 1235
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - ? * 3 from dual',
                          'select ?, 1 from dual');
--error 1235
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - ? / 3 from dual',
                          'select ?, 1 from dual');

--error 1235
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - ? / 3 / 4 from dual',
                          'select ?, 1 from dual');
--error 1235
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - :1 + :2 from dual',
                          'select :1, :2 from dual');

--error 1235
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - :1 * 3 from dual',
                          'select :1, 1 from dual');
--error 1235
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - :A / 3 from dual',
                          'select :A, 1 from dual');

--error 1235
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select 1 - :A / 3 / 4 from dual',
                          'select :A, 1 from dual');

--echo #***************** 规则名称重复 *****************
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select ?, ? from dual',
                          'select ?, ? + 1 from dual');

--error 1062
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select ?, ? + 1 from dual',
                          'select ?, ? + 2 from dual');


call dbms_udr.remove_rule('luofan test1');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES;

alter system set enable_user_defined_rewrite_rules = false;

connection default;
--disable_warnings
DROP DATABASE IF EXISTS luofan_db1;
--enable_warnings
