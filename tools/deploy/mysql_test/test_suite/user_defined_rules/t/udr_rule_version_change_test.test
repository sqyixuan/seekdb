--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: luofan.zp
#owner group: SQL2
#description:
#
#tags: user defined rules version change test

connect(obsys, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, oceanbase, $OBMYSQL_PORT);

--result_format 4
connection obsys;
alter system flush plan cache global;
alter system flush sql audit global;
connection default;
alter system set enable_user_defined_rewrite_rules = true;

--sleep 6

--disable_warnings
DROP DATABASE IF EXISTS luofan_db1;
--enable_warnings
call dbms_udr.remove_rule('luofan test1');

create database luofan_db1;
use luofan_db1;

--echo ***************** create rule *****************
call dbms_udr.create_rule('luofan test1',
                          'luofan_db1',
                          'select ? from dual',
                          'select ? + 1 from dual');
select DB_NAME, RULE_NAME, PATTERN, REPLACEMENT, NORMALIZED_PATTERN, STATUS, PATTERN_DIGEST from oceanbase.DBA_OB_USER_DEFINED_RULES where DB_NAME='luofan_db1';

--echo #plan cache preheating
select 1 from dual;
select 1 * 1 from dual;

--echo #expect 0
select query_sql, is_hit_plan from oceanbase.gv$ob_sql_audit where query_sql = 'select 1 from dual';
select query_sql, is_hit_plan from oceanbase.gv$ob_sql_audit where query_sql = 'select 1 * 1 from dual';


--echo #test hit plan cache
select 1 from dual;
select 1 * 1 from dual;

--echo #expect 0, 1
select query_sql, is_hit_plan from oceanbase.gv$ob_sql_audit where query_sql = 'select 1 from dual';
select query_sql, is_hit_plan from oceanbase.gv$ob_sql_audit where query_sql = 'select 1 * 1 from dual';

--echo #push up the rule version
call dbms_udr.enable_rule('luofan test1');
select 1 from dual;
select 1 * 1 from dual;

--echo #expect 0, 1, 0
select query_sql, is_hit_plan from oceanbase.gv$ob_sql_audit where query_sql = 'select 1 from dual';

--echo #expect 0, 1, 1
select query_sql, is_hit_plan from oceanbase.gv$ob_sql_audit where query_sql = 'select 1 * 1 from dual';

alter system set enable_user_defined_rewrite_rules = false;
--sleep 6

select 1 from dual;
select 1 * 1 from dual;

--echo #expect 0, 1, 0, 0
select query_sql, is_hit_plan from oceanbase.gv$ob_sql_audit where query_sql = 'select 1 from dual';

--echo #expect 0, 1, 1, 1
select query_sql, is_hit_plan from oceanbase.gv$ob_sql_audit where query_sql = 'select 1 * 1 from dual';

--disable_warnings
DROP DATABASE IF EXISTS luofan_db1;
call dbms_udr.remove_rule('luofan test1');
--enable_warnings
