### Q3 空值、边界值测试
select hour(null),hour(null),hour(null) from dual ;
hour(null)	hour(null)	hour(null)
NULL	NULL	NULL
select hour(''),hour(''),hour('') from dual;
hour('')	hour('')	hour('')
NULL	NULL	NULL
Warnings:
Warning	5086	Not timestamp Can not cast varchar value to timestamp type
select hour('0000-0-0');
hour('0000-0-0')
0
