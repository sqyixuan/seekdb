### Q1 最基本测试
SELECT HOUR('10:05:03') from dual;
HOUR('10:05:03')
10
SELECT HOUR('272:59:59') from dual;
HOUR('272:59:59')
272
select hour('2018-10-15 14:37:00') from dual;
hour('2018-10-15 14:37:00')
14
select hour(cast('2018-10-15 14:37:00' as char)) from dual;
hour(cast('2018-10-15 14:37:00' as char))
14
