alter table t1 add column c_e8tmk double;
create view t_i as 
select  
    ref_0.c2 as c0, 
    case when (ref_0.c1 between ref_0.c1 and (select c1 from t1 order by c1 limit 1 offset 2)
          ) then ref_0.c1 else case when (cast(nullif(
            ref_0.c1, 
            ref_0.c1
            ) as signed) between ref_0.c1 and ref_0.c1) then ref_0.c1 else ref_0.c1 end
         end
       as c1, 
    ref_0.c1 as c2
  from 
    t1 as ref_0
  where 1=1;
