create table func_t2(c1 datetime(6), c2 time(6), c3 varchar(100), c4 varchar(100));
insert into func_t2 values(null, null, null, null);
insert into func_t2 values('2018-6-14 22:28:00.4444', '12:00:40.0400', '2019-12-1 1:23:45.6', '1 4:5:6.4');
