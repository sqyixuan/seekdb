insert into func_t2 values('2008-6-24 12:28:00.44244', '2:05:00.5000', '2019-11-31 1:2:45.46', '3 14:5:6.0');
insert into func_t2 values('2018-1-14 12:18:00.44444', '5:00:6.4000', '2019-1-31 1:23:5.56', '4 5:26:7.');
