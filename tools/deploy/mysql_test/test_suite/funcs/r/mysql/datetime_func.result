result_format: 4
drop database if exists datetime_func_db;
create database datetime_func_db;
use datetime_func_db;

create table func_t1(c1 datetime, c2 date, c3 timestamp(6) null, c4 varchar(100), c5 int);

insert into func_t1 values('2018-6-4 9:24:00', '2018-6-4', '2018-6-4 9:24:45.432', '2018-2-27 6:01:59', 20180604);
insert into func_t1 values(null, null, null, null, null);
insert into func_t1 values('1970-1-1 0:0:0', '1970-1-1', '1971-1-1 1:0:2.000', '1970-1-1', 19700101);
commit;

