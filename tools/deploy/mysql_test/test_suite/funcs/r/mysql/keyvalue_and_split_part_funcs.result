drop table if exists funcs_test;
create table funcs_test(
dict_str varchar(512) CHARACTER SET utf8mb4,
dict_text longtext CHARACTER SET gbk,
delimiter_str varchar(512) CHARACTER SET utf16
);
insert into funcs_test values ('组别:sql;姓名:xx;年龄:20;', '组别:sql;姓名:xx;年龄:20;', ';');
select keyvalue(dict_str, '年龄') from funcs_test;
keyvalue(dict_str, '年龄')
20
select keyvalue(dict_str, ';', ':', '年龄') from funcs_test;
keyvalue(dict_str, ';', ':', '年龄')
20
select keyvalue(dict_str, ';', ':', '性别') from funcs_test;
keyvalue(dict_str, ';', ':', '性别')
NULL
select keyvalue(dict_str, '', '', '年龄') from funcs_test;
keyvalue(dict_str, '', '', '年龄')
NULL
select keyvalue(dict_str, '', '', '性别') from funcs_test;
keyvalue(dict_str, '', '', '性别')
NULL
select keyvalue(dict_text, '年龄') from funcs_test;
keyvalue(dict_text, '年龄')
20
select keyvalue(dict_text, ';', ':', '年龄') from funcs_test;
keyvalue(dict_text, ';', ':', '年龄')
20
select keyvalue(dict_text, ';', ':', '性别') from funcs_test;
keyvalue(dict_text, ';', ':', '性别')
NULL
select keyvalue(dict_text, NULL, '', '年龄') from funcs_test;
keyvalue(dict_text, NULL, '', '年龄')
NULL
select keyvalue(dict_text, '', '', '年龄') from funcs_test;
keyvalue(dict_text, '', '', '年龄')
NULL
select keyvalue(dict_text, '', '', '性别') from funcs_test;
keyvalue(dict_text, '', '', '性别')
NULL
select split_part(dict_str, ';', 1) from funcs_test;
split_part(dict_str, ';', 1)
组别:sql
select split_part(dict_str, ';', -1) from funcs_test;
split_part(dict_str, ';', -1)

select split_part(dict_str, ';', 4) from funcs_test;
split_part(dict_str, ';', 4)

select split_part(dict_text, '', 1) from funcs_test;
split_part(dict_text, '', 1)
组别:sql;姓名:xx;年龄:20;
