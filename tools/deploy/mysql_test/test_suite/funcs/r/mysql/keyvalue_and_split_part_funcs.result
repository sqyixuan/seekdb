SELECT
CASE
WHEN 1 = 1 THEN subq_0.c0
ELSE subq_0.c0
END
FROM
(SELECT keyvalue('1', '1') AS c0 FROM DUAL) subq_0;
CASE
WHEN 1 = 1 THEN subq_0.c0
ELSE subq_0.c0
END
NULL
SELECT 
CASE 
WHEN 1 = 1 THEN subq_0.c0 
ELSE subq_0.c0 
END 
FROM 
(SELECT split_part('1,2,3', ',', 1) AS c0 FROM DUAL) subq_0;
CASE 
WHEN 1 = 1 THEN subq_0.c0 
ELSE subq_0.c0 
END
1
drop table if exists funcs_test;
