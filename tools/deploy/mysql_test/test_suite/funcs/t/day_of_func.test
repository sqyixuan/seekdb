select dayofmonth('2004-2-29')  from dual;
select dayofmonth('1582-10-4') from dual;
select dayofmonth('1582-10-5') from dual;
select dayofmonth('1582-10-15')  from dual;
select dayofmonth('0000-1-1') ,dayofweek('0001-1-1')  from dual;
