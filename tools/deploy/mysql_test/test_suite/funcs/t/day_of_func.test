select dayofyear('1582-10-5') from dual;
select dayofyear('1582-10-15')  from dual;
select dayofyear('0000-1-1'), dayofyear('0001-1-1') from dual;
select dayofyear('333-3-3'), dayofmonth('5555-5-5') from dual;
select dayofweek('2018-4-28') +  dayofmonth('2018-4-28') + dayofyear('2018-4-28') from dual;

--echo ### Q2 参数来自表的函数查询  ###
select c1, dayofweek(c1), dayofweek(c2),dayofweek(c3),dayofweek(c4),dayofweek(c5)  from func_t1 order by c1 asc;
select c1, dayofmonth(c1), dayofmonth(c2), dayofmonth(c3),dayofmonth(c4), dayofmonth(c5) from func_t1 order by c1 asc;
select c1, dayofyear(c1), dayofyear(c2),dayofyear(c3),dayofyear(c4), dayofyear(c5) from func_t1 order by c1 asc;

--echo ### Q3 空值、边界值测试
select dayofweek(null),dayofmonth(null),dayofyear(null) from dual ;
select dayofweek(''),dayofmonth(''),dayofyear('') from dual;
select dayofweek('0000-0-0'),dayofmonth('0000-0-0'),dayofyear('0000-0-0') from dual;
select dayofweek('0000-0-1'),dayofmonth('0000-0-1'),dayofmonth('0000-0-10'), dayofyear('0000-0-1') from dual;
select dayofweek('9999-12-31'),dayofmonth('9999-0-1'),dayofyear('9999-0-1') from dual;

--echo ### Q4 错误测试  ###
select dayofmonth(20180500);
select dayofmonth(2018050);
select dayofmonth(20180015);
select dayofmonth(2018000);
select dayofmonth(20180000);
select dayofmonth(20180005);
select dayofmonth(2018005);
select dayofmonth(0);
 # mysql 0, ob null,  但是dayofweek(0), dayofyear(0)都返回null

select dayofweek('2000-5-0'),dayofmonth('2000-6-0'),dayofyear('2000-7-0') from dual;  
# mysql null, 0, null

select dayofmonth('0001-0-0'),dayofmonth('0000-1-0'), dayofmonth('0000-0-0') from dual;
#-- mysql5.7 0,0,null
#-- mysql5.6 0,0,0


select dayofweek('0000-0-0'),dayofmonth('0000-0-0'),dayofyear('0000-0-0') from dual;  
# ob null, 0, null
# mysql5.7 null, null, null
#mysql5.6 null,0,NULL

select dayofweek('0000-0-1'),dayofmonth('0000-0-1'),dayofyear('0000-0-1') from dual; 
# ob null,null,null
# mysql null, 1, null

select dayofweek('9999-12-31'),dayofmonth('9999-0-1'),dayofyear('9999-0-1') from dual; 
# ob 6, null,null
# mysql 6,1,null

select dayofweek('1999-12-32'),dayofweek('2001-2-29'),dayofweek('xyz') from dual;
select dayofmonth('1999-12-32'),dayofmonth('2001-2-29'),dayofmonth('xyz') from dual;
select dayofyear('1999-12-32'),dayofyear('2001-2-29'),dayofyear('xyz') from dual;

