--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
# description: Verify correctness of dayofyear(), dayofmonth(), dayofweek();
# results should be the same as mysql 
--disable_warnings
drop database if exists day_of_func_db;
--enable_warnings
create database day_of_func_db;
 
use day_of_func_db;
create table func_t1(c1 datetime, c2 date, c3 timestamp(6) null, c4 varchar(100), c5 int);

insert into func_t1 values('2018-4-26 17:59:00', '2018-4-26', '2018-4-26 18:00:00.000', '2018-4-26 18:00:00', 20180426);
