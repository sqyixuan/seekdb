# tags:funcs
# descriotion:verify correctness of weekofyear(),weekday(),yearweek(),week()
# result should be the same as mysql
--disable_warnings
drop database if exists week_of_func_db;
--enable_warnings
create database week_of_func_db;

use week_of_func_db;
create table func_test1(c1 datetime,c2 date,c3 timestamp(6) null,c4 varchar(100),c5 int);

