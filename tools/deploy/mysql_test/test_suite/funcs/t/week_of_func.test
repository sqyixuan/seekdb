--echo ### Q6 不合法日期字符串测试

select weekofyear('abs12') from dual;
select weekofyear('!^-') from dual;
select weekofyear('2018-a-a') from dual;
select weekofyear('xa-01-01') from dual;
select weekofyear('+-') from dual;
select weekofyear('oceanbase') from dual;
select weekday('coin') from dual;
select weekday('//') from dual;
select weekday('!@#$') from dual;
select weekday('__') from dual;
select yearweek('2014-03-02','2') from dual;
select yearweek('2016-*-*') from dual;
select yearweek('',2) from dual;
select yearweek('%') from dual;
select yearweek('^',3) from dual;
select yearweek('forever') from dual;
select week('',2) from dual;
select week('%') from dual;
select week('^',3) from dual;
select week('forever') from dual;
