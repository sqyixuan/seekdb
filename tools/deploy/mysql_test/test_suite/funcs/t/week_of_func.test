--echo ### Q2 参数来自表的函数查询  ###
select c1, weekofyear(c1), weekofyear(c2),weekofyear(c3),weekofyear(c4),weekofyear(c5)  from func_test1 order by c1 asc;
select c1, weekday(c1), weekday(c2), weekday(c3),weekday(c4), weekday(c5) from func_test1 order by c1 asc;
select c1, yearweek(c1), yearweek(c2),yearweek(c3),yearweek(c4), yearweek(c5) from func_test1 order by c1 asc;
select c1, week(c1,mod(c5,8)),week(c2,mod(c5,8)),week(c3,mod(c5,2)),week(c4,mod(c5,18)),week(c5,mod(c5,8)) from func_test1 order by c1 asc;
--echo ### Q3 空值、边界值测试
select weekofyear(null),weekday(null),yearweek(null),week(null) from dual ;
select weekofyear(''),weekday(''),yearweek(''),week('') from dual;
select weekofyear('0000-0-0'),weekday('0000-0-0'),yearweek('0000-0-0'),week('0000-0-0') from dual;
select weekofyear('0000-0-1'),weekday('0000-0-1'),weekday('0000-0-10'), yearweek('0000-0-1'),week('0000-0-1') from dual;
select weekofyear('9999-12-31'),weekday('9999-0-1'),yearweek('9999-0-1'),week('9999-0-1') from dual;

