--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: gongyusen.gys
#owner group : SQL2
# tags: func
#description : test decode_trace_id
 
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
 
create table t1(trace_id varchar(128)) CHARSET=utf8;
insert into t1 values('Y3E820B7C052B-0006100D07448BE8-0-0');

create table t2(trace_id varchar(128)) CHARSET=utf16;
insert into t2 values('Y3E820B7C052B-0006100D07448BE8-0-0'),('YE60364586D82-000612F99AE60B70-0-0'),('YE11111111D82-000612F99AE60B70-0-0'),('YE11111111D82-000612F99AE60B70-9-9'),('YE11111111D82-000000B00CB00A70-9-9'),('Y0-0000000000000001-0-0'),('YE60364586D82-000612F99AE60B70-0-0');
 
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--echo #关闭向量化
alter system set _rowsets_enabled=false;
alter system flush plan cache;
 
connection default;
--error 1210
select decode_trace_id('') from dual;

select decode_trace_id('  ') from dual;
select decode_trace_id(NULL) from t1 limit 5;

select decode_trace_id('123456789') from dual;
select decode_trace_id('Y3E820B7C052B-0006100D07448BE8-0-0') from dual;
select decode_trace_id(trace_id) from t1 limit 5;
select decode_trace_id(trace_id) from t2;
 
 
connection obsys;
--echo #打开向量化
alter system set _rowsets_enabled = true;
alter system flush plan cache;
 
connection default;
--error 1210
select decode_trace_id('') from dual;

select decode_trace_id('  ') from dual;
select decode_trace_id(NULL) from t1 limit 5;

select decode_trace_id('123456789') from dual;
select decode_trace_id('Y3E820B7C052B-0006100D07448BE8-0-0') from dual;
select decode_trace_id(trace_id) from t1 limit 5;
select decode_trace_id(trace_id) from t2;
 
drop table t1;
drop table t2;
