--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
# description: Verify correctness of hour();
# results should be the same as mysql, see https://dev.mysql.com/doc/refman/5.7/en/date-and-time-functions.html#function_hour
--disable_warnings
drop database if exists hour_func_db;
--enable_warnings
create database hour_func_db;

 use hour_func_db;
 create table func_t1(c1 datetime, c2 date, c3 timestamp(6) null, c4 varchar(100), c5 int);

 insert into func_t1 values('2018-4-26 17:59:00', '2018-4-26', '2018-4-26 18:00:00.000', '2018-4-26 18:00:00', 20180426);
 insert into func_t1 values(null, null, null, null, null);
 insert into func_t1 values('1970-1-1 0:0:0', '1970-1-1', '1971-1-1 1:0:2.000', '1970-1-1', 19700101);
 insert into func_t1 values('2000-1-1 0:0:0', '20-10-10', '20-10-10 10:0:0.000', '1000-1-1', 0);
 insert into func_t1 values('1582-3-1 10:00:00', '1582-3-1', null, '1582-3-1', 15820301);
 insert into func_t1 values('1582-10-4 0:10:0', '1582-10-4', '2000-10-4 12:12:0.100', '1582-10-4', 15821004);
 insert into func_t1 values('1582-10-5 13:10:0', '1582-10-5', '1980-10-5 1:10:10.000', '1582-10-5', 15821005);
 insert into func_t1 values('1582-10-15 13:10:0', '1582-10-15', '1987-10-15 1:10:10.000', '1582-10-15', 15821015);
 insert into func_t1 values('1582-10-16 15:10:10', '1582-10-16', '1990-10-16 1:10:10.000', '1582-10-16', 15821005);
 insert into func_t1 values('2000-1-1 0:0:0', '1582-10-16', '2002-10-16 1:10:10.000', '1582-10-16', 15821005);
 insert into func_t1 values('2004-2-29 15:10:10', '2004-2-29', '2004-2-29 1:10:10.000', '2004-2-29', 20040229);
 insert into func_t1 values('2008-12-31 23:59:59', '2008-12-31', '2008-12-31 1:10:10.000', '2008-12-31', 20081231);
 insert into func_t1 values('2008-1-1 23:59:59', '2008-1-1', '2008-1-1 1:10:10.000', '2008-1-1', 20080101);
 insert into func_t1 values('2009-12-31 23:59:59', '2009-12-31', '2009-12-31 1:10:10.000', '2009-12-31', 20091231);
 insert into func_t1 values('2009-1-1 23:59:59', '2009-1-1', '2009-1-1 1:10:10.000', '2009-1-1', 20090101);

## set @@session.ob_enable_transformation = 0;
 --echo ### Q1 最基本测试
 SELECT HOUR('10:05:03') from dual;
 SELECT HOUR('272:59:59') from dual;
 select hour('2018-10-15 14:37:00') from dual;
 select hour(cast('2018-10-15 14:37:00' as char)) from dual;

 --echo ### Q2 参数来自表的函数查询  ###
 select c1, hour(c1), hour(c3),hour(c4),hour(c5)  from func_t1 order by c1 asc;

 --echo ### Q3 空值、边界值测试
 select hour(null),hour(null),hour(null) from dual ;
 select hour(''),hour(''),hour('') from dual;
 select hour('0000-0-0');
 --echo ### Q4 错误测试  ###
 select hour(20180500);
 select hour('2018-10-15 14:67:00') from dual;
 select hour(0);

  drop database hour_func_db;


