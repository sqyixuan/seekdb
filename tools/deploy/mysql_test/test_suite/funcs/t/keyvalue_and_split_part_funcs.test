--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: gongyusen.gys
#owner group : SQL2
# tags: func
#description : test keyvalue and split_part

select keyvalue('a;b:c;d', ';', ':', 'b') from dual;
select keyvalue('0:1;1:2', 1) from dual;
select keyvalue('0:1;1:2', 2) from dual;
select keyvalue('0:1;1:2', ';', '=', 0) from dual;
select keyvalue('name=Li;age=1;', ';', '=', 'age') from dual;
select keyvalue('name=Li;age=1;', '', '=', 'age') from dual;
select keyvalue('name=Li;age=1;', ';', '', 'age') from dual;
select keyvalue('name=Li;age=1;', ';', '=', '') from dual;
select keyvalue('name=Li;age=1;', ' ', '=', 'age') from dual;
select keyvalue(NULL, ';', '=', 'age') from dual;
select keyvalue('name=Li;age=1;', NULL, '=', 'age') from dual;
select keyvalue('name=Li;age=1;', ';', NULL, 'age') from dual;
select keyvalue('name=Li;age=1;', ';', '=', NULL) from dual;

--error 1210
select split_part('a,b,c,d', ',', -2, -3) from dual;
--error 1210
select split_part('a,b,c,d', ',', -1, 1) from dual;
select split_part('a,b,c,d', ',', -99, -1) from dual;
select split_part('a,b,c,d', ',', -99) from dual;

select split_part('a,b,c,d', ',', 1) from dual;
select split_part('a,b,c,d', ',', 1, 2) from dual;
select split_part('a,b,c,d', ',', 10) from dual;
select split_part('a,b,c,d', ':', 1) from dual;
select split_part('a,b,c,d', ':', 2) from dual;
select split_part('a,b,c,d', '', 1) from dual;
select split_part('a,b,c,d', '', 2) from dual;
select split_part('a,b,c,d', ',', 2, 6) from dual;

select split_part('', ',', 1) from dual;
select split_part('a,b,c,d', '', 1, 2) from dual;
select split_part(NULL, ',', 10) from dual;
select split_part('a,b,c,d', NULL, 1) from dual;
select split_part('a,b,c,d', ':', NULL) from dual;
select split_part('a,b,c,d', '', '') from dual;
select split_part('a,b,c,d', '', 2) from dual;
select split_part('a,b,c,d', ',', 2, 6) from dual;

select split_part('a,b,c,d', ',', -1) from dual;
select split_part('a,b,c,d', ',', -2, -1) from dual;
select split_part('a,b,c,d', ',', -10) from dual;

select split_part('a,b,c,d', ',', null) from dual;

--disable_warnings
drop table if exists funcs_test;
create table funcs_test(
    dict_str varchar(512) CHARACTER SET utf8mb4,
    dict_text longtext CHARACTER SET gbk,
    delimiter_str varchar(512) CHARACTER SET utf16
);

insert into funcs_test values ('组别:sql;姓名:xx;年龄:20;', '组别:sql;姓名:xx;年龄:20;', ';');
select keyvalue(dict_str, '年龄') from funcs_test;
select keyvalue(dict_str, ';', ':', '年龄') from funcs_test;
select keyvalue(dict_str, ';', ':', '性别') from funcs_test;
select keyvalue(dict_str, '', '', '年龄') from funcs_test;
select keyvalue(dict_str, '', '', '性别') from funcs_test;
select keyvalue(dict_text, '年龄') from funcs_test;
select keyvalue(dict_text, ';', ':', '年龄') from funcs_test;
select keyvalue(dict_text, ';', ':', '性别') from funcs_test;
select keyvalue(dict_text, NULL, '', '年龄') from funcs_test;
select keyvalue(dict_text, '', '', '年龄') from funcs_test;
select keyvalue(dict_text, '', '', '性别') from funcs_test;

select split_part(dict_str, ';', 1) from funcs_test;
select split_part(dict_str, ';', -1) from funcs_test;
select split_part(dict_str, ';', 4) from funcs_test;
select split_part(dict_text, '', 1) from funcs_test;
select split_part(dict_text, '', 3) from funcs_test;
select split_part(dict_text, '', -1) from funcs_test;
select split_part(dict_text, '', 0) from funcs_test;
select split_part(dict_text, NULL, 0) from funcs_test;

SELECT
    CASE
        WHEN 1 = 1 THEN subq_0.c0
        ELSE subq_0.c0
    END
FROM
    (SELECT keyvalue('1', '1') AS c0 FROM DUAL) subq_0;

SELECT 
    CASE 
        WHEN 1 = 1 THEN subq_0.c0 
        ELSE subq_0.c0 
    END 
FROM 
    (SELECT split_part('1,2,3', ',', 1) AS c0 FROM DUAL) subq_0;

--disable_warnings
drop table if exists funcs_test;