--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: dachuan.sdc
# owner group: SQL1
# description: Verify correctness of second(), minute(), microsecond(), to_seconds, sec_to_time, time_to_sec;
# 期望结果和mysql 5.6一致, 由于ob的cast、非法值处理和mysql不同所以在
# 这些情况下结果会不同如Q4.3; 只保证正常时间日期值结果一致;

--result_format 4

--disable_warnings
drop database if exists datetime_func_db;
--enable_warnings

create database datetime_func_db;
use datetime_func_db;

create table func_t1(c1 datetime, c2 date, c3 timestamp(6) null, c4 varchar(100), c5 int);

insert into func_t1 values('2018-6-4 9:24:00', '2018-6-4', '2018-6-4 9:24:45.432', '2018-2-27 6:01:59', 20180604);
insert into func_t1 values(null, null, null, null, null);
insert into func_t1 values('1970-1-1 0:0:0', '1970-1-1', '1971-1-1 1:0:2.000', '1970-1-1', 19700101);
commit;

# 和mysql不一致的结果
select to_days('0-1-1'), to_days('0000-1-1') from dual;

select cast('1-1-1' as date);
select cast('0-1-1' as date);
#ob: 2000-1-1
#mysql: 0000-1-1

select cast(2378 as time) from dual;
#ob: 00:00:00
#mysql: null

select to_seconds('0-1-1 0:0:06');
select time_to_sec(2378) from dual;
select time_to_sec(2378)+0 from dual;
select cast('2005-1-1 59:59:59' as time);
# ob 00:00:00
# mysql null

select time_to_sec('2005-1-1 59:59:59') from dual;
select cast('1970-1-1' as time);
# ob 00:00:00
# mysql null

select cast('2005-1-1 59:59:59' as time);

select cast(19700101 as time);

--echo ### Q1 最基本测试
select second('2018-3-26 14:00:06.999') as x,second('2017-2-29 14:10:56.999') as y ,second(null) as z from dual;
select minute('2018-3-26 14:00:06.999') as x,minute('2017-2-29 14:10:56.999') as y ,minute(null) as z from dual;
select microsecond('2018-3-26 14:00:06.19') as x, microsecond('2017-2-29 14:10:56.123') as y, microsecond(null) as z from dual;
select to_seconds('2018-3-26 14:01:06.19') as x, to_seconds('2017-4-29 14:10:16.123') as y, to_seconds(null) as z from dual;
select to_seconds('0000-1-1 0:0:06');
select sec_to_time(3020400) from dual;
select sec_to_time(3020399) from dual;
select sec_to_time(3020398) from dual;
select sec_to_time(3020401) from dual;
select sec_to_time(0) from dual;
select sec_to_time(2378) from dual;
select sec_to_time(2378)+0 from dual;
select sec_to_time(2378)+1 from dual;
#select time_to_sec(2378)+0 from dual;
select time_to_sec('22:23:00') from dual;
select time_to_sec('00:39:38') from dual;
select time_to_sec('2005-1-1 59:59:59') from dual;
select time_to_sec('2005-12-31 0:0:0') from dual;
select minute('20:45:04'),second('20:02:15'),microsecond('20:52:1.444455') from dual;

--echo ### Q2 表中数据作为参数
select second(c1), second(c2), second(c3), second(c4), second(c5) from func_t1;
select minute(c1), minute(c2), minute(c3), minute(c4), minute(c5) from func_t1;
select microsecond(c1), microsecond(c2), microsecond(c3), microsecond(c4), microsecond(c5) from func_t1;
select to_seconds(c1), to_seconds(c2), to_seconds(c3), to_seconds(c4), to_seconds(c5) from func_t1;

--echo ### Q3 复杂一点的测例
select * from func_t1 where second(c1) + minute(c2) = time_to_sec(c3) - to_seconds(c5) + length(c4) + 63695255698;


# Q4 subitme测例
#4.1 基础测试 string + string
SELECT SUBTIME('2007-12-31 23:59:59.999999','1 1:1:1.000002') from dual;
SELECT SUBTIME('01:00:00.999999', '02:00:00.999998') from dual;
SELECT SUBTIME('03:00:00', '02:00:00') from dual;
SELECT SUBTIME('03:00:00.123456', '02:00:00.654321') from dual;
SELECT SUBTIME('03:00:00.123456', '1 02:00:00.654321') from dual;
SELECT SUBTIME('2018-6-13 15:24:04', '6:24:2') from dual;
SELECT SUBTIME('2018-6-13 15:24:04', '6:24:2.0') from dual;
SELECT SUBTIME('2018-6-13 15:24:04.000', '6:24:2.000') from dual;
SELECT SUBTIME('2018-6-13 15:24:04.000', '6:24:2') from dual;
SELECT SUBTIME('2018-6-14 22:11:04.123', '48:56:6.456789') from dual;

SELECT SUBTIME(cast('2018-6-13 15:24:04' as datetime), '6:24:2') from dual;

SELECT DATE_SUB(cast('2018-6-13 15:24:04' as datetime), interval '6:24:2.0' day_second) from dual;

SELECT SUBTIME(cast('2018-6-13 15:24:04' as datetime), cast('6:24:2.0' as time)) from dual;

#4.1.2 string + time
SELECT SUBTIME('2007-12-31 23:59:59.999999',cast('1 1:1:1.000002' as time(6))) from dual;
SELECT SUBTIME('01:00:00.999999', cast('02:00:00.999998' as time(6))) from dual;
SELECT SUBTIME('03:00:00', cast('02:00:00' as time)) from dual;

#4.1.3 datetime/time + string
SELECT SUBTIME(cast('2007-12-31 23:59:59.999999' as datetime(6)),'1 1:1:1.000002') from dual;
SELECT SUBTIME(cast('01:00:00.999999' as time(6)), '02:00:00.999998') from dual;
SELECT SUBTIME(cast('03:00:00' as time), '02:00:00') from dual;
SELECT SUBTIME(cast('01:00:00.999999' as datetime(6)), '02:00:00.999998') from dual;

#4.1.4 datetime/time + time
SELECT SUBTIME(cast('2007-12-31 23:59:59.999999' as datetime(6)),cast('1 1:1:1.000002' as time(6))) from dual;
SELECT SUBTIME(cast('01:00:00.999999' as datetime(6)), cast('02:00:00.999998' as time(6))) from dual;
SELECT SUBTIME(cast('01:00:00.999999' as time(6)), cast('02:00:00.999998' as time(6))) from dual;
SELECT SUBTIME(cast('03:00:00' as time), cast('02:00:00' as time)) from dual;

#4.2 包含/不包含微秒
SELECT SUBTIME(cast('2007-12-31 23:59:59' as datetime(6)), cast('1 1:1:1.000002' as time(6))) from dual;
SELECT SUBTIME(cast('2007-12-31 23:59:59' as datetime(6)), '1:1:2') from dual;
SELECT SUBTIME('2018-6-13 15:24:04', '80 6:24:2') from dual;
SELECT SUBTIME('2018-6-13 15:24:04.665', '6:24:2') from dual;
SELECT SUBTIME(cast('01:00:00.999999' as time(6)), cast('02:00:00' as time)) from dual;
SELECT SUBTIME('2000-1-1 0:0:0.1', '24:0:59') from dual;
SELECT SUBTIME('2013-11-19 14:26:50.999999', '666:6:9.88888') from dual;
SELECT SUBTIME('2013-11-19 14:26:50.999999', '26 66:6:9.88888') from dual;

# Q4.2 特殊值、错误值测试
SELECT SUBTIME('0:0:0', '0:00:00') from dual;
SELECT SUBTIME('2000-1-1 0:0:0', '0:00:00') from dual;
SELECT SUBTIME('', '02:00:00.999998') from dual;
SELECT SUBTIME(NULL, '02:00:00.999998') from dual;
SELECT SUBTIME('01:00:00.999999', '') from dual;
SELECT SUBTIME('01:00:00.999999', NULL) from dual;
SELECT SUBTIME(null, null) from dual;
SELECT SUBTIME('2007-12-32 23:59:59.999999','1 1:1:1.000002') from dual; 
SELECT SUBTIME('2007-12-32 23:59:59.999999','41:51:1.000002') from dual;  
SELECT SUBTIME('2007-12-3 23:59:59.999999','41:1:1.000002') from dual;   
SELECT SUBTIME('2017-2-29 23:59:59.999999','1 1:1:1.000002') from dual;   
SELECT SUBTIME('2017-2-29 23:59:59.999999','361 1:1:1.000002') from dual; 
SELECT SUBTIME('2017-2-25 23:59:59.999999','361 1:1:1.000002') from dual; 
SELECT SUBTIME('2017-2-25 23:59:59.999999','5 1:1:1.000002') from dual; 
SELECT date_sub('2017-2-25 23:59:59.999999',interval '361 1:1:1.000002' day_microsecond) from dual; 

#Q4.3 表中查询
create table func_t2(c1 datetime(6), c2 time(6), c3 varchar(100), c4 varchar(100));
insert into func_t2 values(null, null, null, null);
insert into func_t2 values('2018-6-14 22:28:00.4444', '12:00:40.0400', '2019-12-1 1:23:45.6', '1 4:5:6.4');
insert into func_t2 values('2018-6-4 0:38:00.4144', '22:00:10.4000', '2019-2-3 1:2:45.67', '2 41:51:6.4423');
insert into func_t2 values('2008-6-24 12:28:00.44244', '2:05:00.5000', '2019-11-31 1:2:45.46', '3 14:5:6.0');
insert into func_t2 values('2018-1-14 12:18:00.44444', '5:00:6.4000', '2019-1-31 1:23:5.56', '4 5:26:7.');
insert into func_t2 values('1998-6-30 12:28:40.244', '5:00:6.4000', '2019-1-31 1:23:5.56', '4 5:26:7.');
insert into func_t2 values('1988-4-5 17:28:05', '15:01:16.000', '2019-2-28 2:2:2.222', '1 2:3:4.5');
commit;

SELECT SUBTIME(C1, '1 2:3:4.567890'), SUBTIME(C2, c4),SUBTIME(c3, c4) FROM func_t2;

drop database datetime_func_db;

