--echo # timeformat-1-mysql
--echo # 不同参数
 # 不支持,同上 年 / 月 / 日 / 星期 
SELECT TIME_FORMAT('2003-12-31 12:00:00', '%Y-%c-%d %T:%i:%s');
SELECT TIME_FORMAT('2003-12-31 12:00:00', '%Y——%c——%d %T:%i:%s');
SELECT TIME_FORMAT('2003-12-31 12:00:00', '%Y %c %d %T:%i:%s');
SELECT TIME_FORMAT('2003-12-31 12:00:00', '%Y %b %M %m %% %s');
SELECT TIME_FORMAT('2003-12-31 12:00:00', '%Y-%M-%d');
SELECT TIME_FORMAT('1987-06-28 02:24:22.138', '%Y-%m-%d %T:%i:%s');
SELECT TIME_FORMAT('1987-June-28 02:24:22.138', '%Y-%M-%d %T:%i:%s');
SELECT TIME_FORMAT('02:24:22.138', '%a');
SELECT TIME_FORMAT('02:24:22.138', '%a');
SELECT TIME_FORMAT('02:24:22.138', '%D');
SELECT TIME_FORMAT('02:24:22.138', '%d');
SELECT TIME_FORMAT('02:24:22.138', '%e');
SELECT TIME_FORMAT('02:24:22.138', '%j');

 # 支持 上下午，时分秒，微妙，%
SELECT TIME_FORMAT('02:24:22.138', '%p');
SELECT TIME_FORMAT('02:24:22.138', '%r');
SELECT TIME_FORMAT('16:24:22.138', '%r');
SELECT TIME_FORMAT('02:24:22.138', '%T');
SELECT TIME_FORMAT('16:24:22.138', '%T');
SELECT TIME_FORMAT('16:24:22.138', '%H');
SELECT TIME_FORMAT('16:24:22.138', '%h');
SELECT TIME_FORMAT('16:24:22.138', '%I');
SELECT TIME_FORMAT('16:24:22.138', '%k');
SELECT TIME_FORMAT('16:24:22.138', '%l');
SELECT TIME_FORMAT('16:24:22.138', '%i');
SELECT TIME_FORMAT('16:24:22.138', '%S');
SELECT TIME_FORMAT('16:24:22.138', '%f');
SELECT TIME_FORMAT('16:24:22.138', '%s');
SELECT TIME_FORMAT('16:24:22.138', '%s %%');

 # 不支持,同上 %U...%x
SELECT TIME_FORMAT('16:24:22.138', '%U');
SELECT TIME_FORMAT('16:24:22.138', '%u');
SELECT TIME_FORMAT('16:24:22.138', '%V');
SELECT TIME_FORMAT('16:24:22.138', '%v');
SELECT TIME_FORMAT('16:24:22.138', '%W');
SELECT TIME_FORMAT('16:24:22.138', '%w');
SELECT TIME_FORMAT('16:24:22.138', '%X');
SELECT TIME_FORMAT('16:24:22.138', '%x');


 # 函数, 单双引号
SELECT TIME_FORMAT(current_date(), '%r %T %f');  # 不支持 12:00:00 AM 00:00:00 000000 
SELECT TIME_FORMAT(concat('2003-12-31 12:00:00.123456789'), '%r %T %f');
SELECT TIME_FORMAT("2003-12-31 12:22:11", '%r %T %f');
--error 0,1582
SELECT TIME_FORMAT('16:24:22.138');
SELECT TIME_FORMAT("2003-12-31 12:22:11", "%r %T %f");
SELECT TIME_FORMAT("13:01:22", "%r %T %f");
SELECT TIME_FORMAT('13:01:22', "%r %T %f");
SELECT TIME_FORMAT("12-34:44", '%r %T %f');
SELECT TIME_FORMAT(NULL, '%r %T %f');


--echo # 不同时间
SELECT TIME_FORMAT('1987-June-28 02:24:22.138', '%r %T'); # 不支持,同上,同上
SELECT TIME_FORMAT('1987-Jun-28 02:24:22.138', '%r %T'); # 不支持,同上,同上
SELECT TIME_FORMAT('87-June-28 02:24:22.138', '%r %T'); # 不支持,同上,同上
SELECT TIME_FORMAT('87-Jun-28 02:24:22.138', '%r %T');  # 不支持,同上,同上
SELECT TIME_FORMAT('87-07-28th 02:24:22.138', '%r %T');
SELECT TIME_FORMAT('87-07-28th 02:24:22.138', '%r %T');
SELECT TIME_FORMAT('87-07-28th 179 02:24:22.138', '%r %T'); # 不支持,同上,同上
SELECT TIME_FORMAT('AM 02:24:22.138', '%r %T'); # 不支持,同上,同上
SELECT TIME_FORMAT('PM 02:24:22.138', '%r %T'); # 不支持,同上 
SELECT TIME_FORMAT('BEIJING 02:24:22.138', '%r %T'); # 不支持,同上
SELECT TIME_FORMAT('02:24:22.138', '%r %T'); 
SELECT TIME_FORMAT('02:24:22.138', '%r %T %f %k %l'); 
SELECT TIME_FORMAT('02.24.22.138', '%r.%T.%f %k %l'); 
SELECT TIME_FORMAT('02.1234567', '%T.%f %k %l'); 
SELECT TIME_FORMAT('02.1234567', '%T %r'); 
SELECT TIME_FORMAT('', '%i');  # 不支持,同上
SELECT TIME_FORMAT('', '%r %T %f'); # 不支持,同上
SELECT TIME_FORMAT(' ', '%r %T %f'); # 不支持,同上
SELECT TIME_FORMAT('1', '%r %T %f'); 
SELECT TIME_FORMAT('13:60:00.80', '%r %T %f');  # 不支持,同上
SELECT TIME_FORMAT('13:27:60.80', '%r %T %f');  # 不支持,同上
SELECT TIME_FORMAT('25:27:59', '%r %T %f');  # 不支持,同上
SELECT TIME_FORMAT('25_27_59', '%r %T %f');
SELECT TIME_FORMAT('25.1349', '%r %T %f');
SELECT TIME_FORMAT('0.1234', '%r %T %f');
SELECT TIME_FORMAT('1.175494351E-38', '%r %T %f'); 
SELECT TIME_FORMAT('1.7976931348623157E+308', '%r %T %f');
SELECT TIME_FORMAT('13:01:22', '%r %T %f');
SELECT TIME_FORMAT('80:01:22', '%r %T %f');
SELECT TIME_FORMAT('80:01:22', '%r %T %H %k %I %f');
SELECT TIME_FORMAT('80:01:61', '%r %T %H %k %I %f'); # 不支持,同上
SELECT TIME_FORMAT('80:61:31', '%r %T %H %k %I %f'); # 不支持,同上
# SELECT TIME_FORMAT(80:61:31, '%r %T %H %k %I %f'); 
SELECT TIME_FORMAT('165847.1234567', '%r %T %H %k %I %f');
SELECT TIME_FORMAT('-165847.1234567', '%r %T %H %k %I %f');
SELECT TIME_FORMAT('-13:01:22.233', '%r %T %H %k %I %f');
SELECT TIME_FORMAT('-13:01:22。123', '%r %T %H %k %I %f');
SELECT TIME_FORMAT('-13:01:22+123', '%r %T %H %k %I %f');
SELECT TIME_FORMAT('-13:01:22+123', ' ');
SELECT TIME_FORMAT('80:01:22', ' ');
SELECT TIME_FORMAT('-13:01:22+123', '');
SELECT TIME_FORMAT('80:01:22', NULL);

