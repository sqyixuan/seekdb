select float_1, timestamp(float_1) from t1;
select double_2, timestamp(double_2) from t1;
# 部分支持 int 类型数据
select id, timestamp(id) from t1;
# 支持 date 类型
select date_1, timestamp(date_1) from t1;
# 支持 time 类型，年月日 显示当前的时间点
# select time_2, timestamp(time_2) from t1;
select year_3, timestamp(year_3) from t1;
select date_tim, timestamp(date_tim) from t1;
select time_stp, timestamp(time_stp) from t1;


--echo # 不同参数个数
SELECT TIMESTAMP(' ', ' ');
--error 0,1064
SELECT TIMESTAMP(' ', );
--error 0,1064
SELECT TIMESTAMP( , ' ');
SELECT TIMESTAMP('1988-08-05', '100');
SELECT TIMESTAMP('1988-08-05', '10000');
SELECT TIMESTAMP('1988-08-05', '1000000');
SELECT TIMESTAMP('1988-08-05', '1000000.123');
SELECT TIMESTAMP('1988-08-05', '-1000.123');
SELECT TIMESTAMP('1988-08-05', '-000.123');
SELECT TIMESTAMP('1988-08-05', '-000');
SELECT TIMESTAMP('1988-08-05', 'null');
SELECT TIMESTAMP('1988-08-05', '12:00:00');
SELECT TIMESTAMP('1988-08-05', '11:12:20');
SELECT TIMESTAMP('1988-08-05', '01 12:32:21');
SELECT TIMESTAMP('1988-08-05', '1987');
SELECT TIMESTAMP('1988-08-05', '100'+'1000');
SELECT TIMESTAMP('2003-12-31 12:00:00', '12:00:00');
SELECT TIMESTAMP('2003-12-31 12:00:00', '00:00:00');
SELECT TIMESTAMP('2003-12-31 12:00:00', ' ');
SELECT TIMESTAMP('2003-12-31 12:00:00', '2020-01-12');
select timestamp(20101203160303,'11:12:20');

# ob结果显示时间，mysql5.7显示null
SELECT TIMESTAMP('2003-12-31 12:00:00',' 2020-01-23 21:29:31'); 
SELECT TIMESTAMP('1988-08-05', '2003-12-31 12:00:00');

# 不支持
SELECT TIMESTAMP('123456','2020-01-12');
SELECT TIMESTAMP('123456','11:12:20');
SELECT TIMESTAMP('1234',' ');




