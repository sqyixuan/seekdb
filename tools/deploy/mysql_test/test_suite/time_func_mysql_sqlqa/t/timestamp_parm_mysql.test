SELECT a,TIMESTAMP(a) from t1;
SELECT a,TIMESTAMP(a,a) from t1;
SELECT a1,TIMESTAMP(a1) from t1;
SELECT a1,TIMESTAMP(a1,a1) from t1;
SELECT a2,TIMESTAMP(a2) from t1;
SELECT a2,TIMESTAMP(a2,a2) from t1;
SELECT a3,TIMESTAMP(a3) from t1;
SELECT a3,TIMESTAMP(a3,a3) from t1;
SELECT a4,TIMESTAMP(a4) from t1;
SELECT a4,TIMESTAMP(a4,a1) from t1;
SELECT a5,TIMESTAMP(a5) from t1;
SELECT a5,TIMESTAMP(a5,a6) from t1;
SELECT a6,TIMESTAMP(a6) from t1;
SELECT a6,TIMESTAMP(a6,a5) from t1;
SELECT b,TIMESTAMP(b) from t1;
SELECT b,TIMESTAMP(b,b1) from t1;
SELECT b1,TIMESTAMP(b1) from t1;
SELECT b1,TIMESTAMP(b1,b2) from t1;
SELECT b2,TIMESTAMP(b2) from t1;
SELECT b2,TIMESTAMP(b2,b3) from t1;
SELECT b3,TIMESTAMP(b3) from t1;
SELECT b4,TIMESTAMP(b4) from t1;
SELECT b5,TIMESTAMP(b5) from t1;
SELECT c,TIMESTAMP(c) from t1;
SELECT c,TIMESTAMP(c,c) from t1;
# SELECT c1,c,TIMESTAMP(c1,c) from t1;
SELECT c2,c,TIMESTAMP(c2,c) from t1;
SELECT c3,c,TIMESTAMP(c3,c) from t1;

SELECT c,c1,TIMESTAMP(c,c1) from t1;
# SELECT c1,c1,TIMESTAMP(c1,c1) from t1;
SELECT c2,c1,TIMESTAMP(c2,c1) from t1;
SELECT c3,c1,TIMESTAMP(c3,c1) from t1;
SELECT c2,c1,TIMESTAMP(c2,c1+c1) from t1;

# 数据表现与Mysql5.7不一样
SELECT c,c2,TIMESTAMP(c,c2) from t1;
# SELECT c1,c2,TIMESTAMP(c1,c2) from t1;
SELECT c2,c2,TIMESTAMP(c2,c2) from t1;
SELECT c3,c2,TIMESTAMP(c3,c2) from t1;

SELECT c,c3,TIMESTAMP(c,c3) from t1;
# SELECT c1,c3,TIMESTAMP(c1,c3) from t1;
SELECT c2,c3,TIMESTAMP(c2,c3) from t1;
SELECT c3,c3,TIMESTAMP(c3,c3) from t1;




--error 0,1051
DROP TABLE t1;
CREATE TABLE t1 (
  float_1 float ,
  double_2 double,
  id int,
  date_1 DATE,
  time_2 time,
  year_3 year,
  date_tim datetime,
  time_stp timestamp
);

