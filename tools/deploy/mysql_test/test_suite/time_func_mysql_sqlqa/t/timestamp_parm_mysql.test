--echo # timestamp-1-mysql
--echo # 不同参数
SELECT TIMESTAMP(' ');
SELECT TIMESTAMP(NULL);
SELECT TIMESTAMP('WWW');
SELECT TIMESTAMP('中国');
SELECT TIMESTAMP('#$%^');
SELECT TIMESTAMP('123456');
SELECT TIMESTAMP('1234');
SELECT TIMESTAMP('2003-12-31 12:00:00');
SELECT TIMESTAMP('2003-12-31 12:00:00'+'01 12:32:21');
SELECT TIMESTAMP('2003-12-31 12:00:00'+'05:30');
SELECT TIMESTAMP(-2003-12-31);
SELECT TIMESTAMP(-2011);
SELECT TIMESTAMP('2003-12-31 12:00:00.000001');
SELECT TIMESTAMP('2003-12-31 12:00:00.000000001');
select timestamp(20101203160303);
select timestamp('0:02:01.000000');
--error 0,1064
SELECT TIMESTAMP(2003-12-31 12:00:00);
 # SELECT TIMESTAMP(current_date);
SELECT TIMESTAMP(concat('2003-12-31 12:00:00.123456789'));
SELECT TIMESTAMP("2003-12-31 12:00:00");
 # double
SELECT TIMESTAMP(2.2250738585072014E-308) From dual;
SELECT TIMESTAMP(1.7976931348623157E+308) From dual;
 # float
SELECT TIMESTAMP(1.175494351E-38) From dual;
 # time 
SELECT TIMESTAMP('00:00:00') From dual;
SELECT TIMESTAMP('00:01:00') From dual;
SELECT TIMESTAMP('01:00:00') From dual;
SELECT TIMESTAMP('01:00:88') From dual;
SELECT TIMESTAMP('09:10:05') From dual;
 # year ：return null
SELECT TIMESTAMP('2020') From dual;
SELECT TIMESTAMP('0999') From dual;
SELECT TIMESTAMP('0001') From dual;
 # datetime ：pass
SELECT TIMESTAMP('0000-12-25 00:00:00') From dual;
SELECT TIMESTAMP('0001-12-25 00:00:00') From dual;
SELECT TIMESTAMP('09:10:05:12:34:44') From dual;
SELECT TIMESTAMP('09-10-05-12-34:44') From dual;
 # timestamp ： return null
SELECT TIMESTAMP('2147483647') From dual;
 # other ： return null
SELECT TIMESTAMP('w(ﾟДﾟ)w') FROM dual;
SELECT TIMESTAMP('ヽ(✿ﾟ▽ﾟ)ノ') FROM dual;


--error 0,1051
DROP TABLE T2;
--error 0,1051
DROP TABLE T1;

CREATE TABLE t1(
	a tinyint,a1 smallint,a2 mediumint,a3 int,a4 bigint,a5 float,a6 double,
	b char(20),b1 varchar(20),b2 tinytext,b3 text, b4 mediumtext, b5 mediumtext,
	c date,c1 time,c2 datetime,c3 timestamp
);

