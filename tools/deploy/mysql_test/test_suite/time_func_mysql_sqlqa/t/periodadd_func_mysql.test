--echo # periodadd-2-mysql
 # 普通表
CREATE TABLE `t1` (
  `id` int NOT NULL AUTO_INCREMENT,
  `consumer` char(20) DEFAULT NULL,
  `brand` varchar(20) DEFAULT NULL,
  `sal` bigint DEFAULT NULL,
  PRIMARY KEY (`id`)
);

INSERT INTO t1 VALUES(1,'书局','apple',5000);
INSERT INTO t1 VALUES(2,'微山','xiaomi',-4000);
INSERT INTO t1 VALUES(3,'深咖','oppo',0);
INSERT INTO t1 VALUES(4,'流苏','huawei',NULL);
INSERT INTO t1 VALUES(5,'玻璃','LG',6000);
INSERT INTO t1 VALUES(6,'钛钢','HTC',8000);
INSERT INTO t1 VALUES(7,'合金','VIVO',3500);

--error 0,1051
DROP TABLE T2;
CREATE TABLE `t2` (
  `id` int NOT NULL AUTO_INCREMENT,
  `model` varchar(200) DEFAULT NULL,
  `Price` bigint DEFAULT NULL,
  PRIMARY KEY (`id`)
);

INSERT INTO t2 VALUES(1,'apple 12',7000);
INSERT INTO t2 VALUES(2,'xiaomi 9',0);
INSERT INTO t2 VALUES(3,'oppo findx',-6000);
INSERT INTO t2 VALUES(4,'huawei mata30',8000);
INSERT INTO t2 VALUES(5,'huawei mata30',NULL);
INSERT INTO t2 VALUES(6,'htc cc30',26.44);
INSERT INTO t2 VALUES(7,'shumei xi2',-26.44);

 # 视图
CREATE VIEW t1_view AS SELECT *  FROM t1;
CREATE VIEW t2_view AS SELECT *  FROM t2;


 # SELECT
SELECT period_add(e.id,10) FROM t1 e;
SELECT period_add(e.consumer,10) FROM t1 e;
SELECT period_add(e.brand,10) FROM t1 e;
SELECT * FROM t1 e WHERE period_add(e.sal,10) = '205010';


 # left join + right join + inner join
SELECT period_add(e.sal,10) sal,p.Price,period_add(p.Price,10) FROM t1 e LEFT JOIN t2 p ON e.id = p.id ORDER BY e.sal DESC;
SELECT period_add(e.sal,10) sal,period_add(p.Price,10), p.Price FROM t1 e RIGHT JOIN t2 p ON e.id = p.id ORDER BY e.sal DESC;
SELECT period_add(e.sal,10) sal,period_add(p.Price,10), p.Price FROM t1 e INNER JOIN t2 p ON e.id = p.id ORDER BY e.sal DESC;
SELECT * FROM (SELECT e.id,period_add(e.sal,10) sal,period_add(p.Price,10) FROM t1 e LEFT JOIN t2 p ON e.id = p.id ) e ORDER BY e.sal;

 # ANY
SELECT *  FROM t1 e WHERE period_add(e.sal,10) = ANY (SELECT period_add(p.Price,10) FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE period_add(e.sal,10) < ANY (SELECT period_add(p.Price,10) FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE period_add(e.sal,10) > ANY (SELECT period_add(p.Price,10) FROM t2 p ) ORDER BY e.id;

 # ALL
SELECT *  FROM t1 e WHERE period_add(e.sal,10) < ALL (SELECT period_add(p.Price,10) FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE period_add(e.sal,10) > ALL (SELECT period_add(p.Price,10) FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE period_add(e.sal,10) = ALL (SELECT period_add(p.Price,10) FROM t2 p WHERE p.model = 'oppo findx') ORDER BY e.id;

 # EXISTS AND NOT EXISTS
SELECT *  FROM t1 e WHERE EXISTS (SELECT period_add(p.Price,10) FROM t2 p ) ORDER BY e.id;
SELECT period_add(e.sal,10)  FROM t1 e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2 p WHERE period_add(p.Price,10)='2000-01-10' ) ORDER BY e.id;
SELECT period_add(e.sal,10)  FROM t1 e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2 p WHERE period_add(p.Price,10)=7500 ) ORDER BY e.id;


 # CREATE AS  
CREATE TABLE t3 AS SELECT * FROM t1 e WHERE period_add(e.sal,10) ='205010';
DROP TABLE t3;

CREATE TABLE t3 AS SELECT * FROM t1 e WHERE period_add(e.sal,11.1) ='205010';
DROP TABLE t3;

CREATE TABLE t3 AS SELECT * FROM t1 e WHERE period_add(e.sal,0) <=> NUll;
DROP TABLE t3;

# LIKE
SELECT brand, period_add(brand,10) FROM t1 e WHERE e.brand LIKE '%a%';
SELECT sal, period_add(sal,10) FROM t1 e LEFT JOIN t2 p ON e.id = p.id WHERE e.sal LIKE '%00%';


 # WHERE
SELECT * FROM t1 e WHERE period_add(e.sal,10) = 0;
SELECT * FROM t1 e WHERE period_add(e.sal,10) = 1;
SELECT * FROM t1 e WHERE period_add(e.sal,10) = NULL;
SELECT * FROM t1 e WHERE period_add(e.sal,10) <=> NULL;
SELECT * FROM t1 e WHERE period_add(e.sal,10) > 0 ORDER BY e.id;
SELECT * FROM t1 e WHERE period_add(e.sal,10) >= 0 ORDER BY e.id;
SELECT * FROM t1 e WHERE period_add(e.sal,10) < 0 ORDER BY e.id;
SELECT * FROM t1 e WHERE period_add(e.sal,10) <= 0 ORDER BY e.id;
SELECT * FROM t1 e WHERE period_add(e.sal,10) <> 0 ORDER BY e.id;

 # ORDER BY
SELECT e.id, e.sal, period_add(e.sal,10) FROM t1 e WHERE e.id > 0 ORDER BY period_add(e.sal,10);
SELECT e.id, e.sal, period_add(e.sal,10) FROM t1 e WHERE e.id > 0 ORDER BY period_add(e.sal,10) DESC;
SELECT e.id, e.sal, period_add(e.brand,10) FROM t1 e WHERE e.id > 0 ORDER BY period_add(e.brand,10) ASC;
SELECT e.id, e.sal, period_add(e.brand,10) FROM t1 e WHERE e.id > 0 ORDER BY period_add(e.brand,10) DESC;


 # GROUP BY HAVING
SELECT e.id, period_add(e.sal,10), SUM(e.sal+p.Price) FROM t1 e ,t2 p WHERE e.id=p.id GROUP BY e.id, period_add(e.sal,10)  ORDER BY e.id;
SELECT e.id, e.sal,period_add(e.sal,10) tt, SUM(e.sal+p.Price) FROM t1 e ,t2 p WHERE e.id=p.id GROUP BY e.id, period_add(e.sal,10) HAVING tt > -1 ORDER BY e.id;

 # CASE WHEN
select id, sal, period_add(case when sal=0 then 200 else sal end, 10) from t1_view ORDER BY id;
select id, sal, period_add(case when sal>0 then 200 else sal end, 10) from t1_view order by id;
select id, sal, period_add(case when sal=0 then 200 else sal end, 10), COUNT(*) from t1_view GROUP by period_add(case when sal=0 then 200 else sal end, 10),id ORDER BY id;

 # INSERT
INSERT INTO t2(model,price) SELECT model,price from t2_view WHERE period_add(price,10) = '205010';
SELECT COUNT(*) FROM t2;

--error 0,1292
INSERT INTO t2(model,price) SELECT model,price from t2_view WHERE period_add(price,10) = '0';
SELECT COUNT(*) FROM t2;

