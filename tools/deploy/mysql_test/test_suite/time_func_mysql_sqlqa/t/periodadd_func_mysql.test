 # UPDATE
UPDATE t2_view SET MODEL = 'xiaomi 10' WHERE period_add(Price,10) = '205010';
UPDATE t2_view SET price = '9000' WHERE period_add(Price,10) < 0;
UPDATE t2_view SET price = (SELECT period_add(t1.sal,10) FROM t1 WHERE period_add(t1.sal,10) = '197010' ) WHERE id = 1 ;

# UPDATE t2_view SET price = (period_add(now(),10));
--error 0,1292
UPDATE t2_view SET price = (period_add('2003',10));
UPDATE t2_view SET price = (period_add(201,10));
UPDATE t2_view SET price = (cast(period_add(201,10) as unsigned integer));


 # DELETE
DELETE FROM t2_view WHERE period_add(Price,10) = 0;
SELECT COUNT(*) FROM t2_view;

DELETE FROM t2_view WHERE period_add(Price,10) = -1;
SELECT COUNT(*) FROM t2_view;

DELETE FROM t2_view WHERE period_add(Price,10) <= 2;
SELECT COUNT(*) FROM t2_view;

