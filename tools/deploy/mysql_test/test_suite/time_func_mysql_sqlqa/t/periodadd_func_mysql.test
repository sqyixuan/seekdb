 # 生成列: varchar 类型 + case when
--error 0,1051
DROP TABLE t1;
CREATE TABLE t1 (
    a INT AUTO_INCREMENT PRIMARY KEY,
	c_time varchar(50),
    d_time varchar(50) GENERATED ALWAYS AS (case when period_add(c_time,10) > "20210706" then "now" when period_add(c_time,10) <= "20210706" then 'yesterday' end)
);
CREATE INDEX idx_t1 ON T1(d_time);
