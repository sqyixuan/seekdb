 # update
update t1 set b = period_add(STR_TO_DATE('2014-January-1st', '%Y-%M-%d'),10) where a = 3;


--echo # 分区表
--error 0,1051
DROP TABLE t1;
CREATE TABLE T1(
    a bigint,
	b datetime
)partition by range columns(b) subpartition by hash(a) subpartitions 2
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);

insert into t1 values(LENGTH(period_add('1995',10)),'1995-12-02 22:30:27');
insert into t1 values(ROUND(period_add('2006',10)), '2006-08-09 03:20:51');
insert into t1 values(CEIL(period_add('2006',10)), '2006-03-31 14:45:32');
insert into t1 values(FLOOR(period_add('2016',10)), '2016-03-19 13:22:51');
insert into t1 values(ABS(period_add('2010',10)), '2010-12-03 16:03:03');
insert into t1 values(NEG(period_add('1992',10)), '1992-01-02 23:51:32');
insert into t1 values(SIGN(period_add('1980',10)), '1980-12-03 01:08:01.000');
insert into t1 values(11,null);
select least(period_add(b,10), '1987-06-28 02:24:22.000', sign(null)) from t1;
select least(period_add(b,10), '1987-06-28 02:24:22.000') from t1;
select * from t1 where period_add(b,10) is null;
select * from t1 where period_add(b,10) is not null;


