DROP TABLE t1;
CREATE TABLE `t1` (
  `id` int NOT NULL AUTO_INCREMENT,
  `consumer` char(20) NOT NULL,
  `price` varchar(20) DEFAULT NULL,
  `sal` int DEFAULT NULL,
  `datetime1` DATE,
  `datetime2` bigint,
  PRIMARY KEY (`id`),
  UNIQUE KEY `t1_UN` (`price`)
);
