-- echo obmysql-periodadd-6
DELIMITER //;

#定义一个无参的函数
--error 0,1305
drop function f_test ;//
CREATE  FUNCTION f_test()
returns varchar(200)
begin
	declare a varchar(200);
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10)='202709' INTO a;
	return a;
END;
//
DELIMITER ;//

SELECT f_test();


#定义一个有参的函数
DELIMITER //;
--error 0,1305
drop function f_test ;//
CREATE FUNCTION f_test(samplename varchar(200))
returns varchar(200)
begin
	declare a varchar(200);
	SELECT PERIOD_ADD(samplename,10) FROM t1 e WHERE PERIOD_ADD(year_3,10)='202709' INTO a ;
	return a;
END;
//
DELIMITER ;//

SELECT f_test(-100);
SELECT f_test('2015');
SELECT f_test('0000-12-25 00:00:00');
SELECT f_test('09:10:05:12:34:44');
--error 0,1054
SELECT f_test(abc);
SELECT f_test(NULL);


--echo obmysql-PERIOD_ADD-8-2
#定义函数用 while 循环
DELIMITER //;
--error 0,1305
drop function f_test;//
CREATE FUNCTION f_test(samplename varchar(200), samplename1 varchar(200))
returns  varchar(200)
begin
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = samplename into a;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = samplename1 into b;
WHILE i <= 0 do
	INSERT INTO t1 VALUES (2951,a,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000','2002-06-20 05:50:54');
	INSERT INTO t1 VALUES (17854,b,32209,'2005-11-05','07:00:06',2005,'1982-04-20 13:13:32.000','2014-11-24 23:19:45.000');
	set i := i + 1;
END WHILE;
return a+b;
END;
//
DELIMITER ;//

SELECT f_test(0,-1) FROM dual;
SELECT f_test(NULL,-1) FROM dual;
SELECT f_test('202709',0) FROM dual;
SELECT f_test(-1,-1) FROM dual;
# SELECT f_test( '07:44:26', '18:32:37' ) FROM dual;
select count(*) from t1;
delete from t1 where id in (1088,32209);


#定义函数用 repeat 循环
--error 0,1305
DELIMITER //;
drop function f_test;//
CREATE  FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
begin
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = samplename into a;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = samplename1 into b;
repeat 	
	INSERT INTO t1 VALUES(0,a,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000','2002-06-20 05:50:54'),(0,b,32209,'2005-11-05','07:00:06',2005,'1982-04-20 13:13:32.000','2014-11-24 23:19:45.000');
	set i := i + 1;
	until i >= 1	
end repeat;
	return period_add(a,10);
END;
//
DELIMITER ;//

select count(*) from t1;
SELECT f_test(0,-1) FROM dual;
SELECT f_test(NULL,-1) FROM dual;
SELECT f_test('202709', '202204') FROM dual;
SELECT f_test(-1,0) FROM dual;
SELECT f_test(-1,-1) FROM dual;
select count(*) from t1;
delete from t1 where id in (1088,32209);


#定义函数用 repeat 循环
--error 0,1305
DELIMITER //;
drop function f_test;//
CREATE  FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
begin
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = samplename into a;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = samplename1 into b;
return a;
END;
//
DELIMITER ;//

SELECT f_test('202709', '2007-01-10') FROM dual;


#定义函数用loop循环
DELIMITER //;
--error 0,1305
drop function f_test;//
CREATE FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns varchar(200)
BEGIN
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = samplename into a;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = samplename1 into b;
	
lp1:loop
	set i := i + 1;
	INSERT INTO t1 VALUES(0,a,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000','2002-06-20 05:50:54');
	INSERT INTO t1 VALUES(0,b,32209,'2005-11-05','07:00:06',2005,'1982-04-20 13:13:32.000','2014-11-24 23:19:45.000');
if i > 1 then
	leave lp1;
end if;
	end Loop lp1;
	return period_add(b,10);
END;
//
DELIMITER ;//

select count(*) from t1;
SELECT f_test(0,-1) FROM dual;
SELECT f_test(NULL,-1) FROM dual;
SELECT f_test(-1,0) FROM dual;
SELECT f_test(-1,-1) FROM dual;
SELECT f_test('202709', '202204') FROM dual;
select count(*) from t1;
delete from t1 where id in (1088,32209);


--echo obmysql-PERIOD_ADD-9
--echo obmysql-PERIOD_ADD-9-1
#无参的存储过程
DELIMITER //;
--error 0,1305
drop procedure p_test;//
CREATE PROCEDURE p_test()
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = '202709' into a;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = '202204' into b;
WHILE i < 1 do
	INSERT INTO t1 VALUES(0,a,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000','2002-06-20 05:50:54');
	INSERT INTO t1 VALUES(0,b,32209,'2005-11-05','07:00:06',2005,'1982-04-20 13:13:32.000','2014-11-24 23:19:45.000');
	set i := i + 1;
	END while;
END;
//

DELIMITER ;//

SELECT COUNT(*) FROM t1;
CALL p_test();
SELECT COUNT(*) FROM t1;
delete from t1 where id in (1088,32209);


# 只有一个in参数的存储过程
DELIMITER //;
--error 0,1305
drop procedure p_test;//
CREATE PROCEDURE p_test(in samplename varchar(200))
begin
	declare i int;
	declare a varchar(200);
	declare b varchar(200);
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = samplename into a;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = samplename into b;
    set i := 1;
repeat
	INSERT INTO t1 VALUES(0,a,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000','2002-06-20 05:50:54');
	INSERT INTO t1 VALUES(0,b,32209,'2005-11-05','07:00:06',2005,'1982-04-20 13:13:32.000','2014-11-24 23:19:45.000');
	set i := i+1;
	until i >= 2
	end	 repeat;
END ;
//
DELIMITER ;//

SELECT COUNT(*) FROM t1;
CALL p_test(500);
CALL p_test(0);
CALL p_test(-1);
CALL p_test('202709');
CALL p_test(NULL);
SELECT COUNT(*) FROM t1;
delete from t1 where id in (1088,32209);


#包含 out 参数的存储过程
DELIMITER //;
--error 0,1305
drop procedure p_test;//
CREATE PROCEDURE p_test(out wb  varchar(200), out wb1  varchar(200))
begin
	declare i int;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE TIME_FORMAT(e.time_stp,10) ='2015-01-30 06:13:54' into wb;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE TIME_FORMAT(e.time_stp,10) ='2018-01-20 10:56:17' into wb1;
   	set i :=  1;
while i <= 1 do
	INSERT INTO t1 VALUES(0,wb,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000','2002-06-20 05:50:54');
	INSERT INTO t1 VALUES(0,wb1,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000','2002-06-20 05:50:54');
	set i := i + 1;
end while;
END;
//

DELIMITER ;//

SELECT COUNT(*) FROM t1;
call p_test(@wb,@wb1);
SELECT COUNT(*) FROM t1;
delete from t1 where id in (1088,32209);


#包含out, inout参数的存储过程
DELIMITER //;
--error 0,1305
drop PROCEDURE p_test;//
CREATE PROCEDURE p_test( out wb varchar(200),inout wb1 varchar(200))
begin
	declare i int;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) ='202709' into wb;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) ='2007-01-10' into wb1;
    set i := 1;
while i <= 1 do
	INSERT INTO t1 VALUES(0,wb,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000','2002-06-20 05:50:54');
	INSERT INTO t1 VALUES(0,wb1,32209,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000','2002-06-20 05:50:54');
	set i := i + 1;
end while;
END;
//
DELIMITER ;//

SELECT COUNT(*) FROM t1;
call p_test(@wb,@wb1);
SELECT COUNT(*) FROM t1;
delete from t1 where id in (1088,32209);


#out, inout参数
DELIMITER //;
--error 0,1305
drop procedure p_test;//
CREATE PROCEDURE p_test(OUT wb varchar(200),inout wb1 timestamp ,in wb2 datetime)
begin
	declare i int;
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = '202204' into wb;
	set wb1 := '2000-03-23 00:15:01';
	set i := 1;
	WHILE i < 2 do
    INSERT INTO t1 VALUES(0,15879,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000',wb1);
	INSERT INTO t1 VALUES(0,488,32209,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000',wb2);
	set i := i + 1;
	END while;
END;
//
DELIMITER ;//

SELECT COUNT(*) FROM t1;
call p_test(@wb,@wb1,'2015-01-30 06:13:54');
SELECT COUNT(*) FROM t1;
delete from t1 where id in (1088,32209);


#存储过程用循环
DELIMITER //;
--error 0,1305
drop procedure p_test;//
create PROCEDURE p_test(in wb varchar(200))
begin
	declare i int;
  	set i := 1;
	WHILE i < 2 do
    INSERT INTO t1 VALUES(0,15879,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000',wb);
	set i := i+1;
	END while;
END;
//
DELIMITER ;//

SELECT COUNT(*) FROM  t1;
CALL p_test(PERIOD_ADD(0221,10));
CALL p_test(PERIOD_ADD('202709',10));
CALL p_test(PERIOD_ADD('01',10));
CALL p_test(PERIOD_ADD(NULL,10));
CALL p_test(PERIOD_ADD(1000,10));
SELECT COUNT(*) FROM  t1;
delete from t1 where id in (1088,32209);


#存储过程和函数的结果作为参数传递
DELIMITER //;
--error 0,1305
drop function f_test;//
CREATE FUNCTION f_test()
returns varchar(200)
begin
	declare a varchar(200);
	SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10)= '202204' into a ;
	RETURN a;
END;
//
DELIMITER ;//

SELECT f_test() FROM  dual;


DELIMITER //;
--error 0,1305
drop procedure p_test;//
create  PROCEDURE p_test(in wb varchar(200))
begin
	declare i int;
  	set i := 1;
	WHILE i <= 1 do
    INSERT INTO t1 VALUES(0,15879,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000',wb);
	set i := i+1;
	END while;
END;
//
DELIMITER ;//

CALL p_test(f_test());
SELECT COUNT(*) FROM t1;



