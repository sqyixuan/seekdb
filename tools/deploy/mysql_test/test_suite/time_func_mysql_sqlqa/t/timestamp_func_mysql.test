--echo # timestamp-2-mysql
 # 普通表
CREATE TABLE `t1` (
  `id` int NOT NULL AUTO_INCREMENT,
  `consumer` char(20) DEFAULT NULL,
  `brand` varchar(20) DEFAULT NULL,
  `sal` bigint DEFAULT NULL,
  PRIMARY KEY (`id`)
);

INSERT INTO t1 VALUES(1,'书局','apple',5000);
INSERT INTO t1 VALUES(2,'微山','xiaomi',-4000);
INSERT INTO t1 VALUES(3,'深咖','oppo',0);
INSERT INTO t1 VALUES(4,'流苏','huawei',NULL);
INSERT INTO t1 VALUES(5,'玻璃','LG',6000);
INSERT INTO t1 VALUES(6,'钛钢','HTC',8000);
INSERT INTO t1 VALUES(7,'合金','VIVO',3500);


CREATE TABLE `t2` (
  `id` int NOT NULL AUTO_INCREMENT,
  `model` varchar(200) DEFAULT NULL,
  `Price` bigint DEFAULT NULL,
  PRIMARY KEY (`id`)
);

INSERT INTO t2 VALUES(1,'apple 12',7000);
INSERT INTO t2 VALUES(2,'xiaomi 9',0);
INSERT INTO t2 VALUES(3,'oppo findx',-6000);
INSERT INTO t2 VALUES(4,'huawei mata30',8000);
INSERT INTO t2 VALUES(5,'huawei mata30',NULL);
INSERT INTO t2 VALUES(6,'htc cc30',26.44);
INSERT INTO t2 VALUES(7,'shumei xi2',-26.44);

 # 视图
--error 0,1051
DROP VIEW T1_VIEW;
--error 0,1051
DROP VIEW T2_VIEW;
CREATE VIEW t1_view AS SELECT *  FROM t1;
CREATE VIEW t2_view AS SELECT *  FROM t2;


 # SELECT bug：35325746
SELECT timestamp(e.id) FROM t1 e;
SELECT timestamp(e.consumer) FROM t1 e;
SELECT timestamp(e.brand) FROM t1 e;
SELECT * FROM t1 e WHERE timestamp(e.sal) = 1;

 # left join + right join + inner join
SELECT timestamp(e.sal) sal,timestamp(p.Price) FROM t1 e LEFT JOIN t2 p ON e.id = p.id ORDER BY e.sal DESC;
SELECT timestamp(e.sal) sal,timestamp(p.Price) FROM t1 e RIGHT JOIN t2 p ON e.id = p.id ORDER BY e.sal DESC;
SELECT timestamp(e.sal) sal,timestamp(p.Price) FROM t1 e INNER JOIN t2 p ON e.id = p.id ORDER BY e.sal DESC;
SELECT * FROM (SELECT e.id,timestamp(e.sal) sal,timestamp(p.Price) FROM t1 e LEFT JOIN t2 p ON e.id = p.id ) e ORDER BY e.sal;

 # ANY
SELECT *  FROM t1 e WHERE timestamp(e.sal) = ANY (SELECT timestamp(p.Price) FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE timestamp(e.sal) < ANY (SELECT timestamp(p.Price) FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE timestamp(e.sal) > ANY (SELECT timestamp(p.Price) FROM t2 p ) ORDER BY e.id;

 # ALL
SELECT *  FROM t1 e WHERE timestamp(e.sal) < ALL (SELECT timestamp(p.Price) FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE timestamp(e.sal) > ALL (SELECT timestamp(p.Price) FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE timestamp(e.sal) = ALL (SELECT timestamp(p.Price) FROM t2 p WHERE p.model = 'oppo findx') ORDER BY e.id;

 # EXISTS AND NOT EXISTS  bug：35325746
SELECT *  FROM t1 e WHERE EXISTS (SELECT timestamp(p.Price) FROM t2 p ) ORDER BY e.id;
SELECT timestamp(e.sal)  FROM t1 e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2 p WHERE timestamp(p.Price)=7500 ) ORDER BY e.id;

 # CREATE AS  
--error 0,1292
