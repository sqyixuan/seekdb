--error 0,1051
DROP TABLE t3;

--error 0,1292
CREATE TABLE t3 AS SELECT * FROM t1 e WHERE timestamp(e.sal) <=> NULL;
--error 0,1051
DROP TABLE t3;

CREATE TABLE t3 AS SELECT * FROM t1 e WHERE timestamp(e.sal) = NUll;
--error 0,1051
DROP TABLE t3;

 # LIKE
SELECT brand, timestamp(brand) FROM t1 e WHERE e.brand LIKE '%a%';
SELECT sal, timestamp(sal) FROM t1 e LEFT JOIN t2 p ON e.id = p.id WHERE e.sal LIKE '%00%';

 # WHERE
SELECT * FROM t1 e WHERE timestamp(e.sal) = 0;
SELECT * FROM t1 e WHERE timestamp(e.sal) = 1;
SELECT * FROM t1 e WHERE timestamp(e.sal) = NULL;
SELECT * FROM t1 e WHERE timestamp(e.sal) > 0 ORDER BY e.id;
SELECT * FROM t1 e WHERE timestamp(e.sal) >= 0 ORDER BY e.id;
SELECT * FROM t1 e WHERE timestamp(e.sal) < 0 ORDER BY e.id;
SELECT * FROM t1 e WHERE timestamp(e.sal) <= 0 ORDER BY e.id;
SELECT * FROM t1 e WHERE timestamp(e.sal) = 1 ORDER BY e.id;
SELECT * FROM t1 e WHERE timestamp(e.sal) <> 0 ORDER BY e.id;

 # ORDER BY
SELECT e.id, e.sal, timestamp(e.sal) FROM t1 e WHERE e.id > 0 ORDER BY timestamp(e.sal);
SELECT e.id, e.sal, timestamp(e.sal) FROM t1 e WHERE e.id > 0 ORDER BY timestamp(e.sal) DESC;
SELECT e.id, e.sal, timestamp(e.brand) FROM t1 e WHERE e.id > 0 ORDER BY timestamp(e.brand) ASC;
SELECT e.id, e.sal, timestamp(e.brand) FROM t1 e WHERE e.id > 0 ORDER BY timestamp(e.brand) DESC;


 # GROUP BY HAVING
SELECT e.id, timestamp(e.sal), SUM(e.sal+p.Price) FROM t1 e ,t2 p WHERE e.id=p.id GROUP BY e.id, timestamp(e.sal)  ORDER BY e.id;
SELECT e.id, e.sal,timestamp(e.sal) tt, SUM(e.sal+p.Price) FROM t1 e ,t2 p WHERE e.id=p.id GROUP BY e.id, timestamp(e.sal) HAVING tt > -1 ORDER BY e.id;

 # CASE WHEN  bug：35325746
select id, sal, timestamp(case when sal=0 then 200 else sal end ) from t1_view ORDER BY id;
select id, sal, timestamp(case when sal>0 then 200 else sal end ) from t1_view order by id;
select id, sal, timestamp(case when sal=0 then 200 else sal end ), COUNT(*) from t1_view GROUP by timestamp(case when sal=0 then 200 else sal end ),id ORDER BY id;

