DROP TABLE IF EXISTS t1;
CREATE TABLE `t1` (
  `id` int NOT NULL AUTO_INCREMENT,
  `consumer` char(20) NOT NULL,
  `price` varchar(20) DEFAULT NULL,
  `sal` int DEFAULT NULL,
  `datetime1` DATE,
  `datetime2` bigint,
  PRIMARY KEY (`id`),
  UNIQUE KEY `t1_UN` (`price`)
);
INSERT INTO t1 VALUES(1,'书局','7000',5000,'2020-09-22',20200923121200);
INSERT INTO t1 VALUES(2,'微山','3000',-4000,'2020-09-21',20200921101159);
INSERT INTO t1 VALUES(3,'深咖','5000',0,'2020-08-21',20190821101159);
INSERT INTO t1 VALUES(4,'流苏','0',NULL,'2020-02-29',20200228101159);
INSERT INTO t1 VALUES(5,'玻璃','3200',6000,'2020-02-29',20200228101159);
INSERT INTO t1 VALUES(6,'钛钢',NULL,8000,'2020-02-29',20200228101159);
INSERT INTO t1 VALUES(7,'合金','VIVO',3500,'2020-02-29',20200228101159);

 # select
SELECT makedate(price,10) FROM t1 order by id;
SELECT makedate(sal,10) FROM t1 order by id;
SELECT makedate(datetime1,10), makedate(datetime2,10), makedate(sal,10), makedate(price,10) FROM t1 order by id;
SELECT id, consumer, makedate(sal,10), makedate(price,10) FROM t1 WHERE makedate(sal,10)>0 ORDER BY id DESC;
SELECT id,consumer, makedate(sal,10), makedate(price,10) FROM t1 WHERE makedate(sal,10)<0 ORDER BY makedate(sal,10);
SELECT id, sal,SUM(makedate(sal,10)) FROM t1 WHERE t1.sal <> 6000 GROUP BY sal,id HAVING SUM(makedate(sal,10)) > 0 ORDER BY id;

