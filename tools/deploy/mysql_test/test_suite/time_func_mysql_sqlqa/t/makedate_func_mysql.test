--echo # makedate-4-mysql
--echo # 函数嵌套
DROP TABLE IF EXISTS t1;
CREATE TABLE T1(
    a bigint,
	b varchar(30),
	c timestamp
)PARTITION BY RANGE(a)
(
	PARTITION id_part1 values less than (3),
	PARTITION id_part2 values less than (8),
	PARTITION id_part3 values less than (MAXVALUE)
);
 # insert
insert into t1 values (1, CAST(makedate(2012,10) AS UNSIGNED INTEGER), '2013-05-22 18:32:37.000');
insert into t1 values (2, null , '1992-01-02 23:51:32.000');
insert into t1 values (3, FROM_UNIXTIME(UNIX_timestamp(makedate('1995',10))), '2006-08-09 03:20:51');
insert into t1 values (4, hour(makedate('1995',10)), '1980-12-03 01:08:01.000');
# insert into t1 values (5, makedate(now(),10), '1980-12-03 01:08:01.000');
# insert into t1 values (6, makedate(CURRENT_timestamp(),10), '1980-12-03 01:08:01.000');
insert into t1 values (7, date(makedate('1980',10)), '1980-12-03 01:08:01.000');
# insert into t1 values (8, makedate(SYSDATE(),10), '2006-03-31 14:45:32.000');
# insert into t1 values (9, makedate(CURRENT_TIME(),10), '2006-03-31 14:45:32.000');
# insert into t1 values (10, makedate(CURRENT_DATE(),10), '2006-03-31 14:45:32.000');
insert into t1 values(11, (select makedate(e.c,10) from t1 e where a=3),  '2006-08-09 03:20:51');
insert into t1 values (makedate(201,10), '2006-08-09 03:20:51', '2015-01-30 06:13:54.000');

 # update
update t1 set b = DATE_FORMAT(makedate('2014',10), '%Y-%M-%D') where a = 1;
update t1 set b = makedate(STR_TO_DATE('2014-January-1st', '%Y-%M-%d'),10) where a = 3;
update t1 set b = TIME_TO_USEC(makedate('2014',10)) where a = 4;


--echo # 分区表
DROP TABLE IF EXISTS t1;
CREATE TABLE T1(
    a bigint,
	b datetime
)partition by range columns(b) subpartition by hash(a) subpartitions 2
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);

insert into t1 values(1,(substr(makedate('2012',10),1)));
insert into t1 values(LENGTH(makedate('1995',10)),'1995-12-02 22:30:27');
insert into t1 values(ROUND(makedate('2006',10)), '2006-08-09 03:20:51');
insert into t1 values(CEIL(makedate('2006',10)), '2006-03-31 14:45:32');
insert into t1 values(FLOOR(makedate('2016',10)), '2016-03-19 13:22:51');
insert into t1 values(ABS(makedate('2010',10)), '2010-12-03 16:03:03');
insert into t1 values(NEG(makedate('1992',10)), '1992-01-02 23:51:32');
insert into t1 values(SIGN(makedate('1980',10)), '1980-12-03 01:08:01.000');
insert into t1 values(11,null);
select least(makedate(b,10), '1987-06-28 02:24:22.000', sign(null)) from t1;
select least(makedate(b,10), '1987-06-28 02:24:22.000') from t1;
select * from t1 where makedate(b,10) is null;
select * from t1 where makedate(b,10) is not null;


