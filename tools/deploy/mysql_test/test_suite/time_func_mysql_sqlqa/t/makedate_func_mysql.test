 # 生成列:datetime 类型 + 算数运算
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
    a INT AUTO_INCREMENT PRIMARY KEY,
	c_time varchar(50),
    d_time datetime GENERATED ALWAYS AS (makedate(c_time,10) + 1234)
);
CREATE INDEX idx_t1 ON T1(d_time);
