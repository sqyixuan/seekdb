SELECT makedate('2003',10) > makedate('2003',9) FROM DUAL;
SELECT makedate('2003',10) < makedate('2003',9) FROM DUAL;
SELECT makedate('2003',10) = makedate('2003',10) FROM DUAL;
SELECT makedate('2003',10) <=> makedate(NULL,10)  FROM DUAL;
SELECT makedate(null,10) <=> makedate(NULL,10)  FROM DUAL;

SELECT '2013-12-31 12:00:00' BETWEEN makedate('2003',10) AND makedate('2023',10) FROM DUAL;
SELECT '2013-12-31' BETWEEN makedate('2003',0) AND makedate('2013',20) FROM DUAL;
SELECT '2013-12-31 12:00:00' BETWEEN makedate('2003',1) AND makedate('2023',1) FROM DUAL;

