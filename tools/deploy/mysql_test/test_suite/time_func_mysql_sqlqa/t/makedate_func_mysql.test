 # UPDATE
UPDATE t2_view SET MODEL = 'xiaomi 10' WHERE makedate(Price,10) = '2026-01-10 ';
UPDATE t2_view SET price = '9000' WHERE makedate(Price,10) < 0;
UPDATE t2_view SET price = (SELECT makedate(t1.sal,10) FROM t1 WHERE makedate(t1.sal,10) = '2000-01-10 ' ) WHERE id = 1 ;
SELECT price FROM t2_view;

# UPDATE t2_view SET price = (makedate(now(),10));
