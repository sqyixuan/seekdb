SELECT TIME_FORMAT('2003-12-31 12:00:00','%T.%f') >> TIME_FORMAT(201,'%T.%f') FROM DUAL;
SELECT TIME_FORMAT('2003-12-31 12:00:00','%T.%f') << TIME_FORMAT(201,'%T.%f') FROM DUAL;
SELECT ~TIME_FORMAT(201,'%T.%f') FROM DUAL;
SELECT ~TIME_FORMAT('2003-12-31 12:00:00','%T.%f') FROM DUAL;
SELECT ~TIME_FORMAT(0,'%T.%f') FROM DUAL;

SELECT TIME_FORMAT('09:10:05','%T.%f') > TIME_FORMAT('09:10:06','%T.%f') FROM DUAL;
