--echo # timeformat-4-mysql
--echo # 函数嵌套
--error 0,1051
DROP TABLE t1;
CREATE TABLE T1(
    a bigint,
	b varchar(30),
	c timestamp
)PARTITION BY RANGE(a)
(
	PARTITION id_part1 values less than (3),
	PARTITION id_part2 values less than (8),
	PARTITION id_part3 values less than (MAXVALUE)
);
 # insert
insert into t1 values (1, CAST(time_format('2012-04-20 11:57:49.000', '%H%i%s') AS UNSIGNED INTEGER), '2013-05-22 18:32:37.000');
