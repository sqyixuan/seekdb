--error 0,1051
DROP TABLE t3;

CREATE TABLE t3 AS SELECT * FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') = NUll;
--error 0,1051
DROP TABLE t3;


 # LIKE
SELECT brand, time_format(brand, '%r %T %H %k %I %i %s %f') as tf FROM t1 e WHERE time_format(brand, '%r %T %H %k %I %i %s %f') LIKE '%12:00%';
SELECT sal, time_format(sal, '%r %T %H %k %I %i %s %f') FROM t1 e LEFT JOIN t2 p ON e.id = p.id WHERE e.sal LIKE '%00%';

 # WHERE
SELECT * FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') = 0;
SELECT * FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') = '-12:40:00 AM 00:40:00 00 0 12 40 00 000000';
SELECT * FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') = NULL;
SELECT * FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') <=> NULL;
SELECT * FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') > 0 ORDER BY e.id;
SELECT * FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') >= 0 ORDER BY e.id;
SELECT * FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') < 0 ORDER BY e.id;
SELECT * FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') <= 0 ORDER BY e.id;
SELECT * FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') = 1 ORDER BY e.id;
SELECT * FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') <> 0 ORDER BY e.id;

 # ORDER BY
SELECT e.id, e.sal, time_format(e.sal, '%r %T %H %k %I %i %s %f') FROM t1 e WHERE e.id > 0 ORDER BY time_format(e.sal, '%r %T %H %k %I %i %s %f');
SELECT e.id, e.sal, time_format(e.sal, '%r %T %H %k %I %i %s %f') FROM t1 e WHERE e.id > 0 ORDER BY time_format(e.sal, '%r %T %H %k %I %i %s %f') DESC;
SELECT e.id, e.sal, time_format(e.brand, '%r %T %H %k %I %i %s %f') FROM t1 e WHERE e.id > 0 ORDER BY time_format(e.brand, '%r %T %H %k %I %i %s %f') ASC;
SELECT e.id, e.sal, time_format(e.brand, '%r %T %H %k %I %i %s %f') FROM t1 e WHERE e.id > 0 ORDER BY time_format(e.brand, '%r %T %H %k %I %i %s %f') DESC;

 # GROUP BY HAVING
SELECT e.id, time_format(e.sal, '%r %T %H %k %I %i %s %f'), SUM(e.sal+p.Price) FROM t1 e ,t2 p WHERE e.id=p.id GROUP BY e.id, time_format(e.sal, '%r %T %H %k %I %i %s %f')  ORDER BY e.id;
SELECT e.id, e.sal,time_format(e.sal,'%r %T %H %k %I %i %s %f') tt, SUM(e.sal+p.Price) FROM t1 e ,t2 p WHERE e.id=p.id GROUP BY e.id, time_format(e.sal, '%r %T %H %k %I %i %s %f') HAVING tt > -1 ORDER BY e.id;
SELECT e.id, e.sal,time_format(e.sal+p.Price,'%r %T %H %k %I %i %s %f') tt, SUM(e.sal+p.Price) FROM t1 e ,t2 p WHERE e.id=p.id GROUP BY e.id, time_format(e.sal+p.Price, '%r %T %H %k %I %i %s %f') HAVING tt > -1 ORDER BY e.id;

 # CASE WHEN 
select id, sal, time_format(case when sal=0 then 200 else sal end, '%r %T %H %k %I %i %s %f') from t1_view ORDER BY id;
select id, sal, time_format(case when sal=0 then 6000 else sal end, '%r %T %H %k %I %i %s %f') from t1_view ORDER BY id;
select id, sal, time_format(case when sal=0 then null else sal end, '%r %T %H %k %I %i %s %f') from t1_view ORDER BY id;
select id, sal, time_format(case when sal>0 then 200 else sal end, '%r %T %H %k %I %i %s %f') from t1_view order by id;
select id, sal, time_format(case when sal=0 then 200 else sal end, '%r %T %H %k %I %i %s %f' ), COUNT(*) from t1_view GROUP by time_format(case when sal=0 then 200 else sal end, '%r %T %H %k %I %i %s %f' ),id ORDER BY id;

