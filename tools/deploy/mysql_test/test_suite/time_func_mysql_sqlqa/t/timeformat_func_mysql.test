# 视图
--error 0,1051
DROP VIEW T1_VIEW;
--error 0,1051
DROP VIEW T2_VIEW;

CREATE VIEW t1_view AS SELECT *  FROM t1;
CREATE VIEW t2_view AS SELECT *  FROM t2;

SELECT TIME_FORMAT(e.id, '%r %T %H %k %I %i %s %f') FROM t1 e;
SELECT TIME_FORMAT(e.consumer, '%r %T %H %k %I %i %s %f') FROM t1 e;
SELECT TIME_FORMAT(e.brand, '%r %T %H %k %I %i %s %f') FROM t1 e;
SELECT * FROM t1 e WHERE TIME_FORMAT(e.sal, '%r %T %H %k %I %i %s %f') = 1;

 # left join + right join + inner join
SELECT TIME_FORMAT(e.sal, '%r %T %H %k %I %i %s %f') sal,TIME_FORMAT(p.Price, '%r %T %H %k %I %i %s %f') FROM t1 e LEFT JOIN t2 p ON e.id = p.id ORDER BY e.sal DESC;
SELECT e.sal, TIME_FORMAT(e.sal, '%r %T %H %k %I %i %s %f') sal,TIME_FORMAT(p.Price, '%r %T %H %k %I %i %s %f') FROM t1 e RIGHT JOIN t2 p ON e.id = p.id ORDER BY e.sal DESC;
SELECT TIME_FORMAT(e.sal, '%r %T %H %k %I %i %s %f') sal,TIME_FORMAT(p.Price, '%r %T %H %k %I %i %s %f') FROM t1 e INNER JOIN t2 p ON e.id = p.id ORDER BY e.sal DESC;
SELECT * FROM (SELECT e.id,TIME_FORMAT(e.sal, '%r %T %H %k %I %i %s %f') sal,TIME_FORMAT(p.Price, '%r %T %H %k %I %i %s %f') FROM t1 e LEFT JOIN t2 p ON e.id = p.id ) e ORDER BY e.id;

 # ANY
SELECT *  FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') = ANY (SELECT time_format(p.Price, '%r %T %H %k %I %i %s %f') FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') < ANY (SELECT time_format(p.Price, '%r %T %H %k %I %i %s %f') FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') > ANY (SELECT time_format(p.Price, '%r %T %H %k %I %i %s %f') FROM t2 p ) ORDER BY e.id;

 # ALL
SELECT *  FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') < ALL (SELECT time_format(p.Price, '%r %T %H %k %I %i %s %f') FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') > ALL (SELECT time_format(p.Price, '%r %T %H %k %I %i %s %f') FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') = ALL (SELECT time_format(p.Price, '%r %T %H %k %I %i %s %f') FROM t2 p WHERE p.model = 'oppo findx') ORDER BY e.id;

 # EXISTS AND NOT EXISTS 
SELECT *  FROM t1 e WHERE EXISTS (SELECT time_format(p.Price, '%r %T %H %k %I %i %s %f') FROM t2 p ) ORDER BY e.id;
SELECT time_format(e.sal, '%r %T %H %k %I %i %s %f')  FROM t1 e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2 p WHERE time_format(p.Price, '%r %T %H %k %I %i %s %f')=7500 ) ORDER BY e.id;


 # CREATE AS  
--error 0,1292
CREATE TABLE t3 AS SELECT * FROM t1 e WHERE time_format(e.sal, '%r %T %H %k %I %i %s %f') = '12:50:00 AM 00:50:00 00 0 12 50 00 000000';
