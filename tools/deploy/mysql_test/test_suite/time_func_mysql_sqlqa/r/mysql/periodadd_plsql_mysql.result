drop procedure p_test;//
CREATE PROCEDURE p_test()
begin
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = '202709' into a;
SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = '202204' into b;
WHILE i < 1 do
INSERT INTO t1 VALUES(0,a,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000','2002-06-20 05:50:54');
INSERT INTO t1 VALUES(0,b,32209,'2005-11-05','07:00:06',2005,'1982-04-20 13:13:32.000','2014-11-24 23:19:45.000');
set i := i + 1;
END while;
END;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
10
CALL p_test();
SELECT COUNT(*) FROM t1;
COUNT(*)
12
delete from t1 where id in (1088,32209);
drop procedure p_test;//
CREATE PROCEDURE p_test(in samplename varchar(200))
begin
declare i int;
declare a varchar(200);
declare b varchar(200);
SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = samplename into a;
SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = samplename into b;
set i := 1;
repeat
INSERT INTO t1 VALUES(0,a,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000','2002-06-20 05:50:54');
INSERT INTO t1 VALUES(0,b,32209,'2005-11-05','07:00:06',2005,'1982-04-20 13:13:32.000','2014-11-24 23:19:45.000');
set i := i+1;
until i >= 2
end	 repeat;
END ;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
10
CALL p_test(500);
CALL p_test(0);
CALL p_test(-1);
CALL p_test('202709');
CALL p_test(NULL);
SELECT COUNT(*) FROM t1;
COUNT(*)
20
delete from t1 where id in (1088,32209);
drop procedure p_test;//
CREATE PROCEDURE p_test(out wb  varchar(200), out wb1  varchar(200))
begin
declare i int;
SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE TIME_FORMAT(e.time_stp,10) ='2015-01-30 06:13:54' into wb;
SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE TIME_FORMAT(e.time_stp,10) ='2018-01-20 10:56:17' into wb1;
set i :=  1;
while i <= 1 do
INSERT INTO t1 VALUES(0,wb,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000','2002-06-20 05:50:54');
INSERT INTO t1 VALUES(0,wb1,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000','2002-06-20 05:50:54');
set i := i + 1;
end while;
END;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
10
call p_test(@wb,@wb1);
SELECT COUNT(*) FROM t1;
COUNT(*)
12
delete from t1 where id in (1088,32209);
