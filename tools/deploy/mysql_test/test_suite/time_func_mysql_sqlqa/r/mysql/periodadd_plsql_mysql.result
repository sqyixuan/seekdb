CREATE  FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
begin
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = samplename into a;
SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10) = samplename1 into b;
repeat 	
INSERT INTO t1 VALUES(0,a,1088,'1985-05-10','05:14:41',1984,'2000-03-23 00:15:01.000','2002-06-20 05:50:54'),(0,b,32209,'2005-11-05','07:00:06',2005,'1982-04-20 13:13:32.000','2014-11-24 23:19:45.000');
set i := i + 1;
until i >= 1	
end repeat;
return period_add(a,10);
END;
//
