CREATE  FUNCTION f_test()
returns varchar(200)
begin
declare a varchar(200);
SELECT PERIOD_ADD(year_3,10) FROM t1 e WHERE PERIOD_ADD(year_3,10)='202709' INTO a;
return a;
END;
//
SELECT f_test();
f_test()
202709
drop function f_test ;//
CREATE FUNCTION f_test(samplename varchar(200))
returns varchar(200)
begin
declare a varchar(200);
SELECT PERIOD_ADD(samplename,10) FROM t1 e WHERE PERIOD_ADD(year_3,10)='202709' INTO a ;
return a;
END;
//
SELECT f_test(-100);
f_test(-100)
0
SELECT f_test('2015');
f_test('2015')
202201
SELECT f_test('0000-12-25 00:00:00');
f_test('0000-12-25 00:00:00')
0
Warnings:
Warning	1292	Truncated incorrect INTEGER value: '0000-12-25 00:00:00'
SELECT f_test('09:10:05:12:34:44');
f_test('09:10:05:12:34:44')
200107
Warnings:
Warning	1292	Truncated incorrect INTEGER value: '09:10:05:12:34:44'
SELECT f_test(abc);
SELECT f_test(NULL);
f_test(NULL)
NULL
