DROP TABLE t1;
CREATE TABLE t1 (
a INT AUTO_INCREMENT PRIMARY KEY,
c_time varchar(50),
d_time varchar(50) GENERATED ALWAYS AS (case when timestamp(c_time) > "2021-07-06" then "now" when timestamp(c_time) <= "2021-07-06" then 'yesterday' end)
);
