DROP TABLE T1;
CREATE TABLE `t1` (
a bigint DEFAULT NULL,
b float DEFAULT NULL,
c double DEFAULT NULL,
d date DEFAULT NULL,
e time DEFAULT NULL,
f year DEFAULT NULL,
g timestamp,
h char(20) DEFAULT NULL,
i varchar(20) DEFAULT NULL,
j text DEFAULT NULL
);
