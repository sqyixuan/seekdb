DROP TABLE t1;
CREATE TABLE t1 (
a INT AUTO_INCREMENT PRIMARY KEY,
c_time timestamp,
d_time varchar(101) GENERATED ALWAYS AS (period_add(c_time,10) + 123456789)
);
