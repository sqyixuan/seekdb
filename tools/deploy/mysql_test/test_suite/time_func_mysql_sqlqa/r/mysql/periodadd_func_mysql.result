CREATE TABLE t1 (
a INT,
c_time VARCHAR(50),
d_time VARCHAR(101) GENERATED ALWAYS AS (period_add(c_time,10))
);
CREATE UNIQUE INDEX idx_t1 ON T1(d_time);
DROP INDEX idx_t1 ON t1;
