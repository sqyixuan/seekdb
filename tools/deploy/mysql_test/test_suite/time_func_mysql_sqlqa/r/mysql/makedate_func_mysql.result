CREATE TABLE t1 (
a INT AUTO_INCREMENT PRIMARY KEY,
c_time varchar(50),
d_time varchar(50) GENERATED ALWAYS AS (case when makedate(c_time,10) > "20210706" then "now" when makedate(c_time,10) <= "20210706" then 'yesterday' end)
);
CREATE INDEX idx_t1 ON T1(d_time);
