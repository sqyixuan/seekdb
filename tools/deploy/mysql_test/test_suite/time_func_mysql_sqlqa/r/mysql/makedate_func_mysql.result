update t1 set b = TIME_TO_USEC(makedate('2014',10)) where a = 4;
# 分区表
DROP TABLE IF EXISTS t1;
CREATE TABLE T1(
a bigint,
b datetime
)partition by range columns(b) subpartition by hash(a) subpartitions 2
( 
partition part_1 values less than ('2016-09-01'),
partition part_2 values less than ('2020-09-01'),
partition part_3 values less than ('2021-09-01')
);
