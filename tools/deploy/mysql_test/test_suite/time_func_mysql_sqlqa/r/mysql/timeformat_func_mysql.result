insert into t1 values (7, date(time_format('1980-12-03 01:08:01.000', '%H%i%s.%f')), '1980-12-03 01:08:01.000');
insert into t1 values (10, time_format(CURRENT_DATE(), '%H%i%s.%f'), '2006-03-31 14:45:32.000');
