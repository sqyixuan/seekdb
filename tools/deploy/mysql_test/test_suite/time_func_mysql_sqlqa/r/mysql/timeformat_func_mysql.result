insert into t1 values (time_format(201, '%H%i%s.%f'), '2006-08-09 03:20:51', '2015-01-30 06:13:54.000');
update t1 set b = time_format(STR_TO_DATE('1995-12-02 22:30:27', '%Y-%m-%d'), '%H%i%s.%f') where a = 3;
# 分区表
DROP TABLE t1;
CREATE TABLE T1(
a bigint,
b datetime
)partition by range columns(b) subpartition by hash(a) subpartitions 2
( 
partition part_1 values less than ('2016-09-01'),
partition part_2 values less than ('2020-09-01'),
partition part_3 values less than ('2021-09-01')
);
