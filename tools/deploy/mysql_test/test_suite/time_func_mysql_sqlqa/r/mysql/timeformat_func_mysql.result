DROP TABLE t1;
CREATE TABLE t1 (
a INT AUTO_INCREMENT PRIMARY KEY,
c_time varchar(50),
d_time varchar(50) GENERATED ALWAYS AS (case when time_format(c_time,'%H:%i:%s.%f') > "10:10:10" then "now" when time_format(c_time, '%H:%i:%s.%f') <= "21:10:10" then 'yesterday' end)
);
CREATE INDEX idx_t1 ON T1(d_time);
