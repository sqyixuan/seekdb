drop user lcq1;
create user lcq1 identified by "lcq";
grant all on *.* to lcq1;
drop user lcq3;
create user lcq3 identified by "lcq";
grant all on *.* to lcq3;
drop table t1;
create table t1(c1 int, c2 int);
insert into t1 values(1, 2);
insert into t1 values(1, 3);
insert into t1 values(4, 5);
create view v as select c1 from t1 group by c2;
set autocommit = on;
set sql_mode = 'ONLY_FULL_GROUP_BY';
select * from v@my_link1;
ERROR 42000: nonaggregated column is not functionally dependent on columns in GROUP BY clause; this is incompatible with sql_mode=only_full_group_by
set sql_mode = '';
select * from v@my_link1;
c1
1
1
4
drop table t1;
drop view v;
drop user lcq1;
drop user lcq3;
drop database link my_link1;
