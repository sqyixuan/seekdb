drop user lcq1;
create user lcq1 identified by "lcq";
grant all on *.* to lcq1;
drop user lcq3;
create user lcq3 identified by "lcq";
grant all on *.* to lcq3;
drop table t1;
create table t1(c1 int, c2 int, c3 int);
insert into t1 values(1, 2, 3);
set autocommit = on;
drop table t2;
create table t2(c1 int, c2 int, c3 int);
insert into t2 values(1, 2, 3);
select * from t1@my_link1;
c1	c2	c3
1	2	3
select * from t1@my_link1 a , t2 b where a.c1 = b.c2;
c1	c2	c3	c1	c2	c3
delete from t1@my_link1;
