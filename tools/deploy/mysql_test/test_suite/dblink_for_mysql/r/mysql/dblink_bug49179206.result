drop user link1;
create user link1 identified by "link";
grant all on *.* to link1;
drop user link3;
create user link3 identified by "link";
grant all on *.* to link3;
drop database if exists link1;
drop database if exists link3;
create database if not exists link1;
create database if not exists link3;
create table t1(c1 int, c2 int);
insert into t1 values(1, 2);
insert into t1 values(1, 3);
insert into t1 values(4, 5);
CREATE TABLE d0(c0 DECIMAL(27, 0) )  PARTITION BY KEY (c0) partitions 8;
insert into d0(c0) values(5172020946056835000);
insert into d0(c0) values(1);
insert into d0(c0) values(0);
insert into d0(c0) values(NULL);
CREATE TABLE t2(c0 DECIMAL(9, 0) , c1 TINYTEXT  COMMENT 'asdf'  , c2 MEDIUMINT ZEROFILL );
insert into t2(c0) values(6);
set autocommit = on;
result_format: 4
explain_protocol: 0
SELECT  (SELECT MIN(c1) FROM t1@my_link1), c2 FROM (SELECT c1, c2 FROM t1@my_link1) WHERE c1 < c2 ORDER BY 2 DESC, 1 DESC LIMIT 0, 2;
+-----------------------------------+------+
| (SELECT MIN(c1) FROM t1@my_link1) | c2   |
+-----------------------------------+------+
|                                 1 |    5 |
|                                 1 |    3 |
+-----------------------------------+------+

SELECT  (SELECT MIN(c1) FROM t1@my_link1), c2 FROM (SELECT c1, c2 FROM t1@my_link1) WHERE c1 < c2 ORDER BY 2 DESC, 1 DESC LIMIT 1, 2;
+-----------------------------------+------+
| (SELECT MIN(c1) FROM t1@my_link1) | c2   |
+-----------------------------------+------+
|                                 1 |    3 |
|                                 1 |    2 |
+-----------------------------------+------+

SELECT  (SELECT MIN(c1) FROM t1@my_link1), c2 FROM (SELECT c1, c2 FROM t1@my_link1) WHERE c1 < c2 ORDER BY 2 DESC, 1 DESC LIMIT 2;
+-----------------------------------+------+
| (SELECT MIN(c1) FROM t1@my_link1) | c2   |
+-----------------------------------+------+
|                                 1 |    5 |
|                                 1 |    3 |
+-----------------------------------+------+

SELECT  (SELECT MIN(c1) FROM t1@my_link1), c2 FROM (SELECT c1, c2 FROM t1@my_link1) WHERE c1 < c2 ORDER BY 2 DESC, 1 DESC LIMIT 2 OFFSET 1;
+-----------------------------------+------+
| (SELECT MIN(c1) FROM t1@my_link1) | c2   |
+-----------------------------------+------+
|                                 1 |    3 |
|                                 1 |    2 |
+-----------------------------------+------+

SELECT /*+no_rewrite*/ c1 + (SELECT  (SELECT MIN(c1) FROM t1@my_link1) FROM (SELECT c1, c2 FROM t1@my_link1) WHERE c1 < c2 ORDER BY 1 DESC LIMIT 1 OFFSET 1) FROM t1@my_link1;
+---------------------------------------------------------------------------------------------------------------------------------------+
| c1 + (SELECT  (SELECT MIN(c1) FROM t1@my_link1) FROM (SELECT c1, c2 FROM t1@my_link1) WHERE c1 < c2 ORDER BY 1 DESC LIMIT 1 OFFSET 1) |
+---------------------------------------------------------------------------------------------------------------------------------------+
|                                                                                                                                     2 |
|                                                                                                                                     2 |
|                                                                                                                                     5 |
+---------------------------------------------------------------------------------------------------------------------------------------+

SELECT * FROM t1@my_link1 where 3 > 1 + (SELECT  (SELECT MIN(c1) FROM t1@my_link1) FROM (SELECT c1, c2 FROM t1@my_link1) WHERE c1 < c2 ORDER BY 1 DESC LIMIT 1 OFFSET 1);
+------+------+
| c1   | c2   |
+------+------+
|    1 |    2 |
|    1 |    3 |
|    4 |    5 |
+------+------+

