drop table set_t;
create table set_t(c_set set('123', 'abcd', 'ABC'));
insert into set_t values ('123,abcd,ABC');
insert into set_t values ('123,ABC');
insert into set_t values ('123');
drop table precison_t;
create table precison_t(c_float float(8,2), c_double double(10,3));
