drop user lcq1;
create user lcq1 identified by "lcq";
grant all on *.* to lcq1;
drop user lcq3;
create user lcq3 identified by "lcq";
grant all on *.* to lcq3;
drop table number_t;
create table number_t(c_tinyint tinyint, c_smallint smallint, c_mediumint mediumint, c_int int, c_bigint bigint, c_float float, c_double double, c_decimal decimal(40,10));
insert into number_t values(127, 32767, 8388, 214748, 92233720368, 3.402823466351, 1.7976931348623157, 123456789123456789.123456789);
drop table datetime_t;
create table datetime_t(c_date date, c_time time, c_year year, c_datetime datetime, c_timestamp timestamp);
insert into datetime_t values('2023-4-13', '12:12:12', '2078', '2100-11-1 12:12:13', '2100-12-1 13:14:15');
drop table string_t_link;
