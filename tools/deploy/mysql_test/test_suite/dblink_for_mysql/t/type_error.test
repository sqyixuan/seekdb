grant all on *.* to lcq1;
--error 0,1396
drop user lcq3;
create user lcq3 identified by "lcq";
grant all on *.* to lcq3;

connect (conn_lcq1,$OBMYSQL_MS0,lcq1,lcq,test,$OBMYSQL_PORT);
connection conn_lcq1;

#number type test
--error 0, 1051
drop table cast_table;
--error 0, 1051
create table cast_table(a float) ;
insert into cast_table values(-5656.565);
select cast(a as unsigned) from cast_table;
--error 0, 1051
drop table ljh_test;
--error 0, 1051
create table ljh_test(c1 int,c2 int);
insert into ljh_test values (-5656.565,5656.565);
SELECT BIT_OR(c1) OVER (PARTITION BY c2 ORDER BY C2) FROM ljh_test;

CREATE TABLE IF NOT EXISTS t0(c0 FLOAT , c1 DECIMAL(8, 0) , c2 DECIMAL(29, 0) ZEROFILL , c3 FLOAT ZEROFILL , c4 FLOAT(1, 0) ZEROFILL )  PARTITION BY KEY (c0, c3, c4, c2) partitions 11;
insert into t0 values(NULL,NULL,4394478091032449000,6,0);
insert into t0 values(1442970000,23397312,NULL,NULL,5);

CREATE TABLE t3(c0 DECIMAL(30, 0)  NULL COMMENT 'asdf' , c1 SMALLINT ZEROFILL  COMMENT 'asdf' , c2 DECIMAL(40, 0) ZEROFILL )  BLOCK_SIZE =  32768  PARTITION BY KEY (c0) SUBPARTITION BY HASH(c1)  subpartitions 6 partitions 20;
create table t2 like t3;
REPLACE INTO t3(c2) VALUES(1);
REPLACE INTO t2(c1) VALUES(2);
SELECT * FROM t3 t3D, t2 WHERE ("") OR concat(t3D.c2,'') = '0000000000000000000000000000000000000001' AND t2.c1='00002' ;

connect (conn_lcq3,$OBMYSQL_MS0,lcq3,lcq,test,$OBMYSQL_PORT);
connection conn_lcq3;
set autocommit = on;
--disable_query_log
--error 0, 5836
drop database link my_link1;
eval create database link my_link1 connect to lcq1 database test identified by "lcq" host '$OBMYSQL_MS0:$OBMYSQL_PORT';
select cast(a as unsigned) from cast_table@my_link1;
SELECT BIT_OR(c1) OVER (PARTITION BY c2 ORDER BY C2) FROM ljh_test@my_link1;

SELECT /*+ USE_NL (t2) */ ALL concat(t1D.c0,'') AS t1c0, t1D.c1 AS t1c1, concat(t1D.c2,'') AS t1c2, concat(t1D.c3,'') AS t1c3, concat(t1D.c4,'') AS t1c4, concat(t2.c0,'') AS t2c0, t2.c1 AS t2c1, concat(t2.c2,'') AS t2c2, concat(t2.c3,'') AS t2c3, concat(t2.c4,'') AS t2c4 FROM t0@my_link1 t1D, t0 t2 WHERE ((NULL) IS NOT UNKNOWN) || (-1921812964)  AND lower(concat(t1D.c0,'')) IS NULL AND t1D.c1 IS NULL AND lower(concat(t1D.c2,'')) = lower('00000000004394478091032449000') AND upper(concat(t1D.c3,'')) = upper("000000000006") AND lower(concat(t1D.c4,'')) = lower("0") AND lower(concat(t2.c0,'')) = lower('1442970000') AND t2.c1 = 23397312 AND trim(concat(t2.c2,'')) IS NULL AND concat(t2.c3,'') IS NULL ;

SELECT * FROM t3@my_link1 t3D, t2 WHERE ("") OR concat(t3D.c2,'') = '0000000000000000000000000000000000000001' AND t2.c1='00002' ;

