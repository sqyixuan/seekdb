connect (conn_lcq3,$OBMYSQL_MS0,lcq3,lcq,test,$OBMYSQL_PORT);
connection conn_lcq3;
set autocommit = on;
--disable_query_log
--error 0, 5836
drop database link my_link1;
eval create database link my_link1 connect to lcq1 database test identified by "lcq" host '$OBMYSQL_MS0:$OBMYSQL_PORT';
eval create database link if not exists my_link1 connect to lcq1 database test identified by "lcq" host '$OBMYSQL_MS0:$OBMYSQL_PORT';
drop database link if exists aaaa;
--enable_query_log
select * from  number_t@my_link1;
select * from datetime_t@my_link1;
select * from string_t@my_link1;
create table string_t_link as select * from string_t@my_link1;
select * from string_t_link;
#attention!!!! obclient will get varchar type from remote set type column, means create table xx as select * from set_t will get a varchar_t
#attention!!!! obclient will get varchar type from remote enum type column, means create table xx as select * from enum_t will get a varchar_t
select * from enum_t@my_link1;
select * from set_t@my_link1;
select * from precison_t@my_link1;
--error 0, 1051
drop table tt10;
create table tt10 as select *  from t10@my_link1;
