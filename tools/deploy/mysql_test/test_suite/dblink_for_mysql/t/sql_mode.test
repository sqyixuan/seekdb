grant all on *.* to lcq1;
--error 0,1396
drop user lcq3;
create user lcq3 identified by "lcq";
grant all on *.* to lcq3;

connect (conn_lcq1,$OBMYSQL_MS0,lcq1,lcq,test,$OBMYSQL_PORT);
connection conn_lcq1;

#number type test
--error 0, 1051
drop table t1;
create table t1(c1 int, c2 int);
insert into t1 values(1, 2);
insert into t1 values(1, 3);
insert into t1 values(4, 5);
--error 0, 1050
create view v as select c1 from t1 group by c2;

connect (conn_lcq3,$OBMYSQL_MS0,lcq3,lcq,test,$OBMYSQL_PORT);
connection conn_lcq3;
set autocommit = on;
--disable_query_log
--error 0, 5836
drop database link my_link1;
eval create database link my_link1 connect to lcq1 database test identified by "lcq" host '$OBMYSQL_MS0:$OBMYSQL_PORT';
--enable_query_log
set sql_mode = 'ONLY_FULL_GROUP_BY';
--error 1055
select * from v@my_link1;
set sql_mode = '';
select * from v@my_link1;


