grant all on *.* to link1;
--error 0,1396
drop user link3;
create user link3 identified by "link";
grant all on *.* to link3;
--disable_warnings
drop database if exists link1;
drop database if exists link3;
--enable_warnings
create database if not exists link1;
create database if not exists link3;

connect (conn_link1,$OBMYSQL_MS0,link1,link,link1,$OBMYSQL_PORT);
connection conn_link1;

