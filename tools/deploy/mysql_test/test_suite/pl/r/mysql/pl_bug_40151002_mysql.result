result_format: 4
drop function if exists func;
set @a=1;
create function func() returns varchar(20)
begin 
set @a='test03';
return @a;
end;//
select func();
+--------+
| func() |
+--------+
| test03 |
+--------+
select @a;
+--------+
| @a     |
+--------+
| test03 |
+--------+
drop function func;
set @a='test03';
create function func() returns int
begin 
set @a=1;
return @a;
end;//
select func();
+--------+
| func() |
+--------+
|      1 |
+--------+
select @a;
+------+
| @a   |
+------+
|    1 |
+------+
drop function func;
set @a='1';
create function func() returns int
begin 
return @a;
end;//
select func();
+--------+
| func() |
+--------+
|      1 |
+--------+
drop function func;
set @a='test03';
create function func() returns int
begin 
return @a;
end;//
select func();
ERROR HY000: Incorrect integer value
set @a=1;
select func();
+--------+
| func() |
+--------+
|      1 |
+--------+
drop function func;
set @a=NULL;
create function func() returns int
begin 
declare a datetime;
set a=@a;
return year(a);
end;//
select func();
+--------+
| func() |
+--------+
|   NULL |
+--------+
set @a=1;
select func();
ERROR 22007: Incorrect value
set @a='1970-01-01 00:00:01.000000';
select func();
+--------+
| func() |
+--------+
|   1970 |
+--------+
drop function if exists return_int;
drop function if exists return_varchar;
drop function if exists return_double;
drop function if exists return_datetime;
set @a=1;
create function return_varchar() returns varchar(50)
begin 
return @a;
end;//
create function return_double() returns double
begin 
return @a;
end;//
create function return_datetime() returns datetime
begin 
return @a;
end;//
select return_varchar();
+------------------+
| return_varchar() |
+------------------+
| 1                |
+------------------+
select return_double();
+-----------------+
| return_double() |
+-----------------+
|               1 |
+-----------------+
select return_datetime();
ERROR 22007: Incorrect value
set @a='1970-01-01 00:00:01.000000';
create function return_int() returns int
begin 
return @a;
end;//
select return_varchar();
+----------------------------+
| return_varchar()           |
+----------------------------+
| 1970-01-01 00:00:01.000000 |
+----------------------------+
select return_datetime();
+---------------------+
| return_datetime()   |
+---------------------+
| 1970-01-01 00:00:01 |
+---------------------+
select return_int();
ERROR 01000: Data truncated for argument
set @a=0.5;
select return_varchar();
+------------------+
| return_varchar() |
+------------------+
| 0.5              |
+------------------+
select return_double();
+-----------------+
| return_double() |
+-----------------+
|             0.5 |
+-----------------+
select return_int();
+--------------+
| return_int() |
+--------------+
|            1 |
+--------------+
drop function func;
drop function return_varchar;
drop function return_double;
drop function return_datetime;
drop function return_int;
drop procedure if exists p;
set @a='1.00000';
create procedure p()
begin
set @a=@a+1;
end;
//
call p();
select @a;
+------+
| @a   |
+------+
|    2 |
+------+
set @a=1.00000;
call p();
select @a;
+---------+
| @a      |
+---------+
| 2.00000 |
+---------+
drop procedure p;
set @a='1.00000';
create procedure p()
begin
set @a=1.00000;
set @a=@a+1;
end;
//
call p();
select @a;
+---------+
| @a      |
+---------+
| 2.00000 |
+---------+

