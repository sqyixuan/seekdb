result_format: 4
DROP FUNCTION if exists func_param_precision;

CREATE FUNCTION func_param_precision(empId_uint8 tinyint unsigned, empId_uint16 smallint unsigned, empId_uint24 mediumint unsigned, empId_uint32 INT unsigned, empId_uint64 bigint unsigned, mpsId_int8 tinyint, mpsid_int16 smallint, mpsid_int24 mediumint, mpsid_int32 int, mpsid_int64 bigint)  RETURNS decimal(12,2) unsigned DETERMINISTIC
BEGIN
    RETURN IF(empId_uint32 IS NOT NULL, 44, 3);
END;/

