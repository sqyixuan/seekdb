result_format: 4
drop database if exists routine_name_test1;
drop database if exists routine_name_test2;
CREATE DATABASE routine_name_test1;
CREATE DATABASE routine_name_test2;

drop procedure `routine_name_test1`.`test`;
drop procedure `routine_name_test2`.`test`;


CREATE PROCEDURE `routine_name_test1`.`test`() 
BEGIN 
    SELECT 3 from dual;
END;
/

CREATE PROCEDURE `routine_name_test2`.`test`() BEGIN SELECT 2; END; /


select specific_name,ROUTINE_SCHEMA,routine_name,definer from information_schema.routines where ROUTINE_SCHEMA='routine_name_test1';
+---------------+--------------------+--------------+-------------+
| specific_name | ROUTINE_SCHEMA     | routine_name | definer     |
+---------------+--------------------+--------------+-------------+
| test          | routine_name_test1 | test         | 'admin'@'%' |
+---------------+--------------------+--------------+-------------+
select specific_name,ROUTINE_SCHEMA,routine_name,definer from information_schema.routines where ROUTINE_SCHEMA='routine_name_test2';
+---------------+--------------------+--------------+-------------+
| specific_name | ROUTINE_SCHEMA     | routine_name | definer     |
+---------------+--------------------+--------------+-------------+
| test          | routine_name_test2 | test         | 'admin'@'%' |
+---------------+--------------------+--------------+-------------+

drop procedure `routine_name_test1`.`test`;
drop procedure `routine_name_test2`.`test`;
drop database routine_name_test1;
drop database routine_name_test2;
