result_format: 4
drop table t_user_tag;
drop table t_tag_userbit;
drop function my_rb_contain;

create table t_user_tag(
uid bigint,
tag varchar(100),
modtime timestamp,
primary key (tag,uid)
);

truncate table t_user_tag;

insert into t_user_tag (uid,tag,modtime) values
(1000000001,'18',current_timestamp()),
(1000000002,'18',current_timestamp()),
(100000003,'22',current_timestamp()),
(10000004,'22',current_timestamp()),
(1000000001,'male',current_timestamp()),
(1000000002,'female',current_timestamp()),
(1000000003,'male',current_timestamp()),
(1000000004,'female',current_timestamp()),
(1000000005,'female',current_timestamp());

create table t_tag_userbit(
tag varchar(100) primary key,
userbit roaringbitmap,
modtime timestamp
);

truncate table t_tag_userbit;

insert /*+ enable_parallel_dml parallel(3) */ into t_tag_userbit
select tag,rb_build_agg(uid),current_timestamp()
from t_user_tag
group by tag order by tag;

create function my_rb_contain(bitmap roaringbitmap, value bigint) RETURNS int
begin
 return rb_or_cardinality(bitmap,rb_from_string(cast(value as char))) - rb_cardinality(bitmap);
end
/

select my_rb_contain(userbit, 1000000001) from t_tag_userbit;
+------------------------------------+
| my_rb_contain(userbit, 1000000001) |
+------------------------------------+
|                                  0 |
|                                  1 |
|                                  1 |
|                                  0 |
+------------------------------------+
select my_rb_contain(userbit, 1001) from t_tag_userbit;
+------------------------------+
| my_rb_contain(userbit, 1001) |
+------------------------------+
|                            1 |
|                            1 |
|                            1 |
|                            1 |
+------------------------------+

drop table t_user_tag;
drop table t_tag_userbit;
drop function my_rb_contain;
