result_format: 4
############################start case 1############################
#####
drop table t1;
DROP PROCEDURE pro_1;

CREATE TABLE t1 (
  id INT,
  salary INT,
  pass BOOLEAN
);

INSERT INTO t1 VALUES(1,8000,FALSE),(2,9000,TRUE);

CREATE PROCEDURE pro_1(OUT res1 BOOLEAN)
BEGIN
  SELECT pass INTO res1 FROM t1 WHERE id = 1;
END;
/

CALL pro_1(@res1);
SELECT @res1;
+-------+
| @res1 |
+-------+
|     0 |
+-------+

drop table t1;
DROP PROCEDURE pro_1;
############################end case 1#############################
############################start case 2############################
####
DROP PROCEDURE p_test01;

CREATE PROCEDURE p_test01 ()
BEGIN
  SET SESSION TRANSACTION ISOLATION LEVEL SERIALIZABLE;
  SET SESSION TRANSACTION ISOLATION LEVEL REPEATABLE READ;
  SET SESSION TRANSACTION ISOLATION LEVEL READ COMMITTED;
  SET TRANSACTION READ ONLY;
  SET TRANSACTION READ WRITE;
END;
/

call p_test01();
/

DROP PROCEDURE p_test01;
/

#####
CREATE PROCEDURE p_test01 ()
BEGIN
	ROLLBACK WORK;
END;
/

call p_test01();
/
drop PROCEDURE p_test01;
/

####
CREATE PROCEDURE p_test01 ()
BEGIN
	COMMIT WORK;
END;
/

call p_test01();
/
DROP PROCEDURE p_test01;
/

####
CREATE PROCEDURE p_test01()
begin
  savepoint b;
end;
/

call p_test01();
/
DROP PROCEDURE p_test01;
/

############################end case 2#############################
############################start case 3#############################
######
drop procedure p_show_warnings;

create procedure p_show_warnings()
begin
  declare continue handler for sqlexception
  begin
  show warnings;
  end;
  select c;
end;
/

call p_show_warnings();
+-------+------+------------------------------------+
| Level | Code | Message                            |
+-------+------+------------------------------------+
| Error | 1054 | Unknown column 'c' in 'field list' |
+-------+------+------------------------------------+

drop procedure p_show_warnings;
############################end case 3#############################
############################start case 4#############################
######
set @aaa = @@sql_mode;
select @aaa;
+-------------------------------------------------------+
| @aaa                                                  |
+-------------------------------------------------------+
| STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER |
+-------------------------------------------------------+
drop function test;
set @@sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
create function test (S varchar(60)) returns varchar(60)
BEGIN
DECLARE
a int;
IF S = 0 THEN
set
  a = 1;
end if;
RETURN a;
end
/
select test('');
+----------+
| test('') |
+----------+
| 1        |
+----------+
select test('aa');
+------------+
| test('aa') |
+------------+
| 1          |
+------------+
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: 'aa'
drop function test;
set @@sql_mode = '';
create function test (S varchar(60)) returns varchar(60)
BEGIN
DECLARE
a int;
IF S = 0 THEN
set
  a = 1;
end if;
RETURN a;
end
/
select test('');
+----------+
| test('') |
+----------+
| 1        |
+----------+
select test('123');
+-------------+
| test('123') |
+-------------+
| NULL        |
+-------------+
drop function test;
set @@sql_mode = @aaa;
select @@sql_mode;
+-------------------------------------------------------+
| @@sql_mode                                            |
+-------------------------------------------------------+
| STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER |
+-------------------------------------------------------+
############################end case 4#############################
