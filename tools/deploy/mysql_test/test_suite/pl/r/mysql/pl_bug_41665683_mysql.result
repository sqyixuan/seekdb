result_format: 4


drop procedure if exists `test`;
drop table if exists `t`;
create table t(col int);

create procedure test()
begin
    update t set col = col + 1;
end;
/

set autocommit = off;
set ob_query_timeout = 100000000;

insert into t values (1);
commit;
update t set col = col + 1;

set autocommit = off;
insert into t values(1);
call test();

commit;

select * from t;
+------+
| col  |
+------+
|    2 |
|    3 |
+------+

drop table t;
drop procedure test;

