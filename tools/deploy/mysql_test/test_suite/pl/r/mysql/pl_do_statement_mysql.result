SET @p1=1,@p2=2,@p3=3//
DROP FUNCTION IF EXISTS `fun_2`//
CREATE FUNCTION fun_2() RETURNS VARCHAR(30)
BEGIN
  DECLARE a INT DEFAULT 5+1;  
  SET @p1=@p1+1,@p2=@p2+1,@p3=@p3+1;
  RETURN a;
END//
DO fun_2(),fun_2()//
SELECT @p1,@p2,@p3//
+------+------+------+
| @p1  | @p2  | @p3  |
+------+------+------+
|    3 |    4 |    5 |
+------+------+------+

