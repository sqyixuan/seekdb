DROP PROCEDURE IF EXISTS circle;
CREATE PROCEDURE circle(
IN radius DOUBLE,
IN height DOUBLE,
IN name VARCHAR(63),
OUT diameter DOUBLE,
OUT circumference DOUBLE,
OUT area DOUBLE,
OUT volume DOUBLE,
OUT shape VARCHAR(63)
)
BEGIN
SELECT radius * 2 INTO diameter;
SELECT diameter * PI() INTO circumference;
SELECT PI() * POW(radius, 2) INTO area;
SELECT area * height INTO volume;
SELECT 'circle' INTO shape;
SELECT CONCAT(name, shape);
END /
SELECT SPECIFIC_NAME, ROUTINE_SCHEMA, ROUTINE_NAME, ROUTINE_TYPE, ROUTINE_BODY, ROUTINE_DEFINITION, PARAMETER_STYLE, SQL_DATA_ACCESS, SECURITY_TYPE FROM INFORMATION_SCHEMA.ROUTINES
where  ROUTINE_NAME = 'circle';
SPECIFIC_NAME	ROUTINE_SCHEMA	ROUTINE_NAME	ROUTINE_TYPE	ROUTINE_BODY	ROUTINE_DEFINITION	PARAMETER_STYLE	SQL_DATA_ACCESS	SECURITY_TYPE
circle	test	circle	PROCEDURE	SQL	BEGIN
SELECT radius * 2 INTO diameter;
SELECT diameter * PI() INTO circumference;
SELECT PI() * POW(radius, 2) INTO area;
SELECT area * height INTO volume;
SELECT 'circle' INTO shape;
SELECT CONCAT(name, shape);
END	SQL	CONTAINS_SQL	DEFINER
DROP PROCEDURE IF EXISTS circle;
drop table if EXISTS t1;
create table t1(c1 int);
CREATE PROCEDURE circle(
IN radius DOUBLE,
IN height DOUBLE,
IN name VARCHAR(63),
OUT diameter DOUBLE,
OUT circumference DOUBLE,
OUT area DOUBLE,
OUT volume DOUBLE,
OUT shape VARCHAR(63)
)
BEGIN
SELECT radius * 2 INTO diameter;
SELECT diameter * PI() INTO circumference;
SELECT PI() * POW(radius, 2) INTO area;
SELECT area * height INTO volume;
select c1 from t1;
SELECT 'circle' INTO shape;
SELECT CONCAT(name, shape);
END /
SELECT SPECIFIC_NAME, ROUTINE_SCHEMA, ROUTINE_NAME, ROUTINE_TYPE, ROUTINE_BODY, ROUTINE_DEFINITION, PARAMETER_STYLE, SQL_DATA_ACCESS, SECURITY_TYPE FROM INFORMATION_SCHEMA.ROUTINES
where  ROUTINE_NAME = 'circle';
SPECIFIC_NAME	ROUTINE_SCHEMA	ROUTINE_NAME	ROUTINE_TYPE	ROUTINE_BODY	ROUTINE_DEFINITION	PARAMETER_STYLE	SQL_DATA_ACCESS	SECURITY_TYPE
circle	test	circle	PROCEDURE	SQL	BEGIN
SELECT radius * 2 INTO diameter;
SELECT diameter * PI() INTO circumference;
SELECT PI() * POW(radius, 2) INTO area;
SELECT area * height INTO volume;
select c1 from t1;
SELECT 'circle' INTO shape;
SELECT CONCAT(name, shape);
END	SQL	READS_SQL_DATA	DEFINER
drop table t1;
drop procedure circle;
