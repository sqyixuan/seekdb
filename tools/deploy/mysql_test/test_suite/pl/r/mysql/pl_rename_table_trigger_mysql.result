create table t1(c1 int);
create table t2(c1 int);
create table t3(c1 int);
create table t4(c1 int);

create trigger tri_t1 before insert on t1 for each row set @a = 1;
create trigger tri_t2 before insert on test.t2 for each row set @a = 2;
create trigger tri_t3 before insert on test.`t3` for each row set @a = 3;
create trigger tri_t4 before insert on `test`.`t4` for each row set @a = 4;

alter table t1 rename to t11;

insert into t11 values (1);

select @a;
+------+
| @a   |
+------+
|    1 |
+------+

show create trigger tri_t1;
Trigger	sql_mode	SQL Original Statement	character_set_client	collation_connection	Database Collation
tri_t1	STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER	CREATE DEFINER = admin@% trigger tri_t1 before insert on `t11` for each row set @a = 1	utf8mb4	utf8mb4	utf8mb4

select trigger_name, event_object_schema, action_statement from
  information_schema.triggers where trigger_name = 'TRI_T1';
+--------------+---------------------+---------------------------------------------------------------+
| trigger_name | event_object_schema | action_statement                                              |
+--------------+---------------------+---------------------------------------------------------------+
| tri_t1       | test                | trigger tri_t1 before insert on `t11` for each row set @a = 1 |
+--------------+---------------------+---------------------------------------------------------------+

