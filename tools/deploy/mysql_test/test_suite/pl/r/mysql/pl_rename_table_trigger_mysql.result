##################### test unreserved_keyword
drop table value;
drop table package;

create table value(c1 int);

create trigger tri_t1 before insert on value for each row set @a = 1;

alter table value rename to package;

select trigger_name, event_object_schema, action_statement from
  information_schema.triggers where trigger_name = 'TRI_T1';
+--------------+---------------------+-------------------------------------------------------------------+
| trigger_name | event_object_schema | action_statement                                                  |
+--------------+---------------------+-------------------------------------------------------------------+
| tri_t1       | test                | trigger tri_t1 before insert on `package` for each row set @a = 1 |
+--------------+---------------------+-------------------------------------------------------------------+

insert into package values (1);

select @a;
+------+
| @a   |
+------+
|    1 |
+------+

alter table package rename to value;

select trigger_name, event_object_schema, action_statement from
  information_schema.triggers where trigger_name = 'TRI_T1';
+--------------+---------------------+-----------------------------------------------------------------+
| trigger_name | event_object_schema | action_statement                                                |
+--------------+---------------------+-----------------------------------------------------------------+
| tri_t1       | test                | trigger tri_t1 before insert on `value` for each row set @a = 1 |
+--------------+---------------------+-----------------------------------------------------------------+

insert into value values (1);

drop trigger tri_t1;

create trigger tri_t1 before insert on test.`value` for each row set @a = 2;

alter table value rename to package;

select trigger_name, event_object_schema, action_statement from
  information_schema.triggers where trigger_name = 'TRI_T1';
+--------------+---------------------+------------------------------------------------------------------------+
| trigger_name | event_object_schema | action_statement                                                       |
+--------------+---------------------+------------------------------------------------------------------------+
| tri_t1       | test                | trigger tri_t1 before insert on test.`package` for each row set @a = 2 |
+--------------+---------------------+------------------------------------------------------------------------+

insert into package values (1);

select @a;
+------+
| @a   |
+------+
|    2 |
+------+

alter table package rename to value;

select trigger_name, event_object_schema, action_statement from
  information_schema.triggers where trigger_name = 'TRI_T1';
+--------------+---------------------+----------------------------------------------------------------------+
| trigger_name | event_object_schema | action_statement                                                     |
+--------------+---------------------+----------------------------------------------------------------------+
| tri_t1       | test                | trigger tri_t1 before insert on test.`value` for each row set @a = 2 |
+--------------+---------------------+----------------------------------------------------------------------+

insert into value values (1);

drop table value;

### [Aone 53079739]
drop table t1;
drop table t2;
drop table t3;
drop table t4;
drop trigger t1_bi;

create table t1 (id int);
insert into t1 values (101);
create trigger t1_bi before insert on t1 for each row set @a:=new.id;
alter table t1 rename to t2;
alter table t2 rename to t3;
alter table t3 rename to t4, add column val int default 0;

select * from t4;
+------+------+
| id   | val  |
+------+------+
|  101 |    0 |
+------+------+
insert into t4 values (104, 1);
select @a;
+------+
| @a   |
+------+
|  104 |
+------+
select * from t4;
+------+------+
| id   | val  |
+------+------+
|  101 |    0 |
|  104 |    1 |
+------+------+

drop table t4;
