result_format: 4
drop procedure p1;/
create procedure p1()
begin
    DECLARE continue HANDLER FOR SQLEXCEPTION
    begin
        select 'catch sqlexception';
        select cast('c' as json);
    end;
    select cast('b' as json);
end
/
call p1()
/
+--------------------+
| catch sqlexception |
+--------------------+
| catch sqlexception |
+--------------------+
ERROR 22032: Invalid JSON text in argument.
drop procedure p1;
/

drop table t1/
create table t1(id int);/
drop procedure p1;/
create procedure p1()
begin
    declare aa int;
    DECLARE continue HANDLER FOR SQLEXCEPTION
    begin
        insert into t1 values(0);
        insert into t1 values('a');
    end;
    insert into t1 values('aa');
end
/
call p1()/
ERROR HY000: Incorrect integer value for column 'id' at row 1
select * from t1/
+------+
| id   |
+------+
|    0 |
+------+
drop procedure p1;/

