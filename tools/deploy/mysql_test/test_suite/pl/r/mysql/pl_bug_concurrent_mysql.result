result_format: 4
drop outline udf_ol;
drop outline proc_ol;
drop PROCEDURE Getnumber;
drop FUNCTION add_numbers;

alter system flush pl cache global;
CREATE PROCEDURE Getnumber(IN a INT)
BEGIN
set a = a+1;
END
$

call Getnumber(1);
$

select STATEMENT,SQL_ID,HIT_COUNT,OUTLINE_DATA from oceanbase.__all_virtual_plan_stat 
    WHERE OBJECT_STATUS = 0 AND TYPE > 5 AND TYPE < 11 
        AND is_in_pc=true and STATEMENT like '%Getnumber%';
$
+----------------+----------------------------------+-----------+-------------------------+
| STATEMENT      | SQL_ID                           | HIT_COUNT | OUTLINE_DATA            |
+----------------+----------------------------------+-----------+-------------------------+
| test.Getnumber | D42654F69DE0F81C83F51D8621796276 |         0 | /*+max_concurrent(-1)*/ |
+----------------+----------------------------------+-----------+-------------------------+

CREATE OR REPLACE OUTLINE proc_ol ON 'D42654F69DE0F81C83F51D8621796276' USING HINT /*+ max_concurrent(0) */;
$

call Getnumber(1);
$
ERROR HY000: SQL reach max concurrent num

select STATEMENT,SQL_ID,HIT_COUNT,OUTLINE_DATA from oceanbase.__all_virtual_plan_stat 
    WHERE OBJECT_STATUS = 0 AND TYPE > 5 AND TYPE < 11 
        AND is_in_pc=true and STATEMENT like '%Getnumber%';
$
+----------------+----------------------------------+-----------+------------------------+
