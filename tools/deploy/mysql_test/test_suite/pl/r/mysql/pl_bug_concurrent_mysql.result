+----------------+----------------------------------+-----------+------------------------+
| test.Getnumber | D42654F69DE0F81C83F51D8621796276 |         1 | /*+max_concurrent(0)*/ |
+----------------+----------------------------------+-----------+------------------------+

CREATE FUNCTION `add_numbers`(a INT, b INT) RETURNS INT
BEGIN
    RETURN a + b;
END
$

select add_numbers(1,2);
$
+------------------+
| add_numbers(1,2) |
+------------------+
|                3 |
+------------------+

