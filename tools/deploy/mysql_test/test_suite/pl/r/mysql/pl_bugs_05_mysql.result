DROP PROCEDURE IF EXISTS pro1;/
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  IF pval = 0 THEN
    SIGNAL SQLSTATE '45000' SET  MESSAGE_TEXT=null, MYSQL_ERRNO=9999;
  ELSE
    SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT='[SIGNAL]MYSQL_ERRNO为null', MYSQL_ERRNO=null;
  END IF;	
END;
/
CALL pro1(0)/
ERROR 42000: Variable 'MESSAGE_TEXT' can't be set to the value of 'NULL'
CALL pro1(1)/
ERROR 42000: Variable 'MYSQL_ERRNO' can't be set to the value of 'NULL'

DROP PROCEDURE IF EXISTS pro1;/
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF pval = 0 THEN
      RESIGNAL SET MESSAGE_TEXT=null, MYSQL_ERRNO=9999;
    ELSE
      RESIGNAL SQLSTATE '45000' SET MESSAGE_TEXT=null, MYSQL_ERRNO=9999;
    END IF;
  END;
  DROP TABLE xxx;
END;
/
CALL pro1(0)/
ERROR 42000: Variable 'MESSAGE_TEXT' can't be set to the value of 'NULL'
CALL pro1(1)/
ERROR 42000: Variable 'MESSAGE_TEXT' can't be set to the value of 'NULL'

drop procedure pro1/


drop table if exists t2;
create table t2(c0 int);
insert into t2 value(100),(200),(300);


CREATE PROCEDURE pro1()
BEGIN
  DECLARE V_1 INT;
  DECLARE V_2 INT;
  DECLARE done INT default 0;
  DECLARE C_1 CURSOR  FOR SELECT T2.C0 AS T2C0 FROM T2;
  DECLARE CONTINUE HANDLER FOR NOT FOUND SET done=1;
  OPEN C_1;
  C_1_loop:LOOP
    set done=0;
    FETCH C_1 INTO V_2;
    IF done=1 THEN
      LEAVE C_1_loop;
    END IF;
    select V_2;
  END LOOP C_1_loop;
  CLOSE C_1;
  BEGIN
    DECLARE V_3 INT default 59396;
    IF V_3 <= 10000 then
      OPEN C_1;
      C_1_loop:LOOP
        set done=0;
        FETCH C_1 INTO V_2;
        IF done=1 THEN
          LEAVE C_1_loop;
        END IF;
      END LOOP C_1_loop;
      CLOSE C_1;
    end if;
  END;
END;
/

call pro1()/
+------+
| V_2  |
+------+
+------+
| V_2  |
+------+
+------+
| V_2  |
+------+
|  100 |
|  200 |
|  300 |
+------+
+------+
+------+


drop procedure pro1;
drop table t2;

