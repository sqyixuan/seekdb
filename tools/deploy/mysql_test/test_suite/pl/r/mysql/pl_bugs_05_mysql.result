drop table if exists t0;
drop function if exists f1;

create table t0(c0 int);
insert into t0 values(0);


create function f1() returns int
begin
declare a int;
declare done int default 0;
declare c cursor for select * from t0;
DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;
open c;
loop_label:loop
fetch c into a;
if done then
  leave loop_label;
end if;
end loop;
close c;
return 1;
end;
/

select f1() from t0;
+------+
| f1() |
+------+
|    1 |
+------+
select  /*+ parallel(2) */ f1() from t0;
+------+
| f1() |
+------+
|    1 |
+------+

drop table t0;
drop function f1;

drop table if exists t1;
drop function if exists f1;
create table t1(c0 int);
insert into t1 values(0);
insert into t1 values(1);


create function f1() returns int
begin
  return @a;
end/

set @a=1;
select /*+ ENABLE_PARALLEL_DML parallel(2) */ * from t1  where c0=f1();
+------+
| c0   |
+------+
|    1 |
+------+

drop table if exists t1;
drop procedure if exists sp1;
drop function if exists f1;
set optimizer_capture_sql_plan_baselines = true;
set optimizer_use_sql_plan_baselines = true;

CREATE PROCEDURE sp1( f1 TEXT ) NOT DETERMINISTIC SELECT f1;
create function f1() returns varchar(50) return 'hello';
create table t1 (a int, b int, unique key (a), key (b));
insert into t1 values (1,1);
SELECT * FROM t1 WHERE a = f1();
+------+------+
| a    | b    |
+------+------+
+------+------+
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: 'hello'
CALL sp1(f1());
+-------+
| f1    |
+-------+
| hello |
+-------+

set optimizer_capture_sql_plan_baselines = false;
set optimizer_use_sql_plan_baselines = false;

drop table t1;
drop procedure sp1;
drop function f1;

DROP PROCEDURE IF EXISTS json_pl;
create procedure json_pl(x bigint)
begin
declare i bigint default 2;
if (x<i)
then
  select a, b, json_length( b ) from json_mj_length where a = 1 limit 1;

  set names 'utf8';
  select a, c, json_length( c, '$' ) from utf8_mj_length where a = 1 limit 1;
  select a, c, json_length( c, '$' ) from utf8_mj_length where a = 2 limit 1;
  select a, c, json_length( c, '$' ) from utf8_mj_length where a = 5 limit 1;
  select a, c, json_length( c, '$' ) from utf8_mj_length where a = 6 limit 1;
  select a, c, json_length( c, '$' ) from utf8_mj_length where a = 7 limit 1;

  select a, b, json_length( b, '$' ) from json_mj_length where a = 1 limit 1;
else

  select count(*) from json_mj_length;
  select * from json_mj_length union select * from json_mj_length;

end if;
end;
/

drop procedure json_pl;
