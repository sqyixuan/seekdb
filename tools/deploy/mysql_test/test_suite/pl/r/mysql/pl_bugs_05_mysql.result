CREATE PROCEDURE p1()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SET @error_count = @error_count + 1;
    IF @a = 0 THEN RESIGNAL SQLSTATE '45000' SET MYSQL_ERRNO=5; END IF;
  END;
  DROP TABLE xx;
END/

SET @error_count = 0/
SET @a = 0/

call p1()/
ERROR 45000: Unknown table 'test.xx'
drop procedure p1/
CREATE PROCEDURE p1()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    RESIGNAL SQLSTATE VALUE '01000' SET MESSAGE_TEXT = 'An error occurred';
  END;
  DROP TABLE no_such_table;
END/

call p1()/
