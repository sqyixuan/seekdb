drop procedure if exists p1;
drop procedure if exists p2;
create procedure p1(a int, b int)
begin
select a + b;
end/
create procedure p2(a int, b int)
begin
set @a = a;
set @b = b;
prepare st1 from 'call p1(?,?)';
execute st1 using @a,@b;
deallocate prepare st1;
end/
call p2(2,3);
a + b
5
call p2(5,6);
a + b
11
drop procedure p1;
call p2(2,3);
ERROR 42000: procedure test.p1 does not exist
create procedure p1(a int, b int)
begin
select a + b + 1;
end/
call p2(2,3);
a + b + 1
6
call p2(4,5);
a + b + 1
10
drop procedure p1;
drop procedure p2;
