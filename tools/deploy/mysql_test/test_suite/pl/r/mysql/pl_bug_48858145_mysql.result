result_format: 4
drop table t;
create table t(col int);
insert into t values(0);

drop procedure p;


create procedure p()
begin
    declare i int default 30000;
    declare x int;
    req_continue_label:
    while(i<>1) do
        if i > 0 then
            set i = i - 1;
            update t set col = i;
            commit;
            ITERATE req_continue_label;
        end if;
    end while req_continue_label;
end;
/


call p();
drop procedure p;
drop table t;

