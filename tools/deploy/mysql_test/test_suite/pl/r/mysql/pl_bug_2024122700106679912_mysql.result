## test multipolygon
create procedure test_multipolygon (IN a multipolygon) begin    
SET @greeting = 'Hello';    
SET @name = 'Multipolygon';    
SELECT CONCAT(@greeting, ',', @name, '!'); 
SELECT ST_Area(a) AS total_area;
end;
/

CREATE PROCEDURE multipolygon_example()
BEGIN
    DECLARE multipolygon_var Multipolygon;;
    SET multipolygon_var = ST_GeomFromText('MULTIPOLYGON(((5 5, 5 15, 15 15, 15 5, 5 5)))');
    SELECT ST_Area(multipolygon_var) AS area_size;
END 
/

CREATE FUNCTION create_multipolygon(
    x1 DOUBLE, 
    y1 DOUBLE,
    x2 DOUBLE, 
    y2 DOUBLE
) 
RETURNS multipolygon
BEGIN
    DECLARE multipolygon_text VARCHAR(10000) DEFAULT 'POLYGON((';
    SET multipolygon_text = CONCAT(multipolygon_text, x1, ' ',  y1, ',', x1, ' ', y2, ',',  x2, ' ', y2, ',',  x2, ' ', y1, ',',  x1, ' ', y1, '))');
    RETURN ST_GeomFromText(multipolygon_text);
END
/

SET @pt = ST_GeomFromText('MULTIPOLYGON(((0 0, 0 10, 10 10, 10 0, 0 0)), ((20 20, 20 30, 30 30, 30 20, 20 20)))');
CALL test_multipolygon(@pt);
+------------------------------------+
| CONCAT(@greeting, ',', @name, '!') |
+------------------------------------+
+------------+
| total_area |
+------------+
| Hello,Multipolygon!                |
|        200 |
+------------------------------------+
+------------+
call multipolygon_example();
+-----------+
| area_size |
+-----------+
|       100 |
+-----------+
SELECT ST_AsText(create_multipolygon(0, 0, 20, 20));
+----------------------------------------------+
| ST_AsText(create_multipolygon(0, 0, 20, 20)) |
+----------------------------------------------+
| POLYGON((0 0,0 20,20 20,20 0,0 0))           |
+----------------------------------------------+
CALL test_multipolygon(create_multipolygon(0, 0, 25, 25));
+------------------------------------+
| CONCAT(@greeting, ',', @name, '!') |
+------------------------------------+
+------------+
| total_area |
+------------+
| Hello,Multipolygon!                |
|        625 |
+------------------------------------+
+------------+
