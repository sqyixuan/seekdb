drop table areas;
drop table routes;
drop table landmarks;
drop table mixed_geometries;
drop procedure test_geometry;
drop procedure geometry_example;
drop function create_geometry;
drop procedure test_point;
drop procedure point_example;
drop function create_point;
drop procedure test_linestring;
drop procedure linestring_example;
drop function create_linestring;
drop procedure test_polygon;
drop procedure polygon_example;
drop function create_polygon;
drop procedure test_multipoint;
drop procedure multipoint_example;
