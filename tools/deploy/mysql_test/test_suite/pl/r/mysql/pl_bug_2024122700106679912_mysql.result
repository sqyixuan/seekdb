## test LINESTRING
create procedure test_linestring (IN a linestring) begin    
SET @greeting = 'Hello';    
SET @name = 'Linestring';    
SELECT CONCAT(@greeting, ',', @name, '!'); 
SELECT id, name, ST_AsText(path) AS path_as_text FROM routes WHERE ST_Intersects(path, a);
end;
/

CREATE PROCEDURE linestring_example()
BEGIN
    DECLARE linestring_var linestring;;
    SET linestring_var = ST_GeomFromText('LINESTRING(1 1, 6 6)');
    SELECT ST_Length(linestring_var) AS length;
END 
/

CREATE FUNCTION create_linestring(
    x1 DOUBLE, 
    y1 DOUBLE,
    x2 DOUBLE, 
    y2 DOUBLE
) 
RETURNS linestring
BEGIN
    DECLARE linestring_text VARCHAR(10000) DEFAULT 'LINESTRING(';
    SET linestring_text = CONCAT(linestring_text, x1, ' ',  y1, ',', x2, ' ', y2, ')');
    RETURN ST_GeomFromText(linestring_text);
END
/

SET @pt = ST_GeomFromText('LINESTRING(1 1, 6 6)');
CALL test_linestring(@pt);
+------------------------------------+
| CONCAT(@greeting, ',', @name, '!') |
+------------------------------------+
+----+---------+-------------------------+
| id | name    | path_as_text            |
+----+---------+-------------------------+
| Hello,Linestring!                  |
|  1 | Route A | LINESTRING(0 0,1 1,2 2) |
|  2 | Route B | LINESTRING(3 3,4 4,5 5) |
+------------------------------------+
+----+---------+-------------------------+
call linestring_example();
+--------------------+
| length             |
+--------------------+
| 7.0710678118654755 |
+--------------------+
SELECT ST_AsText(create_linestring(0, 0, 20, 20));
+--------------------------------------------+
| ST_AsText(create_linestring(0, 0, 20, 20)) |
+--------------------------------------------+
| LINESTRING(0 0,20 20)                      |
+--------------------------------------------+
CALL test_linestring(create_linestring(0, 0, 25, 25));
+------------------------------------+
| CONCAT(@greeting, ',', @name, '!') |
+------------------------------------+
+----+---------+-------------------------+
| id | name    | path_as_text            |
+----+---------+-------------------------+
| Hello,Linestring!                  |
|  1 | Route A | LINESTRING(0 0,1 1,2 2) |
|  2 | Route B | LINESTRING(3 3,4 4,5 5) |
+------------------------------------+
+----+---------+-------------------------+
