Function	sql_mode	Create Function	character_set_client	collation_connection	Database Collation
create_multilinestring	STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER	CREATE DEFINER = `admin`@`%` FUNCTION `create_multilinestring`(
    x1 DOUBLE, 
    y1 DOUBLE,
    x2 DOUBLE, 
    y2 DOUBLE,
    m1 DOUBLE, 
    n1 DOUBLE,
    m2 DOUBLE, 
    n2 DOUBLE
) RETURNS multilinestring
