## test multipoint
create procedure test_multipoint (IN a multipoint) begin    
SET @greeting = 'Hello';    
SET @name = 'Multipoint';    
SELECT CONCAT(@greeting, ',', @name, '!'); 
SELECT id, name, ST_AsText(locations) AS locations_as_text FROM landmarks WHERE ST_Intersects(locations, a);
end;
/

CREATE PROCEDURE multipoint_example()
BEGIN
    DECLARE multipoint_var polygon;;
    SET multipoint_var = ST_GeomFromText('MULTIPOINT((1 1), (3 3))');
    SELECT id, name, ST_AsText(locations) AS locations_as_text FROM landmarks WHERE ST_Intersects(locations, multipoint_var);
END 
/

CREATE FUNCTION create_multipoint(
    x1 DOUBLE, 
    y1 DOUBLE,
    x2 DOUBLE, 
    y2 DOUBLE
) 
RETURNS multipoint
BEGIN
    DECLARE multipoint_text VARCHAR(10000) DEFAULT 'MULTIPOINT((';
    SET multipoint_text = CONCAT(multipoint_text, x1, ' ',  y1, '),(', x2, ' ', y2, '))');
    RETURN ST_GeomFromText(multipoint_text);
END
/

SET @pt = ST_GeomFromText('MULTIPOINT((1 1), (2 2))');
CALL test_multipoint(@pt);
+------------------------------------+
| CONCAT(@greeting, ',', @name, '!') |
+------------------------------------+
+----+------------+-------------------------+
| id | name       | locations_as_text       |
+----+------------+-------------------------+
| Hello,Multipoint!                  |
|  1 | Landmark A | MULTIPOINT((1 1),(2 2)) |
+------------------------------------+
+----+------------+-------------------------+
call multipoint_example();
+----+------------+-------------------------+
| id | name       | locations_as_text       |
+----+------------+-------------------------+
|  1 | Landmark A | MULTIPOINT((1 1),(2 2)) |
|  2 | Landmark B | MULTIPOINT((3 3),(4 4)) |
+----+------------+-------------------------+
SELECT ST_AsText(create_multipoint(0, 0, 20, 20));
+--------------------------------------------+
| ST_AsText(create_multipoint(0, 0, 20, 20)) |
+--------------------------------------------+
| MULTIPOINT((0 0),(20 20))                  |
+--------------------------------------------+
CALL test_multipoint(create_multipoint(0, 0, 25, 25));
+------------------------------------+
| CONCAT(@greeting, ',', @name, '!') |
+------------------------------------+
+----+------+-------------------+
| id | name | locations_as_text |
+----+------+-------------------+
| Hello,Multipoint!                  |
+------------------------------------+
+----+------+-------------------+
