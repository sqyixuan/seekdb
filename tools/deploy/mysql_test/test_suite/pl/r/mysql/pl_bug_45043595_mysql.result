result_format: 4
######case1#####
drop function if exists f1/
drop function if exists f2/
create function f1(a int, b int, c int)returns int
begin
return 1;
end/
create function f2(id int)returns int
begin
set @a=f1(1,2);
return 1;
end/

select f2(2)/
ERROR 42000: Incorrect number of arguments

######case2#####
drop function if exists f1/
drop function if exists f2/
create function f1(a int, b int, c int)returns int
begin
return 1;
end/
create function f2(id int)returns int
begin
set @a=f1(1,2,3,4);
set @a=f1(1,2,4,5,6,7);
return 1;
end/

select f2(2)/
ERROR 42000: Incorrect number of arguments

drop function f1/
drop function f2/

