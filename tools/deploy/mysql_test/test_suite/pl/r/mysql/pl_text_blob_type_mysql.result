drop procedure if exists p0;
drop function if exists f1;


create procedure p0()
begin
  declare c1 text;
  declare c2 text(10);

  set c1 = 'dfgg1';
  set c2 = 'dfggfd2';

  select c1,c2;
end/

call p0()/
+-------+---------+
| c1    | c2      |
+-------+---------+
| dfgg1 | dfggfd2 |
+-------+---------+

drop procedure p0/

create procedure p0()
begin
  declare c1 tinytext;
  declare c2 mediumtext;
  declare c3 longtext;

  set c1 = 'dfggfd';
  set c2 = 'dfggfc';
  set c3 = 'dfggggh';

  select c1,c2,c3;
end/

call p0()/
