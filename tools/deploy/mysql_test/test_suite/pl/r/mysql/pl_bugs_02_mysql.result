result_format: 4
#### 
#### call procedure `s rowcount is last sql`s rowcount
drop table if exists t;
drop table if exists t1;
drop procedure if exists proc1;
drop procedure if exists proc2;
drop procedure if exists proc3;
drop procedure if exists proc4;
drop procedure if exists proc5;
drop procedure if exists proc6;
drop procedure if exists proc7;
create table t(col int);
insert into t values(1),(2),(3);
create procedure proc1() insert into t values(4);
call proc1();
select row_count();
+-------------+
| row_count() |
+-------------+
|           1 |
+-------------+
create procedure proc2() update t set col = col + 1;
call proc2();
select row_count();
+-------------+
| row_count() |
+-------------+
|           4 |
+-------------+

create procedure proc3()
begin
  declare cur cursor for select * from t;
  open cur;
  close cur;
end;
|
call proc3()|
select row_count()|
+-------------+
| row_count() |
+-------------+
|           0 |
+-------------+

create procedure proc4()
begin
  insert into t values(5);
  update t set col = col + 1 where col >=4;
end;|
call proc4();|
select row_count()|
+-------------+
| row_count() |
+-------------+
|           3 |
+-------------+

create procedure proc5()
begin
  insert into t values(6);
  commit;
end;|
call proc5();|
select row_count()|
+-------------+
| row_count() |
+-------------+
|           0 |
+-------------+

create procedure proc6()
begin
  insert into t values(7);
  create table t1(col int);
end;|
call proc6();|
select row_count()|
+-------------+
| row_count() |
+-------------+
|           0 |
+-------------+

create procedure proc7(x int)
begin
  insert into t values(8);
  if x > 1 then update t set col = col + 1; end if;
end;|
call proc7(2)|
select row_count();|
+-------------+
| row_count() |
+-------------+
|           8 |
+-------------+
call proc7(1)|
select row_count();|
+-------------+
| row_count() |
+-------------+
|           1 |
+-------------+

drop procedure proc1;
drop procedure proc2;
drop procedure proc3;
drop procedure proc4;
drop procedure proc5;
drop procedure proc6;
drop procedure proc7;

