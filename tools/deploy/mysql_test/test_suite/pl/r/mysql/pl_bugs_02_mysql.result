ERROR 42000: Display width out of range for column 'a' (max = 255)

create procedure pro1()
begin
  declare a float(3.6);
  set a = 20;
  create table t_hr0(a float(24.8));
  desc t_hr0;
  create table t_hr1(a float(25.1));
  desc t_hr1;
end/

call pro1()/
+-------+-------+------+-----+---------+-------+
