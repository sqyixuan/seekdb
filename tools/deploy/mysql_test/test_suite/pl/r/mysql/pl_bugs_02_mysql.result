#### 
drop table if exists t1/
drop procedure if exists pro1/
create table t1 (
  id int(10) primary key,
  result char(20),
  a float
)/

create procedure pro1()
begin
  declare a float(54,2);
  set a = 20;
  insert into t1 VALUES(1,"insert value",a);
end/

call pro1()/

select * from t1/
+----+--------------+------+
| id | result       | a    |
+----+--------------+------+
|  1 | insert value |   20 |
+----+--------------+------+

drop table t1/
drop procedure pro1/


create table t1(empno decimal(6,2),ename varchar(10),job varchar(9),loc char(10),dname char(10),sal int,note char(20),deptno decimal(2)) character set binary;
insert into t1 values(7782,unhex('E5858BE68B89E5858B'),unhex('E8BF90E58AA8E59198'),unhex('D6D0B9FA'),unhex('97E9551B'),2450,unhex('CAC0BDE7BCB6D4CBB6AFD4B1'),10);

create procedure pro1()
begin
  declare a varchar(20) character set utf8mb4;
  declare b varchar(20) character set binary;
  declare c varchar(20) character set gbk;
  declare d varchar(20) character set utf16;
  declare e varchar(20) character set gb18030;
  declare msg varchar(20); declare done int default 0;
  declare mc cursor for select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc, cast(dname as char(2) character set utf16)dname,cast(note as char(7) character set gb18030)note from t1 where cast(job as char character set binary) = '运动员';
  declare continue handler for not found set done = 1;
  open mc;
  while done != 1 do
    set msg = '';
    fetch mc into a,b,c,d,e;
    if done != 1 then set msg = concat('5:',(select a),(select d)); select msg; end if;
  end while;
  close mc;
end/

call pro1()/
+-------------------+
| msg               |
+-------------------+
| 5:克拉克韩唛      |
+-------------------+

drop procedure pro1/

drop table t1/


drop table if exists t1;
drop function if exists f1;
create table t1(c1 int);
set autocommit=1;
create function f1() returns int begin   insert into t1 value(1);   return 1; end/
start transaction/
select f1()/
+------+
| f1() |
+------+
|    1 |
+------+
select * from t1/
+------+
| c1   |
+------+
|    1 |
+------+
rollback/
select * from t1/
+------+
| c1   |
+------+
+------+
drop table t1;
drop function f1;
