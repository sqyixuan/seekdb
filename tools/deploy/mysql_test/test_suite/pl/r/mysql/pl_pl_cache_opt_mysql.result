result_format: 4
alter system flush pl cache global;
alter system flush plan cache global;


DROP USER hr;

CREATE USER 'hr' IDENTIFIED BY 'hr';
GRANT all ON *.* TO hr WITH GRANT OPTION;
DROP DATABASE henry;
CREATE DATABASE henry;
use henry;




#############测试临时表场景##############
#############测试存储过程内部只有sql语句, table ddl变更不影响存储过程缓存##############
create table t2(c1 int);
insert into t2 value(1);


create procedure p2()
begin
  declare a int;
  declare b int;
  set b = 1;
  select count(*) into a from t2 where c1 = b;
  select a;
end;
/


alter system flush pl cache global;
alter system flush plan cache global;


call p2();
+------+
| a    |
+------+
|    1 |
+------+

drop table t2;
create table t2(c1 int, c2 int);
insert into t2 value(1,2);

#hit pl cache, t2定义变更预期不影响p2的缓存
call p2();
+------+
| a    |
+------+
|    1 |
+------+
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P2' order by gmt_create desc limit 1);
+------+-------------+-----------+
| type | object_type | hit_count |
+------+-------------+-----------+
|    6 | PROCEDURE   |         1 |
+------+-------------+-----------+

drop table t2;

call p2();
ERROR 42S02: Table 'henry.t2' doesn't exist

drop procedure p2;

alter system flush pl cache global;
alter system flush plan cache global;


create table t2(c1 int);
insert into t2 value(1);


create procedure p2()
begin
  select count(*) from t2;
end;
/


alter system flush pl cache global;
alter system flush plan cache global;


call p2();
+----------+
| count(*) |
+----------+
|        1 |
+----------+

drop table t2;
create table t2(c1 int, c2 int);
insert into t2 value(1,2);

#hit pl cache, t2定义变更预期不影响p2的缓存
call p2();
+----------+
| count(*) |
+----------+
|        1 |
+----------+
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P2' order by gmt_create desc limit 1);
+------+-------------+-----------+
| type | object_type | hit_count |
+------+-------------+-----------+
|    6 | PROCEDURE   |         1 |
+------+-------------+-----------+
drop procedure p2;


create procedure p2()
begin
  declare a int;
  declare cs cursor for select count(*) from t2;
  open cs;
  fetch cs into a;
  close cs;
  select a;
end;
/


alter system flush pl cache global;
alter system flush plan cache global;


call p2();
+------+
| a    |
+------+
|    1 |
+------+

drop table t2;
create table t2(c1 int, c2 int);
insert into t2 value(1,2);

#hit pl cache, t2定义变更预期不影响p2的缓存
call p2();
+------+
| a    |
+------+
|    1 |
+------+
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P2' order by gmt_create desc limit 1);
+------+-------------+-----------+
| type | object_type | hit_count |
+------+-------------+-----------+
|    6 | PROCEDURE   |         1 |
+------+-------------+-----------+
drop table t2;

call p2();
ERROR 42S02: Table 'henry.t2' doesn't exist

drop procedure p2;

alter system flush pl cache global;
alter system flush plan cache global;


drop table if exists t1;
drop procedure if exists p1;

#############测试存储过程内部相关表做truncate变更不影响存储过程缓存##############
create table t1(c1 int, c2 int);

insert into t1 value(1,2);


create procedure p1()
begin
  declare var int;
  declare cs cursor for select c1 from t1;
  open cs;
  fetch cs into var;
  close cs;
  select var;
end;
/


alter system flush pl cache global;
alter system flush plan cache global;


call p1();
+------+
| var  |
+------+
|    1 |
+------+
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);
+------+-------------+-----------+
| type | object_type | hit_count |
+------+-------------+-----------+
|    6 | PROCEDURE   |         0 |
+------+-------------+-----------+
call p1();
+------+
| var  |
+------+
|    1 |
+------+
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);
+------+-------------+-----------+
| type | object_type | hit_count |
+------+-------------+-----------+
|    6 | PROCEDURE   |         1 |
+------+-------------+-----------+

