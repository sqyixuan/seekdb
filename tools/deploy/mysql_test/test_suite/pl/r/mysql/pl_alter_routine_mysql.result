result_format: 4
drop table if exists t1;
drop procedure if exists p1;
drop function if exists f1;
create table t1(id int);


create definer = 'nouser'@'%' procedure p1() sql security invoker
begin
  insert into t1 value(2);
end/
Warnings:
Warning	1449	User nouser not exist

call p1()/

alter procedure p1/
call p1()/
alter procedure p1 sql security definer LANGUAGE SQL CONTAINS SQL/

call p1()/
ERROR HY000: User not exist

alter procedure p1 sql security invoker MODIFIES SQL DATA comment 'fddf'/
call p1()/

select * from t1/
+------+
| id   |
+------+
|    2 |
|    2 |
|    2 |
+------+

create definer = 'nouser'@'%' function f1() returns int
sql security definer
begin
  insert into t1 value(3);
  return 0;
end/
Warnings:
Warning	1449	User nouser not exist

select f1()/
ERROR HY000: User not exist
alter function f1 sql security invoker/
select f1()/
+------+
| f1() |
+------+
|    0 |
+------+
alter function f1 sql security definer/

select f1()/
ERROR HY000: User not exist
select * from t1/
+------+
| id   |
+------+
|    2 |
|    2 |
|    2 |
|    3 |
+------+

drop procedure p1;
drop function f1;
drop table t1;
