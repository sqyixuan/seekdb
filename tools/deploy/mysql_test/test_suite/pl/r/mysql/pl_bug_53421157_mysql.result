result_format: 4
drop procedure proc;
drop function func;

create procedure proc(x int)
begin
select x;
end;
/

create function func(x int)
returns varchar(64)
begin
return 'hello world!';
end;
/

call proc(42);
+------+
| x    |
+------+
|   42 |
+------+

select func(42);
+--------------+
| func(42)     |
+--------------+
| hello world! |
+--------------+

select db, name, returns, param_list from mysql.proc where db = 'test' AND name in ('proc', 'func') order by name;
+------+------+-----------------------------+------------+
| db   | name | returns                     | param_list |
+------+------+-----------------------------+------------+
| test | func | varchar(64) CHARSET utf8mb4 | x int      |
| test | proc |                             | x int      |
+------+------+-----------------------------+------------+

drop procedure proc;
drop function func;
