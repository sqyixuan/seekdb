result_format: 4
desc mysql.proc;
+----------------------+---------------+------+-----+---------+-------+
| Field                | Type          | Null | Key | Default | Extra |
+----------------------+---------------+------+-----+---------+-------+
| DB                   | varchar(128)  | NO   |     |         |       |
| NAME                 | varchar(128)  | NO   |     |         |       |
| TYPE                 | varchar(10)   | NO   |     |         |       |
| SPECIFIC_NAME        | varchar(128)  | NO   |     |         |       |
| LANGUAGE             | varchar(4)    | NO   |     |         |       |
| SQL_DATA_ACCESS      | varchar(32)   | NO   |     |         |       |
| IS_DETERMINISTIC     | varchar(4)    | NO   |     |         |       |
| SECURITY_TYPE        | varchar(10)   | NO   |     |         |       |
| PARAM_LIST           | longblob      | NO   |     |         |       |
| RETURNS              | longblob      | NO   |     |         |       |
| BODY                 | longblob      | NO   |     |         |       |
| DEFINER              | varchar(77)   | NO   |     |         |       |
| CREATED              | timestamp(6)  | NO   |     |         |       |
| MODIFIED             | timestamp(6)  | NO   |     |         |       |
| SQL_MODE             | text          | NO   |     |         |       |
| COMMENT              | varchar(4096) | NO   |     |         |       |
| CHARACTER_SET_CLIENT | varchar(128)  | NO   |     |         |       |
| COLLATION_CONNECTION | varchar(128)  | NO   |     |         |       |
| DB_COLLATION         | varchar(128)  | NO   |     |         |       |
| BODY_UTF8            | longblob      | NO   |     |         |       |
+----------------------+---------------+------+-----+---------+-------+

desc information_schema.routines;
+--------------------------+---------------------+------+-----+---------+-------+
| Field                    | Type                | Null | Key | Default | Extra |
+--------------------------+---------------------+------+-----+---------+-------+
| SPECIFIC_NAME            | varchar(64)         | NO   |     |         |       |
| ROUTINE_CATALOG          | varchar(512)        | NO   |     |         |       |
| ROUTINE_SCHEMA           | varchar(64)         | NO   |     |         |       |
| ROUTINE_NAME             | varchar(64)         | NO   |     |         |       |
| ROUTINE_TYPE             | varchar(9)          | NO   |     |         |       |
| DATA_TYPE                | varchar(64)         | NO   |     |         |       |
| CHARACTER_MAXIMUM_LENGTH | bigint(20)          | NO   |     |         |       |
| CHARACTER_OCTET_LENGTH   | bigint(20)          | NO   |     |         |       |
| NUMERIC_PRECISION        | bigint(20) unsigned | NO   |     |         |       |
| NUMERIC_SCALE            | bigint(20)          | NO   |     |         |       |
| DATETIME_PRECISION       | bigint(20) unsigned | NO   |     |         |       |
| CHARACTER_SET_NAME       | varchar(64)         | NO   |     |         |       |
| COLLATION_NAME           | varchar(64)         | NO   |     |         |       |
| DTD_IDENTIFIER           | longtext            | NO   |     |         |       |
| ROUTINE_BODY             | varchar(8)          | NO   |     |         |       |
| ROUTINE_DEFINITION       | longtext            | NO   |     |         |       |
| EXTERNAL_NAME            | varchar(64)         | NO   |     |         |       |
| EXTERNAL_LANGUAGE        | varchar(64)         | NO   |     |         |       |
| PARAMETER_STYLE          | varchar(8)          | NO   |     |         |       |
| IS_DETERMINISTIC         | varchar(3)          | NO   |     |         |       |
| SQL_DATA_ACCESS          | varchar(64)         | NO   |     |         |       |
| SQL_PATH                 | varchar(64)         | NO   |     |         |       |
| SECURITY_TYPE            | varchar(7)          | NO   |     |         |       |
| CREATED                  | datetime            | YES  |     |         |       |
| LAST_ALTERED             | datetime            | YES  |     |         |       |
| SQL_MODE                 | text                | NO   |     |         |       |
| ROUTINE_COMMENT          | longtext            | NO   |     |         |       |
| DEFINER                  | varchar(93)         | NO   |     |         |       |
| CHARACTER_SET_CLIENT     | varchar(32)         | NO   |     |         |       |
| COLLATION_CONNECTION     | varchar(32)         | NO   |     |         |       |
| DATABASE_COLLATION       | varchar(32)         | NO   |     |         |       |
