########################################################################
drop table t;
drop table msg;
drop trigger tri1_t;
drop trigger tri2_t;
drop trigger tri3_t;
drop trigger tri4_t;
drop trigger tri5_t;

create table t (c1 int);
create table msg (c1 int AUTO_INCREMENT primary key , c2 varchar(100));

create trigger tri1_t before insert on t for each row
BEGIN
  insert into msg (c2) values ('before insert tri1_t');
end;
/

create trigger tri2_t before insert on t for each row FOLLOWS tri1_t
BEGIN
  insert into msg (c2) values ('before insert tri2_t');
end;
/

create trigger tri3_t before insert on t for each row FOLLOWS tri1_t
BEGIN
  insert into msg (c2) values ('before insert tri3_t');
end;
/

create trigger tri4_t before insert on t for each row PRECEDES tri1_t
BEGIN
  insert into msg (c2) values ('before insert tri4_t');
end;
/

create trigger tri5_t before insert on t for each row PRECEDES tri1_t
BEGIN
  insert into msg (c2) values ('before insert tri5_t');
end;
/

insert into t values (1);

select * from msg;
+----+----------------------+
| c1 | c2                   |
+----+----------------------+
|  1 | before insert tri4_t |
|  2 | before insert tri5_t |
|  3 | before insert tri1_t |
|  4 | before insert tri3_t |
|  5 | before insert tri2_t |
+----+----------------------+

select TRIGGER_SCHEMA, TRIGGER_NAME, EVENT_OBJECT_TABLE, ACTION_ORDER
  from information_schema.triggers where EVENT_OBJECT_TABLE = 't' and TRIGGER_SCHEMA = 'test';
+----------------+--------------+--------------------+--------------+
| TRIGGER_SCHEMA | TRIGGER_NAME | EVENT_OBJECT_TABLE | ACTION_ORDER |
+----------------+--------------+--------------------+--------------+
| test           | tri1_t       | t                  |            3 |
| test           | tri2_t       | t                  |            5 |
| test           | tri3_t       | t                  |            4 |
| test           | tri4_t       | t                  |            1 |
| test           | tri5_t       | t                  |            2 |
+----------------+--------------+--------------------+--------------+

delete from msg;
drop trigger tri3_t;
insert into t values (1);

select * from msg;
+----+----------------------+
| c1 | c2                   |
+----+----------------------+
|  6 | before insert tri4_t |
|  7 | before insert tri5_t |
|  8 | before insert tri1_t |
|  9 | before insert tri2_t |
+----+----------------------+

select TRIGGER_SCHEMA, TRIGGER_NAME, EVENT_OBJECT_TABLE, ACTION_ORDER
  from information_schema.triggers where EVENT_OBJECT_TABLE = 't' and TRIGGER_SCHEMA = 'test';
+----------------+--------------+--------------------+--------------+
| TRIGGER_SCHEMA | TRIGGER_NAME | EVENT_OBJECT_TABLE | ACTION_ORDER |
+----------------+--------------+--------------------+--------------+
| test           | tri1_t       | t                  |            3 |
| test           | tri2_t       | t                  |            4 |
| test           | tri4_t       | t                  |            1 |
| test           | tri5_t       | t                  |            2 |
+----------------+--------------+--------------------+--------------+

create trigger tri3_t before insert on t for each row PRECEDES tri4_t
BEGIN
  insert into msg (c2) values ('before insert tri3_t');
end;
/

delete from msg;
insert into t values (1);

select * from msg;
+----+----------------------+
| c1 | c2                   |
+----+----------------------+
| 10 | before insert tri3_t |
| 11 | before insert tri4_t |
| 12 | before insert tri5_t |
| 13 | before insert tri1_t |
| 14 | before insert tri2_t |
+----+----------------------+

select TRIGGER_SCHEMA, TRIGGER_NAME, EVENT_OBJECT_TABLE, ACTION_ORDER
  from information_schema.triggers where EVENT_OBJECT_TABLE = 't' and TRIGGER_SCHEMA = 'test';
+----------------+--------------+--------------------+--------------+
| TRIGGER_SCHEMA | TRIGGER_NAME | EVENT_OBJECT_TABLE | ACTION_ORDER |
+----------------+--------------+--------------------+--------------+
| test           | tri1_t       | t                  |            4 |
| test           | tri2_t       | t                  |            5 |
| test           | tri3_t       | t                  |            1 |
| test           | tri4_t       | t                  |            2 |
| test           | tri5_t       | t                  |            3 |
+----------------+--------------+--------------------+--------------+

drop table t;
drop table msg;
##############################test flashback##########################################
set recyclebin=on;

create table t(c1 int, c2 int);

create trigger tri1_t before insert on t for each row
BEGIN
  set @a=1;
end;
/

create trigger tri2_t before insert on t for each row FOLLOWS tri1_t
BEGIN
  set @a=1;
end;
/

drop table t;

flashback table t to before drop;

insert into t values (1, 1);

drop table t;
