result_format: 4
set @a=0;
drop function if exists f4;


create function f4() returns int
begin
    case 'abc'
    when 1 then
    set @a=1;
    when 0 then
    set @a=0;
    else
    set @a=-1;
end case;
return 1;
end /


select f4();
+------+
| f4() |
+------+
|    1 |
+------+
select @a;
+------+
| @a   |
+------+
|    0 |
+------+
drop function f4;
