+------+----------------------------+
+------------+---------------------------+
+--------+--------------------------+
call proc_set(7);
+------+----------------------------+
| var1 | CAST(var1 AS DECIMAL(3,2)) |
+------+----------------------------+
+------------+---------------------------+
| arg        | CAST(arg AS DECIMAL(3,2)) |
+------------+---------------------------+
+--------+--------------------------+
| c1     | CAST(c1 AS DECIMAL(3,2)) |
+--------+--------------------------+
| NULL |                       3.00 |
| NULL,1.235 |                      7.00 |
| -1.234 |                     3.00 |
| 2.345  |                     4.00 |
| 3.456  |                     5.00 |
| 4.567  |                     6.00 |
+------+----------------------------+
+------------+---------------------------+
+--------+--------------------------+

drop procedure proc_set;

drop procedure proc_set_error;

CREATE PROCEDURE proc_set_error(arg set('','NULL', '1.235'))
BEGIN
  declare var1 set(',','two', 'three', 'four') default 7;
  select var1,CAST(var1 AS DECIMAL(3,2));
END 
/


call proc_set_error(2);

drop procedure proc_set_error;
drop table tab;

drop table result;

create table result(x1 enum('x', 'y', 'z'));

drop procedure my_proc;
create procedure my_proc()
begin
  declare x1 enum('x', 'y', 'z') default 'x';
  insert into result values(x1);
  set x1 = 'y';
  insert into result values(x1);
end;
/

drop procedure my_proc;/

create procedure my_proc()
begin
  declare x1 enum('x', 'y', 'z') default null;
  declare x2 enum('1', '2') default null;
  insert into result values(x1);
  insert into result values(x2);
end;
/

call my_proc();
select * from result;
+------+
| x1   |
+------+
| NULL |
| NULL |
+------+

drop procedure my_proc;
drop table result;

drop PROCEDURE pro13_7;

CREATE PROCEDURE pro13_7(in arg1 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR','ENUM'),in arg2 SET('','NULL', 'ONE', 'TWO','THREE','FOUR','SET'))
BEGIN
  if arg1 != arg2 then
    if arg1> arg2 then
      SELECT 'arg1 > arg2 ',arg1,arg2;
    else
      SELECT 'arg1 < arg2 ',arg1,arg2;
    end if;
  else
    SELECT 'arg1 = arg2 ',arg1,arg2;
  end if;
END 
/
call pro13_7('','');
+--------------+------+------+
| arg1 = arg2  | arg1 | arg2 |
+--------------+------+------+
| arg1 = arg2  |      |      |
+--------------+------+------+
call pro13_7('NULL','');
+--------------+------+------+
| arg1 > arg2  | arg1 | arg2 |
+--------------+------+------+
| arg1 > arg2  | NULL |      |
+--------------+------+------+

drop procedure pro13_7;

drop table t0;
create table t0(c0 int,c1 enum('NULL', 'one', 'TWO'));
insert into t0 values(1,'NULL');

drop function my_f1;
drop procedure proc_enum1;

CREATE FUNCTION my_f1(arg ENUM('','NULL', 'one', 'TWO','Three','FouR')) RETURNS INT 
BEGIN
  RETURN arg;
END
/

select c1, my_f1(c1) from t0; /
+------+-----------+
| c1   | my_f1(c1) |
+------+-----------+
| NULL |         2 |
+------+-----------+

CREATE PROCEDURE proc_enum1()
BEGIN
declare var1 enum('NULL','1.235','2.567') default 'NULL';
declare var2 int;
set var2 = my_f1(var1);
select var2;
select my_f1(var1);
end;
/

call proc_enum1; /
+------+
| var2 |
+------+
+-------------+
| my_f1(var1) |
+-------------+
|    2 |
|           2 |
+------+
+-------------+

drop table t0;
drop function my_f1;
drop procedure proc_enum1;
