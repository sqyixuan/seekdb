drop table tab1;
CREATE TABLE tab1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    c1 ENUM('11', '12','13','14','15') NOT NULL,
    c2 ENUM('21', '22', '23', '24', '25') DEFAULT '21',
    c3 varchar(2000));

drop table tab2;
CREATE TABLE tab2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    c1 ENUM('11', '12','13','14','15') NOT NULL,
    c2 ENUM('21', '22', '23', '24','25') DEFAULT '21',
    c3 varchar(2000),
    c4 varchar(2000));

drop PROCEDURE my_pro2;/
CREATE PROCEDURE my_pro2(inout p1 ENUM('11', '12','13','14','15'),inout p2 ENUM('1','2','21', '22', '23', '24', '25'))
BEGIN
  set @bk_p1 = p1;
  set @bk_p2 = p2;
  set p1 = p1+1;
  set p2 = p2+1;
END;
/
drop trigger my_tri3;/
create trigger my_tri3 before insert on tab1 for each row
begin
  INSERT INTO tab2(c1,c2,c3,c4) VALUES (new.c1,new.c2,new.c3,'[call 前]');
  call my_pro2(new.c1,new.c2);
  INSERT INTO tab2(c1,c2,c3,c4) VALUES (new.c1,new.c2,new.c3,'[call 后]');
end;
/

INSERT INTO tab1(c1,c2,c3) VALUES ('11','21','id=1');

select * from tab1 order by 1;
+----+------+------+------+
| id | c1   | c2   | c3   |
+----+------+------+------+
|  1 | 12   | 22   | id=1 |
+----+------+------+------+
select * from tab2 order by 1;
+----+------+------+------+------------+
| id | c1   | c2   | c3   | c4         |
+----+------+------+------+------------+
|  1 | 11   | 21   | id=1 | [call 前]  |
|  2 | 12   | 22   | id=1 | [call 后]  |
+----+------+------+------+------------+
SELECT @bk_p1,@bk_p2;
+--------+--------+
| @bk_p1 | @bk_p2 |
+--------+--------+
| 11     | 21     |
+--------+--------+

drop trigger my_tri3;
drop table tab1;
drop PROCEDURE my_pro2;


CREATE PROCEDURE my_pro2(inout p1 ENUM('11', '12','13','14','15'),inout p2 ENUM('1','2','21', '22', '23', '24', '25'))
BEGIN
  set @bk_p1 = p1;
  set @bk_p2 = p2;
  set p1 = p1+1;
  set p2 = p2+1;
END;
/

drop procedure my_pro;/
create procedure my_pro()
BEGIN
  declare p1 ENUM('11', '12','13','14','15');
  declare p2  ENUM('25', 'b', '24');
  set p1 = '11';
  set p2 = '24';
  call my_pro2(p1,  p2);
  select p1, p2;
END;
/

call my_pro;/
+------+------+
| p1   | p2   |
+------+------+
| 12   | 25   |
+------+------+
select @bk_p1, @bk_p2;/
+--------+--------+
| @bk_p1 | @bk_p2 |
+--------+--------+
| 11     | 24     |
+--------+--------+
drop procedure my_pro2;/
drop procedure my_pro;/

CREATE PROCEDURE my_pro2(inout p1 ENUM('','null','10','11','12','13','14','15'))
BEGIN 
 DECLARE v1 ENUM('','null','10','11','12','13','14','15') DEFAULT 'null'; 
  set p1 = p1 +1; 
  CASE p1   
    WHEN @p1 THEN SELECT '1',p1,@p1; 
     WHEN @p2 THEN SELECT '2',p1,@p1; 
     WHEN v1 THEN SELECT '3',v1,@p1;  
     WHEN null THEN SELECT '4',null;   
     ELSE SELECT '5 else',p1; 
  END CASE;
  END;
/


SET @p1 = '10';
SET @p2 = 3;
call my_pro2(@p1);
+--------+------+
| 5 else | p1   |
+--------+------+
| 5 else | 11   |
+--------+------+
select @p1;
+------+
| @p1  |
+------+
| 11   |
+------+

PREPARE stmt FROM 'call my_pro2(?)';
SET @p1 = '10';
SET @p2 = 3;
EXECUTE stmt using @p1;
+--------+------+
| 5 else | p1   |
+--------+------+
| 5 else | 11   |
+--------+------+
select @p1;
+------+
| @p1  |
+------+
| 11   |
+------+

drop procedure my_pro2;

