+------+---------------------------+
| arg  | CAST(arg AS DECIMAL(3,2)) |
+------+---------------------------+
+--------+--------------------------+
| c1     | CAST(c1 AS DECIMAL(3,2)) |
+--------+--------------------------+
+------+----------------------------+
| var2 | CAST(var2 AS DECIMAL(3,2)) |
+------+----------------------------+
| 2.567 |                       4.00 |
| NULL |                      2.00 |
| -1.234 |                     3.00 |
| 2.345  |                     4.00 |
| 3.456  |                     5.00 |
| 4.567  |                     6.00 |
| NULL |                       NULL |
+-------+----------------------------+
+------+---------------------------+
+--------+--------------------------+
+------+----------------------------+
call pro12_6(null);
