result_format: 4
SET @@sql_mode='';

DROP PROCEDURE IF EXISTS sp2;//
CREATE PROCEDURE sp2()
BEGIN
   SET @@sql_mode=default;
   SHOW VARIABLES LIKE 'sql_mode';
END//

SHOW VARIABLES LIKE 'sql_mode';
Variable_name	Value
sql_mode	
CALL sp2();
+---------------+-------------------------------------------------------+
| Variable_name | Value                                                 |
+---------------+-------------------------------------------------------+
| sql_mode      | STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER |
+---------------+-------------------------------------------------------+
SHOW VARIABLES LIKE 'sql_mode';
Variable_name	Value
sql_mode	

SET @@sql_mode=default;
