result_format: 4
############################start case 1############################
set @a=0/
drop function if exists f1/
create function f1() returns int
begin
    declare x int default '111';
    case
    when '997a11ek'=9976 then
    set @a=1;
    when 'a11ek'=0 then
    set @a=0;
    else
    set @a=-1;
end case;
return x;
end;
/
select f1()/
+------+
| f1() |
+------+
|  111 |
+------+
select @a/
+------+
| @a   |
+------+
|    0 |
+------+

drop function f1/

############################start case 2############################
drop procedure if exists p1/
create procedure p1()
begin
  declare a varchar(20);
  set a = 'k';
  case 
  when a = 0 then
    select a;
  else
    select 1;
  end case;
end/
call p1()/
+------+
| a    |
+------+
| k    |
+------+

drop procedure p1/

############################start case 3############################
drop function if exists f2/
create function f2() returns int
begin
    declare x varchar(20);
    set x = '3e1a11ek';
    case
    when x=30 then
    set @a=1;
    when x=3 then
    set @a=0;
    else
    set @a=-1;
end case;
return 1;
end;
/
select f2()/
+------+
| f2() |
+------+
|    1 |
+------+
select @a/
+------+
| @a   |
+------+
|    1 |
+------+

drop function f2/


############################start case 4############################
drop table if exists a;
drop procedure if exists p;
create table a(a1 int);
create procedure p(x int)
begin
case x
when 1 then insert into a values(1);
when 2 then insert into a values(2);
end case;
end//
call p(1);
select * from a;
+------+
| a1   |
+------+
|    1 |
+------+
call p(2);
select * from a;
+------+
| a1   |
+------+
|    1 |
|    2 |
+------+
call p(3);
ERROR 20000: Case not found for CASE statement
select * from a;
+------+
| a1   |
+------+
|    1 |
|    2 |
+------+
drop table a;
drop procedure p;

############################start case 4############################
set @a=0/
drop function if exists f4/
create function f4() returns int
begin
    case 'abc'
    when 1 then
    set @a=1;
    when 0 then
    set @a=0;
    else
    set @a=-1;
end case;
return 1;
end;
/
select f4()/
+------+
| f4() |
+------+
|    1 |
+------+
select @a/
+------+
| @a   |
+------+
|    0 |
+------+

drop function f4/

