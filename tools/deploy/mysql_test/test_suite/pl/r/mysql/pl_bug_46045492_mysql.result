DROP PROCEDURE IF EXISTS p;
/
CREATE PROCEDURE p (a INT)
BEGIN
    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
	case a
        when 1 then RESIGNAL;
        when 2 then RESIGNAL set MESSAGE_TEXT='no table';
        when 3 then RESIGNAL sqlstate '23000';
    end case;
    end;
    DROP TABLE xxx;
END;
/
call p(1);
/
ERROR 42S02: Unknown table 'test.xxx'
call p(2);
/
ERROR 42S02: no table
call p(3);
/
ERROR 23000: Unknown table 'test.xxx'

drop procedure if exists p;
/
CREATE PROCEDURE p (a int)
BEGIN
  DECLARE specialty CONDITION FOR SQLSTATE '45000' ;
  DECLARE EXIT HANDLER FOR sqlexception
  begin
    case a
      when 1 then resignal;
      when 2 then resignal set message_text='no table';
      when 3 then resignal sqlstate '23000';
    end case;
  end;
  signal specialty set message_text='aaaaaaaa',mysql_errno=100;
END;
/
CALL p(1);
/
ERROR 45000: aaaaaaaa
CALL p(2);
/
ERROR 45000: no table
CALL p(3);
/
ERROR 23000: aaaaaaaa


drop table if exists t0;
/
create table t0(c0 int);
/
drop trigger if exists tr1;
/
create trigger tr1 before insert on t0 for each row
begin
    if new.c0=1 then
        SIGNAL SQLSTATE '40001' SET MESSAGE_TEXT = 'error';
    end if;
end;
/

drop procedure if exists p;
/
CREATE PROCEDURE p()
BEGIN
    declare continue handler for SQLSTATE '40001' select 'eeeeee';
    insert into t0 values(1);
END
/
call p();
/
+--------+
| eeeeee |
+--------+
| eeeeee |
+--------+

drop table t0;
/
drop procedure p;
/


drop table if exists t0;
/
create table t0(c0 int);
/
drop table if exists xxx;
/
drop procedure if exists p;
/
CREATE PROCEDURE p ()
begin
    declare a int;
    declare c cursor for select * from t0;
    DECLARE continue HANDLER FOR sqlexception select 'sqlexception';
    DECLARE continue HANDLER FOR not found
    begin
        select 'not found';
        drop table xxx;
    end;
    open c ;
    fetch c into a;
    close c;
end;
/
call p();
/
+-----------+
| not found |
+-----------+
| not found |
+-----------+
ERROR 42S02: Unknown table 'test.xxx'

drop table if exists t0;
/
create table t0(c0 int);
/
drop table if exists xxx;
/
drop procedure if exists p;
/
CREATE PROCEDURE p ()
begin
    declare a int;
    declare c cursor for select * from t0;
    DECLARE continue HANDLER FOR not found
    begin
        select 'not found';
        drop table xxx;
    end;
    DECLARE continue HANDLER FOR sqlexception select 'sqlexception';
    open c ;
    fetch c into a;
    close c;
end;
/
call p();
/
+-----------+
| not found |
+-----------+
| not found |
+-----------+
ERROR 42S02: Unknown table 'test.xxx'


drop table if exists xxx;
/
drop procedure if exists p;
/
CREATE PROCEDURE p()
label:
begin
    declare continue handler for 1051
    label:
    begin
        if 1=1 then
            select 'aaa';
            leave label;
        end if;
    end;
    drop table xxx;
end;
/
call p()
/
+-----+
| aaa |
+-----+
| aaa |
+-----+
drop procedure p;
/
