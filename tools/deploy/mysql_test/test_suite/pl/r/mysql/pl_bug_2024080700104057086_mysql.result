result_format: 4

drop function if exists square;
create function square(x int) returns int deterministic return x * x;
select routine_name, routine_body from oceanbase.__all_routine_history where routine_name = 'square' order by routine_id desc limit 1;
+--------------+---------------------------------------------------------------+
| routine_name | routine_body                                                  |
+--------------+---------------------------------------------------------------+
| square       | function square(x int) returns int deterministic return x * x |
+--------------+---------------------------------------------------------------+
select square(3);
+-----------+
| square(3) |
+-----------+
|         9 |
+-----------+


alter system change tenant sys;
update __all_routine_history set routine_body = 'return x * x' where routine_name = 'square';
select routine_name, routine_body from __all_routine_history where routine_name = 'square' order by routine_id desc limit 1;
+--------------+--------------+
| routine_name | routine_body |
+--------------+--------------+
| square       | return x * x |
+--------------+--------------+
alter system change tenant sys;
alter system flush kvcache;
alter system flush pl cache global;

select routine_name, routine_body from oceanbase.__all_routine_history where routine_name = 'square' order by routine_id desc limit 1;
+--------------+--------------+
| routine_name | routine_body |
+--------------+--------------+
| square       | return x * x |
+--------------+--------------+
select square(4);
+-----------+
| square(4) |
+-----------+
|        16 |
+-----------+
drop function if exists square;
