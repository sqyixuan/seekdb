result_format: 4

drop table if exists t1;
CREATE TABLE t1(a JSON);

DROP PROCEDURE IF EXISTS p;
create procedure p()
begin
    declare x int default 1;
    while x <=20 do
        SET @a:= CONCAT('[',REPEAT('"a",',150000),'"a"]');
        SELECT JSON_TYPE(@a), LENGTH(@a), LENGTH(@a)*3;
        INSERT INTO t1(a) VALUES(@a);
        set x = x+1;
    end while;
    commit;
end //
call p;
