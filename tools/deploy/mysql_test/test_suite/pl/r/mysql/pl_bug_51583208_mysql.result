drop table t_hr;
drop procedure p1;
drop procedure p2;
drop procedure if exists p0;
create procedure p0(a int)begin set @i=0;end;
/
create procedure p1()
begin
declare i int default 0;
while i < 5 do
set @a=concat(concat('exists(select ',i),')');
set @sql=concat(concat('call p0(',@a),')');
prepare stmt from @sql;
execute stmt;
deallocate prepare stmt;
set i=i+1;
end while;
end;
/
call p1();
