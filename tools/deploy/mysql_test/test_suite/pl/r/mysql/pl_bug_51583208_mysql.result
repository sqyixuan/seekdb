alter system flush ps cache global;
drop table if exists t_hr;
drop procedure if exists p1;
drop procedure if exists p2;
create table t_hr(c1 int, c2 int);
create procedure p1()
begin
insert into t_hr value(1,1);
insert into t_hr value(1);
end;
/
create procedure p2()
begin
insert into t_hr value(2,1);
insert into t_hr value(2,2);
end;
/
select ps_sql, stmt_item_ref_count, stmt_info_ref_count from oceanbase.gv$ob_ps_item_info where upper(ps_sql) like '%T_HR%';
