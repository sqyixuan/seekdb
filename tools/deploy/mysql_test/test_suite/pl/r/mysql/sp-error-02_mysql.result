  DECLARE CONTINUE HANDLER FOR SQLWARNING
    SELECT 'H2' AS HandlerId;

  DECLARE CONTINUE HANDLER FOR SQLSTATE '01000'
    SELECT 'H3' AS HandlerId;

  SIGNAL SQLSTATE '01000'; # Should be handled by H3.
