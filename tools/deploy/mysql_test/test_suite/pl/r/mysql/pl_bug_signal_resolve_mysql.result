############################start case 1############################
drop procedure if exists p$$
CREATE PROCEDURE p ()
begin
DECLARE aaa CONDITION FOR sqlstate '00';
signal aaa set message_text='aa';
end;
$$
ERROR 42000: Bad SQLSTATE: '00'
call p()$$
ERROR 42000: procedure test.p does not exist
############################start case 2############################
drop procedure if exists p$$
CREATE PROCEDURE p ()
begin
DECLARE continue HANDLER FOR sqlstate '45000',sqlstate '45000' select 'aaa';
signal sqlstate '45000' set message_text='a';
end;
$$
ERROR 42000: Duplicate handler declared in the same block
call p()$$
ERROR 42000: procedure test.p does not exist
############################start case 3############################
drop procedure if exists p1$$
CREATE PROCEDURE p1()
BEGIN
SIGNAL SQLSTATE  '99999' SET MESSAGE_TEXT = null;
END;
$$
call p1()$$
ERROR 42000: Variable 'MESSAGE_TEXT' can't be set to the value of 'NULL'
drop procedure p1$$
############################start case 4############################
drop procedure if exists p$$
CREATE PROCEDURE p ()
BEGIN
DECLARE EXIT HANDLER FOR SQLEXCEPTION
BEGIN
select 'aaaaa';
END;
resignal sqlstate '00000';
END$$
ERROR 42000: Bad SQLSTATE: '00000'
CALL p()$$
ERROR 42000: procedure test.p does not exist
############################start case 5############################
drop procedure if exists p;
CREATE PROCEDURE p () RESIGNAL sqlstate '00000';
ERROR 42000: Bad SQLSTATE: '00000'
call p();
ERROR 42000: procedure test.p does not exist
############################start case 6############################
drop procedure if exists p$$
CREATE PROCEDURE p ()
BEGIN
DECLARE no_such_table condition FOR 1051;
DECLARE EXIT HANDLER FOR SQLEXCEPTION select 'bbbbbb';
resignal no_such_table set message_text='zzzz', mysql_errno=1051;
END$$
ERROR HY000: SIGNAL/RESIGNAL can only use a CONDITION defined with SQLSTATE
CALL p()$$
ERROR 42000: procedure test.p does not exist
############################start case 7############################
drop procedure if exists p$$
CREATE PROCEDURE p ()
BEGIN
declare a condition for sqlstate '43000';
declare b condition for sqlstate '43001';
declare c condition for sqlstate '43002';
declare continue handler for a,b,c
begin
get diagnostics condition 1 @p=returned_sqlstate;
SELECT 'aaa';
end;
signal a;
END$$
CALL p()$$
aaa
aaa
drop procedure p$$
############################start case 8############################
drop procedure if exists p1$$
CREATE PROCEDURE p1()
BEGIN
declare continue handler for b
begin
get diagnostics condition 1 @p=returned_sqlstate;
SELECT 'aaa';
end;
END $$
ERROR 42000: Undefined CONDITION: b
call p1();$$
ERROR 42000: procedure test.p1 does not exist
