CREATE PROCEDURE get_txmm(in pnum char (20))
BEGIN
DECLARE _txmm CHAR (10);
DECLARE t_error INTEGER DEFAULT 0;
DECLARE errmsg VARCHAR (128) DEFAULT '其他异常' CHARACTER SET gbk;
DECLARE exit HANDLER FOR SQLEXCEPTION 
begin
SELECT -1 as t_error,'更新数据失败' as errmsg;
end;
declare exit handler for not found 
begin 
SELECT -1 as t_error,'手机号码未注册' as errmsg;
end;
SELECT t_error,errmsg;
END;
/
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near ''其他异常' CHARACTER SET gbk' at line 5
