############ ◆◆ PL中枚举变量赋值给用户自定义变量
drop PROCEDURE pro9_1;

CREATE PROCEDURE pro9_1(arg1 ENUM('one', 'TWO','Three','FouR'))
begin
  declare var1 ENUM('one', 'TWO','Three','FouR') default 'TWO';
  set @var1 = var1;
  set @var2 = arg1;
  set @var3 = (select var1 from dual);
  select arg1 into @var4 from dual;
  select @var1,@var2,@var3,@var4;
end;
/

call pro9_1('one');
+-------+-------+-------+-------+
| @var1 | @var2 | @var3 | @var4 |
+-------+-------+-------+-------+
| TWO   | one   | TWO   | one   |
+-------+-------+-------+-------+
select @var1,@var2,@var3,@var4;
+-------+-------+-------+-------+
| @var1 | @var2 | @var3 | @var4 |
+-------+-------+-------+-------+
| TWO   | one   | TWO   | one   |
+-------+-------+-------+-------+

drop PROCEDURE pro9_1;

############ ◆◆ 游标中使用枚举值
drop PROCEDURE pro10_1;

CREATE PROCEDURE pro10_1()
BEGIN
    DECLARE done BOOLEAN DEFAULT FALSE;
    DECLARE var1 ENUM('','NULL', 'one', 'TWO','Three','FouR') DEFAULT 'one';
    DECLARE var2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two') DEFAULT 'Two';
    DECLARE cursor_name CURSOR FOR SELECT c1, c2 FROM tab0 order by id;
    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;
    OPEN cursor_name;
    read_loop: LOOP
        FETCH cursor_name INTO var1, var2;
        IF done THEN
            LEAVE read_loop;
        END IF;
        SELECT var1, var2;
    END LOOP;
    CLOSE cursor_name;
END;
/

call pro10_1();
+------+------+
| var1 | var2 |
+------+------+
+------+------+
| var1 | var2 |
+------+------+
+------+------+
| var1 | var2 |
+------+------+
+------+------+
| var1 | var2 |
+------+------+
+-------+------+
| var1  | var2 |
+-------+------+
+------+------+
| var1 | var2 |
+------+------+
|      |      |
| NULL | NULL |
| one  | -1   |
| TWO  | 2    |
| Three | 3.14 |
| FouR | 4.0  |
+------+------+
+------+------+
+------+------+
+------+------+
+-------+------+
+------+------+

drop PROCEDURE pro10_1;

