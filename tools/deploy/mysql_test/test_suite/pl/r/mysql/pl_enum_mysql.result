CREATE PROCEDURE pro12_2(arg ENUM('','NULL', 'one', 'TWO','Three','FouR'))
BEGIN
  declare var1 ENUM('','NULL', 'one', 'TWO','Three','FouR') default 'one';
  declare var2 ENUM('','null', 'one', 'two','three','four','1','2','3','4') default 'TWO';
  select EXPORT_SET(arg, '1','0',',', 10);
  select FORMAT(arg, 2);
  select MAKE_SET(arg,var1,var2,'aa','bb');
  select REPEAT(arg, var1);
  select INTERVAL(arg,var1,var2);
END;
/

call pro12_2('NULL');
