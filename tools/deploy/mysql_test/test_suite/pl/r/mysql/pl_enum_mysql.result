CREATE PROCEDURE pro7_5(arg1 ENUM('','NULL', 'one', 'TWO','Three','FouR'),arg2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two'))
begin
  CASE arg1
    WHEN ''     THEN select '【WHEN 空分支 1】';
    WHEN 'NULL' THEN select '【WHEN NULL分支 2】';
    WHEN arg2   THEN select  '【WHEN arg2分支 3】';
    ELSE select '【ELSE分支 4】';
  END CASE; 
end;
/

