############ ◆◆ 存储过程
#### 变量类型
#### 参数类型 in/inout
drop PROCEDURE my_pro4_1;
drop PROCEDURE my_pro4_2;
drop PROCEDURE my_pro4_3;

CREATE PROCEDURE my_pro4_1(in arg ENUM('','null', 'one', 'two','three','four'))
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO') default null;
  SELECT var1 default_value;
END;
/
CREATE PROCEDURE my_pro4_2(inout arg ENUM('','null', 'one', 'two','three','four'))
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'ONE';
  declare var2 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'TWO';
  SELECT var1, var2, arg;
  set var1 = arg;
  set arg  = var2;
  set var2 = 'four';
  SELECT var1 ,var2, arg;
END;
/
CREATE PROCEDURE my_pro4_3()
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'THREE';
  declare var2 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'FOUR';
  SELECT var1, var2;
  call my_pro4_2(var1);
  call my_pro4_2(var2);
  SELECT var1 ,var2;
END;
/

call my_pro4_1('   ');
+---------------+
| default_value |
+---------------+
| NULL          |
+---------------+
call my_pro4_1('two');
+---------------+
| default_value |
+---------------+
| NULL          |
+---------------+
call my_pro4_1(concat('T','wo'));
+---------------+
| default_value |
+---------------+
| NULL          |
+---------------+
call my_pro4_1(4);
+---------------+
| default_value |
+---------------+
| NULL          |
+---------------+
call my_pro4_1(5);
+---------------+
| default_value |
+---------------+
| NULL          |
+---------------+
call my_pro4_1('three');
+---------------+
| default_value |
+---------------+
| NULL          |
+---------------+

set @arg='three';
call my_pro4_2(@arg);
+------+------+-------+
| var1 | var2 | arg   |
+------+------+-------+
+-------+------+------+
| var1  | var2 | arg  |
+-------+------+------+
| ONE  | TWO  | three |
| THREE | FOUR | two  |
+------+------+-------+
+-------+------+------+
SELECT @arg;
+------+
| @arg |
+------+
| two  |
+------+

set @arg=2;
call my_pro4_2(@arg);
+------+------+------+
| var1 | var2 | arg  |
+------+------+------+
+------+------+------+
| var1 | var2 | arg  |
+------+------+------+
| ONE  | TWO  | null |
| NULL | FOUR | two  |
+------+------+------+
+------+------+------+
SELECT @arg;
+------+
| @arg |
+------+
| two  |
+------+

call my_pro4_3();
+-------+------+
| var1  | var2 |
+-------+------+
+------+------+-------+
| var1 | var2 | arg   |
+------+------+-------+
+-------+------+------+
| var1  | var2 | arg  |
+-------+------+------+
+------+------+------+
| var1 | var2 | arg  |
+------+------+------+
+------+------+------+
| var1 | var2 | arg  |
+------+------+------+
+------+------+
| var1 | var2 |
+------+------+
| THREE | FOUR |
| ONE  | TWO  | three |
| THREE | FOUR | two  |
| ONE  | TWO  | four |
| FOUR | FOUR | two  |
| TWO  | TWO  |
+-------+------+
+------+------+-------+
+-------+------+------+
+------+------+------+
+------+------+------+
+------+------+

#### 变量类型 out
drop PROCEDURE my_pro5_1;
drop PROCEDURE my_pro5_2;
drop PROCEDURE my_pro5_3;

CREATE PROCEDURE my_pro5_1(out out_arg ENUM('','null', 'one', 'two','three','four'))
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO') default null;
  set out_arg = var1;
  SELECT out_arg;
  set out_arg = 'ONE';
  SELECT out_arg;
  set out_arg = 3;
  SELECT out_arg;
  set out_arg = @var;
  SELECT out_arg;
END;
/
CREATE PROCEDURE my_pro5_2(in in_arg ENUM('','null', 'one', 'two','three','four'),inout inout_arg ENUM('','null', 'one', 'two','three','four'),out out_arg ENUM('','null', 'one', 'two','three','four'))
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'ONE';
  declare var2 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'TWO';
  set inout_arg = in_arg;
  SELECT inout_arg;
  set out_arg = in_arg;
  SELECT out_arg;
  set out_arg = inout_arg;
  SELECT out_arg;
END;
/
CREATE PROCEDURE my_pro5_3()
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'ONE';
  declare var2 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'TWO';
  declare var3 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'THREE';
  SELECT var1, var2, var3;
  call my_pro5_2(var1,var2,var3);
  SELECT var1 ,var2;
END;
/

set @var='two';
call my_pro5_1(@var);
+---------+
| out_arg |
+---------+
+---------+
| out_arg |
+---------+
+---------+
| out_arg |
+---------+
+---------+
| out_arg |
+---------+
| NULL    |
| one     |
| one     |
| two     |
+---------+
+---------+
+---------+
+---------+
select @var;
+------+
| @var |
+------+
| two  |
+------+

set @var1='two';
set @var2='THREE';
set @var3='FOUR';
call my_pro5_2(@var1,@var2,@var3);
+-----------+
| inout_arg |
+-----------+
+---------+
| out_arg |
+---------+
+---------+
| out_arg |
+---------+
| two       |
| two     |
| two     |
+-----------+
+---------+
+---------+
select @var1,@var2,@var3;
+-------+-------+-------+
| @var1 | @var2 | @var3 |
+-------+-------+-------+
| two   | two   | two   |
+-------+-------+-------+

call my_pro5_3();
+------+------+-------+
| var1 | var2 | var3  |
+------+------+-------+
+-----------+
| inout_arg |
+-----------+
+---------+
| out_arg |
+---------+
+---------+
| out_arg |
+---------+
+------+------+
| var1 | var2 |
+------+------+
| ONE  | TWO  | THREE |
| one       |
| one     |
| one     |
| ONE  | ONE  |
+------+------+-------+
+-----------+
+---------+
+---------+
+------+------+

drop PROCEDURE my_pro5_1;
drop PROCEDURE my_pro5_2;
drop PROCEDURE my_pro5_3;

drop PROCEDURE my_pro5_4;

CREATE PROCEDURE my_pro5_4(arg ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR'))
BEGIN
  declare var1 ENUM('one', 'two') default 'one';
  declare var2 ENUM('','null', 'one', 'two') default 'two';
  declare var3 ENUM('','null', 'one', 'two','1','2','3') default '3';
  select var1,var2,var3,arg;
  set arg = var1;
  set var3 = var2;
  select var1,var2,var3,arg;
END 
/

call my_pro5_4('     ');
+------+------+------+------+
| var1 | var2 | var3 | arg  |
+------+------+------+------+
+------+------+------+------+
| var1 | var2 | var3 | arg  |
+------+------+------+------+
| one  | two  | 3    |      |
| one  | two  | two  | ONE  |
+------+------+------+------+
+------+------+------+------+
call my_pro5_4('THREE');
+------+------+------+-------+
| var1 | var2 | var3 | arg   |
+------+------+------+-------+
+------+------+------+------+
| var1 | var2 | var3 | arg  |
+------+------+------+------+
| one  | two  | 3    | THREE |
| one  | two  | two  | ONE  |
+------+------+------+-------+
+------+------+------+------+
call my_pro5_4('three');
+------+------+------+-------+
| var1 | var2 | var3 | arg   |
+------+------+------+-------+
+------+------+------+------+
