CREATE PROCEDURE pro12_6(arg ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR'))
BEGIN
  declare var1 ENUM('','null', 'one', 'two','1.235','2024-11-26 11:30:00.123456') default '2024-11-26 11:30:00.123456';
  select CAST(var1 AS DATE),CAST(var1 AS DATETIME(3));
  set var1 = '1.235';
  select CAST(var1 AS DECIMAL(3,2)),CAST(var1 AS UNSIGNED),CAST(var1 AS SIGNED);
  SELECT CAST(arg AS CHAR(10));
END 
/

