| NULL  | NULL |
| one   | -1   |
| TWO   | 2    |
| Three | 3.14 |
| FouR  | 4.0  |
+-------+------+
DEALLOCATE PREPARE stmt;

SET @sql = 'SELECT c1, c2 FROM tab0 where c1 = ? order by id';
SET @c1 ='Three';
SET @c2 = 3;
PREPARE stmt FROM @sql;
EXECUTE stmt using @c1;
+-------+------+
| c1    | c2   |
+-------+------+
| Three | 3.14 |
+-------+------+
EXECUTE stmt using @c2;
+------+------+
| c1   | c2   |
+------+------+
| one  | -1   |
+------+------+
DEALLOCATE PREPARE stmt;

############ ◆◆ 循环结构中使用枚举值
drop PROCEDURE pro11_1;
drop PROCEDURE pro11_2;

CREATE PROCEDURE pro11_1(inout arg ENUM('','NULL', 'one', 'TWO','Three','FouR'))
BEGIN
  WHILE arg > 1 DO
    select arg;
    SET arg = arg - 1;
  END WHILE;
END;
/
CREATE PROCEDURE pro11_2(inout arg ENUM('','NULL', 'one', 'TWO','Three','FouR'))
  BEGIN
    loop_label1: LOOP
      select arg;
      SET arg = arg - 1;
      IF arg = 2 THEN
        select 'ITERATE';
        ITERATE loop_label1;
      END IF;
      IF arg = 1 THEN
        select 'LEAVE';
        LEAVE loop_label1;
      END IF; 
    END LOOP loop_label1;
END;
/

SET @var1 ='FouR';
call pro11_1(@var1);
+------+
| arg  |
+------+
+-------+
| arg   |
+-------+
+------+
| arg  |
+------+
+------+
| arg  |
+------+
+------+
| arg  |
+------+
| FouR |
| Three |
| TWO  |
| one  |
| NULL |
+------+
+-------+
+------+
+------+
+------+

SET @var2 ='FouR';
call pro11_2(@var2);
+------+
| arg  |
+------+
+-------+
| arg   |
+-------+
+------+
| arg  |
+------+
+------+
| arg  |
+------+
+---------+
| ITERATE |
+---------+
+------+
| arg  |
+------+
+-------+
| LEAVE |
+-------+
| FouR |
| Three |
| TWO  |
| one  |
| ITERATE |
| NULL |
| LEAVE |
+------+
+-------+
+------+
+------+
+---------+
+------+
+-------+

drop PROCEDURE pro11_1;
drop PROCEDURE pro11_2;

############ ◆◆ 枚举值与内置函数正交
drop PROCEDURE pro12_1;

CREATE PROCEDURE pro12_1(arg ENUM('','NULL', 'one', 'TWO','Three','FouR'))
BEGIN
  declare var1 ENUM('','NULL', 'one', 'TWO','Three','FouR') default 'one';
  declare var2 ENUM('','null', 'one', 'two','three','four','1','2','3','4') default 'TWO';
  select ASCII(arg),CHAR_LENGTH(arg),LENGTH(arg),SOUNDEX(arg),HEX(WEIGHT_STRING(arg AS CHAR(4)));
  select upper(arg),CONCAT(var1, arg),INSERT(arg,0,3,var1),LPAD(arg,10,var1),LEFT(arg,2),MID(arg,1,2);
  select FIELD(arg, var1,var2),FIND_IN_SET(arg,var2),HEX(arg),INSTR(arg,var2),OCT(arg),UNHEX(arg);
  select POSITION(arg IN var2),QUOTE(arg),REPLACE(arg, arg, var1),REVERSE(arg),SUBSTR(arg, 0,3),SUBSTRING_INDEX(arg, var2, 1);
  select arg rlike var1,arg rlike var2,STRCMP(var1,arg),STRCMP(var2,arg);
END;
/
call pro12_1('TWO');
+------------+------------------+-------------+--------------+------------------------------------+
| ASCII(arg) | CHAR_LENGTH(arg) | LENGTH(arg) | SOUNDEX(arg) | HEX(WEIGHT_STRING(arg AS CHAR(4))) |
+------------+------------------+-------------+--------------+------------------------------------+
+------------+-------------------+----------------------+-------------------+-------------+--------------+
| upper(arg) | CONCAT(var1, arg) | INSERT(arg,0,3,var1) | LPAD(arg,10,var1) | LEFT(arg,2) | MID(arg,1,2) |
+------------+-------------------+----------------------+-------------------+-------------+--------------+
|         84 |                3 |           3 | T000         | 00540057004F0020                   |
| TWO        | oneTWO            | TWO                  | oneoneoTWO        | TW          | TW           |
+------------+------------------+-------------+--------------+------------------------------------+
+------------+-------------------+----------------------+-------------------+-------------+--------------+
ERROR 22000: Invalid data type for the operation

drop PROCEDURE pro12_1;

