create trigger my_tri7_3 before insert on tab1 for each row
begin
  DECLARE str1 ENUM('','NULL', 'one', 'TWO','Three','FouR') DEFAULT 'one';
  DECLARE str2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two') DEFAULT 'Two';
  IF new.c1 != new.c2 THEN
    if new.c2 > new.c1 THEN
      set new.c2 = 6;
      INSERT INTO tab2(c1,c2,c3) VALUES (new.c1,new.c2,concat('new.c1 > new.c2 ',new.c3));
    else
      set new.c1 = str1;
      set new.c2 = str2;
      INSERT INTO tab2(c1,c2,c3) VALUES (new.c1,new.c2,concat('new.c1 < new.c2 ',new.c3));
    END IF;
  else
    set new.c1 = str1;
    set new.c2 = str2;
    INSERT INTO tab2(c1,c2,c3) VALUES (new.c1,new.c2,concat('new.c1 = new.c2 ',new.c3));
  END IF;
end;
/

