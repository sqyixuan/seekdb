CREATE PROCEDURE pro8_1(arg1 ENUM('','NULL', 'one', 'TWO','Three','FouR'))
begin
  declare var1 ENUM('','NULL', 'one', 'TWO','Three','FouR');
  set var1 = (select arg1);
  select var1;
  set var1 = (select c1 from tab1 where id = 3);
  select var1;
end;
/

