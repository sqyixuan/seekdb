drop trigger my_tri7_6;

create trigger my_tri7_6 before update on tab1 for each row
begin
  CASE new.c1
    WHEN old.c1 THEN SET new.c1 = 'one';SET new.c2 = 'One';SET new.c3 = concat('【WHEN old.c1分支 1】',old.c3);
    WHEN ''     THEN SET new.c1 = 'TWO';SET new.c2 = 'Two';SET new.c3 = concat('【WHEN 空分支 2】',old.c3);
    WHEN 'NULL' THEN SET new.c1 = 'Three';SET new.c2 = '3.14';SET new.c3 = concat('【WHEN NULL分支 3】',old.c3);
    ELSE SET new.c1 = 'FouR';SET new.c2 = '4.0';SET new.c3 = concat('【ELSE分支 4】',old.c3);
  END CASE; 
  INSERT INTO tab2(c1,c2,c3) VALUES (old.c1,old.c2,concat('old.xxx ',old.c3));
  INSERT INTO tab2(c1,c2,c3) VALUES (new.c1,new.c2,concat('new.xxx ',new.c3));
end;
/

