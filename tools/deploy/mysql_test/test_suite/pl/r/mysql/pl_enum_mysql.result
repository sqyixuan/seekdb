#### 变量类型
drop FUNCTION my_fun3_1;
drop FUNCTION my_fun3_2;
drop FUNCTION my_fun3_3;
drop FUNCTION my_fun3_4;
drop FUNCTION my_fun3_5;

CREATE FUNCTION my_fun3_1(arg ENUM('','null', 'one', 'two')) RETURNS ENUM('','null', 'one', 'two') DETERMINISTIC
BEGIN
  RETURN arg;
END 
/
CREATE FUNCTION my_fun3_2(arg ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR')) RETURNS ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') DETERMINISTIC
BEGIN
  RETURN arg;
END 
/
CREATE FUNCTION my_fun3_3() RETURNS INT DETERMINISTIC
BEGIN
  declare var1 ENUM('','NULL', 'One', 'TWO');
  set var1 = 'One';
  RETURN var1;
END 
/
CREATE FUNCTION my_fun3_4() RETURNS INT DETERMINISTIC
BEGIN
  declare var1 ENUM('','NULL', 'One', 'TWO') default 'TWO';
  RETURN var1;
END 
/
CREATE FUNCTION my_fun3_5(arg ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR')) RETURNS INT DETERMINISTIC
BEGIN
  declare var1 ENUM('','null', 'one', 'two');
  set var1 = arg;
  RETURN var1;
END 
/

