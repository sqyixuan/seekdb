result_format: 4

# ◆ 准备测试用户
drop user if exists whh_test0;
drop database if exists whh_test0_db;
create user 'whh_test0' identified by 'whh_test0';
create database whh_test0_db character set utf8;
grant all on *.* to 'whh_test0'@'%' with grant option;



set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
SET GLOBAL sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER';

#-----------------------------------------------------------------------------
# 场景： enum 与 pl 正交测试
#-----------------------------------------------------------------------------
drop table tab0;
CREATE TABLE tab0 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    c1 ENUM('','NULL', 'one', 'TWO','Three','FouR') NOT NULL,
    c1_index int as (c1) STORED,
    c2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two') DEFAULT '',
    c2_index int as (c2+0) STORED,
    c3 VARCHAR(255));
INSERT INTO tab0(c1,c2,c3) VALUES ('', '', '空枚举值');
INSERT INTO tab0(c1,c2,c3) VALUES ('NULL', NULL, 'NULL');
INSERT INTO tab0(c1,c2,c3) VALUES ('one', '-1', '枚举值');
INSERT INTO tab0(c1,c2,c3) VALUES ('4', '4', '下标');
INSERT INTO tab0(c1,c2,c3) VALUES (5, 5, '下标');
INSERT INTO tab0(c1,c2,c3) VALUES ('FouR', '4.0','枚举值');
select * from tab0 order by 1;
+----+-------+----------+------+----------+--------------+
| id | c1    | c1_index | c2   | c2_index | c3           |
+----+-------+----------+------+----------+--------------+
|  1 |       |        1 |      |        1 | 空枚举值     |
|  2 | NULL  |        2 | NULL |     NULL | NULL         |
|  3 | one   |        3 | -1   |        3 | 枚举值       |
|  4 | TWO   |        4 | 2    |        4 | 下标         |
|  5 | Three |        5 | 3.14 |        5 | 下标         |
|  6 | FouR  |        6 | 4.0  |        6 | 枚举值       |
+----+-------+----------+------+----------+--------------+

drop table tab1;
CREATE TABLE tab1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    c1 ENUM('','NULL', 'one', 'TWO','Three','FouR') NOT NULL,
    c2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two') DEFAULT '',
    c3 varchar(2000));
INSERT INTO tab1(c1,c2,c3) VALUES ('one', '-1', '1');
INSERT INTO tab1(c1,c2,c3) VALUES ('TWO', '2','2');
select * from tab1 order by 1;
+----+------+------+------+
| id | c1   | c2   | c3   |
+----+------+------+------+
|  1 | one  | -1   | 1    |
|  2 | TWO  | 2    | 2    |
+----+------+------+------+

drop table tab2;
CREATE TABLE tab2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    c1 ENUM('','NULL', 'one', 'TWO','Three','FouR') NOT NULL,
    c2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two') DEFAULT '',
    c3 varchar(2000));
INSERT INTO tab2(c1,c2,c3) VALUES ('Three', '3.14','1');
select * from tab2 order by 1;
+----+-------+------+------+
| id | c1    | c2   | c3   |
+----+-------+------+------+
|  1 | Three | 3.14 | 1    |
+----+-------+------+------+

############ ◆◆ function
#### 参数类型
drop FUNCTION my_fun1_1;
drop FUNCTION my_fun1_2;

CREATE FUNCTION MY_FUN1_1(arg ENUM('','NULL', 'one', 'TWO','Three','FouR')) RETURNS INT DETERMINISTIC
BEGIN
  RETURN arg+0;
END 
/
CREATE FUNCTION MY_FUN1_2(arg ENUM('','NULL', 'one', 'TWO','Three','FouR','ARG')) RETURNS ENUM('','NULL', 'one', 'TWO','Three','FouR','RETURNS') DETERMINISTIC
BEGIN
  RETURN arg;
END 
/
CREATE FUNCTION MY_FUN1_3(arg1 ENUM('','NULL', 'one', 'TWO','Three','FouR','ARG'), arg2 ENUM('','NULL', 'one', 'TWO','Three','FouR','ARG')) RETURNS ENUM('','NULL', 'one', 'TWO','Three','FouR','RETURNS') DETERMINISTIC
BEGIN
  RETURN arg1 + arg2;
END 
/

