result_format: 4
drop function if exists f1;
drop procedure if exists p1;

create function f1(a int) returns int DETERMINISTIC
begin
  return a;
end
/

create procedure p1(arg1 int,arg2 int)
begin
  declare a int;
  select arg1;
end
/

set @a=1;
prepare stmt from 'call p1(10,?)';
execute stmt using @a;
+------+
| arg1 |
+------+
|   10 |
+------+

set @a=f1();
ERROR 42000: Incorrect number of arguments
prepare stmt from 'call p1(10,?)';
execute stmt using @a;
+------+
| arg1 |
+------+
|   10 |
+------+

set @a=f1(10);
select @a;
+------+
| @a   |
+------+
|   10 |
+------+
prepare stmt from 'call p1(10,?)';
execute stmt using @a;
+------+
| arg1 |
+------+
|   10 |
+------+

deallocate prepare stmt;

drop function f1;
drop procedure p1;

