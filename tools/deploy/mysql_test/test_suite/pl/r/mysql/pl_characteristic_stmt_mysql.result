------------- case 1 ------------
drop procedure if exists p1;
CREATE PROCEDURE p1(v_num1 decimal)
SQL SECURITY INVOKER
LANGUAGE SQL
DETERMINISTIC
READS SQL DATA
COMMENT "查看characteristic"
BEGIN
SELECT 1 into v_num1 FROM dual;
END;/
show CREATE procedure p1;
Procedure	sql_mode	Create Procedure	character_set_client	collation_connection	Database Collation
p1	STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER	CREATE DEFINER = `admin`@`%` PROCEDURE `p1`(v_num1 decimal)
    DETERMINISTIC
    SQL SECURITY INVOKER
    COMMENT '查看characteristic'
BEGIN
SELECT 1 into v_num1 FROM dual;
END	utf8mb4	utf8mb4_general_ci	utf8mb4_general_ci
drop procedure p1;
