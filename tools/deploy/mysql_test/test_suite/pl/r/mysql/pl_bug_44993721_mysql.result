ERROR 02000: No data - zero rows fetched, selected, or processed

drop table t1;
drop procedure p1;

drop table if exists t2;
create table t2 (a int);
insert into t2 values (1),(2);

drop function if exists f1;

create function f1() returns int
begin
  declare res int;
  declare i int default 1;
  declare cur cursor for select a from t2;
  open cur;
  while i < 5 do
    fetch cur into res;
    set i = i+1;
  end while;
  close cur;
  return res;
end/

select f1() from t2;
ERROR 02000: No data - zero rows fetched, selected, or processed

drop table t2;
drop function f1;
