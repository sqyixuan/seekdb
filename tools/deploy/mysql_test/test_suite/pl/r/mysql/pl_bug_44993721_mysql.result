result_format: 4
drop table if exists t1;
create table t1 (s1 int);
insert into t1 values (1),(2),(3);

drop procedure if exists p1;
create procedure p1()
begin
declare aa int;
declare i int default 1;
declare cur cursor for select s1 from t1 ;
open cur;
 while i < 7 do
fetch cur into aa;
set i = i + 1;
select aa;
end while;
close cur;
end/


call p1();
