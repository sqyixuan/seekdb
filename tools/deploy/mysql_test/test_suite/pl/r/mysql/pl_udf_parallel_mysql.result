CREATE FUNCTION FUNC_NEST_OUTER_DML_INNER_SELECT_15_1318(INTVALUE INT)
   RETURNS INT
   BEGIN
     DECLARE A, B INT;
     select ceil(rand() * 1000) INTO B from dual;
     SELECT INTVALUE INTO A FROM (select B from dual);
     SELECT count(*) - B + A + INTVALUE INTO A FROM (SELECT * FROM ((SELECT t13_15.c4 AS c1 FROM (SELECT (SELECT MIN(t13.c1) FROM t13) AS c1, (SELECT t13.c2 FROM t13 ORDER BY 1 DESC LIMIT 1) AS c2, t13.c3, t13.c4, (SELECT t13.c5 FROM t13 ORDER BY 1 LIMIT 1) AS c5, t13.c6, t13.c7, t13.c8, t13.c9, t13.c10 FROM t13) AS t13_15 WHERE '11' IN (t13_15.c3, t13_15.c3) OR 'PtsWVEFrXbmdNdERjXIeHRHhMSeXwQEPUViODkoIOyUylswpgJiAzOKlmERo' <> 'kFbeNUsrPjMprLRTvnrsZFbaDpKkLtTkDCbMdLKAJgtVebzwDtfCZNaIvVry' AND concat('JGgHsaFKIBncZKIwtKyvWpoOmYJCFYeVUDFxpgeOptVxdVBvRhfPkYFMKoeuwP', 'ACRFcfoyLFHwOowEcGT') LIKE '%Ab%' GROUP BY t13_15.c4 HAVING COUNT(t13_15.c9) <> 285 ORDER BY 1 DESC) EXCEPT (SELECT t9_5.c9 FROM t9 AS t9_5 WHERE '814' IN (t9_5.c12, t9_5.c12) OR t9_5.c7 <= (SELECT t9_5.c10 FROM t9 AS t9_5 ORDER BY 1 LIMIT 1) AND t9_5.c7 <> t9_5.c10 GROUP BY t9_5.c9 ORDER BY 1 ASC) ORDER BY 1) ORDER BY 1);
     RETURN A;
   END;/

