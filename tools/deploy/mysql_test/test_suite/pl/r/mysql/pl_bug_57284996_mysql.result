result_format: 4

alter system flush sql audit global;
alter system flush plan cache global;
alter system flush pl cache global;

CREATE OR REPLACE PACKAGE DBMS_OUTPUT AUTHID CURRENT_USER
  procedure enable(in buffer_size integer default 2000);
  procedure disable();
  procedure put_line(in a varchar(255));
  procedure put_init();
  procedure show_buffer();
  procedure test();
  function f_default_value(a int default 5) return int;
end;
/

CREATE OR REPLACE PACKAGE BODY DBMS_OUTPUT
  declare enabled         BOOLEAN DEFAULT FALSE;
  declare buf_size        INTEGER;
  declare linebuflen      INTEGER DEFAULT 0;
  declare putidx          INTEGER DEFAULT 1;
  declare getidx          INTEGER DEFAULT 1;
  declare get_in_progress BOOLEAN DEFAULT TRUE;
  declare buf             VARCHAR(32767) default 'dbms_output:';
  declare bufleft         INTEGER DEFAULT -1;

  procedure enable(in buffer_size integer default 2000)
  BEGIN
    set enabled = true;
    IF buffer_size < 2000 THEN
      set buf_size = 2000;
    ELSEIF buffer_size > 1000000 THEN
      set buf_size = 1000000;
    ELSE
      set buf_size = buffer_size;
    END IF;
    set bufleft = buf_size;
  END;

  procedure disable()
  BEGIN
    set enabled = false;
    set get_in_progress = true;
  END;

  procedure put_line(in a varchar(255))
  BEGIN
    declare strlen INTEGER;
    IF enabled THEN
      IF get_in_progress THEN -- clear buffer
        call put_init();
      END IF;

      set strlen = IFNULL(LENGTH(a), 0);
      IF ((strlen + linebuflen) > 32767) THEN
        set linebuflen = 0;
      END IF;

      IF (buf_size <> -1) THEN
        IF (strlen > bufleft) THEN  
          select "exception occur";
        END IF;
        set bufleft = bufleft - strlen;
      END IF;

      set buf = concat(buf, a);
      set linebuflen = linebuflen + strlen;
    END IF;
  END;

  procedure put_init()
  BEGIN
    set linebuflen = 0;
    set bufleft = buf_size;
    set get_in_progress = false;
  END;

  procedure show_buffer()
  begin
    declare output_buf VARCHAR(32767);
    set output_buf = buf;
    select output_buf;
  end;

  procedure test()
  begin
    select "test succ";
  end;
  function f_default_value(a int default 5) return int
  begin
    return a;
  end;
end;
/

call DBMS_OUTPUT.enable()/

call DBMS_OUTPUT.put_line('test package in sys tenant succ!')/

call DBMS_OUTPUT.show_buffer()/
+----------------------------------------------+
| output_buf                                   |
+----------------------------------------------+
| dbms_output:test package in sys tenant succ! |
+----------------------------------------------+

select DBMS_OUTPUT.f_default_value()/
+-------------------------------+
| DBMS_OUTPUT.f_default_value() |
+-------------------------------+
|                             5 |
+-------------------------------+
select DBMS_OUTPUT.f_default_value(10)/
+---------------------------------+
| DBMS_OUTPUT.f_default_value(10) |
+---------------------------------+
|                              10 |
+---------------------------------+

call DBMS_OUTPUT.disable()/

call DBMS_OUTPUT.enable(2000);/
call DBMS_OUTPUT.put_line('test package in mysql mode succ!')/

call DBMS_OUTPUT.show_buffer()/
+----------------------------------------------+
| output_buf                                   |
+----------------------------------------------+
| dbms_output:test package in mysql mode succ! |
+----------------------------------------------+

select DBMS_OUTPUT.f_default_value()/
+-------------------------------+
| DBMS_OUTPUT.f_default_value() |
+-------------------------------+
|                             5 |
+-------------------------------+
select DBMS_OUTPUT.f_default_value(10)/
+---------------------------------+
| DBMS_OUTPUT.f_default_value(10) |
+---------------------------------+
|                              10 |
+---------------------------------+

call DBMS_OUTPUT.disable()/


SELECT PARAMETERIZE_TEXT, object_type, db_id FROM gv$ob_pl_cache_object where PARAMETERIZE_TEXT like '%DBMS_OUTPUT%' ORDER BY last_active_time ASC;
+-----------------------+--------------+--------+
| PARAMETERIZE_TEXT     | object_type  | db_id  |
+-----------------------+--------------+--------+
| oceanbase.DBMS_OUTPUT | PACKAGE      | 201001 |
| oceanbase.DBMS_OUTPUT | PACKAGE BODY | 201001 |
| oceanbase.DBMS_OUTPUT | PACKAGE      | 500001 |
| oceanbase.DBMS_OUTPUT | PACKAGE BODY | 500001 |
+-----------------------+--------------+--------+

SELECT PARAMETERIZE_TEXT, object_type, db_id FROM v$ob_pl_cache_object where PARAMETERIZE_TEXT like '%DBMS_OUTPUT%' ORDER BY last_active_time ASC;
+-----------------------+--------------+--------+
| PARAMETERIZE_TEXT     | object_type  | db_id  |
+-----------------------+--------------+--------+
| oceanbase.DBMS_OUTPUT | PACKAGE      | 201001 |
| oceanbase.DBMS_OUTPUT | PACKAGE BODY | 201001 |
| oceanbase.DBMS_OUTPUT | PACKAGE      | 500001 |
| oceanbase.DBMS_OUTPUT | PACKAGE BODY | 500001 |
+-----------------------+--------------+--------+

drop package DBMS_OUTPUT;
