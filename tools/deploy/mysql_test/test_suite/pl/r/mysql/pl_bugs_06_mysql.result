CREATE procedure p1()
begin
   declare out_code varchar(10);
   declare out_msg varchar(100);
   declare continue handler for SQLEXCEPTION
   begin
        show warnings;
        get diagnostics condition 1
          out_code=returned_sqlstate,out_msg=message_text;
        select 'error:',out_code,out_msg;
   end;
   call p2('aaaa');
end;
/

