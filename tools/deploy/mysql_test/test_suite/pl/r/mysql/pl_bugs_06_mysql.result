CREATE PROCEDURE p1(pval INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
	DECLARE specialty CONDITION FOR SQLSTATE '45000';
	IF pval = 0 THEN
      RESIGNAL;
	ELSEIF pval = 1 THEN
      RESIGNAL SQLSTATE '03000';
	ELSEIF pval = 2 THEN
      RESIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = '【RESIGNAL】An 45000 occurred';
	ELSEIF pval = 3 THEN
      RESIGNAL specialty SET MESSAGE_TEXT = '【RESIGNAL】An error occurred';
	ELSE
      RESIGNAL SQLSTATE '99999' SET MESSAGE_TEXT = '【RESIGNAL】An 99999 occurred', MYSQL_ERRNO = 1001;
	END IF;    
  END;
  DROP TABLE xxx;
END;
/
