`months` varchar(10) COLLATE utf8mb4_bin DEFAULT NULL
);
CREATE PROCEDURE `sp_proc_route_1121`(Months nvarchar(10))
MODIFIES SQL DATA
BEGIN
set @Months = IFNULL(Months,'2021/11');
set @batchID = UUID(); 
-- 
insert into approve_info(id) value('e');
-- 删除旧数据
delete from tb_isa_schedule_check_1119 a where a.months=@Months;
set @now=now();
END;
/
call sp_proc_route_1121('2023/09');
select * from approve_info;
