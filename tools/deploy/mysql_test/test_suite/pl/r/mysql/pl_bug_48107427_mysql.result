drop table t1;
drop table t2;
drop procedure p1;
drop trigger tr_1;
create table t1 (c1 int,c2 int,c3 int);
create table t2 (c1 int,c2 int);
create procedure p1(aa int,bb int)
begin
select * from t1 where c1 = aa and c2 = bb;
end;
/
create trigger tr_1 
after insert on t2 
for each row 
begin 
call p1(1,2);
end;
/
insert into t2 values(1,1);
ERROR 0A000: Not allowed to return a result set from a trigger
drop table t1;
drop table t2;
drop procedure p1;
