+---+
| 1 |
| 2 |
+---+
+---+
call proc2();
+---+
| 1 |
+---+
| 1 |
+---+
call proc3();
+---+
| 1 |
+---+
+---+
| 2 |
+---+
| 1 |
| 2 |
+---+
+---+
call proc4();
+---+
| 1 |
+---+
+---+
| 2 |
+---+
| 1 |
| 2 |
+---+
+---+
call proc5();
+---+
| 1 |
+---+
| 1 |
+---+
ERROR 01000: Data truncated for argument
call proc6();
+---+
| 1 |
+---+
| 1 |
+---+
ERROR 01000: Data truncated for argument
call proc7();
+---+
| 1 |
+---+
| 1 |
+---+

drop procedure proc;
drop procedure proc1;
drop procedure proc2;
drop procedure proc3;
drop procedure proc4;
drop procedure proc5;
drop procedure proc6;
drop procedure proc7;
