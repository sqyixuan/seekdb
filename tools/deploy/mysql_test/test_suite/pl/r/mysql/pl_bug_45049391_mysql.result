result_format: 4
drop procedure if exists proc;
drop procedure if exists proc1;
drop procedure if exists proc2;
drop procedure if exists proc3;
drop procedure if exists proc4;
drop procedure if exists proc5;
drop procedure if exists proc6;
drop procedure if exists proc7;

create procedure proc()
begin
    declare x condition for sqlstate '01000';
    signal x;
    select 1;
end;
/

create procedure proc1()
begin
    declare x condition for sqlstate '01000';
    declare continue handler for x
    begin
        select 1;
    end;
    signal x;
    select 2;
end;
/

create procedure proc2()
begin
    declare x condition for sqlstate '01000';
    declare exit handler for x
    begin
        select 1;
    end;
    signal x;
    select 2;
end;
/

create procedure proc3()
begin
    declare x condition for sqlstate '01000';
    declare continue handler for x
    begin
        select 1;
        signal x;
    end;
    signal x;
    select 2;
end;
/

create procedure proc4()
begin
    declare x condition for sqlstate '01000';
    declare continue handler for x
    begin
        select 1;
        resignal;
    end;
    signal x;
    select 2;
end;
/

create procedure proc5()
begin
    declare x int;
    declare continue handler for sqlwarning
    begin
        select 1;
        resignal;
    end;
    set x = '1a';
end;
/

create procedure proc6()
begin
    declare x int;
    declare continue handler for sqlwarning
    begin
        select 1;
        set x = '1a';
    end;
    set x = '1a';
end;
/

create procedure proc7()
begin
    declare x int;
    declare continue handler for sqlwarning
    begin
        select 1;
    end;
    set x = '1a';
end;
/


call proc();
