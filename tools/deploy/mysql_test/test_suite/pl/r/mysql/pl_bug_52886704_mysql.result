result_format: 4

DROP FUNCTION IF EXISTS fn1;//
CREATE FUNCTION fn1( f1 ENUM("value1", "value2") ) RETURNS DECIMAL(63, 30)
   NO SQL COMMENT 'this is simple'
BEGIN
   RETURN f1;
END//

SELECT fn1( "value1" );
+----------------------------------+
| fn1( "value1" )                  |
+----------------------------------+
| 1.000000000000000000000000000000 |
+----------------------------------+
SELECT fn1( "value2" );
+----------------------------------+
| fn1( "value2" )                  |
+----------------------------------+
| 2.000000000000000000000000000000 |
+----------------------------------+

DROP FUNCTION IF EXISTS fn1;//
CREATE FUNCTION fn1( f1 SET("value1", "value2") ) RETURNS DECIMAL(63, 30)
   NO SQL COMMENT 'this is simple'
BEGIN
   RETURN f1;
END//

SELECT fn1( "value1, value2" );
ERROR 01000: Data truncated for argument
SELECT fn1( "value1,value2"  );
+----------------------------------+
| fn1( "value1,value2"  )          |
+----------------------------------+
| 3.000000000000000000000000000000 |
+----------------------------------+

DROP FUNCTION fn1;
