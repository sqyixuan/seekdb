result_format: 4
DROP PROCEDURE IF EXISTS p_test01;
DROP FUNCTION IF EXISTS f_test01;

CREATE PROCEDURE p_test01()
begin
prepare st1 from 'select 1';
execute st1;
deallocate prepare st1;
end;
//

CREATE FUNCTION f_test01() returns int
begin
prepare st1 from 'select 1';
execute st1;
deallocate prepare st1;
return 1;
end;
//
ERROR 0A000: Dynamic SQL is not allowed in stored function or trigger

CREATE FUNCTION f_test01() returns int
begin
call p_test01();
return 1;
end;
//

prepare st1 from 'call p_test01()';
execute st1;
ERROR HY000: The prepared statement contains a stored routine call that refers to that same statement. It's not allowed to execute a prepared statement in such a recursive manner
deallocate prepare st1;

prepare st1 from 'select f_test01()';
execute st1;
ERROR 0A000: Dynamic SQL is not allowed in stored function or trigger
deallocate prepare st1;

DROP PROCEDURE p_test01;
DROP FUNCTION f_test01;

