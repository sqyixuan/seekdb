result_format: 4

alter system flush plan cache global;
alter system flush pl cache global;
alter system flush sql audit global;

drop procedure if exists p1;

CREATE PROCEDURE p1(in id int)
begin
select id from dual;
end;
/


prepare st1 from 'CALL p1(?)';
set @a=1;
execute st1 using @a;
+------+
| id   |
+------+
|    1 |
+------+
deallocate prepare st1;

call p1(1);
+------+
| id   |
+------+
|    1 |
+------+

select query_sql,statement from GV$OB_PLAN_CACHE_PLAN_STAT where SQL_ID in (select SQL_ID from GV$OB_sql_audit where query_sql like '%call p1%');
+-----------+-----------+
| query_sql | statement |
+-----------+-----------+
+-----------+-----------+
select query_sql from GV$OB_sql_audit where query_sql like '%call%';
+--------------------------------------------------------------------------------------------------------------------------------------------------+
| query_sql                                                                                                                                        |
+--------------------------------------------------------------------------------------------------------------------------------------------------+
| prepare st1 from 'CALL p1(?)'                                                                                                                    |
| CALL p1(?)                                                                                                                                       |
| call p1(1)                                                                                                                                       |
| select query_sql,statement from GV$OB_PLAN_CACHE_PLAN_STAT where SQL_ID in (select SQL_ID from GV$OB_sql_audit where query_sql like '%call p1%') |
+--------------------------------------------------------------------------------------------------------------------------------------------------+
select query_sql,statement from GV$OB_PLAN_CACHE_PLAN_STAT where statement like '%call p1%';
+-----------+------------+
| query_sql | statement  |
+-----------+------------+
| NULL      | CALL p1(?) |
+-----------+------------+
select PARAMETERIZE_TEXT from GV$ob_pl_cache_object;
+-------------------+
| PARAMETERIZE_TEXT |
+-------------------+
| CALL p1(?)        |
| test.p1           |
+-------------------+

drop procedure p1;
