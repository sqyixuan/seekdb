drop function if exists func_test_mysql_proc;

drop procedure if exists proc_test_mysql_proc;


CREATE FUNCTION func_test_mysql_proc(empId_uint8 tinyint unsigned, empId_uint16 smallint unsigned, empId_uint24 mediumint unsigned, empId_uint32 INT unsigned)  RETURNS decimal(12,2) unsigned DETERMINISTIC
BEGIN
declare a tinyint;
    RETURN IF(empId_uint8 IS NOT NULL, 44, 3);
END;
/

CREATE PROCEDURE proc_test_mysql_proc(IN empId TEXT CHARACTER SET latin1 COLLATE latin1_bin) comment 'test comment begin' not DETERMINISTIC no sql sql security invoker
BEGIN
    DECLARE baseSalary DECIMAL(10,2); 
    set @a= empId;
END;
/

