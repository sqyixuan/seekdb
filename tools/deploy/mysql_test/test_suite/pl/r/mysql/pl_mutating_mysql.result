result_format: 4
############################## case1
###
### The outer layer reads t2, the inner layer writes t2 and reports an error,
### and the inner layer reads t2 without reporting an error
drop table t1;
drop table t2;
drop trigger tri_t1;

create table t1(id int);
create table t2(id int);

insert into t2 values(1);
insert into t2 values(2);

create trigger tri_t1 after insert on t1 for each row
begin
  insert into t2 values (1);
end;
/

insert into t1(id) values ((select id from t2 where id = 2));
ERROR HY000: Can't update table 't2' in stored function/trigger because it is already used by statement which invoked this stored function/trigger.

drop trigger tri_t1;

create trigger tri_t1 before insert on t1 for each row
begin
  insert into t2 values (1);
end;
/

insert into t1(id) values ((select id from t2 where id = 2));
ERROR HY000: Can't update table 't2' in stored function/trigger because it is already used by statement which invoked this stored function/trigger.

drop trigger tri_t1;

create trigger tri_t1 before insert on t1 for each row
begin
  select count(*) into @cnt from t2;
end;
/

insert into t1(id) values ((select id from t2 where id = 2));

select @cnt;
+------+
| @cnt |
+------+
|    2 |
+------+

drop table t1;
drop table t2;

############################## case2
###
### the outer layer writes t1, and the inner layer reads t1 is allowed
drop table t1;
drop table t2;
drop table t3;
drop trigger tri_t1;

create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int, c2 int);
create table t3 (c1 int);

insert into t1 values (1, 2);
insert into t2 values (1, 3);

create trigger tri_t1 before update on t1 for each row
  insert into t3 select t2.c2 from t2 inner join t1 on t1.c1 = t2.c1;

update t1 set c2 = 10;
ERROR HY000: Can't update table 't1' in stored function/trigger because it is already used by statement which invoked this stored function/trigger.

select * from t1;
+----+------+
| c1 | c2   |
+----+------+
|  1 |    2 |
+----+------+

select * from t3;
+------+
| c1   |
+------+
+------+

drop trigger tri_t1;

create trigger tri_t1 before insert on t1 for each row
  insert into t3 select t2.c2 from t2 inner join t1 on t1.c1 = t2.c1;

insert into t1 values (10, 11);
insert into t1 values (11, 12),(12, 13);
ERROR HY000: Can't update table 't1' in stored function/trigger because it is already used by statement which invoked this stored function/trigger.
replace into t1 values (11, 12);
replace into t1 values (12, 13),(13, 14);
ERROR HY000: Can't update table 't1' in stored function/trigger because it is already used by statement which invoked this stored function/trigger.

select * from t1;
+----+------+
| c1 | c2   |
+----+------+
|  1 |    2 |
| 10 |   11 |
| 11 |   12 |
+----+------+

select * from t3;
+------+
| c1   |
+------+
|    3 |
|    3 |
+------+

drop table t1;
drop table t2;
drop table t3;

############################## case3
###
### Through function, the outer layer reads t2, and the inner layer writes t2
drop table t1;
drop table t2;
drop function n_1;

create table t1(stats int, s1 int, s2 int);

create table t2(id int ,s1 int, s2 int);

CREATE FUNCTION n_1() RETURNS INT
BEGIN
  INSERT INTO t2 VALUES(1,0,1);
  RETURN 0;
END;
/

select n_1() from t2;
+-------+
| n_1() |
+-------+
+-------+

INSERT INTO t2 VALUES(0,1,3),(1,0,0);

select n_1() from t2;
ERROR HY000: Can't update table 't2' in stored function/trigger because it is already used by statement which invoked this stored function/trigger.

drop table t1;
drop table t2;
drop function n_1;

############################## case4
###
drop table t1;
drop table t2;
drop function f_mutating;

create table t1(c1 int, c2 int);

insert into t1 values (1, 2);

#### The update statement has 0 data that meets the where condition
create function f_mutating() returns int
begin
  update t1 set c1 = 2 where c2 = 3;
  return 2;
end;
/

select count(*) from t1 where f_mutating() > 1;
ERROR HY000: Can't update table 't1' in stored function/trigger because it is already used by statement which invoked this stored function/trigger.

drop function f_mutating;

#### The update statement has 1 data that meets the where condition
create function f_mutating() returns int
begin
  update t1 set c1 = 2 where c2 = 2;
  return 2;
end;
/

select count(*) from t1 where f_mutating() > 1;
ERROR HY000: Can't update table 't1' in stored function/trigger because it is already used by statement which invoked this stored function/trigger.

drop function f_mutating;

#### select nested insert
create function f_mutating() returns int
begin
  insert into t1 values (10, 11);
  return 2;
end;
/

select count(*) from t1 where f_mutating() > 1;
ERROR HY000: Can't update table 't1' in stored function/trigger because it is already used by statement which invoked this stored function/trigger.

drop function f_mutating;

delete from t1;
insert into t1 values (100, 101);

#### select nested delete, the data that meets the where condition is 0
create function f_mutating() returns int
begin
  delete from t1 where c1 = 101;
  return 2;
end;
/

select count(*) from t1 where f_mutating() > 1;
ERROR HY000: Can't update table 't1' in stored function/trigger because it is already used by statement which invoked this stored function/trigger.


drop function f_mutating;
drop table t1;
create table t1 (c1 int primary key, c2 int);

insert into t1 values (100, 101);

create table t2 (c1 int, c2 int);

#### select 嵌套 relace into
create function f_mutating() returns int
begin
  replace into t1 values (100, 200);
  return 2;
end;
/

select count(*) from t1 where f_mutating() > 1;
ERROR HY000: Can't update table 't1' in stored function/trigger because it is already used by statement which invoked this stored function/trigger.

drop function f_mutating;
#### select 嵌套 relace into
create function f_mutating() returns int
begin
  replace into t1 select * from t2;
  return 2;
end;
/

select count(*) from t1 where f_mutating() > 1;
ERROR HY000: Can't update table 't1' in stored function/trigger because it is already used by statement which invoked this stored function/trigger.

drop table t2;


drop function f_mutating;
delete from t1;
insert into t1 values (100, 101);

#### select nested insert on duplicate
create function f_mutating() returns int
begin
  insert into t1 values (100, 200) on duplicate key update c2 = 200;
  return 2;
end;
/

select count(*) from t1 where f_mutating() > 1;
ERROR HY000: Can't update table 't1' in stored function/trigger because it is already used by statement which invoked this stored function/trigger.

drop function f_mutating;
drop table t1;

