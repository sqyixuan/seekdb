alter system set leak_mod_to_check='';
alter system set leak_mod_to_check='PlStmtHashMap';
DROP PROCEDURE if exists p1;
DROP PROCEDURE if exists p2;
CREATE PROCEDURE p1 (pval INT)
BEGIN
DECLARE CONTINUE HANDLER FOR SQLSTATE '23000'
  BEGIN
SIGNAL SQLSTATE '01000' SET MESSAGE_TEXT = 'A warning occurred', MYSQL_ERRNO = 1000;
END;
END
/
CREATE PROCEDURE p2 (pval INT)
BEGIN
DECLARE CONTINUE HANDLER FOR SQLSTATE '23000'
  BEGIN
SIGNAL SQLSTATE '01000' SET MESSAGE_TEXT = 'A warning occurred', MYSQL_ERRNO = 1000;
END;
DECLARE CONTINUE HANDLER FOR SQLSTATE '23000'
  BEGIN
SIGNAL SQLSTATE '01000' SET MESSAGE_TEXT = 'A warning occurred', MYSQL_ERRNO = 1000;
END;
END
/
ERROR 42000: Duplicate handler declared in the same block
call p1(1);
drop procedure p1;
select * from oceanbase.__all_virtual_mem_leak_checker_info order by alloc_count;
