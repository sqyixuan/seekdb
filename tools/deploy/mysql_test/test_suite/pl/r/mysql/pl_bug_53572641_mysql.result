result_format: 4
### simplified case ###
drop procedure if exists proc;

create procedure proc(c numeric(16,2))
begin
select c;
end;
/


call proc(12345.67890);
+----------+
| c        |
+----------+
| 12345.68 |
+----------+

drop procedure proc;

### original case from the client ###
drop table if exists testnum2;

CREATE TABLE testnum2(
  `id` decimal(16,2) DEFAULT NULL,
  `name` varchar(16) DEFAULT NULL
);

drop PROCEDURE if exists insert_into_table;


CREATE  PROCEDURE insert_into_table(IN tableName VARCHAR(255), IN column1Value numeric(16,2), IN column2Value VARCHAR(255))
BEGIN

    select 'input';
    select column1Value;
    select 'input';
    SET @sqlQuery = CONCAT('INSERT INTO ', tableName, ' VALUES (''', column1Value, ''', ''', column2Value, ''')');
    
    PREPARE stmt FROM @sqlQuery;
    EXECUTE stmt;
    DEALLOCATE PREPARE stmt;
END //


CALL insert_into_table('testnum2', 11.22221, 'aaa');
+-------+
| input |
+-------+
+--------------+
| column1Value |
+--------------+
+-------+
| input |
+-------+
| input |
|        11.22 |
| input |
+-------+
+--------------+
+-------+

select * from testnum2;
+-------+------+
| id    | name |
+-------+------+
| 11.22 | aaa  |
+-------+------+

drop procedure insert_into_table;
drop table testnum2;
