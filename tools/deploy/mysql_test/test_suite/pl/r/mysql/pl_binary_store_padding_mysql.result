SET @p1=0,@p2=0,@p3=0//
DROP TABLE IF EXISTS t//
Warnings:
Note	1051	Unknown table 'test.t'
CREATE TABLE t (
b BINARY(3)
)//
INSERT INTO t VALUES ('a ')//
SELECT HEX(b), b = 'a ', b = 'a \0' from t//
HEX(b)	b = 'a '	b = 'a \0'
612000	0	1
DROP PROCEDURE IF EXISTS `pro_1`//
CREATE PROCEDURE pro_1()
BEGIN
DECLARE c BINARY(3);
SET c = 'a ';
SELECT HEX(c), c = 'a ', c = 'a \0' INTO @p1,@p2,@p3;
END//
CALL pro_1()//
SELECT @p1 'HEX(c)',@p2 'c = ''a ''' ,@p3 'c = a 0'//
HEX(c)	c = 'a '	c = a 0
612000	0	1
DROP TABLE IF EXISTS t//
CREATE TABLE t(a1 BINARY(3))//
SET @p1=0,@p2=0,@p3=0,@p4=0,@p5=0//
DROP PROCEDURE IF EXISTS pro1//
CREATE PROCEDURE pro1()
BEGIN
DECLARE i BINARY(3) DEFAULT 'a';
INSERT INTO t VALUES (i);
SET i = 'b\0';
SELECT HEX(a1), a1 = 'a', a1 = 'a\0\0' FROM t INTO @p1,@p2,@p3;
SELECT i = 'b\0\0' INTO @p4;
SELECT HEX(i) INTO @p5;
END//
CALL pro1()//
SELECT @p1 'HEX(a1)',@p2 'a1 = ''a''' ,@p3 'a1 = a\\0\\0',@p4 'i = b\\0\\0',@p5 'HEX(i)'//
HEX(a1)	a1 = 'a'	a1 = a\0\0	i = b\0\0	HEX(i)
610000	0	1	1	620000
DROP TABLE t//
