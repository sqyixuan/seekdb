result_format: 4
drop function if exists f;
drop function if exists f1;
drop function if exists f2;
drop function if exists f3;
drop function if exists f4;
drop function if exists f5;
drop function if exists f6;
drop function if exists f7;
drop table if exists t1;
drop table if exists t2;

create function f()
    returns int
begin
    insert into t2 values(1);
    return 1;
end;
/

create function f1()
    returns int
begin
    declare x int;
    select c1 into x from t2 for update;
    return 1;
end;
/

create function f2()
    returns int
begin
    set global autocommit=on;
    return 1;
end;
/
ERROR HY000: Not allowed to set autocommit from a stored function or trigger

create function f3()
    returns int
begin
    set autocommit = on;
    return 1;
end;
/
ERROR HY000: Not allowed to set autocommit from a stored function or trigger

create function f4()
    returns int
begin
    commit;
    return 1;
end;
/
ERROR HY000: Explicit or implicit commit is not allowed in stored function or trigger.

create function f5()
    returns int
begin
    rollback;
    return 1;
end;
/
ERROR HY000: Explicit or implicit commit is not allowed in stored function or trigger.

create function f6()
    returns int
begin
    savepoint a;
    return 1;
end;
/

create function f7()
    returns int
begin
    savepoint a;
    rollback to a;
    return 1;
end;
/

create table t2(c1 int);
create table t1 select f();
ERROR HY000: Can't update table while ctas is being created.
create table t1 select f1();
drop table t1;
create table t1 select f6();
drop table t1;
create table t1 select f7();
select * from t1;
+------+
| f7() |
+------+
|    1 |
+------+
select * from t2;
+------+
| c1   |
+------+
+------+

drop table t1;
drop table t2;


drop procedure if exists bug20953;
CREATE PROCEDURE bug20953() CREATE OR REPLACE VIEW v AS SELECT 1 INTO @a;
ERROR HY000: View's SELECT contains a 'INTO' clause.
call bug20953();
ERROR 42000: procedure test.bug20953 does not exist
CREATE PROCEDURE bug20953() CREATE OR REPLACE VIEW v AS SELECT 1 INTO OUTFILE "file";
ERROR HY000: View's SELECT contains a 'INTO' clause.
call bug20953();
ERROR 42000: procedure test.bug20953 does not exist

