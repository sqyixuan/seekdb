result_format: 4
drop procedure if exists test_invalid;

create procedure test_invalid(IN a int, IN b set('abc','def'))
BEGIN
    DECLARE v1 INT;
    SET a = 2;
    SET b = 2;
    SET v1 = a + 2;
    SELECT v1;
END //

select DTD_IDENTIFIER from information_schema.parameters where SPECIFIC_NAME ='test_invalid';
+------------------+
| DTD_IDENTIFIER   |
+------------------+
| int(11)          |
| set('abc','def') |
+------------------+

drop procedure test_invalid;
create procedure test_invalid(IN a enum('abcňôłňôłňôłňôł','def', '101'))
BEGIN
    DECLARE v1 INT;
    SET a = 2;
    SET v1 = a + 2;
    SELECT v1;
END //

select DTD_IDENTIFIER from information_schema.parameters where SPECIFIC_NAME ='test_invalid';
+-------------------------------------+
| DTD_IDENTIFIER                      |
+-------------------------------------+
| enum('abcňôłňôłňôłňôł','def','101')     |
+-------------------------------------+

drop procedure test_invalid;
