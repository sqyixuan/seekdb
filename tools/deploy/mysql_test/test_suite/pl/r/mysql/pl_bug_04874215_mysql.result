drop table if exists t1;
drop function if exists f1;
create table t1(c1 enum('1','2'));
insert into t1 value('2');
create function f1(arg enum('1','2')) returns enum('1','2')
BEGIN
declare var enum('1','2');
set var = arg;
return var;
end;
/
select f1(c1) from t1/
f1(c1)
2
drop table t1;
drop function f1;
