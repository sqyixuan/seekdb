drop procedure if exists pro1;
### 指示符对象-存储过程参数
SET @p11=NULL, @p12=NULL,@p21=NULL, @p22=NULL;//

CREATE PROCEDURE pro1(out num1 varchar(200),out row_cou1 varchar(200),out num2 varchar(200),out row_cou2 varchar(200)) 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET CURRENT DIAGNOSTICS num1 = NUMBER, row_cou1 = ROW_COUNT;
	  GET STACKED DIAGNOSTICS num2 = NUMBER, row_cou2 = ROW_COUNT;
  END;
  DROP TABLE no_such_table3;
END;
//

CALL pro1(@p11, @p12,@p21, @p22)//
SELECT 'CURRENT DIAGNOSTICS',@p11 'NUMBER', @p12 'ROW_COUNT';//
+---------------------+--------+-----------+
| CURRENT DIAGNOSTICS | NUMBER | ROW_COUNT |
+---------------------+--------+-----------+
| CURRENT DIAGNOSTICS | 1      | -1        |
+---------------------+--------+-----------+
SELECT 'STACKED DIAGNOSTICS',@p21 'NUMBER', @p22 'ROW_COUNT';//
+---------------------+--------+-----------+
| STACKED DIAGNOSTICS | NUMBER | ROW_COUNT |
+---------------------+--------+-----------+
| STACKED DIAGNOSTICS | 1      | -1        |
+---------------------+--------+-----------+

### 指示符对象-用户定义的变量
SET @p1=NULL, @p2=NULL,@p3=NULL, @p4=NULL;//

DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
	  GET STACKED DIAGNOSTICS @p3 = NUMBER, @p4 = ROW_COUNT;
      SELECT 'CURRENT DIAGNOSTICS',@p1 'NUMBER', @p2 'ROW_COUNT';
	  SELECT 'STACKED DIAGNOSTICS',@p3 'NUMBER', @p4 'ROW_COUNT';
  END;
  DROP TABLE no_such_table4;
END;
//

CALL pro1()//
+---------------------+--------+-----------+
| CURRENT DIAGNOSTICS | NUMBER | ROW_COUNT |
+---------------------+--------+-----------+
+---------------------+--------+-----------+
| STACKED DIAGNOSTICS | NUMBER | ROW_COUNT |
+---------------------+--------+-----------+
| CURRENT DIAGNOSTICS |      1 |        -1 |
| STACKED DIAGNOSTICS |      1 |        -1 |
+---------------------+--------+-----------+
+---------------------+--------+-----------+

### 指示符对象- DECLARE声明的局部变量
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () DETERMINISTIC
BEGIN
  DECLARE num1,num2 varchar(200);
  DECLARE row_cou1,row_cou2 varchar(200);
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET DIAGNOSTICS num1 = NUMBER, row_cou1 = ROW_COUNT;
	  GET STACKED DIAGNOSTICS num2 = NUMBER, row_cou2 = ROW_COUNT;
      SELECT 'CURRENT DIAGNOSTICS',num1 'NUMBER', row_cou1 'ROW_COUNT';
	  SELECT 'STACKED DIAGNOSTICS',num2 'NUMBER', row_cou2 'ROW_COUNT';
  END;
  SELECT * FROM no_such_table5;
END;
//

CALL pro1()//
+---------------------+--------+-----------+
| CURRENT DIAGNOSTICS | NUMBER | ROW_COUNT |
+---------------------+--------+-----------+
+---------------------+--------+-----------+
| STACKED DIAGNOSTICS | NUMBER | ROW_COUNT |
+---------------------+--------+-----------+
| CURRENT DIAGNOSTICS | 1      | -1        |
| STACKED DIAGNOSTICS | 1      | -1        |
+---------------------+--------+-----------+
+---------------------+--------+-----------+

DROP PROCEDURE IF EXISTS pro1;//


drop function if exists fun_test;
DROP TABLE tt1;

create table tt1(id int);


create function fun_test()
returns int
begin
  insert into tt1 values(1);
  insert into tt1 values(1,2);
  return 1;
end;
/


select fun_test();
ERROR 21S01: Column count doesn't match value count at row 1

select * from tt1;
+------+
| id   |
+------+
+------+

set autocommit = 1;

drop function fun_test;


create function fun_test()
returns int
begin
  savepoint a;
  release savepoint a;
  return 1;
end;
/

select fun_test()/
+------------+
| fun_test() |
+------------+
|          1 |
+------------+


drop function fun_test;
drop table tt1;

DROP TABLE t1;
DROP TABLE t2;

CREATE TABLE t1 (
 stats INT,
 s1 INT,
 s2 INT
);

CREATE TABLE t2 (
  s1 INT,
 s2 INT
);

INSERT INTO t1 VALUES(0,1,3),(1,0,0);


CREATE FUNCTION fun_test() RETURNS INT
BEGIN
 INSERT INTO t2 VALUES(0,1);
 RETURN 0;
END/

SELECT * FROM t1 WHERE stats IN (SELECT fun_test());/
+-------+------+------+
| stats | s1   | s2   |
+-------+------+------+
|     0 |    1 |    3 |
+-------+------+------+
SELECT * FROM t2/
+------+------+
| s1   | s2   |
+------+------+
|    0 |    1 |
+------+------+

drop function fun_test/

delete from t2/

CREATE FUNCTION fun_test() RETURNS INT DETERMINISTIC
BEGIN
 INSERT INTO t2 VALUES(0,1);
 RETURN 0;
END/

SELECT * FROM t1 WHERE stats IN (SELECT fun_test());/
+-------+------+------+
| stats | s1   | s2   |
+-------+------+------+
|     0 |    1 |    3 |
+-------+------+------+
SELECT * FROM t2/
+------+------+
| s1   | s2   |
+------+------+
|    0 |    1 |
|    0 |    1 |
+------+------+


drop table t1;
drop table t2;

drop function fun_test;

