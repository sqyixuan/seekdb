call p1();

DROP PROCEDURE if EXISTS p1;
CREATE PROCEDURE p1() SET @a=DEFAULT;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'SET @a=DEFAULT' at line 1
DROP PROCEDURE if EXISTS p1;
CREATE PROCEDURE p1() SET a = DEFAULT;
ERROR 42000: Undeclared variable: a
drop table if exists t1;
drop function if exists f1;
create table t1(c0 int);


create function f1() returns int deterministic
begin
   insert into t1 values(1);
   insert into t1 values('a');
return 1;
end;/


set autocommit = 0;

insert into t1 values(0);
set @a=f1();
ERROR HY000: Incorrect integer value for column 'c0' at row 1
select * from t1;
