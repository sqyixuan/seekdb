result_format: 4
drop function if exists func;

create function func() returns int return 42;

select database();
+------------+
| database() |
+------------+
| test       |
+------------+

select func();
+--------+
| func() |
+--------+
|     42 |
+--------+

select test.func();
+-------------+
| test.func() |
+-------------+
|          42 |
+-------------+

create database no_use;

use no_use;

drop database no_use;

select database();
+------------+
| database() |
+------------+
| NULL       |
+------------+

select func();
ERROR 42000: FUNCTION func does not exist

select test.func();
+-------------+
| test.func() |
+-------------+
|          42 |
+-------------+
