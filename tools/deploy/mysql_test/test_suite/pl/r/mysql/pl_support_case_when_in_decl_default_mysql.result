result_format: 4
drop procedure if exists p_test;
drop procedure if exists p_test;


CREATE  PROCEDURE p_test(
    IN planyear numeric, 
    IN regionOrgId VARCHAR(200) 
)
begin
    DECLARE init_all VARCHAR(500) default 
	case when regionOrgId is null or regionOrgId = '' then 1 else 0 end;
    select init_all from dual;
end
//

CREATE  PROCEDURE p_test1(
    IN planyear numeric, 
    IN regionOrgId VARCHAR(200) 
)
begin
    DECLARE init_all VARCHAR(500) default 
	(case when regionOrgId is null or regionOrgId = '' then 1 else 0 end);
    select init_all from dual;
end
//

show create procedure p_test//
Procedure	sql_mode	Create Procedure	character_set_client	collation_connection	Database Collation
p_test	STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER	CREATE DEFINER = `admin`@`%` PROCEDURE `p_test`(
    IN planyear numeric, 
    IN regionOrgId VARCHAR(200) 
)
begin
    DECLARE init_all VARCHAR(500) default 
	case when regionOrgId is null or regionOrgId = '' then 1 else 0 end;
    select init_all from dual;
end	utf8mb4	utf8mb4_general_ci	utf8mb4_general_ci
show create procedure p_test1//
Procedure	sql_mode	Create Procedure	character_set_client	collation_connection	Database Collation
p_test1	STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER	CREATE DEFINER = `admin`@`%` PROCEDURE `p_test1`(
    IN planyear numeric, 
    IN regionOrgId VARCHAR(200) 
)
begin
    DECLARE init_all VARCHAR(500) default 
	(case when regionOrgId is null or regionOrgId = '' then 1 else 0 end);
    select init_all from dual;
end	utf8mb4	utf8mb4_general_ci	utf8mb4_general_ci

call p_test(1, 'aaa')//
+----------+
| init_all |
+----------+
| 0        |
+----------+
call p_test1(2, 'bbb')//
+----------+
| init_all |
+----------+
| 0        |
+----------+

call p_test(1, NULL)//
+----------+
| init_all |
+----------+
| 1        |
+----------+
call p_test1(2, '')//
+----------+
| init_all |
+----------+
| 1        |
+----------+


DROP procedure p_test1;
DROP procedure p_test;



