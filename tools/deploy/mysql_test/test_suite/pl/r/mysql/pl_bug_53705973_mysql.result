result_format: 4
drop database db1;

drop database db2;

create database db1;
create database db2;

set @a='';
set @b='';

use db1;

create table t0(k int primary key auto_increment, c0 varchar(100), c1 varchar(100));

drop procedure if exists p1;

drop procedure if exists p2;

create procedure p1()
SQL SECURITY INVOKER
begin
select database() into @a from dual;
select current_user() into @b  from dual;
insert into t0(c0,c1) values(@a,@b);
end;
/

create procedure p2()
begin
select database() into @a from dual;
select current_user() into @b  from dual;
insert into t0(c0,c1) values(@a,@b);
end;
/

call p1();
select @a,@b;
+------+---------+
| @a   | @b      |
+------+---------+
| db1  | admin@% |
+------+---------+

call p2();
select @a,@b;
+------+---------+
| @a   | @b      |
+------+---------+
| db1  | admin@% |
+------+---------+

use db2;

create table t0(k int primary key auto_increment, c0 varchar(100), c1 varchar(100));

call db1.p1();
select @a,@b;
+------+---------+
| @a   | @b      |
+------+---------+
| db1  | admin@% |
+------+---------+

call db1.p2();
select @a,@b;
+------+---------+
| @a   | @b      |
+------+---------+
| db1  | admin@% |
+------+---------+

drop user hyy;

create user hyy;

grant all on *.* to hyy;


use db1;

call p1();
select @a,@b;
+------+-------+
| @a   | @b    |
+------+-------+
| db1  | hyy@% |
+------+-------+

call p2();
select @a,@b;
+------+---------+
| @a   | @b      |
+------+---------+
| db1  | admin@% |
+------+---------+

use db2;

call db1.p1();
select @a,@b;
+------+-------+
| @a   | @b    |
+------+-------+
| db1  | hyy@% |
+------+-------+

call db1.p2();
select @a,@b;
+------+---------+
| @a   | @b      |
+------+---------+
| db1  | admin@% |
+------+---------+



set @a='';
set @b='';

select * from db1.t0 order by k;
+---+------+---------+
| k | c0   | c1      |
+---+------+---------+
| 1 | db1  | admin@% |
| 2 | db1  | admin@% |
| 3 | db1  | admin@% |
| 4 | db1  | admin@% |
| 5 | db1  | hyy@%   |
| 6 | db1  | admin@% |
| 7 | db1  | hyy@%   |
| 8 | db1  | admin@% |
+---+------+---------+

select * from db2.t0 order by k;
+---+------+------+
| k | c0   | c1   |
+---+------+------+
+---+------+------+

drop user hyy;

use db1;

create procedure proc()
sql security invoker
begin
prepare stmt from 'create table create_table_test(c int)';
execute stmt;
deallocate prepare stmt;
insert into create_table_test values(42);
end;
/

use db2;

call db1.proc();

show tables;
Tables_in_db2
t0

select * from create_table_test;
ERROR 42S02: Table 'db2.create_table_test' doesn't exist

use db1;

show tables;
Tables_in_db1
create_table_test
t0

select * from create_table_test;
+------+
| c    |
+------+
|   42 |
+------+

drop database db1;
