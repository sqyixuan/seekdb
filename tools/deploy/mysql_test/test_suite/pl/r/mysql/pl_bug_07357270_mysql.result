drop table if exists ps_endpoints;
CREATE TABLE `ps_endpoints` (
`id` varchar(40) NOT NULL,
`direct_media_method` enum('invite','update') ,
`id2` varchar(40) NOT NULL,
`direct_media_glare_mitigation` enum('yes','incoming') ,
`disable_direct_media_on_nat` enum('yes') ,
`dtmf_mode` enum('rfc4733','info','auto','auto_info'),
`timers` enum('forced','required','yes') ,
`callerid_privacy` enum('allowed_not_screened') ,
`100rel` enum('no','peer_supported','yes') ,
`media_encryption` enum('no','dtls') ,
`id1` varchar(40) NOT NULL,
`t38_udptl_ec` enum('none','redundancy') ,
`dtls_setup` enum('active','actpass') ,
`redirect_method` enum('user') ,
`stir_shaken` enum('0','off') ,
`incoming_call_offer_pref` enum('local') ,
`outgoing_call_offer_pref` enum('local1') ,
`security_negotiation1` enum('no') 
);
prepare s from 'select * from ps_endpoints where ps_endpoints.id = ? limit 1';
deallocate prepare s;
drop table ps_endpoints;
