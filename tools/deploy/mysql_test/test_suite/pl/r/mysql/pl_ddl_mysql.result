result_format: 4
drop table if exists a,b,t,t1;
drop procedure if exists p;
drop procedure if exists f;
drop procedure if exists pp;

create procedure p(x int)
begin
  declare y int default 0;
  create table t(a1 int);
  insert into t values(1);
  select a1+1 from t where a1=x into y ;
  insert into t values(y);
end//
call p(1);
select * from t;
+------+
| a1   |
+------+
|    1 |
|    2 |
+------+
drop table t;
drop procedure p;

create procedure p(x int)
begin
  declare y int default 0;
  create table t(a1 int);
  insert into t values(1);
  create view v as select * from t;
  select a1+1 from v where a1=x into y ;
  insert into t values(y);
end//
call p(1);
select * from t;
+------+
| a1   |
+------+
|    1 |
|    2 |
+------+
drop view v;
drop table t;
drop procedure p;

create procedure p(x int)
begin
  declare y int default 0;
  create table t(a1 int);
  alter table t add column a2 int;
  create index idx_1 on t(a1,a2);
  insert into t values(1,1);
  alter table t change column a1 aa1 int;
  select aa1+1 from t where a2=x into y ;
  insert into t values(y,y);
  show create table t;
end//
call p(1);
+-------+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| Table | Create Table                                                                                                                                                                                                                                                                                                                                                            |
+-------+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| t     | CREATE TABLE `t` (
  `aa1` int(11) DEFAULT NULL,
  `a2` int(11) DEFAULT NULL,
  KEY `idx_1` (`aa1`, `a2`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 |
+-------+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
select * from t;
+------+------+
| aa1  | a2   |
+------+------+
|    1 |    1 |
|    2 |    2 |
+------+------+
drop table t;
drop procedure p;

create procedure p()
begin
  create table t(a1 int);
  rename table t to t1;
  select * from t1;
  drop table t1;
end//
call p;
+------+
| a1   |
+------+
+------+
drop procedure p;

