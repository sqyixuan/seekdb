result_format: 4
DROP PROCEDURE IF EXISTS p;

CREATE PROCEDURE p(
  a TINYINT,
  b SMALLINT,
  c MEDIUMINT,
  d INT,
  e BIGINT,
  f TINYINT UNSIGNED,
  g SMALLINT UNSIGNED,
  h MEDIUMINT UNSIGNED,
  i INT UNSIGNED,
  j BIGINT UNSIGNED,
  k FLOAT,
  l DOUBLE,
  m FLOAT UNSIGNED,
  n DOUBLE UNSIGNED,
  o DECIMAL,
  p DECIMAL UNSIGNED
) BEGIN END;

SELECT * FROM information_schema.PARAMETERS WHERE routine_type='PROCEDURE' and specific_name='P' and specific_schema='TEST' order by ordinal_position;
