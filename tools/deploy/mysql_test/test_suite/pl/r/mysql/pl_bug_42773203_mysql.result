result_format: 4


DROP VIEW IF EXISTS test_view;
Warnings:
Note	1051	Unknown table 'test.test_view'
DROP FUNCTION IF EXISTS test_func;


CREATE FUNCTION test_func() RETURNS VARCHAR(30)
BEGIN
    DECLARE A VARCHAR(200);
    SELECT CONCAT('111', '222', '333') FROM DUAL INTO A;
    RETURN A;
END;//


SELECT ROUTINE_NAME, ROUTINE_TYPE, DATA_TYPE, CHARACTER_MAXIMUM_LENGTH FROM INFORMATION_SCHEMA.ROUTINES WHERE ROUTINE_NAME = 'TEST_FUNC';
+--------------+--------------+-----------+--------------------------+
| ROUTINE_NAME | ROUTINE_TYPE | DATA_TYPE | CHARACTER_MAXIMUM_LENGTH |
+--------------+--------------+-----------+--------------------------+
| test_func    | FUNCTION     | varchar   |                       30 |
+--------------+--------------+-----------+--------------------------+

CREATE VIEW test_view AS SELECT test_func();
SELECT * FROM test_view;
+-------------+
| test_func() |
+-------------+
| 111222333   |
+-------------+
SELECT COLUMN_TYPE FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME = 'TEST_VIEW' AND TABLE_SCHEMA = 'TEST';
+-------------+
| COLUMN_TYPE |
+-------------+
| varchar(30) |
+-------------+

DROP VIEW IF EXISTS test_view;
DROP FUNCTION IF EXISTS test_func;
