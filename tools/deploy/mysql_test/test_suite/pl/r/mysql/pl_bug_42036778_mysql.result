CREATE PROCEDURE p() SIGNAL SQLSTATE '02000';
CALL p();
ERROR 02000: Unhandled user-defined not found condition
DROP PROCEDURE p;
CREATE PROCEDURE p() SIGNAL SQLSTATE '02000' SET MESSAGE_TEXT = '【SIGNAL】An 02xxx occurred', MYSQL_ERRNO = 2222;
CALL p();
ERROR 02000: 【SIGNAL】An 02xxx occurred
DROP PROCEDURE p;
CREATE PROCEDURE p() RESIGNAL SQLSTATE '02000';
