drop PROCEDURE if exists proc_test_parameters;//
CREATE PROCEDURE proc_test_parameters(IN empId int(24) ZEROFILL, a1 int(24) unsigned, a2 int(24), a3 int, a4 int unsigned, a5 int ZEROFILL)
BEGIN
    DECLARE baseSalary DECIMAL(10,2); 
    set @a= empId;
END; //

SELECT DATA_TYPE,ORDINAL_POSITION,DTD_IDENTIFIER,NUMERIC_PRECISION ,NUMERIC_SCALE FROM information_schema.parameters WHERE SPECIFIC_NAME ='proc_test_parameters';
+-----------+------------------+-----------------------+-------------------+---------------+
| DATA_TYPE | ORDINAL_POSITION | DTD_IDENTIFIER        | NUMERIC_PRECISION | NUMERIC_SCALE |
+-----------+------------------+-----------------------+-------------------+---------------+
| int       |                1 | int unsigned zerofill |                24 |             0 |
| int       |                2 | int unsigned          |                24 |             0 |
| int       |                3 | int(24)               |                24 |             0 |
| int       |                4 | int(11)               |                11 |             0 |
| int       |                5 | int unsigned          |                10 |             0 |
| int       |                6 | int unsigned zerofill |                10 |             0 |
+-----------+------------------+-----------------------+-------------------+---------------+

