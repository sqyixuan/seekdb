result_format: 4
drop user u9;

create user u9;
grant all on *.* to u9;

drop procedure if exists my_proc1;

set @a='';

CREATE definer = 'u9' PROCEDURE my_proc1 (OUT user_host VARCHAR(1000))
BEGIN
 SELECT current_user() INTO user_host;
END
/

call my_proc1(@a);
select @a;
+------+
| @a   |
+------+
| u9@% |
+------+

drop procedure my_proc1;

set @a='';

CREATE definer = 'u9' PROCEDURE my_proc1 (OUT user_host VARCHAR(1000)) SQL SECURITY INVOKER
BEGIN
 SELECT current_user() INTO user_host;
END
/

call my_proc1(@a);
select @a;
+---------+
| @a      |
+---------+
| admin@% |
+---------+

drop procedure my_proc1;

drop user u9;

set @a='';
