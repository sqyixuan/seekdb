drop table test_ddl;
drop table test_ddl_1;
drop table msg;
drop trigger tri_test_ddl;

create table test_ddl(c1 int);
create table msg (c1 int);

create trigger tri_test_ddl before insert on test_ddl for each row
insert into msg values (NEW.c1);
/

insert into test_ddl values (1);

select * from test_ddl;
+------+
| c1   |
+------+
|    1 |
+------+
select * from msg;
+------+
| c1   |
+------+
|    1 |
+------+

truncate table test_ddl;

insert into test_ddl values (2);
select * from test_ddl;
+------+
| c1   |
+------+
|    2 |
+------+
select * from msg;
+------+
| c1   |
+------+
|    1 |
|    2 |
+------+

rename table test_ddl to test_ddl_1;
insert into test_ddl_1 values (3);
select * from test_ddl_1;
+------+
| c1   |
+------+
|    2 |
|    3 |
+------+
select * from msg;
+------+
| c1   |
+------+
|    1 |
|    2 |
|    3 |
+------+

drop table test_ddl_1;
drop table msg;
##########################test1  end##########################
