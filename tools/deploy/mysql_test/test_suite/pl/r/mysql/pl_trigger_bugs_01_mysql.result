##########################test8  start##########################
######
drop table t;
drop table msg;
drop trigger tri_t;

create table t (c1 int, c2 int);
create table msg (c1 int, c2 int);

create trigger tri_t before insert on t for each row
BEGIN
  declare a1 int;
  declare b1 int;

  set a1 = NEW.c1;
  set b1 = new.C2;

  insert into msg values (new.c1, A1);
  insert into msg values (A1 + b1, NEW.C2);
end;
/

insert into t values (10, 10);

select * from t;
+------+------+
| c1   | c2   |
+------+------+
|   10 |   10 |
+------+------+

select * from msg;
+------+------+
| c1   | c2   |
+------+------+
|   10 |   10 |
|   20 |   10 |
+------+------+

drop table t;
drop table msg;
##########################test8  end##########################
