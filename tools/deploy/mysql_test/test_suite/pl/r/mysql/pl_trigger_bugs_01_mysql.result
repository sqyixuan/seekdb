set recyclebin=on;

drop table test_drop_table;
drop trigger if exists tri_test_drop_table;
Warnings:
Note	1360	Trigger does not exist

create table test_drop_table (c1 int);

create trigger tri_test_drop_table before insert on test_drop_table for each row
set @aaa = 1;

drop trigger if exists tri_test_drop_table;

select count(*) from INFORMATION_SCHEMA.TRIGGERS
  where trigger_name = 'tri_test_drop_table' and trigger_schema = 'test';
+----------+
| count(*) |
+----------+
|        0 |
+----------+

create trigger tri_test_drop_table before insert on test_drop_table for each row
set @aaa = 1;

select count(*) from INFORMATION_SCHEMA.TRIGGERS
  where trigger_name = 'tri_test_drop_table' and trigger_schema = 'test';
+----------+
| count(*) |
+----------+
|        1 |
+----------+

drop table test_drop_table;

select count(*) from INFORMATION_SCHEMA.TRIGGERS where trigger_schema = '__recyclebin';
+----------+
| count(*) |
+----------+
|        0 |
+----------+

