drop table test_set_t1;
drop table test_set_t2;
drop trigger tri_test_set_t1;

CREATE TABLE test_set_t1(c0 INT, c1 VARCHAR(10), 
                         c2 SET('a','b','c','d','e','f','g'));

CREATE TABLE test_set_t2(c0 INT, c1 VARCHAR(10), 
                         c2 SET('a','b','c','d','e','f','g'));

CREATE TRIGGER tri_test_set_t1 AFTER INSERT ON test_set_t1 FOR EACH ROW
  INSERT INTO test_set_t2 VALUES(new.c0, new.c1, new.c2);

INSERT INTO test_set_t1 VALUES(7,'GG','d');

INSERT INTO test_set_t1 (c0, c1) VALUES(8,'DD');

select * from test_set_t2;
+------+------+------+
| c0   | c1   | c2   |
+------+------+------+
|    7 | GG   | d    |
|    8 | DD   | NULL |
+------+------+------+

drop table test_set_t1;
drop table test_set_t2;
##########################test11  end##########################
