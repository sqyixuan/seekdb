drop table t;
drop table msg;
drop trigger tri_t;

create table t (c1 int);
create table msg (c1 int);

create trigger tri_t before delete on t for each row
BEGIN
  set @aa = NEW.c1;
end;
/
ERROR HY000: There is no NEW row in on DELETE trigger

create trigger tri_t before delete on t for each row
BEGIN
  insert into msg values (NEW.c1);
end;
/
ERROR HY000: There is no NEW row in on DELETE trigger

create trigger tri_t before insert on t for each row
BEGIN
  set @aa = OLD.c1;
end;
/
ERROR HY000: There is no OLD row in on INSERT trigger

create trigger tri_t before insert on t for each row
BEGIN
  insert into msg values (OLD.c1);
end;
/
ERROR HY000: There is no OLD row in on INSERT trigger

drop table t;
drop table msg;
