result_format: 4
set global ob_query_timeout = 100000000;
set global ob_query_timeout = 100000000;

-- 1.1 check DBMS_STATS params on mysql tenant
call dbms_stats.reset_param_defaults();
select dbms_stats.get_param('ESTIMATE_PERCENT');
+------------------------------------------+
| dbms_stats.get_param('ESTIMATE_PERCENT') |
+------------------------------------------+
| DBMS_STATS.AUTO_SAMPLE_SIZE              |
+------------------------------------------+

-- 1.2 modify DBMS_STATS params on mysql tenant using sys dispatch call
call dbms_stats.set_param('ESTIMATE_PERCENT', '10') tenant = 'sys';

-- 1.3 check DBMS_STATS params on mysql tenant
select dbms_stats.get_param('ESTIMATE_PERCENT');
+------------------------------------------+
| dbms_stats.get_param('ESTIMATE_PERCENT') |
+------------------------------------------+
| 10                                       |
+------------------------------------------+

-- 1.4 modify DBMS_STATS prefs on mysql tenant using sys dispatch call
call dbms_stats.reset_param_defaults() tenant = 'sys';

-- 1.5 check DBMS_STATS params on mysql tenant
select dbms_stats.get_param('ESTIMATE_PERCENT');
+------------------------------------------+
| dbms_stats.get_param('ESTIMATE_PERCENT') |
+------------------------------------------+
| DBMS_STATS.AUTO_SAMPLE_SIZE              |
+------------------------------------------+

