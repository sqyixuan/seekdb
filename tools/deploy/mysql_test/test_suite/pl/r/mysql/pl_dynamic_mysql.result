create table a(a1 varchar(100), a2 int);
insert into a values('a', 1);
insert into a values('b', 2);
create table b(b1 varchar(100), b2 int);
create procedure p(arg int)
begin
set @stmt_str = 'select a1,a2 from a where a2 = ? into @y,@x';
prepare stmt1 from @stmt_str;
set @arg=arg;
execute stmt1 using @arg;
deallocate prepare stmt1;
insert into b values(@y, @x);
end//
select * from a;
+------+------+
| a1   | a2   |
+------+------+
| a    |    1 |
| b    |    2 |
+------+------+
call p(1);
select * from b;
+------+------+
| b1   | b2   |
+------+------+
| a    |    1 |
+------+------+
call p(2);
select * from b;
+------+------+
| b1   | b2   |
+------+------+
| a    |    1 |
| b    |    2 |
+------+------+
drop table a;
drop table b;
drop procedure p;

create table a(a1 varchar(100), a2 int);
insert into a values('a', 1);
insert into a values('b', 2);
create table b(b1 varchar(100), b2 int);
create procedure p(arg varchar(100))
begin
set @stmt_str = 'select * from a where a1 like ? into @x,@y';
prepare stmt1 from @stmt_str;
set @arg_str=arg;
execute stmt1 using @arg_str;
deallocate prepare stmt1;
insert into b values(@x, @y);
end//
select * from a;
+------+------+
| a1   | a2   |
+------+------+
| a    |    1 |
| b    |    2 |
+------+------+
call p('a');
select * from b;
+------+------+
| b1   | b2   |
+------+------+
| a    |    1 |
+------+------+
call p('b');
select * from b;
+------+------+
| b1   | b2   |
+------+------+
| a    |    1 |
| b    |    2 |
+------+------+
drop table a;
drop table b;
drop procedure p;

