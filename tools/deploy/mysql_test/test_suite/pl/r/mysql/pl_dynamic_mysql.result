use test;

## bug 16739130 execute not call get_next
drop function if exists my_func_1;
drop function if exists my_func_2;
create function my_func_1() returns int return 10;
create function my_func_2() returns int return my_func_1();
prepare stmt from "select my_func_2()";
execute stmt;
+-------------+
| my_func_2() |
+-------------+
|          10 |
+-------------+
execute stmt;
+-------------+
| my_func_2() |
+-------------+
|          10 |
+-------------+
drop function my_func_1;
execute stmt;
ERROR 42000: FUNCTION does not exist
deallocate prepare stmt;
drop function my_func_2;

drop table if exists my_tab;
drop procedure if exists my_proc;
create table my_tab(col int);
insert into my_tab values(10);
create procedure my_proc()
begin
  set @v = 0;
  prepare stmt from 'select * from my_tab into @v';
  execute stmt;
  insert into my_tab values(@v);
  deallocate prepare stmt;
end |
call my_proc();
select * from my_tab;
+------+
| col  |
+------+
|   10 |
|   10 |
+------+

drop table my_tab;
drop procedure my_proc;

drop table if exists my_tab;
drop procedure if exists my_proc;
create table my_tab(col int);
create procedure my_proc()
begin
  prepare stmt from 'select * from my_tab;';
  execute stmt;
  deallocate prepare stmt;
end |
call my_proc();
+------+
| col  |
+------+
+------+
drop table my_tab;
call my_proc();
ERROR 42S02: Table 'test.my_tab' doesn't exist
drop procedure my_proc;

drop procedure IF EXISTS my_proc;
create PROCEDURE my_proc()
begin
  PREPARE stmt FROM 'drop table if exists test';
  EXECUTE stmt;
end; |

call my_proc();
call my_proc();
call my_proc();
call my_proc();
call my_proc();
drop procedure my_proc;

drop table if exists a,b,t,t1;
drop procedure if exists p;
drop procedure if exists f;
drop procedure if exists pp;

create table a(a1 varchar(100));
create procedure p()
begin
prepare stmt1 from "insert into a values('1')";
execute stmt1;
deallocate prepare stmt1;
end//
call p();
select * from a;
+------+
| a1   |
+------+
| 1    |
+------+
drop table a;
drop procedure p;

create table a(a1 varchar(100));
create procedure p()
begin
set @stmt_str = 'insert into a values(\'1\')';
prepare stmt1 from @stmt_str;
execute stmt1;
deallocate prepare stmt1;
end//
call p();
select * from a;
+------+
| a1   |
+------+
| 1    |
+------+
drop table a;
drop procedure p;

create table a(a1 varchar(100));
create procedure p(x varchar(100))
begin
set @stmt_str = 'insert into a values(?)';
prepare stmt1 from @stmt_str;
set @x = x;
execute stmt1 using @x;
deallocate prepare stmt1;
end//
call p('a');
select * from a;
+------+
| a1   |
+------+
| a    |
+------+
drop table a;
drop procedure p;

create table a(a1 varchar(100), a2 int);
create procedure p(x varchar(100), y int)
begin
set @stmt_str = 'insert into a values(?,?)';
prepare stmt1 from @stmt_str;
set @x = x, @y = y;
execute stmt1 using @x,@y;
deallocate prepare stmt1;
end//
call p('a', 1);
select * from a;
+------+------+
| a1   | a2   |
+------+------+
| a    |    1 |
+------+------+
drop table a;
drop procedure p;

create table a(a1 varchar(100), a2 int);
create procedure p(x varchar(100), y int)
