result_format: 4
drop procedure if exists proc;

drop function if exists func;

create procedure proc(in a enum('1', '2'), s varchar(20))
begin
end;
/

create function func(a enum('1', '2')) returns enum('1', '2')
DETERMINISTIC
begin
return a;
end;
/

select param_list, returns from mysql.proc where name in ('func', 'proc') order by name;
+------------------------------------+---------------+
| param_list                         | returns       |
+------------------------------------+---------------+
| a enum('1', '2')                   | enum('1','2') |
| in a enum('1', '2'), s varchar(20) |               |
+------------------------------------+---------------+

select routine_name, DTD_IDENTIFIER from information_schema.routines where routine_name in  ('func', 'proc') order by routine_name;
+--------------+----------------+
| routine_name | DTD_IDENTIFIER |
+--------------+----------------+
| func         | enum('1','2')  |
| proc         | NULL           |
+--------------+----------------+

select specific_name, parameter_name, ORDINAL_POSITION, parameter_mode, DTD_IDENTIFIER from information_schema.parameters where specific_name in  ('func', 'proc') order by specific_name,ORDINAL_POSITION;
+---------------+----------------+------------------+----------------+----------------+
| specific_name | parameter_name | ORDINAL_POSITION | parameter_mode | DTD_IDENTIFIER |
+---------------+----------------+------------------+----------------+----------------+
| func          | NULL           |                0 | NULL           | enum('1','2')  |
| func          | a              |                1 | IN             | enum('1','2')  |
| proc          | a              |                1 | IN             | enum('1','2')  |
| proc          | s              |                2 | IN             | varchar(20)    |
+---------------+----------------+------------------+----------------+----------------+

drop procedure proc;
drop function func;

create procedure proc(in a set('1', '2'), s varchar(20))
begin
end;
/

create function func(a set('1', '2')) returns set('1', '2')
DETERMINISTIC
begin
return a;
end;
/

select param_list, returns from mysql.proc where name in ('func', 'proc') order by name;
+-----------------------------------+--------------+
| param_list                        | returns      |
+-----------------------------------+--------------+
| a set('1', '2')                   | set('1','2') |
| in a set('1', '2'), s varchar(20) |              |
+-----------------------------------+--------------+

select routine_name, DTD_IDENTIFIER from information_schema.routines where routine_name in  ('func', 'proc') order by routine_name;
+--------------+----------------+
| routine_name | DTD_IDENTIFIER |
+--------------+----------------+
| func         | set('1','2')   |
| proc         | NULL           |
+--------------+----------------+

select specific_name, parameter_name, ORDINAL_POSITION, parameter_mode, DTD_IDENTIFIER from information_schema.parameters where specific_name in  ('func', 'proc') order by specific_name,ORDINAL_POSITION;
+---------------+----------------+------------------+----------------+----------------+
| specific_name | parameter_name | ORDINAL_POSITION | parameter_mode | DTD_IDENTIFIER |
+---------------+----------------+------------------+----------------+----------------+
| func          | NULL           |                0 | NULL           | set('1','2')   |
| func          | a              |                1 | IN             | set('1','2')   |
| proc          | a              |                1 | IN             | set('1','2')   |
| proc          | s              |                2 | IN             | varchar(20)    |
+---------------+----------------+------------------+----------------+----------------+

drop procedure proc;
drop function func;
