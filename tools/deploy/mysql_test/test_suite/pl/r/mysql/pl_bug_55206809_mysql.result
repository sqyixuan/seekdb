result_format: 4
drop function if exists func1;


create function func1(p9 json) returns text
begin
  declare res text default null;
  select export_set(6,p9,p9) into res from dual;
  select insert(p9,1,1,p9) into res from dual;
  select substring_index(p9,p9,1) into res from dual;
  return res;
end;
/


select func1(null) as param_null from dual;
+------------+
| param_null |
+------------+
| NULL       |
+------------+
select func1(json_object('1','1')) as param_null from dual;
+------------+
| param_null |
+------------+
|            |
+------------+

drop table if exists test1;
create table test1(c0 longtext);

drop function func1;


create function func1(p9 json) returns json
begin
  insert into test1 values(concat(p9,p9));
  insert into test1 values(lpad(p9,11,p9));
  return p9;
end;
/


select func1(null) as param_null from dual;
+------------+
| param_null |
+------------+
| NULL       |
+------------+
select func1('{"id": "1", "name": "Fred"}') as param_null from dual;
+-----------------------------+
| param_null                  |
+-----------------------------+
| {"id": "1", "name": "Fred"} |
+-----------------------------+
select * from test1;
+--------------------------------------------------------+
| c0                                                     |
+--------------------------------------------------------+
| NULL                                                   |
| NULL                                                   |
| {"id": "1", "name": "Fred"}{"id": "1", "name": "Fred"} |
| {"id": "1",                                            |
+--------------------------------------------------------+

drop function func1;


create function func1(p9 json) returns text
begin
  declare res text default null;
  select regexp_substr(p9,'a(.*)(b)',1,1) into res from dual;
  select regexp_replace(p9,1,1) into res from dual;
  return res;
end;
/


select func1(null) as param_null from dual;
+------------+
| param_null |
+------------+
| NULL       |
+------------+
select func1(json_object('1','1')) as param_null from dual;
+------------+
| param_null |
+------------+
| {"1": "1"} |
+------------+

drop function func1;
drop table test1;
