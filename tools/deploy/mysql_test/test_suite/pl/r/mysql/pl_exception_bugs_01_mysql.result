result_format: 4
############################start case 1############################
#####
DROP PROCEDURE p_exception;

CREATE PROCEDURE p_exception (divisor INT,msg VARCHAR(100)) 
BEGIN 
  DECLARE errorno INT;
  SET errorno = 5;
  IF divisor = 0 THEN 
      SIGNAL SQLSTATE '45000'
      SET MESSAGE_TEXT = msg,
      MYSQL_ERRNO = errorno;
  END IF;
END;
/

CALL p_exception(0,'message_text An error occurred');
ERROR 45000: message_text An error occurred

DROP PROCEDURE p_exception;

############################end case 1#############################
############################start case 2############################
#####
CREATE PROCEDURE p_exception() 
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN 
      SIGNAL SQLSTATE VALUE '99999'  SET MYSQL_ERRNO = 1101;
    END;
  DROP TABLE no_such_table;
END;
/

call p_exception;
ERROR 99999: Unhandled user-defined exception condition

drop PROCEDURE p_exception;

CREATE PROCEDURE p_exception()
BEGIN 
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
      SIGNAL SQLSTATE VALUE '99999' SET MYSQL_ERRNO = NULL;
    END;
  DROP TABLE no_such_table;
END;
/

call p_exception;
ERROR 42000: Variable 'MYSQL_ERRNO' can't be set to the value of 'NULL'

drop PROCEDURE p_exception;
############################end case 2#############################
############################start case 3############################
#####
CREATE PROCEDURE p_exception()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
      SIGNAL SQLSTATE VALUE '99999' SET MESSAGE_TEXT = 'An error occurred';
    END;
DROP TABLE no_such_table;
END;
/

call p_exception;
ERROR 99999: An error occurred

drop PROCEDURE p_exception;
############################end case 3#############################
############################start case 4############################
######
CREATE PROCEDURE p_exception(divisor INT) 
BEGIN
  DECLARE no_such_table CONDITION FOR 1051; 
  IF divisor = 0 THEN 
    SIGNAL no_such_table;
  END IF;
END;
/
ERROR HY000: SIGNAL/RESIGNAL can only use a CONDITION defined with SQLSTATE
############################end case 4#############################
############################start case 5############################
#####
CREATE PROCEDURE p_exception()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SIGNAL SQLSTATE '45000' SET MYSQL_ERRNO = 1002, MYSQL_ERRNO = 1001;
  END;
  DROP TABLE t1;
END;
/
ERROR 42000: Duplicate condition information item 'MYSQL_ERRNO'
############################end case 5#############################
############################start case 6#############################
create procedure p_exception()
begin
  declare continue handler for 10000
    begin
      select 1;
    end;
  signal SQLSTATE '99999' set MESSAGE_TEXT='xxx', MYSQL_ERRNO = 10000;
end;
/


call p_exception();
+---+
| 1 |
+---+
| 1 |
+---+

drop procedure p_exception;
############################end case 6#############################
############################start case 7#############################
create procedure p_exception()
begin
  signal SQLSTATE '02000' set MESSAGE_TEXT='xxx', MYSQL_ERRNO = 10000;
end;
/

call p_exception();
/
ERROR 02000: xxx

drop procedure p_exception;
/

create procedure p_exception()
begin
  signal SQLSTATE '02000';
end;
/

call p_exception();
ERROR 02000: Unhandled user-defined not found condition

drop procedure p_exception;
############################end case 7#############################
