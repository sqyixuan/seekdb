result_format: 4
#### 测试锁冲突场景下的行为

drop table t1;
create table t1(col int);
insert into t1 values(1);
set autocommit=off;
#### 加大语句超时
set ob_query_timeout=1000000000;
#### 加大事务超时
set ob_trx_timeout=10000000000;
#### 加锁
update t1 set col = col + 1;

drop procedure if exists proc;
/
create procedure proc()
begin
  insert into t1 values(1);
  update t1 set col = col + 1;
end;
/
call proc();
/
ERROR HY000: Lock wait timeout exceeded; try restarting transaction
drop procedure proc;
/

rollback;
#### 再次加锁
update t1 set col = col + 1;

#### 调整pl_block_timeout超时
set ob_pl_block_timeout=5000000;
/
create procedure proc()
begin
  update t1 set col = col + 1; -- 锁冲突, 本地重试一次后, 扔回队列重试到pl_block_timeout
end;
/
call proc();
/
Got one of the listed errors
drop procedure proc;
/


rollback;
drop table t1;

