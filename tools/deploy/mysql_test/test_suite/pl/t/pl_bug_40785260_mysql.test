#owner group: sql1-PL/SQL
#tags: pl
#description: 

--result_format 4

--disable_warnings
drop procedure if exists `add_index_wtj`;
--enable_warnings

delimiter /;
CREATE  PROCEDURE `add_index_wtj`(
IN database_name varchar(50),IN table_name varchar(50),IN column_name varchar(50),IN index_name varchar(50))
  SQL SECURITY INVOKER
  BEGIN
    DECLARE cur_database VARCHAR(50) DEFAULT NULL;
    DECLARE count_number INT DEFAULT 0;
    IF database_name IS NULL OR database_name = '' THEN
            SET cur_database = DATABASE();
    ELSE
                SET cur_database = database_name;
        END IF;
        SET @str = CONCAT(' ALTER TABLE ', cur_database, '.', table_name, ' ADD INDEX ', index_name, '(', column_name, ')');
    SET count_number = (SELECT COUNT(*) FROM information_schema.STATISTICS
                            WHERE TABLE_NAME= table_name AND INDEX_NAME=index_name AND INDEX_SCHEMA=cur_database);
    IF count_number = 0 THEN
            PREPARE stmt FROM @str;
            EXECUTE stmt;
    END IF;
 END
/
delimiter ;/

drop procedure `add_index_wtj`;