#owner: heyongyi.hyy
#owner group: pl/sql
#tags: pl
#description: test pl memory leak
 
--result_format 4
 
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
 
--disable_warnings
drop tenant if exists bug_54806294_tenant force;
drop resource pool if exists bug_54806294_pool;
--enable_warnings
 
#create resource pool bug_54806294_pool unit='1c2g',unit_num=1;
#create tenant bug_54806294_tenant resource_pool_list=('bug_54806294_pool') set ob_tcp_invited_nodes='%',ob_compatibility_mode='mysql';
--source mysql_test/include/check_tenant_sync.inc
 
disconnect obsys;
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
connect (conn, $TE_SERVER_IP, root,,*NO-ONE*, $TE_SERVER_PORT);

connection conn;

DO (select 1);

--error 2222
SIGNAL SQLSTATE '02000' SET MESSAGE_TEXT = '【SIGNAL】An 02xxx occurred', MYSQL_ERRNO = 2222;

--error 1645
RESIGNAL SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 1111;

disconnect conn;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

let $debug_tenant_id=query_get_value(SELECT tenant_id as ID FROM oceanbase.__all_tenant where tenant_name='sys', ID, 1);

alter system flush pl cache global;

drop tenant if exists bug_54806294_tenant force;
drop resource pool if exists bug_54806294_pool;

alter system flush pl cache global;

select /*+query_timeout(100000000)*/sleep(60);

--replace_regex /[0-9]+/TENANT_ID/g
eval select * from oceanbase.__all_virtual_memory_info where tenant_id=$debug_tenant_id and mod_name in ('PlJit', 'PlCodeGen');

disconnect obsys;
 
connection default;
