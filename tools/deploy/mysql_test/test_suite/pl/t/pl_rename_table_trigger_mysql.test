--error 0,1051
drop table package;

create table value(c1 int);

create trigger tri_t1 before insert on value for each row set @a = 1;

alter table value rename to package;

select trigger_name, event_object_schema, action_statement from
  information_schema.triggers where trigger_name = 'TRI_T1';

insert into package values (1);

select @a;

alter table package rename to value;

select trigger_name, event_object_schema, action_statement from
  information_schema.triggers where trigger_name = 'TRI_T1';

insert into value values (1);

drop trigger tri_t1;

create trigger tri_t1 before insert on test.`value` for each row set @a = 2;

alter table value rename to package;

select trigger_name, event_object_schema, action_statement from
  information_schema.triggers where trigger_name = 'TRI_T1';

insert into package values (1);

select @a;

alter table package rename to value;

select trigger_name, event_object_schema, action_statement from
  information_schema.triggers where trigger_name = 'TRI_T1';

insert into value values (1);

drop table value;


