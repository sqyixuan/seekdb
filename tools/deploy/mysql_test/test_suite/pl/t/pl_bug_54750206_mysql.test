#owner: hr351303
#owner group: pl/sql
#tags: pl
#description: test pl bug

--result_format 4

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop function if exists f1;
drop function if exists f2;

create table t1(c1 int);
create table t2(c1 int);
set autocommit=0;

insert into t1 value(1);

commit;

delimiter /;

create function f1() returns int
begin
  return 1;
end/

create function f2() returns int
begin
  insert into t2 value(1);
  return 1;
end/

delimiter ;/

select * from t1 where c1 = f1();
select ob_transaction_id() = 0;

select * from t1 where c1 = f2();
select ob_transaction_id() <> 0;

rollback;

select * from t2;

drop table t1;
drop table t2;

drop function f1;
drop function f2;