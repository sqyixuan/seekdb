--echo #############测试存储过程内部只有sql语句, table ddl变更不影响存储过程缓存##############

create table t2(c1 int);
insert into t2 value(1);


delimiter /;

create procedure p2()
begin
  declare a int;
  declare b int;
  set b = 1;
  select count(*) into a from t2 where c1 = b;
  select a;
end;
/

delimiter ;/

connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;

connection conn2;

call p2();

drop table t2;
create table t2(c1 int, c2 int);
insert into t2 value(1,2);

--echo #hit pl cache, t2定义变更预期不影响p2的缓存
call p2();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P2' order by gmt_create desc limit 1);

drop table t2;

--error 1146
call p2();

drop procedure p2;


connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;

connection conn2;

create table t2(c1 int);
insert into t2 value(1);


delimiter /;

create procedure p2()
begin
  select count(*) from t2;
end;
/

delimiter ;/

connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;

connection conn2;

call p2();

drop table t2;
create table t2(c1 int, c2 int);
insert into t2 value(1,2);

--echo #hit pl cache, t2定义变更预期不影响p2的缓存
call p2();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P2' order by gmt_create desc limit 1);
drop procedure p2;

delimiter /;

create procedure p2()
begin
  declare a int;
  declare cs cursor for select count(*) from t2;
  open cs;
  fetch cs into a;
  close cs;
  select a;
end;
/

delimiter ;/

connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;

connection conn2;

call p2();

drop table t2;
create table t2(c1 int, c2 int);
insert into t2 value(1,2);

--echo #hit pl cache, t2定义变更预期不影响p2的缓存
call p2();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P2' order by gmt_create desc limit 1);
drop table t2;

--error 1146
call p2();

drop procedure p2;

connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;

connection default;

--disable_warnings
drop table if exists t1;
drop procedure if exists p1;

--echo #############测试存储过程内部相关表做truncate变更不影响存储过程缓存##############

create table t1(c1 int, c2 int);

insert into t1 value(1,2);


delimiter /;

create procedure p1()
begin
  declare var int;
  declare cs cursor for select c1 from t1;
  open cs;
  fetch cs into var;
  close cs;
  select var;
end;
/

delimiter ;/

connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;

connection default;

call p1();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);
call p1();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);

--echo ####预期缓存命中####
truncate table t1;
insert into t1 value(1,2);
call p1();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);
call p1();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);

drop table t1;
create table t1(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) (partition p0 values less than(10));
insert into t1 value(1,2);

call p1();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);
call p1();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);

--echo ####预期缓存命中####
alter table t1 add partition (partition p1 values less than(20));
call p1();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);
call p1();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);

--echo ####预期缓存失效####
alter table t1 add (c3 enum('d','f'));
call p1();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);
call p1();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);

--echo ####预期缓存失效####
alter table t1 modify column c2 double;
call p1();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);
call p1();
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);

drop table t1;

--error 1146
call p1();

drop procedure p1;

DROP DATABASE henry;
