--result_format 4


delimiter //;

--disable_warnings ONCE
DROP PROCEDURE IF EXISTS p1;//
CREATE PROCEDURE p1 ()
BEGIN
  declare var4 set('one', 'two', 'three', 'four', 'five') DEFAULT 'five';
  if var4 = 'five' then
    SELECT 'if分支：var4 = five';
  ELSE
    SELECT 'else分支：var4 != five';
  END if; 
END//

delimiter ;//
CALL p1();

delimiter //;

--disable_warnings ONCE
DROP PROCEDURE IF EXISTS p2;//

CREATE PROCEDURE p2 ()
BEGIN
  declare var4 set('one', 'two', 'three', 'four', 'five') DEFAULT 'five';
  case
    when var4 = 'five' then
      SELECT 'when分支：var4 = five';
    ELSE 
      SELECT 'ELSE分支：var4 != five';
  END case;
END//
delimiter ;//

CALL p2();

DROP PROCEDURE p1;
DROP PROCEDURE p2;
