#owner: linlin.xll
#owner group: pl/sql
#tags: pl
#description: test pl bug

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

let $old_value = query_get_value(show parameters like 'leak_mod_to_check', value, 1);
alter system set leak_mod_to_check='';
alter system set leak_mod_to_check='PlStmtHashMap';

connection default;

--disable_warnings ONCE
DROP PROCEDURE if exists p1;
--disable_warnings ONCE
DROP PROCEDURE if exists p2;

delimiter /;

CREATE PROCEDURE p1 (pval INT)
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLSTATE '23000'
  BEGIN
    SIGNAL SQLSTATE '01000' SET MESSAGE_TEXT = 'A warning occurred', MYSQL_ERRNO = 1000;
  END;
END
/

--error 1413
CREATE PROCEDURE p2 (pval INT)
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLSTATE '23000'
  BEGIN
    SIGNAL SQLSTATE '01000' SET MESSAGE_TEXT = 'A warning occurred', MYSQL_ERRNO = 1000;
  END;
  DECLARE CONTINUE HANDLER FOR SQLSTATE '23000'
  BEGIN
    SIGNAL SQLSTATE '01000' SET MESSAGE_TEXT = 'A warning occurred', MYSQL_ERRNO = 1000;
  END;
END
/

delimiter ;/
call p1(1);
drop procedure p1;

connection obsys;
select * from oceanbase.__all_virtual_mem_leak_checker_info order by alloc_count;

#eval alter system set leak_mod_to_check='$old_value';

