#owner: heyongyi.hyy
#owner group: pl/sql
#tags: pl
#description: test pl mysql.proc RETURNS column

--result_format 4

--error 0,1305
drop procedure proc;
--error 0,1305
drop function func;

delimiter /;
create procedure proc(x int)
begin
select x;
end;
/

create function func(x int)
returns varchar(64)
begin
return 'hello world!';
end;
/
delimiter ;/

call proc(42);

select func(42);

select db, name, returns, param_list from mysql.proc where db = 'test' AND name in ('proc', 'func') order by name;

drop procedure proc;
drop function func;
