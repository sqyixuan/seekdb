--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#tags: pl
#owner: haohao.hao
#owner group: sql4
#description: pl

--result_format 4

--disable_warnings
--error 0,1305
drop procedure pro1;
--error 0,1305
drop procedure pro2;
--error 0,1305
drop procedure pro3;
--error 0,1305
drop procedure pro4;
--enable_warnings


## case : 
## dd is not keywords now
## mysql keywords https://dev.mysql.com/doc/mysqld-version-reference/en/keywords-8-0.html#keywords-8-0-detailed-D
## mysql do expr 


DELIMITER |;

create procedure pro1()
begin
  select 1;
end;|

--error 1064
create procedure pro2()
begin
  do
  begin
    select 1;
  end;
end;|

--error 1064
create procedure pro3()
begin
  dd
  begin
    select 1;
  end;
end;|

create procedure pro4(dd int)
begin
  select 1;
end;|

DELIMITER ;|

drop procedure pro1;
drop procedure pro4;
