#owner: heyongyi.hyy
#owner group: pl/sql
#tags: pl
#description: test sql_mode=ANSI_QUOTES + information_schema.routines/information_schema.parameters

--result_format 4

--disable_warnings ONCE
drop procedure if exists spTest;

SET sql_mode=ANSI_QUOTES;

delimiter /;
CREATE PROCEDURE spTest(`@Param1` text)
BEGIN
  SELECT `@Param1`;
END;
/

delimiter ;/

--replace_column 24 ###### 25 ###### 
SELECT * FROM INFORMATION_SCHEMA.ROUTINES WHERE ROUTINE_SCHEMA = 'test' AND ROUTINE_NAME = 'spTest';

SELECT * FROM INFORMATION_SCHEMA.PARAMETERS WHERE SPECIFIC_SCHEMA = 'test' AND SPECIFIC_NAME ='spTest';

drop procedure spTest;

SET sql_mode=default;
