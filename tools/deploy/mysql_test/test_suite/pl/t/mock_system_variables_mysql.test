#owner: wangbai.wx
#owner group: pl/sql
#tags: pl
#description:

--result_format 4

#1. test debug var
SELECT @@debug;
SELECT @@global.debug;
SELECT @@session.debug;
set debug = "T";
set session debug = "T";
set global debug = "P";
SELECT @@debug;
SELECT @@global.debug;
SELECT @@session.debug;
# test +- grammar
SET debug = '+P';
SET debug = '-P';
SELECT @@debug;
SELECT @@global.debug;
SELECT @@session.debug;

#2. test innodb_change_buffering_debug var
SELECT @@innodb_change_buffering_debug;
SELECT @@global.innodb_change_buffering_debug;
--error 1238
SELECT @@session.innodb_change_buffering_debug;
--error 1229
set innodb_change_buffering_debug = 1;
--error 1229
set session innodb_change_buffering_debug = 1;
set global innodb_change_buffering_debug  = 2;
--error 1231
set global innodb_change_buffering_debug = -1;
--error 1231
set global innodb_change_buffering_debug = 3;
SELECT @@innodb_change_buffering_debug;
SELECT @@global.innodb_change_buffering_debug;

#3. test innodb_compress_debug var
SELECT @@innodb_compress_debug;
SELECT @@global.innodb_compress_debug;
--error 1238
SELECT @@session.innodb_compress_debug;
--error 1229
set innodb_compress_debug = "zlib";
--error 1229
set session innodb_compress_debug = "zlib";
set global innodb_compress_debug  = "zlib";
--error 1231
set global innodb_compress_debug = "a";
SELECT @@innodb_compress_debug;
SELECT @@global.innodb_compress_debug;

#4. test innodb_disable_resize_buffer_pool_debug var
SELECT @@innodb_disable_resize_buffer_pool_debug;
SELECT @@global.innodb_disable_resize_buffer_pool_debug;
--error 1238
SELECT @@session.innodb_disable_resize_buffer_pool_debug;
--error 1229
set innodb_disable_resize_buffer_pool_debug = OFF;
--error 1229
set session innodb_disable_resize_buffer_pool_debug = OFF;
set global innodb_disable_resize_buffer_pool_debug  = OFF;
set global innodb_disable_resize_buffer_pool_debug  = 1;
set global innodb_disable_resize_buffer_pool_debug  = 0;
set global innodb_disable_resize_buffer_pool_debug  = true;
set global innodb_disable_resize_buffer_pool_debug  = false;
--error 1231
set global innodb_disable_resize_buffer_pool_debug = "a";
SELECT @@innodb_disable_resize_buffer_pool_debug;
SELECT @@global.innodb_disable_resize_buffer_pool_debug;

