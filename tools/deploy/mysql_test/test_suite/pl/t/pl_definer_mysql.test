#owner:hr351303
#owner group:sql4
#description:definer/invoker
#tags: pl

--disable_warnings
--error 0,1396
drop user usr1@'%';

--error 0,1396
drop user usr2@'%';

--error 0,1396
drop user usr3@'%';

--error 0,1008
drop database ceshi;

create database ceshi;
use ceshi;
--enable_warnings
create user usr1 identified by '123';
grant all on ceshi.* to usr1;

create user usr2 identified by '123';
grant update on ceshi.* to usr2;

#assign super privilege to usr3
create user usr3 identified by '123';
grant all privileges on *.* to usr3;

connect (conn1,$OBMYSQL_MS0,usr1,123,ceshi,$OBMYSQL_PORT);
connection conn1;

use ceshi;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop procedure if exists p1;
drop trigger if exists tg1;
--enable_warnings

create table t1(id int);
insert into t1 values(1);

delimiter /;

select current_user(), database();
/

#
# 测试项：不指定host时，需要super权限
#
create definer = 'usr1' procedure p1()
begin
  select * from t1;
end;
/

drop procedure p1;
/

#
# 测试项：指定host为%时，需要super权限
#
create definer = 'usr1'@'%' procedure p1()
begin
  select * from t1;
end;
/

drop procedure p1;
/

#
# 测试项：指定不存在的用户切当前用户没有super权限时，编译期报权限不够的error
#
--error 1227
create definer = 'usr3'@'localhost' procedure p1()
begin
  select * from t1;
end;
/

create table t2(id int)/


#
# 测试项：trigger只要指定user%host，就需要super权限
#
--error 1227
create definer=usr1@localhost trigger tg1 before insert on t1
for each row
begin
  insert into t2 values(1);
end;
/

delimiter ;/

drop table t1;
drop table t2;

connect (conn3,$OBMYSQL_MS0,usr3,123,ceshi,$OBMYSQL_PORT);
connection conn3;

use ceshi;

--disable_warnings
drop table if exists t3;
drop table if exists t4;
drop procedure if exists p1;
drop procedure if exists p2;
drop procedure if exists p3;
drop procedure if exists p4;
drop procedure if exists p5;
drop procedure if exists p6;
drop procedure if exists p7;
drop procedure if exists p8;
drop function if exists f1;
drop function if exists f2;
drop function if exists f3;
drop trigger if exists tg1;
drop trigger if exists tg2;
--enable_warnings

create table t1(id int);

insert into t1 values(2);

create table t2(id int);
create table t3(id int);
create table t4(id int);

delimiter /;

#
# 测试项：指定不存在的用户且当前用户有super权限时，编译期报用户不存在的warning，执行期报错
#
--disable_warnings
create definer = 'not_exist' procedure p1()
begin
  select * from t1;
end;
/
--enable_warnings

--error 1449
call p1()/

drop procedure p1/

#
# 测试项：'current_user'整体作为user name，区别于current_user
#
--disable_warnings
create definer = 'current_user' procedure p1()
begin
  select * from t1;
end;
/
--enable_warnings

--error 1449
call p1()/

drop procedure p1/

#
# 测试项：current_user
#
create definer = current_user procedure p2()
begin
  select * from t1;
end;
/

create definer = 'usr3' procedure p1()
begin
  select * from t1;
end;
/

#
# 测试项：指定invoker
#
create definer = 'usr3' procedure p3() sql security invoker
begin
  select * from t1;
end;
/

#
#测试项：function指定definer,使用字符串
#
create definer = 'usr3' function f1() returns int
begin
  declare a int;
  select id into a from t1 limit 1;
  return a;
end;
/

#
#测试项：function指定define, 使用identify
#
create definer = usr3 function f2() returns int
begin
  declare a int;
  select id into a from t1 limit 1;
  return a;
end;
/

#
#测试项：function指定definer和invoker
#
create definer = 'usr3' function f3() returns int
sql security invoker
begin
  declare a int;
  select id into a from t1 limit 1;
  return a;
end;
/

#
#测试项：嵌套调用场景
#
create definer = usr1 procedure p4()
begin
  call p2();
end;
/

create definer = usr1 procedure p5()
begin
  call p3();
end;
/

create definer = usr1 procedure p6() sql security invoker
begin
  call p4();
end;
/

#以usr1权限执行, usr1有执行权限和t1 select权限, 能执行成功
call p4()/

#以usr1权限执行, usr1有执行权限和t1 select权限, 能执行成功
call p5()/

#以调用者(usr3)权限执行, usr3有super权限, 能执行成功
call p6()/

create definer = usr2 procedure p7()
begin
  select * from t1;
end;
/

#以usr2权限执行, usr2无t1 select权限
--error 1142, 1370
call p7()/

create definer = usr1 procedure p8()
begin
  call p7();
end;
/

#以usr1权限执行,同上
--error 1142, 1370
call p8()/

#
# 测试项：拥有super权限的用户创建trigger时，指定不存在的用户，编译期报用户不存在的warning，执行期报错
#
--disable_warnings
create definer=not_exist@localhost trigger tg1 before insert on t1
for each row
begin
  insert into t2 values(1);
end;
/
--enable_warnings

--error 1449
insert into t1 values(2)/

drop trigger tg1/

create definer=usr2 trigger tg1 before insert on t1
for each row
begin
  insert into t2 values(1);
end;
/

#以usr2权限执行tg1，usr2用户没有t2表的insert权限，预期报错1142
--error 1142
insert into t1 values(2)/

create definer=usr1 trigger tg2 before insert on t3
for each row
begin
  insert into t4 values(1);
end;
/

insert into t3 values(3)/

select * from t3/

select * from t4/

delimiter ;/

connection default;
#赋予usr2对t1表的insert权限
grant insert on ceshi.t3 to usr2;

connect (conn2,$OBMYSQL_MS0,usr2,123,ceshi,$OBMYSQL_PORT);
connection conn2;

use ceshi;

#usr2 没有t1的select权限 
--error 1142
select id from t1;

#usr3用户下创建的存储过程，usr2用户可以正常调用
--error 1370
call p1();
--error 1370
call p2();

#p3需要以调用者的权限执行，user2没有表t1的select权限，预期报错
--error 1142, 1370
call p3();
--error 1370
select f1();
--error 1370
select f2();

#f3需要以调用者的权限执行，user2没有表t1的select权限，预期报错
--error 1142,1370
select f3();

#usr2有t3表的insert权限，但是没有t4表的insert权限，usr1表有t4表的insert权限。
#通过definer指定usr，usr2可以成功执行tg2
insert into t3 values(4);

connection default;

use ceshi;

select * from t3;
select * from t4;

drop table t1;
drop table t2;
drop table t3;
drop table t4;

drop procedure p1;
drop procedure p2;
drop procedure p3;
drop procedure p4;
drop procedure p5;
drop procedure p6;
drop procedure p7;
drop procedure p8;
drop function f1;
drop function f2;
drop function f3;


drop user usr1;
drop user usr2;
drop user usr3;


#

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop procedure if exists p1;
drop function if exists f1;
drop trigger if exists tg1;
--enable_warnings

delimiter /;

create procedure p1()
begin
  select 2;
end/

show create procedure p1/

drop procedure p1/

create procedure p1()
begin
  select 2;
end/

show create procedure p1/

drop procedure p1/

create function f1() returns int
begin
  return 1;
end/

show create function f1/

create table t1(id int)/
create table t2(id int)/

--disable_warnings
create definer=not_exist@localhost trigger tg1 before insert on t1
for each row
begin
  insert into t2 values(1);
end;
/
--enable_warnings

show create trigger tg1/

drop trigger tg1/

drop table t1/
drop table t2/


--disable_warnings
create definer=not_exist@'%' procedure p1()
begin
  select 2;
end;
/
--enable_warnings

create procedure p2()
begin
  call p1();
  select "fail to raise exception!";
end;
/

--error 1449
call p2()/

drop procedure p1/
drop procedure p2/

#

CREATE DEFINER = admin@% PROCEDURE `ceshi`.`p1`
()
 begin
 end;

show create procedure p1;

drop procedure p1/
drop database ceshi/