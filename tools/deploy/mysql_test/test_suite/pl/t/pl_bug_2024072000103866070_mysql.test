#owner: wangbai.wx
#owner group: pl/sql
#tags: pl
#description: test param value in sql audit

--result_format 4

--disable_warnings
drop procedure if exists test;
--enable_warnings

connect (con, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
connection con;
alter system flush sql audit global;
connection default;

delimiter /;
create procedure test(proc int) begin select 1 from dual; end;/
delimiter ;/
prepare t1 from 'CALL test(?);';
set @aa=111;
execute t1 using @aa;
select QUERY_SQL,PARAMS_VALUE,SQL_ID from oceanbase.GV$OB_SQL_AUDIT where SQL_ID = '28CD79915C2EE3A3BDD9086F5478032F' and QUERY_SQL like 'call test(?);';


drop procedure test;
