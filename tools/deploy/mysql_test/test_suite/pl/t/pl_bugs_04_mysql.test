--disable_warnings
drop table if exists t1;
drop function if exists f1;
--enable_warnings

create table t1(c0 int);

delimiter /;

create function f1() returns int deterministic
begin
   insert into t1 values(1);
   insert into t1 values('a');
return 1;
end;/

delimiter ;/

set autocommit = 0;

insert into t1 values(0);
--error 1366
set @a=f1();
#t1有0
select * from t1;

rollback;

select * from t1;

drop table t1;
drop function f1;

set autocommit=1;