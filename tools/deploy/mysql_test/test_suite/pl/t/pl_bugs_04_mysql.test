--disable_warnings
drop function if exists fun_test;
--enable_warnings

--error 0,1051
DROP TABLE tt1;

create table tt1(id int);

delimiter /;

create function fun_test()
returns int
begin
  insert into tt1 values(1);
  insert into tt1 values(1,2);
  return 1;
end;
/

delimiter ;/

--error 1136
select fun_test();

select * from tt1;

set autocommit = 1;

drop function fun_test;

delimiter /;

create function fun_test()
returns int
begin
  savepoint a;
  release savepoint a;
  return 1;
end;
/

select fun_test()/

delimiter ;/

drop function fun_test;
drop table tt1;


--error 0,1051
DROP TABLE t1;
--error 0,1051
DROP TABLE t2;

CREATE TABLE t1 (
 stats INT,
 s1 INT,
 s2 INT
);

CREATE TABLE t2 (
  s1 INT,
 s2 INT
);

INSERT INTO t1 VALUES(0,1,3),(1,0,0);

delimiter /;

CREATE FUNCTION fun_test() RETURNS INT
BEGIN
 INSERT INTO t2 VALUES(0,1);
 RETURN 0;
END/

SELECT * FROM t1 WHERE stats IN (SELECT fun_test());/
SELECT * FROM t2/

drop function fun_test/

delete from t2/

CREATE FUNCTION fun_test() RETURNS INT DETERMINISTIC
BEGIN
 INSERT INTO t2 VALUES(0,1);
 RETURN 0;
END/

SELECT * FROM t1 WHERE stats IN (SELECT fun_test());/
SELECT * FROM t2/

delimiter ;/

drop table t1;
drop table t2;

drop function fun_test;


