--result_format 4
--echo ############################start case 1############################
#####
delimiter /;

--error 1422
create function functionAdd1 (a int, b int)
returns int
begin
start transaction;
return 1;
end;
/

--error 1422
create function functionAdd1 (a int, b int)
returns int
begin
rollback;
return 1;
end;
/

--error 1422
create function functionAdd1 (a int, b int)
returns int
begin
commit;
return 1;
end;
/

delimiter ;/

--error 0, 1051
drop table t1;
--error 1360
drop trigger tr_test;

create table t1 (c1 int);

--error 1422
CREATE TRIGGER tr_test
BEFORE
INSERT ON t1
FOR EACH ROW
START TRANSACTION;

--error 1422
CREATE TRIGGER tr_test
BEFORE
INSERT ON t1
FOR EACH ROW
rollback;

--error 1422
CREATE TRIGGER tr_test
BEFORE
INSERT ON t1
FOR EACH ROW
commit;

drop table t1;
--echo ############################end case 1#############################

#

--disable_warnings
drop procedure if exists pro1;
--enable_warnings

delimiter //;
--echo ### 指示符对象-存储过程参数
SET @p11=NULL, @p12=NULL,@p21=NULL, @p22=NULL;//

CREATE PROCEDURE pro1(out num1 varchar(200),out row_cou1 varchar(200),out num2 varchar(200),out row_cou2 varchar(200)) 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET CURRENT DIAGNOSTICS num1 = NUMBER, row_cou1 = ROW_COUNT;
	  GET STACKED DIAGNOSTICS num2 = NUMBER, row_cou2 = ROW_COUNT;
  END;
  DROP TABLE no_such_table3;
END;
//

CALL pro1(@p11, @p12,@p21, @p22)//
SELECT 'CURRENT DIAGNOSTICS',@p11 'NUMBER', @p12 'ROW_COUNT';//
SELECT 'STACKED DIAGNOSTICS',@p21 'NUMBER', @p22 'ROW_COUNT';//

--echo ### 指示符对象-用户定义的变量
SET @p1=NULL, @p2=NULL,@p3=NULL, @p4=NULL;//

DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
	  GET STACKED DIAGNOSTICS @p3 = NUMBER, @p4 = ROW_COUNT;
      SELECT 'CURRENT DIAGNOSTICS',@p1 'NUMBER', @p2 'ROW_COUNT';
	  SELECT 'STACKED DIAGNOSTICS',@p3 'NUMBER', @p4 'ROW_COUNT';
  END;
  DROP TABLE no_such_table4;
END;
//

CALL pro1()//

--echo ### 指示符对象- DECLARE声明的局部变量
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () DETERMINISTIC
BEGIN
  DECLARE num1,num2 varchar(200);
  DECLARE row_cou1,row_cou2 varchar(200);
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET DIAGNOSTICS num1 = NUMBER, row_cou1 = ROW_COUNT;
	  GET STACKED DIAGNOSTICS num2 = NUMBER, row_cou2 = ROW_COUNT;
      SELECT 'CURRENT DIAGNOSTICS',num1 'NUMBER', row_cou1 'ROW_COUNT';
	  SELECT 'STACKED DIAGNOSTICS',num2 'NUMBER', row_cou2 'ROW_COUNT';
  END;
  SELECT * FROM no_such_table5;
END;
//

CALL pro1()//

DROP PROCEDURE IF EXISTS pro1;//

delimiter ;//

