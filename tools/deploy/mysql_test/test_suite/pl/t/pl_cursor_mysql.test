--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: hr351303
#owner group: sql4
#tags: pl
#description: 4.0 support cursur

--disable_warnings
--error 0,1396
drop user henry@'%';
--enable_warnings
create user henry identified by 'henry';
grant all on *.* to henry WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,henry,henry,test,$OBMYSQL_PORT);
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop procedure if exists p1;
drop function if exists f1;
--enable_warnings


create table t1(id int);

create table t2(id int);

delimiter /;

######################### cursor in procedure test start ####################

#########################ac = off############################
set autocommit = off;
/

#非可更新游标 rollback场景
create procedure p1()
begin
  declare c int;
  declare c1 cursor for select id from t1;
  savepoint s1;
  insert into t1 value(2);
  open c1;
  rollback to s1;
  fetch c1 into c;
  insert into t2 value(c);
  close c1;
end;
/

call p1()/

select * from t1;
/

select * from t2;
/

drop procedure p1/

rollback/

insert into t1 value(1)/

#非可更新游标，事务存在修改，rollback场景, 不会导致cursor 快照失效
create procedure p1()
begin
  declare c int;
  declare c1 cursor for select id from t1;
  savepoint s1;
  open c1;
  rollback;
  fetch c1 into c;
  insert into t2 value(c);
  close c1;
end;
/

insert into t2 values(11);
/

call p1()/

select * from t1/

select * from t2/

rollback/

drop procedure p1/

#可更新游标 rollback场景, 不会导致cursor 快照失效
create procedure p1()
begin
  declare c int;
  declare c1 cursor for select id from t1 for update;
  savepoint s1;
  insert into t1 value(2);
  open c1;
  rollback to s1;
  fetch c1 into c;
  insert into t2 value(c);
  close c1;
end;
/

call p1()/

select * from t1;
/

select * from t2;
/

rollback/

drop procedure p1/

#事务期间无修改, 兼容
create procedure p1()
begin
  declare c int;
  declare c1 cursor for select id from t1 for update;
  savepoint s1;
  -- insert into t2 value(2);
  open c1;
  rollback to s1;
  fetch c1 into c;
  insert into t2 value(c);
  close c1;
end;
/

call p1()/

select * from t1;
/

select * from t2;
/

rollback/

drop procedure p1/

#可更新游标，提交场景, 不会导致cursor
create procedure p1()
begin
  declare c int;
  declare c1 cursor for select id from t1 for update;
  savepoint s1;
  -- insert into t2 value(10);
  -- insert into t1 value(3);
  open c1;
  commit;
  fetch c1 into c;
  insert into t2 value(c);
  close c1;
end;
/

call p1()/

select * from t1/
select * from t2/

rollback/

drop procedure p1/

#非可更新游标，提交场景, 不会导致cursor 快照失效
create procedure p1()
begin
  declare c int;
  declare c1 cursor for select id from t1;
  savepoint s1;
  insert into t2 value(10);
  insert into t1 value(3);
  open c1;
  commit;
  fetch c1 into c;
  insert into t2 value(c);
  close c1;
end;
/

call p1()/

select * from t2;
/

select * from t1;
/

drop procedure p1/

#########################ac = on############################

set autocommit = on;
/

#非可更新游标 rollback场景
create procedure p1()
begin
  declare c int;
  declare c1 cursor for select id from t1;
  savepoint s1;
  insert into t1 value(2);
  open c1;
  rollback to s1;
  fetch c1 into c;
  insert into t2 value(c);
  close c1;
end;
/

