######################### cursor in procedure test end ####################

######################### cursor in function test start ####################

delete from t1/

delete from t2/

insert into t1 value(1)/

#非可更新游标 rollback场景
create function f1() returns int deterministic
begin
  declare c int default 0;
  declare c1 cursor for select id from t1;
  savepoint s1;
  insert into t1 value(2);
  open c1;
  rollback to s1;
  fetch c1 into c;
  insert into t2 value(c);
  close c1;
  return c;
end;
/

select f1() from dual/

select * from t1/

select * from t2/

drop function f1/

#可更新游标 rollback场景
create function f1() returns int deterministic
begin
  declare c int default 0;
  declare c1 cursor for select id from t1 for update;
  savepoint s1;
  insert into t1 value(2);
  open c1;
  rollback to s1;
  fetch c1 into c;
  insert into t2 value(c);
  close c1;
  return c;
end;
/

select f1() from dual/

select * from t1/

select * from t2/

drop function f1/

