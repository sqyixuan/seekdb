#description: test tigger with if not exist
 
--result_format 4
--error 0,1051
DROP TABLE `t1`;
--error 0,1051
DROP TABLE `t2`;

create table t1 (i int);
create table t2 (i int);

create trigger if not exists t1_trigger after insert on t1 for each row insert into t2 values (new.i);
show create trigger t1_trigger;

create trigger if not exists t1_trigger after insert on t1 for each row insert into t2 values (new.i + 1);
show create trigger t1_trigger;

--error 5734
create trigger t1_trigger after insert on t1 for each row insert into t2 values (new.i + 1);
show create trigger t1_trigger;

drop trigger t1_trigger;

create trigger t1_trigger after insert on t1 for each row insert into t2 values (new.i);
show create trigger t1_trigger;

create trigger if not exists t1_trigger after insert on t1 for each row insert into t2 values (new.i + 1);
show create trigger t1_trigger;

drop trigger t1_trigger;
DROP TABLE t1;
