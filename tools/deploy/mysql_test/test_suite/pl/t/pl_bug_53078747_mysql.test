#owner: heyongyi.hyy
#owner group: pl/sql
#tags: pl
#description: test pl bug

--result_format 4

--disable_warnings ONCE
drop function if exists func;

--disable_warnings ONCE
drop procedure if exists proc;

create function func() returns int SQL SECURITY INVOKER return 42;

delimiter /;
create procedure proc() SQL SECURITY INVOKER begin select 42; end;
/
delimiter ;/

--replace_column 4 'root@localhost' 5 '0000-00-00 00:00:00' 6 '0000-00-00 00:00:00'
show function status like '%func%';

--replace_column 4 'root@localhost' 5 '0000-00-00 00:00:00' 6 '0000-00-00 00:00:00'
show procedure status like '%proc%';

ALTER FUNCTION func LANGUAGE SQL READS SQL DATA  SQL SECURITY DEFINER COMMENT 'SQL SECURITY=DEFINER';

ALTER PROCEDURE proc LANGUAGE SQL READS SQL DATA  SQL SECURITY DEFINER COMMENT 'SQL SECURITY=DEFINER';

--replace_column 4 'root@localhost' 5 '0000-00-00 00:00:00' 6 '0000-00-00 00:00:00'
show function status like '%func%';

--replace_column 4 'root@localhost' 5 '0000-00-00 00:00:00' 6 '0000-00-00 00:00:00'
show procedure status like '%proc%';

ALTER FUNCTION func LANGUAGE SQL READS SQL DATA  SQL SECURITY INVOKER COMMENT 'SQL SECURITY=INVOKER';

ALTER PROCEDURE proc LANGUAGE SQL READS SQL DATA  SQL SECURITY INVOKER COMMENT 'SQL SECURITY=INVOKER';

--replace_column 4 'root@localhost' 5 '0000-00-00 00:00:00' 6 '0000-00-00 00:00:00'
show function status like '%func%';

--replace_column 4 'root@localhost' 5 '0000-00-00 00:00:00' 6 '0000-00-00 00:00:00'
show procedure status like '%proc%';

drop function func;
drop procedure proc;
