#owner: heyongyi.hyy
#owner group: PL/SQL
#tags: pl

--result_format 4

--disable_warnings ONCE
drop table if exists t;

create table t(c char(1));
set sql_mode='';

--disable_warnings ONCE
drop procedure if exists p;

delimiter /;
create procedure p()
begin
set @ob_dbmsmview_cno=null;
set @ob_dbmsmview_errno=null;
set @ob_dbmsmview_p4=null;
insert into t values('aa');
GET DIAGNOSTICS @ob_dbmsmview_cno = NUMBER;
GET DIAGNOSTICS CONDITION 1 @ob_dbmsmview_errno = MYSQL_ERRNO, @ob_dbmsmview_p4 = MESSAGE_TEXT;
select @ob_dbmsmview_cno, @ob_dbmsmview_errno, @ob_dbmsmview_p4;
end;
/
delimiter ;/

call p();

drop table t;
drop procedure p;
set sql_mode=default;
