#owner: haohao.hao
#owner group: PL/SQL
#tags: pl
#description: use "USER" as mysql procedure variable

--result_format 4

--echo 

delimiter //;


--echo -- 1. procedure
--error 0, 600
drop procedure if exists proc;//
create procedure proc()
begin
  declare user varchar(64);
end;
//
drop procedure proc;//


--echo -- 2. trigger
--error 0, 600
drop table if exists test_user_var;//
create table test_user_var(id int, data int, username varchar(64));//
insert into test_user_var(id, data) values (1, 0);//
create trigger test_trigger before update on test_user_var for each row
begin
  declare user varchar(64);
  declare i int;
  select 'user()' into user;
  set NEW.username = user;
  select count(*) from ((select 1) union (select 2)) as d1 into i;
end;
//
update test_user_var set data = 1;//
select * from test_user_var;//
drop table test_user_var;//


--echo -- 3. mysql pl ddl
create procedure proc()
begin
  create user test_create_user;
end;
//
call proc();//
drop user test_create_user;//
drop procedure proc;//


delimiter ;//
