--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#tags: pl
#owner: heyongyi.hyy
#owner group: sql4
#description: test dynamic alloc buffer

--result_format 4

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log


--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1(a JSON);

--disable_warnings
DROP PROCEDURE IF EXISTS p;
--enable_warnings

delimiter //;
create procedure p()
begin
    declare x int default 1;
    while x <=20 do
        SET @a:= CONCAT('[',REPEAT('"a",',150000),'"a"]');
        SELECT JSON_TYPE(@a), LENGTH(@a), LENGTH(@a)*3;
        INSERT INTO t1(a) VALUES(@a);
        set x = x+1;
    end while;
    commit;
end //
delimiter ;//
call p;
