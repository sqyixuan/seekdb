#owner: heyongyi.hyy
#owner group: sql4
#tags: pl
#description: test pl bugs [Aone]
--result_format 4
--disable_warnings
drop function if exists func;
--enable_warnings
set @a=1;
delimiter //;
create function func() returns varchar(20)
begin 
set @a='test03';
return @a;
end;//
delimiter ;//
select func();
select @a;
drop function func;
set @a='test03';
delimiter //;
create function func() returns int
begin 
set @a=1;
return @a;
end;//
delimiter ;//
select func();
select @a;
drop function func;
set @a='1';
delimiter //;
create function func() returns int
begin 
return @a;
end;//
delimiter ;//
select func();
drop function func;
set @a='test03';
delimiter //;
create function func() returns int
begin 
return @a;
end;//
delimiter ;//
--error 1366
select func();
set @a=1;
select func();
drop function func;
set @a=NULL;
delimiter //;
create function func() returns int
begin 
declare a datetime;
set a=@a;
return year(a);
end;//
delimiter ;//
select func();
set @a=1;
--error 1292
select func();
set @a='1970-01-01 00:00:01.000000';
select func();
--disable_warnings
drop function if exists return_int;
drop function if exists return_varchar;
drop function if exists return_double;
drop function if exists return_datetime;
--enable_warnings
set @a=1;
delimiter //;
create function return_varchar() returns varchar(50)
begin 
return @a;
end;//
create function return_double() returns double
begin 
return @a;
end;//
create function return_datetime() returns datetime
begin 
return @a;
end;//
delimiter ;//
select return_varchar();
select return_double();
--error 1292
select return_datetime();
set @a='1970-01-01 00:00:01.000000';
delimiter //;
create function return_int() returns int
begin 
return @a;
end;//
delimiter ;//
select return_varchar();
select return_datetime();
--error 1265
select return_int();
set @a=0.5;
select return_varchar();
select return_double();
select return_int();
drop function func;
drop function return_varchar;
drop function return_double;
drop function return_datetime;
drop function return_int;
--disable_warnings
drop procedure if exists p;
--enable_warnings
set @a='1.00000';
delimiter //;
create procedure p()
begin
set @a=@a+1;
end;
//
delimiter ;//
call p();
select @a;
set @a=1.00000;
call p();
select @a;
drop procedure p;
set @a='1.00000';
delimiter //;
create procedure p()
begin
set @a=1.00000;
set @a=@a+1;
end;
//
delimiter ;//
call p();
select @a;

