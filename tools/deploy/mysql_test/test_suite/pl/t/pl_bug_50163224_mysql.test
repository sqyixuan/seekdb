#owner: hr351303
#owner group: sql4-PL/SQL
#tags: pl
#description: test pl bug
# 

--result_format 4

--disable_warnings

drop function if exists f1;
drop procedure if exists p1;
delimiter /;

create function f1(a int) returns int DETERMINISTIC
begin
  return a;
end
/

create procedure p1(arg1 int,arg2 int)
begin
  declare a int;
  select arg1;
end
/

delimiter ;/
set @a=1;
prepare stmt from 'call p1(10,?)';
execute stmt using @a;

--error 1318
set @a=f1();
prepare stmt from 'call p1(10,?)';
execute stmt using @a;

set @a=f1(10);
select @a;
prepare stmt from 'call p1(10,?)';
execute stmt using @a;

deallocate prepare stmt;

drop function f1;
drop procedure p1;

--enable_warnings
