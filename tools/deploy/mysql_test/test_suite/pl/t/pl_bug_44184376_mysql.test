--result_format 4

--disable_warnings

drop table if exists t2;
create table t2(id int ,s1 int, s2 int);
drop table if exists t1;
create table t1(id bigint, s1 int, s2 int,s3 date);
insert into t1(id,s1,s2,s3) values (3697483647,1,0,19981225);
drop function if exists n_1;
delimiter /;
create function n_1(a smallint,b tinyint,c int) returns varchar(200)
begin
  insert into t2 values(1,0,1);
  return concat(a,'-',b,'-',c);
end/
delimiter ;/

--error 1264
select n_1(id,id,id) from t1 ;

drop table if exists t2;
create table t2(id int ,s1 int, s2 int);
drop table if exists t1;
create table t1(id bigint, s1 bigint);
insert into t1(id,s1) values (3697483647,19990224232401);

drop function n_1;
delimiter /;
create function n_1(c year) returns varchar(200)
begin
  insert into t2 values(1,0,1);
  return concat(c);
end/
delimiter ;/
--error 1264
select n_1(s1) from t1 ;
select * from t2;

drop table t2;
create table t2(id bigint ,s1 char(20));
drop function n_1;
delimiter /;

