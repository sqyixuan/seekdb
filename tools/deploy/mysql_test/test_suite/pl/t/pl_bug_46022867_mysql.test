#owner: heyongyi.hyy
#owner group: sql4
#tags: pl
#description: show function status 

--result_format 4

delimiter $$;

--echo ----------case1-----------
--disable_warnings
drop table if exists t0;$$
--enable_warnings

create table t0(c0 int)$$
insert into t0 values(1);$$

--disable_warnings
drop procedure if exists p1$$
--enable_warnings

create procedure p1()
begin
declare a int;
declare c cursor for (with tmp as(select * from t0)select * from tmp);
open c;
fetch c into a;
close c;
select a;
end;
$$
call p1()$$
delimiter ;$$

drop table t0;
drop procedure p1;

