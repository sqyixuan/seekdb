#owner: wangbai.wx
#owner group: pl/sql
#tags: pl
#description: test mock show procedure/function code

--result_format 4

--disable_warnings
drop function if exists fn1;
drop procedure if exists p1;
drop procedure if exists p2;
drop procedure if exists p3;
drop procedure if exists p4;
drop procedure if exists p5;
--enable_warnings

delimiter /;
create function fn1(f1 int1 unsigned) returns int1 unsigned NO SQL return f1;/
create procedure p1() begin set @a = @a + 1; end;/
--error 1415
create function fn2(f1 int1 unsigned) returns int1 unsigned begin show function code fn1; return f1; end;/
--error 1415
create function fn2(f1 int1 unsigned) returns int1 unsigned begin show procedure code p1; return f1; end;/

show function code fn1;/
--error 1305
show function code fn2;/
--error 1305
show function code p1;/
show procedure code p1;/
--error 1305
show procedure code p2;/
--error 1305
show procedure code fn1;/

create procedure p2() begin show procedure code p1; show function code fn1; end;/
show procedure code p2;/
call p2;/

create procedure p3() begin show function code fn1; show procedure code p1; end;/
show procedure code p3;/
call p3;/

create procedure p4() begin show procedure code p4; end;/
show procedure code p4;/
call p4;/

create procedure p5() begin show procedure code fn1; show function code p1; end;/
show procedure code p5;/
--error 1305
call p5;/

delimiter ;/

drop function fn1;
drop procedure p1;
drop procedure p2;
drop procedure p3;
drop procedure p4;
drop procedure p5;