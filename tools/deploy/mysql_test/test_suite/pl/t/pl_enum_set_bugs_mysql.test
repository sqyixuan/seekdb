drop PROCEDURE pro12_6;

DELIMITER /;
CREATE PROCEDURE pro12_6(arg ENUM('','NULL', '1.235'))
BEGIN
  declare var1 ENUM('','NULL','1.235','2.567') default '2.567';
  declare var2 enum('','NULL', '1.235','2.567') default null;
  select var1,CAST(var1 AS DECIMAL(3,2));
  SELECT arg,CAST(arg AS DECIMAL(3,2));
  SELECT c1,CAST(c1 AS DECIMAL(3,2)) from tab;
  select var2,CAST(var2 AS DECIMAL(3,2));
END 
/
DELIMITER ;/

call pro12_6('1.235');
call pro12_6('NULL');
call pro12_6(null);

drop procedure pro12_6;

--error 0, 1305
drop PROCEDURE pro12_2;

DELIMITER /;
CREATE PROCEDURE pro12_2(arg ENUM('','NULL', 'one', 'TWO','Three','FouR'))
BEGIN
  declare var1 ENUM('','NULL', 'one', 'TWO','Three','FouR') default 'one';
  declare var2 ENUM('','null', 'one', 'two','three','four','1','2','3','4') default 'TWO';
  declare var3 set('','null', 'one', 'two','three','four','1','2','3','4') default 'TWO';
  select EXPORT_SET(arg, '1','0',',', 10);
  select FORMAT(arg, 2);
  select MAKE_SET(arg,var1,var2,'aa','bb');
  select REPEAT(arg, var1);
  select INTERVAL(arg,var1,var2);
  select REPEAT(arg, var3);
END;
/
DELIMITER ;/

call pro12_2('NULL');

drop procedure pro12_2;

