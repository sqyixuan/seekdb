--error 0, 1305
drop procedure my_pro;/
create procedure my_pro()
BEGIN
  declare p1 ENUM('11', '12','13','14','15');
  declare p2  ENUM('25', 'b', '24');
  set p1 = '11';
  set p2 = '24';
  call my_pro2(p1,  p2);
  select p1, p2;
END;
/

call my_pro;/
select @bk_p1, @bk_p2;/
drop procedure my_pro2;/
drop procedure my_pro;/

CREATE PROCEDURE my_pro2(inout p1 ENUM('','null','10','11','12','13','14','15'))
BEGIN 
 DECLARE v1 ENUM('','null','10','11','12','13','14','15') DEFAULT 'null'; 
  set p1 = p1 +1; 
  CASE p1   
    WHEN @p1 THEN SELECT '1',p1,@p1; 
     WHEN @p2 THEN SELECT '2',p1,@p1; 
     WHEN v1 THEN SELECT '3',v1,@p1;  
     WHEN null THEN SELECT '4',null;   
     ELSE SELECT '5 else',p1; 
  END CASE;
  END;
/

DELIMITER ;/

SET @p1 = '10';
SET @p2 = 3;
call my_pro2(@p1);
select @p1;

PREPARE stmt FROM 'call my_pro2(?)';
SET @p1 = '10';
SET @p2 = 3;
EXECUTE stmt using @p1;
select @p1;

drop procedure my_pro2;

