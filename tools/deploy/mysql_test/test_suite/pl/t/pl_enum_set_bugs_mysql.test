--error 0, 1360
drop trigger tri1;

CREATE TABLE tab1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    c1 ENUM( 'one', 'TWO','Three','FouR') NOT NULL,
    c2 ENUM( 'a', 'b', 'c', 'd', 'One', 'Two') DEFAULT 'a',
    c3 varchar(2000));

CREATE TABLE tab2 (id INT AUTO_INCREMENT PRIMARY KEY,c1 varchar(2000));

DELIMITER /;
create trigger tri1 before insert on tab1 for each row
begin
  IF new.c1 != new.c2 THEN
    IF new.c1 > new.c2 THEN
      INSERT INTO tab2(c1) VALUES ('new.c1 > new.c2');
    else
      INSERT INTO tab2(c1) VALUES ('new.c1 < new.c2');
    END IF;
  else
    INSERT INTO tab2(c1) VALUES ('new.c1 = new.c2');
  END IF;
end;
/
DELIMITER ;/

INSERT INTO tab1(c1,c2,c3) VALUES ('one', 'a',1);
select id,c1,c1+0,c2,c2+0,c3 from tab1 order by 1;
select * from tab2 order by 1;

INSERT INTO tab1(c1,c2,c3) VALUES ('one', 'One',2);
select id,c1,c1+0,c2,c2+0,c3 from tab1 order by 1;
select * from tab2 order by 1;

drop trigger tri1;
drop table tab1;
drop table tab2;

--error 0, 1305
drop PROCEDURE pro7_5;

DELIMITER /;
CREATE PROCEDURE pro7_5(arg1 ENUM('','NULL', 'one', 'TWO','Three','FouR'),arg2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two'))
begin
  CASE arg1
    WHEN ''     THEN select '【WHEN 空分支 1】';
    WHEN 'NULL' THEN select '【WHEN NULL分支 2】';
    WHEN arg2   THEN select  '【WHEN arg2分支 3】';
    ELSE select '【ELSE分支 4】';
  END CASE; 

  CASE 2
    WHEN arg1  THEN select '【WHEN 1】';
    ELSE select '【ELSE分支】';
  END CASE; 

  CASE 'NULL'
    WHEN arg1  THEN select '【WHEN 1】';
    ELSE select '【ELSE分支 】';
  END CASE;
end;
/

DELIMITER ;/

call pro7_5('', '-1');
call pro7_5('NULL', '-1');
call pro7_5('one', 'One');

drop procedure pro7_5;

