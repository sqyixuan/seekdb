drop PROCEDURE pro2;
--error 0, 1305
drop PROCEDURE pro3;
--error 0, 1305
drop PROCEDURE pro4;

DELIMITER /;

CREATE PROCEDURE pro1(inout arg ENUM('','null', 'one', 'two','three','four'))
BEGIN
  set arg  = 'two';
  SELECT arg, @var;
END;
/

CREATE PROCEDURE pro2(inout arg ENUM('','null', 'one', 'two','three','four'))
BEGIN
  call pro1(arg);
END;
/

create procedure pro3()
begin
  declare var1 ENUM('one', 'TWO','Three','FouR') default 'TWO';
  call pro2(var1);
end;
/

create procedure pro4()
begin
  call pro1(@var1);
end;
/


DELIMITER ;/

set @var='one';
call  pro1(@var);
call pro3;
call pro2(@var);
call pro4;
SELECT @var;

drop procedure pro1;
drop procedure pro2;
drop procedure pro3;
drop procedure pro4;

--error 0, 1051
drop table tab1;
