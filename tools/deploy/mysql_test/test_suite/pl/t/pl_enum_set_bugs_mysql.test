drop table t_enum;

create table t_enum(c1 ENUM('one', 'TWO','Three','FouR'));
insert into t_enum values('one');

DELIMITER /;
CREATE PROCEDURE pro9_1(arg1 ENUM('one', 'TWO','Three','FouR'))
begin
  declare var1 ENUM('one', 'TWO','Three','FouR') default 'TWO';
  set @var1 = var1;
  set @var2 = arg1;
  set @var3 = (select var1 from dual);
  select arg1 into @var4 from dual;
  select c1 into @var5 from t_enum;
  select @var1,@var2,@var3,@var4,@var5;
end;
/
DELIMITER ;/

call pro9_1('one');
select @var1,@var2,@var3,@var4,@var5;

drop procedure pro9_1;
drop table t_enum;

