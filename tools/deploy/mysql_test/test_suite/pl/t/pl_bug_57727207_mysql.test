#description: 
 
--result_format 4
--disable_warnings
DROP TABLE IF exists test_status;
DROP TABLE IF exists test_status2;
--enable_warnings

--error 0,1305
DROP PROCEDURE `TestProcedureStatus`;
--error 0,1305
DROP PROCEDURE `TestProcedureStatus2`;

CREATE TABLE test_status (n1 INT PRIMARY KEY, status varchar(20), d1 DATETIME DEFAULT current_timestamp);
INSERT INTO test_status (n1, status) values (1, 'Y');
--replace_column 3 time
SELECT * FROM test_status;
CREATE TABLE test_status2 (n1 INT PRIMARY KEY, status varchar(20), d1 DATETIME DEFAULT current_timestamp);
INSERT INTO test_status2 (n1, status) values (1, 'Y');
--replace_column 3 time
SELECT * FROM test_status2;

DELIMITER //;
CREATE  PROCEDURE `TestProcedureStatus`(
IN status varchar(20)
)
BEGIN
  UPDATE test_status SET test_status.status = status;
END //
DELIMITER ;//

call TestProcedureStatus ('N');
--replace_column 3 time
SELECT * FROM test_status;

UPDATE test_status SET test_status.status = status;

DELIMITER //;
CREATE  PROCEDURE `TestProcedureStatus2`(
IN `status` varchar(20)
)
BEGIN
  UPDATE test_status2 SET test_status2.`status` = `status`;
END //
DELIMITER ;//

call TestProcedureStatus2('N');
--replace_column 3 time
SELECT * FROM test_status2;

UPDATE test_status2 SET test_status2.`status` = `status`;

DROP TABLE test_status;
DROP PROCEDURE `TestProcedureStatus`;
DROP TABLE test_status2;
DROP PROCEDURE `TestProcedureStatus2`;