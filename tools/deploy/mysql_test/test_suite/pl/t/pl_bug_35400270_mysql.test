#owner: heyongyi.hyy
#owner group: sql4
#tags: pl
#description: 

--result_format 4

delimiter //;
SET sql_mode = 'STRICT_ALL_TABLES'//
--disable_warnings ONCE
DROP TABLE IF EXISTS t1//
CREATE TABLE t1 (
c1 CHAR(10)
)//

INSERT INTO t1 (c1) VALUES('xy  ')//

--disable_warnings ONCE
DROP PROCEDURE IF EXISTS `pro_1`//
CREATE PROCEDURE pro_1()
BEGIN
DECLARE d1,d2 CHAR(10);
SET d1 = 'xy  ';
SELECT c1 INTO d2 FROM t1;
SET sql_mode = '';
SELECT CHAR_LENGTH(d1),CHAR_LENGTH(d2) INTO @p1,@p2;
END//

CALL pro_1()//
SELECT '禁用PAD_CHAR_TO_FULL_LENGTH SQL模式场合',@p1 '变量d1的长度',@p2 '表列d2的长度'//

--disable_warnings ONCE
DROP PROCEDURE IF EXISTS `pro_2`//
CREATE PROCEDURE pro_2()
BEGIN
DECLARE d1,d2 CHAR(10);
SET d1 = 'xy  ';
SELECT c1 INTO d2 FROM t1;
SET sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
SELECT CHAR_LENGTH(d1),CHAR_LENGTH(d2) INTO @p1,@p2;
END//

CALL pro_2()//
SELECT '启用PAD_CHAR_TO_FULL_LENGTH SQL模式场合',@p1 'CHAR(10)的变量d1的长度',@p2 'CHAR(10)的表列d2的长度'//

--disable_warnings ONCE
DROP PROCEDURE IF EXISTS `pro_3`//
CREATE PROCEDURE pro_3()
BEGIN
DECLARE d1,d2 CHAR(10);
SET sql_mode = '';
SET d1 = ' test';
SET d2 = ' test   ';
SELECT CHAR_LENGTH(d1),CHAR_LENGTH(d2) INTO @p1,@p2;
SET sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
SELECT CHAR_LENGTH(d1),CHAR_LENGTH(d2) INTO @p3,@p4;
END//

CALL pro_3()//
SELECT @p1, @p2, @p3, @p4//

delimiter ;//
SET sql_mode = '';
