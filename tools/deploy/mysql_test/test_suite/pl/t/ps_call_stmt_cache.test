#owner: hr351303
#owner group: sql4
#description: cache call stmt to pl cache in ps mode
#tags: pl

--disable_warnings
drop procedure if exists p1;
drop procedure if exists p2;
--enable_warnings

delimiter /;

create procedure p1(a int, b int)
begin
  select a + b;
end/

create procedure p2(a int, b int)
begin
  set @a = a;
  set @b = b;
  prepare st1 from 'call p1(?,?)';
  execute st1 using @a,@b;
  deallocate prepare st1;
end/

delimiter ;/

call p2(2,3);

#从缓存中查找到call stmt
call p2(5,6);

#缓存call语句后，，删除存储过程，再次执行存储过程
drop procedure p1;

--error 1305
call p2(2,3);

delimiter /;

create procedure p1(a int, b int)
begin
  select a + b + 1;
end/

delimiter ;/

#p1 schema变更, 淘汰call缓存项，重新add plan

call p2(2,3);

#从缓存中查找到call stmt
call p2(4,5);

drop procedure p1;
drop procedure p2;