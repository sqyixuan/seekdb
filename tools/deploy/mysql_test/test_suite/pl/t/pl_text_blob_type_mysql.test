#owner: hr351303
#owner group: sql4
#description: pl support text and blob data type
#tags: pl
#author:hr351303

--result_format 4

connection default;

--error 0,1305
drop procedure if exists p0;
--error 0,1305
drop function if exists f1;

delimiter /;

create procedure p0()
begin
  declare c1 text;
  declare c2 text(10);

  set c1 = 'dfgg1';
  set c2 = 'dfggfd2';

  select c1,c2;
end/

call p0()/

drop procedure p0/

create procedure p0()
begin
  declare c1 tinytext;
  declare c2 mediumtext;
  declare c3 longtext;

  set c1 = 'dfggfd';
  set c2 = 'dfggfc';
  set c3 = 'dfggggh';

  select c1,c2,c3;
end/

call p0()/

drop procedure p0/

create procedure p0()
begin
  declare c1 blob;
  declare c2 blob(20);


  set c1 = 'dfgg1';
  set c2 = 'dfggfd2';

  select c1,c2;
end/

call p0()/

drop procedure p0/

create procedure p0()
begin
  declare a tinyblob;
  declare b mediumblob;
  declare c longblob;

  set a = '1223';
  set b = '122445';
  set c = '134456';

  select a,b,c;
end/

call p0()/

drop procedure p0/

--error 1064
create procedure p0()
begin
  declare c1 tinytext(10);
  declare c2 mediumtext(10);
  declare c3 longtext(10);
  declare c4 tinyblob(20);
  declare c5 mediumblob(20);
  declare c6 longblob(20);
end/

create function f1(c1 mediumtext) returns mediumtext charset utf8
begin
  declare x mediumtext;
  set x = c1;
  return x;
end/

select f1('ddd')/

drop function f1/

create procedure p0()
begin
  declare a fixed;
  set a = 10;
  select a;
end/

call p0()/

drop procedure p0/

delimiter ;/

