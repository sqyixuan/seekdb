#owner group: PL/SQL
#tags: pl
#description:

--disable_warnings ONCE
drop procedure if exists loops;

delimiter /;

create procedure loops()
begin
declare x int default 1;
set @cnt=1;
my_loop: loop
set x=x+@cnt;
if x>10000000 then
leave my_loop;
end if;
end loop;
end;
/

delimiter ;/

call loops();
