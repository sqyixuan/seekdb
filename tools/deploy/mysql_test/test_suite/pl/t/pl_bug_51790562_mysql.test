#owner: hr351303
#owner group: PL/SQL
#tags: pl
#description: test sql audit

--disable_warnings
drop procedure if exists test_sql_audit;
--enable_warnings

delimiter /;

create procedure test_sql_audit()
begin
  select 1;
  select 2;
  select 3;
end/

delimiter ;/

call test_sql_audit();

select retry_cnt from oceanbase.gv$ob_sql_audit where query_sql like '%call test_sql_audit%';

drop procedure test_sql_audit;