#owner: webber.wb
#owner group: PL/SQL
#tags: pl, trigger
#

 --result_format 4

--error 0,1051
drop table muti_t1;
--error 0,1051
drop table muti_t2;
--error 0,1360
drop trigger trg_muti_t1;
--error 0,1360
drop trigger trg_muti_t2;

create table muti_t1 (c1 int, c2 int);

create table muti_t2 (c1 int, c2 int);

insert into muti_t1 values (1, 2);

insert into muti_t2 values (1, 3);

create trigger trg_muti_t1 before delete on muti_t1 for each row
set @a=1;

create trigger trg_muti_t2 after update on muti_t2 for each row
set @a=1;

delete muti_t1, muti_t2 from muti_t1 LEFT JOIN muti_t2 on muti_t1.c1 = muti_t2.c1;

update muti_t1 LEFT JOIN muti_t2 on muti_t1.c1 = muti_t2.c1 set muti_t1.c2 = 100, muti_t2.c2 = 101;

update muti_t1, muti_t2 set muti_t1.c2 = 10, muti_t2.c2 = 11;

drop table muti_t1;
drop table muti_t2;
