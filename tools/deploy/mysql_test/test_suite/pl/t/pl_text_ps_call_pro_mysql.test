#owner: hr351303
#owner group: sql4
#description: pl support call procedure out param in text ps mode
#tags: pl
#author:hr351303

--disable_warnings
drop procedure if exists p1;
drop procedure if exists p2;
--enable_warnings

delimiter /;

CREATE  PROCEDURE p1(in id int,out a int)
begin
select id into a;
end;
/

delimiter ;/

prepare st1 from 'CALL p1(?,?)';

set @a=1;
execute st1 using @a,@b;
select @b;

set @a='5';
execute st1 using @a,@b;
select @b;
deallocate prepare st1;

prepare st1 from 'CALL p1(?,@b)';

set @a=3;
execute st1 using @a;
select @b;
deallocate prepare st1;

delimiter /;

create procedure p2(a int)
begin
  prepare st2 from 'CALL p1(?,?)';
  set @a=a;
  execute st2 using @a,@b;
  select @b;
  deallocate prepare st2;
end/

delimiter ;/

call p2(3);
call p2(10);

drop procedure p1;
drop procedure p2;

#

--disable_warnings

drop procedure if exists p1;

delimiter /;

create procedure p1(a int,out b int)
begin
set b:=1;
end;
/

delimiter ;/

prepare stmt from 'call p1(10,?);';
execute stmt using @a;
select @a;

set @b=5;
prepare stmt from 'call p1(10 + ? - 5,?);';
execute stmt using @b, @a;
select @a;

set @b=10;
prepare stmt from 'call p1(?,?);';
execute stmt using @b,@a;
select @a;

deallocate prepare stmt;
drop procedure p1;