#owner: webber.wb
#owner group: sql4
#tags: pl, trigger
#description: mysql trigger

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
--sleep 2
connection default;

######################################### case1 start #########################################
--error 0,1051
drop table test;
--error 0,1051
drop table msg;
--error 0,1360
drop trigger tri_test_before_insert;
--error 0,1360
drop trigger tri_test_after_insert;
--error 0,1360
drop trigger tri_test_before_delete;
--error 0,1360
drop trigger tri_test_after_delete;

create table test(c1 int primary key, c2 int, c3 int);
create table msg (c1 int, c2 int, c3 int);

create trigger tri_test_before_insert before insert on test for each row
  insert into msg values (NEW.c1, NEW.c2, NEW.c3);

create trigger tri_test_after_insert after insert on test for each row
  insert into msg values (NEW.c3 + 1, NEW.c2 + 1, NEW.c1 + 1);

create trigger tri_test_before_delete before delete on test for each row
  insert into msg values (OLD.c3 + 1, OLD.c2 + 1, OLD.c1 + 1);

create trigger tri_test_after_delete after delete on test for each row
  insert into msg values (OLD.c3 + 100, OLD.c2 + 100, OLD.c1 + 100);

replace into test values (1, 2, 3);
replace into test values (10, 11, 12);

--sorted_result
select * from test;

--sorted_result
select * from msg;

delete from msg;

connect (obsys_for_load_data,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys_for_load_data;

--disable_query_log
let $HOST_IP = query_get_value('select host_ip()',host_ip(), 1);
let $DATA_FOLDER_NAME = data_for_mysqltest_loaddata;
let $SCP_CMD = ssh $HOST_IP 'mkdir -p "$OBSERVER_DIR/$DATA_FOLDER_NAME"' && scp -r $PWD/mysql_test/test_suite/pl/load_data/* $HOST_IP:"$OBSERVER_DIR/$DATA_FOLDER_NAME";
exec $SCP_CMD;
--enable_query_log

disconnect obsys_for_load_data;
connection default;

--error 1235
load data infile 'data_for_mysqltest_loaddata/pl_trigger_load_data_mysql.dat' replace into table test fields TERMINATED by ',';

--sorted_result
select * from msg;

drop table test;
drop table msg;

######################################### case1 end #########################################

######################################### case2 start #########################################
#######
--error 0,1051
drop table test;
--error 0,1051
drop table msg;
--error 0,1360
drop trigger tri_test_before_insert;

create table test(c1 int primary key, c2 int, c3 int);
create table msg (c1 int, c2 int, c3 int);

create trigger tri_test_before_insert before insert on test for each row
  insert into msg values (1, 2, 3);

connect (obsys_for_load_data,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys_for_load_data;

--disable_query_log
let $HOST_IP = query_get_value('select host_ip()',host_ip(), 1);
let $DATA_FOLDER_NAME = data_for_mysqltest_loaddata;
let $SCP_CMD = ssh $HOST_IP 'mkdir -p "$OBSERVER_DIR/$DATA_FOLDER_NAME"' && scp -r $PWD/mysql_test/test_suite/pl/load_data/* $HOST_IP:"$OBSERVER_DIR/$DATA_FOLDER_NAME";
exec $SCP_CMD;
--enable_query_log

disconnect obsys_for_load_data;
connection default;

--error 1235
load data infile 'data_for_mysqltest_loaddata/pl_trigger_load_data_mysql.dat' replace into table test fields TERMINATED by ',';

--sorted_result
select * from test;

--sorted_result
select * from msg;

drop table test;
drop table msg;
######################################### case2 end #########################################

connection syscon;
--sleep 2
