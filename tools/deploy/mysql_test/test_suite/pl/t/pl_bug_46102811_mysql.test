--result_format 4

--disable_warnings
drop procedure if exists p1;
--enable_warnings


# 存储函数
--error 0,1305
drop FUNCTION obwmj_f_test;
DELIMITER //;

CREATE FUNCTION obwmj_f_test()
returns varchar(200)
COMMENT "FUNCTION comments"
begin
    declare a varchar(200);
    SELECT sign(sal) FROM obwmj_t1 e WHERE sign(sal)=0 INTO a;
    return a;
END;
//

DELIMITER ;//

--replace_regex /[0-9]/A/g
SELECT ROUTINE_NAME,CREATED,LAST_ALTERED,ROUTINE_COMMENT,SQL_DATA_ACCESS FROM INFORMATION_SCHEMA.ROUTINES WHERE ROUTINE_SCHEMA='test' and SPECIFIC_NAME = 'obwmj_f_test';
select CREATED = LAST_ALTERED FROM INFORMATION_SCHEMA.ROUTINES WHERE ROUTINE_SCHEMA='test' and SPECIFIC_NAME = 'obwmj_f_test';

--sleep 3
ALTER FUNCTION obwmj_f_test COMMENT "FUNCTION new comments";
--replace_regex /[0-9]/A/g
SELECT ROUTINE_NAME,CREATED,LAST_ALTERED,ROUTINE_COMMENT,SQL_DATA_ACCESS FROM INFORMATION_SCHEMA.ROUTINES WHERE ROUTINE_SCHEMA='test' and SPECIFIC_NAME = 'obwmj_f_test';

ALTER FUNCTION obwmj_f_test NO SQL;
--replace_regex /[0-9]/A/g
SELECT ROUTINE_NAME,CREATED,LAST_ALTERED,ROUTINE_COMMENT,SQL_DATA_ACCESS FROM INFORMATION_SCHEMA.ROUTINES WHERE ROUTINE_SCHEMA='test' and SPECIFIC_NAME = 'obwmj_f_test';

select CREATED < LAST_ALTERED FROM INFORMATION_SCHEMA.ROUTINES WHERE ROUTINE_SCHEMA='test' and SPECIFIC_NAME = 'obwmj_f_test';


drop FUNCTION obwmj_f_test;


# 存储过程
--error 0,1305
drop PROCEDURE obwmj_p_test;

DELIMITER //;
CREATE PROCEDURE obwmj_p_test(in samplename  varchar(200)) 
COMMENT "PROCEDURE comments"
CONTAINS SQL
begin
    declare i int;
    declare a varchar(200);
    declare b varchar(200);
    SELECT sign(sal) FROM obwmj_t1 e WHERE sign(e.sal) = samplename into a;
    SELECT sign(sal) FROM obwmj_t1 e WHERE sign(e.sal) = samplename into b;
END;
//
DELIMITER ;//
--replace_regex /[0-9]/A/g
SELECT ROUTINE_NAME,CREATED,LAST_ALTERED,ROUTINE_COMMENT,SQL_DATA_ACCESS FROM INFORMATION_SCHEMA.ROUTINES WHERE ROUTINE_SCHEMA='test' and SPECIFIC_NAME = 'obwmj_p_test';
select CREATED = LAST_ALTERED FROM INFORMATION_SCHEMA.ROUTINES WHERE ROUTINE_SCHEMA='test' and SPECIFIC_NAME = 'obwmj_p_test';

--sleep 3
ALTER PROCEDURE obwmj_p_test COMMENT "PROCEDURE new comments";
select CREATED < LAST_ALTERED FROM INFORMATION_SCHEMA.ROUTINES WHERE ROUTINE_SCHEMA='test' and SPECIFIC_NAME = 'obwmj_p_test';
--replace_regex /[0-9]/A/g
SELECT ROUTINE_NAME,CREATED,LAST_ALTERED,ROUTINE_COMMENT,SQL_DATA_ACCESS FROM INFORMATION_SCHEMA.ROUTINES WHERE ROUTINE_SCHEMA='test' and SPECIFIC_NAME = 'obwmj_p_test';

ALTER PROCEDURE obwmj_p_test CONTAINS SQL;
--replace_regex /[0-9]/A/g
SELECT ROUTINE_NAME,CREATED,LAST_ALTERED,ROUTINE_COMMENT,SQL_DATA_ACCESS FROM INFORMATION_SCHEMA.ROUTINES WHERE ROUTINE_SCHEMA='test' and SPECIFIC_NAME = 'obwmj_p_test';


drop PROCEDURE obwmj_p_test;
