##########################test5  start##########################

--error 0,1051
drop table test;
--error 0,1051
drop table msg;
--error 0,1360
drop trigger tri_test_before_insert;
--error 0,1360
drop trigger tri_test_after_insert;
--error 0,1360
drop trigger tri_test_before_update;
--error 0,1360
drop trigger tri_test_after_update;

create table test(c1 int, c2 int, c3 int, primary key (c1));
create table msg (c1 int, c2 int, c3 int);

insert into test values (1, 2, 3),(2, 3, 4);

create trigger tri_test_before_insert before insert on test for each row
  insert into msg values (NEW.c1, NEW.c2, NEW.c3);

create trigger tri_test_after_insert after insert on test for each row
  insert into msg values (NEW.c3 + 1, NEW.c2 + 1, NEW.c1 + 1);

delimiter /;
create trigger tri_test_before_update before update on test for each row
begin
  insert into msg values (OLD.c3 + 1, OLD.c2 + 1, OLD.c1 + 1);
  insert into msg values (NEW.c3 * -1, NEW.c2 * -1, NEW.c1 * -1);
end;
/

create trigger tri_test_after_update after update on test for each row
begin
  insert into msg values (OLD.c3 + 100, OLD.c2 + 100, OLD.c1 + 100);
  insert into msg values (NEW.c3 * -100, NEW.c2 * -100, NEW.c1 * -100);
end;
/
delimiter ;/

insert into test values (1, 2, 3) on duplicate key update c2 = C2 + 100;

--sorted_result
select * from test;

--sorted_result
select * from msg;

delete from msg;

insert into test values (1, 2, 3), (2, 5, 10) on duplicate key update c2 = C2 + 100;

--sorted_result
select * from msg;

delete from msg;

insert into test values (1, 2, 3) on duplicate key update c2 = 202;

--sorted_result
select * from msg;

delete from msg;

insert into test values (3, 5, 10) on duplicate key update c2 = C2 + 100;

--sorted_result
select * from msg;

drop table test;
drop table msg;
##########################test5  end##########################

