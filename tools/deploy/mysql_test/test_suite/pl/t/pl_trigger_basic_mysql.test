##########################test7  start##########################
#### 测试 NEW.col, OLD.col 作为左值和右值
--error 0,1051
drop table test;
--error 0,1051
drop table msg;
--error 0,1051
drop table msg_update;
--error 0,1360
drop trigger tri_test_before_update;
--error 0,1360
drop trigger tri_test_after_update;

create table test(c1 int, c2 int, c3 int);
create table msg (c1 int, c2 int, c3 int);
create table msg_update (c1 int, c2 int, c3 int);

insert into test values (1, 2, 3);
insert into test values (10, 11, 12);
insert into msg_update values (1, 2, 100);
insert into msg_update values (10, 11, 12);

delimiter /;
create trigger tri_test_before_update before update on test for each row
begin
  declare a int;
  set NEW.c2 = NEW.c2 * 100;
  set a = OLD.c3 * -100;
  update msg_update set c2 = NEW.c2 where c1 = NEW.c1;
  insert into msg values (NEW.c1, NEW.c2, NEW.c3);
  insert into msg values (OLD.c1, OLD.c2, a);
end;
/

create trigger tri_test_after_update after update on test for each row
begin
  declare a int;
  set a = NEW.c1 * 222;
  delete from msg_update where c1 = NEW.c1 and c3 = NEW.c3;
  insert into msg values (a, NEW.c2 + 100, NEW.c1 + 100);
  insert into msg values (OLD.c3 + 100, OLD.c2 + 100, OLD.c1 + 100);
end;
/
delimiter ;/

update test set c2 = 10 where c1 = 1;

--sorted_result
select * from test;

--sorted_result
select * from msg;

--sorted_result
select * from msg_update;

delete from msg;

update test set c2 = 10 where c1 = 10 and c3 = 12;

--sorted_result
select * from test;

--sorted_result
select * from msg;

--sorted_result
select * from msg_update;

drop table msg;
drop table test;
drop table msg_update;

##########################test7  end##########################

