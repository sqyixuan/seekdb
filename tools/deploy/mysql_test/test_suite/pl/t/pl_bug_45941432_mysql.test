#owner: linlin.xll
#owner group: PL/SQL
#tags: pl

--result_format 4

--error 0,1051
drop table t0;
create table t0(c0 int);
insert into t0 values(1);
insert into t0 values(1);

--disable_warnings
drop procedure if exists p1;
drop procedure if exists p2;
--enable_warnings

delimiter /;

CREATE PROCEDURE p1()
begin
    declare v int default 1;
    declare c0 cursor for select * from t0;
    select count(*) from t0 where c0 = v;
end;
/

delimiter ;/
call p1();

drop table t0;
drop procedure p1;

delimiter /;

create procedure p1(x date) begin select x from dual; end;

create procedure p2()
begin
    set @a = date('1970-01-01');
    call p1(@a);
end;
/

delimiter ;/
call p2();

drop procedure p1;
drop procedure p2;




