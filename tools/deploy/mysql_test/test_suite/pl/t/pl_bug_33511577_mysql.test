--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: wangbai.wx
#owner group: sql4
#description: pl

--result_format 4

--disable_warnings
--error 0,1305
drop procedure pro1;
--enable_warnings


## case : 
## mysql.proc support time info

DELIMITER |;

create procedure pro1()
begin
  select 1;
end;|

DELIMITER ;|

--disable_result_log
select created, modified from mysql.proc where name like 'pro1';
--enable_result_log

drop procedure pro1;
