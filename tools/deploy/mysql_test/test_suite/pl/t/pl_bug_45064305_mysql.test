#owner: heyongyi.hyy
#owner group: sql4
#description: 
# 
--result_format 4

#case1
--disable_warnings
DROP PROCEDURE IF EXISTS p;
--enable_warnings

delimiter /;
create procedure p() 
begin 
declare count int default 3;
set count := count+1;
end;
/
delimiter ;/
call p;


#case2

--disable_warnings
DROP FUNCTION IF EXISTS f1;
--enable_warnings

delimiter /;
create function f1() returns int
begin 
    declare count int default 5;
    set count := count+1;
    return count;
end;
/
delimiter ;/
select f1() from dual;