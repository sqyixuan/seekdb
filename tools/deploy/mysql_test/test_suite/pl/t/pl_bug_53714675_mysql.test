--result_format 4
--disable_warnings

delimiter //;
DROP PROCEDURE IF EXISTS testIf;//
--error 1064
CREATE PROCEDURE testIf(OUT result VARCHAR(255))
BEGIN
     DECLARE val VARCHAR(255);
     SET val = 'a';
     IF (SELECT ST_SymDifference(point(1,0),point(1,0))) = ST_SymDifference(point(2,2,),point(2,2))
        THEN SET result = 'IS e';
        ELSE SET result = 'IS NOT e';
     END IF;
END //

CREATE PROCEDURE testIf(OUT result VARCHAR(255))
BEGIN
     DECLARE val VARCHAR(255);
     SET val = 'a';
     IF (SELECT ST_SymDifference(point(1,0),point(1,0))) = ST_SymDifference(point(2,2),point(2,2))
        THEN SET result = 'IS e';
        ELSE SET result = 'IS NOT e';
     END IF;
END //

DROP PROCEDURE IF EXISTS testIf;//
--error 1064
CREATE PROCEDURE testIf(OUT result VARCHAR(255))
BEGIN
     DECLARE val VARCHAR(255);
     SET val = 'a';
     IF (SELECT multipoint(point(1,2)) = multipoint(point(1,2),))
        THEN SET result = 'IS e';
        ELSE SET result = 'IS NOT e';
     END IF;
END //

CREATE PROCEDURE testIf(OUT result VARCHAR(255))
BEGIN
     DECLARE val VARCHAR(255);
     SET val = 'a';
     IF (SELECT multipoint(point(1,2)) = multipoint(point(1,2)))
        THEN SET result = 'IS e';
        ELSE SET result = 'IS NOT e';
     END IF;
END //

DROP PROCEDURE IF EXISTS testIf;//
--error 1064
CREATE PROCEDURE testIf(OUT result VARCHAR(255))
BEGIN
  DECLARE val VARCHAR(255);
  SET val = 'a';
  IF (SELECT nvl(1,2)) = nvl(2,)
  THEN SET result = 'IS e';
  ELSE SET result = 'IS NOT e';
  END IF;
END
//

CREATE PROCEDURE testIf(OUT result VARCHAR(255))
BEGIN
  DECLARE val VARCHAR(255);
  SET val = 'a';
  IF (SELECT nvl(1,2)) = nvl(2,1)
  THEN SET result = 'IS e';
  ELSE SET result = 'IS NOT e';
  END IF;
END
//
DROP PROCEDURE IF EXISTS testIf;//



