#owner: wangbai.wx
#owner group: pl/sql
#tags: pl
#description: test pl bug56636904

--result_format 4

--echo 

drop procedure if exists pl_test_56636904;
delimiter $$;
create procedure  pl_test_56636904(
IN num INTEGER,
IN tab_name VARCHAR (100)
)BEGIN
    DECLARE i int(100);
    set @ddl =concat( 'CREATE TABLE if not exists ', tab_name, ' (
        id int(11) NOT NULL,
        name varchar(256) DEFAULT NULL,
        value int(11) DEFAULT NULL)');
    prepare stmt from @ddl;
    execute stmt;
    drop prepare stmt;
    set i = 1;
    WHILE i <=num DO
        set @data=concat('insert into ', tab_name, ' values(', i, ',''Name'',', i,')');
        prepare stmt2 from @data;
        execute stmt2;
        drop prepare stmt2;
        set i = i + 1;
    END WHILE;
END;     
$$
delimiter ;$$

call pl_test_56636904(10, 'plan_test_56636904');

select query_sql, statement from oceanbase.gv$ob_plan_cache_plan_stat where sql_id = '20D01E7D05623FB1E4854B7A3DB67532' limit 1;

select query_sql from oceanbase.gv$ob_sql_audit where sql_id = '20D01E7D05623FB1E4854B7A3DB67532' order by request_time desc limit 1;

drop procedure if exists pl_test_56636904;
drop table plan_test_56636904;