#description: test tigger with if not exist
 
--result_format 4

--disable_warnings ONCE
DROP PROCEDURE IF EXISTS sp;
--disable_warnings ONCE
DROP FUNCTION IF EXISTS fn;

delimiter /;

# test function
create function if not exists fn(v int) RETURNS int begin return 1; end;/
show create function fn;/
 
create function if not exists fn(v int) RETURNS int begin return 1; end;/
show create function fn;/
 
--error 1304
create function fn(v int) RETURNS int begin return 1; end;/
show create function fn;/
 
drop function fn;/
 
create function fn(v int) RETURNS int begin return 1; end;/
show create function fn;/
 
create function if not exists fn(v int) RETURNS int begin return 1; end;/
show create function fn;/

# test procedure
CREATE PROCEDURE if not exists sp( cnt int(20) ) SELECT 1 + 1;/

show create procedure sp;/

CREATE PROCEDURE if not exists sp( cnt int(20) ) SELECT 1 + 1;/

show create procedure sp;/

--error 1304
CREATE PROCEDURE sp( cnt int(20) ) SELECT 1 + 1;/
show create procedure sp;/

drop procedure sp;/
 
CREATE PROCEDURE sp( cnt int(20) ) SELECT 1 + 1;/
show create procedure sp;/
 
CREATE PROCEDURE if not exists sp( cnt int(20) ) SELECT 1 + 1;/
show create procedure sp;/

delimiter ;/
drop function fn;
drop procedure sp;