#owner: heyongyi.hyy
#owner group: sql4
#tags: pl
#description: mysql pl do statement 

--result_format 4

--echo ############################start case 1############################

delimiter //;

SET @p1=1,@p2=2,@p3=3//

DO @p1+1,@p2,1+1//


--echo ############################start case 2############################

DO SLEEP(3)//
--disable_warnings
DROP TABLE IF EXISTS t1//
--enable_warnings
CREATE TABLE t1 (
  id INT
)//
INSERT INTO t1 VALUES(1),(1),(1)//

--error 1064
DO id FROM t1//

SET @p1=1,@p2=2,@p3=3//
--disable_warnings
DROP FUNCTION IF EXISTS `fun_2`//
--enable_warnings
CREATE FUNCTION fun_2() RETURNS VARCHAR(30)
BEGIN
  DECLARE a INT DEFAULT 5+1;  
  SET @p1=@p1+1,@p2=@p2+1,@p3=@p3+1;
  RETURN a;
END//
DO fun_2(),fun_2()//
SELECT @p1,@p2,@p3//

--echo ############################start case 3############################

--disable_warnings
DROP FUNCTION IF EXISTS `fun_1`//
--enable_warnings

--error 1064
CREATE FUNCTION fun_1() RETURNS VARCHAR(30)
BEGIN
  DO id FROM t1;
  RETURN 'DO 执行完了';
END//
--error 1305
SELECT fun_1()//

--disable_warnings
DROP FUNCTION IF EXISTS `fun_3`//
--enable_warnings

CREATE FUNCTION fun_3() RETURNS VARCHAR(30)
BEGIN
  DO SLEEP(1);
  RETURN 'DO 执行完了';
END//
SELECT fun_3()//

delimiter ;//

drop table t1;
drop function fun_2;
drop function fun_3;