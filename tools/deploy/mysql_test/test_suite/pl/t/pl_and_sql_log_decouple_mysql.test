#owner: heyongyi.hyy
#owner group: pl/sql
#tags: pl
#description: test sql audit after pl & sql log decouple

--result_format 4

--disable_warnings
drop table if exists t;
drop function if exists a;
drop function if exists b;
drop procedure if exists c;
drop function if exists outer_function;
--enable_warnings

create table t(i int);
insert into t values(1);

alter system flush sql audit global;

delimiter /;

create function a() returns int
begin
declare res int;
select avg(i) into res from t;
return res;
end;
/

create function b() returns int
begin
declare res int;
select a+sum(i) into res from t;
return res;
end;
/

create procedure c(ident varchar(128))
begin
declare res int;
select a+b into res from dual;
end;
/

delimiter ;/

call c('pl & sql log decouple test mysql 1');

select trace_id into @pl_trace_id from oceanbase.__all_virtual_sql_audit where query_sql like '%pl & sql log decouple test mysql 1%';

select query_sql from oceanbase.__all_virtual_sql_audit where pl_trace_id=@pl_trace_id order by query_sql;

select count(distinct trace_id) from oceanbase.__all_virtual_sql_audit where pl_trace_id=@pl_trace_id order by query_sql;

drop procedure c;
drop function b;
drop function a;

delimiter /;

create function a() returns int
begin
declare res int;
select avg(i) into res from t;
return res;
end;
/

create function b() returns int
begin
declare res int;
select a+sum(i) into res from t;
return res;
end;
/

create function outer_function(ident varchar(128)) returns int
begin
declare res int;
select a+b into res from dual;
return res;
end;
/

delimiter ;/

select outer_function('pl & sql log decouple test mysql 2');

select trace_id into @pl_trace_id from oceanbase.__all_virtual_sql_audit where query_sql like '%pl & sql log decouple test mysql 2%';

select query_sql from oceanbase.__all_virtual_sql_audit where pl_trace_id=@pl_trace_id order by query_sql;

select count(distinct trace_id) from oceanbase.__all_virtual_sql_audit where pl_trace_id=@pl_trace_id order by query_sql;

drop function outer_function;
drop function b;
drop function a;

delimiter /;

create function a() returns int
begin
declare res int;
declare done int default false;
declare cur cursor for select avg(i) from t;
declare continue handler for not found set done = true;
open cur;
cursor_loop: loop
fetch cur into res;
if done then
leave cursor_loop;
end if;
end loop;
close cur;
return res;
end;
/

create function b() returns int
begin
declare res int;
select a+sum(i) into res from t;
return res;
end;
/

create procedure c(ident varchar(128))
begin
declare res int;
select a+b into res from dual;
end;
/

delimiter ;/

call c('pl & sql log decouple test mysql 3');

select trace_id into @pl_trace_id from oceanbase.__all_virtual_sql_audit where query_sql like '%pl & sql log decouple test mysql 3%';

select query_sql from oceanbase.__all_virtual_sql_audit where pl_trace_id=@pl_trace_id order by query_sql;

select count(distinct trace_id) from oceanbase.__all_virtual_sql_audit where pl_trace_id=@pl_trace_id order by query_sql;

drop procedure c;
drop function b;
drop function a;

drop table t;
