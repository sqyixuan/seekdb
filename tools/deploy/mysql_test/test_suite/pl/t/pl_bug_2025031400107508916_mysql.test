#owner: wangbai.wx
#owner group: PL/SQL
#tags: pl
#description: fix bug 2025031400107508916

drop procedure IF EXISTS my_pro;
drop procedure IF EXISTS my_pro1;
drop function IF EXISTS my_fun;
delimiter /;

CREATE PROCEDURE my_pro()
BEGIN
  declare v1 SERIAL;
  set v1 = 1;
  select v1;
END;
/

CREATE PROCEDURE my_pro1(a SERIAL)
BEGIN
  select a;
END;
/

CREATE function my_fun() returns SERIAL
BEGIN
  return 1;
END;
/

delimiter ;/
call my_pro();
SET @pt = 1;
call my_pro1(@pt);
select my_fun();

drop procedure my_pro;
drop procedure my_pro1;
drop function my_fun;