#owner: jiabokai.jbk
#owner group: PL/SQL
#tags: pl
#description: test outline concurrent binding by sql id

--result_format 4

--error 0,5265
drop outline udf_ol;
--error 0,5265
drop outline proc_ol;
--error 0,1305
drop PROCEDURE Getnumber;
--error 0,1305
drop FUNCTION add_numbers;

alter system flush pl cache global;
delimiter $;
CREATE PROCEDURE Getnumber(IN a INT)
BEGIN
set a = a+1;
END
$

call Getnumber(1);
$

select STATEMENT,SQL_ID,HIT_COUNT,OUTLINE_DATA from oceanbase.__all_virtual_plan_stat 
    WHERE OBJECT_STATUS = 0 AND TYPE > 5 AND TYPE < 11 
        AND is_in_pc=true and STATEMENT like '%Getnumber%';
$

CREATE OR REPLACE OUTLINE proc_ol ON 'D42654F69DE0F81C83F51D8621796276' USING HINT /*+ max_concurrent(0) */;
$

--error 5268
call Getnumber(1);
$

select STATEMENT,SQL_ID,HIT_COUNT,OUTLINE_DATA from oceanbase.__all_virtual_plan_stat 
    WHERE OBJECT_STATUS = 0 AND TYPE > 5 AND TYPE < 11 
        AND is_in_pc=true and STATEMENT like '%Getnumber%';
$

CREATE FUNCTION `add_numbers`(a INT, b INT) RETURNS INT
BEGIN
    RETURN a + b;
END
$

select add_numbers(1,2);
$

select STATEMENT,SQL_ID,HIT_COUNT,OUTLINE_DATA from oceanbase.__all_virtual_plan_stat 
    WHERE OBJECT_STATUS = 0 AND TYPE > 5 AND TYPE < 11 
        AND is_in_pc=true and STATEMENT like '%add_numbers%';
$

CREATE OR REPLACE OUTLINE udf_ol ON 'CA251D45A0450ACA0FE439B9F9905453' USING HINT /*+ max_concurrent(0) */;
$
--error 5268
select add_numbers(1,2);
$

select STATEMENT,SQL_ID,HIT_COUNT,OUTLINE_DATA from oceanbase.__all_virtual_plan_stat 
    WHERE OBJECT_STATUS = 0 AND TYPE > 5 AND TYPE < 11 
        AND is_in_pc=true and STATEMENT like '%add_numbers%';
$


delimiter ;$

drop outline udf_ol;
drop outline proc_ol;
call Getnumber(1);
select add_numbers(1,2);
select STATEMENT,SQL_ID,HIT_COUNT,OUTLINE_DATA from oceanbase.__all_virtual_plan_stat 
    WHERE OBJECT_STATUS = 0 AND TYPE > 5 AND TYPE < 11 
        AND is_in_pc=true and STATEMENT like '%Getnumber%';

select STATEMENT,SQL_ID,HIT_COUNT,OUTLINE_DATA from oceanbase.__all_virtual_plan_stat 
    WHERE OBJECT_STATUS = 0 AND TYPE > 5 AND TYPE < 11 
        AND is_in_pc=true and STATEMENT like '%add_numbers%';

drop PROCEDURE Getnumber;
drop FUNCTION add_numbers;