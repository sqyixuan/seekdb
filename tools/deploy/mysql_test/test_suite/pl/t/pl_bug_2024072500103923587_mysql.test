#owner: xinning.lf
#owner group: pl/sql
#tags: pl
#description: test information_schema.parameters COLLATION_NAME column and mysql.proc returns column

--result_format 4

delimiter //;
drop PROCEDURE if exists proc_param_collate_01; //
CREATE PROCEDURE proc_param_collate_01(IN empId TEXT CHARACTER SET latin1 COLLATE latin1_bin)
BEGIN
    DECLARE baseSalary DECIMAL(10,2); 
    set @a= empId;
END; //

drop PROCEDURE if exists proc_param_collate_02;//
CREATE PROCEDURE proc_param_collate_02(IN utf8mb4_general_ci TEXT CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci,
in utf8mb4_bin text CHARACTER set utf8mb4 COLLATE utf8mb4_general_ci,
in c_binary text CHARACTER set binary,
in gb18030_2022_radical_ci text CHARACTER set gb18030_2022 COLLATE gb18030_2022_radical_ci,
in gb18030_2022_chinese_ci text CHARACTER set gb18030_2022 COLLATE gb18030_2022_chinese_ci
)
BEGIN
    DECLARE baseSalary DECIMAL(10,2); 
END; //


drop PROCEDURE if exists proc_param_collate_03;//
CREATE PROCEDURE proc_param_collate_03(IN empId TEXT CHARACTER SET binary)
BEGIN
    DECLARE baseSalary DECIMAL(10,2); 
END; //

DELIMITER ;//

SELECT PARAMETER_NAME, CHARACTER_SET_NAME, COLLATION_NAME FROM information_schema.parameters WHERE SPECIFIC_NAME like 'proc_param_collate_0%';

drop procedure proc_param_collate_01;
drop procedure proc_param_collate_02;
drop procedure proc_param_collate_03;


DELIMITER //;
drop FUNCTION if exists func_returns_collate_01;//
CREATE FUNCTION func_returns_collate_01(birthDate CHAR(20))
RETURNS  CHAR(20) CHARACTER SET latIN1 COLLATe latin1_bin DETERMINISTIC
BEGIN
    RETURN birthDate;
END; //

drop FUNCTION if exists func_returns_collate_02;//
CREATE FUNCTION func_returns_collate_02(birthDate CHAR(20))
RETURNS  CHAR(20) CHARACTER SET binary DETERMINISTIC
BEGIN
    RETURN birthDate;
END; //

drop FUNCTION if exists func_returns_collate_03;//
CREATE FUNCTION func_returns_collate_03(birthDate char(20))
RETURNS CHAR(20) CHARACTER SET gbk COLLATe gbk_bin DETERMINISTIC
BEGIN
    RETURN birthDate;
END; //

drop FUNCTION if exists func_returns_collate_04;//
CREATE FUNCTION func_returns_collate_04(birthDate char(20))
RETURNS CHAR(20) CHARACTER SET utf8mb4 COLLATe utf8mb4_general_ci DETERMINISTIC
BEGIN
    RETURN birthDate;
END; //

drop FUNCTION if exists func_returns_collate_05;//
CREATE FUNCTION func_returns_collate_05(birthDate char(20))
RETURNS CHAR(20) CHARACTER SET utf8mb4 COLLATe utf8mb4_bin DETERMINISTIC
BEGIN
    RETURN birthDate;
END; //

drop FUNCTION if exists func_returns_collate_06;//
CREATE FUNCTION func_returns_collate_06(birthDate char(20))
RETURNS CHAR(20) CHARACTER SET gbk COLLATe gbk_chinese_ci DETERMINISTIC
BEGIN
    RETURN birthDate;
END; //

drop FUNCTION if exists func_returns_collate_07;//
CREATE FUNCTION func_returns_collate_07(birthDate char(20))
RETURNS CHAR(20) CHARACTER SET gbk DETERMINISTIC
BEGIN
    RETURN birthDate;
END; //

drop FUNCTION if exists func_returns_collate_08;//
CREATE FUNCTION func_returns_collate_08(birthDate char(20))
RETURNS CHAR(20) DETERMINISTIC
BEGIN
    RETURN birthDate;
END; //

drop FUNCTION if exists func_returns_collate_09;//
CREATE FUNCTION func_returns_collate_09(birthDate varchar(20))
RETURNS  varchar(20) CHARACTER SET latIN1 COLLATe latin1_bin DETERMINISTIC
BEGIN
    RETURN birthDate;
END; //

drop FUNCTION if exists func_returns_collate_10;//
CREATE FUNCTION func_returns_collate_10(birthDate nvarchar(20))
RETURNS  nvarchar(20) DETERMINISTIC
BEGIN
    RETURN birthDate;
END; //

drop FUNCTION if exists func_returns_collate_11;//
CREATE FUNCTION func_returns_collate_11(birthDate nchar(20))
RETURNS  nchar(20) DETERMINISTIC
BEGIN
    RETURN birthDate;
END; //

drop FUNCTION if exists func_returns_collate_12;//
CREATE FUNCTION func_returns_collate_12(birthDate text)
RETURNS text CHARACTER SET latIN1 COLLATe latin1_bin DETERMINISTIC
BEGIN
    RETURN birthDate;
END; //

drop FUNCTION if exists func_returns_collate_13;//
CREATE FUNCTION func_returns_collate_13(birthDate blob)
RETURNS blob DETERMINISTIC
BEGIN
    RETURN birthDate;
END; //

DELIMITER ;//
select name,returns from mysql.proc where NAME like 'func_returns_collate_%' order by name;

drop function func_returns_collate_01;
drop function func_returns_collate_02;
drop function func_returns_collate_03;
drop function func_returns_collate_04;
drop function func_returns_collate_05;
drop function func_returns_collate_06;
drop function func_returns_collate_07;
drop function func_returns_collate_08;
drop function func_returns_collate_09;
drop function func_returns_collate_10;
drop function func_returns_collate_11;
drop function func_returns_collate_12;
