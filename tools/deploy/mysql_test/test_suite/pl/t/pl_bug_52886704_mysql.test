#owner: linlin.xll
#owner group: pl/sql
#tags: pl
#description: test pl bugs
 
--result_format 4
--disable_warnings


delimiter //;
DROP FUNCTION IF EXISTS fn1;//
CREATE FUNCTION fn1( f1 ENUM("value1", "value2") ) RETURNS DECIMAL(63, 30)
   NO SQL COMMENT 'this is simple'
BEGIN
   RETURN f1;
END//
delimiter ;//

SELECT fn1( "value1" );
SELECT fn1( "value2" );

delimiter //;
DROP FUNCTION IF EXISTS fn1;//
CREATE FUNCTION fn1( f1 SET("value1", "value2") ) RETURNS DECIMAL(63, 30)
   NO SQL COMMENT 'this is simple'
BEGIN
   RETURN f1;
END//
delimiter ;//

--error 1265
SELECT fn1( "value1, value2" );
SELECT fn1( "value1,value2"  );

DROP FUNCTION fn1;
