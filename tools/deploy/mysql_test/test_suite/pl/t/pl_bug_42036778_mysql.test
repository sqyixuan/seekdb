#owner: heyongyi.hyy
#owner group: sql4
#tags: pl
#description: 

--result_format 4

--error 1643
SIGNAL SQLSTATE '02000';

--error 2222
SIGNAL SQLSTATE '02000' SET MESSAGE_TEXT = '【SIGNAL】An 02xxx occurred', MYSQL_ERRNO = 2222;

--error 1645
RESIGNAL SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 1111;

SIGNAL SQLSTATE '01000' SET MESSAGE_TEXT = '【SIGNAL】WARNING', MYSQL_ERRNO = 2222;

--error 1407
SIGNAL SQLSTATE '00000';

--error 1407
SIGNAL SQLSTATE '00000' SET MESSAGE_TEXT = '【SIGNAL】', MYSQL_ERRNO = 2222;

--disable_warnings
DROP PROCEDURE IF EXISTS p;
--enable_warnings

--error 1407
CREATE PROCEDURE p() SIGNAL SQLSTATE '00000';
--error 1305
CALL p();
--error 1407
CREATE PROCEDURE p() RESIGNAL SQLSTATE '00000';
--error 1305
CALL p();

CREATE PROCEDURE p() SIGNAL SQLSTATE '02000';
--error 1643
CALL p();
DROP PROCEDURE p;
CREATE PROCEDURE p() SIGNAL SQLSTATE '02000' SET MESSAGE_TEXT = '【SIGNAL】An 02xxx occurred', MYSQL_ERRNO = 2222;
--error 2222
CALL p();
DROP PROCEDURE p;
CREATE PROCEDURE p() RESIGNAL SQLSTATE '02000';
--error 1645
CALL p();
DROP PROCEDURE p;

CREATE PROCEDURE p() DO SQRT(1);
CALL p();
DROP PROCEDURE p;
CREATE PROCEDURE p() DO SQRT(1),SQRT(1),SQRT(1);
CALL p();
DROP PROCEDURE p;

delimiter /;
--error 1407
CREATE PROCEDURE p() BEGIN SIGNAL SQLSTATE '00000'; END;/
--error 1305
CALL p()/
--error 1407
CREATE PROCEDURE p() BEGIN RESIGNAL SQLSTATE '00000'; END;/
--error 1305
CALL p()/

CREATE PROCEDURE p() BEGIN SIGNAL SQLSTATE '02000'; END;/
--error 1643
CALL p()/
DROP PROCEDURE p/
CREATE PROCEDURE p() BEGIN RESIGNAL SQLSTATE '02000'; END;/
--error 1645
CALL p()/
DROP PROCEDURE p/
delimiter ;/
