#owner: jiabokai.jbk
#owner group: SQL-SQL4 PL/SQL
#tags: pl

--result_format 4
--disable_warnings
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;
DELIMITER /;
#package
CREATE OR REPLACE PACKAGE TEST_PKG
  procedure disable();
end;
/
CREATE OR REPLACE PACKAGE BODY TEST_PKG
  declare enabled         BOOLEAN DEFAULT FALSE;
  procedure disable()
  BEGIN
    set enabled = false;
  END;
end;
/
call TEST_PKG.disable();/

DELIMITER ;/
connection default;

--error 0,1396
DROP USER hr;

CREATE USER 'hr' IDENTIFIED BY 'hr';
GRANT all ON *.* TO hr WITH GRANT OPTION;

--error 0,1008
DROP DATABASE henry;
CREATE DATABASE henry;
use henry;
--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,hr,hr,henry,$OBMYSQL_PORT);

connection conn1;
create table t2(c1 int);
insert into t2 value(1);
delimiter /;

#procedure
create procedure test_p2()
begin
  declare a int;
  declare b int;
  set b = 1;
  select count(*) into a from t2 where c1 = b;
  select a;
end;
/
--error 0,1360
drop trigger test_trig;/

#trigger
CREATE trigger test_trig after insert on t2
for each row
begin
set @c=(select '测试');
end;
/
insert into t2 value(2);/

#udf
CREATE FUNCTION test_func() RETURNS VARCHAR(30)
BEGIN
    DECLARE A VARCHAR(200);
    SELECT CONCAT('111', '222', '333') FROM DUAL INTO A;
    RETURN A;
END;/

DELIMITER ;/
SELECT test_func();
call test_p2();


connection conn_admin;
use oceanbase;
--sorted_result
select PARAMETERIZE_TEXT from GV$ob_pl_cache_object where PARAMETERIZE_TEXT like '%TEST%' order by LAST_ACTIVE_TIME;
use test;
drop package TEST_PKG;
use oceanbase;
--sorted_result
select PARAMETERIZE_TEXT from GV$ob_pl_cache_object where PARAMETERIZE_TEXT like '%TEST%' order by LAST_ACTIVE_TIME;

connection conn1;
drop FUNCTION test_func;
drop trigger test_trig;
drop procedure test_p2;

use oceanbase;
--sorted_result
select PARAMETERIZE_TEXT from GV$ob_pl_cache_object where PARAMETERIZE_TEXT like '%TEST%' order by LAST_ACTIVE_TIME;

use henry;
DELIMITER /;
#procedure
create procedure test_p2()
begin
  declare a int;
  declare b int;
  set b = 1;
  select count(*) into a from t2 where c1 = b;
  select a;
end;
/
--error 0,1360
drop trigger test_trig;/

#trigger
CREATE trigger test_trig after insert on t2
for each row
begin
set @c=(select '测试');
end;
/
insert into t2 value(2);/

CREATE FUNCTION test_func() RETURNS VARCHAR(30)
BEGIN
    DECLARE A VARCHAR(200);
    SELECT CONCAT('111', '222', '333') FROM DUAL INTO A;
    RETURN A;
END;/

DELIMITER ;/
SELECT test_func();
call test_p2();

use oceanbase;
--sorted_result
select PARAMETERIZE_TEXT from GV$ob_pl_cache_object where PARAMETERIZE_TEXT like '%TEST%' order by LAST_ACTIVE_TIME;

drop database henry;
DROP USER hr;
#the pl cache will be truly deleted after clearing RECYCLEBIN
PURGE RECYCLEBIN;
--sorted_result
select PARAMETERIZE_TEXT from GV$ob_pl_cache_object where PARAMETERIZE_TEXT like '%TEST%' order by LAST_ACTIVE_TIME;

connection default;
