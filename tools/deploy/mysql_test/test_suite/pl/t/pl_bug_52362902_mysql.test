#owner: hr351303
#owner group: sql4-PL/SQL
#tags: pl
#description: test pl bug

--result_format 4

--disable_warnings

DROP PROCEDURE if EXISTS PROCEDURE_1;
DELIMITER /;
CREATE  PROCEDURE PROCEDURE_1(in aa time,out bb date)
begin
select aa into bb;
end;
/
DELIMITER ;/

select '12:12:12' into @aa from dual;

call PROCEDURE_1(@aa,@bb);

select 1 where current_date=@bb;

drop PROCEDURE PROCEDURE_1;