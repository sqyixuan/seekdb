#owner group: pl/sql
#tags: pl
#description: test pl bugs

--result_format 4

SET @@sql_mode='';

delimiter //;
DROP PROCEDURE IF EXISTS sp2;//
CREATE PROCEDURE sp2()
BEGIN
   SET @@sql_mode=default;
   SHOW VARIABLES LIKE 'sql_mode';
END//
delimiter ;//

SHOW VARIABLES LIKE 'sql_mode';
CALL sp2();
SHOW VARIABLES LIKE 'sql_mode';

SET @@sql_mode=default;
