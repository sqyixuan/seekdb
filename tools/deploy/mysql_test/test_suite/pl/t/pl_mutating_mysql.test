############################## case 9
### delete triggers the update statement in the trigger

create table t1(id int);
create table t2(id int);

insert into t1 values (1);
insert into t2 values (100);

create trigger tri_t1 before delete on t1 for each row
  update t1 set id = 10;

--error 1442
delete from t1;

drop trigger tri_t1;

create trigger tri_t1 after delete on t1 for each row
  update t1 set id = 10;

--error 1442
delete from t1;

drop table t1;
drop table t2;
############################## case 10
### delete triggers the insert statement in the trigger

create table t1(id int);
create table t2(id int);

insert into t1 values (1);
insert into t2 values (100);

create trigger tri_t1 before delete on t1 for each row
  insert into t1 values (1);

--error 1442
delete from t1;

