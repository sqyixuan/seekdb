############################## case 11
### delete,update,delete triggers the select statement in the trigger

create table t1(id int);
create table t2(id int);

insert into t1 values (1);
insert into t2 values (100);

create trigger tri_t1 before delete on t1 for each row
  select count(*) into @cnt from t1;

--error 1442
delete from t1;

drop trigger tri_t1;

create trigger tri_t1 after delete on t1 for each row
  select count(*) into @cnt from t1;

--error 1442
delete from t1;


drop trigger tri_t1;

create trigger tri_t1 before insert on t1 for each row
  select count(*) into @cnt from t1;

insert into t1 values (2);

drop trigger tri_t1;

create trigger tri_t1 after insert on t1 for each row
  select count(*) into @cnt from t1;

insert into t1 values (2);
--error 1442
insert into t1 values (3),(4);



drop trigger tri_t1;

create trigger tri_t1 before update on t1 for each row
  select count(*) into @cnt from t1;

--error 1442
update t1 set id = 100;

drop trigger tri_t1;

create trigger tri_t1 after update on t1 for each row
  select count(*) into @cnt from t1;

--error 1442
update t1 set id = 100;



drop table t1;
drop table t2;

##分区表场景下mysql 模式，子语句写，父语句读相同表的mutating检查
create table t1 (c1 int primary key, c2 varchar(128),c3 float) partition by key(c1) partitions 3;
create table t2 (a1 int primary key, a2 varchar(128),a3 float) partition by key(a1) partitions 3;
insert into t1 values(2,'dddd',2.32);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);

create trigger tr1 before delete on t1 for each row
  update t2 set a1=3 where a2='ssss';

--error 1442
DELETE  a FROM t1 AS a LEFT JOIN t2 AS b ON a.c1 = b.a1 WHERE b.a1 > 0;

drop table t1;
drop table t2;