--disable_query_log
#set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: luofan.zp
#owner group: SQL2
#description: 支持call procedure参数不同，生成唯一的sql_id
#tags: pl

use test;
set sql_mode=default;
--disable_warnings
drop table if exists t1;
drop procedure if exists bar;
--enable_warnings
create table t1 (c1 int, c2 varchar(64));
create procedure bar(x int, y char(64))
  insert into t1 values (x, y);

call bar(1, '111');
select sql_id, query_sql from oceanbase.GV$OB_SQL_AUDIT where query_sql = "call bar(1, '111')";
call bar(2, '222');
select sql_id, query_sql from oceanbase.GV$OB_SQL_AUDIT where query_sql = "call bar(2, '222')";
call bar(3, '333');
select sql_id, query_sql from oceanbase.GV$OB_SQL_AUDIT where query_sql = "call bar(3, '333')";
call bar(4, '444');
select sql_id, query_sql from oceanbase.GV$OB_SQL_AUDIT where query_sql = "call bar(4, '444')";


--disable_warnings
drop procedure if exists bar;
drop table if exists t1;
--enable_warnings
