    DECLARE geometrycollection_var polygon;;
    SET geometrycollection_var = ST_GeomFromText('GEOMETRYCOLLECTION(POINT(3 3), LINESTRING(2 2, 4 4), POLYGON((2 2, 2 3, 3 3, 3 2, 2 2)))');
