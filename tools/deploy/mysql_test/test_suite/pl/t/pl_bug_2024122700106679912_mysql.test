## test LINESTRING
delimiter /;
create procedure test_linestring (IN a linestring) begin    
SET @greeting = 'Hello';    
SET @name = 'Linestring';    
SELECT CONCAT(@greeting, ',', @name, '!'); 
SELECT id, name, ST_AsText(path) AS path_as_text FROM routes WHERE ST_Intersects(path, a);
end;
/

CREATE PROCEDURE linestring_example()
BEGIN
    DECLARE linestring_var linestring;;
    SET linestring_var = ST_GeomFromText('LINESTRING(1 1, 6 6)');
    SELECT ST_Length(linestring_var) AS length;
END 
/

CREATE FUNCTION create_linestring(
    x1 DOUBLE, 
    y1 DOUBLE,
    x2 DOUBLE, 
    y2 DOUBLE
) 
RETURNS linestring
BEGIN
    DECLARE linestring_text VARCHAR(10000) DEFAULT 'LINESTRING(';
    SET linestring_text = CONCAT(linestring_text, x1, ' ',  y1, ',', x2, ' ', y2, ')');
    RETURN ST_GeomFromText(linestring_text);
END
/

delimiter ;/
SET @pt = ST_GeomFromText('LINESTRING(1 1, 6 6)');
CALL test_linestring(@pt);
call linestring_example();
SELECT ST_AsText(create_linestring(0, 0, 20, 20));
CALL test_linestring(create_linestring(0, 0, 25, 25));
show create procedure test_linestring;
show create procedure linestring_example;
show create function create_linestring;
--replace_column 13 time 14 time
SELECT * from mysql.proc where specific_name='test_linestring';
--replace_column 13 time 14 time
SELECT * from mysql.proc where specific_name='linestring_example';
--replace_column 13 time 14 time
SELECT * from mysql.proc where specific_name='create_linestring';
## test polygon
delimiter /;
create procedure test_polygon (IN a polygon) begin    
SET @greeting = 'Hello';    
SET @name = 'Polygon';    
SELECT CONCAT(@greeting, ',', @name, '!'); 
SELECT ST_Area(a) AS area_size;
end;
/

CREATE PROCEDURE polygon_example()
BEGIN
    DECLARE polygon_var polygon;;
    SET polygon_var = ST_GeomFromText('POLYGON((5 5, 5 15, 15 15, 15 5, 5 5))');
    SELECT ST_Area(polygon_var) AS area_size;
END 
/

CREATE FUNCTION create_polygon(
    x1 DOUBLE, 
    y1 DOUBLE,
    x2 DOUBLE, 
    y2 DOUBLE
) 
RETURNS polygon
BEGIN
    DECLARE polygon_text VARCHAR(10000) DEFAULT 'POLYGON((';
    SET polygon_text = CONCAT(polygon_text, x1, ' ',  y1, ',', x1, ' ', y2, ',',  x2, ' ', y2, ',',  x2, ' ', y1, ',',  x1, ' ', y1, '))');
    RETURN ST_GeomFromText(polygon_text);
END
/

delimiter ;/
SET @pt = ST_GeomFromText('POLYGON((5 5, 5 15, 15 15, 15 5, 5 5))');
CALL test_polygon(@pt);
call polygon_example();
SELECT ST_AsText(create_polygon(0, 0, 20, 20));
CALL test_polygon(create_polygon(0, 0, 25, 25));
show create procedure test_polygon;
show create procedure polygon_example;
show create function create_polygon;
--replace_column 13 time 14 time
SELECT * from mysql.proc where specific_name='test_polygon';
--replace_column 13 time 14 time
SELECT * from mysql.proc where specific_name='polygon_example';
--replace_column 13 time 14 time
SELECT * from mysql.proc where specific_name='create_polygon';
## test multipoint
delimiter /;
create procedure test_multipoint (IN a multipoint) begin    
SET @greeting = 'Hello';    
SET @name = 'Multipoint';    
SELECT CONCAT(@greeting, ',', @name, '!'); 
SELECT id, name, ST_AsText(locations) AS locations_as_text FROM landmarks WHERE ST_Intersects(locations, a);
end;
/

CREATE PROCEDURE multipoint_example()
BEGIN
    DECLARE multipoint_var polygon;;
    SET multipoint_var = ST_GeomFromText('MULTIPOINT((1 1), (3 3))');
    SELECT id, name, ST_AsText(locations) AS locations_as_text FROM landmarks WHERE ST_Intersects(locations, multipoint_var);
END 
/

CREATE FUNCTION create_multipoint(
    x1 DOUBLE, 
    y1 DOUBLE,
    x2 DOUBLE, 
    y2 DOUBLE
) 
RETURNS multipoint
BEGIN
    DECLARE multipoint_text VARCHAR(10000) DEFAULT 'MULTIPOINT((';
    SET multipoint_text = CONCAT(multipoint_text, x1, ' ',  y1, '),(', x2, ' ', y2, '))');
    RETURN ST_GeomFromText(multipoint_text);
END
/

delimiter ;/
SET @pt = ST_GeomFromText('MULTIPOINT((1 1), (2 2))');
CALL test_multipoint(@pt);
call multipoint_example();
SELECT ST_AsText(create_multipoint(0, 0, 20, 20));
CALL test_multipoint(create_multipoint(0, 0, 25, 25));
show create procedure test_multipoint;
show create procedure multipoint_example;
show create function create_multipoint;
--replace_column 13 time 14 time
SELECT * from mysql.proc where specific_name='test_multipoint';
--replace_column 13 time 14 time
SELECT * from mysql.proc where specific_name='multipoint_example';
--replace_column 13 time 14 time
SELECT * from mysql.proc where specific_name='create_multipoint';
## test multilinestring
delimiter /;
create procedure test_multilinestring (IN a multilinestring) begin    
SET @greeting = 'Hello';    
SET @name = 'Multilinestring';    
SELECT CONCAT(@greeting, ',', @name, '!'); 
SELECT ST_Length(a) AS total_length;
end;
/

CREATE PROCEDURE multilinestring_example()
BEGIN
    DECLARE multilinestring_var polygon;;
    SET multilinestring_var = ST_GeomFromText('MULTILINESTRING((0 0, 1 1), (2 2, 3 3))');
    SELECT ST_Length(multilinestring_var) AS total_length;
END 
/

CREATE FUNCTION create_multilinestring(
    x1 DOUBLE, 
    y1 DOUBLE,
    x2 DOUBLE, 
    y2 DOUBLE,
    m1 DOUBLE, 
    n1 DOUBLE,
    m2 DOUBLE, 
    n2 DOUBLE
) 
RETURNS multilinestring
BEGIN
    DECLARE multilinestring_text VARCHAR(10000) DEFAULT 'MULTILINESTRING((';
    SET multilinestring_text = CONCAT(multilinestring_text, x1, ' ',  y1, ',', x2, ' ', y2, '),(',  m1, ' ',  n1, ',', m2, ' ', n2, '))');
    RETURN ST_GeomFromText(multilinestring_text);
END
/

delimiter ;/
SET @pt = ST_GeomFromText('MULTILINESTRING((4 4, 5 5), (6 6, 7 7))');
CALL test_multilinestring(@pt);
call multilinestring_example();
SELECT ST_AsText(create_multilinestring(0, 0, 20, 20, 0, 0, 10, 10));
CALL test_multilinestring(create_multilinestring(0, 0, 25, 25, 0, 0, 15, 15));
show create procedure test_multilinestring;
show create procedure multilinestring_example;
show create function create_multilinestring;
--replace_column 13 time 14 time
SELECT * from mysql.proc where specific_name='test_multilinestring';
--replace_column 13 time 14 time
SELECT * from mysql.proc where specific_name='multilinestring_example';
--replace_column 13 time 14 time
SELECT * from mysql.proc where specific_name='create_multilinestring';
## test multipolygon
delimiter /;
create procedure test_multipolygon (IN a multipolygon) begin    
SET @greeting = 'Hello';    
SET @name = 'Multipolygon';    
SELECT CONCAT(@greeting, ',', @name, '!'); 
SELECT ST_Area(a) AS total_area;
end;
/

CREATE PROCEDURE multipolygon_example()
BEGIN
    DECLARE multipolygon_var Multipolygon;;
    SET multipolygon_var = ST_GeomFromText('MULTIPOLYGON(((5 5, 5 15, 15 15, 15 5, 5 5)))');
    SELECT ST_Area(multipolygon_var) AS area_size;
END 
/

CREATE FUNCTION create_multipolygon(
    x1 DOUBLE, 
    y1 DOUBLE,
    x2 DOUBLE, 
    y2 DOUBLE
) 
RETURNS multipolygon
BEGIN
    DECLARE multipolygon_text VARCHAR(10000) DEFAULT 'POLYGON((';
    SET multipolygon_text = CONCAT(multipolygon_text, x1, ' ',  y1, ',', x1, ' ', y2, ',',  x2, ' ', y2, ',',  x2, ' ', y1, ',',  x1, ' ', y1, '))');
    RETURN ST_GeomFromText(multipolygon_text);
END
/

delimiter ;/
SET @pt = ST_GeomFromText('MULTIPOLYGON(((0 0, 0 10, 10 10, 10 0, 0 0)), ((20 20, 20 30, 30 30, 30 20, 20 20)))');
CALL test_multipolygon(@pt);
call multipolygon_example();
SELECT ST_AsText(create_multipolygon(0, 0, 20, 20));
CALL test_multipolygon(create_multipolygon(0, 0, 25, 25));
show create procedure test_multipolygon;
show create procedure multipolygon_example;
show create function create_multipolygon;
