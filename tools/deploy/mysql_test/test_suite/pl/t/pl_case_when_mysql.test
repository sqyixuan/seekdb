#owner: heyongyi.hyy
#owner group: pl/sql
#tags: pl
#description: CASE WHEN statement test

--result_format 4

delimiter /;

--disable_warnings ONCE
drop procedure if exists p;
/

CREATE PROCEDURE p()
  BEGIN
    DECLARE v INT DEFAULT 1;

    CASE v
      WHEN 2 THEN SELECT v;
      WHEN '3' THEN SELECT 0;
      ELSE
        BEGIN
        END;
    END CASE;
  END;
/
call p();
/
drop procedure p;
/

CREATE PROCEDURE p()
  BEGIN
    DECLARE v INT DEFAULT 2;

    CASE v
      WHEN 2 THEN SELECT v;
      WHEN '3' THEN SELECT 0;
      ELSE
        BEGIN
        END;
    END CASE;
  END;
/
call p();
/
drop procedure p;
/

CREATE PROCEDURE p()
  BEGIN
    DECLARE v INT DEFAULT 3;

    CASE v
      WHEN 2 THEN SELECT v;
      WHEN '3' THEN SELECT 0;
      ELSE
        BEGIN
        END;
    END CASE;
  END;
/
call p();
/
drop procedure p;
/

--disable_warnings ONCE
drop table if exists case_when;
/
create table case_when(c int);
/
--disable_warnings ONCE
drop function if exists f;
create function f() returns int
begin
declare ret int default -1;
select count(*) into ret from case_when;
insert into case_when values(ret);
return ret;
end;
/

create procedure p()
begin
case f()
when 2 then select 2;
when 1 then select 1;
when 0 then select 0;
end case;
end;
/
call p();
/
select * from case_when;
/
drop procedure p;
/

truncate table case_when;
/

create procedure p(x int)
begin
case f()
when f() then select 'f';
when '1' then select '1';
when 1 then select 1;
when x then select 2;
else select 3;
end case;
end;
/

call p(1);
/
select * from case_when;
/

truncate table case_when;
/

call p(0);
/
select * from case_when;
/

truncate table case_when;
/
drop procedure p;
/

create procedure p()
begin 
case 
when f()=1 then select 0;
when f()=1 then select 1;
when f()=1 then select 2;
end case;
end;
/

call p();
/
select * from case_when;
/

truncate table case_when;
/
drop procedure p;
/

create procedure p()
begin 
case 
when f() then select 0;
when f() then select 1;
when f() then select 2;
end case;
end;
/

call p();
/
select * from case_when;
/

drop procedure p;
/
drop function f;
/
drop table case_when;
/

create procedure p()
begin
case 0
when 0 then select 0;
when 0 then select 1;
else select 2;
end case;
end;
/
call p();
/
drop procedure p;
/

create procedure p()
begin
case null
when null then select 0;
when false then select 1;
else select 2;
end case;
end;
/
call p();
/
drop procedure p;
/

create procedure p()
begin
case
when false then select 0;
else select 1;
end case;
end;
/
call p();
/
drop procedure p;
/

create procedure p()
begin
case
when false then select 0;
end case;
end;
/
--error 1339
call p();
/
drop procedure p;
/
delimiter ;/
