#owner: linlin.xll
#owner group: sql4
#tags: pl,cross_validation

--result_format 4
--error 0,1051
drop table t;
create table t(col int);
insert into t values(0);

--error 0,1305
drop procedure p;

delimiter /;

create procedure p()
begin
    declare i int default 30000;
    declare x int;
    req_continue_label:
    while(i<>1) do
        if i > 0 then
            set i = i - 1;
            update t set col = i;
            commit;
            ITERATE req_continue_label;
        end if;
    end while req_continue_label;
end;
/

delimiter ;/

call p();
drop procedure p;
drop table t;

