#owner: linlin.xll
#owner group: sql4
#tags: pl
#description: some exception bugs

--result_format 4

delimiter /;

--echo 
--disable_warnings ONCE
drop procedure if exists p;
/

create procedure p()
begin
    declare code varchar(100);
    declare msg varchar(100);
    declare continue handler for sqlstate '42000'
    begin
        get diagnostics condition 1 code=returned_sqlstate, msg=MESSAGE_TEXT;
        select code, msg;
    end;
    signal sqlstate '99999' SET MESSAGE_TEXT='aaa', MYSQL_ERRNO=null;
end;
/ 

call p();
/

--disable_warnings ONCE
drop procedure if exists p;
/
create procedure p()
begin
    declare code varchar(100);
    declare msg varchar(100);
    declare continue handler for sqlstate '42000'
    begin
        get diagnostics condition 1 code=returned_sqlstate, msg=MESSAGE_TEXT;
        select code, msg;
    end;
    signal sqlstate '99999' SET MESSAGE_TEXT='aaa', MYSQL_ERRNO=1231;
end;
/
--error 1231
call p();
/

--disable_warnings ONCE
drop procedure if exists p;
/
create procedure p()
begin
    declare code varchar(100);
    declare msg varchar(100);
    declare continue handler for sqlstate '99999'
    begin
        get diagnostics condition 1 code=returned_sqlstate, msg=MESSAGE_TEXT;
        select code, msg;
    end;
    signal sqlstate '99999' SET MESSAGE_TEXT='aaa', MYSQL_ERRNO=1231;
end;
/
call p();
/

--echo 

--disable_warnings ONCE
DROP PROCEDURE IF EXISTS p;
/
CREATE PROCEDURE p (a INT)
BEGIN
    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
	case a
        when 1 then RESIGNAL;
        when 2 then RESIGNAL set MESSAGE_TEXT='no table';
        when 3 then RESIGNAL sqlstate '23000';
    end case;
    end;
    DROP TABLE xxx;
END;
/
--error 1051
call p(1);
/
--error 1051
call p(2);
/
--error 1644
call p(3);
/

drop procedure if exists p;
/
CREATE PROCEDURE p (a int)
BEGIN
  DECLARE specialty CONDITION FOR SQLSTATE '45000' ;
  DECLARE EXIT HANDLER FOR sqlexception
  begin
    case a
      when 1 then resignal;
      when 2 then resignal set message_text='no table';
      when 3 then resignal sqlstate '23000';
    end case;
  end;
  signal specialty set message_text='aaaaaaaa',mysql_errno=100;
END;
/
--error 100
CALL p(1);
/
--error 100
CALL p(2);
/
--error 1644
CALL p(3);
/

--echo 

--disable_warnings ONCE
drop table if exists t0;
/
create table t0(c0 int);
/
--disable_warnings ONCE
drop trigger if exists tr1;
/
create trigger tr1 before insert on t0 for each row
begin
    if new.c0=1 then
        SIGNAL SQLSTATE '40001' SET MESSAGE_TEXT = 'error';
    end if;
end;
/

--disable_warnings ONCE
drop procedure if exists p;
/
CREATE PROCEDURE p()
BEGIN
    declare continue handler for SQLSTATE '40001' select 'eeeeee';
    insert into t0 values(1);
END
/
call p();
/

drop table t0;
/
drop procedure p;
/

--echo 

--disable_warnings ONCE
drop table if exists t0;
/
create table t0(c0 int);
/
--disable_warnings ONCE
drop table if exists xxx;
/
--disable_warnings ONCE
drop procedure if exists p;
/
CREATE PROCEDURE p ()
begin
    declare a int;
    declare c cursor for select * from t0;
    DECLARE continue HANDLER FOR sqlexception select 'sqlexception';
    DECLARE continue HANDLER FOR not found
    begin
        select 'not found';
        drop table xxx;
    end;
    open c ;
    fetch c into a;
    close c;
end;
/
--error 1051
call p();
/

--disable_warnings ONCE
drop table if exists t0;
/
create table t0(c0 int);
/
--disable_warnings ONCE
drop table if exists xxx;
/
--disable_warnings ONCE
drop procedure if exists p;
/
CREATE PROCEDURE p ()
begin
    declare a int;
    declare c cursor for select * from t0;
    DECLARE continue HANDLER FOR not found
    begin
        select 'not found';
        drop table xxx;
    end;
    DECLARE continue HANDLER FOR sqlexception select 'sqlexception';
    open c ;
    fetch c into a;
    close c;
end;
/
--error 1051
call p();
/

--echo 
--disable_warnings ONCE
drop table if exists xxx;
/
--disable_warnings ONCE
drop procedure if exists p;
/
CREATE PROCEDURE p()
label:
begin
    declare continue handler for 1051
    label:
    begin
        if 1=1 then
            select 'aaa';
            leave label;
        end if;
    end;
    drop table xxx;
end;
/
call p()
/
drop procedure p;
/
