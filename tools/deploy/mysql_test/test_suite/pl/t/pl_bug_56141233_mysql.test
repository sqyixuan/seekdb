#tags: pl
#description: test pl bug

--result_format 4

--disable_warnings
set @a=0;
drop function if exists f4;

delimiter /;

create function f4() returns int
begin
    case 'abc'
    when 1 then
    set @a=1;
    when 0 then
    set @a=0;
    else
    set @a=-1;
end case;
return 1;
end /

delimiter ;/

select f4();
select @a;
drop function f4;