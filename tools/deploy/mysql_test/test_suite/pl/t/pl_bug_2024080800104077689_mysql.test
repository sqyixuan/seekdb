#owner: xinning.lf
#owner group: pl/sql
#tags: pl
#description: test mysql.proc

--result_format 4

drop table if exists t_mysql_proc;

create table t_mysql_proc as select * from mysql.proc;

desc t_mysql_proc;

drop table t_mysql_proc;

drop function if exists func_test_mysql_proc;

drop procedure if exists proc_test_mysql_proc;

delimiter /;

CREATE FUNCTION func_test_mysql_proc(empId_uint8 tinyint unsigned, empId_uint16 smallint unsigned, empId_uint24 mediumint unsigned, empId_uint32 INT unsigned)  RETURNS decimal(12,2) unsigned DETERMINISTIC
BEGIN
declare a tinyint;
    RETURN IF(empId_uint8 IS NOT NULL, 44, 3);
END;
/

CREATE PROCEDURE proc_test_mysql_proc(IN empId TEXT CHARACTER SET latin1 COLLATE latin1_bin) comment 'test comment begin' not DETERMINISTIC no sql sql security invoker
BEGIN
    DECLARE baseSalary DECIMAL(10,2); 
    set @a= empId;
END;
/

delimiter ;/
select db, name, type, specific_name, language, sql_data_access, is_deterministic, security_type, param_list, returns, body, definer, sql_mode, comment, character_set_client, collation_connection, db_collation,body_utf8 
from mysql.proc where name = 'func_test_mysql_proc' or name = 'proc_test_mysql_proc' order by name;

drop function func_test_mysql_proc;
drop procedure proc_test_mysql_proc;
