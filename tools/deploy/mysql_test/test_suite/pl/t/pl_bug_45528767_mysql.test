delimiter /;

echo --------case 1----------
--disable_warnings ONCE
drop PROCEDURE if exists p1/
CREATE PROCEDURE p1(v_num1 decimal)
LANGUAGE SQL
DETERMINISTIC
CONTAINS SQL
SQL SECURITY DEFINER
COMMENT "查看 characteristic"
SELECT 1 into v_num1 FROM dual;
SELECT 2 FROM dual;
select 3 from dual;
/


show CREATE procedure p1/

--vertical_results
--replace_column 5 # 6 #
show procedure status like 'p1'/
--horizontal_results


echo --------case 2----------

--disable_warnings ONCE
drop PROCEDURE if exists p2/
CREATE PROCEDURE p2(v_num1 decimal)
LANGUAGE SQL
NOT DETERMINISTIC
CONTAINS SQL
SQL SECURITY DEFINER
SELECT 1 into v_num1 FROM dual;
SELECT 2 FROM dual;
select 3 from dual;
/


show CREATE procedure p2/

--vertical_results
--replace_column 5 # 6 #
show procedure status like 'p2'/
--horizontal_results


echo --------case 3----------
--disable_warnings ONCE
DROP function if exists f1/


CREATE function f1 () returns int
LANGUAGE SQL
DETERMINISTIC
CONTAINS SQL
SQL SECURITY DEFINER
COMMENT "see_characteristic"
BEGIN  
  
  RETURN 1;
END;
/

show CREATE function f1/

echo --------case 4----------
--disable_warnings ONCE
drop PROCEDURE if exists p3/
CREATE PROCEDURE p3()
SQL SECURITY DEFINER
COMMENT "see_characteristic"
-- SELECT 1 into v_num1 FROM dual;
SELECT 2 FROM dual;
select 3 from dual;
/

show CREATE procedure p3/

--vertical_results
--replace_column 5 # 6 #
show procedure status like 'p3'/
--horizontal_results


drop procedure p1/
drop procedure p2/
drop procedure p3/
drop function f1/

delimiter ;/
