#owner: heyongyi.hyy
#owner group: sql4
#tags: pl
#description: mysql pl do statement 

--result_format 4

--echo ############################start case 1############################

delimiter /;
set @a=0/
--disable_warnings
drop function if exists f1/
--enable_warnings

create function f1() returns int
begin
    declare x int default '111';
    case
    when '997a11ek'=9976 then
    set @a=1;
    when 'a11ek'=0 then
    set @a=0;
    else
    set @a=-1;
end case;
return x;
end;
/
select f1()/
select @a/

drop function f1/

--echo ############################start case 2############################

--disable_warnings
drop procedure if exists p1/
--enable_warnings

create procedure p1()
begin
  declare a varchar(20);
  set a = 'k';
  case 
  when a = 0 then
    select a;
  else
    select 1;
  end case;
end/
call p1()/

drop procedure p1/

--echo ############################start case 3############################

--disable_warnings
drop function if exists f2/
--enable_warnings

create function f2() returns int
begin
    declare x varchar(20);
    set x = '3e1a11ek';
    case
    when x=30 then
    set @a=1;
    when x=3 then
    set @a=0;
    else
    set @a=-1;
end case;
return 1;
end;
/
select f2()/
select @a/

drop function f2/

delimiter ;/


--echo ############################start case 4############################

--disable_warnings
drop table if exists a;
drop procedure if exists p;
--enable_warnings

create table a(a1 int);
delimiter //;
create procedure p(x int)
begin
case x
when 1 then insert into a values(1);
when 2 then insert into a values(2);
end case;
end//
delimiter ;//
call p(1);
select * from a;
call p(2);
select * from a;
--error ER_SP_CASE_NOT_FOUND
call p(3);
select * from a;
drop table a;
drop procedure p;

--echo ############################start case 4############################

delimiter /;
set @a=0/
--disable_warnings
drop function if exists f4/
--enable_warnings

create function f4() returns int
begin
    case 'abc'
    when 1 then
    set @a=1;
    when 0 then
    set @a=0;
    else
    set @a=-1;
end case;
return 1;
end;
/
select f4()/
select @a/

drop function f4/

--echo ############################start case 4############################

drop function if exists f5/
create function f5() returns int
begin
    case '22abc'
    when 22 then
    set @a=1;
    when 0 then
    set @a=0;
    else
    set @a=-1;
end case;
return 1;
end;
/
select f5()/
select @a/

drop function f5/