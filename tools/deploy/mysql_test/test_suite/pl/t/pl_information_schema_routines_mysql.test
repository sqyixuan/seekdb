delimiter /;
--disable_warnings ONCE
DROP PROCEDURE IF EXISTS p2/
CREATE PROCEDURE p2(v_num1 decimal(10), ch char(10), flo float(10))
COMMENT "查看characteristic"
BEGIN
    declare k float(10);
	SELECT 1 FROM dual;
END;
/


--disable_warnings ONCE
drop function if EXISTS f2/
CREATE function f2(e text(50), f char(10), g TIMESTAMP(2)) returns char(10)
BEGIN
return f;
end;
/


--disable_warnings ONCE
drop function if EXISTS f3/
CREATE function f3(e text(50), f char(10), g TIMESTAMP(3)) returns TIMESTAMP(3)
BEGIN
return g;
end;
/

--disable_warnings ONCE
drop function if EXISTS f4/
CREATE function f4() returns varchar(64)
BEGIN
return '';
end;
/

delimiter ;/
--replace_column 24 ###### 25 ###### 
select * FROM INFORMATION_SCHEMA.ROUTINES where routine_schema='test' and routine_name in ('p2', 'f2', 'f3', 'f4') order by specific_name;
desc INFORMATION_SCHEMA.ROUTINES;

drop procedure p2;
drop function f2;
drop function f3;
drop function f4;

