#owner: jiabokai.jbk
#owner group: PL/SQL
#tags: pl,pl cache
#description: pl cache key db_id

--result_format 4
alter system flush pl cache global;

--disable_warnings
--error 0,1396
drop user jbk;
CREATE USER jbk;
GRANT all ON *.* TO jbk WITH GRANT OPTION;

--error 0,1396
drop user jbk2;
CREATE USER jbk2;
GRANT all ON *.* TO jbk2 WITH GRANT OPTION;

--error 0,1008
DROP DATABASE jbkdb;
CREATE DATABASE jbkdb;
--error 0,1008
DROP DATABASE jbkdb2;
CREATE DATABASE jbkdb2;
use jbkdb;
--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,jbk,,jbkdb,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,jbk2,,jbkdb2,$OBMYSQL_PORT);
connection conn1;

drop table if exists t1,t2;
create table t1(a int);
insert into t1 values(1);
create table t2(id int);

drop procedure if exists testcachep1;
drop procedure if exists testcachep2;
drop function if exists testcachef2;
drop trigger if exists testcachetrig3;

delimiter /;
CREATE definer = 'jbk' procedure if not exists testcachep1()
begin
  declare v_a int;
  select a into v_a from t1 limit 1;
  insert into t2 values(v_a);
end;
/

CREATE procedure if not exists testcachep2() sql security invoker
begin
  declare v_a int;
  select a into v_a from t1 limit 1;
  insert into t2 values(v_a);
end;
/

CREATE definer = 'jbk' function if not exists testcachef2() returns int
begin
  declare v_a int;
  select a into v_a from t1 limit 1;
  return v_a;
end;
/

create definer=jbk trigger testcachetrig3 before insert on t1
for each row
begin
  insert into t2 values(1);
end;
/

delimiter ;/

call testcachep1();
call testcachep2();
select testcachef2();
insert into t1 values(1);
select * from t1;
select * from t2;

connection conn2;
use jbkdb2;
drop table if exists t1,t2;
create table t1(a int);
insert into t1 values(1);
create table t2(id int);

call jbkdb.testcachep1();
call jbkdb.testcachep2();
select jbkdb.testcachef2();
insert into jbkdb.t1 values(1);
select * from jbkdb.t1;
select * from jbkdb.t2;
select * from t2;

use oceanbase;
select PARAMETERIZE_TEXT,HIT_COUNT,object_type from GV$ob_pl_cache_object where PARAMETERIZE_TEXT like '%TESTCACHE%' order by LAST_ACTIVE_TIME;
drop user jbk;
drop user jbk2;
DROP DATABASE jbkdb;
--enable_warnings
DROP DATABASE jbkdb2;



