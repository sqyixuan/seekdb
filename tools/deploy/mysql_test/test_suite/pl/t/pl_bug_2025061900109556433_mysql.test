DELIMITER $$;

CREATE PROCEDURE p1(a int)
BEGIN
call __DBMS_UPGRADE.UPGRADE_ALL(true);
END$$

DELIMITER ;$$


drop PROCEDURE p1;
DELIMITER $$;

CREATE PROCEDURE p1(a int)
BEGIN
call __DBMS_UPGRADE.UPGRADE_ALL();
END$$

DELIMITER ;$$

drop PROCEDURE p1;

