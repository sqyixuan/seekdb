#owner: wangbai.wx
#owner group: pl/sql
#tags: pl
#description: pl support case when in del default

--result_format 4

--disable_warnings ONCE
drop procedure if exists p_test;
--disable_warnings ONCE
drop procedure if exists p_test;

delimiter //;

CREATE  PROCEDURE p_test(
    IN planyear numeric, 
    IN regionOrgId VARCHAR(200) 
)
begin
    DECLARE init_all VARCHAR(500) default 
	case when regionOrgId is null or regionOrgId = '' then 1 else 0 end;
    select init_all from dual;
end
//

CREATE  PROCEDURE p_test1(
    IN planyear numeric, 
    IN regionOrgId VARCHAR(200) 
)
begin
    DECLARE init_all VARCHAR(500) default 
	(case when regionOrgId is null or regionOrgId = '' then 1 else 0 end);
    select init_all from dual;
end
//

show create procedure p_test//
show create procedure p_test1//

call p_test(1, 'aaa')//
call p_test1(2, 'bbb')//

call p_test(1, NULL)//
call p_test1(2, '')//

delimiter ;//

DROP procedure p_test1;
DROP procedure p_test;





