#owner: heyongyi.hyy
#owner group: pl/sql
#tags: pl
#description: test DEFINER + CURRENT_USER()

--result_format 4

--error 0,1396
drop user u9;

create user u9;
grant all on *.* to u9;

--disable_warnings ONCE
drop procedure if exists my_proc1;

set @a='';

delimiter /;
CREATE definer = 'u9' PROCEDURE my_proc1 (OUT user_host VARCHAR(1000))
BEGIN
 SELECT current_user() INTO user_host;
END
/
delimiter ;/

call my_proc1(@a); select @a;

drop procedure my_proc1;

set @a='';

delimiter /;
CREATE definer = 'u9' PROCEDURE my_proc1 (OUT user_host VARCHAR(1000)) SQL SECURITY INVOKER
BEGIN
 SELECT current_user() INTO user_host;
END
/
delimiter ;/

call my_proc1(@a); select @a;

drop procedure my_proc1;

drop user u9;

set @a='';
