#owner: haohao.hao
#owner group: PL/SQL
#tags: pl
#description: pl code coverage

--result_format 4

--echo ===== ob_pl_resolver.cpp ObPLResolver::build_record_type_by_table_schema() test coverage =====
drop table if exists test_table;
drop table if exists log_table;

create table test_table (
  id int,
  value varchar(100),
  bit_flag bit(1)
);

create table log_table (
  operation varchar(100),
  new_id int,
  new_bit_flag bit(1)
);

delimiter /;
create trigger test_trigger
after insert on test_table
for each row
begin
  insert into log_table (operation, new_id, new_bit_flag)
  values ('INSERT', new.id, new.bit_flag);
end;
/
delimiter ;/

insert into test_table (id, value, bit_flag) values (1, 'Hello', b'0');
insert into test_table (id, value, bit_flag) values (2, 'World', b'1');
insert into test_table (id, value, bit_flag) values (3, '!', b'0');
select id, value from test_table order by id;
select operation, new_id from log_table where not (new_bit_flag & b'1') order by new_id;

drop trigger test_trigger;
drop table log_table;
drop table test_table;
