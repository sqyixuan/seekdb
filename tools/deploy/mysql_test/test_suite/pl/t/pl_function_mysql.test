CREATE FUNCTION bug18037_f1() RETURNS INT
BEGIN
  RETURN @@identity;
END|

CREATE PROCEDURE bug18037_p1()
BEGIN
  DECLARE v INT DEFAULT @@identity;
END|

CREATE PROCEDURE bug18037_p2()
BEGIN
  CASE @@identity
  WHEN -1 THEN
    SELECT 0;
  ELSE
    SELECT 1;
  END CASE;
END|

