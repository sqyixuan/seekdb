CREATE FUNCTION f2 () RETURNS INTEGER
BEGIN
   DECLARE CONTINUE HANDLER FOR SQLSTATE '42000' SET @aux = 1;
   RETURN f_not_exists () ;
END|

CREATE FUNCTION my_func() RETURNS INT
BEGIN
  DECLARE v INT DEFAULT 0;
  DECLARE CONTINUE HANDLER FOR SQLSTATE '42000' SET v=1;
  RETURN no_such_func();
  RETURN v;
END|
DELIMITER ;|

SELECT my_func();

--disable_warnings
DROP FUNCTION IF EXISTS no_such_func;
--enable_warnings
CREATE FUNCTION no_such_func() RETURNS INT RETURN 3;
SELECT my_func();

DROP FUNCTION no_such_func;
DROP FUNCTION my_func;

DELIMITER |;
CREATE FUNCTION my_func() RETURNS INT
BEGIN
  DECLARE v INT DEFAULT 0;
  DECLARE CONTINUE HANDLER FOR SQLSTATE '42000' SET v = no_such_func();
  RETURN v;
END|
DELIMITER ;|
SELECT my_func();

DROP FUNCTION my_func;

--disable_warnings
DROP PROCEDURE IF EXISTS my_proc;
--enable_warnings
DELIMITER |;
CREATE PROCEDURE my_proc()
BEGIN
  CALL no_such_proc();
END|
DELIMITER ;|
--error 1305
CALL my_proc();

--disable_warnings
DROP PROCEDURE IF EXISTS no_such_proc;
CREATE PROCEDURE no_such_proc()
BEGIN END;

CALL my_proc();

DROP PROCEDURE no_such_proc;
DROP PROCEDURE my_proc;

DELIMITER |;
CREATE PROCEDURE my_proc()
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLSTATE '42000'
  CALL no_such_proc();
END|
DELIMITER ;|
CALL my_proc();
DROP PROCEDURE my_proc;

USE TEST;
DROP DATABASE my_db;

#### Case 60: procedure function dependency test
--disable_warnings
DROP PROCEDURE IF EXISTS my_proc;
DROP PROCEDURE IF EXISTS my_proc1;
DROP FUNCTION IF EXISTS my_func;
DROP FUNCTION IF EXISTS my_func1;
--enable_warnings

delimiter |;
create procedure my_proc() begin call my_proc1(my_func()); end;|
create procedure my_proc1(v int) begin set v = 2; end;|
create function my_func() returns int return 1;|
call my_proc()|
drop function my_func|
create function my_func() returns int return 1;|
call my_proc()|


drop function my_func|
drop procedure my_proc|
drop procedure my_proc1|

create procedure my_proc() begin declare v int; set v = my_func(); end|
create function my_func() returns int return 1;|
call my_proc()|
drop function my_func|
create function my_func() returns int return 1;|
call my_proc()|

drop procedure my_proc|
drop function my_func|

create function my_func() returns int begin declare v int; set v = my_func1(); return v; end;|
create function my_func1() returns int return 1;|
drop function my_func1|
create function my_func1() returns int return 1;|
select my_func()|
drop function my_func1|
create function my_func1() returns int return 1;|
select my_func()|

drop function my_func|
drop function my_func1|

create function my_func() returns int
begin
  declare v int default 1;
  call my_proc(v); return v;
end|
create procedure my_proc(OUT v int) begin set v = 2; end;|
select my_func()|
drop procedure my_proc|
create procedure my_proc(OUT v int) begin set v = 3; end;|
select my_func()|

drop function my_func|
drop procedure my_proc|

create function my_func() returns int
begin
  call my_proc(my_func1());
  return 1;
end;|
create procedure my_proc(v int) begin set v = my_func1(); end;|
create function my_func1() returns int return 1;|
select my_func()|
drop function my_func1|
create function my_func1() returns int return 2;|
select my_func()|

drop function my_func|
drop function my_func1|
drop procedure my_proc|

delimiter ;|


















