--result_format 4
alter system flush pl cache global;
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER';
--error 0,1305
drop procedure test_p;
--error 0,1305
drop procedure test_p1;
--error 0,1051
drop table test;

--echo ####procedure DDL变更####
alter system plsql_v2_compatibility = 0;

create table test(a int);

delimiter //;
create procedure test_p() begin  select * from test; end;//
create procedure test_p1() begin  call test_p(); end;//
delimiter ;//

select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='TEST_P' order by gmt_create desc limit 1);

call test_p();

select OBJECT_TYPE,HIT_COUNT from oceanbase.GV$OB_PL_CACHE_OBJECT where PARAMETERIZE_TEXT like '%test_p%';
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='TEST_P' order by gmt_create desc limit 1);

call test_p();

select OBJECT_TYPE,HIT_COUNT from oceanbase.GV$OB_PL_CACHE_OBJECT where PARAMETERIZE_TEXT like '%test_p%';
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='TEST_P' order by gmt_create desc limit 1);

alter system plsql_v2_compatibility = 1;

alter table test modify a double;

set sql_mode = STRICT_ALL_TABLES;
alter system flush pl cache global;
alter procedure test_p compile;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
#select "exists" as test_result from __all_ncomp_dll_v2 where key_id = (select routine_id from __all_routine where routine_name='test_p');
connection default;

select routine_name, exec_env, route_sql from oceanbase.__all_routine where routine_name = 'test_p';
select routine_name, exec_env, route_sql from oceanbase.__all_routine where routine_name = 'test_p1';
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='TEST_P' order by gmt_create desc limit 1);

call test_p();

select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='TEST_P' order by gmt_create desc limit 1);

alter table test modify a char;
alter procedure test_p1 compile reuse settings;

select routine_name, exec_env, route_sql from oceanbase.__all_routine where routine_name = 'test_p1';
connection obsys;
#select "exists" as test_result from __all_ncomp_dll_v2 where key_id = (select routine_id from __all_routine where routine_name='test_p1');
connection default;
--echo ####function DDL变更####
alter system plsql_v2_compatibility = 0;
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER';
--error 0,1305
drop function test_f;
--error 0,1305
drop function test_f1;
--error 0,1051
drop table test1;

create table test1(a int, b double);
insert into test1 value(1, 13.14);

delimiter //;
create function test_f()
returns int
begin
update test1 set b=13.15 where a=1;
return 1;
end;
//

create function test_f1()
returns int
begin
      declare i int;
      set i =1;
      while i< 10    
      do
           update test1 set b=13.15 where a=1;
           set i=i+1;
      end while;
      return 1;
end;
//
delimiter ;//

select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='TEST_F' order by gmt_create desc limit 1);

select test_f();

select OBJECT_TYPE,HIT_COUNT from oceanbase.GV$OB_PL_CACHE_OBJECT where PARAMETERIZE_TEXT like '%test_f%';
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='TEST_F' order by gmt_create desc limit 1);

select test_f();

select OBJECT_TYPE,HIT_COUNT from oceanbase.GV$OB_PL_CACHE_OBJECT where PARAMETERIZE_TEXT like '%test_f%';
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='TEST_F' order by gmt_create desc limit 1);

alter system plsql_v2_compatibility = 1;

alter table test1 modify b int;

set sql_mode = STRICT_ALL_TABLES;
alter system flush pl cache global;
alter function test_f compile;
connection obsys;
#select "exists" as test_result from __all_ncomp_dll_v2 where key_id = (select routine_id from __all_routine where routine_name='test_f');
connection default;

select routine_name, exec_env, route_sql from oceanbase.__all_routine where routine_name = 'test_f';
select routine_name, exec_env, route_sql from oceanbase.__all_routine where routine_name = 'test_f1';
select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='TEST_F' order by gmt_create desc limit 1);

select test_f();

select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='TEST_F' order by gmt_create desc limit 1);

alter table test1 modify b char(10);
alter function test_f1 compile reuse settings;

select routine_name, exec_env, route_sql from oceanbase.__all_routine where routine_name = 'test_f1';
connection obsys;
#select "exists" as test_result from __all_ncomp_dll_v2 where key_id = (select routine_id from __all_routine where routine_name='test_f1');
connection default;

set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER';
