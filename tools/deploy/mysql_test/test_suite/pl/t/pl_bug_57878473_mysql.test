#owner: hr351303
#owner group: pl/sql
#tags: pl
#description: test pl memory leak

--result_format 4

--disable_warnings
drop procedure if exists p1;
--enable_warnings

delimiter /;

CREATE PROCEDURE p1()
BEGIN
 declare code varchar(10);
 declare msg varchar(100);
  reSIGNAL SQLSTATE  '99999' SET MESSAGE_TEXT = 'aaa', MYSQL_ERRNO=null;
END;
/

delimiter ;/
--error 1645
call p1();

drop procedure p1;

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection conn_admin;

select "has memory leak" from __all_virtual_malloc_sample_info where mod_name='PlStmtHashMap' and alloc_bytes > 0;