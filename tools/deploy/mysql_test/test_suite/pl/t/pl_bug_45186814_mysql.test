#owner: linlin.xll
#owner group: sql4
#tags: pl
#description: mysql pl continue handler

--result_format 4

delimiter /;
--error 0,1305
drop procedure p1;/
create procedure p1()
begin
    DECLARE continue HANDLER FOR SQLEXCEPTION
    begin
        select 'catch sqlexception';
        select cast('c' as json);
    end;
    select cast('b' as json);
end
/
--error 3141
call p1()
/
drop procedure p1;
/

--error 0,1051
drop table t1/
create table t1(id int);/
--error 0,1305
drop procedure p1;/
create procedure p1()
begin
    declare aa int;
    DECLARE continue HANDLER FOR SQLEXCEPTION
    begin
        insert into t1 values(0);
        insert into t1 values('a');
    end;
    insert into t1 values('aa');
end
/
--error 1366
call p1()/
select * from t1/
drop procedure p1;/

delimiter ;/
