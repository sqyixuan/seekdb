--disable_query_log
set@@sql_mode='ONLY_FULL_GROUP_BY,STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION'; 
--enable_query_log

#owner: xinning.lf
#owner group: pl/sql
#tags: pl
#description: test mysql.proc sql_mode column

--result_format 4

DELIMITER //;
--error 1305
drop FUNCTION func_mysql_proc_sql_mode;//
CREATE  FUNCTION func_mysql_proc_sql_mode(birthDate int)
RETURNS float DETERMINISTIC
BEGIN
    set @a=birthDate;
    RETURN 1;
END; 
//
DELIMITER ;//

select name,sql_mode from mysql.proc where NAME ='func_mysql_proc_sql_mode' ;
drop function func_mysql_proc_sql_mode;

