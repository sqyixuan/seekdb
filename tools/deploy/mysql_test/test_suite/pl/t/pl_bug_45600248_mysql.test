#owner: heyongyi.hyy
#owner group: sql4
#tags: pl
#description: show function status 

--result_format 4

delimiter /;
--echo ----------case1-----------
--disable_warnings
drop function if exists f1/
--enable_warnings

create function f1() returns int
return 1;
/

--vertical_results
--replace_column 5 # 6 #
show function status like 'f1'/
--horizontal_results
--echo ----------case2-----------
--disable_warnings
drop function if exists f2/
--enable_warnings
create function f2() returns int
SQL SECURITY DEFINER
 return 1;/
--vertical_results
--replace_column 5 # 6 #
show function status like 'f2'/
--horizontal_results

delimiter ;/
drop function f1;
drop function f2;



