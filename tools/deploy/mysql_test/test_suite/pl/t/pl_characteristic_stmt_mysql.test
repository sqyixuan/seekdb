#####

--echo ------------- case 1 ------------

--disable_warnings
drop procedure if exists p1;
--enable_warnings

delimiter /;

CREATE PROCEDURE p1(v_num1 decimal)
SQL SECURITY INVOKER
LANGUAGE SQL
DETERMINISTIC
READS SQL DATA
COMMENT "查看characteristic"
BEGIN
    SELECT 1 into v_num1 FROM dual;
END;/

delimiter ;/

show CREATE procedure p1;
drop procedure p1;


--echo ------------- case 2 ------------


--disable_warnings
DROP PROCEDURE IF EXISTS PRO01;
--enable_warnings

delimiter /;
CREATE PROCEDURE PRO01 (VAR1 INT)
NO SQL
COMMENT "查看characteristic"
BEGIN
    SELECT 1 FROM dual;
END;/

delimiter ;/
SHOW CREATE PROCEDURE PRO01;
DROP PROCEDURE PRO01;

--echo ------------- case 3 ------------

delimiter /;

--disable_warnings
DROP PROCEDURE IF EXISTS p2/
--enable_warnings

CREATE PROCEDURE p2(v_num1 decimal)
SQL SECURITY INVOKER
LANGUAGE SQL
DETERMINISTIC
NO SQL
modifies sql data
READS SQL DATA
COMMENT "查看characteristic"
BEGIN
SELECT 1 into v_num1 FROM dual;
END
/

delimiter ;/

show CREATE procedure p2;
drop procedure p2;
