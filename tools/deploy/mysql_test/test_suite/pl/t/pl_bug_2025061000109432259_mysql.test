#owner: wangbai.wx
#owner group: PL/SQL
#tags: pl
#description: create routine parallel ddl conflict with drop user

--result_format 4
--disable_warnings
drop user if exists test;
create user test identified by 'test';
grant all privileges on *.* to test;
grant all on *.* to 'test'@'%' with grant option;
--enable_warnings

--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,test,test,test,$OBMYSQL_PORT);

connection default;
--disable_warnings
drop user if exists test;
--enable_warnings

connection conn;
--error 0,1305
drop PROCEDURE test_procedure;
delimiter /;
--error 1133
CREATE PROCEDURE test_procedure()
BEGIN
   select 1;
END;
/
delimiter ;/
connection default;
--disable_warnings
create user test identified by 'test';
--enable_warnings
connection conn;
delimiter /;
CREATE PROCEDURE test_procedure()
BEGIN
   select 1;
END;
/
delimiter ;/
drop PROCEDURE test_procedure;

connection default;
--disable_warnings
drop user if exists test;
--enable_warnings
