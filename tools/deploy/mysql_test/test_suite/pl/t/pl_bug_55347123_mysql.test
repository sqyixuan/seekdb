#owner: hr351303
#owner group: pl/sql
#tags: pl
#description: test pl bug

--result_format 4

connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn1;

set autocommit=0;

--disable_warnings
drop table if exists t0;
drop procedure if exists p1;
create table t0(c0 int);

insert into t0 values(1);
insert into t0 values(2);
insert into t0 values(3);

delimiter /;

create procedure p1()
begin
  update t0 set c0=c0+1;
end;
/

delimiter ;/

commit;

select * from t0 for update;

connection conn2;
set autocommit=0;

savepoint a;

send call p1();

connection conn1;

rollback;

connection conn2;
reap;

rollback to a;

drop table t0;
drop procedure p1;