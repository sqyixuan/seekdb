#owner group: sql4
#tags: pl
#description:
#

--result_format 4

# case 1

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (s1 int);
insert into t1 values (1),(2),(3);

--disable_warnings
drop procedure if exists p1;
--enable_warnings

delimiter /;
create procedure p1()
begin
declare aa int;
declare i int default 1;
declare cur cursor for select s1 from t1 ;
open cur;
 while i < 7 do
fetch cur into aa;
set i = i + 1;
select aa;
end while;
close cur;
end/

delimiter ;/

--error 1329
call p1();

drop table t1;
drop procedure p1;

# case 2

--disable_warnings
drop table if exists t2;
--enable_warnings

create table t2 (a int);
insert into t2 values (1),(2);

--disable_warnings
drop function if exists f1;
--enable_warnings

delimiter /;

create function f1() returns int
begin
  declare res int;
  declare i int default 1;
  declare cur cursor for select a from t2;
  open cur;
  while i < 5 do
    fetch cur into res;
    set i = i+1;
  end while;
  close cur;
  return res;
end/

delimiter ;/
--error 1329
select f1() from t2;

drop table t2;
drop function f1;