#owner: linlin.xll
#owner group: sql4
#tags: pl
#description: test pl_block_timeout

--result_format 4

--disable_warnings

--echo #### 测试锁冲突场景下的行为
connect (conn1, $OBMYSQL_MS0, admin, admin, test, $OBMYSQL_PORT);
connect (conn2, $OBMYSQL_MS0, admin, admin, test, $OBMYSQL_PORT);

connection conn1;
--error 0,1051
drop table t1;
create table t1(col int);
insert into t1 values(1);
set autocommit=off;
--echo #### 加大语句超时
set ob_query_timeout=1000000000;
--echo #### 加大事务超时
set ob_trx_timeout=10000000000;
--echo #### 加锁
update t1 set col = col + 1;


connection conn2;
delimiter /;
drop procedure if exists proc;
/
create procedure proc()
begin
  insert into t1 values(1);
  update t1 set col = col + 1;
end;
/
--error 1205
call proc();
/
drop procedure proc;
/
delimiter ;/

connection conn1;
rollback;
--echo #### 再次加锁
update t1 set col = col + 1;

connection conn2;
delimiter /;
--echo #### 调整pl_block_timeout超时
set ob_pl_block_timeout=5000000;
/
create procedure proc()
begin
  update t1 set col = col + 1; -- 锁冲突, 本地重试一次后, 扔回队列重试到pl_block_timeout
end;
/
--error 1205,4012
call proc();
/
drop procedure proc;
/

delimiter ;/

connection conn1;
rollback;
drop table t1;

