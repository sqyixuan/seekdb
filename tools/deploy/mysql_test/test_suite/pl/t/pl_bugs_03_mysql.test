--error 0,1305
drop procedure p_show_warnings;

delimiter /;
create procedure p_show_warnings()
begin
  declare continue handler for sqlexception
  begin
  show warnings;
  end;
  select c;
end;
/
delimiter ;/

call p_show_warnings();

drop procedure p_show_warnings;
--echo ############################end case 3#############################

--echo ############################start case 4#############################
######
set @aaa = @@sql_mode;
select @aaa;
--error 0,1305
drop function test;
set @@sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
delimiter /;
create function test (S varchar(60)) returns varchar(60)
BEGIN
DECLARE
a int;
IF S = 0 THEN
set
  a = 1;
end if;
RETURN a;
end
/
delimiter ;/
select test('');
select test('aa');
drop function test;
set @@sql_mode = '';
delimiter /;
create function test (S varchar(60)) returns varchar(60)
BEGIN
DECLARE
a int;
IF S = 0 THEN
set
  a = 1;
end if;
RETURN a;
end
/
delimiter ;/
select test('');
select test('123');
drop function test;
set @@sql_mode = @aaa;
select @@sql_mode;
--echo ############################end case 4#############################

--error 0,1008
drop database hr_db;
create database hr_db;
--disable_warnings
drop procedure if exists p1;
drop table if exists tt1;
--enable_warnings
delimiter /;
create procedure hr_db.p1()
begin
  insert into tt1 value(2);
end/
use hr_db/
--error 1146
call p1()/
create table tt1(id int)/
call p1()/
select * from tt1/
drop table tt1/
drop procedure p1/
use test/
drop database hr_db/

#
delimiter ;/

--disable_warnings
drop function if exists f1;
drop function if exists f2;
drop trigger if exists tg1;
drop table if exists t1;
--enable_warnings

set autocommit = 0;

create table t1(id int);

delimiter /;

create function f1() returns int
begin
  savepoint a;
  savepoint b;
  rollback to b;
  return 1;
end/

select f1()/

--error 1305
rollback work to a/

create procedure p1()
begin
  select f1() from dual;
  rollback work to a;
end/

--error 1305
call p1()/

create function f2() returns int
begin
  declare val int;
  savepoint a;
  savepoint b;
  select f1() into val from dual;
  release savepoint b;
  release savepoint a;
  return 2;
end/

select f2()/

create trigger tg1 before insert on t1 for each row
begin
  savepoint aa;
  savepoint bb;
  release savepoint bb;
end/

insert into t1 value(2)/
--error 1305
rollback to aa/

drop procedure p1/

create procedure p1()
begin
  insert into t1 value(3);
  rollback to aa;
end/

--error 1305
call p1()/

drop procedure p1/

create procedure p1()
begin
  savepoint aa;
  insert into t1 value(3);
  rollback to aa;
end/

call p1()/

drop function f1/
drop procedure p1/
drop function f2/
drop trigger tg1/
drop table t1/

delimiter ;/
set autocommit = 1;

--disable_warnings
drop function if exists f1;
drop function if exists f2;
drop function if exists f3;
drop function if exists f4;
drop procedure if exists p1;
drop procedure if exists p2;
drop procedure if exists p3;
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1(id int);
create table t2(id int);
insert into t2 value(1);

delimiter /;
create function f1() returns int deterministic
begin
insert into t1 value(2);
insert into t1 value('dd');
return 1;
end/

#procedure调用udf场景
create procedure p1()
begin
set @a = f1();
end/

#pl内部表达式调用udf, f1内部会回滚
--error 1366
call p1()/
select * from t1/
#预期结果
#mysql> call p1()/
#ERROR 1366 (HY000): Incorrect integer value: 'dd' for column 'id' at row 1
#mysql> select * from t1/
#Empty set (0.00 sec)

drop procedure p1/
create procedure p1()
begin
insert into t1 value(4);
set @a = f1();
end/

#p1内部insert语句执行时，会开启事务，执行完直接提交事务了，f1内部报错时且有事务时需自行回滚
--error 1366
call p1()/
select * from t1/
#预期结果
#mysql> call p1/
#ERROR 1366 (HY000): Incorrect integer value: 'dd' for column 'id' at row 1
#mysql> select * from t1/
#+------+
#| id   |
#+------+
#|    4 |
#+------+
#1 row in set (0.00 sec)

delete from t1/

create procedure p2()
begin
select f1() from t2;
end/

#不开事务dml语句触发udf, f1内部dml语句会开事务，最终f1会回滚
--error 1366
call p2/
select * from t1/
#预期结果
#mysql> call p2()/
#ERROR 1366 (HY000): Incorrect integer value: 'dd' for column 'id' at row 1
#mysql> select * from t1/
#Empty set (0.00 sec)


drop procedure p2/
create procedure p2()
begin
select f1() from dual;
end/

#f1内部会回滚
--error 1366
call p2()/
select * from t1/
#预期结果
#mysql> call p2()/
#ERROR 1366 (HY000): Incorrect integer value: 'dd' for column 'id' at row 1
#mysql> select * from t1/
#Empty set (0.00 sec)


create procedure p3()
begin
update t2 set id = 2 where id = f1();
end/

#开事务dml语句触发udf, f1内部不回滚, 跟随外层dml语句回滚
--error 1366
call p3()/
select * from t1/
#预期结果
#mysql> call p3()/
#ERROR 1366 (HY000): Incorrect integer value: 'dd' for column 'id' at row 1
#mysql> select * from t1/
#Empty set (0.01 sec)


#udf调用udf场景
create function f2() returns int deterministic
begin
insert into t1 value(0);
set @a = f1();
return 2;
end/

#f2内部insert语句执行时会开启事务, f1内部insert语句执行在同一个事务内, f1报错, 由f2来负责回滚该事务
--error 1366
select f2()/
select * from t1/
#预期结果
#mysql> select f2()/
#ERROR 1366 (HY000): Incorrect integer value: 'dd' for column 'id' at row 1
#mysql> select * from t1/
#Empty set (0.00 sec)

create function f3() returns int deterministic
begin
insert into t1 value(3);
return 1;
end/

#f3内部的成功执行的dml语句也会被回滚
create function f4() returns int deterministic
begin
set @a = f3();
select f1() into @b from dual;
return 0;
end/

--error 1366
select f4()/
select * from t1/
#预期结果
#mysql> select f4()/
#ERROR 1366 (HY000): Incorrect integer value: 'dd' for column 'id' at row 1
#mysql> select * from t1/
#Empty set (0.00 sec)


delimiter ;/

--disable_warnings
drop function if exists f1;
drop function if exists f2;
drop function if exists f3;
drop function if exists f4;
drop procedure if exists p1;
drop procedure if exists p2;
drop procedure if exists p3;
drop table if exists t1;
drop table if exists t2;
--enable_warnings



create table t1(id int);
create table t2(id int);
insert into t2 value(1);

delimiter /;

create function f1() returns int deterministic
begin
insert into t1 value(2);
return 1;
end/

#procedure调用udf场景
create procedure p1()
begin
	set @a = f1();
	rollback;
end/

#pl内部表达式触发f1执行，f1内部必须提交
call p1()/
select * from t1/
#预期结果
#mysql> call p1()/
#Query OK, 0 rows affected (0.00 sec)

#mysql> select * from t1/
#+------+
#| id   |
#+------+
#|    2 |
#+------+
#1 row in set (0.00 sec)

#不开事务dml语句触发udf, f1内部执行完，不提交，由外部dml语句负责提交
create procedure p2()
begin
select f1() from t2;
rollback;
end/

call p2()/
select * from t1/
#预期结果
#mysql> select * from t1/
#+------+
#| id   |
#+------+
#|    2 |
#|    2 |
#+------+
#2 rows in set (0.00 sec)


#select f1 from dual执行完会提交事务
drop procedure p2/
create procedure p2()
begin
select f1() from dual;
rollback;
end/

call p2()/
select * from t1/
#预期结果
#mysql> select * from t1/
#+------+
#| id   |
#+------+
#|    2 |
#|    2 |
#|    2 |
#+------+
#3 rows in set (0.00 sec)

#开事务dml语句触发udf, f1内部执行完，不提交，由外部dml语句负责提交
create procedure p3()
begin
	update t2 set id = 2 where id = f1();
	rollback;
end/

call p3()/
select * from t1/
#预期结果
#mysql> select * from t1/
#+------+
#| id   |
#+------+
#|    2 |
#|    2 |
#|    2 |
#|    2 |
#+------+
#4 rows in set (0.00 sec)

delete from t1/

#udf调用udf场景
create function f2() returns int deterministic
begin
insert into t1 value(0);
set @a = f1();
return 2;
end/

#f2内部insert语句执行时会开启事务, f1内部insert语句执行在同一个事务内, f1成功执行时不提交, 由外部dml提交事务
select f2()/
rollback/
select * from t1/
#预期结果
#mysql> select * from t1/
#+------+
#| id   |
#+------+
#|    0 |
#|    2 |
#+------+
#2 rows in set (0.00 sec)


create function f3() returns int deterministic
begin
set @a = f1();
select f1() into @b from dual;
return 0;
end/

select f3()/
rollback/
select * from t1/
#预期结果
#mysql> select * from t1/
#+------+
#| id   |
#+------+
#|    0 |
#|    2 |
#|    2 |
#|    2 |
#+------+
#4 rows in set (0.00 sec



delete from t1/

drop function f1/
create function f1() returns int deterministic
begin
insert into t1 value(2);
return 1;
end/

--error 1235
set @a = f1()/
rollback/
select * from t1/

delimiter ;/

drop table t1;
drop table t2;
drop procedure p1;
drop procedure p2;
drop procedure p3;
drop function f1;
drop function f2;
drop function f3;

