set autocommit = 0;

create table t1(id int);

delimiter /;

create function f1() returns int deterministic
begin
insert into t1 value(2);
insert into t1 value('dd');
return 1;
end/

create procedure p1()
begin
insert into t1 value(4);
set @a = f1();
end/

--error 1366
call p1()/

select * from t1/

delimiter ;/

drop table t1;
drop function f1;
drop procedure p1;

#


create table t1(c0 int);

delimiter /;

create function f1() returns int deterministic
begin
insert into t1 value(2);
insert into t1 value('dd');
return 1;
end/

#udf调用udf场景
create function f2() returns int deterministic
begin
set @a = f1();
return 2;
end/

--error 1366
select f2()/
select * from t1/

drop table t1/
drop function f1/
drop function f2/

set autocommit = 1/

#

create function f1()returns int
begin
if cast('dd' as signed)>10 then
   set @a=10;
end if;
return 10;
end/

--disable_warnings
select f1()/
--enable_warnings

drop function f1/

#

delimiter ;/
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop function if exists n_1;
--enable_warnings

create table t1(stats int , s1 int , s2 int);
create table t2(id int ,s1 int, s2 int);

insert into t1 values(2,1,3),(1,0,0),(0,0,0);

delimiter /;
create function n_1() returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return 0;
end/
delimiter ;/

explain basic select n_1() from t1;

drop function n_1;
drop table t1;
drop table t2;