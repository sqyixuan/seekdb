#owner: heyongyi.hyy
#owner group: sql4/pl
#tags: pl
#description: 

--result_format 4

delimiter $$;

--disable_warnings
drop procedure if exists p1$$
--enable_warnings

create procedure p1(a int)
begin
  set a=10;
end;
$$

--disable_warnings
drop procedure if exists p2$$
--enable_warnings

create procedure p2()
begin
  declare continue handler for sqlexception 
  begin
    select 'aaa';
    resignal;
  end;
  call p1();
end;
$$

delimiter ;$$

--error 1318
call p2();