#owner group: pl/sql
#tags: pl
#description: use variable in CREATE VIEW

--result_format 4

--error 1351
CREATE PROCEDURE proc(i INT) CREATE VIEW v AS SELECT i;

delimiter /;
--error 1351
CREATE PROCEDURE proc(i INT)
BEGIN
  CREATE VIEW v AS SELECT i;
END;
/
delimiter ;/

--error 1064
CREATE VIEW v AS SELECT ?;
