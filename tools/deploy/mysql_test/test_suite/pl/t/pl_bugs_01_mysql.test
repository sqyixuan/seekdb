#####
--error 0,1396
drop user webber;
--error 0,1008
drop database wb;
--disable_warnings ONCE
create user "webber" identified by "webber";
grant all on *.* to webber with grant option;

create database wb;

sleep 2;

connect (conn1,$OBMYSQL_MS0,webber,webber,wb,$OBMYSQL_PORT);

connection conn1;

create procedure p1()
begin
end;

select routine_name, definer from information_schema.routines where routine_schema = 'wb';

connection default;

use wb;
drop user webber;

sleep 2;

select routine_name, definer from information_schema.routines where routine_schema = 'wb';

--replace_column 5 # 6 #
show procedure status like 'p1';

drop database wb;
--echo ############################end case 1############################

### 
--disable_warnings
drop database if exists hr;
--enable_warnings
create database hr;

use hr;

--disable_warnings
drop procedure if exists proc_36107210;
drop view if exists v_hr;
--enable_warnings

delimiter /;

create procedure proc_36107210()
begin
    create view v_hr as select * from notable_hr;
end
/

--error 1146
call proc_36107210()/

delimiter ;/

--error 1049
call no.p1();

drop procedure proc_36107210;
drop database hr;
