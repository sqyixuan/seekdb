#owner: heyongyi.hyy
#owner group: pl/sql
#tags: pl
#description: test SHOW CREATE PROCEDURE/FUNCTION output format

--result_format 4

delimiter /;

--disable_warnings ONCE
drop procedure if exists test;
/
--disable_warnings ONCE
drop function if exists test;
/

create procedure tEst(tEst int, `nAMe` varchar(10), age float(3))
begin
  select test;
end;
/

show create procedure test;
/

select routine_body from oceanbase.__all_routine where routine_name='test';
/

select param_list, body from mysql.proc where name='test';
/

drop procedure test;
/

create function tEst(tEst int, `nAMe` varchar(10), age float(3))
returns float(3)
begin
  return age;
end;
/

show create function test;
/

select routine_body from oceanbase.__all_routine where routine_name='test';
/

select param_list, body from mysql.proc where name='test';
/

drop function test;
/

create function tEst

(
    
    tEst int, 
    
    `nAMe` varchar(10), age float(3))

returns

float(3)

deterministic

comment 'comment'

begin
  return age;
end;
/

show create function test;
/

select routine_body from oceanbase.__all_routine where routine_name='test';
/

select param_list, body from mysql.proc where name='test';
/

set sql_quote_show_create=off;
/
show create function test;
/

set sql_quote_show_create=on;
/
show create function test;
/

drop function test;
/

set sql_mode=ANSI_QUOTES;
/

create procedure "test" ("aBc" int, `BcD` int, cDe int) begin end;
/

show create procedure test;
/

set sql_quote_show_create=off;
/
show create procedure test;
/

set sql_mode='';
/
show create procedure test;
/

set sql_quote_show_create=default;
/
show create procedure test;
/

drop procedure test;
/

delimiter ;/
