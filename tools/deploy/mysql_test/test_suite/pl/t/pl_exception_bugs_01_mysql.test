#owner: webber.wb
#owner group: sql4
#tags: pl
#description: mysql pl exception bugs

--result_format 4

--echo ############################start case 1############################
#####

--error 0,1305
DROP PROCEDURE p_exception;

delimiter /;
CREATE PROCEDURE p_exception (divisor INT,msg VARCHAR(100)) 
BEGIN 
  DECLARE errorno INT;
  SET errorno = 5;
  IF divisor = 0 THEN 
      SIGNAL SQLSTATE '45000'
      SET MESSAGE_TEXT = msg,
      MYSQL_ERRNO = errorno;
  END IF;
END;
/
delimiter ;/

--error 5
CALL p_exception(0,'message_text An error occurred');

DROP PROCEDURE p_exception;

--echo ############################end case 1#############################

--echo ############################start case 2############################
#####
delimiter /;
CREATE PROCEDURE p_exception() 
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN 
      SIGNAL SQLSTATE VALUE '99999'  SET MYSQL_ERRNO = 1101;
    END;
  DROP TABLE no_such_table;
END;
/
delimiter ;/

--error 1101
call p_exception;

drop PROCEDURE p_exception;

delimiter /;
CREATE PROCEDURE p_exception()
BEGIN 
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
      SIGNAL SQLSTATE VALUE '99999' SET MYSQL_ERRNO = NULL;
    END;
  DROP TABLE no_such_table;
END;
/
delimiter ;/

--error 1231
call p_exception;

drop PROCEDURE p_exception;
--echo ############################end case 2#############################

--echo ############################start case 3############################
#####

delimiter /;
CREATE PROCEDURE p_exception()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
      SIGNAL SQLSTATE VALUE '99999' SET MESSAGE_TEXT = 'An error occurred';
    END;
DROP TABLE no_such_table;
END;
/
delimiter ;/

--error 1644
call p_exception;

drop PROCEDURE p_exception;
--echo ############################end case 3#############################

--echo ############################start case 4############################
######

delimiter /;
--error 1646
CREATE PROCEDURE p_exception(divisor INT) 
BEGIN
  DECLARE no_such_table CONDITION FOR 1051; 
  IF divisor = 0 THEN 
    SIGNAL no_such_table;
  END IF;
END;
/
delimiter ;/
--echo ############################end case 4#############################

--echo ############################start case 5############################
#####

delimiter /;
--error 1641
CREATE PROCEDURE p_exception()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SIGNAL SQLSTATE '45000' SET MYSQL_ERRNO = 1002, MYSQL_ERRNO = 1001;
  END;
  DROP TABLE t1;
END;
/
delimiter ;/
--echo ############################end case 5#############################

--echo ############################start case 6#############################
delimiter /;
create procedure p_exception()
begin
  declare continue handler for 10000
    begin
      select 1;
    end;
  signal SQLSTATE '99999' set MESSAGE_TEXT='xxx', MYSQL_ERRNO = 10000;
end;
/

delimiter ;/

call p_exception();

drop procedure p_exception;
--echo ############################end case 6#############################

--echo ############################start case 7#############################
delimiter /;
create procedure p_exception()
begin
  signal SQLSTATE '02000' set MESSAGE_TEXT='xxx', MYSQL_ERRNO = 10000;
end;
/

--error 10000
call p_exception();
/

drop procedure p_exception;
/

create procedure p_exception()
begin
  signal SQLSTATE '02000';
end;
/
delimiter ;/

--error 1643
call p_exception();

drop procedure p_exception;
--echo ############################end case 7#############################
