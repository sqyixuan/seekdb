--disable_warnings

--error 0,1051
drop table t_test_constraint;

create table t_test_constraint(c1 int);

insert into t_test_constraint values (1);

--error 0,1360
drop trigger trg_before_delete;

delimiter /;
--error 1362
create trigger trg_before_delete before delete on t_test_constraint 
for each row
begin
  set old.c1 := 1;
end;
/

--error 1363
create trigger trg_before_delete before delete on t_test_constraint 
for each row
begin
  set new.c1 := 1;
end;
/
delimiter ;/

--error 0,1360
drop trigger trg_after_delete;

delimiter /;
--error 1362
create trigger trg_after_delete after delete on t_test_constraint 
for each row
begin
  set old.c1 := 1;
end;
/

--error 1363
create trigger trg_after_delete after delete on t_test_constraint 
for each row
begin
  set new.c1 := 1;
end;
/
delimiter ;/

