--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: linlin.xll
#owner group: sql1
#tags: pl
#description: test pl dynamic

--result_format 4

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

use test;

## bug 16739130 execute not call get_next
--disable_warnings
drop function if exists my_func_1;
drop function if exists my_func_2;
--enable_warnings

create function my_func_1() returns int return 10;
create function my_func_2() returns int return my_func_1();
prepare stmt from "select my_func_2()";
execute stmt;
execute stmt;
drop function my_func_1;
--error 1305
execute stmt;
deallocate prepare stmt;
drop function my_func_2;

--disable_warnings
drop table if exists my_tab;
drop procedure if exists my_proc;
--enable_warnings

create table my_tab(col int);
insert into my_tab values(10);
delimiter |;
create procedure my_proc()
begin
  set @v = 0;
  prepare stmt from 'select * from my_tab into @v';
  execute stmt;
  insert into my_tab values(@v);
  deallocate prepare stmt;
end |
delimiter ;|
call my_proc();
select * from my_tab;

drop table my_tab;
drop procedure my_proc;

--disable_warnings
drop table if exists my_tab;
drop procedure if exists my_proc;
--enable_warnings

create table my_tab(col int);
delimiter |;
create procedure my_proc()
begin
  prepare stmt from 'select * from my_tab;';
  execute stmt;
  deallocate prepare stmt;
end |
delimiter ;|
call my_proc();
drop table my_tab;
--error 1146
call my_proc();
drop procedure my_proc;

drop procedure IF EXISTS my_proc;
delimiter |;
create PROCEDURE my_proc()
begin
  PREPARE stmt FROM 'drop table if exists test';
  EXECUTE stmt;
end; |
delimiter ;|

--disable_warnings
call my_proc();
call my_proc();
call my_proc();
call my_proc();
call my_proc();
--enable_warnings

drop procedure my_proc;

--disable_warnings
drop table if exists a,b,t,t1;
drop procedure if exists p;
drop procedure if exists f;
drop procedure if exists pp;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection default;

create table a(a1 varchar(100));
delimiter //;
create procedure p()
begin
prepare stmt1 from "insert into a values('1')";
execute stmt1;
deallocate prepare stmt1;
end//
delimiter ;//
call p();
select * from a;
drop table a;
drop procedure p;

create table a(a1 varchar(100));
delimiter //;
create procedure p()
begin
set @stmt_str = 'insert into a values(\'1\')';
prepare stmt1 from @stmt_str;
execute stmt1;
deallocate prepare stmt1;
end//
delimiter ;//
call p();
select * from a;
drop table a;
drop procedure p;

create table a(a1 varchar(100));
delimiter //;
create procedure p(x varchar(100))
begin
set @stmt_str = 'insert into a values(?)';
prepare stmt1 from @stmt_str;
set @x = x;
execute stmt1 using @x;
deallocate prepare stmt1;
end//
delimiter ;//
call p('a');
select * from a;
drop table a;
drop procedure p;

create table a(a1 varchar(100), a2 int);
delimiter //;
create procedure p(x varchar(100), y int)
begin
set @stmt_str = 'insert into a values(?,?)';
prepare stmt1 from @stmt_str;
set @x = x, @y = y;
execute stmt1 using @x,@y;
deallocate prepare stmt1;
end//
delimiter ;//
call p('a', 1);
select * from a;
drop table a;
drop procedure p;

create table a(a1 varchar(100), a2 int);
delimiter //;
create procedure p(x varchar(100), y int)
begin
set @stmt_str = 'insert into a values(?,?)';
prepare stmt1 from @stmt_str;
set @x = x, @y = y;
execute stmt1 using @x;
deallocate prepare stmt1;
end//
delimiter ;//
--error 1210
call p('a', 1);
select * from a;
drop table a;
drop procedure p;

create table a(a1 varchar(100), a2 int);
insert into a values('a', 1);
create table b(b1 varchar(100), b2 int);
delimiter //;
create procedure p()
begin
set @stmt_str = 'select * from a into @x,@y';
prepare stmt1 from @stmt_str;
execute stmt1;
deallocate prepare stmt1;
insert into b values(@x, @y);
end//
delimiter ;//
call p();
select * from a;
select * from b;
drop table a;
drop table b;
drop procedure p;

create table a(a1 varchar(100));
insert into a values('a');
create table b(b1 varchar(100));
delimiter //;
create procedure p()
begin
set @stmt_str = 'select * from a into @x';
prepare stmt1 from @stmt_str;
execute stmt1;
deallocate prepare stmt1;
insert into b values(@x);
end//
delimiter ;//
call p();
select * from a;
select * from b;
drop table a;
drop table b;
drop procedure p;

create table a(a1 varchar(100));
insert into a values('a');
create table b(b1 varchar(100));
delimiter //;
create procedure p()
begin
set @stmt_str = 'select * from a into @x';
prepare stmt1 from @stmt_str;
execute stmt1;
deallocate prepare stmt1;
prepare stmt1 from "insert into b values(?)";
set @xx = @x;
execute stmt1 using @xx;
deallocate prepare stmt1;
end//
delimiter ;//
call p();
select * from a;
select * from b;
drop table a;
drop table b;
drop procedure p;

create table a(a1 varchar(100), a2 int);
insert into a values('a', 1);
insert into a values('b', 2);
create table b(b1 varchar(100), b2 int);
delimiter //;
create procedure p(arg int)
begin
set @stmt_str = 'select a1,a2 from a where a2 = ? into @y,@x';
prepare stmt1 from @stmt_str;
set @arg=arg;
execute stmt1 using @arg;
deallocate prepare stmt1;
insert into b values(@y, @x);
end//
delimiter ;//
select * from a;
call p(1);
select * from b;
call p(2);
select * from b;
drop table a;
drop table b;
drop procedure p;

create table a(a1 varchar(100), a2 int);
insert into a values('a', 1);
insert into a values('b', 2);
create table b(b1 varchar(100), b2 int);
delimiter //;
create procedure p(arg varchar(100))
begin
set @stmt_str = 'select * from a where a1 like ? into @x,@y';
prepare stmt1 from @stmt_str;
set @arg_str=arg;
execute stmt1 using @arg_str;
deallocate prepare stmt1;
insert into b values(@x, @y);
end//
delimiter ;//
select * from a;
call p('a');
select * from b;
call p('b');
select * from b;
drop table a;
drop table b;
drop procedure p;

create table t(a1 int);
delimiter //;
create procedure p()
begin
prepare stmt1 from "insert into t values(?)";
set @a=1;
execute stmt1 using @a;
deallocate prepare stmt1;
end //
delimiter ;//
call p();
select * from t;
drop procedure p;
drop table t;

create table t(a1 int);
insert into t values(1);
delimiter //;
create procedure p()
begin
prepare stmt1 from "select * from t where a1=?";
set @a=1;
execute stmt1 using @a;
deallocate prepare stmt1;
end //
delimiter ;//
call p();
select * from t;
drop procedure p;
drop table t;

create table t(a1 int);
delimiter //;
create procedure p()
begin
declare a varchar(20) default 'select * from ';
set @stmt_str=concat(a, 't');
prepare stmt1 from @stmt_str;
execute stmt1;
deallocate prepare stmt1;
end //
delimiter ;//
call p();
select * from t;
drop procedure p;
drop table t;

