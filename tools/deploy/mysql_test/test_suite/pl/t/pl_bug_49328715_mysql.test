--error 1064
TRIGGER t2_bi BEFORE INSERT ON td1 FOR EACH ROW SET @a = 2;

--error 0,1051
drop table td1;
--error 0,1051
drop table td2;

create table td1(c int);
--error 0,1360
drop trigger t2_bi;
CREATE TRIGGER t2_bi BEFORE INSERT ON td1 FOR EACH ROW SET @a = 2;

insert into td1 values(@a);

select * from td1;

select @a;

alter table td1 rename to td2;
set @a=0;
insert into td2 values(@a);

select * from td2;

select @a;

drop trigger t2_bi;
drop table td2;
