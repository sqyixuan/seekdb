#owner: jiabokai.jbk
#owner group: SQL-SQL4 PL/SQL
#tags: pl

--result_format 4
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection obsys;
alter system flush pl cache global;
--disable_warnings
connection default;

drop procedure if exists cacheviewp1;
drop function if exists cacheviewf1;
drop trigger if exists cacheviewt1;
drop table if exists trig_table; 
drop table if exists msg;
create table trig_table(c1 int, c2 int);
create table msg (c1 int);
alter system flush pl cache global;
alter system flush plan cache global;
delimiter /;

#proc
create procedure cacheviewp1()
begin
  select null from dual;
end;
/



#function
create function cacheviewf1() returns int
begin
DECLARE a int;
select 1 into a from dual;
return a;
end;
/

#trigger
create trigger cacheviewt1 before insert on trig_table for each row
begin
  insert into msg values (1);
end;
/

insert into trig_table values (1, 2);/
call cacheviewp1();/
select cacheviewf1() from dual;/


delimiter ;/
connection obsys;
--sorted_result
select PARAMETERIZE_TEXT,object_type from GV$ob_pl_cache_object where schema_version != -1 and PARAMETERIZE_TEXT like '%cacheview%' ORDER BY last_active_time ASC;
--sorted_result
select PARAMETERIZE_TEXT,object_type from V$ob_pl_cache_object where schema_version != -1 and PARAMETERIZE_TEXT like '%cacheview%' ORDER BY last_active_time ASC;

select STATEMENT,object_type FROM oceanbase.__all_virtual_plan_stat WHERE 
    OBJECT_STATUS = 0 AND TYPE > 5 AND TYPE < 11 AND is_in_pc=true AND schema_version != -1 AND STATEMENT like '%cacheview%';

connection default;
drop table trig_table;
drop table msg; 

drop procedure cacheviewp1;
drop trigger if exists cacheviewt1;
drop function cacheviewf1;
