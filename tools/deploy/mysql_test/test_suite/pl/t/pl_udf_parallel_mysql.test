#tags: pl,cross_validation

--result_format 4
 
--disable_warnings
drop table if exists t0;
drop table if exists t1;
drop function if exists f1;
--enable_warnings
 
create table t0(c1 int,c2 int) partition by hash(c1) partitions 4;
insert into t0 values(0,0);
insert into t0 values(1,1);
insert into t0 values(2,2);
insert into t0 values(3,3);
insert into t0 values(4,4);
insert into t0 values(5,5);
 
create table t1(c0 int);
insert into t1 values(0);
 
 
delimiter /;
create function f1() returns int
begin
declare a int;
select count(*) into a from t1 for update;
return 1;
end;
/
 
delimiter ;/
explain select  /*+ENABLE_PARALLEL_DML parallel(2) */ f1() from t0;
select  /*+ENABLE_PARALLEL_DML parallel(2) */ f1() from t0;
 
drop table t0;
drop table t1;
drop function f1;

 
--disable_warnings
drop table if exists t9;
drop table if exists t13;
drop function if exists f1;
drop function if exists FUNC_NEST_OUTER_DML_INNER_SELECT_15_1318;
--enable_warnings
 
create table t9 (c1 TIMESTAMP(3)  NOT NULL default 0,c2 BINARY(89) ,c3 BIGINT(127)  auto_increment,c4 TIMESTAMP(1)  NOT NULL default 0,c5 NUMERIC(64,5) ,c6 NUMERIC(64,16) ,c7 DATE,c8 TIMESTAMP NOT NULL default 0,c9 TIMESTAMP NOT NULL default 0,c10 DATE,c11 VARCHAR(86) ,c12 BIGINT(127) ,c13 TIMESTAMP(5)  NOT NULL default 0,c14 CHAR(152) ,c15 DECIMAL(64,6) ,c16 CHAR(152) , primary key(c16,c3,c11,c12,c2,c14))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin  PARTITION BY KEY(c16,c3) PARTITIONS 10;
create table t13 (c1 BINARY(147) ,c2 INTEGER(127) ,c3 INT(127) ,c4 TIME,c5 TIMESTAMP NOT NULL default 0,c6 DATETIME,c7 NUMERIC(64,1) ,c8 INT(127)  auto_increment,c9 BIGINT(127) ,c10 VARBINARY(52) , primary key(c7,c10,c8))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin  PARTITION BY KEY(c7,c10) PARTITIONS 10;
 
delimiter /;
 
CREATE FUNCTION FUNC_NEST_OUTER_DML_INNER_SELECT_15_1318(INTVALUE INT)
   RETURNS INT
   BEGIN
     DECLARE A, B INT;
     select ceil(rand() * 1000) INTO B from dual;
     SELECT INTVALUE INTO A FROM (select B from dual);
     SELECT count(*) - B + A + INTVALUE INTO A FROM (SELECT * FROM ((SELECT t13_15.c4 AS c1 FROM (SELECT (SELECT MIN(t13.c1) FROM t13) AS c1, (SELECT t13.c2 FROM t13 ORDER BY 1 DESC LIMIT 1) AS c2, t13.c3, t13.c4, (SELECT t13.c5 FROM t13 ORDER BY 1 LIMIT 1) AS c5, t13.c6, t13.c7, t13.c8, t13.c9, t13.c10 FROM t13) AS t13_15 WHERE '11' IN (t13_15.c3, t13_15.c3) OR 'PtsWVEFrXbmdNdERjXIeHRHhMSeXwQEPUViODkoIOyUylswpgJiAzOKlmERo' <> 'kFbeNUsrPjMprLRTvnrsZFbaDpKkLtTkDCbMdLKAJgtVebzwDtfCZNaIvVry' AND concat('JGgHsaFKIBncZKIwtKyvWpoOmYJCFYeVUDFxpgeOptVxdVBvRhfPkYFMKoeuwP', 'ACRFcfoyLFHwOowEcGT') LIKE '%Ab%' GROUP BY t13_15.c4 HAVING COUNT(t13_15.c9) <> 285 ORDER BY 1 DESC) EXCEPT (SELECT t9_5.c9 FROM t9 AS t9_5 WHERE '814' IN (t9_5.c12, t9_5.c12) OR t9_5.c7 <= (SELECT t9_5.c10 FROM t9 AS t9_5 ORDER BY 1 LIMIT 1) AND t9_5.c7 <> t9_5.c10 GROUP BY t9_5.c9 ORDER BY 1 ASC) ORDER BY 1) ORDER BY 1);
     RETURN A;
   END;/
 
delimiter ;/

explain DELETE /*+ ENABLE_PARALLEL_DML parallel(t9, 2) */ FROM t9 WHERE t9.c2='zSwSrSuGyIKFbcNlzNJmTEVwheeAQRm';
 
explain DELETE /*+ ENABLE_PARALLEL_DML parallel(t9, 2) */ FROM t9 WHERE t9.c2='zSwSrSuGyIKFbcNlzNJmTEVwheeAQRm' or t9.c3=(SELECT FUNC_NEST_OUTER_DML_INNER_SELECT_15_1318(@DEF_BIGINT_NAME) FROM DUAL) or t9.c11='ENeETgcGPsnNjIEqyLDLmEPDwcDrcRoTgCYtSUcRCUpEmBcNyXZUbbxSKFAMvVgjLIGrVW' or t9.c12=943 ;

drop table t9;
drop table t13;
drop function FUNC_NEST_OUTER_DML_INNER_SELECT_15_1318;

--disable_warnings
drop function if exists f1;
drop function if exists f2;

create table t1(c1 int);

insert into t1 value(1);

delimiter /;

create function f1() returns int no sql
begin
  declare a int;
  select count(*) into a from t1;
  return a;
end;
/

create function f2() returns int no sql
begin
  declare a int;
  insert into t1 values(1);
  return a;
end;
/

delimiter ;/


select f1() from t1;

insert into t1 values(f1());
--error 1442
update t1 set c1 = f1();
--disable_result_log
--error 1442
delete from t1 where c1 = f1();
--enable_result_log

--error 1442
select f2() from t1;

--error 1442
insert into t1 values(f2());
--error 1442
insert into t1 values(f2());
--error 1442
update t1 set c1 = f2();
--disable_result_log
--error 1442
delete from t1 where c1 = f2();
--enable_result_log

drop table t1;
drop function f1;
drop function f2;
--disable_warnings
drop table if exists t9;
drop table if exists t13;
