
#owner: linlin.xll
#owner group: sql21
#tags: pl
#description: test show create routine

--result_format 4

--disable_warnings

delimiter /;

DROP PROCEDURE IF EXISTS PROC;
/
CREATE PROCEDURE PROC() BEGIN END;
/
SHOW CREATE PROCEDURE PROC;
/

DROP PROCEDURE IF EXISTS PROC;
/
CREATE PROCEDURE PROC(x INT, y VARCHAR(4000), z DATE) BEGIN END;
/
SHOW CREATE PROCEDURE PROC;
/

DROP PROCEDURE IF EXISTS PROC;
/
CREATE PROCEDURE PROC(x TIMESTAMP) BEGIN END;
/
SHOW CREATE PROCEDURE PROC;
/

DROP FUNCTION IF EXISTS FUNC;
/
CREATE FUNCTION FUNC(x INT) RETURNS INT BEGIN RETURN 1; END;
/
SHOW CREATE FUNCTION FUNC;
/

DROP FUNCTION IF EXISTS FUNC;
/
--error 1320
CREATE FUNCTION FUNC(x INT, y VARCHAR(3000), z DATE) RETURNS VARCHAR(2500) BEGIN END;
/
--error 1305
SHOW CREATE FUNCTION FUNC;
/

DROP PROCEDURE PROC;
/
--error 1305
DROP FUNCTION func;
/

