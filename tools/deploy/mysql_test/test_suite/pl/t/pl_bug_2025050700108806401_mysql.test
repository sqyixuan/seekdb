#owner group: PL/SQL
#tags: pl
#description: mysql pl `fetch into @user_var` 

drop procedure if exists proc;
delimiter //;
--error 1064
create procedure proc()
begin
    declare cur cursor for select 1;
    open cur;
    fetch cur into @id, @id2;
    close cur;
end;
//
delimiter ;//

