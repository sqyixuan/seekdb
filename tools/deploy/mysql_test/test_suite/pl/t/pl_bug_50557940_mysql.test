#owner: webber.wb
#owner group: pl/sql
#tags: pl,cross_validation,trigger
#description: 

--result_format 4


--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
--error 0,1360
drop trigger trg_affect_1;
--error 0,1360
drop trigger trg_affect_2;
--error 0,1360
drop trigger trg_affect_3;
--error 0,1305
drop function func_affect;

create table t1 (c1 int);
create table t2 (c1 int);

create trigger trg_affect_1 before insert on t1 for each row
insert into t2 values (new.c1);

create trigger trg_affect_2 before update on t1 for each row
update t2 set c1 = new.c1 where c1 = old.c1;

create trigger trg_affect_3 before delete on t1 for each row
delete from t2 where c1 = old.c1;

insert into t1 values (1);
select row_count();

insert into t1 values (2);
select row_count();

update t1 set c1 = 11 where c1 = 1;
select row_count();

update t1 set c1 = 22 where c1 = 2;
select row_count();

delete from t1;
select row_count();

update t1 set c1 = 100;
select row_count();

delimiter /;
create function func_affect() returns int
BEGIN
  insert into t2 values (2);
  return 10;
END;
/
delimiter ;/

drop trigger trg_affect_1;
insert into t1 values (func_affect());
select row_count();

drop table t1;
drop table t2;
drop function func_affect;
