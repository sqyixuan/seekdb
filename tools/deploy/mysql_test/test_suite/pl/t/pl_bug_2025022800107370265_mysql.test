#owner: haohao.hao
#owner group: PL/SQL
#tags: pl
#description: decimal int

--result_format 4

--disable_warnings
--error 0, 1051
drop table if exists t1;

create table t1(f1 decimal(22,1));
insert into t1 values (1);
create trigger t1_bi before
    insert on t1 for each row set new.f1=(
        select sum(f1) from t1
    );

insert into t1 values (1003);
insert into t1 values (1003);
insert into t1 values (1003);

select * from t1 order by f1;

drop table t1;
