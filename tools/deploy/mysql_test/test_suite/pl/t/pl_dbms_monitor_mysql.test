#owner：xiaoyi.xy
#owner group: sql2
#description: package dbms_monitor test
#tags: pl

--result_format 4
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
alter system flush plan cache global;
alter system flush pl cache global;

connection default;

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

--disable_warnings

set @@ob_query_timeout=1000000000;

delimiter //;

#test for dbms monitor, session level
--error 4179
call dbms_monitor.ob_session_trace_enable(123, 1, 1, 'ALL'); //
--sleep 5
call dbms_monitor.ob_session_trace_enable(NULL, 1, 0.01, 'ALL'); //
--sleep 5

--error 4179
call dbms_monitor.ob_session_trace_disable(123); //
--sleep 5
call dbms_monitor.ob_session_trace_disable(NULL); //
--sleep 5

#test for dbms monitor, mod act level
--error 0,4179
call dbms_monitor.ob_mod_act_trace_disable('mod', 'act'); //
--sleep 5
call dbms_monitor.ob_mod_act_trace_enable('mod', 'act', 1, 0.01, 'ALL'); //
--sleep 5
--error 4179
call dbms_monitor.ob_mod_act_trace_enable('mod', 'act', 1, 1, 'ALL'); //
--sleep 5

call dbms_monitor.ob_mod_act_trace_disable('mod', 'act'); //
--sleep 5
--error 4179
call dbms_monitor.ob_mod_act_trace_disable('mod', 'act'); //
--sleep 5

#test for dbms monitor, client id level
call dbms_monitor.ob_client_id_trace_enable('cli', 1, 0.01, 'ALL'); //
--sleep 5
--error 4179
call dbms_monitor.ob_client_id_trace_enable('cli', 1, 1, 'ALL'); //
--sleep 5

call dbms_monitor.ob_client_id_trace_disable('cli'); //
--sleep 5
--error 4179
call dbms_monitor.ob_client_id_trace_disable('cli'); //
--sleep 5

#test for dbms monitor, tenant level
--error 0,4179
call dbms_monitor.ob_tenant_trace_disable(); //
--sleep 5

call dbms_monitor.ob_tenant_trace_enable(1, 0.01, 'ALL'); //
--sleep 5
--error 4179
call dbms_monitor.ob_tenant_trace_enable(1, 1, 'ALL'); //
--sleep 5

call dbms_monitor.ob_tenant_trace_disable(); //
--sleep 5
--error 4179
call dbms_monitor.ob_tenant_trace_disable(); //
--sleep 5

delimiter ;//

connection my_obsys;
disconnect my_obsys;

