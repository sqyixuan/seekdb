DELIMITER ;//

SELECT DATA_TYPE,ORDINAL_POSITION,DTD_IDENTIFIER,NUMERIC_PRECISION ,NUMERIC_SCALE FROM information_schema.parameters WHERE SPECIFIC_NAME ='proc_test_parameters';

DELIMITER //;
drop PROCEDURE proc_test_parameters;//
CREATE PROCEDURE proc_test_parameters(IN empId DATETIME(3))
BEGIN
    DECLARE baseSalary DECIMAL(10,2); 
    set @a= empId;
END; //
DELIMITER ;//

SELECT data_type, ORDINAL_POSITION,DTD_IDENTIFIER,NUMERIC_PRECISION ,NUMERIC_SCALE,DATETIME_PRECISION FROM information_schema.parameters WHERE SPECIFIC_NAME ='proc_test_parameters';

DELIMITER //;
drop PROCEDURE proc_test_parameters;//
CREATE PROCEDURE proc_test_parameters(IN empId BINARY,IN empId1 BINARY(200), empid2 varbinary(1), empId3 varbinary(100), empid4 char charset binary, empid5 varchar(100) charset binary)
BEGIN
    DECLARE baseSalary DECIMAL(10,2); 
    set @a= empId1;
END; //
DELIMITER ;//

SELECT PARAMETER_NAME , DATA_TYPE ,DTD_IDENTIFIER, CHARACTER_MAXIMUM_LENGTH , CHARACTER_OCTET_LENGTH FROM information_schema.parameters WHERE SPECIFIC_NAME ='proc_test_parameters';

DELIMITER //;
drop PROCEDURE proc_test_parameters;//
CREATE PROCEDURE proc_test_parameters(IN empId TINYBLOB, empid2 blob, empid3 mediumblob, empid4 longblob, empid5 tinytext, empid6 text, empid7 mediumtext, empid8 longtext)
BEGIN
    DECLARE baseSalary DECIMAL(10,2); 
    set @a= empId;
END; //
DELIMITER ;//

SELECT PARAMETER_NAME , DATA_TYPE , DTD_IDENTIFIER,CHARACTER_MAXIMUM_LENGTH , CHARACTER_OCTET_LENGTH FROM information_schema.parameters WHERE SPECIFIC_NAME ='proc_test_parameters';

DELIMITER //;
drop PROCEDURE proc_test_parameters;//
CREATE PROCEDURE proc_test_parameters(IN empId  TEXT CHARACTER SET utf8mb4 COLLATE utf8mb4_bin,IN empId1 TEXT)
BEGIN
    DECLARE baseSalary DECIMAL(10,2); 
    set @a= empId;
END; //
DELIMITER ;//


SELECT PARAMETER_NAME , DATA_TYPE , DTD_IDENTIFIER, CHARACTER_MAXIMUM_LENGTH , CHARACTER_OCTET_LENGTH FROM information_schema.parameters WHERE SPECIFIC_NAME ='proc_test_parameters';

DELIMITER //;
drop PROCEDURE proc_test_parameters;//
CREATE PROCEDURE proc_test_parameters(IN empId  ENUM('value1','value2','value3','value4') CHARACTER SET utf8mb4 COLLATE utf8mb4_bin,IN empId1 ENUM('value1','value2'))
BEGIN
    DECLARE baseSalary DECIMAL(10,2); 
    set @a= empId;
END; //
DELIMITER ;//

SELECT PARAMETER_NAME , DATA_TYPE , CHARACTER_MAXIMUM_LENGTH , CHARACTER_OCTET_LENGTH FROM information_schema.parameters WHERE SPECIFIC_NAME ='proc_test_parameters';

DELIMITER //;
drop PROCEDURE proc_test_parameters;//
CREATE PROCEDURE proc_test_parameters(IN empId  SET('value1','value2','value3','val') CHARACTER SET utf8mb4 COLLATE utf8mb4_bin,IN empId1 SET('value1','value2'))
BEGIN
    DECLARE baseSalary DECIMAL(10,2); 
    set @a= empId;
END; //
DELIMITER ;//

SELECT PARAMETER_NAME , DATA_TYPE , CHARACTER_MAXIMUM_LENGTH , CHARACTER_OCTET_LENGTH FROM information_schema.parameters WHERE SPECIFIC_NAME ='proc_test_parameters';

drop procedure proc_test_parameters;