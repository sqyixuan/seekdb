BEGIN
    DECLARE baseSalary DECIMAL(10,2); 
    set @a= empId;
END; //
DELIMITER ;//

SELECT data_type, ORDINAL_POSITION,DTD_IDENTIFIER,NUMERIC_PRECISION ,NUMERIC_SCALE FROM information_schema.parameters WHERE SPECIFIC_NAME ='proc_test_parameters';

DELIMITER //;
drop PROCEDURE proc_test_parameters;//
