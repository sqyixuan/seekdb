#owner: hr351303
#owner group: sql4
#description: pl cache
#tags: pl

--disable_warnings
drop table if exists t1;
drop procedure if exists p1;
--enable_warnings

create table t1(id int);

delimiter /;

create procedure p1()
begin
  insert into t1 value(1);
end/

call p1()/

#需要从pl cache中拿到routine
call p1()/

drop table t1/

create table t1(id int)/

#需要淘汰pl cache中的cache node，重新编译routine并add
call p1()/

drop table t1/

#依赖表不存在, 需要淘汰pl cache中的cache node, 重新编译时报错
--error 1146
call p1()/

create table t1(id int)/

drop procedure p1/

create procedure p1()
begin
  insert into t1 value(1);
end/

#routine id已变更, 生成新的cache node，原有的cache node靠定时任务清理
call p1()/

#改变exec env, 生成新的cache node
SET SQL_MODE=NO_AUTO_VALUE_ON_ZERO/

delimiter ;/

call p1();

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection conn_admin;
alter system flush pl cache global;

connection default;

call p1();

drop table t1;
drop procedure p1;