--result_format 4

--error 0,1051
drop table t0;
--error 0,1051
drop table t1;
--error 0,1051
drop view f1;
--error 0,1305
drop procedure distinct;

CREATE TABLE t1 (f1 int(10) unsigned NOT NULL, f2 int(10) unsigned NOT NULL, f3 smallint(5) unsigned NOT NULL);
create table t0(c1 int, c2 float, c3 number, c4 varchar(10), c5 datetime);
CREATE VIEW f1 AS select t0.c1 AS c1, t0.c2 AS c2, t0.c3 AS c3, t0.c4 AS c4, t0.c5 AS c5 from t0;

drop table t0;
--disable_warnings
CREATE PROCEDURE distinct() SELECT * FROM t1  where f2=f1;
--enable_warnings

--error 1356
call distinct();

drop procedure distinct;
drop view f1;
drop table t1;