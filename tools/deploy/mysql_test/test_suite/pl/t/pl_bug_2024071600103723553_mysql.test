--result_format 4

drop procedure if exists test_invalid;

DELIMITER //;
create procedure test_invalid(IN a int, IN b set('abc','def'))
BEGIN
    DECLARE v1 INT;
    SET a = 2;
    SET b = 2;
    SET v1 = a + 2;
    SELECT v1;
END //
DELIMITER ;//

select DTD_IDENTIFIER from information_schema.parameters where SPECIFIC_NAME ='test_invalid';


drop procedure test_invalid;
DELIMITER //;
create procedure test_invalid(IN a enum('abc哈哈哈哈','def', '101'))
BEGIN
    DECLARE v1 INT;
    SET a = 2;
    SET v1 = a + 2;
    SELECT v1;
END //
DELIMITER ;//

select DTD_IDENTIFIER from information_schema.parameters where SPECIFIC_NAME ='test_invalid';

drop procedure test_invalid;
