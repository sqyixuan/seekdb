#owner group: sql4
#tags: pl
#description: 

--result_format 4

--disable_warnings ONCE
drop table if exists  t1;
--disable_warnings ONCE
drop table if exists  t2;
--disable_warnings ONCE
drop function if exists  f1;
--disable_warnings ONCE
drop procedure if exists  p1;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
delimiter //;
CREATE PROCEDURE p1()
begin
    insert into t1 values(2,'dddd',2.32);
    insert into t2 values(2,'dddd',3.120);
    insert into t2 values(222,'ssss',0.012);
end//
delimiter ;//
--error 1064
call p1(select c1 from t1);
--error 1064
call p1((select c1 from t1);
--error 1064
call p1(select c1 from t1));
--error 1318
call p1((select c1 from t1));
--error 1064
call p1(set @a=1);
--error 1064
call p1((set @a=1);
--error 1064
call p1(set @a=1));
--error 1064
call p1((set @a=1));
--error 1064
call p1(());

select @a;
select count(*) from t1;
select count(*) from t2;

delimiter //;
create function f1() returns int
begin
return 0;
end;
//
delimiter ;//
--error 1064
select f1(select 1);
--error 1318
select f1((select 1));
