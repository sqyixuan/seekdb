--echo ############ case
--error 0,1305
drop FUNCTION FUN13_5;
--error 0,1305
drop PROCEDURE pro13_6;
--error 0,1305
drop PROCEDURE pro13_7;

DELIMITER /;
CREATE FUNCTION FUN13_5(arg ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR','ENUM')) RETURNS SET('','null', 'one', 'two','three','four','set') DETERMINISTIC
BEGIN
  RETURN arg;
END 
/
CREATE PROCEDURE pro13_6(in arg ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR','ENUM'))
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR','ENUM') default 'ONE';
  declare var2 SET('','NULL', 'ONE', 'TWO','THREE','FOUR','SET') default 'TWO';
  SELECT arg,var1,var2;
  set var1 = var2;
  set arg = var2;
  SELECT arg,var1,var2;
  set var2 = concat(arg,',NULL');
  SELECT arg,var1,var2;
END 
/
CREATE PROCEDURE pro13_7(in arg1 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR','ENUM'),in arg2 SET('','NULL', 'ONE', 'TWO','THREE','FOUR','SET'))
BEGIN
  if arg1 != arg2 then
    if arg1> arg2 then
      SELECT 'arg1 > arg2 ',arg1,arg2;
    else
      SELECT 'arg1 < arg2 ',arg1,arg2;
    end if;
  else
    SELECT 'arg1 = arg2 ',arg1,arg2;
  end if;
END 
/
DELIMITER ;/

select FUN13_5(NULL);
select FUN13_5('');
select FUN13_5('   ');
select FUN13_5('NULL   ');
select FUN13_5('THREE');
--error 1265
select FUN13_5('ENUM');
--error 1265
select FUN13_5(7);

call pro13_6(NULL);
call pro13_6('');
call pro13_6('THREE');

call pro13_7(null,null);
call pro13_7(null,'ONE');
call pro13_7('ONE',null);
call pro13_7('','');
call pro13_7('ONE','ONE');
call pro13_7('ONE','TWO');
call pro13_7('ENUM','SET');
call pro13_7('ONE','ONE,TWO');
call pro13_7('ENUM',',ONE');
call pro13_7('ENUM','');

drop FUNCTION FUN13_5;
drop PROCEDURE pro13_6;
drop PROCEDURE pro13_7;

