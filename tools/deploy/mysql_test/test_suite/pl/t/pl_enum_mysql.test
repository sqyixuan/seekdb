--error 0,1051
drop table tab0;
CREATE TABLE tab0 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    c1 ENUM('','NULL', 'one', 'TWO','Three','FouR') NOT NULL,
    c1_index int as (c1) STORED,
    c2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two') DEFAULT '',
    c2_index int as (c2+0) STORED,
    c3 VARCHAR(255));
INSERT INTO tab0(c1,c2,c3) VALUES ('', '', '空枚举值');
INSERT INTO tab0(c1,c2,c3) VALUES ('NULL', NULL, 'NULL');
