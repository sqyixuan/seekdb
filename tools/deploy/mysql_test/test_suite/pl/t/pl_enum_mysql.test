INSERT INTO tab0(c1,c2,c3) VALUES ('4', '4', '下标');
INSERT INTO tab0(c1,c2,c3) VALUES (5, 5, '下标');
INSERT INTO tab0(c1,c2,c3) VALUES ('FouR', '4.0','枚举值');
select * from tab0 order by 1;

