--echo ############ ◆◆ 存储过程
--echo #### 变量类型
--echo #### 参数类型 in/inout
--error 0,1305
drop PROCEDURE my_pro4_1;
--error 0,1305
drop PROCEDURE my_pro4_2;
--error 0,1305
drop PROCEDURE my_pro4_3;

DELIMITER /;
CREATE PROCEDURE my_pro4_1(in arg ENUM('','null', 'one', 'two','three','four'))
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO') default null;
  SELECT var1 default_value;
END;
/
CREATE PROCEDURE my_pro4_2(inout arg ENUM('','null', 'one', 'two','three','four'))
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'ONE';
  declare var2 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'TWO';
  SELECT var1, var2, arg;
  set var1 = arg;
  set arg  = var2;
  set var2 = 'four';
  SELECT var1 ,var2, arg;
END;
/
CREATE PROCEDURE my_pro4_3()
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'THREE';
  declare var2 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'FOUR';
  SELECT var1, var2;
  call my_pro4_2(var1);
  call my_pro4_2(var2);
  SELECT var1 ,var2;
END;
/
DELIMITER ;/

call my_pro4_1('   ');
call my_pro4_1('two');
call my_pro4_1(concat('T','wo'));
call my_pro4_1(4);
call my_pro4_1(5);
call my_pro4_1('three');

set @arg='three';
call my_pro4_2(@arg);
SELECT @arg;

set @arg=2;
call my_pro4_2(@arg);
SELECT @arg;

call my_pro4_3();

--echo #### 变量类型 out
--error 0,1305
drop PROCEDURE my_pro5_1;
--error 0,1305
drop PROCEDURE my_pro5_2;
--error 0,1305
drop PROCEDURE my_pro5_3;

DELIMITER /;
CREATE PROCEDURE my_pro5_1(out out_arg ENUM('','null', 'one', 'two','three','four'))
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO') default null;
  set out_arg = var1;
  SELECT out_arg;
  set out_arg = 'ONE';
  SELECT out_arg;
  set out_arg = 3;
  SELECT out_arg;
  set out_arg = @var;
  SELECT out_arg;
END;
/
CREATE PROCEDURE my_pro5_2(in in_arg ENUM('','null', 'one', 'two','three','four'),inout inout_arg ENUM('','null', 'one', 'two','three','four'),out out_arg ENUM('','null', 'one', 'two','three','four'))
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'ONE';
  declare var2 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'TWO';
  set inout_arg = in_arg;
  SELECT inout_arg;
  set out_arg = in_arg;
  SELECT out_arg;
  set out_arg = inout_arg;
  SELECT out_arg;
END;
/
CREATE PROCEDURE my_pro5_3()
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'ONE';
  declare var2 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'TWO';
  declare var3 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'THREE';
  SELECT var1, var2, var3;
  call my_pro5_2(var1,var2,var3);
  SELECT var1 ,var2;
END;
/
DELIMITER ;/

set @var='two';
call my_pro5_1(@var);
select @var;

set @var1='two';
set @var2='THREE';
set @var3='FOUR';
call my_pro5_2(@var1,@var2,@var3);
select @var1,@var2,@var3;

call my_pro5_3();

drop PROCEDURE my_pro5_1;
drop PROCEDURE my_pro5_2;
drop PROCEDURE my_pro5_3;

--error 0,1305
drop PROCEDURE my_pro5_4;

DELIMITER /;
CREATE PROCEDURE my_pro5_4(arg ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR'))
BEGIN
  declare var1 ENUM('one', 'two') default 'one';
  declare var2 ENUM('','null', 'one', 'two') default 'two';
  declare var3 ENUM('','null', 'one', 'two','1','2','3') default '3';
  select var1,var2,var3,arg;
  set arg = var1;
  set var3 = var2;
  select var1,var2,var3,arg;
END 
/
DELIMITER ;/

call my_pro5_4('     ');
call my_pro5_4('THREE');
call my_pro5_4('three');
--error 1265
call my_pro5_4('  three  ');
--error 1265
call my_pro5_4('xxxxx');

drop PROCEDURE my_pro5_4;

--echo ############ ◆◆ 触发器
--echo #### NEW.columnName 和 OLD.columnName 枚举值
--error 0,1360
drop trigger my_tri6_1;
--error 0,1360
drop trigger my_tri6_2;
--error 0,1360
drop trigger my_tri6_3;

DELIMITER /;
create trigger my_tri6_1 before insert on tab1 for each row
begin
  declare var1 ENUM('','NULL', 'one', 'TWO','Three','FouR') DEFAULT 'two';
  declare var2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two') DEFAULT '2';
  INSERT INTO tab2(c1,c2,c3) VALUES (new.c1,new.c2,new.c3);
  set new.c1=var1;
  set new.c2=(select var2);
  set new.c3=111;
  INSERT INTO tab2(c1,c2,c3) VALUES (new.c1,new.c2,new.c3);
end;
/
create trigger my_tri6_2 before update on tab1 for each row
begin
  INSERT INTO tab2(c1,c2,c3) VALUES (old.c1,old.c2,old.c3);
  INSERT INTO tab2(c1,c2,c3) VALUES (new.c1,new.c2,new.c3);
  set new.c1='Three';
  set new.c2= (select c2 from tab2 where id = 1);
  set new.c3=222;
  INSERT INTO tab2(c1,c2,c3) VALUES (new.c1,new.c2,new.c3);  
end;
/
create trigger my_tri6_3 before delete on tab1 for each row
begin
  INSERT INTO tab2(c1,c2,c3) VALUES (old.c1,old.c2,old.c3);
end;
/
DELIMITER ;/

select * from tab1 order by 1;
select * from tab2 order by 1;

INSERT INTO tab1(c1,c2,c3) VALUES ('one', '-1',10);
select * from tab1 order by 1;
select * from tab2 order by 1;

update tab1 set c1='NULL',c2='NULL',c3=20 where id = 2;
select * from tab1 order by 1;
select * from tab2 order by 1;

delete from tab1 where id = 1;
select * from tab1 order by 1;
select * from tab2 order by 1;

drop trigger my_tri6_1;
drop trigger my_tri6_2;
drop trigger my_tri6_3;

--echo #### 枚举变量进行比较 IF
--echo ## 函数中
--error 1305
drop FUNCTION MY_FUN7_1;

DELIMITER /;
CREATE FUNCTION MY_FUN7_1(arg1 ENUM('','NULL', 'one', 'TWO','Three','FouR'),arg2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two')) RETURNS INT DETERMINISTIC
BEGIN
  IF arg1 != arg2 THEN
    IF arg1 > arg2 THEN
      INSERT INTO tab2(c3) VALUES ('arg1 > arg12');
    else
      INSERT INTO tab2(c3) VALUES ('arg1 < arg12');
    END IF;
  else
    INSERT INTO tab2(c3) VALUES ('arg1 = arg12');
  END IF;
  RETURN arg1;
END 
/
DELIMITER ;/

delete from tab2;

select MY_FUN7_1('one', '-1');
select c3 from tab2 order by 1;

select MY_FUN7_1('one', 'One');
select c3 from tab2 order by 1;

drop FUNCTION MY_FUN7_1;

--echo ## 存储过程中
--error 1305
drop PROCEDURE pro7_2;

DELIMITER /;
CREATE PROCEDURE pro7_2(arg1 ENUM('','NULL', 'one', 'TWO','Three','FouR'),arg2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two'))
begin
  IF arg1 != arg2 THEN
    IF arg1 > arg2 THEN
      select 'arg1 > arg2 ';
    else
      select 'arg1 < arg2';
    END IF;
  else
    select 'arg1 = arg2';
  END IF;
end;
/
DELIMITER ;/

call pro7_2('one', '-1');
call pro7_2('one', 'One');
drop PROCEDURE pro7_2;

--echo ## 触发器中
--error 0,1360
drop trigger my_tri7_3;

DELIMITER /;
create trigger my_tri7_3 before insert on tab1 for each row
begin
  DECLARE str1 ENUM('','NULL', 'one', 'TWO','Three','FouR') DEFAULT 'one';
  DECLARE str2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two') DEFAULT 'Two';
  IF new.c1 != new.c2 THEN
    if new.c2 > new.c1 THEN
      set new.c2 = 6;
      INSERT INTO tab2(c1,c2,c3) VALUES (new.c1,new.c2,concat('new.c1 > new.c2 ',new.c3));
    else
      set new.c1 = str1;
      set new.c2 = str2;
      INSERT INTO tab2(c1,c2,c3) VALUES (new.c1,new.c2,concat('new.c1 < new.c2 ',new.c3));
    END IF;
  else
    set new.c1 = str1;
    set new.c2 = str2;
    INSERT INTO tab2(c1,c2,c3) VALUES (new.c1,new.c2,concat('new.c1 = new.c2 ',new.c3));
  END IF;
end;
/
DELIMITER ;/

delete from tab1 where id > 2;
delete from tab2;

INSERT INTO tab1(c1,c2,c3) VALUES ('one', '-1',1);
select * from tab1 order by 1;
select * from tab2 order by 1;

INSERT INTO tab1(c1,c2,c3) VALUES ('one', 'One',2);
select * from tab1 order by 1;
select * from tab2 order by 1;

INSERT INTO tab1(c1,c2,c3) VALUES ('FouR', 'Two',3);
select * from tab1 order by 1;
select * from tab2 order by 1;

INSERT INTO tab1(c1,c2,c3) VALUES ('FouR', '-1',4);
select * from tab1 order by 1;
select * from tab2 order by 1;

drop trigger my_tri7_3;

--echo #### 枚举变量进行比较 CASE
--echo ## 函数中
--error 0,1305
drop FUNCTION MY_FUN7_4;

DELIMITER /;
CREATE FUNCTION MY_FUN7_4(arg1 ENUM('','NULL', 'one', 'TWO','Three','FouR'),arg2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two')) RETURNS varchar(2000) DETERMINISTIC
BEGIN
  declare res varchar(2000);
  CASE arg1
    WHEN ''     THEN SET res = '【WHEN 空分支 1】';
    WHEN 'NULL' THEN SET res ='【WHEN NULL分支 2】';
    WHEN arg2     THEN SET res= '【WHEN arg2分支 3】';
    ELSE SET res = '【ELSE分支 4】';
  END CASE; 
  RETURN res;
END 
/
DELIMITER ;/

select MY_FUN7_4('', '-1');
select MY_FUN7_4('NULL', 'One');
select MY_FUN7_4('NULL', 'NULL');

drop FUNCTION MY_FUN7_4;

--echo ## 存储过程中
--error 0,1305
drop PROCEDURE pro7_5;

DELIMITER /;
CREATE PROCEDURE pro7_5(arg1 ENUM('','NULL', 'one', 'TWO','Three','FouR'),arg2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two'))
begin
  CASE arg1
    WHEN ''     THEN select '【WHEN 空分支 1】';
    WHEN 'NULL' THEN select '【WHEN NULL分支 2】';
    WHEN arg2   THEN select  '【WHEN arg2分支 3】';
    ELSE select '【ELSE分支 4】';
  END CASE; 
end;
/
DELIMITER ;/


call pro7_5('', '-1');

call pro7_5('NULL', '-1');

call pro7_5('one', 'One');

drop PROCEDURE pro7_5;

--echo ## 触发器中
--error 0,1360
drop trigger my_tri7_6;

DELIMITER /;
create trigger my_tri7_6 before update on tab1 for each row
begin
  CASE new.c1
    WHEN old.c1 THEN SET new.c1 = 'one';SET new.c2 = 'One';SET new.c3 = concat('【WHEN old.c1分支 1】',old.c3);
    WHEN ''     THEN SET new.c1 = 'TWO';SET new.c2 = 'Two';SET new.c3 = concat('【WHEN 空分支 2】',old.c3);
    WHEN 'NULL' THEN SET new.c1 = 'Three';SET new.c2 = '3.14';SET new.c3 = concat('【WHEN NULL分支 3】',old.c3);
    ELSE SET new.c1 = 'FouR';SET new.c2 = '4.0';SET new.c3 = concat('【ELSE分支 4】',old.c3);
  END CASE; 
  INSERT INTO tab2(c1,c2,c3) VALUES (old.c1,old.c2,concat('old.xxx ',old.c3));
  INSERT INTO tab2(c1,c2,c3) VALUES (new.c1,new.c2,concat('new.xxx ',new.c3));
end;
/
DELIMITER ;/

delete from tab1;
delete from tab2;
INSERT INTO tab1 VALUES (2,'TWO', '2','2');
select * from tab1 order by 1;
select * from tab2 order by 1;


update tab1 set c1='TWO',c2='2',c3=2 where id = 2;
select * from tab1 order by 1;
select * from tab2 order by 1;


update tab1 set c1='',c2='',c3=30 where id = 2;
select * from tab1 order by 1;
select * from tab2 order by 1;


update tab1 set c1='NULL',c2='NULL',c3=30 where id = 2;
select * from tab1 order by 1;
select * from tab2 order by 1;


update tab1 set c1='one',c2='NULL',c3=30 where id = 2;
select * from tab1 order by 1;
select * from tab2 order by 1;

drop trigger my_tri7_6;


--echo ############ ◆◆ 子查询返回类型是enum类型枚举值赋值给变量
--error 0,1305
drop PROCEDURE pro8_1;

delete from tab1;
INSERT INTO tab1 VALUES (3,'TWO', '2','2');
select * from tab1 order by 1;

DELIMITER /;
CREATE PROCEDURE pro8_1(arg1 ENUM('','NULL', 'one', 'TWO','Three','FouR'))
begin
  declare var1 ENUM('','NULL', 'one', 'TWO','Three','FouR');
  set var1 = (select arg1);
  select var1;
  set var1 = (select c1 from tab1 where id = 3);
  select var1;
end;
/
DELIMITER ;/

call pro8_1('');
call pro8_1('NULL');
call pro8_1('one');

drop PROCEDURE pro8_1;

--echo ############ ◆◆ PL中枚举变量赋值给用户自定义变量
--error 0,1305
drop PROCEDURE pro9_1;

DELIMITER /;
CREATE PROCEDURE pro9_1(arg1 ENUM('one', 'TWO','Three','FouR'))
begin
  declare var1 ENUM('one', 'TWO','Three','FouR') default 'TWO';
  set @var1 = var1;
  set @var2 = arg1;
  set @var3 = (select var1 from dual);
  select arg1 into @var4 from dual;
  select @var1,@var2,@var3,@var4;
end;
/
DELIMITER ;/

call pro9_1('one');
select @var1,@var2,@var3,@var4;

drop PROCEDURE pro9_1;

--echo ############ ◆◆ 游标中使用枚举值
--error 0,1305
drop PROCEDURE pro10_1;

DELIMITER /;
CREATE PROCEDURE pro10_1()
BEGIN
    DECLARE done BOOLEAN DEFAULT FALSE;
    DECLARE var1 ENUM('','NULL', 'one', 'TWO','Three','FouR') DEFAULT 'one';
    DECLARE var2 ENUM('','NULL', '-1', '2', '3.14', '4.0', 'One', 'Two') DEFAULT 'Two';
    DECLARE cursor_name CURSOR FOR SELECT c1, c2 FROM tab0 order by id;
    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;
    OPEN cursor_name;
    read_loop: LOOP
        FETCH cursor_name INTO var1, var2;
        IF done THEN
            LEAVE read_loop;
        END IF;
        SELECT var1, var2;
    END LOOP;
    CLOSE cursor_name;
END;
/
DELIMITER ;/

call pro10_1();

drop PROCEDURE pro10_1;

--echo ############ ◆◆ 动态sql中使用枚举值
SET @sql = 'SELECT c1, c2 FROM tab0 order by id';
PREPARE stmt FROM @sql;
EXECUTE stmt;
DEALLOCATE PREPARE stmt;

SET @sql = 'SELECT c1, c2 FROM tab0 where c1 = ? order by id';
SET @c1 ='Three';
SET @c2 = 3;
PREPARE stmt FROM @sql;
EXECUTE stmt using @c1;
EXECUTE stmt using @c2;
DEALLOCATE PREPARE stmt;

--echo ############ ◆◆ 循环结构中使用枚举值
--error 0,1305
drop PROCEDURE pro11_1;
--error 0,1305
drop PROCEDURE pro11_2;

DELIMITER /;
CREATE PROCEDURE pro11_1(inout arg ENUM('','NULL', 'one', 'TWO','Three','FouR'))
BEGIN
  WHILE arg > 1 DO
    select arg;
    SET arg = arg - 1;
  END WHILE;
END;
/
CREATE PROCEDURE pro11_2(inout arg ENUM('','NULL', 'one', 'TWO','Three','FouR'))
  BEGIN
    loop_label1: LOOP
      select arg;
      SET arg = arg - 1;
      IF arg = 2 THEN
        select 'ITERATE';
        ITERATE loop_label1;
      END IF;
      IF arg = 1 THEN
        select 'LEAVE';
        LEAVE loop_label1;
      END IF; 
    END LOOP loop_label1;
END;
/
DELIMITER ;/

SET @var1 ='FouR';
call pro11_1(@var1);

SET @var2 ='FouR';
call pro11_2(@var2);

drop PROCEDURE pro11_1;
drop PROCEDURE pro11_2;

--echo ############ ◆◆ 枚举值与内置函数正交
# 字符函数
--error 0,1305
drop PROCEDURE pro12_1;

DELIMITER /;
CREATE PROCEDURE pro12_1(arg ENUM('','NULL', 'one', 'TWO','Three','FouR'))
BEGIN
  declare var1 ENUM('','NULL', 'one', 'TWO','Three','FouR') default 'one';
  declare var2 ENUM('','null', 'one', 'two','three','four','1','2','3','4') default 'TWO';
  select ASCII(arg),CHAR_LENGTH(arg),LENGTH(arg),SOUNDEX(arg),HEX(WEIGHT_STRING(arg AS CHAR(4)));
  select upper(arg),CONCAT(var1, arg),INSERT(arg,0,3,var1),LPAD(arg,10,var1),LEFT(arg,2),MID(arg,1,2);
  select FIELD(arg, var1,var2),FIND_IN_SET(arg,var2),HEX(arg),INSTR(arg,var2),OCT(arg),UNHEX(arg);
  select POSITION(arg IN var2),QUOTE(arg),REPLACE(arg, arg, var1),REVERSE(arg),SUBSTR(arg, 0,3),SUBSTRING_INDEX(arg, var2, 1);
  select arg rlike var1,arg rlike var2,STRCMP(var1,arg),STRCMP(var2,arg);
END;
/
DELIMITER ;/
--error 5083
call pro12_1('TWO');

drop PROCEDURE pro12_1;

# 有问题函数
--error 0,1305
drop PROCEDURE pro12_2;

DELIMITER /;
CREATE PROCEDURE pro12_2(arg ENUM('','NULL', 'one', 'TWO','Three','FouR'))
BEGIN
  declare var1 ENUM('','NULL', 'one', 'TWO','Three','FouR') default 'one';
  declare var2 ENUM('','null', 'one', 'two','three','four','1','2','3','4') default 'TWO';
  select EXPORT_SET(arg, '1','0',',', 10);
  select FORMAT(arg, 2);
  select MAKE_SET(arg,var1,var2,'aa','bb');
  select REPEAT(arg, var1);
  select INTERVAL(arg,var1,var2);
END;
/
DELIMITER ;/

call pro12_2('NULL');

drop PROCEDURE pro12_2;

# 比较函数
--error 0,1305
drop PROCEDURE pro12_3;

DELIMITER /;
CREATE PROCEDURE pro12_3(arg ENUM('','Null', 'One', 'Two','Three','Four'))
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'one';
  declare var2 ENUM('','null', 'one', 'two','three','four','1','2','3','4') default 'TWO';
  select GREATEST(arg,var1,var2),LEAST(arg,var1,var2),ISNULL(arg);
END;
/
DELIMITER ;/

call pro12_3('');
call pro12_3('Null');
call pro12_3(Null);
call pro12_3('Three');

drop PROCEDURE pro12_3;

# 流程控制函数
--error 0,1305
drop PROCEDURE pro12_4;

DELIMITER /;
CREATE PROCEDURE pro12_4(arg ENUM('','Null', 'One', 'Two','Three','Four'))
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'one';
  declare var2 ENUM('','null', 'one', 'two','three','four','1','2','3','4') default 'TWO';
  SELECT CASE arg WHEN var1 THEN 1 WHEN var2 THEN 2 WHEN 'Null' THEN 3 ELSE 'ELSE' END;
  SELECT IF(arg>var1, 'T','F'),IF(arg>var2, 'T','F');
END;
/
DELIMITER ;/

call pro12_4('');
call pro12_4('Null');
call pro12_4(Null);
call pro12_4('One');
call pro12_4('Two');
call pro12_4('Three');

drop PROCEDURE pro12_4;

--error 0,1305
drop PROCEDURE pro12_5;

DELIMITER /;
CREATE PROCEDURE pro12_5(arg ENUM('','Null', 'One', 'Two','Three','Four'))
BEGIN
  declare var1 ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR') default 'one';
  declare var2 ENUM('','null', 'one', 'two','three','four','1','2','3','4') default null;
  SELECT IFNULL(arg, var1),IFNULL(arg, var2);
  SELECT NULLIF(arg, var1),NULLIF(arg, var2);
  SELECT ORA_DECODE(arg, var1,1, var2,2,3);
END;
/
DELIMITER ;/

call pro12_5('');
call pro12_5('Null');
call pro12_5(Null);
call pro12_5('One');
call pro12_5('Two');
call pro12_5('Three');

drop PROCEDURE pro12_5;

#转换函数
--error 0,1305
drop PROCEDURE pro12_6;

DELIMITER /;
CREATE PROCEDURE pro12_6(arg ENUM('','NULL', 'ONE', 'TWO','THREE','FOUR'))
BEGIN
  declare var1 ENUM('','null', 'one', 'two','1.235','2024-11-26 11:30:00.123456') default '2024-11-26 11:30:00.123456';
  select CAST(var1 AS DATE),CAST(var1 AS DATETIME(3));
  set var1 = '1.235';
  select CAST(var1 AS DECIMAL(3,2)),CAST(var1 AS UNSIGNED),CAST(var1 AS SIGNED);
  SELECT CAST(arg AS CHAR(10));
END 
/
DELIMITER ;/

call pro12_6('TWO');

drop PROCEDURE pro12_6;

