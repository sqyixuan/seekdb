#owner: hr351303
#owner group: sql4
#tags: pl

--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;

connection default;


--disable_warnings
drop procedure if exists p1;
--enable_warnings

set @save_sqlmode = @@global.sql_mode;

delimiter $;

create procedure p1()
begin
  select 99 / 5;
end;
$

delimiter ;$

call p1();

select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);

set @@session.sql_mode = 2147483680;
select @@session.sql_mode;

call p1();

select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);

set div_precision_increment = 1;

call p1();

select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);

set div_precision_increment = 5;

call p1();

select type,object_type,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where pl_schema_id=(select routine_id from oceanbase.__all_routine where upper(routine_name)='P1' order by gmt_create desc limit 1);

set @@session.sql_mode = @save_sqlmode;

drop procedure p1;

connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;

connection default;