#owner: haohao.hao
#owner group: PL/SQL
#tags: pl
#description: sys dispatch call mysql

--result_format 4

connect(conn_sys, $OBMYSQL_MS0, root@sys, , *NO-ONE*, $OBMYSQL_PORT);
connect(conn_mysql, $OBMYSQL_MS0, root, , test, $OBMYSQL_PORT);
connection conn_sys;
set global ob_query_timeout = 100000000;
connection conn_mysql;
set global ob_query_timeout = 100000000;


--echo -- 1.1 check DBMS_STATS params on mysql tenant
connection conn_mysql;
call dbms_stats.reset_param_defaults();
select dbms_stats.get_param('ESTIMATE_PERCENT');

--echo -- 1.2 modify DBMS_STATS params on mysql tenant using sys dispatch call
connection conn_sys;
call dbms_stats.set_param('ESTIMATE_PERCENT', '10') tenant = 'sys';

--echo -- 1.3 check DBMS_STATS params on mysql tenant
connection conn_mysql;
select dbms_stats.get_param('ESTIMATE_PERCENT');

--echo -- 1.4 modify DBMS_STATS prefs on mysql tenant using sys dispatch call
connection conn_sys;
call dbms_stats.reset_param_defaults() tenant = 'sys';

--echo -- 1.5 check DBMS_STATS params on mysql tenant
connection conn_mysql;
select dbms_stats.get_param('ESTIMATE_PERCENT');

