#owner: haohao.hao
#owner group: PL/SQL
#tags: pl
#description: upgrade scenario, udf call report "parse error"

--result_format 4


connect (conn_mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn_mysql;
drop function if exists square;
create function square(x int) returns int deterministic return x * x;
select routine_name, routine_body from oceanbase.__all_routine_history where routine_name = 'square' order by routine_id desc limit 1;
select square(3);
disconnect conn_mysql;


connect (conn_sys_proxy,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection conn_sys_proxy;
let $ADMIN_SVR_IP = query_get_value('select SVR_IP from oceanbase.DBA_OB_SERVERS',SVR_IP,1);
let $ADMIN_SQL_PORT = query_get_value('select SQL_PORT from oceanbase.DBA_OB_SERVERS',SQL_PORT,1);

connect (conn_sys_direct,$ADMIN_SVR_IP,root@sys,,oceanbase,$ADMIN_SQL_PORT);
connection conn_sys_direct;
alter system change tenant sys;
update __all_routine_history set routine_body = 'return x * x' where routine_name = 'square';
select routine_name, routine_body from __all_routine_history where routine_name = 'square' order by routine_id desc limit 1;
alter system change tenant sys;
alter system flush kvcache;
alter system flush pl cache global;
disconnect conn_sys_direct;


connect (conn_mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn_mysql;
select routine_name, routine_body from oceanbase.__all_routine_history where routine_name = 'square' order by routine_id desc limit 1;
select square(4);
drop function if exists square;
disconnect conn_mysql;
