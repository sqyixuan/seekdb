--echo ############################start case 1############################
delimiter $$;

--disable_warnings
drop procedure if exists p$$
--enable_warnings

-- error 1407
CREATE PROCEDURE p ()
begin
DECLARE aaa CONDITION FOR sqlstate '00';
signal aaa set message_text='aa';
end;
$$

--error 1305
call p()$$
--error 1305
drop procedure p$$
delimiter ;$$