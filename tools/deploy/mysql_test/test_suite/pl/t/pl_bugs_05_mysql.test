--error 1407
create procedure p1()
begin
  declare exit handler for sqlexception
  begin
    signal sqlstate '00110';
  end;
  drop table t1;
end/

create procedure p1()
begin
  declare exit handler for sqlexception
  begin
    resignal SQLSTATE VALUE '01000';
  end;
select x;
end/

call p1()/

drop procedure p1/

CREATE PROCEDURE p1()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SET @error_count = @error_count + 1;
    IF @a = 0 THEN RESIGNAL SQLSTATE '45000' SET MYSQL_ERRNO=5; END IF;
  END;
  DROP TABLE xx;
END/

SET @error_count = 0/
SET @a = 0/

--error 5
call p1()/
drop procedure p1/
CREATE PROCEDURE p1()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    RESIGNAL SQLSTATE VALUE '01000' SET MESSAGE_TEXT = 'An error occurred';
  END;
  DROP TABLE no_such_table;
END/

--disable_warnings
call p1()/
--enable_warnings

show warnings/

drop procedure p1/

create procedure p1()
begin
  declare exit handler for sqlexception
  begin
    resignal set MYSQL_ERRNO=5;
  end;
  select x;
end/

--error 5
call p1()/
drop procedure p1/


