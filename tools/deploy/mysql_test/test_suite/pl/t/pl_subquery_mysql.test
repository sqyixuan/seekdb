#owner: hr351303
#owner group: sql4
#description: pl support subquery in expression
#tags: pl, subquery
#author:hr351303

--result_format 4

connection default;

--echo #pl/sql
--echo #	存储过程
--echo #	循环语句
--echo #	while循环, repeat循环

--error 0,1305
drop procedure if exists p0;

delimiter /;

create procedure p0()
begin
  declare a int;
  declare i int;
  set a = 5;
  set i = 0;
  while (i < a and exists(select a)) do
    set i = i + 1;
  end while;

  if (i = a) then
    select "support subquery in while stmt ok!";
  end if;
end/

call p0()/

drop procedure p0/

create procedure p0()
begin
  declare a int;
  set a = 0;
  repeat
    set a = a + 1;
  until (a > 5 and exists(select a)) end repeat;
  
  if (a = 6) then
    select "support subquery in repeat stmt ok!";
  end if;
end/

call p0()/

drop procedure p0/


--echo # pl/sql
--echo # 存储过程
--echo # 条件语句
--echo # if条件语句, case条件语句

create procedure p0()
begin
  declare a int;
  declare b float;
  declare c varchar(20);
  set a = 5;
  set b = 4;
  set c = '3';
  if (a + b + c + exists(select a)) then
    select "support subquery in if stmt ok!";
  end if;
end/

call p0()/

drop procedure p0/

create procedure p0()
begin
  declare a int;
  declare b float;
  declare c varchar(20);
  set a = 1;
  set b = 0;
  set c = 1;
  case a + exists(select a)
  when b + exists(select b) then
    select "error!";
  when c + exists(select c) then
    select "support subquery in case stmt ok!";
  else
    select "not support subquery in case stmt!";
  end case;
end/

call p0()/

drop procedure p0/


--echo # pl/sql
--echo # 存储过程
--echo # 赋值语句

create procedure p0()
  begin
    declare a int;
    declare c varchar(20);
    set a = 1;
    set c = a + exists(select a);
    set @b = a + exists(select a);

    if (c = 2 and @b = 2) then
      select "support subquery in set stmt ok!";
    end if;
end/

call p0/

drop procedure p0/

--echo # pl/sql
--echo # 存储过程
--echo # 调用语句

create procedure p0(a int)
begin
  if (a = 1) then
    select "support subquery in call stmt ok!";
  end if;
end/

call p0(exists(select 2))/

drop procedure p0/

delimiter ;/

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop procedure if exists p1;
--enable_warnings

create table t1(deptno int,dname varchar(20),loc varchar(20));
create table t2(empno int,ename varchar(10),job varchar(9),mgr int,hiredate date,sal int,comm int,deptno int);

insert into t1 values (20,'RESEARCH','DALLAS');
insert into t2 values (7369,'SMITH','CLERK',7902,'1980-12-17',800,100,20);

delimiter /;

create procedure p1()
begin
  declare a int;
  declare b varchar(50) character set utf8;
  declare c varchar(50) character set utf8;
  declare msg varchar(50) character set utf8;
  declare done int default 0;
  declare mc cursor for select p.ename,e.loc,p.sal from t1 e left join t2 p on e.deptno = p.deptno order by 1,2,3;
  declare continue handler for not found set done = 1;
  open mc;
  while done != 1 do
    set msg = '';
    fetch mc into b,c,a;
    if done != 1 then
      case
      when (length(c)) = 6 and not exists (select * from t1 e where e.loc = c) then set msg = concat(a,' ',b,' ','低'); select msg;
      else set msg = concat(msg,b,'error'); select msg;
      end case;
    end if;
  end while;
  close mc;
end;
/

call p1()/

delimiter ;/

drop table t1;
drop table t2;
drop procedure p1;

--disable_warnings
drop trigger if exists tg1;
--enable_warnings

create table t1(deptno int,dname varchar(20),loc varchar(20));
insert into t1 values (10,'ACCOUNTING','NEW YORK');

delimiter /;

create trigger tg1 before insert on t1 for each row
begin
  if new.loc = 'NEW YORK' and exists(select * from t1 where deptno = 10) then
    set new.loc = 'A';
  else
    set new.loc = 'D';
  end if;
end;
/

select * from t1;/

insert into t1 values (10,'ACCOUNTING','NEW YORK');/
--sorted_result
select * from t1;/

drop table t1/

--error 0,1360
drop trigger tg1/

delimiter ;/