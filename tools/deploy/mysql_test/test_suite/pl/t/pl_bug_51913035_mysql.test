#owner: haohao.hao
#owner group: PL/SQL
#tags: pl, national
#description: test mysql pl support for natioanl character type

--result_format 4

--echo 

DROP FUNCTION IF EXISTS test_nchar_func;
DROP FUNCTION IF EXISTS test_national_charactor_func;
DROP FUNCTION IF EXISTS test_nvarchar_func;
DROP FUNCTION IF EXISTS test_nchar_varchar_func;
DROP FUNCTION IF EXISTS test_national_varchar_func;
DROP FUNCTION IF EXISTS test_national_char_varying_func;
DROP FUNCTION IF EXISTS test_national_character_varying_func;

CREATE FUNCTION test_nchar_func(param NCHAR(10)) RETURNS INT NO SQL RETURN 1;
CREATE FUNCTION test_national_charactor_func(param NATIONAL CHARACTER(10)) RETURNS INT NO SQL RETURN 1;
CREATE FUNCTION test_nvarchar_func(param NVARCHAR(10)) RETURNS INT NO SQL RETURN 1;
CREATE FUNCTION test_nchar_varchar_func(param NCHAR VARCHAR(10)) RETURNS INT NO SQL RETURN 1;
CREATE FUNCTION test_national_varchar_func(param NATIONAL VARCHAR(10)) RETURNS INT NO SQL RETURN 1;
CREATE FUNCTION test_national_char_varying_func(param NATIONAL CHAR VARYING(10)) RETURNS INT NO SQL RETURN 1;
CREATE FUNCTION test_national_character_varying_func(param NATIONAL CHARACTER VARYING(10)) RETURNS INT NO SQL RETURN 1;

SELECT * FROM information_schema.parameters WHERE specific_name LIKE 'test_%_func' AND parameter_mode = 'IN';

DROP FUNCTION test_nchar_func;
DROP FUNCTION test_national_charactor_func;
DROP FUNCTION test_nvarchar_func;
DROP FUNCTION test_nchar_varchar_func;
DROP FUNCTION test_national_varchar_func;
DROP FUNCTION test_national_char_varying_func;
DROP FUNCTION test_national_character_varying_func;
