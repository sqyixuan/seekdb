--result_format 4

--error 0,1396
drop user hyy;

create user hyy;
grant create routine on test.* to hyy;
grant execute on test.* to hyy;
grant alter routine on test.* to hyy;
grant select on test.* to hyy;

connect (conn, $OBMYSQL_MS0, hyy, , test, $OBMYSQL_PORT);

connection conn;

select current_user(), database();

--disable_warnings ONCE
drop procedure if exists px;

delimiter /;
CREATE DEFINER = 'hyy'@'%' PROCEDURE px()
       BEGIN
        select * from test.t1;
        create table px(c0 int);
       END;
/
delimiter ;/

