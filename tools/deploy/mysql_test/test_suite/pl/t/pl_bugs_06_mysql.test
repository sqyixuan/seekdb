CREATE PROCEDURE p1(pval INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF pval = 0 THEN
      RESIGNAL SET MESSAGE_TEXT='【RESIGNAL】MYSQL_ERRNO值：负数', MYSQL_ERRNO='-1001';
    ELSE
      RESIGNAL SQLSTATE '45000' SET MESSAGE_TEXT='【RESIGNAL】MYSQL_ERRNO值：负数', MYSQL_ERRNO="-1.56789";
    END IF;
  END;
  DROP TABLE xxx;
END;
/
