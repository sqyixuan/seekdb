create table t1(c0 int)/
insert into t1 values(100)/

create procedure p1()
begin
  DECLARE V_1 int;
  DECLARE done INT default 0;
  DECLARE C_1 CURSOR  FOR SELECT T1.C0 FROM T1;
  DECLARE CONTINUE HANDLER FOR NOT FOUND SET done=65530;
  OPEN C_1;
  repeat
  FETCH C_1 INTO V_1;
  select done;
  UNTIL done END REPEAT;
  CLOSE C_1;
END/

call p1()/

drop table t1/

drop procedure p1/

