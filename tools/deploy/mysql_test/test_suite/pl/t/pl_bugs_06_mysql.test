--disable_warnings
drop procedure if exists test_lpad_length;
--enable_warnings

DELIMITER //;
CREATE PROCEDURE test_lpad_length()
BEGIN
    DECLARE padded_string VARCHAR(32767);
    DECLARE length_limit INT DEFAULT 1;
    DECLARE continue_loop BOOLEAN DEFAULT TRUE;

    WHILE continue_loop DO
        SET padded_string = LPAD('Hello', length_limit, '*');
        SET length_limit = length_limit + 1;
        IF padded_string == '' THEN
            SELECT length_limit - 1 AS max_length;
            SET continue_loop = FALSE;
        END IF;
    END WHILE;
END
//

delimiter ;//

drop procedure test_lpad_length;

