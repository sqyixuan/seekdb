create table t1(id int);/

create function f1()returns varchar(1)
begin
insert into t1 values(1);
return 'a';
end;/

create function f2()returns int deterministic
begin
declare aa int;
DECLARE continue HANDLER FOR SQLEXCEPTION
set @a=1;
set aa=f1();
return 1;
end
/

select f2()/
select * from t1/

create procedure p1()
begin
declare aa int;
DECLARE continue HANDLER FOR SQLEXCEPTION
begin
set @a=1;
end;
set aa=f1();
end
/

call p1()/
select * from t1/

drop table t1/
drop function f1/
drop function f2/
drop procedure p1/

#

create table t1(id int);/

create procedure p1()
begin
declare t_error int;
DECLARE continue HANDLER FOR SQLEXCEPTION set t_error=1;
insert into t1 values(1);
start transaction;
insert into t1 values(2);
insert into t1 values('a');
if t_error=1 then
rollback;
end if;
end;
/

call p1()/
select * from t1/

drop table t1/
drop procedure p1/

