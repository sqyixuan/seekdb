--disable_warnings
drop procedure if exists p2/
--enable_warnings

CREATE procedure p2(a varchar(2))
begin
   set @a=100;
end;
/

CREATE procedure p1()
begin
   declare out_code varchar(10);
   declare out_msg varchar(100);
   declare continue handler for SQLEXCEPTION
   begin
        show warnings;
        get diagnostics condition 1
          out_code=returned_sqlstate,out_msg=message_text;
        select 'error:',out_code,out_msg;
   end;
   call p2('aaaa');
end;
/

call p1()/

drop procedure p1/
drop procedure p2/

