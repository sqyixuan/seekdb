--disable_warnings
DROP FUNCTION IF EXISTS fun1/
--enable_warnings

CREATE FUNCTION fun1 (pval INT) RETURNS varchar(200) DETERMINISTIC 
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF pval = 0 THEN
      RESIGNAL SET MESSAGE_TEXT=@n1, MYSQL_ERRNO=@n2;
    ELSE
      RESIGNAL SQLSTATE '99999' SET MESSAGE_TEXT=@n1, MYSQL_ERRNO=@n2;
    END IF;
  END;
  SELECT id into @temp FROM  xxx;
  RETURN '用户定义的变量修改错误信息';
END;
/

SET @n1 ='[RESIGNAL] An error occurred in function';/
SET @n2 =1111;/
--error 1111
SELECT fun1(0)/
--error 1111
SELECT fun1(1)/

drop function fun1/

#

CREATE PROCEDURE p1(pval INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
	DECLARE specialty CONDITION FOR SQLSTATE '45000';
	IF pval = 0 THEN
      RESIGNAL;
	ELSEIF pval = 1 THEN
      RESIGNAL SQLSTATE '03000';
	ELSEIF pval = 2 THEN
      RESIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = '【RESIGNAL】An 45000 occurred';
	ELSEIF pval = 3 THEN
      RESIGNAL specialty SET MESSAGE_TEXT = '【RESIGNAL】An error occurred';
	ELSE
      RESIGNAL SQLSTATE '99999' SET MESSAGE_TEXT = '【RESIGNAL】An 99999 occurred', MYSQL_ERRNO = 1001;
	END IF;    
  END;
  DROP TABLE xxx;
END;
/
