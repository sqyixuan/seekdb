--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group: sql1
#tags: pl
#description: 

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

--disable_warnings
drop table if exists t1;
drop table if exists t;
drop procedure if exists p;
--enable_warnings

create table t (a int, b date, c datetime, d double, e char(3));
insert into t values(5, "2000-10-10", "2020-10-10 12:12:12", 3.55, "abc");
insert into t values(15, "2000-11-20", "2020-11-20 10:10:10", 5.55, "bbc");
insert into t values(25, "2001-11-15", "2019-11-15 10:10:10", 7.55, "cba");
insert into t values(35, "2002-11-10", "2018-11-10 11:11:11", 9.55, "nba");
insert into t values(45, "2002-11-10", "2018-11-10 11:11:12", 11.55, "ccc");

delimiter /;
create procedure p(arg1 int) 
begin 
create table t1 as select * from t where a<arg1; 
end/
delimiter ;/
call p(10);
select * from t1 where a < 10;
drop table if exists t1;
drop procedure p;

delimiter /;
create procedure p(arg1 date) 
begin 
create table t1 as select * from t where b<arg1; 
end/
delimiter ;/
call p("2000-11-21");
select * from t1 where b < "2000-11-21";
drop table if exists t1;
drop procedure p;

delimiter /;
create procedure p(arg1 datetime) 
begin 
create table t1 as select * from t where c<arg1; 
end/
delimiter ;/
call p("2000-11-21");
select * from t1 where c < "2000-11-21 10:10:10";
drop table if exists t1;
drop procedure p;


delimiter /;
create procedure p(arg1 double) 
begin 
create table t1 as select * from t where d<arg1; 
end/
delimiter ;/
call p(9.9);
select * from t1 where c < 9.9;
drop table if exists t1;
drop procedure p;

delimiter /;
create procedure p(arg1 char(3)) 
begin 
create table t1 as select * from t where e<arg1; 
end/
delimiter ;/
call p("ccc");
select * from t1 where e < "ccc";
drop table if exists t1;
drop procedure p;

drop table t;
