#owner: linlin.xll
#owner group: sql1-PL/SQL
#tags: pl
#description: 

--result_format 4

connect (conn1, $OBMYSQL_MS0, admin, admin, test, $OBMYSQL_PORT);
connect (conn2, $OBMYSQL_MS0, admin, admin, test, $OBMYSQL_PORT);

connection conn1;

--disable_warnings
drop procedure if exists `test`;
drop table if exists `t`;
--enable_warnings

create table t(col int);

delimiter /;
create procedure test()
begin
    update t set col = col + 1;
end;
/
delimiter ;/

set autocommit = off;
set ob_query_timeout = 100000000;

insert into t values (1);
commit;
update t set col = col + 1;

connection conn2;
set autocommit = off;
insert into t values(1);
send call test();

connection conn1;
sleep 1;
commit;

connection conn2;
reap;
--sorted_result
select * from t;

drop table t;
drop procedure test;


