#owner: wangbai.wx
#owner group: sql4-PL/SQL
#tags: pl
#description: test pl bug
# 

--result_format 4

--disable_warnings



set autocommit=0;
drop table if exists test5;
drop procedure if exists ps_test;
create table test5(ID INT primary key, NAME VARCHAR(200))partition by hash (ID) partitions 5;

delimiter /;

create procedure ps_test(IN a int, IN b VARCHAR(200)) begin INSERT INTO test5 VALUES (a,b); end;/

delimiter ;/

PREPARE ps_stmt FROM 'call ps_test(?,?);';
SET @a = 1;
SET @b = 'test';
EXECUTE ps_stmt using @a, @b;

--enable_warnings
