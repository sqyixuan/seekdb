--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: hr351303
#owner group: sql4
#tags: pl, cross_validation
#description: test pl bugs [Aone]

--result_format 4

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

use test;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop function if exists f1;
--enable_warnings

create table t1(id int);
insert into t1 value(1);

create table t2(id int);
insert into t2 value(2);

delimiter /;

create function f1() returns int
begin
  insert into t1 value(3);
  return 1;
end/

select f1() from t2/

drop function f1/

create function f1() returns int
begin
  declare cs cursor for select * from t1 for update;
  open cs;
  return 1;
end/

delimiter ;/

select f1() from t2;

start transaction read only;

--error 1792
select f1() from t2;

commit;

drop function f1;

delimiter /;

create function f1() returns int
begin
  declare val int;
  select count(id) into val from t1;
  return 1;
end/

delimiter ;/

select f1() from t2;

start transaction read only;

select f1() from t2;

commit;


drop table t1;
drop table t2;
drop function f1;

--disable_warnings
drop table if exists CFG_ROAM_REPORT_RATE;
drop table if exists ROAM_STAT_INT_SZX;
drop function if exists BI_MYJS_GJ;
--enable_warnings

CREATE TABLE CFG_ROAM_REPORT_RATE (
  REPORT_ID int NOT NULL,
  RATE_NAME VARCHAR(50),
  RATE_VALUE1 int,
  RATE_VALUE2 int
);

CREATE TABLE ROAM_STAT_INT_SZX (
  LX VARCHAR(5),
  HDRQ VARCHAR(8),
  JS_TIME DATE,
  JSDX int,
  CALL_TYPE VARCHAR(3),
  HDS int,
  THSC int,
  JFSC int,
  JFCS int,
  MYF int,
  CTF int,
  CTF2 int,
  ERROR_TYPE VARCHAR(4),
  JSFS VARCHAR(2),
  JSYF VARCHAR(6),
  FILE_DATE VARCHAR(8),
  SERVICE_TYPE VARCHAR(5),
  BY1 VARCHAR(6),
  WJM VARCHAR(20),
  UFEE int,
  NUMBER_TYPE int,
  TABLE_DATE VARCHAR(8),
  YEARMON int,
  SERVICE_CODE VARCHAR(4)
);

delimiter /;

CREATE FUNCTION BI_MYJS_GJ(I_ITEMNAME varchar(10), I_LX varchar(10), I_CALLTYPE varchar(10), I_MYF int, I_CTF int, I_CTF2 int) RETURNs int
begin
  declare Result int;
  declare Rate1 int;
  declare Rate2 int;
  declare Fee1  int;
  declare Fee2  int;
  declare Fee3  int;
  SELECT nvl(rate_value1,1) ,nvl(rate_value2,1) INTO Rate1,Rate2 FROM CFG_ROAM_REPORT_RATE  WHERE report_id=10003;
  SELECT decode(substr(I_LX,-1,1),'2',-1,'1',-1,1)*I_MYF*Rate1 INTO Fee1 FROM dual;
  SELECT decode(substr(I_LX,-1,1),'2',-1,'1',-1,1)*decode(I_CALLTYPE,'01',1,'03',1,0)*I_CTF*Rate1 INTO Fee2 FROM dual;
  SELECT decode(substr(I_LX,-1,1),'2',-1,'1',-1,1)*decode(I_CALLTYPE,'01',1,'03',1,0)*I_CTF2*Rate1 INTO Fee3 FROM dual;

  IF I_ITEMNAME='MYF' THEN
     set Result = Fee1;
  ELSE
      IF I_ITEMNAME='CTF' THEN
         set Result = Fee2;
      ELSE
          IF I_ITEMNAME='CTF2' THEN
             set Result = Fee3;
          ELSE
              IF I_ITEMNAME='SUM' THEN
                 set Result = Fee1+Fee2+Fee3;
              ELSE
                 set Result=0;
              END IF;
          END IF;
      END IF;
  END IF;

  return(Result);
end;
/

delimiter ;/

SELECT /*+ read_consistency(weak)*/  LX,WJM,HDRQ,JS_TIME,JSDX,CALL_TYPE,HDS,THSC,JFSC,JFCS,MYF,CTF,CTF2,
    BI_MYJS_GJ('MYF', LX, CALL_TYPE, MYF, CTF, CTF2) AS FIN_MYF,
    BI_MYJS_GJ('CTF', LX, CALL_TYPE, MYF, CTF, CTF2) AS FIN_CTF,
    BI_MYJS_GJ('CTF2', LX, CALL_TYPE, MYF, CTF, CTF2) AS FIN_CTF2,
    BI_MYJS_GJ('SUM', LX, CALL_TYPE, MYF, CTF, CTF2) AS FIN_SUM,
    ERROR_TYPE,JSFS,JSYF,' ' AS FILE_DATE,SERVICE_TYPE,BY1
    FROM ROAM_STAT_INT_SZX;

drop table CFG_ROAM_REPORT_RATE;
drop table ROAM_STAT_INT_SZX;
drop function BI_MYJS_GJ;