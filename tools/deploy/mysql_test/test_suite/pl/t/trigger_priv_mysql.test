drop database trigger_priv;
--disable_warnings
drop table if exists t1,t2;
--enable_warnings

CREATE USER mysqltest_1 identified by '123';
CREATE USER mysqltest_2 identified by '123';

show grants for mysqltest_1;
GRANT ALL ON *.* TO mysqltest_1;
select user, trigger_priv from mysql.user where user = 'mysqltest_1';
show grants for mysqltest_1;
REVOKE TRIGGER ON *.* FROM 'mysqltest_1';
select user, trigger_priv from mysql.user where user = 'mysqltest_1';
show grants for mysqltest_1;

show grants for mysqltest_2;
GRANT ALL ON *.* TO mysqltest_2;
