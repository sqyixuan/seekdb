show grants for mysqltest_2;

create database trigger_priv;

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (u1_con,$OBMYSQL_MS0, mysqltest_1, 123, trigger_priv,$OBMYSQL_PORT);

