## 极联权限
disconnect u2_con;
connect (u2_con,$OBMYSQL_MS0, mysqltest_2, 123, trigger_priv,$OBMYSQL_PORT);
connection u2_con;
CREATE TRIGGER trg1 AFTER INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES(CURRENT_USER());
CREATE TRIGGER trg2 AFTER INSERT ON t2 FOR EACH ROW INSERT INTO t1 VALUES(1);
## 这里display成功
show create trigger trg1;
show create trigger trg2;
--replace_column 6 time
--sorted_result
show triggers;
--replace_column 6 time
--sorted_result
show triggers like 't%';
--replace_column 17 time
--sorted_result
select * from information_schema.TRIGGERS;
--error 1442
INSERT INTO t1 VALUES(1);
select * from t1;
select * from t2;
drop trigger trg1;
drop trigger trg2;

connection default;
use trigger_priv;
CREATE TABLE t3(num_value INT);
disconnect u1_con;
connect (u1_con,$OBMYSQL_MS0, mysqltest_1, 123, trigger_priv,$OBMYSQL_PORT);
connection u1_con;
CREATE TRIGGER trg1 AFTER INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES(CURRENT_USER());
disconnect u2_con;
connect (u2_con,$OBMYSQL_MS0, mysqltest_2, 123, trigger_priv,$OBMYSQL_PORT);
connection u2_con;
CREATE TRIGGER trg2 AFTER INSERT ON t2 FOR EACH ROW INSERT INTO t3 VALUES(1);
connection default;
use trigger_priv;
## 这里display成功
show create trigger trg1;
show create trigger trg2;
--replace_column 6 time
--sorted_result
show triggers;
--replace_column 6 time
--sorted_result
show triggers like 't%';
--replace_column 17 time
--sorted_result
select * from information_schema.TRIGGERS;
INSERT INTO t1 VALUES(1);
select * from t1;
select * from t2;
select * from t3;
REVOKE TRIGGER ON *.* FROM 'mysqltest_2';
--error 1142
INSERT INTO t1 VALUES(1);
drop trigger trg1;
drop trigger trg2;
GRANT TRIGGER ON *.* TO 'mysqltest_2';

## 测试dml语句 trigger权限
disconnect u1_con;
connect (u1_con,$OBMYSQL_MS0, mysqltest_1, 123, trigger_priv,$OBMYSQL_PORT);
connection u1_con;
CREATE TRIGGER trg1 AFTER INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES(CURRENT_USER());
connection default;
use trigger_priv;
INSERT INTO t1 VALUES(1);
REVOKE TRIGGER ON *.* FROM 'mysqltest_1';
--error 1142
INSERT INTO t1 VALUES(1);
GRANT TRIGGER ON trigger_priv.* TO 'mysqltest_1';
INSERT INTO t1 VALUES(1);
REVOKE TRIGGER ON trigger_priv.* FROM 'mysqltest_1';
--error 1142
INSERT INTO t1 VALUES(1);
GRANT TRIGGER ON trigger_priv.t1 TO 'mysqltest_1';
INSERT INTO t1 VALUES(1);
REVOKE TRIGGER ON trigger_priv.t1 FROM 'mysqltest_1';
--error 1142
INSERT INTO t1 VALUES(1);
GRANT TRIGGER ON *.* TO 'mysqltest_1';

## 测试update语句不生效时 trigger权限 不检查
CREATE TRIGGER trg2 AFTER UPDATE ON t1 FOR EACH ROW INSERT INTO t2 VALUES(CURRENT_USER());
## 这里display成功
show create trigger trg1;
show create trigger trg2;
--replace_column 6 time
--sorted_result
show triggers;
--replace_column 6 time
--sorted_result
show triggers like 't%';
--replace_column 17 time
--sorted_result
select * from information_schema.TRIGGERS;
update t1 set num_value = 2 where num_value = 3;
select * from t1;
select * from t2;
select * from t3;
REVOKE TRIGGER ON *.* FROM 'mysqltest_1';
update t1 set num_value = 2 where num_value = 3;
GRANT TRIGGER ON *.* TO 'mysqltest_1';
select * from t1;
select * from t2;
select * from t3;
drop trigger trg1;
drop trigger trg2;

## 多个trigger权限的测试
disconnect u1_con;
connect (u1_con,$OBMYSQL_MS0, mysqltest_1, 123, trigger_priv,$OBMYSQL_PORT);
connection u1_con;
CREATE TRIGGER trg1 AFTER INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES(CURRENT_USER());
disconnect u2_con;
connect (u2_con,$OBMYSQL_MS0, mysqltest_2, 123, trigger_priv,$OBMYSQL_PORT);
connection u2_con;
CREATE TRIGGER trg2 AFTER INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES(CURRENT_USER());
connection default;
use trigger_priv;
## 这里display成功
show create trigger trg1;
show create trigger trg2;
--replace_column 6 time
--sorted_result
show triggers;
--replace_column 6 time
--sorted_result
show triggers like 't%';
--replace_column 17 time
--sorted_result
select * from information_schema.TRIGGERS;
INSERT INTO t1 VALUES(1);
REVOKE TRIGGER ON *.* FROM 'mysqltest_1';
--error 1142
INSERT INTO t1 VALUES(1);
GRANT TRIGGER ON *.* TO 'mysqltest_1';
INSERT INTO t1 VALUES(1);
REVOKE TRIGGER ON *.* FROM 'mysqltest_2';
--error 1142
INSERT INTO t1 VALUES(1);
drop trigger trg2;
INSERT INTO t1 VALUES(1);
select * from t1;
select * from t2;
select * from t3;

