#owner: heyongyi.hyy
#owner group: pl/sql
#tags: pl
#description: test database() inside PL

--result_format 4

--error 0,1008
drop database db1;

--error 0,1008
drop database db2;

create database db1;
create database db2;

set @a='';
set @b='';

use db1;

create table t0(k int primary key auto_increment, c0 varchar(100), c1 varchar(100));

--disable_warnings ONCE
drop procedure if exists p1;

--disable_warnings ONCE
drop procedure if exists p2;

delimiter /;
create procedure p1()
SQL SECURITY INVOKER
begin
select database() into @a from dual;
select current_user() into @b  from dual;
insert into t0(c0,c1) values(@a,@b);
end;
/

create procedure p2()
begin
select database() into @a from dual;
select current_user() into @b  from dual;
insert into t0(c0,c1) values(@a,@b);
end;
/
delimiter ;/

call p1();
select @a,@b;

call p2();
select @a,@b;

use db2;

create table t0(k int primary key auto_increment, c0 varchar(100), c1 varchar(100));

call db1.p1();
select @a,@b;

call db1.p2();
select @a,@b;

--error 0,1396
drop user hyy;

create user hyy;

grant all on *.* to hyy;

connect (conn,$OBMYSQL_MS0,hyy,,test,$OBMYSQL_PORT);
connection conn;

use db1;

call p1();
select @a,@b;

call p2();
select @a,@b;

use db2;

call db1.p1();
select @a,@b;

call db1.p2();
select @a,@b;

disconnect conn;

connection default;

set @a='';
set @b='';

select * from db1.t0 order by k;

select * from db2.t0 order by k;

drop user hyy;

use db1;

delimiter /;
create procedure proc()
sql security invoker
begin
prepare stmt from 'create table create_table_test(c int)';
execute stmt;
deallocate prepare stmt;
insert into create_table_test values(42);
end;
/
delimiter ;/

use db2;

call db1.proc();

show tables;

--error 1146
select * from create_table_test;

use db1;

--sorted_result
show tables;

select * from create_table_test;

drop database db1;
drop database db2;

use test;
