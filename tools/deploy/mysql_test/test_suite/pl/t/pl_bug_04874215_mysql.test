#owner group: sql4
#tags: pl
#description: test pl bugs

--disable_warnings
drop table if exists t1;
drop function if exists f1;
--enable_warnings

create table t1(c1 enum('1','2'));

insert into t1 value('2');

delimiter /;

create function f1(arg enum('1','2')) returns enum('1','2')
BEGIN
  declare var enum('1','2');
  set var = arg;
  return var;
end;
/

select f1(c1) from t1/

delimiter ;/
drop table t1;
drop function f1;