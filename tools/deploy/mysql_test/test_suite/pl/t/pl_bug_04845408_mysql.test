#owner: hr351303
#owner group: pl/sql
#tags: pl,cross_validation
#description: test subquery bug

--disable_warnings
drop table if exists `slow_classify`;
drop table if exists t1;
drop table if exists log;
drop TRIGGER if exists `slow_cla_trigger`;
--enable_warnings

CREATE TABLE `slow_classify` (
  `status` enum('analyzed','new','informed','adopted') NOT NULL DEFAULT 'new'
);

create table t1(c1 enum('analyzed','new','informed','adopted'));

create table log(c1 enum('analyzed','new','informed','adopted'));

insert into t1 value('new');


delimiter /;

CREATE TRIGGER `slow_cla_trigger` BEFORE INSERT ON `slow_classify` FOR EACH ROW
BEGIN
  set new.`status` = (select c1 from t1 limit 1);
  insert into log value(new.`status`);
END /

delimiter ;/

insert into `slow_classify` value('analyzed');

select * from log;

drop TRIGGER `slow_cla_trigger`;
drop table log;
drop table t1;
drop table `slow_classify`;