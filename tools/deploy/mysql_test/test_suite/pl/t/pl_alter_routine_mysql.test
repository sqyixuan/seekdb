--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: hr351303
#owner group: sql4
#tags: pl
#description:
--result_format 4
--enable_sorted_result
--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

--disable_warnings
drop table if exists t1;
drop procedure if exists p1;
drop function if exists f1;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection default;
create table t1(id int);

delimiter /;

create definer = 'nouser'@'%' procedure p1() sql security invoker
begin
  insert into t1 value(2);
end/

call p1()/

alter procedure p1/
call p1()/
alter procedure p1 sql security definer LANGUAGE SQL CONTAINS SQL/

--error 1449
call p1()/

alter procedure p1 sql security invoker MODIFIES SQL DATA comment 'fddf'/
call p1()/

select * from t1/

create definer = 'nouser'@'%' function f1() returns int
sql security definer
begin
  insert into t1 value(3);
  return 0;
end/

--error 1449
select f1()/
alter function f1 sql security invoker/
select f1()/
alter function f1 sql security definer/

--error 1449
select f1()/
select * from t1/

delimiter ;/
drop procedure p1;
drop function f1;
drop table t1;