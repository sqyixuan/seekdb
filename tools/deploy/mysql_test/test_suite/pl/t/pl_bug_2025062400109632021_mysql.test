#description: fix dima 2025062400109632021

DROP DATABASE IF EXISTS u1;
CREATE DATABASE u1;
USE u1;
CREATE TABLE IF NOT EXISTS t0(c0 LONGTEXT  COMMENT 'asdf' , c1 DECIMAL ZEROFILL   COMMENT 'asdf'  NOT NULL UNIQUE KEY, c2 FLOAT(45, 0)  , c3 VARCHAR(500)  , PRIMARY KEY(c1, c2)) USE_BLOOM_FILTER =  FALSE ,  DUPLICATE_SCOPE = 'CLUSTER' ,  BLOCK_SIZE =  32768 , AUTO_INCREMENT = 7070835189135807 WITH COLUMN GROUP (all columns, each column);
CREATE TABLE t1 LIKE t0;
CREATE TABLE t2(c0 FLOAT  COMMENT 'asdf'  SKIP_INDEX(MIN_MAX)  NOT NULL UNIQUE, c1 SMALLINT  UNIQUE KEY, PRIMARY KEY(c0))  WITH COLUMN GROUP (all columns, each column);
CREATE TABLE t3 LIKE t2;
CREATE MATERIALIZED VIEW LOG on t3 parallel 9 with rowid, sequence(c1) including new values;
CREATE MATERIALIZED VIEW mv_t3 parallel 13 refresh force on demand enable QUERY rewrite AS SELECT t3.c0, t3.c1 FROM t3 WHERE ((concat(t3.c0,'')) IS NOT FALSE) BETWEEN (CAST(concat(t3.c0,'') AS SIGNED)) AND ((! ('2025-06-24 16:53:56')));
CREATE VIEW v_t3 AS SELECT /*+ no_mv_rewrite */ t3.c0, t3.c1 FROM t3 WHERE ((concat(t3.c0,'')) IS NOT FALSE) BETWEEN (CAST(concat(t3.c0,'') AS SIGNED)) AND ((NOT ('2025-06-24 16:53:56')));
REPLACE INTO t3(c1, c0) VALUES(17, 80), (122, 0), (125, -23);
REPLACE INTO t3(c1, c0) VALUES(-94, -27), (-31, 122), (49, -17), (120, 49);
--error 1644
CALL DBMS_MVIEW.REFRESH('mv_t3','c',refresh_parallel => 9);

USE test;
DROP DATABASE u1;
