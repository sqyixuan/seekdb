--error 0,1051
drop table t;
--error 0,1051
drop table msg;
--error 0,1360
drop trigger tri_t;

create table t (c1 int, c2 int);
create table msg (c1 int, c2 int);

delimiter /;
create trigger tri_t before insert on t for each row
BEGIN
  declare a1 int;
  declare b1 int;

  set a1 = NEW.c1;
  set b1 = new.C2;

  insert into msg values (new.c1, A1);
  insert into msg values (A1 + b1, NEW.C2);
end;
/
delimiter ;/

insert into t values (10, 10);

select * from t;

--sorted_result
select * from msg;

drop table t;
drop table msg;
##########################test8  end##########################

