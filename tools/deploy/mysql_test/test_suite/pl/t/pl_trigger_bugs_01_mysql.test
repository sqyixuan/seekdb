--error 0,1051
drop table zy;
--error 0,1051
drop table zy1;
--error 0,1360
drop trigger tri_test;

create table zy(coll_id int not null, doc_id int not null, doc_data varchar(30) not null,
                last_modified bigint not null, primary key(coll_id, doc_id),
                index idx_col(coll_id, last_modified));

create table zy1(coll_id int not null, doc_id int not null, doc_data varchar(30) not null,
                 last_modified bigint not null, primary key(coll_id, doc_id),
                 index idx_col(coll_id, last_modified));

create trigger tri_test before insert on zy for each row 
  insert into zy1 values (NEW.coll_id, NEW.doc_id, NEW.doc_data,NEW.last_modified);

insert into zy values (1,1,'{ "item" : "canvas"}',1000);

select * from zy1;

drop table zy;
drop table zy1;
