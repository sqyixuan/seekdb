#owner: linlin.xll
#owner group: pl/sql
#tags: pl
#description: test pl bugs

--result_format 4
--disable_warnings

drop function if exists f;
drop function if exists f1;
drop function if exists f2;
drop function if exists f3;
drop function if exists f4;
drop function if exists f5;
drop function if exists f6;
drop function if exists f7;
drop table if exists t1;
drop table if exists t2;

delimiter /;
create function f()
    returns int
begin
    insert into t2 values(1);
    return 1;
end;
/

create function f1()
    returns int
begin
    declare x int;
    select c1 into x from t2 for update;
    return 1;
end;
/

--error 1445
create function f2()
    returns int
begin
    set global autocommit=on;
    return 1;
end;
/

--error 1445
create function f3()
    returns int
begin
    set autocommit = on;
    return 1;
end;
/

--error 1422
create function f4()
    returns int
begin
    commit;
    return 1;
end;
/

--error 1422
create function f5()
    returns int
begin
    rollback;
    return 1;
end;
/

create function f6()
    returns int
begin
    savepoint a;
    return 1;
end;
/

create function f7()
    returns int
begin
    savepoint a;
    rollback to a;
    return 1;
end;
/
delimiter ;/

create table t2(c1 int);
--error 1746
create table t1 select f();
create table t1 select f1();
drop table t1;
create table t1 select f6();
drop table t1;
create table t1 select f7();
select * from t1;
select * from t2;

drop table t1;
drop table t2;

--echo 

drop procedure if exists bug20953;
--error 1350
CREATE PROCEDURE bug20953() CREATE OR REPLACE VIEW v AS SELECT 1 INTO @a;
--error 1305
call bug20953();
--error 1350
CREATE PROCEDURE bug20953() CREATE OR REPLACE VIEW v AS SELECT 1 INTO OUTFILE "file";
--error 1305
call bug20953();

