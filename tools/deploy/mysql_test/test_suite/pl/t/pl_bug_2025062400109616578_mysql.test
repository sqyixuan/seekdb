#owner: wangbai.wx
#owner group: pl/sql
#tags: pl
#description: fix dima 2025062400109616578

--result_format 4
--error 0,1305
drop function prop_group_val;

DELIMITER //;
create function `prop_group_val` (`json_str` varchar(2643),`group_code` varchar(1024),`prop_code` varchar(1024)) returns varchar(1024) begin
/**
   `json_str` varchar(3100)   --  订单属性表，目标字段
   ,`group_code` varchar(1000)  --  属性组的code
   ,`prop_code` varchar(1000)   --  目标属性code
*/
set @attr_group_reg = concat('"code":"', group_code, '".*?}]"}');  --  属性组的正则
set @attr_reg = concat('"code\\\\":\\\\"', prop_code, '\\\\".*?"value\\\\":.*?}');  --  目标json的正则
--  一个属性组
set @attr_group_str = regexp_substr(json_str, @attr_group_reg);
--  目标json
set @target_str = regexp_substr(@attr_group_str, @attr_reg);
set @tmp_val = regexp_substr(@target_str, '\\\\":[^:]*?}');
return  replace(replace(replace(@tmp_val, '\\"', ''), '}', ''), ':', '');
end;
//

DELIMITER ;//

--error 3995
select prop_group_val('sbhf','vfds','vfgs');

drop function prop_group_val;
