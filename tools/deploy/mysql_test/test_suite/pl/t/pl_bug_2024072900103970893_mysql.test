--result_format 4

--disable_warnings
drop database if exists xaaa;
--enable_warnings

create database xaaa;
drop function if exists xaaa.funcx;
create function xaaa.funcx (d INT) RETURNS INT DETERMINISTIC RETURN d;
drop database if exists xaaa;
create database xaaa;
drop function if exists xaaa.funcx;
create function xaaa.funcx (d INT) RETURNS INT DETERMINISTIC RETURN d;
select db,name from mysql.proc where name ='funcx';

drop function xaaa.funcx;
drop database xaaa;
