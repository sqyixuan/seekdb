#owner: wangbai.wx
#owner group: pl/sql
#tags: pl
#description: test pl bugs

--result_format 4

#1. test with no pl var
drop table if exists tt1;
drop table if exists tt2;
drop table if exists tt3;
drop procedure if exists p1;
delimiter /;
create procedure p1() begin set @x := 1; set @x := @x + 1; end
/
call p1()/
select @x/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#2. test with pl var (one var)
drop table tt1;
drop procedure p1;
delimiter /;
create procedure p1(in y int) begin set @x := 1; set @x := @x + y; end
/
call p1(1)/
select @x/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#3. test with pl var (multi var)
drop table tt1;
drop procedure p1;
delimiter /;
create procedure p1(in y int, in z int, in a int) begin set @x := 1; set @x := @x + y + z + a; end
/
call p1(1, 2, 3)/
select @x/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#4. test with multi var_val stmt
drop table tt1;
drop procedure p1;
delimiter /;
create procedure p1(in y int, in z int) begin set @x := 1; set @x := @x + y + z, @x := @x + y + z; end
/
call p1(1, 2)/
select @x/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#5. test with cacl diff type
drop table tt1;
drop procedure p1;
delimiter /;
create procedure p1() begin set @x := 1; set @x := @x + '1'; end
/
call p1()/
select @x/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#6. test with inout param
drop table tt1;
drop procedure p1;
set @x := 1;
set @y := 1;
delimiter /;
create procedure p1(inout y int, inout z int) begin set @z := 1; set @z := @z + y + z; end
/
call p1(@x, @y)/
select @x/
select @y/
select @z/
delimiter ;/
create table tt1 as select @x from dual;
create table tt2 as select @y from dual;
create table tt3 as select @z from dual;
desc tt1;
desc tt2;
desc tt3;

drop table tt1;
drop table tt2;
drop table tt3;
drop procedure p1;
delimiter /;
create procedure p1(inout y int, inout z int) begin set @z := 1; set y = 1, z = 2, @z := @z + y + z; end
/
call p1(@x, @y)/
select @x/
select @y/
select @z/
delimiter ;/
create table tt1 as select @x from dual;
create table tt2 as select @y from dual;
create table tt3 as select @z from dual;
desc tt1;
desc tt2;
desc tt3;

drop table tt1;
drop table tt2;
drop table tt3;
drop procedure p1;
set @x := 1;
set @y := 1;
delimiter /;
create procedure p1(inout y int, inout z int) begin set @z := 1; set @z := @z + y + z, y := y + z, z = y + z; end
/
call p1(@x, @y)/
select @x/
select @y/
select @z/
delimiter ;/
create table tt1 as select @x from dual;
create table tt2 as select @y from dual;
create table tt3 as select @z from dual;
desc tt1;
desc tt2;
desc tt3;

drop table tt1;
drop table tt2;
drop table tt3;
drop procedure p1;
delimiter /;
create procedure p1(inout y int, inout z int) begin set y = 1, z = 2, @z := 1; set @z := @z + y + z, y := y + z, z = y + z; end
/
call p1(@x, @y)/
select @x/
select @y/
select @z/
delimiter ;/
create table tt1 as select @x from dual;
create table tt2 as select @y from dual;
create table tt3 as select @z from dual;
desc tt1;
desc tt2;
desc tt3;

#7. test with out param
drop table tt1;
drop table tt2;
drop table tt3;
drop procedure p1;
set @x := 1;
set @y := 1;
delimiter /;
create procedure p1(out y int, out z int) begin set @z := 1; set @z := @z + y + z, y := y + z, z = y + z; end
/
call p1(@x, @y)/
select @x/
select @y/
select @z/
delimiter ;/
create table tt1 as select @x from dual;
create table tt2 as select @y from dual;
create table tt3 as select @z from dual;
desc tt1;
desc tt2;
desc tt3;

drop table tt1;
drop table tt2;
drop table tt3;
drop procedure p1;
set @x := 1;
set @y := 1;
set @z := NULL;
delimiter /;
create procedure p1(out y int, out z int) begin set y := 2, z = 2; end
/
call p1(@x, @y)/
select @x/
select @y/
select @z/
delimiter ;/
create table tt1 as select @x from dual;
create table tt2 as select @y from dual;
create table tt3 as select @z from dual;
desc tt1;
desc tt2;
desc tt3;

#8. test multi var_val is NORMAL
drop table tt1;
drop procedure p1;
delimiter /;
create procedure p1(in y int, in z int) begin set @x := 1; end
/
call p1(1, 2)/
select @x/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#9. test multi var_val is NORMAL + NORMAL
drop table tt1;
drop procedure p1;
delimiter /;
create procedure p1(in y int, in z int) begin set @x := 2, @a := 5; end
/
call p1(1, 2)/
select @x/
select @a/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#10. test multi var_val is NORMAL + DYNAMIC
drop table tt1;
drop procedure p1;
delimiter /;
create procedure p1(in y int, in z int) begin set @x := 1, @x := @x + y + z; end
/
call p1(1, 2)/
select @x/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#11. test multi var_val is NORMAL + DYNAMIC + NORMAL
drop table tt1;
drop procedure p1;
delimiter /;
create procedure p1(in y int, in z int) begin set @x := 1, @a := 2, @x := @x + y + z + @a, @a := 5; end
/
call p1(1, 2)/
select @x/
select @a/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

