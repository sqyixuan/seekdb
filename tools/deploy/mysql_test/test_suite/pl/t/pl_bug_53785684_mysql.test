#14. test multi var_val is DYNAMIC + NORMAL
drop table tt1;
drop procedure p1;
set @x := 1;
delimiter /;
create procedure p1(in y int, in z int) begin set @x := @x + y + z, @a := 2; end
/
call p1(1, 2)/
select @x/
select @a/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#15.test multi var_val is DYNAMIC + NORMAL + DYNAMIC
drop table tt1;
drop procedure p1;
set @x := 1;
delimiter /;
create procedure p1(in y int, in z int) begin set @x := @x + y + z, @a := 2, @x := @x + y + z + @a; end
/
call p1(1, 2)/
select @x/
select @a/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#16. test multi var_val DYNAMIC is PL + no PL + PL + no PL
drop table tt1;
drop procedure p1;
set @x := 1;
delimiter /;
create procedure p1(in y int, in z int) begin set @x := @x + y + z, @x = @x + 2, @x := @x + y + z, @x = @x + 2; end
/
call p1(1, 2)/
select @x/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#17. test multi var_val DYNAMIC is no PL + PL + no PL + PL
drop table tt1;
drop procedure p1;
set @x := 1;
delimiter /;
create procedure p1(in y int, in z int) begin set @x := @x + 1, @x := @x + y + z, @x = @x + 2, @x := @x + y + z; end
/
call p1(1, 2)/
select @x/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#18. test multi var_val is DYNAMIC
drop table tt1;
drop procedure p1;
delimiter /;
create procedure p1(in y int, in z int) begin set @x := 1 + y + z; end
/
call p1(1, 2)/
select @x/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#19. test multi var_val is DYNAMIC + DYNAMIC
drop table tt1;
drop procedure p1;
delimiter /;
create procedure p1(in y int, in z int) begin set @x := 2 + y + z, @a := 5 + y + z; end
/
call p1(1, 2)/
select @x/
select @a/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#20. test bug 53785684
drop table tt1;
drop table tt2;
drop procedure p1;
drop table if exists t1;
create table t1 (id bigint primary key);
insert into t1 values(1),(2);
delimiter /;
CREATE  PROCEDURE p1() BEGIN
  select min(id),max(id) into @low,@high from t1;
  create table tt1 as select @low from dual;
  set @low:=@low+100000;
  create table tt2 as select @low from dual;
END
/
call p1()/
desc tt1/
desc tt2/
select @low/
select @high/
delimiter ;/

drop procedure p1;
drop table t1;
drop table tt1;
drop table tt2;
drop table tt3;