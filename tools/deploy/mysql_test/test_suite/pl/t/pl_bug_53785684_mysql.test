drop table tt1;
drop procedure p1;
set @x := 1;
delimiter /;
create procedure p1(in y int, in z int) begin set @x := @x + y + z; end
/
call p1(1, 2)/
select @x/
delimiter ;/
create table tt1 as select @x from dual;
desc tt1;

#13. test multi var_val is DYNAMIC + DYNAMIC
drop table tt1;
drop procedure p1;
set @x := 1;
delimiter /;
create procedure p1(in y int, in z int) begin set @x := @x + y + z, @x := @x + y + z; end
/
call p1(1, 2)/
select @x/
delimiter ;/
