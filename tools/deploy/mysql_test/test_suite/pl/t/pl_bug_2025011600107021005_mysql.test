#owner: jiabokai.jbk
#owner group: pl/sql
#tags: pl
#description: Release the restriction which does not enter the cache due to compilation error in mysql mode

--result_format 4

--error 0,1305
drop procedure testp1;

--error 0,1305
drop procedure proc;

--error 0,1305
drop procedure proc2;

alter system flush plan cache global;
alter system flush pl cache global;

delimiter /;

create procedure testp1()
begin
  DECLARE CONTINUE HANDLER FOR SQLSTATE '42000' set @done = 1;
call proc();
end
/

--echo ##依赖routine不存在##
call testp1();
/

select PARAMETERIZE_TEXT,HIT_COUNT from oceanbase.GV$OB_PL_CACHE_OBJECT where PARAMETERIZE_TEXT like '%testp1%';
/

call testp1();
/

select PARAMETERIZE_TEXT,HIT_COUNT from oceanbase.GV$OB_PL_CACHE_OBJECT where PARAMETERIZE_TEXT like '%testp1%';
/

--echo ##依赖routine参数不匹配##
create procedure proc(a int)
begin
end
/

call testp1();
/

select PARAMETERIZE_TEXT,HIT_COUNT from oceanbase.GV$OB_PL_CACHE_OBJECT where PARAMETERIZE_TEXT like '%testp1%';
/

call testp1();
/

select PARAMETERIZE_TEXT,HIT_COUNT from oceanbase.GV$OB_PL_CACHE_OBJECT where PARAMETERIZE_TEXT like '%testp1%';
/
--echo ##ddl变更会导致该缓存失效##
create procedure proc2(a int)
begin
end
/
call testp1();
/
select PARAMETERIZE_TEXT,HIT_COUNT from oceanbase.GV$OB_PL_CACHE_OBJECT where PARAMETERIZE_TEXT like '%testp1%';
/

drop procedure proc;
/
--echo ##创建正确的依赖routine##
create procedure proc()
begin
end
/
call testp1();
/
select PARAMETERIZE_TEXT,HIT_COUNT from oceanbase.GV$OB_PL_CACHE_OBJECT where PARAMETERIZE_TEXT like '%testp1%';
/

drop procedure proc2;
/
call testp1();
/
select PARAMETERIZE_TEXT,HIT_COUNT from oceanbase.GV$OB_PL_CACHE_OBJECT where PARAMETERIZE_TEXT like '%testp1%';
/

delimiter ;/

drop procedure testp1;
drop procedure proc;
