#

DELIMITER /;

# case 1

--disable_warnings
drop function if exists f1/
--enable_warnings

--error 1445
create function f1() returns int deterministic
begin
  set autocommit=0;
return 1;
end/

--error 1305
select f1()/

# case 2

--disable_warnings
drop table if exists t1/
--enable_warnings

create table t1 (
  a int default 1,
  b int default 1
);/

--disable_warnings
drop trigger if exists trg_insert;/
--enable_warnings

--error 1445
create trigger trg_insert after insert on t1 for each row
begin
  set autocommit=0;
end;
/

drop table t1;/

DELIMITER ;/