##BEGIN##
CREATE TABLE ff01(a NUMBER,b varchar(10),c char(10));
CREATE OR REPLACE PROCEDURE pro01 AS
BEGIN
	DELETE FROM ff01;
END;
//
CREATE OR REPLACE FUNCTION fun01 RETURN varchar AS
	fun_a VARCHAR(10);
BEGIN
	SELECT b INTO fun_a FROM ff01 WHERE rownum=1;
	RETURN fun_a;
END;
//
CREATE OR REPLACE PACKAGE pac_test AS
	var_test NUMBER ;
	CURSOR cur_test IS SELECT * FROM ff01;
END;
//
CREATE OR REPLACE PACKAGE body pac01 AS
	FUNCTION fun01 RETURN NUMBER AS
	BEGIN
		pro01();
		RETURN 1;
	END;
END;
//
CREATE OR REPLACE PACKAGE body pac02 AS
	FUNCTION fun02 RETURN varchar AS
	BEGIN
		RETURN fun01();
	END;
END;
//
CREATE OR REPLACE PACKAGE pac03 AS
	FUNCTION fun03 RETURN NUMBER ;
END;
//
CREATE OR REPLACE PACKAGE body pac03 AS
	FUNCTION fun03 RETURN NUMBER AS
		fun03_a NUMBER;
	BEGIN
		OPEN pac_test.cur_test;
		CLOSE pac_test.cur_test;
	END;
END;
//
CREATE OR REPLACE PACKAGE pac04 AS
	FUNCTION fun04 RETURN NUMBER ;
END;
//
CREATE OR REPLACE PACKAGE body pac04 AS
	FUNCTION fun04 RETURN NUMBER AS
		fun04_a NUMBER;
	BEGIN
		fun04_a := pac_test.var_test;
		RETURN fun04_a;
	END;
END;
