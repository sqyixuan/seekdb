CREATE OR REPLACE PROCEDURE pro01 (a varchar,b varchar) AS
BEGIN
	EXECUTE IMMEDIATE 'alter package '||a||' compile';
	EXECUTE IMMEDIATE CONCAT('alter package ',b||' compile');
END;
//
CALL pro01('pac01','pac01');
CALL pro01(CONCAT('pac','01'),'pac'||'01');
