+-------+--------------+------+----------+--------------------------------------------------------------------------+----------------+
CREATE OR REPLACE TYPE t1 AS TABLE OF NUMBER;
//
CREATE OR REPLACE FUNCTION FUN01 RETURN T1 AS
	FUN_B T1;
BEGIN
	FOR I IN (SELECT B FROM FF01) LOOP
		FUN_B := T1(I.b);
	END LOOP ;
	RETURN FUN_B;
END;
//
CREATE OR REPLACE PACKAGE pac01 AS
	subtype sub01 IS t1 NOT NULL;
	var sub01 := fun01();
	FUNCTION FUN01 RETURN T1;
END;
//
CREATE OR REPLACE PACKAGE body pac01 AS
FUNCTION fun01 RETURN T1 IS
	fun_a T1;
BEGIN
	FOR I IN (SELECT A FROM FF01) LOOP
		FUN_A := T1(I.A);
	END LOOP;
	RETURN FUN_A;
END fun01;
BEGIN
	NULL;
END;
//
