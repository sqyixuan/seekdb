##创建测试用户
drop user CHI_ALTER_PROCEDURE cascade;
create user CHI_ALTER_PROCEDURE IDENTIFIED BY CHI_ALTER_PROCEDURE;
grant all on *.* to CHI_ALTER_PROCEDURE WITH GRANT OPTION;
grant dba to CHI_ALTER_PROCEDURE;
####包头部分COMPILE PACKAGE####
DROP TABLE ff01;
CREATE TABLE ff01(a NUMBER,b varchar(10),c char(10));
CREATE OR REPLACE PACKAGE pac01 AS
	var ff01.a%type;
	CURSOR CUR01 IS SELECT * FROM ff01;
END;
//
CREATE OR REPLACE PACKAGE body pac01 AS
BEGIN
	NULL;
END;
//
ALTER PACKAGE pac01 compile;
ALTER PACKAGE pac01 compile PACKAGE;
ALTER PACKAGE pac01 compile body;
select name, type, line, position, text, message_number from all_errors where name = 'PAC01';
