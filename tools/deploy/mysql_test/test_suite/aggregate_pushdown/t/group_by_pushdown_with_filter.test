select c1,min(c2),max(c2),sum(c2) from t1 where c2 < 1 group by c1 order by c1;
select c1,min(c3),max(c3) from t1 where c3 > 'abcdefg0' group by c1 order by c1;
select c1,min(c3),max(c3) from t1 where c3 > 'abcdefg3' group by c1 order by c1;

select c2,min(c1),max(c1),sum(c1) from t1 where c1 > -1  group by c2 order by c2;
select c2,min(c1),max(c1),sum(c1) from t1 where c1 > 0  group by c2 order by c2;
