# owner: yht146439
# tags: storage
# description: pushdown group by to storage layer with filter

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
connection default;
--enable_query_log

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1,t2,pt1;
--enable_warnings
--enable_query_log

create table t1(pk int, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048;
create table t2(pk int, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048;
create table pt1(pk int, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048 partition by hash(pk) partitions 4;

--disable_query_log
--let $count = 0
while($count < 1000)
{
  eval insert into t1(pk, c1,c2,c3) values 
                                  ($count * 10 + 1,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 2,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 3,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 4,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 5,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 6,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 7,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 8,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 9,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 10,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5)));
  eval insert into t2(pk, c1,c2,c3) values 
                                  ($count * 10 + 1,null, mod($count * 10 + 1 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 2,mod($count * 10 + 2, 4), mod($count * 10 + 2 + 1, 8), concat("aaaaaaaaaa", mod($count, 3))),
                                  ($count * 10 + 3,mod($count * 10 + 3, 4), mod($count * 10 + 3 + 1, 8), concat("aaaaaaaaaa", mod($count, 3))),
                                  ($count * 10 + 4,mod($count * 10 + 4, 4), null, concat("aaaaaaaaaa", mod($count, 3))),
                                  ($count * 10 + 5,mod($count * 10 + 5, 4), mod($count * 10 + 5 + 1, 8), concat("aaaaaaaaaa", mod($count, 3))),
                                  ($count * 10 + 6,mod($count * 10 + 6, 4), mod($count * 10 + 6 + 1, 8), concat("aaaaaaaaaa", mod($count, 3))),
                                  ($count * 10 + 7,mod($count * 10 + 7, 4), mod($count * 10 + 7 + 1, 8), null),
                                  ($count * 10 + 8,mod($count * 10 + 8, 4), mod($count * 10 + 8 + 1, 8), concat("aaaaaaaaaa", mod($count, 3))),
                                  ($count * 10 + 9,mod($count * 10 + 9, 4), mod($count * 10 + 9 + 1, 8), concat("aaaaaaaaaa", mod($count, 3))),
                                  ($count * 10 + 10,null, null, null);
  eval insert into pt1(pk, c1,c2,c3) values 
                                  ($count * 10 + 1,mod($count * 10 + 1, 4), mod($count * 10 + 1 + 1, 8), concat("bbbbbbbbbbbbbbbbb", mod($count, 3))),
                                  ($count * 10 + 2,mod($count * 10 + 2, 4), mod($count * 10 + 2 + 1, 8), concat("bbbbbbbbbbbbbbbbb", mod($count, 3))),
                                  ($count * 10 + 3,mod($count * 10 + 3, 4), mod($count * 10 + 3 + 1, 8), concat("bbbbbbbbbbbbbbbbb", mod($count, 3))),
                                  ($count * 10 + 4,mod($count * 10 + 4, 4), mod($count * 10 + 4 + 1, 8), concat("bbbbbbbbbbbbbbbbb", mod($count, 3))),
                                  ($count * 10 + 5,mod($count * 10 + 5, 4), mod($count * 10 + 5 + 1, 8), concat("bbbbbbbbbbbbbbbbb", mod($count, 3))),
                                  ($count * 10 + 6,mod($count * 10 + 6, 4), mod($count * 10 + 6 + 1, 8), concat("bbbbbbbbbbbbbbbbb", mod($count, 3))),
                                  ($count * 10 + 7,mod($count * 10 + 7, 4), mod($count * 10 + 7 + 1, 8), concat("bbbbbbbbbbbbbbbbb", mod($count, 3))),
                                  ($count * 10 + 8,mod($count * 10 + 8, 4), mod($count * 10 + 8 + 1, 8), concat("bbbbbbbbbbbbbbbbb", mod($count, 3))),
                                  ($count * 10 + 9,mod($count * 10 + 9, 4), mod($count * 10 + 9 + 1, 8), concat("bbbbbbbbbbbbbbbbb", mod($count, 3))),
                                  ($count * 10 + 10,mod($count * 10 + 10, 4), mod($count * 10 + 10+ 1, 8), concat("bbbbbbbbbbbbbbbbb", mod($count, 3)));
  --inc $count
}
--enable_query_log

select count(*) from t1 where c1 > -1 group by c1 order by c1;
select count(*) from t1 where c1 > 0 group by c1 order by c1;
select count(*) from t1 where c1 > 1 group by c1 order by c1;
select count(*) from t1 where c1 > 2 group by c1 order by c1;
select c1,count(*) from t1 where c2 < 10 group by c1 order by c1;
select c1,count(*) from t1 where c2 < 5 group by c1 order by c1;
select c1,count(*) from t1 where c2 < 1 group by c1 order by c1;
select c1,count(c2) from t1 where c3 > 'a' group by c1 order by c1;
select c1,count(c2) from t1 where c3 > 'abcdefg0' group by c1 order by c1;
select c1,count(c2) from t1 where c3 > 'abcdefg3' group by c1 order by c1;
select c1,count(*),count(pk),count(c1),count(c2),count(c3) from t1 where c1 > 0 or c2 > 0 or c3 > 'abcdefg0' group by c1 order by c1;

select c2,count(*) from t1 where c1 > -1 group by c2 order by c2;
select c2,count(*) from t1 where c1 > 0 group by c2 order by c2;
select c2,count(*) from t1 where c1 > 1 group by c2 order by c2;
select c2,count(*) from t1 where c1 > 2 group by c2 order by c2;
select c2,count(c3) from t1 where c2 < 10 group by c2 order by c2;
select c2,count(c3) from t1 where c2 < 5 group by c2 order by c2;
select c2,count(c3) from t1 where c2 < 1 group by c2 order by c2;
select c2,count(*),count(pk),count(c1),count(c2),count(c3) from t1  where c1 > 0 or c2 > 0 or c3 > 'abcdefg0' group by c2 order by c2;

select c3,count(*) from t1 where c3 > 'abcdefg0' group by c3 order by c3;
select c3,count(*) from t1 where c3 > 'abcdefg3' group by c3 order by c3;
select c3,count(c1) from t1 where c1 > -1 group by c3 order by c3;
select c3,count(c1) from t1 where c1 > 0 group by c3 order by c3;
select c3,count(c1) from t1 where c1 > 1 group by c3 order by c3;
select c3,count(c1) from t1 where c1 > 2 group by c3 order by c3;
select c3,count(*),count(pk),count(c1),count(c2),count(c3) from t1 where c1 + c2 > 0 or c3 > 'abcdefg0'  group by c3 order by c3;

select c1,min(c1),max(c1),sum(c1) from t1 where c1 > -1 group by c1 order by c1;
select c1,min(c1),max(c1),sum(c1) from t1 where c1 > 0 group by c1 order by c1;
select c1,min(c1),max(c1),sum(c1) from t1 where c1 > 1 group by c1 order by c1;
