select c2,min(c3),max(c3) from t1 where c3 > 'abcdefg0' group by c2 order by c2;
select c2,min(c3),max(c3) from t1 where c3 > 'abcdefg1' group by c2 order by c2;

select c3,min(c1),max(c1),sum(c1) from t1 where c1 + c2 > 0 group by c3 order by c3;
select c3,min(c1),max(c1),sum(c1) from t1 where c1 + c2 > 1 group by c3 order by c3;
select c3,min(c1),max(c1),sum(c1) from t1 where c1 + c2 > 2 group by c3 order by c3;
