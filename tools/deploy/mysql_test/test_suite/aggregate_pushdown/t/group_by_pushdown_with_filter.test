select c3,min(c3),max(c3) from t1 where c3 > 'abcdefg0' group by c3 order by c3;

select c1,count(*),count(pk),count(c1),count(c2),count(c3),min(pk),min(c1),min(c2),min(c3),max(pk),max(c1),max(c2),max(c3),sum(pk),sum(c1),sum(c2) from t1 where c1 > -1 group by c1 order by c1;
select c1,count(*),count(pk),count(c1),count(c2),count(c3),min(pk),min(c1),min(c2),min(c3),max(pk),max(c1),max(c2),max(c3),sum(pk),sum(c1),sum(c2) from t1 where c1 > 0 group by c1 order by c1;
select c2,count(*),count(pk),count(c1),count(c2),count(c3),min(pk),min(c1),min(c2),min(c3),max(pk),max(c1),max(c2),max(c3),sum(pk),sum(c1),sum(c2) from t1 where c1 > 1 group by c2 order by c2;
select c3,count(*),count(pk),count(c1),count(c2),count(c3),min(pk),min(c1),min(c2),min(c3),max(pk),max(c1),max(c2),max(c3),sum(pk),sum(c1),sum(c2) from t1 where c1 > 2 group by c3 order by c3;

