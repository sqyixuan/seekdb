# owner: dengzhi.ldz
# owner group: storage
# description: scan with lob column

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=90;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@session.explicit_defaults_for_timestamp=off;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
--enable_query_log

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
create table t1(pk int auto_increment primary key,
  a longtext SKIP_INDEX(MIN_MAX),
  b longblob SKIP_INDEX(MIN_MAX));
create table t2(pk int auto_increment primary key,
  a mediumtext SKIP_INDEX(MIN_MAX),
  b blob SKIP_INDEX(MIN_MAX),
  c tinytext SKIP_INDEX(MIN_MAX));

insert into t1(a, b) values(repeat('a', 5000000), repeat('b', 10000000));
insert into t1(a, b) values(repeat('A', 5000000), repeat('B', 10000000));
insert into t2(a, b, c) values(repeat('a', 5000000), repeat('b', 60000), repeat('c', 255));
insert into t2(a, b, c) values(repeat('A', 5000000), repeat('B', 60000), repeat('C', 255));
insert into t1(a, b) values(repeat('a', 200000), repeat('b', 200000));
insert into t1(a, b) values(repeat('A', 200000), repeat('B', 200000));
insert into t2(a, b, c) values(repeat('a', 100000), repeat('b', 60000), repeat('c', 255));
insert into t2(a, b, c) values(repeat('A', 100000), repeat('B', 60000), repeat('C', 255));

--let $loop=5
while($loop > 0)
{
  insert into t1 (a, b) select a, b from t1;
  insert into t2 (a, b, c) select a, b, c from t2;
  dec $loop;
}
select count(1) from t1;
select count(1) from t2;
select pk, length(a), length(b) from t1 order by 1 asc, 2;
select pk, length(a), length(b), length(c) from t2 order by 1 asc, 2;

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc
--enable_query_log

select min(a), max(a), min(b), max(b) from t1;
select min(a), max(a), min(b), max(b), max(c) from t2;
select count(*) from t1 where a > 'B';
select count(*) from t2 where b > 'B';
select min(b), max(b) from t1 where a > 'B';
select min(a), max(a), min(c), max(c) from t2 where b > 'B';
select a, count(*) from t1 group by a order by 1 asc;
select a, count(*) from t2 group by a order by 1 asc;
select b, count(*) from t2 group by b order by 1 asc;
select c, count(*) from t2 group by c order by 1 asc;

#cleanup
--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

--disable_query_log
set global max_allowed_packet=16777216;
set global ob_sql_work_area_percentage=5;
--enable_query_log
