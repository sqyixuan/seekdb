# owner: houhaojun.hhj
# tags: storage
# description: force pushdown group by to storage layer by sql hint

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_name = "EN_FORCE_GBY_PUSHDOWN_STORAGE", error_code = 4016, frequency = 0;
connection default;
alter system set _pushdown_storage_level=4;
alter system flush plan cache;
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1 (pk int primary key, c1 int, c2 double, c3 varchar(10));

explain select count(*) from t1 where c1 > -1;
explain select count(c1), min(c1), max(c1) from t1 where c1 > -1;

explain select c2, min(c1) from t1 where c1 > -1 group by c2;
explain select c2, max(c3) from t1 where c1 > -1 group by c2;
explain select c3, count(c1) from t1 where c1 > -1 group by c3;

explain select distinct(c1) from t1 where c1 > -1;
explain select distinct(c3) from t1 where c1 > -1;
explain select distinct(c1) from t1 where c1 > -1 group by c2;
explain select distinct(c2) from t1 where c1 > -1 group by c3;

explain select /*+opt_param('pushdown_storage_level', 0)*/ count(*) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 0)*/ count(c1), min(c1), max(c1) from t1 where c1 > -1;

explain select /*+opt_param('pushdown_storage_level', 0)*/ c2, min(c1) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 0)*/ c2, max(c3) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 0)*/ c3, count(c1) from t1 where c1 > -1 group by c3;

explain select /*+opt_param('pushdown_storage_level', 0)*/ distinct(c1) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 0)*/ distinct(c3) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 0)*/ distinct(c1) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 0)*/ distinct(c2) from t1 where c1 > -1 group by c3;

explain select /*+opt_param('pushdown_storage_level', 1)*/ count(*) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 1)*/ count(c1), min(c1), max(c1) from t1 where c1 > -1;

explain select /*+opt_param('pushdown_storage_level', 1)*/ c2, min(c1) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 1)*/ c2, max(c3) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 1)*/ c3, count(c1) from t1 where c1 > -1 group by c3;

explain select /*+opt_param('pushdown_storage_level', 1)*/ distinct(c1) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 1)*/ distinct(c3) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 1)*/ distinct(c1) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 1)*/ distinct(c2) from t1 where c1 > -1 group by c3;

explain select /*+opt_param('pushdown_storage_level', 2)*/ count(*) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 2)*/ count(c1), min(c1), max(c1) from t1 where c1 > -1;

explain select /*+opt_param('pushdown_storage_level', 2)*/ c2, min(c1) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 2)*/ c2, max(c3) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 2)*/ c3, count(c1) from t1 where c1 > -1 group by c3;

explain select /*+opt_param('pushdown_storage_level', 2)*/ distinct(c1) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 2)*/ distinct(c3) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 2)*/ distinct(c1) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 2)*/ distinct(c2) from t1 where c1 > -1 group by c3;

explain select /*+opt_param('pushdown_storage_level', 3)*/ count(*) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 3)*/ count(c1), min(c1), max(c1) from t1 where c1 > -1;

explain select /*+opt_param('pushdown_storage_level', 3)*/ c2, min(c1) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 3)*/ c2, max(c3) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 3)*/ c3, count(c1) from t1 where c1 > -1 group by c3;

explain select /*+opt_param('pushdown_storage_level', 3)*/ distinct(c1) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 3)*/ distinct(c3) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 3)*/ distinct(c1) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 3)*/ distinct(c2) from t1 where c1 > -1 group by c3;

explain select /*+opt_param('pushdown_storage_level', 4)*/ count(*) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 4)*/ count(c1), min(c1), max(c1) from t1 where c1 > -1;

explain select /*+opt_param('pushdown_storage_level', 4)*/ c2, min(c1) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 4)*/ c2, max(c3) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 4)*/ c3, count(c1) from t1 where c1 > -1 group by c3;

explain select /*+opt_param('pushdown_storage_level', 4)*/ distinct(c1) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 4)*/ distinct(c3) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 4)*/ distinct(c1) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 4)*/ distinct(c2) from t1 where c1 > -1 group by c3;

explain select /*+opt_param('pushdown_storage_level', 4) opt_param('rowsets_enabled', 'false')*/ count(*) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 4) opt_param('rowsets_enabled', 'false')*/ count(c1), min(c1), max(c1) from t1 where c1 > -1;

explain select /*+opt_param('pushdown_storage_level', 4) opt_param('rowsets_enabled', 'false')*/ c2, min(c1) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 4) opt_param('rowsets_enabled', 'false')*/ c2, max(c3) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 4) opt_param('rowsets_enabled', 'false')*/ c3, count(c1) from t1 where c1 > -1 group by c3;

explain select /*+opt_param('pushdown_storage_level', 4) opt_param('rowsets_enabled', 'false')*/ distinct(c1) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 4) opt_param('rowsets_enabled', 'false')*/ distinct(c3) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 4) opt_param('rowsets_enabled', 'false')*/ distinct(c1) from t1 where c1 > -1 group by c2;
explain select /*+opt_param('pushdown_storage_level', 4) opt_param('rowsets_enabled', 'false')*/ distinct(c2) from t1 where c1 > -1 group by c3;

--disable_query_log
connection obsys;
alter system set_tp tp_name = "EN_FORCE_GBY_PUSHDOWN_STORAGE", error_code = 4016, frequency = 1;
connection default;
--enable_query_log

explain select count(*) from t1 where c1 > -1;
explain select count(c1), min(c1), max(c1) from t1 where c1 > -1;

explain select c2, min(c1) from t1 where c1 > -1 group by c2;
explain select c2, max(c3) from t1 where c1 > -1 group by c2;
explain select c3, count(c1) from t1 where c1 > -1 group by c3;

explain select distinct(c1) from t1 where c1 > -1;
explain select distinct(c3) from t1 where c1 > -1;
explain select distinct(c1) from t1 where c1 > -1 group by c2;
explain select distinct(c2) from t1 where c1 > -1 group by c3;

--disable_query_log
connection obsys;
alter system set_tp tp_name = "EN_FORCE_GBY_PUSHDOWN_STORAGE", error_code = 4016, frequency = 0;
connection default;
--enable_query_log

--disable_query_log
connection obsys;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
connection default;

--let $count=0
while($count < 10000)
{
  eval insert into t1(pk, c1, c2, c3) values ($count, $count, 1.77 + mod($count, 5), concat("abcd", mod($count, 10)));
  inc $count;
}
--enable_query_log

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

--disable_query_log
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);
--enable_query_log

explain select count(*) from t1 where c1 > -1;
explain select count(c1), min(c1), max(c1) from t1 where c1 > -1;

explain select distinct(c2) from t1 where c1 > -1;
explain select distinct(c3) from t1 where c1 > -1;
explain select c2, max(c1) from t1 where c1 > -1 group by c2;
explain select c3, min(c1) from t1 where c1 > -1 group by c3;

explain select /*+opt_param('pushdown_storage_level', 0)*/ count(*) from t1 where c1 > -1;
explain select /*+opt_param('pushdown_storage_level', 0)*/ count(c1), min(c1), max(c1) from t1 where c1 > -1;

