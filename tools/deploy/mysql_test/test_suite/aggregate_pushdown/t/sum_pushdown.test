select sum(pk),sum(c1),sum(c2) from t2 where pk > 10 and pk < 9910;
select sum(pk),sum(c1),sum(c2) from t2 where c1 > 10 and c1 < 9910;


select sum(c1),sum(c2),sum(c3),sum(c4),sum(c5),sum(c6) from tt1;
select sum(c1),sum(c2),sum(c3),sum(c4),sum(c5) from tt2;
select sum(c1), sum(c2) from tt3;
select sum(c1), sum(c2) from tt4;

alter system major freeze;
