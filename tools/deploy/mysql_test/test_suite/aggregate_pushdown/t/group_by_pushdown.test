explain select/*+leading(st1) use_nl(tt) NO_USE_NL_MATERIALIZATION(tt) */ * from st1,(select c2,count(*) from st2 group by c2) tt where tt.c2>st1.pk-10 and tt.c2 < st1.pk+1000 order by 1,2,3;
select/*+leading(st1) use_nl(tt) NO_USE_NL_MATERIALIZATION(tt) */ * from st1,(select c2,count(*) from st2 group by c2) tt where tt.c2>st1.pk-10 and tt.c2 < st1.pk+1000 order by 1,2,3;

