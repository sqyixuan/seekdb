# owner: houhaojun.hhj
# tags: storage
# description: test group by pushdown vector format switch

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
connection default;
--enable_query_log

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t_empty,t_null1,t_null2,t_default1,t_default2,t1,t2,t3,pt1,st1,st2,t_padding;
--enable_warnings
--enable_query_log

set _enable_rich_vector_format = true;

# empty table
create table t_empty(c1 int, c2 int);
select count(c1), min(c1), max(c1), sum(c1) from t_empty;
select count(c2), min(c2), max(c2), sum(c2) from t_empty;
select c1,count(c2),min(c2),max(c2),sum(c2) from t_empty group by c1 order by c1;
select c2,count(c1),min(c1),max(c1),sum(c1) from t_empty group by c1 order by c2;

# null values
create table t_null1(c1 int, c2 int);
insert into t_null1 values(null,null),(null,null),(null,null);
select count(c1), min(c1), max(c1), sum(c1) from t_null1;
select count(c2), min(c2), max(c2), sum(c2) from t_null1;
select c1,count(c2),min(c2),max(c2),sum(c2) from t_null1 group by c1 order by c1;
select c2,count(c1),min(c1),max(c1),sum(c1) from t_null1 group by c1 order by c2;

create table t_null2(c1 int, c2 int);
insert into t_null2 values(null,null),(1,null),(null,2),(3,3);
select count(c1), min(c1), max(c1), sum(c1) from t_null2;
select count(c2), min(c2), max(c2), sum(c2) from t_null2;
select c1,count(c2),min(c2),max(c2),sum(c2) from t_null2 group by c1 order by c1;
select c2,count(c1),min(c1),max(c1),sum(c1) from t_null2 group by c1 order by c2;

delete from t_null2 where 1=1;
insert into t_null2 values(1,1),(null,null),(2,2);
select count(c1), min(c1), max(c1), sum(c1) from t_null2;
select count(c2), min(c2), max(c2), sum(c2) from t_null2;
select c1,count(c2),min(c2),max(c2),sum(c2) from t_null2 group by c1 order by c1;
select c2,count(c1),min(c1),max(c1),sum(c1) from t_null2 group by c1 order by c2;

# default values
create table t_default1(pk int primary key, c1 int default 10, c2 int default 100) row_format = compact;
insert into t_default1 values(1,1,1);
insert into t_default1(pk) values(2),(3);
select count(c1), min(c1), max(c1), sum(c1) from t_default1;
select count(c2), min(c2), max(c2), sum(c2) from t_default1;
select c1,count(c2),min(c2),max(c2),sum(c2) from t_default1 group by c1 order by c1;
select c2,count(c1),min(c1),max(c1),sum(c1) from t_default1 group by c1 order by c2;

--disable_query_log
--let $loop=4
while($loop < 1000)
{
  eval insert into t_default1(pk) values($loop);
  inc $loop;
}
--enable_query_log
select count(c1), min(c1), max(c1), sum(c1) from t_default1;
select count(c2), min(c2), max(c2), sum(c2) from t_default1;
select c1,count(c2),min(c2),max(c2),sum(c2) from t_default1 group by c1 order by c1;
select c2,count(c1),min(c1),max(c1),sum(c1) from t_default1 group by c1 order by c2;

create table t_default2(pk int primary key, c1 int default 10, c2 int default 100) row_format = compact;
insert into t_default2 values(1,9,19);
select count(c1), min(c1), max(c1), sum(c1) from t_default2;
select count(c2), min(c2), max(c2), sum(c2) from t_default2;
select c1,count(c2),min(c2),max(c2),sum(c2) from t_default2 group by c1 order by c1;
select c2,count(c1),min(c1),max(c1),sum(c1) from t_default2 group by c1 order by c2;

--disable_query_log
--let $loop=2
while($loop < 1000)
{
  eval insert into t_default2(pk) values($loop);
  inc $loop;
}
call dbms_stats.gather_table_stats('TEST', 't_default2', method_opt=>'for all columns size 64', estimate_percent=>100);
--enable_query_log
select count(c1), min(c1), max(c1), sum(c1) from t_default2;
select count(c2), min(c2), max(c2), sum(c2) from t_default2;
select c1,count(c2),min(c2),max(c2),sum(c2) from t_default2 group by c1 order by c1;
select c2,count(c1),min(c1),max(c1),sum(c1) from t_default2 group by c1 order by c2;

set _enable_rich_vector_format = false;

# empty table
select count(c1), min(c1), max(c1), sum(c1) from t_empty;
select count(c2), min(c2), max(c2), sum(c2) from t_empty;
select c1,count(c2),min(c2),max(c2),sum(c2) from t_empty group by c1 order by c1;
select c2,count(c1),min(c1),max(c1),sum(c1) from t_empty group by c1 order by c2;

# null values
select count(c1), min(c1), max(c1), sum(c1) from t_null1;
select count(c2), min(c2), max(c2), sum(c2) from t_null1;
select c1,count(c2),min(c2),max(c2),sum(c2) from t_null1 group by c1 order by c1;
select c2,count(c1),min(c1),max(c1),sum(c1) from t_null1 group by c1 order by c2;

select count(c1), min(c1), max(c1), sum(c1) from t_null2;
select count(c2), min(c2), max(c2), sum(c2) from t_null2;
select c1,count(c2),min(c2),max(c2),sum(c2) from t_null2 group by c1 order by c1;
select c2,count(c1),min(c1),max(c1),sum(c1) from t_null2 group by c1 order by c2;

# default values
select count(c1), min(c1), max(c1), sum(c1) from t_default1;
select count(c2), min(c2), max(c2), sum(c2) from t_default1;
select c1,count(c2),min(c2),max(c2),sum(c2) from t_default1 group by c1 order by c1;
select c2,count(c1),min(c1),max(c1),sum(c1) from t_default1 group by c1 order by c2;

select count(c1), min(c1), max(c1), sum(c1) from t_default2;
select count(c2), min(c2), max(c2), sum(c2) from t_default2;
select c1,count(c2),min(c2),max(c2),sum(c2) from t_default2 group by c1 order by c1;
select c2,count(c1),min(c1),max(c1),sum(c1) from t_default2 group by c1 order by c2;

create table t1(pk int, c1 int, c2 int unsigned, c3 varchar(100), primary key(c1,pk)) block_size=2048;
create table t2(pk int primary key, c1 int, c2 decimal(4, 2), c3 varchar(100)) block_size=2048;
create table t3(pk int primary key, c1 int, c2 decimal(4, 2), c3 longtext) block_size=2048;
create table pt1(pk int primary key, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048 partition by hash(pk) partitions 4;
create table t_padding(pk int primary key, c1 char(20), c2 char(20)) block_size=2048;

create table st1(pk int, c1 int, c2 int, primary key(pk));
create table st2(c1 int primary key, c2 int);
create index st1_idx1 on st1(c1,c2);
create index st2_c2 on st2(c2);

--disable_query_log
--let $count = 0
while($count < 1000)
{
  eval insert into t1(pk, c1,c2,c3) values 
                                  ($count * 10 + 1,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 2,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 3,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 4,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 5,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 6,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 7,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 8,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 9,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 10,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5)));
  eval insert into t2(pk, c1,c2,c3) values 
                                  ($count * 10 + 1,null, 1.23 + mod($count * 10 + 1 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 2,mod($count * 10 + 2, 4), 1.23 + mod($count * 10 + 2 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 3,mod($count * 10 + 3, 4), 1.23 + mod($count * 10 + 3 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 4,mod($count * 10 + 4, 4), null, concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 5,mod($count * 10 + 5, 4), 1.23 + mod($count * 10 + 5 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 6,mod($count * 10 + 6, 4), 1.23 + mod($count * 10 + 6 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 7,mod($count * 10 + 7, 4), 1.23 + mod($count * 10 + 7 + 1, 8), null),
                                  ($count * 10 + 8,mod($count * 10 + 8, 4), 1.23 + mod($count * 10 + 8 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 9,mod($count * 10 + 9, 4), 1.23 + mod($count * 10 + 9 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 10,null, null, null);
  eval insert into pt1(pk, c1,c2,c3) values 
                                  ($count * 10 + 1,mod($count * 10 + 1, 4), mod($count * 10 + 1 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 2,mod($count * 10 + 2, 4), mod($count * 10 + 2 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 3,mod($count * 10 + 3, 4), mod($count * 10 + 3 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 4,mod($count * 10 + 4, 4), mod($count * 10 + 4 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 5,mod($count * 10 + 5, 4), mod($count * 10 + 5 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 6,mod($count * 10 + 6, 4), mod($count * 10 + 6 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 7,mod($count * 10 + 7, 4), mod($count * 10 + 7 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 8,mod($count * 10 + 8, 4), mod($count * 10 + 8 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 9,mod($count * 10 + 9, 4), mod($count * 10 + 9 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 10,mod($count * 10 + 10, 4), mod($count * 10 + 10+ 1, 8), concat("abcdefg", mod($count, 3)));
  eval insert into t_padding(pk, c1, c2) values
                                  ($count * 10 + 1,  ("aa"),   concat("abc", mod($count, 3))),
                                  ($count * 10 + 2,  ("bbb"),  concat("abc", mod($count, 3))),
                                  ($count * 10 + 3,  ("c"),    concat("abc", mod($count, 3))),
                                  ($count * 10 + 4,  ("dddd"), concat("abc", mod($count, 3))),
                                  ($count * 10 + 5,  null,     concat("abc", mod($count, 3))),
                                  ($count * 10 + 6,  ("ee"),   concat("abc", mod($count, 3))),
                                  ($count * 10 + 7,  ("fff"),  concat("abc", mod($count, 3))),
                                  ($count * 10 + 8,  ("ggg"),  concat("abc", mod($count, 3))),
                                  ($count * 10 + 9,  ("hh"),   concat("abc", mod($count, 3))),
                                  ($count * 10 + 10, ("iii"),  concat("abc", mod($count, 3)));
  --inc $count
}
--enable_query_log
insert into t3 select * from t2;
# lob out row
update t3 set c3 = repeat("abc", 10000) where mod(pk, 100) = 0;
insert into st1 select pk,pk%3,pk from t1 limit 5000;
insert into st2 select pk,c1 from st1;

set _enable_rich_vector_format = true;
--source mysql_test/include/group_by_pushdown_query.inc

set _enable_rich_vector_format = false;
--source mysql_test/include/group_by_pushdown_query.inc

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

set _enable_rich_vector_format = true;
--source mysql_test/include/group_by_pushdown_query.inc

set _enable_rich_vector_format = false;
--source mysql_test/include/group_by_pushdown_query.inc

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

--disable_query_log
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'T2', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'T3', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'PT1', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'ST1', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'ST2', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'T_PADDING', method_opt=>'for all columns size 64', estimate_percent=>100);
--enable_query_log

set _enable_rich_vector_format = true;
--source mysql_test/include/group_by_pushdown_query.inc

set _enable_rich_vector_format = false;
--source mysql_test/include/group_by_pushdown_query.inc

# insert new rows to memtable
--disable_query_log
while($count < 1010)
{
  eval insert into t1(pk, c1,c2,c3) values 
                                  ($count * 10 + 1,mod($count, 3), mod($count, 10), concat("oceanbase", mod($count, 5))),
                                  ($count * 10 + 2,mod($count, 3), mod($count, 10), concat("oceanbase", mod($count, 5))),
                                  ($count * 10 + 3,mod($count, 3), mod($count, 10), concat("oceanbase", mod($count, 5))),
                                  ($count * 10 + 4,mod($count, 3), mod($count, 10), concat("oceanbase", mod($count, 5))),
                                  ($count * 10 + 5,mod($count, 3), mod($count, 10), concat("oceanbase", mod($count, 5))),
                                  ($count * 10 + 6,mod($count, 3), mod($count, 10), concat("oceanbase", mod($count, 5))),
                                  ($count * 10 + 7,mod($count, 3), mod($count, 10), concat("oceanbase", mod($count, 5))),
                                  ($count * 10 + 8,mod($count, 3), mod($count, 10), concat("oceanbase", mod($count, 5))),
                                  ($count * 10 + 9,mod($count, 3), mod($count, 10), concat("oceanbase", mod($count, 5))),
                                  ($count * 10 + 10,mod($count, 3), mod($count, 10), concat("oceanbase", mod($count, 5)));
  eval insert into t2(pk, c1,c2,c3) values 
                                  ($count * 10 + 1,null, 1.23 + mod($count * 10 + 1 + 1, 8), concat("oceanbase", mod($count, 3))),
                                  ($count * 10 + 2,mod($count * 10 + 2, 4), 1.23 + mod($count * 10 + 2 + 1, 8), concat("oceanbase", mod($count, 3))),
                                  ($count * 10 + 3,mod($count * 10 + 3, 4), 1.23 + mod($count * 10 + 3 + 1, 8), concat("oceanbase", mod($count, 3))),
                                  ($count * 10 + 4,mod($count * 10 + 4, 4), null, concat("oceanbase", mod($count, 3))),
                                  ($count * 10 + 5,mod($count * 10 + 5, 4), 1.23 + mod($count * 10 + 5 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 6,mod($count * 10 + 6, 4), 1.23 + mod($count * 10 + 6 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 7,mod($count * 10 + 7, 4), 1.23 + mod($count * 10 + 7 + 1, 8), null),
                                  ($count * 10 + 8,mod($count * 10 + 8, 4), 1.23 + mod($count * 10 + 8 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 9,mod($count * 10 + 9, 4), 1.23 + mod($count * 10 + 9 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 10,null, null, null);
  eval insert into pt1(pk, c1,c2,c3) values 
                                  ($count * 10 + 1,mod($count * 10 + 1, 4), mod($count * 10 + 1 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 2,mod($count * 10 + 2, 4), mod($count * 10 + 2 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 3,mod($count * 10 + 3, 4), mod($count * 10 + 3 + 1, 8), concat("oceanbase", mod($count, 3))),
                                  ($count * 10 + 4,mod($count * 10 + 4, 4), mod($count * 10 + 4 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 5,mod($count * 10 + 5, 4), mod($count * 10 + 5 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 6,mod($count * 10 + 6, 4), mod($count * 10 + 6 + 1, 8), concat("oceanbase", mod($count, 3))),
                                  ($count * 10 + 7,mod($count * 10 + 7, 4), mod($count * 10 + 7 + 1, 8), concat("oceanbase", mod($count, 3))),
                                  ($count * 10 + 8,mod($count * 10 + 8, 4), mod($count * 10 + 8 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 9,mod($count * 10 + 9, 4), mod($count * 10 + 9 + 1, 8), concat("oceanbase", mod($count, 3))),
                                  ($count * 10 + 10,mod($count * 10 + 10, 4), mod($count * 10 + 10+ 1, 8), concat("abcdefg", mod($count, 3)));
  eval insert into t_padding(pk, c1, c2) values
                                  ($count * 10 + 1,  ("aa"),   concat("abc", mod($count, 3))),
                                  ($count * 10 + 2,  ("bbb"),  concat("abc", mod($count, 3))),
                                  ($count * 10 + 3,  ("c"),    concat("abc", mod($count, 3))),
                                  ($count * 10 + 4,  ("dddd"), concat("abc", mod($count, 3))),
                                  ($count * 10 + 5,  null,     concat("abc", mod($count, 3))),
                                  ($count * 10 + 6,  ("ee"),   concat("abc", mod($count, 3))),
                                  ($count * 10 + 7,  ("fff"),  concat("abc", mod($count, 3))),
                                  ($count * 10 + 8,  ("ggg"),  concat("abc", mod($count, 3))),
                                  ($count * 10 + 9,  ("hh"),   concat("abc", mod($count, 3))),
                                  ($count * 10 + 10, ("iii"),  concat("abc", mod($count, 3)));
  --inc $count
}
--enable_query_log
insert into t3 select * from t2 limit 100 offset 10000;
insert into st1 select pk,pk%3,pk from t1 limit 100 offset 10000;
insert into st2 select pk,c1 from st1 limit 100 offset 10000;

