# owner: houhaojun.hhj
# tags: storage
# description: test scale group by pushdown datum buffer

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
connection default;
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
alter system set _pushdown_storage_level=4;
sleep 1;

set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1;
drop sequence if exists seq1;
--enable_warnings
--enable_query_log

create table t1 (pk int, c1 varchar(100));

--disable_query_log
create sequence seq1 cache 20000 noorder;
insert into t1 select seq1.nextval, concat("abcdefg", mod(seq1.nextval, 3)) from table(generator(10000));
insert into t1 select seq1.nextval, concat("hijklmn", mod(seq1.nextval, 10)) from table(generator(10000));
--enable_query_log

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

--disable_query_log
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);
--enable_query_log

select count(pk), c1 from t1 where mod(pk, 500) <> 0 group by c1;
select min(pk), c1 from t1 where mod(pk, 500) <> 0 group by c1;
select max(pk), c1 from t1 where mod(pk, 500) <> 0 group by c1;

--disable_query_log
connection obsys;
alter system set_tp tp_no = 368, error_code = 4016, frequency = 1;
connection default;
--enable_query_log
drop sequence seq1;
drop table t1;
