# owner: yht146439
#tags: optimizer
# description: pushdown aggregation(count/min/max) to storage layer

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings
--enable_query_log

create table t1(pk int, c1 int, c2 int);
create table t2(pk int, c1 int, c2 int) partition by hash(pk) partitions 4;
create table t3(pk int, c1 char(10), c2 int default 5);
create table t4(c1 int, c2 int) block_size=2048;

insert into t1 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,null,null);
insert into t2 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,null,null);
insert into t3(pk,c1) values(1,'a'),(2,'b'),(3,'c');
--disable_query_log
--let $count = 0
while($count < 1000)
{
  eval insert into t4(c1,c2) values 
                                  ($count * 10 + 1 ,$count * 10 + 1 + 1),
                                  ($count * 10 + 2 ,$count * 10 + 2 + 1),
                                  ($count * 10 + 3 ,$count * 10 + 3 + 1),
                                  ($count * 10 + 4 ,$count * 10 + 4 + 1),
                                  ($count * 10 + 5 ,$count * 10 + 5 + 1),
                                  ($count * 10 + 6 ,$count * 10 + 6 + 1),
                                  ($count * 10 + 7 ,$count * 10 + 7 + 1),
                                  ($count * 10 + 8 ,$count * 10 + 8 + 1),
                                  ($count * 10 + 9 ,$count * 10 + 9 + 1),
                                  ($count * 10 + 10,$count * 10 + 10+ 1);
  --inc $count
}

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc
--enable_query_log

explain select count(*) from t1;
explain select c1,count(c1) from t1;
explain select min(c1) from t1;
explain select max(c2) from t1;
explain select c1,min(c1) from t1;
explain select count(*),count(c1),min(c1),max(c1) from t1;
explain select sum(c1) from t1;
explain select sum(c1) from t3;
explain select sum(c1+c2) from t3;

select count(*) from t1;
select count(*) from t1 where c1 is not null;
select count(pk) from t1;
select c1,count(c1) from t1;

select count(*) from t2;
select count(*) from t2 where c1 is not null;
select count(pk) from t2;
select c1,count(c1) from t2;

select min(c1) from t1;
select max(c2) from t1;
select min(c1) from t1 where c1 is not null;
select max(c2) from t1 where c2 is not null;
select c1,min(c1),max(c1) from t1;
select count(*),count(c1),min(c1),max(c1) from t1;

select min(c1) from t2;
select max(c2) from t2;
select min(c1) from t2 where c1 is not null;
select max(c2) from t2 where c2 is not null;
select c1,min(c1),max(c1) from t2;
select count(*),count(c1),min(c1),max(c1) from t2;
select /*+opt_param('rowsets_max_rows', 65535) opt_param('enable_rich_vector_format', 'false')*/ count(*),count(c1),min(c1),max(c1) from t2;

select sum(c1) from t1;
select sum(pk),sum(c1),sum(c2) from t1;
select sum(pk),sum(c1),sum(c2) from t2;
select sum(c1),sum(c2) from t4;
select count(*),count(c1),min(c1),max(c1),sum(c1) from t1;
select /*+opt_param('rowsets_max_rows', 65535) opt_param('enable_rich_vector_format', 'false')*/ count(*),count(c1),min(c1),max(c1),sum(c1) from t1;

SET sql_mode = 'STRICT_ALL_TABLES,PAD_CHAR_TO_FULL_LENGTH';
select c1,count(c1) from t3;
select c2,count(c2) from t3; 

select c1,min(c1),max(c1) from t3;
select c2,min(c2),max(c2) from t3;

SET sql_mode = '';
select c1,count(c1) from t3;
select c2,count(c2) from t3; 

select count(*) from t4 where rand() < 2;
select count(*) from t4 where rand() > 2;

select c1,min(c1),max(c1) from t3;
select c2,min(c2),max(c2) from t3;

# clean
drop table if exists t1,t2,t3,t4;
