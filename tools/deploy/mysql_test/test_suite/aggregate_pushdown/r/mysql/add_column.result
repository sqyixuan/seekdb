create table t1(pk int, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048;
create table t2(pk int, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048 partition by hash(pk) partitions 4;
select count(*),count(pk),min(pk),max(pk),sum(pk),min(c1),max(c1),sum(c1),min(c2),max(c2),sum(c2),min(c3),max(c3) from t1;
count(*)	count(pk)	min(pk)	max(pk)	sum(pk)	min(c1)	max(c1)	sum(c1)	min(c2)	max(c2)	sum(c2)	min(c3)	max(c3)
10000	10000	1	10000	50005000	1	10000	50005000	2	10001	50015000	abcdefg0	abcdefg999
alter system minor freeze;
alter table t1 add column c4 bigint default 10, add column c5 bigint unsigned default 20;
alter table t1 add column c6 bigint default null;
