create table pt1(a int);
create table pt2(a int, b int, c int) partition by hash(a) partitions 4;
create table pt3(a int, b int, c int) partition by hash(a) partitions 4;
insert into pt1 values(1),(2),(3);
insert into pt2 values(1,1,1),(2,2,2),(3,3,3);
insert into pt3 values (null,null,null),(1,1,1),(2,2,2),(3,3,3);
select a,sum_opnsize(a),approx_count_distinct(a),sum_opnsize(b),approx_count_distinct(b),sum_opnsize(c),approx_count_distinct(c) from pt2;
a	sum_opnsize(a)	approx_count_distinct(a)	sum_opnsize(b)	approx_count_distinct(b)	sum_opnsize(c)	approx_count_distinct(c)
1	60	3	60	3	60	3
select a,sum_opnsize(a),approx_count_distinct(a),sum_opnsize(b),approx_count_distinct(b),sum_opnsize(c),approx_count_distinct(c) from pt3;
a	sum_opnsize(a)	approx_count_distinct(a)	sum_opnsize(b)	approx_count_distinct(b)	sum_opnsize(c)	approx_count_distinct(c)
NULL	72	3	72	3	72	3
select/*+ leading(pt1,tt) use_nl(pt1,tt) NO_USE_NL_MATERIALIZATION(tt) */ * from pt1,(select a,sum_opnsize(a),approx_count_distinct(a),sum_opnsize(b),approx_count_distinct(b),sum_opnsize(c),approx_count_distinct(c) from pt2) as tt where pt1.a=tt.a;
a	a	sum_opnsize(a)	approx_count_distinct(a)	sum_opnsize(b)	approx_count_distinct(b)	sum_opnsize(c)	approx_count_distinct(c)
1	1	60	3	60	3	60	3
select/*+ leading(pt1,tt) use_nl(pt1,tt) NO_USE_NL_MATERIALIZATION(tt) */ * from pt1,(select a,sum_opnsize(a),approx_count_distinct(a),sum_opnsize(b),approx_count_distinct(b),sum_opnsize(c),approx_count_distinct(c) from pt3) as tt where pt1.a=tt.a;
a	a	sum_opnsize(a)	approx_count_distinct(a)	sum_opnsize(b)	approx_count_distinct(b)	sum_opnsize(c)	approx_count_distinct(c)
drop table if exists t_types,t_empty,t_null1,t_null2,t_default1,t_default2,t_padding,t1,t2,pt1,pt2,pt3;
