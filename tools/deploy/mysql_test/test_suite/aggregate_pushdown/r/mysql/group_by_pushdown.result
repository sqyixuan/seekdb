-------------------------------------
  0 - output([st1.c1], [T_FUN_COUNT(*)], [T_FUN_COUNT(st1.c1)]), filter(nil), rowset=4
      group([st1.c1]), agg_func([T_FUN_COUNT(*)], [T_FUN_COUNT(st1.c1)])
  1 - output([st1.c1]), filter([st1.c2 = 1234]), rowset=4
      access([st1.c2], [st1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([st1.c1], [st1.c2], [st1.pk]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
