create table t1(pk int, c1 int, c2 int unsigned, c3 varchar(100), primary key(c1,pk)) block_size=2048;
create table t2(pk int primary key, c1 int, c2 decimal(4, 2), c3 varchar(100)) block_size=2048;
create table t3(pk int primary key, c1 int, c2 decimal(4, 2), c3 longtext) block_size=2048;
create table pt1(pk int primary key, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048 partition by hash(pk) partitions 4;
create table t_padding(pk int primary key, c1 char(20), c2 char(20)) block_size=2048;
create table t_lob(pk int primary key, c1 int, c2 text) lob_inrow_threshold = 0;
create table t_lob_cs(pk int primary key, c1 int, c2 text) row_format = compressed lob_inrow_threshold = 0;
create table st1(pk int, c1 int, c2 int, primary key(pk));
create table st2(c1 int primary key, c2 int);
create index st1_idx1 on st1(c1,c2);
create index st2_c2 on st2(c2);
create table tm1(c1 int, c2 int, c3 int, c4 int, primary key(c1,c2));
create table tm2(c1 int, c2 int, c3 int);
create index tm1_idx1 on tm1(c1,c4);
create index tm1_idx2 on tm1(c3,c4);
