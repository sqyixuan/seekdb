explain select/*+leading(st1) use_nl(tt) NO_USE_NL_MATERIALIZATION(tt) */ * from st1,(select c2,count(*) from st2 group by c2) tt where tt.c2>st1.pk-10 and tt.c2 < st1.pk+1000 order by 1,2,3;
Query Plan
=========================================================================
|ID|OPERATOR                          |NAME       |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------------
|0 |NESTED-LOOP JOIN                  |           |16      |451774      |
|1 |├─TABLE FULL SCAN                 |st1        |5000    |521         |
|2 |└─SUBPLAN SCAN                    |tt         |1       |90          |
|3 |  └─MERGE GROUP BY                |           |1       |90          |
|4 |    └─DISTRIBUTED TABLE RANGE SCAN|st2(st2_c2)|1667    |46          |
=========================================================================
Outputs & filters:
-------------------------------------
  0 - output([st1.pk], [st1.c1], [st1.c2], [tt.c2], [tt.count(*)]), filter(nil), rowset=4
      conds(nil), nl_params_([st1.pk(:0)]), use_batch=true
  1 - output([st1.pk], [st1.c1], [st1.c2]), filter([st1.pk + 1000 > st1.pk + -10]), rowset=4
      access([st1.pk], [st1.c1], [st1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([st1.pk]), range(MIN ; MAX)always true
  2 - output([tt.c2], [tt.count(*)]), filter(nil), rowset=4
      access([tt.c2], [tt.count(*)])
  3 - output([st2.c2], [T_FUN_COUNT(*)]), filter(nil), rowset=4
      group([st2.c2]), agg_func([T_FUN_COUNT(*)])
