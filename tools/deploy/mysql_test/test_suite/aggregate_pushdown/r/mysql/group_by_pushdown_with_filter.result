create table t1(pk int, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048;
create table t2(pk int, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048;
create table pt1(pk int, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048 partition by hash(pk) partitions 4;
