create table t1(pk int, c1 int, c2 int);
create table t2(pk int, c1 int, c2 int) partition by hash(pk) partitions 4;
create table t3(pk int, c1 char(10), c2 int default 5);
create table t4(c1 int, c2 int) block_size=2048;
insert into t1 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,null,null);
insert into t2 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,null,null);
insert into t3(pk,c1) values(1,'a'),(2,'b'),(3,'c');
alter system major freeze;
explain select count(*) from t1;
