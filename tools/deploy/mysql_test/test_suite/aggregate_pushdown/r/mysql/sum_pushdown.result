create table t_empty(a int);
select a,sum(a) from t_empty;
a	sum(a)
NULL	NULL
create table t_null1(a int);
insert into t_null1 values(null),(null),(null);
select sum(a) from t_null1;
sum(a)
NULL
create table t_null2(a int);
insert into t_null2 values(null),(1),(2);
select a,sum(a) from t_null2;
a	sum(a)
NULL	3
delete from t_null2 where 1=1;
insert into t_null2 values(1),(null),(2);
select a,sum(a) from t_null2;
a	sum(a)
1	3
create table t_default1(pk int primary key, a int default 10) row_format = compact;
insert into t_default1 values(1,1);
insert into t_default1(pk) values(2),(3);
select sum(pk),sum(a) from t_default1;
sum(pk)	sum(a)
6	21
select sum(pk),sum(a) from t_default1;
sum(pk)	sum(a)
499500	9981
create table t_default2(pk int primary key, a int default 10) row_format = compact;
insert into t_default2 values(1,9);
select sum(pk),sum(a) from t_default2;
sum(pk)	sum(a)
1	9
select sum(pk),sum(a) from t_default2;
sum(pk)	sum(a)
