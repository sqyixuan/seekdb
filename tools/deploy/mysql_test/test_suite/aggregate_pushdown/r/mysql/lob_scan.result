c4
select distinct c4 from t2 where c2 > 10000;
c4
select count(*) from t1 where c2 >= 1234 or c4 like '%3%';
count(*)
8766
select count(*) from t1 where c4 is not null or c4 like '%3%';
count(*)
10000
select count(*) from t1 where c2 >= 1234 or c4 like '%3%' ;
count(*)
