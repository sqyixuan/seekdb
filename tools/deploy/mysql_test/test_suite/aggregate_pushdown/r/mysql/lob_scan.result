drop table if exists t1;
drop table if exists t2;
set session ob_trx_timeout=100000000000;
create table t1 (c1 int NOT NULL,
c2 int NOT NULL SKIP_INDEX(MIN_MAX),
c3 int NOT NULL SKIP_INDEX(MIN_MAX),
c4 blob NOT NULL SKIP_INDEX(MIN_MAX),
PRIMARY KEY (c1)) ROW_FORMAT=redundant BLOCK_SIZE = 4096 COMPRESSION = 'none';
create table t2 (c1 int NOT NULL,
c2 int NOT NULL SKIP_INDEX(MIN_MAX),
c3 int NOT NULL SKIP_INDEX(MIN_MAX),
c4 blob NOT NULL SKIP_INDEX(MIN_MAX),
PRIMARY KEY (c1)) ROW_FORMAT=redundant BLOCK_SIZE = 4096 COMPRESSION = 'none';
alter system major freeze;
select min(c4), max(c4) from t1 where c2 > 1000;
min(c4)	max(c4)
	
select min(c4), max(c4) from t2 where c2 > 1000;
min(c4)	max(c4)
	
select c4, sum(c1), sum(c2) from t1 group by c4 order by 1 asc;
c4	sum(c1)	sum(c2)
	49936816	49936816
	58184	58184
select c4, sum(c1), sum(c2) from t2 group by c4 order by 1 asc;
c4	sum(c1)	sum(c2)
	49995000	49995000
select distinct c4 from t1 where c2 > 10000;
c4
select distinct c4 from t2 where c2 > 10000;
c4
select count(*) from t1 where c2 >= 1234 or c4 like '%3%';
count(*)
8766
select count(*) from t1 where c4 is not null or c4 like '%3%';
count(*)
10000
select count(*) from t1 where c2 >= 1234 or c4 like '%3%' ;
count(*)
8766
select count(*) from t1 where c4 is not null or c4 like '%3%' ;
count(*)
10000
select count(*) from t1 where c4 like '%2%' order by c1;
count(*)
9985
select count(*) from t2 where c4 like '%2%' order by c1;
count(*)
10000
