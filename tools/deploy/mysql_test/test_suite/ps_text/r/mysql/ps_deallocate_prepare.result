result_format: 4

alter system flush ps cache global;

drop database if exists luofan_db;
create database luofan_db;
use luofan_db;

create table t1(c1 int);
insert into t1 values (1);
prepare stmt1 from 'select * from t1';
execute stmt1;
+------+
| c1   |
+------+
|    1 |
+------+
//expect stmt_info_ref_count = 3;
select ps_sql, stmt_info_ref_count from oceanbase.gv$ob_ps_item_info where ps_sql = "select * from t1";
+------------------+---------------------+
| ps_sql           | stmt_info_ref_count |
+------------------+---------------------+
| select * from t1 |                   3 |
+------------------+---------------------+
deallocate prepare stmt1;
//expect stmt_info_ref_count = 2;
select ps_sql, stmt_info_ref_count from oceanbase.gv$ob_ps_item_info where ps_sql = "select * from t1";
+------------------+---------------------+
| ps_sql           | stmt_info_ref_count |
+------------------+---------------------+
| select * from t1 |                   2 |
+------------------+---------------------+

drop database if exists luofan_db;
