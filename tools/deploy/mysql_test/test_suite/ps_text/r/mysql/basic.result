result_format: 4
/// 1. basic test
drop table if exists t1;
set @i1 = 1;
set @i2 = 2;
set @i3 = 3;
set @s1 = 'abc';

create table t1(c1 int);
prepare ins_stmt1 from 'insert into t1 values(?)';
prepare ins_stmt2 from 'insert into t1 values(?), (?)';
execute ins_stmt1 using @i1;
execute ins_stmt2 using @i2, @i3;

prepare sel_stmt1 from 'select * from t1';
execute sel_stmt1;
+------+
| c1   |
+------+
|    1 |
|    2 |
|    3 |
+------+
prepare sel_stmt2 from 'select * from t1 where c1 = ?';
execute sel_stmt2 using @i1;
+------+
| c1   |
+------+
|    1 |
+------+
execute sel_stmt2 using @i2;
+------+
| c1   |
+------+
|    2 |
+------+

/// basic test done

/// 2. error test
deallocate prepare ins_stmt1;
// unknown ps handle
execute ins_stmt1 using @i1;
ERROR HY000: Unknown prepared statement handle
// incorrect arguments
execute ins_stmt2 using @i1;
ERROR HY000: Incorrect arguments to execute
// incoorect integer value
execute ins_stmt2 using @i1, @s1;
ERROR HY000: Incorrect integer value for column 'c1' at row 2
/// error test done

/// 3. test all type in mysql mode
drop table if exists t1;
prepare create_stmt from 'create table t1 (c1 int, c2 int unsigned,
                                          c3 tinyint, c4 tinyint unsigned,
                                          c5 smallint, c6 smallint unsigned,
                                          c7 mediumint, c8 mediumint unsigned,
                                          c9 integer, c10 integer unsigned,
                                          c11 bigint, c12 bigint unsigned,
                                          c13 float, c14 float unsigned,
                                          c15 double, c16 double unsigned,
                                          c17 decimal, c18 decimal unsigned,
                                          c19 datetime, c20 timestamp,
                                          c21 year, c22 date, c23 time,
                                          c24 varchar(30), c25 char(30),
                                          c26 varbinary(30), c27 binary(30),
                                          c28 enum("","0","1","2","3","5","6","7","8","9"),
                                          c29 set("","0","1","2","3","5","6","7","8","9")
                                          )';
execute create_stmt;
desc t1;
+-------+----------------------------------------------+------+-----+---------+-------+
| Field | Type                                         | Null | Key | Default | Extra |
+-------+----------------------------------------------+------+-----+---------+-------+
| c1    | int(11)                                      | YES  |     | NULL    |       |
| c2    | int(10) unsigned                             | YES  |     | NULL    |       |
| c3    | tinyint(4)                                   | YES  |     | NULL    |       |
| c4    | tinyint(3) unsigned                          | YES  |     | NULL    |       |
| c5    | smallint(6)                                  | YES  |     | NULL    |       |
| c6    | smallint(5) unsigned                         | YES  |     | NULL    |       |
| c7    | mediumint(9)                                 | YES  |     | NULL    |       |
| c8    | mediumint(8) unsigned                        | YES  |     | NULL    |       |
| c9    | int(11)                                      | YES  |     | NULL    |       |
| c10   | int(10) unsigned                             | YES  |     | NULL    |       |
| c11   | bigint(20)                                   | YES  |     | NULL    |       |
| c12   | bigint(20) unsigned                          | YES  |     | NULL    |       |
| c13   | float                                        | YES  |     | NULL    |       |
| c14   | float unsigned                               | YES  |     | NULL    |       |
| c15   | double                                       | YES  |     | NULL    |       |
| c16   | double unsigned                              | YES  |     | NULL    |       |
| c17   | decimal(10,0)                                | YES  |     | NULL    |       |
| c18   | decimal(10,0) unsigned                       | YES  |     | NULL    |       |
| c19   | datetime                                     | YES  |     | NULL    |       |
| c20   | timestamp                                    | YES  |     | NULL    |       |
| c21   | year(4)                                      | YES  |     | NULL    |       |
| c22   | date                                         | YES  |     | NULL    |       |
| c23   | time                                         | YES  |     | NULL    |       |
| c24   | varchar(30)                                  | YES  |     | NULL    |       |
| c25   | char(30)                                     | YES  |     | NULL    |       |
| c26   | varbinary(30)                                | YES  |     | NULL    |       |
| c27   | binary(30)                                   | YES  |     | NULL    |       |
| c28   | enum('','0','1','2','3','5','6','7','8','9') | YES  |     | NULL    |       |
| c29   | set('','0','1','2','3','5','6','7','8','9')  | YES  |     | NULL    |       |
+-------+----------------------------------------------+------+-----+---------+-------+

prepare ins_stmt from 'insert into t1 values(1, 2,
    1, 2,
    1, 2,
    1, 2,
    1, 2,
    1, 2,
    3.1, 4.1,
    5.1, 6.1,
    7.1, 8.1,
    "2019-12-01 12:00:00", "2019-12-13 06:00:00",
    2020,"2020-01-01","12:34:56",
    "9.1", "10.1",
    "9.1", "10.1",
    2, 2)';
execute ins_stmt;
Warnings:
Warning	1265	Data truncated for column 'c17' at row 1
Warning	1265	Data truncated for column '"test"."t1"."c18"' at row 1
select * from t1;
+------+------+------+------+------+------+------+------+------+------+------+------+------+------+------+------+------+------+---------------------+---------------------+------+------------+----------+------+------+------+--------------------------------+------+------+
| c1   | c2   | c3   | c4   | c5   | c6   | c7   | c8   | c9   | c10  | c11  | c12  | c13  | c14  | c15  | c16  | c17  | c18  | c19                 | c20                 | c21  | c22        | c23      | c24  | c25  | c26  | c27                            | c28  | c29  |
