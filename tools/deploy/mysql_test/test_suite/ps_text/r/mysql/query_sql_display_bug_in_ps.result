drop table if exists t1;
create table t1(c1 int, c2 int, c3 int);
insert into t1(c1,c2,c3) values(1, 2, 3), (4, 5, 6),(7, 8, 9);
alter system flush sql audit;
prepare s1 from 'select c1 from t1 where c1 > ? and c2 = 2';
set @a=0;
execute s1 using @a;
c1
1
