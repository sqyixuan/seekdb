--result_format 4

# --echo
--disable_warnings
drop database if exists luofan_db;
--enable_warnings
create database luofan_db;
use luofan_db;

set @i1 = 1;
create table t1(c1 int);
prepare INS_sTmt1 from 'insert into t1 values(?)';
execute ins_stmt1 using @i1;
execute Ins_Stmt1 using @i1;
execute INS_sTmt1 using @i1;
select c1 from t1;

