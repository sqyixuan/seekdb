# owner: luofan.zp
# owner group: SQL2
# description: 测试单个session上ps handle打开的最大个数限制

--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_metadata
--disable_abort_on_error

connection conn_admin;
alter system flush ps cache global;
--sleep 3
connection default;
--echo
--echo #设置单个session上ps handle打开的最大个数限制为50
alter system set open_cursors = 50;

let $cnt=50;
let $i=1;
while ($i <= $cnt)
{
  eval prepare stmt$i from 'select $i from dual';
  inc $i;
}

--error 5930
eval prepare stmt$i from 'select $i from dual';

connection conn_admin;
alter system flush ps cache global;
--sleep 3
connection default;
--echo
--echo #设置单个session上ps handle打开的最大个数无限制
alter system set open_cursors = 0;

let $cnt=100;
let $i=1;
while ($i <= $cnt)
{
  eval prepare stmt$i from 'select $i from dual';
  inc $i;
}

alter system set open_cursors = 50;
connection conn_admin;
alter system flush ps cache global;
--sleep 3
