# owner: luofan.zp
# owner group: SQL2
# description: ps 文本模式测试

--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

alter system flush ps cache global;
--sleep 3
connection default;

--disable_warnings
drop database if exists luofan_db;
--enable_warnings
create database luofan_db;
use luofan_db;

create table t1(c1 int);
insert into t1 values (1);
prepare stmt1 from 'select * from t1';
execute stmt1;
--echo //expect stmt_info_ref_count = 3;
select ps_sql, stmt_info_ref_count from oceanbase.gv$ob_ps_item_info where ps_sql = "select * from t1";
deallocate prepare stmt1;
--echo //expect stmt_info_ref_count = 2;
select ps_sql, stmt_info_ref_count from oceanbase.gv$ob_ps_item_info where ps_sql = "select * from t1";

--disable_warnings
drop database if exists luofan_db;
--enable_warnings
