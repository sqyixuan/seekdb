################################################# bug:48269702 ####################################

--disable_warnings
drop table if exists t_ps_escape;
--enable_warnings

create table t_ps_escape(a varchar(10));
insert into t_ps_escape values("abcd"); 

prepare stmt1 from 'select * from t_ps_escape where a like \'a?%\' escape ?';
--error 0,1210
execute stmt1;

prepare stmt2 from 'select * from t_ps_escape where a like \'a?%\' escape \'?\'';
execute stmt2;

prepare stmt3 from 'select * from t_ps_escape where a like \'a%\'';
execute stmt3;

--disable_warnings
drop table if exists t_ps_escape;
--enable_warnings

--error 0,1305
drop procedure p_string;
delimiter //;
CREATE PROCEDURE p_string(
  IN v0 INT,
  OUT v1 CHAR(32),
  IN v2 CHAR(32),
  INOUT v3 CHAR(32))
BEGIN
  SET v0 = -1;
  SET v1 = 'test_v1';
  SET v2 = 'n/a';
  SET v3 = 'test_v3';
END//

delimiter ;//
PREPARE stmt_str FROM 'CALL p_string(?, ?, ?, ?)';

SET @x_str_1 = NULL;
SET @x_str_2 = NULL;
SET @x_str_3 = NULL;
SET @x_int_1 = NULL;
EXECUTE stmt_str USING @x_int_1, @x_str_1, @x_str_2, @x_str_3;
SELECT @x_int_1, @x_str_1, @x_str_2, @x_str_3;

--error 0,1305
drop procedure p_string;

