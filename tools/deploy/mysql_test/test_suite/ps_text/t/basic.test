# owner: luofan.zp
# owner group: SQL2
# description: ps 文本模式基本测试

--result_format 4

--echo /// 1. basic test
--disable_warnings
drop table if exists t1;
--enable_warnings

set @i1 = 1;
set @i2 = 2;
set @i3 = 3;
set @s1 = 'abc';

create table t1(c1 int);
prepare ins_stmt1 from 'insert into t1 values(?)';
prepare ins_stmt2 from 'insert into t1 values(?), (?)';
execute ins_stmt1 using @i1;
execute ins_stmt2 using @i2, @i3;

prepare sel_stmt1 from 'select * from t1';
execute sel_stmt1;
prepare sel_stmt2 from 'select * from t1 where c1 = ?';
execute sel_stmt2 using @i1;
execute sel_stmt2 using @i2;

--echo /// basic test done

--echo
--echo /// 2. error test
deallocate prepare ins_stmt1;
--echo // unknown ps handle
--error 1243
execute ins_stmt1 using @i1;
--echo // incorrect arguments
--error 1210
execute ins_stmt2 using @i1;
--echo // incoorect integer value
--error 1366
execute ins_stmt2 using @i1, @s1;
--echo /// error test done

--echo
--echo /// 3. test all type in mysql mode
--disable_warnings
drop table if exists t1;
--enable_warnings
prepare create_stmt from 'create table t1 (c1 int, c2 int unsigned,
                                          c3 tinyint, c4 tinyint unsigned,
                                          c5 smallint, c6 smallint unsigned,
                                          c7 mediumint, c8 mediumint unsigned,
                                          c9 integer, c10 integer unsigned,
                                          c11 bigint, c12 bigint unsigned,
                                          c13 float, c14 float unsigned,
                                          c15 double, c16 double unsigned,
                                          c17 decimal, c18 decimal unsigned,
                                          c19 datetime, c20 timestamp,
                                          c21 year, c22 date, c23 time,
                                          c24 varchar(30), c25 char(30),
                                          c26 varbinary(30), c27 binary(30),
                                          c28 enum("","0","1","2","3","5","6","7","8","9"),
                                          c29 set("","0","1","2","3","5","6","7","8","9")
                                          )';
execute create_stmt;
desc t1;

prepare ins_stmt from 'insert into t1 values(1, 2,
    1, 2,
    1, 2,
    1, 2,
    1, 2,
    1, 2,
    3.1, 4.1,
    5.1, 6.1,
    7.1, 8.1,
    "2019-12-01 12:00:00", "2019-12-13 06:00:00",
    2020,"2020-01-01","12:34:56",
    "9.1", "10.1",
    "9.1", "10.1",
    2, 2)';
execute ins_stmt;
select * from t1;

set @i1 = 1;
set @i_date = 2012;
set @f1 = 1.1;
set @s1 = '9.1';
set @s_datetime = '2019-12-01 12:00:00';
set @s_date = '2019-12-01';
set @s_time = '11:11:11';
prepare ins_stmt1 from 'insert into t1 values(?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)';
execute ins_stmt1 using @i1, @i1, @i1, @i1, @i1, @i1, @i1, @i1, @i1, @i1, @i1, @i1, @f1, @f1, @f1, @f1, @f1, @f1, @s_datetime, @s_datetime, @i_date, @s_date, @s_time, @s1, @s1, @s1, @s1, @i1, @i1;
select * from t1;
--echo /// test all type in mysql mode done

--echo
--echo /// 4. check plan cache hit count
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system flush plan cache global;
sleep 2;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int);
prepare stmt from 'insert into t1 values(1)';
execute stmt;
execute stmt;
--echo // expect 1
select hit_count, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'insert into t1 values(?)';

set @i1 = 1;
prepare stmt from 'insert into t1 values(?)';
execute stmt using @i1;
execute stmt using @i1;
--echo // expect 1
select hit_count, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'insert into t1 values(?)';

prepare stmt from 'select * from t1 where c1 = ?';
execute stmt using @i1;
execute stmt using @i1;
--echo // expect 1
select hit_count, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where c1 = ?';
--echo /// check plan cache hit count done


--echo
--echo /// 5. test can't not prepare multi stmt
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int);
--error 1235
prepare stmt from 'insert into t1 values(1); insert into t1 values(1);';
drop table if exists t1;

--echo
--echo /// [bugfix]
prepare st2 from 'select 6';
--error 1235
PREPARE st2 FROM 'create table tt4(id int);drop table tt4';
--error 1243
execute st2;
--error 1243
deallocate prepare st2;

--echo
--echo /// [bugfix]
prepare st1 from 'SELECT LEFT(?, ?)';
set @i1='testtesttest';
set @i2=8;
execute st1 using @i1, @i2;

--echo
--echo /// [bugfix]
prepare st1 from "SELECT JSON_OBJECT(?, ?, ?, ?)";
set @i1='id';
set @i2=69;
set @i3='name';
set @i4='apple';
execute st1 using @i1, @i2, @i3, @i4;

--echo
--echo /// [bugfix]
--echo /// 支持order by ?
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int, c2 int, c3 int);
insert into t1 values (3, 1, 2);
insert into t1 values (1, 2, 3);
insert into t1 values (2, 3, 1);
prepare stmt from 'select * from t1 order by ?';
set @i1 = 1;
execute stmt using @i1;
set @i1 = 2;
execute stmt using @i1;
set @i1 = 3;
execute stmt using @i1;
set @i1 = 'testtesttest';
execute stmt using @i1;


--echo
--echo /// group by ?
--echo ///
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int, c2 int);
insert into t1 values (1, 2);
insert into t1 values (2, 1);
insert into t1 values (2, 3);
insert into t1 values (3, 2);
set sql_mode = ONLY_FULL_GROUP_BY;
prepare stmt from 'select c1 from t1 group by ?';
set @i1 = 1;
--error 1055
execute stmt using @i1;
set sql_mode = default;
prepare stmt from 'select c1 from t1 group by ?';
set @i1 = 1;
execute stmt using @i1;


--disable_warnings
drop table if exists t1;
--enable_warnings
