--error 5160
alter system major freeze tenant = sys, xxx;
--error 5160
alter system major freeze tenant = all_user, xxx;
--error 5160
alter system major freeze tenant = all_meta, xxx;

## major freeze tenant not existing
--error 1064
alter system major freeze tenant;
--error 5160
alter system major freeze tenant = xxx;
#--error 5160
#alter system major freeze tenant = xxx, mysql;

## capital tenant name
--error 5160
alter system major freeze tenant = mySQL;
--error 5160
alter system major freeze tenant = 'mysQl';
--error 5160
alter system major freeze tenant = "Mysql";
--error 5160
alter system major freeze tenant = sys, "mySQL";
--error 5160
alter system major freeze tenant = 'sys', "mySQL";

## invalid argument
## syntax error
--error 1064
alter system major freeze tenants = sys;
--error 1064
alter system major freeze tenants = all_user;
--error 1064
alter system major freeze tenants = all_meta;

--error 1210
alter system major freeze tenant = '';

## invalid tenant name
--error 5160
alter system major freeze tenant = xxx;

