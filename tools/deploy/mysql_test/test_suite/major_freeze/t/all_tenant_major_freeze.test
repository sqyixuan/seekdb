alter system major freeze;

connection default;
#--error 1227
#alter system major freeze tenant = mysql;
alter system major freeze;
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

############ test frozen_scn error #############
connection sys_conn;
let $ori_max_frozen_scn = query_get_value(select max(frozen_scn) as value from oceanbase.__all_freeze_info, value, 1);
# decrease the maximum frozen_scn by one, and expect one new major freeze to encounter an error
--disable_query_log
eval update __all_freeze_info set frozen_scn = ($ori_max_frozen_scn - 1) where frozen_scn = $ori_max_frozen_scn;
--enable_query_log
--error 4016
alter system major freeze;
# resume frozen_scn, expect one successful new major freeze
--disable_query_log
eval update __all_freeze_info set frozen_scn = $ori_max_frozen_scn where frozen_scn = ($ori_max_frozen_scn - 1);
--enable_query_log
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

connection sys_conn;
let $ori_max_frozen_scn = query_get_value(select max(frozen_scn) as value from oceanbase.__all_freeze_info, value, 1);
# increase the maximum frozen_scn by one. one new major freeze will find larger frozen_scn already
# exist, and complete major freeze with this larger frozen_scn
--disable_query_log
eval update __all_freeze_info set frozen_scn = ($ori_max_frozen_scn + 1) where frozen_scn = $ori_max_frozen_scn;
--enable_query_log
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc
