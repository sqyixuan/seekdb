############ test enable_major_freeze #############
connection sys_conn;
alter system set enable_major_freeze = false;
let $enable_major_freeze_value = 'False';
--source mysql_test/include/wait_set_enable_major_freeze.inc
--error 4217
alter system major freeze tenant = sys;
#--error 4217
alter system major freeze tenant = all_user;
#--error 4217
alter system major freeze tenant = all_meta;
#--error 4217
#alter system major freeze tenant = sys;

alter system set enable_major_freeze = true;
let $enable_major_freeze_value = 'True';
--source mysql_test/include/wait_set_enable_major_freeze.inc
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
