#owner: binifei.bnf 
#owner group: rootserver
#tags: checksum error

connect (sys_conn,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection sys_conn;
alter system set enable_major_freeze = true;
# Note: there may be unfinished major_merge, which are launched according to major_freeze_duty_time.
# Therefore, we need to disable daily_merge and wait the launched major_merge to finish here.
alter system set major_freeze_duty_time = 'Disable' tenant sys;
alter system set major_freeze_duty_time = 'Disable' tenant all_user;
alter system set major_freeze_duty_time = 'Disable' tenant all_meta;
--source mysql_test/include/wait_daily_merge.inc
connection sys_conn;
# non-partitioned_table
--disable_warnings
drop table if exists test;
drop table if exists save_column_checksum;
--enable_warnings
create table test(c1 int primary key, c2 int);
create index test_idx_c2 on test(c2);
create table save_column_checksum(tablet_id bigint primary key, ori_b_column_checksums varbinary(65535));
insert into test values(0, 2);
insert into test values(1, 2);
insert into test values(2, 2);

let $sys_tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'sys', tenant_id, 1);
let $zone_num = query_get_value(select count(*) as value from __all_zone_merge_info where tenant_id = $sys_tenant_id, value, 1);

# launch one major freeze for generating checksums into __all_tablet_replica_checksum
connection sys_conn;
alter system major freeze tenant = sys;
--source mysql_test/include/wait_daily_merge.inc

connection sys_conn;
let $idx_tablet_id = query_get_value(select tablet_id from __all_table where table_name like "%test_idx_c2%", tablet_id, 1);
let $b_column_checksums_last_modified_time = query_get_value(select gmt_modified from __all_tablet_replica_checksum 
                                                where tenant_id = $sys_tenant_id and tablet_id = $idx_tablet_id, gmt_modified, 1);
let $ori_epoch = query_get_value(select value from __all_service_epoch where tenant_id = $sys_tenant_id and name = 'freeze_service_epoch', value, 1);
--disable_query_log
eval insert into save_column_checksum select tablet_id, b_column_checksums from __all_tablet_replica_checksum where tenant_id = $sys_tenant_id and tablet_id = $idx_tablet_id limit 1;
--enable_query_log
alter system major freeze tenant = sys;
# modify epoch after finishing updating broadcast_scn in __all_zone_merge_info
let $start_time = query_get_value(select now() as value, value, 1);
let $generated_frozen_scn = query_get_value(select max(frozen_scn) as value from __all_freeze_info, value, 1);
let $__k__ = 100;
while ($__k__ > 0)
{
    let $interval_second = query_get_value("select timestampdiff(second, '$start_time', now()) as value;", value, 1);
    if ($interval_second <= 600){
        let $broadcasted_zone_num = query_get_value(select count(*) as value from __all_zone_merge_info 
                                        where tenant_id = $sys_tenant_id and broadcast_scn = $generated_frozen_scn, value, 1);
        if ($broadcasted_zone_num == $zone_num)
        {
            --disable_query_log
            eval update __all_service_epoch set value = -5 where tenant_id = $sys_tenant_id and name = 'freeze_service_epoch';
            --enable_query_log
            let $__k__ = -5;
        }
    }
    if ($interval_second > 600)
    {
        --echo timeout: __all_zone_merge_info not updated by rs
        let $__k__ = -3;
    }
}
# once the storage engine updates checksums during major freeze, modify b_column_checksums and then resume epoch
let $__i__ = 100;
if ($__k__ == -5)
{
    let $start_time = query_get_value(select now() as value, value, 1);
    while ($__i__ > 0)
    {
        let $interval_second = query_get_value("select timestampdiff(second, '$start_time', now()) as value;", value, 1);
        if ($interval_second <= 600)
        {
            let $b_column_checksums_new_modified_time = query_get_value(select gmt_modified from __all_tablet_replica_checksum 
                                                        where tenant_id = $sys_tenant_id and tablet_id = $idx_tablet_id, gmt_modified, 1);
            if ($b_column_checksums_new_modified_time != $b_column_checksums_last_modified_time)
            {
                --disable_query_log
                eval update __all_tablet_replica_checksum set b_column_checksums = (select b_column_checksums from __all_tablet_replica_checksum where tenant_id = $sys_tenant_id and tablet_id = 1 limit 1) where tenant_id = $sys_tenant_id and tablet_id = $idx_tablet_id;
                eval update __all_service_epoch set value = $ori_epoch where tenant_id = $sys_tenant_id and name = 'freeze_service_epoch';
                --enable_query_log
                let $__i__ = -5;
            }
        }
        if ($interval_second > 600)
        {
            --echo timeout: __all_tablet_replica_checksum not updated by the storage engine
            let $__i__ = -3;
        }
    }
}
# expect CHECKSUM_ERROR
let $__j__ = 600;
if ($__i__ == -5)
{
    while ($__j__ > 0)
    {
        sleep 1;
        dec $__j__;
        let $sys_is_error = query_get_value(select is_error from CDB_OB_MAJOR_COMPACTION where tenant_id = $sys_tenant_id, is_error, 1);
        let $sys_info = query_get_value(select info from CDB_OB_MAJOR_COMPACTION where tenant_id = $sys_tenant_id, info, 1);
        if ($sys_is_error == "YES")
        {
            if ($sys_info == "CHECKSUM_ERROR")
            {
                --echo succeed to detect checksum_error by index_checksum_validator
                let $__j__ = -5;
            }
        }
    }
}

############################################################
# in the case of checksum_error, expect new major freezes to be forbidden
let $__ret_forbidden__ = 100;
if ($__j__ == -5)
{
    let $ori_max_frozen_scn = query_get_value(select max(frozen_scn) as max_frozen_scn from oceanbase.__all_freeze_info, max_frozen_scn, 1);
    alter system major freeze tenant = sys;
    let $new_max_frozen_scn = query_get_value(select max(frozen_scn) as max_frozen_scn from oceanbase.__all_freeze_info, max_frozen_scn, 1);
    # check whether generating new frozen_scn
    if ($ori_max_frozen_scn == $new_max_frozen_scn)
    {
        let $__ret_forbidden__ = -5;
        --echo succeed to forbid launching one new major freeze
    }
    if ($ori_max_frozen_scn != $new_max_frozen_scn)
    {
        --echo fail to forbid launching one new major freeze
    }
    alter system major freeze tenant = sys;
    alter system major freeze tenant = all_user;
    alter system major freeze tenant = all_meta;
}

############################################################
# resume b_column_checksums and clear merge error, expect one new major freeze to be successful
if ($__ret_forbidden__ == -5)
{
    --disable_query_log
    eval update __all_tablet_replica_checksum set b_column_checksums = (select /*+ QUERY_TIMEOUT(100000000) */ ori_b_column_checksums from save_column_checksum where tablet_id = $idx_tablet_id) where tenant_id = $sys_tenant_id and tablet_id = $idx_tablet_id;
    alter system clear merge error;
    --enable_query_log
    # wait until finishing the last major freeze with merge error
    --source mysql_test/include/wait_daily_merge.inc
    connection sys_conn;
    alter system major freeze tenant = sys;
    --source mysql_test/include/wait_daily_merge.inc
}
