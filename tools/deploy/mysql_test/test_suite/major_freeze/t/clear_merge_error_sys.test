# only clear merge error of sys tenant
alter system clear merge error;
let $sys_is_error = query_get_value(select is_error from CDB_OB_MAJOR_COMPACTION, is_error, 1);
let $sys_info = query_get_value(select info from CDB_OB_MAJOR_COMPACTION, info, 1);
if ($sys_is_error != "NO")
{
    --echo clear merge error failed
}
if ($sys_info == "CHECKSUM_ERROR")
{
    --echo clear merge error failed
}
