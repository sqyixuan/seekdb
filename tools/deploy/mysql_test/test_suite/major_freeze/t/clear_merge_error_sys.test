# clear merge error for sys
# when observer restart, __all_service_epoch exists one old valid freeze_service_epoch. the
# new freeze_service_epoch may has not been updated. in this case, freeze_service_epoch in memory
# is equal to -1. give some time for ObMajorMergeScheduler to update the new freeze_service_epoch.
sleep 20;
alter system clear merge error tenant = sys;

# check clear_merge_error is valid
let $sys_is_error = query_get_value(select is_error from CDB_OB_MAJOR_COMPACTION, is_error, 1);
let $sys_info = query_get_value(select info from CDB_OB_MAJOR_COMPACTION, info, 1);
if ($sys_is_error != "NO")
{
    --echo clear merge error failed
}
if ($sys_info == "CHECKSUM_ERROR")
{
    --echo clear merge error failed
}

# re-check again
--disable_query_log
#eval update __all_merge_info set is_merge_error = 1, error_type = 1 where tenant_id = $sys_tenant_id;
--enable_query_log
#let $sys_is_error = query_get_value(select is_error from CDB_OB_MAJOR_COMPACTION where tenant_id = $sys_tenant_id, is_error, 1);
#let $sys_info = query_get_value(select info from CDB_OB_MAJOR_COMPACTION where tenant_id = $sys_tenant_id, info, 1);
