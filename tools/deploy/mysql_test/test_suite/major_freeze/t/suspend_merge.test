# owner: chaser.ch
# owner group: STORAGE2
# description:
#
--disable_query_log
--disable_warnings
drop table if exists test_suspend;
--enable_warnings
--enable_query_log

create table test_suspend(a int, b varchar(100));
insert into test_suspend values(1, 'aaaaa');
insert into test_suspend values(2, 'bbbbb');
insert into test_suspend values(3, 'ccccc');
insert into test_suspend values(4, 'ddddd');


connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection obsys1;
let $table_id= query_get_value(select table_id from __all_virtual_table where table_name='test_suspend', table_id, 1);
let $__table_id__= query_get_value(select table_id from __all_virtual_table where table_name='test_suspend', table_id, 1);

alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
--source mysql_test/include/wait_daily_merge.inc

--echo first major freeze

alter system suspend merge;
--real_sleep 1

connection default;
insert into test_suspend select * from test_suspend;

--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
--real_sleep 5

connection obsys1;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
--real_sleep 3

connection default;
let $sus = query_get_value(select suspend_merging from oceanbase.__all_virtual_merge_info, suspend_merging, 1);
--echo try major freeze, suspend merge: $sus

alter system resume merge;
--source mysql_test/include/wait_daily_merge.inc
--echo second major freeze

drop table test_suspend;
