#owner: donglou.zl 
#owner group: rootserver
#tags: suspend resume major merge

connect (sys_conn,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connect (mysql_conn,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection sys_conn;
alter system set enable_major_freeze = true;
# Note: there may be unfinished major_merge, which are launched according to major_freeze_duty_time.
# Therefore, we need to disable daily_merge and wait the launched major_merge to finish here.
alter system set major_freeze_duty_time = 'Disable' tenant sys;
alter system set major_freeze_duty_time = 'Disable' tenant sys;
alter system set major_freeze_duty_time = 'Disable' tenant sys;
--source mysql_test/include/wait_daily_merge.inc
connection sys_conn;
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(c1 int primary key, c2 int);
insert into test values(0, 2);
insert into test values(1, 2);
insert into test values(2, 2);

let $sys_tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'sys', tenant_id, 1);
let $mysql_tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'sys', tenant_id, 1);
let $ori_sys_frozen_scn = query_get_value(select frozen_scn from __all_zone_merge_info where tenant_id = $sys_tenant_id, frozen_scn, 1);
let $ori_mysql_frozen_scn = query_get_value(select frozen_scn from __all_zone_merge_info where tenant_id = $mysql_tenant_id, frozen_scn, 1);

############################################################
connection sys_conn;
alter system major freeze tenant = sys;
let $cur_sys_frozen_scn = query_get_value(select frozen_scn from __all_virtual_freeze_info where tenant_id = $sys_tenant_id order by frozen_scn desc limit 1, frozen_scn, 1);
let $cur_mysql_frozen_scn = query_get_value(select frozen_scn from __all_virtual_freeze_info where tenant_id = $mysql_tenant_id order by frozen_scn desc limit 1, frozen_scn, 1);
if ($cur_sys_frozen_scn == $ori_sys_frozen_scn)
{
    --echo sys tenant, alter system major freeze failed
}
if ($cur_mysql_frozen_scn == $ori_mysql_frozen_scn)
{
    --echo mysql tenant, alter system major freeze failed
}

alter system suspend merge tenant = sys;
let $cur_sys_is_suspend = query_get_value(select is_suspended from CDB_OB_MAJOR_COMPACTION where tenant_id = $sys_tenant_id, is_suspended, 1);
let $cur_mysql_is_suspend = query_get_value(select is_suspended from CDB_OB_MAJOR_COMPACTION where tenant_id = $mysql_tenant_id, is_suspended, 1);
if ($cur_sys_is_suspend != "YES")
{
    --echo sys tenant, alter system suspend merge failed
}
if ($cur_mysql_is_suspend != "YES")
{
    --echo mysql tenant, alter system suspend merge failed
}

alter system resume merge tenant = sys;
let $cur_sys_is_suspend = query_get_value(select is_suspended from CDB_OB_MAJOR_COMPACTION where tenant_id = $sys_tenant_id, is_suspended, 1);
let $cur_mysql_is_suspend = query_get_value(select is_suspended from CDB_OB_MAJOR_COMPACTION where tenant_id = $mysql_tenant_id, is_suspended, 1);
if ($cur_sys_is_suspend != "NO")
{
    --echo sys tenant, alter system resume merge failed
}
if ($cur_mysql_is_suspend != "NO")
{
    --echo mysql tenant, alter system resume merge failed
}
--source mysql_test/include/wait_daily_merge.inc

############################################################
# test suspend and resume merge in sys tenant 
# suspend merge on specified tenant
connection sys_conn;
alter system suspend merge tenant = 'sys';
let $sus = query_get_value(select suspend_merging from oceanbase.__all_virtual_merge_info where tenant_id = $sys_tenant_id, suspend_merging, 1);
--echo sys suspend merge: $sus
alter system suspend merge tenant = 'sys';
let $sus = query_get_value(select suspend_merging from oceanbase.__all_virtual_merge_info where tenant_id = $mysql_tenant_id, suspend_merging, 1);
--echo mysql suspend merge: $sus

# resume merge on specified tenant
alter system resume merge tenant = 'sys';
let $sus = query_get_value(select suspend_merging from oceanbase.__all_virtual_merge_info where tenant_id = $sys_tenant_id, suspend_merging, 1);
--echo sys suspend merge: $sus
alter system resume merge tenant = 'sys';
let $sus = query_get_value(select suspend_merging from oceanbase.__all_virtual_merge_info where tenant_id = $mysql_tenant_id, suspend_merging, 1);
--echo mysql suspend merge: $sus

alter system suspend merge tenant = 'sys';
alter system suspend merge tenant = 'sys';
alter system suspend merge tenant = 'sys';
let $sus = query_get_value(select suspend_merging from oceanbase.__all_virtual_merge_info where tenant_id = $sys_tenant_id, suspend_merging, 1);
--echo sys suspend merge: $sus
let $sus = query_get_value(select suspend_merging from oceanbase.__all_virtual_merge_info where tenant_id = $mysql_tenant_id, suspend_merging, 1);
--echo mysql suspend merge: $sus
alter system resume merge tenant = 'sys';
alter system resume merge tenant = 'sys';
alter system resume merge tenant = 'sys';
let $sus = query_get_value(select suspend_merging from oceanbase.__all_virtual_merge_info where tenant_id = $sys_tenant_id, suspend_merging, 1);
--echo sys suspend merge: $sus
let $sus = query_get_value(select suspend_merging from oceanbase.__all_virtual_merge_info where tenant_id = $mysql_tenant_id, suspend_merging, 1);
--echo mysql suspend merge: $sus

# suspend merge on invalid tenant
--error 1064
alter system suspend merge tenant;
--error 5160
alter system suspend merge tenant = 'xxx';
--error 5160
alter system suspend merge tenant = 'xxx', 'mysql';

# invalid argument
--error 1210
alter system suspend merge tenant = '';

# syntax error
--error 1064
alter system suspend merge tenants = 'sys';
--error 1064
alter system suspend merge tenants = 'all_user';
--error 1064
alter system suspend merge tenants = 'all_meta';

# resume merge on invalid tenant
--error 1064
alter system resume merge tenant;
--error 5160
alter system resume merge tenant = 'xxx';
--error 5160
alter system resume merge tenant = 'xxx', 'mysql';

# invalid argument
--error 1210
alter system resume merge tenant = '';

# syntax error
--error 1064
alter system resume merge tenants = 'sys';
--error 1064
alter system resume merge tenants = 'all_user';
--error 1064
alter system resume merge tenants = 'all_meta';

