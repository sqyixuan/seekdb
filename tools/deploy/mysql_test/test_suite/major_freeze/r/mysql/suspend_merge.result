create table test_suspend(a int, b varchar(100));
insert into test_suspend values(1, 'aaaaa');
insert into test_suspend values(2, 'bbbbb');
insert into test_suspend values(3, 'ccccc');
insert into test_suspend values(4, 'ddddd');
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
first major freeze
alter system suspend merge;
insert into test_suspend select * from test_suspend;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
try major freeze, suspend merge: 1
alter system resume merge;
second major freeze
drop table test_suspend;
