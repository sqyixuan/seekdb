drop table hz;
create table hz(f1 int(10));
INSERT INTO hz(f1) VALUES(ln(15));
SELECT * FROM hz;
INSERT INTO hz(f1) VALUES(ln(100));
SELECT * FROM hz;
UPDATE hz SET f1 = ln(100)+1 WHERE f1 = ln(100);
SELECT * FROM hz;
UPDATE hz SET f1 = ln(15) WHERE f1 = ln(15)+1;
