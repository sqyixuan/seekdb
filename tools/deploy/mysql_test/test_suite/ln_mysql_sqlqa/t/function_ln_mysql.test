--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);

--echo       #ln-6   静态sql
--echo       #ln-7   常用函数嵌套 
--echo       #ln-8   视图
--echo       #ln-9   索引
--echo       #ln-10  约束


--echo   #ln-6  静态sql
--echo   #LN-6-1     insert单列/多列 
--echo   # LN-6-1-1      VALUE
--error 0,1051
drop table a;
create table a(id int(2),name varchar(20));
insert into a (id,name)value (1,"zhangsan");
insert into a (id,name)value (2,"lisi");
select * from a; 
SELECT (SELECT ln(6))from a;
insert into a (id)value (ln(4));
select * from a;
insert into a (id,name)value (ln(6),"xiaobai");
select * from a;
--error 0,1064
insert into a (id,name)value (3,ln('xiaocai');
--error 0,1265
insert into a (id,name)value (ln('88'),ln('jiugui'));
--error 0,1265
insert into a (id,name)value((ln(4)),(ln('xiaocao')));
--error 0,1064
insert into a (id,name)value(select * from a where id=ln(4),(ln('xiaocao')));
drop table a;

--echo   #LN-6-1-2   insert into
--error 0,1051
drop table a;
create table a(id int(2),name varchar(20));
insert into a (id,name)value (1,"zhangsan");
insert into a (id,name)value (2,"lisi");
SELECT * from a;
DELETE FROM a WHERE 1=1;
SELECT * from a;
INSERT INTO a VALUE(0.6931471,1.94591123);
SELECT * from a;
INSERT INTO a(id) VALUE(6.9314718);
SELECT * from a;
INSERT INTO a(id) SELECT id FROM a WHERE id<>1 GROUP BY id,name HAVING ln(id) IS NOT NULL;
SELECT * FROM a;
drop table a;

--echo   #LN-6-2        update
--echo   #LN-6-2        set、where
--error 0,1051
drop table test1;
create table test1(f1 int(10),f2 int(10));
DELETE FROM test1 WHERE 1=1;
SELECT * FROM test1;
INSERT INTO test1 VALUE('20.1','30');
SELECT * FROM test1;
UPDATE test1 SET f1 = ln(55) WHERE f1>ln(111);
SELECT * FROM test1;
UPDATE test1 SET f1 = ln(642),f2=ln(f2)/10 WHERE f1>ln(99);
SELECT * FROM test1;
DELETE FROM test1 WHERE 1=1;
SELECT * FROM test1;
INSERT INTO test1 VALUES('20.1','30');
INSERT INTO test1 VALUES('20.2',NULL);
INSERT INTO test1 VALUES(5.5,99);
UPDATE test1 SET f1 = '5' WHERE f1=55;
SELECT * FROM test1;
drop table test1;

--echo  #LN-6-3  select
--error 0,1051
drop table test1;
CREATE TABLE test1(f1 varchar(30),f2 varchar(30));
INSERT INTO test1 VALUES('20.1','30');
INSERT INTO test1 VALUES('20.1','40');
INSERT INTO test1 VALUES('0.1','30');
INSERT INTO test1 VALUES('0.1','40');
--echo #6-3-1      select
SELECT ln(f2) FROM test1;
SELECT ln(f2) FROM test1;
--echo #6-3-2      from
SELECT ln(10+20.1) FROM (SELECT ln(f1) f1,ln(f2) f2 FROM test1);
--echo #6-3-3      where
SELECT * FROM test1 WHERE ln(f2)<ln(f1) AND ln(f2) IN (ln(20));
--echo #6-3-4      group by having
SELECT * FROM test1 GROUP by f2;
SELECT * FROM test1 HAVING f2;
SELECT * FROM test1 GROUP BY f1,f2 HAVING ln(3)*ln(3)<>0;
--echo #6-3-5      order by
SELECT f1,ln(f2) FROM test1 ORDER BY ln(f2) DESC;
--echo #6-3-6      case when
SELECT sum(CASE WHEN ln(f2)>0 THEN 2 ELSE 1 END ) FROM test1;
SELECT sum(ln(ln(f1)>0)/ln(f2)) FROM test1;
--echo #6-3-7      distinct
SELECT DISTINCT ln(f1) FROM test1;
DROP TABLE test1;


--echo #LN-6-4  delete
--error 0,1051
drop table test1;
create table test1(f1 int(10),f2 int(10));
SELECT * from test1;
DELETE FROM test1 WHERE 1=1;
INSERT INTO test1 VALUES('20.1','30');
DELETE FROM test1 WHERE ln(f1)+ln(f2)<>1;
SELECT * FROM test1;
INSERT INTO test1 VALUES('20.1','30');
DELETE FROM test1 WHERE f1=ln(20.1)>0;
DELETE FROM test1 WHERE f1=20.1>0;
SELECT * FROM test1;
INSERT INTO test1 VALUES('20.1','30');
SELECT * FROM test1;
DELETE FROM test1 WHERE f1=ln(20.1)>= 0;
DELETE FROM test1 WHERE f1=20.1>= 0;
INSERT INTO test1 VALUES('20.1','30');
DELETE FROM test1 WHERE f2=ln(30)<0;
DELETE FROM test1 WHERE f2=30<0;
SELECT * FROM test1;
INSERT INTO test1 VALUES('20.1','30');
DELETE FROM test1 WHERE f2=ln(30) <= 0;
DELETE FROM test1 WHERE f2=30 <= 0;
SELECT * FROM test1;
INSERT INTO test1 VALUES('20.1','30');
DELETE FROM test1 WHERE f1=30 = 30;
SELECT * FROM test1;
INSERT INTO test1 VALUES('20.1','30');
DELETE FROM test1 WHERE f1=ln(30) != 30;
DELETE FROM test1 WHERE f1=30 != 30;
SELECT * FROM test1;
DROP TABLE test1;


--echo #LN-7 常用函数嵌套
--echo #LN-7-1        mod
--error 0,1051
drop table test2;
create table test2(f1 int(10),f2 int(10));
INSERT INTO test2 VALUES('100','3');
SELECT * from test2;
SELECT ln(MOD(100,3)) FROM test2;
SELECT MOD(ln(MOD(11.23,1.1)),0.2345) FROM test2;
--echo #LN-7-2       round
SELECT ln(100-round(11.235545574741)) FROM test2;
SELECT ln(ln(round(11,3))/ln(10)) FROM test2;
SELECT ln(round(2.3365*3))*ln(round(2.3365*3)) FROM test2;

--echo #LN-7-3       sum
SELECT sum(ln(11)-100) FROM test2;
SELECT MOD(sum(ln(100000)),50) FROM test2;

--echo #LN-7-4       power
SELECT ln(1/POWER(10,20)) FROM test2;
drop table test2;


--echo #LN-8        视图
--echo #LN-8-1      select
--error 0,1051
drop table b;
--error 0,1051
drop view shitu;
CREATE TABLE b(f1 int(10),f2 int(10));
INSERT INTO b VALUES(20.1,10);
INSERT INTO b VALUES(20.1,40);
INSERT INTO b VALUES(20.1,30);
INSERT INTO b VALUES(20.1,40);
CREATE OR REPLACE VIEW shitu AS SELECT * FROM b;
SELECT ln(f1),ln(f2) FROM shitu;
SELECT * FROM shitu GROUP BY f1,f2 HAVING ln(3333333333333333333333333333333333333)*log(3)<>0;
SELECT f1,ln(f2) FROM shitu ORDER BY log(f2) DESC;
SELECT sum(CASE WHEN ln(5)>0 THEN 2 ELSE 1 END ) FROM shitu;
SELECT sum((CASE WHEN ln(3)>0 THEN 2 ELSE 1 END)/ln(60)) FROM shitu;
SELECT sum(ln((CASE f2 WHEN 10 THEN ln(f1) WHEN 30 THEN ln(f1+100) ELSE 10 END))/ln(f1)) t1 FROM  shitu;
SELECT sum(ln((CASE ln(f2) WHEN ln(f2) THEN 1 ELSE 2 END))) FROM shitu;
SELECT DISTINCT ln(f1) FROM shitu;
--error 0,1064
SELECT ln(f1) FROM shitu WHERE ln(2.5)>ln(2.5) AND ln(5.5)=SOME(ln(5.5),ln(5.5)) GROUP BY ln(10) HAVING ln(10)>0;
--error 0,1064
SELECT b(ln(3,f1)),shitu.* FROM shitu WHERE table(ln(f1*f2))!=ln(f1+f2) GROUP BY f1,f2 HAVING ln(f1)>0;
--error 0,1064
WITH a AS (SELECT ln(100) m FROM shitu), b AS (SELECT ln(100) n,ln(20*12) FROM shitu) SELECT a.*,b.* FROM a INNER JOIN b ON a.m=b.n;
drop table b;
drop view shitu;


--echo  #LN-8-2      insert
--error 0,1051
drop table b;
--error 0,1051
drop view shitu;
CREATE TABLE b(f1 int(10),f2 int(10));
INSERT INTO b VALUES(20.1,10);
INSERT INTO b VALUES(20.1,40);
INSERT INTO b VALUES(20.1,30);
INSERT INTO b VALUES(20.1,40);
CREATE OR REPLACE VIEW shitu AS SELECT * FROM b;
SELECT * from shitu;
DELETE FROM b WHERE 1=1;
INSERT INTO shitu VALUE((ln(88)),(ln(20))||'123');
SELECT * from shitu;
INSERT INTO shitu(f1) VALUE((ln(30*10)-ln(55)));
SELECT * from shitu;
INSERT INTO shitu(f1) SELECT f1 FROM shitu WHERE f1>1 GROUP BY f1 HAVING ln(5) IS NOT NULL;
SELECT * FROM shitu;
drop view shitu;
drop table b;

--echo  #LN-8-3      update
--error 0,1051
drop table b;
--error 0,1051
drop view shitu;
CREATE TABLE b(f1 int(10),f2 int(10));
INSERT INTO b VALUES(20.1,10);
INSERT INTO b VALUES(20.1,40);
INSERT INTO b VALUES(20.1,30);
INSERT INTO b VALUES(20.1,40);
CREATE OR REPLACE VIEW shitu AS SELECT * FROM b;
select * from shitu;
UPDATE shitu set f1=20.999 where f1=20.1;
select * from shitu;
UPDATE shitu SET f1 = ln(20),f2=ln(40/10) WHERE f1<ln(1000);
select * from shitu;
UPDATE shitu SET f1 = ln((SELECT sum(ln(10)) FROM shitu WHERE f1>0));
select * from shitu;
--error 0,1242
UPDATE shitu SET f1 = ln((SELECT f2 FROM shitu WHERE f1>0 GROUP BY f2 HAVING ln(100) IS NOT NULL));
--error 0,1305
UPDATE shitu SET f1 = ln((SELECT * FROM (SELECT ln(100) FROM shitu WHERE f2 BETWEEN l(1) AND l(3) ORDER BY ln(100) DESC)));
drop view shitu;
drop table b;

