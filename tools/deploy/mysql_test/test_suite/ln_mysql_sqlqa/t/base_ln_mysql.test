--echo LN-1        #参数个数要求
SELECT ln(0);
SELECT ln(66);
SELECT ln(-8);
SELECT ln(0.55);
SELECT ln('%');
select ln('汉字');
--error 0,1064
SELECT ln();
--error 0,1305
SELECT ln2(0);
--error 0,1064
SELECT ln(6,0);
--error 0,1064
SELECT ln(66,98);
--error 0,1064
SELECT ln(66,98,70);
--error 0,1051
drop table a;
create table a(id int(10),fenshu int(10),banji int(10));
insert into a(id,fenshu,banji)value(1,87,6228);
insert into a(id,fenshu,banji)value(2,78,6229);
insert into a(id,fenshu,banji)value(3,100,6229);
insert into a(id,fenshu,banji)value(4,70,6228);
insert into a(id,fenshu,banji)value(5,ln(70),6228);
select * from a;
insert into a(id,fenshu,banji)value(6,ln(70),ln(6228));
select * from a;
insert into a(id,fenshu,banji)value(7,ln(70),ln(6228));
select * from a;
insert into a(id,fenshu,banji)value(8,ln(120/30),ln(6228));
--error 0,1064
insert into a(id,fenshu,banji)value(8,ln( ),6228);
select * from a;
--error 0,1064
insert into a(id,fenshu,banji)value(9,ln(120,30),ln(6228));
select * from a;
drop table a;

--echo LN-2        #常规操作
--echo LN-2-1      #符合操作
--error 0,1051
drop table a;
create table a(id int(10),fenshu int(10),banji int(10));
insert into a(id,fenshu,banji)value(1,0,-6228);
insert into a(id,fenshu,banji)value(2,-78,6229);
insert into a(id,fenshu,banji)value(3,100,0.6229);
insert into a(id,fenshu,banji)value(4,+70,6228);
insert into a(id,fenshu,banji)value(5,-0.0001,6229);
select * from a;

SELECT ln(0) from a;
select ln(100) from a;
SELECT ln(+70) from a;
SELECT ln(6228) from a;
select ln(-78) from a;
select ln(-6228) from a;
select ln(0.6229) from a;
select ln(-0.0001) from a;
select ln(banji) from a;
select * from a where banji=ln(6229);
select ln(fenshu) from a where banji=6229;
select ln(fenshu),banji from a where banji=6228;
SELECT ln(avg(fenshu)),banji from a group by banji;
SELECT fenshu,banji from a where banji=6228 order by ln(fenshu) desc;
select * from a order by ln(fenshu) desc;


