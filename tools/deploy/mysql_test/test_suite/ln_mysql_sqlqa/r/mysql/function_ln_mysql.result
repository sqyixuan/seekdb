# LN-10    约束
# LN-10-1  约束ddl
drop table hz;
create table hz(id int(10),name varchar(10),fenshu int(10),banji int(10),xuexiao varchar(10));
insert into hz(id,name,fenshu,banji,xuexiao)value(1,"zhansan",ln(5899),6224,"ligong"),(2,"xiaoli",ln(1000),6223,"henankeji"),(3,"xiaoai",99,6223,"nongye"),(4,"xiaocao",100,6224,"zheda");
SELECT * from hz;
id	name	fenshu	banji	xuexiao
1	zhansan	9	6224	ligong
2	xiaoli	7	6223	henankeji
3	xiaoai	99	6223	nongye
4	xiaocao	100	6224	zheda
#非空
alter table hz modify id int not null;
alter table hz modify id int null;
#主键
alter table hz add primary key (id);
#唯一、自增长
alter table hz add unique yueshu(id);
alter table hz modify id int auto_increment;
alter table hz modify id int;
alter table hz drop key yueshu;
drop table hz;
#外键
drop table shanghai;
drop table hz;
CREATE TABLE hz(id INT PRIMARY KEY,name VARCHAR(50) NOT NULL,fenshu int(10));
insert into hz value (1,"xiaozhang",ln(987));
insert into hz value (2,"xiaoli",ln(598));
CREATE TABLE shanghai(id INT,CONSTRAINT hz_shanghai_id FOREIGN KEY(id) REFERENCES hz(id),fenshu int(10));
select * from hz where name="xiaozhang";
id	name	fenshu
1	xiaozhang	7
select * from shanghai;
id	fenshu
drop table shanghai;
drop table hz;
