2	lisi	79
3	lisi	89
4	lisi	79
SELECT * FROM f WHERE ln(fenshu*1)<=(SELECT ln(fenshu)+699 FROM f WHERE id=4);
id	name	fenshu
1	zhangsan	99
2	lisi	79
3	lisi	89
4	lisi	79
