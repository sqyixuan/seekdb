LN-5-2        #比较运算符
drop table f;
create table f(id int(2),name varchar(20),fenshu int(20));
insert into f (id,name,fenshu)value (1,"zhangsan",99);
insert into f (id,name,fenshu)value (2,"lisi",79);
insert into f (id,name,fenshu)value (3,"lisi",89);
insert into f (id,name,fenshu)value (4,"lisi",79);
select * from f;
id	name	fenshu
1	zhangsan	99
2	lisi	79
3	lisi	89
4	lisi	79
select ln(99>79);
ln(99>79)
0
select ln(79>=79);
ln(79>=79)
0
select ln(79<89);
ln(79<89)
0
select ln(79<=79);
ln(79<=79)
0
select ln(79=79);
ln(79=79)
0
select ln(89!=99);
ln(89!=99)
0
select ln(99)>ln(79);
ln(99)>ln(79)
1
select ln(79)>=ln(79);
ln(79)>=ln(79)
1
select ln(79)<ln(89);
ln(79)<ln(89)
1
select ln(79)<=ln(79);
ln(79)<=ln(79)
1
select ln(79)=ln(79);
ln(79)=ln(79)
1
select ln(89)!=ln(99);
ln(89)!=ln(99)
1
select ln(99><79);
select ln(99)><ln(79);
SELECT * FROM f WHERE ln(fenshu*10)>(SELECT ln(fenshu)+1 FROM f WHERE id=4);
id	name	fenshu
