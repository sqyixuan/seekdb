DROP TABLE test1;
create table test1(id int(5) ,name varchar(20));
select * from test1;
id	name
drop procedure if exists test_process;
create procedure test_process()
begin
declare i int default 1;
while i<ln(2999)
do
insert into test1 values(i,concat('shanghai',i));
set i=i+1;
end while;
commit;
end //
select * from test1;
id	name
call test_process();
select * from test1;
id	name
1	shanghai1
2	shanghai2
3	shanghai3
4	shanghai4
5	shanghai5
6	shanghai6
7	shanghai7
8	shanghai8
drop PROCEDURE test_process;
drop table test1;
#ln-11-1-1-2     repeat循环
drop table test;
create table test(id int(5));
drop procedure if exists test;
create procedure test()
begin
declare i int;
set i = ln(1);
repeat
insert into test values (i);
set i = i + 1;
until i > 10 end repeat;
select * from test;
end
//
call test();
