#ln-11-2-1-3     LOOP循环
DROP TABLE test1;
DROP TABLE test2;
CREATE TABLE test1(f1 decimal(5,1), f2 decimal(5,1));
INSERT INTO test1 VALUES(50,100);
INSERT INTO test1 VALUES(2.7,2);
INSERT INTO test1 VALUES(exp(1),2.8);
Warnings:
Warning	1265	Data truncated for column 'f1' at row 1
INSERT INTO test1(f1) VALUES(10.1);
INSERT INTO test1(f2) VALUES(10.1);
CREATE TABLE test2(f1 decimal(5,1),f2 decimal(5,1));
DROP FUNCTION test_func;
CREATE FUNCTION test_func() RETURNS int
BEGIN
DECLARE v_in int DEFAULT 2;
loop1:LOOP
IF v_in<0 THEN
UPDATE test1 SET f2=11 WHERE ln(f2)<2 AND f1 IS NOT NULL;
LEAVE loop1;
END IF;
SET v_in = v_in-2;
END LOOP;
RETURN 5;
END;
//
SELECT  test_func();
test_func()
5
SELECT * FROM test1;
f1	f2
50.0	100.0
2.7	11.0
2.7	11.0
10.1	NULL
NULL	10.1
drop FUNCTION test_func;
#ln-11-2-2       if条件语句
DELETE FROM test2 WHERE 1=1;
DROP FUNCTION test_func;
CREATE FUNCTION test_func() RETURNS int
BEGIN
DECLARE i int;
IF ln(i)<1 THEN
INSERT INTO test2 VALUES(1,2);
END IF;
RETURN 5;
END;
//
SELECT  test_func();
test_func()
5
SELECT * FROM test2;
f1	f2
#ln-11-2-3       游标
DELETE FROM test1 WHERE 1=1;
DELETE FROM test2 WHERE 1=1;
INSERT INTO test1 VALUE(50,100);
INSERT INTO test1 VALUE(2.7,2);
INSERT INTO test1 VALUE(exp(1),2.8);
Warnings:
Warning	1265	Data truncated for column 'f1' at row 1
INSERT INTO test1(f1) VALUE(10.1);
INSERT INTO test1(f2) VALUE(10.1);
DROP FUNCTION test_func;
CREATE FUNCTION test_func() RETURNS int
BEGIN
DECLARE out_1 decimal(5,1);
DECLARE out_2 decimal(5,1);
DECLARE done int DEFAULT 0;
DECLARE result_cursor CURSOR FOR SELECT f1 a,(CASE WHEN ln(f2)>10 THEN 1 WHEN ln(f2)>30 THEN 2 ELSE 3 END) b FROM test1;
DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
OPEN result_cursor;
FETCH result_cursor INTO out_1,out_2;
WHILE done<>1 DO
INSERT INTO test2 VALUES(out_1,out_2);
FETCH result_cursor INTO out_1,out_2;
END WHILE;
CLOSE result_cursor;
RETURN 5;
END;
//
SELECT  test_func();
test_func()
5
SELECT * FROM test1;
f1	f2
50.0	100.0
2.7	2.0
2.7	2.8
10.1	NULL
NULL	10.1
SELECT * FROM test2;
f1	f2
50.0	3.0
2.7	3.0
2.7	3.0
10.1	3.0
NULL	3.0
drop table test1;
drop table test2;
drop FUNCTION test_func;
