#ln-11-1-1-2     loop循环
DROP TABLE test3;
create table test3(id int(5));
drop procedure if exists test3;
create procedure test3()
begin
declare i int;
set i = ln(200);
lp : loop
insert into test3 values (i);
set i = i + 1;
if i > 10 then
leave lp;
end if; 
end loop;
select * from test3;
end
//
select * from test3;
id
call test3();
id
5
6
7
8
9
10
select * from test3;
id
5
6
7
8
9
10
drop PROCEDURE test3;
drop tables test3;
#ln-11-1-2     if条件语句
DROP TABLE test4;
create table test4(id int(10),fenshu int(10));
insert into test4 value (5,6);
insert into test4 value (7,2);
select * from test4;
id	fenshu
5	6
7	2
DROP FUNCTION test4;
CREATE FUNCTION test4() RETURNS int
BEGIN
DECLARE i int;
IF ln(i<1) THEN
INSERT INTO test4 VALUES(1,2);
END IF;
RETURN 5;
END;
//
SELECT * FROM test4;
id	fenshu
5	6
7	2
drop tables test4;
drop FUNCTION test4;
#ln-11-1-3     游标
DROP TABLE test5;
CREATE TABLE test5(f1 decimal(5,1),f2 decimal(5,1));
INSERT INTO test5 VALUES('20.1','10');
INSERT INTO test5 VALUES('20.1','30');
INSERT INTO test5 VALUES('20.1','40');
INSERT INTO test5 VALUES(NULL,NULL);
CREATE TABLE test6(f1 decimal(5,1),f2 decimal(5,1));
DROP PROCEDURE test5_pro;
create procedure test5_pro()
begin
DECLARE v1 decimal(5,1);
DECLARE v2 decimal(5,1);
DECLARE done INT DEFAULT 0;
DECLARE youbiao CURSOR FOR SELECT avg(f2),f1 from test5 GROUP by f1;
DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
OPEN youbiao;
FETCH youbiao INTO v1,v2;
WHILE done<>1 DO
INSERT INTO test5 VALUES(ln(35),ln(99));
FETCH youbiao INTO v1,v2;
END WHILE;
CLOSE youbiao;
END;
//
SELECT* from test5;
f1	f2
20.1	10.0
20.1	30.0
20.1	40.0
NULL	NULL
CALL test5_pro();
SELECT * FROM test5;
f1	f2
20.1	10.0
20.1	30.0
20.1	40.0
NULL	NULL
3.6	4.6
3.6	4.6
SELECT * FROM test6;
f1	f2
drop PROCEDURE test5_pro;
drop tables test5;
drop tables test6;
#ln-11-2  函数
#ln-11-2-1  	 循环函数
#ln-11-2-2      if条件语句
#ln-11-2-3      游标
#ln-11-2-1-1  	 while循环
DROP TABLE test1;
DROP TABLE test2;
CREATE TABLE test1(f1 decimal(5,1), f2 decimal(5,1));
INSERT INTO test1 VALUE(50,100);
INSERT INTO test1 VALUE(2.7,2);
INSERT INTO test1 VALUE(ln(1),2.8);
INSERT INTO test1(f1) VALUE(10.1);
INSERT INTO test1(f2) VALUE(10.1);
CREATE TABLE test2(f1 decimal(5,1),f2 decimal(5,1));
drop FUNCTION test_func;
CREATE FUNCTION test_func() RETURNS int
begin
DECLARE v1 decimal(5,1);
DECLARE v2 decimal(5,1);
DECLARE done INT DEFAULT 0;
DECLARE result_cursor CURSOR FOR SELECT f1,f2 FROM test1;
DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
OPEN result_cursor;
FETCH result_cursor INTO v1,v2;
WHILE done<>1 DO
IF v1>10 THEN
INSERT INTO test2 SELECT * FROM test1 WHERE ln(null);
ELSEIF v1<10 THEN
INSERT INTO test2(f2) SELECT f1 FROM test1 WHERE ln(NULL) GROUP BY f1 HAVING ln(10);
ELSE
INSERT INTO test2 VALUES(v1||'1234567890',v2);
END IF;
FETCH result_cursor INTO v1,v2;
END WHILE;
CLOSE result_cursor;
RETURN 5;
END;
//
SELECT * FROM test1;
f1	f2
50.0	100.0
2.7	2.0
0.0	2.8
10.1	NULL
NULL	10.1
SELECT * FROM test2;
f1	f2
DELETE FROM test2 WHERE 1=1;
DROP FUNCTION test_func;
CREATE FUNCTION test_func() RETURNS int
BEGIN
DECLARE v1 decimal(5,1) DEFAULT 20;
WHILE ln(v1)>ln(30) DO
INSERT INTO test2 VALUES(1,2);
SET v1=v1+5;
END WHILE;
RETURN 5;
END;
//
SELECT  test_func();
test_func()
5
SELECT * FROM test2;
f1	f2
drop FUNCTION test_func;
drop table test1;
drop table test2;
