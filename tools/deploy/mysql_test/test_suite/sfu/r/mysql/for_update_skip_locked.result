#
# - add for select for update skip locked in mysql mode
#
create table t1 (c1 int primary key, c2 int);
insert into t1 values(1, 1);
insert into t1 values(2, 1);
insert into t1 values(3, 2);
result_format: 4
set autocommit = 0;

select * from t1 where c1 = 1 for update;
+----+------+
| c1 | c2   |
+----+------+
|  1 |    1 |
+----+------+
select * from t1 where c1 = 1 for update nowait;
ERROR HY000: Lock wait timeout exceeded; try restarting transaction
select * from t1 where c2 = 1 for update skip locked;
+----+------+
| c1 | c2   |
+----+------+
|  2 |    1 |
+----+------+

commit;
set autocommit = 1;
drop table t1;

## lock mult rows and skip mult rows
create table t1 (c1 int primary key, c2 int, c3 int);
create index idx1 on t1(c2);
insert into t1 values(1, 1, 1);
insert into t1 values(2, 1, 1);
insert into t1 values(3, 1, 1);
insert into t1 values(4, 1, 1);
insert into t1 values(5, 2, 1);
insert into t1 values(6, 2, 1);
insert into t1 values(7, 3, 1);
insert into t1 values(8, 3, 2);

result_format: 4
set autocommit = 0;

select * from t1 where c2 = 1 for update;
+----+------+------+
| c1 | c2   | c3   |
+----+------+------+
|  1 |    1 |    1 |
|  2 |    1 |    1 |
|  3 |    1 |    1 |
|  4 |    1 |    1 |
+----+------+------+
select * from t1 where c3 = 1 for update nowait;
ERROR HY000: Lock wait timeout exceeded; try restarting transaction
select * from t1 where c3 = 1 for update skip locked;
+----+------+------+
| c1 | c2   | c3   |
+----+------+------+
|  5 |    2 |    1 |
|  6 |    2 |    1 |
|  7 |    3 |    1 |
+----+------+------+

# Violation of sql grammar rules
select * from t1 where c3 = 1 for update nowait skip locked;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'skip locked' at line 1

commit;

## select from view and lock mult rows skip mult rows
commit;
set autocommit = 1;
drop table t1;

## select with join but only lock one table
create table t1 (c1 int primary key, c2 int, c3 int);
insert into t1 values(1, 1, 1);
insert into t1 values(4, 3, 1);

create table t2 (c1 int primary key, c2 int, c3 int);
insert into t2 values(1, 1, 1);
insert into t2 values(4, 5, 1);

result_format: 4
set autocommit = 0;

select * from t1, t2 where t1.c2 = t2.c2 for update;
+----+------+------+----+------+------+
| c1 | c2   | c3   | c1 | c2   | c3   |
+----+------+------+----+------+------+
|  1 |    1 |    1 |  1 |    1 |    1 |
+----+------+------+----+------+------+
select * from t1, t2 where t1.c3 = t2.c3 for update nowait;
ERROR HY000: Lock wait timeout exceeded; try restarting transaction
select * from t1, t2 where t1.c3 = t2.c3 for update skip locked;
+----+------+------+----+------+------+
| c1 | c2   | c3   | c1 | c2   | c3   |
+----+------+------+----+------+------+
|  4 |    3 |    1 |  4 |    5 |    1 |
+----+------+------+----+------+------+
commit;
set autocommit = 1;
drop table t1;
drop table t2;

# test for skip locked multi rows 
create table t1 (c1 int primary key, c2 int, c3 int, c4 int);
insert into t1 values(1, 1, 1, 1);
insert into t1 values(2, 2, 2, 2);
insert into t1 values(3, 1, 3, 3);
insert into t1 values(4, 2, 4, 4);
insert into t1 values(5, 1, 5, 5);
insert into t1 values(6, 6, 6, 6);
insert into t1 values(7, 2, 7, 7);
insert into t1 values(8, 2, 8, 8);
insert into t1 values(9, 1, 9, 9);
insert into t1 values(10, 1, 10, 10);

result_format: 4
set autocommit = 0;

select * from t1 where c2 = 2 for update;
+----+------+------+------+
| c1 | c2   | c3   | c4   |
+----+------+------+------+
|  2 |    2 |    2 |    2 |
|  4 |    2 |    4 |    4 |
|  7 |    2 |    7 |    7 |
|  8 |    2 |    8 |    8 |
+----+------+------+------+
select * from t1 for update nowait;
ERROR HY000: Lock wait timeout exceeded; try restarting transaction
select * from t1 for update skip locked;
+----+------+------+------+
| c1 | c2   | c3   | c4   |
+----+------+------+------+
|  1 |    1 |    1 |    1 |
|  3 |    1 |    3 |    3 |
|  5 |    1 |    5 |    5 |
|  6 |    6 |    6 |    6 |
|  9 |    1 |    9 |    9 |
| 10 |    1 |   10 |   10 |
+----+------+------+------+

commit;
set autocommit = 1;
drop table t1;

