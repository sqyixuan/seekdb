drop table if exists t1, t2, t_part, t9;
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int primary key, c2 int, c3 int);
create table t_part(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create index gkey1 on t_part(c2) global;
result_format: 4
explain_protocol: 2
##PK Preserving(table scan/inner join/outer join/window func/order by/limit/subplan filter...)
