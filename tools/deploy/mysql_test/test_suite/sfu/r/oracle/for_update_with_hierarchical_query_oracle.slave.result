drop table t1;
drop table t2;
drop table t3;
drop table tp1;
drop table tp2;
drop index idx1;
drop index idx2;
drop table zct1;
drop table zct2;
drop table zct3;
drop table zct4;
drop index in_t4;
set autocommit = 0;
commit;
set autocommit = 0;
commit;
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int, c2 int);
create table t3 (c1 int, c2 int);
create table tp1 (c1 int primary key, c2 int) partition by hash(c1) partitions 4;
create table tp2 (c1 int, c2 int) partition by hash(c1) partitions 4;
create index idx1 on tp1(c2) global;
create index idx2 on tp2(c2) global;
insert into t1 values (1, 1);
insert into t1 values (2, 2);
insert into t1 values (3, 3);
insert into t2 select * from t1;
insert into t3 select * from t1;
insert into tp1 select * from t1;
insert into tp2 select * from t1;
CREATE TABLE zct1(emp_id INT PRIMARY KEY,position VARCHAR(20),mgr_id INT);
INSERT INTO zct1 VALUES (1,'全球经理',NULL);
INSERT INTO zct1 VALUES (2,'欧洲区经理',1);
INSERT INTO zct1 VALUES (3,'亚太区经理',1);
INSERT INTO zct1 VALUES (4,'美洲区经理',1);
INSERT INTO zct1 VALUES (5,'意大利区经理',2);
INSERT INTO zct1 VALUES (6,'法国区经理',2);
INSERT INTO zct1 VALUES (7,'中国区经理',3);
INSERT INTO zct1 VALUES (8,'韩国区经理',3);
INSERT INTO zct1 VALUES (9,'日本区经理',3);
INSERT INTO zct1 VALUES (10,'美国区经理',4);
INSERT INTO zct1 VALUES (11,'加拿大区经理',4);
INSERT INTO zct1 VALUES (12,'北京区经理',7);
CREATE TABLE zct2(emp_id INT CONSTRAINT t2_unq UNIQUE,position VARCHAR(20),mgr_id INT);
INSERT INTO zct2 SELECT * from zct1;
CREATE TABLE zct3(c1 NUMBER,c2 VARCHAR(10),c3 DATE,c4 NUMBER) PARTITION by RANGE(c1) (PARTITION p0 VALUES LESS THAN (0),PARTITION p1 VALUES LESS than (3),PARTITION p2 VALUES less THAN (6));
INSERT into zct3 VALUES(-2,'a','1999-11-11 11:11:11',NULL);
INSERT into zct3 VALUES(-1,'b','2000-11-11 11:11:11',-2);
INSERT into zct3 VALUES(0,'c','2001-11-11 11:11:11',-1);
INSERT into zct3 VALUES(1,'d','2002-11-11 11:11:11',0);
INSERT into zct3 VALUES(2,'e','2003-11-11 11:11:11',1);
INSERT into zct3 VALUES(3,'f','2004-11-11 11:11:11',2);
INSERT into zct3 VALUES(4,'g','2005-11-11 11:11:11',3);
CREATE TABLE zct4(emp_id INT ,position VARCHAR(20),mgr_id INT) PARTITION BY range(emp_id)(PARTITION p0 VALUES LESS THAN (4),PARTITION p1 VALUES LESS than (8),PARTITION p2 VALUES less THAN (MAXVALUE));
CREATE INDEX in_t4 ON zct4(emp_id,mgr_id);
INSERT INTO zct4 SELECT * from zct1;
commit;
result_format: 4
