# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer, dml

--disable_warnings
drop table if exists t1, t2, t_part, t9;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int primary key, c2 int, c3 int);
create table t_part(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create index gkey1 on t_part(c2) global;

--result_format 4
--explain_protocol 2

##PK Preserving(table scan/inner join/outer join/window func/order by/limit/subplan filter...)
select * from t1 for update;
select /*+index(t_part gkey1)*/* from t_part for update;
select * from (select * from t1 for update) tt1, (select * from t2 for update) tt2;
select * from (select * from t1 for update wait 1) tt1, (select * from t2 for update wait 2) tt2;
select * from t1 left join t2 on t1.c1 = t2.c1 for update;
select * from t1 left join t2 on t1.c1 = (select max(c2) from t2 as t3 for update) for update;
select sum(c1) over() from t1 for update;
select * from t1 where c1 > 1 order by c2 for update;
select * from t1 where c1 > 1 order by c2 limit 1 for update;
select * from t1 where c1 in (select c1 from t2) for update;
select /*+no_rewrite*/ * from t1 where c1 in (select c1 from t2) for update;
select * from t_part where c1 in (select c1 from t2 for update) for update;
select /*+no_rewrite*/ * from t_part where c1 in (select c1 from t2 for update) for update;
select * from t_part for update;
select * from t1, t_part for update;
(select * from t1 for update) union all (select * from t_part for update);

##Non PK Preserving(distinct/group by/left semi join(left anti join)的右表/right semi join(right anti join)的左表...)
select distinct c1 from t1 for update;
select count(c1) from t_part for update;
select c2, c3 from t_part group by c2, c3 for update;
select * from t1 where c2 in (select c2 from t2 for update) and exists(select 1 from t2 for update);
select /*+leading(t1, t2)*/* from t1 where c2 in (select c2 from t2 for update);
select /*+leading(t2, t_part)*/* from t_part where c2 in (select c2 from t2 for update) for update;
select /*+leading(t1, t2)*/* from t1 where c2 not in (select c2 from t2 for update) for update;
select /*+leading(t_part, t1)*/* from t1 where c2 not in (select c2 from t_part for update);
select * from t1 where c2 in (select t2.c2 from t2,t_part) for update;
select * from t1 where c2 in (select t2.c2 from t2,t_part for update) for update;
select * from t1 where c2 in (select t2.c2 from t2,t_part where t_part.c2 in (select c2 from t1 t3 for update)) for update;
select * from t1 where c2 in (select c2 from t2 for update) and c2 in (select c2 from t_part for update) for update;
select * from t1 where c2 in (select c2 from t2 where c3 in (select c3 from t_part for update) for update) for update;
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1 for update) for update;
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1 for update wait 1) for update;
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1 for update wait 1) for update wait 1;
select /*+leading(t1,t2,t_part)*/* from t1 where c2 in (select t2.c1 from t2 where c2 in (select c2 from t_part for update) for update) for update;
select /*+leading(t1,t_part, t2)*/* from t1 where c2 in (select c2 from t_part where c2 in (select c1 from t2 for update) for update) for update;
select /*+leading(t1,t_part, t2)*/* from t1 where c2 in (select c2 from t_part where c2 in (select c1 from t2 for update wait 1) for update) for update;
select * from t1 where exists(
    select 1 from t2 where t1.c2=t2.c2 and exists(
        select 1 from t_part t3 where t3.c3 = t2.c3 and exists(
            select 1 from t2 t4 where t4.c2 = t3.c2
            for update)
        for update)
    for update)
for update;

## for update in dml cases
drop table t2;
create table t2(a int not null, b int, primary key(a)) ;
insert into t2 values (8,6),(12,1),(3,1);
create table t9(d int not null, e int, primary key(d)) ;
insert into t9 values (8,6),(12,1),(3,1);

call dbms_stats.gather_table_stats('TEST', 'T2');
call dbms_stats.gather_table_stats('TEST', 'T9');

connect (a,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (b,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection a;
set autocommit = 0;
select * from t2 for update;

connection b;
set autocommit = 0;
explain update t9 set e = (select b from t2 where a = d for update);
--error 1205, 4012
update t9 set e = (select b from t2 where a = d for update);

explain delete from t9 where (select b from t2 where a = d for update) > 0;
--error 1205, 4012
delete from t9 where (select b from t2 where a = d for update) > 0;

disconnect a;
disconnect b;
connection default;

drop table t1,t2,t_part;
