#owner: zhanyue.zzy
#owner group: SQL1
#description: test auto dop for dml
#tags: optimizer

--result_format 4

--disable_warnings
drop table if exists t1, tp1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create table tp1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 10;

--disable_query_log
insert /*+parallel(8) enable_parallel_dml append*/ into t1 select abs(random()%1000000), abs(random()%1000000), abs(random()%1000000) from table(generator(200000));
insert /*+parallel(8) enable_parallel_dml append*/ into tp1 select * from t1;
call dbms_stats.set_table_prefs('TEST', 'T1', 'ESTIMATE_BLOCK', 'false');
call dbms_stats.set_table_prefs('TEST', 'TP1', 'ESTIMATE_BLOCK', 'false');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'TP1', method_opt=>'for all columns size 64', estimate_percent=>100);
--enable_query_log

explain basic update /*+parallel(auto) parallel(t1, 1)*/ t1 set c2 = 4;
explain basic update /*+parallel(auto) parallel(t1, 4)*/ t1 set c2 = 4;
explain basic update /*+parallel(auto) parallel(t1, 4) disable_parallel_dml*/ t1 set c2 = 4;
explain basic update /*+parallel(auto) parallel(t1, 80)*/ t1 set c2 = 4;
explain basic delete /*+parallel(auto) parallel(t1, 1)*/ from t1 where c2 = 4;
explain basic delete /*+parallel(auto) parallel(t1, 4)*/ from t1 where c2 = 4;
explain basic delete /*+parallel(auto) parallel(t1, 4) disable_parallel_dml*/ from t1 where c2 = 4;
explain basic delete /*+parallel(auto) parallel(t1, 80)*/ from t1 where c2 = 4;

explain basic update /*+parallel(auto) parallel(tp1, 1)*/ tp1 set c2 = 4;
explain basic update /*+parallel(auto) parallel(tp1, 4)*/ tp1 set c2 = 4;
explain basic update /*+parallel(auto) parallel(tp1, 80)*/ tp1 set c2 = 4;
explain basic update /*+parallel(auto) parallel(tp1, 80) disable_parallel_dml*/ tp1 set c2 = 4;
explain basic update /*+parallel(auto) parallel(tp1, 256)*/ tp1 set c2 = 4;
explain basic delete /*+parallel(auto) parallel(tp1, 1)*/ from tp1 where c2 = 4;
explain basic delete /*+parallel(auto) parallel(tp1, 4)*/ from tp1 where c2 = 4;
explain basic delete /*+parallel(auto) parallel(tp1, 80)*/ from tp1 where c2 = 4;
explain basic delete /*+parallel(auto) parallel(tp1, 80) disable_parallel_dml*/ from tp1 where c2 = 4;
explain basic delete /*+parallel(auto) parallel(tp1, 256)*/ from tp1 where c2 = 4;

## calculate dml dop
show variables like 'parallel_degree_policy';
show variables like 'parallel_min_scan_time_threshold';
show variables like 'parallel_servers_target';

set parallel_min_scan_time_threshold = 10;
set parallel_degree_limit = 20;

explain basic insert /*+parallel(auto)*/ into t1 select * from t1;
explain basic insert /*+parallel(auto)*/ into t1 select * from t1 where c1 >= 0;
explain basic insert /*+parallel(auto)*/ into t1 select * from t1 limit 1000000;
explain basic insert /*+parallel(auto)*/ into t1 select /*+no_rewrite*/ * from (select * from t1);
explain basic insert /*+parallel(auto)*/ into t1 select /*+no_rewrite*/ * from (select * from t1 where c1 >= 0);
explain basic insert /*+parallel(auto) append*/ into t1 select * from t1;
explain basic insert /*+parallel(auto) append*/ into tp1 select * from t1;

explain basic delete /*+parallel(auto)*/ from t1;
explain basic delete /*+parallel(auto)*/ from t1 where c1 >= 0;
explain basic delete /*+parallel(auto)*/ from t1 limit 1000000;

explain basic update /*+parallel(auto)*/ t1 set c3 = c2;
explain basic update /*+parallel(auto)*/ t1 set c3 = c2 where c1 >= 0;
explain basic update /*+parallel(auto)*/ t1 set c3 = c2 limit 1000000;

set parallel_min_scan_time_threshold = 1000;
set parallel_degree_limit = 0;

drop table t1;
drop table tp1;
