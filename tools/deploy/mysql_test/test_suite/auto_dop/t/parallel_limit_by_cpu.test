#owner: zhanyue.zzy
#owner group: SQL1
#description: test auto dop parallel limit by cpu
#tags: optimizer

--result_format 4
set ob_query_timeout = 1000000000;

--disable_query_log
connect (sys,$OBMYSQL_MS0,root,"",oceanbase,$OBMYSQL_PORT);
connection sys;
let $saved_primary_zone=`select primary_zone from oceanbase.__all_tenant where tenant_name = 'sys'`;
alter tenant sys set primary_zone = 'RANDOM';
sleep 2;

connection default;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 2;
create index idx on t1(c2);
--disable_query_log
insert /*+parallel(8) enable_parallel_dml*/ into t1 
(with recursive cte as ( select 1 as c1 union all select c1+1 from cte where c1 < 1000)
 select c1 % 2, c1, c1, c1 from cte);
insert /*+parallel(8) enable_parallel_dml*/ into t1 select * from t1;
insert /*+parallel(8) enable_parallel_dml*/ into t1 select * from t1;
insert /*+parallel(8) enable_parallel_dml*/ into t1 select * from t1;
insert /*+parallel(8) enable_parallel_dml*/ into t1 select * from t1;
insert /*+parallel(8) enable_parallel_dml*/ into t1 select * from t1;
insert /*+parallel(8) enable_parallel_dml*/ into t1 select * from t1;
insert /*+parallel(8) enable_parallel_dml*/ into t1 select * from t1;
insert /*+parallel(8) enable_parallel_dml*/ into t1 select * from t1;
insert /*+parallel(8) enable_parallel_dml*/ into t1 select * from t1;
call dbms_stats.set_table_prefs('TEST', 'T1', 'ESTIMATE_BLOCK', 'false');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);
--enable_query_log

show variables like 'parallel_degree_policy';
show variables like 'parallel_min_scan_time_threshold';
show variables like 'parallel_servers_target';

select min_cpu from oceanbase.V$OB_UNITS;

set parallel_min_scan_time_threshold = 10;

##select TABLE_NAME, PARTITION_NAME, SVR_IP, SVR_PORT, ROLE from oceanbase.dba_ob_table_locations where table_id = (select max(table_id) from oceanbase.__all_table where table_name = 't1');

--replace_regex /dop=[24]/dop= 2 or 4/
explain basic select /*+parallel(auto)*/ * from t1;
explain basic select /*+parallel(auto)*/ * from t1 partition (p0);
explain basic select /*+parallel(auto)*/ * from t1 partition (p1);
--replace_regex /dop=[24]/dop= 2 or 4/
explain basic select /*+parallel(auto)*/ * from t1 partition (p0, p1);

set parallel_degree_limit = 10;
--replace_regex /dop=[56]/dop= 5 or 6/
explain basic select /*+parallel(auto)*/ * from t1;
explain basic select /*+parallel(auto)*/ * from t1 where c2 in (1,2);

drop table t1;
set parallel_min_scan_time_threshold = 1000;
set parallel_degree_limit = 0;

--disable_query_log
connection sys;
eval alter tenant sys set primary_zone = "$saved_primary_zone";
--enable_query_log
