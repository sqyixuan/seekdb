#owner: zhanyue.zzy
#owner group: SQL1
#description: test auto dop parallel limit by cpu
#tags: optimizer

--result_format 4
set ob_query_timeout = 1000000000;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create index idx on t1(c2, c3, c1);

--disable_query_log
insert /*+parallel(8) enable_parallel_dml append*/ into t1 select abs(random()%1000000), abs(random()%1000000), abs(random()%1000000) from table(generator(200000));
call dbms_stats.set_table_prefs('TEST', 'T1', 'ESTIMATE_BLOCK', 'false');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);
--enable_query_log

show variables like 'parallel_degree_policy';
show variables like 'parallel_min_scan_time_threshold';
#show variables like 'parallel_servers_target';

set parallel_min_scan_time_threshold = 10;
set parallel_degree_limit = 20;

explain basic select /*+no_rewrite parallel(auto)*/ count(distinct c1 + c2) from t1;
explain basic select /*+no_rewrite parallel(auto)*/ count(distinct c1 + c2), count(c2 + c3), sum(c1 + c2), sum(c2 + c3), sum(c3 + c2) from t1;
explain basic select /*+no_rewrite parallel(auto)*/ count(distinct c1 + c2), count(distinct c2 + c3), sum(c1 + c2), sum(c2 + c3), sum(c3 + c2) from t1;
explain basic select /*+no_rewrite parallel(auto)*/ count(distinct c1 + c2), count(distinct c2 + c3), count(distinct c1 + c3), sum(c2 + c3), sum(c3 + c2) from t1;
explain basic select /*+no_rewrite parallel(auto)*/ count(distinct c1 + c2), count(distinct c2 + c3), count(distinct c1 + c3), count(distinct c3 + c1), sum(c3 + c2) from t1;

explain basic select /*+no_rewrite parallel(auto)*/ count(distinct c1 + c2), count(distinct c2 + c3), count(distinct c1 + c3), count(distinct c3 + c1), sum(c3 + c2) from t1 where c2 >= 0;
explain basic select /*+no_rewrite parallel(auto)*/ count(distinct c1 + c2), count(distinct c2 + c3), count(distinct c1 + c3), count(distinct c3 + c1), sum(c3 + c2) from t1 where c1 > 0 and c2 >= 0;

explain basic select /*+no_rewrite parallel(auto)*/ count(distinct c1 + c2) from t1 group by c1;
explain basic select /*+no_rewrite parallel(auto)*/ count(distinct c1 + c2), count(c2 + c3), sum(c1 + c2), sum(c2 + c3), sum(c3 + c2) from t1 group by c1;
explain basic select /*+no_rewrite parallel(auto)*/ count(distinct c1 + c2), count(distinct c2 + c3), sum(c1 + c2), sum(c2 + c3), sum(c3 + c2) from t1 group by c1;
explain basic select /*+no_rewrite parallel(auto)*/ count(distinct c1 + c2), count(distinct c2 + c3), count(distinct c1 + c3), sum(c2 + c3), sum(c3 + c2) from t1 group by c1;
explain basic select /*+no_rewrite parallel(auto)*/ count(distinct c1 + c2), count(distinct c2 + c3), count(distinct c1 + c3), count(distinct c3 + c1), sum(c3 + c2) from t1 group by c1;

drop table t1;
set parallel_min_scan_time_threshold = 1000;
set parallel_degree_limit = 0;
