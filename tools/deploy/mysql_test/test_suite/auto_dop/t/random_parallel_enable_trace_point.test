
#owner: zhanyue.zzy
#owner group: SQL1
#description: test random parallel limit by parallel_degree_limit when enable trace point 552
#tags: optimizer

--result_format 4

--disable_query_log
connect (sys,$OBMYSQL_MS0,root,"",oceanbase,$OBMYSQL_PORT);
connection sys;
alter system set_tp tp_no = 552, error_code = 4016, frequency = 1;
sleep 2;

connection default;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 10;

set parallel_degree_limit = 1;

explain basic select * from t1;
explain basic select * from t1;
explain basic select * from t1;

set parallel_degree_limit = 0;

drop table t1;

--disable_query_log
connection sys;
alter system set_tp tp_no = 552, error_code = 4016, frequency = 0;
--enable_query_log
