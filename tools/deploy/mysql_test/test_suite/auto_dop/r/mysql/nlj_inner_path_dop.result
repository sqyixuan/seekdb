result_format: 4
set ob_query_timeout = 1000000000;

drop table if exists t1, tp1;
create table t1(c1 int ,c2 int, c3 int);
create table tp1(c1 int ,c2 int, c3 int, primary key(c1)) partition by hash(c1) partitions 4;

## pkey
explain basic select /*+parallel(t1 8) parallel(tp1 1) leading(t1) use_nl(tp1) pq_distribute(tp1 partition none)*/ * from t1, tp1 where t1.c2 = tp1.c1;
