result_format: 4
set ob_query_timeout = 1000000000;

drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 2;
create index idx on t1(c2);
show variables like 'parallel_degree_policy';
Variable_name	Value
parallel_degree_policy	MANUAL
show variables like 'parallel_min_scan_time_threshold';
Variable_name	Value
parallel_min_scan_time_threshold	1000
show variables like 'parallel_servers_target';
Variable_name	Value
parallel_servers_target	30

select min_cpu from oceanbase.V$OB_UNITS;
+---------+
| min_cpu |
+---------+
|       3 |
+---------+

set parallel_min_scan_time_threshold = 10;

##select TABLE_NAME, PARTITION_NAME, SVR_IP, SVR_PORT, ROLE from oceanbase.dba_ob_table_locations where table_id = (select max(table_id) from oceanbase.__all_table where table_name = 't1');
explain basic select /*+parallel(auto)*/ * from t1;
Query Plan
===================================
|ID|OPERATOR             |NAME    |
-----------------------------------
|0 |PX COORDINATOR       |        |
|1 |└─EXCHANGE OUT DISTR |:EX10000|
|2 |  └─PX BLOCK ITERATOR|        |
|3 |    └─TABLE FULL SCAN|t1      |
===================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4)]), filter(nil), rowset=256
  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4)]), filter(nil), rowset=256
      dop=3
  2 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256
  3 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256
      access([t1.c1], [t1.c2], [t1.c3], [t1.c4]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
