set parallel_degree_limit = 10;
explain basic select /*+parallel(auto)*/ * from t1;
Query Plan
===================================
|ID|OPERATOR             |NAME    |
-----------------------------------
|0 |PX COORDINATOR       |        |
|1 |└─EXCHANGE OUT DISTR |:EX10000|
|2 |  └─PX BLOCK ITERATOR|        |
|3 |    └─TABLE FULL SCAN|t1      |
===================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4)]), filter(nil), rowset=256
  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4)]), filter(nil), rowset=256
      dop= 5 or 6
  2 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256
  3 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256
      access([t1.c1], [t1.c2], [t1.c3], [t1.c4]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
explain basic select /*+parallel(auto)*/ * from t1 where c2 in (1,2);
Query Plan
=======================================
|ID|OPERATOR                 |NAME    |
---------------------------------------
|0 |PX COORDINATOR           |        |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|
|2 |  └─PX PARTITION ITERATOR|        |
|3 |    └─TABLE RANGE SCAN   |t1(idx) |
=======================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4)]), filter(nil), rowset=256
  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4)]), filter(nil), rowset=256
      dop=1
  2 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256
      force partition granule
  3 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256
      access([t1.__pk_increment], [t1.c1], [t1.c2], [t1.c3], [t1.c4]), partitions(p[0-1])
      is_index_back=true, is_global_index=false, 
      range_key([t1.c2], [t1.__pk_increment]), range(1,MIN ; 1,MAX), (2,MIN ; 2,MAX), 
      range_cond([t1.c2 IN (1, 2)])

drop table t1;
set parallel_min_scan_time_threshold = 1000;
set parallel_degree_limit = 0;

