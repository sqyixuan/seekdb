result_format: 4
drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 10;

set parallel_degree_limit = 1;

explain basic select * from t1;
Query Plan
=======================================
|ID|OPERATOR                 |NAME    |
---------------------------------------
|0 |PX COORDINATOR           |        |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|
|2 |  └─PX PARTITION ITERATOR|        |
|3 |    └─TABLE FULL SCAN    |t1      |
=======================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4)]), filter(nil), rowset=16
      dop=1
  2 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=16
      force partition granule
  3 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=16
      access([t1.c1], [t1.c2], [t1.c3], [t1.c4]), partitions(p[0-9])
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
