result_format: 4
set ob_query_timeout = 1000000000;

drop table if exists t1;
create table t1(c1 int, c2 int, c3 int);
create index idx on t1(c2, c3, c1);

show variables like 'parallel_degree_policy';
Variable_name	Value
parallel_degree_policy	MANUAL
show variables like 'parallel_min_scan_time_threshold';
Variable_name	Value
parallel_min_scan_time_threshold	1000
set parallel_min_scan_time_threshold = 10;
set parallel_degree_limit = 20;

explain basic select /*+no_rewrite parallel(auto)*/ count(distinct c1 + c2) from t1;
Query Plan
===========================
|ID|OPERATOR         |NAME|
---------------------------
|0 |SCALAR GROUP BY  |    |
|1 |└─TABLE FULL SCAN|t1  |
===========================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT(distinct t1.c1 + t1.c2)]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_COUNT(distinct t1.c1 + t1.c2)])
  1 - output([t1.c1], [t1.c2]), filter(nil), rowset=256
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
