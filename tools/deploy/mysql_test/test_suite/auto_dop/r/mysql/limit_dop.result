result_format: 4
set ob_query_timeout = 1000000000;

drop table if exists t1, tp1;
drop table if exists t1, tp1;
create table t1(c1 int, c2 int, c3 int);
create index idx on t1(c2, c3, c1);
create table tp1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 10;

show variables like 'parallel_degree_policy';
Variable_name	Value
parallel_degree_policy	MANUAL
show variables like 'parallel_min_scan_time_threshold';
Variable_name	Value
parallel_min_scan_time_threshold	1000
show variables like 'parallel_servers_target';
Variable_name	Value
parallel_servers_target	30

set parallel_min_scan_time_threshold = 10;
set parallel_degree_limit = 20;

explain basic select /*+parallel(auto)*/ * from t1 limit 1000000;
Query Plan
=========================
|ID|OPERATOR       |NAME|
-------------------------
|0 |TABLE FULL SCAN|t1  |
=========================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      limit(1000000), offset(nil), is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
explain basic select /*+parallel(auto)*/ * from t1 where c2 >= 0 limit 1000000;
Query Plan
=============================
|ID|OPERATOR        |NAME   |
-----------------------------
|0 |TABLE RANGE SCAN|t1(idx)|
=============================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
      access([t1.c2], [t1.c1], [t1.c3]), partitions(p0)
      limit(1000000), offset(nil), is_index_back=false, is_global_index=false, 
      range_key([t1.c2], [t1.c3], [t1.c1], [t1.__pk_increment]), range(0,MIN,MIN,MIN ; MAX,MAX,MAX,MAX), 
      range_cond([t1.c2 >= 0])
explain basic select /*+parallel(auto)*/ * from t1 where c2 >= 0 and c1 >= 0 limit 1000000;
Query Plan
========================================
|ID|OPERATOR                  |NAME    |
----------------------------------------
|0 |LIMIT                     |        |
|1 |└─PX COORDINATOR          |        |
|2 |  └─EXCHANGE OUT DISTR    |:EX10000|
|3 |    └─LIMIT               |        |
|4 |      └─PX BLOCK ITERATOR |        |
|5 |        └─TABLE RANGE SCAN|t1(idx) |
========================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
      limit(1000000), offset(nil)
  1 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
  2 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
      dop=4
  3 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
      limit(1000000), offset(nil)
  4 - output([t1.c2], [t1.c1], [t1.c3]), filter(nil), rowset=256
  5 - output([t1.c2], [t1.c1], [t1.c3]), filter([t1.c1 >= 0]), rowset=256
      access([t1.c2], [t1.c1], [t1.c3]), partitions(p0)
      limit(1000000), offset(nil), is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.c2], [t1.c3], [t1.c1], [t1.__pk_increment]), range(0,MIN,MIN,MIN ; MAX,MAX,MAX,MAX), 
      range_cond([t1.c2 >= 0])
explain basic select /*+parallel(auto)*/ * from t1 order by c2 limit 1000000;
Query Plan
============================
|ID|OPERATOR       |NAME   |
----------------------------
|0 |TABLE FULL SCAN|t1(idx)|
============================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      limit(1000000), offset(nil), is_index_back=false, is_global_index=false, 
      range_key([t1.c2], [t1.c3], [t1.c1], [t1.__pk_increment]), range(MIN,MIN,MIN,MIN ; MAX,MAX,MAX,MAX)always true

explain basic select /*+parallel(auto)*/ * from tp1 limit 1000000;
Query Plan
=======================================
|ID|OPERATOR                 |NAME    |
---------------------------------------
|0 |LIMIT                    |        |
|1 |└─PX COORDINATOR         |        |
|2 |  └─EXCHANGE OUT DISTR   |:EX10000|
|3 |    └─LIMIT              |        |
|4 |      └─PX BLOCK ITERATOR|        |
|5 |        └─TABLE FULL SCAN|tp1     |
=======================================
Outputs & filters:
-------------------------------------
  0 - output([tp1.c1], [tp1.c2], [tp1.c3]), filter(nil), rowset=256
      limit(1000000), offset(nil)
  1 - output([tp1.c1], [tp1.c2], [tp1.c3]), filter(nil), rowset=256
  2 - output([tp1.c1], [tp1.c2], [tp1.c3]), filter(nil), rowset=256
      dop=3
  3 - output([tp1.c1], [tp1.c2], [tp1.c3]), filter(nil), rowset=256
      limit(1000000), offset(nil)
  4 - output([tp1.c1], [tp1.c2], [tp1.c3]), filter(nil), rowset=256
  5 - output([tp1.c1], [tp1.c2], [tp1.c3]), filter(nil), rowset=256
      access([tp1.c1], [tp1.c2], [tp1.c3]), partitions(p[0-9])
      limit(1000000), offset(nil), is_index_back=false, is_global_index=false, 
      range_key([tp1.__pk_increment]), range(MIN ; MAX)always true

drop table t1;
drop table tp1;
set parallel_min_scan_time_threshold = 1000;
set parallel_degree_limit = 0;
