result_format: 4
# ◆ 准备测试用户
drop user if exists testuser;
drop database if exists testuser_db;
create user 'testuser' identified by 'testuser';
CREATE DATABASE IF NOT EXISTS  testuser_db;
grant all on *.* to testuser WITH GRANT OPTION;


## CURDATE
drop procedure pro1;/
CREATE procedure pro1 (out p1 date,out p2 date)
begin
  #set p1 = CURDATE;
  set p2 = CURDATE();
end;
/
call pro1(@v1,@v2);/
select @v1,@v2;/
select CURDATE;/
select CURDATE();/
