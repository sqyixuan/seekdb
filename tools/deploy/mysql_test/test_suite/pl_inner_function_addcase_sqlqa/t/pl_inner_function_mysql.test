#owner: xinning.lf
#owner group: 技术部-SQL-存储过程
#description: 【PL编译报错SQLCODE函数不存在】跟进补充case
#tags: pl
#author:whh01047778

--result_format 4
connection default;

--echo # ◆ 准备测试用户
--disable_warnings
drop user if exists testuser;
drop database if exists testuser_db;
create user 'testuser' identified by 'testuser';
CREATE DATABASE IF NOT EXISTS  testuser_db;
grant all on *.* to testuser WITH GRANT OPTION;
--enable_warnings

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$obmysql_ms0,testuser,testuser,testuser_db,$obmysql_port);
connection conn1;

--disable_result_log
delimiter /;
## CURDATE
--error 0,1305
drop procedure pro1;/
CREATE procedure pro1 (out p1 date,out p2 date)
begin
  #set p1 = CURDATE;
  set p2 = CURDATE();
end;
/

call pro1(@v1,@v2);/
select @v1,@v2;/

--error 1054
select CURDATE;/
select CURDATE();/

