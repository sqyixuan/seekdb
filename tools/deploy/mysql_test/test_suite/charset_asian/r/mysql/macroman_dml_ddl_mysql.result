### SELECT id, a, LAST_DAY(CURRENT_DATE) AS last_day_of_month FROM db2.t2;
### SELECT id, a, YEAR(CURRENT_DATE) AS year, DATE(CURRENT_DATE) AS date FROM db2.t2;
########################## insert ########################
DROP table db2.t2;
CREATE TABLE db2.t2 (
    a char(10)
)DEFAULT CHARACTER SET = macroman;

DROP PROCEDURE build_macroman_table;

create procedure build_macroman_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_macroman_table();
/

INSERT INTO T2(a) VALUES (_macroman 0x878A);
INSERT INTO T2(a) VALUES (_macroman 0x9353);
INSERT INTO T2(a) VALUES (_macroman 0x9373);
