purge recyclebin;
result_format: 4
#Environmental cleaning
###A√§√©¬ß¬£A√§√©¬ß¬£A√§√©¬ß¬£
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##A√§√©¬ß¬£A√§√©¬ß¬£A√§√©¬ß¬£A√§√©¬ß¬£A√§√©¬ß¬£A√§√©¬ß¬£
set names 'macroman';
set character_set_database = 'macroman';
set character_set_server = 'macroman';
set character_set_results = 'utf8mb4';
show character set where Charset = 'macroman';
Charset	Description	Default collation	Maxlen
macroman	Mac West European	macroman_general_ci	1
show variables like 'character_set%';
Variable_name	Value
character_sets_dir	
character_set_client	macroman
character_set_connection	macroman
character_set_database	macroman
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	macroman
character_set_system	utf8mb4
########################## select ########################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET macroman;
use db1;
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(10)
)DEFAULT CHARACTER SET = macroman;

DROP PROCEDURE build_macroman_table;

create procedure build_macroman_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_macroman_table();
/
INSERT INTO T2(a) VALUES (_macroman 0x878A);
INSERT INTO T2(a) VALUES (_macroman 0x9353);
INSERT INTO T2(a) VALUES (_macroman 0x9373);
INSERT INTO T2(a) VALUES (0x878A);
INSERT INTO T2(a) VALUES (0x9353);
INSERT INTO T2(a) VALUES (0x9373);
INSERT INTO T2(a) VALUES (0xb1);
INSERT INTO T2(a) VALUES (0xb2);
INSERT INTO T2(a) VALUES (0xb3);
INSERT INTO T2(a) VALUES (0xF1F2);

select * from t2 order by id;
select id,a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t2 order by id;

select ascii(a)||HEX(a)||LEFT(HEX(a), 2)||UNHEX(HEX(a)) from db1.t2 order by id;

##with as
with with_as_name as(
    select id,a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t2
)
select * from with_as_name order by with_as_name.id;

SELECT CONCAT('Hello, ', 'World!')as 'hw';
select CAST('balance' AS CHAR);
select DISTINCT a from db1.t2 order by 1;
select DISTINCT a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t2 order by 1,2;

DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET macroman;
use db1;
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = macroman;
DROP PROCEDURE build_macroman_table;

create procedure build_macroman_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_macroman_table();
/

select * from t2 order by id;
select id,a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t2 order by id;

select t2222.* from t2 t2222 order by id;
DROP DATABASE db2;
CREATE DATABASE db2 CHARACTER SET macroman;
use db2;

DROP table db2.t2;
CREATE TABLE db2.t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = macroman;

DROP PROCEDURE build_macroman_table;

create procedure build_macroman_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_macroman_table();
/

select * from db2.t2 order by id;
select * from db1.t2 order by id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 order by t1.id and t1.a;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id order by t1.id;
select count(*) from db1.t2,db2.t2 where convert(db1.t2.a using macroman)=db2.t2.a;
+----------+
| count(*) |
+----------+
|      291 |
+----------+
select count(*) from db1.t2,db2.t2 where convert(db1.t2.a using UTF8MB4)=db2.t2.a;
+----------+
| count(*) |
+----------+
|      277 |
+----------+
select count(*) from db1.t2,db2.t2 where convert(db1.t2.a using UTF8)=db2.t2.a;
+----------+
| count(*) |
+----------+
|      277 |
+----------+
select count(*) from db1.t2,db2.t2 where convert(db1.t2.a using GBK)=db2.t2.a;
ERROR HY000: Illegal mix of collations (gbk_chinese_ci,IMPLICIT), (macroman_general_ci,IMPLICIT)

