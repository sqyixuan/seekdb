INSERT INTO T2(a) VALUES (0xb1);
INSERT INTO T2(a) VALUES (0xb2);
INSERT INTO T2(a) VALUES (0xb3);
INSERT INTO T2(a) VALUES (0xF1F2);
select * from db2.t2 order by a;
INSERT INTO db2.t2  (select a from db2.t2 order by a);

select * from db2.t2 order by a;
CREATE OR REPLACE VIEW db2.v_t2 AS
SELECT a FROM db2.t2;
INSERT INTO db2.v_t2 (a) VALUES ('x');

SELECT * FROM db2.v_t2;
########################## update ########################
update db2.t2 set a = 'a' where a='a';
select * from db2.t2 where a='a' order by a;
+------+
| a    |
+------+
| a    |
| a    |
| a    |
| a    |
| a    |
| a    |
| a    |
| a    |
+------+

update db2.t2 set a = 'A' where a='a';
select * from db2.t2 where a='A' order by a;
+------+
| a    |
+------+
| A    |
| A    |
| A    |
| A    |
| A    |
| A    |
| A    |
| A    |
+------+

update db2.t2 set a = ']' where a='{';
select * from db2.t2 where a=']' order by a;
+------+
| a    |
+------+
| ]    |
| ]    |
| ]    |
| ]    |
+------+

update db2.t2 t1 set a=(select a from db1.t2 t2 where t1.a=t2.a) where exists(select 1 from db1.t2 where  t1.a=t2.a);
ERROR 21000: Subquery returns more than 1 row

########################## delete ########################
INSERT INTO db2.t2 (a) VALUES ('X');
INSERT INTO db2.t2 (a) VALUES ('Y');
INSERT INTO db2.t2 (a) VALUES ('Z');
INSERT INTO db2.t2 (a) VALUES ('Y');

DELETE FROM db2.t2 WHERE a = 'W';
DELETE FROM db2.t2 WHERE a = 'Z';
DELETE FROM db2.t2 WHERE a = 'Y';
DELETE FROM db2.t2;
TRUNCATE TABLE db2.t2;

########################## DDL ########################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET macroman;
use db1;
DROP table db1.t1;
CREATE TABLE db1.t1 (
    id INT AUTO_INCREMENT PRIMARY KEY COMMENT 'id_',
    a char(10) COMMENT 'a_'
)DEFAULT CHARACTER SET = macroman;

DROP PROCEDURE build_macroman_table;

create procedure build_macroman_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_macroman_table();
/

