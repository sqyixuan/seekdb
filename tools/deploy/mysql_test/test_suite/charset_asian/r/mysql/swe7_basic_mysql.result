-------------------test charset function----------------------
select weight_string(_swe7 'a' collate swe7_swedish_ci), weight_string(_swe7 'A' collate swe7_swedish_ci);
+--------------------------------------------------+--------------------------------------------------+
| weight_string(_swe7 'a' collate swe7_swedish_ci) | weight_string(_swe7 'A' collate swe7_swedish_ci) |
+--------------------------------------------------+--------------------------------------------------+
| A                                                | A                                                |
+--------------------------------------------------+--------------------------------------------------+
select weight_string(_swe7 'a' collate swe7_bin), weight_string(_swe7 'A' collate swe7_bin);
+-------------------------------------------+-------------------------------------------+
| weight_string(_swe7 'a' collate swe7_bin) | weight_string(_swe7 'A' collate swe7_bin) |
+-------------------------------------------+-------------------------------------------+
| a                                         | A                                         |
+-------------------------------------------+-------------------------------------------+

set collation_connection = swe7_swedish_ci;
select 'abc' like 'ABC';
+------------------+
| 'abc' like 'ABC' |
+------------------+
|                1 |
+------------------+
select instr('XABCdfdabc','abc');
+---------------------------+
| instr('XABCdfdabc','abc') |
+---------------------------+
|                         2 |
+---------------------------+
set collation_connection = swe7_bin;
select 'abc' like 'ABC';
+------------------+
| 'abc' like 'ABC' |
+------------------+
|                0 |
+------------------+
select instr('XABCdfdabc','abc');
+---------------------------+
| instr('XABCdfdabc','abc') |
+---------------------------+
|                         8 |
+---------------------------+

