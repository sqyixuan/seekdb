### SELECT id, a, ADDDATE(CURRENT_DATE, INTERVAL 1 DAY) AS next_day FROM db2.t2;
### SELECT id, a, LAST_DAY(CURRENT_DATE) AS last_day_of_month FROM db2.t2;
### SELECT id, a, YEAR(CURRENT_DATE) AS year, DATE(CURRENT_DATE) AS date FROM db2.t2;
########################## insert ########################
DROP table db2.t2;
CREATE TABLE db2.t2 (
    a char(10)
)DEFAULT CHARACTER SET = cp850;

DROP PROCEDURE build_cp850_table;

create procedure build_cp850_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_cp850_table();
/

INSERT INTO T2(a) VALUES (_cp850 0x878A);
INSERT INTO T2(a) VALUES (_cp850 0x9353);
INSERT INTO T2(a) VALUES (_cp850 0x9373);
INSERT INTO T2(a) VALUES (0x878A);
INSERT INTO T2(a) VALUES (0x9353);
INSERT INTO T2(a) VALUES (0x9373);
INSERT INTO T2(a) VALUES (0xb1);
INSERT INTO T2(a) VALUES (0xb2);
INSERT INTO T2(a) VALUES (0xb3);
INSERT INTO T2(a) VALUES (0xF1F2);
select * from db2.t2 order by a;
INSERT INTO db2.t2  (select a from db2.t2 order by a);

select * from db2.t2 order by a;
CREATE OR REPLACE VIEW db2.v_t2 AS
SELECT a FROM db2.t2;
INSERT INTO db2.v_t2 (a) VALUES ('x');

SELECT * FROM db2.v_t2;
########################## update ########################
update db2.t2 set a = 'a' where a='a';
select * from db2.t2 where a='a' order by a;
+------+
| a    |
+------+
| a    |
| a    |
| a    |
| a    |
+------+

update db2.t2 set a = 'A' where a='a';
select * from db2.t2 where a='A' order by a;
+------+
| a    |
+------+
| A    |
| A    |
| A    |
| A    |
+------+

update db2.t2 set a = ']' where a='{';
select * from db2.t2 where a=']' order by a;
+------+
| a    |
+------+
| ]    |
| ]    |
| ]    |
| ]    |
+------+

update db2.t2 t1 set a=(select a from db1.t2 t2 where t1.a=t2.a) where exists(select 1 from db1.t2 where  t1.a=t2.a);
