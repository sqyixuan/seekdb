purge recyclebin;
result_format: 4
#Environmental cleaning
###??????
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##  hp8
##????????????
set names 'hp8' COLLATE hp8_english_ci;
set character_set_database = 'hp8';
set character_set_server = 'hp8';
set character_set_results = 'utf8mb4';
show character set where Charset = 'hp8';
Charset	Description	Default collation	Maxlen
hp8	HP West European	hp8_english_ci	1
show variables like '%character%';
Variable_name	Value
character_sets_dir	
character_set_client	hp8
character_set_connection	hp8
character_set_database	hp8
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	hp8
character_set_system	utf8mb4
show variables like'%collation%';
Variable_name	Value
collation_connection	hp8_english_ci
collation_database	hp8_english_ci
collation_server	hp8_english_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
# ????????????????????
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET hp8;
use db1;

drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100));

DROP PROCEDURE build_hp8_table;

create procedure build_hp8_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_hp8_table();
/

