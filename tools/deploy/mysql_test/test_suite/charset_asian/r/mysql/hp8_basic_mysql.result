set collation_connection = hp8_english_ci;
select 'abc' like 'ABC';
+------------------+
| 'abc' like 'ABC' |
+------------------+
|                1 |
+------------------+
select instr('XABCdfdabc','abc');
+---------------------------+
| instr('XABCdfdabc','abc') |
+---------------------------+
|                         2 |
+---------------------------+
set collation_connection = hp8_bin;
select 'abc' like 'ABC';
+------------------+
| 'abc' like 'ABC' |
+------------------+
|                0 |
+------------------+
select instr('XABCdfdabc','abc');
+---------------------------+
| instr('XABCdfdabc','abc') |
+---------------------------+
|                         8 |
+---------------------------+

