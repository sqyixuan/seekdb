set names hp8;
select collation(concat(convert("abc" using gb18030_2022), convert("cde" using hp8))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (gb18030_2022_chinese_ci,IMPLICIT), (hp8_english_ci,IMPLICIT)
