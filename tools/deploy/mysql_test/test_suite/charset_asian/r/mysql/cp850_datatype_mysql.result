############################# ???? #############################
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    numeric_column DECIMAL(10, 2) NOT NULL,
    float_column FLOAT,
    double_column DOUBLE
)DEFAULT CHARACTER SET = cp850;

DROP PROCEDURE build_cp850_table;

create procedure build_cp850_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t2(numeric_column,float_column,double_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_cp850_table();
/
ERROR HY000: Incorrect decimal value for column 'numeric_column' at row 1
select * from t2 order by id;
+----+----------------+--------------+---------------+
| id | numeric_column | float_column | double_column |
+----+----------------+--------------+---------------+
+----+----------------+--------------+---------------+
select t2.*,ascii(t2.float_column),char(ascii(t2.float_column)) from t2 order by id;
+----+----------------+--------------+---------------+------------------------+------------------------------+
| id | numeric_column | float_column | double_column | ascii(t2.float_column) | char(ascii(t2.float_column)) |
+----+----------------+--------------+---------------+------------------------+------------------------------+
+----+----------------+--------------+---------------+------------------------+------------------------------+

DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    BOOL_column BOOL ,
    SMALLINT_column SMALLINT,
    BIT_column BIT
)DEFAULT CHARACTER SET = cp850;

DROP PROCEDURE build_cp850_table;

create procedure build_cp850_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t2(BOOL_column,SMALLINT_column,BIT_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_cp850_table();
/
ERROR HY000: Incorrect integer value for column 'BOOL_column' at row 1
select * from t2 order by id;
+----+-------------+-----------------+------------+
| id | BOOL_column | SMALLINT_column | BIT_column |
+----+-------------+-----------------+------------+
+----+-------------+-----------------+------------+
select t2.*,ascii(t2.BOOL_column),char(ascii(t2.SMALLINT_column)),char(ascii(t2.BIT_column)) from t2 order by id;
+----+-------------+-----------------+------------+-----------------------+---------------------------------+----------------------------+
| id | BOOL_column | SMALLINT_column | BIT_column | ascii(t2.BOOL_column) | char(ascii(t2.SMALLINT_column)) | char(ascii(t2.BIT_column)) |
+----+-------------+-----------------+------------+-----------------------+---------------------------------+----------------------------+
+----+-------------+-----------------+------------+-----------------------+---------------------------------+----------------------------+

