DROP PROCEDURE create_cp850;
CREATE PROCEDURE create_cp850()
BEGIN
  DECLARE i INT DEFAULT 0;
  DECLARE max_value INT DEFAULT 256;

  WHILE i <= max_value DO
    select char(i);
    SET i = i + 1;
  END WHILE;
END;
//

call create_cp850();
