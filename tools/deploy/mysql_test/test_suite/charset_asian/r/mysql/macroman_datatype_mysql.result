DROP table t3;
CREATE TABLE t3 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    date_column DATE,
    timestamp_column TIMESTAMP,
    interval_value VARCHAR(255),
    interval_unit ENUM('seconds', 'minutes', 'hours', 'days', 'weeks', 'months', 'years')
) DEFAULT CHARACTER SET = macroman;
