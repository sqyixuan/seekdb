### ?????? macroman
use db1;
drop table t11;
ERROR 42S02: Unknown table 'db1.t11'
CREATE TABLE t11 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(10),
    nchar_column NATIONAL CHAR(10),
    varchar_column VARCHAR(10),
    nvarchar_column NATIONAL VARCHAR(10),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = utf8mb4;

DROP PROCEDURE build_macroman_table;

create procedure build_macroman_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t11(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_macroman_table();
/

insert into t11(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (_macroman 0x878A,_macroman 0x878A,_macroman 0x878A,_macroman 0x878A,_macroman 0x878A,_macroman 0x878A);
