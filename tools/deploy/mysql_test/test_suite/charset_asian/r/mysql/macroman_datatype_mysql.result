drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    BINARY_column BINARY(1),
    BINARY_column2 BINARY(2),
    VARBINARY_column VARBINARY(1),
    VARBINARY_column2 VARBINARY(1),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = macroman;

DROP PROCEDURE build_macroman_table;

create procedure build_macroman_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(BINARY_column,BINARY_column2,VARBINARY_column,VARBINARY_column2,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_macroman_table();
/

insert into t1(BINARY_column,BINARY_column2,VARBINARY_column,VARBINARY_column2,text_column,blob_column) values (_macroman 0x878A,_macroman 0x878A,_macroman 0x878A,_macroman 0x878A,_macroman 0x878A,_macroman 0x878A);
ERROR 22001: Data too long for column 'BINARY_column' at row 1
insert into t1(BINARY_column,BINARY_column2,VARBINARY_column,VARBINARY_column2,text_column,blob_column) values (0x9373,0x9373,0x9373,0x9373,0x9373,0x9373);
ERROR 22001: Data too long for column 'BINARY_column' at row 1
insert into t1(BINARY_column,BINARY_column2,VARBINARY_column,VARBINARY_column2,text_column,blob_column) values (0xF1F2,0xF1F2,0xF1F2,0xF1F2,0xF1F2,0xF1F2);
