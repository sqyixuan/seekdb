purge recyclebin;
result_format: 4
#Environmental cleaning
###??????
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##  macroman
##????????????
set names 'macroman' COLLATE macroman_general_ci;
set character_set_database = 'macroman';
set character_set_server = 'macroman';
set character_set_results = 'utf8mb4';
show character set where Charset = 'macroman';
Charset	Description	Default collation	Maxlen
macroman	Mac West European	macroman_general_ci	1
show variables like '%character%';
Variable_name	Value
character_sets_dir	
character_set_client	macroman
character_set_connection	macroman
character_set_database	macroman
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	macroman
character_set_system	utf8mb4
show variables like'%collation%';
Variable_name	Value
collation_connection	macroman_general_ci
collation_database	macroman_general_ci
collation_server	macroman_general_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
# ????????????????????
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET macroman;
use db1;

drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100));

DROP PROCEDURE build_macroman_table;

create procedure build_macroman_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_macroman_table();
/

