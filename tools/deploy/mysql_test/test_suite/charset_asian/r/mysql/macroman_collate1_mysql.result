DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET macroman;
use db1;

drop table macroman_table;
drop procedure build_macroman_table;
drop table macroman_bin_table;
drop procedure build_macroman_bin_table;

create table macroman_table(c1 char(3) charset macroman collate macroman_general_ci);
create table macroman_bin_table(c1 char(3) charset macroman collate macroman_bin);

DROP PROCEDURE build_macroman_table;

create procedure build_macroman_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into macroman_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_macroman_table();
/

