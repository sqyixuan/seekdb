| c0   | c0 |
+------+----+
| A    | a  |
| a    | a  |
+------+----+
alter table t1 add constraint foreignconst1 foreign key (c0) references t2(c0);
select p.c0,e.c0 from t2 e inner join t1 p on e.c0 = p.c0 order by p.c0;
+------+----+
| c0   | c0 |
+------+----+
| A    | a  |
| a    | a  |
+------+----+
drop table t1;
drop table t2;

drop table test_macroman_bak;
create table test_macroman_bak(c0 char(100) collate macroman_general_ci,c1 char(100) collate utf16le_bin,c2 char(100) collate macroman_general_ci,c3 char(100) collate macroman_bin,c4 char(100) collate utf8mb4_unicode_ci,c5 char(100) collate macroman_general_ci,c6 char(100) collate utf16le_bin,sal int,id int) character set macroman;

drop procedure test_macroman_bak_ascii_pro;

create procedure test_macroman_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_macroman_bak values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
/
call test_macroman_bak_ascii_pro();
/
