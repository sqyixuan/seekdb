drop table test_macroman_bak;
create table test_macroman_bak(c0 varchar(100) collate utf16le_general_ci,c1 varchar(100) collate utf16le_bin,c2 varchar(100) collate macroman_general_ci,c3 varchar(100) collate macroman_bin,c4 varchar(100) collate utf8mb4_unicode_ci,c5 varchar(100) collate utf16le_general_ci,c6 varchar(100) collate utf16le_bin,sal int,id int) character set macroman;

drop procedure test_macroman_bak_ascii_pro;

create procedure test_macroman_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_macroman_bak values(char(i),char(i),char(i),char(i),char(i),char(i),char(i),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call test_macroman_bak_ascii_pro();
/
