drop table test_macroman_bak;

CREATE TABLE test_macroman_bak(
    c0 TEXT COLLATE utf16le_general_ci default null,
    c1 TEXT COLLATE utf16le_bin default null,
    c2 TEXT COLLATE macroman_general_ci default null,
    c3 TEXT COLLATE macroman_bin default null,
    c4 TEXT COLLATE utf8mb4_unicode_ci default null,
    c5 TEXT COLLATE utf16le_general_ci default null,
    c6 TEXT COLLATE utf16le_bin default null,
    sal INT default null,
    id INT default null
) CHARACTER SET macroman;
INSERT INTO test_macroman_bak (c0) VALUES (CONVERT(CHAR(255) USING macroman));
INSERT INTO test_macroman_bak (c1) VALUES (CONVERT(CHAR(255) USING macroman));
INSERT INTO test_macroman_bak (c2) VALUES (CONVERT(CHAR(255) USING macroman));
INSERT INTO test_macroman_bak (c3) VALUES (CONVERT(CHAR(255) USING macroman));
INSERT INTO test_macroman_bak (c4) VALUES (CONVERT(CHAR(255) USING macroman));
INSERT INTO test_macroman_bak (c5) VALUES (CONVERT(CHAR(255) USING macroman));
INSERT INTO test_macroman_bak (c6) VALUES (CONVERT(CHAR(255) USING macroman));

