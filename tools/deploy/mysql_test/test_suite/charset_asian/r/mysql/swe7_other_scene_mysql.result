DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET swe7;
use db1;

drop table t1;
ERROR 42S02: Unknown table 'db1.t1'
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(10),
    nchar_column NATIONAL CHAR(10),
    varchar_column VARCHAR(10),
    nvarchar_column NATIONAL VARCHAR(10),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = swe7;

