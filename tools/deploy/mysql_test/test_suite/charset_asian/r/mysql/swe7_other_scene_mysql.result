DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(255) CHARACTER SET swe7,
    nchar_column NATIONAL CHAR(255),
    varchar_column VARCHAR(255) CHARACTER SET swe7,
    nvarchar_column NATIONAL VARCHAR(255),
    text_column TEXT CHARACTER SET swe7,
    blob_column BLOB
) DEFAULT CHARACTER SET = swe7;

INSERT INTO t1 (char_column, nchar_column, varchar_column, nvarchar_column, text_column, blob_column)
VALUES (
    REPEAT(_swe7 0x8A, 255),
    REPEAT(_utf8mb4 0x8A, 255),
    REPEAT(_swe7 0x8A, 255),
    REPEAT(_utf8mb4 0x8A, 255),
    REPEAT(_swe7 0x8A, 255),
    REPEAT(0xF1, 255)
);
ERROR HY000: Invalid utf8mb4 character string: '8A'

SELECT * FROM t1;
