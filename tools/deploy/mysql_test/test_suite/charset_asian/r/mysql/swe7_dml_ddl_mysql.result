db1	CREATE DATABASE ?db1? DEFAULT CHARACTER SET = ascii REPLICA_NUM = 1
alter DATABASE db1 CHARACTER SET swe7;
show create database db1;
Database	Create Database
db1	CREATE DATABASE ?db1? DEFAULT CHARACTER SET = swe7 REPLICA_NUM = 1

DROP table db1.t1;
CREATE TABLE db1.t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(10)
)DEFAULT CHARACTER SET = swe7;

