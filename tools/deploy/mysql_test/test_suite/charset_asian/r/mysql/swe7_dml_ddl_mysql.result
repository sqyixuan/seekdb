DROP DATABASE db2;
CREATE DATABASE db2 CHARACTER SET swe7;
use db2;

DROP table db2.t2;
CREATE TABLE db2.t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = swe7;

