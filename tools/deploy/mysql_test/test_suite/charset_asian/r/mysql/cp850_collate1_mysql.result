DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET cp850;
use db1;

drop table cp850_table;
drop procedure build_cp850_table;
drop table cp850_bin_table;
drop procedure build_cp850_bin_table;

create table cp850_table(c1 char(3) charset cp850 collate cp850_general_ci);
create table cp850_bin_table(c1 char(3) charset cp850 collate cp850_bin);

DROP PROCEDURE build_cp850_table;

create procedure build_cp850_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into cp850_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_cp850_table();
/

INSERT INTO cp850_table(c1) VALUES (_cp850 0x878A);
