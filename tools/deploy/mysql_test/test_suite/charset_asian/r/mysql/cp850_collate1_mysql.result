drop table test_cp850_bak;
create table test_cp850_bak(c0 varchar(100),c1 varchar(100),full varchar(100) collate cp850_bin generated always as(concat(c0,c1)) ) character set cp850;

drop procedure build_cp850_table;

create procedure build_cp850_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_cp850_bak(c0,c1) values(unhex(hex(i)),unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_cp850_table();
/
