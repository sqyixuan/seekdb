drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    BINARY_column BINARY(1),
    BINARY_column2 BINARY(2),
    VARBINARY_column VARBINARY(1),
    VARBINARY_column2 VARBINARY(1),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = swe7;

