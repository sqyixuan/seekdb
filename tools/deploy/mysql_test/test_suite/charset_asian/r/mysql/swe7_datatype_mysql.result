SELECT DATE('2012-12-12') + INTERVAL 123 DAY;
+---------------------------------------+
| DATE('2012-12-12') + INTERVAL 123 DAY |
+---------------------------------------+
| 2013-04-14                            |
+---------------------------------------+
SELECT date_column,(date_column + INTERVAL 123 DAY)as "new_date_column" from t3;
+-------------+-----------------+
| date_column | new_date_column |
+-------------+-----------------+
| 2023-06-07  | 2023-10-08      |
| 2023-06-07  | 2023-10-08      |
+-------------+-----------------+
select * from t3 order by id;
+----+-------------+---------------------+----------------+---------------+
| id | date_column | timestamp_column    | interval_value | interval_unit |
+----+-------------+---------------------+----------------+---------------+
|  1 | 2023-06-07  | 2023-06-07 14:30:00 | 15             | days          |
|  2 | 2023-06-07  | 2023-06-07 14:30:00 | 15             | days          |
+----+-------------+---------------------+----------------+---------------+
select length(id),length(date_column),length(timestamp_column),length(interval_value),length(12) from t3 order by id;
+------------+---------------------+--------------------------+------------------------+------------+
| length(id) | length(date_column) | length(timestamp_column) | length(interval_value) | length(12) |
+------------+---------------------+--------------------------+------------------------+------------+
|          1 |                  10 |                       19 |                      2 |          2 |
|          1 |                  10 |                       19 |                      2 |          2 |
+------------+---------------------+--------------------------+------------------------+------------+

