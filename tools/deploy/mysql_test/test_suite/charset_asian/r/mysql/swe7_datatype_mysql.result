purge recyclebin;
result_format: 4
#Environmental cleaning
###??????
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##????????????
set names 'swe7';
set character_set_database = 'swe7';
set character_set_server = 'swe7';
set character_set_results = 'utf8mb4';
show character set where Charset = 'swe7';
Charset	Description	Default collation	Maxlen
swe7	7bit West European	swe7_swedish_ci	1
show variables like 'character_set%';
Variable_name	Value
character_sets_dir	
character_set_client	swe7
character_set_connection	swe7
character_set_database	swe7
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	swe7
character_set_system	utf8mb4
############################# ???? #############################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET swe7;
use db1;

drop table t1;
CREATE TABLE t1 (char_column CHAR(1))DEFAULT CHARACTER SET = swe7;
insert into t1 values(unhex(hex(200)));
select * from t1 ;
+-------------+
| char_column |
+-------------+
| ?           |
+-------------+

drop table t1;
CREATE TABLE t1 (char_column NATIONAL CHAR(1))DEFAULT CHARACTER SET = swe7;
insert into t1 values(unhex(hex(200)));
ERROR HY000: Incorrect string value
select * from t1 ;
+-------------+
| char_column |
+-------------+
+-------------+

drop table t1;
CREATE TABLE t1 (char_column VARCHAR(1))DEFAULT CHARACTER SET = swe7;
insert into t1 values(unhex(hex(200)));
select * from t1 ;
+-------------+
| char_column |
+-------------+
| ?           |
+-------------+

drop table t1;
CREATE TABLE t1 (char_column NATIONAL VARCHAR(1))DEFAULT CHARACTER SET = swe7;
insert into t1 values(unhex(hex(200)));
ERROR HY000: Incorrect string value
select * from t1 ;
+-------------+
| char_column |
+-------------+
+-------------+

drop table t1;
CREATE TABLE t1 (char_column TEXT)DEFAULT CHARACTER SET = swe7;
insert into t1 values(unhex(hex(200)));
select * from t1 ;
+-------------+
| char_column |
+-------------+
| ?           |
+-------------+

drop table t1;
CREATE TABLE t1 (char_column BLOB)DEFAULT CHARACTER SET = swe7;
insert into t1 values(unhex(hex(200)));
select * from t1 ;
+-------------+
| char_column |
+-------------+
| ╚            |
+-------------+

drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(1),
    nchar_column NATIONAL CHAR(1),
    varchar_column VARCHAR(1),
    nvarchar_column NATIONAL VARCHAR(1),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = swe7;

