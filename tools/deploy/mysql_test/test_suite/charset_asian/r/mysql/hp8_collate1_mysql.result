drop table test_hp8_bak;
create table test_hp8_bak(c0 varchar(100),c1 varchar(100),full varchar(100) collate hp8_bin generated always as(concat(c0,c1)) ) character set hp8;

drop procedure build_hp8_table;

create procedure build_hp8_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_hp8_bak(c0,c1) values(unhex(hex(i)),unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_hp8_table();
/
