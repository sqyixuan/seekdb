drop table test_hp8_bak;

CREATE TABLE test_hp8_bak(
    c0 TEXT COLLATE utf16le_general_ci,
    c1 TEXT COLLATE utf16le_bin,
    c2 TEXT COLLATE hp8_english_ci,
    c3 TEXT COLLATE hp8_bin,
    c4 TEXT COLLATE utf8mb4_unicode_ci,
    c5 TEXT COLLATE utf16le_general_ci,
    c6 TEXT COLLATE utf16le_bin,
    sal INT,
    id INT
) CHARACTER SET hp8;

drop procedure test_hp8_bak_ascii_pro;

CREATE PROCEDURE test_hp8_bak_ascii_pro()
BEGIN
  DECLARE i INT DEFAULT 0;
  WHILE i < 255 DO
    INSERT INTO test_hp8_bak(c0, c1, c2, c3, c4, c5, c6, sal, id)
    VALUES(CONVERT(CHAR(i) USING hp8), CONVERT(CHAR(i) USING hp8), CONVERT(CHAR(i) USING hp8), CONVERT(CHAR(i) USING hp8), CONVERT(CHAR(i) USING hp8), CONVERT(CHAR(i) USING hp8), CONVERT(CHAR(i) USING hp8), i, i);
    SET i = i + 1;
  END WHILE;
  COMMIT;
END /

CALL test_hp8_bak_ascii_pro();
