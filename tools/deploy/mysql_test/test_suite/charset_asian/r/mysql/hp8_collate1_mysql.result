drop table test_hp8_bak;
create table test_hp8_bak(c0 varchar(100) collate utf16le_general_ci,c1 varchar(100) collate utf16le_bin,c2 varchar(100) collate hp8_english_ci,c3 varchar(100) collate hp8_bin,c4 varchar(100) collate utf8mb4_unicode_ci,c5 varchar(100) collate utf16le_general_ci,c6 varchar(100) collate utf16le_bin,sal int,id int) character set hp8;

drop procedure test_hp8_bak_ascii_pro;

create procedure test_hp8_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_hp8_bak values(char(i),char(i),char(i),char(i),char(i),char(i),char(i),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call test_hp8_bak_ascii_pro();
/
