DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET hp8;
use db1;

drop table hp8_table;
drop procedure build_hp8_table;
drop table hp8_bin_table;
drop procedure build_hp8_bin_table;

create table hp8_table(c1 char(3) charset hp8 collate hp8_english_ci);
create table hp8_bin_table(c1 char(3) charset hp8 collate hp8_bin);

DROP PROCEDURE build_hp8_table;

create procedure build_hp8_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into hp8_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_hp8_table();
/

INSERT INTO hp8_table(c1) VALUES (_hp8 0x878A);
