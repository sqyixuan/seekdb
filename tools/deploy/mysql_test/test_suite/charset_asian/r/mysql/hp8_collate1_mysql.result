CREATE TABLE test_hp8_bak(
    c0 TEXT COLLATE utf16le_general_ci default null,
    c1 TEXT COLLATE utf16le_bin default null,
    c2 TEXT COLLATE hp8_english_ci default null,
    c3 TEXT COLLATE hp8_bin default null,
    c4 TEXT COLLATE utf8mb4_unicode_ci default null,
    c5 TEXT COLLATE utf16le_general_ci default null,
    c6 TEXT COLLATE utf16le_bin default null,
    sal INT default null,
    id INT default null
) CHARACTER SET hp8;
