--error 0,1305
drop procedure test_cp850_bak_ascii_pro;

delimiter /;
CREATE PROCEDURE test_cp850_bak_ascii_pro()
BEGIN
  DECLARE i INT DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO test_cp850_bak(c0, c1, c2, c3, c4, c5, c6, sal, id)
    VALUES(CONVERT(CHAR(i) USING cp850), CONVERT(CHAR(i) USING cp850), CONVERT(CHAR(i) USING cp850), CONVERT(CHAR(i) USING cp850), CONVERT(CHAR(i) USING cp850), CONVERT(CHAR(i) USING cp850), CONVERT(CHAR(i) USING cp850), i, i);
    SET i = i + 1;
  END WHILE;
  COMMIT;
END /
DELIMITER ;/

