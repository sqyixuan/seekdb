    text_column = @longSjisString,
    blob_column = @longBlobData;
SELECT * FROM t1;

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

CREATE TABLE t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(255) CHARACTER SET swe7,
    nchar_column NATIONAL CHAR(255),
    varchar_column VARCHAR(255) CHARACTER SET swe7,
    nvarchar_column NATIONAL VARCHAR(255),
    text_column TEXT CHARACTER SET swe7,
    blob_column BLOB
) DEFAULT CHARACTER SET = swe7;

