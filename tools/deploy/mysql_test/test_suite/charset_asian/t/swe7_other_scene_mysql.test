drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(10),
    nchar_column NATIONAL CHAR(10),
    varchar_column VARCHAR(10),
    nvarchar_column NATIONAL VARCHAR(10),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = swe7;

let $i=0;
while($i<128)
{
    eval insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex($i)),unhex(hex($i)),unhex(hex($i)),unhex(hex($i)),unhex(hex($i)),unhex(hex($i)));
    inc $i;
}

select * from t1 order by id;

