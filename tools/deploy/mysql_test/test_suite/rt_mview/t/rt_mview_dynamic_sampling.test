--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test for rt_mview dynamic sampling
#tags: mv_optimizer,mview

--result_format 4
--disable_warnings
--error 0, 1146
drop materialized view log on t1;
drop table if exists t1;
--error 0, 9757
drop materialized view t1_rt_mv1;
--enable_warnings

create table t1(c1 int primary key, c2 int, c3 int, c4 int);
insert into t1 values(1,1,1,1);
create materialized view log on t1 with primary key, rowid, sequence (c2, c3) including new values;

create materialized view t1_rt_mv1
refresh fast on demand
enable on query computation
disable query rewrite
as
select a.c1 as a_c1, b.c1 as b_c1 from t1 a, t1 b where a.c2 = b.c3;

--disable_query_log
connect (con1,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);
connection con1;
alter system flush kvcache;
sleep 1;
connection default;
--enable_query_log
--replace_regex /__mv_container_[0-9]{6}/__mv_container_xxxxxx/
explain extended_noaddr select /*+no_mv_rewrite dynamic_sampling(1)*/ * from t1_rt_mv1;

insert into t1 values(2,1,1,1);
insert into t1 values(3,1,1,1);

--disable_query_log
connection con1;
alter system flush kvcache;
sleep 1;
connection default;
--enable_query_log
--replace_regex /__mv_container_[0-9]{6}/__mv_container_xxxxxx/
explain extended_noaddr select /*+no_mv_rewrite dynamic_sampling(1)*/ * from t1_rt_mv1;

call DBMS_MVIEW.REFRESH('t1_rt_mv1', 'f');

--disable_query_log
connection con1;
alter system flush kvcache;
sleep 1;
connection default;
--enable_query_log
--replace_regex /__mv_container_[0-9]{6}/__mv_container_xxxxxx/
explain extended_noaddr select /*+no_mv_rewrite dynamic_sampling(1)*/ * from t1_rt_mv1;

drop materialized view log on t1;
drop table if exists t1;
drop materialized view t1_rt_mv1;
