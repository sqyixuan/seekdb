--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test for real-time simple join mav
#tags: mv_optimizer,mview

--result_format 4
set ob_query_timeout = 100000000;

--disable_warnings
--error 0, 1146
drop materialized view log on t1;
drop table if exists t1;
drop table if exists t2;
drop view if exists t1_v1;
drop view if exists t1_v2;
--error 0, 9757
drop materialized view t1_rt_mv1;
--error 0, 9757
drop materialized view t1_rt_mv2;
--enable_warnings

create table t1(c1 int primary key auto_increment, c2 int, c3 int, c4 int, c5 int);
create table t2(c1 int primary key auto_increment, c2 int, c3 int, c4 int, c5 int);
insert into t1(c2, c3, c4) values(1,1,1);
create materialized view log on t1 with primary key, rowid, sequence (c2, c3, c4) including new values;

create materialized view t1_rt_mv1
refresh fast on demand
enable on query computation
disable query rewrite
as
select a.c4 as group_col, count(*) cnt from t1 a, t1 b where a.c2 = b.c3 group by a.c4;

create or replace view t1_v1 
as
select a.c4 as group_col, count(*) cnt from t1 a, t1 b where a.c2 = b.c3 group by a.c4;

create or replace view res_com1
as
with mv as (select /*+materialize*/ * from t1_rt_mv1),
     v as (select /*+materialize*/ * from t1_v1)
select 2 * (select count(*) from (select * from v union select * from mv))
       -  (select count(*) from (select * from v union all select * from mv)) as expect_0
from dual;

create materialized view t1_rt_mv2
refresh fast on demand
enable on query computation
disable query rewrite
as
select a.c3 a_c3, b.c2 b_c2,
       count(*) cnt,
       count(e.c4) cnt_e_c4,
       sum(e.c4) sum_e_c4,
       count(c.c3) cnt_c_c3,
       sum(c.c3) sum_c_c3,
       avg(e.c4) avg_e_c4,
       sum(c.c3) * avg(e.c4) calc_1
from t1 a, t1 b, t1 c, t1 d, t1 e
where a.c2 = b.c3 and b.c2 = c.c4 and c.c2 = d.c3 and d.c4 = e.c2
group by a.c3, b.c2
;

create or replace view t1_v2 as
select a.c3 a_c3, b.c2 b_c2,
       count(*) cnt,
       count(e.c4) cnt_e_c4,
       sum(e.c4) sum_e_c4,
       count(c.c3) cnt_c_c3,
       sum(c.c3) sum_c_c3,
       avg(e.c4) avg_e_c4,
       sum(c.c3) * avg(e.c4) calc_1
from t1 a, t1 b, t1 c, t1 d, t1 e
where a.c2 = b.c3 and b.c2 = c.c4 and c.c2 = d.c3 and d.c4 = e.c2
group by a.c3, b.c2
;

create or replace view res_com2
as
with mv as (select /*+materialize*/ * from t1_rt_mv2),
     v as (select /*+materialize*/ * from t1_v2)
select 2 * (select count(*) from (select * from v union select * from mv))
       -  (select count(*) from (select * from v union all select * from mv)) as expect_0
from dual;

--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
explain basic select * from t1_rt_mv1;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
explain basic select * from t1_rt_mv2;

select * from res_com1;
select * from res_com2;

insert into t1(c2, c3, c4) select uniform(1, 5, random()), uniform(1, 5, random()), uniform(1, 5, random()) from table(generator(20));
select * from res_com1;
select * from res_com2;

insert into t1(c2, c3, c4) select uniform(1, 5, random()), uniform(1, 5, random()), uniform(1, 5, random()) from table(generator(20));
update t1 set c2 = c4 where c3 > 3;
delete from t1 where c4 < 2;
select * from res_com1;
select * from res_com2;

delete from t1;
select * from res_com1;
select * from res_com2;

insert into t1(c2, c3, c4) select uniform(1, 5, random()), uniform(1, 5, random()), uniform(1, 5, random()) from table(generator(40));
select * from res_com1;
select * from res_com2;

--disable_warnings
# disable_warnings to avoid Data truncated Warning generated by fast refresh in mysql mode
call DBMS_MVIEW.REFRESH('t1_rt_mv1', 'f');
call DBMS_MVIEW.REFRESH('t1_rt_mv2', 'f');
--enable_warnings


update t1 set c4 = c2 where c3 > 2;
select * from res_com1;
select * from res_com2;

delete from t1 where c3 < 2 and c2 < 3;
select * from res_com1;
select * from res_com2;

drop materialized view log on t1;
drop table if exists t1;
drop table if exists t2;
drop view if exists t1_v1;
drop view if exists t1_v2;
drop materialized view t1_rt_mv1;
drop materialized view t1_rt_mv2;
