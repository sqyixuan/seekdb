--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test for real-time simple mjv
#tags: mv_optimizer,mview

--result_format 4
--disable_warnings
--error 0, 1146
drop materialized view log on t1;
drop table if exists t1;
drop table if exists t2;
drop view if exists t1_v1;
drop view if exists t1_v2;
drop view if exists t1_v3;
--error 0, 9757
drop materialized view t1_rt_mv1;
--error 0, 9757
drop materialized view t1_rt_mv2;
--error 0, 9757
drop materialized view t1_rt_mv3;
--enable_warnings

create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create table t2(c1 int primary key, c2 int, c3 int, c4 int);
insert into t1 values(1,1,1,1);
create materialized view log on t1 with primary key, rowid, sequence (c2, c3) including new values;

--error 9783
create materialized view t1_rt_mv1 never refresh enable on query computation as
select a.c1 as a_c1 from t1 a, t1 b where a.c2 = b.c3;

--error 9783
create materialized view t1_rt_mv1 never refresh enable on query computation as
select a.c1 as a_c1, b.c1 as b_c1 from t1 a, t2 b where a.c2 = b.c3;

--error 9783
create materialized view t1_rt_mv1 never refresh enable on query computation as
select a.c1 as a_c1, b.c1 as b_c1 from t1 a left join t1 b on a.c2 = b.c3;

create materialized view t1_rt_mv1 never refresh enable on query computation as
select a.c1 as a_c1,
       b.c1 as b_c1,
       c.c1 as c_c1,
       d.c1 as d_c1,
       e.c1 as e_c1,
       f.c1 as f_c1 from t1 a, t1 b, t1 c, t1 d, t1 e, t1 f;
drop materialized view t1_rt_mv1;

create materialized view t1_rt_mv1 never refresh
enable on query computation
disable query rewrite
as
select a.c1 as a_c1, b.c1 as b_c1 from t1 a, t1 b where a.c2 = b.c3;

create or replace view t1_v1 as
select a.c1 as a_c1, b.c1 as b_c1 from t1 a, t1 b where a.c2 = b.c3;

create materialized view t1_rt_mv2 never refresh
disable query rewrite
enable on query computation
as
select a.c1 as a_c1, b.c1 as b_c1 from t1 a inner join t1 b on a.c2 = b.c3;

create or replace view t1_v2 as
select a.c1 as a_c1, b.c1 as b_c1 from t1 a inner join t1 b on a.c2 = b.c3;

create materialized view t1_rt_mv3 never refresh enable on query computation as
select a.c1 as a_c1,
       b.c1 as b_c1,
       c.c1 as c_c1,
       d.c1 as d_c1,
       e.c1 as e_c1 from t1 a, t1 b, t1 c, t1 d, t1 e;

create or replace view t1_v3 as
select a.c1 as a_c1,
       b.c1 as b_c1,
       c.c1 as c_c1,
       d.c1 as d_c1,
       e.c1 as e_c1 from t1 a, t1 b, t1 c, t1 d, t1 e;

create or replace view res_com1
as
select res, count(*) from 
(   select group_concat(view_type order by view_type) res
    from (
        select t1_v1.*, '1.normal view' view_type from t1_v1
        union all
        select t1_rt_mv1.*, '2.mview' from t1_rt_mv1)
    group by a_c1, b_c1
)
group by res
;

create or replace view res_com2
as
select res, count(*) from 
(   select group_concat(view_type order by view_type) res
    from (
        select t1_v2.*, '1.normal view' view_type from t1_v2
        union all
        select t1_rt_mv2.*, '2.mview' from t1_rt_mv2)
    group by a_c1, b_c1
)
group by res
;

create or replace view res_com3
as
select res, count(*) from 
(   select group_concat(view_type order by view_type) res
    from (
        select t1_v3.*, '1.normal view' view_type from t1_v3
        union all
        select t1_rt_mv3.*, '2.mview' from t1_rt_mv3)
    group by a_c1, b_c1, c_c1, d_c1, e_c1
)
group by res
;

--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
explain basic select * from t1_rt_mv1;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
explain basic select * from t1_rt_mv2;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
explain basic select * from t1_rt_mv3;

select * from res_com1;
select * from res_com2;
select * from res_com3;

insert into t1 values(2,1,2,1);
insert into t1 values(3,1,3,1);

select * from res_com1;
select * from res_com2;
select * from res_com3;

insert into t1 values(4,1,4,1);
insert into t1 values(5,2,5,1);
update t1 set c2 = c3/2 where c3 > 3;
delete from t1 where c1 = 1;

select * from res_com1;
select * from res_com2;
select * from res_com3;

drop materialized view log on t1;
drop table if exists t1;
drop table if exists t2;
drop view if exists t1_v1;
drop view if exists t1_v2;
drop view if exists t1_v3;
drop materialized view t1_rt_mv1;
drop materialized view t1_rt_mv2;
drop materialized view t1_rt_mv3;
