--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test for real-time simple mav
#tags: mv_optimizer,mview

--result_format 4

--disable_warnings
--error 0, 1146
drop materialized view log on t1;
drop table if exists t1;
drop view if exists t1_v1;
--error 0, 9757
drop materialized view t1_mv1;
--error 0, 9757
drop materialized view t1_rt_mv1;
--error 0, 9757
drop materialized view t1_rt_mv2;
--error 0, 9757
drop materialized view t1_rt_mv3;
--enable_warnings

create table t1(c1 int primary key, c2 int, c3 int, c4 int);
insert into t1 values(1,1,1,1);
create materialized view log on t1 with primary key, rowid, sequence (c2, c3) including new values;

create or replace view t1_v1 as
select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3)/c2 calc_1 from t1 group by c2;

create materialized view t1_mv1 refresh fast on demand as
select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3)/c2 calc_1 from t1 group by c2;

--error 9783
create materialized view t1_rt_mv1
enable on query computation
as
select count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3)/c2 calc_1 from t1 group by c2;

create materialized view t1_rt_mv1
refresh fast on demand
enable on query computation
as
select /*+parallel(8)*/ c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3)/c2 calc_1 from t1 group by c2;

create or replace view res_compare
as
select * from (
    select t1_v1.*, '1.normal view' view_type from t1_v1
    union all
    select t1_mv1.*, '2.mview' from t1_mv1
    union all
    select t1_rt_mv1.*, '3.rt-mview' from t1_rt_mv1)
order by c2, view_type;

--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
explain basic select * from t1_rt_mv1;

select * from res_compare;

insert into t1 values(2,1,2,1);
insert into t1 values(3,1,3,1);

select /*+no_mv_rewrite*/ * from t1_rt_mv1;

select * from res_compare;

call DBMS_MVIEW.REFRESH('t1_mv1', 'f');
call DBMS_MVIEW.REFRESH('t1_rt_mv1', 'f');

select * from res_compare;

insert into t1 values(4,1,4,1);
insert into t1 values(5,2,5,1);
select * from res_compare;

update t1 set c2 = c3/2 where c3 > 3;
delete from t1 where c1 = 1;
select * from res_compare;

call DBMS_MVIEW.REFRESH('t1_mv1', 'f');
call DBMS_MVIEW.REFRESH('t1_rt_mv1', 'f');

select * from res_compare;

create materialized view t1_rt_mv2 partition by hash(cnt) partitions 2
refresh fast on demand
enable on query computation
as
select c2 as c2, count(*) cnt from t1 group by c2;
--error 1235
select * from t1_rt_mv2 partition (p0);

## bug:
create materialized view t1_rt_mv3 (primary key(c2))
partition by range(c2) subpartition by hash(c2) subpartitions 2
(partition p0 values less than (10),partition p1 values less than(maxvalue))
refresh fast on demand
enable on query computation
as
select c2 as c2, count(*) cnt, count(c3) cnt_c3
from t1 group by c2;

select * from t1_rt_mv3 a left join t1 b on a.c2 > b.c1;

drop materialized view log on t1;
drop table if exists t1;
drop view if exists t1_v1;
drop materialized view t1_mv1;
drop materialized view t1_rt_mv1;
drop materialized view t1_rt_mv2;
drop materialized view t1_rt_mv3;
