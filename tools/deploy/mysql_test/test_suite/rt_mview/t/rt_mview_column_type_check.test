--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test mview column result type check
#tags: mv_optimizer,mview

--result_format 4

--disable_warnings
--error 0, 1146
drop materialized view log on t1;
drop table if exists t1;
drop view if exists t1_v1;
--error 0, 9757
drop materialized view t1_mv1;
--enable_warnings

create table t1 (c1 ENUM('中文ing123','蘩騠字','蘩騠字ss'), c2 ENUM('null','@!#%$','kasdhka'), c3 varchar(20) primary key);
create materialized view log on t1 parallel 9 with rowid, sequence (c1, c2) including new values;

--error 1235
create materialized view t1_mv1 parallel 9 refresh fast on demand enable on query computation
as select c1 as c1, count(*) cnt from t1 group by c1;

--error 1235
create materialized view t1_mv1 parallel 9 refresh fast on demand enable on query computation
as select a.c3 as ac3, b.c3 as bc3 from t1 a,t1 b where a.c1=b.c3;

create materialized view t1_mv1 parallel 9 refresh fast on demand
as select c1 as c1, count(*) cnt from t1 group by c1;

drop materialized view t1_mv1;
drop materialized view log on t1;
drop table t1;
