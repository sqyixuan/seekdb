--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#tags: mv_optimizer,mview

--result_format 4

--disable_query_log
connect (sys,$OBMYSQL_MS0,root,"",oceanbase,$OBMYSQL_PORT);
connection sys;
--enable_query_log

--disable_warnings
drop table if exists t1;
--error 0, 9757
drop materialized view local_session_var_bug_test_mv1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int);

create materialized view local_session_var_bug_test_mv1 as 
select c1, c2 from t1;

select table_id into @mview_id from __all_table where table_name = 'local_session_var_bug_test_mv1';

## new mview, local_session_vars is '00'
select local_session_vars from __all_table where table_id = @mview_id;
select local_session_vars from __all_table_history where table_id = @mview_id order by schema_version;

## set local_session_vars as null
update __all_table set local_session_vars = NULL where table_id = @mview_id;
update __all_table_history set local_session_vars = NULL where table_id = @mview_id order by schema_version desc limit 1;
select local_session_vars from __all_table where table_id = @mview_id;
select local_session_vars from __all_table_history where table_id = @mview_id order by schema_version;

## after complete refresh, local_session_vars reset to '00'
call DBMS_MVIEW.REFRESH('local_session_var_bug_test_mv1', 'c');
select local_session_vars from __all_table where table_id = @mview_id;
select local_session_vars from __all_table_history where table_id = @mview_id order by schema_version;

call DBMS_MVIEW.REFRESH('local_session_var_bug_test_mv1', 'c');

select local_session_vars from __all_table where table_id = @mview_id;
select local_session_vars from __all_table_history where table_id = @mview_id order by schema_version;

drop table t1;
drop materialized view local_session_var_bug_test_mv1;

