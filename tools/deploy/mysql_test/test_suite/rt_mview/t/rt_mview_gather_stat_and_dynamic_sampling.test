--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test mview column result type check
#tags: mv_optimizer,mview

--result_format 4

--disable_warnings
--error 0, 1146
drop materialized view log on collect_info;
drop table if exists collect_info;
--error 0, 1146
drop materialized view log on collect_item;
drop table if exists collect_item;
--error 0, 9757
drop materialized view mv;
drop tablegroup if exists tg1;
--enable_warnings

create tablegroup tg1;

create table collect_info(user_id bigint auto_increment,item_id bigint,primary key(user_id, item_id)) tablegroup = tg1 partition by hash(user_id) partitions 128;
create table collect_item(item_id bigint auto_increment primary key,price int,pic_url varchar(100));

insert into collect_info values (10010, 1);
insert into collect_info values (10086, 1);
insert into collect_info values (10086, 2);
insert into collect_info values (10010, 3);
insert into collect_info values (10086, 4);
insert into collect_info values (10010, 5);
insert into collect_info values (10086, 5);
insert into collect_info values (12345, 6);
insert into collect_info values (10010, 7);
insert into collect_info values (10086, 8);
insert into collect_info values (10010, 9);

insert into collect_item values (1, 100, 'pic1');
insert into collect_item values (2, 200, 'pic2');
insert into collect_item values (3, 300, 'pic3');
insert into collect_item values (4, 400, 'pic4');
insert into collect_item values (5, 500, 'pic5');
insert into collect_item values (6, 600, 'pic6');
insert into collect_item values (7, 700, 'pic7');
insert into collect_item values (8, 800, 'pic8');
insert into collect_item values (9, 900, 'pic9');
insert into collect_item values (10, 1000, 'pic10');
insert into collect_item values (11, 1100, 'pic11');
insert into collect_item values (12, 1200, 'pic12');
insert into collect_item values (13, 1300, 'pic13');
insert into collect_item values (14, 1400, 'pic14');
insert into collect_item values (15, 1500, 'pic15');

create materialized view log on collect_info parallel 16 with rowid, sequence including new values;
create materialized view log on collect_item parallel 16 with rowid, sequence (price, pic_url) including new values;

create /*+parallel(16)*/ materialized view mv (primary key(user_id, item_id_info)) tablegroup = tg1 partition by hash(user_id) partitions 128 refresh fast on demand enable on query computation enable query rewrite 
as select user_id, collect_info.item_id item_id_info, collect_item.item_id item_id_item, price, pic_url from collect_info, collect_item where collect_info.item_id = collect_item.item_id;

create /*+parallel(16)*/ index idx2 on mv(item_id_item);

--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
explain select /*+dynamic_sampling(1)*/ * from mv;

call dbms_stats.gather_table_stats("test","mv",degree=>16);
call dbms_stats.gather_table_stats("test","collect_info",degree=>16);
call dbms_stats.gather_table_stats("test","mv",degree=>16);
call dbms_stats.gather_table_stats("test","mv",degree=>16);

--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
explain select * from mv;

drop materialized view log on collect_info;
drop table if exists collect_info;
drop materialized view log on collect_item;
drop table if exists collect_item;
drop materialized view mv;
drop tablegroup if exists tg1;
