result_format: 4
drop materialized view log on t1;
drop table if exists t1;
drop materialized view t1_rt_mv1;
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
insert into t1 values(1,1,1,1);
create materialized view log on t1 with primary key, rowid, sequence (c2, c3) including new values;

create materialized view t1_rt_mv1
refresh fast on demand
enable on query computation
disable query rewrite
as
select a.c1 as a_c1, b.c1 as b_c1 from t1 a, t1 b where a.c2 = b.c3;

explain extended_noaddr select /*+no_mv_rewrite dynamic_sampling(1)*/ * from t1_rt_mv1;
Query Plan
====================================================
|ID|OPERATOR       |NAME     |EST.ROWS|EST.TIME(us)|
----------------------------------------------------
|0 |TABLE FULL SCAN|t1_rt_mv1|1       |3           |
====================================================
Outputs & filters:
-------------------------------------
  0 - output([t1_rt_mv1.a_c1], [t1_rt_mv1.b_c1]), filter(nil), rowset=16
      access([t1_rt_mv1.a_c1], [t1_rt_mv1.b_c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1_rt_mv1.__pk_increment]), range(MIN ; MAX)always true
Used Hint:
-------------------------------------
  /*+
      
      NO_MV_REWRITE
      DYNAMIC_SAMPLING(1)
  */
Qb name trace:
-------------------------------------
  stmt_id:0, stmt_type:T_EXPLAIN 
  stmt_id:1, SEL$1
Outline Data: 
-------------------------------------
  /*+
      BEGIN_OUTLINE_DATA
      FULL(@"SEL$1" "t1_rt_mv1"@"SEL$1")
      OPTIMIZER_FEATURES_ENABLE('')
      DYNAMIC_SAMPLING(1)
      END_OUTLINE_DATA
  */
Optimization Info:
-------------------------------------
  t1_rt_mv1:
      table_rows:1
      physical_range_rows:1
      logical_range_rows:1
      index_back_rows:0
      output_rows:1
      table_dop:1
      dop_method:Table DOP
      avaiable_index_name:[__mv_container_xxxxxx]
      stats info:[version=1970-01-01 08:00:00.000000, is_locked=0, is_expired=0]
      dynamic sampling level:1
      estimation method:[DYNAMIC SAMPLING FULL]
  Plan Type:
      LOCAL
  Note:
      Degree of Parallelisim is 1 because of table property

