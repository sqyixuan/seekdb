create materialized view t1_rt_mv2 partition by hash(cnt) partitions 2
refresh fast on demand
enable on query computation
as
select c2 as c2, count(*) cnt from t1 group by c2;
select * from t1_rt_mv2 partition (p0);
ERROR 0A000: access some partitions of real-time materialized view now not supported

## bug:
create materialized view t1_rt_mv3 (primary key(c2))
partition by range(c2) subpartition by hash(c2) subpartitions 2
(partition p0 values less than (10),partition p1 values less than(maxvalue))
refresh fast on demand
enable on query computation
as
select c2 as c2, count(*) cnt, count(c3) cnt_c3
from t1 group by c2;

select * from t1_rt_mv3 a left join t1 b on a.c2 > b.c1;
+----+------+--------+----+------+------+------+
| c2 | cnt  | cnt_c3 | c1 | c2   | c3   | c4   |
+----+------+--------+----+------+------+------+
|  2 |    1 |      1 | NULL | NULL | NULL | NULL |
|  1 |    2 |      2 | NULL | NULL | NULL | NULL |
|  3 |    1 |      1 |  2 |    1 |    2 |    1 |
+----+------+--------+----+------+------+------+

drop materialized view log on t1;
drop table if exists t1;
drop view if exists t1_v1;
drop materialized view t1_mv1;
drop materialized view t1_rt_mv1;
drop materialized view t1_rt_mv2;
drop materialized view t1_rt_mv3;
