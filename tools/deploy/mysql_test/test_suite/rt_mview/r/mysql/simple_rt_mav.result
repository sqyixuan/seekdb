|    1 |    3 |      3 |      6 | 2.0000 | 12.00000000 | 1.normal view |
|    1 |    3 |      3 |      6 | 2.0000 | 12.00000000 | 2.mview       |
|    1 |    3 |      3 |      6 | 2.0000 | 12.00000000 | 3.rt-mview    |
+------+------+--------+--------+--------+-------------+---------------+

insert into t1 values(4,1,4,1);
insert into t1 values(5,2,5,1);
select * from res_compare;
