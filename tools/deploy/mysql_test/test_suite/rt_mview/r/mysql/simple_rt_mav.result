|    1 |    4 |      4 |     10 | 2.5000 | 25.00000000 | 1.normal view |
|    1 |    3 |      3 |      6 | 2.0000 | 12.00000000 | 2.mview       |
|    1 |    4 |      4 |     10 | 2.5000 | 25.00000000 | 3.rt-mview    |
|    2 |    1 |      1 |      5 | 5.0000 | 12.50000000 | 1.normal view |
|    2 |    1 |      1 |      5 | 5.0000 | 12.50000000 | 3.rt-mview    |
+------+------+--------+--------+--------+-------------+---------------+

update t1 set c2 = c3/2 where c3 > 3;
delete from t1 where c1 = 1;
select * from res_compare;
