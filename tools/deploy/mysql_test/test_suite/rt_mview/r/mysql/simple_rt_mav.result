|    1 |    3 |      3 |      6 | 2.0000 | 12.00000000 | 2.mview       |
|    1 |    2 |      2 |      5 | 2.5000 | 12.50000000 | 3.rt-mview    |
|    2 |    1 |      1 |      4 | 4.0000 |  8.00000000 | 1.normal view |
|    2 |    1 |      1 |      4 | 4.0000 |  8.00000000 | 3.rt-mview    |
|    3 |    1 |      1 |      5 | 5.0000 |  8.33333333 | 1.normal view |
|    3 |    1 |      1 |      5 | 5.0000 |  8.33333333 | 3.rt-mview    |
