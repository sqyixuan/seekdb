|    1 |    1 |      1 |      1 | 1.0000 | 1.00000000 |
+------+------+--------+--------+--------+------------+

select * from res_compare;
+------+------+--------+--------+--------+-------------+---------------+
| c2   | cnt  | cnt_c3 | sum_c3 | avg_c3 | calc_1      | view_type     |
+------+------+--------+--------+--------+-------------+---------------+
|    1 |    3 |      3 |      6 | 2.0000 | 12.00000000 | 1.normal view |
|    1 |    1 |      1 |      1 | 1.0000 |  1.00000000 | 2.mview       |
|    1 |    3 |      3 |      6 | 2.0000 | 12.00000000 | 3.rt-mview    |
