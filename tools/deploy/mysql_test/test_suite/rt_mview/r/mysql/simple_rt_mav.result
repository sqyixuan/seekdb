result_format: 4
drop materialized view log on t1;
drop table if exists t1;
drop view if exists t1_v1;
drop materialized view t1_mv1;
drop materialized view t1_rt_mv1;
drop materialized view t1_rt_mv2;
drop materialized view t1_rt_mv3;
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
insert into t1 values(1,1,1,1);
create materialized view log on t1 with primary key, rowid, sequence (c2, c3) including new values;

create or replace view t1_v1 as
select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3)/c2 calc_1 from t1 group by c2;

create materialized view t1_mv1 refresh fast on demand as
select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3)/c2 calc_1 from t1 group by c2;

create materialized view t1_rt_mv1
enable on query computation
as
select count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3)/c2 calc_1 from t1 group by c2;
ERROR HY000: cannot ENABLE ON QUERY COMPUTATION for the materialized view t1_rt_mv1: all group by column are required in the select item list

create materialized view t1_rt_mv1
refresh fast on demand
enable on query computation
as
select /*+parallel(8)*/ c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3)/c2 calc_1 from t1 group by c2;

create or replace view res_compare
as
select * from (
    select t1_v1.*, '1.normal view' view_type from t1_v1
    union all
    select t1_mv1.*, '2.mview' from t1_mv1
    union all
    select t1_rt_mv1.*, '3.rt-mview' from t1_rt_mv1)
order by c2, view_type;

explain basic select * from t1_rt_mv1;
Query Plan
==============================================
|ID|OPERATOR                   |NAME         |
----------------------------------------------
|0 |HASH GROUP BY              |             |
|1 |└─SUBPLAN SCAN             |INNER_RT_MV$$|
|2 |  └─UNION ALL              |             |
|3 |    ├─TABLE FULL SCAN      |t1_rt_mv1    |
|4 |    └─HASH GROUP BY        |             |
|5 |      └─SUBPLAN SCAN       |DLT_T$$      |
|6 |        └─WINDOW FUNCTION  |             |
|7 |          └─TABLE FULL SCAN|mlog$_t1     |
==============================================
Outputs & filters:
-------------------------------------
  0 - output([INNER_RT_MV$$.c2], [cast(T_FUN_SUM(INNER_RT_MV$$.cnt), BIGINT(20, 0))], [cast(T_FUN_SUM(INNER_RT_MV$$.cnt_c3), BIGINT(20, 0))], [cast(CASE 
      WHEN T_FUN_SUM(INNER_RT_MV$$.cnt_c3) = cast(0, DECIMAL_INT(81, 0)) THEN NULL ELSE T_FUN_SUM(INNER_RT_MV$$.sum_c3) END, DECIMAL_INT(33, 0))], [cast(cast(CASE 
      WHEN T_FUN_SUM(INNER_RT_MV$$.cnt_c3) = cast(0, DECIMAL_INT(81, 0)) THEN NULL ELSE T_FUN_SUM(INNER_RT_MV$$.sum_c3) END, DECIMAL(75, 0)) / cast(T_FUN_SUM(INNER_RT_MV$$.cnt_c3),
       DECIMAL(81, 0)), DECIMAL(15, 4))], [cast(cast(CASE WHEN T_FUN_SUM(INNER_RT_MV$$.cnt_c3) = cast(0, DECIMAL_INT(81, 0)) THEN NULL ELSE T_FUN_SUM(INNER_RT_MV$$.sum_c3) 
      END, DECIMAL(75, 0)) / cast(T_FUN_SUM(INNER_RT_MV$$.cnt_c3), DECIMAL(81, 0)) * cast(CASE WHEN T_FUN_SUM(INNER_RT_MV$$.cnt_c3) = cast(0, DECIMAL_INT(81, 
      0)) THEN NULL ELSE T_FUN_SUM(INNER_RT_MV$$.sum_c3) END, DECIMAL(75, 0)) / cast(INNER_RT_MV$$.c2, DECIMAL(11, 0)), DECIMAL(52, 8))]), filter([T_FUN_SUM(INNER_RT_MV$$.cnt) 
      > cast(0, DECIMAL_INT(64, 0))]), rowset=16
      group([INNER_RT_MV$$.c2]), agg_func([T_FUN_SUM(INNER_RT_MV$$.cnt)], [T_FUN_SUM(INNER_RT_MV$$.cnt_c3)], [T_FUN_SUM(INNER_RT_MV$$.sum_c3)])
  1 - output([INNER_RT_MV$$.c2], [INNER_RT_MV$$.cnt], [INNER_RT_MV$$.cnt_c3], [INNER_RT_MV$$.sum_c3]), filter(nil), rowset=16
      access([INNER_RT_MV$$.c2], [INNER_RT_MV$$.cnt], [INNER_RT_MV$$.cnt_c3], [INNER_RT_MV$$.sum_c3])
  2 - output([UNION([1])], [UNION([2])], [UNION([3])], [UNION([4])]), filter(nil), rowset=16
  3 - output([t1_rt_mv1.c2], [cast(t1_rt_mv1.cnt, DECIMAL_INT(42, 0))], [cast(t1_rt_mv1.cnt_c3, DECIMAL_INT(62, 0))], [cast(t1_rt_mv1.sum_c3, DECIMAL_INT(53,
       0))]), filter(nil), rowset=16
      access([t1_rt_mv1.c2], [t1_rt_mv1.cnt], [t1_rt_mv1.cnt_c3], [t1_rt_mv1.sum_c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1_rt_mv1.__pk_increment]), range(MIN ; MAX)always true
  4 - output([DLT_T$$.c2], [T_FUN_SUM(CASE WHEN DLT_T$$.OLD_NEW$$ = 'N' THEN 1 ELSE -1 END)], [T_FUN_SUM(CASE WHEN DLT_T$$.OLD_NEW$$ = 'N' THEN 1 ELSE -1 
      END * CASE WHEN DLT_T$$.c3 IS NULL THEN 0 ELSE 1 END)], [T_FUN_SUM(CASE WHEN DLT_T$$.OLD_NEW$$ = 'N' THEN 1 ELSE -1 END * DLT_T$$.c3)]), filter(nil), rowset=16
      group([DLT_T$$.c2]), agg_func([T_FUN_SUM(CASE WHEN DLT_T$$.OLD_NEW$$ = 'N' THEN 1 ELSE -1 END)], [T_FUN_SUM(CASE WHEN DLT_T$$.OLD_NEW$$ = 'N' THEN 
      1 ELSE -1 END * CASE WHEN DLT_T$$.c3 IS NULL THEN 0 ELSE 1 END)], [T_FUN_SUM(CASE WHEN DLT_T$$.OLD_NEW$$ = 'N' THEN 1 ELSE -1 END * DLT_T$$.c3)])
  5 - output([DLT_T$$.c2], [DLT_T$$.c3], [CASE WHEN DLT_T$$.OLD_NEW$$ = 'N' THEN 1 ELSE -1 END]), filter([DLT_T$$.OLD_NEW$$ = 'N' AND DLT_T$$.SEQUENCE$$ 
      = DLT_T$$.MAXSEQ$$ OR DLT_T$$.OLD_NEW$$ = 'O' AND DLT_T$$.SEQUENCE$$ = DLT_T$$.MINSEQ$$]), rowset=16
      access([DLT_T$$.OLD_NEW$$], [DLT_T$$.SEQUENCE$$], [DLT_T$$.MAXSEQ$$], [DLT_T$$.MINSEQ$$], [DLT_T$$.c2], [DLT_T$$.c3])
  6 - output([mlog$_t1.OLD_NEW$$], [mlog$_t1.SEQUENCE$$], [T_FUN_MAX(mlog$_t1.SEQUENCE$$)], [T_FUN_MIN(mlog$_t1.SEQUENCE$$)], [mlog$_t1.c2], [mlog$_t1.c3]), filter(nil), rowset=16
      win_expr(T_FUN_MAX(mlog$_t1.SEQUENCE$$)), partition_by([mlog$_t1.c1]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED 
      FOLLOWING)
      win_expr(T_FUN_MIN(mlog$_t1.SEQUENCE$$)), partition_by([mlog$_t1.c1]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED 
      FOLLOWING)
  7 - output([mlog$_t1.c1], [mlog$_t1.SEQUENCE$$], [mlog$_t1.OLD_NEW$$], [mlog$_t1.c2], [mlog$_t1.c3]), filter([ORA_ROWSCN > last_refresh_scn(xxxxxx)]), rowset=16
      access([mlog$_t1.c1], [mlog$_t1.SEQUENCE$$], [mlog$_t1.OLD_NEW$$], [mlog$_t1.c2], [mlog$_t1.c3], [ORA_ROWSCN]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([mlog$_t1.c1], [mlog$_t1.SEQUENCE$$]), range(MIN,MIN ; MAX,MAX)always true

