explain basic select * from collect_info_mv where user_id = 1;
Query Plan
==================================================
|ID|OPERATOR                     |NAME           |
--------------------------------------------------
|0 |UNION ALL                    |               |
|1 |├─MERGE OUTER JOIN           |               |
|2 |│ ├─NESTED-LOOP OUTER JOIN   |               |
|3 |│ │ ├─TABLE RANGE SCAN       |collect_info_mv|
|4 |│ │ └─SUBPLAN SCAN           |collect_item   |
|5 |│ │   └─DISTRIBUTED TABLE GET|collect_item   |
|6 |│ └─SUBPLAN SCAN             |collect_info   |
|7 |│   └─TABLE RANGE SCAN       |collect_info   |
|8 |└─NESTED-LOOP JOIN           |               |
|9 |  ├─MERGE ANTI JOIN          |               |
|10|  │ ├─TABLE RANGE SCAN       |collect_info   |
|11|  │ └─SUBPLAN SCAN           |VIEW2          |
|12|  │   └─TABLE RANGE SCAN     |collect_info_mv|
|13|  └─DISTRIBUTED TABLE GET    |collect_item   |
==================================================
Outputs & filters:
-------------------------------------
  0 - output([UNION([1])], [UNION([2])], [UNION([3])], [UNION([4])]), filter(nil), rowset=256
  1 - output([collect_info_mv.user_id], [collect_info_mv.item_id], [CASE WHEN collect_item.OLD_NEW$$ IS NULL THEN collect_info_mv.dup_item_id ELSE collect_item.item_id 
      END], [CASE WHEN collect_item.OLD_NEW$$ IS NULL THEN collect_info_mv.price ELSE collect_item.price END]), filter([collect_info.OLD_NEW$$ = 'N' OR collect_info.OLD_NEW$$ 
      IS NULL]), rowset=256
      equal_conds([collect_info.item_id = collect_info_mv.item_id]), other_conds(nil)
      merge_directions([ASC])
  2 - output([collect_info_mv.user_id], [collect_info_mv.item_id], [collect_item.OLD_NEW$$], [collect_info_mv.dup_item_id], [collect_info_mv.price], [collect_item.item_id],
       [collect_item.price]), filter([collect_item.OLD_NEW$$ = 'N' OR collect_item.OLD_NEW$$ IS NULL]), rowset=256
      conds(nil), nl_params_([collect_info_mv.item_id(:0)]), use_batch=true
  3 - output([collect_info_mv.user_id], [collect_info_mv.item_id], [collect_info_mv.dup_item_id], [collect_info_mv.price]), filter(nil), rowset=256
      access([collect_info_mv.user_id], [collect_info_mv.item_id], [collect_info_mv.dup_item_id], [collect_info_mv.price]), partitions(p1)
      is_index_back=false, is_global_index=false, 
      range_key([collect_info_mv.user_id], [collect_info_mv.item_id]), range(1,MIN ; 1,MAX), 
      range_cond([collect_info_mv.user_id = 1])
  4 - output([collect_item.item_id], [collect_item.OLD_NEW$$], [collect_item.price]), filter(nil), rowset=256
      access([collect_item.item_id], [collect_item.OLD_NEW$$], [collect_item.price])
  5 - output([collect_item.item_id], [collect_item.price], [OLD_NEW$$]), filter([ORA_ROWSCN > last_refresh_scn(xxxxxx)]), rowset=256
      access([GROUP_ID], [collect_item.item_id], [collect_item.price], [ORA_ROWSCN], [OLD_NEW$$]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([collect_item.item_id]), range(MIN ; MAX)always true, 
      range_cond([:0 = collect_item.item_id])
  6 - output([collect_info.item_id], [collect_info.OLD_NEW$$]), filter(nil), rowset=256
      access([collect_info.item_id], [collect_info.OLD_NEW$$])
  7 - output([collect_info.user_id], [collect_info.item_id], [OLD_NEW$$]), filter([ORA_ROWSCN > last_refresh_scn(xxxxxx)]), rowset=256
      access([collect_info.user_id], [collect_info.item_id], [ORA_ROWSCN], [OLD_NEW$$]), partitions(p1)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([collect_info.user_id], [collect_info.item_id]), range(1,MIN ; 1,MAX), 
      range_cond([collect_info.user_id = 1])
  8 - output([collect_info.user_id], [collect_info.item_id], [collect_item.item_id], [collect_item.price]), filter(nil), rowset=256
      conds(nil), nl_params_([collect_info.item_id(:1)]), use_batch=true
  9 - output([collect_info.item_id], [collect_info.user_id]), filter(nil), rowset=256
      equal_conds([collect_info.item_id = VIEW2.collect_info_mv.item_id]), other_conds(nil)
      merge_directions([ASC])
 10 - output([collect_info.user_id], [collect_info.item_id]), filter(nil), rowset=256
      access([collect_info.user_id], [collect_info.item_id]), partitions(p1)
      is_index_back=false, is_global_index=false, 
      range_key([collect_info.user_id], [collect_info.item_id]), range(1,MIN ; 1,MAX), 
      range_cond([collect_info.user_id = 1])
 11 - output([VIEW2.collect_info_mv.item_id]), filter(nil), rowset=256
      access([VIEW2.collect_info_mv.item_id])
 12 - output([collect_info_mv.item_id]), filter(nil), rowset=256
      access([collect_info_mv.item_id]), partitions(p1)
      is_index_back=false, is_global_index=false, 
      range_key([collect_info_mv.user_id], [collect_info_mv.item_id]), range(1,MIN ; 1,MAX), 
      range_cond([collect_info_mv.user_id = 1])
 13 - output([collect_item.item_id], [collect_item.price]), filter(nil), rowset=256
      access([GROUP_ID], [collect_item.item_id], [collect_item.price]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([collect_item.item_id]), range(MIN ; MAX), 
      range_cond([:1 = collect_item.item_id])
