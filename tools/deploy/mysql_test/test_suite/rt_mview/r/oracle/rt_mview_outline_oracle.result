result_format: 4
drop materialized view log on t1;
drop table t1;
drop materialized view mv1;
drop materialized view mv2;
CREATE TABLE t1(pk int primary key, c1 int, c2 int, c3 int);

CREATE MATERIALIZED VIEW LOG ON t1 parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c1,c2,c3) INCLUDING NEW VALUES;

create materialized view mv1 REFRESH FAST ON DEMAND enable on query computation AS
select c1 as c1,PK AS c2,C2 AS C3,count(*) as c4
from t1 ZT1
group by c1,C2,PK;

create materialized view mv2 REFRESH FAST ON DEMAND enable on query computation AS
select ROUND(c1) as c1,LENGTH(PK) AS c2,ABS(C2) AS C3,count(*) as c4
from t1 ZT1
group by ROUND(c1),ABS(C2),LENGTH(PK) ;

explain basic
SELECT UNIQUE * FROM (SELECT ALL A.C1,B.C2,A.C3,B.C4 FROM mv2 A INNER JOIN mv1 B ON A.C4 > B.C3 WHERE A.C1 IS NOT NULL OR A.C4 IS NOT NULL) A WHERE A.C1 != SOME (SELECT  C4 FROM mv1 WHERE A.C3 = C3) order by c1;
