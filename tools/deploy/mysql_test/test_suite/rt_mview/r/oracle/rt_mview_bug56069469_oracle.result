SELECT /*+use_concat*/   SUM(DISTINCT OUTR . col_int_key ) AS X FROM  mve OUTR2 LEFT JOIN  B OUTR ON ( OUTR2 . col_varchar_10 = OUTR . col_varchar_20_key ) WHERE OUTR . col_varchar_20 < any ( SELECT  INNR . col_varchar_20 AS Y FROM  I INNR2 LEFT JOIN  A INNR ON ( INNR2 . col_ts < INNR . col_ts ) WHERE INNR . col_int_key in (6,6,2,9,1,8) ) and OUTR . col_varchar_20 < any ( SELECT  INNR . col_varchar_20 AS Y FROM  I INNR2 LEFT JOIN  A INNR ON ( INNR2 . col_ts < INNR . col_ts ) WHERE INNR . col_int_key in (6,6,2,9,1,8) and INNR . col_varchar_10_key in ('a','t','q','t') ) AND ( exists (select col_date_key from  H where OUTR . col_ts >= DATE '2000-08-11') OR OUTR . col_varchar_20_key = 'f' )  ORDER BY X;
