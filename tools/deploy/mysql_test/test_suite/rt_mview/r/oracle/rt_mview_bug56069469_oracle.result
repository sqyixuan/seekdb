EXPLAIN BASIC SELECT 1
FROM
  mve OUTR2
WHERE
  1 < any (
    SELECT
      2
    FROM
      I INNR2
      LEFT JOIN A INNR ON (INNR2.col_ts < INNR.col_ts)
  )
  and 3 < any (
    SELECT
      4
    FROM
      I INNR2
      LEFT JOIN A INNR ON (INNR2.col_ts < INNR.col_ts)
  );
