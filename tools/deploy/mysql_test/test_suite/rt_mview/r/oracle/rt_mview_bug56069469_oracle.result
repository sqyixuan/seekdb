result_format: 4
explain_protocol: 1
## issue: 
DROP MATERIALIZED VIEW LOG ON E;
DROP TABLE A;
DROP TABLE B;
DROP TABLE E;
DROP TABLE I;
DROP TABLE H;
DROP MATERIALIZED VIEW mve;
CREATE  TABLE A (
pk int,
col_varchar_10 varchar(10),
col_date date,
col_int_key int,
col_ts_key timestamp,
col_int int,
col_varchar_10_key varchar(10),
col_ts timestamp,
col_varchar_20 varchar(20),
col_varchar_20_key varchar(20),
col_date_key date);

CREATE  TABLE B (
pk int,
col_date_key date,
col_varchar_20_key varchar(20),
col_int_key int,
col_varchar_10_key varchar(10),
col_ts_key timestamp,
col_int int,
col_date date,
col_varchar_10 varchar(10),
col_varchar_20 varchar(20),
col_ts timestamp)    PARTITION BY hash (pk) partitions 19  ;

CREATE  TABLE E (
pk int,
col_ts timestamp,
col_varchar_20_key varchar(20),
col_int int,
col_date date,
col_date_key date,
col_varchar_10 varchar(10),
col_varchar_10_key varchar(10),
col_ts_key timestamp,
col_varchar_20 varchar(20),
col_int_key int)    PARTITION BY hash (pk,col_ts_key) partitions 8 ;

CREATE  TABLE I (
col_varchar_20_key varchar(20),
col_ts timestamp,
col_int int,
pk int,
col_date_key date,
col_varchar_20 varchar(20),
col_varchar_10 varchar(10),
col_int_key int,
col_varchar_10_key varchar(10),
col_ts_key timestamp,
col_date date)    
PARTITION BY range(col_date_key)
(partition p0 values less than (to_date('2000-01-01', 'yyyy-mm-dd')),
partition p1 values less than (to_date('2003-01-01', 'yyyy-mm-dd')),
partition p2 values less than (to_date('2007-01-01', 'yyyy-mm-dd')),
partition p3 values less than (to_date('2010-01-01', 'yyyy-mm-dd')),
partition p4 values less than (maxvalue)) ;

CREATE  TABLE H (
col_varchar_20 varchar(20),
pk int,
col_ts_key timestamp,
col_varchar_10 varchar(10),
col_int_key int,
col_date date,
col_ts timestamp,
col_int int,
col_varchar_20_key varchar(20),
col_date_key date,
col_varchar_10_key varchar(10))    
PARTITION BY range (col_int_key)
( partition p0 values less than (2),
partition p1 values less than (5),
partition p2 values less than (8),
partition p3 values less than (maxvalue)) ;

CREATE MATERIALIZED VIEW LOG on E parallel 9 with rowid, sequence(pk, col_int_key, col_int, col_date_key, col_date, col_ts_key, col_ts, col_varchar_20_key, col_varchar_10_key, col_varchar_20, col_varchar_10) including new values;
CREATE MATERIALIZED VIEW mve parallel 9 refresh fast on demand enable on QUERY computation AS select pk, col_int_key, col_int, col_date_key, col_date, col_ts_key, col_ts, col_varchar_20_key, col_varchar_10_key, col_varchar_20, col_varchar_10,count(*) as c from E group by pk, col_int_key, col_int, col_date_key, col_date, col_ts_key, col_ts, col_varchar_20_key, col_varchar_10_key, col_varchar_20, col_varchar_10;

EXPLAIN BASIC SELECT /*+use_concat*/   SUM(DISTINCT OUTR . col_int_key ) AS X FROM  mve OUTR2 LEFT JOIN  B OUTR ON ( OUTR2 . col_varchar_10 = OUTR . col_varchar_20_key ) WHERE OUTR . col_varchar_20 < any ( SELECT  INNR . col_varchar_20 AS Y FROM  I INNR2 LEFT JOIN  A INNR ON ( INNR2 . col_ts < INNR . col_ts ) WHERE INNR . col_int_key in (6,6,2,9,1,8) ) and OUTR . col_varchar_20 < any ( SELECT  INNR . col_varchar_20 AS Y FROM  I INNR2 LEFT JOIN  A INNR ON ( INNR2 . col_ts < INNR . col_ts ) WHERE INNR . col_int_key in (6,6,2,9,1,8) and INNR . col_varchar_10_key in ('a','t','q','t') ) AND ( exists (select col_date_key from  H where OUTR . col_ts >= DATE '2000-08-11') OR OUTR . col_varchar_20_key = 'f' )  ORDER BY X;
