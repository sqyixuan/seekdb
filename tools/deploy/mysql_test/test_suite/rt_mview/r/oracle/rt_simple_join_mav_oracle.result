result_format: 4
set ob_query_timeout = 100000000;

drop materialized view log on t1;
drop table t1;
drop table t2;
drop view t1_v1;
drop view t1_v2;
drop materialized view t1_rt_mv1;
drop materialized view t1_rt_mv2;
drop sequence seq1;
create sequence seq1;
create table t1(c1 int primary key default seq1.nextval, c2 int, c3 int, c4 int, c5 int);
create index idx_t1_c2 on t1(c2);
create index idx_t1_c3 on t1(c3);
create index idx_t1_c4 on t1(c4);
create table t2(c1 int primary key, c2 int, c3 int, c4 int, c5 int);
insert into t1(c2, c3, c4) values(1,1,1);
create materialized view log on t1 with primary key, rowid, sequence (c2, c3, c4) including new values;

create materialized view t1_rt_mv1
refresh fast on demand
enable on query computation
disable query rewrite
as
select a.c4 as group_col, count(*) cnt from t1 a, t1 b where a.c2 = b.c3 group by a.c4;

create or replace view t1_v1 
as
select a.c4 as group_col, count(*) cnt from t1 a, t1 b where a.c2 = b.c3 group by a.c4;

create or replace view res_com1
as
with mv as (select /*+materialize*/ * from t1_rt_mv1),
     v as (select /*+materialize*/ * from t1_v1)
select 2 * (select count(*) from (select * from v union select * from mv))
       -  (select count(*) from (select * from v union all select * from mv)) as expect_0
from dual;

create materialized view t1_rt_mv2
refresh fast on demand
enable on query computation
disable query rewrite
as
select a.c3 a_c3, b.c2 b_c2,
       count(*) cnt,
       count(e.c4) cnt_e_c4,
       sum(e.c4) sum_e_c4,
       count(c.c3) cnt_c_c3,
       sum(c.c3) sum_c_c3,
       avg(e.c4) avg_e_c4,
       sum(c.c3) * avg(e.c4) calc_1
from t1 a, t1 b, t1 c, t1 d, t1 e
where a.c2 = b.c3 and b.c2 = c.c4 and c.c2 = d.c3 and d.c4 = e.c2
group by a.c3, b.c2
;

create or replace view t1_v2 as
select a.c3 a_c3, b.c2 b_c2,
       count(*) cnt,
       count(e.c4) cnt_e_c4,
       sum(e.c4) sum_e_c4,
       count(c.c3) cnt_c_c3,
       sum(c.c3) sum_c_c3,
       avg(e.c4) avg_e_c4,
       sum(c.c3) * avg(e.c4) calc_1
from t1 a, t1 b, t1 c, t1 d, t1 e
where a.c2 = b.c3 and b.c2 = c.c4 and c.c2 = d.c3 and d.c4 = e.c2
group by a.c3, b.c2
;

create or replace view res_com2
as
with mv as (select /*+materialize*/ * from t1_rt_mv2),
     v as (select /*+materialize*/ * from t1_v2)
select 2 * (select count(*) from (select * from v union select * from mv))
       -  (select count(*) from (select * from v union all select * from mv)) as expect_0
from dual;

explain basic select * from t1_rt_mv1;
