| whh1     | whh1       | utf8mb4           | utf8mb4             |
+----------+------------+-------------------+---------------------+
select schema(),database(),coercibility(schema()),coercibility(database()) from dual;
+----------+------------+------------------------+--------------------------+
| schema() | database() | coercibility(schema()) | coercibility(database()) |
+----------+------------+------------------------+--------------------------+
| whh1     | whh1       |                      3 |                        3 |
+----------+------------+------------------------+--------------------------+
##日期时间函数 
select schema(),database(),day(schema()),day(database()) from dual;
+----------+------------+---------------+-----------------+
| schema() | database() | day(schema()) | day(database()) |
+----------+------------+---------------+-----------------+
| whh1     | whh1       |          NULL |            NULL |
+----------+------------+---------------+-----------------+
select schema(),database(),year(schema()),year(database()) from dual;
+----------+------------+----------------+------------------+
| schema() | database() | year(schema()) | year(database()) |
+----------+------------+----------------+------------------+
| whh1     | whh1       |           NULL |             NULL |
+----------+------------+----------------+------------------+
select schema(),database(),time(schema()),time(database()) from dual;
+----------+------------+-----------------+------------------+
| schema() | database() | time(schema())  | time(database()) |
+----------+------------+-----------------+------------------+
| whh1     | whh1       | 00:00:00.000000 | 00:00:00.000000  |
+----------+------------+-----------------+------------------+
##加密压缩函数(32x分支暂未支持)
select schema(),database(),md5(schema()),md5(database()) from dual;
+----------+------------+----------------------------------+----------------------------------+
| schema() | database() | md5(schema())                    | md5(database())                  |
+----------+------------+----------------------------------+----------------------------------+
| whh1     | whh1       | b994860a2a3d783d83af10064b6cacf1 | b994860a2a3d783d83af10064b6cacf1 |
+----------+------------+----------------------------------+----------------------------------+
select schema(),database(),sha(schema()),sha1(schema()),sha2(database(),0) from dual;
+----------+------------+------------------------------------------+------------------------------------------+------------------------------------------------------------------+
| schema() | database() | sha(schema())                            | sha1(schema())                           | sha2(database(),0)                                               |
+----------+------------+------------------------------------------+------------------------------------------+------------------------------------------------------------------+
| whh1     | whh1       | a88c2c72a84e9b874b1194d2232c9fc62623da66 | a88c2c72a84e9b874b1194d2232c9fc62623da66 | 57692f9dbaa64b0058ed019898f5f8d71cc0f1b8968e432fc6011bb315477b6e |
+----------+------------+------------------------------------------+------------------------------------------+------------------------------------------------------------------+
select schema(),database(),length(compress(schema())),uncompress(compress(schema())) from dual;
+----------+------------+----------------------------+--------------------------------+
| schema() | database() | length(compress(schema())) | uncompress(compress(schema())) |
+----------+------------+----------------------------+--------------------------------+
| whh1     | whh1       |                         16 | whh1                           |
+----------+------------+----------------------------+--------------------------------+
##流程控制函数
select schema(),database(),if(schema()<>'',1,2),if(database(),schema(),schema()) from dual;
+----------+------------+----------------------+----------------------------------+
| schema() | database() | if(schema()<>'',1,2) | if(database(),schema(),schema()) |
+----------+------------+----------------------+----------------------------------+
| whh1     | whh1       |                    1 | whh1                             |
+----------+------------+----------------------+----------------------------------+
select schema(),database(),ifnull(schema(),2),ifnull(null,schema()),ifnull(database(),null) from dual;
+----------+------------+--------------------+-----------------------+-------------------------+
| schema() | database() | ifnull(schema(),2) | ifnull(null,schema()) | ifnull(database(),null) |
+----------+------------+--------------------+-----------------------+-------------------------+
| whh1     | whh1       | whh1               | whh1                  | whh1                    |
+----------+------------+--------------------+-----------------------+-------------------------+
select schema(),database(),nullif(schema(),schema()),nullif(schema(),database()),nullif(1,database()) from dual;
+----------+------------+---------------------------+-----------------------------+----------------------+
| schema() | database() | nullif(schema(),schema()) | nullif(schema(),database()) | nullif(1,database()) |
+----------+------------+---------------------------+-----------------------------+----------------------+
| whh1     | whh1       | NULL                      | NULL                        |                    1 |
+----------+------------+---------------------------+-----------------------------+----------------------+
select schema(),database(),case schema() when 'whhtest' then 'schema()=whhtest'when database() then 'schema()=database()' else 'schema()!=whhtest' end as case_when from dual;
+----------+------------+---------------------+
| schema() | database() | case_when           |
+----------+------------+---------------------+
| whh1     | whh1       | schema()=database() |
+----------+------------+---------------------+
select schema(),database(),coalesce(null,schema(),1),coalesce(schema(),null),coalesce(database(),schema(),1) from dual;
+----------+------------+---------------------------+-------------------------+---------------------------------+
| schema() | database() | coalesce(null,schema(),1) | coalesce(schema(),null) | coalesce(database(),schema(),1) |
+----------+------------+---------------------------+-------------------------+---------------------------------+
| whh1     | whh1       | whh1                      | whh1                    | whh1                            |
+----------+------------+---------------------------+-------------------------+---------------------------------+
###schema-6-2 多级函数嵌套 
##自己嵌套自己
select schema(),database(),schema(schema()),database(database()) from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'database'
select schema(),database(),schema(schema(schema())),database(database(schema())) from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'database'
##自己嵌套其他函数
select schema(),database(),schema(abs(-1)),database(abs(-1)) from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'database'
