-------------------------- 标签：schema-7  其他场景 ----------------------------
----------------------------------------------------------------------------------


###连接到 mysql 服务器后，并没有使用 use 语句选择数据库，再用schema()查看
select schema(),database() from dual;
+----------+------------+
| schema() | database() |
+----------+------------+
| test     | test       |
+----------+------------+
###使用 use 语句切换了 mysql1 数据库，再用schema()查看
use whh1;
select schema(),database() from dual;
+----------+------------+
| schema() | database() |
+----------+------------+
| whh1     | whh1       |
+----------+------------+
###使用 use 语句再次切换了 mysql2 数据库，再用schema()查看
use whh2;
select schema(),database() from dual;
+----------+------------+
| schema() | database() |
+----------+------------+
| whh2     | whh2       |
+----------+------------+
###将当前数据库删除，再用schema()查看
drop database whh2;
select schema(),database() from dual;
+----------+------------+
| schema() | database() |
+----------+------------+
| NULL     | NULL       |
+----------+------------+
###在存储的例程中（存储过程、函数）
##默认数据库与调用上下文中的默认数据库相同同场合
use whh1;
drop procedure whh1.p_schema;//
create procedure whh1.p_schema()
begin
  select concat('★存储过程关联的数据库:schema()=',schema()) into @p from dual;
  select @p;
end;
//
drop function whh1.f_schema;//
create function whh1.f_schema() returns varchar(200) reads sql data 
begin
  return concat('★函数关联的数据库:schema()=',schema());
end;
//
select concat('★调用上下文中的默认数据库:schema()=',schema()) current_database from dual;//
+-------------------------------------------------------+
| current_database                                      |
+-------------------------------------------------------+
| ★调用上下文中的默认数据库:schema()=whh1               |
+-------------------------------------------------------+
call whh1.p_schema();//
+-------------------------------------------------+
| @p                                              |
+-------------------------------------------------+
| ★存储过程关联的数据库:schema()=whh1             |
+-------------------------------------------------+
select whh1.f_schema();//
+-------------------------------------------+
| whh1.f_schema()                           |
+-------------------------------------------+
| ★函数关联的数据库:schema()=whh1           |
+-------------------------------------------+
###在存储的例程中，默认数据库与调用上下文中的默认数据库不同场合
use whh3//
select concat('★调用上下文中的默认数据库:schema()=',schema()) current_database from dual;//
+-------------------------------------------------------+
| current_database                                      |
+-------------------------------------------------------+
| ★调用上下文中的默认数据库:schema()=whh3               |
+-------------------------------------------------------+
call whh1.p_schema();//
+-------------------------------------------------+
| @p                                              |
+-------------------------------------------------+
| ★存储过程关联的数据库:schema()=whh1             |
+-------------------------------------------------+
select whh1.f_schema();//
+-------------------------------------------+
| whh1.f_schema()                           |
+-------------------------------------------+
| ★函数关联的数据库:schema()=whh1           |
+-------------------------------------------+
# Clean up users
drop user whh@'%';
