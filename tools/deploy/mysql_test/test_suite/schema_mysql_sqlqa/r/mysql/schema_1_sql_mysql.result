##from 表 - 普通表 - schema()作为表中字段的default默认值 (mysql 8.0支持列default值为表达式，ob目前只有oracle模式支持，mysql模式不支持的。)
drop table schema_default;
create table schema_default(
  id int,
  bases varchar(200) default (database()),
  txt varchar(200)
);
