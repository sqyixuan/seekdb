##from 表 - 分区表(schema()函数作为分区键)
drop table schema_table5;
create table schema_table5 (
  n0 tinyint, 
  n1 int, 
  n2 varchar(200)
)
partition by range (schema())
(partition p0 values less than (1),
 partition p1 values less than (2),
 partition p2 values less than maxvalue);
ERROR HY000: Constant or random or timezone-dependent expressions in (sub)partitioning function are not allowed
##from 表 - 分区表(schema()函数作为list分区范围值)
drop table schema_table5;
create table schema_table5 (
  n0 tinyint, 
  n1 int, 
  n2 varchar(200)
)
partition by list (n1)
(partition p0 values in (schema()),
 partition p1 values in (1,3,5),
 partition p2 values in (2,4,6));
ERROR HY000: This partition function is not allowed
##from 表 - 分区表
drop table schema_table5;
create table schema_table5 (
  n0 tinyint, 
  n1 int, 
  n2 varchar(200)
)
partition by list (n1)
(partition p0 values in (7),
 partition p1 values in (1,3,5),
 partition p2 values in (2,4,6));
insert into schema_table5 values(1,2,'分区表1'),(3,4,'分区表1');
select schema() from schema_table5 order by n0;
