### 标签：schema-4-3 约束
DROP TABLE schema_table1;
CREATE TABLE schema_table1(
  id int PRIMARY KEY,
  name char(200) UNIQUE, 
  database1 varchar(200) NOT NULL,
  database2 varchar(200)
);
INSERT INTO schema_table1 VALUES(1,'楠楠','whh1','whh2'),(2,'康康','whhtest1','whhtest2');
#insert 
INSERT INTO schema_table1 VALUES(3,'洋洋',schema(),schema());
SELECT * FROM schema_table1 ORDER BY schema(),id;
+----+--------+-----------+-----------+
| id | name   | database1 | database2 |
+----+--------+-----------+-----------+
|  1 | 楠楠   | whh1      | whh2      |
|  2 | 康康   | whhtest1  | whhtest2  |
|  3 | 洋洋   | whh1      | whh1      |
+----+--------+-----------+-----------+
#update 
UPDATE schema_table1 set name = '洋洋-update' WHERE database1 = schema() and id=3;
SELECT *  FROM schema_table1 ORDER BY schema(),id;
+----+---------------+-----------+-----------+
| id | name          | database1 | database2 |
+----+---------------+-----------+-----------+
|  1 | 楠楠          | whh1      | whh2      |
|  2 | 康康          | whhtest1  | whhtest2  |
|  3 | 洋洋-update   | whh1      | whh1      |
+----+---------------+-----------+-----------+
#SELECT 
SELECT id,name,database1,database2,schema() FROM schema_table1 WHERE database1 > schema() ORDER BY id;
+----+--------+-----------+-----------+----------+
| id | name   | database1 | database2 | schema() |
+----+--------+-----------+-----------+----------+
|  2 | 康康   | whhtest1  | whhtest2  | whh1     |
+----+--------+-----------+-----------+----------+
SELECT id,name,database1,database2,schema() FROM schema_table1 WHERE database1 like schema() order by schema(),id desc;
+----+---------------+-----------+-----------+----------+
| id | name          | database1 | database2 | schema() |
+----+---------------+-----------+-----------+----------+
|  3 | 洋洋-update   | whh1      | whh1      | whh1     |
|  1 | 楠楠          | whh1      | whh2      | whh1     |
+----+---------------+-----------+-----------+----------+
#delete 
DELETE FROM schema_table1 WHERE database1 = concat(schema(),1);
SELECT *  FROM schema_table1 ORDER BY schema(),id;
+----+---------------+-----------+-----------+
| id | name          | database1 | database2 |
+----+---------------+-----------+-----------+
|  1 | 楠楠          | whh1      | whh2      |
|  2 | 康康          | whhtest1  | whhtest2  |
|  3 | 洋洋-update   | whh1      | whh1      |
+----+---------------+-----------+-----------+
# clean up users
drop user whh@'%';
