# owner: dachuan.sdc
# owner group: sql-sql2
# description: schema() 函数 - 运算符，函数间嵌套，其他场景
# tags: ddl,dml,pl
# author: whh01047778


purge recyclebin;
--result_format 4
--echo ### 测试环境准备
--error 0,1396
drop user whh@'%';
--error 0,1008
drop database whh1;
--error 0,1008
drop database whh2;
--error 0,1008
drop database whh3;
--enable_warnings
create user whh identified by 'whh';
create database whh1;
create database whh2;
create database whh3;
grant all on *.* to whh with grant option;
--source mysql_test/include/check_schema_sync.inc
connect (conn1,$obmysql_ms0,whh,whh,whh1,$obmysql_port);

set @@sql_mode='STRICT_ALL_TABLES';

--echo ------------------------------------------------------------------------------------------
--echo -------------------------- 用例：schema-5  运算符 ----------------------------------------
--echo ------------------------------------------------------------------------------------------
--error 0,1051
drop table schema_table1;
create table schema_table1(
  id int, 
  name varchar(100), 
  database1 varchar(100),
  primary key (id)
);
insert into schema_table1 values(1,'洋洋','whh1'),(2,'慧慧','whh2'),(3,'萌萌','whh3'),(4,'洋洋','whh1');
insert into schema_table1 values(5,'康康','whhtest'),(6,'宁宁','whhtest1'),(7,'洋洋','whhtest2'),(8,'康康','whhtest');

--echo ### 标签：schema-5-1 算术运算符
--error 1582
select schema(1+1-0*2/1) from dual;
--disable_warnings
select schema()+schema(),schema()-schema(),schema()*schema(),schema()/schema() from dual;
select schema() mod schema(),schema() div schema() from dual;
--enable_warnings

--echo ### 标签：schema-5-2 比较运算符
select id,name,database1,schema() from schema_table1 where database1 in (schema())  order by schema(),id;
select id,name,database1,schema() from schema_table1 where database1 not in (schema())  order by schema(),id;
select id,name,database1,schema() from schema_table1 where schema() like '%hh%'  order by schema(),id;
select id,name,database1,schema() from schema_table1 where database1 not like schema()  order by schema(),id;
select id,name,database1,schema() from schema_table1 where exists (select * from schema_table1 where database1 = schema())  order by schema(),id;
select id,name,database1,schema() from schema_table1 where schema() = any (select database1 from schema_table1 where database1 like schema()) order by schema(),id;
select id,name,database1,schema() from schema_table1 where schema() != all (select database1 from schema_table1 where database1 like schema()) order by schema(),id;
select id,name,database1,schema() from schema_table1 where schema() is null  order by schema(),id;
select id,name,database1,schema() from schema_table1 where schema() is not null order by schema(),id;
select id,name,database1,schema() from schema_table1 where schema() regexp '^w'  order by schema(),id;
select id,name,database1,schema() from schema_table1 where schema() not regexp '^1'  order by schema(),id;
select id,name,database1,schema() from schema_table1 where schema() rlike '^w.*1$'  order by schema(),id;
select id,name,database1,schema() from schema_table1 where schema() between 'a' and 'w'  order by schema(),id;
select id,name,database1,schema() from schema_table1 where database1 between schema() and schema()  order by schema(),id;
select id,name,database1,schema() from schema_table1 where database1 >= schema()  order by schema(),id;
select id,name,database1,schema() from schema_table1 where database1 <= schema()  order by schema(),id;
select id,name,database1,schema() from schema_table1 where database1 = schema()  order by schema(),id;
select id,name,database1,schema() from schema_table1 where database1 != schema()  order by schema(),id;
select id,name,database1,schema() from schema_table1 where database1 <> schema()  order by schema(),id;
select id,name,database1,schema() from schema_table1 where database1 <=> schema()  order by schema(),id;
select id,name,database1,schema() from schema_table1 where NULL <=> schema()  order by schema(),id;


--echo ### 标签：schema-5-3 逻辑运算符
--disable_warnings
select schema(),not schema(),not not schema() from dual;
select schema(),schema() and schema(),schema() and null,schema() and 1,schema() and 0 from dual;
select schema(),schema() or schema(),schema() or null,schema() or 1,schema() or 0 from dual;
select schema(),schema() xor schema(),schema() xor null,schema() xor 1,schema() xor 0 from dual;
--enable_warnings


--echo ### 标签：schema-5-4 位运算符
--disable_warnings
select schema(),schema() & schema(),schema() & null,schema() & 1,schema() & 0 from dual;
select schema(),schema() | schema(),schema() | null,schema() | 1,schema() | 0 from dual;
select schema(),schema() ^ schema(),schema() ^ null,schema() ^ 1,schema() ^ 0 from dual;
select schema(),!schema(),!!schema() from dual;
select schema(),schema()<<2,schema()>>2 from dual;
--enable_warnings


--echo ### 标签：schema-5-5 赋值运算符
SET @user_var1 :=  schema();
SET @user_var2 =  schema();
select @user_var1,@user_var2;


--error 0,1051
drop table schema_table1;
create table schema_table1(
  id int,
  bases varchar(200),
  txt varchar(200)
);

delimiter //;

--error 0,1305
drop procedure p_schema;//
create procedure p_schema()
begin
  declare local_var1 varchar(200);
  declare local_var2 varchar(200);
  set local_var1 := schema();
  set local_var2 = schema();
  insert into schema_table1 values(1,local_var1,local_var2);
end;
//

call p_schema();//
select * from schema_table1;//

delimiter ;//


--echo ----------------------------------------------------------------------------------
--echo -------------------------- 标签：schema-6  函数间嵌套 ----------------------------
--echo ----------------------------------------------------------------------------------
--echo ###schema-6-1,schema-6-2 函数嵌套,多级函数嵌套-其他函数嵌套自己   
--echo ## 数值型函数
--disable_warnings
select schema(),database(),abs(schema()),abs(database()) from dual;
select schema(),database(),sqrt(schema()),sqrt(database()) from dual;
select schema(),database(),mod(schema(),database()),mod(schema(),1),mod(database(),0) from dual;
select schema(),database(),floor(schema()),floor(database()) from dual;
select schema(),database(),round(schema()),round(schema()+5),round(database()) from dual;
select schema(),database(),rand(schema()),rand(database()) from dual;
--enable_warnings

--echo ## 聚合函数
--disable_warnings
select schema(),database(),max(schema()+2),max(database()) from dual;
select schema(),database(),min(schema()),min(database()) from dual;
select schema(),database(),sum(schema()),sum(database()) from dual;
select schema(),database(),avg(schema()),avg(database()) from dual;
select schema(),database(),count(schema()),count(database()) from dual;
--enable_warnings

--echo ##字符函数
select schema(),database(),instr(schema(),schema()),instr(schema(),'h'),instr(database(),'h') from dual;
select schema(),database(),insert(schema(),1,2,'gg'),insert(schema(),3,10,schema()) from dual;
select schema(),database(),concat(schema(),schema()),concat(schema(),111),concat(schema(),database()) from dual;
select schema(),database(),strcmp(schema(),schema()),strcmp(schema(),'whhtest'),strcmp(schema(),'whh1'),strcmp(schema(),database()) from dual;
select schema(),database(),substr(schema(),1,3),substr(database(),1,6) from dual;
select schema(),database(),length(schema()),length(database()) from dual;
select schema(),database(),rpad(schema(),10,'*'),rpad(schema(),10,0),lpad(schema(),10,'?'),lpad(database(),10,database()) from dual;
select schema(),database(),trim(schema()),ltrim(database()),rtrim(database()) from dual;


--echo ##信息函数
select schema(),database(),benchmark(2,schema()),benchmark(2,database()) from dual;
select schema(),database(),charset(schema()),charset(database()) from dual;
select schema(),database(),coercibility(schema()),coercibility(database()) from dual;


--echo ##日期时间函数 
--disable_warnings
select schema(),database(),day(schema()),day(database()) from dual;
select schema(),database(),year(schema()),year(database()) from dual;
select schema(),database(),time(schema()),time(database()) from dual;
--enable_warnings

--echo ##加密压缩函数(32x分支暂未支持)
select schema(),database(),md5(schema()),md5(database()) from dual;
select schema(),database(),sha(schema()),sha1(schema()),sha2(database(),0) from dual;
select schema(),database(),length(compress(schema())),uncompress(compress(schema())) from dual;


--echo ##流程控制函数
--disable_warnings
select schema(),database(),if(schema()<>'',1,2),if(database(),schema(),schema()) from dual;
select schema(),database(),ifnull(schema(),2),ifnull(null,schema()),ifnull(database(),null) from dual;
select schema(),database(),nullif(schema(),schema()),nullif(schema(),database()),nullif(1,database()) from dual;
select schema(),database(),case schema() when 'whhtest' then 'schema()=whhtest'when database() then 'schema()=database()' else 'schema()!=whhtest' end as case_when from dual;
select schema(),database(),coalesce(null,schema(),1),coalesce(schema(),null),coalesce(database(),schema(),1) from dual;
--enable_warnings


--echo ###schema-6-2 多级函数嵌套 
--echo ##自己嵌套自己
--error 1582
select schema(),database(),schema(schema()),database(database()) from dual;
--error 1582
select schema(),database(),schema(schema(schema())),database(database(schema())) from dual;


--echo ##自己嵌套其他函数
--error 1582
select schema(),database(),schema(abs(-1)),database(abs(-1)) from dual;


--echo ----------------------------------------------------------------------------------
--echo -------------------------- 标签：schema-7  其他场景 ----------------------------
--echo ----------------------------------------------------------------------------------
--source mysql_test/include/check_schema_sync.inc
connect (conn2,$obmysql_ms0,whh,whh,,$obmysql_port);


--echo ###连接到 mysql 服务器后，并没有使用 use 语句选择数据库，再用schema()查看
select schema(),database() from dual;


--echo ###使用 use 语句切换了 mysql1 数据库，再用schema()查看
use whh1;
select schema(),database() from dual;


--echo ###使用 use 语句再次切换了 mysql2 数据库，再用schema()查看
use whh2;
select schema(),database() from dual;


--echo ###将当前数据库删除，再用schema()查看
drop database whh2;
select schema(),database() from dual;


--echo ###在存储的例程中（存储过程、函数）
--echo ##默认数据库与调用上下文中的默认数据库相同同场合
use whh1;

delimiter //;

--error 0,1305
drop procedure whh1.p_schema;//
create procedure whh1.p_schema()
begin
  select concat('★存储过程关联的数据库:schema()=',schema()) into @p from dual;
  select @p;
end;
//

--error 0,1305
drop function whh1.f_schema;//
create function whh1.f_schema() returns varchar(200) reads sql data 
begin
  return concat('★函数关联的数据库:schema()=',schema());
end;
//

select concat('★调用上下文中的默认数据库:schema()=',schema()) current_database from dual;//
call whh1.p_schema();//
select whh1.f_schema();//


--echo ###在存储的例程中，默认数据库与调用上下文中的默认数据库不同场合
use whh3//
select concat('★调用上下文中的默认数据库:schema()=',schema()) current_database from dual;//
call whh1.p_schema();//
select whh1.f_schema();//


delimiter ;//

--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user whh@'%';
--enable_warnings
