purge recyclebin;
--result_format 4
--echo ### 测试环境准备
--error 0,1396
drop user whh@'%';
--error 0,1008
drop database whh1;
--error 0,1008
drop database whh2;
--enable_warnings
create user whh identified by 'whh';
create database whh1;
create database whh2;
grant all on *.* to whh with grant option;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$obmysql_ms0,whh,whh,whh1,$obmysql_port);

set @@sql_mode='STRICT_ALL_TABLES';

--echo ----------------------------------------------------------------------------------
--echo -------------------------- 标签：schema-3  pl/sql --------------------------------
--echo ----------------------------------------------------------------------------------
--error 0,1051
drop table schema_table1;
create table schema_table1(
  id int, 
  name varchar(100), 
  database1 varchar(100),
  primary key (id)
);
insert into schema_table1 values(1,'洋洋','whh1'),(2,'慧慧','whh2'),(3,'萌萌','whh3'),(4,'洋洋','whh1');
insert into schema_table1 values(5,'康康','whhtest'),(6,'宁宁','whhtest1'),(7,'洋洋','whhtest2'),(8,'康康','whhtest');

--error 1051
drop table schema_table2;
create table schema_table2(
  id int,
  database1 varchar(200),
  schema1 varchar(200),
  txt varchar(200)
);

--echo ###schema-3-1 存储过程
--echo ##无参数的存储过程
delimiter //;

--error 0,1305
drop procedure p_schema;//
create procedure p_schema()
begin
  declare v1 varchar(200);
  declare v2 varchar(200);
  select database(),schema() into v1,v2 from dual;
  select database(),schema() into @p1,@p2 from dual;
  insert into schema_table2 values(1,v1,v2,'无参存储过程');
end;
//

call p_schema();//
select @p1,@p2;//
select * from schema_table2 order by id;//

--echo ##只有一个in参数的存储过程
--error 0,1305
drop procedure p_schema;//
create procedure p_schema(in id int,in invalue varchar(200))
begin
  declare v1 varchar(200);
  declare v2 varchar(200);
  select database1,schema() into v1,v2 from schema_table1 where database1 = invalue limit 1;
  insert into schema_table2 values(id,v1,v2,'in参数的存储过程');
end;
//

call p_schema(2,schema());//
select * from schema_table2 order by id;//

--echo ##包含out参数的存储过程
--error 0,1305
drop procedure p_schema;//
create procedure p_schema(out outa varchar(200),out outb varchar(200))
begin
  select database1,schema() into outa,outb from schema_table1 where database1 like schema() limit 1;
  insert into schema_table2 values(3,outa,outb,'包含out参数的存储过程');
end;
//

call p_schema(@outa,@outb);//
select @outa,@outb;//
select * from schema_table2 order by id;//


--echo ##包含inout参数的存储过程
--error 0,1305
drop procedure p_schema;//
create  procedure p_schema(out outa varchar(200),inout inoutb varchar(200))
begin
  declare invalue varchar(200);
  set invalue := inoutb;
  select database1,schema() into outa,inoutb from schema_table1 where database1 > invalue limit 1;
  insert into schema_table2 values(4,outa,inoutb,'包含inout参数的存储过程');
end;
//

set @inoutb := schema();//
call p_schema(@outa,@outb);//
select @outa,@outb;//
select * from schema_table2 order by id;//


--echo ##dml语句
--echo #条件语句
--error 0,1305
DROP PROCEDURE p_schema;//
CREATE PROCEDURE p_schema(IN ina varchar(200),IN inb varchar(200))
begin
    IF schema() = 'whhtest' THEN 
	   INSERT INTO schema_table2 VALUES(5,ina,inb,'条件语句 schema()=whhtest');
    ELSE 
	   INSERT INTO schema_table2 VALUES(6,schema(),database(),'条件语句 schema()!=whhtest');
    END IF;
END;
//

SET @ina := 'if-ina';//
SET @inb := 'if-inb';//
CALL p_schema(@ina,@inb);//
select * from schema_table2 order by id;//

--echo #循环语句
--error 0,1305
DROP PROCEDURE p_schema;//
CREATE PROCEDURE p_schema()
begin
    declare i int default 7;
    WHILE i <= 9 do
      INSERT INTO schema_table2 VALUES(i,schema(),database(),'PROCEDURE-While 循环');
      set i := i+1;
    END WHILE;

    loop_name:LOOP
      INSERT INTO schema_table2 VALUES(i,schema(),database(),'PROCEDURE-LOOP 循环');
      SET i := i+1;
      IF i > 12 THEN 
	    LEAVE loop_name;
      END IF;
    END LOOP loop_name;

    REPEAT
      INSERT INTO schema_table2 VALUES(i,schema(),database(),'PROCEDURE-REPEAT 循环');
      SET i := i+1;
      until i > 15	
    END  REPEAT;
END;
//

CALL p_schema();//
select * from schema_table2 order by id;//

use whh2//
CALL whh1.p_schema();//
select * from whh1.schema_table2 order by id;//


--echo ##游标
use whh1//
--error 0,1305
drop procedure p_schema;//
create procedure p_schema()
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 16;
	declare done int default 0;
	declare schema_cursor cursor for select database1,schema() from schema_table1 where database1 >= schema() order by id;
	declare continue handler for sqlstate 'HY000' 
	begin
	  set done=1;
	  insert into schema_table2 values(i+1,'handler','handler','游标结束');
	end;
	
	open schema_cursor;
	fetch schema_cursor into a,b;
	while done<>1 do
      insert into schema_table2 values(i,a,b,'游标读取');
      fetch schema_cursor into a,b;
	  SET i := i+1;
	end while;
	close schema_cursor;
end;
//

select * from schema_table2 order by id;//


--echo ##动态sql
--error 0,1305
drop procedure p_schema;//
create procedure p_schema()
begin
  set @s = 'insert into schema_table2 values(?,?,?,"动态sql插入的数据");';
  prepare stmt1 from @s;
  set @id = 21;
  set @a = database();
  set @b = schema();
  execute stmt1 using  @id,@a,@b;
  
  prepare stmt1 from @s;
  set @id = 22;
  execute stmt1 using  @id,@a,@b;

  prepare stmt1 from @s;
  set @id = 23;
  execute stmt1 using  @id,@a,@b;
  
  set @s = 'select * from schema_table2 where schema1 = ? and id >=21';
  prepare stmt2 from @s;
  set @a = schema();
  execute stmt2 using @a; 
end;
//

delete from schema_table2;
call p_schema();//


--error 0,1305
DROP PROCEDURE p_schema;//
CREATE PROCEDURE p_schema()
BEGIN
  SET @s = 'update schema_table2 set schema1 = concat(?,"-update"),txt=? where schema1 = ? and id =22';
  PREPARE stmt1 FROM @s;
  SET @a = schema();
  SET @b = "动态sql更新的数据";
  EXECUTE stmt1 USING @a,@b,@a;
  
  SET @s = 'delete FROM schema_table2 where schema1 = ? and id =23';
  PREPARE stmt2 FROM @s;
  SET @a = schema();
  EXECUTE stmt2 USING @a;

  SET @s = 'select * from schema_table2 where id >= 21';
  PREPARE stmt3 FROM @s;
  EXECUTE stmt3;  
END;
//

CALL p_schema();//


--echo ##函数返回值作为存储过程的参数传递
--error 0,1305
DROP FUNCTION f_schema;//
CREATE FUNCTION f_schema() RETURNS varchar(200) READS SQL DATA 
BEGIN
  RETURN schema();
END;
//

--error 0,1305
drop procedure p_schema;//
create PROCEDURE p_schema(in infun varchar(200))
begin
  INSERT INTO schema_table2 VALUES(24,infun,schema(),'函数返回值作为存储过程的参数传递');
END;
//

CALL p_schema(f_schema());//
select * from schema_table2 order by id;//


--echo ### 标签：schema-3-2 函数    
--echo #定义一个无参的函数
--error 0,1305
drop function f_schema;//
create function f_schema() returns varchar(200) reads sql data 
begin
  declare a varchar(200);
  select schema() into a from dual;
  return concat('schema(): ',a);
end;
//

select f_schema();//


--echo #定义一个有参的函数
--error 0,1305
DROP FUNCTION f_schema;//
CREATE FUNCTION f_schema(invalue varchar(200)) returns varchar(200) READS SQL DATA 
begin
  declare a varchar(200);
  select schema1 into a from schema_table2 where schema1 >= invalue limit 1;
  return concat('schema1: ',a);
END ;
//

SELECT f_schema(schema());//

--echo ##dml语句
--echo #条件语句
--error 0,1305
drop function f_schema;//
create function f_schema(ina varchar(200),inb varchar(200))returns varchar(200) deterministic
begin
   if schema() = 'whhtest' then 
     insert into schema_table2 values(25,ina,inb,'条件语句 schema()=whhtest');
   else 
     insert into schema_table2 values(26,schema(),database(),'条件语句 schema()!=whhtest');
   end if;
   return concat('schema(): ',schema());
end;
//

set @ina := 'if-ina';//
set @inb := 'if-inb';//
SELECT f_schema(@ina,@inb);//
select * from schema_table2 order by id;//


--echo #循环语句
--error 0,1305
DROP FUNCTION f_schema;//
CREATE  FUNCTION f_schema() returns varchar(200) DETERMINISTIC
begin
    declare i int default 27;
    WHILE i <= 29 do
      INSERT INTO schema_table2 VALUES(i,schema(),database(),'FUNCTION-While 循环');
      set i := i+1;
    END WHILE;

    loop_name:LOOP
      INSERT INTO schema_table2 VALUES(i,schema(),database(),'FUNCTION-LOOP 循环');
      SET i := i+1;
      IF i > 32 THEN 
	    LEAVE loop_name;
      END IF;
    END LOOP loop_name;

    REPEAT
      INSERT INTO schema_table2 VALUES(i,schema(),database(),'FUNCTION-REPEAT 循环');
      SET i := i+1;
      until i > 35	
    END  REPEAT;
	return concat('schema(): ',schema());
END;
//

SELECT f_schema();//
select * from schema_table2 order by id;//

use whh2//
SELECT whh1.f_schema();//
select * from whh1.schema_table2 order by id;//


--echo ### 标签：sha-3-3 触发器    
use whh1//
--error 0,1360
DROP TRIGGER base_pl;//
CREATE TRIGGER base_pl BEFORE INSERT
ON schema_table1 FOR EACH ROW
BEGIN
	DECLARE a int;
	DECLARE b VARCHAR(20);
	set a=36;
	set b='insert';
	loop1: LOOP
	  if a < 40 then
	    INSERT INTO schema_table2 VALUES(a,schema(),database(),'触发器插入数据');
	  elseif a = 41 then
	    update schema_table2 set schema1 = concat(schema(),'-update'), txt ='触发器更新数据' WHERE id = 38;
	    LEAVE loop1;
	  else
	    delete FROM schema_table2 WHERE id = 39;	
	  end if;
	  set a = a + 1;
	end LOOP loop1;
END;
//

delete from schema_table2;//
INSERT INTO schema_table1 VALUES(10,'触发器','whh');//
SELECT * FROM schema_table2 ORDER BY id;//

DELIMITER ;//

--echo ----------------------------------------------------------------------------------
--echo -------------------- 标签：schema-4  视图，索引，约束 ----------------------------
--echo ----------------------------------------------------------------------------------
--echo ### 表，视图创建
--error 0,1051
drop table schema_table1;
create table schema_table1(
  id int, 
  name varchar(100), 
  database1 varchar(100),
  primary key (id)
);
insert into schema_table1 values(1,'洋洋','whh1'),(2,'慧慧','whh2'),(3,'萌萌','whh3'),(4,'洋洋','whh1');
insert into schema_table1 values(5,'康康','whhtest'),(6,'宁宁','whhtest1'),(7,'洋洋','whhtest2'),(8,'康康','whhtest');

--error 0,1051
drop table schema_table2;
create table schema_table2(
  id int,
  fun varchar(200)
);
insert into schema_table2 values(1,'schema()'),(2,'sha()'),(3,'compress()');
insert into schema_table2 values(4,'year()'),(5,'week()'),(6,'to_data()');


--error 0,1051
drop view t1_view;
create view t1_view as select * from schema_table1;

--error 0,1051
drop view t2_view;
create view t2_view as select * from schema_table2;


--echo ### 标签：sha-4-1 视图
--echo ### SELECT
select id,name,database1,schema() from t1_view;
select id,name,database1,schema() from t1_view where database1 like schema() order by id;

--echo ##where 子句
select id,name,database1,schema() from t1_view where database1 >= schema() order by id;
select id,name,database1,schema() from t1_view where database1 like schema() order by id;

--echo ##order by 子句
select id,name,database1,schema() from t1_view where database1 >= schema() order by schema() asc,id;
select id,name,database1,schema() from t1_view where database1 >= schema() order by schema() desc,id;

--echo ##group by having 子句
select id,name,database1,schema() from t1_view where database1 <= schema() group by schema() order by id ;
select id,name,database1,schema() from t1_view where database1 <= schema() group by schema(),id having database1 >= schema() order by id;

--echo #distinct
select distinct schema(),id,name,database1 from t1_view order by id;
select distinct schema(),id,name,database1 from t1_view where database1 != schema() order by id;

--echo #case when
select id,name,database1,schema(),case when database1 < schema() then 'database1 < schema()' else 'database1 >= schema()' end case_when from schema_table1 order by id;
select id,name,database1,schema(),case database1 when schema() then 'database1 = schema()' else 'database1 != schema()' end case_when from schema_table1 order by id; 

--echo #select ...into 
select schema() into @p1 from dual;
select concat(id,name,database1,schema()) into @p2 from t1_view where database1 = schema() limit 1;
select schema() into @p3 from t1_view where database1 > schema() and id < 7 order by id limit 1;
select @p1,@p2,@p3;

--echo ##连接查询
select e.id,e.name,e.database1,p.fun,schema() from t1_view e, t2_view p where e.id = p.id and e.database1 >= schema() order by e.id desc;
select e.id,e.name,e.database1,p.fun,schema() from t1_view e left join t2_view p on e.id = p.id where e.database1 >= schema() order by e.id desc;
select e.id,e.name,e.database1,p.fun,schema() from t1_view e right join t2_view p on e.id = p.id where e.database1 >= schema() order by e.id desc;
select e.id,e.name,e.database1,p.fun,schema() from t1_view e inner join t2_view p on e.id = p.id where e.database1 >= schema() order by e.id desc;

--echo ##select嵌套
--echo #SELECT
select t.id,t.name,t.database1,t.fun,schema() from (select e.id,e.name,e.database1,p.fun,schema() from t1_view e, t2_view p where e.id = p.id) t order by t.id; 
select t.id,t.name,t.database1,schema() from t1_view t where t.database1 in (select e.database1 from t1_view e, t2_view p where e.id = p.id) order by t.id; 

--echo #EXISTS AND NOT EXISTS
select id,name,database1,schema() from t1_view e where exists (select e.id,e.name,e.database1,p.fun,schema() from t1_view e inner join t2_view p on e.id = p.id where e.database1 >= schema()) order by id;
select id,name,database1,schema() from t1_view e where not exists (select e.id,e.name,e.database1,p.fun,schema() from t1_view e inner join t2_view p on e.id = p.id where e.database1 = schema() and e.id < 2) order by id;

--echo #any
select id,name,database1,schema() from t1_view e where schema() = any (select distinct e.database1 from t1_view e left join t2_view p on e.id = p.id where e.database1 >= schema()) order by e.id;
select id,name,database1,schema() from t1_view e where schema() < any (select distinct e.database1 from t1_view e left join t2_view p on e.id = p.id where e.database1 >= schema()) order by e.id;
select id,name,database1,schema() from t1_view e where schema() > any (select distinct e.database1 from t1_view e left join t2_view p on e.id = p.id where e.database1 >= schema()) order by e.id;

--echo #all                                                                                    
select id,name,database1,schema() from t1_view e where schema() = all (select distinct e.database1 from t1_view e left join t2_view p on e.id = p.id where e.database1 >= schema()) order by e.id;
select id,name,database1,schema() from t1_view e where schema() < all (select distinct e.database1 from t1_view e left join t2_view p on e.id = p.id where e.database1 >= schema()) order by e.id;
select id,name,database1,schema() from t1_view e where schema() > all (select distinct e.database1 from t1_view e left join t2_view p on e.id = p.id where e.database1 >= schema()) order by e.id;

--echo #create as
--error 0,1051
drop view t3_view;
create view t3_view as select id,name,database1,schema() from t1_view where database1>schema(); 
select * from t3_view order by id;

--echo #insert into select
--error 1348
insert into t3_view select id,name,database1,schema() from t1_view where database1=schema();
--error 1471
insert into t3_view(id,name,database1) select id,name,database1 from t1_view where database1=schema();
select * from t3_view order by id;

--echo #update set
update t3_view e inner join t2_view p on e.id = p.id set e.database1=schema() where e.id = 6;
select * from t3_view order by id;

--echo #with as的select
with a as (select e.id,e.name,e.database1,p.fun,schema() from t1_view e inner join t2_view p on e.id = p.id ) select a.id,a.name,a.database1,a.fun from a order by a.id;
with a as (select e.id,e.name,e.database1,p.fun,schema() from t1_view e inner join t2_view p on e.id = p.id where e.database1 >= schema()) select a.id,a.name,a.database1,a.fun from a order by a.id;

--echo #模糊查询like 
select id,name,database1,schema() from t1_view where database1 like (select e.database1 from t1_view e inner join t2_view p on e.id = p.id where e.database1 >= schema() limit 1) order by id;
select e.id,e.name,e.database1,schema() from t1_view e left join t2_view p on e.id = p.id where schema() like '%whh%' order by e.id;


--echo ### 标签：schema-2-2 insert
--error 0,1051
drop table schema_table4;
create table schema_table4(
  id int primary key, 
  name varchar(100), 
  database1 varchar(100),
  cur_schema varchar(100)
);

--error 0,1051
drop view t4_view;
create view t4_view as select * from schema_table4;

--echo ##values
insert into t4_view values(1,'insert1',schema(),schema()),(2,'insert2',concat(schema(),schema()),schema());
select * from  t4_view order by id;

--echo ##insert ... select 语句
insert into t4_view select id,name,database1,schema() from schema_table1 where database1 like '%2%' and id != 2;
insert into t4_view select id,name,database1,schema() from schema_table1 where database1 > schema() and database1 not like '%2%' order by schema(),id desc;
insert into t4_view select id+1,name,database1,schema() from schema_table1 where database1 != schema() group by schema(),id having database1 like '%3%';
select * from  t4_view order by id;

--echo ##insert ... on duplicate key update 语句
insert into t4_view values (1,'insert1',schema(),schema()) on duplicate key update database1=concat('duplicate-',schema());
select * from  t4_view order by id;

--echo ##insert delayed 语句
--error 1064
insert delayed into t4_view values(4,'insert4',schema(),schema());
select * from  t4_view order by id;


--echo ### 标签：schema-2-3 update
update t1_view set database1 = concat('update-',schema()) where database1 = schema() order by schema(),id desc;
update t1_view set database1 = (select concat(fun,schema()) from schema_table2 group by schema(),id having id = 1 order by schema(),id )where id = 1 ;
select * from  t1_view order by id;


--echo ### 标签：schema-2-4 delete
select * from  t4_view order by id;
delete from t4_view where database1 > schema() order by schema(),id desc;
select * from  t4_view order by id;


--echo ### 标签：schema-2-5 replace 
replace into t1_view values(5,'replace',concat('replace-',schema()));
select * from t1_view where id = 5;


--echo ### 标签：schema-2-6 prepare   
PREPARE stmt_name FROM 'select id,name,database1,schema() from t1_view e where database1 >= ? order by id';
set @q = schema();
EXECUTE stmt_name USING @q;
DROP PREPARE stmt_name;


