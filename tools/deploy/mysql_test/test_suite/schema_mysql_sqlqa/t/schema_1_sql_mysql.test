--echo ------------------------------------------------------------------------------------------
--echo -------------------------- 用例：schema-2  sql -------------------------------------------
--echo ------------------------------------------------------------------------------------------
--error 0,1051
drop table schema_table1;
create table schema_table1(
  id int, 
  name varchar(100), 
  database1 varchar(100),
  primary key (id)
);
insert into schema_table1 values(1,'洋洋','whh1'),(2,'慧慧','whh2'),(3,'萌萌','whh3'),(4,'洋洋','whh1');
insert into schema_table1 values(5,'康康','whhtest'),(6,'宁宁','whhtest1'),(7,'洋洋','whhtest2'),(8,'康康','whhtest');

--error 0,1051
drop table schema_table2;
create table schema_table2(
  id int,
  fun varchar(200)
);
insert into schema_table2 values(1,'schema()'),(2,'sha()'),(3,'compress()');
insert into schema_table2 values(4,'year()'),(5,'week()'),(6,'to_data()');


--echo ### 标签：schema-2-1 select
--echo ##多列/单列
select  schema() from schema_table1 order by id;
select concat(schema(),id,name) from schema_table1 order by id;

--echo ##from 表 - 分区表(schema()函数作为分区键)
--error 0,1051
drop table schema_table5;
--error 1486
create table schema_table5 (
  n0 tinyint, 
  n1 int, 
  n2 varchar(200)
)
partition by range (schema())
(partition p0 values less than (1),
 partition p1 values less than (2),
 partition p2 values less than maxvalue);


--echo ##from 表 - 分区表(schema()函数作为list分区范围值)
--error 0,1051
drop table schema_table5;
--error 1564
create table schema_table5 (
  n0 tinyint, 
  n1 int, 
  n2 varchar(200)
)
partition by list (n1)
(partition p0 values in (schema()),
 partition p1 values in (1,3,5),
 partition p2 values in (2,4,6));

--echo ##from 表 - 分区表
--error 0,1051
drop table schema_table5;
create table schema_table5 (
  n0 tinyint, 
  n1 int, 
  n2 varchar(200)
)
partition by list (n1)
(partition p0 values in (7),
 partition p1 values in (1,3,5),
 partition p2 values in (2,4,6));
insert into schema_table5 values(1,2,'分区表1'),(3,4,'分区表1');

select schema() from schema_table5 order by n0;

--echo ##from 表 - 虚拟表
select schema() from dual;
select schema() from dual where schema() != '';

--echo ##from 表 - 普通表 - schema()作为表中字段的default默认值 (mysql 8.0支持列default值为表达式，ob目前只有oracle模式支持，mysql模式不支持的。)
--error 0,1051
drop table schema_default;
create table schema_default(
  id int,
  bases varchar(200) default (database()),
  txt varchar(200)
);

insert into schema_default(id) values(1),(2),(3),(4);

--sorted_result
select * from schema_default order by id;


--echo ##from 表 - 普通表
select id,name,database1,schema() from schema_table1;
select id,name,database1,schema() from schema_table1 where database1 like schema() order by id;

--echo ##where 子句
select id,name,database1,schema() from schema_table1 where database1 >= schema() order by id;
select id,name,database1,schema() from schema_table1 where database1 like schema() order by id;

--echo ##order by 子句
select id,name,database1,schema() from schema_table1 where database1 >= schema() order by schema() asc,id;
select id,name,database1,schema() from schema_table1 where database1 >= schema() order by schema() desc,id;

--echo ##group by having 子句
select id,name,database1,schema() from schema_table1 where database1 <= schema() group by schema() order by id ;
select id,name,database1,schema() from schema_table1 where database1 <= schema() group by schema(),id having database1 >= schema() order by id;

--echo #distinct
select distinct schema(),id,name,database1 from schema_table1 order by id;
select distinct schema(),id,name,database1 from schema_table1 where database1 != schema() order by id;

--echo #case when
select id,name,database1,schema(),case when database1 < schema() then 'database1 < schema()' else 'database1 >= schema()' end case_when from schema_table1 order by id;
select id,name,database1,schema(),case database1 when schema() then 'database1 = schema()' else 'database1 != schema()' end case_when from schema_table1 order by id; 

--echo #select ...into 
select schema() into @p1 from dual;
select concat(id,name,database1,schema()) into @p2 from schema_table1 where database1 = schema() limit 1;
select schema() into @p3 from schema_table1 where database1 < schema() and id < 2 order by id;
select @p1,@p2,@p3;

--echo ##连接查询
select e.id,e.name,e.database1,p.fun,schema() from schema_table1 e, schema_table2 p where e.id = p.id and e.database1 >= schema() order by e.id desc;
select e.id,e.name,e.database1,p.fun,schema() from schema_table1 e left join schema_table2 p on e.id = p.id where e.database1 >= schema() order by e.id desc;
select e.id,e.name,e.database1,p.fun,schema() from schema_table1 e right join schema_table2 p on e.id = p.id where e.database1 >= schema() order by e.id desc;
select e.id,e.name,e.database1,p.fun,schema() from schema_table1 e inner join schema_table2 p on e.id = p.id where e.database1 >= schema() order by e.id desc;

--echo ##select嵌套
--echo #SELECT
select t.id,t.name,t.database1,t.fun,schema() from (select e.id,e.name,e.database1,p.fun,schema() from schema_table1 e, schema_table2 p where e.id = p.id) t order by t.id; 
select t.id,t.name,t.database1,schema() from schema_table1 t where t.database1 in (select e.database1 from schema_table1 e, schema_table2 p where e.id = p.id) order by t.id; 

--echo #EXISTS AND NOT EXISTS
select id,name,database1,schema() from schema_table1 e where exists (select e.id,e.name,e.database1,p.fun,schema() from schema_table1 e inner join schema_table2 p on e.id = p.id where e.database1 >= schema()) order by id;
select id,name,database1,schema() from schema_table1 e where not exists (select e.id,e.name,e.database1,p.fun,schema() from schema_table1 e inner join schema_table2 p on e.id = p.id where e.database1 = schema() and e.id < 2) order by id;

--echo #any
select id,name,database1,schema() from schema_table1 e where schema() = any (select distinct e.database1 from schema_table1 e left join schema_table2 p on e.id = p.id where e.database1 >= schema()) order by e.id;
select id,name,database1,schema() from schema_table1 e where schema() < any (select distinct e.database1 from schema_table1 e left join schema_table2 p on e.id = p.id where e.database1 >= schema()) order by e.id;
select id,name,database1,schema() from schema_table1 e where schema() > any (select distinct e.database1 from schema_table1 e left join schema_table2 p on e.id = p.id where e.database1 >= schema()) order by e.id;

--echo #all                                                                                    
select id,name,database1,schema() from schema_table1 e where schema() = all (select distinct e.database1 from schema_table1 e left join schema_table2 p on e.id = p.id where e.database1 >= schema()) order by e.id;
select id,name,database1,schema() from schema_table1 e where schema() < all (select distinct e.database1 from schema_table1 e left join schema_table2 p on e.id = p.id where e.database1 >= schema()) order by e.id;
select id,name,database1,schema() from schema_table1 e where schema() > all (select distinct e.database1 from schema_table1 e left join schema_table2 p on e.id = p.id where e.database1 >= schema()) order by e.id;

--echo #create as
--error 0,1051
drop table schema_table3;
create table schema_table3 as select id,name,database1,schema() from schema_table1 where database1>schema(); 
select * from schema_table3 order by id;

--echo #insert into select
insert into schema_table3 select id,name,database1,schema() from schema_table1 where database1=schema();
select * from schema_table3 order by id;

--echo #update set
update schema_table3 e inner join schema_table2 p on e.id = p.id set e.database1=schema() where e.id = 6;
select * from schema_table3 order by id;

--echo #with as的select
with a as (select e.id,e.name,e.database1,p.fun,schema() from schema_table1 e inner join schema_table2 p on e.id = p.id ) select a.id,a.name,a.database1,a.fun from a order by a.id;
with a as (select e.id,e.name,e.database1,p.fun,schema() from schema_table1 e inner join schema_table2 p on e.id = p.id where e.database1 >= schema()) select a.id,a.name,a.database1,a.fun from a order by a.id;

--echo #模糊查询like 
select id,name,database1,schema() from schema_table1 where database1 like (select e.database1 from schema_table1 e inner join schema_table2 p on e.id = p.id where e.database1 >= schema() limit 1) order by id;
select e.id,e.name,e.database1,schema() from schema_table1 e left join schema_table2 p on e.id = p.id where schema() like '%whh%' order by e.id;


--echo ### 标签：schema-2-2 insert
--error 0,1051
drop table schema_table4;
create table schema_table4(
  id int primary key, 
  name varchar(100), 
  database1 varchar(100),
  cur_schema varchar(100)
);

--echo ##values
insert into schema_table4 values(1,'insert1',schema(),schema()),(2,'insert2',concat(schema(),schema()),schema());
select * from  schema_table4 order by id;

--echo ##insert ... select 语句
insert into schema_table4 select id,name,database1,schema() from schema_table1 where database1 like '%2%' and id != 2;
insert into schema_table4 select id,name,database1,schema() from schema_table1 where database1 > schema() and database1 not like '%2%' order by schema(),id desc;
insert into schema_table4 select id+1,name,database1,schema() from schema_table1 where database1 != schema() group by schema(),id having database1 like '%3%';
select * from  schema_table4 order by id;

--echo ##insert ... on duplicate key update 语句
insert into schema_table4 values (1,'insert1',schema(),schema()) on duplicate key update database1=concat('duplicate-',schema());
select * from  schema_table4 order by id;

--echo ##insert delayed 语句 (ob(32x)暂不支持)
--error 1064
insert delayed into schema_table4 values(4,'insert4',schema(),schema());
select * from  schema_table4 order by id;


--echo ### 标签：schema-2-3 update
update schema_table1 set database1 = concat('update-',schema()) where database1 = schema() order by schema(),id desc;
update schema_table1 set database1 = (select concat(fun,schema()) from schema_table2 group by schema(),id having id = 1 order by schema(),id )where id = 1 ;
select * from  schema_table1 order by id;


--echo ### 标签：schema-2-4 delete
select * from  schema_table4 order by id;
delete from schema_table4 where database1 < schema() order by schema(),id desc;
select * from  schema_table4 order by id;


--echo ### 标签：schema-2-5 replace   
replace into schema_table1 values(5,'replace',concat('replace-',schema()));
select * from schema_table1 where id = 5;


--echo ### 标签：schema-2-6 prepare   
prepare stmt_name from 'select id,name,database1,schema() from schema_table1 e where database1 >= ? order by id';
set @q = schema();
execute stmt_name using @q;
drop prepare stmt_name;

--echo ### 标签：schema-2-7 do 语句  (ob(32x)暂不支持)

do schema(),database();

--echo ### 标签：schema-2-8 handler  语句 (ob(32x)暂不支持)
--error 0,1051
drop table schema_table1;
create table schema_table1(
  id int,
  bases varchar(200),
  txt varchar(200)
);
create index handler_index on schema_table1(bases);

insert into schema_table1 values(1,'whh','default1'),(2,'whh1','default2'),(3,'whh2','default3');

--error 1064
handler schema_table1 open as p;
handler p read handler_index = (schema());
handler p close;


--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user whh@'%';
--enable_warnings
