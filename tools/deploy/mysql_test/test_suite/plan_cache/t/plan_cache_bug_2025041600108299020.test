#owner: gongyusen.gys
#owner group: sql2

--result_format 4
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 varchar(1024));
alter system flush plan cache;
explain insert into t1 values (null,concat(c1,c1));
insert into t1 values (null,concat(c1,c1));
explain insert into t1 values ('4',concat(c1,c1));
insert into t1 values ('4',concat(c1,c1));
select * from t1;

drop table t1;
