
#owner: luofan.zp
#owner group: sql1
##
## Test Name: plan_cache_basic
##
## Scope: Test basic function of plan cache match
##
## INFO:  if you want to add case; you should read ../README.md;
#         don't use sys tenant, because when parallel run on obfarm, the hit_count can't be expected;
#         so we use new tenant, new plan cache will be  used for this case only;
##
##
## Date: 2015-9-16
##

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--disable_result_log
connection conn_admin;
alter system flush plan cache global;
connection default;
drop table if exists t;
create table t(c1 int);

--echo
--echo ********************cluster configs***************
--echo
--echo ********************_enable_px_ordered_coord***************
connection conn_admin;
alter system set _enable_px_ordered_coord=false;
--sleep 3
alter system flush plan cache global;
connection default;
select * from t;
--enable_result_log
select hit_count, query_sql, configs from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select * from t';
--disable_result_log

connection conn_admin;
alter system set _enable_px_ordered_coord=true;
--sleep 3

connection default;
select * from t;
--enable_result_log
select hit_count, query_sql, configs from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select * from t';
--disable_result_log

connection conn_admin;
alter system set _enable_px_ordered_coord=false;
--sleep 3
alter system flush plan cache global;


--echo
--echo ********************tenant configs***************
--echo ********************_enable_px_batch_rescan***************
connection conn_admin;
alter system flush plan cache global;
connection default;
alter system set _enable_px_batch_rescan=true;
--sleep 3
select * from t;
--enable_result_log
select hit_count, query_sql, configs from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select * from t';
--disable_result_log

alter system set _enable_px_batch_rescan=false;
--sleep 3

select * from t;
--enable_result_log
select hit_count, query_sql, configs from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select * from t';
--disable_result_log
alter system set _enable_px_batch_rescan=true;
--sleep 3
connection conn_admin;
alter system flush plan cache global;

--echo
--echo ********************_rowsets_enabled***************
connection conn_admin;
alter system flush plan cache global;
connection default;
alter system set _rowsets_enabled=false;
--sleep 3
select * from t;
--enable_result_log
select hit_count, query_sql, configs from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select * from t';
--disable_result_log

alter system set _rowsets_enabled=true;
--sleep 3

select * from t;
--enable_result_log
select hit_count, query_sql, configs from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select * from t';
--disable_result_log
alter system set _rowsets_enabled=false;
--sleep 3
connection conn_admin;
alter system flush plan cache global;

--echo
--echo ********************_bloom_filter_enabled***************
connection conn_admin;
alter system flush plan cache global;
connection default;
alter system set _bloom_filter_enabled=true;
--sleep 3
select * from t;
--enable_result_log
select hit_count, query_sql, configs from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select * from t';
--disable_result_log

alter system set _bloom_filter_enabled=false;
--sleep 3

select * from t;
--enable_result_log
select hit_count, query_sql, configs from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select * from t';
--disable_result_log
alter system set _bloom_filter_enabled=true;

--sleep 3
connection conn_admin;
alter system flush plan cache global;

--echo
--echo ********************end***************

connection default;
drop table t;
alter system set _rowsets_enabled=true;
connection conn_admin;
alter system flush plan cache global;
