#owner:luofan.zp
#owner group: sql-sql2
#description: udf内部SQL命中plan cache测试
#tags:udf, plan_cache
#author: luofan.zp
--disable_query_log

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

alter system flush plan cache global;
alter system flush sql audit global;
drop table if exists t1, t2;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);
create table t2(id int ,s1 int, s2 int);
insert into t2 values(1, 1, 1);
--error 0, 1305
drop function n_1;
delimiter /;
create function n_1() returns int      
begin
  declare ret_id int default 0;
  select id into ret_id from t2 where id=1;
  return ret_id;
end/

delimiter ;/

set @@tx_read_only = 1;
select * from t1 where stats=n_1();
select * from t1 where stats=n_1();

select query_sql, is_hit_plan from oceanbase.gv$ob_sql_audit where query_sql like 'select id  from t2 where id=1';

set @@tx_read_only = 0;

--error 0, 1305
drop function n_1;
drop table if exists t1, t2;
