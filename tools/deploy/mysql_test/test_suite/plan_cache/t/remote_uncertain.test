#owner: luofan.zp
#owner group: sql1
#tags: optimizer

--result_format 4
--enable_sorted_result
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_info
--disable_metadata

alter system flush plan cache global;
alter system set enable_auto_leader_switch=false;

--enable_query_log
--enable_result_log
connection default;
set ob_trx_timeout = 1000000000000;
set autocommit = 0;

--disable_warnings
drop table if exists t;
--enable_warnings

create table t (pk int primary key, a int);

create index idx_t on t(a) global partition by hash(a) partitions 2;

insert into t values (1,1), (2,2);

select /*+ index(t idx_t)*/* from t where a in (1, 1);
select /*+ index(t idx_t)*/* from t where a in (2, 2);
select /*+ index(t idx_t)*/* from t where a in (1, 2);
select /*+ index(t idx_t)*/* from t where a in (1, 2);

explain select /*+ index(t idx_t)*/* from t where a in (1, 1);
explain select /*+ index(t idx_t)*/* from t where a in (2, 2);
explain select /*+ index(t idx_t)*/* from t where a in (1, 2);

--echo // EXPECT (1, 1), (1, 3)
--disable_warnings
select hit_count, type from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+ index(t idx_t)*/* from t where a in (?, ?)';
--enable_warnings

connection conn_admin;
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name like '%idx_t%' order by table_id desc limit 1,table_id, 1);
let $backup_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id=$table_id and role = 2 and partition_id = 0 limit 1, svr_ip, 1);
let $backup_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id=$table_id and role = 2 and partition_id = 0 limit 1, svr_port, 1);

--disable_query_log
eval alter system switch replica leader partition_id='0%2@$table_id' server='$backup_ip:$backup_port';
--enable_query_log
--sleep 10

connection default;

select /*+ index(t idx_t)*/* from t where a in (1, 1);
select /*+ index(t idx_t)*/* from t where a in (2, 2);
select /*+ index(t idx_t)*/* from t where a in (2, 2);
select /*+ index(t idx_t)*/* from t where a in (1, 2);

explain select /*+ index(t idx_t)*/* from t where a in (1, 1);
explain select /*+ index(t idx_t)*/* from t where a in (2, 2);
explain select /*+ index(t idx_t)*/* from t where a in (1, 2);

--echo // EXPECT (1, 2), (2, 1), (2, 3)
--disable_warnings
select hit_count, type from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+ index(t idx_t)*/* from t where a in (?, ?)';
--enable_warnings

drop table t;
set autocommit = 1;
connection conn_admin;
alter system set enable_auto_leader_switch=true;