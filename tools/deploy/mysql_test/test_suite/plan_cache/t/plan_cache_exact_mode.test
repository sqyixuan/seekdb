##owner: luofan.zp
#owner group: sql1
# tags: outline
##
## Test Name: plan_cache_exact_mode
##
## Scope: Test basic function of exact_mode
##
## INFO:  if you want to add case; you should read ../README.md;
#         don't use sys tenant, because when parallel run on obfarm, the hit_count can't be expected;
#         so we use new tenant, new plan cache will be  used for this case only;
##
##
## Date: 2015-9-16
##


connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
--disable_info
--disable_metadata
--disable_warnings

alter system flush plan cache global;

connection default;
set cursor_sharing='exact';
drop table if exists t1;
create table t1(c1 int, c2 int);
--disable_warnings
--echo **************** normal test ***************
--echo 
--echo 
--disable_result_log
select 'abc' as 'c' from dual;
select 'abc' as 'c' from dual;
--enable_result_log
--echo expected hit_count: 1
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like "select 'abc' as 'c' from dual";

--echo 
--echo 
--disable_result_log
select 'ab' as 'db' from  dual;
select 'abc' as 'db' from  dual;
--enable_result_log
--echo expected hit_count:0, 0
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like "select % as % from  dual";

--echo 
--echo 
--disable_result_log
SELECT month(2);
SELECT month(1);
--enable_result_log
--echo expected hit_count: 0, 0
select  hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like "SELECT month(%";

--echo 
--echo 
--disable_result_log
select  convert('1234' using utf8);
select  convert('12345' using utf8);
--enable_result_log
--echo expected hit_count: 0, 0
select  hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select  convert(%";

--echo 
--echo 
--disable_result_log
select _utf8mb4'good';
select _utf8mb4'goodman';
--enable_result_log
--echo expected hit_count: 0, 0
select  hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select _utf8mb4%";

--echo 
--echo 
--disable_result_log
select * from t1 where c1 = cast(1 as binary(2));
select * from t1 where c1 = cast(100 as binary(3));
--enable_result_log
--echo expected hit_count: 0, 0
select  hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select * from t1 where c1 = cast(%";

--echo 
--echo 
--disable_result_log
select * from t1 where c1 = cast(1000 as char(1));
select * from t1 where c1 = cast(1000 as char(2));
--enable_result_log
--echo expected hit_count: 0, 0
select  hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select * from t1 where c1 = cast(1000%";

--echo 
--echo 
--echo 
--disable_result_log
select * from t1 where c1=true;
select * from t1 where c1=false;
--enable_result_log
--echo expected hit_count: 0, 0
select  hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select * from t1 where c1=%";

--echo 
--echo 
--disable_result_log
select  * from t1 where c1 = 'good' collate 'utf8mb4_bin';
select  * from t1 where c1 = 'goodman' collate 'utf8mb4_bin';
--enable_result_log
--echo expected hit_count: 0, 0
select  hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select  * from t1 where c1 =%collate%";

--echo 
--echo 
--disable_result_log
select  * from t1 where c1 = _utf8mb4'good';
select  * from t1 where c1 = _utf8mb4'goodman';
--enable_result_log
--echo expected hit_count: 0, 0
select  hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select  * from t1 where c1 = _utf8mb4%";

--echo 
--echo 
--disable_result_log
select * from t1 where c1=1;
select * from t1 where c1=1;
--enable_result_log
--echo expected hit_count: 1
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select * from t1 where c1=1';

--echo 
--echo 
--disable_result_log
select * from t1 where c1=now(0);
select * from t1 where c1=now(1);
--enable_result_log
--echo expected hit_count: 0, 0 
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select * from t1 where c1=now%';

--echo 
--echo 
--disable_result_log
select * from t1 where c1=current_time(0);
select * from t1 where c1=current_time(1);
--enable_result_log
--echo expected hit_count: 0, 0 
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select * from t1 where c1=current_time%';

--echo 
--echo 
--disable_result_log
select * from t1 where c1=date_add('2015-01-01', interval 5 day_microsecond);
select * from t1 where c1=date_add('2015-01-02', interval 5 day_microsecond);
--enable_result_log
--echo expected hit_count: 0, 0 
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select * from t1 where c1=date_add(%, interval % day_microsecond)';

--echo 
--echo 
--disable_result_log
select * from t1 where c2=1;
select * from t1 where c2=2;
--enable_result_log
--echo expected hit_count: 0, 0
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select * from t1 where c2%';

--echo 
--echo 
--echo **************** hint test ***************
connection default;
set cursor_sharing='force';
drop table if exists t2;
create table t2(c1 int, c2 int);
--echo
--echo
--disable_result_log
select * from t2 where c1=1;
select * from t2 where c1=2;
--enable_result_log
--echo expected hit_count: 0, 0
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t2 where c1%';

--echo
--echo
--disable_result_log
select /*+CURSOR_SHARING_EXACT*/* from t2 where c1=1;
select /*+CURSOR_SHARING_EXACT*/* from t2 where c1=2;
--enable_result_log
--echo expected hit_count: 0, 0
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+CURSOR_SHARING_EXACT*/* from t2 where c1%';

--echo
--echo
--disable_result_log
select /*+CURSOR_SHARING_EXACT*/* from t2 where c2=1;
select /*+CURSOR_SHARING_EXACT*/* from t2 where c2=1;
--enable_result_log
--echo expected hit_count: 1
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+CURSOR_SHARING_EXACT*/* from t2 where c2%';


--echo
--echo
--disable_result_log
select * from (select * from t2 where c1=1) where c1=1;
select * from (select * from t2 where c1=2) where c1=2;
--enable_result_log
--echo expected hit_count: 0, 0
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from (select * from t2 where%';


--echo
--echo
--disable_result_log
select * from (select /*+CURSOR_SHARING_EXACT*/* from t2 where c1=1) where c1=1;
select * from (select /*+CURSOR_SHARING_EXACT*/* from t2 where c1=2) where c1=2;
--enable_result_log
--echo expected hit_count: 0, 0
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from (select /*+CURSOR_SHARING_EXACT*/* from t2 where%';

--echo
--echo
--disable_result_log
select /*+CURSOR_SHARING_EXACT*/* from (select /*+CURSOR_SHARING_EXACT*/* from t2 where c1=1) where c1=1;
select /*+CURSOR_SHARING_EXACT*/* from (select /*+CURSOR_SHARING_EXACT*/* from t2 where c1=2) where c1=2;
--enable_result_log
--echo expected hit_count: 0, 0
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+CURSOR_SHARING_EXACT*/* from (select /*+CURSOR_SHARING_EXACT*/* from t2 where%';

--echo
--echo
--disable_result_log
select /*+CURSOR_SHARING_EXACT*/* from (select * from t2 where c1=1) where c1=1;
select /*+CURSOR_SHARING_EXACT*/* from (select * from t2 where c1=2) where c1=2;
--enable_result_log
--echo expected hit_count: 0, 0
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+CURSOR_SHARING_EXACT*/* from (select * from t2 where%';

--echo 
--echo 
--echo **************** outline test ***************
connection default;
set cursor_sharing='exact';
drop table if exists t3;
create table t3(c1 int, c2 int);
--echo
--echo
--disable_result_log
--error 0, 5265
drop outline otl1;
create index idx_c1 on t3(c1);
--enable_result_log
explain select c1 from t3 where c1=1;
--disable_result_log
create outline otl1 on select/*+FULL(t3)*/ c1 from t3 where c1=1;
--sleep 3
select c1 from t3 where c1=1;
--enable_result_log
--echo expected hit_count: 0
select query_sql, hints_info from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select c1 from t3 where c1=1';

connection conn_admin;
alter system flush plan cache global;

connection default;
set cursor_sharing='force';
drop table if exists t2;
create table t2(c1 int, c2 int);

--echo
--echo
--disable_result_log
select * from t2 where c1=1;
select * from t2 where c1=2;
--enable_result_log
--echo expected hit_count: 1
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t2 where c1=?';

--echo
--echo
--disable_result_log
select /*+CURSOR_SHARING_EXACT*/* from t2 where c1=1;
select /*+CURSOR_SHARING_EXACT*/* from t2 where c1=2;
--enable_result_log
--echo expected hit_count: 0, 0
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+CURSOR_SHARING_EXACT*/* from t2 where c1%';

--echo
--echo
--disable_result_log
select /*+CURSOR_SHARING_EXACT*/* from t2 where c2=1;
select /*+CURSOR_SHARING_EXACT*/* from t2 where c2=1;
--enable_result_log
--echo expected hit_count: 1
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+CURSOR_SHARING_EXACT*/* from t2 where c1%';

--echo
--echo
--disable_result_log
select * from (select * from t2 where c1=1) where c1=1;
select * from (select * from t2 where c1=2) where c1=2;
--enable_result_log
--echo expected hit_count: 1
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from (select * from t2 where%';


--echo
--echo
--disable_result_log
select * from (select /*+CURSOR_SHARING_EXACT*/* from t2 where c1=1) where c1=1;
select * from (select /*+CURSOR_SHARING_EXACT*/* from t2 where c1=2) where c1=2;
--enable_result_log
--echo expected hit_count: 0, 0
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from (select /*+CURSOR_SHARING_EXACT*/* from t2 where%';

--echo
--echo
--disable_result_log
select /*+CURSOR_SHARING_EXACT*/* from (select /*+CURSOR_SHARING_EXACT*/* from t2 where c1=1) where c1=1;
select /*+CURSOR_SHARING_EXACT*/* from (select /*+CURSOR_SHARING_EXACT*/* from t2 where c1=2) where c1=2;
--enable_result_log
--echo expected hit_count: 0, 0
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+CURSOR_SHARING_EXACT*/* from (select /*+CURSOR_SHARING_EXACT*/* from t2 where%';

--echo
--echo
--disable_result_log
select /*+CURSOR_SHARING_EXACT*/* from (select * from t2 where c1=1) where c1=1;
select /*+CURSOR_SHARING_EXACT*/* from (select * from t2 where c1=2) where c1=2;
--enable_result_log
--echo expected hit_count: 0, 0
select hit_count, statement, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+CURSOR_SHARING_EXACT*/* from (select * from t2 where%';

--echo
--echo
drop table t1, t2, t3;
drop outline otl1;
connection conn_admin;
alter system flush plan cache global;

