#owner: luofan.zp
#owner group: sql1
# tags: outline

--result_format 4
--enable_sorted_result

--disable_info
--disable_metadata

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

alter system flush plan cache global;
--sleep 3

connection default;

--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_result_log
create table t1 (a int);
insert into t1 values (1), (2), (3), (4), (5);
--enable_result_log

--echo // >>>>>>>>>>>>>>>>>>>>>>>>>> CASE#1 Param Not Match, From `found_rows.test`

select * from t1 limit 2, 2;

--echo // expect 1 record
--disable_warnings
select hit_count, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1 limit ?, _';
--enable_warnings

--disable_result_log
drop table t1;
create table t1 (name varchar(255));
insert into t1 values ("hello0"), ("hello1"), ("hello2"), ("hello3"), ("hello4");
--enable_result_log

select * from t1 limit 3, 1;
--echo // expect 1 record
--disable_warnings
select hit_count, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1 limit ?, _';
--enable_warnings

select * from t1 limit 3, 2;
--echo // pcv_set is deleted, expect 1 record
--disable_warnings
select hit_count, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1 limit ?, _';
--enable_warnings

--echo // >>>>>>>>>>>>>>>>>>>>>>>>>> CASE#2 Tenant schema version is lifted after creating outline
--disable_result_log
drop table t1;
create table t1 (a int);
insert into t1 values (1), (2), (3), (4), (5);
create index idx_t1_a on t1(a);
--source mysql_test/include/check_all_idx_ok.inc

--enable_result_log
select * from t1 limit 2;
select * from t1 limit 1;

--echo // expect 1 plans
--disable_warnings
select hit_count, outline_data from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1 limit _';
--enable_warnings

--error 0,5265
drop outline olt_1;

create outline olt_1 on select /*+ index(t1 idx_t1_a)*/* from t1 limit 1;

select * from t1 limit 2;
--echo // expect 1 record
--disable_warnings
select hit_count, outline_data from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1 limit _';
--enable_warnings
select * from t1 limit 1;

--echo // expect 1 record
--disable_warnings
select hit_count, outline_data from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1 limit _';
--enable_warnings
drop outline olt_1;
