#owner: luofan.zp
#owner group: sql1
##
## Test Name: plan_cache_jit_compile
##
## Scope: Test plan cache using jit compilation
##
## INFO:  if you want to add case; you should read ../README.md;
#         don't use sys tenant, because when parallel run on obfarm, the hit_count can't be expected;
#         so we use new tenant, new plan cache will be  used for this case only;
##
##
## Date: 2018-8-14
##

connect (conn_admin,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

alter system flush plan cache;
alter system set large_query_threshold='1s';
--sleep 3

--enable_query_log
--enable_result_log
connection default;
select effective_tenant();
--disable_query_log
--disable_result_log

--disable_query_log
--disable_result_log
--disable_warnings
drop table if exists t;

create table t (a bigint, b varchar(128));

insert into t values (1, 'hello'), (2, 'hi'), (3, 'world');

# test jit compiling use session variable
--echo ***************** TEST USING SESSION VARIABLE *****************

--enable_query_log
--echo
set ob_enable_jit='FORCE';

--enable_result_log
--echo
select * from t where a + 1 < 4;

--echo
--echo // expect (1, 0)
select is_use_jit, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t where a + ? < ?';

--echo
select * from t where a + 2 < 4;

--echo
--echo // expect (1, 1)
select is_use_jit, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t where a + ? < ?';

--echo
--disable_result_log
set ob_enable_jit='OFF';

--enable_result_log
select * from t where a + 1 < 4;

--echo
--echo // expect (1,1), (0, 0)
select is_use_jit, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t where a + ? < ?';

--echo
--echo ***************** TEST USING HINT *****************

--echo
select /*+ USE_JIT(FORCE)*/* from t where a + 1 < 4;

--echo
--echo // expect (1, 0)
select is_use_jit, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+ USE_JIT(FORCE)*/* from t where a + ? < ?';

--echo
select /*+ USE_JIT(OFF)*/* from t where a + 1 < 4;

--echo
--echo // expect (0, 0)
select is_use_jit, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+ USE_JIT(OFF)*/* from t where a + ? < ?';

--echo
--disable_result_log
set ob_enable_jit='FORCE';

--enable_result_log
--echo
select /*+ USE_JIT(FORCE)*/* from t where a + 1 < 4;

--echo
--echo // hint's priviledge is higher, expect (1, 0), (1, 0)
select is_use_jit, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+ USE_JIT(FORCE)*/* from t where a + ? < ?';