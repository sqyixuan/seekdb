
#owner: luofan.zp
#owner group: sql1
##
## Test Name: plan_cache_basic
##
## Scope: Test basic function of plan cache match
##
## INFO:  if you want to add case; you should read ../README.md;
#         don't use sys tenant, because when parallel run on obfarm, the hit_count can't be expected;
#         so we use new tenant, new plan cache will be  used for this case only;
##
##
## Date: 2015-9-16
##

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_info
--disable_metadata
--disable_abort_on_error

--enable_query_log
--enable_result_log
connection default;
let $def_plan_cache_percentage = query_get_value(show variables like 'ob_plan_cache_percentage', Value, 1);
let $def_plan_cache_evict_interval = query_get_value(show parameters like 'plan_cache_evict_interval', value, 1);
set global ob_plan_cache_percentage = 10;
set ob_trx_timeout = 1000000000;
select  effective_tenant();
--disable_query_log
--disable_result_log

set autocommit = 0;

# --echo
--disable_warnings
drop database if exists xy_db;
--enable_warnings
create database xy_db;
use xy_db;

--disable_query_log
--disable_result_log
source mysql_test/test_suite/plan_cache/t/plan_cache_table_init.sql;

connection conn_admin;
alter system flush plan cache global;
alter system set plan_cache_evict_interval = 1;
--sleep 3
connection default;

--echo
--echo ******************select  * from t1 where c1 = 1; select  * from t1 where c1 = 2;******
--disable_query_log
--disable_result_log
delimiter //;
select  * from t1 where c1 = 1; select  * from t1 where c1 = 2;//
delimiter ;//
--enable_result_log
select  hit_count, sql_id from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select  * from t1 where c1 = ?;";


#bug #8651393 as STRING_VALUE 导致的正常parse和fast parse识别常量不一致问题
--echo
--echo ********************select  'abc' as 'a' ***************
--echo ********************select  'abc' as 'a' ***************
--disable_query_log
--disable_result_log
select  'abc' as 'a';

select  'abc' as 'a';
--enable_result_log
select  hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select  ? as 'a'";


--echo
--echo ********************select  'abc' as a ***************
--echo ********************select  'abc' as a ***************
--disable_query_log
--disable_result_log
select  'abc' as a;
select  'abc' as a;
--enable_result_log
select  hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select  ? as a";

--echo
--echo ********************select  'abc' a ***************
--echo ********************select  'abc' a ***************
--disable_query_log
--disable_result_log
select  'abc' a;
select  'abc' a;
--enable_result_log
select  hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select  ? a";

--echo
--echo ********************select  'abc' 'a' ***************
--echo ********************select  'abc' 'a' ***************
--disable_query_log
--disable_result_log
select  'abc' 'a';
select  'abc' 'a';
--enable_result_log
select  hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select  ?";

