select hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement like 'select /*+no_rewrite*/* from (select * from case1_t_4 join case1_t_1 on c41=c11 where c41=?) as tab union all select * from (select * from case1_t_3 join case1_t_2 on c31=c21) as tab1' order by hit_count;
