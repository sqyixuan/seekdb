--echo
--echo 
--echo **************************************** Union ALL and Partition wise Join Dist Plan ****************************************
--echo
--echo =============================== pwj union_all ===============================
connection default;
--enable_query_log
--enable_result_log
--echo
explain select * from case1_t_3 union all (select c41, c11 from case1_t_4 join case1_t_1 on c41=c11 where c41=0);
--disable_result_log
select * from case1_t_3 union all (select c41, c11 from case1_t_4 join case1_t_1 on c41=c11 where c41=0);
select * from case1_t_3 union all (select c41, c11 from case1_t_4 join case1_t_1 on c41=c11 where c41=0);
--echo
--echo // expect hit_count =  1
--enable_result_log
