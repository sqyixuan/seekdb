--disable_result_log
select * from case1_t_4 where c41=0 union all select * from case1_t_1 union all select * from case1_t_3 union all select * from case1_t_2;
select * from case1_t_4 where c41=0 union all select * from case1_t_1 union all select * from case1_t_3 union all select * from case1_t_2;
