#owner: luofan.zp

--result_format 4
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

alter system flush plan cache global;

connection default;
set ob_trx_timeout = 10000000000;

--disable_warnings
drop table if exists t;
--enable_warnings

create table t (pk int primary key, a int);
insert into t values (1, 1);
insert into t values  (2, 2);

delimiter //;


select 1 from dual;//
select 1 from dual;//

--disable_warnings
select hit_count, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select ? from dual;'//
--enable_warnings

alter system set ob_enable_batched_multi_statement = true;//
--real_sleep 5

select 1 from dual;//
select 1 from dual;//

--disable_warnings
select hit_count, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select ? from dual%'//
--enable_warnings

update t set a = 1 where pk = 1;update t set a = 2 where pk = 2;//
update t set a = 1 where pk = 1;update t set a = 2 where pk = 2;//
update t set a = 1 where pk = 3  ;update t set a = 2 where pk = 2     ;//

--echo // expect 2
--disable_warnings
select hit_count, is_batched_multi_stmt, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'update t set a%'//
--enable_warnings

drop table t//

--error 1064
select 1;select  ; select 2;//

--error 1065
select 1;   ; select 2;//

connection conn_admin //



