#owner: zongmei.zzm
#owner group: sql2

--result_format 4
--enable_sorted_result

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

alter system flush plan cache global;
--sleep 3

connection default;

--disable_warnings
drop table if exists decint_t1;
--enable_warnings

select cast(1.0 * 2.0 as decimal(8, 0)) from dual;
select cast(1.0 * 9.0 as decimal(8, 0)) from dual;
select query_sql, hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement = 'select cast(? * ? as decimal(8, 0)) from dual';
select cast(32.0 * 33554432.0 as decimal(8, 0)) from dual;
select query_sql, hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement = 'select cast(? * ? as decimal(8, 0)) from dual';
select cast(64.0 * 33554432.0 as decimal(8, 0)) from dual;
select query_sql, hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement = 'select cast(? * ? as decimal(8, 0)) from dual';

explain select 1 * 2.0;
select 1 * 2.0 from dual;
select 2147483648 * 2.0 from dual;
select 1234 * 2.0 from dual;
select query_sql, hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement = 'select ? * ? from dual';

explain select 2147483648 * 32.0 from dual;
select 2147483648 * 32.0 from dual;
select query_sql, hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement = 'select ? * ? from dual';

select 123 + 1.234 from dual;
select 1234 + 1.234 from dual;
select 123456789 + 1.234 from dual;
select query_sql, hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement = 'select ? + ? from dual';

select 123 + 11.234 from dual;
select query_sql, hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement = 'select ? + ? from dual';
select 123456789 + 11.234 from dual;
select query_sql, hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement = 'select ? + ? from dual';

explain select 123456789 + 11.234 from dual;

create table decint_t1 (a decimal(10, 2));
insert into decint_t1 values (1.23), (2.45), (3.0);

explain select * from decint_t1 where a + 1 = 2.23;
explain select * from decint_t1 where a + 123456789012345678 = 2.23;

select * from decint_t1 where a + 1 = 2.23;
select * from decint_t1 where a + 001 = 2.23;
select * from decint_t1 where a + 123456789012345678 = 2.23;

select query_sql, hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement = 'select * from decint_t1 where a + ? = ?';

select * from decint_t1 where a + 0001 = 2.230;
select query_sql, hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement = 'select * from decint_t1 where a + ? = ?';

select * from decint_t1 where a + 000001 = 3.450;
select query_sql, hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement = 'select * from decint_t1 where a + ? = ?';

select * from decint_t1 where a + 000001 = 02.230;
select query_sql, hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement = 'select * from decint_t1 where a + ? = ?';

select * from decint_t1 where a + 0000001 = 03.450;
select query_sql, hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement = 'select * from decint_t1 where a + ? = ?';

select * from decint_t1 where a = 3;
select * from decint_t1 where a = 003;
select * from decint_t1 where a = 0030000000000000000;

select query_sql, hit_count from oceanbase.v$ob_plan_cache_plan_stat where statement = 'select * from decint_t1 where a = ?';

drop table decint_t1;