
#owner: luofan.zp
#owner group: sql2
##
##
## Scope: Test update, on duplicate key update set null of plan cache match
##
##

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_info
--disable_metadata
--disable_abort_on_error

--enable_query_log
--enable_result_log
connection default;
let $def_plan_cache_percentage = query_get_value(show variables like 'ob_plan_cache_percentage', Value, 1);
let $def_plan_cache_evict_interval = query_get_value(show parameters like 'plan_cache_evict_interval', value, 1);
set global ob_plan_cache_percentage = 10;
set ob_trx_timeout = 1000000000;
select  effective_tenant();
--disable_query_log
--disable_result_log

# --echo
--disable_warnings
drop database if exists luofan_db;
--enable_warnings
create database luofan_db;
use luofan_db;

--disable_query_log

connection conn_admin;
alter system flush plan cache global;
alter system set plan_cache_evict_interval = 1;
--sleep 3
connection default;

--echo
--echo *********update t1 set c1=3, c2=4 where c3=1;************
--echo *********update t1 set c1=4, c2=null where c3=1;*********
create table t1 (c1 int primary key, c2 int, c3 int);
insert into t1 values (1, 1, 1);
insert into t1 values (2, 2, 2);
--disable_query_log
--disable_result_log
update t1 set c1=3, c2=4 where c3=1;
--echo //expect hit_count = 0;
--enable_result_log
select  hit_count, statement from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "update t1 set c1=?, c2=? where c3=?";
update t1 set c1=4, c2=null where c3=1;
--echo //expect hit_count = 1;
--enable_result_log
select  hit_count, statement from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "update t1 set c1=?, c2=? where c3=?";


--echo
--echo ****insert into t1 values (1, 2, 3) on duplicate key update c1=5, c2=6;************
--echo ****insert into t1 values (2, 3, 4) on duplicate key update c1=6, c2=null;*********
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 int);
insert into t1 values (1, 1, 1);
insert into t1 values (2, 2, 2);
--disable_query_log
--disable_result_log
insert into t1 values (1, 2, 3) on duplicate key update c1=5, c2=6;
--echo //expect hit_count = 0;
--enable_result_log
select  hit_count, statement from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "insert into t1 values (?, ?, ?) on duplicate key update c1=?, c2=?";
insert into t1 values (2, 3, 4) on duplicate key update c1=6, c2=null;
--echo //expect hit_count = 1;
--enable_result_log
select  hit_count, statement from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "insert into t1 values (?, ?, ?) on duplicate key update c1=?, c2=?";



--disable_result_log
# recover variables
eval set global ob_plan_cache_percentage = $def_plan_cache_percentage;
--disable_warnings
drop database if exists luofan_db;
--enable_warnings

# login using admin acount
connection conn_admin;

alter system set large_query_threshold = '100ms';
eval alter system set plan_cache_evict_interval = $def_plan_cache_evict_interval;
--sleep 3

