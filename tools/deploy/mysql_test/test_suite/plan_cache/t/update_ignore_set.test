
#owner: luofan.zp
#owner group: sql2
##
##
## Scope: Test update ignore set of plan cache match
##
##

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_info
--disable_metadata
--disable_abort_on_error

--enable_query_log
--enable_result_log
connection default;
let $def_plan_cache_percentage = query_get_value(show variables like 'ob_plan_cache_percentage', Value, 1);
let $def_plan_cache_evict_interval = query_get_value(show parameters like 'plan_cache_evict_interval', value, 1);
set global ob_plan_cache_percentage = 10;
set ob_trx_timeout = 1000000000;
select  effective_tenant();
--disable_query_log
--disable_result_log

# --echo
--disable_warnings
drop database if exists luofan_db;
--enable_warnings
create database luofan_db;
use luofan_db;
create table t1 (v1 datetime);

--disable_query_log

connection conn_admin;
alter system flush plan cache global;
alter system set plan_cache_evict_interval = 1;
--sleep 3
connection default;

--echo
--echo ******************************************
--disable_query_log
--disable_result_log
update ignore t1 set t1.v1 = '';
--echo //expect hit_count = 0;
--enable_result_log
select  hit_count, sql_id, query_sql from oceanbase.v$ob_plan_cache_plan_stat where statement = "update ignore t1 set t1.v1 = ?";
update ignore t1 set t1.v1 = '';
--echo //expect hit_count = 1;
--enable_result_log
select  hit_count, sql_id, query_sql from oceanbase.v$ob_plan_cache_plan_stat where statement = "update ignore t1 set t1.v1 = ?";

--disable_result_log
# recover variables
eval set global ob_plan_cache_percentage = $def_plan_cache_percentage;
--disable_warnings
drop database if exists luofan_db;
--enable_warnings

# login using admin acount
connection conn_admin;

alter system set large_query_threshold = '100ms';
eval alter system set plan_cache_evict_interval = $def_plan_cache_evict_interval;
--sleep 3
