#owner: luofan.zp
#owner group: sql1
##
## Test Name: plan_cache_same_name
##
## Scope: Test misc cases in oracle mode from obqa env
##

# mysql模式下不同db下的同名sql场景
--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_info
--disable_metadata

--disable_query_log
--disable_result_log

alter system flush plan cache;
alter system set large_query_threshold = '1s';
--sleep 3

--enable_query_log
--enable_result_log

connection default;

--disable_warnings
drop database if exists test_db1;
drop database if exists test_db2;
--enable_warnings

create database test_db1;
create database test_db2;

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test_db1,$OBMYSQL_PORT);
set autocommit = 0;
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test_db2,$OBMYSQL_PORT);
set autocommit = 0;

use test_db1;
create table test (a int);
insert into test values (1);

use test_db2;
create table test (a int);
insert into test values (2);

connection conn1;

select t1.a, t2.a from test_db1.test as t1, test as t2 where t1.a = t2.a;
--disable_result_log
select t1.a, t2.a from test_db1.test as t1, test as t2 where t1.a = t2.a;

--enable_result_log
--enable_result_log
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select t1.a, t2.a from test_db1.test as t1, test as t2 where t1.a = t2.a';

select t1.a, t2.a from test as t1, test_db2.test as t2 where t1.a = t2.a;
--disable_result_log
select t1.a, t2.a from test as t1, test_db2.test as t2 where t1.a = t2.a;

--enable_result_log
--echo // expect hit_count = 1
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select t1.a, t2.a from test as t1, test_db2.test as t2 where t1.a = t2.a';

select t1.a, t2.a from test_db1.test as t1, test_db2.test as t2 where t1.a = t2.a;
--disable_result_log
select t1.a, t2.a from test_db1.test as t1, test_db2.test as t2 where t1.a = t2.a;

--enable_result_log
--echo // expect hit_count = 1
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select t1.a, t2.a from test_db1.test as t1, test_db2.test as t2 where t1.a = t2.a';
--enable_warnings

commit;

--disable_query_log
--disable_result_log
connection conn_admin;
alter system set large_query_threshold = '100ms';
