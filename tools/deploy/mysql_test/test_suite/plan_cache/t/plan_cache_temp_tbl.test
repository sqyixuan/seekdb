#owner: luofan.zp
#owner group: sql1
##
## Test Name: plan_cache_obqa_misc_oracle
##
## Scope: Test misc cases in oracle mode from obqa env
##

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_info
--disable_metadata
--disable_abort_on_error

--disable_query_log
--disable_result_log

alter system flush plan cache;
alter system set large_query_threshold = '1s';
--sleep 3

--enable_query_log
--enable_result_log
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
set ob_trx_timeout = 1000000000;
set autocommit = 0;
connection conn2;
set ob_trx_timeout = 1000000000;
set autocommit = 0;
--disable_query_log
--disable_result_log

--echo // >>>>>>>>>>>>>> Test Temp Table Basic In MySQL Mode
--echo
