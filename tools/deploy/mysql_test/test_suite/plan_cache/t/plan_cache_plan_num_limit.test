#owner: luofan.zp
#owner group: sql1
##
## Test Name: plan_cache_plan_num_limit
##
## Date: 2019-02-02
##

--result_format 4

--echo // >>>>>>>>>>>>>>> TEST LIMIT OF PLANS UNDER PCV_SET <<<<<<<<<<<<<<<<
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

--disable_info
--disable_metadata

--disable_query_log
--disable_result_log

alter system flush plan cache global;
alter system set large_query_threshold = '1s';
--sleep 3

connection default;

let $cnt = 1;

while ($cnt <= 200)
{
  eval select 1 from dual where cast(1 as char($cnt)) = '1';
  inc $cnt;
}

--enable_result_log
--enable_query_log
--disable_warnings
select count(*) from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select ? from dual where cast(? as char%';


select 1 from dual where cast(1 as char(200)) = '1';

--echo // expect hit_count = 1
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select ? from dual where cast(? as char(200)) = ?';

select 1 from dual where cast(1 as char(201)) = '1';
--echo // expect count(*) = 0
select count(*) from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select ? from dual where cast(? as char(201)) = ?';

--echo // change key of pcv_set
select  1 from dual where cast(1 as char(201)) = '1';

--echo // expect hit_count = 0
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select  ? from dual where cast(? as char(201)) = ?';
--enable_warnings

--disable_query_log
--disable_result_log
connection obsys;
alter system set large_query_threshold = '100ms';


