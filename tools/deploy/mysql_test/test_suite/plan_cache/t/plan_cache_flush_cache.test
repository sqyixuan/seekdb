--echo // expected: 2, 1
select count(1) from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where c1=?' group by svr_ip, svr_port order by svr_ip, svr_port;
--echo ********** end system tenant's flush plan cache test *********************

