alter system flush plan cache sql_id='A07D4B0B800C20F31180D2E0F3F73BFE' databases='db1' tenant=sys;
--echo // expected: 1 value, 2 for slave
select count(1) from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where c1=?' group by svr_ip, svr_port order by svr_ip, svr_port;
--echo
--echo >>>> PART2.2 GLOBAL >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
--echo >>>> PART2.2.1: tenant list empty >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
