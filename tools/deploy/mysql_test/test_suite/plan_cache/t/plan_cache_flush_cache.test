##
## Test Name: plan_cache_flush_cache
##
## Scope: Test basic function of flush plan cache
#
--source mysql_test/include/backup_spm_var.inc

connect (conn_admin_tmp, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin_tmp;
--source mysql_test/include/backup_spm_var.inc

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
let $port_1 = query_get_value(select inner_port from oceanbase.__all_server, inner_port, 1);
let $ip_1 = query_get_value(select svr_ip from oceanbase.__all_server, svr_ip, 1);
#let $port_2 = query_get_value(select inner_port from oceanbase.__all_server, inner_port, 2);
#let $ip_2 = query_get_value(select svr_ip from oceanbase.__all_server, svr_ip, 2);
connect (conn_master, $ip_1, root, '', test, $port_1);
connect (conn_slave, $ip_1, root, '', test, $port_1);
connect (conn_admin_slave, $ip_1,admin,$OBMYSQL_PWD,test,$port_1);


alter system flush plan cache global;
--sleep 3

--disable_info
--disable_metadata
--disable_abort_on_error

--disable_query_log
--disable_warnings
drop database if exists db1;
--enable_warnings
create database db1;
--disable_warnings
use db1;
drop table if exists t;
--enable_warnings
create table t(c1 int primary key, c2 int);
--disable_warnings
drop database if exists db2;
--enable_warnings
create database db2;
use db2;
--disable_warnings
drop table if exists t;
--enable_warnings
create table t(c1 int primary key, c2 int);

connection conn_master;
--disable_warnings
drop database if exists db1;
--enable_warnings
create database db1;
use db1;
--disable_warnings
drop table if exists t;
--enable_warnings
create table t(c1 int primary key, c2 int);
--disable_warnings
drop database if exists db2;
--enable_warnings
create database db2;
use db2;
--disable_warnings
drop table if exists t;
--enable_warnings
create table t(c1 int primary key, c2 int);

--echo 
--echo ***** admin: db1:t db2:t **************
--echo ***** mysql: db1:t db2:t **************
--echo 
--echo
--echo >>>>>>>>>>> begin system tenant's flush plan cache test ********************
--enable_query_log
--disable_result_log
--echo >>>> PART1: coarse grained plan cache evict >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
--echo **** PART1.1 NOT GLOBAL **************************************************
--echo **** PART1.1.1: tenant list empty ****************************************
connection conn_master;
use db1;
select * from t where c1=1;
use db2;
select * from t where c1=1;
connection conn_admin;
use db1;
select * from t where c1=1;
use db2;
select * from t where c1=1;
--enable_result_log
--echo // expected: 4 for master, 4,2 for slave
select count(1) from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where c1=?' group by svr_ip, svr_port order by svr_ip, svr_port;
--echo 
alter system flush plan cache;
--echo 
--echo expected: empty set, 4 for slave
select count(1) from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where c1=?' group by svr_ip, svr_port order by svr_ip, svr_port;
--echo
--echo **** PART1.1.2: tenant list not empty *************************************
--disable_result_log
connection conn_admin;
alter system flush plan cache;
connection conn_master;
use db1;
select * from t where c1=1;
use db2;
select * from t where c1=1;
connection conn_admin;
use db1;
select * from t where c1=1;
use db2;
select * from t where c1=1;
--enable_result_log
--echo expected 4 for master, 4,2 for slave 
select count(1) from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where c1=?' group by svr_ip, svr_port order by svr_ip, svr_port;
--echo 
alter system flush plan cache;
--echo 
--echo expected 2 for master, 4,2 for slave 
select count(1) from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where c1=?' group by svr_ip, svr_port order by svr_ip, svr_port;
--echo 
--echo >>>> PART1.2: GLOBAL >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
--echo **** PART1.2.1: tenant list empty ****************************************
--disable_result_log
connection conn_admin;
alter system flush plan cache;
connection conn_master;
use db1;
select * from t where c1=1;
use db2;
select * from t where c1=1;
connection conn_admin;
use db1;
select * from t where c1=1;
use db2;
select * from t where c1=1;

## remote plan
connection conn_slave;
use db1;
select * from t where c1=1;
use db2;
select * from t where c1=1;
connection conn_admin_slave;
use db1;
select * from t where c1=1;
use db2;
select * from t where c1=1;
--enable_result_log
--echo expected 8,4 for master, 6,4 for slave
select count(1) from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where c1=?' group by svr_ip, svr_port order by svr_ip, svr_port;
--echo 
alter system flush plan cache global;
--echo 
--echo expected: empty set
select count(1) from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where c1=?' group by svr_ip, svr_port order by svr_ip, svr_port;
