alter system flush plan cache global;
connection default;
use db1;
select * from t where c1=1;
use db2;
select * from t where c1=1;
connection conn_admin;
use db1;
select * from t where c1=1;
use db2;
select * from t where c1=1;

# remote plan 
connection conn_slave;
use db1;
select * from t where c1=1;
use db2;
select * from t where c1=1;
connection conn_admin_slave;
use db1;
select * from t where c1=1;
use db2;
select * from t where c1=1;
--enable_result_log
--echo // expected count: 8, 4 for master, 4,4 for slave
select count(1) from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where c1=?' group by svr_ip, svr_port order by svr_ip, svr_port;
--echo 
alter system flush plan cache global;
--echo 
--echo // expected count: 4, 2 for master, 2,2 for slave
select count(1) from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where c1=?' group by svr_ip, svr_port order by svr_ip, svr_port;
--echo
--echo
--echo **** PART2: fine grained plan cache evict ********************************
--echo >>>> PART2.1 NOT GLOBAL >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
--echo >>>> PART2.1.1: tenant list empty >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
