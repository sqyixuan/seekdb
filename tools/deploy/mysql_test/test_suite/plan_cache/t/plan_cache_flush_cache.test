--echo
--echo >>>>>>>>>>> begin mysql tenant's flush plan cache test ********************
--enable_query_log
--disable_result_log
--echo >>>> PART1: privilege test >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
--echo **** PART1.1 NOT GRANT DBA **************************************************
connection conn_master;
--error 0, 1396
drop user flush_cache_test;
create user flush_cache_test identified by 'flush_cache';
grant select, insert, update, delete, create, drop on test.* to flush_cache_test;
## create connection for flush cache
connection conn_admin;
let $port_1 = query_get_value(select inner_port from oceanbase.__all_server, inner_port, 1);
let $ip_1 = query_get_value(select svr_ip from oceanbase.__all_server, svr_ip, 1);
let $port_2 = query_get_value(select inner_port from oceanbase.__all_server, inner_port, 2);
let $ip_2 = query_get_value(select svr_ip from oceanbase.__all_server, svr_ip, 2);
connect (conn_flush_cache, $ip_1, flush_cache_test, 'flush_cache', test, $port_1);
connection conn_flush_cache;
--echo // insufficent privileges
--error 1227
alter system flush plan cache;
--echo
--echo **** PART1.2 GRANT DBA *****************************************************
connection conn_master;
grant all privileges on *.* to flush_cache_test;
connection conn_flush_cache;
alter system flush plan cache;
--echo **** PART1.3 USE SYS TENANT's CMD *******************************************
connection conn_flush_cache;
--echo // use system tenant's command, insufficent privileges
--error 1227
alter system flush plan cache tenant=sys;
--echo
--echo
