alter system flush plan cache global;
connection conn_master;
use db1;
select * from t where c1=1;
use db2;
select * from t where c1=1;
connection conn_admin;
--error 5161
alter system flush plan cache sql_id='A07D4B0B800C20F31180D2E0F3F73BFE';
--echo
--echo >>>> PART2.1.2: tenant list NOT empty >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
--echo >>>> PART2.1.2.1: database list empty >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
