# owner: gongyusen.gys
# owner group: SQL2

drop database if exists DB1;
create database DB1;
use DB1;
create table if not exists TEST200(COL_INT int, COL_VARCHAR_20 varchar(20));
delimiter //;
create procedure insert_one_row(in col1 int, in col2 varchar(20))  begin insert into TEST200 values(col1, col2); end//
create procedure select_specific_row(in col1_filter int) begin select * from TEST200 where COL_INT = col1_filter; end //
delimiter ;//
alter system flush plan cache global;
call insert_one_row(1, 'zhang');
call insert_one_row(2, 'wang');
call insert_one_row(3, 'he');
call insert_one_row(4, 'neo');
call insert_one_row(5, 'zhao');
call insert_one_row(6, 'white');
call insert_one_row(7, 'blue');

call select_specific_row(1);

select count(*) from oceanbase.gv$ob_plan_cache_plan_stat where db_id = 18446744073709551615 and query_sql like 'select * from TEST200 where%';
select count(*) from oceanbase.gv$ob_plan_cache_plan_stat where db_id = 18446744073709551615 and query_sql like 'insert into TEST200 values%';
drop procedure insert_one_row;
drop procedure select_specific_row;
drop table TEST200;
drop database DB1;
