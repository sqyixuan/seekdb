#bugfix: 
--result_format 4
--disable_warnings
drop table if exists test_34x;
--enable_warnings

CREATE TABLE test_34x(
pk1 int(11) NOT NULL,
pk2 int(11) NOT NULL,
first_name text DEFAULT NULL,
last_name varchar(100) DEFAULT NULL,
full_name varchar(300) AS (concat(`first_name`,'.',`last_name`)) VIRTUAL,
primary key(pk1,pk2)
);
alter system flush plan cache global;
--echo #test insert values
explain insert into test_34x(pk1,pk2,first_name,last_name, full_name) values(182615592,372640017,NULL,NULL,default);
insert into test_34x(pk1,pk2,first_name,last_name, full_name) values(182615592,372640017,NULL,NULL,default);
explain insert into test_34x(pk1,pk2,first_name,last_name, full_name) values(157141000,384567981,'lazing mome',NULL,default);
insert into test_34x(pk1,pk2,first_name,last_name, full_name) values(157141000,384567981,'lazing mome',NULL,default);
insert into test_34x(pk1,pk2,first_name,last_name, full_name) values(157141001,384567981,'lazing m11',NULL,default);

select * from test_34x;
select statement, hit_count, outline_id from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into test_34x(pk1,pk2,first_name,last_name, full_name) values%';

delete from test_34x;
alter system flush plan cache global;
explain insert into test_34x(pk1,pk2,first_name,last_name) values(182615592,372640017,NULL,NULL);
insert into test_34x(pk1,pk2,first_name,last_name) values(182615592,372640017,NULL,NULL);
explain insert into test_34x(pk1,pk2,first_name,last_name) values(157141000,384567981,'lazing mome',NULL);
insert into test_34x(pk1,pk2,first_name,last_name) values(157141000,384567981,'lazing mome',NULL);
insert into test_34x(pk1,pk2,first_name,last_name) values(157141001,384567981,'lazing m11',NULL);
select statement, hit_count, outline_id from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into test_34x(pk1,pk2,first_name,last_name) values%';

--echo #test insert assign
delete from test_34x;
alter system flush plan cache global;
explain insert into test_34x set pk1 = 1,pk2 = 2,first_name = NULL,last_name = NULL, full_name = default;
insert into test_34x set pk1 = 2,pk2 = 1,first_name = NULL,last_name = NULL, full_name = default;
explain insert into test_34x set pk1 = 2,pk2 = 2,first_name = NULL,last_name = 'last', full_name = default;
insert into test_34x set pk1 = 2,pk2 = 2,first_name = NULL,last_name = 'last', full_name = default;
insert into test_34x set pk1 = 2,pk2 = 3,first_name = NULL,last_name = 'last2', full_name = default;

select * from test_34x;
select statement, hit_count, outline_id from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into test_34x set pk1%';

delete from test_34x;
alter system flush plan cache global;
explain insert into test_34x set pk1 = 1,pk2 = 2,first_name = NULL,last_name = NULL;
insert into test_34x set pk1 = 2,pk2 = 1,first_name = NULL,last_name = NULL;
explain insert into test_34x set pk1 = 2,pk2 = 2,first_name = NULL,last_name = 'last';
insert into test_34x set pk1 = 2,pk2 = 2,first_name = NULL,last_name = 'last';
insert into test_34x set pk1 = 2,pk2 = 3,first_name = NULL,last_name = 'last2';

select * from test_34x;
select statement, hit_count, outline_id from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into test_34x set pk1%';

drop table test_34x;