#owner: luofan.zp
#owner group: sql1
#tags: optimizer
--result_format 4
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system flush plan cache global;

alter system set resource_hard_limit = 500;

--disable_query_log
--disable_warnings
#drop tenant if exists ttt1 force;
#drop resource pool if exists rp1;
#drop resource unit if exists rp_box_1;
--enable_warnings
#eval create resource unit if not exists rp_box_1 max_cpu 1, memory_size '2G';
#create resource pool if not exists rp1 unit = 'rp_box_1', unit_num = 1, zone_list = ('zone1', 'zone2');
#create tenant if not exists ttt1 replica_num 2, primary_zone 'zone1', resource_pool_list ('rp1'), locality = "F{1,memstore_percent:100}@zone1,F{1,memstore_percent:0}@zone2" set ob_tcp_invited_nodes='%';
--enable_query_log
--source mysql_test/include/check_tenant_sync.inc

let $MYSQL_IP1 = query_get_value(select svr_ip from oceanbase.__all_server where with_rootserver = 1, svr_ip, 1);
let $MYSQL_IP2 = query_get_value(select svr_ip from oceanbase.__all_server where with_rootserver = 0, svr_ip, 1);

let $MYSQL_PORT1 = query_get_value(select inner_port from oceanbase.__all_server where with_rootserver = 1, inner_port, 1);
let $MYSQL_PORT2 = query_get_value(select inner_port from oceanbase.__all_server where with_rootserver = 0 order by inner_port, inner_port, 1);

connect(conn_ttt1, $OBMYSQL_MS0, root, ,test, $MYSQL_PORT);
connect(conn_ttt2, $OBMYSQL_MS0, root, ,test, $MYSQL_PORT);

connection conn_ttt1;

--disable_warnings
drop table if exists test;
--enable_warnings
create table test (a int);
insert into test values (1), (2);

connection conn_ttt2;
#set ob_read_consistency='weak';

--echo // select * from test; farm没有结果，本地是正常的。D副本功能已经不维护了

--echo // expect a remote plan
explain select * from test;

connection conn_admin;
#drop tenant ttt1 force;
#drop resource pool rp1;
#drop resource unit rp_box_1;

