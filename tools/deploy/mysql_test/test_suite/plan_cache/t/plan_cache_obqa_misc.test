#owner: luofan.zp
#owner group: sql1
##
## Test Name: plan_cache_obqa_misc
##
## Scope: Test misc cases from obqa env
##
--result_format 4
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_info
--disable_metadata
--disable_abort_on_error

--disable_query_log
--disable_result_log

alter system flush plan cache;
alter system set large_query_threshold = '1s';
--sleep 3

--enable_query_log
--enable_result_log
connection default;

set ob_trx_timeout = 1000000000;

--disable_query_log
--disable_result_log

set autocommit = 0;

# --echo
--disable_warnings
drop database if exists xy_db;
--enable_warnings
create database xy_db;
use xy_db;

--disable_query_log
--disable_result_log

--echo // >>>>>>>>>>>>>> TEST Insert With Global Index
--echo // Dependency tables contain index table

CREATE TABLE `timeout_003` (
  `JOB_ID` varchar(64) NOT NULL,
  `TRADE_NO` bigint(64) NOT NULL,
  `USER_ID` bigint(64) NOT NULL,
  `PAYTYPE` varchar(8) DEFAULT NULL,
  `END_TIME` datetime DEFAULT NULL,
  `ACTION` varchar(60) DEFAULT NULL,
  `PARAMETER` varchar(200) DEFAULT NULL,
  `STATUS` varchar(2) DEFAULT NULL,
  `ACTION_TYPE` varchar(2) DEFAULT NULL,
  `GMT_CREATE` datetime NOT NULL,
  `PRIOR_LEVEL` bigint(64) DEFAULT '1',
  `GMT_MODIFIED` datetime DEFAULT NULL,
  `GMT_OCCUR` datetime DEFAULT NULL,
  `GMT_COMPENSATED` datetime DEFAULT NULL,
  `partition_id` varchar(10) GENERATED ALWAYS AS (substr(`JOB_ID`,18,2)) VIRTUAL,
  PRIMARY KEY (`JOB_ID`, `USER_ID`, `GMT_CREATE`),
  KEY `IND_BEYOND_TIMEOUT_ETIME` (`END_TIME`) GLOBAL  BLOCK_SIZE 16384,
  KEY `TIMEOUT_PL_IND` (`PRIOR_LEVEL`) GLOBAL  BLOCK_SIZE 16384,
  KEY `TIMEOUT_TNO_IND` (`TRADE_NO`) GLOBAL  BLOCK_SIZE 16384,
  KEY `IDX_GMT_COMPENSATED_TIMEOUT` (`GMT_COMPENSATED`) STORING (`STATUS`) GLOBAL  BLOCK_SIZE 16384,
  CONSTRAINT `cst1` CHECK ((`partition_id` = substr(`TRADE_NO`,18,2)))
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
 partition by list columns(partition_id)
