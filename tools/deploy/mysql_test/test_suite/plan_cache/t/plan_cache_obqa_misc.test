--echo
--echo // >>>>>>>>>>>>>> TEST Large Query SQL
--echo // Large query sql is truncated to OB_MAX_SQL_LENGTH
--echo

--disable_query_log
--disable_result_log
source mysql_test/test_suite/plan_cache/t/plan_cache_obqa.sql;

--enable_query_log
--enable_result_log
--echo // query_sql is truncated to 65536
select length(query_sql) from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where sql_id = 'B2FD215564A613E27B321C64B690F933';


--echo
--echo // >>>>>>>>>>>>>> TEST Window function, fast parser param count mismatch with normal parser count
#bug 
--disable_query_log
--disable_result_log
--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt (i int, v int);
insert into tt values (1, 1), (1, 2), (3, 1), (3, 2), (2, 1), (2, 2);

--enable_query_log
SELECT i,COUNT(v) OVER (ORDER BY i ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING) from tt;
SELECT i,COUNT(v) OVER (ORDER BY i ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING) from tt;

SELECT i,COUNT(v) OVER (ORDER BY i RANGE BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING) from tt;
SELECT i,COUNT(v) OVER (ORDER BY i RANGE BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING) from tt;

SELECT i,COUNT(v) OVER (ORDER BY i ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) from tt;
SELECT i,COUNT(v) OVER (ORDER BY i ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) from tt;

--enable_result_log
--echo // expect hit_count = 1
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'SELECT i,COUNT(v) OVER (ORDER BY i ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING) from tt';


--echo // expect hit_count = 1
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'SELECT i,COUNT(v) OVER (ORDER BY i RANGE BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING) from tt';

--echo // expect hit_count = 1
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'SELECT i,COUNT(v) OVER (ORDER BY i ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) from tt';
--enable_warnings

--echo
--echo // >>>>>>>>>TEST mysql模式下plan_cache_plan_stat表命中计划
--disable_result_log
select count(*) from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT;
select count(*) from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT;

--enable_result_log
--echo // expect hit_count = 1
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select count(*) from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT';
--enable_warnings

--echo // >>>>>>>>>>>>>>>TEST Select from gv table
--echo // bug link: 
connection conn_admin;
let $zone1_ip = query_get_value(select svr_ip from oceanbase.__all_server where zone = 'zone1' limit 1, svr_ip, 1);
let $zone2_ip = query_get_value(select svr_ip from oceanbase.__all_server where zone = 'zone2' limit 1, svr_ip, 1);

let $zone1_port = query_get_value(select inner_port from oceanbase.__all_server where zone = 'zone1' limit 1, inner_port, 1);
let $zone2_port = query_get_value(select inner_port from oceanbase.__all_server where zone = 'zone2' limit 1, inner_port, 1);

let $svr_port1 = query_get_value(select svr_port from oceanbase.__all_server where zone = 'zone1' limit 1, svr_port, 1);
let $svr_port2 = query_get_value(select svr_port from oceanbase.__all_server where zone = 'zone2' limit 1, svr_port, 1);

connect (sess1, $zone1_ip, admin, admin, test, $zone1_port);
connect (sess2, $zone1_ip, admin, admin, test, $zone1_port);

connection conn_admin;
alter system flush sql audit global;
alter system flush plan cache global;
--sleep 3
connection sess1;
--echo // query from local, expect true
--replace_result $svr_port1 svr_port1
eval select count(*) = 0 from oceanbase.GV\$OB_SQL_AUDIT where svr_port = $svr_port1 and is_inner_sql = 0;

connection sess2;
--echo // execute query in remote
select 1 from dual;

connection sess1;
--echo // query from local, expect true
--replace_result $svr_port2 svr_port2
eval select count(*) > 0 from oceanbase.GV\$OB_SQL_AUDIT where svr_port = $svr_port2 and is_inner_sql = 0;

commit;

--disable_query_log
--disable_result_log
connection conn_admin;
alter system set large_query_threshold = '100ms';
drop database xy_db;
