
#owner: luofan.zp
#owner group: sql1
##
## Test Name: plan_cache_outline
## Scope: Test outline plan in plan cache
## Date: 2016-06-24

connect (conn_admin,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_info
 --disable_metadata
--disable_abort_on_error

--disable_query_log
--error 0,5157

--disable_abort_on_error
--sleep 10

--enable_query_log
alter system flush plan cache;
--sleep 3

connection default;
--echo

--disable_warnings
drop database if exists xy_db;
--enable_warnings
create database xy_db;
use xy_db;
create table xy_t(c1 int, c2 int);
--sleep 3

--echo //建立outline
create outline otl1 on select * from xy_t;
select * from xy_t;

--echo
--echo //expected 0
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from xy_t';

--echo //生成多个plan
--disable_query_log
--disable_result_log
source mysql_test/test_suite/plan_cache/t/plan_cache_table_init.sql;
source mysql_test/test_suite/plan_cache/t/plan_cache.sql;
--enable_query_log
--enable_result_log

--echo
--echo ************测试在merged_version均未失效时, outline生成的plan也会根据权重被淘汰
--echo //减小plan cache淘汰上限,触发淘汰, 期望将outline生成的plan淘汰,因为其执行时间最早
set global ob_plan_cache_evict_high_percentage = 1;
set global ob_plan_cache_evict_low_percentage = 1;
sleep 35;
--echo //expected null
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from xy_t';

--echo
select * from xy_t;
--echo //expected 0
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from xy_t';

--echo
--echo *******测试outline version变更时plan需要更新*************
drop outline otl1;
select * from xy_t;
--echo //expected 0;
select /*+use_plan_cache(none)*/ hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from xy_t';

set global ob_plan_cache_evict_high_percentage = 90;
set global ob_plan_cache_evict_low_percentage = 50;
drop table xy_t;
drop database xy_db;




