# description: ObPsCache在删除租户时会被析构. 本case检查ObPsCache析构时是否会有内存未释放的问题
# 但是case不完整，因为还需要让observer退出(kill -19 pid)，然后才能从日志里面看到 HAS UNFREE PTR!!!
# 这样的报错，所以还需要查看日志, 流程如下:
# 1. 运行本case:
# 2. kill -15 observer_pid: 让observer下线，不能用-9，不然server会直接被杀死
# 3. grep 'release ps plan cache' *: 检查是否有所有租户都已经在删除自己的ps cache对象
# 4. grep 'HAS UNFREE PTR!!!' *: 检查是否ps cache里面是否有未被显示释放的对象

--echo // uncomment below, follow the instructions to run this case manually
--echo // 1. run this case.
--echo // 2. kill -15 observer
--echo // 3. grep 'release ps plan cache' *: 确认调用到ObPsCache的析构
--echo // 4. grep 'has_unfree_callback' *: 确认没有unfree内存
