#owner: luofan.zp
#owner group: sql1

--result_format 4
--enable_sorted_result

--disable_info
--disable_metadata

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

alter system flush plan cache global;
alter system flush pl cache global;

--disable_query_log
alter system refresh memory stat;
--enable_query_log
sleep 2;

select USED > 0 from oceanbase.V$OB_MEMORY where tenant_id = 1002 and mod_name = 'HashBuckPlanCac';
select USED < 8000000 from oceanbase.V$OB_MEMORY where tenant_id = 1002 and mod_name = 'HashBuckPlanCac';

select USED > 0 from oceanbase.V$OB_MEMORY where tenant_id = 1002 and mod_name = 'HashBuckLCSta';
select USED < 8000000 from oceanbase.V$OB_MEMORY where tenant_id = 1002 and mod_name = 'HashBuckLCSta';

select USED > 0 from oceanbase.V$OB_MEMORY where tenant_id = 1001 and mod_name = 'HashBuckPlanCac';
select USED < 8000000 from oceanbase.V$OB_MEMORY where tenant_id = 1001 and mod_name = 'HashBuckPlanCac';

select USED > 0 from oceanbase.V$OB_MEMORY where tenant_id = 1001 and mod_name = 'HashBuckLCSta';
select USED < 8000000 from oceanbase.V$OB_MEMORY where tenant_id = 1001 and mod_name = 'HashBuckLCSta';

select USED > 0 from oceanbase.V$OB_MEMORY where tenant_id = 1 and mod_name = 'HashBuckPlanCac';
select USED < 8000000 from oceanbase.V$OB_MEMORY where tenant_id = 1 and mod_name = 'HashBuckPlanCac';
select USED < 8000000 from oceanbase.V$OB_MEMORY where tenant_id = 1 and mod_name = 'HashBuckPsCache';
select USED < 8000000 from oceanbase.V$OB_MEMORY where tenant_id = 1 and mod_name = 'HashBuckPsInfo';
