# owner: luofan.zp
# owner group: sql2
# description: test for limit topn sort

--disable_warnings
alter system flush plan cache global;
drop table if exists t_limit;
--enable_warnings
--result_format 4
--source mysql_test/include/backup_spm_var.inc


create table t_limit(c1 int, c2 int);
insert into t_limit values(3,3),(3,1),(3,2),(1,3),(1,1),(1,2),(2,3),(2,1),(2,2);

################################ test for topn sort exchange simple sort ##########################
--explain_protocol 1
select * from t_limit order by c1, c2 limit 5;
select * from t_limit order by c1, c2 limit 50;
select * from t_limit order by c1, c2 limit 50000;
select * from t_limit order by c1, c2 limit 5 offset 1;
select * from t_limit order by c1, c2 limit 50 offset 1;
select * from t_limit order by c1, c2 limit 50000 offset 1;
--explain_protocol 0

select type, query_sql, statement, outline_data, hit_count from oceanbase.gv$ob_plan_cache_plan_stat where query_sql like 'select * from t_limit order by%' order by type;



################################ test for topn sort exchange prefix sort ##########################
create index idx1 on t_limit(c1);
--explain_protocol 1
select * from t_limit order by c1, c2 limit 5;
select * from t_limit order by c1, c2 limit 50;
select * from t_limit order by c1, c2 limit 50000;
select * from t_limit order by c1, c2 limit 5 offset 1;
select * from t_limit order by c1, c2 limit 50 offset 1;
select * from t_limit order by c1, c2 limit 50000 offset 1;
--explain_protocol 0

select type, query_sql, statement, outline_data, hit_count from oceanbase.gv$ob_plan_cache_plan_stat where query_sql like 'select * from t_limit order by%' order by type;



--disable_warnings
drop table if exists t_limit;
alter system flush plan cache global;
--source mysql_test/include/recover_spm_var.inc
--enable_warnings
