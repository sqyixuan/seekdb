#owner: luofan.zp
#owner group: sql1
#tags: optimizer

--result_format 4
--enable_sorted_result

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

alter system set enable_auto_leader_switch=false;
alter system flush plan cache global;

--disable_info
--disable_metadata

connection default;
--disable_query_log
--disable_result_log

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

create table t1 (a int) partition by hash(a) partitions 2;
create table t2 (a int) partition by hash(a) partitions 2;
create table t3 (a int) partition by hash(a) partitions 2;

insert into t1 values (1), (2), (3);
insert into t2 values (1), (2), (3);
insert into t3 values (1), (2), (3);

--enable_query_log
--enable_result_log
#set _ob_use_parallel_execution = false;

--echo // CASE#1 hit different plan after changing session variable
--enable_result_log
select * from t1;

explain select * from t1;

#set _ob_use_parallel_execution = true;
select * from t1;
explain select * from t1;

--echo // expect hit_count = 0, 0
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1';

--echo // CASE#2 hit different plan using different parallel

select /*+ use_px parallel(1)*/* from t1;

explain select /*+ use_px parallel(1)*/* from t1;

select /*+ use_px parallel(2)*/* from t1;

explain select /*+ use_px parallel(2)*/* from t1;

--echo // hit_count = 0
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+ use_px parallel(1)*/* from t1';

--echo // hit_count = 0
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+ use_px parallel(2)*/* from t1';
--enable_warnings

--echo // CASE#3 Partition Wise Join

connection conn_admin;

let $case3_tbl1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' order by table_id desc limit 1, table_id, 1);
let $case3_tbl2_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't2' order by table_id desc limit 1, table_id, 1);
let $case3_tbl3_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't3' order by table_id desc limit 1, table_id, 1);

# get tbl1 ips, ports
let $case3_tbl1_part1_main_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl1_id and role = 1 order by partition_id, svr_ip, 1);
let $case3_tbl1_part2_main_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl1_id and role = 1 order by partition_id, svr_ip, 2);
let $case3_tbl1_part1_backup_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl1_id and role = 2 order by partition_id, svr_ip, 1);
let $case3_tbl1_part2_backup_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl1_id and role = 2 order by partition_id, svr_ip, 2);

let $case3_tbl1_part1_main_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl1_id and role = 1 order by partition_id, svr_port, 1);
let $case3_tbl1_part2_main_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl1_id and role = 1 order by partition_id, svr_port, 2);
let $case3_tbl1_part1_backup_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl1_id and role = 2 order by partition_id, svr_port, 1);
let $case3_tbl1_part2_backup_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl1_id and role = 2 order by partition_id, svr_port, 2);

# get tbl2 ips, ports
let $case3_tbl2_part1_main_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl2_id and role = 1 order by partition_id, svr_ip, 1);
let $case3_tbl2_part2_main_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl2_id and role = 1 order by partition_id, svr_ip, 2);
let $case3_tbl2_part1_backup_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl2_id and role = 2 order by partition_id, svr_ip, 1);
let $case3_tbl2_part2_backup_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl2_id and role = 2 order by partition_id, svr_ip, 2);

let $case3_tbl2_part1_main_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl2_id and role = 1 order by partition_id, svr_port, 1);
let $case3_tbl2_part2_main_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl2_id and role = 1 order by partition_id, svr_port, 2);
let $case3_tbl2_part1_backup_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl2_id and role = 2 order by partition_id, svr_port, 1);
let $case3_tbl2_part2_backup_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl2_id and role = 2 order by partition_id, svr_port, 2);

# get tbl3 ips, ports
let $case3_tbl3_part1_main_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl3_id and role = 1 order by partition_id, svr_ip, 1);
let $case3_tbl3_part2_main_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl3_id and role = 1 order by partition_id, svr_ip, 2);
let $case3_tbl3_part1_backup_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl3_id and role = 2 order by partition_id, svr_ip, 1);
let $case3_tbl3_part2_backup_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl3_id and role = 2 order by partition_id, svr_ip, 2);

let $case3_tbl3_part1_main_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl3_id and role = 1 order by partition_id, svr_port, 1);
let $case3_tbl3_part2_main_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl3_id and role = 1 order by partition_id, svr_port, 2);
let $case3_tbl3_part1_backup_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl3_id and role = 2 order by partition_id, svr_port, 1);
let $case3_tbl3_part2_backup_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case3_tbl3_id and role = 2 order by partition_id, svr_port, 2);

connection default;

--enable_query_log
--enable_result_log
select t1.a as a1, t2.a as a2 from t1 join t2 on t1.a = t2.a;
explain select t1.a as a1, t2.a as a2 from t1 join t2 on t1.a = t2.a;

connection conn_admin;

--disable_query_log
--disable_result_log
--echo // switch t1's part1 to backup, t2's part1 to backup
eval alter system switch replica leader partition_id='0%2@$case3_tbl1_id' server='$case3_tbl1_part1_backup_ip:$case3_tbl1_part1_backup_port';
eval alter system switch replica leader partition_id='0%2@$case3_tbl2_id' server='$case3_tbl2_part1_backup_ip:$case3_tbl2_part1_backup_port';
--sleep 5

connection default;

--enable_query_log
--enable_result_log

select t1.a as a1, t2.a as a2 from t1 join t2 on t1.a = t2.a;
explain select t1.a as a1, t2.a as a2 from t1 join t2 on t1.a = t2.a;

--echo // expect hit_count = 1
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select t1.a as a1, t2.a as a2 from t1 join t2 on t1.a = t2.a';

--disable_result_log
--disable_query_log
connection conn_admin;
--echo // switch t1's part1 to main
eval alter system switch replica leader partition_id='0%2@$case3_tbl1_id' server='$case3_tbl1_part1_main_ip:$case3_tbl1_part1_main_port';
--sleep 5

connection default;
let $tbl_name_to_check_sw_ok = 't1';
--source check_switch_leader_ok.inc
--enable_result_log
--enable_query_log
select t1.a as a1, t2.a as a2 from t1 join t2 on t1.a = t2.a;
explain select t1.a as a1, t2.a as a2 from t1 join t2 on t1.a = t2.a;

--echo // expect hit_count = 0, 1
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select t1.a as a1, t2.a as a2 from t1 join t2 on t1.a = t2.a';

--disable_result_log
--disable_query_log
connection conn_admin;
eval alter system switch replica leader partition_id='0%2@$case3_tbl1_id' server='$case3_tbl1_part1_main_ip:$case3_tbl1_part1_main_port';
eval alter system switch replica leader partition_id='0%2@$case3_tbl2_id' server='$case3_tbl2_part1_main_ip:$case3_tbl2_part1_main_port';
--sleep 5

connection default;
--enable_result_log
--enable_query_log

--echo // CASE#4 local, remote plan using px, change to dist plan
--echo // local
select * from t1 where a = 1;
explain select * from t1 where a = 1;

select t1.a as a1, t2.a as a2 from t1 join t2 where t1.a = t2.a and t1.a = 1;
explain select t1.a as a1, t2.a as a2 from t1 join t2 where t1.a = t2.a and t1.a = 1;

select /*+ use_px parallel(2)*/* from t1 where a = 1;
select /*+ use_px parallel(2)*/* from t1 where a = 1;
explain select /*+ use_px parallel(2)*/* from t1 where a = 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+ use_px parallel(2)*/* from t1 where a = ?';

select /*+ use_px parallel(2)*/t1.a as a1, t2.a as a2 from t1 join t2 where t1.a = t2.a and t1.a = 1;
select /*+ use_px parallel(2)*/t1.a as a1, t2.a as a2 from t1 join t2 where t1.a = t2.a and t1.a = 1;
explain select /*+ use_px parallel(2)*/t1.a as a1, t2.a as a2 from t1 join t2 where t1.a = t2.a and t1.a = 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+ use_px parallel(2)*/t1.a as a1, t2.a as a2 from t1 join t2 where t1.a = t2.a and t1.a = ?';

connection conn_admin;
--disable_result_log
--disable_query_log
eval alter system switch replica leader partition_id='0%2@$case3_tbl1_id' server='$case3_tbl1_part1_backup_ip:$case3_tbl1_part1_backup_port';
eval alter system switch replica leader partition_id='0%2@$case3_tbl2_id' server='$case3_tbl2_part1_backup_ip:$case3_tbl2_part1_backup_port';
--sleep 3

connection default;
--enable_result_log
--enable_query_log
--echo // remote
select * from t1 where a = 2;
explain select * from t1 where a = 2;

select /*+ use_px parallel(2)*/* from t1 where a = 2;
select /*+ use_px parallel(2)*/* from t1 where a = 2;
explain select /*+ use_px parallel(2)*/* from t1 where a = 2;
--echo // expect hit_count = 3, hit plan before
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+ use_px parallel(2)*/* from t1 where a = ?';

select t1.a as a1, t2.a as a2 from t1 join t2 where t1.a = t2.a and t1.a = 2;
explain select t1.a as a1, t2.a as a2 from t1 join t2 where t1.a = t2.a and t1.a = 2;

select /*+ use_px parallel(2)*/t1.a as a1, t2.a as a2 from t1 join t2 where t1.a = t2.a and t1.a = 2;
select /*+ use_px parallel(2)*/t1.a as a1, t2.a as a2 from t1 join t2 where t1.a = t2.a and t1.a = 2;
explain select /*+ use_px parallel(2)*/t1.a as a1, t2.a as a2 from t1 join t2 where t1.a = t2.a and t1.a = 2;

select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+ use_px parallel(2)*/t1.a as a1, t2.a as a2 from t1 join t2 where t1.a = t2.a and t1.a = ?';

--echo // Simple Misc Case
--disable_warnings
drop table if exists tt1;
--enable_warnings
create table tt1 (pk int primary key, a int) partition by hash(pk) partitions 2;

insert into tt1 values (1, 1), (2, 2);

select * from tt1 where pk in (1, 1);
select * from tt1 where pk in (1, 1);
select * from tt1 where pk in (1, 2);

--echo // expect (0, 3), (1, 1)
--disable_warnings
select hit_count, type from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from tt1 where pk in (?, ?)';

--echo // CASE#5 px with 'try plan'
--disable_warnings
drop table if exists t5;
--enable_warnings
create table t5 (pk int primary key, a int, b int);
create index idx_t5_a on t5(a) global partition by hash(a) partitions 2;
insert into t5 values (1, 1, 1), (2, 2, 2);

connection conn_admin;
alter system flush plan cache global;

let $idx_t5_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name like '%_idx_t5_a%' order by table_id desc limit 1, table_id, 1);
let $idx_t5_backup_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $idx_t5_id and role = 2 order by partition_id limit 1, svr_ip, 1);
let $idx_t5_backup_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $idx_t5_id and role = 2 order by partition_id limit 1, svr_port, 1);

--disable_query_log
--disable_result_log
--echo // switch idx_t5_a part0 to backup
eval alter system switch replica leader partition_id = '0%2@$idx_t5_id' server='$idx_t5_backup_ip:$idx_t5_backup_port';
--sleep 5
--enable_query_log
--enable_result_log
connection default;
--echo // local plan with parallel = 2
select /*+ index(t5 idx_t5_a), parallel(2)*/* from t5 where a = 1;
select /*+ index(t5 idx_t5_a), parallel(2)*/* from t5 where a = 1;
explain select /*+ index(t5 idx_t5_a), parallel(2)*/* from t5 where a = 1;

select hit_count, type from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+ index(t5 idx_t5_a), parallel(2)*/* from t5 where a = ?';

--echo // remote plan with paralllel = 2
select /*+ index(t5 idx_t5_a), parallel(2)*/* from t5 where a = 2;
select /*+ index(t5 idx_t5_a), parallel(2)*/* from t5 where a = 2;
explain select /*+ index(t5 idx_t5_a), parallel(2)*/* from t5 where a = 2;

select hit_count, type from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+ index(t5 idx_t5_a), parallel(2)*/* from t5 where a = ?';
--enable_warnings

--echo >>>>>>>>>>>>>>>>>>>>cleanup<<<<<<<<<<<<<<<<<<<<<<<<<<
connection conn_admin;
alter system set enable_auto_leader_switch=true;
