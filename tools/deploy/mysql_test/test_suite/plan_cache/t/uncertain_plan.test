#owner: luofan.zp
#owner group: sql1
#tags: optimizer, outline
##
## Test Name: uncertain plan test
## 
##
## INFO:  if you want to add case; you should read ../README.md;
#         don't use sys tenant, because when parallel run on obfarm, the hit_count can't be expected;
#         so we use new tenant, new plan cache will be  used for this case only;
##
##
## Date: 2019-06-22
##
--result_format 4
--enable_sorted_result
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_info
--disable_metadata

alter system flush plan cache global;
alter system set enable_auto_leader_switch=false;

--enable_query_log
--enable_result_log
connection default;
set ob_trx_timeout = 100000000000;
--disable_query_log
--disable_result_log

set autocommit = 1;

--source mysql_test/test_suite/plan_cache/t/uncertain_plan.inc
commit;

connection conn_admin;
alter system flush plan cache global;
alter system set enable_auto_leader_switch=true;
