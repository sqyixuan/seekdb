let $case5_tbl1_part1_main_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_1 and role = 1 order by partition_id, svr_port, 1);
# backups
let $case5_tbl1_part1_backup_ip1 = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_1 and role = 2 and partition_id = 0, svr_ip, 1);
let $case5_tbl1_part1_backup_port1 = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_1 and role = 2 and partition_id = 0, svr_port, 1);

let $case5_tbl1_part2_main_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_1 and role = 1 order by partition_id, svr_ip, 2);
let $case5_tbl1_part2_main_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_1 and role = 1 order by partition_id, svr_port, 2);
# backups
let $case5_tbl1_part2_backup_ip1 = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_1 and role = 2 and partition_id = 1, svr_ip, 1);
let $case5_tbl1_part2_backup_port1 = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_1 and role = 2 and partition_id = 1, svr_port, 1);

let $case5_tbl2_part1_main_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_2 and role = 1 order by partition_id, svr_ip, 1);
let $case5_tbl2_part1_main_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_2 and role = 1 order by partition_id, svr_port, 1);
# backups
let $case5_tbl2_part1_backup_ip1 = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_2 and role = 2 and partition_id = 0, svr_ip, 1);
let $case5_tbl2_part1_backup_port1 = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_2 and role = 2 and partition_id = 0, svr_port, 1);

let $case5_tbl2_part2_main_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_2 and role = 1 order by partition_id, svr_ip, 2);
let $case5_tbl2_part2_main_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_2 and role = 1 order by partition_id, svr_port, 2);
# backups
let $case5_tbl2_part2_backup_ip1 = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_2 and role = 2 and partition_id = 1, svr_ip, 1);
let $case5_tbl2_part2_backup_port1 = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $case5_tbl_id_2 and role = 2 and partition_id = 1, svr_port, 1);

connection default;

--enable_query_log
insert into case5_t_1 values (1, 1), (2, 2);
insert into case5_t_1 values (3, 3), (4, 4);

--enable_result_log
--echo // expect 1
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into case5_t_1 values (?, ?), (?, ?)';

connection conn_admin;
--echo switch case5_t_1 part0 to backup, now part0 in backup, part1 in main
--disable_result_log
--disable_query_log
eval alter system switch replica leader partition_id='0%2@$case5_tbl_id_1' server='$case5_tbl1_part1_backup_ip1:$case5_tbl1_part1_backup_port1';
--sleep 10

connection default;
--enable_query_log
insert into case5_t_1 values (5, 5), (6, 6);


--enable_result_log
explain insert into case5_t_1 values (5, 5), (6, 6);
--echo // expect 2
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into case5_t_1 values (?, ?), (?, ?)';

--echo // select result for debug
select * from case5_t_1 order by pk;

--echo
--echo // Insert into select

insert into case5_t_2 (select * from case5_t_1);
explain insert into case5_t_2 (select * from case5_t_1);

--echo // expect hit_count = 0
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into case5_t_2 (select * from case5_t_1)';

--disable_result_log
delete from case5_t_2;

connection conn_admin;
--disable_query_log
--echo switch case5_t_1 part0 to main, now part0 in main, part1 in main
eval alter system switch replica leader partition_id='0%2@$case5_tbl_id_2' server='$case5_tbl2_part1_backup_ip1:$case5_tbl2_part1_backup_port1';
--sleep 10

connection default;
--enable_query_log
insert into case5_t_2 (select * from case5_t_1);
--enable_result_log
explain insert into case5_t_2 (select * from case5_t_1);

--echo // expect hit_count = 1
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into case5_t_2 (select * from case5_t_1)';

--echo // select result for debug
select * from case5_t_2 order by pk;

--disable_result_log
--disable_query_log
drop table case5_t_1, case5_t_2;

--echo ****************************** cleanup ******************************
--disable_warnings
drop database if exists xy_db;
--enable_warnings
# using admin acount
connection conn_admin;

alter system set large_query_threshold = '100ms';
alter system set enable_auto_leader_switch = true;
