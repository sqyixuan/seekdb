# select t1.c1, t1.c2 from dist_t as t1, dist_t as t2, dist_t as t3 where t1.c1 = 1 or t2.c1 = 2 or t3.c1 >=3;
# select t1.c1, t1.c2 from dist_t as t1, dist_t as t2, dist_t as t3 where t1.c1 = 1 or t2.c1 = 2 or t3.c1 >=3;
# --enable_result_log
# --echo
# explain select t1.c1, t1.c2 from dist_t as t1, dist_t as t2, dist_t as t3 where t1.c1 = 1 or t2.c1 = 2 or t3.c1 >=3;
# --echo
# --echo // expect hit_count = 1, type = 3
# select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select t1.c1, t1.c2 from dist_t as t1, dist_t as t2, dist_t as t3 where t1.c1 = ? or t2.c1 = ? or t3.c1 >=?';
--enable_warnings

drop table dist_t;
commit;
--disable_result_log
--disable_query_log

connection conn_admin;
alter system set large_query_threshold = '100ms';