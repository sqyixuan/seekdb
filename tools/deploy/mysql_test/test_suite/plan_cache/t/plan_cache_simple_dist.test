#owner: luofan.zp
#owner group: sql1
# tags: optimizer
##
## Test Name: plan_cache_basic
##
## Scope: Test basic function for simple dist plan
##
## INFO:  if you want to add case; you should read ../README.md;
#         don't use sys tenant, because when parallel run on obfarm, the hit_count can't be expected;
#         so we use new tenant, new plan cache will be  used for this case only;
##
##
## Date: 2018-12-19
##

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_info
--disable_metadata
#--disable_abort_on_error

--disable_query_log
--disable_result_log

alter system flush plan cache;
alter system set large_query_threshold = '1s';
--sleep 3
--enable_query_log
--enable_result_log
connection default;
--disable_query_log
--disable_result_log

set autocommit = 0;
--disable_warnings
drop database if exists xy_db;
--enable_warnings
create database xy_db;
use xy_db;

--disable_query_log
--disable_result_log
create table dist_t(c1 int primary key, c2 int) partition by hash (c1) partitions 5;
insert into dist_t values(0, 0);
insert into dist_t values(1, 1);
insert into dist_t values(2, 1);
insert into dist_t values(3, 2);
insert into dist_t values(4, 2);
insert into dist_t values(5, 3);
insert into dist_t values(6, 3);
insert into dist_t values(7, 4);
insert into dist_t values(8, 4);
insert into dist_t values(9, 5);
--sleep 1

--echo // >>>>>>>>>>>>>>>>>>>> TEST Single Table With Dist Plan
--echo
--enable_query_log
select  * from dist_t where c1 = (c1 >= 2 and c2 <= 2) or c1 = 1;
select  * from dist_t where c1 = (c1 >= 2 and c2 <= 2) or c1 = 1;
--enable_result_log
--echo
--echo // expect dist plan
explain select  * from dist_t where c1 = (c1 >= 2 and c2 <= 2) or c1 = 1;
--echo
--echo // expect hit_count = 1, type = 3
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select  * from dist_t where c1 = (c1 >= ? and c2 <= ?) or c1 = ?';

--echo
--disable_result_log
select  * from dist_t where c1 <=> 1;
select  * from dist_t where c1 <=> 1;

--echo
--enable_result_log
--echo // expect dist plan
explain select  * from dist_t where c1 <=> 1;
--echo
--echo // expect hit_count = 1, type = 3
select  hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select  * from dist_t where c1 <=> ?";

--echo
--disable_result_log
select  * from dist_t where c1 between 0 and 3;
select  * from dist_t where c1 between 3 and 5;
--enable_result_log
--echo
explain select  * from dist_t where c1 between 0 and 3;

--echo
--echo // expect hit_count = 1, type = 3
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select  * from dist_t where c1 between ? and ?';

--echo
--echo // >>>>>>>>>>>>>>>>>>>> TEST MultiTable With Dist Plan
# bug 
