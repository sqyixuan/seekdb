## owner: jim.wjh
# owner group: sql2

--source mysql_test/include/select_into_outfile/get_host_ip.inc
let $DATA_FOLDER_NAME = plan_cache_select_into_outfile_test;

--source mysql_test/include/select_into_outfile/delete_dir.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump.inc

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

alter system flush plan cache global;
connection default;

--error 0,1051
drop table t1;
create table t1(c1 int);
--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * into outfile '$DATA_FOLDER_NAME/data1' fields terminated by '|' enclosed by '"' lines terminated by '\n' from t1;

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * into outfile '$DATA_FOLDER_NAME/data2' fields terminated by '|' enclosed by '"' lines terminated by '\n' from t1;

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * into outfile '$DATA_FOLDER_NAME/data1' fields terminated by '|' enclosed by '"' lines terminated by '\n' from t1 where c1 > 1;

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * into outfile '$DATA_FOLDER_NAME/data2' fields terminated by '|' enclosed by '"' lines terminated by '\n' from t1 where c1 > 10;

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 where c1 > 1 into outfile '$DATA_FOLDER_NAME/data1' fields terminated by '|' enclosed by '"' lines terminated by '\n';

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 where c1 > 10 into outfile '$DATA_FOLDER_NAME/data2' fields terminated by '|' enclosed by '"' lines terminated by '\n';

--disable_warnings
select hit_count, statement from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "%into outfile%";
--enable_warnings
drop table t1;

--source mysql_test/include/select_into_outfile/delete_dir.inc

connection conn_admin;
alter system flush plan cache global;
