--echo
--echo bug: 

alter system flush plan cache global;

--result_format 4
--disable_warnings
drop table if exists plan_cache_default;
--enable_warnings

create table plan_cache_default(c1 varchar(10) default '', c2 int);
insert into plan_cache_default(c2) values(5);
select statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT
where statement like 'insert into plan_cache_default%';

drop table plan_cache_default;
