#owner: xiaoyi.xy
#owner group: sql1

--disable_info
--disable_metadata
--disable_abort_on_error
set ob_trx_timeout = 1000000000;
set autocommit = 0;

--echo
--echo bug: 
--disable_warnings
drop table if exists t;
--enable_warnings
--enable_query_log
--enable_result_log
create table t(c1 varchar(10));
select * from t where c1 like substring('', 1, 2) escape 'c';
select * from t where c1 like substring('', 1, 2) escape 'c';
--echo // expected hit_count = 1
select  hit_count, statement from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select * from t where c1 like substring('', 1, 2) escape 'c'";
drop table t;

commit;


