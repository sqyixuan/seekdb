
#owner: luofan.zp
#owner group: sql1
##
## Test Name: plan_cache_check_constraint
##
## Scope: Test basic constraint of plan cache match
##
## INFO:  if you want to add case; you should read ../README.md;
#         don't use sys tenant, because when parallel run on obfarm, the hit_count can't be expected;
#         so we use new tenant, new plan cache will be  used for this case only;
##
##
## Date: 26-Aug-21 
##

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system flush plan cache global;


connection default;
drop table if exists t;
create table t(c1 int, c2 int, c3 int, primary key(c1, c2, c3)) partition by hash(c3) partitions 2;
insert into t values(1, 1, 1),(1, 2, 1), (1,1,2),(1,2,2),(2, 1,1),(2,1,2),(2,2,1),(2,2,2);
select * from t where (c1=1 and c2=1 and c3=1) or (c1=1 and c2=2 and c3=2);
select * from t where (c1=1 and c2=2 and c3=1) or (c1=1 and c2=2 and c3=1);
select * from t where (c1=1 and c2=1 and c3=1) or (c1=1 and c2=2 and c3=1);
select type, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where sql_id='71E7055D7F5E6EB5742D6C6DB211D767';
drop table t;

connection conn_admin;
alter system flush plan cache global;


