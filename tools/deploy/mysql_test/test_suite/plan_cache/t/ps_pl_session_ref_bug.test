# owner: luofan.zp
# owner group: SQL2
# description: 
# 本case是为了覆盖内部sql跟session交互引起的ps cache对象引用计数的问题
# 其实应该是ps相关的case，但是由于本case不需要在ps模式下运行，所以放在本目录

--result_format 4
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system flush pl cache global;
alter system flush plan cache global;

--disable_warnings
drop table if exists t1;
drop procedure if exists p;
--enable_warnings

create table t1 (shaogedebug_ps_col varchar(100));
insert into t1 values('abcd');

delimiter //;
create procedure p(in x int)
begin 
select hex(shaogedebug_ps_col) from t1; 
end//
delimiter ;//

--echo // stmt_item_ref_count and stmt_info_ref_count 应该是2
--echo // 一个是视图占用的引用计数,一个是pl func对象占用的引用计数
--echo // 该bug未解决前，引用计数是3，是session占用的
select ps_sql,stmt_item_ref_count,stmt_info_ref_count from oceanbase.__all_virtual_ps_item_info where ps_sql like '%shaogedebug%';
drop procedure p;
