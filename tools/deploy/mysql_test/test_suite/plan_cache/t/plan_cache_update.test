--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: luofan.zp
#owner group: sql1
##
## Test Name: plan_cache_update
##
## Scope:Test plan cache update plan when some property changed
##
## Date: 2015-9-16
##
connect (conn_admin,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_info
--disable_metadata
--disable_abort_on_error

alter system set resource_hard_limit = 500;
--enable_query_log
alter system flush plan cache;
--sleep 3
#connect (conn1,$OBMYSQL_MS0,root@xy_tenant_1,,*NO-ONE*,$OBMYSQL_PORT);
# connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

#为普通租户建立用户，用于测试read_only系统变量对plan cache的影响
connection default;
set ob_trx_timeout = 1000000000;
--error 0,1396
drop user 'xy'@'%';
create user 'xy'@'%';
grant CREATE, SELECT, INSERT, DROP on *.* to xy;
--disable_query_log
--disable_result_log
let $cur_mode = query_get_value(select effective_tenant() tenant from dual, tenant, 1);
--source mysql_test/include/check_schema_sync.inc
connect (conn_xy, $OBMYSQL_MS0, xy@$cur_mode, , test, $OBMYSQL_PORT);
connection default;
# set ob_log_level='sql.*:debug';
--enable_query_log
--enable_result_log
select effective_tenant();

set autocommit = 0;
set ob_read_consistency = 'weak';
--disable_warnings
drop database if exists xy_db;
--enable_warnings
create database xy_db;
use xy_db;

--echo
--echo #bug 8044575 plan cache对table schema校验bug
create table ts_t(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
--sleep 3
select * from ts_t where c1 = 0; #//local plan
--echo // expect hit_count = 0
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from ts_t where c1 = ?';
drop table ts_t;
--enable_warnings
create table ts_t(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
--sleep 3

select * from ts_t where c1 = 1; #remote plan
--echo //expect hit_count = 0, because new pcv create and add plan create by 'select * from ts_t where c1 = 1';
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from ts_t where c1 = ?';
select * from ts_t where c1 = 1;
--echo //expect hit_count = 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from ts_t where c1 = ?';
--enable_warnings

--echo
--echo #bug 7998585 plan cache支持恒真/假表达式的校验
--disable_warnings
drop table if exists bool_t1,bool_t2,bool_t3;
drop tablegroup if exists bool_group;
--enable_warnings
create tablegroup bool_group;
create table bool_t1(c1 int primary key, c2 int) tablegroup='bool_group';

create table bool_t2(c1 int primary key, c2 int) tablegroup='bool_group';

create table bool_t3(c1 int primary key, c2 int) tablegroup='bool_group';
--sleep 3

select * from bool_t1 where (0 = 1) or c1 = 1;
--echo
--echo //expect hit_count = 0
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from bool_t1 where (? = ?) or c1 = ?';
select * from bool_t1 where (1 = 1) or c1 = 1;
--echo //expect two records, each record's hit_count is 0;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from bool_t1 where (? = ?) or c1 = ?';
--echo
select * from bool_t1 left join bool_t2 on (1 = 0 or bool_t1.c1 = bool_t2.c1) left join bool_t3 on (2=2 or bool_t2.c1 = bool_t3.c1);
--echo //expect hit_count = 0
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from bool_t1 left join bool_t2 on (? = ? or bool_t1.c1 = bool_t2.c1) left join bool_t3 on (?=? or bool_t2.c1 = bool_t3.c1)';
select * from bool_t1 left join bool_t2 on (1 = 3 or bool_t1.c1 = bool_t2.c1) left join bool_t3 on (4=4 or bool_t2.c1 = bool_t3.c1);
--echo //expect hit_count = 1
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from bool_t1 left join bool_t2 on (? = ? or bool_t1.c1 = bool_t2.c1) left join bool_t3 on (?=? or bool_t2.c1 = bool_t3.c1)';
--enable_warnings
drop table bool_t1,bool_t2,bool_t3;

#change view table version
--echo
--echo *********************************change view table version ************************
--echo //test drop/create view
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(i1 int primary key, f1 float, s1 varchar(32), d1 datetime);

--disable_warnings
drop view if exists vt;
--enable_warnings
create view vt as select * from t1;
--echo
--sleep 3
select * from vt;
--echo // expect hit_count = 0;
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from vt';
--echo
drop view vt;
create view vt as select * from t1;
select * from vt;
--echo // expect hit_count = 0; not hit, because view version change, plan update
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from vt';
--echo
select * from vt;
--echo // expect hit_count is 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from vt';
--enable_warnings

