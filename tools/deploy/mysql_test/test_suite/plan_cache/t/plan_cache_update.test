#alter table
--echo
--echo ************** test alter table, plan update; ****************************************
--disable_warnings
drop table if exists alter_add_t;
--enable_warnings
create table alter_add_t(i1 int primary key, f1 float, s1 varchar(32), d1 datetime);
--sleep 3
--echo
select * from alter_add_t where i1 = 1;
--echo //expect hit_count = 0;
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from alter_add_t where i1 = ?';
--echo
alter table alter_add_t add i2 int;
--sleep 3
select * from alter_add_t where i1 = 1;
--echo //expect hit_count = 0, not hit, because table version change, plan update
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from alter_add_t where i1 = ?';
--echo
select * from alter_add_t where i1 = 1;
--echo //expect hit_count = 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from alter_add_t where i1 = ?';
--enable_warnings

--echo
--echo ************************ test alter table, plan update ******************************
--disable_warnings
drop table if exists alter_table_t;
--enable_warnings
create table alter_table_t(i1 int primary key, f1 float, s1 varchar(32), d1 datetime);
--sleep 3
--echo
select * from alter_table_t where i1 = 1;
--echo // expect hit_count = 0;
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from alter_table_t where i1 = ?';
--echo
alter table alter_table_t drop s1;
--sleep 3
select * from alter_table_t where i1 = 1;
--echo //expect hit_count = 0, not hit, because table version change, plan update
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from alter_table_t where i1 = ?';
--echo
select * from alter_table_t where i1 = 1;
--echo //expect hit_count = 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from alter_table_t where i1 = ?';
--enable_warnings

--echo
--echo ***************************** change system variable : binlog_row_image *************************
--disable_warnings
drop table if exists binlog_t_update_oracle;
--enable_warnings
create table binlog_t_update_oracle(c1 int primary key, c2 varchar(100), v3 timestamp);
--sleep 3
--echo
set binlog_row_image='minimal';
update binlog_t_update_oracle set v3 = current_timestamp();
--echo //expect hit_count = 0;
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'update binlog_t_update_oracle set v3 = current_timestamp()';
--echo
set binlog_row_image = 'full';
update binlog_t_update_oracle set v3 = current_timestamp();
--echo //expect two records, each record's hit_count is 0; because system variable change, add new plan;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'update binlog_t_update_oracle set v3 = current_timestamp()';
--echo
update binlog_t_update_oracle set v3 = current_timestamp();
--echo //expect two records, one hit_count is 0, another hit_count is 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'update binlog_t_update_oracle set v3 = current_timestamp()';
--enable_warnings
drop table binlog_t_update_oracle;
commit;

--echo
--echo ********************************* change system variable : ob_enable_index_direct_select  ************************
--echo //change to system tenant, because only system tenant can read __all_table;
set autocommit = 0;
--disable_warnings
drop database if exists xy_db;
--enable_warnings
create database xy_db;
use xy_db;
--disable_warnings
drop table if exists index_enabled_t;
--enable_warnings
create table index_enabled_t(c1 int primary key, c2 int);
create index i1_unique_index on index_enabled_t(c1);
--source mysql_test/include/check_all_idx_ok.inc
#$table的值是在每次test执行时是变化的，所以为确保结果值的稳定性，使用echo显示输出查询；
--echo let \$table = query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id=(select table_id from oceanbase.__all_virtual_table where table_name='index_enabled_t'),table_name,1);

connection default;
let $xy_db_id = query_get_value(select database_id from oceanbase.__all_database where database_name = 'xy_db', database_id, 1);
let $table = query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id=(select table_id from oceanbase.__all_virtual_table where table_name='index_enabled_t' and database_id = $xy_db_id),table_name,1);

--echo
set ob_enable_index_direct_select = 1;
--disable_query_log
--echo select  * from \$table
eval select  * from $table;
--echo //expect hit_count = 0;
--disable_warnings
--echo select hit_count from oceanbase.V\$OB_PLAN_CACHE_PLAN_STAT where statement like 'select  * from \$table';
eval select hit_count from oceanbase.V\$OB_PLAN_CACHE_PLAN_STAT where statement like 'select  * from $table';
--enable_warnings
--enable_query_log

--echo
set ob_enable_index_direct_select = 0;
--disable_query_log
--echo select  * from \$table;
--disable_result_log
--error 1146
eval select  * from $table;
--echo error 1146  #该处报错信息中有表的id，该id是变化的，为保证结果稳定性使用echo输出；
--enable_result_log
--echo //expect hit_count = 0; not hit, and not add new plan
--disable_warnings
--echo select hit_count from oceanbase.V\$OB_PLAN_CACHE_PLAN_STAT where statement like 'select  * from \$table';
eval select hit_count from oceanbase.V\$OB_PLAN_CACHE_PLAN_STAT where statement like 'select  * from $table';
--enable_query_log

--echo
set ob_enable_index_direct_select = 1;
--disable_query_log
--echo select  * from \$table;
eval select  * from $table;
--echo //expect hit_count = 1;
--echo select hit_count from oceanbase.V\$OB_PLAN_CACHE_PLAN_STAT where statement like 'select  * from \$table';
eval select hit_count from oceanbase.V\$OB_PLAN_CACHE_PLAN_STAT where statement like 'select  * from $table';
--enable_warnings
--enable_query_log
--echo
--disable_warnings
drop database if exists xy_db;
--enable_warnings
commit;

--echo
--echo ********************************* change system variable : collation_connection ************************

set autocommit = 0;
create database xy_db;
