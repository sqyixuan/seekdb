--echo
select * from collation_t where c2 = 'ab';
--echo //expect two records, one hit_count is 0, another hit_count is 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from collation_t where c2 = ?';
--enable_warnings

