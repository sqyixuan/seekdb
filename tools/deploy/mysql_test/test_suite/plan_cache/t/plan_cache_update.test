--sleep 3

set ob_enable_transformation = 1;
select * from t1, (select * from t1 ) as v1;
--echo //expect hit_count = 0;
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1, (select * from t1 ) as v1';
--echo
set ob_enable_transformation = 0;
select * from t1, (select * from t1 ) as v1;
--echo //expect two records, every hit_count is 0 ;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1, (select * from t1 ) as v1';
--echo
select * from t1, (select * from t1 ) as v1;
--echo //expect two records, one hit_count is 0, another hit_count is 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1, (select * from t1 ) as v1';
--enable_warnings
drop table t1;

commit;
set autocommit = 1;

#read only需要通过租户的管理员用户更改该变量，并且不能在事务中进行更改。
--echo
--echo ******************************* change system variable : read only *********************************
# connect (conn_xy,$OBMYSQL_MS0,xy@$MODE,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_xy;
use xy_db;
set autocommit = 0;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 int);
--sleep 3
--echo
connection default;
set @@global.read_only = off;
connection conn_xy;
--sleep 2
insert into t1 values(1,1);
--echo //expect hit_count = 0;
--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 values(?,?)';
--echo
connection default;
set @@global.read_only = on;
connection conn_xy;
--sleep 2
insert into t1 values(2,1);
--echo //expect hit_count = 0;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 values(?,?)';
--enable_warnings
--echo
connection default;
set @@global.read_only = off;
connection conn_xy;
--sleep 2
commit;

connection default;
--disable_warnings
--disable_query_log
drop database if exists xy_db;
drop database if exists merge_db;
--error 0, 1396
drop user 'xy';
--enable_warnings
