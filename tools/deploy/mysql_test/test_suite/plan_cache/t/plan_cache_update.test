--disable_warnings
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from collation_t where c2 = ?';
--echo
set collation_connection = 'utf8_general_ci';
select * from collation_t where c2 = 'ab';
--echo //expect two records, each record's hit_count is 0; because system variable change, add new plan;
