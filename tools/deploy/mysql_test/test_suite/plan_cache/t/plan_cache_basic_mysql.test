#owner: luofan.zp
#owner group: sql1
##
## Test Name: plan_cache_basic sysdate() function
##
## Scope: Test basic function of plan cache match
##
## INFO:  if you want to add case; you should read ../README.md;
#         don't use sys tenant, because when parallel run on obfarm, the hit_count can't be expected;
#         so we use new tenant, new plan cache will be  used for this case only;
##
##
## Date: 2015-9-16
##

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_info
--disable_metadata
--disable_abort_on_error

--disable_query_log
--disable_result_log

alter system flush plan cache;
alter system set large_query_threshold = '1s';
--sleep 3

--enable_query_log
--enable_result_log
connection default;
select  effective_tenant();

--disable_query_log
--disable_result_log
source mysql_test/test_suite/plan_cache/t/plan_cache_table_init.sql;

--echo
--echo **********************select  * from type_t where datetime_c = sysdate()****************
--echo **********************select  * from type_t where datetime_c = sysdate()****************
--disable_query_log
--disable_result_log
select  * from type_t where datetime_c = sysdate();
select  * from type_t where datetime_c = sysdate();
--enable_result_log
select  hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select  * from type_t where datetime_c = sysdate()";

--echo
--echo **********************select  * from type_t where datetime_c = sysdate(0)****************
--echo **********************select  * from type_t where datetime_c = sysdate(0)****************
--disable_query_log
--disable_result_log
select  * from type_t where datetime_c = sysdate(0);
select  * from type_t where datetime_c = sysdate(0);
--enable_result_log
select  hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select  * from type_t where datetime_c = sysdate(0)";

--echo
--echo **********************select  * from type_t where datetime_c = sysdate(1)****************
--echo **********************select  * from type_t where datetime_c = sysdate(2)****************
--disable_query_log
--disable_result_log
select  * from type_t where datetime_c = sysdate(1);
select  * from type_t where datetime_c = sysdate(2);
--enable_result_log
select  hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select  * from type_t where datetime_c = sysdate(1)";

--disable_query_log
--disable_result_log

--echo
--echo bug fix: 

--echo
--echo ***************************select convert('123' using 'utf8')***************************
--echo ***************************select convert('456' using 'utf8')***************************
select convert('123' using 'utf8');
select convert('456' using 'utf8');
--enable_result_log
select hit_count, statement from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select convert(? using ''utf8'')';
--disable_result_log

--echo
--echo ***************************select convert('123' using utf8)***************************
--echo ***************************select convert('456' using utf8)***************************
select convert('123' using utf8);
select convert('456' using utf8);
--enable_result_log
select hit_count, statement from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select convert(? using utf8)';
--disable_result_log

--echo
--echo ***************************select character('123' using 'utf8')***************************
--echo ***************************select character('456' using 'utf8')***************************
select character('123' using 'utf8');
select character('456' using 'utf8');
--enable_result_log
select hit_count, statement from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select character(? using ''utf8'')';
--disable_result_log

--echo
--echo ***************************select character('123' using utf8)***************************
--echo ***************************select character('456' using utf8)***************************
select character('123' using utf8);
select character('456' using utf8);
--enable_result_log
select hit_count, statement from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select character(? using utf8)';
--disable_query_log
--disable_result_log

connection conn_admin;
alter system set large_query_threshold = '100ms';