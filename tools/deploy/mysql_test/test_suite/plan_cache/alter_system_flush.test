--echo
#test flush cache after major freeze
--echo //test flush cache after major freeze
connection conn_sys_1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

connection conn_nt_1;
select /*+use_plan_cache(none)*/ plan_num > 0 as result from oceanbase.V$OB_PLAN_CACHE_STAT;
connection conn_nt_2;
select /*+use_plan_cache(none)*/ plan_num > 0 as result from oceanbase.V$OB_PLAN_CACHE_STAT;
