
#owner: zongmei.zzm
#owner group: sql1
##
## Test Name: alter_system_flush
## Scope: test feature of flush cache
## Date: 2016-07-21

--disable_info
 --disable_metadata
--disable_abort_on_error

--disable_query_log
--error 0,5157
drop tenant xy_tenant_1 force;

alter system set resource_hard_limit = 500;
eval create resource unit if not exists xy_box_1 max_cpu 5, memory_size 1500000000;
let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);
let $obs_num = query_get_value(select count(1) as cnt from oceanbase.__all_server group by zone asc limit 1,cnt, 1);
eval create resource pool if not exists xy_pool_1 unit = 'xy_box_1', unit_num = $obs_num;
eval create tenant if not exists xy_tenant_1 primary_zone='$zone_name', resource_pool_list('xy_pool_1') set ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc

--enable_query_log

#获取所有机器ip 和 port
let $obs_count= query_get_value(select count(1) as cnt from oceanbase.__all_server, cnt, 1);
--echo $obs_count
let $svr_ip_1 = query_get_value(select svr_ip from oceanbase.__all_server order by id, svr_ip, 1);
let $svr_ip_2 = query_get_value(select svr_ip from oceanbase.__all_server order by id, svr_ip, 2);
let $svr_ip_3 = query_get_value(select svr_ip from oceanbase.__all_server order by id, svr_ip, 3);
let $svr_ip_4 = query_get_value(select svr_ip from oceanbase.__all_server order by id, svr_ip, 4);

let $svr_port_1 = query_get_value(select inner_port from oceanbase.__all_server order by id, inner_port, 1);
let $svr_port_2 = query_get_value(select inner_port from oceanbase.__all_server order by id, inner_port, 2);
let $svr_port_3 = query_get_value(select inner_port from oceanbase.__all_server order by id, inner_port, 3);
let $svr_port_4 = query_get_value(select inner_port from oceanbase.__all_server order by id, inner_port, 4);

connect(conn_sys_1, $svr_ip_1, admin@sys, admin, oceanbase, $svr_port_1);
connect(conn_sys_2, $svr_ip_2, admin@sys, admin, oceanbase, $svr_port_2);

connect(conn_nt_1, $svr_ip_1, root@xy_tenant_1,, test, $svr_port_1);
connect(conn_nt_2, $svr_ip_2, root@xy_tenant_1,, test, $svr_port_2);
connect(conn_nt_3, $svr_ip_3, root@xy_tenant_1,, test, $svr_port_3);
connect(conn_nt_4, $svr_ip_4, root@xy_tenant_1,, test, $svr_port_4);
--sleep 3

--echo
#init
--echo //init
connection conn_nt_1;
select 1;
select plan_num > 0 as result from oceanbase.V$OB_PLAN_CACHE_STAT;

connection conn_nt_2;
select 1;
select plan_num > 0 as result from oceanbase.V$OB_PLAN_CACHE_STAT;

connection conn_nt_3;
select 1;
select plan_num > 0 as result from oceanbase.V$OB_PLAN_CACHE_STAT;

connection conn_nt_4;
select 1;
select plan_num > 0 as result from oceanbase.V$OB_PLAN_CACHE_STAT;


--echo
# flush xy_tenant_1, local
--echo // flush xy_tenant_1, local
connection conn_sys_1;
alter system flush plan cache tenant = 'xy_tenant_1';

connection conn_nt_1;
select /*+use_plan_cache(none)*/ plan_num = 0 as result from oceanbase.V$OB_PLAN_CACHE_STAT;
connection conn_nt_2;
select /*+use_plan_cache(none)*/ plan_num > 0 as result from oceanbase.V$OB_PLAN_CACHE_STAT;
connection conn_nt_3;
select /*+use_plan_cache(none)*/ plan_num > 0 as result from oceanbase.V$OB_PLAN_CACHE_STAT;
connection conn_nt_4;
select /*+use_plan_cache(none)*/ plan_num > 0 as result from oceanbase.V$OB_PLAN_CACHE_STAT;

--echo
