--echo
#test flush tenant list, local
--echo // tenant list, local
connection conn_sys_2;
alter system flush plan cache tenant = 'xy_tenant_1', 'sys';

connection conn_nt_1;
select  /*+use_plan_cache(none)*/ plan_num > 0 as result from oceanbase.V$OB_PLAN_CACHE_STAT;

connection conn_nt_2;
select  /*+use_plan_cache(none)*/ plan_num = 0 as result from oceanbase.V$OB_PLAN_CACHE_STAT;

