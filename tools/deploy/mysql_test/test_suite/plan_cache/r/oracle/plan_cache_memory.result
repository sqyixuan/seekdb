alter system flush plan cache;
grant CREATE, SELECT, INSERT, DROP on *.* to xy;

//sys tenant
show variables like 'ob_plan_cache%';
Variable_name	Value
ob_plan_cache_evict_high_percentage	90
ob_plan_cache_evict_low_percentage	50
ob_plan_cache_percentage	5

//normal tenant
//expect 90 50 5
show variables like 'ob_plan_cache%';
Variable_name	Value
ob_plan_cache_evict_high_percentage	90
ob_plan_cache_evict_low_percentage	50
ob_plan_cache_percentage	5


//测试plan cache是否使用的对应租户的内存expect 1 1 1
select USED > 0 as result from oceanbase.V$OB_MEMORY where context = 'OB_SQL_PLAN_CACHE' or context = 'OB_SQL_PHY_PLAN';
result
1
1

select mem_limit from oceanbase.V$OB_PLAN_CACHE_STAT;
mem_limit
75000000

//change plan cache system variables
set global ob_plan_cache_evict_high_percentage = 10;
set global ob_plan_cache_evict_low_percentage = 5;
set global ob_plan_cache_percentage = 1;

//expect 10 5 1
show variables like 'ob_plan_cache%';
Variable_name	Value
ob_plan_cache_evict_high_percentage	10
ob_plan_cache_evict_low_percentage	5
ob_plan_cache_percentage	1

//expect 1 1 1; prove evict happened
select @mem_limit_evict < @mem_limit;
@mem_limit_evict < @mem_limit
1
select @mem_used_evict < @mem_used;
@mem_used_evict < @mem_used
1
select @plan_num_evict < @plan_num;
@plan_num_evict < @plan_num
1

//normal tenant user
//expect 10 5 1
show variables like 'ob_plan_cache%';
Variable_name	Value
ob_plan_cache_evict_high_percentage	10
ob_plan_cache_evict_low_percentage	5
ob_plan_cache_percentage	1
select mem_limit from oceanbase.V$OB_PLAN_CACHE_STAT;
mem_limit
15000000

//expect error
set global ob_plan_cache_evict_high_percentage = 50;
ERROR 42501: Access denied; you need (at least one of) the SUPER privilege(s) for this operation
set global ob_plan_cache_evict_low_percentage = 20;
ERROR 42501: Access denied; you need (at least one of) the SUPER privilege(s) for this operation
set global ob_plan_cache_percentage = 1;
ERROR 42501: Access denied; you need (at least one of) the SUPER privilege(s) for this operation
drop database xy_db;

//sys tenant
//expect 90 50 5
show variables like 'ob_plan_cache%';
Variable_name	Value
ob_plan_cache_evict_high_percentage	90
ob_plan_cache_evict_low_percentage	50
ob_plan_cache_percentage	5
//测试major freeze后失效plan是否全被淘汰
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
//expected 0
select /*+use_plan_cache(none)*/ plan_num from oceanbase.V$OB_PLAN_CACHE_STAT;
plan_num
0
//测试flush plan cache后plan全被淘汰，内存全部释放
alter system flush plan cache global;
//expected 0, 0, 1(plan cache自身结构内存)
select plan_num, sql_num, mem_hold < 1000000 from oceanbase.V$OB_PLAN_CACHE_STAT where tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = 'xy_tenant_1');
plan_num	sql_num	mem_hold < 1000000
0	0	1

drop tenant xy_tenant_1 force;
drop resource pool xy_pool_1;
drop resource unit xy_box_1;
