============================ delete with subquery  ============================


delete from case2_t_2 where pk2 in (select pk3 from case2_t_3);
delete from case2_t_2 where pk2 in (select pk3 from case2_t_3);

explain delete from case2_t_2 where pk2 in (select pk3 from case2_t_3);
Query Plan
=================================================
|ID|OPERATOR           |NAME     |EST. ROWS|COST|
-------------------------------------------------
|0 |EXCHANGE IN DISTR  |         |1        |73  |
|1 | EXCHANGE OUT DISTR|         |1        |73  |
|2 |  DELETE           |         |1        |73  |
|3 |   MERGE JOIN      |         |1        |73  |
|4 |    TABLE SCAN     |case2_t_2|2        |36  |
|5 |    TABLE SCAN     |case2_t_3|2        |36  |
=================================================

Outputs & filters: 
-------------------------------------
  0 - output(nil), filter(nil)
  1 - output(nil), filter(nil)
  2 - output(nil), filter(nil), params([{case2_t_2: (case2_t_2.pk2, case2_t_2.a2)}])
  3 - output([case2_t_2.pk2], [case2_t_2.a2]), filter(nil), 
      equal_conds([case2_t_2.pk2 = case2_t_3.pk3]), other_conds(nil)
  4 - output([case2_t_2.pk2], [case2_t_2.a2]), filter(nil), 
      access([case2_t_2.pk2], [case2_t_2.a2]), partitions(p[0-1])
  5 - output([case2_t_3.pk3]), filter(nil), 
      access([case2_t_3.pk3]), partitions(p[0-1])


// expect 1
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'delete from case2_t_2 where pk2 in (select pk3 from case2_t_3)';
hit_count
1

// switch replica leader for case2_t_2, part0 in backup, part1 in main

delete from case2_t_2 where pk2 in (select pk3 from case2_t_3);
delete from case2_t_2 where pk2 in (select pk3 from case2_t_3);

explain delete from case2_t_2 where pk2 in (select pk3 from case2_t_3);
