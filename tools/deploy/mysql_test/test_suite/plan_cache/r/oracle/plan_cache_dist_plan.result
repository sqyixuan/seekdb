  1 - output([case2_t_2.pk2], [case2_t_2.a2]), filter(nil)
  2 - output([case2_t_2.pk2], [case2_t_2.a2]), filter(nil)
  3 - output([case2_t_2.pk2], [case2_t_2.a2]), filter(nil), 
      equal_conds([case2_t_2.pk2 = case2_t_3.pk3]), other_conds(nil)
  4 - output([case2_t_2.pk2], [case2_t_2.a2]), filter(nil), sort_keys([case2_t_2.pk2, ASC])
  5 - (#keys=1, [case2_t_2.pk2]), output([case2_t_2.pk2], [case2_t_2.a2]), filter(nil)
  6 - output([case2_t_2.pk2], [case2_t_2.a2]), filter(nil), 
      access([case2_t_2.pk2], [case2_t_2.a2]), partitions(p[0-1])
  7 - output([case2_t_3.pk3]), filter(nil), 
      access([case2_t_3.pk3]), partitions(p[0-1])


