drop table t0;
create table t0(c0 int);
insert into t0 values(2035561);
insert into t0 values(2035233);
CREATE OR REPLACE PROCEDURE p1(PRM_NEWID  IN VARCHAR2,PRM_OLDID  IN VARCHAR2) IS
BEGIN
UPDATE t0
SET c0 = DECODE(c0,
TO_NUMBER(PRM_NEWID),
TO_NUMBER(PRM_OLDID),
TO_NUMBER(PRM_OLDID),
TO_NUMBER(PRM_NEWID),
c0)
WHERE c0 IN (TO_NUMBER(PRM_OLDID), TO_NUMBER(PRM_NEWID));
END p1;//
call p1('2035561','2035233');
call p1('2035561','2035233');
# expect hit_count = 1
select hit_count, statement from sys.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'update "TEST"."T0" set "TEST"."T0"."C0" = decode("TEST"."T0"."C0",TO_NUMBER(:0),TO_NUMBER(:1),TO_NUMBER(:1),TO_NUMBER(:0),"TEST"."T0"."C0") where ("TEST"."T0"."C0" in (TO_NUMBER(:1),TO_NUMBER(:0)))';
HIT_COUNT	STATEMENT
1	update "TEST"."T0" set "TEST"."T0"."C0" = decode("TEST"."T0"."C0",TO_NUMBER(:0),TO_NUMBER(:1),TO_NUMBER(:1),TO_NUMBER(:0),"TEST"."T0"."C0") where ("TEST"."T0"."C0" in (TO_NUMBER(:1),TO_NUMBER(:0)))
1	update "TEST"."T0" set "TEST"."T0"."C0" = decode("TEST"."T0"."C0",TO_NUMBER(:0),TO_NUMBER(:1),TO_NUMBER(:1),TO_NUMBER(:0),"TEST"."T0"."C0") where ("TEST"."T0"."C0" in (TO_NUMBER(:1),TO_NUMBER(:0)))
drop table t0;
drop procedure p1;
