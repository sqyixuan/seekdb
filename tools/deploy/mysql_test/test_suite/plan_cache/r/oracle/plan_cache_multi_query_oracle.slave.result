alter system flush plan cache global;

// test multi query hit plan
drop table t1;
create table t1(c1 int);
begin;
select * from t1 where c1 = 1;select * from t1 where c1 = 1;select * from t1 where c1 = 1;//
// expected hit_count 2
select  hit_count from SYS.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select * from t1 where c1 = ?;';
HIT_COUNT
2
2
commit;
drop table t1;
