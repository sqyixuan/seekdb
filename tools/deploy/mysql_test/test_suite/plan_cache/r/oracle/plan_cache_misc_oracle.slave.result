// 修复Oracle模式下fast parser和normal parser字符串解析不一致的测试用例

// Case #1 Test insert char value

insert into test_misc values (1, 'hello');
insert into test_misc values (2, 'hi');

// epxect hit_count to be 1
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'insert into test_misc values (?, ?)';
hit_count
1

// Case #2 Test select stmt with char

select * from test_misc where a = 1 and b = 'hi';
select * from test_misc where a = 2 and b = 'hi';

// expect hit_count to be 1
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select * from test_misc where a = ? and b = ?';
hit_count
1
1

// Case #3 Test select constant
select 'hello' from dual;
select 'hello' from dual;

// expect hit_count to be 1
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select ? from dual';
hit_count
1

// >>>>>>>>>>>>>>>>>>>>>>>CASE#4: CAST func const number
create table test_cast(a int);
insert into test_cast values (1);

select * from test_cast where cast(a + 1 as int) = 2;

select * from test_cast where cast(a + 1 as int) = 2;

// expect 1 records, hit_count = 1
select hit_count from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select * from test_cast where cast(a + ? as int) = ?';
HIT_COUNT
1
1

drop table test_cast;
