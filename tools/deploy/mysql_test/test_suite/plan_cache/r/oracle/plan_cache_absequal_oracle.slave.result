drop table Z0CASE;
CREATE TABLE Z0CASE(z0_test0 char(100),z0_test1 nchar(50),z0_test2 NUMBER);
INSERT INTO Z0CASE (z0_test0,z0_test1,z0_test2)values('abc ABC','abc%%^#AB C',1);
