**********test precise constraint**********
test like pattern precise constraint, only add constraint when the pattern is used to extract query range
like pattern used to extract query range, non-precise plan first
select * from t4 where c1 like '%a';
select * from t4 where c1 like 'a%';
select * from t4 where c1 like 'b%';
select * from t4 where c1 like '%b';
select * from t4 where c1 like 'c%';
## expect generate 2 plan
select sql_id, hit_count, type, query_sql from GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t4 where c1 like ?';
+----------------------------------+-----------+------+-------------------------------------+
| SQL_ID                           | HIT_COUNT | TYPE | QUERY_SQL                           |
+----------------------------------+-----------+------+-------------------------------------+
| C0D9C5DA8E84829D729E8C019229C63E |         1 |    1 | select * from t4 where c1 like ?    |
| C0D9C5DA8E84829D729E8C019229C63E |         1 |    2 | select * from t4 where c1 like '%a' |
| C0D9C5DA8E84829D729E8C019229C63E |         2 |    1 | select * from t4 where c1 like ?    |
| C0D9C5DA8E84829D729E8C019229C63E |         2 |    2 | select * from t4 where c1 like 'a%' |
+----------------------------------+-----------+------+-------------------------------------+

like pattern used to extract query range of final access path, precise plan first
(%a,a%) will hit the (%a,%a) plan
select * from t4 where c1 like 'a%' and c3 like 'b%';
select * from t4 where c1 like '%a' and c3 like '%b';
select * from t4 where c1 like 'a%' and c3 like '%b';
select * from t4 where c1 like '%a' and c3 like 'b%';
select * from t4 where c1 like '%b' and c3 like '%c';
select * from t4 where c1 like '%b' and c3 like 'c%';
## expect generate 2 plan
select sql_id, hit_count, type, query_sql from GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t4 where c1 like ? and c3 like ?';
+----------------------------------+-----------+------+------------------------------------------------------+
| SQL_ID                           | HIT_COUNT | TYPE | QUERY_SQL                                            |
+----------------------------------+-----------+------+------------------------------------------------------+
| 621A0D7525B513BAF7D28ABF6144E51D |         1 |    1 | select * from t4 where c1 like ? and c3 like ?       |
| 621A0D7525B513BAF7D28ABF6144E51D |         1 |    2 | select * from t4 where c1 like 'a%' and c3 like 'b%' |
| 621A0D7525B513BAF7D28ABF6144E51D |         3 |    1 | select * from t4 where c1 like ? and c3 like ?       |
| 621A0D7525B513BAF7D28ABF6144E51D |         3 |    2 | select * from t4 where c1 like '%a' and c3 like '%b' |
+----------------------------------+-----------+------+------------------------------------------------------+

like pattern used to extract query range, add constraint
select * from t4 where c1 like concat('a','%');
select * from t4 where c1 like concat('%','a');
select * from t4 where c1 like concat('b','%');
select * from t4 where c1 like concat('%','b');
select * from t4 where c1 like concat('c','%');
## expect generate 2 plan
select sql_id, hit_count, type, query_sql from GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t4 where c1 like concat(?,?)';
+----------------------------------+-----------+------+------------------------------------------------+
| SQL_ID                           | HIT_COUNT | TYPE | QUERY_SQL                                      |
+----------------------------------+-----------+------+------------------------------------------------+
| 350E1E079E329EA1FCFBF1F488718C65 |         1 |    1 | select * from t4 where c1 like concat(?,?)     |
| 350E1E079E329EA1FCFBF1F488718C65 |         1 |    2 | select * from t4 where c1 like concat('%','a') |
| 350E1E079E329EA1FCFBF1F488718C65 |         2 |    1 | select * from t4 where c1 like concat(?,?)     |
| 350E1E079E329EA1FCFBF1F488718C65 |         2 |    2 | select * from t4 where c1 like concat('a','%') |
+----------------------------------+-----------+------+------------------------------------------------+

like pattern in normal predicate, do not add constraint
select * from t4 where c2 like concat('a','%');
select * from t4 where c2 like concat('%','a');
select * from t4 where c2 like concat('b','%');
select * from t4 where c2 like concat('%','b');
select * from t4 where c2 like concat('c','%');
## expect generate 1 plan
select sql_id, hit_count, type, query_sql from GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t4 where c2 like concat(?,?)';
