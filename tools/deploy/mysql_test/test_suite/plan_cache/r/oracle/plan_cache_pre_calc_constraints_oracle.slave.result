| SQL_ID                           | HIT_COUNT | TYPE | QUERY_SQL                         |
+----------------------------------+-----------+------+-----------------------------------+
| F47323FA01D6B6525BAD2CC74AB4FFEF |         5 |    1 | select 100/1 from t1 where c1 < 5 |
| F47323FA01D6B6525BAD2CC74AB4FFEF |         5 |    2 | select 100/1 from t1 where c1 < 5 |
+----------------------------------+-----------+------+-----------------------------------+

multi err constraint
select 100/1, 50/1 from t1;
select 100/0, 50/1 from t1;
select 100/1, 50/0 from t1;
select 100/0, 50/0 from t1;
select 100/1, 50/1 from t1;
select 100/1, 50/1 from t1;
select 100/0, 50/1 from t1;
select 100/0, 50/1 from t1;
select 100/1, 50/0 from t1;
select 100/1, 50/0 from t1;
select 100/0, 50/0 from t1;
select 100/0, 50/0 from t1;
