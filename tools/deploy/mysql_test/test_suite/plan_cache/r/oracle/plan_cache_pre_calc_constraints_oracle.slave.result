drop table t1;
drop table t2;
drop table t3;
drop table t4;
drop table t5;
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int primary key, c2 int, c3 int);
create table t3(c1 int, c2 int, c3 int) partition by hash(c3) partitions 4;
create table t4(c1 varchar(10) primary key, c2 varchar(10), c3 varchar(10));
create index i4_1 on t4(c3);
create table t5(c1 varchar(10), c2 varchar(10)) partition by range(c2) (partition p0 values less than('b'), partition p1 values less than(MAXVALUE));
insert into t1 values (1,1,1),(2,2,2);
insert into t4 values('a','a','a');
insert into t4 values('b','b','b');
insert into t5 values('a','a');
insert into t5 values('c','c');
explain_protocol: 0
result_format: 4
alter system flush plan cache global;

**********test true/false constraint**********
hit plan with true constraint
select * from t1 where 1 = 1 and 2 = 2;
select * from t1 where 0 = 0 and 2 = 2;
hit plan with false constraint
select * from t1 where 1 = 1 and 2 = 0;
select * from t1 where 0 = 0 and 2 = 0;
select * from t1 where 2 = 1 and 0 = 0;
select * from t1 where 3 = 0 and 2 = 2;
select * from t1 where 2 = 1 and 2 = 0;
select * from t1 where 2 = 0 and 2 = 0;
expect generate 2 plan
select sql_id, hit_count, type, query_sql from GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1 where ? = ? and ? = ?';
+----------------------------------+-----------+------+----------------------------------------+
| SQL_ID                           | HIT_COUNT | TYPE | QUERY_SQL                              |
+----------------------------------+-----------+------+----------------------------------------+
| D685DF52D9A01CF8193B45BED9D46B2F |         1 |    1 | select * from t1 where ? = ? and ? = ? |
| D685DF52D9A01CF8193B45BED9D46B2F |         1 |    2 | select * from t1 where 1 = 1 and 2 = 2 |
| D685DF52D9A01CF8193B45BED9D46B2F |         5 |    1 | select * from t1 where 1 = 1 and 2 = 0 |
+----------------------------------+-----------+------+----------------------------------------+


**********test pre calculate error constraint**********
query execute error expect timeout will not count in plancache hint count
generate pre calculate error paln first
select 100/0 from t1;
select 100/1 from t1;
select 200/0 from t1;
select 200/0 from t1;
select 200/1 from t1;
select 200/1 from t1;
## expect generate 1 plan
select sql_id, hit_count, type, query_sql from GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select ?/? from t1';
+----------------------------------+-----------+------+----------------------+
| SQL_ID                           | HIT_COUNT | TYPE | QUERY_SQL            |
+----------------------------------+-----------+------+----------------------+
| 74AE9A343D03DA7853F1320A76761E74 |         5 |    1 | select 100/0 from t1 |
| 74AE9A343D03DA7853F1320A76761E74 |         5 |    2 | select 100/0 from t1 |
+----------------------------------+-----------+------+----------------------+

generate pre calculate success paln first
select 100/1 from t1 where c1 < 5;
select 100/0 from t1 where c1 < 5;
select 200/0 from t1 where c1 < 5;
select 200/0 from t1 where c1 < 5;
select 200/1 from t1 where c1 < 5;
select 200/1 from t1 where c1 < 5;
## expect generate 1 plan
select sql_id, hit_count, type, query_sql from GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select ?/? from t1 where c1 < ?';
