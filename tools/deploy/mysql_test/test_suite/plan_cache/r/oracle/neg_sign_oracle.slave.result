result_format: 4

alter system flush plan cache global;
set ob_trx_timeout = 1000000000;
drop table t1;
drop table t2;

create table t1 (a int, b int);
begin;

// CASE#1: Insert
insert into t1 values (1, 1), (1, -1);
insert into t1 values (-1, 1), (1, 1);

select hit_count, sql_id from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'insert into t1 values (?, ?)';
