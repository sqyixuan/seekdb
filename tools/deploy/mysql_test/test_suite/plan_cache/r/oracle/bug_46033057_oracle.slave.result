drop table TEST190;
drop table TEST191;
create table TEST190(COL_NUMBER_29_0 int, COL_VARCHAR2_200 varchar2 (200), PK int, COL_TS timestamp, COL_DATE date, COL_DECIMAL_21_2 number(21,2));
create table TEST191(NAME varchar(20), JOB varchar(20), NUM int);

select (case when (("B"."NAME" like n'SMIT%' escape B.NAME))     then A.PK  else     ("A"."PK") end) "ABC" from TEST191 B right join TEST190 A on ("A"."PK" = "B"."NUM");
ABC
select (case when (("B"."NAME" like n'SMIT%' escape B.NAME))     then A.PK  else     ("A"."PK") end) "ABC" from TEST191 B right join TEST190 A on ("A"."PK" = "B"."NUM");
ABC

