result_format: 4
// >>>>>>>>>>>>>>>>>>>> TEST Paramed Const In Select <<<<<<<<<<<<<<<<<<<<

// >>>>>>>>>> Test#1 Basic Cases
begin;

select 1, 2, 3, 'hello' from dual;
+---+---+---+---------+
| 1 | 2 | 3 | 'HELLO' |
+---+---+---+---------+
| 1 | 2 | 3 | hello   |
+---+---+---+---------+
select 3, 4, 5, 'hi' from dual;
+---+---+---+------+
| 3 | 4 | 5 | 'HI' |
+---+---+---+------+
| 3 | 4 | 5 | hi   |
+---+---+---+------+

// expect hit_count = 1

select substr('hello', 2), cast(2 as char(20)), concat('h', '2'), abs(-1), floor(1.23) from dual;
+-------------------+----------------------+-----------------+---------+-------------+
| SUBSTR('HELLO',2) | CAST(2ASCHAR(20))    | CONCAT('H','2') | ABS(-1) | FLOOR(1.23) |
+-------------------+----------------------+-----------------+---------+-------------+
| ello              | 2                    | h2              |       1 |           1 |
+-------------------+----------------------+-----------------+---------+-------------+
select substr('hey', 2), cast(3 as char(20)), concat('h', 'h2'), abs(-2), floor(2.23) from dual;
+-----------------+----------------------+------------------+---------+-------------+
| SUBSTR('HEY',2) | CAST(3ASCHAR(20))    | CONCAT('H','H2') | ABS(-2) | FLOOR(2.23) |
+-----------------+----------------------+------------------+---------+-------------+
| ey              | 3                    | hh2              |       2 |           2 |
+-----------------+----------------------+------------------+---------+-------------+

// expect hit_count = 1
select hit_count from sys.V$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select substr(?, 2), cast(? as char(20)), concat(?, ?), abs(?), floor(?) from dual';
+-----------+
| HIT_COUNT |
+-----------+
|         1 |
+-----------+
commit;
drop table test_t;

create table test_t (a int, b int);

begin;

insert into test_t values (1, 1);
insert into test_t values (2, 2);
insert into test_t values (3, 3);

select a, a as test_a, b + 1 as test_b, a + 1, b + 1 from test_t;
+------+--------+--------+------+------+
| A    | TEST_A | TEST_B | A+1  | B+1  |
+------+--------+--------+------+------+
|    1 |      1 |      2 |    2 |    2 |
|    2 |      2 |      3 |    3 |    3 |
|    3 |      3 |      4 |    4 |    4 |
+------+--------+--------+------+------+
select a, a as test_a, b + 3 as test_b, a + 2, b + 3 from test_t;
+------+--------+--------+------+------+
| A    | TEST_A | TEST_B | A+2  | B+3  |
+------+--------+--------+------+------+
|    1 |      1 |      4 |    3 |    4 |
|    2 |      2 |      5 |    4 |    5 |
|    3 |      3 |      6 |    5 |    6 |
+------+--------+--------+------+------+

// expect hit_count = 1
select hit_count from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select a, a as test_a, b + ? as test_b, a + ?, b + ? from test_t';
+-----------+
| HIT_COUNT |
+-----------+
|         1 |
|         1 |
+-----------+

// >>>>>>>>>> Test#2 Subquery
select * from (select 1, 2, 3 from dual);
+---+---+---+
| 1 | 2 | 3 |
+---+---+---+
| 1 | 2 | 3 |
+---+---+---+
select * from (select 2, 3, 4 from dual);
+---+---+---+
| 2 | 3 | 4 |
+---+---+---+
| 2 | 3 | 4 |
+---+---+---+

// expect hit_count = 1
select hit_count from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select * from (select ?, ?, ? from dual)';
+-----------+
| HIT_COUNT |
+-----------+
|         1 |
+-----------+

select * from (select 1, 2, 2 from dual);
+---+---+---+
| 1 | 2 | 2 |
+---+---+---+
| 1 | 2 | 2 |
+---+---+---+

select * from (select 1 as c1, a, b + 1 from test_t);
+----+------+------+
| C1 | A    | B+1  |
+----+------+------+
|  1 |    1 |    2 |
|  1 |    2 |    3 |
|  1 |    3 |    4 |
+----+------+------+
select * from (select 2 as c1, a, b + 2 from test_t);
+----+------+------+
| C1 | A    | B+2  |
+----+------+------+
|  2 |    1 |    3 |
|  2 |    2 |    4 |
|  2 |    3 |    5 |
+----+------+------+

// expect hit_count = 1
select hit_count from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select * from (select ? as c1, a, b + ? from test_t)';
+-----------+
| HIT_COUNT |
+-----------+
|         1 |
|         1 |
+-----------+

// >>>>>>>>>> Test#3 Column is Const String
select 'hello' from dual;
+---------+
| 'HELLO' |
+---------+
| hello   |
+---------+
select 'hello hey' from dual;
+------------+
| 'HELLOHEY' |
+------------+
| hello hey  |
+------------+
select '''hello' from dual;
+----------+
| ''HELLO' |
+----------+
| 'hello   |
+----------+

// >>>>>>>>>> Test#4 Negetive Const
select -1, -2, -1-2, 1-3 from dual;
+----+----+------+-----+
| -1 | -2 | -1-2 | 1-3 |
+----+----+------+-----+
| -1 | -2 |   -3 |  -2 |
+----+----+------+-----+
select -2, -3, -2-1, 1-3 from dual;
+----+----+------+-----+
| -2 | -3 | -2-1 | 1-3 |
+----+----+------+-----+
| -2 | -3 |   -3 |  -2 |
+----+----+------+-----+

// expect hit_count = 1
select hit_count from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select ?, ?, ?-?, ?-? from dual';
+-----------+
| HIT_COUNT |
+-----------+
|         1 |
+-----------+

// >>>>>>>>>> Test#4 Const Value with Prefix
select Date'2012-12-12' from dual;
+---------------------+
| DATE'2012-12-12'    |
+---------------------+
| 2012-12-12 00:00:00 |
+---------------------+
select Date'2013-12-12' from dual;
+---------------------+
| DATE'2013-12-12'    |
+---------------------+
| 2013-12-12 00:00:00 |
+---------------------+
select Timestamp'2012-12-12 12:13:13' from dual;
+-------------------------------+
| TIMESTAMP'2012-12-1212:13:13' |
+-------------------------------+
| 2012-12-12 12:13:13.000000000 |
+-------------------------------+

// >>>>>>>>>> Test#6 Union
select 1 from dual union select 2 from dual;
+------+
| 1    |
+------+
|    1 |
|    2 |
+------+
select 2 from dual union select 3 from dual;
+------+
| 2    |
+------+
|    2 |
|    3 |
+------+

// expect hit_count = 1
select hit_count from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select ? from dual union select ? from dual';
+-----------+
| HIT_COUNT |
+-----------+
|         1 |
+-----------+

select * from (select 1, 2 + 3, 4 as c0, a, b + 1 from test_t union select 1, 2, 3, 4, 6 from dual);
+------+------+------+------+------+
| 1    | 2+3  | C0   | A    | B+1  |
+------+------+------+------+------+
|    1 |    2 |    3 |    4 |    6 |
|    1 |    5 |    4 |    1 |    2 |
|    1 |    5 |    4 |    2 |    3 |
|    1 |    5 |    4 |    3 |    4 |
+------+------+------+------+------+
select * from (select 2, 3 + 4, 5 as c0, a, b + 2 from test_t union select 2, 3, 4, 5, 6 from dual);
+------+------+------+------+------+
| 2    | 3+4  | C0   | A    | B+2  |
+------+------+------+------+------+
|    2 |    3 |    4 |    5 |    6 |
|    2 |    7 |    5 |    1 |    3 |
|    2 |    7 |    5 |    2 |    4 |
|    2 |    7 |    5 |    3 |    5 |
+------+------+------+------+------+

// expect hit_count = 1
select hit_count from sys.V$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select * from (select ?, ? + ?, ? as c0, a, b + ? from test_t union select ?, ?, ?, ?, ? from dual)';
+-----------+
| HIT_COUNT |
+-----------+
|         1 |
+-----------+
commit;

// >>>>>>>>>> Test#7 Oracle Extra Space, Upper Case, Identifier
begin;

select 'hel  lo' from dual;
+---------+
| 'HELLO' |
+---------+
| hel  lo |
+---------+
select '''' from dual;
+-----+
| ''' |
+-----+
| '   |
+-----+
select substr('hello''    hey', 6) from dual;
+------------------------+
| SUBSTR('HELLO''HEY',6) |
+------------------------+
| '    hey               |
+------------------------+
select 1 as "hello" from dual;
+-------+
| hello |
+-------+
|     1 |
+-------+
select 1 "hello" from dual;
+-------+
| hello |
+-------+
|     1 |
+-------+

// >>>>>>>>>> Test#8 CTE
with cte_tbl as (select 1, 2, a, b + 1 from test_t) select * from cte_tbl;
+---+---+------+------+
| 1 | 2 | A    | B+1  |
+---+---+------+------+
| 1 | 2 |    1 |    2 |
| 1 | 2 |    2 |    3 |
| 1 | 2 |    3 |    4 |
+---+---+------+------+
with cte_tbl as (select 2, 3, a, b + 1 from test_t) select * from cte_tbl;
+---+---+------+------+
| 2 | 3 | A    | B+1  |
+---+---+------+------+
| 2 | 3 |    1 |    2 |
| 2 | 3 |    2 |    3 |
| 2 | 3 |    3 |    4 |
+---+---+------+------+

// expect hit_count = 1
select hit_count from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'with cte_tbl as (select ?, ?, a, b + ? from test_t) select * from cte_tbl';
+-----------+
| HIT_COUNT |
+-----------+
|         1 |
|         1 |
+-----------+

// >>>>>>>>>> Test#9 Group by
select a + 1 + b + 2 from test_t group by a + 1 + b + 2;
+---------+
| A+1+B+2 |
+---------+
|       5 |
|       7 |
|       9 |
+---------+
select a + 1 + b + 2 from test_t group by a + 1 + b + 2;
+---------+
| A+1+B+2 |
+---------+
|       5 |
|       7 |
|       9 |
+---------+
select a + 2 + b + 1 from test_t group by a + 2 + b + 1;
+---------+
| A+2+B+1 |
+---------+
|       5 |
|       7 |
|       9 |
+---------+
select a + 2 + b + 1 from test_t group by a + 2 + b + 1;
+---------+
| A+2+B+1 |
+---------+
|       5 |
|       7 |
|       9 |
+---------+

// expect hit_count = (3)
select hit_count from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select a + ? + b + ? from test_t group by a + ? + b + ?';
+-----------+
| HIT_COUNT |
+-----------+
|         3 |
|         3 |
+-----------+

select a + 1 + b + 1 from test_t group by a + 1 + b + 2;
ERROR 42000: 'TEST.TEST_T.A' not a GROUP BY expression
commit;

drop table test_t;
drop view test_view;

begin;

// >>>>>>>>>> Test#10 NString
select     n'蚂蚁金服' from dual;
+-----------------+
| N'蚂蚁金服'     |
+-----------------+
| 蚂蚁金服        |
+-----------------+
select     n'蚂蚁金服' from dual;
+-----------------+
| N'蚂蚁金服'     |
+-----------------+
| 蚂蚁金服        |
+-----------------+

// expect hit_count = (1, 1)
select hit_count from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select     ? from dual';
+-----------+
| HIT_COUNT |
+-----------+
|         1 |
+-----------+

select CONCAT('こ',N'中') from dual;
+----------------------+
| CONCAT('こ',N'中')   |
+----------------------+
| こ中                 |
+----------------------+
select CONCAT('こ',N'中') from dual;
+----------------------+
| CONCAT('こ',N'中')   |
+----------------------+
| こ中                 |
+----------------------+
// expect hit_count = (1, 1)
select hit_count from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select CONCAT(?,?) from dual';
+-----------+
| HIT_COUNT |
+-----------+
|         1 |
+-----------+

commit;

alter system set large_query_threshold = '100ms';
