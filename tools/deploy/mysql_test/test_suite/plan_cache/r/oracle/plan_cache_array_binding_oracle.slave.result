alter system flush plan cache global;
drop table t;
create table t(c1 int primary key, c2 int) partition by hash(c1) partitions 3;
insert into t values(1, 1);
insert into t values(2, 2);
insert into t values(3, 3);
insert into t values(4, 4);
insert into t values(5, 5);
insert into t values(6, 6);

//****************** test array binding need rollback **************
declare
TYPE int_arr is TABLE OF int;
arr int_arr := int_arr();
begin
arr.extend(5);
FOR idx IN 1..5 LOOP
arr(idx) := idx;
END LOOP;
FORALL idx IN 1..5
delete from t where c1=arr(idx);
end;
//

// ****************** test use array binding **************
declare
TYPE int_arr is TABLE OF int;
arr int_arr := int_arr();
begin
arr.extend(5);
FOR idx IN 1..5 LOOP
arr(idx) := 1;
END LOOP;
FORALL idx IN 1..5
delete from t where c1=arr(idx);
end;
//
declare
TYPE int_arr is TABLE OF int;
arr int_arr := int_arr();
begin
arr.extend(5);
FOR idx IN 1..5 LOOP
arr(idx) := 1;
END LOOP;
FORALL idx IN 1..5
delete from t where c1=arr(idx);
end;
//

//****************** test array binding need rollback **************
declare
TYPE int_arr is TABLE OF int;
arr int_arr := int_arr();
begin
arr.extend(5);
FOR idx IN 1..5 LOOP
arr(idx) := idx;
END LOOP;
FORALL idx IN 1..5
delete from t where c1=arr(idx);
end;
//
//expected hit_count=1 and hit_count = 9 , slave : hit_count = 19
select hit_count, QUERY_SQL from SYS.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = '182E647E77B7057AD0C424295A87C118';
HIT_COUNT	QUERY_SQL
19	delete  from "TEST"."T" where ("TEST"."T"."C1" = :0)
19	delete  from "TEST"."T" where ("TEST"."T"."C1" = :0)
drop table t;
drop table t1;
drop table t2;
drop view v1;
drop view v2;
create table t1 (c1 int primary key, c2 int, c3 int);
create table t2 (c1 int primary key, c2 int, c3 int);
insert into t1 (c1, c2, c3) values (1, 1, 1);
insert into t2 (c1, c2, c3) values (1, 1, 1);
create view v1 as select * from t1;
create view v2 as select /*+no_pred_deduce, no_merge, leading(t1) use_merge(t2)*/ t1.c1 c1, t1.c2 c2, t1.c3 c3, t2.c1 c4, t2.c2 c5, t2.c3 c6 from t1, t2 where t1.c1 = t2.c1;

//****************** test use array binding**************
declare
TYPE int_arr is TABLE OF int;
arr int_arr := int_arr();
begin
arr.extend(5);
FOR idx IN 1..5 LOOP
arr(idx) := 5;
END LOOP;
FORALL idx IN 1..5
update /*+no_rewrite*/ v2 set c2 = 3 where c1 = arr(idx) returning c2 + c6;
end;
//
declare
TYPE int_arr is TABLE OF int;
arr int_arr := int_arr();
begin
arr.extend(5);
FOR idx IN 1..5 LOOP
arr(idx) := 5;
END LOOP;
FORALL idx IN 1..5
update /*+no_rewrite*/ v2 set c2 = 3 where c1 = arr(idx) returning c2 + c6;
end;
//
//expected hit_count=1 slave : hit_count = 9
select hit_count, QUERY_SQL from SYS.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = '39564423B681A7B25AB11EA366D3F7B2';
HIT_COUNT	QUERY_SQL
// TEST Plan Cache Memory
alter system flush plan cache tenant=oracle global;
// expect count(*) = 0
select /*+use_plan_cache(none)*/count(*) = 0 from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where object_type = 'SQL_PLAN';
count(*) = 0
0
