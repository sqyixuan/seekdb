// >>>>>>>>>>>>>>>TEST Select from gv table
// bug link: 




alter system flush sql audit global;
alter system flush plan cache global;
// query from local, expect true
select case when count(*) = 0 then 1 else 0 end from sys.GV$OB_SQL_AUDIT where svr_port = svr_port1;
+---------------------------------+
| CASEWHENCOUNT(*)=0THEN1ELSE0END |
+---------------------------------+
|                               0 |
+---------------------------------+

// execute a query in remote
select 1 from dual;
+---+
| 1 |
+---+
| 1 |
+---+

// query from local expect true
select case when count(*) > 0 then 1 else 0 end from sys.GV$OB_SQL_AUDIT where svr_port = svr_port2;
+---------------------------------+
| CASEWHENCOUNT(*)>0THEN1ELSE0END |
+---------------------------------+
|                               1 |
+---------------------------------+
commit;

