result_format: 4


set ob_trx_timeout = 1000000000;

// >>>>>>>>>>>>>>CASE#1: TEST SEQUENCE
// test query using sequence
create sequence test_seq;

select test_seq.nextval from dual;
+---------+
| NEXTVAL |
+---------+
|       1 |
+---------+
select test_seq.nextval from dual;
+---------+
| NEXTVAL |
+---------+
|       2 |
+---------+
select test_seq.nextval from dual;
+---------+
| NEXTVAL |
+---------+
|       3 |
+---------+

select test_seq.currval from dual;
+---------+
| CURRVAL |
+---------+
|       3 |
+---------+


// expect hit_count = 2
select hit_count from sys.V$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select test_seq.nextval from dual';
+-----------+
| HIT_COUNT |
+-----------+
|         2 |
+-----------+

// expect hit_count = 0
select hit_count from sys.V$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select test_seq.currval from dual';
+-----------+
| HIT_COUNT |
+-----------+
|         0 |
+-----------+


drop sequence test_seq;

create sequence test_seq;


select test_seq.nextval from dual;
+---------+
| NEXTVAL |
+---------+
|       1 |
+---------+
select test_seq.nextval from dual;
+---------+
| NEXTVAL |
+---------+
|       2 |
+---------+

select test_seq.currval from dual;
+---------+
| CURRVAL |
+---------+
|       2 |
+---------+


// sequence schema version changed, expect hit_count = 1
select hit_count from sys.V$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select test_seq.nextval from dual';
+-----------+
| HIT_COUNT |
+-----------+
|         1 |
+-----------+
// expect hit_count = 0
select hit_count from sys.V$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select test_seq.currval from dual';
+-----------+
| HIT_COUNT |
+-----------+
|         0 |
+-----------+


// >>>>>>>>>>>>>>CASE#1: TEST SYS Table and Normal Table with Same Name

// select from sys table

select * from all_sequences where sequence_name = 'ZZM';
+----------------+---------------+-----------+-----------+--------------+------------+------------+------------+-------------+
| SEQUENCE_OWNER | SEQUENCE_NAME | MIN_VALUE | MAX_VALUE | INCREMENT_BY | CYCLE_FLAG | ORDER_FLAG | CACHE_SIZE | LAST_NUMBER |
+----------------+---------------+-----------+-----------+--------------+------------+------------+------------+-------------+
+----------------+---------------+-----------+-----------+--------------+------------+------------+------------+-------------+


// create user table all_sequences

create table all_sequences(sequence_name varchar2(255));

insert into all_sequences values ('ZZM');

// select from user table

select * from all_sequences where sequence_name = 'ZZM';
+---------------+
| SEQUENCE_NAME |
+---------------+
| ZZM           |
+---------------+


// expect 2 record, (0, 0)
select hit_count from sys.V$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select * from all_sequences where sequence_name = ?';
+-----------+
| HIT_COUNT |
+-----------+
|         0 |
|         0 |
+-----------+


// drop user table
drop table all_sequences;


// select sys table

select * from all_sequences where sequence_name = 'ZZM';
+----------------+---------------+-----------+-----------+--------------+------------+------------+------------+-------------+
| SEQUENCE_OWNER | SEQUENCE_NAME | MIN_VALUE | MAX_VALUE | INCREMENT_BY | CYCLE_FLAG | ORDER_FLAG | CACHE_SIZE | LAST_NUMBER |
+----------------+---------------+-----------+-----------+--------------+------------+------------+------------+-------------+
+----------------+---------------+-----------+-----------+--------------+------------+------------+------------+-------------+


// expect 2 record, (1, 0)
select hit_count from sys.V$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select * from all_sequences where sequence_name = ?';
+-----------+
| HIT_COUNT |
+-----------+
|         1 |
|         0 |
+-----------+


// >>>>>>>>>>>>>> TEST Window function, fast parser param count mismatch with normal parser count
