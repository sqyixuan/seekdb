select effective_tenant();
effective_tenant()
oracle

set ob_enable_plan_cache=true;
create table test_late (a bigint, b bigint, c varchar(128), d varchar(128));
set ob_enable_jit=true;
******************** Case #1 large query automatically turns on jit compilation **************************

// execute ten times 
select sum(a + b), sum(a + b + 1), sum(a + b + 2), sum(a + b + 3), sum(a + b + 4), sum(a + b + 5), sum(a + b + 6), sum(a + b + 7), sum(a + b + 8), sum(a + b + 9), sum(a + b + 10), sum(a + b + 11), sum(a + b + 12), sum(a + b + 13), sum(a + b + 14), sum(a + b + 15), sum(a + b + 16), sum(a + b + 17), sum(a + b + 18), sum(a + b + 19), sum(a + b + 20) from test_late where upper(substr(c, 1, 5)) = "HELLO" and upper(substr(d, 1, 5)) = "HELLO";

// first query, exepct cpu_time > 10s, is_use_jit = false, executions = 10
cpu_time > 10000000	is_use_jit = 0	executions = 10
1	1	1


// large query should automatically turn on jit compilation
// is_use_jit == 1, hit_count == 0, new plan with jit compilation is generated
hit_count = 0	is_use_jit = 1
1	1


// should hit plan with jit compilation, expect is_use_jit == 1, hit_count == 1
hit_count = 1	is_use_jit = 1
1	1
