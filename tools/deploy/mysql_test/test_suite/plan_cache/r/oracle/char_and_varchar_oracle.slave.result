result_format: 4

set ob_trx_timeout = 1000000000;
set @@ob_enable_plan_cache = 1;

drop table t1;

create table t1 (a varchar(20), b char(20));

begin;

// CASE#1 Insert Sql
insert into t1 values (1, 2);
insert into t1 values (2, 1);
insert into t1 values ('ab', 'ab');
insert into t1 values ('cd', 'ef');

// expect hit_count = 3
select hit_count from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'insert into t1 values (?, ?)';
+-----------+
| HIT_COUNT |
+-----------+
|         3 |
+-----------+

select a, b, length(a) as la, length(b) as lb from t1;
+------+----------------------+------+------+
| A    | B                    | LA   | LB   |
+------+----------------------+------+------+
| 1    | 2                    |    1 |   20 |
| 2    | 1                    |    1 |   20 |
| ab   | ab                   |    2 |   20 |
| cd   | ef                   |    2 |   20 |
+------+----------------------+------+------+
commit;

// CASE#2 Select Sql
begin;

select * from t1 where a = '1' and b = '2';
+------+----------------------+
| A    | B                    |
+------+----------------------+
| 1    | 2                    |
+------+----------------------+
select * from t1 where a = '2' and b = '1';
+------+----------------------+
| A    | B                    |
+------+----------------------+
| 2    | 1                    |
+------+----------------------+

// expect hit_count = 1
select hit_count from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select * from t1 where a = ? and b = ?';
+-----------+
| HIT_COUNT |
+-----------+
|         1 |
|         1 |
+-----------+

select 1 from dual;
+---+
| 1 |
+---+
| 1 |
+---+
select 2 from dual;
+---+
| 2 |
+---+
| 2 |
+---+
select '' from dual;
+------+
| ''   |
+------+
| NULL |
+------+
select '' from dual;
+------+
| ''   |
+------+
| NULL |
+------+
select 'ab' from dual;
+------+
| 'AB' |
+------+
| ab   |
+------+
select 'bc' from dual;
+------+
| 'BC' |
+------+
| bc   |
+------+

// expect hit_count = 1, 1, 1
select hit_count, param_infos from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select ? from dual';
+-----------+----------------+
| HIT_COUNT | PARAM_INFOS    |
+-----------+----------------+
|         1 | {1,0,0,-85,15} |
|         1 | {1,0,0,-1,23}  |
|         1 | {1,0,0,-1,23}  |
+-----------+----------------+
commit;

// CASE#2 update sql
begin;

update t1 set a = 1 where b = '2';
update t1 set a = 2 where b = '2';
update t1 set a = 'a' where b = '1';
update t1 set a = 'ab' where b = '2';

// expect hit_count = 1, 1
select hit_count, param_infos from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'update t1 set a = ? where b = ?';
+-----------+------------------------------+
| HIT_COUNT | PARAM_INFOS                  |
+-----------+------------------------------+
|         3 | {0,0,0,-85,15},{1,0,0,-1,23} |
|         3 | {0,0,0,-85,15},{1,0,0,-1,23} |
+-----------+------------------------------+

// CASE#3 string with spaces
select 1 from dual where 'ab ' = 'ab   ';
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual where 'ab ' = 'ab   ';
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual where 'ab ' = 'ab     ';
+---+
| 1 |
+---+
| 1 |
+---+

select hit_count, param_infos from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select ? from dual where ? = ?';
+-----------+--------------------------------------------+
| HIT_COUNT | PARAM_INFOS                                |
+-----------+--------------------------------------------+
|         2 | {1,0,0,-85,15},{1,0,0,-1,23},{1,0,0,-1,23} |
+-----------+--------------------------------------------+
commit;
drop table t1;

commit;
set autocommit = 1;


