***************************** change system variable : binlog_row_image *************************
drop table if exists binlog_t_update_oracle;
create table binlog_t_update_oracle(c1 int primary key, c2 varchar(100), v3 timestamp);

set binlog_row_image='minimal';
update binlog_t_update_oracle set v3 = current_timestamp();
//expect hit_count = 0;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'update binlog_t_update_oracle set v3 = current_timestamp()';
hit_count
0

set binlog_row_image = 'full';
update binlog_t_update_oracle set v3 = current_timestamp();
//expect two records, each record's hit_count is 0; because system variable change, add new plan;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'update binlog_t_update_oracle set v3 = current_timestamp()';
hit_count
0
0

update binlog_t_update_oracle set v3 = current_timestamp();
//expect two records, one hit_count is 0, another hit_count is 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'update binlog_t_update_oracle set v3 = current_timestamp()';
hit_count
0
1
drop table binlog_t_update_oracle;
commit;

********************************* change system variable : ob_enable_index_direct_select  ************************
//change to system tenant, because only system tenant can read __all_table;
set autocommit = 0;
drop database if exists xy_db;
create database xy_db;
use xy_db;
drop table if exists index_enabled_t;
create table index_enabled_t(c1 int primary key, c2 int);
create index i1_unique_index on index_enabled_t(c1);
let $table = query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id=(select table_id from oceanbase.__all_virtual_table where table_name='index_enabled_t'),table_name,1);

set ob_enable_index_direct_select = 1;
select  * from $table
c1
//expect hit_count = 0;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select  * from $table';
hit_count
0

set ob_enable_index_direct_select = 0;
select  * from $table;
error 1146  #该处报错信息中有表的id，该id是变化的，为保证结果稳定性使用echo输出；
//expect hit_count = 0; not hit, and not add new plan
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select  * from $table';
hit_count
0

set ob_enable_index_direct_select = 1;
select  * from $table;
c1
//expect hit_count = 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select  * from $table';
hit_count
1

drop database if exists xy_db;
commit;

