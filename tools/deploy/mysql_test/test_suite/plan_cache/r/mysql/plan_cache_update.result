alter system set resource_hard_limit = 500;
alter system flush plan cache;
set ob_trx_timeout = 1000000000;
drop user 'xy'@'%';
create user 'xy'@'%';
grant CREATE, SELECT, INSERT, DROP on *.* to xy;
select effective_tenant();
effective_tenant()
sys
set autocommit = 0;
set ob_read_consistency = 'weak';
drop database if exists xy_db;
create database xy_db;
use xy_db;

#bug 8044575 plan cache对table schema校验bug
create table ts_t(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
select * from ts_t where c1 = 0;
c1	c2
// expect hit_count = 0
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from ts_t where c1 = ?';
hit_count
0
drop table ts_t;
create table ts_t(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
select * from ts_t where c1 = 1;
c1	c2
//expect hit_count = 0, because new pcv create and add plan create by 'select * from ts_t where c1 = 1';
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from ts_t where c1 = ?';
hit_count
0
select * from ts_t where c1 = 1;
c1	c2
//expect hit_count = 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from ts_t where c1 = ?';
hit_count
1

#bug 7998585 plan cache支持恒真/假表达式的校验
drop table if exists bool_t1,bool_t2,bool_t3;
drop tablegroup if exists bool_group;
create tablegroup bool_group;
create table bool_t1(c1 int primary key, c2 int) tablegroup='bool_group';
create table bool_t2(c1 int primary key, c2 int) tablegroup='bool_group';
create table bool_t3(c1 int primary key, c2 int) tablegroup='bool_group';
select * from bool_t1 where (0 = 1) or c1 = 1;
c1	c2

//expect hit_count = 0
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from bool_t1 where (? = ?) or c1 = ?';
hit_count
0
select * from bool_t1 where (1 = 1) or c1 = 1;
c1	c2
//expect two records, each record's hit_count is 0;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from bool_t1 where (? = ?) or c1 = ?';
hit_count
0
0

select * from bool_t1 left join bool_t2 on (1 = 0 or bool_t1.c1 = bool_t2.c1) left join bool_t3 on (2=2 or bool_t2.c1 = bool_t3.c1);
c1	c2	c1	c2	c1	c2
//expect hit_count = 0
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from bool_t1 left join bool_t2 on (? = ? or bool_t1.c1 = bool_t2.c1) left join bool_t3 on (?=? or bool_t2.c1 = bool_t3.c1)';
hit_count
0
select * from bool_t1 left join bool_t2 on (1 = 3 or bool_t1.c1 = bool_t2.c1) left join bool_t3 on (4=4 or bool_t2.c1 = bool_t3.c1);
c1	c2	c1	c2	c1	c2
//expect hit_count = 1
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from bool_t1 left join bool_t2 on (? = ? or bool_t1.c1 = bool_t2.c1) left join bool_t3 on (?=? or bool_t2.c1 = bool_t3.c1)';
hit_count
1
drop table bool_t1,bool_t2,bool_t3;

*********************************change view table version ************************
//test drop/create view
drop table if exists t1;
create table t1(i1 int primary key, f1 float, s1 varchar(32), d1 datetime);
drop view if exists vt;
create view vt as select * from t1;

select * from vt;
i1	f1	s1	d1
// expect hit_count = 0;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from vt';
hit_count
0

drop view vt;
create view vt as select * from t1;
select * from vt;
i1	f1	s1	d1
// expect hit_count = 0; not hit, because view version change, plan update
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from vt';
hit_count
0

select * from vt;
i1	f1	s1	d1
// expect hit_count is 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from vt';
hit_count
1

********************* test nest view, and have reduplicated view *****************
drop table if exists t1;
create table t1(i1 int primary key, f1 float, s1 varchar(32), d1 datetime);
drop view if exists vt,vvt;
create view vt as select * from t1;
create view vvt as select * from vt;

select * from vvt;
i1	f1	s1	d1
// expect hit_count = 0;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from vvt';
hit_count
0

drop view vt;
create view vt as select * from t1;
select * from vvt where i1=1;
select * from vvt;
i1	f1	s1	d1
// expect hit_count = 0;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from vvt';
hit_count
0

select * from vvt;
i1	f1	s1	d1
// expect hit_count is 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from vvt';
hit_count
1

