************** test alter table, plan update; ****************************************
drop table if exists alter_add_t;
create table alter_add_t(i1 int primary key, f1 float, s1 varchar(32), d1 datetime);

select * from alter_add_t where i1 = 1;
i1	f1	s1	d1
//expect hit_count = 0;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from alter_add_t where i1 = ?';
hit_count
0

alter table alter_add_t add i2 int;
select * from alter_add_t where i1 = 1;
i1	f1	s1	d1	i2
//expect hit_count = 0, not hit, because table version change, plan update
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from alter_add_t where i1 = ?';
hit_count
0

select * from alter_add_t where i1 = 1;
i1	f1	s1	d1	i2
//expect hit_count = 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from alter_add_t where i1 = ?';
hit_count
1

************************ test alter table, plan update ******************************
drop table if exists alter_table_t;
