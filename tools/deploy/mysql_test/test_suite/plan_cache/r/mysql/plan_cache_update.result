******************************* change system variable : sql mode *********************************
drop table if exists t1;
create table t1(i1 int primary key, f1 float, s1 varchar(32), d1 datetime);

set session sql_mode='STRICT_TRANS_TABLES';
select * from t1 where i1 > 0;
i1	f1	s1	d1
//expect hit_count = 0;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1 where i1 > ?';
hit_count
0

set session sql_mode='STRICT_ALL_TABLES';
select * from t1 where i1 > 0;
i1	f1	s1	d1
//expect two records, each record's hit_count is 0; because system variable change, add new plan;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1 where i1 > ?';
hit_count
0
0

select * from t1 where i1 > 0;
i1	f1	s1	d1
//expect two records, one hit_count is 0, another hit_count is 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1 where i1 > ?';
hit_count
0
1
drop table t1;

******************************* change system variable : ob_enable_transformation *********************************
drop table if exists t1;
create table t1(c1 int primary key, c2 int);
set ob_enable_transformation = 1;
select * from t1, (select * from t1 ) as v1;
c1	c2	c1	c2
//expect hit_count = 0;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1, (select * from t1 ) as v1';
hit_count
0

set ob_enable_transformation = 0;
select * from t1, (select * from t1 ) as v1;
c1	c2	c1	c2
//expect two records, every hit_count is 0 ;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1, (select * from t1 ) as v1';
hit_count
0
0

select * from t1, (select * from t1 ) as v1;
c1	c2	c1	c2
//expect two records, one hit_count is 0, another hit_count is 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from t1, (select * from t1 ) as v1';
hit_count
0
1
drop table t1;
commit;
set autocommit = 1;

******************************* change system variable : read only *********************************
use xy_db;
set autocommit = 0;
drop table if exists t1;
create table t1(c1 int primary key, c2 int);

set @@global.read_only = off;
insert into t1 values(1,1);
//expect hit_count = 0;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 values(?,?)';
hit_count
0

set @@global.read_only = on;
insert into t1 values(2,1);
ERROR HY000: The MySQL server is running with the --read-only option so it cannot execute this statement
//expect hit_count = 0;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 values(?,?)';
hit_count
0

set @@global.read_only = off;
commit;
