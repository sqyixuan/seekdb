alter system flush plan cache;

drop database if exists xy_db;
create database xy_db;
use xy_db;
create table xy_t(c1 int, c2 int);
//建立outline
create outline otl1 on select * from xy_t;
select * from xy_t;
c1	c2

//expected 0
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from xy_t';
hit_count
0
//生成多个plan

************测试在merged_version均未失效时, outline生成的plan也会根据权重被淘汰
//减小plan cache淘汰上限,触发淘汰, 期望将outline生成的plan淘汰,因为其执行时间最早
set global ob_plan_cache_evict_high_percentage = 1;
set global ob_plan_cache_evict_low_percentage = 1;
//expected null
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from xy_t';
hit_count

select * from xy_t;
c1	c2
//expected 0
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from xy_t';
hit_count
0

*******测试outline version变更时plan需要更新*************
drop outline otl1;
select * from xy_t;
c1	c2
//expected 0;
select /*+use_plan_cache(none)*/ hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from xy_t';
hit_count
0
set global ob_plan_cache_evict_high_percentage = 90;
set global ob_plan_cache_evict_low_percentage = 50;
drop table xy_t;
drop database xy_db;
