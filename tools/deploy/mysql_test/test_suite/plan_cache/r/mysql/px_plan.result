// CASE#3 Partition Wise Join








set _ob_use_parallel_execution = true;

select t1.a as a1, t2.a as a2 from t1 join t2 on t1.a = t2.a;
+------+------+
| a1   | a2   |
+------+------+
|    1 |    1 |
|    2 |    2 |
|    3 |    3 |
+------+------+
explain select t1.a as a1, t2.a as a2 from t1 join t2 on t1.a = t2.a;
Query Plan
====================================================
|ID|OPERATOR               |NAME    |EST. ROWS|COST|
----------------------------------------------------
|0 |PX COORDINATOR         |        |1        |100 |
|1 | EXCHANGE OUT DISTR    |:EX10000|1        |100 |
|2 |  PX PARTITION ITERATOR|        |1        |100 |
|3 |   NESTED-LOOP JOIN    |        |1        |100 |
|4 |    TABLE SCAN         |t1      |1        |92  |
|5 |    TABLE SCAN         |t2      |1        |14  |
====================================================

Outputs & filters: 
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.a, t2.a)]), filter(nil)
  1 - output([INTERNAL_FUNCTION(t1.a, t2.a)]), filter(nil), dop=1
  2 - output([t1.a], [t2.a]), filter(nil)
  3 - output([t1.a], [t2.a]), filter(nil), 
      conds(nil), nl_params_([t1.a])
  4 - output([t1.a]), filter(nil), 
      access([t1.a]), partitions(p[0-1])
  5 - output([t2.a]), filter(nil), 
      access([t2.a]), partitions(p[0-1])



// switch t1's part1 to backup, t2's part1 to backup
