result_format: 4

alter system set enable_auto_leader_switch=false;
alter system flush plan cache global;

set _ob_use_parallel_execution = false;

// CASE#1 hit different plan after changing session variable
select * from t1;
+------+
| a    |
+------+
|    1 |
|    2 |
|    3 |
+------+

explain select * from t1;
Query Plan
====================================================
|ID|OPERATOR               |NAME    |EST. ROWS|COST|
----------------------------------------------------
|0 |PX COORDINATOR         |        |1        |92  |
|1 | EXCHANGE OUT DISTR    |:EX10000|1        |92  |
|2 |  PX PARTITION ITERATOR|        |1        |92  |
|3 |   TABLE SCAN          |t1      |1        |92  |
====================================================

Outputs & filters: 
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.a)]), filter(nil)
  1 - output([INTERNAL_FUNCTION(t1.a)]), filter(nil), dop=1
  2 - output([t1.a]), filter(nil)
  3 - output([t1.a]), filter(nil), 
      access([t1.a]), partitions(p[0-1])


set _ob_use_parallel_execution = true;
select * from t1;
+------+
| a    |
+------+
|    1 |
|    2 |
|    3 |
+------+
