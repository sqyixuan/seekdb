alter system flush plan cache global;
drop table t1;
create table t1(c1 int);
select * into outfile 'plan_cache_select_into_outfile_test/data1' fields terminated by '|' enclosed by '"' lines terminated by '\n' from t1;
select * into outfile 'plan_cache_select_into_outfile_test/data2' fields terminated by '|' enclosed by '"' lines terminated by '\n' from t1;
select * into outfile 'plan_cache_select_into_outfile_test/data1' fields terminated by '|' enclosed by '"' lines terminated by '\n' from t1 where c1 > 1;
select * into outfile 'plan_cache_select_into_outfile_test/data2' fields terminated by '|' enclosed by '"' lines terminated by '\n' from t1 where c1 > 10;
select * from t1 where c1 > 1 into outfile 'plan_cache_select_into_outfile_test/data1' fields terminated by '|' enclosed by '"' lines terminated by '\n';
select * from t1 where c1 > 10 into outfile 'plan_cache_select_into_outfile_test/data2' fields terminated by '|' enclosed by '"' lines terminated by '\n';
select hit_count, statement from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "%into outfile%";
hit_count	statement
1	select * into outfile ? fields terminated by '|' enclosed by '"' lines terminated by '\n' from t1
1	select * into outfile ? fields terminated by '|' enclosed by '"' lines terminated by '\n' from t1 where c1 > ?
1	select * from t1 where c1 > ? into outfile ? fields terminated by '|' enclosed by '"' lines terminated by '\n'
drop table t1;
alter system flush plan cache global;
