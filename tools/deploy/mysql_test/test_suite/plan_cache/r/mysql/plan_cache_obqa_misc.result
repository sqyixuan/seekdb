result_format: 4


set ob_trx_timeout = 1000000000;

// >>>>>>>>>>>>>> TEST Insert With Global Index
// Dependency tables contain index table

insert into timeout_003 (job_id,trade_no,user_id,paytype,end_time,action,parameter,status,action_type,GMT_CREATE,PRIOR_LEVEL,GMT_MODIFIED,GMT_COMPENSATED) values ('1000000000000137498', '1000000000000137498', '1000000000000137498', 'S', '2018-12-21 09:01:40', 'allowRefundAction', null, 'W', 'M', '2018-12-21 09:01:40', 1, '2018-12-21 09:01:40', CURRENT_TIMESTAMP(6));


insert into timeout_003 (job_id,trade_no,user_id,paytype,end_time,action,parameter,status,action_type,GMT_CREATE,PRIOR_LEVEL,GMT_MODIFIED,GMT_COMPENSATED) values ('1000000000000137499', '1000000000000137499', '1000000000000137498', 'S', '2018-12-21 09:01:40', 'allowRefundAction', null, 'W', 'M', '2018-12-21 09:01:40', 1, '2018-12-21 09:01:40', CURRENT_TIMESTAMP(6));


// EXEPCT hit_count = 1, plan_type = 1
select hit_count, type from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into timeout_003 (job_id,trade_no,user_id,paytype,end_time,action,parameter,status,action_type,GMT_CREATE,PRIOR_LEVEL,GMT_MODIFIED,GMT_COMPENSATED) values (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, CURRENT_TIMESTAMP(6))';
+-----------+------+
| hit_count | type |
+-----------+------+
|         1 |    1 |
+-----------+------+

