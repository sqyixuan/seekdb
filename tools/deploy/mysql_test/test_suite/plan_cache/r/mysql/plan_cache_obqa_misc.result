// >>>>>>>>>>>>>>>TEST Select from gv table
// bug link: https://work.aone.alibaba-inc.com/issue/21308303




alter system flush sql audit global;
alter system flush plan cache global;
// query from local, expect true
select count(*) = 0 from oceanbase.GV$OB_SQL_AUDIT where svr_port = svr_port1 and is_inner_sql = 0;
+--------------+
| count(*) = 0 |
+--------------+
|            0 |
+--------------+

// execute query in remote
select 1 from dual;
+---+
| 1 |
+---+
| 1 |
+---+

