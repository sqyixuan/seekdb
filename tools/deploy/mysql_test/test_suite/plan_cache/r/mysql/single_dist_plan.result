result_format: 4

alter system set large_query_threshold = '1s';
alter system set resource_hard_limit = 500;

alter system flush plan cache global;

set autocommit = 0;
set ob_trx_timeout = 1000000000;
drop table if exists dist_t;
create table dist_t (pk int primary key, a int, b int) partition by hash(pk) partitions 2;
insert into dist_t values (1, 2, 3), (2, 3, 4), (3, 4, 5), (4, 5, 6);



// >>>>>>>>>>>>>>>> Case#1 Normal dist plan with single table
select * from dist_t;
+----+------+------+
| pk | a    | b    |
+----+------+------+
|  1 |    2 |    3 |
|  2 |    3 |    4 |
|  3 |    4 |    5 |
|  4 |    5 |    6 |
+----+------+------+
select * from dist_t;
+----+------+------+
| pk | a    | b    |
+----+------+------+
|  1 |    2 |    3 |
|  2 |    3 |    4 |
|  3 |    4 |    5 |
|  4 |    5 |    6 |
+----+------+------+

explain select * from dist_t;
Query Plan
=============================================================
|ID|OPERATOR                 |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |PX COORDINATOR           |        |4       |11          |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|4       |9           |
|2 |  └─PX PARTITION ITERATOR|        |4       |5           |
|3 |    └─TABLE FULL SCAN    |dist_t  |4       |5           |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(dist_t.pk, dist_t.a, dist_t.b)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(dist_t.pk, dist_t.a, dist_t.b)]), filter(nil), rowset=16
      dop=1
  2 - output([dist_t.pk], [dist_t.a], [dist_t.b]), filter(nil), rowset=16
      force partition granule
  3 - output([dist_t.pk], [dist_t.a], [dist_t.b]), filter(nil), rowset=16
      access([dist_t.pk], [dist_t.a], [dist_t.b]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([dist_t.pk]), range(MIN ; MAX)always true
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from dist_t';
+-----------+
| hit_count |
+-----------+
|         1 |
+-----------+

