// >>>>>>>>>>>>>>>> Case#3 Single table dist plan with dop > 1
drop table dist_t;
create table dist_t (pk int primary key, a int) partition by hash(pk) partitions 2;
insert into dist_t values (1, 1), (2, 2), (3, 3), (4, 4);

select /*+ use_px parallel(2) */* from dist_t where pk >= 1 and pk <= 4;
+----+------+
| pk | a    |
+----+------+
|  1 |    1 |
|  2 |    2 |
|  3 |    3 |
|  4 |    4 |
+----+------+
select /*+ use_px parallel(2) */* from dist_t where pk >= 1 and pk <= 4;
