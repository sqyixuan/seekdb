============================ delete with subquery  ============================


delete from case2_t_2 where pk2 in (select pk3 from case2_t_3);
delete from case2_t_2 where pk2 in (select pk3 from case2_t_3);

explain delete from case2_t_2 where pk2 in (select pk3 from case2_t_3);
