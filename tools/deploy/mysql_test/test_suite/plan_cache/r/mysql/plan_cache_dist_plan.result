result_format: 4

alter system set large_query_threshold = '1s';
alter system set enable_auto_leader_switch=false;
alter system set resource_hard_limit = 500;

alter system flush plan cache global;
**************************************** Single Table Dist Plan ****************************************

=============================== single table select ===============================

select * from case1_t_1;
select * from case1_t_1;


explain select * from case1_t_1;
Query Plan
=====================================================
|ID|OPERATOR               |NAME     |EST. ROWS|COST|
-----------------------------------------------------
|0 |PX COORDINATOR         |         |1        |92  |
|1 | EXCHANGE OUT DISTR    |:EX10000 |1        |92  |
|2 |  PX PARTITION ITERATOR|         |1        |92  |
|3 |   TABLE SCAN          |case1_t_1|1        |92  |
=====================================================

Outputs & filters: 
-------------------------------------
  0 - output([INTERNAL_FUNCTION(case1_t_1.pk1, case1_t_1.a1)]), filter(nil)
  1 - output([INTERNAL_FUNCTION(case1_t_1.pk1, case1_t_1.a1)]), filter(nil), dop=1
  2 - output([case1_t_1.pk1], [case1_t_1.a1]), filter(nil)
  3 - output([case1_t_1.pk1], [case1_t_1.a1]), filter(nil), 
      access([case1_t_1.pk1], [case1_t_1.a1]), partitions(p[0-1])



