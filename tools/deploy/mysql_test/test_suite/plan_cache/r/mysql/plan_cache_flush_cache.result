>>>>>>>>>>> begin mysql tenant's flush plan cache test ********************
>>>> PART1: privilege test >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
**** PART1.1 NOT GRANT DBA **************************************************
drop user flush_cache_test;
create user flush_cache_test identified by 'flush_cache';
grant select, insert, update, delete, create, drop on test.* to flush_cache_test;
// insufficent privileges
alter system flush plan cache;

**** PART1.2 GRANT DBA *****************************************************
grant all privileges on *.* to flush_cache_test;
alter system flush plan cache;
**** PART1.3 USE SYS TENANT's CMD *******************************************
// use system tenant's command, insufficent privileges
alter system flush plan cache tenant=sys;


