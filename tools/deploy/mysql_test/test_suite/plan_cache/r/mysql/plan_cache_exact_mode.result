**************** outline test ***************
set cursor_sharing='exact';
drop table if exists t3;
create table t3(c1 int, c2 int);


drop outline otl1;
create index idx_c1 on t3(c1);
explain select c1 from t3 where c1=1;
Query Plan
======================================================
|ID|OPERATOR        |NAME      |EST.ROWS|EST.TIME(us)|
------------------------------------------------------
|0 |TABLE RANGE SCAN|t3(idx_c1)|1       |3           |
======================================================
Outputs & filters:
-------------------------------------
  0 - output([t3.c1]), filter(nil), rowset=16
      access([t3.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t3.c1], [t3.__pk_increment]), range(1,MIN ; 1,MAX), 
      range_cond([t3.c1 = 1])
create outline otl1 on select/*+FULL(t3)*/ c1 from t3 where c1=1;
select c1 from t3 where c1=1;
expected hit_count: 0
select query_sql, hints_info from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select c1 from t3 where c1=1';
query_sql	hints_info
select c1 from t3 where c1=1	/*+  FULL(@"SEL$1" "test"."t3"@"SEL$1") OPTIMIZER_FEATURES_ENABLE('')  */
