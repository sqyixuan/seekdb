drop table if exists test_34x;
CREATE TABLE test_34x(
pk1 int(11) NOT NULL,
pk2 int(11) NOT NULL,
first_name text DEFAULT NULL,
last_name varchar(100) DEFAULT NULL,
full_name varchar(300) AS (concat(`first_name`,'.',`last_name`)) VIRTUAL,
primary key(pk1,pk2)
);
