explain basic select * from t3;
Query Plan
=======================================
|ID|OPERATOR                 |NAME    |
---------------------------------------
|0 |PX COORDINATOR           |        |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|
|2 |  └─PX PARTITION ITERATOR|        |
|3 |    └─TABLE FULL SCAN    |t3      |
=======================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t3.c1)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t3.c1)]), filter(nil), rowset=16
      dop=1
  2 - output([t3.c1]), filter(nil), rowset=16
      force partition granule
  3 - output([t3.c1]), filter(nil), rowset=16
      access([t3.c1]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t3.__pk_increment]), range(MIN ; MAX)always true

insert into t1 values(1),(2),(3),(4);
insert into pindex values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5);

// local + local = local plan
insert into t2 select * from t1;
// dist(multi part convert to local) + local = local plan
insert into t3 select * from t1;
// dist(multi part convert to local) + local = local plan
insert into t4 select * from t1;
// local + dist = dist plan
insert into t2 select /*+index(pindex i)*/ c3 from pindex;
// local + local = local
insert into t2 select /*+index(pindex i)*/ c3 from pindex where c2 = 1;
// local + dist = dist plan
insert into t2 select /*+use_px,parallel(2)*/ c1 from t3;
insert into t2 select c1 from t3;
// local + local = local plan
insert into t2 select /*+use_px,parallel(2)*/ c1 from t3 where c1 = 2;
