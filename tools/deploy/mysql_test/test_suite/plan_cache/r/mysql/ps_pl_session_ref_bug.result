result_format: 4
alter system flush pl cache global;
alter system flush plan cache global;

drop table if exists t1;
drop procedure if exists p;
create table t1 (shaogedebug_ps_col varchar(100));
insert into t1 values('abcd');

create procedure p(in x int)
begin 
select hex(shaogedebug_ps_col) from t1; 
end//

// stmt_item_ref_count and stmt_info_ref_count 应该是2
// 一个是视图占用的引用计数,一个是pl func对象占用的引用计数
// 该bug未解决前，引用计数是3，是session占用的
select ps_sql,stmt_item_ref_count,stmt_info_ref_count from oceanbase.__all_virtual_ps_item_info where ps_sql like '%shaogedebug%';
+--------+---------------------+---------------------+
| ps_sql | stmt_item_ref_count | stmt_info_ref_count |
+--------+---------------------+---------------------+
+--------+---------------------+---------------------+
drop procedure p;
