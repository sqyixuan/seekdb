result_format: 4
alter system flush plan cache global;
alter system set enable_auto_leader_switch = false;

set ob_enable_plan_cache=on;
set optimizer_use_sql_plan_baselines = false;
set optimizer_capture_sql_plan_baselines = false;
begin;
create table test (pk1 int, pk2 int, c1 int, c2 int, primary key(pk1, pk2)) partition by hash(pk2) partitions 2;

insert into test values (1, 1, 1, 1);
insert into test values (2, 2, 2, 2);
commit;

begin;
select * from test where pk2 in (1, 2) order by pk2 limit 1;
+-----+-----+------+------+
| pk1 | pk2 | c1   | c2   |
+-----+-----+------+------+
|   1 |   1 |    1 |    1 |
+-----+-----+------+------+
select * from test where pk2 in (1, 2) order by pk2 limit 1;
+-----+-----+------+------+
| pk1 | pk2 | c1   | c2   |
+-----+-----+------+------+
|   1 |   1 |    1 |    1 |
+-----+-----+------+------+

explain select * from test where pk2 in (1, 2) order by pk2 limit 1;
Query Plan
========================================================
|ID|OPERATOR                   |NAME    |EST. ROWS|COST|
--------------------------------------------------------
|0 |LIMIT                      |        |1        |93  |
|1 | PX COORDINATOR MERGE SORT |        |1        |93  |
|2 |  EXCHANGE OUT DISTR       |:EX10000|1        |92  |
|3 |   TOP-N SORT              |        |1        |92  |
|4 |    PX PARTITION ITERATOR  |        |1        |92  |
|5 |     TABLE SCAN            |test    |1        |92  |
========================================================

Outputs & filters: 
-------------------------------------
  0 - output([test.pk1], [test.pk2], [test.c1], [test.c2]), filter(nil), limit(1), offset(nil)
  1 - output([test.pk1], [test.pk2], [test.c1], [test.c2]), filter(nil), sort_keys([test.pk2, ASC])
  2 - output([test.pk1], [test.pk2], [test.c1], [test.c2]), filter(nil), dop=1
  3 - output([test.pk1], [test.pk2], [test.c1], [test.c2]), filter(nil), sort_keys([test.pk2, ASC]), topn(1)
  4 - output([test.pk1], [test.pk2], [test.c1], [test.c2]), filter(nil)
  5 - output([test.pk1], [test.pk2], [test.c1], [test.c2]), filter([test.pk2 IN (1, 2)]), 
      access([test.pk1], [test.pk2], [test.c1], [test.c2]), partitions(p[0-1])


select hit_count, type from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from test where pk2 in (?, ?) order by pk2 limit 1';
+-----------+------+
| hit_count | type |
+-----------+------+
|         1 |    3 |
+-----------+------+
commit;


begin;
select * from test where pk2 in (1, 3) order by pk2 limit 1;
+-----+-----+------+------+
| pk1 | pk2 | c1   | c2   |
+-----+-----+------+------+
|   1 |   1 |    1 |    1 |
+-----+-----+------+------+
select * from test where pk2 in (1, 3) order by pk2 limit 1;
+-----+-----+------+------+
| pk1 | pk2 | c1   | c2   |
+-----+-----+------+------+
|   1 |   1 |    1 |    1 |
+-----+-----+------+------+

explain select * from test where pk2 in (1, 3) order by pk2 limit 1;
Query Plan
====================================
|ID|OPERATOR   |NAME|EST. ROWS|COST|
------------------------------------
|0 |TOP-N SORT |    |1        |228 |
|1 | TABLE SCAN|test|10       |228 |
====================================

Outputs & filters: 
-------------------------------------
  0 - output([test.pk1], [test.pk2], [test.c1], [test.c2]), filter(nil), sort_keys([test.pk2, ASC]), topn(1)
  1 - output([test.pk1], [test.pk2], [test.c1], [test.c2]), filter([test.pk2 IN (1, 3)]), 
      access([test.pk1], [test.pk2], [test.c1], [test.c2]), partitions(p1)


select hit_count, type from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from test where pk2 in (?, ?) order by pk2 limit 1';
+-----------+------+
| hit_count | type |
+-----------+------+
|         1 |    3 |
|         1 |    1 |
+-----------+------+
commit;




begin;
delete from test where pk1 >= 3;
commit;

begin;
select * from test where pk2 in (1, 2) order by pk2 limit 1;
+-----+-----+------+------+
| pk1 | pk2 | c1   | c2   |
+-----+-----+------+------+
|   1 |   1 |    1 |    1 |
+-----+-----+------+------+
