alter system flush plan cache;
alter system set large_query_threshold = '1s';
select effective_tenant();
effective_tenant()
mysql
create table test_gen (a bigint, b bigint, c bigint,
d bigint as (a + 1), e bigint as (a + 2 + b + 3), f bigint as (4 + 5 + 6 + 7),
index idx_d(d), index idx_e(e), index idx_f(f));
************************************ Case 1 Single const param *****************************************

select a from test_gen where a + 1 > 0;

explain select a from test_gen where a + 1 > 0;
Query Plan
=======================================
|ID|OPERATOR  |NAME    |EST. ROWS|COST|
---------------------------------------
|0 |TABLE SCAN|test_gen|200      |583 |
=======================================

Outputs & filters: 
-------------------------------------
  0 - output([test_gen.a]), filter([test_gen.d > 0]), 
      access([test_gen.a], [test_gen.d]), partitions(p0)


// expect 0
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select a from test_gen where a + ? > ?';
hit_count
0

