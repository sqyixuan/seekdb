result_format: 4


drop database if exists test_db1;
drop database if exists test_db2;
create database test_db1;
create database test_db2;

set autocommit = 0;
set autocommit = 0;

use test_db1;
create table test (a int);
insert into test values (1);

use test_db2;
create table test (a int);
insert into test values (2);


select t1.a, t2.a from test_db1.test as t1, test as t2 where t1.a = t2.a;
+------+------+
| a    | a    |
+------+------+
|    1 |    1 |
+------+------+
select t1.a, t2.a from test_db1.test as t1, test as t2 where t1.a = t2.a;

select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select t1.a, t2.a from test_db1.test as t1, test as t2 where t1.a = t2.a';
+-----------+
| hit_count |
+-----------+
|         1 |
+-----------+

select t1.a, t2.a from test as t1, test_db2.test as t2 where t1.a = t2.a;
+------+------+
| a    | a    |
+------+------+
+------+------+
select t1.a, t2.a from test as t1, test_db2.test as t2 where t1.a = t2.a;

// expect hit_count = 1
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select t1.a, t2.a from test as t1, test_db2.test as t2 where t1.a = t2.a';
+-----------+
| hit_count |
+-----------+
|         1 |
+-----------+

select t1.a, t2.a from test_db1.test as t1, test_db2.test as t2 where t1.a = t2.a;
+------+------+
| a    | a    |
+------+------+
+------+------+
select t1.a, t2.a from test_db1.test as t1, test_db2.test as t2 where t1.a = t2.a;

// expect hit_count = 1
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select t1.a, t2.a from test_db1.test as t1, test_db2.test as t2 where t1.a = t2.a';
+-----------+
