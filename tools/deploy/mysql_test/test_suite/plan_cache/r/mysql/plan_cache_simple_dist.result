// >>>>>>>>>>>>>>>>>>>> TEST Single Table With Dist Plan

select  * from dist_t where c1 = (c1 >= 2 and c2 <= 2) or c1 = 1;
select  * from dist_t where c1 = (c1 >= 2 and c2 <= 2) or c1 = 1;

// expect dist plan
explain select  * from dist_t where c1 = (c1 >= 2 and c2 <= 2) or c1 = 1;
Query Plan
=============================================================
|ID|OPERATOR                 |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |PX COORDINATOR           |        |10      |22          |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|10      |19          |
|2 |  └─PX PARTITION ITERATOR|        |10      |12          |
|3 |    └─TABLE FULL SCAN    |dist_t  |10      |12          |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(dist_t.c1, dist_t.c2)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(dist_t.c1, dist_t.c2)]), filter(nil), rowset=16
      dop=1
  2 - output([dist_t.c1], [dist_t.c2]), filter(nil), rowset=16
      force partition granule
  3 - output([dist_t.c1], [dist_t.c2]), filter([dist_t.c1 = dist_t.c1 >= 2 AND dist_t.c2 <= 2 OR dist_t.c1 = 1]), rowset=16
      access([dist_t.c1], [dist_t.c2]), partitions(p[0-4])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([dist_t.c1]), range(MIN ; MAX)always true

// expect hit_count = 1, type = 3
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select  * from dist_t where c1 = (c1 >= ? and c2 <= ?) or c1 = ?';
hit_count
1

select  * from dist_t where c1 <=> 1;
select  * from dist_t where c1 <=> 1;

// expect dist plan
explain select  * from dist_t where c1 <=> 1;
Query Plan
===========================================
|ID|OPERATOR |NAME  |EST.ROWS|EST.TIME(us)|
-------------------------------------------
|0 |TABLE GET|dist_t|1       |5           |
===========================================
Outputs & filters:
-------------------------------------
  0 - output([dist_t.c1], [dist_t.c2]), filter(nil), rowset=16
      access([dist_t.c1], [dist_t.c2]), partitions(p1)
      is_index_back=false, is_global_index=false, 
      range_key([dist_t.c1]), range[1 ; 1], 
      range_cond([dist_t.c1 <=> 1])

// expect hit_count = 1, type = 3
select  hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select  * from dist_t where c1 <=> ?";
hit_count
1

select  * from dist_t where c1 between 0 and 3;
select  * from dist_t where c1 between 3 and 5;

explain select  * from dist_t where c1 between 0 and 3;
Query Plan
=============================================================
|ID|OPERATOR                 |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |PX COORDINATOR           |        |4       |13          |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|4       |12          |
|2 |  └─PX PARTITION ITERATOR|        |4       |9           |
|3 |    └─TABLE RANGE SCAN   |dist_t  |4       |9           |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(dist_t.c1, dist_t.c2)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(dist_t.c1, dist_t.c2)]), filter(nil), rowset=16
      dop=1
  2 - output([dist_t.c1], [dist_t.c2]), filter(nil), rowset=16
      force partition granule
  3 - output([dist_t.c1], [dist_t.c2]), filter(nil), rowset=16
      access([dist_t.c1], [dist_t.c2]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([dist_t.c1]), range[0 ; 3], 
      range_cond([dist_t.c1 >= 0], [dist_t.c1 <= 3])

// expect hit_count = 1, type = 3
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select  * from dist_t where c1 between ? and ?';
hit_count
1

