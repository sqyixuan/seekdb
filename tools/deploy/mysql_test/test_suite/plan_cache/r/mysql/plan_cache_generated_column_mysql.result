************************************ Case 3 Just const params *****************************************

select * from test_gen where 4 + 5 + 6 + 7 > 0;

// new plan, expect 0,0
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from test_gen where ? + ? + ? + ? > ?';
hit_count
0

select * from test_gen where 4 + 5 + 6 + 8 > 0;

// hit plan, expect 1,1
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from test_gen where ? + ? + ? + ? > ?';
hit_count
1

select * from test_gen where 4 + 5 + 7 + 7 > 0;

// hit plan, expect 2,2
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from test_gen where ? + ? + ? + ? > ?';
hit_count
2

select * from test_gen where 4 + 5 + 6 + 7 > 100;

// new plan, expect 2, 0,2,0
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from test_gen where ? + ? + ? + ? > ?';
hit_count
2
0

select * from test_gen where 4 + 5 + 6 + 7 > 120;

// hit second plan, expect 2, 1, 2,1
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from test_gen where ? + ? + ? + ? > ?';
hit_count
2
1

************************************ Case 4 Complicated Case *****************************************

select * from test_gen where (a + 1 > 0 and a + 1 < 10) or (a + 2 > 0 and a + 1 < 10) or (a + 2 + b + 3 > 0) or (a + 3 + b + 3 < 10);

// expect 0
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from test_gen where (a + ? > ? and a + ? < ?) or (a + ? > ? and a + ? < ?) or (a + ? + b + ? > ?) or (a + ? + b + ? < ?)';
hit_count
0

select * from test_gen where (a + 1 > 0 and a + 2 < 10) or (a + 2 > 0 and a + 1 < 10) or (a + 2 + b + 3 > 0) or (a + 3 + b + 3 < 10);

// new plan should be generated, expect 0, 0
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from test_gen where (a + ? > ? and a + ? < ?) or (a + ? > ? and a + ? < ?) or (a + ? + b + ? > ?) or (a + ? + b + ? < ?)';
hit_count
1

select * from test_gen where (a + 1 > 0 and a + 1 < 10) or (a + 2 > 0 and a + 1 < 10) or (a + 2 + b + 3 > 0) or (a + 3 + b + 4 < 10);

// the changed const param is not in generated column, should hit the first plan, expect 1, 0
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from test_gen where (a + ? > ? and a + ? < ?) or (a + ? > ? and a + ? < ?) or (a + ? + b + ? > ?) or (a + ? + b + ? < ?)';
hit_count
2

select * from test_gen where (a + 1 > 0 and a + 3 < 10) or (a + 2 > 0 and a + 1 < 10) or (a + 2 + b + 3 > 0) or (a + 3 + b + 4 < 10);

// should hit the second plan, expect 1, 1
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from test_gen where (a + ? > ? and a + ? < ?) or (a + ? > ? and a + ? < ?) or (a + ? + b + ? > ?) or (a + ? + b + ? < ?)';
hit_count
3

select * from test_gen where (a + 1 > 0 and a + 3 < 10) or (a + 2 > 0 and a + 2 < 10) or (a + 2 + b + 3 > 0) or (a + 3 + b + 4 < 10);

// new plan should be generated, expect 1, 1, 0
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from test_gen where (a + ? > ? and a + ? < ?) or (a + ? > ? and a + ? < ?) or (a + ? + b + ? > ?) or (a + ? + b + ? < ?)';
hit_count
4
