alter system flush plan cache global;
alter system set large_query_threshold = '1s';
select effective_tenant();
effective_tenant()
sys
create table test_gen (a bigint, b bigint, c bigint,
d bigint as (a + 1), e bigint as (a + 2 + b + 3), f bigint as (4 + 5 + 6 + 7),
index idx_d(d), index idx_e(e), index idx_f(f));
************************************ Case 1 Single const param *****************************************

select a from test_gen where a + 1 > 0;

explain select a from test_gen where a + 1 > 0;
Query Plan
===========================================================
|ID|OPERATOR        |NAME           |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------
|0 |TABLE RANGE SCAN|test_gen(idx_d)|1       |7           |
===========================================================
Outputs & filters:
-------------------------------------
  0 - output([test_gen.a]), filter(nil), rowset=16
      access([test_gen.__pk_increment], [test_gen.a]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([test_gen.d], [test_gen.__pk_increment]), range(0,MAX ; MAX,MAX), 
      range_cond([test_gen.d > 0])

// expect 0
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select a from test_gen where a + ? > ?';
hit_count
0

