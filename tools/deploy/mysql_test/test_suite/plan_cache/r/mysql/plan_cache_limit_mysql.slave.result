alter system flush plan cache global;
drop table if exists t_limit;
result_format: 4

create table t_limit(c1 int, c2 int);
insert into t_limit values(3,3),(3,1),(3,2),(1,3),(1,1),(1,2),(2,3),(2,1),(2,2);

################################ test for topn sort exchange simple sort ##########################
explain_protocol: 1
EXPLAIN BASIC select * from t_limit order by c1, c2 limit 5;
Query Plan
==================================
|ID|OPERATOR             |NAME   |
----------------------------------
|0 |EXCHANGE IN REMOTE   |       |
|1 |└─EXCHANGE OUT REMOTE|       |
|2 |  └─TOP-N SORT       |       |
|3 |    └─TABLE FULL SCAN|t_limit|
==================================
Outputs & filters:
-------------------------------------
  0 - output([t_limit.c1], [t_limit.c2]), filter(nil)
  1 - output([t_limit.c1], [t_limit.c2]), filter(nil)
  2 - output([t_limit.c1], [t_limit.c2]), filter(nil), rowset=16
      sort_keys([t_limit.c1, ASC], [t_limit.c2, ASC]), topn(5)
  3 - output([t_limit.c1], [t_limit.c2]), filter(nil), rowset=16
      access([t_limit.c1], [t_limit.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t_limit.__pk_increment]), range(MIN ; MAX)always true
select * from t_limit order by c1, c2 limit 5;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    1 |
|    1 |    2 |
|    1 |    3 |
|    2 |    1 |
|    2 |    2 |
+------+------+
