result_format: 4
alter system set plan_cache_evict_interval = 1;
alter system flush plan cache global;



select USED > 0 as result from oceanbase.V$OB_MEMORY where context = 'OB_SQL_PLAN_CACHE';
+--------+
| result |
+--------+
|      1 |
+--------+

select mem_limit from oceanbase.V$OB_PLAN_CACHE_STAT;
+-----------+
| mem_limit |
+-----------+
|  40265315 |
+-----------+


//change plan cache system variables
set global ob_plan_cache_evict_high_percentage = 10;
set global ob_plan_cache_evict_low_percentage = 5;
set global ob_plan_cache_percentage = 1;

//expect 10 5 1
show variables like 'ob_plan_cache%';
Variable_name	Value
ob_plan_cache_evict_high_percentage	10
ob_plan_cache_evict_low_percentage	5
ob_plan_cache_percentage	1


//expect 1 1 1; prove evict happened
select @mem_limit_evict < @mem_limit;
+-------------------------------+
| @mem_limit_evict < @mem_limit |
+-------------------------------+
|                             1 |
+-------------------------------+
select @mem_used_evict < @mem_used;
+-----------------------------+
| @mem_used_evict < @mem_used |
+-----------------------------+
|                           1 |
+-----------------------------+
select @plan_num_evict < @plan_num;
+-----------------------------+
| @plan_num_evict < @plan_num |
+-----------------------------+
|                           1 |
+-----------------------------+

//测试major freeze后失效plan是否全被淘汰
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
//expected 0
select /*+no_rewrite,use_plan_cache(none)*/ count(query_sql) as plan_num from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where query_sql not like '%__all%';
+----------+
| plan_num |
+----------+
|        0 |
+----------+

set global ob_plan_cache_evict_high_percentage = 90;
set global ob_plan_cache_evict_low_percentage = 50;
set global ob_plan_cache_percentage = 10;
// sql exec done

//expected 0
select mem_hold < 4 * 6000000 from oceanbase.V$OB_PLAN_CACHE_STAT where tenant_id = 1002;
+------------------------+
| mem_hold < 4 * 6000000 |
+------------------------+
|                      0 |
+------------------------+
//测试flush plan cache后plan全被淘汰，内存全部释放
set global ob_enable_plan_cache = false;
alter system flush plan cache global;
//expected 0,1,0
select /*+ use_plan_cache(none)*/ mem_hold < 4 * 6000000 from oceanbase.V$OB_PLAN_CACHE_STAT where tenant_id = 1002;
+------------------------+
| mem_hold < 4 * 6000000 |
+------------------------+
|                      1 |
+------------------------+

drop table t1, t2, t3, type_t, emp, acs_test, dist_t;
drop database xy_db;
drop tablegroup xy_group;
set global ob_plan_cache_evict_high_percentage = 90;
set global ob_plan_cache_evict_low_percentage = 50;
set global ob_plan_cache_percentage = 5;
set global ob_enable_plan_cache = true;
alter system set plan_cache_evict_interval = 30;
