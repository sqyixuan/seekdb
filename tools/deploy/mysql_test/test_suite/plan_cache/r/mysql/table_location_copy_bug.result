drop table if exists promo_user_data;
set ob_query_timeout = 100000000;
CREATE TABLE `promo_user_data` (
`user_id` varchar(1024) NOT NULL COMMENT '用户ID',
`biz_type` varchar(4) NOT NULL COMMENT '业务类型',
`crowd_id` varchar(32) NOT NULL COMMENT '人群ID',
`row_num` bigint(20) NOT NULL COMMENT '行号',
`ext_info` varchar(2048) DEFAULT NULL COMMENT '扩展数据',
`timer_task_id` bigint(20) DEFAULT NULL COMMENT '定时任务ID',
`gmt_create` timestamp NOT NULL COMMENT '创建时间',
`gmt_modified` timestamp NOT NULL COMMENT '修改时间',
`gmt_expired` timestamp NULL DEFAULT NULL COMMENT '人群过期时间',
`negative_modify_time` bigint(20) DEFAULT NULL COMMENT '修改时间转换为毫秒后取反，用于根据修改时间降序排序',
`p_crowd` varchar(4) GENERATED ALWAYS AS (substr(`crowd_id`,2,4)) VIRTUAL COMMENT '一级分区',
`p_uid` varchar(2) GENERATED ALWAYS AS (substr(`user_id`,-3,2)) VIRTUAL COMMENT '二级分区',
PRIMARY KEY (`user_id`, `biz_type`, `crowd_id`, `row_num`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'lz4_1.0' REPLICA_NUM = 5 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
partition by list columns(p_crowd) subpartition by key(p_uid) subpartitions 100
(partition P202001 values in ('2001'),
partition P202002 values in ('2002'),
partition P202003 values in ('2003'),
partition P202004 values in ('2004'),
partition P202005 values in ('2005'),
partition P202006 values in ('2006'),
partition P202007 values in ('2007'),
partition P202008 values in ('2008'),
partition P202009 values in ('2009'),
partition P202010 values in ('2010'),
partition P202011 values in ('2011'),
partition P202012 values in ('2012'),
partition P202101 values in ('2101'),
partition P202102 values in ('2102'),
partition P202103 values in ('2103'),
partition P202104 values in ('2104'),
partition P202105 values in ('2105'),
partition P202106 values in ('2106'),
partition P202107 values in ('2107'),
partition P202108 values in ('2108'),
partition P202109 values in ('2109'),
partition P202110 values in ('2110'),
partition P202111 values in ('2111'),
partition P202112 values in ('2112'));
select/*+parallel(20))*/ * from promo_user_data;
user_id	biz_type	crowd_id	row_num	ext_info	timer_task_id	gmt_create	gmt_modified	gmt_expired	negative_modify_time	p_crowd	p_uid

select /*+ QUERY_TIMEOUT(200000) */ user_id, biz_type, crowd_id, row_num, ext_info, timer_task_id, gmt_create, gmt_expired from promo_user_data where user_id='2088531073816790' and biz_type='1'   and crowd_id in ('0200819224233560') limit 1;
user_id	biz_type	crowd_id	row_num	ext_info	timer_task_id	gmt_create	gmt_expired
