result_format: 4

alter system flush plan cache global;
alter system set enable_auto_leader_switch=false;

set ob_trx_timeout = 1000000000000;
set autocommit = 0;

drop table if exists t;
create table t (pk int primary key, a int);

create index idx_t on t(a) global partition by hash(a) partitions 2;

insert into t values (1,1), (2,2);

select /*+ index(t idx_t)*/* from t where a in (1, 1);
+----+------+
| pk | a    |
+----+------+
|  1 |    1 |
+----+------+
select /*+ index(t idx_t)*/* from t where a in (2, 2);
+----+------+
| pk | a    |
+----+------+
|  2 |    2 |
+----+------+
select /*+ index(t idx_t)*/* from t where a in (1, 2);
+----+------+
| pk | a    |
+----+------+
|  1 |    1 |
|  2 |    2 |
+----+------+
select /*+ index(t idx_t)*/* from t where a in (1, 2);
+----+------+
| pk | a    |
+----+------+
|  1 |    1 |
|  2 |    2 |
+----+------+

explain select /*+ index(t idx_t)*/* from t where a in (1, 1);
Query Plan
===================================================
|ID|OPERATOR              |NAME    |EST. ROWS|COST|
---------------------------------------------------
|0 |DISTRIBUTED TABLE SCAN|t(idx_t)|1        |46  |
===================================================

Outputs & filters: 
-------------------------------------
  0 - output([t.pk], [t.a]), filter(nil), 
      access([t.pk], [t.a]), partitions(p1)

explain select /*+ index(t idx_t)*/* from t where a in (2, 2);
Query Plan
===================================================
|ID|OPERATOR              |NAME    |EST. ROWS|COST|
---------------------------------------------------
|0 |DISTRIBUTED TABLE SCAN|t(idx_t)|1        |46  |
===================================================

Outputs & filters: 
-------------------------------------
  0 - output([t.pk], [t.a]), filter(nil), 
      access([t.pk], [t.a]), partitions(p0)

explain select /*+ index(t idx_t)*/* from t where a in (1, 2);
Query Plan
===================================================
|ID|OPERATOR              |NAME    |EST. ROWS|COST|
---------------------------------------------------
|0 |DISTRIBUTED TABLE SCAN|t(idx_t)|1        |92  |
===================================================

Outputs & filters: 
-------------------------------------
  0 - output([t.pk], [t.a]), filter(nil), 
      access([t.pk], [t.a]), partitions(p[0-1])


// EXPECT (1, 1), (1, 3)
select hit_count, type from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select /*+ index(t idx_t)*/* from t where a in (?, ?)';
+-----------+------+
| hit_count | type |
+-----------+------+
|         3 |    1 |
+-----------+------+


