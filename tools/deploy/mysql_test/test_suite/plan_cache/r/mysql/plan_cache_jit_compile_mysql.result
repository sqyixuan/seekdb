alter system flush plan cache;
alter system set large_query_threshold='1s';
select effective_tenant();
effective_tenant()
mysql
***************** TEST USING SESSION VARIABLE *****************

set ob_enable_jit='FORCE';

select * from t where a + 1 < 4;
a	b
1	hello
2	hi

// expect (1, 0)
select is_use_jit, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where a + ? < ?';
is_use_jit	hit_count
1	0

select * from t where a + 2 < 4;
a	b
1	hello

// expect (1, 1)
select is_use_jit, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where a + ? < ?';
is_use_jit	hit_count
1	1

set ob_enable_jit='OFF';
select * from t where a + 1 < 4;
a	b
1	hello
2	hi

// expect (1,1), (0, 0)
select is_use_jit, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where a + ? < ?';
is_use_jit	hit_count
1	1
0	0

***************** TEST USING HINT *****************

select /*+ USE_JIT(FORCE)*/* from t where a + 1 < 4;
a	b
1	hello
2	hi

// expect (1, 0)
select is_use_jit, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select /*+ USE_JIT(FORCE)*/* from t where a + ? < ?';
is_use_jit	hit_count
1	0

select /*+ USE_JIT(OFF)*/* from t where a + 1 < 4;
a	b
1	hello
2	hi

// expect (0, 0)
select is_use_jit, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select /*+ USE_JIT(OFF)*/* from t where a + ? < ?';
is_use_jit	hit_count
0	0

set ob_enable_jit='FORCE';

select /*+ USE_JIT(FORCE)*/* from t where a + 1 < 4;
a	b
1	hello
2	hi

// hint's priviledge is higher, expect (1, 0), (1, 0)
select is_use_jit, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select /*+ USE_JIT(FORCE)*/* from t where a + ? < ?';
is_use_jit	hit_count
1	0
1	0
