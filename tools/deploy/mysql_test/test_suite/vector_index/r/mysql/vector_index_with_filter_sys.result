====================== basic test #1 =======================
============= create vec index on existing table ===========
CREATE TABLE vec_table (
id int,
c2 vector(10),
primary key(id));
create vector index vec_idx1 on vec_table(c2) with (distance=l2, type=hnsw, lib=vsag);
===== vec_table columns =============
column_id	column_name
16	id
17	c*
18	__vid_*
19	__type_*_*
20	__vector_*_*
21	__scn_*_*
22	__key_*_*
23	__data_*_*
===== vec index aux tables =====
table_name
__idx_DATA_TABLE_ID_rowkey_vid_table
__idx_DATA_TABLE_ID_vec_idx1
__idx_DATA_TABLE_ID_vid_rowkey_table
__idx_DATA_TABLE_ID_vec_idx1_index_id_table
__idx_DATA_TABLE_ID_vec_idx1_index_snapshot_data_table
===== vec_table rowkey_vid cols ===
column_id	column_name
16	id
18	__vid_*
===== vec_table vid rowkey cols ===
column_id	column_name
16	id
18	__vid_*
===== vec_table delta buf cols ======
column_id	column_name
18	__vid_*
19	__type_*_*
20	__vector_*_*
===== vec_table index id cols ===
column_id	column_name
18	__vid_*
19	__type_*_*
20	__vector_*_*
21	__scn_*_*
===== vec_table snapshot cols ===
column_id	column_name
16	id
18	__vid_*
20	__vector_*_*
22	__key_*_*
23	__data_*_*
DROP TABLE IF EXISTS vec_table;
alter system set ob_vector_memory_limit_percentage = 0;
