partitioned_rows
1
drop table t_partitioned;
drop table if exists t1, t2, lob_t1, t1_json;
create table t1_async(
pk int primary key,
doc_content varchar(1000),
long_text longtext,
vector index idx_async_doc(doc_content) with (distance=l2, type=hnsw, model=ob_embed, dim=1024, sync_mode=async, sync_interval=10s)
);
insert into t1_async values(1, 'Async sync document 1', repeat('async1', 1000));
insert into t1_async values(2, 'Async sync document 2', repeat('async2', 2000));
insert into t1_async values(3, 'Async sync document 3', repeat('async3', 3000));
update t1_async set doc_content='Updated async document', long_text=repeat('updated_async', 1500) where pk = 1;
delete from t1_async where pk = 2;
drop table t1_async;
alter system set _enable_semantic_index=false;
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT ('ob_embed_endpoint');
call DBMS_AI_SERVICE.DROP_AI_MODEL ('ob_embed');
