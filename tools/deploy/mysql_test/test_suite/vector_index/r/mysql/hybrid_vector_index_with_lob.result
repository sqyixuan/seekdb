create table lob_t1(
a int primary key, 
c2 longtext,
doc_content varchar(1000),
vector index idx_lob_doc(doc_content) with (distance=l2, type=hnsw, model=ob_embed, dim=1024, sync_mode=immediate)
) merge_engine = delete_insert;
insert into lob_t1 values(123456, repeat('1', 1024*10), 'Merge engine document with LOB data');
update lob_t1 set c2 = repeat('2', 1024*10), doc_content='Updated merge engine document' where a = 123456;
CREATE TABLE t1_json(
pk int primary key, 
json_col_1 JSON,
doc_content varchar(1000),
vector index idx_json_doc(doc_content) with (distance=l2, type=hnsw, model=ob_embed, dim=1024, sync_mode=immediate)
) merge_engine = delete_insert;
SET @a:=CONCAT('[',REPEAT('"a",',200000),'"a"]');
INSERT INTO t1_json VALUES(3, @a, 'JSON document with large array for vector search testing');
select md5(json_col_1) from t1_json where pk = 3;
md5(json_col_1)
fb40a1efd15a961c607b7e9d3169b13e
SET @b:=CONCAT('[',REPEAT('"b",',200000),'"b"]');
update t1_json set json_col_1 = @b, doc_content='Updated JSON document with new array data' where pk = 3;
select md5(json_col_1) from t1_json where pk = 3;
md5(json_col_1)
29c9699a10efa5f60eae88b4a89b3211
添加新的LOB列
alter table t1 add column new_text text, add column new_blob blob;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `pk` int(11) NOT NULL,
  `tiny_text` tinytext DEFAULT NULL,
  `tiny_blob` tinyblob DEFAULT NULL,
  `text_type` text DEFAULT NULL,
  `blob_type` blob DEFAULT NULL,
  `medium_text` mediumtext DEFAULT NULL,
  `medium_blob` mediumblob DEFAULT NULL,
  `long_text` longtext DEFAULT NULL,
  `long_blob` longblob DEFAULT NULL,
  `doc_content` varchar(1000) DEFAULT NULL,
  `new_text` text DEFAULT NULL,
  `new_blob` blob DEFAULT NULL,
  PRIMARY KEY (`pk`),
  VECTOR KEY `idx_doc` (`doc_content`) WITH (DISTANCE=L2, TYPE=HNSW, MODEL=OB_EMBED, DIM=1024, SYNC_MODE=IMMEDIATE, LIB=VSAG, M=16, EF_CONSTRUCTION=200, EF_SEARCH=64, SYNC_INTERVAL=10s) BLOCK_SIZE 16384
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
insert into t1 values (10, 'test', 'test', 'test', 'test', 'test', 'test', 'test', 'test', 'New LOB columns test document', 'new_text_content', 'new_blob_content');
select md5(new_text), md5(new_blob) from t1 where pk = 10;
md5(new_text)	md5(new_blob)
8de959f311c9434be65b5b856246ef8d	9cc6a080e6e551271f393f5ab43fb4df
