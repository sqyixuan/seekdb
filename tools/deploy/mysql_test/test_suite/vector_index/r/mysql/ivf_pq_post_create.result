bugfix: 2025011700107043379
SET @geo_py = 'POLYGON((0 0, 5 0, 0 5, 5 5, 0 0))';
DROP TABLE IF EXISTS vec_t1;
create table vec_t1(c1 int, c2 int, g GEOMETRY NOT NULL SRID 0, v vector(3), 
primary key(c1), SPATIAL INDEX idxg (g),
vector index idxv(v) with (distance=l2, type=hnsw, lib=vsag));
insert into vec_t1 values(1, 1, ST_GeomFromText('POINT(0 0)'), '[0.203846,0.205289,0.880265]');
insert into vec_t1 values(2, 2, ST_GeomFromText('POINT(0 1)'), '[0.226980,0.579658,0.933939]');
insert into vec_t1 values(3, 3, ST_GeomFromText('POINT(1 0)'), null);
insert into vec_t1 values(4, 4, ST_GeomFromText('POINT(1 1)'), '[0.442633,0.637534,0.633993]');
insert into vec_t1 values(5, 5, ST_GeomFromText('POINT(0 3)'), '[0.190118,0.959676,0.796483]');
insert into vec_t1 values(6, 6, ST_GeomFromText('POINT(3 0)'), '[0.710370,0.007130,0.710913]');
insert into vec_t1 values(7, 7, ST_GeomFromText('POINT(3 3)'), '[0.238120,0.289662,0.970101]');
insert into vec_t1 values(8, 8, ST_GeomFromText('POINT(0 6)'), '[0.168794,0.567442,0.062338]');
insert into vec_t1 values(9, 9, ST_GeomFromText('POINT(6 0)'), '[0.901419,0.676738,0.122339]');
insert into vec_t1 values(10, 10, ST_GeomFromText('POINT(6 6)'), '[0.563644,0.811224,0.175574]');
drop index idxv on vec_t1;
create vector index idxv on vec_t1(v) with (distance=l2, type=ivf_pq, lib=ob,m=1);
SELECT /*+index(vec_t1 idxg) */c1, ST_AsText(g) FROM vec_t1 WHERE ST_Intersects(g, ST_GeomFromText(@geo_py)) or v is not null
ORDER BY l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
