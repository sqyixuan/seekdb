  PRIMARY KEY (`c2`, `c6`, `c1`),
  VECTOR KEY `idx2` (`c3`) WITH (DISTANCE=L2, TYPE=HNSW_SQ, EXTRA_INFO_MAX_SIZE=1, LIB=VSAG, M=16, EF_SEARCH=64, EF_CONSTRUCTION=200) BLOCK_SIZE 16384
