# Vector Index hgraph Test
drop table if exists hgraph_vecindex_suite_table_test;
drop table if exists t1;
alter system set ob_vector_memory_limit_percentage = 44;
create table t1 (c1 int, c2 vector(3), primary key(c1));
create table hgraph_vecindex_suite_table_test (c1 int auto_increment, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=INNER_PRODUCT, type=hnsw_bq, lib=vsag));
drop table hgraph_vecindex_suite_table_test;
create table hgraph_vecindex_suite_table_test (c1 int auto_increment, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=COSINE, type=hnsw_bq, lib=vsag));
drop table hgraph_vecindex_suite_table_test;
create vector index vec_idx1 on t1(c2) with (distance=inner_product,type=hnsw_bq,lib=vsag);
drop index vec_idx1 on t1;
create vector index vec_idx1 on t1(c2) with (distance=cosine,type=hnsw_bq,lib=vsag);
drop index vec_idx1 on t1;
create table hgraph_vecindex_suite_table_test (c1 int auto_increment, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw_bq, lib=vsag));
insert into /*ob_query_time=100000000*/ hgraph_vecindex_suite_table_test(c2) select c2 from t1 limit 2000;
set ob_enable_index_direct_select = 1;
select * from hgraph_vecindex_suite_table_test order by l2_distance(c2, [0,0,0]) APPROXIMATE limit 5;
insert into /*ob_query_time=100000000*/ hgraph_vecindex_suite_table_test(c2) select c2 from t1 where c1 > 2000 and c1 <= 4000;
insert into /*ob_query_time=100000000*/ hgraph_vecindex_suite_table_test(c2) select c2 from t1 where c1 > 4000 and c1 <= 6000;
insert into /*ob_query_time=100000000*/ hgraph_vecindex_suite_table_test(c2) select c2 from t1 where c1 > 6000 and c1 <= 8000;
insert into /*ob_query_time=100000000*/ hgraph_vecindex_suite_table_test(c2) select c2 from t1 where c1 > 8000 and c1 <= 10000;
insert into /*ob_query_time=100000000*/ hgraph_vecindex_suite_table_test(c2) select c2 from t1 where c1 > 10000 and c1 <= 12000;
select * from hgraph_vecindex_suite_table_test order by l2_distance(c2, [0,0,0]) APPROXIMATE limit 5;
select count(*) from hgraph_vecindex_suite_table_test;
count(*)
12000
call dbms_vector.rebuild_index('idx1','hgraph_vecindex_suite_table_test','c2', 0);
result
1
