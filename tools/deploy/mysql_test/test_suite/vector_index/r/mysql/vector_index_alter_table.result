create table t_vec(c1 int, c2 int, c3 vector(3), primary key(c1,c2), vector index idx1(c3) with (distance=l2, type=hnsw)) partition by range(c1) (partition p0 values less than (10));
alter table t_vec add partition (partition p1 values less than (20));
show create table t_vec;
