drop database if exists yjl_vec_post_create;
create database yjl_vec_post_create;
use yjl_vec_post_create;
alter system set ob_vector_memory_limit_percentage = 20;


"======================================= ivfflat basic test ============================================"
drop table if exists t_vec_ivf_flat;
create table t_vec_ivf_flat(c1 int, c2 vector(3));
create vector index ivf_flat_idx on t_vec_ivf_flat(c2) with (distance=l2, type=ivf_flat);
show create table t_vec_ivf_flat;
Table	Create Table
t_vec_ivf_flat	CREATE TABLE `t_vec_ivf_flat` (
  `c1` int(11) DEFAULT NULL,
  `c2` VECTOR(3) DEFAULT NULL,
  VECTOR KEY `ivf_flat_idx` (`c2`) WITH (DISTANCE=L2, TYPE=IVF_FLAT, LIB=OB, NLIST=128, SAMPLE_PER_NLIST=256) BLOCK_SIZE 16384
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
show index from t_vec_ivf_flat;
