drop table if exists t1_vec_bitmap_sync;
drop table if exists t2_vec_bitmap_sync;
alter system set ob_vector_memory_limit_percentage = 20;
create table
create table t1_vec_bitmap_sync(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2_vec_bitmap_sync(c1 int, v1 varchar(2), c2 vector(10), primary key(c1, v1), vector index idx2(c2) with (distance=l2, type=hnsw, lib=vsag));
select
sum(JSON_VALUE(sync_info, '$.incr_cnt')) as check_incr_cnt,
sum(JSON_VALUE(sync_info, '$.vbitmap_cnt')) as check_vbitmap_cnt,
sum(JSON_VALUE(sync_info, '$.snap_cnt')) as check_snap_cnt,
sum(JSON_VALUE(sync_info, '$.sync_fail_cnt')) as check_sync_fail_cnt
from oceanbase.__all_virtual_vector_index_info a, oceanbase.__all_virtual_table b 
where a.data_table_id = b.table_id and b.table_name in ('t1_vec_bitmap_sync', 't2_vec_bitmap_sync');
check_incr_cnt	check_vbitmap_cnt	check_snap_cnt	check_sync_fail_cnt
0	0	0	0
insert data for t1_vec_bitmap_sync
insert into t1_vec_bitmap_sync values(1, '[0.203846,0.205289,0.880265,0.824340,0.615737,0.496899,0.983632,0.865571,0.248373,0.542833]');
check t1_vec_bitmap_sync inc sync 1st
do fast refresh for t1_vec_bitmap_sync
call dbms_vector.refresh_index('idx1', 't1_vec_bitmap_sync', 'c2', 20, 'FAST');
insert more data for t1_vec_bitmap_sync to trigger anther sync_info
check t1_vec_bitmap_sync inc sync 2nd
test multi column rowkey tables
insert into t2_vec_bitmap_sync values(1, 'a', '[0.203846,0.205289,0.880265,0.824340,0.615737,0.496899,0.983632,0.865571,0.248373,0.542833]');
check t2_vec_bitmap_sync inc sync 1st
do fast refresh for t2_vec_bitmap_sync
call dbms_vector.refresh_index('idx2', 't2_vec_bitmap_sync', 'c2', 20, 'FAST');
insert more data for t2_vec_bitmap_sync to trigger anther sync_info
check t2_vec_bitmap_sync inc sync 2nd
check upper sync limit
select
sum(JSON_VALUE(sync_info, '$.incr_cnt')) <= 812 as check_incr_cnt,
sum(JSON_VALUE(sync_info, '$.vbitmap_cnt')) <= 203 as check_vbitmap_cnt,
sum(JSON_VALUE(sync_info, '$.snap_cnt')) <= 812 as check_snap_cnt,
sum(JSON_VALUE(sync_info, '$.sync_total_cnt')) <= 8 as check_sync_total_cnt,
sum(JSON_VALUE(sync_info, '$.sync_fail_cnt')) = 0 as check_sync_fail_cnt
from oceanbase.__all_virtual_vector_index_info a, oceanbase.__all_virtual_table b 
where a.data_table_id = b.table_id and b.table_name in ('t1_vec_bitmap_sync', 't2_vec_bitmap_sync');
check_incr_cnt	check_vbitmap_cnt	check_snap_cnt	check_sync_total_cnt	check_sync_fail_cnt
1	1	1	1	1
drop table t1_vec_bitmap_sync;
drop table t2_vec_bitmap_sync;
select count(*) 
from oceanbase.__all_virtual_vector_index_info a, oceanbase.__all_virtual_table b 
where a.data_table_id = b.table_id and b.table_name in ('t1_vec_bitmap_sync', 't2_vec_bitmap_sync');
count(*)
0
alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;
