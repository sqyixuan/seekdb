CREATE TABLE t1 (id bigint not null AUTO_INCREMENT,js1 json, js2 json, v1 vector(3),v2 vector(3),sv1 sparsevector,sv2 sparsevector, primary key (id),   vector index idx1(v1) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200, extra_info_max_size=512))
partition by range(id) (
