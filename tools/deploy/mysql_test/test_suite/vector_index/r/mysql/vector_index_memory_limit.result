# Vector Index Memory limit
drop table if exists t1,t2;
=========================================== not config memstore_limit_percentage and _memstore_limit_percentage ===========================================
alter system set memstore_limit_percentage = 0;
alter system set _memstore_limit_percentage = 0;
adaptive configure
alter system set ob_vector_memory_limit_percentage = 0;
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, c2 vector(10), primary key(c1));
create vector index vec_idx2 on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
drop table t1;
drop table t2;
alter system set ob_vector_memory_limit_percentage = 10;
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, c2 vector(10), primary key(c1));
create vector index vec_idx2 on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
drop table t1;
drop table t2;
alter system set ob_vector_memory_limit_percentage = 0;
alter system set _memstore_limit_percentage = 0;
alter system set ob_vector_memory_limit_percentage = 70;
=========================================== only config memstore_limit_percentage and not config _memstore_limit_percentage ===========================================
#set memstore_limit_percentage < 85, like 50, vector memory is valid in range "[0, 100-50-15)"
alter system set memstore_limit_percentage = 40;
alter system set _memstore_limit_percentage = 0;
alter system set ob_vector_memory_limit_percentage = 0;
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, c2 vector(10), primary key(c1));
create vector index vec_idx2 on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
drop table t2;
drop table t1;
alter system set ob_vector_memory_limit_percentage = 10;
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, c2 vector(10), primary key(c1));
create vector index vec_idx2 on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
drop table t1;
drop table t2;
alter system set ob_vector_memory_limit_percentage = 0;
alter system set ob_vector_memory_limit_percentage = 70;
#set memstore_limit_percentage > 85 which makes vector memory config not available
alter system set memstore_limit_percentage = 86;
alter system set ob_vector_memory_limit_percentage = 1;
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, c2 vector(10), primary key(c1));
create vector index vec_idx2 on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
drop table t1;
drop table t2;
=========================================== both config memstore_limit_percentage and config _memstore_limit_percentage ===========================================
alter system set memstore_limit_percentage = 90;
alter system set _memstore_limit_percentage = 40;
alter system set ob_vector_memory_limit_percentage = 0;
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, c2 vector(10), primary key(c1));
create vector index vec_idx2 on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
drop table t2;
drop table t1;
alter system set ob_vector_memory_limit_percentage = 44;
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, c2 vector(10), primary key(c1));
create vector index vec_idx2 on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
drop table t1;
drop table t2;
alter system set ob_vector_memory_limit_percentage = 0;
alter system set _memstore_limit_percentage = 0;
alter system set ob_vector_memory_limit_percentage = 45;
alter system set ob_vector_memory_limit_percentage = 0;
=========================================== Memory usage exceeds vector memory limit ===========================================
alter system set ob_vector_memory_limit_percentage = 1;
select vector_mem_limit > 10000000 from oceanbase.__all_virtual_tenant_vector_mem_info;
vector_mem_limit > 10000000
1
1
create table t1 (c1 int, c2 vector(1536)) with column group(each column);
create table t2 (c1 int, c2 vector(1536));
create vector index vec_idx1 on t1(c2) with (distance=l2, type=hnsw, lib=vsag);
ERROR 22000: Using the vsag interface returns an error
create vector index vec_idx1 on t1(c2) with (distance=l2, type=hnsw_sq, lib=vsag);
ERROR 22000: Using the vsag interface returns an error
create vector index vec_idx1 on t1(c2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200, extra_info_max_size=512);
ERROR 22000: Using the vsag interface returns an error
create vector index vec_idx1 on t1(c2) with (distance=l2, type=hnsw_bq, lib=vsag);
ERROR 22000: Using the vsag interface returns an error
create vector index vec_idx1 on t1(c2) with (distance=l2, type=ivf_flat);
ERROR 0A000: create ivf index on table with column store is not supported
create vector index vec_idx1 on t2(c2) with (distance=l2, type=ivf_flat);
select vector_mem_used > 780000, vector_mem_hold, vector_mem_limit > 10000000, vector_mem_detail_info from oceanbase.__all_virtual_tenant_vector_mem_info;
vector_mem_used > 780000	vector_mem_hold	vector_mem_limit > 10000000	vector_mem_detail_info
0	2097152	1	{"rb_used":0, "VectorIndex":{"hold":0 }}
1	2097152	1	{"rb_used":0, "VectorIndex":{"hold":131072 , "child":{"IvfCacheCtx":{"hold":32768 , "child":{"IvfCacheCtx":{"hold":819200 }}}}}}
drop index vec_idx1 on t2;
