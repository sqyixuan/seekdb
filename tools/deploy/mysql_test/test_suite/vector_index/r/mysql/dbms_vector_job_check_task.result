# DBMS VECTOR job check task
SET @@recyclebin = off;
drop table if exists t1;
drop table if exists t2;
drop database if exists shk_new_test;
"=========================== basic ======================="
create table t1(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=hnsw, lib=vsag));
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
refresh_job name is OK
rebuild_job name is OK
"=========================== rename table ======================="
create database if not exists shk_new_test;
rename table t1 to shk_new_test.new_t1;
use shk_new_test;
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
refresh_job name is OK
rebuild_job name is OK
drop table new_t1;
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
"=========================== default: vector index name case ======================="
use test;
drop database if exists shk_new_test;
create table t1(c1 int, c2 vector(3), c3 vector(3), primary key(c1));
create vector index idx1 on t1(c2) with(distance=l2, type=hnsw, lib=vsag);
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
refresh_job name is OK
rebuild_job name is OK
create vector index IDX1 on t1(c3) with(distance=l2, type=hnsw, lib=vsag);
ERROR 42000: Duplicate key name 'IDX1'
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
refresh_job name is OK
rebuild_job name is OK
drop table t1;
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
"=========================== special char ======================="
create table t1(c1 int, c2 vector(3), primary key(c1));
create vector index `idx\n1` on t1(c2) with(distance=l2, type=hnsw, lib=vsag);
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
drop table t1;
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
"=========================== index with the same name in a db ======================="
create table t1(c1 int, c2 vector(3), primary key(c1));
create table t2(c1 int, c2 vector(3), primary key(c1));
create vector index idx on t1(c2) with(distance=l2, type=hnsw, lib=vsag);
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
refresh_job name is OK
rebuild_job name is OK
create vector index idx on t2(c2) with(distance=l2, type=hnsw, lib=vsag);
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 8 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
refresh_job name is OK
rebuild_job name is OK
drop table t1;
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
drop table t2;
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
"=========================== the same index name, the same table name, in different db ======================="
create database if not exists shk_new_test;
create table t1(c1 int, c2 vector(3), primary key(c1));
create vector index idx on t1(c2) with(distance=l2, type=hnsw, lib=vsag);
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
use shk_new_test;
create table t1(c1 int, c2 vector(3), primary key(c1));
create vector index idx on t1(c2) with(distance=l2, type=hnsw, lib=vsag);
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 8 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
refresh_job name is OK
rebuild_job name is OK
refresh_job name is OK
rebuild_job name is OK
drop table t1;
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
use test;
drop database shk_new_test;
refresh_job name is OK
rebuild_job name is OK
drop table t1;
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
"=========================== simple create table with vector index ======================="
use test;
alter system set _enable_parallel_table_creation = false;
create table t1(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=hnsw, lib=vsag));
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
refresh_job name is OK
rebuild_job name is OK
drop table t1;
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 THEN 'TRUE' ELSE 'FALSE' end as res;
res
TRUE
alter system set _enable_parallel_table_creation = true;
