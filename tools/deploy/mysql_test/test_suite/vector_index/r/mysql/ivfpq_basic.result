# 多分区先建混合向量索引
drop table if exists vec_t1;
drop table if exists normal;
drop view if exists vec_view;
CREATE TABLE vec_t1 (c1 int primary key, c3 vector(3) ,c4 vector(10),
VECTOR INDEX idx1(c4)
WITH (distance=l2, type=ivf_pq, m=5),
VECTOR INDEX idx2(c3)
WITH (distance=l2, type=hnsw))
PARTITION BY RANGE(c1) (
PARTITION p0 VALUES less than(10),
PARTITION p1 VALUES less than(20),
PARTITION p2 VALUES less than(MAXVALUE)
);
