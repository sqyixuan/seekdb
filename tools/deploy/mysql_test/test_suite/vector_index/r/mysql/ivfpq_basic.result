################# complex dml operation ##################
DROP TABLE IF EXISTS vec;
DROP TABLE IF EXISTS normal;
DROP VIEW IF EXISTS vec_view;
create table vec(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_pq, m=5));
create table normal(c1 int, c2 vector(10), primary key(c1));
CREATE VIEW vec_view as select * from vec;
