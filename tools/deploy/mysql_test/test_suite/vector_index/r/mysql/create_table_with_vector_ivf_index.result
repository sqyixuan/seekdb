ERROR 0A000: this value of vector index sample_per_nlist is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=ivf_sq8, sample_per_nlist=0));
ERROR 0A000: this value of vector index sample_per_nlist is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=ivf_pq, sample_per_nlist=0));
ERROR 0A000: this value of vector index sample_per_nlist is not supported
