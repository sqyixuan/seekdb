"---------------------------------normal create ---------------------------------------------------------------------------"
drop table if exists t_vec;
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=hnsw, nlist=1));
ERROR 0A000: hnsw vector index setting nlist or sample_per_nlist or nbits is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=hnsw, sample_per_nlist=1));
ERROR 0A000: hnsw vector index setting nlist or sample_per_nlist or nbits is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=hnsw, lib=OB));
ERROR 0A000: hnsw vector index lib name not equal to 'VSAG' is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, lib=vsag, type=ivf_flat));
ERROR 0A000: ivf vector index lib name not equal to 'OB' is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, lib=vsag, type=ivf_sq8));
ERROR 0A000: ivf vector index lib name not equal to 'OB' is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, lib=vsag, type=ivf_pq));
ERROR 0A000: ivf vector index lib name not equal to 'OB' is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, lib=OB, type=ivf_flat, m=100));
ERROR 0A000: ivf vector index param m to be set in ivf_sq8 or ivf_flat is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, lib=OB, type=ivf_sq8, m=100));
ERROR 0A000: ivf vector index param m to be set in ivf_sq8 or ivf_flat is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=ivf_flat, m=100));
ERROR 0A000: ivf vector index param m to be set in ivf_sq8 or ivf_flat is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=ivf_sq8, m=100));
ERROR 0A000: ivf vector index param m to be set in ivf_sq8 or ivf_flat is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=ivf_flat, ef_search=100));
ERROR 0A000: ivf vector index param setting ef_construction or ef_search should or extra_info_max_size is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=ivf_sq8, ef_search=100));
ERROR 0A000: ivf vector index param setting ef_construction or ef_search should or extra_info_max_size is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=ivf_pq, ef_search=100));
ERROR 0A000: ivf_pq vector index param m not set is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=ivf_flat, ef_construction=100));
ERROR 0A000: ivf vector index param setting ef_construction or ef_search should or extra_info_max_size is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=ivf_sq8, ef_construction=100));
ERROR 0A000: ivf vector index param setting ef_construction or ef_search should or extra_info_max_size is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=ivf_pq, ef_construction=100));
ERROR 0A000: ivf_pq vector index param m not set is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=ivf_flat, nlist=0));
