insert into t1 values(9, 9, 2, '[0.901419,0.676738,0.122339]');
insert into t1 values(10, 10, 1, '[0.563644,0.811224,0.175574]');
create vector index idx3 on t1(v) with (distance=l2, type=hnsw, lib=vsag);
create index idx1 on t1(c2);
create index idx2 on t1(c3);
explain select * from t1 where c2 > 5 or c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROX limit 5;
