=== 分区表DML ===
CREATE TABLE t1(id int not null auto_increment, doc varchar(100),
primary key(id),
VECTOR INDEX idx1(doc) WITH (distance=L2,
type=hnsw, dim=1024,
model=ob_embed,
sync_mode=immediate)) organization heap
PARTITION BY RANGE COLUMNS(id)
(
PARTITION p0 VALUES LESS THAN(100),
PARTITION p1 VALUES LESS THAN(200),
PARTITION p2 VALUES LESS THAN(300),
PARTITION p3 VALUES LESS THAN(10000),
PARTITION p4 VALUES LESS THAN MAXVALUE
);
insert into t1 (doc) values('Partition document 1');
insert into t1 (id, doc) values(150, 'Document in partition p1');
insert into t1 (id, doc) values(250, 'Document in partition p2');
insert into t1 (id, doc) values(5000, 'Document in partition p3');
insert into t1 (id, doc) values(10, 'Duplicate id test') on duplicate key update doc = 'Updated in partition';
insert ignore into t1 (id, doc) values(11, 'Ignore test document');
create table t2 (id int primary key, doc varchar(100)) organization heap;
insert into t2 values(99, 'Document from t2 in p0');
insert into t2 values(150, 'Document from t2 in p1');
insert into t1 select * from t2 on duplicate key update doc = concat(t1.doc, ' - merged from t2');
