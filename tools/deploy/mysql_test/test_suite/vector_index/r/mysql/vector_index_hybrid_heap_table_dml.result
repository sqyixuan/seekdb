insert into t3 values(501, 'Another document from t3');
insert into t1(id, doc)
select t2.id, t3.doc
from t2
join t3 on t2.id = t3.id
where t2.id = 500
on duplicate key update doc = concat(t1.doc, ' - complex joined');
