drop table if exists t1 cascade;
drop table if exists doc_table cascade;
create table doc_table(c1 int, vector vector(3), query varchar(255), content varchar(255), vector index idx1(vector) with (distance=l2, type=hnsw, lib=vsag), fulltext idx2(query), fulltext idx3(content));
insert into doc_table values(1, '[1,2,3]', "hello world", "oceanbase Elasticsearch database"),
(2, '[1,2,1]', "hello world, what is your name", "oceanbase mysql database"),
(3, '[1,1,1]', "hello world, how are you", "oceanbase oracle database"),
(4, '[1,3,1]', "real world, where are you from", "postgres oracle database"),
(5, '[1,3,2]', "real world, how old are you", "redis oracle database"),
(6, '[2,1,1]', "hello world, where are you from", "starrocks oceanbase database");
SELECT /*+ opt_param('hidden_column_visible', 'true') */l2_distance(vector, '[1, 2, 3]') as _distance, __pk_increment, query, content, c1, vector, (round((1 / (1 + l2_distance(vector, '[1, 2, 3]'))), 8) * 0.7) as _semantic_score FROM test.doc_table WHERE match(query) against('hello' in boolean mode) OR match(query) against('what' in boolean mode) OR match(query) against('oceanbase' in boolean mode) OR match(query) against('mysql' in boolean mode) OR match(content) against('hello' in boolean mode) OR match(content) against('what' in boolean mode) OR match(content) against('oceanbase' in boolean mode) OR match(content) against('mysql' in boolean mode) ORDER BY _distance APPROXIMATE LIMIT 5;
