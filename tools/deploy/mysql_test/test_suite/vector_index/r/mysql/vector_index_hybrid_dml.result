drop table if exists t1;
create table t1(id int, category int, doc varchar(100), primary key(id), 
vector index idx3(doc) with (distance=l2, type=hnsw, dim=1024, model=ob_embed, sync_mode=immediate));
INSERT INTO t1 (id, doc) VALUES (1, 'aa');
INSERT INTO t1 (id, doc) VALUES (2, 'bb');
