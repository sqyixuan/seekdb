id INT PRIMARY KEY,
doc VARCHAR(100),
VECTOR INDEX idx1(doc) WITH (distance=L2, type=hnsw, dim=1024, model=ob_embed, sync_mode=immediate)
) DEFAULT CHARSET = utf8;
INSERT INTO vector_charset_table VALUES 
(1, 'abc英文空格 中文分号；英文分号;全角空格　全角逗号，等');
SELECT * FROM vector_charset_table WHERE id = 1;
id	doc
1	abc英文空格 中文分号；英文分号;全角空格　全角逗号，等
