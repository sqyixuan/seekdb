drop table if exists t1;
CREATE TABLE t1 (`pk_id` varchar(20) NOT NULL, `doc_data` varchar(100) DEFAULT NULL,
PRIMARY KEY (`pk_id`),
VECTOR KEY `hybrid_idx` (`pk_id`) WITH (DISTANCE = L2, LIB = VSAG, TYPE = HNSW, MODEL = OB_EMBED, DIM = 1024, SYNC_MODE = ASYNC, 
SYNC_INTERVAL = 10S, M=16, EF_CONSTRUCTION=200, EF_SEARCH=64) BLOCK_SIZE 16384
) ORGANIZATION=HEAP;
