=== 存储过程 ===
create procedure process(IN inc1 INT, IN inc2 INT)
begin
DECLARE t2id INT;
select id into t2id
from t2
where id = inc1;
if t2id = inc2 then
update t1
set doc = concat(doc, ' - procedure')
where id > 10000;
else
insert into t1 select * from t2 where t2.id >= 505 on duplicate key update doc = concat(t1.doc, ' - procedure merged');
end if;
end;
//
CALL process(500, 500);
CALL process(500, 501);
drop procedure process;
drop table t1, t2, t3;
