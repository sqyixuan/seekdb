insert into t2 values(150, 'Document from t2 in p1');
insert into t1 select * from t2 on duplicate key update doc = concat(t1.doc, ' - merged from t2');
update t1 set doc = 'Updated partition document' where id = 150;
update t1 set doc = concat(doc, ' - partition modified') where id > 100;
delete from t1 where id <= 10;
select distinct id from t1;
