# DBMS VECTOR job concurrency
SET @@recyclebin = off;
alter system set debug_sync_timeout = '100000s';
SET @@recyclebin = off;
drop database if exists shk_vec;
create database shk_vec;
use shk_vec;
drop table if exists t1;
create table t1(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=hnsw, lib=vsag));
insert into t1 values(21, '[0.748479,0.276979,0.555195]'), (22, '[0.748479,0.276979,0.555195]'),(23, '[0.748479,0.276979,0.555195]'),(24, '[0.748479,0.276979,0.555195]'),(25, '[0.748479,0.276979,0.555195]'),(26, '[0.748479,0.276979,0.555195]'),(27, '[0.748479,0.276979,0.555195]'),(28, '[0.748479,0.276979,0.555195]'),(29, '[0.748479,0.276979,0.555195]'),(30, '[0.748479,0.276979,0.555195]'),(31, '[0.748479,0.276979,0.555195]'),(32, '[0.748479,0.276979,0.555195]'),(33, '[0,0,0]'),(34, '[0.748479,0.276979,0.555195]'),(35, '[0.748479,0.276979,0.555195]'),(36, '[0,0,0]');
SET @@recyclebin = off;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_DBMS_VECTOR_REFRESH wait_for signaldbms execute 10000';
SET @@recyclebin = off;
use shk_vec;
call dbms_vector.refresh_index('idx1','t1','',0,'FAST');
SET @@recyclebin = off;
use shk_vec;
SELECT c1 from t1 order by l2_distance(c2, [0,0,0]) APPROXIMATE limit 4;
c1
