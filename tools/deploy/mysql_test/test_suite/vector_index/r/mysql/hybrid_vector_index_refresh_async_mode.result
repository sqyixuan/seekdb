CREATE TABLE t1 (col1 INT NOT NULL,col2 varchar(10000),col3 INT NOT NULL,primary key(col1,col3),
vector index hybrid_index(col2) with (distance=l2, type=hnsw, lib=vsag, model=ob_embed, dim=1024, sync_mode=async, sync_interval=100s)) organization heap
PARTITION BY RANGE COLUMNS(col1)
SUBPARTITION BY RANGE columns(col3)
SUBPARTITION TEMPLATE 
(SUBPARTITION mp0 VALUES LESS THAN(1000),
SUBPARTITION mp1 VALUES LESS THAN(2000),
SUBPARTITION mp2 VALUES LESS THAN(4000)
)
(PARTITION p0 VALUES LESS THAN(100),
PARTITION p1 VALUES LESS THAN(200),
PARTITION p2 VALUES LESS THAN(400)
);
insert into t1 values(300,repeat('m',10000),3000);
call dbms_vector.refresh_index('hybrid_index','t1','col2', 0);
