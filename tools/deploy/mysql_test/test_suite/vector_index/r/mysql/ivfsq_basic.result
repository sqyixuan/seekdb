VECTOR INDEX vector_idx1(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=12, ef_search=40),
VECTOR INDEX vector_idx2(c4)
WITH (distance=l2, type=ivf_sq8));
