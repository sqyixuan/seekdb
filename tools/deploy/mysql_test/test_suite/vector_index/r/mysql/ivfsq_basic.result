################# complex dml operation ##################
DROP TABLE IF EXISTS vec;
DROP TABLE IF EXISTS normal;
DROP VIEW IF EXISTS vec_view;
create table vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_sq8));
create table normal(c1 int, c2 vector(3), primary key(c1));
CREATE VIEW vec_view as select * from vec;
INSERT INTO vec values (1, '[1,2,3]'), (2, '[3,4,5]');
INSERT INTO normal values (1, '[1,2,3]'), (2, '[3,4,5]');
insert into vec values (1, '[1,2,3]') ON DUPLICATE KEY UPDATE c2 = '[1,2,3]';
insert into normal values (1, '[1,2,3]') ON DUPLICATE KEY UPDATE c2 = '[1,2,3]';
replace into vec (c1, c2) values (1, '[1,2,3]');
replace into normal (c1, c2) values (1, '[1,2,3]');
insert into vec_view values (3, '[5,6,7]'), (4, '[7,8,9]');
insert into normal (c1, c2) values (3, '[1,2,3]');
select * from vec_view;
c1	c2
1	[1,2,3]
2	[3,4,5]
3	[5,6,7]
4	[7,8,9]
select * from normal;
c1	c2
1	[1,2,3]
2	[3,4,5]
3	[1,2,3]
ERROR 22000: Invalid data type for the operation
update vec join normal on vec.c1 = normal.c1 set vec.c2 = '[7,8,9]', normal.c2 = '[9,10,11]';
select * from vec_view;
c1	c2
1	[7,8,9]
2	[7,8,9]
3	[7,8,9]
4	[7,8,9]
select * from normal;
c1	c2
1	[9,10,11]
2	[9,10,11]
3	[9,10,11]
ERROR 22000: Invalid data type for the operation
update vec join normal on vec.c1 = normal.c1 set vec.c2 = '[7,8,9]';
update vec join normal on vec.c1 = normal.c1 set normal.c2 = vec.c2;
select * from normal;
c1	c2
1	[7,8,9]
2	[7,8,9]
3	[7,8,9]
select * from vec;
c1	c2
1	[7,8,9]
2	[7,8,9]
3	[7,8,9]
4	[7,8,9]
ERROR 22000: Invalid data type for the operation
update vec_view join normal on vec_view.c1 = normal.c1 set vec_view.c2 = '[7,8,9]', normal.c2 = '[9,10,11]';
update vec_view set c2 = '[7,8,9]';
select * from vec;
c1	c2
1	[7,8,9]
2	[7,8,9]
3	[7,8,9]
4	[7,8,9]
select * from vec_view;
c1	c2
1	[7,8,9]
2	[7,8,9]
3	[7,8,9]
4	[7,8,9]
ERROR 22000: Invalid data type for the operation
delete vec, normal from vec join normal on vec.c1 = normal.c1;
delete vec from vec join normal on vec.c1 = normal.c1;
delete vec from vec join normal on vec.c1 = normal.c1;
delete normal from vec_view join normal on vec_view.c1 = normal.c1 and 1=0;
delete from vec_view where c2 = '[7,8,9]';
drop table vec;
drop table normal;
drop view vec_view;
drop table if exists vec_t1;
CREATE TABLE vec_t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c2) 
WITH (distance=l2, type=ivf_sq8));
insert into vec_t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into vec_t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into vec_t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into vec_t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into vec_t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
update vec_t1 set c1 = 10 where c3 is null;
drop table vec_t1;
drop table if exists vec_t1;
create table vec_t1(c1 int, c2 vector(10) not null, primary key(c1));
insert ignore into vec_t1 values(1, null);
ERROR 23000: Column 'c2' cannot be null
drop table vec_t1;
drop table if exists vec_t1;
create table vec_t1(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=L2, type=ivf_sq8));
insert into vec_t1 values(1, [1,1,1]);
select c2,123 from vec_t1 for update;
c2	123
[1,1,1]	123
select /*+ opt_param('rowsets_enabled', 'false') */ c2,123 from vec_t1 for update;
c2	123
[1,1,1]	123
drop table vec_t1;
# 单分区先建混合向量索引
drop table if exists vec_t1;
CREATE TABLE vec_t1 (c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX idx1(c4)
WITH (distance=l2, type=ivf_sq8),
VECTOR INDEX idx2(c3)
WITH (distance=l2, type=hnsw));
insert into vec_t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into vec_t1(c1,c2,c3,c4) values(2,'[2,1,2]','[2,2,2]','[2,3,2]');
insert into vec_t1(c1,c2,c3,c4) values(3,'[3,1,2]','[3,2,2]','[3,3,2]');
insert into vec_t1(c1,c2,c3,c4) values(4,'[4,1,2]','[5,2,3]','[4,4,4]');
insert into vec_t1(c1,c2,c3,c4) values(5,'[5,1,2]','[5,2,3]','[5,5,5]');
insert ignore into vec_t1(c1,c2,c3,c4) values(5,'[5,1,2]','[4,3,2]','[5,5,5]');
update vec_t1 set c4 = '[2,2,2]' where c1 = 2;
insert into vec_t1(c1,c2,c3,c4) values(2,'[2,1,2]','[2,2,2]','[2,3,2]') ON DUPLICATE KEY UPDATE c4 = '[9,8,7]';
delete from vec_t1 where c1 = 3;
insert into vec_t1(c1,c2,c3,c4) values(3,'[2,1,2]','[2,2,2]','[2,3,2]') ON DUPLICATE KEY UPDATE c3 = '[1,1,1]';
update vec_t1 set c4 = '[1,2,3]' where c1 = 1;
drop table vec_t1;
# 多分区先建混合向量索引
drop table if exists vec_t1;
drop table if exists normal;
drop view if exists vec_view;
CREATE TABLE vec_t1 (c1 int primary key, c3 vector(3) ,c4 vector(3),
VECTOR INDEX idx1(c4)
WITH (distance=l2, type=ivf_sq8),
VECTOR INDEX idx2(c3)
WITH (distance=l2, type=hnsw))
PARTITION BY RANGE(c1) (
PARTITION p0 VALUES less than(10),
PARTITION p1 VALUES less than(20),
PARTITION p2 VALUES less than(MAXVALUE)
);
