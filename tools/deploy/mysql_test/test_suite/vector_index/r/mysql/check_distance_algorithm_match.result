      sort_keys([inner_product(t_vec.c5, cast(array(1, 1, 1), ARRAY(18, -1))), ASC]), topn(1)
  1 - output([t_vec.c1], [t_vec.c2], [t_vec.c3], [t_vec.c4], [t_vec.c5], [t_vec.c6]), filter(nil), rowset=16
