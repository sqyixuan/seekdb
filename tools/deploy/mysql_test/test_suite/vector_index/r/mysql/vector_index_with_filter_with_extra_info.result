# Vector Index Filter Test
alter system set ob_vector_memory_limit_percentage = 44;
drop table if exists t1;
create table t1(c1 int, c2 int, c3 vector(3), primary key(c1), vector index idxv(c3) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200, extra_info_max_size=1))
PARTITION BY RANGE (c1) (
PARTITION p0 VALUES LESS THAN (20),
PARTITION p1 VALUES LESS THAN (40),
PARTITION p2 VALUES LESS THAN (70),
PARTITION p3 VALUES LESS THAN (400),
PARTITION pMax VALUES LESS THAN MAXVALUE
);
create index idx1 on t1(c2);
