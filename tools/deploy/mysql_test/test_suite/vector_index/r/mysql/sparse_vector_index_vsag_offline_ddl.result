create table t1(c1 int, c2 sparsevector, c3 varchar(10), c4 int, primary key(c1), vector index idx1(c2) with (distance=inner_product, type=sindi, lib=vsag)) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (100));
