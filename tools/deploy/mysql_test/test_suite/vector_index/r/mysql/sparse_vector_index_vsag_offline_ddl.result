drop database if exists sparse_offline_ddl;
create database sparse_offline_ddl;
use sparse_offline_ddl;
alter system set ob_vector_memory_limit_percentage = 20;


"=========================================== add column ==========================================="
drop table if exists t1;
create table t1(c1 int, c2 sparsevector, primary key(c1), vector index idx1(c2) with (distance=inner_product, type=sindi, lib=vsag));
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` int(11) NOT NULL,
  `c2` SPARSEVECTOR DEFAULT NULL,
  PRIMARY KEY (`c1`),
  VECTOR KEY `idx1` (`c2`) WITH (DISTANCE=INNER_PRODUCT, TYPE=SINDI, LIB=VSAG) BLOCK_SIZE 16384
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
show index from t1;
Table	Non_unique	Key_name	Seq_in_index	Column_name	Collation	Cardinality	Sub_part	Packed	Null	Index_type	Comment	Index_comment	Visible	Expression
t1	0	PRIMARY	1	c1	A	NULL	NULL	NULL		BTREE	available		YES	NULL
t1	1	idx1	1	c2	A	NULL	NULL	NULL	YES	VECTOR	available		YES	NULL
insert into t1 values(1, '{1:0.1, 2:0.2, 3:0.3}');
alter table t1 add column c0 smallint first;
alter table t1 add column c3 tinyint before c1;
alter table t1 add column c4 bigint after c2;
alter table t1 add column c5 int auto_increment;
alter table t1 drop c3, add c6 char(10) default 'a';
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c0` smallint(6) DEFAULT NULL,
  `c1` int(11) NOT NULL,
  `c2` SPARSEVECTOR DEFAULT NULL,
  `c4` bigint(20) DEFAULT NULL,
  `c5` int(11) NOT NULL AUTO_INCREMENT,
  `c6` char(10) DEFAULT 'a',
  PRIMARY KEY (`c1`),
  VECTOR KEY `idx1` (`c2`) WITH (DISTANCE=INNER_PRODUCT, TYPE=SINDI, LIB=VSAG) BLOCK_SIZE 16384
) ORGANIZATION INDEX AUTO_INCREMENT = 2 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
