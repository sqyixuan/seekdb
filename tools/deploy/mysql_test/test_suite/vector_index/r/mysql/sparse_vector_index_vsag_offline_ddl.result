"=========================================== complex case ================================================="
drop table if exists t1;
create table t1(c1 int, c2 sparsevector, c3 int, c4 sparsevector, c5 int, c6 sparsevector, primary key(c1), vector index idx1(c2) with (distance=inner_product, type=sindi, lib=vsag));
insert into t1 values(1, '{1:0.1, 2:0.2, 3:0.3}', 5, '{1:0.1, 2:0.2, 3:0.3}', 7, '{1:0.1, 2:0.2, 3:0.3}');
alter table t1 add column c7 int auto_increment;
create vector index idx2 on  t1(c4) with(distance=inner_product, type=sindi, lib=vsag);
alter table t1 drop column c3;
insert into t1 values(2, '{1:0.1, 2:0.2, 3:0.3}', '{1:0.1, 2:0.2, 3:0.3}', 7, '{1:0.1, 2:0.2, 3:0.3}', 2);
select * from t1 order by negative_inner_product(c2, '{2:1, 3:1}');
c1	c2	c4	c5	c6	c7
1	{1:0.1,2:0.2,3:0.3}	{1:0.1,2:0.2,3:0.3}	7	{1:0.1,2:0.2,3:0.3}	1
2	{1:0.1,2:0.2,3:0.3}	{1:0.1,2:0.2,3:0.3}	7	{1:0.1,2:0.2,3:0.3}	2
alter table t1 modify c5 varchar(20) before c4;
create vector index idx3 on t1(c6) with(distance=inner_product, type=sindi, lib=vsag);
alter table t1 drop column c7;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` int(11) NOT NULL,
  `c2` SPARSEVECTOR DEFAULT NULL,
  `c5` varchar(20) DEFAULT NULL,
  `c4` SPARSEVECTOR DEFAULT NULL,
  `c6` SPARSEVECTOR DEFAULT NULL,
  PRIMARY KEY (`c1`),
  VECTOR KEY `idx1` (`c2`) WITH (DISTANCE=INNER_PRODUCT, TYPE=SINDI, LIB=VSAG) BLOCK_SIZE 16384,
  VECTOR KEY `idx2` (`c4`) WITH (DISTANCE=INNER_PRODUCT, TYPE=SINDI, LIB=VSAG) BLOCK_SIZE 16384,
  VECTOR KEY `idx3` (`c6`) WITH (DISTANCE=INNER_PRODUCT, TYPE=SINDI, LIB=VSAG) BLOCK_SIZE 16384
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
show index from t1;
Table	Non_unique	Key_name	Seq_in_index	Column_name	Collation	Cardinality	Sub_part	Packed	Null	Index_type	Comment	Index_comment	Visible	Expression
t1	0	PRIMARY	1	c1	A	NULL	NULL	NULL		BTREE	available		YES	NULL
t1	1	idx1	1	c2	A	NULL	NULL	NULL	YES	VECTOR	available		YES	NULL
t1	1	idx2	1	c4	A	NULL	NULL	NULL	YES	VECTOR	available		YES	NULL
t1	1	idx3	1	c6	A	NULL	NULL	NULL	YES	VECTOR	available		YES	NULL
select * from t1 order by negative_inner_product(c6, '{2:1, 3:1}');
c1	c2	c5	c4	c6
1	{1:0.1,2:0.2,3:0.3}	7	{1:0.1,2:0.2,3:0.3}	{1:0.1,2:0.2,3:0.3}
2	{1:0.1,2:0.2,3:0.3}	7	{1:0.1,2:0.2,3:0.3}	{1:0.1,2:0.2,3:0.3}
truncate table t1;
insert into t1 values(1, '{1:0.1, 2:0.2, 3:0.3}', 'a', '{1:0.1, 2:0.2, 3:0.3}', '{1:0.1, 2:0.2, 3:0.3}');
alter table t1 drop index idx1;
alter table t1 drop column c5, add c9 varchar(10) default 'cc';
