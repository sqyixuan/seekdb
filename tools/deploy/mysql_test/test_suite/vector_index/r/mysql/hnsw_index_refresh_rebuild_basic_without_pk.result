# Vector Index refresh rebuild Test for tables without primary key
drop table if exists t1;
set ob_enable_index_direct_select = 1;
alter system set ob_vector_memory_limit_percentage = 20;
# 非分区表
create table t1(c1 int, c2 vector(3), c3 vector(5), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create vector index idx2  ON t1 (c3)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=12, ef_search=40);
# 空表刷新
call dbms_vector.refresh_index('idx1', 't1', 'c2', 0, 'FAST');
call dbms_vector.refresh_index('idx1', 't1', 'c2', 0, 'FAST');
call dbms_vector.refresh_index('idx1', 't1', 'c2', 0, 'FAST');
call dbms_vector.refresh_index('idx1', 't1', 'c2', 0, 'FAST');
# 带数据刷新
insert into t1 values(1, '[0.203846,0.205289,0.880265]', '[0.01,-0.02,0,0.12,0.34]');
insert into t1 values(2, '[0.484526,0.669954,0.986755]', '[0.02,-0.03,1,0.567,0.8910]');
# 只刷一个索引，另一个不刷
call dbms_vector.refresh_index('idx1', 't1', 'c2', 0, 'FAST');
call dbms_vector.rebuild_index('idx1','t1','c2', 0);
count(*)
0
count(*)
0
count(*)
1
count(*)
2
count(*)
0
count(*)
0
replace into t1 values(1, '[0.880265,0.305289,0.203846]', '[0.01,-0.02,0,0.12,0.34]');
replace into t1 values(2, '[0.986755,0.769954,0.484526]', '[0.02,-0.03,1,0.567,0.8910]');
call dbms_vector.refresh_index('idx1', 't1', 'c2', 0, 'FAST');
count(*)
0
count(*)
2
call dbms_vector.rebuild_index('idx1','t1','c2', 0);
count(*)
0
count(*)
0
count(*)
1
call dbms_vector.refresh_index('idx2', 't1', 'c3', 0, 'FAST');
count(*)
0
count(*)
4
call dbms_vector.rebuild_index('idx2','t1','c3', 0);
count(*)
0
count(*)
0
count(*)
1
drop table if exists t1;
alter system set ob_vector_memory_limit_percentage = 0;
