insert into vec_t1(c1, c5, c6, c4, c2, c3)
select vec_t2.c1, vec_t2.c5, vec_t2.c6, vec_t2.c4, vec_t3.c2, vec_t3.c3
from vec_t2
join vec_t3 on vec_t2.c1 = vec_t3.c1
where vec_t2.c6 = 500;
insert into vec_t1(c1, c5, c6, c4, c2, c3)
select vec_t3.c1, sum(vec_t3.c5), vec_t3.c6, vec_t3.c4, vec_t3.c2, vec_t3.c3
from vec_t2
join vec_t3 on vec_t2.c1 = vec_t3.c1
where vec_t3.c6 < 6
group by vec_t3.c5;
insert into vec_t1(c1, c5, c6, c4, c2, c3)
values (20, 20, 20, '222',
(select c2 from vec_t2 where c1 = 500),
(select vec_t2.c3 from vec_t2 join vec_t3 on vec_t2.c1 = vec_t3.c1 where vec_t3.c1 = 501));
update vec_t1
set vec_t1.c3 = (select vec_t2.c3 from vec_t2 where vec_t2.c1 = vec_t1.c1 and vec_t2.c1 = 100)
where vec_t1.c1 in (select vec_t3.c5 from vec_t3 where vec_t3.c1 = 502);
update vec_t1
join vec_t2 on vec_t1.c1 = vec_t2.c1
set vec_t1.c3 = vec_t2.c3 + '[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]'
where vec_t2.c5 < 5;
update vec_t1
set c2 = case
when c1 = 201 then c3 + '[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]'
            when c1 = 401 then c3 - '[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]'
            else c2
end
where c1 < 500;
with cte as (
select c5, c2 from vec_t2 where c5 = (select vec_t3.c5 from vec_t3 where vec_t3.c1 = 504)
)
update vec_t1
set c2 = (select c2 from cte)
where c1 = (select c5 from cte);
delete from vec_t1
where vec_t1.c1 in (
select vec_t2.c5
from vec_t2
join vec_t3 on vec_t2.c5 = vec_t3.c5
where vec_t2.c6 = 6
);
delete vec_t1
from vec_t1
join vec_t2 on vec_t1.c1 = vec_t2.c5
where vec_t2.c6 <= 3;
START TRANSACTION;
delete from vec_t1
where vec_t1.c1 in (
select c1 from vec_t2
);
update vec_t1
set c2 = c2 + '[0.656600,0.774219,0.219927,0.338169,0.076971,0.765809,0.457919,0.319581,0.684450,0.978672]'
where c1 > 10009;
