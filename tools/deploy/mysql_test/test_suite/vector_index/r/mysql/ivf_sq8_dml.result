3. 二级分区表随表建索引
create table vec_t1 (c1 int AUTO_INCREMENT, c2 vector(10), c3 vector(10), c4 varchar(10), c5 int, c6 int,
PRIMARY KEY(c1, c5),
INDEX (c5, c6),
VECTOR INDEX idx1(c2)
WITH (distance=l2, type=ivf_sq8),
VECTOR INDEX idx2(c3)
WITH (distance=l2, type=ivf_sq8))
PARTITION BY RANGE COLUMNS(c1)
SUBPARTITION BY RANGE COLUMNS(c5)
SUBPARTITION TEMPLATE
(
SUBPARTITION mp0 VALUES LESS THAN(30),
SUBPARTITION mp1 VALUES LESS THAN(60),
SUBPARTITION mp2 VALUES LESS THAN(90),
SUBPARTITION mp3 VALUES LESS THAN MAXVALUE
)
(
PARTITION p0 VALUES LESS THAN(20),
PARTITION p1 VALUES LESS THAN(40),
PARTITION p2 VALUES LESS THAN(60),
PARTITION p3 VALUES LESS THAN(80),
PARTITION p4 VALUES LESS THAN MAXVALUE
);
