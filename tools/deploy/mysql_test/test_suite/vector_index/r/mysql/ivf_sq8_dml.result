1. with different index types
alter system set ob_vector_memory_limit_percentage = 34;
DROP TABLE IF EXISTS vec_t1;
DROP TABLE IF EXISTS vec_t2;
create table vec_t1 (c1 int AUTO_INCREMENT, c2 vector(10), c3 vector(10), c4 varchar(10), c5 int UNIQUE, c6 int,
PRIMARY KEY(c1, c4),
INDEX (c5, c6));
create vector index idx1 on vec_t1 (c2) with (distance=l2, type=ivf_sq8, nlist=2, sample_per_nlist=3);
create vector index idx2 on vec_t1 (c3) with (distance=l2, type=ivf_sq8, nlist=2, sample_per_nlist=3);
