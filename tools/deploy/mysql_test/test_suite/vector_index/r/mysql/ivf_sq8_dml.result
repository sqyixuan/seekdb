5. 一级分区表后建
create table vec_t1 (c1 int AUTO_INCREMENT, c2 vector(10), c3 vector(10), c4 varchar(10), c5 int, c6 int,
PRIMARY KEY(c1, c4),
INDEX (c5, c6))
PARTITION BY RANGE(c1) (
PARTITION p0 VALUES less than(30),
PARTITION p1 VALUES less than(60),
PARTITION p2 VALUES less than(MAXVALUE)
);
create vector index idx1 on vec_t1 (c2) with (distance=l2, type=ivf_sq8, nlist=2, sample_per_nlist=3);
create vector index idx2 on vec_t1 (c3) with (distance=l2, type=ivf_sq8, nlist=2, sample_per_nlist=3);
create table vec_t2 (c1 int AUTO_INCREMENT, c2 vector(10), c3 vector(10), c4 varchar(10), c5 int UNIQUE, c6 int,
PRIMARY KEY(c1, c4),
INDEX (c5, c6));
