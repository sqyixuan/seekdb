COMMIT;
create procedure vec_proc(IN inc1 INT, IN inc2 INT)
begin
DECLARE t2c2 INT;
select c5 into t2c2
from vec_t2
where c1 = inc1;
if t2c2 = inc2 then
update vec_t1
set c2 = c2 + '[0.656600,0.774219,0.219927,0.338169,0.076971,0.765809,0.457919,0.319581,0.684450,0.978672]'
        where c1 > 10000;
else
insert into vec_t1 select * from vec_t2 where vec_t2.c1 >= 505;
end if;
end;
//
CALL vec_proc(500, 500);
CALL vec_proc(500, 501);
drop procedure vec_proc;
