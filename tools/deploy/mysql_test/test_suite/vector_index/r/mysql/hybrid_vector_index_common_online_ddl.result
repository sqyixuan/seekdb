Create partitioned table
CREATE TABLE t2(
id INT PRIMARY KEY,
doc VARCHAR(200),
VECTOR INDEX idx1(doc) 
WITH (distance=L2, type=hnsw, dim=128, model=ob_embed, sync_mode=manual)
)
PARTITION BY RANGE COLUMNS(id)
(
PARTITION p0 VALUES LESS THAN(100),
PARTITION p1 VALUES LESS THAN(200)
);
