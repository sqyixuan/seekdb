Create partitioned table with multiple vector indexes
DROP TABLE IF EXISTS t3;
CREATE TABLE t3(
id INT PRIMARY KEY, 
doc VARCHAR(200),
VECTOR INDEX idx1(doc) 
WITH (distance=L2, type=hnsw, dim=128, model=ob_embed, sync_mode=manual),
VECTOR INDEX idx2(doc) 
WITH (distance=cosine, type=hnsw, dim=256, model=ob_embed, sync_mode=immediate)
)
PARTITION BY RANGE COLUMNS(id)
(
PARTITION p0 VALUES LESS THAN(100),
PARTITION p1 VALUES LESS THAN MAXVALUE
);
ERROR 0A000: more than one vector index on same column is not supported
CREATE TABLE t3(
id INT PRIMARY KEY, 
doc VARCHAR(200),
doc2 VARCHAR(200),
VECTOR INDEX idx1(doc) 
WITH (distance=L2, type=hnsw, dim=128, model=ob_embed, sync_mode=manual),
VECTOR INDEX idx2(doc2) 
WITH (distance=cosine, type=hnsw, dim=256, model=ob_embed, sync_mode=immediate)
)
PARTITION BY RANGE COLUMNS(id)
(
PARTITION p0 VALUES LESS THAN(100),
PARTITION p1 VALUES LESS THAN MAXVALUE
);
