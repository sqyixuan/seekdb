drop table t1,t2,t3,t4;
create table  t1 (c1 int auto_increment, c2 vector(4), primary key(c1)) partition by hash(c1) partitions 2;
insert into t1(c2)  select concat('[', repeat(concat(random()%100, ','), 3), concat(random()%100, ']')) from table(generator(1000));
create vector index idx1 on t1(c2) with(type=ivf_pq,distance=l2,m=2);
create table t2(c1 int, c2 vector(5), c3 varchar(20), primary key(c1), vector index idx2(c2) with (distance=l2, type=ivf_pq, m=1));
insert into t2 values(1, '[1,2,3,4,5]', 'test1');
insert into t2 values(2, '[2,3,4,5,1]', 'test2');
insert into t2 values(3, '[3,4,5,1,2]', 'test3');
insert into t2 values(4, '[4,5,6,7,8]', 'test4');
insert into t2 values(5, '[5,6,7,8,9]', 'test5');
