# Vector Similarity
alter system set ob_vector_memory_limit_percentage = 44;
drop table if exists t1;
create table t1 (c1 int, c2 int, c3 vector(3), primary key(c1), index idx2(c2), vector index idx1(c3) with (distance=cosine, type=hnsw));
insert into t1 values(1, 1, [1,1,2]);
insert into t1 values(2, 2, [0.8,0.5,0.1]);
insert into t1 values(3, 3, [0.9,0.1,0.5]);
set @test_vec = '[1,1,2]';
SET @insert_vec = '[0.8,0.5,0.1]';
DROP PROCEDURE IF EXISTS insert_data$$
CREATE PROCEDURE insert_data(cnt INT)
BEGIN
DECLARE i INT DEFAULT 4;
WHILE i < cnt DO
INSERT INTO t1(c1, c2, c3) VALUES (i, 2, @insert_vec);
INSERT INTO t1(c1, c2, c3) VALUES (i+1, 1, @test_vec);
SET i = i + 2;
END WHILE;
END$$
CALL insert_data(50000);
select /* +index(t1 idx2)*/ c2, cosine_similarity(c3, @test_vec) from t1 where c2=2 order by cosine_distance(c3, [1,1,2]) approx limit 10 ;
c2	cosine_similarity(c3, @test_vec)
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
select /* +index(t1 idx2)*/ c2, cosine_similarity(c3, @test_vec) from t1 where c2=2 order by cosine_distance(c3, [1,1,2]) approx limit 10 parameters (similarity=0.8);
c2	cosine_similarity(c3, @test_vec)
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
2	0.8227486126124859
drop table if exists t1;
