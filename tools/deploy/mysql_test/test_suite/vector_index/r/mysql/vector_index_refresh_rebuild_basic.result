# 字段合法性（非法）
replace into t1 values(1, '[0.880265,0.305289,0.203846]', '[0.01,-0.02,0,0.12,0.34]');
call dbms_vector.refresh_index('idx1');
ERROR 42000: Incorrect number of arguments
call dbms_vector.refresh_index('idx3', 't1');
ERROR HY000: Incorrect arguments to index name
call dbms_vector.refresh_index('idx1', 't2');
ERROR HY000: Incorrect arguments to base table name
call dbms_vector.refresh_index('idx1', 't1', '', 1, 'SLOW');
ERROR 0A000: Not supported feature or function
call dbms_vector.refresh_index('idx1', 't1', 'c3');
ERROR HY000: Invalid argument
call dbms_vector.refresh_index('idx1', 't1', 'c2', null);
ERROR HY000: Invalid argument
call dbms_vector.rebuild_index('idx1');
ERROR 42000: Incorrect number of arguments
call dbms_vector.rebuild_index('idx3', 't1');
ERROR HY000: Incorrect arguments to index name
call dbms_vector.rebuild_index('idx1', 't2');
ERROR HY000: Incorrect arguments to base table name
call dbms_vector.rebuild_index('idx1', 't1', 'c3');
ERROR HY000: Invalid argument
call dbms_vector.rebuild_index('idx1', 't1', 'c2', null);
ERROR HY000: Invalid argument
call dbms_vector.rebuild_index('idx1','t1', '', '', 'not support', '', '','');
ERROR HY000: Incorrect integer value
call dbms_vector.rebuild_index('idx1','t1', '', '', '', 'not support', '','');
ERROR HY000: Incorrect integer value
call dbms_vector.rebuild_index('idx1','t1', '', '', '', '', 'not support','');
ERROR HY000: Incorrect integer value
drop table if exists t1;
# 一级分区表
create table t1(c1 int, c2 vector(3), c3 vector(5), 
primary key(c1),
vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag))
PARTITION BY RANGE COLUMNS(c1)
(
PARTITION p0 VALUES LESS THAN(100),
PARTITION p1 VALUES LESS THAN(200),
PARTITION p2 VALUES LESS THAN(300),
PARTITION p3 VALUES LESS THAN(10000),
PARTITION p4 VALUES LESS THAN MAXVALUE
);
create vector index idx2 on t1(c3) with (distance=l2, type=hnsw, lib=vsag);
# 空表刷新
call dbms_vector.refresh_index('idx1', 't1', 'c2', 1, 'FAST');
call dbms_vector.rebuild_index('idx1','t1','c2');
call dbms_vector.refresh_index('idx2', 't1', 'c3', 1, 'FAST');
call dbms_vector.rebuild_index('idx2','t1','c3');
# 只刷一个索引，另一个不刷
call dbms_vector.refresh_index('idx1', 't1', 'c2', 1, 'FAST');
call dbms_vector.rebuild_index('idx1','t1','c2');
count(*)
0
count(*)
0
count(*)>0
1
count(*)
65
count(*)
0
count(*)=0
1
