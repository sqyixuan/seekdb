"======================================= 多个大小写名字下，会创建失败 ============================================"
drop table if exists t_vec_ivf_flat;
drop table if exists t_vec_ivf_sq8;
drop table if exists t_vec_ivf_pq;
create table t_vec_ivf_flat(c1 int, c2 vector(3), c3 vector(3), primary key(c1), vector index iDx1(c2) with (distance=l2, type=ivf_flat), vector index idx1(c3) with (distance=l2, type=ivf_flat));
ERROR 42000: Duplicate key name 'idx1'
create table t_vec_ivf_sq8(c1 int, c2 vector(3), c3 vector(3), primary key(c1), vector index iDx1(c2) with (distance=l2, type=ivf_sq8), vector index idx1(c3) with (distance=l2, type=ivf_sq8));
ERROR 42000: Duplicate key name 'idx1'
create table t_vec_ivf_pq(c1 int, c2 vector(3), c3 vector(3), primary key(c1), vector index iDx1(c2) with (distance=l2, type=ivf_pq, m=1), vector index idx1(c3) with (distance=l2, type=ivf_pq, m=1));
ERROR 42000: Duplicate key name 'idx1'


