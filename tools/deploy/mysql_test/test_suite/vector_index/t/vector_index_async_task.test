--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : yangjiali.yjl
#owner group: shenzhen
#description: basic test vector index async task

connect (conn_sys,$OBMYSQL_MS0,root@sys,,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

connection conn_sys;
alter system set debug_sync_timeout = '100s';
sleep 1;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
sleep 1;

connection conn1;
alter system set ob_vector_memory_limit_percentage = 30;

--echo
--echo
--echo "========================= basic test of none partition table =========================="

connection conn_sys;
#set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'HANDLE_VECTOR_INDEX_ASYNC_TASK wait_for continue_signal execute 10000';

connection conn1;
# not partition table, check async task building and running
--disable_warnings
drop table if exists t_async_task;
--enable_warnings
create table t_async_task(c1 int, c2 vector(3), primary key(c1));
create vector index idx_async_task on t_async_task(c2) with (distance=l2, type=hnsw);
insert into t_async_task values (1, '[1,1,1]'), (3, '[2,1,1]'), (11, '[3,1,1]');

sleep 12;
select * from t_async_task order by l2_distance(c2, '[2,1,1]') approximate limit 1;

--disable_query_log
--let $task_cnt = 0
while ($task_cnt != 1) {
  sleep 1;
  let $task_cnt = query_get_value(select count(status) as task_cnt from oceanbase.__all_vector_index_task where status=1, task_cnt, 1);
}
--enable_query_log

### debug sync stuck on do_work
let $tenant_id = query_get_value(select effective_tenant_id() as tenant_id, tenant_id, 1);
let $data_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='t_async_task', table_id, 1);
let $index_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name like '__idx_%idx_async_task', table_id, 1);
--disable_query_log
eval select trigger_type, task_type, status, ret_code from oceanbase.__all_vector_index_task where table_id=$index_table_id;
eval select trigger_type, task_type, status, ret_code from oceanbase.DBA_OB_VECTOR_INDEX_TASKS where table_id=$index_table_id;
--enable_query_log

connection conn_sys;
--disable_query_log
eval select trigger_type, task_type, status, ret_code from oceanbase.__all_virtual_vector_index_task where table_id=$index_table_id and tenant_id=$tenant_id;
eval select trigger_type, task_type, status, ret_code from oceanbase.CDB_OB_VECTOR_INDEX_TASKS where table_id=$index_table_id and tenant_id=$tenant_id;
--enable_query_log

#set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';

connection conn1;
--disable_query_log
--let $task_cnt = 1
while ($task_cnt != 0) {
  sleep 1;
  let $task_cnt = query_get_value(select count(*) as task_cnt from oceanbase.__all_vector_index_task, task_cnt, 1);
}
--enable_query_log

# 10s later task record will transfer to history table
sleep 12;
--disable_query_log
eval select trigger_type, task_type, status, ret_code from oceanbase.__all_vector_index_task_history where table_id = $index_table_id;
eval select trigger_type, task_type, status, ret_code from oceanbase.DBA_OB_VECTOR_INDEX_TASK_HISTORY where table_id = $index_table_id;
--enable_query_log

connection conn_sys;
--disable_query_log
eval select trigger_type, task_type, status, ret_code from oceanbase.__all_virtual_vector_index_task_history where table_id=$index_table_id and tenant_id=$tenant_id;
eval select trigger_type, task_type, status, ret_code from oceanbase.CDB_OB_VECTOR_INDEX_TASK_HISTORY where table_id=$index_table_id and tenant_id=$tenant_id;
--enable_query_log

connection conn1;
drop table t_async_task;

# select from history table where drop table 
--disable_query_log
eval select trigger_type, task_type, status, ret_code from oceanbase.DBA_OB_VECTOR_INDEX_TASK_HISTORY where table_id = $index_table_id;
--enable_query_log

connection conn_sys;
#set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'HANDLE_VECTOR_INDEX_ASYNC_TASK wait_for continue_signal execute 10000';

