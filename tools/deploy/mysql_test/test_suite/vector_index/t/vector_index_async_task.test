# not partition table, check async task building and running
create table t_async_task(c1 int, c2 vector(3), primary key(c1)) partition by range(c1) (partition p0 values less than (5), partition p1 values less than (10));
create vector index idx_async_task on t_async_task(c2) with (distance=l2, type=hnsw);
