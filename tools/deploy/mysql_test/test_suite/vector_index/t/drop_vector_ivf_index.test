# case 特殊字符下，创建多个索引，预期内部处理成一个索引，认为创建同名索引失败
--echo
--echo
--echo "========================================== 索引名有特殊字符 003 ==============================================="
drop table if exists t_vec_ivf_flat;
drop table if exists t_vec_ivf_sq8;
drop table if exists t_vec_ivf_pq;
--error 1061
create table t_vec_ivf_flat(c1 int, c2 vector(3), c3 vector(3), primary key(c1), vector index cafe(c2) with (distance=l2, type=hnsw), vector index café(c3) with (distance=l2, type=ivf_flat));
--error 1061
create table t_vec_ivf_sq8(c1 int, c2 vector(3), c3 vector(3), primary key(c1), vector index cafe(c2) with (distance=l2, type=hnsw), vector index café(c3) with (distance=l2, type=ivf_sq8));
--error 1061
create table t_vec_ivf_pq(c1 int, c2 vector(3), c3 vector(3), primary key(c1), vector index cafe(c2) with (distance=l2, type=hnsw), vector index café(c3) with (distance=l2, type=ivf_pq, m=1));

# bugfix：在同一向量列上先创建ivf_pq索引，然后删除索引，再创建ivf_sq8索引，再进行删索引报错表不存在
drop table if exists t_vec;
create table t_vec (c1 int primary key, c2 varchar(3), c3 vector(3), c4 vector(2), vector index vector_idx(c3) with (distance=l2, type=ivf_pq, m=1));
create vector index vector_idx2 on t_vec (c4) with (distance=l2, type=ivf_pq, m=2);
drop index vector_idx2 on t_vec;
create vector index vector_idx2 on t_vec (c4) with (distance=l2, type=ivf_sq8);
drop index vector_idx2 on t_vec;
drop table t_vec;

# 删除多个不同向量索引中的1个或多个
create table t_vec (c1 int primary key, c2 varchar(3), c3 vector(3), c4 vector(3), c5 vector(3));
create vector index idx1 on t_vec(c3) with (distance=l2, type=ivf_flat);
create vector index idx2 on t_vec(c4) with (distance=l2, type=ivf_sq8);
create vector index idx3 on t_vec(c5) with (distance=l2, type=ivf_pq, m=1);
drop index idx3 on t_vec;
drop index idx2 on t_vec;
drop index idx1 on t_vec;
drop table t_vec;

# 删除多个向量索引中的1个
--echo
--echo
--echo "==========================================  删除ivfflat向量索引中的1个或多个 ============================================"
connection conn_user;
