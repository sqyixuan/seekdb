--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : yangjiali.yjl
#owner group: obkv
#description: basic test of drop ivf vector index

connect (conn_user,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (conn_sys,$OBMYSQL_MS0,root@sys,,test,$OBMYSQL_PORT);
connection conn_user;

--disable_warnings
drop database if exists yjl_vec;
create database yjl_vec;
use yjl_vec;

alter system set ob_vector_memory_limit_percentage = 20;
sleep 3;
# __all_ddl_operation
--echo
--echo
--echo "=========================================== __all_ddl_operation ==========================================="
drop table if exists t_vec_ivf_flat;
create table t_vec_ivf_flat(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_flat));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
show index from t_vec_ivf_flat;
drop index idx1 on t_vec_ivf_flat;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
show index from t_vec_ivf_flat;
select ddl_stmt_str from oceanbase.__all_ddl_operation where database_id = (select database_id from oceanbase.__all_database where database_name='yjl_vec') and ddl_stmt_str != '' order by schema_version;

# 索引名有转义字符
--echo
--echo
--echo "=========================================== 索引名有转义字符 ================================================="
drop table if exists t_vec_ivf_flat;
drop table if exists t_vec_ivf_sq8;
drop table if exists t_vec_ivf_pq;
create table t_vec_ivf_flat(c1 int, c2 vector(3), primary key(c1), vector index `idx\n1`(c2) with (distance=l2, type=ivf_flat));
create table t_vec_ivf_sq8(c1 int, c2 vector(3), primary key(c1), vector index `idx\n1`(c2) with (distance=l2, type=ivf_sq8));
create table t_vec_ivf_pq(c1 int, c2 vector(3), primary key(c1), vector index `idx\n1`(c2) with (distance=l2, type=ivf_pq, m=1));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_sq8;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_pq;
show index from t_vec_ivf_flat;
show index from t_vec_ivf_sq8;
show index from t_vec_ivf_pq;
drop index `idx\n1` on t_vec_ivf_flat;
drop index `idx\n1` on t_vec_ivf_sq8;
drop index `idx\n1` on t_vec_ivf_pq;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_sq8;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_pq;
show index from t_vec_ivf_flat;
show index from t_vec_ivf_sq8;
show index from t_vec_ivf_pq;

