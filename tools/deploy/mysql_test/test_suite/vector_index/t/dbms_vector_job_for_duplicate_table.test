#owner: shanhaikang.shk
#owner group: hangzhou
--echo # DBMS VECTOR job for duplicate table

SET @@recyclebin = off;

--disable_warnings
drop table if exists t1;
--enable_warnings
--disable_query_log
--disable_result_log
alter system set ob_vector_memory_limit_percentage = 30;
--enable_result_log
--enable_query_log

--disable_query_log
--disable_result_log
sleep 3;
--enable_result_log
--enable_query_log

create table t1(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=hnsw, lib=vsag)) ;
insert into t1 values(1, '[0.748479,0.276979,0.555195]'), (2, '[0.748479,0.276979,0.555195]'),(3, '[0.748479,0.276979,0.555195]'),(4, '[0.748479,0.276979,0.555195]'),(5, '[0.748479,0.276979,0.555195]'),(6, '[0.748479,0.276979,0.555195]'),(7, '[0.748479,0.276979,0.555195]'),(28, '[0.748479,0.276979,0.555195]');
call dbms_vector.refresh_index('idx1', 't1', '', 0);
call dbms_vector.rebuild_index('idx1', 't1');
