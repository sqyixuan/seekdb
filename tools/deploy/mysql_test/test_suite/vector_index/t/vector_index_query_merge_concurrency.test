#owner: zhuchang.zhu
#owner group: shenzhen
#description: test vector index query replace_scn check logic (scenario1: block before get adaptor, merge replaces adaptor, query gets new adaptor and returns OB_SCHEMA_EAGAIN)

connect (conn_sys,$OBMYSQL_MS0,root@sys,,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,root@mysql,,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,root@mysql,,test,$OBMYSQL_PORT);

connection conn_sys;
alter system set debug_sync_timeout = '300s';
sleep 3;

connection conn1;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--echo
--echo "========== scenario 1: query blocked before get adaptor -> merge completes -> query gets new adaptor -> OB_SCHEMA_EAGAIN，retry =========="

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(
  c1 int primary key,
  c2 vector(3),
  VECTOR INDEX idx1(c2) WITH(distance=l2, type=hnsw, lib=vsag)
);

insert into t1 values(1, '[0.1,0.2,0.3]');
insert into t1 values(2, '[0.4,0.5,0.6]');
insert into t1 values(3, '[0.7,0.8,0.9]');

sleep 5;

--disable_query_log
let $data_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1', table_id, 1);
let $index_table_id = query_get_value(select table_id from oceanbase.__all_table where data_table_id = $data_table_id and table_name like '__idx_%idx1', table_id, 1);
--enable_query_log

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'VECTOR_INDEX_QUERY_BEFORE_GET_ADAPTOR wait_for query_continue_signal execute 10000';

connection conn1;
send SELECT c1 from t1 where c1 = 100 order by l2_distance(c2, '[0,0,0]') APPROXIMATE limit 2;

sleep 2;

--echo "=== insert 100 rows ===="
connection conn2;
--disable_query_log
let $history_cnt_before = query_get_value(select count(*) as cnt from oceanbase.__all_vector_index_task_history where table_id = $index_table_id, cnt, 1);

--let $i = 4
while ($i <= 104) {
  eval insert into t1 values($i, '[0.1,0.1,0.1]');
  inc $i;
}

sleep 5;

let $history_cnt = query_get_value(select count(*) as history_cnt from oceanbase.__all_vector_index_task_history where table_id = $index_table_id, history_cnt, 1);
while ($history_cnt == $history_cnt_before) {
  sleep 1;
  let $history_cnt = query_get_value(select count(*) as history_cnt from oceanbase.__all_vector_index_task_history where table_id = $index_table_id, history_cnt, 1);
}
--enable_query_log

sleep 2;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal query_continue_signal';

connection conn1;
reap;

connection conn1;
--echo scenario1 done, normal query should succeed after retry
SELECT c1 from t1 where c1 = 100 order by l2_distance(c2, '[0,0,0]') APPROXIMATE limit 2;

drop table t1;

--echo
--echo "========== scenario 2: query blocked before adaptor lock -> merge completes -> query continues, use first adaptor (latest replace_scn > query scn) =========="

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(
  c1 int primary key,
  c2 vector(3),
  VECTOR INDEX idx1(c2) WITH(distance=l2, type=hnsw, lib=vsag)
);

insert into t1 values(1, '[0.1,0.2,0.3]');
insert into t1 values(2, '[0.4,0.5,0.6]');
insert into t1 values(3, '[0.7,0.8,0.9]');

sleep 5;

--disable_query_log
let $data_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1', table_id, 1);
let $index_table_id = query_get_value(select table_id from oceanbase.__all_table where data_table_id = $data_table_id and table_name like '__idx_%idx1', table_id, 1);
--enable_query_log

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'VECTOR_INDEX_QUERY_BEFORE_LOCK wait_for lock_continue_signal execute 10000';

connection conn1;
send SELECT c1 from t1  where c1 = 100 order by l2_distance(c2, '[0,0,0]') APPROXIMATE limit 2;

sleep 2;
--echo "=== insert 100 rows ===="
connection conn2;
--disable_query_log
let $history_cnt_before = query_get_value(select count(*) as cnt from oceanbase.__all_vector_index_task_history where table_id = $index_table_id, cnt, 1);

--let $i = 4
while ($i <= 104) {
  eval insert into t1 values($i, '[0.1,0.1,0.1]');
  inc $i;
}

sleep 5;

let $history_cnt = query_get_value(select count(*) as history_cnt from oceanbase.__all_vector_index_task_history where table_id = $index_table_id, history_cnt, 1);
while ($history_cnt == $history_cnt_before) {
  sleep 1;
  let $history_cnt = query_get_value(select count(*) as history_cnt from oceanbase.__all_vector_index_task_history where table_id = $index_table_id, history_cnt, 1);
}
--enable_query_log

sleep 2;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal lock_continue_signal';

connection conn1;
reap;

connection conn1;
--echo scenario 2.2.1 done, query used first adaptor and returned result
SELECT c1 from t1  where c1 = 100 order by l2_distance(c2, '[0,0,0]') APPROXIMATE limit 2;

drop table t1;

--echo
--echo "========== scenario 3: merge blocks before replace -> query blocks before lock -> merge continues (replaces adaptor) -> query continues (use latest adaptor if replace_scn < query scn) =========="

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(
  c1 int primary key,
  c2 vector(3),
  VECTOR INDEX idx1(c2) WITH(distance=l2, type=hnsw, lib=vsag)
);

insert into t1 values(1, '[0.1,0.2,0.3]');
insert into t1 values(2, '[0.4,0.5,0.6]');
insert into t1 values(3, '[0.7,0.8,0.9]');

sleep 5;

--disable_query_log
let $data_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1', table_id, 1);
let $index_table_id = query_get_value(select table_id from oceanbase.__all_table where data_table_id = $data_table_id and table_name like '__idx_%idx1', table_id, 1);
--enable_query_log

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'ASYNC_TASK_BEFORE_REPLACE_OLD_ADAPTOR wait_for merge_continue_signal execute 10000';
set ob_global_debug_sync = 'VECTOR_INDEX_QUERY_BEFORE_LOCK wait_for query_continue_signal execute 10000';

--echo "=== insert 100 rows ===="
connection conn2;
--disable_query_log
let $history_cnt_before = query_get_value(select count(*) as cnt from oceanbase.__all_vector_index_task_history where table_id = $index_table_id, cnt, 1);
--let $i = 4
while ($i <= 104) {
  eval insert into t1 values($i, '[0.1,0.1,0.1]');
  inc $i;
}
let $running_cnt = query_get_value(select count(*) as cnt from oceanbase.__all_vector_index_task where table_id = $index_table_id, cnt, 1);
while ($running_cnt != 1) {
  sleep 1;
  let $running_cnt = query_get_value(select count(*) as cnt from oceanbase.__all_vector_index_task where table_id = $index_table_id, cnt, 1);
}
--enable_query_log

sleep 2;

connection conn1;
send SELECT c1 from t1 where c1 = 100 order by l2_distance(c2, '[0,0,0]') APPROXIMATE limit 2;

sleep 1;

connection conn_sys;
set ob_global_debug_sync = 'now signal merge_continue_signal';

connection conn2;
let $history_cnt = query_get_value(select count(*) as cnt from oceanbase.__all_vector_index_task_history where table_id = $index_table_id, cnt, 1);
while ($history_cnt == $history_cnt_before) {
  sleep 1;
  let $history_cnt = query_get_value(select count(*) as cnt from oceanbase.__all_vector_index_task_history where table_id = $index_table_id, cnt, 1);
}

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal query_continue_signal';

connection conn1;
reap;

connection conn1;
--echo scenario 2.2.2 done, query continued after merge replaced adaptor
SELECT c1 from t1 where c1 = 100 order by l2_distance(c2, '[0,0,0]') APPROXIMATE limit 2;

drop table t1;

connection conn_sys;
set ob_global_debug_sync = 'reset';
