#owner: yangjiali.yjl
#owner group: shenzhen
--echo # check vector index table name length

--disable_warnings
drop table if exists t_vec;
--enable_warnings
alter system set ob_vector_memory_limit_percentage = 30;


############  1. create table with index


--error 1059
create table t_vec(c1 int primary key, c2 vector(3), vector index idx_1111111111111111111111111111111111111111111111111111111111111(c2) with (distance=l2, type=hnsw));
create table t_vec(c1 int primary key, c2 vector(3), vector index idx_111111111111111111111111111111111111111111111111111111111111(c2) with (distance=l2, type=hnsw));
drop table t_vec;

--error 1059
create table t_vec(c1 int primary key, c2 vector(3), vector index idx_1111111111111111111111111111111111111111111111111111111111111(c2) with (distance=l2, type=hnsw_sq));
create table t_vec(c1 int primary key, c2 vector(3), vector index idx_111111111111111111111111111111111111111111111111111111111111(c2) with (distance=l2, type=hnsw_sq));
drop table t_vec;

--error 1059
create table t_vec(c1 int primary key, c2 vector(3), vector index idx_1111111111111111111111111111111111111111111111111111111111111(c2) with (distance=l2, type=ivf_flat));
create table t_vec(c1 int primary key, c2 vector(3), vector index idx_111111111111111111111111111111111111111111111111111111111111(c2) with (distance=l2, type=ivf_flat));
drop table t_vec;

--error 1059
create table t_vec(c1 int primary key, c2 vector(3), vector index idx_1111111111111111111111111111111111111111111111111111111111111(c2) with (distance=l2, type=ivf_sq8));
create table t_vec(c1 int primary key, c2 vector(3), vector index idx_111111111111111111111111111111111111111111111111111111111111(c2) with (distance=l2, type=ivf_sq8));
drop table t_vec;

--error 1059
create table t_vec(c1 int primary key, c2 vector(3), vector index idx_1111111111111111111111111111111111111111111111111111111111111(c2) with (distance=l2, type=ivf_pq, m=1));
create table t_vec(c1 int primary key, c2 vector(3), vector index idx_111111111111111111111111111111111111111111111111111111111111(c2) with (distance=l2, type=ivf_pq, m=1));
drop table t_vec;


############  2. create vector index #####


create table t_vec(c1 int primary key, c2 vector(3));

--error 1059
create vector index idx_1111111111111111111111111111111111111111111111111111111111111 on t_vec(c2) with (distance=l2, type=hnsw);
create vector index idx_111111111111111111111111111111111111111111111111111111111111 on t_vec(c2) with (distance=l2, type=hnsw);
drop index idx_111111111111111111111111111111111111111111111111111111111111 on t_vec;

--error 1059
create vector index idx_1111111111111111111111111111111111111111111111111111111111111 on t_vec(c2) with (distance=l2, type=hnsw_sq);
create vector index idx_111111111111111111111111111111111111111111111111111111111111 on t_vec(c2) with (distance=l2, type=hnsw_sq);
drop index idx_111111111111111111111111111111111111111111111111111111111111 on t_vec;

--error 1059
create vector index idx_1111111111111111111111111111111111111111111111111111111111111 on t_vec(c2) with (distance=l2, type=ivf_flat);
create vector index idx_111111111111111111111111111111111111111111111111111111111111 on t_vec(c2) with (distance=l2, type=ivf_flat);
drop index idx_111111111111111111111111111111111111111111111111111111111111 on t_vec;

--error 1059
create vector index idx_1111111111111111111111111111111111111111111111111111111111111 on t_vec(c2) with (distance=l2, type=ivf_sq8);
create vector index idx_111111111111111111111111111111111111111111111111111111111111 on t_vec(c2) with (distance=l2, type=ivf_sq8);
drop index idx_111111111111111111111111111111111111111111111111111111111111 on t_vec;

--error 1059
create vector index idx_1111111111111111111111111111111111111111111111111111111111111 on t_vec(c2) with (distance=l2, type=ivf_pq, m=1);
create vector index idx_111111111111111111111111111111111111111111111111111111111111 on t_vec(c2) with (distance=l2, type=ivf_pq, m=1);
drop index idx_111111111111111111111111111111111111111111111111111111111111 on t_vec;
drop table t_vec;

alter system set ob_vector_memory_limit_percentage = 0;