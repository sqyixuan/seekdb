# rebuilding conflict before post create
--echo
--echo
--echo "=========================================== rebuilding conflict with flat ==========================================="
connection conn1;
--disable_warnings
drop table if exists t_vec_ivf_flat;
--enable_warnings
create table t_vec_ivf_flat(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_flat));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
show index from t_vec_ivf_flat;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'REBUILD_VEC_INDEX_WAIT_CREATE_NEW_INDEX wait_for continue_signal execute 10000';

connection conn1;
send call dbms_vector.rebuild_index('idx1','t_vec_ivf_flat','c2');
sleep 10;

connection conn2;
send drop index idx1 on t_vec_ivf_flat;
sleep 1;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';

connection conn1;
reap;

connection conn2;
reap;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
--replace_regex /idx_[0-9]+/idx_new/g
show index from t_vec_ivf_flat;

--echo
--echo
--echo "=========================================== rebuilding conflict with sq8 ==========================================="
