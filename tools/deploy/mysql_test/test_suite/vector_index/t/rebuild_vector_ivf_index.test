--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : yangjiali.yjl
#owner group: shenzhen
#description: basic test ob rebuild vector ivf index

connect (conn_sys,$OBMYSQL_MS0,root@sys,,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

connection conn_sys;
alter system set debug_sync_timeout = '100s';
sleep 3;

# normal rebuild
--echo
--echo
--echo "=========================================== normal rebuild ivfflat index ==========================================="
connection conn1;
--disable_warnings
drop table if exists t_vec_ivf_flat;
--enable_warnings
alter system set ob_vector_memory_limit_percentage = 20;
sleep 3;
create table t_vec_ivf_flat(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_flat));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
show index from t_vec_ivf_flat;
call dbms_vector.rebuild_index('idx1','t_vec_ivf_flat','c2');
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
show index from t_vec_ivf_flat;
drop table t_vec_ivf_flat;

# normal rebuild
--echo
--echo
--echo "=========================================== normal rebuild ivfsq8 index ==========================================="
connection conn1;
--disable_warnings
drop table if exists t_vec_ivf_sq8;
--enable_warnings
sleep 3;
create table t_vec_ivf_sq8(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_sq8));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_sq8;
show index from t_vec_ivf_sq8;
call dbms_vector.rebuild_index('idx1','t_vec_ivf_sq8','c2');
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_sq8;
show index from t_vec_ivf_sq8;
drop table t_vec_ivf_sq8;

