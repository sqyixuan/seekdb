# rebuilding when database in recyclebin
--echo
--echo
--echo "=========================================== rebuild when drop index to recyclebin with flat ==========================================="
connection conn1;
--disable_warnings
drop table if exists t_vec_ivf_flat;
--enable_warnings
set recyclebin='on';
create table t_vec_ivf_flat(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_flat));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
show index from t_vec_ivf_flat;
drop index idx1 on t_vec_ivf_flat;
--error 1210
call dbms_vector.rebuild_index('idx1','t_vec_ivf_flat','c2');

--echo
--echo
--echo "=========================================== rebuild when drop index to recyclebin with sq8 ==========================================="
connection conn1;
--disable_warnings
drop table if exists t_vec_ivf_sq8;
--enable_warnings
set recyclebin='on';
create table t_vec_ivf_sq8(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_sq8));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_sq8;
show index from t_vec_ivf_sq8;
drop index idx1 on t_vec_ivf_sq8;
--error 1210
call dbms_vector.rebuild_index('idx1','t_vec_ivf_sq8','c2');

--echo
--echo
--echo "=========================================== rebuild when drop index to recyclebin with pq ==========================================="
connection conn1;
--disable_warnings
drop table if exists t_vec_ivf_pq;
--enable_warnings
set recyclebin='on';
create table t_vec_ivf_pq(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_pq, m=1));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_pq;
show index from t_vec_ivf_pq;
drop index idx1 on t_vec_ivf_pq;
--error 1210
call dbms_vector.rebuild_index('idx1','t_vec_ivf_pq','c2');

--echo
--echo
--echo "=========================================== show index of normal index creating  ==========================================="
connection conn1;
--disable_warnings
drop table if exists t_vec;
--enable_warnings
create table t_vec(c1 int, c2 int, primary key(c1));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'CREATE_INDEX_REPLICA_BUILD wait_for continue_signal execute 10000';

connection conn1;
send create index idx_show on t_vec(c2);
sleep 5;

connection conn2;
show index from t_vec;
sleep 3;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';

connection conn1;
reap;
sleep 3;

show index from t_vec;
drop table t_vec;

--echo
--echo
--echo "========================= rebuilding when ctrl c in PREPARE state with flat =========================="
# REBUILD_VEC_INDEX_PREPARE
connection conn1;
let $sess_1=query_get_value(select connection_id() as id, id, 1);
--disable_warnings
drop table if exists t_vec_ivf_flat;
--enable_warnings
create table t_vec_ivf_flat(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_flat));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
--replace_regex /idx_[0-9]+/idx_new/g
show index from t_vec_ivf_flat;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'REBUILD_VEC_INDEX_PREPARE wait_for continue_signal execute 10000';

connection conn1;
send call dbms_vector.rebuild_index('idx1','t_vec_ivf_flat','c2');
sleep 1;

connection conn2;
# ObDDLTaskStatus::PREPARE state: 0
--disable_query_log
--let $ddl_status = 1000
while ($ddl_status != 0) 
{
  sleep 1;
  let $ddl_status = query_get_value(select status from oceanbase.__all_ddl_task_status where ddl_type=17, status, 1);
}
eval kill $sess_1;
--enable_query_log

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
sleep 6;

disconnect conn1;
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn1;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
show index from t_vec_ivf_flat;
drop table t_vec_ivf_flat;

