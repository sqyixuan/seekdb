create table normal(c1 int, c3 vector(3), c4 vector(10), primary key(c1));
CREATE VIEW vec_view as select * from vec_t1;

INSERT INTO normal select * from vec_t1 where c1 % 2 = 0;

update vec_t1 set c4 = '[0.022470,0.178305,0.813060,0.463923,0.276312,0.330019,0.043964,0.830623,0.266355,0.886212]' where c1 = 2;
