select count(*) from vec_view;

update vec_t1 join normal on vec_t1.c1 = normal.c1 set vec_t1.c4 = '[0.261976,0.930429,0.471947,0.405530,0.324696,0.734540,0.014641,0.351016,0.500687,0.521748]', normal.c4 = '[0.269763,0.342426,0.800285,0.910017,0.817684,0.551279,0.411955,0.685510,0.706911,0.667069]';
select * from vec_view;
select * from normal;

update vec_t1 join normal on vec_t1.c1 = normal.c1 set vec_t1.c3 = '[7,8,9]';
update vec_t1 join normal on vec_t1.c1 = normal.c1 set normal.c3 = vec_t1.c3;
select * from normal;
select * from vec_t1;

update vec_view join normal on vec_view.c1 = normal.c1 set vec_view.c4 = '[0.261976,0.930429,0.471947,0.405530,0.324696,0.734540,0.014641,0.351016,0.500687,0.521748]', normal.c4 = '[0.269763,0.342426,0.800285,0.910017,0.817684,0.551279,0.411955,0.685510,0.706911,0.667069]';
update vec_view set c4 = '[0.269763,0.342426,0.800285,0.910017,0.817684,0.551279,0.411955,0.685510,0.706911,0.667069]';
select * from vec_t1;
select * from vec_view;

delete vec_t1, normal from vec_t1 join normal on vec_t1.c1 = normal.c1;
delete vec_t1 from vec_t1 join normal on vec_t1.c1 = normal.c1;
delete vec_t1 from vec_t1 join normal on vec_t1.c1 = normal.c1;

delete normal from vec_view join normal on vec_view.c1 = normal.c1 and 1=0;
delete from vec_view where c3 = '[7,8,9]';

select * from vec_t1;
select * from vec_view;

set ob_enable_index_direct_select = 0;

drop table vec_t1;
drop table normal;
drop view vec_view;

# lob threshold 0
--disable_warnings
drop table if exists vec;
--enable_warnings
--error 1235
create table vec(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_pq, m=5)) LOB_INROW_THRESHOLD = 0;

--disable_warnings
drop table if exists vec_t1;
drop view if exists vec_v1;
--enable_warnings
CREATE TABLE vec_t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(10),
VECTOR INDEX vector_idx1(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=12, ef_search=40),
VECTOR INDEX vector_idx2(c4)
WITH (distance=l2, type=ivf_pq,m=5));
create view vec_v1 as select * from vec_t1;
replace into vec_v1 values(1,'[1,1,2]','[2,2,3]','[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]');
replace into vec_v1 values(1,'[1,1,2]','[2,2,3]','[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]');
select * from vec_v1;
select * from vec_t1;
drop view vec_v1;
drop table vec_t1;

--disable_warnings
drop table if exists vec_t1;
drop view if exists vec_v1;
--enable_warnings
CREATE TABLE vec_t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(10),
VECTOR INDEX vector_idx1(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=12, ef_search=40),
VECTOR INDEX vector_idx2(c4)
WITH (distance=l2, type=ivf_pq, m=5)) partition by list columns (c1)(
  PARTITION p0 VALUES in(10),
  PARTITION p1 VALUES in(50)
);
create view vec_v1 as select * from vec_t1;
--error 1526
replace into vec_v1 values(1,'[1,1,2]','[2,2,3]','[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]');
replace into vec_v1 values(10,'[1,1,2]','[2,2,3]','[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]');
replace into vec_v1 values(10,'[1,1,2]','[2,2,3]','[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]');
select * from vec_v1;
select * from vec_t1;
drop view vec_v1;
drop table vec_t1;

# bugfix: 2025022400107306306
--disable_warnings
drop table if exists tv;
--enable_warnings
## max length decided by max(pq center ids, vector)
create table tv (c1 int, vec vector(2000), vector index idv(vec) with(distance=l2, type=ivf_pq, m=400)) LOB_INROW_THRESHOLD=8000;
--disable_warnings
drop table if exists tv;
--enable_warnings
## max length decided by vector
create table tv (c1 int, vec vector(2000), vector index idv(vec) with(distance=l2, type=ivf_flat)) LOB_INROW_THRESHOLD=8000;
drop table tv;

let $before_lob_inrow = query_get_value(SHOW VARIABLES LIKE 'ob_default_lob_inrow_threshold', Value, 1);
set ob_default_lob_inrow_threshold=8000;
--disable_warnings
drop table if exists tv;
--enable_warnings
create table tv (c1 int, vec vector(2000), vector index idv(vec) with(distance=l2, type=ivf_pq, m=400));
--disable_warnings
drop table if exists tv;
--enable_warnings
create table tv (c1 int, vec vector(2000), vector index idv(vec) with(distance=l2, type=ivf_flat));
drop table tv;

## post CREATE
create table tv (c1 int, vec vector(2000));
create vector index idx1 on tv (vec) with (distance=l2, type=ivf_pq, m=400);
--error 1235
create vector index idx1 on tv (vec) with (distance=l2, type=ivf_flat);
drop table tv;

--disable_query_log
eval set ob_default_lob_inrow_threshold = $before_lob_inrow; 
--enable_query_log


alter system set ob_vector_memory_limit_percentage = 0;
