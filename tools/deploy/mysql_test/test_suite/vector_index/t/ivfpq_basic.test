--echo ################# complex dml operation ##################
--disable_warnings
DROP TABLE IF EXISTS vec;
DROP TABLE IF EXISTS normal;
DROP VIEW IF EXISTS vec_view;
--enable_warnings

create table vec(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_pq, m=5));
create table normal(c1 int, c2 vector(10), primary key(c1));
CREATE VIEW vec_view as select * from vec;

INSERT INTO vec values (1, '[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]'), (2, '[0.125866,0.428902,0.214633,0.208882,0.435422,0.045606,0.915596,0.065899,0.523299,0.352734]');
INSERT INTO normal values (1, '[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]'), (2, '[0.125866,0.428902,0.214633,0.208882,0.435422,0.045606,0.915596,0.065899,0.523299,0.352734]');

insert into vec values (1, '[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]') ON DUPLICATE KEY UPDATE c2 = '[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]';
insert into normal values (1, '[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]') ON DUPLICATE KEY UPDATE c2 = '[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]';

replace into vec (c1, c2) values (1, '[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]');
replace into normal (c1, c2) values (1, '[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]');

insert into vec_view values (3, '[0.707352,0.537032,0.433431,0.727523,0.293137,0.990979,0.967610,0.895034,0.479304,0.205645]'), (4, '[0.904051,0.864011,0.292710,0.748016,0.307713,0.820417,0.735923,0.839659,0.742446,0.146719]');
insert into normal (c1, c2) values (3, '[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]');

select * from vec_view;
select * from normal;

update vec join normal on vec.c1 = normal.c1 set vec.c2 = '[0.904051,0.864011,0.292710,0.748016,0.307713,0.820417,0.735923,0.839659,0.742446,0.146719]', normal.c2 = '[0.234391,0.660406,0.370087,0.860388,0.586119,0.668096,0.122285,0.670929,0.997141,0.177069]';
select * from vec_view;
select * from normal;

update vec join normal on vec.c1 = normal.c1 set vec.c2 = '[0.904051,0.864011,0.292710,0.748016,0.307713,0.820417,0.735923,0.839659,0.742446,0.146719]';
update vec join normal on vec.c1 = normal.c1 set normal.c2 = vec.c2;
select * from normal;
select * from vec;

update vec_view join normal on vec_view.c1 = normal.c1 set vec_view.c2 = '[0.904051,0.864011,0.292710,0.748016,0.307713,0.820417,0.735923,0.839659,0.742446,0.146719]', normal.c2 = '[0.234391,0.660406,0.370087,0.860388,0.586119,0.668096,0.122285,0.670929,0.997141,0.177069]';
update vec_view set c2 = '[0.904051,0.864011,0.292710,0.748016,0.307713,0.820417,0.735923,0.839659,0.742446,0.146719]';
select * from vec;
select * from vec_view;

delete vec, normal from vec join normal on vec.c1 = normal.c1;
delete vec from vec join normal on vec.c1 = normal.c1;
delete vec from vec join normal on vec.c1 = normal.c1;

delete normal from vec_view join normal on vec_view.c1 = normal.c1 and 1=0;
delete from vec_view where c2 = '[0.904051,0.864011,0.292710,0.748016,0.307713,0.820417,0.735923,0.839659,0.742446,0.146719]';

drop table vec;
drop table normal;
drop view vec_view;

