select * from vec_t1;

update vec_view join normal on vec_view.c1 = normal.c1 set vec_view.c4 = '[7,8,9]', normal.c4 = '[9,10,11]';
update vec_view set c4 = '[7,8,9]';
select * from vec_t1;
select * from vec_view;

delete vec_t1, normal from vec_t1 join normal on vec_t1.c1 = normal.c1;
delete vec_t1 from vec_t1 join normal on vec_t1.c1 = normal.c1;
delete vec_t1 from vec_t1 join normal on vec_t1.c1 = normal.c1;

delete normal from vec_view join normal on vec_view.c1 = normal.c1 and 1=0;
delete from vec_view where c3 = '[7,8,9]';

select * from vec_t1;
select * from vec_view;

set ob_enable_index_direct_select = 0;

drop table vec_t1;
drop table normal;
drop view vec_view;

# lob threshold 0
--disable_warnings
drop table if exists vec;
--enable_warnings
--error 1235
create table vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_sq8)) LOB_INROW_THRESHOLD = 0;

--disable_warnings
drop table if exists vec_t1;
drop view if exists vec_v1;
--enable_warnings
CREATE TABLE vec_t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx1(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=12, ef_search=40),
VECTOR INDEX vector_idx2(c4)
WITH (distance=l2, type=ivf_sq8));
create view vec_v1 as select * from vec_t1;
replace into vec_v1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
