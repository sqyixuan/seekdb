# description: test basic ivfsq8 vector index

connect (conn_user,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn_user;

alter system set ob_vector_memory_limit_percentage = 34;
sleep 3;

--echo # 单分区先建索引
--disable_warnings
drop table if exists vec_t1;
--enable_warnings

CREATE TABLE vec_t1 (c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX idx1(c4)
WITH (distance=l2, type=ivf_sq8));

