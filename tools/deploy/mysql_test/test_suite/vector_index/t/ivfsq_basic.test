create table normal(c1 int, c3 vector(3), c4 vector(3), primary key(c1));
CREATE VIEW vec_view as select * from vec_t1;

INSERT INTO normal select * from vec_t1 where c1 % 2 = 0;

update vec_t1 set c4 = '[2,2,2]' where c1 = 2;
