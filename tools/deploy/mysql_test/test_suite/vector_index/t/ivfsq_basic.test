let $database_id = `select database_id from oceanbase.__all_database where database_name='test';`;
let $table_id = `select table_id from oceanbase.__all_table where table_name = 'vec_t1' and database_id=$database_id;`;
let $center_id_table = `select CONCAT('__idx_', $table_id , '_idx1');`;
let $meta_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_sq_meta');`;
let $cid_vector_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_cid_vector');`;
let $rowkey_cid_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_rowkey_cid');`;

set ob_enable_index_direct_select = 1;

--echo # 查询索引表
--disable_query_log
eval select count(*) from $center_id_table;
eval select count(*) from $cid_vector_table;
eval select count(*) from $rowkey_cid_table;
eval select count(*) from $meta_table;
--enable_query_log

update vec_t1 set c4 = '[2,2,2]' where c1 = 2;
insert into vec_t1(c1,c2,c3,c4) values(2,'[2,1,2]','[2,2,2]','[2,3,2]') ON DUPLICATE KEY UPDATE c4 = '[9,8,7]';
delete from vec_t1 where c1 = 3;
insert into vec_t1(c1,c2,c3,c4) values(3,'[2,1,2]','[2,2,2]','[2,3,2]') ON DUPLICATE KEY UPDATE c3 = '[1,1,1]';
update vec_t1 set c4 = '[1,2,3]' where c1 = 1;

--echo # 查询索引表
--disable_query_log
eval select count(*) from $center_id_table;
eval select count(*) from $cid_vector_table;
eval select count(*) from $rowkey_cid_table;
eval select count(*) from $meta_table;
--enable_query_log

drop table vec_t1;

--echo # 多分区先建索引
--disable_warnings
drop table if exists vec_t1;
--enable_warnings

CREATE TABLE vec_t1 (c1 int primary key, c4 vector(3),
VECTOR INDEX idx1(c4)
WITH (distance=l2, type=ivf_sq8))
PARTITION BY RANGE(c1) (
    PARTITION p0 VALUES less than(10),
    PARTITION p1 VALUES less than(20),
    PARTITION p2 VALUES less than(MAXVALUE)
);

