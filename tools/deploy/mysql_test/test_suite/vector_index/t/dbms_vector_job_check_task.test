#owner: shanhaikang.shk
#owner group: hangzhou
--echo # DBMS VECTOR job check task

SET @@recyclebin = off;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop database if exists shk_new_test;
--enable_warnings
--disable_query_log
--disable_result_log
alter system set ob_vector_memory_limit_percentage = 30;
--enable_result_log
--enable_query_log

--disable_query_log
--disable_result_log
sleep 3;
--enable_result_log
--enable_query_log

--disable_query_log
--disable_result_log
select @refresh_vidx_jobs0 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log

--echo "=========================== basic ======================="
create table t1(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=hnsw, lib=vsag));
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
let $shk_database_name = test;
let $shk_table_name = t1;
let $shk_vidx_name = idx1;
--source mysql_test/include/check_dbms_vector_job.inc

# rename table场景
--echo "=========================== rename table ======================="
create database if not exists shk_new_test;
rename table t1 to shk_new_test.new_t1;
use shk_new_test;
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
let $shk_database_name = shk_new_test;
let $shk_table_name = new_t1;
--source mysql_test/include/check_dbms_vector_job.inc
drop table new_t1;
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 THEN 'TRUE' ELSE 'FALSE' end as res;

# 索引名大小写
# 默认模式，索引名大小写
--echo "=========================== default: vector index name case ======================="
use test;
drop database if exists shk_new_test;
create table t1(c1 int, c2 vector(3), c3 vector(3), primary key(c1));
create vector index idx1 on t1(c2) with(distance=l2, type=hnsw, lib=vsag);
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
let $shk_database_name = test;
let $shk_table_name = t1;
let $shk_vidx_name = idx1;
--source mysql_test/include/check_dbms_vector_job.inc
--error 1061
create vector index IDX1 on t1(c3) with(distance=l2, type=hnsw, lib=vsag);
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
let $shk_database_name = test;
let $shk_table_name = t1;
let $shk_vidx_name = idx1;
--source mysql_test/include/check_dbms_vector_job.inc
drop table t1;
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 THEN 'TRUE' ELSE 'FALSE' end as res;

# 特殊字符
--echo "=========================== special char ======================="
create table t1(c1 int, c2 vector(3), primary key(c1));
create vector index `idx\n1` on t1(c2) with(distance=l2, type=hnsw, lib=vsag);
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
drop table t1;
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 THEN 'TRUE' ELSE 'FALSE' end as res;

# 同名索引
# 同一个DB不同表有相同索引名
--echo "=========================== index with the same name in a db ======================="
create table t1(c1 int, c2 vector(3), primary key(c1));
create table t2(c1 int, c2 vector(3), primary key(c1));
create vector index idx on t1(c2) with(distance=l2, type=hnsw, lib=vsag);
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
let $shk_database_name = test;
let $shk_table_name = t1;
let $shk_vidx_name = idx;
--source mysql_test/include/check_dbms_vector_job.inc
create vector index idx on t2(c2) with(distance=l2, type=hnsw, lib=vsag);
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 8 THEN 'TRUE' ELSE 'FALSE' end as res;
let $shk_database_name = test;
let $shk_table_name = t2;
let $shk_vidx_name = idx;
--source mysql_test/include/check_dbms_vector_job.inc
drop table t1;
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
drop table t2;
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 THEN 'TRUE' ELSE 'FALSE' end as res;


# 不同DB相同表相同索引名
--echo "=========================== the same index name, the same table name, in different db ======================="
create database if not exists shk_new_test;
create table t1(c1 int, c2 vector(3), primary key(c1));
create vector index idx on t1(c2) with(distance=l2, type=hnsw, lib=vsag);
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
use shk_new_test;
create table t1(c1 int, c2 vector(3), primary key(c1));
create vector index idx on t1(c2) with(distance=l2, type=hnsw, lib=vsag);
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 8 THEN 'TRUE' ELSE 'FALSE' end as res;
let $shk_database_name = shk_new_test;
let $shk_table_name = t1;
let $shk_vidx_name = idx;
--source mysql_test/include/check_dbms_vector_job.inc
let $shk_database_name = test;
let $shk_table_name = t1;
let $shk_vidx_name = idx;
--source mysql_test/include/check_dbms_vector_job.inc
drop table t1;
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
use test;
drop database shk_new_test;
let $shk_database_name = test;
let $shk_table_name = t1;
let $shk_vidx_name = idx;
--source mysql_test/include/check_dbms_vector_job.inc
drop table t1;
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 THEN 'TRUE' ELSE 'FALSE' end as res;

# 删除索引+立即新建同名

# 串行建表
--echo "=========================== simple create table with vector index ======================="
use test;
alter system set _enable_parallel_table_creation = false;
create table t1(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=hnsw, lib=vsag));
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
let $shk_database_name = test;
let $shk_table_name = t1;
let $shk_vidx_name = idx1;
--source mysql_test/include/check_dbms_vector_job.inc
drop table t1;
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 THEN 'TRUE' ELSE 'FALSE' end as res;
alter system set _enable_parallel_table_creation = true;