#owner: fanfangyao.ffy
#owner group: storage group
# Test for vector index and FTS index creation to verify push execution id fix

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--sleep 2

connection obsys;
let $new_primary_zone = query_get_value(select GROUP_CONCAT(zone) from __all_server, GROUP_CONCAT(zone), 1);
let $tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
let $origin_primary_zone = query_get_value(select primary_zone from __all_tenant where tenant_name = 'mysql', primary_zone, 1);

--replace_regex /PRIMARY_ZONE = '.*'/PRIMARY_ZONE = "new_primary_zone"/g
eval alter tenant mysql PRIMARY_ZONE = '$new_primary_zone';

sleep 5;


connection conn1;
--disable_warnings
drop table if exists t100;
--enable_warnings

create table t100(c1 int primary key, c2 sparsevector, c3 vector(2)) PARTITION BY HASH(c1) PARTITIONS 2;

INSERT INTO t100 VALUES(1, '{1:0.1,2:0.2, 3:0.3}', '[0.203846,0.205289]');
INSERT INTO t100 VALUES(2, '{3:0.3, 2:0.2, 4:0.4}', '[0.880265,0.824340]');
INSERT INTO t100 VALUES(3, '{3:0.3, 4:0.4, 5:0.5}', '[0.824340,0.615737]');
INSERT INTO t100 VALUES(4, '{5:0.5, 4:0.4, 6:0.6}', '[0.615737,0.496899]');
INSERT INTO t100 VALUES(5, '{5:0.5, 6:0.6, 7:0.7}', '[0.496899,0.983632]');
INSERT INTO t100 VALUES(6, '{7:0.7, 6:0.6, 8:0.8}', '[0.983632,0.865571]');
INSERT INTO t100 VALUES(7, '{7:0.7, 8:0.8, 9:0.9}', '[0.865571,0.248373]');
INSERT INTO t100 VALUES(8, '{9:0.9, 8:0.8, 10:1.0}', '[0.659316,0.765661]');
INSERT INTO t100 VALUES(9, '{9:0.9, 10:1.0, 11:1.1}', '[0.579658,0.933939]');
INSERT INTO t100 VALUES(10, '{11:1.1, 10:1.0, 12:1.2}', '[0.048756,0.084670]');

# Create vector index (VSAG with SINDI type)
create vector index idx1 on t100(c2)
      with (lib=vsag, type=sindi, distance=inner_product,
        prune=true, refine=true, drop_ratio_build=0.1,
        drop_ratio_search=0.5, refine_k=2.0);

alter table t100 add col text;

UPDATE t100 SET col = CONCAT('text_content_', c1) WHERE c1 <= 10;

# Create fulltext index
alter table t100 add fulltext(col);

# Create HNSW index
create vector index idx2 on t100(c3) with (lib=vsag, type=hnsw, distance=l2, m=16);

DROP TABLE t100;

connection obsys;
--replace_regex /PRIMARY_ZONE = '.*'/PRIMARY_ZONE = "origin_primary_zone"/g
eval alter tenant mysql PRIMARY_ZONE = '$origin_primary_zone';
