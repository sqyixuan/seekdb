--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : luohongdi.lhd
#owner group: shenzhen
#description: basic test vector index ivf async task

connect (conn_sys,$OBMYSQL_MS0,root@sys,,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

connection conn_sys;
alter system set debug_sync_timeout = '100s';
sleep 3;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now broadcast continue_signal';
sleep 3;

connection conn1;
alter system set ob_vector_memory_limit_percentage = 20;
--disable_warnings
drop table if exists vec_t1;
drop view if exists view_liyao;
--enable_warnings

--echo # 非分区表
connection conn1;
create table vec_t1 (c1 int AUTO_INCREMENT, c2 vector(10), c3 vector(10), c4 varchar(10), c5 int UNIQUE, c6 int,
  PRIMARY KEY(c1, c4),
  INDEX (c5, c6));

--source mysql_test/test_suite/vector_index/include/ivf_vec_dataset.inc

create view view_liyao as select * from vec_t1;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'HANDLE_VECTOR_INDEX_ASYNC_TASK wait_for continue_signal execute 10000';

connection conn1;
create vector index idx1 on vec_t1(c2) WITH (distance=l2, type=ivf_pq, lib=OB, nlist=5, sample_per_nlist=15, m=5);
create vector index idx2 on vec_t1(c3) with (distance=l2, type=hnsw, lib=vsag);
let $tenant_id = query_get_value(select effective_tenant_id() as tenant_id, tenant_id, 1);
let $database_id = `select database_id from oceanbase.__all_database where database_name='test';`;
let $table_id = `select table_id from oceanbase.__all_table where table_name = 'vec_t1' and database_id=$database_id;`;
let $center_id_table1 = `select CONCAT('__idx_', $table_id , '_idx1');`;
let $index_table_id1 = `select table_id from oceanbase.__all_table where table_name = '$center_id_table1' and database_id=$database_id;`;

--echo # 加载补缓存任务，任务数 = 分区数 x 表上索引数
--disable_query_log
--let $task_cnt = 0
while ($task_cnt != 1) {
  sleep 1;
  let $task_cnt = query_get_value(select count(status) as task_cnt from oceanbase.__all_vector_index_task where table_id=$index_table_id1, task_cnt, 1);
}
--enable_query_log

--disable_query_log
eval select trigger_type, task_type, ret_code from oceanbase.__all_vector_index_task where table_id=$index_table_id1;
eval select trigger_type, task_type, ret_code from oceanbase.DBA_OB_VECTOR_INDEX_TASKS where table_id=$index_table_id1;
--enable_query_log

connection conn_sys;
--disable_query_log
eval select trigger_type, task_type, ret_code from oceanbase.__all_virtual_vector_index_task where table_id=$index_table_id1 and tenant_id=$tenant_id;
eval select trigger_type, task_type, ret_code from oceanbase.CDB_OB_VECTOR_INDEX_TASKS where table_id=$index_table_id1 and tenant_id=$tenant_id;
--enable_query_log

--echo # 执行补缓存任务
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now broadcast continue_signal';

connection conn1;
# 等待任务结束并转移到历史表
--disable_query_log
--let $task_cnt = 0
while ($task_cnt != 1) {
  sleep 1;
  let $task_cnt = query_get_value(select count(status) as task_cnt from oceanbase.__all_vector_index_task_history where table_id=$index_table_id1, task_cnt, 1);
}
--enable_query_log

--disable_query_log
eval select trigger_type, task_type, status, ret_code from oceanbase.__all_vector_index_task_history where table_id=$index_table_id1;
eval select trigger_type, task_type, status, ret_code from oceanbase.DBA_OB_VECTOR_INDEX_TASK_HISTORY where table_id=$index_table_id1;
--enable_query_log

connection conn_sys;
--disable_query_log
eval select trigger_type, task_type, status, ret_code from oceanbase.__all_virtual_vector_index_task_history where table_id=$index_table_id1 and tenant_id=$tenant_id;
eval select trigger_type, task_type, status, ret_code from oceanbase.CDB_OB_VECTOR_INDEX_TASK_HISTORY where table_id=$index_table_id1 and tenant_id=$tenant_id;
--enable_query_log
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'HANDLE_VECTOR_INDEX_ASYNC_TASK wait_for continue_signal execute 10000';

connection conn1;
drop view view_liyao;
drop table vec_t1;

--echo # 加载删除任务，任务数 = 分区数 x 表上索引数
--disable_query_log
--let $task_cnt = 0
while ($task_cnt != 1) {
  sleep 1;
  let $task_cnt = query_get_value(select count(status) as task_cnt from oceanbase.__all_vector_index_task where table_id=$index_table_id1, task_cnt, 1);
}
--enable_query_log

--disable_query_log
eval select trigger_type, task_type, ret_code from oceanbase.__all_vector_index_task where table_id=$index_table_id1;
eval select trigger_type, task_type, ret_code from oceanbase.DBA_OB_VECTOR_INDEX_TASKS where table_id=$index_table_id1;
--enable_query_log

connection conn_sys;
--disable_query_log
eval select trigger_type, task_type, ret_code from oceanbase.__all_virtual_vector_index_task where table_id=$index_table_id1 and tenant_id=$tenant_id;
eval select trigger_type, task_type, ret_code from oceanbase.CDB_OB_VECTOR_INDEX_TASKS where table_id=$index_table_id1 and tenant_id=$tenant_id;
--enable_query_log

--echo # 执行删除任务
--disable_query_log
connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now broadcast continue_signal';

# 等待任务结束并转移到历史表
connection conn1;
--let $task_cnt = 0
while ($task_cnt != 1) {
  sleep 1;
  let $task_cnt = query_get_value(select count(status) as task_cnt from oceanbase.__all_vector_index_task_history where table_id=$index_table_id1, task_cnt, 1);
}
--enable_query_log

--disable_query_log
eval select trigger_type, task_type, status, ret_code from oceanbase.__all_vector_index_task_history where table_id=$index_table_id1;
eval select trigger_type, task_type, status, ret_code from oceanbase.DBA_OB_VECTOR_INDEX_TASK_HISTORY where table_id=$index_table_id1;
--enable_query_log

connection conn_sys;
--disable_query_log
eval select trigger_type, task_type, status, ret_code from oceanbase.__all_virtual_vector_index_task_history where table_id=$index_table_id1 and tenant_id=$tenant_id;
eval select trigger_type, task_type, status, ret_code from oceanbase.CDB_OB_VECTOR_INDEX_TASK_HISTORY where table_id =$index_table_id1 and tenant_id=$tenant_id;
--enable_query_log



--echo # 分区表
connection conn1;
create table vec_t1 (c1 int AUTO_INCREMENT, c2 vector(10), c3 vector(10), c4 varchar(10), c5 int, c6 int,
  PRIMARY KEY(c1, c4),
  INDEX (c5, c6))
PARTITION BY RANGE COLUMNS(c1)
(
  PARTITION p0 VALUES LESS THAN(20),
  PARTITION p1 VALUES LESS THAN(40),
  PARTITION p2 VALUES LESS THAN(60),
  PARTITION p3 VALUES LESS THAN(80),
  PARTITION p4 VALUES LESS THAN MAXVALUE
);

--source mysql_test/test_suite/vector_index/include/ivf_vec_dataset.inc

create view view_liyao as select * from vec_t1;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'HANDLE_VECTOR_INDEX_ASYNC_TASK wait_for continue_signal execute 10000';

connection conn1;
create vector index idx1 on vec_t1 (c2) with (distance=l2, type=ivf_pq, nlist=2, sample_per_nlist=3, m=5);
create vector index idx2 on vec_t1 (c3) with (distance=l2, type=ivf_flat, nlist=2, sample_per_nlist=3);
let $tenant_id = query_get_value(select effective_tenant_id() as tenant_id, tenant_id, 1);
let $database_id = `select database_id from oceanbase.__all_database where database_name='test';`;
let $table_id = `select table_id from oceanbase.__all_table where table_name = 'vec_t1' and database_id=$database_id;`;
let $center_id_table1 = `select CONCAT('__idx_', $table_id , '_idx1');`;
let $index_table_id1 = `select table_id from oceanbase.__all_table where table_name = '$center_id_table1' and database_id=$database_id;`;
let $center_id_table2= `select CONCAT('__idx_', $table_id , '_idx2');`;
let $index_table_id2 = `select table_id from oceanbase.__all_table where table_name = '$center_id_table2' and database_id=$database_id;`;

--echo # 加载补缓存任务，任务数 = 分区数 x 表上索引数
--disable_query_log
--let $task_cnt = 0
while ($task_cnt != 10) {
  sleep 1;
  let $task_cnt = query_get_value(select count(status) as task_cnt from oceanbase.__all_vector_index_task where table_id=$index_table_id1 or table_id=$index_table_id2, task_cnt, 1);
}
--enable_query_log

--disable_query_log
eval select trigger_type, task_type, ret_code from oceanbase.__all_vector_index_task where table_id=$index_table_id1 or table_id=$index_table_id2;
eval select trigger_type, task_type, ret_code from oceanbase.DBA_OB_VECTOR_INDEX_TASKS where table_id=$index_table_id1 or table_id=$index_table_id2;
--enable_query_log

connection conn_sys;
--disable_query_log
eval select trigger_type, task_type, ret_code from oceanbase.__all_virtual_vector_index_task where table_id in ($index_table_id1, $index_table_id2) and tenant_id=$tenant_id;
eval select trigger_type, task_type, ret_code from oceanbase.CDB_OB_VECTOR_INDEX_TASKS where table_id in ($index_table_id1, $index_table_id2) and tenant_id=$tenant_id;
--enable_query_log

--echo # 执行补缓存任务
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now broadcast continue_signal';

connection conn1;
# 等待任务结束并转移到历史表
--disable_query_log
--let $task_cnt = 0
while ($task_cnt != 10) {
  sleep 1;
  let $task_cnt = query_get_value(select count(status) as task_cnt from oceanbase.__all_vector_index_task_history where table_id=$index_table_id1 or table_id=$index_table_id2, task_cnt, 1);
}
--enable_query_log

--disable_query_log
eval select trigger_type, task_type, status, ret_code from oceanbase.__all_vector_index_task_history where table_id in ($index_table_id1, $index_table_id2);
eval select trigger_type, task_type, status, ret_code from oceanbase.DBA_OB_VECTOR_INDEX_TASK_HISTORY where table_id in ($index_table_id1, $index_table_id2);
--enable_query_log

connection conn_sys;
--disable_query_log
eval select trigger_type, task_type, status, ret_code from oceanbase.__all_virtual_vector_index_task_history where table_id in ($index_table_id1, $index_table_id2) and tenant_id=$tenant_id;
eval select trigger_type, task_type, status, ret_code from oceanbase.CDB_OB_VECTOR_INDEX_TASK_HISTORY where table_id in ($index_table_id1, $index_table_id2) and tenant_id=$tenant_id;
--enable_query_log
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'HANDLE_VECTOR_INDEX_ASYNC_TASK wait_for continue_signal execute 10000';

connection conn1;
drop view view_liyao;
drop table vec_t1;

--echo # 加载删除任务，任务数 = 分区数 x 表上索引数
--disable_query_log
--let $task_cnt = 0
while ($task_cnt != 10) {
  sleep 1;
  let $task_cnt = query_get_value(select count(status) as task_cnt from oceanbase.__all_vector_index_task where table_id=$index_table_id1 or table_id=$index_table_id2, task_cnt, 1);
}
--enable_query_log

--disable_query_log
eval select trigger_type, task_type, ret_code from oceanbase.__all_vector_index_task where table_id in ($index_table_id1, $index_table_id2);
eval select trigger_type, task_type, ret_code from oceanbase.DBA_OB_VECTOR_INDEX_TASKS where table_id in ($index_table_id1, $index_table_id2);
--enable_query_log

connection conn_sys;
--disable_query_log
eval select trigger_type, task_type, ret_code from oceanbase.__all_virtual_vector_index_task where table_id in ($index_table_id1, $index_table_id2) and tenant_id=$tenant_id;
eval select trigger_type, task_type, ret_code from oceanbase.CDB_OB_VECTOR_INDEX_TASKS where table_id in ($index_table_id1, $index_table_id2) and tenant_id=$tenant_id;
--enable_query_log

--echo # 执行删除任务
--disable_query_log
connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now broadcast continue_signal';

# 等待任务结束并转移到历史表
connection conn1;
--let $task_cnt = 0
while ($task_cnt != 10) {
  sleep 1;
  let $task_cnt = query_get_value(select count(status) as task_cnt from oceanbase.__all_vector_index_task_history where table_id=$index_table_id1 or table_id=$index_table_id2, task_cnt, 1);
}
--enable_query_log

--disable_query_log
eval select trigger_type, task_type, status, ret_code from oceanbase.__all_vector_index_task_history where table_id in ($index_table_id1, $index_table_id2);
eval select trigger_type, task_type, status, ret_code from oceanbase.DBA_OB_VECTOR_INDEX_TASK_HISTORY where table_id in ($index_table_id1, $index_table_id2);
--enable_query_log

connection conn_sys;
--disable_query_log
eval select trigger_type, task_type, status, ret_code from oceanbase.__all_virtual_vector_index_task_history where table_id in ($index_table_id1, $index_table_id2) and tenant_id=$tenant_id;
eval select trigger_type, task_type, status, ret_code from oceanbase.CDB_OB_VECTOR_INDEX_TASK_HISTORY where table_id in ($index_table_id1, $index_table_id2) and tenant_id=$tenant_id;
--enable_query_log

