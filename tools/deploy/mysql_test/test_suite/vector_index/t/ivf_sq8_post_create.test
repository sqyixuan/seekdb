# owner: xiongliyao.xly
# owner group: shenzhen
# description: test create vector index

connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);

--disable_warnings
DROP TABLE IF EXISTS sq_vec_table;
--enable_warnings

alter system set ob_vector_memory_limit_percentage = 40;
sleep 3;

--echo ====================== test #1 =======================
--echo create ivf sq8 vec index on existing table
CREATE TABLE sq_vec_table (
  id int,
  c2 vector(10));

sleep 2;
create vector index vec_idx1 on sq_vec_table(c2) with (distance=l2, type=ivf_sq8, lib=OB);

connection sys_conn;

let $tenant_id = query_get_value(SELECT tenant_id
                                FROM __all_tenant
                                where tenant_name = 'sys', tenant_id, 1);

let $data_table_id = query_get_value(SELECT table_id
                                     FROM __all_virtual_table
                                     WHERE table_name = 'sq_vec_table'
                                       AND tenant_id = $tenant_id, table_id, 1);

# check vec generate columns on sq_vec_table table
--echo ===== ivf sq8 sq_vec_table columns =============
--disable_query_log
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $data_table_id
       AND tenant_id = $tenant_id;

# expect 4 vec aux index tables
--echo ===== ivf sq8 index aux tables =====
--replace_regex /__idx_[0-9]*/__idx_DATA_TABLE_ID/g
eval SELECT table_name
     FROM __all_virtual_table
     WHERE data_table_id = $data_table_id
       AND tenant_id = $tenant_id
       AND table_name LIKE '__idx%';
--enable_query_log

# get table id of 4 corresponding vec aux index table exists
let $sq_centroid_table_id = query_get_value(
  SELECT table_id
  FROM __all_virtual_table
  WHERE table_name LIKE '%vec_idx1'
    AND tenant_id = $tenant_id
    AND data_table_id = $data_table_id, table_id, 1);
let $sq_meta_table_id = query_get_value(
  SELECT table_id
  FROM __all_virtual_table
  WHERE table_name LIKE '%vec_idx1_ivf_sq_meta'
    AND tenant_id = $tenant_id
    AND data_table_id = $data_table_id, table_id, 1);
let $sq_cid_table_id = query_get_value(
  SELECT table_id
  FROM __all_virtual_table
  WHERE table_name LIKE '%vec_idx1_ivf_cid_vector'
    AND tenant_id = $tenant_id
    AND data_table_id = $data_table_id, table_id, 1);
let $sq_rowkey_cid_table_id = query_get_value(
  SELECT table_id
  FROM __all_virtual_table
  WHERE table_name LIKE '%vec_idx1_ivf_rowkey_cid'
    AND tenant_id = $tenant_id
    AND data_table_id = $data_table_id, table_id, 1);

--disable_query_log

--echo ===== sq_vec_table vec_idx1 cols ===
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $sq_centroid_table_id
       AND tenant_id = $tenant_id;

--echo ===== sq_vec_table vec_idx1_ivf_sq_meta cols ===
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $sq_meta_table_id
       AND tenant_id = $tenant_id;

--echo ===== sq_vec_table vec_idx1_ivf_cid_vector cols ======
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $sq_cid_table_id
       AND tenant_id = $tenant_id;

--echo ===== sq_vec_table vec_idx1_ivf_rowkey_cid cols ===
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $sq_rowkey_cid_table_id
       AND tenant_id = $tenant_id;

--disable_warnings
DROP TABLE IF EXISTS sq_vec_table;
--enable_warnings

--enable_query_log
--echo clear
alter system set ob_vector_memory_limit_percentage = 0;
disconnect sys_conn;

connect (conn_user,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn_user;

alter system set ob_vector_memory_limit_percentage = 20;
set ob_enable_index_direct_select = 1;

--disable_warnings
drop database if exists post_create_vec;
--enable_warnings
create database post_create_vec;
use post_create_vec;

# __all_ddl_operation
--echo
--echo
--echo "=========================================== __all_ddl_operation ==========================================="
--disable_warnings
drop table if exists vec_table;
--enable_warnings
CREATE TABLE vec_table (
  id int,
  c2 vector(10));

sleep 3;
CREATE VECTOR INDEX VEC_IDX1 ON vec_table(c2) with (distance=l2, type=ivf_sq8, lib=OB);

select operation_type, ddl_stmt_str from oceanbase.__all_ddl_operation 
   where database_id = (select database_id from oceanbase.__all_database where database_name='post_create_vec') 
          and ddl_stmt_str != '' order by schema_version;

drop table vec_table;

# 索引名有转义字符
--echo
--echo
--echo "=========================================== 索引名有转义字符 ================================================="
--disable_warnings
drop table if exists t_vec;
--enable_warnings
create table t_vec(c1 int, c2 vector(3), primary key(c1));

create vector index `idx\n1` ON t_vec(c2) with (distance=l2, type=ivf_sq8, lib=OB);
drop table t_vec;

# 索引名有大小写
--echo
--echo
--echo "=========================================== 索引名有大小写 ==================================================="
--disable_warnings
drop table if exists t_vec;
--enable_warnings
create table t_vec(c1 int, c2 vector(3), primary key(c1));

create vector index iDx1 ON t_vec(c2) with (distance=l2, type=ivf_sq8, lib=OB);
drop table t_vec;

# 索引名有特殊字符
# case 1
--echo
--echo
--echo "========================================== 索引名有特殊字符 001 ==============================================="

--disable_warnings
drop table if exists t_vec;
--enable_warnings
create table t_vec(c1 int, c2 vector(3), primary key(c1));

create vector index iDx$1 ON t_vec(c2) with (distance=l2, type=ivf_sq8, lib=OB);
drop table t_vec;

# case 2
--echo
--echo
--echo "========================================== 索引名有特殊字符 002 ==============================================="
--disable_warnings
drop table if exists t_vec;
--enable_warnings
create table t_vec(c1 int, c2 vector(3), primary key(c1));
create vector index café ON t_vec(c2) with (distance=l2, type=ivf_sq8, lib=OB);
drop table t_vec;

# case 特殊字符café与cafe，认为创建同名索引失败
--echo
--echo
--echo "========================================== 索引名有特殊字符 003 ==============================================="
--disable_warnings
drop table if exists t_vec;
--enable_warnings
create table t_vec(c1 int, c2 vector(3), c3 vector(3), primary key(c1));
create vector index café ON t_vec(c2) with (distance=l2, type=ivf_sq8, lib=OB);
--error 1061
create vector index cafe ON t_vec(c3) with (distance=l2, type=ivf_sq8, lib=OB);
drop table t_vec;


--disable_warnings
drop table if exists vec_tmp;
--enable_warnings
create table vec_tmp(c1 int, c2 vector(10));
insert into vec_tmp values(1, '[0.748479,0.276979,0.555195,0.145492,0.045639,0.924278,0.696082,0.841479,0.742934,0.953073]');
--error 1235
create unique index idx1 on vec_tmp(c2) with (distance=l2, type=ivf_sq8, lib=OB);
--error 1072
create vector index idx1 on vec_tmp(c5) with (distance=l2, type=ivf_sq8, lib=OB);
--error 7601
create vector index idx1 on vec_tmp(c1) with (distance=l2, type=ivf_sq8, lib=OB);
--error 1235
create vector index idx1 on vec_tmp(c2);
--error 1235
create vector index idx1 on vec_tmp(c2) with (distance=l2);
--error 1235
create vector index idx1 on vec_tmp(c2) with (distance=l2, lib=OB);
--error 1235
create vector index idx1 on vec_tmp(c2) with (distance=l2, lib=vs);
CREATE VECTOR INDEX IDX1 ON vec_tmp(c2) with (distance=l2, type=ivf_sq8, lib=OB);
drop table vec_tmp;



--echo ====================== test #2 =================================
--echo ============= create vec index on existing table with data ===========

--disable_warnings
DROP TABLE IF EXISTS vec_t1;
DROP VIEW IF EXISTS view_liyao;
--enable_warnings

create table vec_t1 (c1 int AUTO_INCREMENT, c2 vector(10), c3 vector(10), c4 varchar(10), c5 int UNIQUE, c6 int,
  PRIMARY KEY(c1, c4),
  INDEX (c5, c6));
--source mysql_test/test_suite/vector_index/include/ivf_vec_dataset.inc    

alter system set ob_vector_memory_limit_percentage = 20;
--echo # 指定nlist和samples_per_nlist
create vector index idx1 on vec_t1(c2) WITH (distance=l2, type=ivf_sq8, lib=OB, nlist=5, sample_per_nlist=15);
create view view_liyao as select * from vec_t1;

let $database_id = `select database_id from oceanbase.__all_database where database_name='post_create_vec';`;
let $table_id = `select table_id from oceanbase.__all_table where table_name = 'vec_t1' and database_id=$database_id;`;
let $center_id_table = `select CONCAT('__idx_', $table_id , '_idx1');`;
let $meta_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_sq_meta');`;
let $cid_vector_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_cid_vector');`;
let $rowkey_cid_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_rowkey_cid');`;

--echo # 查询索引表
--disable_query_log
eval select count(*) from $center_id_table;
eval select count(*) from $cid_vector_table;
eval select count(*) from $rowkey_cid_table;
eval select count(*) from $meta_table;
--enable_query_log

--echo # 默认参数
create vector index idx2 on vec_t1(c3) WITH (distance=l2, type=ivf_sq8, lib=OB);
--echo # 查询索引表

let $center_id_table = `select CONCAT('__idx_', $table_id , '_idx2');`;
let $meta_table = `select CONCAT('__idx_', $table_id , '_idx2_ivf_sq_meta');`;
let $cid_vector_table = `select CONCAT('__idx_', $table_id , '_idx2_ivf_cid_vector');`;
let $rowkey_cid_table = `select CONCAT('__idx_', $table_id , '_idx2_ivf_rowkey_cid');`;

--disable_query_log
eval select count(*) from $center_id_table;
eval select count(*) from $cid_vector_table;
eval select count(*) from $rowkey_cid_table;
eval select count(*) from $meta_table;
--enable_query_log

--echo # 分区表
--disable_warnings
DROP TABLE IF EXISTS vec_t1;
DROP VIEW IF EXISTS view_liyao;
--enable_warnings

create table vec_t1 (c1 int AUTO_INCREMENT, c2 vector(10), c3 vector(10), c4 varchar(10), c5 int, c6 int,
  PRIMARY KEY(c1, c4),
  INDEX (c5, c6))
PARTITION BY RANGE(c1) (
    PARTITION p0 VALUES less than(30),
    PARTITION p1 VALUES less than(60),
    PARTITION p2 VALUES less than(MAXVALUE)
);

--source mysql_test/test_suite/vector_index/include/ivf_vec_dataset.inc

--echo # 指定nlist和samples_per_nlist
create vector index idx1 on vec_t1(c2) WITH (distance=l2, type=ivf_sq8, lib=OB, nlist=5, sample_per_nlist=15);
create view view_liyao as select * from vec_t1;

let $database_id = `select database_id from oceanbase.__all_database where database_name='post_create_vec';`;
let $table_id = `select table_id from oceanbase.__all_table where table_name = 'vec_t1' and database_id=$database_id;`;
let $center_id_table = `select CONCAT('__idx_', $table_id , '_idx1');`;
let $meta_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_sq_meta');`;
let $cid_vector_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_cid_vector');`;
let $rowkey_cid_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_rowkey_cid');`;

--echo # 查询索引表
--disable_query_log
eval select count(*) from $center_id_table;
eval select count(*) from $cid_vector_table;
eval select count(*) from $rowkey_cid_table;
eval select count(*) from $meta_table;
--enable_query_log

--echo # 默认参数
create vector index idx2 on vec_t1(c3) WITH (distance=l2, type=ivf_sq8, lib=OB);
--echo # 查询索引表

let $center_id_table = `select CONCAT('__idx_', $table_id , '_idx2');`;
let $meta_table = `select CONCAT('__idx_', $table_id , '_idx2_ivf_sq_meta');`;
let $cid_vector_table = `select CONCAT('__idx_', $table_id , '_idx2_ivf_cid_vector');`;
let $rowkey_cid_table = `select CONCAT('__idx_', $table_id , '_idx2_ivf_rowkey_cid');`;

--disable_query_log
eval select count(*) from $center_id_table;
eval select count(*) from $cid_vector_table;
eval select count(*) from $rowkey_cid_table;
eval select count(*) from $meta_table;
--enable_query_log

drop table vec_t1;
drop view view_liyao;

--echo ====================== test #3 =================================
--echo ============= use dataset with dml ===========
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (id int primary key, wine_type int, wine_data vector(13), iris_type varchar(20), iris_data vector(4), data vector(3));

--source mysql_test/test_suite/vector_index/include/wine_dataset.inc

--source mysql_test/test_suite/vector_index/include/iris_dataset.inc

--let $insert_sql_prefix = insert into t1 (id, data) values
--let $value = (500,'[0,0,0]')
--let $loop = 501
--let $data = 1
while ($loop < 800)
{
  --let $value = $value, ($loop , '[$data, $data, $data]')
  inc $loop;
  inc $data;
}
--let $insert_sql = $insert_sql_prefix$value

--disable_query_log
eval $insert_sql;
--enable_query_log

# 存在null向量
create vector index idx1 on t1 (wine_data) with (distance=l2, type=ivf_sq8, nlist=3, sample_per_nlist=50);
create vector index idx2 on t1 (iris_data) with (distance=l2, type=ivf_sq8, nlist=3, sample_per_nlist=50);
create vector index idx3 on t1 (data) with (distance=l2, type=hnsw, lib=vsag, m=10, ef_construction=11, ef_search=40);

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

select count(*) from t1;

let $table_id = `select table_id from oceanbase.__all_table where table_name = 't1' and database_id=$database_id;`;
let $center_id_table = `select CONCAT('__idx_', $table_id , '_idx1');`;
let $meta_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_sq_meta');`;
let $cid_vector_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_cid_vector');`;
let $rowkey_cid_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_rowkey_cid');`;

--echo # 查询索引表
--disable_query_log
eval select count(*) from $center_id_table;
eval select count(*) from $cid_vector_table;
eval select count(*) from $rowkey_cid_table;
eval select count(*) from $meta_table;
--enable_query_log

let $center_id_table = `select CONCAT('__idx_', $table_id , '_idx2');`;
let $meta_table = `select CONCAT('__idx_', $table_id , '_idx2_ivf_sq_meta');`;
let $cid_vector_table = `select CONCAT('__idx_', $table_id , '_idx2_ivf_cid_vector');`;
let $rowkey_cid_table = `select CONCAT('__idx_', $table_id , '_idx2_ivf_rowkey_cid');`;

--disable_query_log
eval select count(*) from $center_id_table;
eval select count(*) from $cid_vector_table;
eval select count(*) from $rowkey_cid_table;
eval select count(*) from $meta_table;
--enable_query_log

# origin id = 1
update t1 set wine_data = '[14.23,1.71,2.43,15.6,127,2.8,3.06,0.28,2.29,5.64,1.04,3.92,1065]' where id = 201;
# origin id = 110
update t1 set wine_data = '[11.61,1.35,2.7,20,94,2.74,2.92,0.29,2.49,2.65,0.96,3.26,680]' where id = 202;
# origin id = 2
insert into t1(id, wine_type, wine_data) values(203, 1, '[13.2,1.78,2.14,11.2,100,2.65,2.76,0.26,1.28,4.38,1.05,3.4,1050]') ON DUPLICATE KEY UPDATE wine_data = '[13.2,1.78,2.14,11.2,100,2.65,2.76,0.26,1.28,4.38,1.05,3.4,1050]';
# origin id = 178
insert into t1(id, wine_type, wine_data) values(179, 3,'[14.13,4.1,2.74,24.5,96,2.05,0.76,0.56,1.35,9.2,0.61,1.6,560]') ON DUPLICATE KEY UPDATE wine_data = '[13.2,1.78,2.14,11.2,100,2.65,2.76,0.26,1.28,4.38,1.05,3.4,1050]';
delete from t1 where id = 178;
replace into t1(id, wine_type, wine_data) values(180, 3,'[13.17,2.59,2.37,20,120,1.65,0.68,0.53,1.46,9.3,0.6,1.62,840]');

select count(*) from t1;

let $center_id_table = `select CONCAT('__idx_', $table_id , '_idx1');`;
let $meta_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_sq_meta');`;
let $cid_vector_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_cid_vector');`;
let $rowkey_cid_table = `select CONCAT('__idx_', $table_id , '_idx1_ivf_rowkey_cid');`;

--echo # 查询索引表
--disable_query_log
eval select count(*) from $center_id_table;
eval select count(*) from $cid_vector_table;
eval select count(*) from $rowkey_cid_table;
eval select count(*) from $meta_table;
--enable_query_log

let $center_id_table = `select CONCAT('__idx_', $table_id , '_idx2');`;
let $meta_table = `select CONCAT('__idx_', $table_id , '_idx2_ivf_sq_meta');`;
let $cid_vector_table = `select CONCAT('__idx_', $table_id , '_idx2_ivf_cid_vector');`;
let $rowkey_cid_table = `select CONCAT('__idx_', $table_id , '_idx2_ivf_rowkey_cid');`;

--disable_query_log
eval select count(*) from $center_id_table;
eval select count(*) from $cid_vector_table;
eval select count(*) from $rowkey_cid_table;
eval select count(*) from $meta_table;
--enable_query_log

drop table t1;


--echo =================== clear ===================
drop database post_create_vec;
alter system set ob_vector_memory_limit_percentage = 0;
