#owner : yangjiali.yjl
#owner group: shenzhen
#description: rs switch when building

connect (conn_sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connect (conn_user1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

connection conn_sys;
alter system set debug_sync_timeout = '100s';
sleep 1;

connection conn_user1;
alter system set ob_vector_memory_limit_percentage = 20;
sleep 1;

--echo
--echo
--echo "================================== switch rs when rs finished create_aux_index  ==================================="
# VECTOR_INDEX_FINISH_CREATE_AUX_INDEX

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'CREATE_AUX_INDEX_TABLE wait_for continue_signal execute 10000';

connection conn_user1;
drop table if exists t_vec;
create table t_vec(c1 int, c2 vector(3), primary key(c1));
send create vector index idx1 on t_vec(c2) with (distance=l2, type=hnsw);
sleep 5;

# 切主
connection conn_sys;
# get leader
let $leader_ip_default = query_get_value(select svr_ip from oceanbase.__all_virtual_server_stat limit 1
let $leader_port_default = query_get_value(select svr_port from oceanbase.__all_virtual_server_stat limit 1
# get follower
let $follower_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_server_stat limit 1
let $follower_port = query_get_value(select svr_port from oceanbase.__all_virtual_server_stat limit 1

# switch rs
--disable_query_log
#eval ALTER SYSTEM SWITCH REPLICA leader LS = 1 SERVER = '$follower_ip:$follower_port' TENANT='sys';
let $cnt=0;
while($cnt != 1)
{
  sleep 1;
    let $cnt = query_get_value(select 1 as cnt, cnt, 1);
}
--enable_query_log

set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
sleep 2;

# wait create vector index finish
connection conn_user1;
reap;

# switch to default
connection conn_sys;
--disable_query_log
#eval ALTER SYSTEM SWITCH REPLICA leader LS = 1 SERVER = '$leader_ip_default:$leader_port_default' TENANT='sys';
let $cnt=0;

while($cnt != 1)
{
  sleep 1;
    let $cnt = query_get_value(select 1 as cnt, cnt, 1);
}
--enable_query_log

connection conn_user1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
drop table t_vec;

alter system set ob_vector_memory_limit_percentage = 0;
drop table if exists t_vec;
