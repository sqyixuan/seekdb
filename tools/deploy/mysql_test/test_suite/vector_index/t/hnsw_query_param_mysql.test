#owner: aozeliu.azl
#owner group: shenzhen
#description: vector index
#tags:vector index

purge recyclebin;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
alter system set ob_vector_memory_limit_percentage =44;
sleep 5;

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 BOOL , c4 vector(3), primary key(c3), vector index idx1(c4) with (distance=l2, type=hnsw_bq, lib=vsag));
insert into t1 values(1, 1, 1, '[0.203846,0.205289,0.880265]');
insert into t1 values(2, 2, 2, '[0.226980,0.579658,0.933939]');
insert into t1 values(3, 3, 3, '[0.181664,0.013905,0.628127]');
insert into t1 values(4, 4, 127, '[0.442633,0.637534,0.633993]');
insert into t1 values(5, 5, -127, '[0.190118,0.959676,0.796483]');
insert into t1 values(6, 6, -126, '[0.710370,0.007130,0.710913]');
insert into t1 values(7, 7, -128, '[0.238120,0.289662,0.970101]');
insert into t1 values(8, 8, 9, '[0.168794,0.567442,0.062338]');
insert into t1 values(9, 9, 0, '[0.901419,0.676738,0.122339]');
insert into t1 values(10, -1, -1, null);
insert into t1 values(11, null, 100, null);
SELECT * FROM t1  order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 10 PARAMETERS(ef_search=101);
SELECT c1 FROM t1  order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 10 PARAMETERS (ef_search=200, refine_k=5.6);

create table t2 as SELECT c1 FROM t1  order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 10 PARAMETERS (ef_search=200, refine_k=5.6);
select count(*) from t2;
drop table t2;

