--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : yangjiali.yjl
#owner group: shenzhen
#description: basic test vector index async task

connect (conn_sys,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

connection conn_sys;
alter system set debug_sync_timeout = '100s';
sleep 1;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
sleep 1;

connection conn1;
alter system set ob_vector_memory_limit_percentage = 30;

--echo
--echo
--echo "========================= test of cancel executing task =========================="

connection conn_sys;
#set ob_global_debug_sync = 'reset';
#set ob_global_debug_sync = 'CANCEL_VEC_TASK_ADD_SNAP_INDEX wait_for continue_signal execute 10000';

connection conn1;
--disable_warnings
drop table if exists t_check_kill_task;
--enable_warnings
create table t_check_kill_task(c1 int, c2 vector(3), primary key(c1));
create vector index idx_check_kill_task on t_check_kill_task(c2) with (distance=l2, type=hnsw);

# insert data
let $ins_cnt = 0;
--disable_query_log
while ($ins_cnt < 200) {
  eval insert into t_check_kill_task values ($ins_cnt, '[1,1,1]');
  inc $ins_cnt;
}
--enable_query_log

sleep 12;
--disable_result_log
select * from t_check_kill_task order by l2_distance(c2, '[2,1,1]') approximate limit 1;
--enable_result_log

let $index_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name like '__idx_%idx_check_kill_task', table_id, 1);

--disable_query_log
--let $task_cnt = 0
while ($task_cnt != 1) {
  sleep 1;
  let $task_cnt = query_get_value(select count(status) as task_cnt from oceanbase.__all_vector_index_task where status=1 and table_id=$index_table_id, task_cnt, 1);
}
--enable_query_log

let $trace_id=query_get_value(select trace_id from oceanbase.__all_vector_index_task where status=1 and table_id=$index_table_id, trace_id, 1);
connection conn_sys;
--disable_query_log
eval alter system cancel task '$trace_id';
--enable_query_log
sleep 3;

#set ob_global_debug_sync = 'reset';
#set ob_global_debug_sync = 'now signal continue_signal';

connection conn1;
--disable_query_log
--let $task_cnt = 1
while ($task_cnt != 0) {
  sleep 1;
  let $task_cnt = query_get_value(select count(*) as task_cnt from oceanbase.__all_vector_index_task, task_cnt, 1);
}
--enable_query_log

# 10s later task record will transfer to history table
sleep 12;
--disable_query_log
eval select trigger_type, task_type, status, ret_code from oceanbase.__all_vector_index_task_history where table_id = $index_table_id;
--enable_query_log

drop table t_check_kill_task;

--echo
--echo
--echo "================================== clear ==================================="

# clear history table
connection conn_sys;
alter system change tenant sys;
delete from oceanbase.__all_vector_index_task_history;

connection conn1;
--disable_warnings
drop table if exists t_check_kill_task;
--enable_warnings
alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;
