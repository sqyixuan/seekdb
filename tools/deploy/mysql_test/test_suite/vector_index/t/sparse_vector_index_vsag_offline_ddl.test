--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : ningxin.ning
#owner group: shenzhen
#description: sparse vector index offline ddl test

# connect (conn_user,$OBMYSQL_MS0,root@mysql,,test,$OBMYSQL_PORT);
# connection conn_user;

--disable_warnings
drop database if exists sparse_offline_ddl;
create database sparse_offline_ddl;
use sparse_offline_ddl;

alter system set ob_vector_memory_limit_percentage = 20;
sleep 3;
--echo
--echo
--echo "=========================================== add column ==========================================="
drop table if exists t1;
create table t1(c1 int, c2 sparsevector, primary key(c1), vector index idx1(c2) with (distance=inner_product, type=sindi, lib=vsag));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;
insert into t1 values(1, '{1:0.1, 2:0.2, 3:0.3}');
#normal add column first is ONLINE DDL now
alter table t1 add column c0 smallint first;
alter table t1 add column c3 tinyint before c1;
alter table t1 add column c4 bigint after c2;
#add auto_increment column is OFFLINE DDL
alter table t1 add column c5 int auto_increment;
alter table t1 drop c3, add c6 char(10) default 'a';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;

--echo
--echo
--echo "=========================================== modify column ================================================="
drop table if exists t1;
create table t1(c1 int, c2 int, c3 sparsevector, primary key(c1), vector index idx1(c3) with (distance=inner_product, type=sindi, lib=vsag));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;
insert into t1 values(1, 2, '{1:0.1, 2:0.2, 3:0.3}');
alter table t1 modify c1 int before c3;
alter table t1 modify c2 varchar(128) first;
alter table t1 modify c2 varchar(12) after c1;
alter table t1 modify c1 int unsigned not null auto_increment;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;

--echo
--echo
--echo "=========================================== change column ================================================="
drop table if exists t1;
create table t1(c1 int, c2 sparsevector, primary key(c1), vector index idx1(c2) with (distance=inner_product, type=sindi, lib=vsag));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;
insert into t1 values(1, '{1:0.1, 2:0.2, 3:0.3}');
alter table t1 change c1 c1 varchar(128);
--error 1235
alter table t1 change c2 c2 varchar(128) before c1;
alter table t1 change c1 c1 varchar(128) before c2;
alter table t1 change c1 c3 int after c2;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;

--echo
--echo
--echo "=========================================== drop column ================================================="
drop table if exists t1;
create table t1(c1 int, c2 int, c3 sparsevector, primary key(c1), vector index idx1(c3) with (distance=inner_product, type=sindi, lib=vsag));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;
insert into t1 values(1, 2, '{1:0.1, 2:0.2, 3:0.3}');
--error 1235
alter table t1 drop column c1;
alter table t1 drop column c2;
--error 3108
alter table t1 drop column c3;
alter table t1 drop primary key;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;

--echo
--echo
--echo "=========================================== drop index ================================================="
# not support alter table drop index yet
drop table if exists t1;
create table t1(c1 int, c2 sparsevector, primary key(c1), vector index idx1(c2) with (distance=inner_product, type=sindi, lib=vsag));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;
insert into t1 values(1, '{1:0.1, 2:0.2, 3:0.3}');
alter table t1 drop index idx1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;

--echo
--echo
--echo "=========================================== add index ================================================="
drop table if exists t1;
create table t1(c1 int, c2 sparsevector, primary key(c1));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;
insert into t1 values(1, '{1:0.1, 2:0.2, 3:0.3}');
--error 1235
alter table t1 add index idx1(c2);
# not support alter table add vector index grammar
--error 1064
alter table t1 add vector index idx1(c2) with (distance=inner_product, type=sindi, lib=vsag);
--error 1235
create index idx1 on t1(c2);
create vector index idx1 on t1(c2) with (distance=inner_product, type=sindi, lib=vsag);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;

--echo
--echo
--echo "=========================================== add primary key ================================================="
drop table if exists t1;
create table t1(c1 int, c2 sparsevector, vector index idx1(c2) with (distance=inner_product, type=sindi, lib=vsag));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;
insert into t1 values(1, '{1:0.1, 2:0.2, 3:0.3}');
alter table t1 modify c1 int primary key;
--error 1068
alter table t1 add primary key(c1);
--error 1068
alter table t1 modify c1 bigint, add primary key(c1);
alter table t1 drop primary key, add primary key(c1);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;

--echo
--echo
--echo "=========================================== add/modify partition/rule ================================================="
drop table if exists t1;
create table t1(c1 int, c2 sparsevector, primary key(c1), vector index idx1(c2) with (distance=inner_product, type=sindi, lib=vsag)) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (50));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;
insert into t1 values(1, '{1:0.1, 2:0.2, 3:0.3}');
alter table t1 partition by range(c1) (partition p0 values less than (20), partition p1 values less than (200));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;

--echo
--echo
--echo "=========================================== complex case ================================================="
drop table if exists t1;
create table t1(c1 int, c2 sparsevector, c3 int, c4 sparsevector, c5 int, c6 sparsevector, primary key(c1), vector index idx1(c2) with (distance=inner_product, type=sindi, lib=vsag));
insert into t1 values(1, '{1:0.1, 2:0.2, 3:0.3}', 5, '{1:0.1, 2:0.2, 3:0.3}', 7, '{1:0.1, 2:0.2, 3:0.3}');
alter table t1 add column c7 int auto_increment;
create vector index idx2 on  t1(c4) with(distance=inner_product, type=sindi, lib=vsag);
alter table t1 drop column c3;
insert into t1 values(2, '{1:0.1, 2:0.2, 3:0.3}', '{1:0.1, 2:0.2, 3:0.3}', 7, '{1:0.1, 2:0.2, 3:0.3}', 2);
select * from t1 order by negative_inner_product(c2, '{2:1, 3:1}');
alter table t1 modify c5 varchar(20) before c4;
create vector index idx3 on t1(c6) with(distance=inner_product, type=sindi, lib=vsag);
alter table t1 drop column c7;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;
select * from t1 order by negative_inner_product(c6, '{2:1, 3:1}');
truncate table t1;
insert into t1 values(1, '{1:0.1, 2:0.2, 3:0.3}', 'a', '{1:0.1, 2:0.2, 3:0.3}', '{1:0.1, 2:0.2, 3:0.3}');
alter table t1 drop index idx1;
alter table t1 drop column c5, add c9 varchar(10) default 'cc';
select * from t1 order by negative_inner_product(c6, '{2:1, 3:1}');
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
show index from t1;

drop table if exists t1;
create table t1(c1 int, c2 sparsevector, primary key(c1), vector index idx1(c2) with (distance=inner_product, type=sindi, lib=vsag));
insert into t1 values(1, '{1:0.1, 2:0.2, 3:0.3}');
ALTER TABLE t1 ADD c3 INT AUTO_INCREMENT;
ALTER TABLE t1 ADD COLUMN c4 int AS (c1 + 3) STORED;
alter table t1 modify c3 tinyint;
alter table t1 modify c1 tinyint;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

drop table if exists t1;
create table t1(c1 int, c2 sparsevector, c3 varchar(10), c4 int, primary key(c1), vector index idx1(c2) with (distance=inner_product, type=sindi, lib=vsag)) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (100));
insert into t1 values(1, '{1:0.1, 2:0.2, 3:0.3}', 'cc', 4);
alter table t1 modify c1 tinyint;
alter table t1 modify c3 varchar(5) charset 'gbk';
alter table t1 modify c1 int;
alter table t1 add constraint cc check (c1 < 10);
alter table t1 modify c3 char(8) , add c5 int, drop column c4;
alter table t1 convert to CHARACTER SET 'utf8';
alter table t1 convert to CHARACTER SET 'gbk';
truncate table t1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

# connection conn_user;
drop table if exists t1;
drop database if exists sparse_offline_ddl;
alter system set ob_vector_memory_limit_percentage =0;