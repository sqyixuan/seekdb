# owner: youchuan.yc
# owner group: storage
# description: copy a table with vec-hnsw indexe via the "create_table_like" path.

connect (conn_sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);

connection conn_sys;
alter system set debug_sync_timeout = '1000s';
alter system set _enable_add_fulltext_index_to_existing_table = true;
sleep 3;

--echo
--echo
--echo # test build vec-hnsw afterword and create table like#
connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BUILD_VECTOR_INDEX_PREPARE_STATUS wait_for continue_signal_0 execute 10000';

connect (conn_user,$OBMYSQL_MS0,root@sys,,test,$OBMYSQL_PORT);
connection conn_user;

--disable_warnings
drop database if exists fts_and_other_index;
--enable_warnings

create database fts_and_other_index;

connect (conn_user1,$OBMYSQL_MS0,root@sys,,fts_and_other_index,$OBMYSQL_PORT);
connect (conn_user2,$OBMYSQL_MS0,root@sys,,fts_and_other_index,$OBMYSQL_PORT);

connection conn_user1;
