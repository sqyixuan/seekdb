#owner: shanhaikang.shk
#owner group: hangzhou
--echo # DBMS VECTOR job with recyclebin

SET @@recyclebin = on;
purge recyclebin;

--disable_warnings
drop table if exists t1;
drop database if exists shk_new_db;
--enable_warnings
--disable_query_log
--disable_result_log
alter system set ob_vector_memory_limit_percentage = 30;
--enable_result_log
--enable_query_log

--disable_query_log
--disable_result_log
sleep 3;
--enable_result_log
--enable_query_log

--disable_query_log
--disable_result_log
select @refresh_vidx_jobs0 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log

create table t1(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=hnsw, lib=vsag));
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;

drop table t1;
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;

flashback table t1 to before drop;
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
let $shk_database_name = test;
let $shk_table_name = t1;
let $shk_vidx_name = idx1;
--source mysql_test/include/check_dbms_vector_job.inc

# flashback 改变db和表名
--echo "========================== flashback with different db & table_name ======================="
create database if not exists shk_new_db;
drop table t1;
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
flashback table t1 to before drop rename to shk_new_db.new_t1;
use shk_new_db;
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
let $shk_database_name = shk_new_db;
let $shk_table_name = new_t1;
let $shk_vidx_name = idx1;
--source mysql_test/include/check_dbms_vector_job.inc

drop table new_t1;
drop database shk_new_db;
purge recyclebin;
--disable_query_log
--disable_result_log
sleep 3;
--enable_result_log
--enable_query_log
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 THEN 'TRUE' ELSE 'FALSE' end as res;
