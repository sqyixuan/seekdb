SHOW CREATE TABLE t2;

--echo Drop vector index from partitioned table
ALTER TABLE t2 DROP INDEX idx1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t2;

--echo Add partition
ALTER TABLE t2 ADD PARTITION (
  PARTITION p3 VALUES LESS THAN(300)
);
