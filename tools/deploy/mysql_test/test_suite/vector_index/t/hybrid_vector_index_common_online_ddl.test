SHOW CREATE TABLE t2;

--echo Add MAXVALUE partition
ALTER TABLE t2 ADD PARTITION (
  PARTITION p4 VALUES LESS THAN MAXVALUE
);

--echo Drop partition
ALTER TABLE t2 DROP PARTITION p1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t2;


--echo Truncate partition
ALTER TABLE t2 TRUNCATE PARTITION p0;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t2;

--echo Create partitioned table with multiple vector indexes
--disable_warnings
DROP TABLE IF EXISTS t3;
--enable_warnings

--error 1235
CREATE TABLE t3(
    id INT PRIMARY KEY, 
    doc VARCHAR(200),
    VECTOR INDEX idx1(doc) 
      WITH (distance=L2, type=hnsw, dim=128, model=ob_embed, sync_mode=manual),
    VECTOR INDEX idx2(doc) 
      WITH (distance=cosine, type=hnsw, dim=256, model=ob_embed, sync_mode=immediate)
)
PARTITION BY RANGE COLUMNS(id)
(
  PARTITION p0 VALUES LESS THAN(100),
  PARTITION p1 VALUES LESS THAN MAXVALUE
);

CREATE TABLE t3(
    id INT PRIMARY KEY, 
    doc VARCHAR(200),
    doc2 VARCHAR(200),
    VECTOR INDEX idx1(doc) 
      WITH (distance=L2, type=hnsw, dim=128, model=ob_embed, sync_mode=manual),
    VECTOR INDEX idx2(doc2) 
      WITH (distance=cosine, type=hnsw, dim=256, model=ob_embed, sync_mode=immediate)
)
PARTITION BY RANGE COLUMNS(id)
(
  PARTITION p0 VALUES LESS THAN(100),
  PARTITION p1 VALUES LESS THAN MAXVALUE
);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t3;

call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_embed');
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('ob_embed_endpoint');

DROP TABLE t1_renamed;
DROP TABLE t2;
DROP TABLE t3;
