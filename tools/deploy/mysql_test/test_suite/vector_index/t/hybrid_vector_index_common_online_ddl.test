# owner: maochongxin.mcx
# owner group: shenzhen
# description: test DDL operations for hybrid vector index

alter system set ob_vector_memory_limit_percentage = 34;
sleep 3;

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT ('ob_embed_endpoint');
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL ('ob_embed');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
'ob_embed', '{
    "type": "dense_embedding",
    "model_name": "bge-M3"
  }');
call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
'ob_embed_endpoint', '{
    "ai_model_name": "ob_embed",
    "scope": "all",
    "url": "https://www.baidu.com/",
    "access_key": "sk-xxxxxxxxxxxx",
    "request_model_name": "bge-M3",
    "provider": "openai"
  }');

--disable_warnings
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
--enable_warnings

CREATE TABLE t1(
    id INT PRIMARY KEY,
    doc VARCHAR(200),
    VECTOR INDEX idx1(doc) 
      WITH (distance=L2, type=hnsw, dim=128, model=ob_embed, sync_mode=manual)
);

--echo Add column at the end of the table
ALTER TABLE t1 ADD category VARCHAR(50);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

--echo Add virtual column
ALTER TABLE t1 ADD COLUMN doc_length INT AS (CHAR_LENGTH(doc)) VIRTUAL;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

--echo Drop virtual column
ALTER TABLE t1 DROP COLUMN doc_length;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

--echo Modify column to NOT NULL
ALTER TABLE t1 MODIFY doc VARCHAR(200) NOT NULL;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

--echo Modify column to NULL
ALTER TABLE t1 MODIFY doc VARCHAR(200) NULL;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

--echo Set column default value
ALTER TABLE t1 ALTER doc SET DEFAULT 'Default text';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

--echo Drop column default value
ALTER TABLE t1 ALTER doc DROP DEFAULT;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

--echo Modify auto-increment column value
ALTER TABLE t1 MODIFY id INT AUTO_INCREMENT;
ALTER TABLE t1 AUTO_INCREMENT = 1000;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

--echo Rename column
ALTER TABLE t1 CHANGE COLUMN category tag VARCHAR(50);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

--echo Increase column type length or precision
ALTER TABLE t1 MODIFY doc VARCHAR(500);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

--echo Mixed column operations
# TODO: 4016
# ALTER TABLE t1 MODIFY COLUMN doc VARCHAR(300) NOT NULL, ADD description TEXT, DROP COLUMN tag;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

--echo Add index
CREATE INDEX idx_id ON t1 (id);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

#TODO add hybrid vector index

--echo Drop index
DROP INDEX idx_id ON t1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

--echo Drop hybrid vector index
ALTER TABLE t1 DROP INDEX idx1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

--disable_warnings
DROP TABLE IF EXISTS vector_idx_test;
--enable_warnings

CREATE TABLE vector_idx_test(
    id INT PRIMARY KEY,
    doc VARCHAR(200),
    VECTOR INDEX idx1(doc) 
      WITH (distance=L2, type=hnsw, dim=128, model=ob_embed, sync_mode=manual)
);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE vector_idx_test;

--echo Modify vector index parameters
--error ER_PARSE_ERROR
ALTER TABLE vector_idx_test ALTER INDEX idx1 CHANGE distance=ip;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE vector_idx_test;

--echo Rename hybrid vector index
ALTER TABLE vector_idx_test RENAME INDEX idx1 TO renamed_idx;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE vector_idx_test;

--echo Hybrid index operations
CREATE INDEX idx_normal ON vector_idx_test(id);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE vector_idx_test;

DROP TABLE vector_idx_test;

--echo Add normal index to original table
ALTER TABLE t1 ADD INDEX idx_id (id);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;


--echo Add foreign key, CHECK/NOT NULL constraints
--disable_warnings
DROP TABLE IF EXISTS t3;
--enable_warnings
CREATE TABLE t3(
    id INT PRIMARY KEY,
    doc_id INT
);

ALTER TABLE t1 ADD CONSTRAINT fk_doc_id FOREIGN KEY (id) REFERENCES t3(id);
--error 3818
ALTER TABLE t1 ADD CONSTRAINT chk_id_positive CHECK (id > 0);
# Use a non-auto_increment field for CHECK constraint
ALTER TABLE t1 ADD CONSTRAINT chk_doc_length CHECK (LENGTH(doc) > 0);
ALTER TABLE t1 MODIFY doc VARCHAR(500) NOT NULL;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

--echo Drop foreign key, CHECK/NOT NULL constraints
ALTER TABLE t1 DROP FOREIGN KEY fk_doc_id;
ALTER TABLE t1 DROP CONSTRAINT chk_doc_length;
ALTER TABLE t1 MODIFY doc VARCHAR(500) NULL;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;


--echo Rename table
--disable_warnings
DROP TABLE IF EXISTS t1_renamed;
--enable_warnings
RENAME TABLE t1 TO t1_renamed;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1_renamed;

--echo Modify row format
ALTER TABLE t1_renamed ROW_FORMAT = COMPACT;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1_renamed;

--echo Modify compression algorithm
ALTER TABLE t1_renamed COMPRESSION = 'NONE';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1_renamed;

OPTIMIZE TABLE t1_renamed;

# 分区表

--disable_warnings
DROP TABLE IF EXISTS t2;
--enable_warnings

--echo Create partitioned table
CREATE TABLE t2(
    id INT PRIMARY KEY,
    doc VARCHAR(200),
    VECTOR INDEX idx1(doc) 
      WITH (distance=L2, type=hnsw, dim=128, model=ob_embed, sync_mode=manual)
)
PARTITION BY RANGE COLUMNS(id)
(
  PARTITION p0 VALUES LESS THAN(100),
  PARTITION p1 VALUES LESS THAN(200)
);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t2;

--echo Add column at the end of the table
ALTER TABLE t2 ADD category VARCHAR(50);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t2;

--echo Add virtual column
