#owner: shanhaikang.shk
#owner group: hangzhou
--echo # DBMS VECTOR job schedule after rebuild index

SET @@recyclebin = off;

--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_query_log
--disable_result_log
alter system set ob_vector_memory_limit_percentage = 30;
--enable_result_log
--enable_query_log

--disable_query_log
--disable_result_log
sleep 3;
--enable_result_log
--enable_query_log

--disable_query_log
--disable_result_log
select @refresh_vidx_jobs0 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log

create table t1(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=hnsw, lib=vsag));
--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
let $shk_database_name = test;
let $shk_table_name = t1;
let $shk_vidx_name = idx1;
--source mysql_test/include/check_dbms_vector_job.inc

call dbms_vector.rebuild_index('idx1', 't1', '', 0);

--disable_query_log
--disable_result_log
select @refresh_vidx_jobs1 := count(*) from oceanbase.__all_tenant_scheduler_job where job_action like "%DBMS_VECTOR%";
--enable_result_log
--enable_query_log
select case when @refresh_vidx_jobs1 = @refresh_vidx_jobs0 + 4 THEN 'TRUE' ELSE 'FALSE' end as res;
let $shk_database_name = test;
let $shk_table_name = t1;
let $shk_vidx_name = idx1;
--source mysql_test/include/check_dbms_vector_job.inc
