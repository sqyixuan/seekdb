#owner: lb446709
#owner group: shenzhen
--echo # Vector Index refresh rebuild Test for tables without primary key

--disable_warnings
drop table if exists t1;
--enable_warnings

set ob_enable_index_direct_select = 1;
alter system set ob_vector_memory_limit_percentage = 20;
sleep 3;

--echo # 非分区表
create table t1(c1 int, c2 vector(3), c3 vector(5), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create vector index idx2  ON t1 (c3)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=12, ef_search=40);

let $table_id = `select table_id from oceanbase.__all_table where table_name = 't1' order by gmt_create desc limit 1;`;
let $index_table_idx1 = `select CONCAT('__idx_', $table_id , '_idx1') from dual;`;
let $index_table_idx2 = `select CONCAT('__idx_', $table_id , '_idx2') from dual;`;
let $index_id_table_idx1 = `select CONCAT('__idx_', $table_id , '_idx1_index_id_table') from dual;`;
let $index_id_table_idx2 = `select CONCAT('__idx_', $table_id , '_idx2_index_id_table') from dual;`;
let $index_snapshot_data_table_idx1 = `select CONCAT('__idx_', $table_id , '_idx1_index_snapshot_data_table') from dual;`;
let $index_snapshot_data_table_idx2 = `select CONCAT('__idx_', $table_id , '_idx2_index_snapshot_data_table') from dual;`;

--echo # 空表刷新
call dbms_vector.refresh_index('idx1', 't1', 'c2', 0, 'FAST');
call dbms_vector.refresh_index('idx1', 't1', 'c2', 0, 'FAST');
call dbms_vector.refresh_index('idx1', 't1', 'c2', 0, 'FAST');
call dbms_vector.refresh_index('idx1', 't1', 'c2', 0, 'FAST');

--echo # 带数据刷新
insert into t1 values(1, '[0.203846,0.205289,0.880265]', '[0.01,-0.02,0,0.12,0.34]');
insert into t1 values(2, '[0.484526,0.669954,0.986755]', '[0.02,-0.03,1,0.567,0.8910]');

--echo # 只刷一个索引，另一个不刷
call dbms_vector.refresh_index('idx1', 't1', 'c2', 0, 'FAST');
call dbms_vector.rebuild_index('idx1','t1','c2', 0);
--disable_query_log
eval select count(*) from $index_table_idx1;
eval select count(*) from $index_id_table_idx1;
eval select count(*) from $index_snapshot_data_table_idx1;
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
eval select count(*) from $index_snapshot_data_table_idx2;
--enable_query_log

replace into t1 values(1, '[0.880265,0.305289,0.203846]', '[0.01,-0.02,0,0.12,0.34]');
replace into t1 values(2, '[0.986755,0.769954,0.484526]', '[0.02,-0.03,1,0.567,0.8910]');
call dbms_vector.refresh_index('idx1', 't1', 'c2', 0, 'FAST');
--disable_query_log
eval select count(*) from $index_table_idx1;
eval select count(*) from $index_id_table_idx1;
--enable_query_log
call dbms_vector.rebuild_index('idx1','t1','c2', 0);
--disable_query_log
eval select count(*) from $index_table_idx1;
eval select count(*) from $index_id_table_idx1;
eval select count(*) from $index_snapshot_data_table_idx1;
--enable_query_log
call dbms_vector.refresh_index('idx2', 't1', 'c3', 0, 'FAST');
--disable_query_log
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
--enable_query_log
call dbms_vector.rebuild_index('idx2','t1','c3', 0);
--disable_query_log
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
eval select count(*) from $index_snapshot_data_table_idx2;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings

alter system set ob_vector_memory_limit_percentage = 0;
