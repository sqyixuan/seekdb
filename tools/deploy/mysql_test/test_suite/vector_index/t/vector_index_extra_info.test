# test show create table
## 随表建
### hnsw
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag)) PARTITION BY KEY(c1) partitions 16;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

### hnsw extra_info
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag, EXTRA_INFO_MAX_SIZE=512));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag, EXTRA_INFO_MAX_SIZE=512))  PARTITION BY KEY(c1) partitions 16;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

### ivf
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_flat));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=ivf_flat)) PARTITION BY KEY(c1) partitions 16;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

