# 边界测试
## 正常
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 vector(100), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag,EXTRA_INFO_MAX_SIZE=512));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

## rowkey 太大
--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1210
create table t1(c1 varchar(100), c2 vector(100), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag,EXTRA_INFO_MAX_SIZE=90));

--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1210
create table t1(c1 int, c2 vector(100), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag,EXTRA_INFO_MAX_SIZE=2));

## 不设置 extra_info_max，使用默认值
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 vector(100), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

set ob_hnsw_extra_info_max_size = 2;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 vector(100), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
set ob_hnsw_extra_info_max_size = 1024;

## 类型不支持
--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1210
create table t1(c1 char(100), c2 vector(100), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag,EXTRA_INFO_MAX_SIZE=100));

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 char(100), c2 vector(100), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

--disable_warnings
drop table if exists t1;
drop table if exists t1_post;
--enable_warnings

create table t1_post(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag,EXTRA_INFO_MAX_SIZE=512));
insert into t1_post values(1, '[0.203846,0.205289,0.880265,0.824340,0.615737,0.496899,0.983632,0.865571,0.248373,0.542833]');
update t1_post set c1 = 10;

--disable_warnings
drop table if exists t1;
drop table if exists t1_post;
--enable_warnings

create table t1(c1 vector(3), c2 array(float), c3 int auto_increment, c4 timestamp, primary key(c3, c4), vector index idx_1(c1) with (distance=l2, type=hnsw, extra_info_max_size=1)) partition by range(unix_timestamp(c4)) (partition p0 values less than (unix_timestamp('2010-01-01')), partition p1 values less than(unix_timestamp('2020-01-01')));
insert into t1 values([1,1,1],[1,1,1],200,'2015-5-5');
insert into t1 values([1,1,1],[1,1,1],201,'2015-5-5');
UPDATE t1 SET c3 = 202 WHERE c3 = 201;

# 2025051300108963219，验证online ddl 设置 snapshot 表extra_info列nullable属性
--disable_warnings
drop table if exists t1;
--enable_warnings
set ob_enable_index_direct_select = 1;
create table t1(c1 varchar(10), c2 vector(50), c3  vector(3) ,c4 vector(50) as (c2),primary key(c1),vector index idx2(c2) with (distance=l2, type=hnsw, EXTRA_INFO_MAX_SIZE=1));
insert into t1(c1,c2,c3) values(10, array_range(1,51),'[0.203846,0.205289,0.880265]');
let $table_id = `select table_id from oceanbase.__all_table where table_name = 't1';`;
let $index_snapshot_data_table_idx = `select CONCAT('__idx_', $table_id , '_idx2_index_snapshot_data_table') from dual;`;

let $index_snapshot_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = '$index_snapshot_data_table_idx', table_id, 1);
--replace_regex /table_id = [0-9]*/table_id = DATA_TABLE_ID/g
eval select nullable from oceanbase.__all_column where table_id = $index_snapshot_table_id order by column_id;

ALTER TABLE t1 MODIFY c1 varchar(100);
insert into t1(c1,c2,c3) values(11, array_range(10001,10051),'[0.203846,0.205289,0.880265]');
let $new_table_id = `select table_id from oceanbase.__all_table where table_name = 't1';`;
let $new_index_snapshot_data_table_idx = `select CONCAT('__idx_', $new_table_id , '_idx2_index_snapshot_data_table') from dual;`;
let $new_index_snapshot_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = '$new_index_snapshot_data_table_idx', table_id, 1);
--replace_regex /table_id = [0-9]*/table_id = DATA_TABLE_ID/g
eval select nullable from oceanbase.__all_column where table_id = $new_index_snapshot_table_id order by column_id;

--disable_warnings
drop table if exists t1;
drop table if exists t1_post;
--enable_warnings
set ob_enable_index_direct_select = 1;
create table t1(c1 int, c2 int, c3 vector(3), primary key(c2, c1), vector index idxv(c3) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200, extra_info_max_size=512))
PARTITION BY RANGE (c1) (
PARTITION p0 VALUES LESS THAN (20),
PARTITION p1 VALUES LESS THAN (40),
PARTITION p2 VALUES LESS THAN (70),
PARTITION p3 VALUES LESS THAN (400),
PARTITION pMax VALUES LESS THAN MAXVALUE
);

