#owner : yangjiali.yjl
#owner group: shenzhen
#description: check distance algorithm

connect (conn_user,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn_user;

--disable_warnings
drop database if exists yjl_vec;
create database yjl_vec;
use yjl_vec;

alter system set ob_vector_memory_limit_percentage = 20;
sleep 3;

drop table if exists t_vec;
create table t_vec(c1 int, c2 vector(3), c3 vector(3), c4 vector(3), c5 vector(3), c6 int, primary key(c1));
insert into t_vec values(1, '[1,2,3]', '[2,1,1]', '[3,1,1]', '[4,1,1]', 1);
create vector index idx1 on t_vec(c2) with (distance=l2, type=hnsw);
create vector index idx2 on t_vec(c3) with (distance=inner_product, type=hnsw);
create vector index idx3 on t_vec(c4) with (distance=cosine, type=hnsw);

# 1. 不指定approximate，表达式非 inner_product / negative_inner_product / L2，报错
--error 1305
explain select * from t_vec order by l2_distance1(c3, [1,1,1]) limit 1;
--error 1305
explain select * from t_vec order by inner_product1(c3, [1,1,1]) limit 1;
--error 1210
# 2. 不指定approximate，表达式是 inner_product / negative_inner_product / L2 / cosine，但指定的列 1）不是向量列 2）是向量列，但没有索引
explain select * from t_vec order by l2_distance(c1, [1,1,1]) limit 1;
--error 1210
explain select * from t_vec order by l2_squared(c1, [1,1,1]) limit 1;
explain select * from t_vec order by inner_product(c5, [1,1,1]) limit 1;
explain select * from t_vec order by cosine_distance(c5, [1,1,1]) limit 1;
# 3. 不指定approximate，表达式是 inner_product / negative_inner_product / L2 / cosine，不走索引
explain select * from t_vec order by l2_distance(c2, [1,1,1]) limit 1;
explain select * from t_vec order by l2_squared(c2, [1,1,1]) limit 1;
explain select * from t_vec order by inner_product(c3, [1,1,1]) limit 1;
explain select * from t_vec order by negative_inner_product(c3, [1,1,1]) limit 1;
explain select * from t_vec order by cosine_distance(c4, [1,1,1]) limit 1;
# 4. 指定approximate，表达式是 inner_product / negative_inner_product / L2，但和对应的向量索引距离算法不匹配，不报错，不走索引
explain select * from t_vec order by l2_distance(c3, [1,1,1]) approximate limit 1;
explain select * from t_vec order by l2_squared(c3, [1,1,1]) approximate limit 1;
explain select * from t_vec order by inner_product(c2, [1,1,1]) approximate limit 1;
explain select * from t_vec order by negative_inner_product(c2, [1,1,1]) approximate limit 1;
explain select * from t_vec order by cosine_distance(c3, [1,1,1]) approximate limit 1;
# 5. 指定approximate，表达式是 inner_product，不走索引
explain select * from t_vec order by inner_product(c3, [1,1,1]) approximate limit 1;
# 6. 指定approximate，表达式是 negative_inner_product / L2 / cosine，和对应的向量索引距离算法匹配，走索引
--replace_regex /_[0-9]+/_0/g
explain select * from t_vec order by l2_distance(c2, [1,1,1]) approximate limit 1;
--replace_regex /_[0-9]+/_0/g
explain select * from t_vec order by l2_squared(c2, [1,1,1]) approximate limit 1;
--replace_regex /_[0-9]+/_0/g
explain select * from t_vec order by negative_inner_product(c3, [1,1,1]) approximate limit 1;
--replace_regex /_[0-9]+/_0/g
explain select * from t_vec order by cosine_distance(c4, [1,1,1]) approximate limit 1;
drop table t_vec;

alter system set ob_vector_memory_limit_percentage = 0;
drop table if exists t_vec;
drop database if exists yjl_vec;
