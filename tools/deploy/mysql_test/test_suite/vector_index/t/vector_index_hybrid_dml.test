# owner: maochongxin.mcx
# owner group: shenzhen
# description: test complex dml of hybrid index

# NOTE: You must add the corresponding model before running this test.

alter system set ob_vector_memory_limit_percentage = 34;
sleep 3;

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT ('ob_embed_endpoint');
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL ('ob_embed');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
'ob_embed', '{
    "type": "dense_embedding",
    "model_name": "qwen3-embedding"
  }');

--disable_query_log
eval call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
'ob_embed_endpoint', '{
    "ai_model_name": "ob_embed",
    "scope": "all",
    "url": "$OB_API_HOST",
    "access_key": "$OB_API_KEY",
    "request_model_name": "$OB_MODEL_NAME",
    "provider": "$OB_MODEL_PROVIDER"
  }');
--enable_query_log

# sync
--echo === 基础DML ===
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists tbl_46;
drop table if exists tbl_291;
drop procedure if exists process;
--enable_warnings


create table t1 (id int AUTO_INCREMENT PRIMARY KEY, doc varchar(100),VECTOR INDEX idx1(doc) WITH (distance=L2,type=hnsw,dim=1024,model=ob_embed,sync_mode=immediate));
insert into t1 (doc) values('Document 1');
insert into t1 (doc) values('Document 2');

insert into t1 (id, doc) values(10, 'Document with specific id') on duplicate key update doc = 'Updated document';
insert ignore into t1 (id, doc) values(11, 'Document eleven');

create table t2 (id int PRIMARY KEY, doc varchar(100));
insert into t2 values(100, 'Document from table t2');
insert into t1 select * from t2 on duplicate key update doc = concat(t1.doc, ' - merged from t2');

update t1 set doc = 'Updated document content' where id = 100;
update t1 set doc = concat(doc, ' - modified') where id > 5;
delete from t1 where id <= 5;

select distinct id from t1;
drop table t1, t2;

--echo === 分区表DML ===
CREATE TABLE t1(id int not null auto_increment, doc varchar(100),
                primary key(id),
                VECTOR INDEX idx1(doc) WITH (distance=L2,
                                             type=hnsw, dim=1024,
                                             model=ob_embed,
                                             sync_mode=immediate))
PARTITION BY RANGE COLUMNS(id)
(
  PARTITION p0 VALUES LESS THAN(100),
  PARTITION p1 VALUES LESS THAN(200),
  PARTITION p2 VALUES LESS THAN(300),
  PARTITION p3 VALUES LESS THAN(10000),
  PARTITION p4 VALUES LESS THAN MAXVALUE
);

insert into t1 (doc) values('Partition document 1');
insert into t1 (id, doc) values(150, 'Document in partition p1');
insert into t1 (id, doc) values(250, 'Document in partition p2');
insert into t1 (id, doc) values(5000, 'Document in partition p3');

insert into t1 (id, doc) values(10, 'Duplicate id test') on duplicate key update doc = 'Updated in partition';
insert ignore into t1 (id, doc) values(11, 'Ignore test document');

create table t2 (id int primary key, doc varchar(100));
insert into t2 values(99, 'Document from t2 in p0');
insert into t2 values(150, 'Document from t2 in p1');
insert into t1 select * from t2 on duplicate key update doc = concat(t1.doc, ' - merged from t2');

update t1 set doc = 'Updated partition document' where id = 150;
update t1 set doc = concat(doc, ' - partition modified') where id > 100;
delete from t1 where id <= 10;

select distinct id from t1;
drop table t1, t2;

CREATE TABLE t1(id int not null, doc varchar(100),primary key(id),VECTOR INDEX idx1(doc) WITH (distance=L2,type=hnsw,dim=1024,model=ob_embed,sync_mode=immediate))PARTITION BY RANGE COLUMNS(id)(
  PARTITION p0 VALUES LESS THAN(100),
  PARTITION p1 VALUES LESS THAN(200),
  PARTITION p2 VALUES LESS THAN(300),
  PARTITION p3 VALUES LESS THAN(10000),
  PARTITION p4 VALUES LESS THAN MAXVALUE
);

insert into t1 values(1, 'Document one');
insert into t1 values(50, 'Document fifty');
insert into t1 values(99, 'Document ninety-nine');
insert into t1 values(150, 'Document one-fifty');
insert into t1 values(200, 'Document two-hundred');

create table t2 (id int primary key, doc varchar(100));
insert into t2 values(50, 'Document from t2');
insert into t2 values(99, 'Another document from t2');

let $before_fallback = query_get_value(select value from oceanbase.__all_virtual_tenant_parameter_stat where name = 'direct_load_allow_fallback', value, 1);
alter system set direct_load_allow_fallback=TRUE;
insert /*+ direct(true, 0) enable_parallel_dml parallel(2) */ into t1 select * from t2 on duplicate key update doc = concat(t1.doc, ' - direct merged');

insert into t2 values(500, 'Document five hundred');
--error 1062
insert /*+ direct(true, 100, 'inc_replace') enable_parallel_dml parallel(2) */ into t1 select * from t2;

create table t3 (id int primary key, doc varchar(100));
insert into t3 values(500, 'Document from t3');
insert into t3 values(501, 'Another document from t3');

insert into t1(id, doc)
select t2.id, t3.doc
from t2
join t3 on t2.id = t3.id
where t2.id = 500
on duplicate key update doc = concat(t1.doc, ' - complex joined');

update t1
join t2 on t1.id = t2.id
set t1.doc = concat(t2.doc, ' - joined')
where t2.id < 5;

update t1
set doc = case
            when id = 201 then concat(doc, ' - case 201')
            when id = 401 then concat(doc, ' - case 401')
            else doc
         end
where id < 500;

delete t1
from t1
join t2 on t1.id = t2.id
where t2.id <= 3;

--echo === 事务 ===

START TRANSACTION;
delete from t1
where t1.id in (
    select id from t2
);
insert into t1 values(30, 'Transaction document');
COMMIT;

--echo === 存储过程 ===
DELIMITER //;
create procedure process(IN inc1 INT, IN inc2 INT)
begin
    DECLARE t2id INT;
    select id into t2id
    from t2
    where id = inc1;

    if t2id = inc2 then
        update t1
        set doc = concat(doc, ' - procedure')
        where id > 10000;
    else
        insert into t1 select * from t2 where t2.id >= 505 on duplicate key update doc = concat(t1.doc, ' - procedure merged');
    end if;
end;
//
DELIMITER ;//

CALL process(500, 500);
CALL process(500, 501);
drop procedure process;

drop table t1, t2, t3;

--echo === 并发DML ===
--echo bugfix 2025011500107001921 parallel dml
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(id int, category int, doc varchar(100), primary key(id), 
                vector index idx3(doc) with (distance=l2,type=hnsw,dim=1024,model=ob_embed,sync_mode=immediate));

insert into t1 values(1, 1, 'Document with parallel test 1') on duplicate key update doc = concat(t1.doc, ' - parallel test 1');
insert into t1 values(2, 2, 'Document with parallel test 2');
insert into t1 values(3, 3, 'Document with parallel test 3');
insert into t1 values(100, 100, 'Document with parallel test 100') on duplicate key update doc = concat(t1.doc, ' - parallel test 100');
update /*+enable_parallel_dml parallel(2)*/t1 set category=(select id from t1 limit 1) where category is null;
update /*+enable_parallel_dml parallel(2)*/t1 set doc=(select doc from t1 limit 1) where category is not null;
update t1 set category=(select /*+enable_parallel_dml parallel(2)*/id from t1 limit 1);


