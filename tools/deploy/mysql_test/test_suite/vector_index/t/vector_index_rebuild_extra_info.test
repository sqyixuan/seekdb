#owner: wumengjie.wmj
#owner group: shenzhen
--echo # rebuild extra_info

alter system set ob_vector_memory_limit_percentage = 44;
sleep 1;

--disable_warnings
drop table if exists t1;
--enable_warnings

# 测试 rebuild
## 随表建 hnsw
--disable_warnings
drop table if exists t1;
drop table if exists t1_post;
--enable_warnings
create table t1(c1 varchar(10), c2 varchar(10), c3 vector(5) , c4 vector(3) ,c5 vector(5) as (c3), c6 int,primary key(c2, c6, c1), vector index idx2(c3) with (distance=l2, type=hnsw, EXTRA_INFO_MAX_SIZE=1)) 
PARTITION BY RANGE (c6) (
PARTITION p0 VALUES LESS THAN (20),
PARTITION p1 VALUES LESS THAN (40),
PARTITION p2 VALUES LESS THAN (70),
PARTITION p3 VALUES LESS THAN (400),
PARTITION pMax VALUES LESS THAN MAXVALUE
);

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

insert into t1(c1, c2, c3, c4, c6) values('abc', 'def', '[0.203846,0.205289,0.880265,0.6743,0.5533]', '[0.873846,0.105289,0.40265]', 1);
insert into t1(c1, c2, c3, c4, c6) values('grqgr', 'grqgr', '[0.503846,0.605289,0.780265,0.6743,0.533]', '[0.873846,0.105289,0.40265]', 3);
insert into t1(c1, c2, c3, c4, c6) values('vfa', 'bgs', '[0.303846,0.5205289,0.8680265,0.67643,0.55633]', '[0.8736846,0.1065289,0.402665]', 15);
insert into t1(c1, c2, c3, c4, c6) values('vfsa', 'vfrb', '[0.2603846,0.2052689,0.8806265,0.67643,0.56533]', '[0.8736846,0.1065289,0.406265]', 23);
insert into t1(c1, c2, c3, c4, c6) values('btb', 'vdabv', '[0.2063846,0.2056289,0.8806265,0.67643,0.5533]', '[0.8763846,0.1056289,0.40265]', 25);
insert into t1(c1, c2, c3, c4, c6) values('bbttqr', 'vfdae', '[0.2036846,0.2065289,0.880265,0.6743,0.5533]', '[0.873846,0.105289,0.40265]', 31);

# 刷新 3号表
call dbms_vector.refresh_index('idx2','t1','c3',0);

# 查辅助表的列
let $deltabuff_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name like '%_idx2', table_id, 1);
let $index_id_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name like '%_idx2_index_id_%', table_id, 1);
let $index_snapshot_data_id = query_get_value(select table_id from oceanbase.__all_table where table_name like '%_idx2_index_snapshot_data_%', table_id, 1);

--disable_query_log
eval select column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name from oceanbase.__all_column where table_id = $deltabuff_table_id;
eval select column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name from oceanbase.__all_column where table_id = $index_id_table_id;
eval select column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name from oceanbase.__all_column where table_id = $index_snapshot_data_id;
--enable_query_log

insert into t1(c1, c2, c3, c4, c6) values('varbae', 'btb', '[0.203846,0.2052869,0.8680265,0.67643,0.5533]', '[0.873846,0.105289,0.40265]', 43);
insert into t1(c1, c2, c3, c4, c6) values('vvvrewq', 'lkjhg', '[0.203846,0.2605289,0.880265,0.6743,0.5533]', '[0.873846,0.105289,0.40265]', 56);
insert into t1(c1, c2, c3, c4, c6) values('wedc', 'ygv', '[0.2038646,0.205289,06.880265,0.6743,0.5533]', '[0.8763846,0.6105289,0.60265]', 61);

# post 查询
select * from t1 order by l2_distance(c3, [0.203846,0.205289,0.880265,0.6743,0.5533]) APPROXIMATE limit 5;
select c2,c6,c1 from t1 order by l2_distance(c3, [0.203846,0.205289,0.880265,0.6743,0.5533]) APPROXIMATE limit 5;
select /*+index(t1 idx2)*/ * from t1 order by l2_distance(c3, [0.203846,0.205289,0.880265,0.6743,0.5533]) APPROXIMATE limit 5;
select /*+index(t1 idx2)*/  * from t1 order by l2_distance(c3, [0.203846,0.205289,0.880265,0.6743,0.5533]) APPROXIMATE limit 5;

# in_filter
select * from t1 where c2 in ('def', 'grqgr', 'bgs', 'vfrb', 'vdabv') order by l2_distance(c3, [0.203846,0.205289,0.880265,0.6743,0.5533]) APPROXIMATE limit 5;
select c2, c6,c1 from t1 where c2 in ('def', 'grqgr', 'bgs', 'vfrb', 'vdabv') order by l2_distance(c3, [0.203846,0.205289,0.880265,0.6743,0.5533]) APPROXIMATE limit 5;
select  /*+index(t1 idx2)*/ c2, c6,c1 from t1 where c2 in ('def', 'grqgr', 'bgs', 'vfrb', 'vdabv') order by l2_distance(c3, [0.203846,0.205289,0.880265,0.6743,0.5533]) APPROXIMATE limit 5;
select /*+index(t1 idx2)*/ * from t1 where c2 in ('def', 'grqgr', 'bgs', 'vfrb', 'vdabv') order by l2_distance(c3, [0.203846,0.205289,0.880265,0.6743,0.5533]) APPROXIMATE limit 5;
# post_filter
select * from t1 where c2 in ('def', 'grqgr', 'bgs', 'vfrb', 'vdabv') and c3 is not null order by l2_distance(c3, [0.203846,0.205289,0.880265,0.6743,0.5533]) APPROXIMATE limit 5;
select c2, c6,c1 from t1 where c2 in ('def', 'grqgr', 'bgs', 'vfrb', 'vdabv') and c3 is not null  order by l2_distance(c3, [0.203846,0.205289,0.880265,0.6743,0.5533]) APPROXIMATE limit 5;
select /*+index(t1 idx2)*/ * from t1 where c2 in ('def', 'grqgr', 'bgs', 'vfrb', 'vdabv') and c3 is not null order by l2_distance(c3, [0.203846,0.205289,0.880265,0.6743,0.5533]) APPROXIMATE limit 5;
select /*+index(t1 idx2)*/ c2, c6,c1 from t1 where c2 in ('def', 'grqgr', 'bgs', 'vfrb', 'vdabv') and c3 is not null  order by l2_distance(c3, [0.203846,0.205289,0.880265,0.6743,0.5533]) APPROXIMATE limit 5;

# rebuild 不带参数
call dbms_vector.rebuild_index('idx2','t1','c3',0,'','','');

# 查辅助表的列
