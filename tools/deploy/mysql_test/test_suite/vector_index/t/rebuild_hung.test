--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : yangjiali.yjl
#owner group: shenzhen
#description: rebuilding vector index when kill session interrupt

connect (conn_sys,$OBMYSQL_MS0,root@sys,,test,$OBMYSQL_PORT);
connect (conn_user1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (conn_user2,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

connection conn_sys;
alter system set debug_sync_timeout = '100s';
sleep 1;

connection conn_user1;

--disable_warnings
drop database if exists yjl_vec;
create database yjl_vec;
use yjl_vec;

alter system set ob_vector_memory_limit_percentage = 20;
sleep 1;

--echo
--echo
--echo "================================== ctrl c when rebuilding 001 ==================================="
# BUILD_VECTOR_INDEX_PREPARE_STATUS

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BUILD_VECTOR_INDEX_PREPARE_STATUS wait_for continue_signal execute 10000';

connection conn_user1;
use yjl_vec;

let $sess_1=query_get_value(select connection_id() as id, id, 1);
drop table if exists t_vec;
create table t_vec(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
--replace_regex /idx_[0-9]+/idx_new/g
show index from t_vec;

send call dbms_vector.rebuild_index('idx1','t_vec','c2');
sleep 10;

connection conn_user2;
--disable_query_log
eval kill $sess_1;
--enable_query_log

sleep 1;
select count(*) from oceanbase.__all_ddl_task_status where ddl_type=17;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
sleep 5;

disconnect conn_user1;
connect (conn_user1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn_user1;
use yjl_vec;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
drop table t_vec;

--echo
--echo
--echo "================================== ctrl c when rebuilding 002 ==================================="
