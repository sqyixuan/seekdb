## 验证 online ddl 更改主键，不影响 ivf_pq_centroid 列属性
--disable_warnings
drop table if exists vec_t1;
--enable_warnings
set ob_enable_index_direct_select = 1;
create table vec_t1(c1 varchar(10), c2 vector(50), c3  vector(3) ,c4 vector(50) as (c2),primary key(c1));
insert into vec_t1(c1,c2,c3) values(10, array_range(1,51),'[0.203846,0.205289,0.880265]');
create vector index idx2 on vec_t1 (c2) with (distance=l2, type=ivf_pq, nlist=2, sample_per_nlist=3, m=5);

let $table_id = `select table_id from oceanbase.__all_table where table_name = 'vec_t1';`;
let $ivf_pq_centroid = `select CONCAT('__idx_', $table_id , '_idx2_ivf_pq_centroid') from dual;`;
let $ivf_pq_centroid_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = '$ivf_pq_centroid', table_id, 1);
--disable_query_log
eval select nullable from oceanbase.__all_column where table_id = $ivf_pq_centroid_table_id order by column_id;
--enable_query_log

ALTER TABLE vec_t1 MODIFY c1 varchar(100);
insert into vec_t1(c1,c2,c3) values(11, array_range(10001,10051),'[0.203846,0.205289,0.880265]');
--disable_query_log
eval select nullable from oceanbase.__all_column where table_id = $ivf_pq_centroid_table_id order by column_id;
--enable_query_log

