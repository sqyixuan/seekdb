# owner: qiyu.zd
# owner group: shenzhen
# description: test hex string format of vector


alter system set ob_vector_memory_limit_percentage = 34;

--disable_warnings
DROP TABLE IF EXISTS vec_t1;
--enable_warnings

--echo 向量查询+表达式：列+常量
create table vec_t1(c1 int, c2 vector(3), vector index idx1(c2) with (distance=l2, type=hnsw));
insert into vec_t1 values(1,[0,1,2]);
insert into vec_t1 values(2,[1,2,3]);
insert into vec_t1 values(3,[1,2,4]);
insert into vec_t1 values(4,[1,2,5]);
insert into vec_t1 values(5,[1,3,5]);
insert into vec_t1 values(6,[2,3,5]);
insert into vec_t1 values(7,[2,3,6]);
insert into vec_t1 values(8,[2,3,7]);
insert into vec_t1 values(9,[2,4,5]);
insert into vec_t1 values(10,[3,3,5]);

select * from vec_t1 order by l2_distance(c2, '[0,1,2]') approx limit 2;
select * from vec_t1 order by l2_distance(c2, 0x000000000000803F00000040) approx limit 2;
select * from vec_t1 order by l2_distance(c2, X'000000000000803F00000040') approx limit 2;
select * from vec_t1 order by l2_distance(c2, b'000000000000000000000000000000000000000000000000100000000011111100000000000000000000000001000000') approx limit 2;

select * from vec_t1 where c1 <= 5 order by l2_distance(c2, '[0,1,2]') approx limit 2;
select * from vec_t1 where c1 <= 5 order by l2_distance(c2, 0x000000000000803F00000040) approx limit 2;
select * from vec_t1 where c1 <= 5 order by l2_distance(c2, X'000000000000803F00000040') approx limit 2;
select * from vec_t1 order by l2_distance(c2, b'000000000000000000000000000000000000000000000000100000000011111100000000000000000000000001000000') approx limit 2;

--disable_warnings
DROP TABLE IF EXISTS vec_t1;
--enable_warnings

--echo 表达式
create table vec_t1(c1 int, c2 vector(3), c3 varchar(30), c4 text, c5 blob(100), c6 varbinary(100), c7 float[], c8 blob, c9 binary(12), vector index idx1(c2) with (distance=l2, type=hnsw));
insert into vec_t1 values(1,[0,1,2],"[0,1,2]", "[0,1,1]", X'000000000000803F00000040', 0x000000000000803F00000040, [1,1,2], X'000000000000803F00000040', 0x000000000000803F00000040);
insert into vec_t1 values(2,[1,1,2],"[0,1,3]", "[0,1,4]", X'00000040000080400000803F', 0x000000000000803F00000040, [1,2,2], X'000000000000803F00000040', 0x000000000000803F00000040);
insert into vec_t1 values(3,[2,1,2],"[0,1,2]", "[0,1,1]", X'000080400000803F00000040', 0x000000000000803F00000040, [1,1,3], X'000000000000803F00000040', 0x000000000000803F00000040);

select inner_product(c2, c3) from vec_t1;
select inner_product(c2, c4) from vec_t1;
select inner_product(c2, c5) from vec_t1;
select inner_product(c2, c6) from vec_t1;

# blob/binary/varbinary 被推导成 array[float]
select inner_product(c5, c2) from vec_t1;
select inner_product(c5, c3) from vec_t1;
select inner_product(c5, c4) from vec_t1;
select inner_product(c5, c7) from vec_t1;
select inner_product(c6, c2) from vec_t1;
select inner_product(c6, c3) from vec_t1;
select inner_product(c6, c4) from vec_t1;
select inner_product(c6, c7) from vec_t1;
select inner_product(c9, c2) from vec_t1;
select inner_product(c9, c3) from vec_t1;
select inner_product(c9, c4) from vec_t1;
select inner_product(c9, c7) from vec_t1;

# blob/binary/varbinary + blob/binary/varbinary
select inner_product(c5, c6) from vec_t1;
select inner_product(c5, c9) from vec_t1;
select inner_product(c6, c5) from vec_t1;
select inner_product(c6, c9) from vec_t1;
select inner_product(c9, c6) from vec_t1;
select inner_product(c9, c5) from vec_t1;

# 常量
select inner_product(X'000000000000803F00000040', X'000000000000803F00000040');
select inner_product(b'000000000000000000000000000000000000000000000000100000000011111100000000000000000000000001000000', b'000000000000000000000000000000000000000000000000100000000011111100000000000000000000000001000000');
select inner_product(c2, '[0,1,2]') from vec_t1;
select inner_product([0,1,2], c2) from vec_t1;
select inner_product(c2, X'000000000000803F00000040') from vec_t1;
select inner_product(X'000000000000803F00000040', c2) from vec_t1;
select inner_product(c2, 0x000000000000803F00000040) from vec_t1;
select inner_product(0x000000000000803F00000040, c2) from vec_t1;
select inner_product(c2, b'000000000000000000000000000000000000000000000000100000000011111100000000000000000000000001000000') from vec_t1;
select inner_product(b'000000000000000000000000000000000000000000000000100000000011111100000000000000000000000001000000', c2) from vec_t1;

select inner_product(c5, X'000000000000803F00000040') from vec_t1;
select inner_product(X'000000000000803F00000040', c5) from vec_t1;
select inner_product(c6, X'000000000000803F00000040') from vec_t1;
select inner_product(X'000000000000803F00000040', c6) from vec_t1;
select inner_product(c9, X'000000000000803F00000040') from vec_t1;
select inner_product(X'000000000000803F00000040', c9) from vec_t1;

--error 1210
select inner_product(c2, '0x000000000000803F00000040') from vec_t1;
--error 1210
select inner_product(c2, '000000000000803F00000040') from vec_t1;

--disable_warnings
DROP TABLE IF EXISTS vec_t1;
--enable_warnings
