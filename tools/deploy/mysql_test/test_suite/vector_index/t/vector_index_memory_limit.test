#owner: gehao.wh
#owner group: shenzhen
--echo # Vector Index Memory limit

--disable_warnings
drop table if exists t1,t2;
--enable_warnings
connect (sys_root,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connect(mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection mysql;
--echo =========================================== not config memstore_limit_percentage and _memstore_limit_percentage ===========================================

connection sys_root;
alter system set memstore_limit_percentage = 0;
connection mysql;
alter system set _memstore_limit_percentage = 0;

--echo adaptive configure
alter system set ob_vector_memory_limit_percentage = 0;
sleep 3;
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, c2 vector(10), primary key(c1));
create vector index vec_idx2 on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
drop table t1;
drop table t2;

alter system set ob_vector_memory_limit_percentage = 10;
sleep 3;
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, c2 vector(10), primary key(c1));
create vector index vec_idx2 on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
drop table t1;
drop table t2;
alter system set ob_vector_memory_limit_percentage = 0;
alter system set _memstore_limit_percentage = 0;

alter system set ob_vector_memory_limit_percentage = 70;


--echo =========================================== only config memstore_limit_percentage and not config _memstore_limit_percentage ===========================================

--echo #set memstore_limit_percentage < 85, like 50, vector memory is valid in range "[0, 100-50-15)"
connection sys_root;
alter system set memstore_limit_percentage = 40;
connection mysql;
alter system set _memstore_limit_percentage = 0;

alter system set ob_vector_memory_limit_percentage = 0;
sleep 3;
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, c2 vector(10), primary key(c1));
create vector index vec_idx2 on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
drop table t2;
drop table t1;

alter system set ob_vector_memory_limit_percentage = 10;
sleep 3;
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, c2 vector(10), primary key(c1));
create vector index vec_idx2 on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
drop table t1;
drop table t2;
alter system set ob_vector_memory_limit_percentage = 0;

alter system set ob_vector_memory_limit_percentage = 70;

--echo #set memstore_limit_percentage > 85 which makes vector memory config not available
connection sys_root;
alter system set memstore_limit_percentage = 86;
--sleep 5
connection mysql;
alter system set ob_vector_memory_limit_percentage = 1;
sleep 3;
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, c2 vector(10), primary key(c1));
create vector index vec_idx2 on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
drop table t1;
drop table t2;


--echo =========================================== both config memstore_limit_percentage and config _memstore_limit_percentage ===========================================

connection sys_root;
alter system set memstore_limit_percentage = 90;
connection mysql;
alter system set _memstore_limit_percentage = 40;

alter system set ob_vector_memory_limit_percentage = 0;
sleep 3;
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, c2 vector(10), primary key(c1));
create vector index vec_idx2 on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
drop table t2;
drop table t1;

alter system set ob_vector_memory_limit_percentage = 44;
sleep 3;
create table t1(c1 int, c2 vector(10), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, c2 vector(10), primary key(c1));
create vector index vec_idx2 on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
drop table t1;
drop table t2;
alter system set ob_vector_memory_limit_percentage = 0;
alter system set _memstore_limit_percentage = 0;

alter system set ob_vector_memory_limit_percentage = 45;
alter system set ob_vector_memory_limit_percentage = 0;

--echo =========================================== Memory usage exceeds vector memory limit ===========================================

alter system set ob_vector_memory_limit_percentage = 1;
sleep 3;

select vector_mem_limit > 10000000 from oceanbase.__all_virtual_tenant_vector_mem_info;
create table t1 (c1 int, c2 vector(1536)) with column group(each column);
create table t2 (c1 int, c2 vector(1536));

--disable_query_log
--let $count = 0
while($count < 6000)
{
   eval insert into t1 values($count, concat('[', repeat(concat(random()%100, ','), 1535), concat(random()%100, ']')));
   eval insert into t2 values($count, concat('[', repeat(concat(random()%100, ','), 1535), concat(random()%100, ']')));
  --inc $count
}
--enable_query_log

--error 7604
create vector index vec_idx1 on t1(c2) with (distance=l2, type=hnsw, lib=vsag);
--error 7604
create vector index vec_idx1 on t1(c2) with (distance=l2, type=hnsw_sq, lib=vsag);
--error 7604
create vector index vec_idx1 on t1(c2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200, extra_info_max_size=512);
--error 7604
create vector index vec_idx1 on t1(c2) with (distance=l2, type=hnsw_bq, lib=vsag);
--error 1235
create vector index vec_idx1 on t1(c2) with (distance=l2, type=ivf_flat);
create vector index vec_idx1 on t2(c2) with (distance=l2, type=ivf_flat);
sleep 5;
select vector_mem_used > 780000, vector_mem_hold, vector_mem_limit > 10000000, vector_mem_detail_info from oceanbase.__all_virtual_tenant_vector_mem_info;
drop index vec_idx1 on t2;

--echo =========================================== increase vector memory limit, create index success ===========================================

alter system set ob_vector_memory_limit_percentage = 40;
sleep 3;
select vector_mem_limit > 420000000 from oceanbase.__all_virtual_tenant_vector_mem_info;
create vector index vec_idx1 on t1(c2) with (distance=l2, type=hnsw_sq, lib=vsag);
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.__all_virtual_tenant_vector_mem_info;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.GV$OB_VECTOR_MEMORY;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.V$OB_VECTOR_MEMORY;

drop index vec_idx1 on t1;
sleep 3;
create vector index vec_idx1 on t1(c2) with (distance=l2, type=hnsw_sq, lib=vsag);
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.__all_virtual_tenant_vector_mem_info;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.GV$OB_VECTOR_MEMORY;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.V$OB_VECTOR_MEMORY;

drop index vec_idx1 on t1;
sleep 3;
create vector index vec_idx1 on t1(c2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200, extra_info_max_size=512);
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.__all_virtual_tenant_vector_mem_info;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.GV$OB_VECTOR_MEMORY;

drop index vec_idx1 on t1;
sleep 3;
create vector index vec_idx1 on t1(c2) with (distance=l2, type=hnsw_bq, lib=vsag);
select vector_mem_hold, vector_mem_limit > 420000000,  vector_mem_detail_info from oceanbase.__all_virtual_tenant_vector_mem_info;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.GV$OB_VECTOR_MEMORY;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.V$OB_VECTOR_MEMORY;

drop index vec_idx1 on t1;
sleep 3;
create vector index vec_idx1 on t2(c2) with (distance=l2, type=ivf_flat);
sleep 3;
select vector_mem_used > 780000, vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.__all_virtual_tenant_vector_mem_info;
select vector_mem_used > 780000, vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.GV$OB_VECTOR_MEMORY;
select vector_mem_used > 780000, vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.V$OB_VECTOR_MEMORY;
drop index vec_idx1 on t2;

--echo =========================================== adaptive vector memory limit, create index success ===========================================

alter system set ob_vector_memory_limit_percentage = 0;
sleep 3;
select vector_mem_limit > 420000000 from oceanbase.__all_virtual_tenant_vector_mem_info;
create vector index vec_idx1 on t1(c2) with (distance=l2, type=hnsw_sq, lib=vsag);
sleep 3;
select vector_mem_hold, vector_mem_limit > 420000000,  vector_mem_detail_info from oceanbase.__all_virtual_tenant_vector_mem_info;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.GV$OB_VECTOR_MEMORY;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.V$OB_VECTOR_MEMORY;

drop index vec_idx1 on t1;
sleep 3;
create vector index vec_idx1 on t1(c2) with (distance=l2, type=hnsw_sq, lib=vsag);
sleep 3;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.__all_virtual_tenant_vector_mem_info;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.GV$OB_VECTOR_MEMORY;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.V$OB_VECTOR_MEMORY;

drop index vec_idx1 on t1;
sleep 3;
create vector index vec_idx1 on t1(c2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200, extra_info_max_size=512);
sleep 3;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.__all_virtual_tenant_vector_mem_info;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.GV$OB_VECTOR_MEMORY;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.V$OB_VECTOR_MEMORY;

drop index vec_idx1 on t1;
sleep 3;
create vector index vec_idx1 on t1(c2) with (distance=l2, type=hnsw_bq, lib=vsag);
sleep 3;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.__all_virtual_tenant_vector_mem_info;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.GV$OB_VECTOR_MEMORY;
select vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.V$OB_VECTOR_MEMORY;

drop index vec_idx1 on t1;
sleep 3;
create vector index vec_idx1 on t2(c2) with (distance=l2, type=ivf_flat);
sleep 3;
select vector_mem_used > 780000, vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.__all_virtual_tenant_vector_mem_info;
select vector_mem_used > 780000, vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.GV$OB_VECTOR_MEMORY;
select vector_mem_used > 780000, vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.V$OB_VECTOR_MEMORY;

--echo =========================================== clean ===========================================
connection sys_root;
select tenant_id, vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.__all_virtual_tenant_vector_mem_info where tenant_id in (1,1002,1004);
select tenant_id, vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.GV$OB_VECTOR_MEMORY where tenant_id in (1,1002,1004);
select tenant_id, vector_mem_hold, vector_mem_limit > 420000000, vector_mem_detail_info from oceanbase.V$OB_VECTOR_MEMORY where tenant_id in (1,1002,1004);
alter system set memstore_limit_percentage = 0;
disconnect sys_root;
connection mysql;
alter system set _memstore_limit_percentage = 0;
drop table t1, t2;
PURGE RECYCLEBIN;
disconnect mysql;
