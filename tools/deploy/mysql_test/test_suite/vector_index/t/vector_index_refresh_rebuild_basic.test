#owner: xf375358
#owner group: shenzhen
--echo # Vector Index refresh rebuild Test

--disable_warnings
drop table if exists t1;
PURGE RECYCLEBIN;
--enable_warnings

set ob_enable_index_direct_select = 1;
alter system set ob_vector_memory_limit_percentage = 20;

--echo # 非分区表
create table t1(c1 int, c2 vector(3), c3 vector(5), primary key(c1), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create vector index idx2  ON t1 (c3)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=12, ef_search=40);

let $table_id = `select table_id from oceanbase.__all_table where table_name = 't1' order by gmt_create desc limit 1;`;
let $index_table_idx1 = `select CONCAT('__idx_', $table_id , '_idx1') from dual;`;
let $index_table_idx2 = `select CONCAT('__idx_', $table_id , '_idx2') from dual;`;
let $index_id_table_idx1 = `select CONCAT('__idx_', $table_id , '_idx1_index_id_table') from dual;`;
let $index_id_table_idx2 = `select CONCAT('__idx_', $table_id , '_idx2_index_id_table') from dual;`;
let $index_snapshot_data_table_idx1 = `select CONCAT('__idx_', $table_id , '_idx1_index_snapshot_data_table') from dual;`;
let $index_snapshot_data_table_idx2 = `select CONCAT('__idx_', $table_id , '_idx2_index_snapshot_data_table') from dual;`;

--echo # 空表刷新
call dbms_vector.refresh_index('idx1', 't1', 'c2', 1, 'FAST');
call dbms_vector.rebuild_index('idx1','t1','c2');
call dbms_vector.refresh_index('idx2', 't1', 'c3', 1, 'FAST');
call dbms_vector.rebuild_index('idx2','t1','c3');

--echo # 带数据刷新
insert into t1 values(1, '[0.203846,0.205289,0.880265]', '[0.01,-0.02,0,0.12,0.34]');
insert into t1 values(2, '[0.484526,0.669954,0.986755]', '[0.02,-0.03,1,0.567,0.8910]');

--echo # 只刷一个索引，另一个不刷
call dbms_vector.refresh_index('idx1', 't1', 'c2', 1, 'FAST');
call dbms_vector.rebuild_index('idx1','t1','c2');
--disable_query_log
eval select count(*) from $index_table_idx1;
eval select count(*) from $index_id_table_idx1;
eval select count(*)>0 from $index_snapshot_data_table_idx1;
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
eval select count(*)=0 from $index_snapshot_data_table_idx2;
--enable_query_log

--echo # 到了刷新阈值，才触发刷新
replace into t1 values(1, '[0.880265,0.305289,0.203846]', '[0.01,-0.02,0,0.12,0.34]');
replace into t1 values(2, '[0.986755,0.769954,0.484526]', '[0.02,-0.03,1,0.567,0.8910]');
call dbms_vector.refresh_index('idx1', 't1', 'c2', 5, 'FAST');
call dbms_vector.rebuild_index('idx1','t1','c2', 4);
--disable_query_log
eval select count(*) from $index_table_idx1;
eval select count(*) from $index_id_table_idx1;
--enable_query_log
call dbms_vector.refresh_index('idx2', 't1', 'c3', 6, 'FAST');
--disable_query_log
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
--enable_query_log
call dbms_vector.rebuild_index('idx2','t1','c3', 3);
--disable_query_log
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
eval select count(*)>0 from $index_snapshot_data_table_idx2;
--enable_query_log

--echo # 字段合法性（合法）
replace into t1 values(1, '[0.880265,0.305289,0.203846]', '[0.01,-0.02,0,0.12,0.34]');
call dbms_vector.refresh_index('idx1', 't1');
call dbms_vector.rebuild_index('idx2','t1');
--disable_query_log
eval select count(*) from $index_table_idx1;
eval select count(*) from $index_id_table_idx1;
eval select count(*)>0 from $index_snapshot_data_table_idx1;
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
eval select count(*)>0 from $index_snapshot_data_table_idx2;
--enable_query_log
replace into t1 values(1, '[0.880265,0.305289,0.203846]', '[0.01,-0.02,0,0.12,0.34]');
call dbms_vector.refresh_index('idx1', 't1', 'c2', -1);
call dbms_vector.rebuild_index('idx2','t1','c3', -1);
--disable_query_log
eval select count(*) from $index_table_idx1;
eval select count(*) from $index_id_table_idx1;
eval select count(*)>0 from $index_snapshot_data_table_idx1;
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
eval select count(*)>0 from $index_snapshot_data_table_idx2;
--enable_query_log
replace into t1 values(1, '[0.880265,0.305289,0.203846]', '[0.01,-0.02,0,0.12,0.34]');
call dbms_vector.rebuild_index('idx1','t1', '', '', '', '', '', 10);
--disable_query_log
eval select count(*) from $index_table_idx1;
eval select count(*) from $index_id_table_idx1;
eval select count(*)>0 from $index_snapshot_data_table_idx1;
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
eval select count(*)>0 from $index_snapshot_data_table_idx2;
--enable_query_log

--echo # 字段合法性（非法）
replace into t1 values(1, '[0.880265,0.305289,0.203846]', '[0.01,-0.02,0,0.12,0.34]');
--error  1318
call dbms_vector.refresh_index('idx1');
--error  1210
call dbms_vector.refresh_index('idx3', 't1');
--error  1210
call dbms_vector.refresh_index('idx1', 't2');
--error  1235
call dbms_vector.refresh_index('idx1', 't1', '', 1, 'SLOW');
--error 1210
call dbms_vector.refresh_index('idx1', 't1', 'c3');
--error 1210
call dbms_vector.refresh_index('idx1', 't1', 'c2', null);
--error  1318
call dbms_vector.rebuild_index('idx1');
--error  1210
call dbms_vector.rebuild_index('idx3', 't1');
--error  1210
call dbms_vector.rebuild_index('idx1', 't2');
--error 1210
call dbms_vector.rebuild_index('idx1', 't1', 'c3');
--error 1210
call dbms_vector.rebuild_index('idx1', 't1', 'c2', null);
--error  1366
call dbms_vector.rebuild_index('idx1','t1', '', '', 'not support', '', '','');
--error  1366
call dbms_vector.rebuild_index('idx1','t1', '', '', '', 'not support', '','');
--error  1366
call dbms_vector.rebuild_index('idx1','t1', '', '', '', '', 'not support','');

--disable_warnings
drop table if exists t1;
--enable_warnings

--echo # 一级分区表
create table t1(c1 int, c2 vector(3), c3 vector(5), 
                primary key(c1),
                vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag))
PARTITION BY RANGE COLUMNS(c1)
(
  PARTITION p0 VALUES LESS THAN(100),
  PARTITION p1 VALUES LESS THAN(200),
  PARTITION p2 VALUES LESS THAN(300),
  PARTITION p3 VALUES LESS THAN(10000),
  PARTITION p4 VALUES LESS THAN MAXVALUE
);
create vector index idx2 on t1(c3) with (distance=l2, type=hnsw, lib=vsag);

let $table_id = `select table_id from oceanbase.__all_table where table_name = 't1' order by gmt_create desc limit 1;`;
let $index_table_idx1 = `select CONCAT('__idx_', $table_id , '_idx1') from dual;`;
let $index_table_idx2 = `select CONCAT('__idx_', $table_id , '_idx2') from dual;`;
let $index_id_table_idx1 = `select CONCAT('__idx_', $table_id , '_idx1_index_id_table') from dual;`;
let $index_id_table_idx2 = `select CONCAT('__idx_', $table_id , '_idx2_index_id_table') from dual;`;
let $index_snapshot_data_table_idx1 = `select CONCAT('__idx_', $table_id , '_idx1_index_snapshot_data_table') from dual;`;
let $index_snapshot_data_table_idx2 = `select CONCAT('__idx_', $table_id , '_idx2_index_snapshot_data_table') from dual;`;

--echo # 空表刷新
call dbms_vector.refresh_index('idx1', 't1', 'c2', 1, 'FAST');
call dbms_vector.rebuild_index('idx1','t1','c2');
call dbms_vector.refresh_index('idx2', 't1', 'c3', 1, 'FAST');
call dbms_vector.rebuild_index('idx2','t1','c3');

--source mysql_test/test_suite/vector_index/include/multi_partition_data.inc

--echo # 只刷一个索引，另一个不刷
call dbms_vector.refresh_index('idx1', 't1', 'c2', 1, 'FAST');
call dbms_vector.rebuild_index('idx1','t1','c2');
--disable_query_log
eval select count(*) from $index_table_idx1;
eval select count(*) from $index_id_table_idx1;
eval select count(*)>0 from $index_snapshot_data_table_idx1;
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
eval select count(*)=0 from $index_snapshot_data_table_idx2;
--enable_query_log

--echo # 到了刷新阈值，才触发刷新
replace into t1 values(1, '[0.1,0.570740,0.487505]', '[0.1,0.239371,0.875098,0.947923,0.617502]');
replace into t1 values(2, '[0.2,0.390351,0.393264]', '[0.2,0.543877,0.337553,0.505269,0.968880]');
call dbms_vector.refresh_index('idx1', 't1', 'c2', 5, 'FAST');
call dbms_vector.rebuild_index('idx1','t1','c2', 0.062);
--disable_query_log
eval select count(*) from $index_table_idx1;
eval select count(*) from $index_id_table_idx1;
--enable_query_log
call dbms_vector.refresh_index('idx2', 't1', 'c3', 69, 'FAST');
--disable_query_log
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
--enable_query_log
call dbms_vector.rebuild_index('idx2','t1','c3', 1.06);
--disable_query_log
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
eval select count(*)>0 from $index_snapshot_data_table_idx2;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings

--echo # 二级分区表
CREATE TABLE t1(c1 INT not null auto_increment, c2 INT, c3 vector(3), c4 vector(5), 
                primary key(c1,c2),
                vector index idx1(c3) with (distance=l2, type=hnsw, lib=vsag))
PARTITION BY RANGE COLUMNS(c1)
SUBPARTITION BY LIST COLUMNS(c2)
SUBPARTITION TEMPLATE
(
  SUBPARTITION mp0 VALUES IN (1,2,3,4,5),
  SUBPARTITION mp1 VALUES IN (6,7,8,9,10),
  SUBPARTITION mp2 VALUES IN (11,12,13,14,15),
  SUBPARTITION mp3 VALUES IN (16,17,18,19,20)
)
(
  PARTITION p0 VALUES LESS THAN(100),
  PARTITION p1 VALUES LESS THAN(200),
  PARTITION p2 VALUES LESS THAN(300),
  PARTITION p3 VALUES LESS THAN(10000),
  PARTITION p4 VALUES LESS THAN MAXVALUE
);
create vector index idx2 on t1(c4) with (distance=l2, type=hnsw, lib=vsag);

let $table_id = `select table_id from oceanbase.__all_table where table_name = 't1' order by gmt_create desc limit 1;`;
let $index_table_idx1 = `select CONCAT('__idx_', $table_id , '_idx1') from dual;`;
let $index_table_idx2 = `select CONCAT('__idx_', $table_id , '_idx2') from dual;`;
let $index_id_table_idx1 = `select CONCAT('__idx_', $table_id , '_idx1_index_id_table') from dual;`;
let $index_id_table_idx2 = `select CONCAT('__idx_', $table_id , '_idx2_index_id_table') from dual;`;
let $index_snapshot_data_table_idx1 = `select CONCAT('__idx_', $table_id , '_idx1_index_snapshot_data_table') from dual;`;
let $index_snapshot_data_table_idx2 = `select CONCAT('__idx_', $table_id , '_idx2_index_snapshot_data_table') from dual;`;

--echo # 空表刷新
call dbms_vector.refresh_index('idx1', 't1', 'c3', 1, 'FAST');
call dbms_vector.rebuild_index('idx1','t1','c3');
call dbms_vector.refresh_index('idx2', 't1', 'c4', 1, 'FAST');
call dbms_vector.rebuild_index('idx2','t1','c4');

--source mysql_test/test_suite/vector_index/include/multi_l2_partition_data.inc

--echo # 只刷一个索引，另一个不刷
call dbms_vector.refresh_index('idx1', 't1', 'c3', 1, 'FAST');
call dbms_vector.rebuild_index('idx1','t1','c3');
--disable_query_log
eval select count(*) from $index_table_idx1;
eval select count(*) from $index_id_table_idx1;
eval select count(*)>0 from $index_snapshot_data_table_idx1;
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
eval select count(*)=0 from $index_snapshot_data_table_idx2;
--enable_query_log

--echo # 到了刷新阈值，才触发刷新
replace into t1(c1, c2, c3, c4) values(1, 6, '[79,79,53]', '[83,99,53,81,73]');
replace into t1(c1, c2, c3, c4) values(2, 8, '[60,87,66]', '[10,72,53,61,16]');
call dbms_vector.refresh_index('idx1', 't1', 'c3', 5, 'FAST');
call dbms_vector.rebuild_index('idx1','t1','c3', 0.075);
--disable_query_log
eval select count(*) from $index_table_idx1;
eval select count(*) from $index_id_table_idx1;
--enable_query_log
call dbms_vector.refresh_index('idx2', 't1', 'c4', 58, 'FAST');
--disable_query_log
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
--enable_query_log
call dbms_vector.rebuild_index('idx2','t1','c4', 1.074);
--disable_query_log
eval select count(*) from $index_table_idx2;
eval select count(*) from $index_id_table_idx2;
eval select count(*)>0 from $index_snapshot_data_table_idx2;
--enable_query_log

drop table t1;
alter system set ob_vector_memory_limit_percentage = 0;
--sleep 20
select count(*) as count
from oceanbase.__all_virtual_vector_index_info a, oceanbase.__all_virtual_table b 
where a.data_table_id = b.table_id and b.table_name = 't1';

# check virtual table later
PURGE RECYCLEBIN;