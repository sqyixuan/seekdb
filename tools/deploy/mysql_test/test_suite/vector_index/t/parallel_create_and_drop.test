#owner : yangjiali.yjl
#owner group: shenzhen
#description: forbid parallel create and drop

connect (conn_sys,$OBMYSQL_MS0,root@sys,,test,$OBMYSQL_PORT);
connect (conn_user1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (conn_user2,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

connection conn_sys;
alter system set debug_sync_timeout = '100s';
sleep 1;

connection conn_user1;
alter system set ob_vector_memory_limit_percentage = 20;
sleep 1;

--echo
--echo
--echo "================================== parallel create and create ==================================="
# BUILD_VECTOR_INDEX_PREPARE_STATUS

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BUILD_VECTOR_INDEX_PREPARE_STATUS wait_for continue_signal execute 10000';

connection conn_user1;
--disable_warnings
drop table if exists t_vec;
--enable_warnings
create table t_vec(c1 int, c2 vector(3), c3 vector(3), primary key(c1));
sleep 2;

connection conn_user1;
send create vector index idx1 on t_vec(c2) with (distance=l2, type=hnsw);
sleep 2;

connection conn_user2;
send create vector index idx2 on t_vec(c3) with (distance=l2, type=hnsw);

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
sleep 5;

connection conn_user1;
reap;

connection conn_user2;
reap;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
drop table t_vec;

--echo
--echo
--echo "================================== parallel create and drop ==================================="
connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BUILD_VECTOR_INDEX_PREPARE_STATUS wait_for continue_signal execute 10000';

connection conn_user1;
--disable_warnings
drop table if exists t_vec;
--enable_warnings
create table t_vec(c1 int, c2 vector(3), c3 vector(3), primary key(c1));
sleep 2;

connection conn_user1;
create vector index idx1 on t_vec(c2) with (distance=l2, type=hnsw);
send create vector index idx2 on t_vec(c3) with (distance=l2, type=hnsw);

connection conn_user2;
send drop index idx1 on t_vec;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
sleep 5;

connection conn_user1;
reap;

connection conn_user2;
reap;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
drop table t_vec;

--echo
--echo
--echo "================================ parallel drop and drop ===================================="
connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'DROP_VECTOR_INDEX_PREPARE_STATUS wait_for continue_signal execute 10000';

connection conn_user1;
--disable_warnings
drop table if exists t_vec;
--enable_warnings
create table t_vec(c1 int, c2 vector(3), c3 vector(3), primary key(c1));
sleep 2;

connection conn_user1;
create vector index idx1 on t_vec(c2) with (distance=l2, type=hnsw);
create vector index idx2 on t_vec(c3) with (distance=l2, type=hnsw);

send drop index idx1 on t_vec;

connection conn_user2;
send drop index idx2 on t_vec;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
sleep 5;

connection conn_user1;
reap;

connection conn_user2;
reap;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
drop table t_vec;

--echo
--echo
--echo "==================================== clean ==================================="

alter system set ob_vector_memory_limit_percentage = 0;
drop table if exists t_vec;