--echo # 分区表 && 并行查询 begin
--echo # 分区表
--disable_warnings
drop table  if exists  t1;
--enable_warnings
create table t1(id INT PRIMARY KEY, doc varchar(100), VECTOR INDEX idx1(doc) WITH (distance=L2, type=hnsw, dim=1024, model=ob_embed, sync_mode=IMMEDIATE)) organization heap
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(3),
PARTITION p1 values less than(5),
PARTITION p2 values less than(10)
);
insert into t1(id,doc ) values(1,'Rose');
insert into t1(id,doc ) values(2,'Bamboo');
insert into t1(id,doc ) values(3,'Dog');
insert into t1(id,doc ) values(4,'Cat');
insert into t1(id,doc ) values(5,'Giraffe');
insert into t1(id,doc ) values(6,'Aloe');

select * from t1 order by semantic_distance(doc, 'monkey')  approximate limit 3;
select /*+ PARALLEL(2) */  * from t1 order by semantic_distance(doc, 'monkey')  approximate limit 3;

--echo # 非分区表
--disable_warnings
drop table  if exists  t1;
--enable_warnings
create table t1(id INT PRIMARY KEY, doc varchar(100), VECTOR INDEX idx1(doc) WITH (distance=L2, type=hnsw, dim=1024, model=ob_embed, sync_mode=IMMEDIATE)) organization heap;
insert into t1(id,doc ) values(1,'Rose');
insert into t1(id,doc ) values(2,'Bamboo');
insert into t1(id,doc ) values(3,'Dog');
insert into t1(id,doc ) values(4,'Cat');
insert into t1(id,doc ) values(5,'Giraffe');
insert into t1(id,doc ) values(6,'Aloe');

select * from t1 order by semantic_distance(doc, 'monkey')  approximate limit 3;
select /*+ PARALLEL(2) */  * from t1 order by semantic_distance(doc, 'monkey')  approximate limit 3;

--echo # cosine、inner_product begin
--disable_warnings
drop table  if exists  t1;
--enable_warnings
create table t1(id INT PRIMARY KEY, doc varchar(100), VECTOR INDEX idx1(doc) WITH (distance=cosine, type=hnsw, dim=1024, model=ob_embed, sync_mode=IMMEDIATE)) organization heap;
insert into t1(id,doc ) values(1,'Rose');
insert into t1(id,doc ) values(2,'Bamboo');
insert into t1(id,doc ) values(3,'Dog');
insert into t1(id,doc ) values(4,'Cat');
insert into t1(id,doc ) values(5,'Giraffe');
insert into t1(id,doc ) values(6,'Aloe');
select * from t1 order by semantic_distance(doc, 'monkey')  approximate limit 3;

--disable_warnings
drop table  if exists  t1;
--enable_warnings
create table t1(id INT PRIMARY KEY, doc varchar(100), VECTOR INDEX idx1(doc) WITH (distance=inner_product, type=hnsw, dim=1024, model=ob_embed, sync_mode=IMMEDIATE)) organization heap;
insert into t1(id,doc ) values(1,'Rose');
insert into t1(id,doc ) values(2,'Bamboo');
insert into t1(id,doc ) values(3,'Dog');
insert into t1(id,doc ) values(4,'Cat');
insert into t1(id,doc ) values(5,'Giraffe');
insert into t1(id,doc ) values(6,'Aloe');
select * from t1 order by semantic_distance(doc, 'monkey')  approximate limit 3;

--echo # bq && rowsets_enabled test begin
--echo # All data in incr index
--disable_warnings
drop table  if exists  t1;
--enable_warnings
CREATE TABLE t1(id INT PRIMARY KEY, doc varchar(100), VECTOR INDEX idx1(doc) WITH (distance=L2, type=hnsw_bq, dim=1024, model=ob_embed, sync_mode=IMMEDIATE)) organization heap;
insert into t1(id,doc ) values(1,'Rose');
insert into t1(id,doc ) values(2,'Bamboo');
insert into t1(id,doc ) values(3,'Dog');
insert into t1(id,doc ) values(4,'Cat');
insert into t1(id,doc ) values(5,'Giraffe');
insert into t1(id,doc ) values(6,'Aloe');

--echo # rowsets_enable is true
select  /*+ opt_param('rowsets_enabled', 'true') */ * from t1 order by semantic_distance(doc, 'monkey')  approximate limit 3;
select  /*+ opt_param('rowsets_enabled', 'true') */ * from t1 where id < 4 order by semantic_distance(doc, 'monkey')  approximate limit 3;
select  /*+index(t1 idx1)  opt_param('rowsets_enabled', 'true') */ * from t1 where id < 4 order by semantic_distance(doc, 'monkey')  approximate limit 3;

--echo # rowsets_enable is false
select  /*+ opt_param('rowsets_enabled', 'false') */ * from t1 order by semantic_distance(doc, 'monkey')  approximate limit 3;
select  /*+ opt_param('rowsets_enabled', 'false') */ * from t1 where id < 4 order by semantic_distance(doc, 'monkey')  approximate limit 3;
select  /*+index(t1 idx1)  opt_param('rowsets_enabled', 'false') */ * from t1 where id < 4 order by semantic_distance(doc, 'monkey')  approximate limit 3;

--echo # All data in snap index
--disable_warnings
drop table  if exists  t1;
--enable_warnings
CREATE TABLE t1(id INT PRIMARY KEY, doc varchar(100), VECTOR INDEX idx1(doc) WITH (distance=L2, type=hnsw_bq, dim=1024, model=ob_embed, sync_mode=IMMEDIATE)) organization heap;
insert into t1(id,doc ) values(1,'Rose');
insert into t1(id,doc ) values(2,'Bamboo');
insert into t1(id,doc ) values(3,'Dog');
insert into t1(id,doc ) values(4,'Cat');
insert into t1(id,doc ) values(5,'Giraffe');
insert into t1(id,doc ) values(6,'Aloe');
sleep 10;
call dbms_vector.rebuild_index('idx1', 't1', 'doc');
--echo # rowsets_enable is true
select  /*+ opt_param('rowsets_enabled', 'true') */ * from t1 order by semantic_distance(doc, 'monkey')  approximate limit 3;
select  /*+ opt_param('rowsets_enabled', 'true') */ * from t1 where id < 4 order by semantic_distance(doc, 'monkey')  approximate limit 3;
select  /*+index(t1 idx1)  opt_param('rowsets_enabled', 'true') */ * from t1 where id < 4 order by semantic_distance(doc, 'monkey')  approximate limit 3;

--echo # rowsets_enable is false
select  /*+ opt_param('rowsets_enabled', 'false') */ * from t1 order by semantic_distance(doc, 'monkey')  approximate limit 3;
select  /*+ opt_param('rowsets_enabled', 'false') */ * from t1 where id < 4 order by semantic_distance(doc, 'monkey')  approximate limit 3;
select  /*+index(t1 idx1)  opt_param('rowsets_enabled', 'false') */ * from t1 where id < 4 order by semantic_distance(doc, 'monkey')  approximate limit 3;

--echo # data partly in snap index and partly in incr index
--disable_warnings
drop table  if exists  t1;
--enable_warnings
CREATE TABLE t1(id INT PRIMARY KEY, doc varchar(100), VECTOR INDEX idx1(doc) WITH (distance=L2, type=hnsw_bq, dim=1024, model=ob_embed, sync_mode=IMMEDIATE)) organization heap;
insert into t1(id,doc ) values(1,'Rose');
insert into t1(id,doc ) values(2,'Bamboo');
insert into t1(id,doc ) values(3,'Dog');
sleep 10;
call dbms_vector.rebuild_index('idx1', 't1', 'doc');
insert into t1(id,doc ) values(4,'Cat');
insert into t1(id,doc ) values(5,'Giraffe');
insert into t1(id,doc ) values(6,'Aloe');
--echo # rowsets_enable is true
select  /*+ opt_param('rowsets_enabled', 'true') */ * from t1 order by semantic_distance(doc, 'monkey')  approximate limit 3;
select  /*+ opt_param('rowsets_enabled', 'true') */ * from t1 where id < 4 order by semantic_distance(doc, 'monkey')  approximate limit 3;
select  /*+index(t1 idx1)  opt_param('rowsets_enabled', 'true') */ * from t1 where id < 4 order by semantic_distance(doc, 'monkey')  approximate limit 3;

--echo # rowsets_enable is false
select  /*+ opt_param('rowsets_enabled', 'false') */ * from t1 order by semantic_distance(doc, 'monkey')  approximate limit 3;
select  /*+ opt_param('rowsets_enabled', 'false') */ * from t1 where id < 4 order by semantic_distance(doc, 'monkey')  approximate limit 3;
select  /*+index(t1 idx1)  opt_param('rowsets_enabled', 'false') */ * from t1 where id < 4 order by semantic_distance(doc, 'monkey')  approximate limit 3;

#bug2025111700111983773
alter system set _inlist_rewrite_threshold = 2;
select * from  t1 where  id IN(1,2,100) order by semantic_distance(doc, 'abc') approximate limit 1;
alter system set _inlist_rewrite_threshold = 1000;

--echo # Drop AI Mode
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('ob_embed_endpoint');
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_embed');
