#owner: zhuchang.zhu
#owner group: shenzhen
--echo # Hybrid Vector Index Select In Sync Mode

--disable_warnings
drop table if exists t1;
--enable_warnings
alter system set ob_vector_memory_limit_percentage = 44;
sleep 3;

--echo # Create AI Mode
--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT ('ob_embed_endpoint');
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL ('ob_embed');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
'ob_embed', '{
    "type": "dense_embedding",
    "model_name": "qwen3-embedding"
  }');

--disable_query_log
eval call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
'ob_embed_endpoint', '{
    "ai_model_name": "ob_embed",
    "scope": "all",
    "url": "$OB_API_HOST",
    "access_key": "$OB_API_KEY",
    "request_model_name": "$OB_MODEL_NAME",
    "provider": "$OB_MODEL_PROVIDER"
  }');
--enable_query_log

--echo # All data in incr index test begin

CREATE TABLE t1(id INT PRIMARY KEY, doc varchar(100), VECTOR INDEX idx1(doc) WITH (distance=L2, type=hnsw, dim=1024, model=ob_embed, sync_mode=IMMEDIATE)) organization heap;
insert into t1(id,doc ) values(1,'Rose');
insert into t1(id,doc ) values(2,'Bamboo');
insert into t1(id,doc ) values(3,'Dog');
insert into t1(id,doc ) values(4,'Cat');
insert into t1(id,doc ) values(5,'Giraffe');
insert into t1(id,doc ) values(6,'Aloe');

--echo # no filter
select * from t1 order by semantic_distance(doc, 'monkey')  approximate limit 3;
