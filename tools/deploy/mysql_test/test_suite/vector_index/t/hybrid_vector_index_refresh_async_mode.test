# rebuild.
create table t1 (id int PRIMARY KEY, 
                doc varchar(100),
                VECTOR INDEX hybrid_index(doc) WITH (distance=L2,type=hnsw, dim=1024,model=ob_embed,sync_mode=IMMEDIATE));
--disable_query_log
--let $loop=0
while($loop < 200)
{
  eval insert into t1 values($loop, 'abc');
  inc $loop;
}
--enable_query_log
let $log_table = query_get_value(select table_name from oceanbase.__all_table where table_name like '__idx_%hybrid_index', table_name, 1);
let $index_id_table = query_get_value(select table_name from oceanbase.__all_table where table_name like '__idx_%hybrid_index_index_id_table', table_name, 1);
let $snapshot_table = query_get_value(select table_name from oceanbase.__all_table where table_name like '__idx_%hybrid_index_index_snapshot_data_table', table_name, 1);

--sleep 30
call dbms_vector.rebuild_index('hybrid_index','t1','doc', 0);
let $log_count = query_get_value(select count(*) cnt from $log_table, cnt, 1);
let $index_id_count = query_get_value(select count(*) cnt from $index_id_table, cnt, 1);
let $snapshot_refreshed = query_get_value(select count(*) > 0 cnt from $snapshot_table, cnt, 1);
eval select $log_count = 0;
eval select $index_id_count = 0;
eval select $snapshot_refreshed = 1;
drop table t1;

create table t1 (id int PRIMARY KEY, 
                doc varchar(100),
                VECTOR INDEX hybrid_index(doc) WITH (distance=L2,type=hnsw, dim=1024,model=ob_embed,sync_mode=IMMEDIATE)) partition by hash(id) partitions 6;
--disable_query_log
--let $loop=0
while($loop < 200)
{
  eval insert into t1 values($loop, 'abc');
  inc $loop;
}
--enable_query_log
let $log_table = query_get_value(select table_name from oceanbase.__all_table where table_name like '__idx_%hybrid_index', table_name, 1);
let $index_id_table = query_get_value(select table_name from oceanbase.__all_table where table_name like '__idx_%hybrid_index_index_id_table', table_name, 1);
let $snapshot_table = query_get_value(select table_name from oceanbase.__all_table where table_name like '__idx_%hybrid_index_index_snapshot_data_table', table_name, 1);
let $log_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name like '__idx_%hybrid_index', table_id, 1);

--sleep 30
call dbms_vector.rebuild_index('hybrid_index','t1','doc', 0);
let $task_cnt = query_get_value(select count(*) cnt from oceanbase.__all_vector_index_task_history where trigger_type=1 and table_id = $log_table_id order by gmt_create, cnt, 1);
eval select $task_cnt = 6;
