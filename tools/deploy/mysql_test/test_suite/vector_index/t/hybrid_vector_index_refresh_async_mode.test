#owner: miyuan.ljr
#owner group: shenzhen
#description: test hybrid_vector_index_refresh

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT ('ob_embed_endpoint');
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL ('ob_embed');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
'ob_embed', '{
    "type": "dense_embedding",
    "model_name": "qwen3-embedding"
  }');

--disable_query_log
eval call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
'ob_embed_endpoint', '{
    "ai_model_name": "ob_embed",
    "scope": "all",
    "url": "$OB_API_HOST",
    "access_key": "$OB_API_KEY",
    "request_model_name": "$OB_MODEL_NAME",
    "provider": "$OB_MODEL_PROVIDER"
  }');
--enable_query_log

alter system set ob_vector_memory_limit_percentage=40;
alter system set _enable_semantic_index = true;
set ob_enable_index_direct_select = 1;

# refresh.
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (id int PRIMARY KEY, 
                doc varchar(100),
                VECTOR INDEX hybrid_index(doc) WITH (distance=L2,type=hnsw, dim=1024,model=ob_embed, sync_mode=async, sync_interval=3s));
--disable_query_log
--let $loop=0
while($loop < 200)
{
  eval insert into t1 values($loop, 'abc');
  inc $loop;
}
--enable_query_log
let $log_table = query_get_value(select table_name from oceanbase.__all_table where table_name like '__idx_%hybrid_index', table_name, 1);
let $index_id_table = query_get_value(select table_name from oceanbase.__all_table where table_name like '__idx_%hybrid_index_index_id_table', table_name, 1);
let $embedded_table = query_get_value(select table_name from oceanbase.__all_table where table_name like '__idx_%hybrid_index_embedded_vec_table', table_name, 1);

--sleep 10
call dbms_vector.refresh_index('hybrid_index','t1','doc', 0);
let $log_count = query_get_value(select count(*) cnt from $log_table, cnt, 1);
let $index_id_count = query_get_value(select count(*) cnt from $index_id_table, cnt, 1);
let $embedded_count = query_get_value(select count(*) cnt from $embedded_table, cnt, 1);
eval select $log_count = 0;
eval select $index_id_count = 200;
eval select $embedded_count = 200;
drop table t1;

create table t1 (id int PRIMARY KEY, 
                doc varchar(100),
                VECTOR INDEX hybrid_index(doc) WITH (distance=L2,type=hnsw, dim=1024,model=guiji_embed, sync_mode=manual));
--disable_query_log
--let $loop=0
while($loop < 200)
{
  eval insert into t1 values($loop, 'abc');
  inc $loop;
}
--enable_query_log
let $log_table = query_get_value(select table_name from oceanbase.__all_table where table_name like '__idx_%hybrid_index', table_name, 1);
let $index_id_table = query_get_value(select table_name from oceanbase.__all_table where table_name like '__idx_%hybrid_index_index_id_table', table_name, 1);
let $embedded_table = query_get_value(select table_name from oceanbase.__all_table where table_name like '__idx_%hybrid_index_embedded_vec_table', table_name, 1);

--sleep 10
call dbms_vector.refresh_index('hybrid_index','t1','doc', 0);
update t1 set doc = 'sss' where id < 100;
call dbms_vector.refresh_index('hybrid_index','t1','doc', 0);
let $log_count = query_get_value(select count(*) cnt from $log_table, cnt, 1);
let $index_id_count = query_get_value(select count(*) cnt from $index_id_table, cnt, 1);
let $embedded_count = query_get_value(select count(*) cnt from $embedded_table, cnt, 1);
eval select $log_count = 0;
eval select $index_id_count = 400;
eval select $embedded_count = 200;
drop table t1;

