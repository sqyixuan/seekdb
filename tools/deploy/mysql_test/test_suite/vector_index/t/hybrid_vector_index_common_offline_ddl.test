--echo
--echo
--echo "=========================================== add primary key ================================================="
drop table if exists t_vec;
create table t_vec(c1 int, c2 varchar(33), vector index idx1(c2) with (distance=L2,type=hnsw, dim=1024, model=ob_embed, sync_mode=async, sync_interval=3s));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
#insert into t_vec values(1, 'asdgb');
alter table t_vec modify c1 int primary key;
--error 1068
alter table t_vec add primary key(c1);
--error 1068
alter table t_vec modify c1 bigint, add primary key(c1);
alter table t_vec drop primary key, add primary key(c1);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;

--echo
--echo
--echo "=========================================== add/modify partition/rule ================================================="
drop table if exists t_vec;
create table t_vec(c1 int, c2 varchar(33), primary key(c1), vector index idx1(c2) with (distance=L2,type=hnsw, dim=1024, model=ob_embed, sync_mode=async, sync_interval=3s)) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (50));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
#insert into t_vec values(1, 'gdabs');
alter table t_vec partition by range(c1) (partition p0 values less than (20), partition p1 values less than (200));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;

--echo
--echo
--echo "=========================================== complex case ================================================="
drop table if exists t_vec;
create table t_vec(c1 int, c2 varchar(33), c3 int, c4 varchar(33), c5 int, c6 varchar(33), primary key(c1), vector index idx1(c2) with (distance=L2,type=hnsw, dim=1024, model=ob_embed, sync_mode=async, sync_interval=3s));
#insert into t_vec values(1, 'asdg', 5, 'dasg', 7, 'sdfh');
alter table t_vec add column c7 int auto_increment;
create vector index idx2 on  t_vec(c4) with(distance=L2,type=hnsw, dim=1024, model=ob_embed, sync_mode=async, sync_interval=3s);
alter table t_vec drop column c3;
#insert into t_vec values(2, 'asdg', 'gasd', 7, 'hsdfh', 2);
select * from t_vec order by semantic_distance(c2, 'wery') approximate limit 1;
alter table t_vec modify c5 varchar(20) before c4;
create vector index idx3 on t_vec(c6) with(distance=L2,type=hnsw, dim=1024, model=ob_embed, sync_mode=async, sync_interval=3s);
alter table t_vec drop column c7;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
select * from t_vec order by semantic_distance(c6, 'wery') approximate limit 1;
truncate table t_vec;
#insert into t_vec values(1, 'rwey', 'a', 'wer', 'wery');
alter table t_vec drop index idx1;
alter table t_vec drop column c5, add c9 varchar(10) default 'cc';
select * from t_vec order by semantic_distance(c6, 'wery') approximate limit 1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;

drop table if exists t_vec;
create table t_vec(c1 int, c2 varchar(33), primary key(c1), vector index idx1(c2) with (distance=L2,type=hnsw, dim=1024, model=ob_embed, sync_mode=async, sync_interval=3s));
#insert into t_vec values(1, 'asdgh');
ALTER TABLE t_vec ADD c3 INT AUTO_INCREMENT;
ALTER TABLE t_vec ADD COLUMN c4 int AS (c1 + 3) STORED;
alter table t_vec modify c3 tinyint;
alter table t_vec modify c1 tinyint;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;

drop table if exists t_vec;
create table t_vec(c1 int, c2 varchar(33), c3 varchar(10), c4 int, primary key(c1), vector index idx1(c2) with (distance=L2,type=hnsw, dim=1024, model=ob_embed, sync_mode=async, sync_interval=3s)) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (100));
#insert into t_vec values(1, 'zxcb', 'cc', 4);
alter table t_vec modify c1 tinyint;
alter table t_vec modify c3 varchar(5) charset 'gbk';
alter table t_vec modify c1 int;
alter table t_vec add constraint cc check (c1 < 10);
alter table t_vec modify c3 char(8) , add c5 int, drop column c4;
alter table t_vec convert to CHARACTER SET 'utf8';
alter table t_vec convert to CHARACTER SET 'gbk';
truncate table t_vec;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
drop table if exists t_vec;

alter system set _enable_semantic_index=false;