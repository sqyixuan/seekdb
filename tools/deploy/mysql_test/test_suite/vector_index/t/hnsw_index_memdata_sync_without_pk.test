#owner: lb446709
#owner group: shenzhen
#description: test vector_index_memdata_sync

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

alter system set ob_vector_memory_limit_percentage = 20;
sleep 3;

create table t1(c1 int, c2 vector(10), vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag));
create table t2(c1 int, v1 varchar(2), c2 vector(10), vector index idx2(c2) with (distance=l2, type=hnsw, lib=vsag));

# wait for follower create adaptors, or sync log before adaptor creation will be discarded 
--sleep 20

insert into t1 values(1, '[0.203846,0.205289,0.880265,0.824340,0.615737,0.496899,0.983632,0.865571,0.248373,0.542833]');
--disable_query_log
--let $loop=2
while($loop < 102)
{
  eval insert into t1 values($loop, '[0.735541,0.670776,0.903237,0.447223,0.232028,0.659316,0.765661,0.226980,0.579658,0.933939]');
  inc $loop;
}
--enable_query_log

insert into t2 values(1, 'a', '[0.203846,0.205289,0.880265,0.824340,0.615737,0.496899,0.983632,0.865571,0.248373,0.542833]');
--disable_query_log
--let $loop=2
while($loop < 103)
{
  eval insert into t2 values($loop, 'b', '[0.327936,0.048756,0.084670,0.389642,0.970982,0.370915,0.181664,0.940780,0.013905,0.628127]');
  inc $loop;
}
--enable_query_log

# wait for follower memdata sync
--sleep 20

--echo #check lower sync limit
select
sum(SUBSTRING_INDEX(SUBSTRING_INDEX(sync_info, 'incr_cnt=', -1),';',1)) >= 203 as check_incr_cnt,
sum(SUBSTRING_INDEX(SUBSTRING_INDEX(sync_info, 'vbitmap_cnt=', -1),';',1)) = 0 as check_vbitmap_cnt,
sum(SUBSTRING_INDEX(SUBSTRING_INDEX(sync_info, 'snap_cnt=', -1),';',1)) = 0 as check_snap_cnt,
sum(SUBSTRING_INDEX(SUBSTRING_INDEX(sync_info, 'sync_total_cnt=', -1),';',1)) >= 2 as check_sync_total_cnt,
sum(SUBSTRING_INDEX(SUBSTRING_INDEX(sync_info, 'sync_fail_cnt=', -1),';',1)) = 0 as check_sync_fail_cnt
from oceanbase.__all_virtual_vector_index_info a, oceanbase.__all_virtual_table b 
where a.data_table_id = b.table_id and b.table_name in ('t1', 't2');

--echo check upper sync limit
select
sum(SUBSTRING_INDEX(SUBSTRING_INDEX(sync_info, 'incr_cnt=', -1),';',1)) <= 406 as check_incr_cnt,
sum(SUBSTRING_INDEX(SUBSTRING_INDEX(sync_info, 'vbitmap_cnt=', -1),';',1)) = 0 as check_vbitmap_cnt,
sum(SUBSTRING_INDEX(SUBSTRING_INDEX(sync_info, 'snap_cnt=', -1),';',1)) = 0 as check_snap_cnt,
sum(SUBSTRING_INDEX(SUBSTRING_INDEX(sync_info, 'sync_total_cnt=', -1),';',1)) <= 8 as check_sync_total_cnt,
sum(SUBSTRING_INDEX(SUBSTRING_INDEX(sync_info, 'sync_fail_cnt=', -1),';',1)) = 0 as check_sync_fail_cnt
from oceanbase.__all_virtual_vector_index_info a, oceanbase.__all_virtual_table b 
where a.data_table_id = b.table_id and b.table_name in ('t1', 't2');

drop table t1;
drop table t2;

--sleep 15
select count(*) 
from oceanbase.__all_virtual_vector_index_info a, oceanbase.__all_virtual_table b 
where a.data_table_id = b.table_id and b.table_name in ('t1', 't2');
alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;