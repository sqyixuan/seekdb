create table t1(
  c1 int, c2 int, c3 vector(3), 
  vector index idx_vec(c3) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200, extra_info_max_size=512)
);

create table t1(
  c1 int, c2 int, c3 vector(3), 
  vector index idx_vec(c3) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200)
);

create index idx_c2 on t1(c2);

