CREATE TABLE t1 (
  c1 int , c2 vector(3), 
  vector index idx1(c2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200)
);
insert into t1 values(1, [1,2,3]);
insert into t1 values(2, [1,2,3]);
insert into t1 values(3, [1,2,3]);
alter table t1 PARTITION BY HASH(c1) PARTITIONS 3;
drop table t1;

# ---------- 无主键表 ----------
# 随表建
CREATE TABLE t1 (
  c1 int , c2 vector(3), 
  vector index idx1(c2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200)
) partition by hash(c1) partitions 3;

# DML
insert into t1 values(1, '[0.203846,0.205289,0.880265]');
insert into t1 values(2, '[0.484526,0.669954,0.986755]');

# drop index
drop index idx1 on t1;

# 后建
create vector index idx1 on t1(c2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200);

# DML
insert into t1 values(3, '[0.327936,0.048756,0.084670]');
insert into t1 values(4, '[0.148869,0.878546,0.028024]');
insert into t1 values(5, '[0.334970,0.857377,0.886132]');
insert into t1 values(6, '[0.117582,0.302352,0.471198]');
insert into t1 values(7, '[0.551185,0.231134,0.075354]');
insert into t1 values(8, '[0.185221,0.315131,0.558301]');
delete from t1 where c1 <= 1;
update t1 set c2 = '[0.928764,0.254038,0.272721]' where c1 = 2;
update /*+ ENABLE_PARALLEL_DML parallel(2) */ t1 set c2 = '[0.9,0.2,0.2]' where c1 = 2;
select * from t1;

# 查询
select * from t1 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;
select /*+index(t1 idx1)*/ * from t1 where c1 < 10 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;

select /*+index(t1 primary)*/ * from t1 where c1 < 10 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;
create index idx_c1 on t1(c1);
select /*+index(t1 idx_c1)*/ * from t1 where c1 < 10 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;

drop index idx1 on t1;
drop table t1;

# ---------- 堆表 ----------
# 随表建
CREATE TABLE t1 (
  c1 int , c2 vector(3),
  vector index idx1(c2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200)
) organization=heap partition by hash(c1) partitions 3;

# DML
insert into t1 values(1, '[0.203846,0.205289,0.880265]');
insert into t1 values(2, '[0.484526,0.669954,0.986755]');

# drop index
drop index idx1 on t1;

# 后建
create vector index idx1 on t1(c2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200);

# DML
insert into t1 values(3, '[0.327936,0.048756,0.084670]');
insert into t1 values(4, '[0.148869,0.878546,0.028024]');
insert into t1 values(5, '[0.334970,0.857377,0.886132]');
insert into t1 values(6, '[0.117582,0.302352,0.471198]');
insert into t1 values(7, '[0.551185,0.231134,0.075354]');
insert into t1 values(8, '[0.185221,0.315131,0.558301]');
delete from t1 where c1 <= 1;
update t1 set c2 = '[0.928764,0.254038,0.272721]' where c1 = 2;
update /*+ ENABLE_PARALLEL_DML parallel(2) */ t1 set c2 = '[0.9,0.2,0.2]' where c1 = 2;
select * from t1;

# 查询
select * from t1 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;
select /*+index(t1 idx1)*/ * from t1 where c1 < 10 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;

select /*+index(t1 primary)*/ * from t1 where c1 < 10 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;
create index idx_c1 on t1(c1);
select /*+index(t1 idx_c1)*/ * from t1 where c1 < 10 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;

drop index idx1 on t1;
drop table t1;

# ---------- 带主键堆表 ----------
# 随表建
CREATE TABLE t1 (
  c1 int primary key, c2 vector(3),
  vector index idx1(c2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200)
) organization=heap partition by hash(c1) partitions 3;

# DML
insert into t1 values(1, '[0.203846,0.205289,0.880265]');
insert into t1 values(2, '[0.484526,0.669954,0.986755]');

# drop index
drop index idx1 on t1;

# 后建
create vector index idx1 on t1(c2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200);

# DML
insert into t1 values(3, '[0.327936,0.048756,0.084670]');
insert into t1 values(4, '[0.148869,0.878546,0.028024]');
insert into t1 values(5, '[0.334970,0.857377,0.886132]');
insert into t1 values(6, '[0.117582,0.302352,0.471198]');
insert into t1 values(7, '[0.551185,0.231134,0.075354]');
insert into t1 values(8, '[0.185221,0.315131,0.558301]');
delete from t1 where c1 <= 1;
update t1 set c2 = '[0.928764,0.254038,0.272721]' where c1 = 2;
update /*+ ENABLE_PARALLEL_DML parallel(2) */ t1 set c2 = '[0.9,0.2,0.2]' where c1 = 2;
select * from t1;

# 查询
select * from t1 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;
select /*+index(t1 idx1)*/ * from t1 where c1 < 10 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;

select /*+index(t1 primary)*/ * from t1 where c1 < 10 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;
create index idx_c1 on t1(c1);
select /*+index(t1 idx_c1)*/ * from t1 where c1 < 10 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;

drop index idx1 on t1;
drop table t1;

# ---------- 分区变更相关操作 ---------
CREATE TABLE t1 (
  c1 int , c2 vector(3),
  vector index idx1(c2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200)
) partition by hash(c1) partitions 3;

insert into t1 values(1, '[0.203846,0.205289,0.880265]');
insert into t1 values(2, '[0.484526,0.669954,0.986755]');
insert into t1 values(3, '[0.327936,0.048756,0.084670]');
insert into t1 values(4, '[0.148869,0.878546,0.028024]');
insert into t1 values(5, '[0.334970,0.857377,0.886132]');
insert into t1 values(6, '[0.117582,0.302352,0.471198]');
insert into t1 values(7, '[0.551185,0.231134,0.075354]');
insert into t1 values(8, '[0.185221,0.315131,0.558301]');
select count(*) from t1;

alter table t1 partition by range(c1) ( 
  partition p0 values less than (3),
  partition p1 values less than (6),
  partition p2 values less than (100)
); 
select count(*) from t1;

alter table t1 drop partition p0;
select count(*) from t1;

select * from t1 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;
select /*+index(t1 idx1)*/ * from t1 where c1 < 10 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;

select /*+index(t1 primary)*/ * from t1 where c1 < 10 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;
create index idx_c1 on t1(c1);
select /*+index(t1 idx_c1)*/ * from t1 where c1 < 10 order by l2_distance(c2, [0.428146,0.408760,0.765300]) APPROXIMATE limit 3;

drop table t1;

CREATE TABLE t1 (id bigint not null AUTO_INCREMENT,js1 json, js2 json, v1 vector(3),v2 vector(3),sv1 sparsevector,sv2 sparsevector, primary key (id),   vector index idx1(v1) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200, extra_info_max_size=512))
partition by range(id) (
    partition p0 values less than (1000),
    partition p1 values less than (2000),
    partition p2 values less than (3000),
    partition p3 values less than (4000)
);

--error 1235
alter table t1 drop primary key;

drop table t1;

