--echo
--echo
--echo "=========================================== __all_ddl_operation ==========================================="
--disable_warnings
drop table if exists t_vec_ivf_flat;
--enable_warnings
create table t_vec_ivf_flat(c1 int, c2 vector(3));
create vector index idx1 on t_vec_ivf_flat(c2) with (distance=l2, type=ivf_flat);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
show index from t_vec_ivf_flat;
select ddl_stmt_str from oceanbase.__all_ddl_operation where database_id = (select database_id from oceanbase.__all_database where database_name='yjl_vec_post_create') and ddl_stmt_str != '' order by schema_version;

--echo
--echo
--echo "=========================================== 索引名有转义字符 ================================================="
--disable_warnings
drop table if exists t_vec_ivf_flat;
--enable_warnings
create table t_vec_ivf_flat(c1 int, c2 vector(3), primary key(c1));
create vector index `idx\n1` ON t_vec_ivf_flat(c2) with (distance=l2, type=ivf_flat);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
show index from t_vec_ivf_flat;

--echo
--echo
--echo "=========================================== 索引名有大小写 ==================================================="
--disable_warnings
drop table if exists t_vec_ivf_flat;
--enable_warnings
create table t_vec_ivf_flat(c1 int, c2 vector(3), primary key(c1));
create vector index iDx1 ON t_vec_ivf_flat(c2) with (distance=l2, type=ivf_flat);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
show index from t_vec_ivf_flat;

--echo
--echo
--echo "========================================== 索引名有特殊字符 001 ==============================================="

--disable_warnings
drop table if exists t_vec_ivf_flat;
--enable_warnings
create table t_vec_ivf_flat(c1 int, c2 vector(3), primary key(c1));
create vector index iDx$1 ON t_vec_ivf_flat(c2) with (distance=l2, type=ivf_flat);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
show index from t_vec_ivf_flat;

# case 2
--echo
--echo
--echo "========================================== 索引名有特殊字符 002 ==============================================="
--disable_warnings
drop table if exists t_vec_ivf_flat;
--enable_warnings
create table t_vec_ivf_flat(c1 int, c2 vector(3), primary key(c1));
create vector index café ON t_vec_ivf_flat(c2) with (distance=l2, type=ivf_flat);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
show index from t_vec_ivf_flat;

# case 特殊字符café与cafe，认为创建同名索引失败
--echo
--echo
--echo "========================================== 索引名有特殊字符 003 ==============================================="
--disable_warnings
drop table if exists t_vec_ivf_flat;
--enable_warnings
create table t_vec_ivf_flat(c1 int, c2 vector(3), c3 vector(3), primary key(c1));
create vector index café ON t_vec_ivf_flat(c2) with (distance=l2, type=ivf_flat);
--error 1061
create vector index cafe ON t_vec_ivf_flat(c3) with (distance=l2, type=ivf_flat);


--echo
--echo
--echo "========================================== 语法测试 ==============================================="
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 vector(10));
insert into t1 values(1, '[0.748479,0.276979,0.555195,0.145492,0.045639,0.924278,0.696082,0.841479,0.742934,0.953073]');
--error 1235
create unique index idx1 on t1(c2) with (distance=l2, type=ivf_flat);
--error 1235
create unique index idx1 on t1(c2) with (distance=l2, type=ivf_sq8);
--error 1235
create unique index idx1 on t1(c2) with (distance=l2, type=ivf_pq, m=1);
--error 1072
create vector index idx1 on t1(c5) with (distance=l2, type=ivf_flat);
--error 7601
create vector index idx1 on t1(c1) with (distance=l2, type=ivf_flat);
--error 1235
create vector index idx1 on t1(c2);
--error 1235
create vector index idx1 on t1(c2) with (distance=l2);
--error 1235
create vector index idx1 on t1(c2) with (distance=l2, lib=vsag);
--error 1235
create vector index idx1 on t1(c2) with (distance=l2, type=ivf_flat, lib=vsag);
--error 1235
create vector index idx1 on t1(c2) with (distance=l2, type=ivf_pq);
--error 1235
create vector index idx1 on t1(c2) with (distance=l2, type=hnsw, lib=OB);
--error 1235
create vector index idx1 on t1(c2) with (distance=l2, type=ivf_flat, ef_construction=10);
--error 1235
create vector index idx1 on t1(c2) with (distance=l2, type=ivf_flat, ef_search=10);
--error 1235
create vector index idx1 on t1(c2) with (distance=l2, type=ivf_sq8, ef_construction=10);
--error 1235
create vector index idx1 on t1(c2) with (distance=l2, type=ivf_sq8, ef_search=10);
--error 1235
create vector index idx1 on t1(c2) with (distance=l2, type=ivf_pq, ef_construction=10);
--error 1235
create vector index idx1 on t1(c2) with (distance=l2, type=ivf_pq, ef_search=10);


--disable_warnings
drop table if exists t1;
drop table if exists t_vec_ivf_flat;
drop table if exists t_vec_ivf_sq8;
drop table if exists t_vec_ivf_pq;
drop database if exists yjl_vec_post_create;
--enable_warnings

alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;