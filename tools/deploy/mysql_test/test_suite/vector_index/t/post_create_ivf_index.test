# owner: yangjiali.yjl
# owner group: shenzhen
# description: test create vector ivf index

connect (conn_user,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (conn_sys,$OBMYSQL_MS0,root@sys,,test,$OBMYSQL_PORT);
connection conn_user;

--disable_warnings
drop database if exists yjl_vec_post_create;
--enable_warnings

create database yjl_vec_post_create;
use yjl_vec_post_create;

alter system set ob_vector_memory_limit_percentage = 20;
sleep 3;

# basic test
--echo
--echo
--echo "======================================= ivfflat basic test ============================================"
--disable_warnings
drop table if exists t_vec_ivf_flat;
--enable_warnings
create table t_vec_ivf_flat(c1 int, c2 vector(3));
create vector index ivf_flat_idx on t_vec_ivf_flat(c2) with (distance=l2, type=ivf_flat);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_flat;
show index from t_vec_ivf_flat;
let $data_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 't_vec_ivf_flat', table_id, 1);

--echo "check vec columns on main table"
--disable_query_log
eval select column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name from oceanbase.__all_column where table_id = $data_table_id;
--enable_query_log
--echo "check vec index table"
--replace_regex /__idx_[0-9]*/__idx_DATA_TABLE_ID/g
--disable_query_log
eval select table_name from oceanbase.__all_table where data_table_id = $data_table_id and table_name like '%__idx%';
--enable_query_log

--echo "check ivfflat tables columns"
let $ivf_flat_domain_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name like '%ivf_flat_idx%', table_id, 1);
let $ivf_flat_cid_vector_id = query_get_value(select table_id from oceanbase.__all_table where table_name like '%ivf_flat_idx_ivf_cid_vector%', table_id, 1);
let $ivf_flat_rowkey_cid_id = query_get_value(select table_id from oceanbase.__all_table where table_name like '%ivf_flat_idx_ivf_rowkey_cid%', table_id, 1);

--disable_query_log
eval select column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name from oceanbase.__all_column where table_id = $ivf_flat_domain_table_id;
eval select column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name from oceanbase.__all_column where table_id = $ivf_flat_cid_vector_id;
eval select column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name from oceanbase.__all_column where table_id = $ivf_flat_rowkey_cid_id;
--enable_query_log


--echo
--echo
--echo "======================================= ivfsq8 basic test ============================================"
--disable_warnings
drop table if exists t_vec_ivf_sq8;
--enable_warnings
create table t_vec_ivf_sq8(c1 int, c2 vector(3));
create vector index ivf_sq8_idx on t_vec_ivf_sq8(c2) with (distance=l2, type=ivf_sq8);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_ivf_sq8;
show index from t_vec_ivf_sq8;
let $data_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 't_vec_ivf_sq8', table_id, 1);

--echo "check vec columns on main table"
--disable_query_log
eval select column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name from oceanbase.__all_column where table_id = $data_table_id;
--enable_query_log
--echo "check vec index table"
--replace_regex /__idx_[0-9]*/__idx_DATA_TABLE_ID/g
--disable_query_log
eval select table_name from oceanbase.__all_table where data_table_id = $data_table_id and table_name like '%__idx%';
--enable_query_log

--echo "check ivfflat tables columns"
let $ivf_sq8_domain_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name like '%ivf_sq8_idx%', table_id, 1);
let $ivf_sq8_cid_vector_id = query_get_value(select table_id from oceanbase.__all_table where table_name like '%ivf_sq8_idx_ivf_cid_vector%', table_id, 1);
let $ivf_sq8_rowkey_cid_id = query_get_value(select table_id from oceanbase.__all_table where table_name like '%ivf_sq8_idx_ivf_rowkey_cid%', table_id, 1);
let $ivf_sq8_sq_meta_id = query_get_value(select table_id from oceanbase.__all_table where table_name like '%ivf_sq8_idx_ivf_sq_meta%', table_id, 1);

--disable_query_log
eval select column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name from oceanbase.__all_column where table_id = $ivf_sq8_domain_table_id;
eval select column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name from oceanbase.__all_column where table_id = $ivf_sq8_cid_vector_id;
eval select column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name from oceanbase.__all_column where table_id = $ivf_sq8_rowkey_cid_id;
eval select column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name from oceanbase.__all_column where table_id = $ivf_sq8_sq_meta_id;
--enable_query_log



