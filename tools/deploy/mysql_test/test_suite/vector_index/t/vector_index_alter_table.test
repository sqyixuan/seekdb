--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : yangjiali.yjl
#owner group: shenzhen
#description: test of alter table which has vector index

connect (conn_user,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn_user;

--disable_warnings
drop database if exists yjl_vec;
create database yjl_vec;
use yjl_vec;

alter system set ob_vector_memory_limit_percentage = 20;
sleep 3;
--echo
--echo
--echo "=================================== alter table change column with vector index table=============================================="
drop table if exists t_vec;
create table t_vec(c1 vector(3), c2 int auto_increment, primary key(c2), vector index idx_1(c1) with (distance=l2, type=hnsw));
alter table t_vec change column c1 c3 vector(3);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
drop table if exists t_vec;
create table t_vec(c1 int, c2 int, c3 BOOL, c4 vector(3), c5 char(10) as (CONCAT(c3, ' ', c2)), primary key(c3, c2));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
create vector index vec_idx1 on t_vec(c4) with (DISTANCE=L2, TYPE=IVF_FLAT);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
--error 1235
ALTER TABLE t_vec MODIFY c4 sparsevector NOT NULL;
--error 1235
ALTER TABLE t_vec MODIFY c4 int[] NOT NULL;
alter table t_vec drop index vec_idx1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
create vector index vec_idx1 on t_vec(c4) with (DISTANCE=L2, TYPE=HNSW);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
--error 1235
ALTER TABLE t_vec MODIFY c4 sparsevector NOT NULL;
--error 1235
ALTER TABLE t_vec MODIFY c4 int[] NOT NULL;
alter table t_vec drop index vec_idx1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;


--echo
--echo
--echo "=================================== alter table add partition =============================================="
drop table if exists t_vec;
create table t_vec(c1 int, c2 int, c3 vector(3), primary key(c1,c2), vector index idx1(c3) with (distance=l2, type=hnsw)) partition by range(c1) (partition p0 values less than (10));
alter table t_vec add partition (partition p1 values less than (20));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;

--echo
--echo
--echo "=================================== alter table add sub partition =============================================="
drop table if exists t_vec;
create table t_vec(c1 int, c2 int, c3 vector(3), primary key(c1,c2), vector index idx1(c3) with (distance=l2, type=hnsw)) partition by range(c1) subpartition by range(c2) (partition p0 values less than (10) (subpartition p00 values less than (5)));
alter table t_vec add partition (partition p1 values less than(20) (subpartition p10 values less than (10)));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;

--echo
--echo
--echo "=================================== alter table truncate partition with primary key =============================================="
drop table if exists t_vec;
create table t_vec(c1 int, c2 vector(3), c3 varchar(3), c4 int, c5 int, primary key(c1)) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (100));
create vector index idx1 on t_vec(c2) with (distance=l2,type=ivf_flat);
alter table t_vec truncate partition p1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;


--echo
--echo
--echo "=================================== alter table truncate partition with unique index key =============================================="
drop table if exists t_vec;
create table t_vec(c1 int, c2 vector(3), c3 varchar(3), c4 int, c5 int, unique (c1)) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (100));
--error 1235
create vector index idx1 on t_vec(c2) with (distance=l2,type=ivf_flat);
alter table t_vec truncate partition p1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;


--echo
--echo
--echo "=================================== alter table truncate partition with complex index key =============================================="
drop table if exists t_vec;
create table t_vec(c1 int, c2 vector(3), c3 varchar(3), c4 int, c5 int, primary key(c1)) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (100));
create index idx1 on t_vec(c3,c4);
create vector index idx2 on t_vec(c2) with (distance=l2,type=ivf_flat);
alter table t_vec truncate partition p1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;



--echo
--echo
--echo "=================================== alter table add/drop partition with primary key =============================================="
drop table if exists t_vec;
create table t_vec(c1 int, c2 vector(3), c3 varchar(3), c4 int, c5 int, primary key(c1)) partition by range(c1) (partition p0 values less than (10));
create vector index idx1 on t_vec(c2) with (distance=l2,type=ivf_flat);
alter table t_vec add partition (partition p1 values less than (100));
alter table t_vec drop partition p1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;


--echo
--echo
--echo "=================================== alter table add/drop partition with unique index key =============================================="
drop table if exists t_vec;
create table t_vec(c1 int, c2 vector(3), c3 varchar(3), c4 int, c5 int, unique (c1)) partition by range(c1) (partition p0 values less than (10));
--error 1235
create vector index idx1 on t_vec(c2) with (distance=l2,type=ivf_flat);
alter table t_vec add partition (partition p1 values less than (100));
alter table t_vec drop partition p1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;


--echo
--echo
--echo "=================================== alter table add/drop partition with complex index key =============================================="
drop table if exists t_vec;
create table t_vec(c1 int, c2 vector(3), c3 varchar(3), c4 int, c5 int, primary key(c1)) partition by range(c1) (partition p0 values less than (10));
create index idx1 on t_vec(c3,c4);
create vector index idx2 on t_vec(c2) with (distance=l2,type=ivf_flat);
alter table t_vec add partition (partition p1 values less than (100));
alter table t_vec drop partition p1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;

connection conn_user;
drop table if exists t_vec;
drop database if exists yjl_vec;
alter system set ob_vector_memory_limit_percentage =0;
