--echo === 多表 JOIN UPDATE ===
--disable_warnings
DROP TABLE IF EXISTS vector_join_t1;
DROP TABLE IF EXISTS vector_join_t2;
DROP TABLE IF EXISTS vector_join_t3;
--enable_warnings

CREATE TABLE vector_join_t1 (
    id INT PRIMARY KEY,
    doc VARCHAR(100),
    category VARCHAR(50),
    VECTOR INDEX idx1(doc) WITH (distance=L2, type=hnsw, dim=1024, model=ob_embed, sync_mode=manual)
) organization heap;

CREATE TABLE vector_join_t2 (
    id INT PRIMARY KEY,
    name VARCHAR(100),
    ref_id INT
) organization heap;

CREATE TABLE vector_join_t3 (
    id INT PRIMARY KEY,
    description TEXT,
    ref_id INT
) organization heap;

INSERT INTO vector_join_t1 VALUES 
    (1, 'Document one', 'tech'),
    (2, 'Document two', 'science'),
    (3, 'Document three', 'tech');

INSERT INTO vector_join_t2 VALUES 
    (1, 'Reference one', 1),
    (2, 'Reference two', 2),
    (3, 'Reference three', 3);

INSERT INTO vector_join_t3 VALUES 
    (1, 'Description for doc one', 1),
    (2, 'Description for doc two', 2),
    (3, 'Description for doc three', 3);

--error 1062
UPDATE vector_join_t1 t1
JOIN vector_join_t2 t2 ON t1.id = t2.ref_id
JOIN vector_join_t3 t3 ON t1.id = t3.ref_id
SET t1.doc = CONCAT(t1.doc, ' - ', t2.name, ' - ', t3.description)
WHERE t1.category = 'tech';

SELECT * FROM vector_join_t1 ORDER BY id;
--echo === 多表 JOIN DELETE ===
DELETE t1 FROM vector_join_t1 t1
JOIN vector_join_t2 t2 ON t1.id = t2.ref_id
WHERE t2.name LIKE '%two%';

SELECT * FROM vector_join_t1 ORDER BY id;

--echo === 子查询 UPDATE ===
--error 1062
UPDATE vector_join_t1 
SET doc = CONCAT(doc, ' - updated')
WHERE id IN (SELECT ref_id FROM vector_join_t2 WHERE name LIKE '%one%');

SELECT * FROM vector_join_t1 ORDER BY id;

DROP TABLE vector_join_t1, vector_join_t2, vector_join_t3;

--echo ========== 视图上的 DML 操作 ==========
--disable_warnings
DROP TABLE IF EXISTS vector_view_base;
DROP VIEW IF EXISTS vector_view;
--enable_warnings

CREATE TABLE vector_view_base (
    id INT PRIMARY KEY,
    doc VARCHAR(100),
    category VARCHAR(50),
    VECTOR INDEX idx1(doc) WITH (distance=L2, type=hnsw, dim=1024, model=ob_embed, sync_mode=manual)
) organization heap;

CREATE VIEW vector_view AS 
SELECT id, doc, category FROM vector_view_base WHERE category = 'tech';

INSERT INTO vector_view_base VALUES 
    (1, 'Tech document one', 'tech'),
    (2, 'Science document', 'science'),
    (3, 'Tech document two', 'tech');

INSERT INTO vector_view (id, doc, category) VALUES (4, 'New tech doc', 'tech');
--error 1062
UPDATE vector_view SET doc = CONCAT(doc, ' - updated') WHERE id = 1;
DELETE FROM vector_view WHERE id = 3;

SELECT * FROM vector_view_base ORDER BY id;
SELECT * FROM vector_view ORDER BY id;

DROP VIEW vector_view;
DROP TABLE vector_view_base;

--echo ========== JSON 字段的 DML 操作 ==========
--disable_warnings
DROP TABLE IF EXISTS vector_json_table;
--enable_warnings

CREATE TABLE vector_json_table (
    id INT PRIMARY KEY,
    doc VARCHAR(100),
    metadata JSON,
    VECTOR INDEX idx1(doc) WITH (distance=L2, type=hnsw, dim=1024, model=ob_embed, sync_mode=manual),
    INDEX metadata_idx ((CAST(json_extract(metadata, '$.tags') AS CHAR(100) ARRAY)))
) organization heap;

INSERT INTO vector_json_table VALUES 
    (1, 'Document with tags', '{"tags": ["tech", "ai"], "priority": "high"}'),
    (2, 'Another document', '{"tags": ["science", "research"], "priority": "medium"}');

UPDATE vector_json_table 
SET metadata = JSON_SET(metadata, '$.tags', JSON_ARRAY('tech', 'ai', 'machine_learning'))
WHERE id = 1;

--error 1062
UPDATE vector_json_table 
SET doc = CONCAT(doc, ' - high priority')
WHERE JSON_EXTRACT(metadata, '$.priority') = 'high';

SELECT * FROM vector_json_table ORDER BY id;

DROP TABLE vector_json_table;


--echo ========== 字符集相关的 DML ==========
--disable_warnings
DROP TABLE IF EXISTS vector_charset_table;
--enable_warnings

--echo === utf8 字符集 ===
CREATE TABLE vector_charset_table (
    id INT PRIMARY KEY,
    doc VARCHAR(100),
    VECTOR INDEX idx1(doc) WITH (distance=L2, type=hnsw, dim=1024, model=ob_embed, sync_mode=manual)
) DEFAULT CHARSET = utf8 organization heap;

INSERT INTO vector_charset_table VALUES 
    (1, 'abc英文空格 中文分号；英文分号;全角空格　全角逗号，等');

SELECT * FROM vector_charset_table WHERE id = 1;

--echo === utf16 字符集 ===
DROP TABLE vector_charset_table;
CREATE TABLE vector_charset_table (
    id INT PRIMARY KEY,
    doc VARCHAR(100),
    VECTOR INDEX idx1(doc) WITH (distance=L2, type=hnsw, dim=1024, model=ob_embed, sync_mode=manual)
) DEFAULT CHARSET = utf16 organization heap;

INSERT INTO vector_charset_table VALUES 
    (1, 'abcdefg');

--error 1062
UPDATE vector_charset_table 
SET doc = CONCAT(doc, 'hijklmn')
WHERE id = 1;

SELECT * FROM vector_charset_table WHERE id = 1;

DROP TABLE vector_charset_table;

--echo ========== 空值和边界值处理 ==========
--disable_warnings
DROP TABLE IF EXISTS vector_null_table;
--enable_warnings

CREATE TABLE vector_null_table (
    id INT PRIMARY KEY,
    doc VARCHAR(100),
    content TEXT,
    VECTOR INDEX idx1(doc) WITH (distance=L2, type=hnsw, dim=1024, model=ob_embed, sync_mode=manual)
) organization heap;

INSERT INTO vector_null_table VALUES 
    (1, '', 'Empty string'),
    (2, NULL, 'NULL value'),
    (3, '   ', 'Whitespace only'),
    (4, 'Normal content', 'Normal document');

--error 1062
UPDATE vector_null_table 
SET doc = NULL 
WHERE id = 4;

--error 1062
UPDATE vector_null_table 
SET doc = '' 
WHERE id = 3;

DELETE FROM vector_null_table 
WHERE doc IS NULL OR doc = '';

SELECT * FROM vector_null_table ORDER BY id;
DROP TABLE vector_null_table;

