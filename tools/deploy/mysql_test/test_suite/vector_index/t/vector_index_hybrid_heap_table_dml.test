DROP TABLE IF EXISTS vector_null_table;
--enable_warnings

CREATE TABLE vector_null_table (
    id INT PRIMARY KEY,
    doc VARCHAR(100),
    content TEXT,
    VECTOR INDEX idx1(doc) WITH (distance=L2, type=hnsw, dim=1024, model=ob_embed, sync_mode=immediate)
) organization heap;

INSERT INTO vector_null_table VALUES 
    (1, '', 'Empty string'),
    (2, NULL, 'NULL value'),
    (3, '   ', 'Whitespace only'),
    (4, 'Normal content', 'Normal document');

