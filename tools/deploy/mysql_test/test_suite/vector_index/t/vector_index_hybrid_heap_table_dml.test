CREATE TABLE test (
pk bigint,
col_varchar_50 varchar(50),
col_varchar_200 varchar(200),
/*Indices*/
primary key (pk),
vector index vector_idx(col_varchar_50) with (distance= cosine, lib=vsag, type= hnsw_bq, model=ob_embed, dim=64, sync_mode=immediate)) organization heap PARTITION BY hash(pk) partitions 2; 
