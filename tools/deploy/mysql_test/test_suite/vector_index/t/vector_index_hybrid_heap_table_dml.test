SET doc = NULL 
WHERE id = 4;

--error 1062
UPDATE vector_null_table 
SET doc = '' 
WHERE id = 3;

DELETE FROM vector_null_table 
WHERE doc IS NULL OR doc = '';

SELECT * FROM vector_null_table ORDER BY id;

DROP TABLE vector_null_table;

