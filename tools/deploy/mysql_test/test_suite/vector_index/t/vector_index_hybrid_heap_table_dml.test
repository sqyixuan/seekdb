# issue 2025102100111528714
DROP TABLE /*! IF EXISTS*/ B; 
CREATE TABLE B (
    pk bigint,
    col_varchar_200_key varchar(200),
    col_int_index int,
    col_int int,
    col_varchar_200 varchar(200),
    /*Indices*/
    primary key (pk) ,
    key idx8(pk, col_varchar_200_key),
    index idx1(pk, col_int_index)
); 

DROP TABLE /*! IF EXISTS*/ U; 
CREATE TABLE U (
    pk bigint,
    col_varchar_200_key varchar(200),
    col_int_index int,
    col_int int,
    col_varchar_200 varchar(200),
    /*Indices*/
    primary key (pk),
    key idx8(pk, col_varchar_200_key),
    index idx1(pk, col_int_index)
); 

DROP TABLE /*! IF EXISTS*/ A; 
CREATE TABLE A (
    pk bigint,
    col_varchar_200_key varchar(200),
    col_int_index int,
    col_int int,
    col_varchar_200 varchar(200),
    /*Indices*/
    primary key (pk),
    key idx8(pk, col_varchar_200_key),
    index idx1(pk, col_int_index )
);

create vector index vector_idx on B(col_varchar_200) with (distance= cosine, lib=vsag, type= hnsw, model=ob_embed, dim=1024, sync_mode=manual);
update  B A,  U B SET A . col_varchar_200_key = B . col_varchar_200_key where A . pk = B . pk and A . `col_int_index` = B . `col_int_index` and A . col_varchar_200_key in ( 'w', 'l' ) or B . `pk` in ( SELECT `col_int` FROM u WHERE pk is not NULL );

#bug2025112500112213222
--disable_warnings
DROP TABLE IF EXISTS F;
--enable_warnings
CREATE TABLE F (
pk bigint,
col_varchar_50 varchar(50),
col_varchar_200 varchar(200),
primary key (pk)
) organization heap PARTITION BY key(pk) partitions 10 ;

INSERT INTO F VALUES (1, 'a', 'a');

create VECTOR index VECTOR_IDX on F(col_varchar_50) with (distance= l2, lib=vsag, type= hnsw, model=ob_embed, dim=1024, sync_mode=manual) ;

INSERT INTO F VALUES (1, 'b', 'b') ON DUPLICATE KEY UPDATE col_varchar_200='cc';
