#owner: shanhaikang.shk
#owner group: hangzhou
--echo # DBMS VECTOR job concurrency

connect (conn_sys,$OBMYSQL_MS0,root@sys,,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

connection conn_sys;
SET @@recyclebin = off;
--disable_query_log
--disable_result_log
alter system set ob_vector_memory_limit_percentage = 30;
--enable_result_log
--enable_query_log

--disable_query_log
--disable_result_log
sleep 3;
--enable_result_log
--enable_query_log

alter system set debug_sync_timeout = '100000s';
sleep 3;

connection conn1;
--disable_query_log
--disable_result_log
alter system set ob_vector_memory_limit_percentage = 30;
--enable_result_log
--enable_query_log

--disable_query_log
--disable_result_log
sleep 3;
--enable_result_log
--enable_query_log

SET @@recyclebin = off;
--disable_warnings
drop database if exists shk_vec;
create database shk_vec;
use shk_vec;

drop table if exists t1;
create table t1(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=hnsw, lib=vsag));
insert into t1 values(21, '[0.748479,0.276979,0.555195]'), (22, '[0.748479,0.276979,0.555195]'),(23, '[0.748479,0.276979,0.555195]'),(24, '[0.748479,0.276979,0.555195]'),(25, '[0.748479,0.276979,0.555195]'),(26, '[0.748479,0.276979,0.555195]'),(27, '[0.748479,0.276979,0.555195]'),(28, '[0.748479,0.276979,0.555195]'),(29, '[0.748479,0.276979,0.555195]'),(30, '[0.748479,0.276979,0.555195]'),(31, '[0.748479,0.276979,0.555195]'),(32, '[0.748479,0.276979,0.555195]'),(33, '[0,0,0]'),(34, '[0.748479,0.276979,0.555195]'),(35, '[0.748479,0.276979,0.555195]'),(36, '[0,0,0]');

connection conn_sys;
SET @@recyclebin = off;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_DBMS_VECTOR_REFRESH wait_for signaldbms execute 10000';

connection conn1;
SET @@recyclebin = off;
use shk_vec;
send call dbms_vector.refresh_index('idx1','t1','',0,'FAST');
--sleep 10

connection conn2;
--disable_query_log
--disable_result_log
alter system set ob_vector_memory_limit_percentage = 30;
--enable_result_log
--enable_query_log

--disable_query_log
--disable_result_log
sleep 3;
--enable_result_log
--enable_query_log

SET @@recyclebin = off;
use shk_vec;
SELECT c1 from t1 order by l2_distance(c2, [0,0,0]) APPROXIMATE limit 4;
insert into t1 values (0, '[0,0,0]');
SELECT c1 from t1 order by l2_distance(c2, [0,0,0]) APPROXIMATE limit 4;
--error 4179
call dbms_vector.refresh_index('idx1','t1','',0,'FAST');
--error 4179
call dbms_vector.rebuild_index('idx1', 't1');

connection conn_sys;
SET @@recyclebin = off;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal signaldbms';
--sleep 10

connection conn1;
reap;
SET @@recyclebin = off;
use shk_vec;
drop table t1;
create table t1(c1 int, c2 vector(3), primary key(c1), vector index idx1(c2) with(distance=l2, type=hnsw, lib=vsag));
insert into t1 values(21, '[0.748479,0.276979,0.555195]'), (22, '[0.748479,0.276979,0.555195]'),(23, '[0.748479,0.276979,0.555195]'),(24, '[0.748479,0.276979,0.555195]'),(25, '[0.748479,0.276979,0.555195]'),(26, '[0.748479,0.276979,0.555195]'),(27, '[0.748479,0.276979,0.555195]'),(28, '[0.748479,0.276979,0.555195]'),(29, '[0.748479,0.276979,0.555195]'),(30, '[0.748479,0.276979,0.555195]'),(31, '[0.748479,0.276979,0.555195]'),(32, '[0.748479,0.276979,0.555195]'),(33, '[0,0,0]'),(34, '[0.748479,0.276979,0.555195]'),(35, '[0.748479,0.276979,0.555195]'),(36, '[0,0,0]');



connection conn_sys;
SET @@recyclebin = off;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_DBMS_VECTOR_REBUILD wait_for signaldbms execute 10000';

connection conn1;
SET @@recyclebin = off;
use shk_vec;
send call dbms_vector.rebuild_index('idx1', 't1');
--sleep 10

connection conn2;
SET @@recyclebin = off;
use shk_vec;
SELECT c1 from t1 order by l2_distance(c2, [0,0,0]) APPROXIMATE limit 4;
insert into t1 values (0, '[0,0,0]');
SELECT c1 from t1 order by l2_distance(c2, [0,0,0]) APPROXIMATE limit 4;
--error 4179
call dbms_vector.refresh_index('idx1','t1','',0,'FAST');
--error 4179
call dbms_vector.rebuild_index('idx1', 't1');

connection conn_sys;
SET @@recyclebin = off;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal signaldbms';
--sleep 10

connection conn1;
reap;
SET @@recyclebin = off;
use shk_vec;
drop table t1;
drop database if exists shk_vec;
--sleep 20
