# owner: fanfangyao.ffy
# owner group: ddl
# description: test create hybrid vector index with no primary key table

--disable_warnings
drop database if exists post_create_vec_npk;
--enable_warnings
create database post_create_vec_npk;
use post_create_vec_npk;

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT ('ob_embed_endpoint');
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL ('ob_embed');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
'ob_embed', '{
    "type": "dense_embedding",
    "model_name": "qwen3-embedding"
  }');

--disable_query_log
eval call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
'ob_embed_endpoint', '{
    "ai_model_name": "ob_embed",
    "scope": "all",
    "url": "$OB_API_HOST",
    "access_key": "$OB_API_KEY",
    "request_model_name": "$OB_MODEL_NAME",
    "provider": "$OB_MODEL_PROVIDER"
  }');
--enable_query_log

alter system set _enable_semantic_index=true;

--echo
--echo
--echo "=========================================== 无主键表：正常后建用例 ==========================================="
--disable_warnings
drop table if exists vec_table_npk;
--enable_warnings
CREATE TABLE vec_table_npk (
  id int,
  c2 varchar(100)
);

alter system set ob_vector_memory_limit_percentage = 20;
sleep 3;
CREATE VECTOR INDEX VEC_IDX1 ON vec_table_npk(c2) with (distance=l2, type=hnsw, lib=vsag, model=ob_embed, dim=1024, sync_mode=IMMEDIATE);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table vec_table_npk;
drop table vec_table_npk;

--echo
--echo
--echo "=========================================== 无主键表：索引名有转义字符 ========================================"
--disable_warnings
drop table if exists t_vec_npk;
--enable_warnings
create table t_vec_npk(c1 int, c2 varchar(100));
create vector index `idx\n1` ON t_vec_npk(c2) with (distance=l2, type=hnsw, lib=vsag, model=ob_embed, dim=1024, sync_mode=IMMEDIATE);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_npk;
drop table t_vec_npk;

# 索引名有大小写
--echo
--echo
--echo "=========================================== 无主键表：索引名有大小写 =========================================="
--disable_warnings
drop table if exists t_vec_npk;
--enable_warnings
create table t_vec_npk(c1 int, c2 varchar(100));
create vector index iDx1 ON t_vec_npk(c2) with (distance=l2, type=hnsw, lib=vsag, model=ob_embed, dim=1024, sync_mode=IMMEDIATE);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_npk;
drop table t_vec_npk;

# 索引名有特殊字符
# case 1
--echo
--echo
--echo "=========================================== 无主键表：索引名有特殊字符 001 ======================================"

--disable_warnings
drop table if exists t_vec_npk;
--enable_warnings
create table t_vec_npk(c1 int, c2 varchar(100));
create vector index iDx$1 ON t_vec_npk(c2) with (distance=l2, type=hnsw, lib=vsag, model=ob_embed, dim=1024, sync_mode=IMMEDIATE);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_npk;
drop table t_vec_npk;

# case 2
--echo
--echo
--echo "=========================================== 无主键表：索引名有特殊字符 002 ======================================"
--disable_warnings
drop table if exists t_vec_npk;
--enable_warnings
create table t_vec_npk(c1 int, c2 varchar(100));
create vector index café ON t_vec_npk(c2) with (distance=l2, type=hnsw, lib=vsag, model=ob_embed, dim=1024, sync_mode=IMMEDIATE);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_npk;
drop table t_vec_npk;

# case 特殊字符café与cafe，认为创建同名索引失败
--echo
--echo
--echo "=========================================== 无主键表：索引名有特殊字符 003 ======================================"
--disable_warnings
drop table if exists t_vec_npk;
--enable_warnings
create table t_vec_npk(c1 int, c2 varchar(100), c3 varchar(100));
create vector index café ON t_vec_npk(c2) with (distance=l2, type=hnsw, lib=vsag, model=ob_embed, dim=1024, sync_mode=IMMEDIATE);
--error 1061
create vector index cafe ON t_vec_npk(c3) with (distance=l2, type=hnsw, lib=vsag, model=ob_embed, dim=1024, sync_mode=IMMEDIATE);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec_npk;
drop table t_vec_npk;

# 并行开关下的后建索引
--echo
--echo
--echo "=========================================== 无主键表：串行/并行构建后建索引 ===================================="
--disable_warnings
drop table if exists t1_npk;
--enable_warnings
alter system set _enable_parallel_table_creation = false;
sleep 3;
create table t1_npk(c1 int, c2 varchar(100));
CREATE VECTOR INDEX idx ON t1_npk(c2) with (distance=l2, type=hnsw, lib=vsag, model=ob_embed, dim=1024, sync_mode=IMMEDIATE);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1_npk;
show index from t1_npk;
drop table if exists t1_npk;

alter system set _enable_parallel_table_creation = true;
sleep 3;
create table t1_npk(c1 int, c2 varchar(100));
CREATE VECTOR INDEX idx_p ON t1_npk(c2) with (distance=l2, type=hnsw, lib=vsag, model=ob_embed, dim=1024, sync_mode=IMMEDIATE);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1_npk;
show index from t1_npk;
drop table if exists t1_npk;

--echo
--echo
--echo ====================== 无主键表：basic test #2 =================================
--echo ============= 在有数据的无主键表上后建向量索引 ===========

--disable_warnings
DROP TABLE IF EXISTS t1_npk;
--enable_warnings

create table t1_npk(c1 int, c2 varchar(100));
insert into t1_npk values(1, 'He was an old man who fished alone in a skiff in the Gulf1 Stream');
insert into t1_npk values(2, 'he had gone eighty-four days now without taking a fish');
insert into t1_npk values(3, 'In the first forty days a boy had been with him.');
insert into t1_npk values(4, 'But after forty days without a fish the boy’s parents');
insert into t1_npk values(5, 'had told him that the old man was now definitely and finally salao');
insert into t1_npk values(6, 'which is the worst form of unlucky');
insert into t1_npk values(7, 'the boy had gone at their orders in another boat');
insert into t1_npk values(8, 'which caught three good fish the first week');
insert into t1_npk values(9, 'It made the boy sad to see the old man');
insert into t1_npk values(10, 'come in each day with his skiff empty');
insert into t1_npk values(11, 'he always went down to help him carry');
insert into t1_npk values(12, 'the coiled lines or the gaff and harpoon');
insert into t1_npk values(13, 'the sail that was furled around the mast');
insert into t1_npk values(14, 'The sail was patched with flour sacks');
insert into t1_npk values(15, 'it looked like the flag of permanent defeat');
insert into t1_npk values(16, 'The old man was thin and gaunt');
insert into t1_npk values(17, 'with deep wrinkles in the back of his neck');
insert into t1_npk values(18, 'The brown blotches of the benevolent skin cancer');
insert into t1_npk values(19, 'sun brings from its reflection on the tropic sea');
insert into t1_npk values(20, 'The blotches ran well down the sides of his face');

create vector index idx1 on t1_npk(c2) WITH (distance=L2, lib=vsag, type=hnsw, m=10, ef_construction = 12, ef_search = 40, model=ob_embed, dim=1024, sync_mode=IMMEDIATE);
drop table t1_npk;

--disable_warnings
drop table if exists t1_npk;
--enable_warnings
CREATE TABLE t1_npk (c1 int, c2 vector(3),c3 varchar(100) ,c4 vector(3));
insert into t1_npk values(1,'[1,1,2]','ggggggggg','[1,3,2]');
insert /*+ direct(true,100) enable_parallel_dml parallel(2) */ into t1_npk select * from t1_npk;
create VECTOR index vector_idx1 on t1_npk(c3) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40, model=ob_embed, dim=1024, sync_mode=IMMEDIATE);
drop table t1_npk;

--disable_warnings
drop table if exists t1_npk;
--enable_warnings
CREATE TABLE t1_npk (c1 int, c2 varchar(100));
insert into t1_npk values(1, "ob1");
insert into t1_npk values(2, "");
insert into t1_npk values(3, null);
insert into t1_npk values(4, "ob4");
create VECTOR index vector_idx1 on t1_npk(c2) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40, model=ob_embed, dim=1024, sync_mode=IMMEDIATE);
drop table t1_npk;

--disable_warnings
drop table if exists d;
--enable_warnings
CREATE TABLE D (
  pk bigint,
  col_varchar_50 varchar(50),
  col_int_key int,
  key idx2(pk, col_int_key )) ORGANIZATION HEAP PARTITION BY hash(pk) partitions 2;

INSERT INTO D VALUES (20, 'was', 4);
COMMIT;
create vector index vector_idx on D(col_varchar_50) with (distance= l2, lib=vsag, type= hnsw, model=ob_embed, dim=64, sync_mode=immediate) ;
update D set D.col_varchar_50 = repeat('a',50) where D.`col_int_key` = 4;
drop table d;

--disable_warnings
drop table if exists t_vec_npk;
--enable_warnings
create table t_vec_npk(c1 int, c2 varchar(100), c3 varchar(20), j json, c4 sparsevector);
insert into t_vec_npk values(1, 'aadwdawdwadawass', 'a', '{"key":[7,932,22]}', '{1:0.1,2:0.2, 3:0.3}');
--error 1235
create vector index idx1 on t_vec_npk(c2) with (distance=l2, type=hnswm, model=ob_embed, dim=1024, sync_mode=IMMEDIATE) with column group(each column);
--error 1235
create vector index idx1 on t_vec_npk(c2) with (distance=l2, type=hnsw, model=ob_embed, dim=1024, sync_mode=IMMEDIATE) with column group(all columns);
--error 1235
create fulltext index idx1 on t_vec_npk(c3) with column group(each column);
--error 1235
create fulltext index idx1 on t_vec_npk(c3) with column group(all columns);
--error 1235
create index idx1 on t_vec_npk((CAST(j->'$.key' AS UNSIGNED ARRAY))) with column group(each column);
--error 1235
create index idx1 on t_vec_npk((CAST(j->'$.key' AS UNSIGNED ARRAY))) with column group(all columns);
drop table t_vec_npk;

# 回归：分区表 + 后建混合索引
--disable_warnings
drop table if exists tbl_65_npk;
--enable_warnings
create TABLE tbl_65_npk ( col_1019 smallint  unsigned not null default 28746 ,col_1020 char ( 191 )    default 'KpflB^i2U9s8tK7sWB' ,col_1021 timestamp   not null default '2016-04-10' ,col_1022 bigint   not null default 8386665492819325807 ,col_1023 int  unsigned ,col_1024 varchar ( 123 )   not null ,col_1025 bit ( 28 )    default 262054020 ,col_1026 int  unsigned not null ,col_1027 smallint  unsigned  default 2990 ,col_1028 bit ( 14 )    default 11989 ,col_1029 smallint  unsigned  default 18662 ) DEFAULT CHARSET= latin1 ROW_FORMAT = DYNAMIC COMPRESSION = 'snappy_1.0' partition by hash ( col_1023 ) partitions 125;
create vector index vector_idx_2918_npk ON tbl_65_npk ( col_1024 ) WITH ( distance=l2, type=hnsw_bq, model=ob_embed, dim=1024, sync_mode=async, sync_interval=10m );
truncate table tbl_65_npk;
drop table tbl_65_npk;

call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_embed');
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('ob_embed_endpoint');

# check virtual table later
PURGE RECYCLEBIN;
--disable_warnings
drop table if exists t1_npk;
--enable_warnings
drop database if exists post_create_vec_npk;
alter system set ob_vector_memory_limit_percentage = 0;
--enable_query_log
PURGE RECYCLEBIN;
