create vector index idxv on t_vec (c3) with (distance=l2, type=ivf_flat, nlist=2, sample_per_nlist=3);
create index idx1 on t_vec(c2);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;

select * from t_vec order by l2_distance(c3, [0.428146,0.408760,0.765300]) APPROXIMATE limit 10;

select * from t_vec where c1 < 100 order by l2_distance(c3, [0.428146,0.408760,0.765300]) APPROXIMATE limit 10;

select/*+index(t_vec idx1)*/ * from t_vec where c1 < 100 order by l2_distance(c3, [0.428146,0.408760,0.765300]) APPROXIMATE limit 10;

select/*+index(t_vec idxv)*/ * from t_vec where c1 < 100 order by l2_distance(c3, [0.428146,0.408760,0.765300]) APPROXIMATE limit 10;

explain select * from t_vec where c1 < 100 order by l2_distance(c3, [0.428146,0.408760,0.765300]) APPROXIMATE limit 10;

explain select/*+index(t_vec idx1)*/ * from t_vec where c1 < 100 order by l2_distance(c3, [0.428146,0.408760,0.765300]) APPROXIMATE limit 10;

--replace_regex /_[0-9]+/_0/g
explain select/*+index(t_vec idxv)*/ * from t_vec where c1 < 100 order by l2_distance(c3, [0.428146,0.408760,0.765300]) APPROXIMATE limit 10;

## normal index + vec index
--disable_warnings
drop table if exists t_vec;
--enable_warnings
create table t_vec(c1 int, c2 int, c3 int, v vector(3), primary key(c1));

insert into t_vec values(1, 1, 10, '[0.203846,0.205289,0.880265]');
insert into t_vec values(2, 2, 9, '[0.226980,0.579658,0.933939]');
insert into t_vec values(3, 3, 8, '[0.181664,0.013905,0.628127]');
insert into t_vec values(4, 4, 7, '[0.442633,0.637534,0.633993]');
insert into t_vec values(5, 5, 6, '[0.190118,0.959676,0.796483]');
insert into t_vec values(6, 6, 5, '[0.710370,0.007130,0.710913]');
insert into t_vec values(7, 7, 4, '[0.238120,0.289662,0.970101]');
insert into t_vec values(8, 8, 3, '[0.168794,0.567442,0.062338]');
insert into t_vec values(9, 9, 2, '[0.901419,0.676738,0.122339]');
insert into t_vec values(10, 10, 1, '[0.563644,0.811224,0.175574]');

create vector index idx3 on t_vec (v) with (distance=l2, type=ivf_flat, nlist=2, sample_per_nlist=3);
create index idx1 on t_vec(c2);
create index idx2 on t_vec(c3);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;

select * from t_vec where c2 > 5 and c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

select /*+index(t_vec idx1) */ * from t_vec where c2 > 5 and c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

select /*+index(t_vec idx2) */ * from t_vec where c2 > 5 and c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

select /*+index(t_vec idx3) */ * from t_vec where c2 > 5 and c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

select * from t_vec order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

explain select * from t_vec where c2 > 5 and c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

explain select /*+index(t_vec idx1) */ * from t_vec where c2 > 5 and c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

explain select /*+index(t_vec idx2) */ * from t_vec where c2 > 5 and c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

--replace_regex /_[0-9]+/_0/g
explain select /*+index(t_vec idx3) */ * from t_vec where c2 > 5 and c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

--replace_regex /_[0-9]+/_0/g
explain select * from t_vec order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

--disable_warnings
drop table if exists t_vec;
--enable_warnings

create table t_vec(c1 int, c2 int, c3 int, v vector(3), primary key(c1));

