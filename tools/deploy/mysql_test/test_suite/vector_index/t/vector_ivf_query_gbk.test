--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : yangjiali.yjl
#owner group: obkv
#description: basic test ivf index select with gbk charset

connect (conn_user,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn_user;

alter system set ob_vector_memory_limit_percentage = 44;
sleep 1;

--disable_warnings
drop database if exists ivf_query_test;
--enable_warnings

create database ivf_query_test default charset gbk;
use ivf_query_test;

# post create index
