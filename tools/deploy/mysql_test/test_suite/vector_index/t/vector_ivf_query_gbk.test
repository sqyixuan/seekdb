--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;

select * from t_vec where c3 < 'ob' order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

select * from t_vec where c3 < 'ob' order by l2_distance(v, [0.712338,0.603321,0.133444]) limit 5;

explain select * from t_vec where c3 < 'ob' order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

select * from t_vec where c3 < 'ob' and c2 > 3 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

explain select * from t_vec where c3 < 'ob' and c2 > 3 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

select * from t_vec where c3 < 'ob' or c2 > 3 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

explain select * from t_vec where c3 < 'ob' or c2 > 3 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

connection conn_user;
drop table if exists t_vec;
drop database if exists ivf_query_test;
PURGE RECYCLEBIN;
