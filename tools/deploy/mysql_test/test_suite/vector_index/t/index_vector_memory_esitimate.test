# index_vector_memory_estimate
create table t1 (id int auto_increment, c1 vector(3));
insert into t1(c1) select array(1/UNIFORM(1,1000,RANDOM(1)), 1/UNIFORM(1,1000,RANDOM(2)) , 1/UNIFORM(1,1000,RANDOM(3))) from table(generator(10000));
analyze table t1;
select sum(table_rows), max(table_rows) from information_schema.PARTITIONS  WHERE  table_name = 't1';

# index_vector_memory_estimate
--error 1318
select dbms_vector.index_vector_memory_estimate();
--error 1318
select dbms_vector.index_vector_memory_estimate('t1');
--error 1318
select dbms_vector.index_vector_memory_estimate('t1','c1');
--error 1210
select dbms_vector.index_vector_memory_estimate('t1','c1','HNSW');
--error 1210
select dbms_vector.index_vector_memory_estimate('t1','c1','IVF');
--error 1210
select dbms_vector.index_vector_memory_estimate('t1','c1','SPIV');
--error 5031
select dbms_vector.index_vector_memory_estimate('t1','c2','HNSW','M=10,TYPE=HNSW,DISTANCE=L2');

# HNSW
select dbms_vector.index_vector_memory_estimate('t1','c1','HNSW','M=10,TYPE=HNSW,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW',10000,3,'FLOAT32','M=10,TYPE=HNSW,DISTANCE=L2');
select dbms_vector.index_vector_memory_estimate('t1','c1','HNSW_SQ','M=10,TYPE=HNSW_SQ,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_SQ',10000,3,'FLOAT32','M=10,TYPE=HNSW_SQ,DISTANCE=L2');
select dbms_vector.index_vector_memory_estimate('t1','c1','HNSW_BQ','M=10,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_BQ',10000,3,'FLOAT32','M=10,DISTANCE=L2');
select dbms_vector.index_vector_memory_estimate('t1','c1','HNSW','M=32,TYPE=HNSW,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW',10000,3,'FLOAT32','M=32,TYPE=HNSW,DISTANCE=L2');
select dbms_vector.index_vector_memory_estimate('t1','c1','HNSW_SQ','M=32,TYPE=HNSW_SQ,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_SQ',10000,3,'FLOAT32','M=32,TYPE=HNSW_SQ,DISTANCE=L2');
select dbms_vector.index_vector_memory_estimate('t1','c1','HNSW_BQ','M=32,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_BQ',10000,3,'FLOAT32','M=32,DISTANCE=L2');

# IVF
select dbms_vector.index_vector_memory_estimate('t1','c1','IVF_FLAT','TYPE=IVF_FLAT,SAMPLE_PER_NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('IVF_FLAT',10000,3,'FLOAT32','TYPE=IVF_FLAT,SAMPLE_PER_NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_estimate('t1','c1','IVF_SQ8','TYPE=IVF_SQ8,SAMPLE_PER_NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('IVF_SQ8',10000,3,'FLOAT32','TYPE=IVF_SQ8,SAMPLE_PER_NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_estimate('t1','c1','IVF_PQ','TYPE=IVF_PQ,SAMPLE_PER_NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('IVF_PQ',10000,3,'FLOAT32','TYPE=IVF_PQ,SAMPLE_PER_NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_estimate('t1','c1','IVF_FLAT','TYPE=IVF_FLAT,NLIST=100,SAMPLE_PER_NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('IVF_FLAT',10000,3,'FLOAT32','TYPE=IVF_FLAT,NLIST=100,SAMPLE_PER_NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_estimate('t1','c1','IVF_SQ8','TYPE=IVF_SQ8,NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('IVF_SQ8',10000,3,'FLOAT32','TYPE=IVF_SQ8,NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_estimate('t1','c1','IVF_PQ','TYPE=IVF_PQ,NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('IVF_PQ',10000,3,'FLOAT32','TYPE=IVF_PQ,NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_estimate('t1','c1','IVF_PQ','TYPE=IVF_PQ,NLIST=100,DISTANCE=L2,NBITS=12');
select dbms_vector.index_vector_memory_advisor('IVF_PQ',10000,3,'FLOAT32','TYPE=IVF_PQ,NLIST=100,DISTANCE=L2,NBITS=12');

create table t2 (id int auto_increment, c1 vector(3)) partition by hash(id) partitions 8;
insert into t2(c1) select array(1/UNIFORM(1,1000,RANDOM(1)), 1/UNIFORM(1,1000,RANDOM(2)) , 1/UNIFORM(1,1000,RANDOM(3))) from table(generator(10000));
analyze table t2;
select sum(table_rows), max(table_rows) from information_schema.PARTITIONS  WHERE  table_name = 't2';
select dbms_vector.index_vector_memory_estimate('t2','c1','HNSW','M=10,TYPE=HNSW,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW',10000,3,'FLOAT32','M=10,TYPE=HNSW,DISTANCE=L2',1250);
select dbms_vector.index_vector_memory_estimate('t2','c1','HNSW_SQ','M=10,TYPE=HNSW_SQ,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_SQ',10000,3,'FLOAT32','M=10,TYPE=HNSW_SQ,DISTANCE=L2',1250);
select dbms_vector.index_vector_memory_estimate('t2','c1','HNSW_BQ','M=10,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_BQ',10000,3,'FLOAT32','M=10,DISTANCE=L2',1250);
select dbms_vector.index_vector_memory_estimate('t2','c1','HNSW','M=32,TYPE=HNSW,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW',10000,3,'FLOAT32','M=32,TYPE=HNSW,DISTANCE=L2',1250);
select dbms_vector.index_vector_memory_estimate('t2','c1','HNSW_SQ','M=32,TYPE=HNSW_SQ,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_SQ',10000,3,'FLOAT32','M=32,TYPE=HNSW_SQ,DISTANCE=L2',1250);
select dbms_vector.index_vector_memory_estimate('t2','c1','HNSW_BQ','M=32,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_BQ',10000,3,'FLOAT32','M=32,DISTANCE=L2',1250);
select dbms_vector.index_vector_memory_estimate('t2','c1','IVF_FLAT','NLIST=100,SAMPLE_PER_NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('IVF_FLAT',10000,3,'FLOAT32','NLIST=100,SAMPLE_PER_NLIST=100,DISTANCE=L2',1250);
select dbms_vector.index_vector_memory_estimate('t2','c1','IVF_SQ8','NLIST=100,SAMPLE_PER_NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('IVF_SQ8',10000,3,'FLOAT32','NLIST=100,SAMPLE_PER_NLIST=100,DISTANCE=L2',1250);
select dbms_vector.index_vector_memory_estimate('t2','c1','IVF_PQ','NLIST=100,SAMPLE_PER_NLIST=100,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('IVF_PQ',10000,3,'FLOAT32','NLIST=100,SAMPLE_PER_NLIST=100,DISTANCE=L2',1250);
select dbms_vector.index_vector_memory_estimate('t2','c1','IVF_PQ','NLIST=100,SAMPLE_PER_NLIST=100,DISTANCE=L2,NBITS=12');
select dbms_vector.index_vector_memory_advisor('IVF_PQ',10000,3,'FLOAT32','NLIST=100,SAMPLE_PER_NLIST=100,DISTANCE=L2,NBITS=12',1250);

