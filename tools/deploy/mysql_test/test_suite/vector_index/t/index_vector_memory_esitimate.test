# SINDI
create table t3 (id int auto_increment, c1 sparsevector);
insert into t3(c1) select '{}' from table(generator(1000));
analyze table t3;
select dbms_vector.index_vector_memory_advisor('SINDI',1000,3,'FLOAT32','TYPE=SINDI,LIB=VSAG,DISTANCE=INNER_PRODUCT');
select dbms_vector.index_vector_memory_estimate('t3','c1','SINDI','TYPE=SINDI,LIB=VSAG,DISTANCE=INNER_PRODUCT');
select dbms_vector.index_vector_memory_advisor('SINDI',1000,3,'FLOAT32','TYPE=SINDI,LIB=VSAG,DISTANCE=INNER_PRODUCT,REFINE=TRUE');
select dbms_vector.index_vector_memory_estimate('t3','c1','SINDI','TYPE=SINDI,LIB=VSAG,DISTANCE=INNER_PRODUCT,REFINE=TRUE');
drop table t3;

# cleanup
drop table t1,t2;
