#description: test for dbms_vector.index_vector_memory_estimate and dbms_vector.index_vector_memory_advisor

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

#index_vector_memory_advisor
--error 1318
select dbms_vector.index_vector_memory_advisor('HNSW');
--error 1318
select dbms_vector.index_vector_memory_advisor('HNSW',10000);
--error 1210
select dbms_vector.index_vector_memory_advisor('IVF_FLAT',10000,10);
--error 1210
select dbms_vector.index_vector_memory_advisor('HNSW',10000,10,'FLOAT32');
--error 1210
select dbms_vector.index_vector_memory_advisor('HNSW',10000,10,'FLOAT32','');
--error 1235
select dbms_vector.index_vector_memory_advisor('HNSW',1000000,10,'FLOAT32','M=10,TYPE=HNSW');

# HNSW
select dbms_vector.index_vector_memory_advisor('HNSW',1000000,10,'FLOAT32','M=10,TYPE=HNSW,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('hnsw',1000000,10,'float32','M=10,TYPE=HNSW,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW',1000000,10,'FLOAT32','M=10,TYPE=HNSW_SQ,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_SQ',1000000,10,'FLOAT32','M=10,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_BQ',1000000,10,'FLOAT32','M=10,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_SQ',1000000,10,'FLOAT32','M=10,TYPE=HNSW_SQ,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_SQ',1000000,10,'FLOAT32','M=10,TYPE=HNSW_SQ,DISTANCE=INNER_PRODUCT');
select dbms_vector.index_vector_memory_advisor('HNSW_SQ',1000000,10,'FLOAT32','M=10,TYPE=HNSW_SQ,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_SQ',1000000,10,'FLOAT32','M=10,TYPE=HNSW_SQ,DISTANCE=COSINE');
--error 1235
select dbms_vector.index_vector_memory_advisor('HNSW_BQ',1000000,10,'FLOAT32','M=10,TYPE=HNSW_BQ,DISTANCE=COSINE');
--error 1235
select dbms_vector.index_vector_memory_advisor('HNSW_SQ',1000000,10,'FLOAT32','M=2,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_SQ',1000000,10,'FLOAT32','M=20,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW',1000000,768,'FLOAT32','M=30,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_SQ',1000000,768,'FLOAT32','M=30,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_BQ',1000000,768,'FLOAT32','M=30,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW',1000000,768,'FLOAT32','M=30,DISTANCE=L2,EXTRA_INFO_ACTUAL_SIZE=1000');
select dbms_vector.index_vector_memory_advisor('HNSW_SQ',1000000,768,'FLOAT32','M=30,DISTANCE=L2,EXTRA_INFO_ACTUAL_SIZE=1000');
select dbms_vector.index_vector_memory_advisor('HNSW_BQ',1000000,768,'FLOAT32','M=30,DISTANCE=L2,EXTRA_INFO_ACTUAL_SIZE=1000');
select dbms_vector.index_vector_memory_advisor('HNSW_BQ',1000000,768,'FLOAT32','M=16,DISTANCE=L2');
select dbms_vector.index_vector_memory_advisor('HNSW_BQ',1000000,768,'FLOAT32','M=16,DISTANCE=L2,REFINE_TYPE=SQ8,BQ_USE_FHT=TRUE,BQ_BITS_QUERY=4') as result;
select dbms_vector.index_vector_memory_advisor('HNSW_BQ',1000000,768,'FLOAT32','M=16,DISTANCE=L2,REFINE_TYPE=SQ8,BQ_USE_FHT=TRUE,BQ_BITS_QUERY=32') as result;
select dbms_vector.index_vector_memory_advisor('HNSW_BQ',1000000,768,'FLOAT32','M=16,DISTANCE=L2,REFINE_TYPE=FP32,BQ_USE_FHT=FALSE,BQ_BITS_QUERY=32') as result;

