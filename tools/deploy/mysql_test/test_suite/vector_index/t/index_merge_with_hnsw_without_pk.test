#owner: wuxingying.wxy
#owner group: shenzhen
--echo # Vector Index with index merge without pk Test

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_name = "EN_FORCE_INDEX_MERGE_PLAN", error_code = 1, frequency = 1;
connection default;
alter system set ob_vector_memory_limit_percentage = 44;
sleep 3;

--disable_warnings
drop table if exists t1 cascade;
--enable_warnings
create table t1(c1 int, c2 int, c3 int, v vector(3), vector index idx3(v) with (distance=l2, type=hnsw, lib=vsag));

insert into t1 values(1, 1, 10, '[0.203846,0.205289,0.880265]');
insert into t1 values(2, 2, 9, '[0.226980,0.579658,0.933939]');
insert into t1 values(3, 3, 8, '[0.181664,0.013905,0.628127]');
insert into t1 values(4, 4, 7, '[0.442633,0.637534,0.633993]');
insert into t1 values(5, 5, 6, '[0.190118,0.959676,0.796483]');
insert into t1 values(6, 6, 5, '[0.710370,0.007130,0.710913]');
insert into t1 values(7, 7, 4, '[0.238120,0.289662,0.970101]');
insert into t1 values(8, 8, 3, '[0.168794,0.567442,0.062338]');
insert into t1 values(9, 9, 2, '[0.901419,0.676738,0.122339]');
insert into t1 values(10, 10, 1, '[0.563644,0.811224,0.175574]');

create index idx1 on t1(c2);
create index idx2 on t1(c3);

explain select * from t1 where c2 > 5 or c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROX limit 5;

select * from t1 where c2 > 5 or c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROX limit 5;

select * from t1 where c2 > 5 or c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) limit 5;

explain select * from t1 where c2 > 5 and c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROX limit 5;

select * from t1 where c2 > 5 and c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROX limit 5;

select * from t1 where c2 > 5 and c3 < 6 order by l2_distance(v, [0.712338,0.603321,0.133444]) limit 5;

--disable_warnings
drop table if exists t1 cascade;
--enable_warnings

--disable_warnings
drop table if exists t11 cascade;
--enable_warnings

create table t11(c1 int, v vector(3), c2 varchar(100), c3 varchar(4096), c4 int, c5 int, fulltext index i3(c3), index i4(c4),
vector index idxv(v) with(distance=l2, type=hnsw, lib=vsag));
insert into t11 (c1, v, c2, c3, c4, c5) values
    (1, '[0.203846,0.205289,0.880265]', "Gerard Salton", "Gerard A. Gerry Salton (8 March 1927 – 28 August 1995) was a professor of Computer Science at Cornell University. Salton was perhaps the leading computer scientist working in the field of information retrieval during his time, and the father of Information Retrieval", 1, 1),
    (2, '[0.226980,0.579658,0.933939]', "Edgar F. Codd", "Edgar Frank Ted Codd (19 August 1923 – 18 April 2003) was an English computer scientist who, while working for IBM, invented the relational model for database management, the theoretical basis for relational databases and relational database management systems. ", 2, 2),
    (3, '[0.181664,0.013905,0.628127]', "Leslie Lamport", "Leslie B. Lamport (born February 7, 1941) is an American computer scientist and mathematician. Lamport is best known for his seminal work in distributed systems, and as the initial developer of the document preparation system LaTeX", 3, 3),
    (4, '[0.442633,0.637534,0.633993]', "Geoffrey Hinton", "Geoffrey Everest Hinton CC FRS FRSC (born 6 December 1947) is a British-Canadian computer scientist and cognitive psychologist, most noted for his work on artificial neural networks.", 4, 4),
    (5, '[0.710370,0.007130,0.710913]', "Yann LeCun", "Yann André LeCun[1] (born 8 July 1960) is a Turing Award winning French computer scientist working primarily in the fields of machine learning, computer vision, mobile robotics and computational neuroscience.", 5, 5),
    (6, '[0.190118,0.959676,0.796483]', "Ken Thompson", "Kenneth Lane Thompson (born February 4, 1943) is an American pioneer of computer science. Thompson worked at Bell Labs for most of his career where he designed and implemented the original Unix operating system. ", 6, 6),
    (7, '[0.238120,0.289662,0.970101]', "Gordon Plotkin", "Gordon David Plotkin, FRS FRSE MAE (born 9 September 1946) is a theoretical computer scientist in the School of Informatics at the University of Edinburgh. Plotkin is probably best known for his introduction of structural operational semantics (SOS) and his work on denotational semantics.", 7, 7),
    (8, '[0.168794,0.567442,0.062338]', "Michael Stonebraker", "Michael Ralph Stonebraker (born October 11, 1943[6]) is a computer scientist specializing in database systems. Through a series of academic prototypes and commercial startups, Stonebraker's research and products are central to many relational databases. ", 8, 8);

# fulltext index merge with normal index 
explain select c1 from t11 where match(c3) against ("distributed database") and c4 = 8 order by l2_distance(v, [0.712338,0.603321,0.133444]) approx limit  5;

select c1 from t11 where match(c3) against ("distributed database") and c4 = 8 order by l2_distance(v, [0.712338,0.603321,0.133444]) approx limit  5;

select c1 from t11 where match(c3) against ("distributed database") and c4 = 8 order by l2_distance(v, [0.712338,0.603321,0.133444]) limit  5;

explain select c1 from t11 where match(c3) against ("distributed database") or c4 = 7 order by l2_distance(v, [0.712338,0.603321,0.133444]) approx limit  5;

select c1 from t11 where match(c3) against ("distributed database") or c4 = 7 order by l2_distance(v, [0.712338,0.603321,0.133444]) approx limit  5;

select c1 from t11 where match(c3) against ("distributed database") or c4 = 7 order by l2_distance(v, [0.712338,0.603321,0.133444]) limit  5;

select c2 from t11 where match(c3) against ("distributed database") and c4 = 7 order by l2_distance(v, [0.712338,0.603321,0.133444]) approx limit 5;

select c2 from t11 where match(c3) against ("distributed database") and c4 = 7 order by l2_distance(v, [0.712338,0.603321,0.133444]) limit  5;
# relevance error
select c1, match(c3) against ("distributed database") from t11 where match(c3) against ("distributed database") or c4 = 7 order by l2_distance(v, [0.712338,0.603321,0.133444]) approx limit  5;

select c1, match(c3) against ("distributed database") from t11 where match(c3) against ("distributed database") or c4 = 7 order by l2_distance(v, [0.712338,0.603321,0.133444]) limit  5;

--disable_warnings
drop table if exists t1 cascade;
--enable_warnings

connection conn_admin;
alter system set_tp tp_name = "EN_FORCE_INDEX_MERGE_PLAN", error_code = 1, frequency = 0;
connection default;