#owner: ningxin.ning
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of sparse vector index
--echo # ----------------------------------------------------------------------
# connect (conn1,$OBMYSQL_MS0,root@mysql,,test,$OBMYSQL_PORT);
# connection conn1;

--disable_warnings
drop database if exists sparse_dml;
--enable_warnings
create database sparse_dml;
use sparse_dml;

let $database_id = query_get_value(SELECT database_id FROM oceanbase.__all_database WHERE database_name = 'sparse_dml', database_id, 1);

alter system set ob_vector_memory_limit_percentage =44;

set ob_enable_index_direct_select = 1;

#设置语句级的超时时间为100s
set ob_query_timeout=100000000;

--echo ============= basic test ==============
# 取消后台优化任务，保证增量数据不会刷新到快照数据中
# alter system set vector_index_optimize_duty_time='[24:00:00, 24:00:00]';
CREATE TABLE t1 (
  c1 int primary key,
  c2 sparsevector
);

insert into t1 values(1, '{1:0.1,2:0.2, 3:0.3}');
insert into t1 values(2, '{3:0.3, 2:0.2, 4:0.4}');
insert into t1 values(3, '{3:0.3, 4:0.4, 5:0.5}');
insert into t1 values(4, '{5:0.5, 4:0.4, 6:0.6}');
insert into t1 values(5, '{5:0.5, 6:0.6, 7:0.7}');
insert into t1 values(6, '{7:0.7, 6:0.6, 8:0.8}');
insert into t1 values(7, '{7:0.7, 8:0.8, 9:0.9}');
insert into t1 values(8, '{9:0.9, 8:0.8, 10:1.0}');
insert into t1 values(9, '{9:0.9, 10:1.0, 11:1.1}');

create vector index idx1 on t1(c2) with (lib=vsag, type=sindi, distance=inner_product);

insert into t1 values(10, '{11:1.1, 10:1.0, 12:1.2}');

let $data_table_id = query_get_value(SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 't1' AND database_id = $database_id, table_id, 1);
let $inc_table_name = query_get_value(SELECT table_name FROM oceanbase.__all_virtual_table WHERE index_type = 27 AND data_table_id = $data_table_id, table_name, 1);

--disable_query_log
eval select count(*) from $inc_table_name;
insert into t1 values(11, '{11:1.1, 10:1.0, 12:1.2}');
insert into t1 values(12, '{}');
--echo insert into t1 values(11, '{11:1.1, 10:1.0, 12:1.2}');
--echo insert into t1 values(12, '{}');
eval select count(*) from $inc_table_name;
delete from t1 where c1=1;
--echo delete from t1 where c1=1;
eval select count(*) from $inc_table_name;
delete from t1 where c1<=5;
--echo delete from t1 where c1<=5;
eval select count(*) from $inc_table_name;
update t1 set c2='{6:0.6}' where c1=6;
--echo update t1 set c2='{6:0.6}' where c1=6;
eval select count(*) from $inc_table_name;
update t1 set c2='{}' where c1=7;
replace into t1(c1, c2) values(8, '{8:0.8}');
replace into t1(c1, c2) values(13, '{13:1.3}');
--echo update t1 set c2='{}' where c1=7;
--echo replace into t1(c1, c2) values(8, '{8:0.8}');
--echo replace into t1(c1, c2) values(13, '{13:1.3}');
eval select count(*) from $inc_table_name;
--enable_query_log
select * from t1;
select * from t1 order by negative_inner_product(c2, '{5:1, 6:1}') approx limit 2;

--disable_warnings
drop table if exists t1;
--enable_warnings

# 多个索引
CREATE TABLE t1 (c1 int primary key, c2 sparsevector, c3 sparsevector, c4 sparsevector, 
vector index inx1(c2) with (lib=vsag, type=sindi, distance=inner_product));

insert into t1 values(1, '{1:0.1,2:0.2, 3:0.3}', '{1:0.1,2:0.2, 3:0.3}', '{1:0.1,2:0.2, 3:0.3}');
insert into t1 values(2, '{3:0.3, 2:0.2, 4:0.4}', '{3:0.3, 2:0.2, 4:0.4}', '{3:0.3, 2:0.2, 4:0.4}');
insert into t1 values(3, '{3:0.3, 4:0.4, 5:0.5}', '{3:0.3, 4:0.4, 5:0.5}', '{3:0.3, 4:0.4, 5:0.5}');
insert into t1 values(4, '{5:0.5, 4:0.4, 6:0.6}', '{5:0.5, 4:0.4, 6:0.6}', '{5:0.5, 4:0.4, 6:0.6}');
insert into t1 values(5, '{5:0.5, 6:0.6, 7:0.7}', '{5:0.5, 6:0.6, 7:0.7}', '{5:0.5, 6:0.6, 7:0.7}');
insert into t1 values(6, '{7:0.7, 6:0.6, 8:0.8}', '{7:0.7, 6:0.6, 8:0.8}', '{7:0.7, 6:0.6, 8:0.8}');

let $data_table_id = query_get_value(SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 't1' AND database_id = $database_id, table_id, 1);
let $inc_table_name = query_get_value(SELECT table_name FROM oceanbase.__all_virtual_table WHERE index_type = 27 AND data_table_id = $data_table_id, table_name, 1);
--disable_query_log
eval select count(*) from $inc_table_name;
insert into t1 values(11, '{11:1.1, 10:1.0, 12:1.2}', '{}', '{11:1.1}');
insert into t1 values(12, '{}', '{}', '{}');
eval select count(*) from $inc_table_name;
delete from t1 where c1=1;
eval select count(*) from $inc_table_name;
delete from t1 where c1<=4;
eval select count(*) from $inc_table_name;
update t1 set c2='{5:0.5}' where c1=5;
eval select count(*) from $inc_table_name;
update t1 set c2='{}' where c1=6;
replace into t1(c1, c2) values(11, '{8:0.8}');
replace into t1(c1, c2) values(13, '{13:1.3}');
eval select count(*) from $inc_table_name;
--enable_query_log
select * from t1;
select * from t1 order by negative_inner_product(c2, '{5:1, 6:1}') approx limit 2;

--disable_warnings
drop table if exists t1;
--enable_warnings

--echo ============= 分区表 ==============
CREATE TABLE t1 (
  c1 int primary key,
  c2 sparsevector,
  vector index idx1(c2) with (lib=vsag, type=sindi, distance=inner_product)
) partition by hash(c1) partitions 3;
insert into t1 values(1, '{1:0.1,2:0.2, 3:0.3}');
insert into t1 values(2, '{3:0.3, 2:0.2, 4:0.4}');
insert into t1 values(3, '{3:0.3, 4:0.4, 5:0.5}');
insert into t1 values(4, '{5:0.5, 4:0.4, 6:0.6}');
insert into t1 values(5, '{5:0.5, 6:0.6, 7:0.7}');
insert into t1 values(6, '{7:0.7, 6:0.6, 8:0.8}');
insert into t1 values(7, '{7:0.7, 8:0.8, 9:0.9}');
insert into t1 values(8, '{9:0.9, 8:0.8, 10:1.0}');
insert into t1 values(9, '{9:0.9, 10:1.0, 11:1.1}');
insert into t1 values(10, '{11:1.1, 10:1.0, 12:1.2}');

let $data_table_id = query_get_value(SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 't1' AND database_id = $database_id, table_id, 1);
let $inc_table_name = query_get_value(SELECT table_name FROM oceanbase.__all_virtual_table WHERE index_type = 27 AND data_table_id = $data_table_id, table_name, 1);
--disable_query_log
eval select count(*) from $inc_table_name;
insert into t1 values(11, '{11:1.1, 10:1.0, 12:1.2}');
insert into t1 values(12, '{}');
eval select count(*) from $inc_table_name;
delete from t1 where c1=1;
eval select count(*) from $inc_table_name;
delete from t1 where c1<=5;
eval select count(*) from $inc_table_name;
update t1 set c2='{6:0.6}' where c1=6;
eval select count(*) from $inc_table_name;
update t1 set c2='{}' where c1=7;
replace into t1(c1, c2) values(8, '{8:0.8}');
replace into t1(c1, c2) values(13, '{13:1.3}');
eval select count(*) from $inc_table_name;
--enable_query_log
select * from t1;
select * from t1 order by negative_inner_product(c2, '{5:1, 6:1}') approx limit 2;

--disable_warnings
drop table if exists t1;
--enable_warnings

--echo ============= 事务 ==============

CREATE TABLE t1 (c1 int primary key, c2 sparsevector);

insert into t1 values(1, '{1:0.1,2:0.2, 3:0.3}');
insert into t1 values(2, '{3:0.3, 2:0.2, 4:0.4}');
insert into t1 values(3, '{3:0.3, 4:0.4, 5:0.5}');
insert into t1 values(4, '{5:0.5, 4:0.4, 6:0.6}');

create vector index idx1 on t1(c2) with (lib=vsag, type=sindi, distance=inner_product);

insert into t1 values(10, '{11:1.1, 10:1.0, 12:1.2}');

let $data_table_id = query_get_value(SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 't1' AND database_id = $database_id, table_id, 1);
let $inc_table_name = query_get_value(SELECT table_name FROM oceanbase.__all_virtual_table WHERE index_type = 27 AND data_table_id = $data_table_id, table_name, 1);

start transaction;
--disable_query_log
eval select count(*) from $inc_table_name;
insert into t1 values(11, '{11:1.1, 10:1.0, 12:1.2}');
insert into t1 values(12, '{}');
--echo insert into t1 values(11, '{11:1.1, 10:1.0, 12:1.2}');
--echo insert into t1 values(12, '{}');
eval select count(*) from $inc_table_name;
delete from t1 where c1=1;
--echo delete from t1 where c1=1;
eval select count(*) from $inc_table_name;
delete from t1 where c1<=5;
--echo delete from t1 where c1<=5;
eval select count(*) from $inc_table_name;
update t1 set c2='{6:0.6}' where c1=6;
--echo update t1 set c2='{6:0.6}' where c1=6;
eval select count(*) from $inc_table_name;
update t1 set c2='{}' where c1=7;
replace into t1(c1, c2) values(8, '{8:0.8}');
replace into t1(c1, c2) values(13, '{13:1.3}');
--echo update t1 set c2='{}' where c1=7;
--echo replace into t1(c1, c2) values(8, '{8:0.8}');
--echo replace into t1(c1, c2) values(13, '{13:1.3}');
eval select count(*) from $inc_table_name;
--enable_query_log
commit;
select * from t1;
select * from t1 order by negative_inner_product(c2, '{5:1, 6:1}') approx limit 2;

--echo ============= 存储过程 ==============
DELIMITER //;
create procedure process(IN id1 INT, IN id2 INT)
begin
    delete from t1 where c1=id1;
    update t1 set c2='{}' where c1=id2;
end;
//
DELIMITER ;//

CALL process(8, 13);
drop procedure process;

select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
alter system set vector_index_optimize_duty_time='[24:00:00, 24:00:00]';
# 无主键
create table test_sparse_vec_tbl (
  id int, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(5), c13 vector(5), c14 vector(5), c15 map(int, int), c16 sparsevector, vector index idx1(c16) with (distance=inner_product, type=sindi, lib=vsag));
--source sparse_vector_index_vsag_dml.inc

# 带主键
create table test_sparse_vec_tbl (
  id int primary key, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(5), c13 vector(5), c14 vector(5), c15 map(int, int), c16 sparsevector, vector index idx1(c16) with (distance=inner_product, type=sindi, lib=vsag));
--source sparse_vector_index_vsag_dml.inc

# hnsw + sindi
create table test_sparse_vec_tbl (
  id int primary key, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(5), c13 vector(5), c14 vector(5), c15 map(int, int), c16 sparsevector, 
  vector index idx1(c16) with (distance=inner_product, type=sindi, lib=vsag),
  vector index idx_c12(c12) with (distance=l2, type=hnsw));
create vector index idx_c13 on test_sparse_vec_tbl(c13) with (distance=l2, type=hnsw);
create vector index idx_c14 on test_sparse_vec_tbl(c14) with (distance=l2, type=hnsw);
--source sparse_vector_index_vsag_dml.inc

# ivf + sindi
create table test_sparse_vec_tbl (
  id int primary key, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(5), c13 vector(5), c14 vector(5), c15 map(int, int), c16 sparsevector, 
  vector index idx1(c16) with (distance=inner_product, type=sindi, lib=vsag),
  vector index idx_c12(c12) with (distance=l2, type=ivf_pq, nlist=2, sample_per_nlist=3, m=5));
create vector index idx_c13 on test_sparse_vec_tbl(c13) with (distance=l2, type=ivf_sq8, nlist=2, sample_per_nlist=3);
create vector index idx_c14 on test_sparse_vec_tbl(c14) with (distance=l2, type=ivf_flat, nlist=2, sample_per_nlist=3);
--source sparse_vector_index_vsag_dml.inc

# hash分区
create table test_sparse_vec_tbl (
  id int primary key, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(5), c13 vector(5), c14 vector(5), c15 map(int, int), c16 sparsevector, 
  vector index idx1(c16) with (distance=inner_product, type=sindi, lib=vsag)) partition by hash(id) partitions 3;
--source sparse_vector_index_vsag_dml.inc

# 复制表
create table test_sparse_vec_tbl (
  id int primary key, c1 bool, c2 int, c3 decimal, c4 float, c5 bit, 
  c6 date, c7 varchar(10), c8 text, c9 json, c10 GEOMETRY,
  c11 array(int), c12 vector(5), c13 vector(5), c14 vector(5), c15 map(int, int), c16 sparsevector,
  vector index idx1(c16) with (distance=inner_product, type=sindi, lib=vsag)) duplicate_scope='cluster';
--source sparse_vector_index_vsag_dml.inc
