#owner: gehao.wh
#owner group: shenzhen
#description: test vector_index_memdata_sync

--disable_warnings
drop table if exists t1_vec_snapshot_sync;
drop table if exists t2_vec_snapshot_sync;
drop table if exists t3_vec_snapshot_sync;
#PURGE RECYCLEBIN;
--enable_warnings

alter system set ob_vector_memory_limit_percentage = 20;
sleep 3;

--echo create table
create table t1_vec_snapshot_sync(c1 int, c2 vector(10), primary key(c1));
create table t2_vec_snapshot_sync(c1 int, v1 varchar(2), c2 vector(10), primary key(c1, v1));

--echo insert data for new t1_vec_snapshot_sync
insert into t1_vec_snapshot_sync values(1, '[0.692623,0.816816,0.418483,0.393929,0.061058,0.402308,0.564665,0.406696,0.628286,0.250843]');
--disable_query_log
--let $loop=2
while($loop < 120)
{
  eval insert into t1_vec_snapshot_sync values($loop, '[0.327936,0.048756,0.084670,0.389642,0.970982,0.370915,0.181664,0.940780,0.013905,0.628127]');
  inc $loop;
}
--enable_query_log

create vector index idx1 on t1_vec_snapshot_sync(c2) WITH (distance=L2, lib=vsag, type=hnsw, m=10, ef_construction = 12, ef_search = 40);


--echo insert data for t2_vec_snapshot_sync to trigger anther sync_info
--disable_query_log
--let $loop= 1
while($loop < 120)
{
  eval insert into t2_vec_snapshot_sync values($loop, 'c', '[0.427936,0.048756,0.084670,0.389642,0.970982,0.370915,0.181664,0.940780,0.013905,0.628127]');
  inc $loop;
}
--enable_query_log
create vector index idx2 on t2_vec_snapshot_sync(c2) with (distance=l2, type=hnsw, lib=vsag);

# wait for sync
--sleep 25
#select * from oceanbase.__all_virtual_vector_index_info order by sync_info;
--echo #check lower sync limit

select
sum(JSON_VALUE(sync_info, '$.incr_cnt')) = 0 as check_incr_cnt,
sum(JSON_VALUE(sync_info, '$.vbitmap_cnt')) = 0 as check_vbitmap_cnt,
sum(JSON_VALUE(sync_info, '$.snap_cnt')) >= 238 as check_snap_cnt,
sum(JSON_VALUE(sync_info, '$.sync_total_cnt')) >= 0 as check_sync_total_cnt,
sum(JSON_VALUE(sync_info, '$.sync_fail_cnt')) <= 1 as check_sync_fail_cnt
from oceanbase.__all_virtual_vector_index_info a, oceanbase.__all_virtual_table b 
where a.data_table_id = b.table_id and b.table_name in ('t1_vec_snapshot_sync', 't2_vec_snapshot_sync');


--echo check upper sync limit
select
sum(JSON_VALUE(sync_info, '$.incr_cnt')) = 0 as check_incr_cnt,
sum(JSON_VALUE(sync_info, '$.vbitmap_cnt')) = 0 as check_vbitmap_cnt,
sum(JSON_VALUE(sync_info, '$.snap_cnt')) <= 476 as check_snap_cnt,
sum(JSON_VALUE(sync_info, '$.sync_total_cnt')) <= 4 as check_sync_total_cnt,
sum(JSON_VALUE(sync_info, '$.sync_fail_cnt')) <= 1 as check_sync_fail_cnt
from oceanbase.__all_virtual_vector_index_info a, oceanbase.__all_virtual_table b 
where a.data_table_id = b.table_id and b.table_name in ('t1_vec_snapshot_sync', 't2_vec_snapshot_sync');


# more test after rebuild index ready
drop table t1_vec_snapshot_sync;
drop table t2_vec_snapshot_sync;

--sleep 15
select count(*)
from oceanbase.__all_virtual_vector_index_info a, oceanbase.__all_virtual_table b 
where a.data_table_id = b.table_id and b.table_name in ('t1_vec_snapshot_sync', 't2_vec_snapshot_sync');

alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;
