#owner: cxf262476
#owner group: transaction
#description: mysql lock table priv

--disable_warnings
connect (sys,$OBMYSQL_MS0,root,"",oceanbase,$OBMYSQL_PORT);
connection sys;
--disable_abort_on_error
--disable_query_log
--disable_result_log
alter proxyconfig set client_session_id_version=2;
alter proxyconfig set enable_single_leader_node_routing=false;
--enable_abort_on_error
--enable_query_log
--enable_result_log
sleep 3;

connection default;
drop user if exists lock_priv;
drop table if exists t;
drop table if exists tt;
--error 0, 1008
drop database test2;
--enable_warnings

create user lock_priv;

# 0. check views
--source mysql_test/test_suite/table_lock/t/check_priv.inc

# 0.1 grant all
grant all on *.* to lock_priv;
--source mysql_test/test_suite/table_lock/t/check_priv.inc

REVOKE lock tables ON *.* FROM 'lock_priv';
--source mysql_test/test_suite/table_lock/t/check_priv.inc

REVOKE all ON *.* FROM 'lock_priv';
--source mysql_test/test_suite/table_lock/t/check_priv.inc

# 0.2 grant lock table
GRANT lock tables ON *.* TO 'lock_priv';
--source mysql_test/test_suite/table_lock/t/check_priv.inc

REVOKE lock tables ON *.* FROM 'lock_priv';
--source mysql_test/test_suite/table_lock/t/check_priv.inc

REVOKE all ON *.* FROM 'lock_priv';
--source mysql_test/test_suite/table_lock/t/check_priv.inc

# 0.3 grant database level
GRANT lock tables ON test.* TO 'lock_priv';
select user, db, lock_tables_priv from mysql.db where user = 'lock_priv' and db = 'test';
--source mysql_test/test_suite/table_lock/t/check_priv.inc

REVOKE lock tables ON *.* FROM 'lock_priv';
select user, db, lock_tables_priv from mysql.db where user = 'lock_priv' and db = 'test';
--source mysql_test/test_suite/table_lock/t/check_priv.inc

REVOKE all ON *.* FROM 'lock_priv';
select user, db, lock_tables_priv from mysql.db where user = 'lock_priv' and db = 'test';

REVOKE lock tables ON test.* FROM 'lock_priv';
--source mysql_test/test_suite/table_lock/t/check_priv.inc

# ----------- test for lock priv -------------
grant create on *.* to lock_priv;
show grants for lock_priv;

ALTER SYSTEM SET enable_lock_priority=true;
sleep 3;

connect(conn_before_grant, $OBMYSQL_MS0, lock_priv, '', test, $OBMYSQL_PORT);
connection conn_before_grant;

# 1. before grant, lock failed.
create table t(k int);
--error 1044
lock table t write;
--error 1044
lock table t read;

# 2. after grant lock table but not select, lock failed.
connection default;
grant lock tables on *.* to lock_priv;
show grants for lock_priv;

connect(conn_after_grant_lock_table, $OBMYSQL_MS0, lock_priv, '', test, $OBMYSQL_PORT);
connection conn_after_grant_lock_table;
--error 1142
lock table t write;
unlock tables;

--error 1142
lock table t read;
unlock tables;

# 3. after grant both lock table and select, lock success.
connection default;
grant select on *.* to lock_priv;
show grants for lock_priv;

connect(conn_after_grant_lock_table_select, $OBMYSQL_MS0, lock_priv, '', test, $OBMYSQL_PORT);
connection conn_after_grant_lock_table_select;
lock table t write;
unlock tables;

lock table t read;
unlock tables;

# 4. after revoke, only select, lock failed
connection default;
revoke lock tables on *.* from lock_priv;
show grants for lock_priv;

connect(conn_after_revoke, $OBMYSQL_MS0, lock_priv, '', test, $OBMYSQL_PORT);
connection conn_after_revoke;
--error 1044
lock table t write;
--error 1044
lock table t read;

# 5. only grant one db
connection default;
grant lock tables on test.* to lock_priv;
show grants for lock_priv;

connect(conn_after_grant_one_db, $OBMYSQL_MS0, lock_priv, '', test, $OBMYSQL_PORT);
connection conn_after_grant_one_db;
lock table t write;
unlock tables;

lock table t read;
unlock tables;

# 5. lock table with database
create database test2;
use test2;
create table tt(k int);
lock table test.t write;
unlock table;

--error 1044
lock table test.t write, test2.tt read;
unlock table;

connection default;
revoke lock tables on test.* from lock_priv;
show grants for lock_priv;

# 6. clean
connection default;
drop table if exists t;
drop table if exists tt;
drop database test2;
drop user lock_priv;

ALTER SYSTEM SET enable_lock_priority=false;

connection sys;
--disable_abort_on_error
--disable_query_log
--disable_result_log
alter proxyconfig set client_session_id_version=1;
alter proxyconfig set enable_single_leader_node_routing=true;
--enable_abort_on_error
--enable_query_log
--enable_result_log

sleep 3;
