#owner: gjw228474
#owner group: trans
#tags: table lock, priority queue
#description: test rename for table lock priority queue
#issue: 2024082000104184578

--result_format 4
--disable_query_log
connect (conn_sys,$OBMYSQL_MS0,root,"",oceanbase,$OBMYSQL_PORT);
connection conn_sys;
--disable_abort_on_error
--disable_result_log
alter proxyconfig set client_session_id_version=2;
alter proxyconfig set enable_single_leader_node_routing=false;
--enable_abort_on_error
--enable_result_log
sleep 3;

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,TEST,$OBMYSQL_PORT);
connection conn1;
set ob_query_timeout = 30000000;

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,TEST,$OBMYSQL_PORT);
connection conn2;
set ob_query_timeout = 30000000;

connection conn1;
--error 0,1051
drop table tlp_t1;
create table tlp_t1 (c1 int, c2 int);
--error 0,1051
drop table tlp_t2;
create table tlp_t2 (c1 int, c2 int);
alter system set enable_lock_priority=true;
sleep 3;  # need time to take effect
--enable_query_log

## case 1
## conn1
connection conn1;
rename table tlp_t1 to tlp_t3, tlp_t2 to tlp_t1, tlp_t3 to tlp_t2;
lock table tlp_t2 write;
unlock tables;

## case2
alter table tlp_t1 rename to tlp_t3;
alter table tlp_t2 rename to tlp_t1;
alter table tlp_t3 rename to tlp_t2;
lock table tlp_t2 write;
unlock tables;

## reset
--disable_query_log
connection conn1;
alter system set enable_lock_priority=false;
--error 0,1051
drop table tlp_t1;
--error 0,1051
drop table tlp_t2;
--enable_query_log

connection conn_sys;
--disable_abort_on_error
--disable_query_log
--disable_result_log
alter proxyconfig set client_session_id_version=1;
alter proxyconfig set enable_single_leader_node_routing=true;
--enable_abort_on_error
--enable_query_log
--enable_result_log
sleep 3;
