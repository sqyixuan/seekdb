# owner: cxf262476
# owner group: transaction
# description: test tablelock retry replay

--disable_warnings
drop user if exists table_lock;
drop table if exists t;
--enable_warnings

create user table_lock;
grant all on *.* to table_lock;

--source mysql_test/include/check_schema_sync.inc
connect(conn1, $OBMYSQL_MS0, table_lock, '', test, $OBMYSQL_PORT);
connect(conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

--disable_query_log
# 1. test replay commit
connection conn1;
set SESSION ob_trx_timeout = 10000000000;
set SESSION ob_query_timeout = 10000000000;
set SESSION ob_trx_idle_timeout = 10000000000;

CREATE TABLE t(k varchar(11), v varchar(10));

# 1.1 retry replay before tablelock
connection conn0;
alter system set_tp tp_name = "TX_REPLAY_COMMIT_FAIL_BEFORE_NOTIFY_TABLELOCK", error_code = 4023, frequency = 1;
sleep 1;

connection conn1;
# 1.2 reduce the length of the column.
ALTER TABLE t MODIFY k varchar(10);
sleep 1;

# 1.3 retry replay after replay tablelock
connection conn0;
alter system set_tp tp_name = "TX_REPLAY_COMMIT_FAIL_AFTER_NOTIFY_TABLELOCK", error_code = 4023, frequency = 1;
sleep 1;
alter system set_tp tp_name = "TX_REPLAY_COMMIT_FAIL_BEFORE_NOTIFY_TABLELOCK", error_code = 4023, frequency = 0;
sleep 1;
sleep 1;  # for replay retry

# 1.4 retry replay after notify on commit
alter system set_tp tp_name = "TX_REPLAY_COMMIT_FAIL_AFTER_NOTIFY_ON_COMMIT", error_code = 4023, frequency = 1;
sleep 1;
alter system set_tp tp_name = "TX_REPLAY_COMMIT_FAIL_AFTER_NOTIFY_TABLELOCK", error_code = 4023, frequency = 0;
sleep 1;
sleep 1;  # for replay retry

# 1.5 retry replay after commit
# TODO: this core now.
# alter system set_tp tp_name = "TX_REPLAY_COMMIT_FAIL_AFTER_COMMIT", error_code = 4023, frequency = 1;
# sleep 1;
alter system set_tp tp_name = "TX_REPLAY_COMMIT_FAIL_AFTER_NOTIFY_ON_COMMIT", error_code = 4023, frequency = 0;
sleep 1;
sleep 1;  # for replay retry


# alter system set_tp tp_name = "TX_REPLAY_COMMIT_FAIL_AFTER_COMMIT", error_code = 4023, frequency = 0;
# sleep 1;
# sleep 1;  # for replay retry

# 2. replay abort
# 2.0 stuck commit. and retry replay before notify tx end.
alter system set_tp tp_name = "TX_FORCE_WRITE_CLOG", error_code = 4023, frequency = 1;
alter system set_tp tp_name = "TX_REPLAY_ABORT_FAIL_BEFORE_NOTIFY_TX_END", error_code = 4023, frequency = 1;
sleep 1;
alter system set_tp tp_name = "SQL_DO_END_TX_FAIL", error_code = 4016, frequency = 1;
sleep 3;

# 2.1 do ddl and do not commit
connection conn1;
# reduce the length of the column.
SEND ALTER TABLE t MODIFY k varchar(9);
sleep 15;

connection conn0;
# 2.3 replay after notify tx end
alter system set_tp tp_name = "SQL_DO_END_TX_FAIL", error_code = 4016, frequency = 0;
alter system set_tp tp_name = "TX_FORCE_WRITE_CLOG", error_code = 4023, frequency = 0;
sleep 20;
alter system set_tp tp_name = "TX_REPLAY_ABORT_FAIL_AFTER_NOTIFY_TX_END", error_code = 4023, frequency = 1;
sleep 1;
alter system set_tp tp_name = "TX_REPLAY_ABORT_FAIL_BEFORE_NOTIFY_TX_END", error_code = 4023, frequency = 0;
sleep 1;
sleep 1;  # for replay retry

alter system set_tp tp_name = "TX_REPLAY_ABORT_FAIL_AFTER_ABORT", error_code = 4023, frequency = 1;
sleep 1;
alter system set_tp tp_name = "TX_REPLAY_ABORT_FAIL_AFTER_NOTIFY_TX_END", error_code = 4023, frequency = 0;
sleep 1;
sleep 1;  # for replay retry

alter system set_tp tp_name = "TX_REPLAY_ABORT_FAIL_AFTER_CLEAR", error_code = 4023, frequency = 1;
sleep 1;
alter system set_tp tp_name = "TX_REPLAY_ABORT_FAIL_AFTER_ABORT", error_code = 4023, frequency = 0;
sleep 1;
sleep 1;  # for replay retry

alter system set_tp tp_name = "TX_REPLAY_ABORT_FAIL_AFTER_NOTIFY_ON_ABORT", error_code = 4023, frequency = 1;
sleep 1;
alter system set_tp tp_name = "TX_REPLAY_ABORT_FAIL_AFTER_CLEAR", error_code = 4023, frequency = 0;
sleep 1;
sleep 1;  # for replay retry

alter system set_tp tp_name = "TX_REPLAY_ABORT_FAIL_AFTER_NOTIFY_ON_ABORT", error_code = 4023, frequency = 0;
sleep 1;

connection conn1;
--error 4016
REAP;

let $cnt = 100;
while ($cnt > 0) {
  INSERT INTO t VALUES(1, 1);
  dec $cnt;
}

DROP TABLE t;
drop user table_lock;
--enable_query_log
