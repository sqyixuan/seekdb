CREATE USER table_lock IDENTIFIED BY "table_lock";
grant all on *.* to table_lock;
ALTER SYSTEM SET enable_lock_priority=true;
"STEP: before lock"
UNLOCK TABLE;
UNLOCK TABLES;
"STEP: lock single table"
LOCK TABLE ttt WRITE;
ERROR 42S02: Table 'test.ttt' doesn't exist
LOCK TABLE ttt READ;
ERROR 42S02: Table 'test.ttt' doesn't exist
LOCK TABLE t WRITE;
ls_id	lock_mode	op_type	op_status	extra_info
1	X	OUT_TRANS_LOCK	COMPLETE	count:0, position:lock_table
LOCK TABLES tt READ;
ls_id	lock_mode	op_type	op_status	extra_info
1	S	OUT_TRANS_LOCK	COMPLETE	count:0, position:lock_table
UNLOCK TABLE;
ls_id	lock_mode	op_type	op_status	extra_info
ls_id	lock_mode	op_type	op_status	extra_info
"STEP: lock multi tables"
LOCK TABLE t WRITE, t READ;
ERROR 42000: Not unique table/alias: 't'
LOCK TABLE t WRITE, t WRITE;
ERROR 42000: Not unique table/alias: 't'
LOCK TABLE t READ, t READ;
ERROR 42000: Not unique table/alias: 't'
LOCK TABLE t WRITE, tt READ;
ls_id	lock_mode	op_type	op_status	extra_info
1	X	OUT_TRANS_LOCK	COMPLETE	count:0, position:lock_table
ls_id	lock_mode	op_type	op_status	extra_info
1	S	OUT_TRANS_LOCK	COMPLETE	count:0, position:lock_table
UNLOCK TABLES;
ls_id	lock_mode	op_type	op_status	extra_info
ls_id	lock_mode	op_type	op_status	extra_info
LOCK TABLES t WRITE;
ls_id	lock_mode	op_type	op_status	extra_info
1	X	OUT_TRANS_LOCK	COMPLETE	count:0, position:lock_table
LOCK TABLE t READ;
ERROR HY000: Lock wait timeout exceeded; try restarting transaction
LOCK TABLE t WRITE;
ERROR HY000: Lock wait timeout exceeded; try restarting transaction
INSERT INTO t VALUES(2);
ERROR HY000: Lock wait timeout exceeded; try restarting transaction
UPDATE t SET k=2;
ERROR HY000: Lock wait timeout exceeded; try restarting transaction
DELETE FROM t;
ERROR HY000: Lock wait timeout exceeded; try restarting transaction
SELECT * FROM t FOR UPDATE;
ERROR HY000: Lock wait timeout exceeded; try restarting transaction
SELECT * FROM t;
k
1
"STEP: lock and rename"
RENAME TABLE t TO t_new;
INSERT INTO t VALUES(2);
ERROR 42S02: Table 'test.t' doesn't exist
SELECT * FROM t_new;
k
1
RENAME TABLE t_new TO t;
UNLOCK TABLES;
"STEP: clean"
ALTER SYSTEM SET enable_lock_priority=false;
"STEP: drop table"
DROP TABLE t;
DROP TABLE tt;
"STEP: drop user"
DROP USER table_lock;
