result_format: 4

set ob_query_timeout = 30000000;

set ob_query_timeout = 30000000;

set ob_query_timeout = 30000000;

drop table tlp_t1;
create table tlp_t1 (c1 int, c2 int);
drop table tlp_t2;
alter system set enable_lock_priority=true;

## case 1, basic
## conn1
lock tables tlp_t1 write;

## conn2
lock tables tlp_t1 write;

## conn3
lock tables tlp_t1 write;

## conn1
unlock tables;

## conn2
unlock tables;

## conn3
unlock tables;

## case 2, dml
## conn1
lock tables tlp_t1 write;

## conn2
lock tables tlp_t1 write;

## conn3
start transaction;
insert into tlp_t1 values (1,1);

## conn1
unlock tables;

## conn2
unlock tables;

## conn3
commit;

select c1 from tlp_t1;
+------+
| c1   |
+------+
|    1 |
+------+

## case 3, dml first
## conn1
lock tables tlp_t1 write;

## conn2
start transaction;
insert into tlp_t1 values (2,2);

## conn3
lock tables tlp_t1 write;

## conn1
unlock tables;

## conn3
unlock tables;

## conn2
commit;

select c1 from tlp_t1;
+------+
| c1   |
+------+
|    1 |
|    2 |
+------+

## case 4, rename table
## conn1
lock tables tlp_t1 write;

## conn2
lock tables tlp_t1 write;

## conn3
rename table tlp_t1 to tlp_t2;

## conn1
unlock tables;

## conn3
select c1 from tlp_t2;
+------+
| c1   |
+------+
|    1 |
|    2 |
+------+

## conn2
unlock tables;

## case 5, switch leader for lock table
## conn1
lock tables tlp_t2 write;

## conn2
lock tables tlp_t2 write;

## conn3
lock tables tlp_t2 write;

## sys, switch leader from zone1 to zone2

## conn1
unlock tables;

## conn2
unlock tables;

## conn3
unlock tables;

## case 6, switch leader for dml
## conn1
lock tables tlp_t2 write;

## conn2
lock tables tlp_t2 write;

## conn3
start transaction;
insert into tlp_t2 values (3,3);

## sys, switch leader from zone2 to zone1

## conn1
unlock tables;

## conn2
unlock tables;

## conn3
commit;

select c1 from tlp_t2;
+------+
| c1   |
+------+
|    1 |
|    2 |
|    3 |
+------+

## case 7, switch leader multiple times
## conn1
lock tables tlp_t2 write;

## conn2
lock tables tlp_t2 write;

## conn3
lock tables tlp_t2 write;

## sys, switch leader from zone1 to zone2, then from zone2 to zone1


## conn1
unlock tables;

## conn2
unlock tables;

## conn3
unlock tables;

## reset
