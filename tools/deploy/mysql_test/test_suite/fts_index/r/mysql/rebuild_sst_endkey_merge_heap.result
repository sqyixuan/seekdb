drop database if exists t1;
create table t1(c1 int primary key, c2 varchar(65535), fulltext index i1(c2));
insert into t1 values(1,'check before observer');
insert into t1 values(2,'check after observer');
insert into t1 values(3,'check observer');
alter system minor freeze;
insert into t1 values(501,'observer');
select * from t1 where match(c2) against ('observer') limit 3;
c1	c2
501	observer
3	check observer
2	check after observer
drop table t1;
