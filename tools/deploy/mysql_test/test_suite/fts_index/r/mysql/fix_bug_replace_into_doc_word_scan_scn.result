alter system set _enable_defensive_check = 2;
drop table if exists t1;
drop database if exists fts;
drop table if exists t_sal;
drop trigger if exists trg_sal;
create database fts;
use fts;
result_format: 4
CREATE TABLE `t_sal` (
  `id` int(11) NOT NULL,
  `fts_field` varchar(10) DEFAULT NULL,
  PRIMARY KEY (`id`),
  FULLTEXT KEY `f` (`fts_field`) WITH PARSER space PARSER_PROPERTIES=(min_token_size=3,max_token_size=84) BLOCK_SIZE 16384
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 WITH COLUMN GROUP(all columns, each column);

CREATE DEFINER = admin@% trigger trg_sal after delete on t_sal for each row set @f:= "After delete t_sal fired";

replace into t_sal values(0,'9_0'),(0,'10_0'),(0,'11_0'),(0,'12_0');

create table t1(a varchar(100), fulltext index fts1(a), fulltext index fts2(a), fulltext index fts3(a));
insert into t1(a) values ('aaaa'), ('bbbb'), ('cccc');
update /*+log_level(debug)*/ t1 set a = 'dddd ddd' where a = 'aaaa';

alter system set _enable_defensive_check = 1;
drop table if exists t1;
drop table if exists t_sal;
drop trigger if exists trg_sal;
drop database fts;
