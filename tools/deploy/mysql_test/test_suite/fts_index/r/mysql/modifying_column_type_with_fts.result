drop table if exists t1;
create table t1(
id int,
name varchar(255),
title varchar(255),
abstract text,
content text
);
create fulltext index idx0 on t1(title);
create fulltext index idx1 on t1(content);
alter table t1 modify title tinytext;
alter table t1 modify title varchar(255);
alter table t1 modify content mediumtext;
alter table t1 modify content longtext;
alter table t1 modify name tinytext;
alter table t1 modify name varchar(255);
alter table t1 modify abstract mediumtext;
alter table t1 modify abstract longtext;
drop table t1;
