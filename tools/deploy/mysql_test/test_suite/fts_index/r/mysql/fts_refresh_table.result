drop database if exists fts;
create database fts;
use fts;
drop table if exists t1;
create table t1(
id int,
title varchar(512),
content varchar(4096),
category varchar(100),
fulltext index i1(content) block_size = 1024
) COMPRESSION = 'none';
alter system minor freeze;
alter system minor freeze;
use fts;
select id, title, match(content) against('database system') as relevance from t1 where match(content) against('database system') limit 1;
id	title	relevance
