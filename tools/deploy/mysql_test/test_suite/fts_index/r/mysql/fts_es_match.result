alter system set _enable_index_merge = true;
drop table if exists t1, t2;
Warnings:
Note	1051	Unknown table 'fts.t1'
Note	1051	Unknown table 'fts.t2'

create table t1(
  id int primary key,
  name varchar(128),
  detail text,
  year int,
  fulltext index i1(name),
  fulltext index i2(detail),
  index i3(year));

create table t2(
  id int primary key,
  category int,
  index i(category));

insert into t1 values
(0, "IBM Db2", "Db2 operating system OS/2.)", 1983),
(16, "Apache Storm", "Apache Storm learning applications.", 2012);

insert into t2 values
(0, 3),
(16, 2);

explain select *, score() from t1 join t2 on t1.id = t2.id
where match (detail^1.2, "system^2 Storm^1", "") and category = 3 and year = 1983;
Query Plan
=======================================================
|ID|OPERATOR             |NAME  |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------
|0 |NESTED-LOOP JOIN     |      |0       |914         |
|1 |├─TEXT RETRIEVAL SCAN|t1(i2)|0       |914         |
|2 |└─TABLE GET          |t2    |1       |16          |
=======================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.id], [t1.name], [t1.detail], [t1.year], [t2.id], [t2.category], [MATCH(t1.detail^cast(1.2, DOUBLE(-1, -1)), 'system^2 Storm^1', '')]), filter(nil), rowset=16
      conds(nil), nl_params_([t1.id(:0)]), use_batch=true
  1 - output([t1.id], [t1.detail], [t1.year], [t1.name], [MATCH(t1.detail^cast(1.2, DOUBLE(-1, -1)), 'system^2 Storm^1', '')]), filter([MATCH(t1.detail^cast(1.2,
       DOUBLE(-1, -1)), 'system^2 Storm^1', '')], [t1.year = 1983]), rowset=16
      access([t1.id], [t1.detail], [t1.year], [t1.name]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false,false], 
      match_expr(MATCH(t1.detail^cast(1.2, DOUBLE(-1, -1)), 'system^2 Storm^1', ''))
  2 - output([t2.id], [t2.category]), filter([t2.category = 3]), rowset=16
      access([GROUP_ID], [t2.id], [t2.category]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.id]), range(MIN ; MAX), 
      range_cond([:0 = t2.id])

