drop database if exists fts;
create database fts;
use fts;
create table t_ir_single_column(
digest varchar(512),
detail varchar(4096),
seq int,
fulltext index i1(detail),
fulltext index i2(digest),
index i3(seq));
create table t_helper (
content varchar(512),
id int,
fulltext index i1(content));
result_format: 4
explain select score() from t_ir_single_column where match (detail^1.2, "computer^2 system^1","operator=or;boost=1.5;minimum_should_match=2;score_norm=min-max;type=best_fields");
