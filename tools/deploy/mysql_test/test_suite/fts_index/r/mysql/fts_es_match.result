CREATE TABLE tab1 (
  content VARCHAR(255),
  seq int,
  FULLTEXT INDEX i(content));

CREATE TABLE tab2 (
  content VARCHAR(255),
  seq int,
  FULLTEXT INDEX i(content));

INSERT INTO tab1 VALUES ('Computer Science and Engineering', 2);

INSERT INTO tab2 VALUES ('CSE 224', 2), ('CSE 232', 2), ('LIFR 1A', 5);

SELECT tab1.content as department, tab2.content as course, tab1.seq, SCORE()
FROM tab1 JOIN tab2 ON tab1.seq = tab2.seq
WHERE MATCH(tab1.content^1, 'computer science', 'operator=or');
+----------------------------------+---------+------+--------------------+
| department                       | course  | seq  | SCORE()            |
+----------------------------------+---------+------+--------------------+
| Computer Science and Engineering | CSE 224 |    2 | 0.6626506024096386 |
| Computer Science and Engineering | CSE 232 |    2 | 0.6626506024096386 |
+----------------------------------+---------+------+--------------------+

CREATE TABLE multilang (
  en VARCHAR(255),
  fr VARCHAR(255) CHARACTER SET latin1,
  seq int NOT NULL AUTO_INCREMENT,
  FULLTEXT INDEX i_en(en),
  FULLTEXT INDEX i_fr(fr));

INSERT INTO multilang (en, fr) VALUES
  ('Her sister went to the same high school in Canada as her.', 'Sa soœur est allée au même lycée qu\'elle au Canada.'),
  ('They will take a vacation abroad this summer in the same region.', 'Ils prendront des vacances à l\'étranger cet été dans la même région.'),
  ('He would have gained a lot if he had invested in the bonds market last summer.', 'Il aurait beaucoup gagné s\'il avait investi sur le marché obligataire l\'été dernier.');

SELECT fr, SCORE() FROM multilang WHERE MATCH(en^1, fr^1, 'summer Canada', '');
