create table wikir1k(id int, document varchar(65535), fulltext index i1(document) WITH PARSER beng ) partition by hash(id) partitions 4;
insert into wikir1k values(1,'asdasd sda');
select * from wikir1k where MATCH(document) AGAINST('+asdasd -sda'IN BOOLEAN MODE);
+------+----------+
| id   | document |
+------+----------+
+------+----------+
select * from wikir1k where MATCH(document) AGAINST('-sda +asdasd'IN BOOLEAN MODE);
+------+----------+
| id   | document |
+------+----------+
+------+----------+

## empty query string with different charset
create table t_chset(c1 varchar(1024), fulltext index(c1)) DEFAULT CHARSET=eucjpms;
select * from t_chset where match(c1) against ("" in BOOLEAN MODE);
+------+
| c1   |
+------+
+------+

drop table if exists t_ir_single_column;
