DROP TABLE IF EXISTS fts_table_1;
DROP TABLE IF EXISTS fts_table_add_not_default_parser;
CREATE TABLE fts_table_1 (
id int primary key,
name varchar(20),
title varchar(20),
content varchar(20));
CREATE TABLE fts_table_add_not_default_parser (
id int,
name varchar(20),
title varchar(20),
content varchar(20));
alter system set _enable_add_fulltext_index_to_existing_table = true;
================= Try parser with a given parser ========================
ALTER TABLE fts_table_add_not_default_parser add FULLTEXT INDEX fti_ngram(name) WITH PARSER ngram;
SHOW CREATE TABLE fts_table_add_not_default_parser;
Table	Create Table
fts_table_add_not_default_parser	CREATE TABLE `fts_table_add_not_default_parser` (
  `id` int(11) DEFAULT NULL,
  `name` varchar(20) DEFAULT NULL,
  `title` varchar(20) DEFAULT NULL,
  `content` varchar(20) DEFAULT NULL,
  FULLTEXT KEY `fti_ngram` (`name`) WITH PARSER ngram PARSER_PROPERTIES=(ngram_token_size=2) BLOCK_SIZE 16384
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
ALTER TABLE fts_table_add_not_default_parser add FULLTEXT INDEX fti_beng(name) WITH PARSER beng;
SHOW CREATE TABLE fts_table_add_not_default_parser;
Table	Create Table
fts_table_add_not_default_parser	CREATE TABLE `fts_table_add_not_default_parser` (
  `id` int(11) DEFAULT NULL,
  `name` varchar(20) DEFAULT NULL,
  `title` varchar(20) DEFAULT NULL,
  `content` varchar(20) DEFAULT NULL,
  FULLTEXT KEY `fti_ngram` (`name`) WITH PARSER ngram PARSER_PROPERTIES=(ngram_token_size=2) BLOCK_SIZE 16384,
  FULLTEXT KEY `fti_beng` (`name`) WITH PARSER beng PARSER_PROPERTIES=(min_token_size=3,max_token_size=84) BLOCK_SIZE 16384
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
================= add first fulltext index ========================
ALTER TABLE fts_table_1 add FULLTEXT INDEX f101(name) WITH PARSER space;
