drop database if exists fts;
create database fts;
use fts;
create table t_ir_single_column(
digest varchar(512),
detail varchar(262144),
seq int,
fulltext index i1(detail),
fulltext index i2(digest, detail),
index i3(seq));
alter system major freeze;
explain select * from t_ir_single_column where true or match(digest, detail) against('test');
Query Plan
=============================================================
|ID|OPERATOR       |NAME              |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |TABLE FULL SCAN|t_ir_single_column|100     |10012       |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([t_ir_single_column.digest], [t_ir_single_column.detail], [t_ir_single_column.seq]), filter([1 OR MATCH(t_ir_single_column.digest, t_ir_single_column.detail) 
      AGAINST('test')]), rowset=256
      access([t_ir_single_column.__pk_increment], [t_ir_single_column.digest], [t_ir_single_column.detail], [t_ir_single_column.seq]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t_ir_single_column.__pk_increment]), range(MIN ; MAX)always true, has_functional_lookup=true
select * from t_ir_single_column where true or match(digest, detail) against('test');
drop table if exists t_ir_single_column;
drop database fts;
