##### case 4: it is prohibited to drop a fts index and rename another index to the name of the dropped index within the same statement #####
drop table if exists t11;
create table t11 (id int, c0 varchar(255), c1 varchar(255), c2 json);
create index idx on t11(id);
create fulltext index fts_idx0 on t11(c0);
create fulltext index fts_idx1 on t11(c1);
create index m_idx0 on t11( (CAST(c2->'$.zipcode' AS UNSIGNED ARRAY)) );
alter table t11 drop index fts_idx0, rename index idx to fts_idx0;
ERROR 0A000: dropping an fts or multivalue index and renaming another index to the droped index name in a single ALTER TABLE statement not supported
alter table t11 drop index fts_idx0, rename index fts_idx1 to fts_idx0;
ERROR 0A000: dropping an fts or multivalue index and renaming another index to the droped index name in a single ALTER TABLE statement not supported
alter table t11 drop index m_idx0, rename index idx to m_idx0;
ERROR 0A000: dropping an fts or multivalue index and renaming another index to the droped index name in a single ALTER TABLE statement not supported
alter table t11 drop index fts_idx0, drop index fts_idx1, rename index idx to fts_idx0;
ERROR 0A000: dropping an fts or multivalue index and renaming another index to the droped index name in a single ALTER TABLE statement not supported
alter table t11 drop index idx, rename index fts_idx0 to idx;
alter table t11 drop index fts_idx1, rename index idx to normal_idx;
##### case 5: building fts index on the string type column  #####
drop table if exists t12, t12_1, t12_2, t12_3, t12_4, t12_5, t12_6, t12_7, t12_8;
create table t12_1 (c1 int, c2 string, primary key(c1, c2), fulltext index idx(c2));
create table t12_2 (c1 int, c2 string, fulltext index idx(c2));
create table t12_3 (c1 int, c2 string, c3 varchar(255), fulltext index idx(c2, c3));
create table t12_4 (c1 int, c2 string, c3 tinytext, fulltext index idx(c2, c3));
create table t12_5 (c1 int, c2 string, c3 text, fulltext index idx(c2, c3));
create table t12_6 (c1 int, c2 string, c3 mediumtext, fulltext index idx(c2, c3));
create table t12_7 (c1 int, c2 string, c3 longtext, fulltext index idx(c2, c3));
create table t12_8 (
c1 int, c2 varchar(255), c3 tinytext, c4 text, c5 mediumtext, c6 longtext, c7 string,
fulltext index idx(c2, c3, c4, c5, c6, c7));
create table t12 (c1 int, c2 varchar(255), c3 tinytext, c4 text, c5 mediumtext, c6 longtext, c7 string, c8 string, primary key (c1, c7));
create fulltext index idx_c7_1 on t12(c7);
alter table t12 add fulltext index idx_c8(c8);
create fulltext index idx_c2_c7 on t12(c2, c7);
alter table t12 add fulltext index idx_c3_c7(c3, c7);
create fulltext index idx_c4_c7 on t12(c4, c7);
alter table t12 add fulltext index idx_c5_c7(c5, c7);
create fulltext index idx_c6_c7 on t12(c6, c7);
alter table t12 add fulltext index idx_c6_c8(c6, c8);
drop table t12, t12_1, t12_2, t12_3, t12_4, t12_5, t12_6, t12_7, t12_8;
