alter system set _enable_add_fulltext_index_to_existing_table = true;
##### case 1: building fts index on the columns with diffrent charset #####
drop table if exists t1;
drop table if exists t2;
create table t1 (
id int primary key, 
name varchar(20) character set utf8mb4 collate utf8mb4_unicode_ci, 
description text character set latin1 collate latin1_swedish_ci);
alter table t1 add fulltext index idx1(name, description);
ERROR 0A000: create fulltext index on columns with different collation not supported
alter table t1 add fulltext index idx2(name);
alter table t1 add fulltext index idx3(name, description);
ERROR 0A000: create fulltext index on columns with different collation not supported
create table t2 (
id int primary key, 
name varchar(20) character set utf8mb4 collate utf8mb4_unicode_ci, 
description text character set latin1 collate latin1_swedish_ci,
fulltext index v_idx(name, description));
ERROR 0A000: create fulltext index on columns with different collation not supported
##### case 2: building fts index on the virtual column #####
drop table if exists t2;
drop table if exists t3;
create table t2 (
id int,
c1 varchar(20),
c2 varchar(20),
c3 varchar(40) generated always as (concat(c1, c2)) virtual
);
alter table t2 add fulltext index idx1(c3);
ERROR 0A000: Fulltext index on generated column is not supported
alter table t2 add fulltext index idx0(c1, c2);
alter table t2 add fulltext index idx1(c3);
ERROR 0A000: Fulltext index on generated column is not supported
CREATE TABLE t3(
c1 VARCHAR(200),
c2 TEXT,
c3 TEXT AS (CONCAT(c2, '')) VIRTUAL,
FULLTEXT INDEX v_idx(c3));
ERROR 0A000: Fulltext index on generated column is not supported
##### case 3: building fts index when using ik paser #####
drop table if exists t3;
CREATE TABLE t3 (id int, content varchar(255)) DEFAULT CHARSET = utf16;
create fulltext index idx on t3(content) with parser ik;
ERROR 0A000: the charset is not supported
alter table t3 add fulltext index idx(content) with parser ik;
ERROR 0A000: the charset is not supported
drop table if exists t4;
create table t4 (id int, content varchar(255), fulltext index idx(content) with parser ik) DEFAULT CHARSET = utf16;
ERROR 0A000: ik with the utf16 charset is not supported
create table t4 (id int, content varchar(255) character set utf16 default null, fulltext index idx(content) with parser ik);
ERROR 0A000: ik with the utf16 charset is not supported
alter system set _enable_parallel_table_creation = false tenant=sys;
create table t4 (id int, content varchar(255), fulltext index idx(content) with parser ik) DEFAULT CHARSET = utf16;
ERROR 0A000: ik with the utf16 charset is not supported
create table t4 (id int, content varchar(255) character set utf16 default null, fulltext index idx(content) with parser ik);
ERROR 0A000: ik with the utf16 charset is not supported
alter system set _enable_parallel_table_creation = true tenant=sys;
drop table if exists t6;
create table t6 (id int, c0 varchar(255) character set utf16, c1 varchar(255));
alter table t6 add fulltext index idx0(c0) with parser ik;
ERROR 0A000: the charset is not supported
create fulltext index idx0 on t6(c0) with parser ik;
ERROR 0A000: the charset is not supported
alter table t6 add fulltext index idx1(c1) with parser ik;
create fulltext index idx2 on t6(c1) with parser ik;
drop table t6;
##### case 3: building global fts index #####
drop table if exists t_global_fts;
create table t_global_fts (id int, c0 varchar(20), c1 varchar(20));
alter table t_global_fts add fulltext index idx0(c0) global;
ERROR 0A000: global fulltext index is not supported
create fulltext index idx0 on t_global_fts(c0) global;
ERROR 0A000: global fulltext index is not supported
alter table t_global_fts add fulltext index idx0(c0);
create fulltext index idx1 on t_global_fts(c1);
drop table if exists t_with_global_fts;
alter system set _enable_parallel_table_creation = true tenant=sys;
create table t_with_global_fts (id int, name varchar(20), fulltext index idx0(name) global);
ERROR 0A000: global fulltext index is not supported
alter system set _enable_parallel_table_creation = false tenant=sys;
create table t_with_global_fts (id int, name varchar(20), fulltext index idx0(name) global);
ERROR 0A000: global fulltext index is not supported
##### case 4: aux table name for domain index may be same #####
drop table if exists t4;
create table t4 (id int, title varchar(20), content varchar(255));
create fulltext index idx0 on t4(title);
alter table t4 add fulltext index idx1(content);
create fulltext index fts_rowkey_doc on t4(title);
ERROR 42000: Duplicate key name 'fts_rowkey_doc'
alter table t4 add fulltext index fts_rowkey_doc(content);
ERROR 42000: Duplicate key name 'fts_rowkey_doc'
alter table t4 rename index idx0 to fts_rowkey_doc;
ERROR 42000: Duplicate key name 'fts_rowkey_doc'
alter table t4 rename index idx1 to fts_doc_rowkey;
ERROR 42000: Duplicate key name 'fts_doc_rowkey'
create fulltext index fts_doc_rowkey on t4(title);
ERROR 42000: Duplicate key name 'fts_doc_rowkey'
alter table t4 add fulltext index fts_doc_rowkey(content);
ERROR 42000: Duplicate key name 'fts_doc_rowkey'
create fulltext index idx0_fts_doc_word on t4(title);
ERROR 42000: Duplicated key name
alter table t4 add fulltext index idx1_fts_doc_word(content);
ERROR 42000: Duplicated key name
drop table t4;
drop table if exists t5;
create table t5 (title varchar(200), body text);
alter table t5 add fulltext index fts_rowkey_doc_fts_doc_word(body);
alter table t5 add fulltext index fts_rowkey_doc(body);
ERROR 42000: Duplicate key name 'fts_rowkey_doc'
create fulltext index fts_rowkey_doc on t5(body);
ERROR 42000: Duplicate key name 'fts_rowkey_doc'
drop table t5;
drop table if exists t6;
create table t6 (
id int,
title varchar(20),
content varchar(255),
fulltext index idx0(title),
