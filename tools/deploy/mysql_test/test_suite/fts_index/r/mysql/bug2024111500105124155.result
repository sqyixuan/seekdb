drop database if exists fts;
create database fts;
use fts;
create table doc(
content char(50),
id int primary key,
fulltext index i1(content));
INSERT INTO doc (content, id) VALUES
('Extended information for document 1', 1),
('Extended information for document 2', 2),
('Extended information for document 3', 3),
('Extended information for document 4', 4),
('Extended information for document 5', 5);
result_format: 4
alter system set _rowsets_max_rows = 1;
select  *, match(content) against('document') as relevance from doc where match(content) against('document') limit 2 offset 2;
+-------------------------------------+----+--------------------+
| content                             | id | relevance          |
+-------------------------------------+----+--------------------+
| Extended information for document 3 |  3 | 0.3503184713375797 |
| Extended information for document 2 |  2 | 0.3503184713375797 |
+-------------------------------------+----+--------------------+
alter system set _rowsets_max_rows = 256;

drop database fts;
