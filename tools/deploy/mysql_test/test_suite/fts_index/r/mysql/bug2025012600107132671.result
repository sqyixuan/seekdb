      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([a.c1]), range(MIN ; MAX)always true
explain select match(A.c4) against("xxxx") from t1 A left join lateral(select A.c1 as zz, A.c2 as yy from t2 where t2.c2=A.c1 order by A.c1,c2 limit 1 offset 1) B on match(A.c4) against("xxxx")=B.zz where B.zz is null order by match(c4) against("xxxx");
ERROR 0A000: pushdown join conds with match expr not supported
alter system _enable_index_merge=true;
drop table t1, t2;
