######### TEST: 反拼 ##########
create view doc_view as select id, title, match(content) against("database") as score from doc where match(content) against("database");
show create view doc_view;
View	Create View	character_set_client	collation_connection
doc_view	CREATE VIEW `doc_view` AS select `fts`.`doc`.`id` AS `id`,`fts`.`doc`.`title` AS `title`,MATCH(`fts`.`doc`.`content`) AGAINST('database') AS `score` from `fts`.`doc` where MATCH(`fts`.`doc`.`content`) AGAINST('database')	utf8mb4	utf8mb4_general_ci

