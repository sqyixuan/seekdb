alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

insert into t2 values (51, 'observer maintenance scheduled'), (52, 'observer audit passed');
delete from t1 where c1 >= 400;

select match(c2) against ('observer') as score,* from t1 where match(c2) against ('observer') limit 2;
select match(c2) against ('observer') as score,* from t2 where match(c2) against ('observer') limit 2;

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

insert into t1 values (601, 'observer reboot after freeze');
insert into t2 values (53, 'observer post-freeze test');

select match(c2) against ('observer') as score,* from t1 where match(c2) against ('observer') limit 2;
select match(c2) against ('observer') as score,* from t2 where match(c2) against ('observer') limit 2;

drop table t1,t2;
