# owner: [CONTRIBUTOR]
# owner group: storage
# description: fix bug

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 int primary key, c2 varchar(65535), fulltext index i1(c2));
create table t2(c1 int primary key, c2 varchar(65535), fulltext index i1(c2) block_size = 1024);

insert into t1 values(1,'check before observer');
insert into t1 values(2,'check after observer');
insert into t1 values(3,'check observer');

