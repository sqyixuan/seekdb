alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

insert into t1 values(501,'observer');
delete from t2 where c1 > 3;

select match(c2) against ('observer') as score,* from t1 where match(c2) against ('observer') limit 3;
select match(c2) against ('observer') as score,* from t2 where match(c2) against ('observer') limit 2;
select match(c2) against ('observer successful') as score,* from t2 where match(c2) against ('observer successful') limit 2;

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

select match(c2) against ('observer') as score,* from t2 where match(c2) against ('observer') limit 2;
