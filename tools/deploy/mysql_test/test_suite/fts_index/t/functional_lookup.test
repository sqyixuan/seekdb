select digest, match (detail) against ("system") as r1, match (detail) against ("system computer") as r2 from t_ir_single_column;

explain select seq, match (detail) against ("computer") from t_ir_single_column where seq > 0;
select seq, match (detail) against ("computer") from t_ir_single_column where seq > 0;

explain select seq, match (detail) against ("system"), match (detail) against ("computer system") from t_ir_single_column where seq > 0;
select seq, match (detail) against ("system"), match (detail) against ("computer system") from t_ir_single_column where seq > 0;

