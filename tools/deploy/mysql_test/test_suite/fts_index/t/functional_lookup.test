explain select digest, match (detail) against ("system") as r1, match (detail) against ("system computer") as r2 from t_ir_single_column limit 3;
select digest, match (detail) against ("system") as r1, match (detail) against ("system computer") as r2 from t_ir_single_column limit 3;

explain select digest, match (detail) against ("computer") from t_ir_single_column where seq > 0 limit 3;
select digest, match (detail) against ("computer") from t_ir_single_column where seq > 0 limit 3;

explain select digest, match (detail) against ("system") as r1, match (detail) against ("system computer") as r2 from t_ir_single_column order by r1 desc;
select digest, match (detail) against ("system") as r1, match (detail) against ("system computer") as r2 from t_ir_single_column order by r1 desc;

explain select digest, match (detail) against ("computer") from t_ir_single_column where seq > 0 order by seq desc;
select digest, match (detail) against ("computer") from t_ir_single_column where seq > 0 order by seq desc;

explain select digest, match (detail) against ("system") as r1, match (detail) against ("computer") as r2 from t_ir_single_column order by r1 desc limit 3;
select digest, match (detail) against ("system") as r1, match (detail) against ("computer") as r2 from t_ir_single_column order by r1 desc limit 3;

explain select digest, match (detail) against ("computer") from t_ir_single_column where seq > 0 order by seq desc limit 3;
select digest, match (detail) against ("computer") from t_ir_single_column where seq > 0 order by seq desc limit 3;

explain select digest, seq from t_ir_single_column where match (detail) against ("computer") and match (detail) against ("system");
select digest, seq from t_ir_single_column where match (detail) against ("computer") and match (detail) against ("system");

