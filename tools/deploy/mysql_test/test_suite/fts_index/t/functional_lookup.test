alter system set _rowsets_max_rows = 16;
alter system flush plan cache;

create table t_global_index(
    c1 varchar(4096),
    c2 bigint,
    fulltext key ft_i1 (c1),
    key global_i1 (c2) global
    ) partition by range(c2)
    (partition p0 values less than (1000),
    partition p1 values less than (MAXVALUE));

explain select match (c1) against ('test') from t_global_index where c2 < 100;
select match (c1) against ('test') from t_global_index where c2 < 100;
explain select *, match (c1) against ('test') from t_global_index where c2 < 100;
select *, match (c1) against ('test') from t_global_index where c2 < 100;
explain select /*+ index(t_global_index global_i1) */ match (c1) against ('test') from t_global_index where c2 < 100;
select /*+ index(t_global_index global_i1) */ match (c1) against ('test') from t_global_index where c2 < 100;
explain select /*+ index(t_global_index global_i1) */ *, match (c1) against ('test') from t_global_index where c2 < 100;
select /*+ index(t_global_index global_i1) */ *, match (c1) against ('test') from t_global_index where c2 < 100;

--sleep 2
--disable_warnings
drop table if exists t_ir_single_column;
drop table if exists t_dim;
drop table if exists t_global_index;
drop database fts;

alter system set _rowsets_max_rows = 256;

--enable_warnings
