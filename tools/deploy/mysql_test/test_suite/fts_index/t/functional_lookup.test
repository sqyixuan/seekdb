explain select count(if(match (detail) against ("computer"), 1, null)) from t_ir_single_column;
select count(if(match (detail) against ("computer"), 1, null)) from t_ir_single_column;

explain select count(NULLIF(match (detail) against ("computer"), 0)) from t_ir_single_column;
select count(NULLIF(match (detail) against ("computer"), 0)) from t_ir_single_column;

explain select count(NULLIF(match (detail) against ("system"), 0)) from t_ir_single_column;
select count(NULLIF(match (detail) against ("system"), 0)) from t_ir_single_column;

# should we enable the match against table on null side of the join？
--error ER_NOT_SUPPORTED_YET
explain select t1.seq, t2.seq, detail, digest from t_ir_single_column as t1 right join t_dim as t2 on (t1.seq = t2.seq) where match (detail) against ("computer");
--error ER_NOT_SUPPORTED_YET
select t1.seq, t2.seq, detail, digest from t_ir_single_column as t1 right join t_dim as t2 on (t1.seq = t2.seq) where match (detail) against ("computer");

explain select digest, match (detail) against ("computer") from t_ir_single_column where match (detail) against ("computer") or seq > 0;
