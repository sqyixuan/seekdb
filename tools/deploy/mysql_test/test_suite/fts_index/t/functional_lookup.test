# owner: saitong.zst
# owner group: storage
# description: text retrieval query with functional lookup

--disable_warnings
drop database if exists fts;
create database fts;
use fts;
--enable_warnings

# dml
create table test_dml(id int, document varchar(256), fulltext(document));
update test_dml set id = 1 where match (document) against ('query');
--error 1235
update test_dml set id = 1 where match (document) against ('query') or id > 0;

create table t_ir_single_column(
  digest varchar(512),
  detail varchar(4096),
  seq int,
  fulltext index i1(detail),
  fulltext index i2(digest, detail),
  index i3(seq));

create table t_dim(
  seq int,
  dim_info varchar(512),
  index i1(seq));

--result_format 4

insert into t_ir_single_column (digest, detail, seq) values
    ("Gerard Salton", "Gerard A. Gerry Salton (8 March 1927 – 28 August 1995) was a professor of Computer Science at Cornell University. Salton was perhaps the leading computer scientist working in the field of information retrieval during his time, and the father of Information Retrieval", 0),
    ("Edgar F. Codd", "Edgar Frank Ted Codd (19 August 1923 – 18 April 2003) was an English computer scientist who, while working for IBM, invented the relational model for database management, the theoretical basis for relational databases and relational database management systems. ", 1),
    ("Michael Stonebraker", "Michael Ralph Stonebraker (born October 11, 1943[6]) is a computer scientist specializing in database systems. Through a series of academic prototypes and commercial startups, Stonebraker's research and products are central to many relational databases. ", 2),
    ("Geoffrey Hinton", "Geoffrey Everest Hinton CC FRS FRSC (born 6 December 1947) is a British-Canadian computer scientist and cognitive psychologist, most noted for his work on artificial neural networks.", 3),
    ("Yann LeCun", "Yann André LeCun[1] (born 8 July 1960) is a Turing Award winning French computer scientist working primarily in the fields of machine learning, computer vision, mobile robotics and computational neuroscience.", 4),
    ("Ken Thompson", "Kenneth Lane Thompson (born February 4, 1943) is an American pioneer of computer science. Thompson worked at Bell Labs for most of his career where he designed and implemented the original Unix operating system. ", 5),
    ("Gordon Plotkin", "Gordon David Plotkin, FRS FRSE MAE (born 9 September 1946) is a theoretical computer scientist in the School of Informatics at the University of Edinburgh. Plotkin is probably best known for his introduction of structural operational semantics (SOS) and his work on denotational semantics.", 6),
    ("Leslie Lamport", "Leslie B. Lamport (born February 7, 1941) is an American computer scientist and mathematician. Lamport is best known for his seminal work in distributed systems, and as the initial developer of the document preparation system LaTeX", 7);

insert into t_dim (seq, dim_info) values
    (1, "dim imfo 1"),
    (3, "dim imfo 3"),
    (4, "dim imfo 4"),
    (7, "dim imfo 7");

alter system set _rowsets_enabled = true;
alter system flush plan cache;
alter system set _enable_index_merge=false;

--sleep 2

explain select digest from t_ir_single_column where match (detail) against ("computer");
select digest from t_ir_single_column where match (detail) against ("computer");

explain select digest, match (detail) against ("computer") from t_ir_single_column where match (detail) against ("computer");
select digest, match (detail) against ("computer") from t_ir_single_column where match (detail) against ("computer");

explain select seq, digest, match (detail) against ("") from t_ir_single_column;
select seq, digest, match (detail) against ("") from t_ir_single_column;

explain select seq,digest, match (detail) against ("test") from t_ir_single_column;
select seq, digest, match (detail) against ("test") from t_ir_single_column;

explain select digest, match (detail) against ("system") from t_ir_single_column where match (detail) against ("computer");
select digest, match (detail) against ("system") from t_ir_single_column where match (detail) against ("computer");

explain select digest, match (detail) against ("system computer") as alias1, match (detail) against ("computer") as alias2 from t_ir_single_column where match (detail) against ("computer");
select digest, match (detail) against ("system computer") as alias1, match (detail) against ("computer") as alias2 from t_ir_single_column where match (detail) against ("computer");

explain select match (detail) against ("computer") from t_ir_single_column;
select match (detail) against ("computer") from t_ir_single_column;

explain select match (detail) against ("computer"), match (detail) against ("computer system") from t_ir_single_column;
select match (detail) against ("computer"), match (detail) against ("computer system") from t_ir_single_column;

explain select seq, match (detail) against ("computer") from t_ir_single_column;
select seq, match (detail) against ("computer") from t_ir_single_column;

explain select digest, match (detail) against ("computer") from t_ir_single_column;
select digest, match (detail) against ("computer") from t_ir_single_column;

