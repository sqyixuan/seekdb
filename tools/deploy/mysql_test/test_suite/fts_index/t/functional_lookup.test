# insert 520
--disable_query_log
alter system set _rowsets_max_rows = 16;
alter system flush plan cache;
begin;
--let $loop=100
while($loop > 0)
{
    eval insert into t_ir_single_column (digest, detail, seq) values ('test', CONCAT('test test',$loop/50,' test',$loop%50), 108 - $loop);
    dec $loop;
}
commit;
--enable_query_log
analyze table t_ir_single_column;

alter system set _rowsets_max_rows = 4;
alter system flush plan cache;

