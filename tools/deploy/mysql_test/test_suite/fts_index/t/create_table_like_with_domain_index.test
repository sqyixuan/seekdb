select table_name from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't14' and database_id = (SELECT database_id FROM oceanbase.__all_database WHERE database_name = 'fts_and_other_index'));

--echo
--echo
--echo # test many complete hnsw, ivf_flat, ivf_pq and ivf_sq8 vex index #
connection conn_user1;
--disable_warnings
drop table if exists t15;
drop table if exists t16;
--enable_warnings
create table t15 (c1 int, c2 int, c3 vector(10), c4 vector(10), c5 vector(10), c6 vector(10), c7 vector(10), c8 vector(10), c9 vector(10), c10 vector(10));
create index idx0 on t15(c1);
create index idx1 on t15(c2);
create vector index idx2 on t15(c3) with (distance=l2, type=hnsw);
create vector index idx3 on t15(c4) with (distance=l2, type=hnsw);
create vector index idx4 on t15(c5) with (distance=l2, type=ivf_flat);
create vector index idx5 on t15(c6) with (distance=l2, type=ivf_flat);
create vector index idx6 on t15(c7) with (distance=l2, type=ivf_pq, nlist=2, sample_per_nlist=3, m=5);
create vector index idx7 on t15(c8) with (distance=l2, type=ivf_pq, nlist=2, sample_per_nlist=3, m=5);
create vector index idx8 on t15(c9) with (distance=l2, type=ivf_sq8, nlist=2, sample_per_nlist=3);
create vector index idx9 on t15(c10) with (distance=l2, type=ivf_sq8, nlist=2, sample_per_nlist=3);

create table t16 like t15;

connection conn_user;
--replace_regex /__idx_[0-9]*/__idx_xxx/g; /__AUX_LOB_META_[0-9]*_/__AUX_LOB_META_xxx_/g; /__AUX_LOB_PIECE_[0-9]*_/__AUX_LOB_PIECE_xxx_/g
select table_name from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't15' and database_id = (SELECT database_id FROM oceanbase.__all_database WHERE database_name = 'fts_and_other_index'));
--replace_regex /__idx_[0-9]*/__idx_xxx/g; /__AUX_LOB_META_[0-9]*_/__AUX_LOB_META_xxx_/g; /__AUX_LOB_PIECE_[0-9]*_/__AUX_LOB_PIECE_xxx_/g
select table_name from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't16' and database_id = (SELECT database_id FROM oceanbase.__all_database WHERE database_name = 'fts_and_other_index'));
