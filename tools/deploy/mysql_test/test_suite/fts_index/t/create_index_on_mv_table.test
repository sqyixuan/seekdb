# owner: youchuan.yc
# owner group: storage
# description: test creating fts/multivalue/vec index on materialized view table is not allowed
connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connection sys_conn;
alter system set _enable_add_fulltext_index_to_existing_table = true;

connect(mysql_conn, $OBMYSQL_MS0, root,,test, $OBMYSQL_PORT);
connection mysql_conn;

alter system set ob_vector_memory_limit_percentage = 44;

--disable_warnings
drop table if exists t;
drop materialized view if exists mvt;
--enable_warnings
create table t(c1 int  primary key, c2 varchar(20), c3 json, c4 vector(3));
create materialized view mvt(c1, c2, c3, c4) as select c1, c2, c3, c4 from t;
--error 1235
create fulltext index idx on mvt(c2);
--error 1235
alter table mvt add fulltext index idx(c2);

--error 1235
create index idx on mvt( (CAST(c3->'$.zipcode' AS UNSIGNED ARRAY)) );
--error 1235
alter table mvt add index idx( (CAST(c3->'$.zipcode' AS UNSIGNED ARRAY)) );

--error 1235
create vector index idx on mvt(c4) with (distance=l2, type=hnsw);
# TO DO build vector index using alter
# --error 1235
# alter table mvt add vector index idx(c4) with (distance=l2, type=hnsw);

create fulltext index idx1 on t(c2);
--disable_warnings
alter table t add fulltext index idx2(c2);
--enable_warnings

create index idx3 on t( (CAST(c3->'$.zipcode' AS UNSIGNED ARRAY)) );
alter table t add index idx4( (CAST(c3->'$.zipcode' AS UNSIGNED ARRAY)) );

alter table t drop index idx1, drop index idx2, drop index idx3, drop index idx4;

create vector index idx5 on t(c4) with (distance=l2, type=hnsw);

drop materialized view mvt;
drop table t;

connection sys_conn;
alter system set _enable_add_fulltext_index_to_existing_table = false;
connection mysql_conn;
alter system set ob_vector_memory_limit_percentage = 0;
