# owner: shangbin.zyx
# owner group: storage
# description: mock for system variables


--result_format 4

#1. test ft_stopword_file var
SELECT @@ft_stopword_file;
SELECT @@global.ft_stopword_file;
--error 1238
SELECT @@session.ft_stopword_file;
set global ft_stopword_file  = 'test';
SELECT @@global.ft_stopword_file;

#2. test innodb_ft_cache_size var
SELECT @@innodb_ft_cache_size;
SELECT @@global.innodb_ft_cache_size;
--error 1238
SELECT @@session.innodb_ft_cache_size;
--error 1231
set global innodb_ft_cache_size  = 160000;
--error 1231
set global innodb_ft_cache_size  = 180000001;
set global innodb_ft_cache_size  = 1600000;
SELECT @@global.innodb_ft_cache_size;

