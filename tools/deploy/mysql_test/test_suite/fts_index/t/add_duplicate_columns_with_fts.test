# owner: youchuan.yc
# owner group: storage
# description: test drop fulltext index

connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connection sys_conn;

alter system set _enable_add_fulltext_index_to_existing_table = true;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (id int, c1 varchar(255));
create fulltext index idx on t1(c1);
insert into t1 (id, c1) values 
(1, 'ob succ'),
(2, 'ob succ'),
(3, 'ob succ');
alter table t1 add c2 varchar(255);
--error 1060
alter table t1 add c2 varchar(255);

drop table t1;

connection sys_conn;
alter system set _enable_add_fulltext_index_to_existing_table = true;