--disable_warnings
drop database if exists fts;
create database fts;
use fts;
drop table if exists t1, t2;
drop database if exists trade;
--enable_warnings

# 改写测试
CREATE table t1 (c15 varchar(100), c26 varchar(100), c43 varchar(100), c1 int primary key, fulltext index fts(c15, c26, c43));
CREATE TABLE t2 (a TEXT, b TEXT, c TEXT, FULLTEXT(a, b), FULLTEXT(c));

UPDATE
  t1 AS t1_2
SET
  t1_2.c43 = (
    SELECT
      MIN(t1_2.c43)
    FROM
      t1 AS t1_2
  )
WHERE
  t1_2.c26 IN (t1_2.c15)
  OR t1_2.c26 NOT LIKE '%000%';

delete FROM t2 where a = (select max(a) FROM t2 );

drop table t1, t2;

CREATE TABLE `t1` (
  `c1` int(127) NOT NULL,
  `c2` year(4) DEFAULT NULL,
  `c3` timestamp(3) NOT NULL DEFAULT '0000-00-00 00:00:00.000',
  `c4` decimal(64,15) DEFAULT NULL,
  `c5` int(127) DEFAULT NULL,
  `c6` year(4) DEFAULT NULL,
  `c7` varbinary(73) NOT NULL,
  `c8` decimal(64,15) NOT NULL,
  `c9` decimal(64,11) DEFAULT NULL,
  `c10` decimal(64,23) DEFAULT NULL,
  `c11` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
  `c12` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
  `c13` time DEFAULT NULL,
  `c14` datetime DEFAULT NULL,
  `c15` decimal(64,5) NOT NULL,
  `c16` timestamp(5) NOT NULL DEFAULT '0000-00-00 00:00:00.00000',
  `c17` binary(54) DEFAULT NULL,
  `c18` bigint(127) DEFAULT NULL,
  `c19` varbinary(54) NOT NULL,
  `c20` varbinary(66) DEFAULT NULL,
  `c21` bigint(127) NOT NULL AUTO_INCREMENT,
  `c22` bigint(127) NOT NULL,
  `c23` binary(153) DEFAULT NULL,
  `c24` date DEFAULT NULL,
  `c25` year(4) DEFAULT NULL,
  `c26` decimal(64,6) DEFAULT NULL,
  `c27` int(127) DEFAULT NULL,
  `c28` year(4) DEFAULT NULL,
  `c29` binary(81) DEFAULT NULL,
  `c30` binary(74) DEFAULT NULL,
  `c31` varbinary(79) DEFAULT NULL,
  `c32` varbinary(68) DEFAULT NULL,
  `c33` datetime DEFAULT NULL,
  `c34` datetime DEFAULT NULL,
  `c35` datetime DEFAULT NULL,
  `c36` int(127) DEFAULT NULL,
  PRIMARY KEY (`c22`, `c19`, `c8`, `c1`, `c15`, `c7`),
  UNIQUE KEY `g_u_0_C` (`c11`, `c18`, `c23`, `c15`) BLOCK_SIZE 16384 GLOBAL,
  UNIQUE KEY `u_1_syOzTfcQ` (`c22`, `c4`, `c5`, `c29`) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY `u_2_KFbB` (`c31`, `c22`) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY `g_u_3_r` (`c32`, `c18`) BLOCK_SIZE 16384 GLOBAL,
  FULLTEXT KEY `f_0_EQaSflryQ` (`c11`) WITH PARSER space BLOCK_SIZE 16384,
  KEY `g_i_0_rosuzDzE` (`c17`, `c36`) BLOCK_SIZE 16384 GLOBAL,
  KEY `g_i_1_cvLR` (`c18`, `c36`) BLOCK_SIZE 16384 GLOBAL,
  KEY `g_i_2_YPAXwF` (`c18`, `c20`, `c22`) BLOCK_SIZE 16384 GLOBAL,
  KEY `g_i_3_EkG` (`c19`, `c10`, `c36`, `c32`) BLOCK_SIZE 16384 GLOBAL
) AUTO_INCREMENT = 99997897 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 LOB_INROW_THRESHOLD=0
 partition by range(c22)
(partition `p0` values less than (1000),
partition `p1` values less than (2000),
partition `p2` values less than (3000),
partition `p3` values less than (4000),
partition `p4` values less than (5000),
partition `p5` values less than (6000),
partition `p6` values less than (7000),
partition `p7` values less than (8000),
partition `p8` values less than (9000),
partition `p9` values less than (MAXVALUE)) WITH COLUMN GROUP(all columns, each column);

UPDATE  t1 AS t1_0 SET t1_0.c2 = '1921'
WHERE t1_0.c5 < (SELECT t1_0.c10 FROM t1 AS t1_0 ORDER BY 1 ASC LIMIT 1) OR t1_0.c11 in (t1_0.c12);

drop table t1;

# dml 权限测试
create database trade;
create user u1;
Grant all on trade.* to u1;

connect (u1,$OBMYSQL_MS0,u1,,trade,$OBMYSQL_PORT);
connection u1;
CREATE TABLE `tx_smpay_traderecord` (
  `recorddate` date NOT NULL COMMENT '记录日期',
  `ordernum` varchar(36) NOT NULL COMMENT '支付订单号',
  `shopid` int(11) NOT NULL COMMENT '店铺id',
  `tradetype` varchar(2) DEFAULT NULL COMMENT '交易类型',
  `fromtype` varchar(2) DEFAULT NULL COMMENT '交易来源',
  `tradechannel` varchar(2) DEFAULT NULL COMMENT '交易渠道',
  `acquirerchannel` varchar(16) DEFAULT NULL COMMENT '收单渠道',
  `usescenes` varchar(2) DEFAULT NULL COMMENT '支付场景',
  `shopname` varchar(128) DEFAULT NULL COMMENT '商户名称',
  `userid` int(11) DEFAULT NULL COMMENT '用户ID',
  `openid` varchar(255) DEFAULT NULL COMMENT 'openid',
  `originalamount` decimal(18,2) DEFAULT NULL COMMENT '原支付金额',
  `payamount` decimal(18,2) DEFAULT NULL COMMENT '实际支付金额',
  `reducedifference` decimal(18,2) DEFAULT NULL COMMENT '总减免金额',
  `platformdifference` decimal(18,2) DEFAULT NULL COMMENT '平台减免',
  `vaccountdifference` decimal(18,2) DEFAULT NULL COMMENT '零钱减免',
  `shopreduce` decimal(18,2) DEFAULT NULL COMMENT '商户减免金额',
  `payfee` decimal(18,2) DEFAULT NULL COMMENT '交易结算手续费（实际支付）',
  `servicechargerate` decimal(8,6) DEFAULT NULL COMMENT '手续费费率',
  `rebatepayment` decimal(18,2) DEFAULT NULL COMMENT '返利金金额',
  `sumpayment` decimal(18,2) DEFAULT NULL COMMENT '总发金额',
  `partrebatereason` int(11) DEFAULT NULL COMMENT '部分返利原因',
  `trade_code` varchar(64) DEFAULT NULL COMMENT '微信/支付宝/云闪付流水号',
  `paystatus` varchar(2) DEFAULT NULL COMMENT '支付状态',
  `paysuccesstime` datetime DEFAULT NULL COMMENT '支付成功时间',
  `qrcode` varchar(64) DEFAULT NULL COMMENT '收款码编号',
  `transactionid` varchar(64) DEFAULT NULL COMMENT '三方订单号',
  `merid` varchar(64) DEFAULT NULL COMMENT '商户号',
  `terminalnumber` varchar(64) DEFAULT NULL COMMENT '交易终端号',
  `transfercard` varchar(64) DEFAULT NULL COMMENT '转入卡号',
  `behalfpaystatus` varchar(2) DEFAULT NULL COMMENT '入账状态',
  `behalfpaydate` datetime DEFAULT NULL COMMENT '合并入账成功，撤销成功时间',
  `behalfretmsg` varchar(255) DEFAULT NULL COMMENT '入账失败原因',
  `remark` varchar(255) DEFAULT NULL COMMENT '付款备注',
  `splittrade` varchar(10) DEFAULT NULL COMMENT '是否分账交易',
  `group_profit_percent` decimal(8,6) DEFAULT NULL COMMENT '管理方分润比例',
  `group_profit_amount` decimal(18,2) DEFAULT NULL COMMENT '管理方分润金额',
  `shop_behalf_type` varchar(2) DEFAULT NULL COMMENT '商户代付模式',
  `revoketime` datetime DEFAULT NULL COMMENT '撤销时间',
  `batchno` varchar(20) DEFAULT NULL COMMENT '批量入账流水',
  `paytype` varchar(16) DEFAULT NULL COMMENT '交易类型',
  `orderrefundstatus` varchar(2) DEFAULT NULL COMMENT '退款方式',
  `needbehalfpay` varchar(2) DEFAULT NULL COMMENT '标记趣街代付还是易生代付',
  `refundreason` varchar(128) DEFAULT NULL COMMENT '退款原因',
  `originordernum` varchar(36) DEFAULT NULL COMMENT '退款的正向交易订单号',
  `behalfpayrequestid` varchar(36) DEFAULT NULL COMMENT '代付流水号',
  `behalfpayaddtime` datetime DEFAULT NULL COMMENT '代付发起时间',
  `realrebateamount` decimal(18,2) DEFAULT NULL COMMENT '实际使用返利额度',
  `remainingrebateamount` decimal(18,2) DEFAULT NULL COMMENT '剩余返利额度',
  `traderecordcoupon` text DEFAULT NULL COMMENT '使用的优惠券(text)',
  `acctname` varchar(64) DEFAULT NULL COMMENT '转入账户名称',
  `cashbackamount` decimal(18,2) DEFAULT NULL COMMENT '返现金额',
  `monthtradeup` decimal(18,2) DEFAULT NULL COMMENT '月返利额度',
  `channelorgid` varchar(32) DEFAULT NULL COMMENT '渠道机构号',
  `plattype` varchar(16) DEFAULT NULL COMMENT '平台类型',
  `updatetime` datetime DEFAULT NULL COMMENT '更新日期',
  `refundorder` varchar(36) DEFAULT NULL COMMENT '退款订单号',
  `refundtradecode` varchar(36) DEFAULT NULL COMMENT '退款银行流水',
  `refundsuctime` datetime DEFAULT NULL COMMENT '退款成功时间',
  `refundamount` decimal(18,2) DEFAULT NULL COMMENT '客户实际退款金额',
  `merchantrefundamt` decimal(18,2) DEFAULT NULL COMMENT '商户退款金额',
  `refundtradefee` decimal(18,2) DEFAULT NULL COMMENT '平台手续费退款',
  `flushplatdifference` decimal(18,2) DEFAULT NULL COMMENT '冲正平台减免',
  `flusvaccountdifference` decimal(18,2) DEFAULT NULL COMMENT '冲正零钱减免',
  `charger` decimal(18,2) DEFAULT NULL COMMENT '手续费承担方',
  `groupbehalftype` varchar(2) DEFAULT NULL COMMENT '集团到账模式',
  `groupactivityid` varchar(36) DEFAULT NULL COMMENT '分润活动id',
  `shopsplitscale` decimal(8,6) DEFAULT NULL COMMENT '商户分账比例',
  `shopsplitamount` decimal(18,2) DEFAULT NULL COMMENT '商户分账金额',
  `groupsplitamount` decimal(18,2) DEFAULT NULL COMMENT '集群分账金额',
  `prebehalfdate` date DEFAULT NULL COMMENT '预代付日期',
  `splitplatformreduce` decimal(18,2) DEFAULT NULL COMMENT '平台补贴分账金额',
  `splitshopreduce` decimal(18,2) DEFAULT NULL COMMENT '商户优惠分账金额',
  `batch` varchar(32) DEFAULT NULL COMMENT '批量代付标记',
  `appid` varchar(32) DEFAULT NULL COMMENT '应用ID',
  `outtradeno` varchar(36) DEFAULT NULL COMMENT '商户订单流水号',
  `preorderno` varchar(36) DEFAULT NULL COMMENT '预下单流水号',
  `appname` varchar(64) DEFAULT NULL COMMENT '应用名称',
  `outrefundno` varchar(36) DEFAULT NULL COMMENT '外部退款流水号',
  `refundsendtime` datetime DEFAULT NULL COMMENT '退款发往渠道方时间',
  `failreason` varchar(255) DEFAULT NULL COMMENT '退款失败原因',
  `del` varchar(2) DEFAULT NULL COMMENT '是否逻辑删除',
  `templateid` varchar(36) DEFAULT NULL COMMENT '券模版id',
  `orderamount` decimal(18,2) DEFAULT NULL COMMENT '原支付订单金额',
  `hbfqnum` int(11) DEFAULT NULL COMMENT '分期数',
  `extresmsg` varchar(255) DEFAULT NULL COMMENT '下单失败原因',
  `clusterids` json DEFAULT NULL COMMENT '商户所属集群id',
  `groupids` json DEFAULT NULL COMMENT '管理方id',
  `rebatescale` decimal(8,6) DEFAULT NULL COMMENT '返利比例',
  `equipname` varchar(64) DEFAULT NULL COMMENT '收款设备名称',
  `employeeid` varchar(32) DEFAULT NULL COMMENT '员工编号',
  `addtime` datetime DEFAULT NULL COMMENT '建单时间',
  `tradefee` decimal(18,2) DEFAULT NULL COMMENT '支付手续费（商家收款金额）',
  `orgsucctime` datetime DEFAULT NULL,
  `splitType` varchar(2) DEFAULT NULL COMMENT '交易分账类型：00-不分账 01-异步接口分账 02-同步分账',
  `ext_info` json DEFAULT NULL COMMENT '扩展字段信息',
  `pCode` varchar(64) DEFAULT NULL COMMENT '省',
  `cityCode` varchar(64) DEFAULT NULL COMMENT '市',
  `districtCode` varchar(64) DEFAULT NULL COMMENT '区',
  `shopType` int(11) DEFAULT NULL COMMENT '店铺一级分类',
  `smTypeId` int(11) DEFAULT NULL COMMENT '店铺二级分类',
  `finType` varchar(16) DEFAULT NULL COMMENT '金融归属  tjbank:天津银行 zxbank:振兴银行，空是天津银行',
  PRIMARY KEY (`recorddate`, `ordernum`, `shopid`),
  INDEX idx_clusterids((CAST(clusterids->'$[*]' AS UNSIGNED ARRAY))),
  INDEX idx_groupids((CAST(groupids->'$[*]' AS char(64) ARRAY)))
);

UPDATE `trade`.`tx_smpay_traderecord` SET`behalfpaystatus` = '3';
select current_user();

drop database trade;

connect(sys_conn, $OBMYSQL_MS0, root,,oceanbase, $OBMYSQL_PORT);
connection sys_conn;
drop user u1;
