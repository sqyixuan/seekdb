# owner: lixia.yq
# owner group: storage
# description test major with fulltext index

connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connect(conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection sys_conn;
alter system set _enable_add_fulltext_index_to_existing_table = true;

connection conn1;
--disable_warnings
DROP TABLE IF EXISTS articles;
--enable_warnings

--result_format 3

--echo ######## Create Table With Auto Increment Column #########
--echo ======================== create ==========================
--disable_warnings
CREATE TABLE articles (
    id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    title VARCHAR(200),
    content TEXT,
    FULLTEXT INDEX ctx1(title, content),
    FULLTEXT INDEX ctx2(title, content),
    FULLTEXT INDEX ctx3(title, content),
    INDEX idx1(title) global,
    INDEX idx2(title, id) local
) partition by hash(id) partitions 3;
--enable_warnings

INSERT INTO articles (title, content) VALUES
('OceanBase Tutorial', 'This is a tutorial about Oceanbase Fulltext.'),
('Fulltext Index', 'Fulltext index can be very useful.'),
('OceanBase Test Case', 'Writing test cases helps ensure quality.');

connection sys_conn;
alter system major freeze tenant sys;
sleep 10;
--source mysql_test/include/wait_daily_merge.inc

connection sys_conn;
alter system major freeze tenant sys;
sleep 10;

connection conn1;
alter table articles drop index idx2;
alter table articles drop index ctx2;

--source mysql_test/include/wait_daily_merge.inc

connection sys_conn;
alter system major freeze tenant sys;
sleep 10;

connection conn1;
alter table articles drop index ctx1;
alter table articles drop index ctx3;

--source mysql_test/include/wait_daily_merge.inc
