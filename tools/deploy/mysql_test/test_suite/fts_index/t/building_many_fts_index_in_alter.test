# owner: youchuan.yc
# owner group: storage
# description: test building many fulltext or multivalue indexes at the same time

connect (conn_sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection conn_sys;
alter system set _enable_drop_and_add_index = true;
alter system set _enable_add_fulltext_index_to_existing_table = true;

--disable_query_log
drop table if exists t0;
--enable_query_log

create table t0 (id int, c1 varchar(20), c2 varchar(20), c3 json, c4 json);

create fulltext index idx0 on t0(c1);
alter table t0 drop index idx0, add fulltext index idx1(c2);

alter table t0 add fulltext index idx0(c1), drop index idx1;

create fulltext index idx1 on t0(c2);
alter table t0 drop index idx0, drop index idx1;

--error 4179
alter table t0 add fulltext index idx0(c1), add fulltext index idx1(c2);

--error 4179
alter table t0 add index idx1( (CAST(c3->'$.zipcode' AS UNSIGNED ARRAY)) ), add index idx2( (CAST(c4->'$.zipcode' AS UNSIGNED ARRAY)) );

--error 4179
alter table t0 add fulltext index idx0(c1), add index idx1( (CAST(c3->'$.zipcode' AS UNSIGNED ARRAY)) );

alter table t0 add index idx0(c1), add index idx1(c2);

drop table t0;

connection conn_sys;
alter system set _enable_drop_and_add_index = false;
alter system set _enable_add_fulltext_index_to_existing_table = false;