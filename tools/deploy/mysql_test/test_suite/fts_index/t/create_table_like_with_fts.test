# owner: youchuan.yc
# owner group: storage
# description: 
connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connection sys_conn;
alter system set _enable_add_fulltext_index_to_existing_table = true;

connect(mysql_conn, $OBMYSQL_MS0, root@sys,,test, $OBMYSQL_PORT);
connection mysql_conn;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
--enable_warnings
create table t1 (c1 varchar(255), fulltext index(c1) with parser IK);
create table t2 like t1;

create table t3 (c1 varchar(255));
create fulltext index idx on t3(c1) with parser IK;
create table t4 like t3;

--disable_warnings
drop table t1;
drop table t2;
drop table t3;
drop table t4;
--enable_warnings


connection sys_conn;
alter system set _enable_add_fulltext_index_to_existing_table = false;
