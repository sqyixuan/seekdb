CREATE TABLE `employee` (  `employee_id` int(11) NOT NULL AUTO_INCREMENT,  `first_name` varchar(50) NOT NULL,  `last_name` varchar(50) NOT NULL,  `position1` varchar(50) DEFAULT NULL,  `position` varchar(50) DEFAULT NULL,  `department` varchar(50) DEFAULT NULL,  `hire_date` date DEFAULT NULL,  `salary` decimal(10,2) DEFAULT NULL,  PRIMARY KEY (`employee_id`),  FULLTEXT KEY `index_i1` (`first_name`, `last_name`, `position`) WITH PARSER space BLOCK_SIZE 16384,  FULLTEXT KEY `index_i2` (`first_name`, `last_name`, `position`, `position1`) WITH PARSER space BLOCK_SIZE 16384,  KEY `index_i10` (`position`) BLOCK_SIZE 16384 LOCAL,  KEY `index_11` (`position`) BLOCK_SIZE 16384 LOCAL);  
select * from  employee USE INDEX (index_i1) where match(`first_name`, `last_name`, `position`) against("Hughes1") or employee_id > 10;

