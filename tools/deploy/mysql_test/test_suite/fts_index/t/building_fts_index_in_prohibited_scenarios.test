--disable_warnings
drop table if exists t9;
--enable_warnings
alter system set ob_vector_memory_limit_percentage = 44;
sleep 3;
--error 1061
create table t9(
id bigint, 
vec1 vector(3),
vector index rowkey_vid_table(vec1) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200));

--error 1061
create table t9(
id bigint, 
vec1 vector(3),
vector index vid_rowkey_table(vec1) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200));

--error 1061
create table t9(
id bigint, 
vec1 vector(3),
vec2 vector(3),
vector index idx(vec1) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200),
vector index idx_index_id_table(vec2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200));

--error 1061
create table t9(
id bigint, 
vec1 vector(3),
vec2 vector(3),
vector index idx(vec1) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200),
vector index idx_index_snapshot_data_table(vec2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200));

--error 1061
create table t9(
id bigint, 
vec1 vector(3),
vec2 vector(3),
vector index idx_index_snapshot_data_table(vec1) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200),
vector index idx(vec2) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200));

create table t9(
id bigint, 
vec1 vector(3),
vector index idx1(vec1) with (distance=L2, type=hnsw, lib=vsag, m=20, ef_construction=200, ef_search=200));

drop table t9;

--disable_warnings
drop table if exists t10;
--enable_warnings
create table t10(id bigint, vec1 vector(3), vec2 vector(3), vec3 vector(3));

--error 1061
create vector index rowkey_vid_table on t10(vec1) with (distance=l2, type=hnsw);
--error 1061
create vector index vid_rowkey_table on t10(vec1) with (distance=l2, type=hnsw);

create vector index idx on t10(vec1) with (distance=l2, type=hnsw);
--error 1061
create vector index idx_index_id_table on t10(vec2) with (distance=l2, type=hnsw);
--error 1061
create vector index idx_index_snapshot_data_table on t10(vec2) with (distance=l2, type=hnsw);

drop index idx on t10;

create vector index idx_index_id_table on t10(vec2) with (distance=l2, type=hnsw);
--error 1061
create vector index idx on t10(vec1) with (distance=l2, type=hnsw);

drop index idx_index_id_table on t10;

create vector index idx1 on t10(vec1) with (distance=l2, type=hnsw);
create vector index idx2 on t10(vec2) with (distance=l2, type=hnsw);
create vector index idx3 on t10(vec3) with (distance=l2, type=hnsw);

drop table t10;


--echo ##### case 4: it is prohibited to drop a fts index and rename another index to the name of the dropped index within the same statement #####
--disable_warnings
drop table if exists t11;
--enable_warnings
create table t11 (id int, c0 varchar(255), c1 varchar(255), c2 json);

create index idx on t11(id);
create fulltext index fts_idx0 on t11(c0);
create fulltext index fts_idx1 on t11(c1);
create index m_idx0 on t11( (CAST(c2->'$.zipcode' AS UNSIGNED ARRAY)) );

--error 1235
alter table t11 drop index fts_idx0, rename index idx to fts_idx0;

--error 1235
alter table t11 drop index fts_idx0, rename index fts_idx1 to fts_idx0;

--error 1235
alter table t11 drop index m_idx0, rename index idx to m_idx0;

--error 1235
alter table t11 drop index fts_idx0, drop index fts_idx1, rename index idx to fts_idx0;

alter table t11 drop index idx, rename index fts_idx0 to idx;

alter table t11 drop index fts_idx1, rename index idx to normal_idx;

--echo ##### case 5: building fts index on the string type column  #####
--disable_warnings
drop table if exists t12, t12_1, t12_2, t12_3, t12_4, t12_5, t12_6, t12_7, t12_8;
--enable_warnings
create table t12_1 (c1 int, c2 string, primary key(c1, c2), fulltext index idx(c2));
create table t12_2 (c1 int, c2 string, fulltext index idx(c2));
create table t12_3 (c1 int, c2 string, c3 varchar(255), fulltext index idx(c2, c3));
create table t12_4 (c1 int, c2 string, c3 tinytext, fulltext index idx(c2, c3));
create table t12_5 (c1 int, c2 string, c3 text, fulltext index idx(c2, c3));
create table t12_6 (c1 int, c2 string, c3 mediumtext, fulltext index idx(c2, c3));
create table t12_7 (c1 int, c2 string, c3 longtext, fulltext index idx(c2, c3));
create table t12_8 (
  c1 int, c2 varchar(255), c3 tinytext, c4 text, c5 mediumtext, c6 longtext, c7 string,
  fulltext index idx(c2, c3, c4, c5, c6, c7));

create table t12 (c1 int, c2 varchar(255), c3 tinytext, c4 text, c5 mediumtext, c6 longtext, c7 string, c8 string, primary key (c1, c7));
create fulltext index idx_c7_1 on t12(c7);
alter table t12 add fulltext index idx_c8(c8);
create fulltext index idx_c2_c7 on t12(c2, c7);
alter table t12 add fulltext index idx_c3_c7(c3, c7);
create fulltext index idx_c4_c7 on t12(c4, c7);
alter table t12 add fulltext index idx_c5_c7(c5, c7);
create fulltext index idx_c6_c7 on t12(c6, c7);
alter table t12 add fulltext index idx_c6_c8(c6, c8);

drop table t12, t12_1, t12_2, t12_3, t12_4, t12_5, t12_6, t12_7, t12_8;

--echo ##### case 6: ban create table with domain index and auto split attribute #####
--disable_warnings
drop table if exists t13;
drop table if exists t14;
drop table if exists t15;
drop table if exists t16;
drop table if exists t17;
drop table if exists t18;
drop table if exists t19;
drop table if exists t20;
--enable_warnings
alter system set enable_auto_split = false;
sleep 1;

--error 1235
create table t13 (c0 int primary key, c1 varchar(255), fulltext index idx(c1)) partition by range () size('128MB');

create table t13 (c0 int primary key, c1 varchar(255), fulltext index idx(c1));

alter system set enable_auto_split = true;
sleep 1;

--error 1235
create table t14 (c0 int primary key, c1 varchar(255), fulltext index idx(c1)) partition by range () size('128MB');

create table t14 (c0 int primary key, c1 varchar(255), fulltext index idx(c1));


alter system set enable_auto_split = false;
sleep 1;

--error 1235
create table t15 (c0 int primary key, c1 json, index idx( (CAST(c1->'$.zipcode' AS UNSIGNED ARRAY)) )) partition by range () size('128MB');

create table t15 (c0 int primary key, c1 json, index idx( (CAST(c1->'$.zipcode' AS UNSIGNED ARRAY)) ));

alter system set enable_auto_split = true;
sleep 1;

--error 1235
create table t16 (c0 int primary key, c1 json, index idx( (CAST(c1->'$.zipcode' AS UNSIGNED ARRAY)) )) partition by range () size('128MB');

create table t16 (c0 int primary key, c1 varchar(255), index idx( (CAST(c1->'$.zipcode' AS UNSIGNED ARRAY)) ));

alter system set ob_vector_memory_limit_percentage = 44;
alter system set enable_auto_split = false;
sleep 1;

--error 1235
create table t17 (c0 int primary key, c1 vector(20), vector index idx42(c1) with (distance=L2, type=hnsw)) partition by range () size('128MB');

create table t17 (c0 int primary key, c1 vector(20), vector index idx42(c1) with (distance=L2, type=hnsw));

alter system set enable_auto_split = true;
sleep 1;

--error 1235
create table t18 (c0 int primary key, c1 vector(20), vector index idx42(c1) with (distance=L2, type=hnsw)) partition by range () size('128MB');

create table t18 (c0 int primary key, c1 vector(20), vector index idx42(c1) with (distance=L2, type=hnsw));


alter system set enable_auto_split = false;
sleep 1;

--error 1235
create table t19 (k int primary key, geom geometry NOT NULL, spatial index (geom)) partition by range () size('128MB');

create table t19 (k int primary key, geom geometry NOT NULL, spatial index (geom));

alter system set enable_auto_split = true;
sleep 1;

--error 1235
create table t20 (k int primary key, geom geometry NOT NULL, spatial index (geom)) partition by range () size('128MB');

create table t20 (k int primary key, geom geometry NOT NULL, spatial index (geom));




