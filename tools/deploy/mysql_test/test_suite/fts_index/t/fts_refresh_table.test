# owner: yht146439
# owner group: storage
# description: test topK retrieval with FTS index using refresh table pattern
# notice: run this mysqltest using observer compiled with errsim

--disable_query_log
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
set @@session.explicit_defaults_for_timestamp=off;
set session ob_trx_timeout=100000000000;
set @@recyclebin = off;
--enable_query_log

connection conn1;
--disable_warnings
drop database if exists fts;
create database fts;
use fts;
drop table if exists t1;
--enable_warnings

# Create tables with FTS index
create table t1(
    id int,
    title varchar(512),
    content varchar(4096),
    category varchar(100),
    fulltext index i1(content) block_size = 1024
) COMPRESSION = 'none';

--disable_query_log

# Insert initial data
let $cnt = 1;
while($cnt <= 400)
{
    eval insert into t1(id, title, content, category) values ($cnt, concat('Title ', $cnt), concat($cnt, 'distributed database management system with high availability and scalability features'), 'Category1');
    eval insert into t1(id, title, content, category) values ($cnt, concat('Title ', $cnt), concat($cnt, 'relational database system designed for enterprise applications and transaction processing'), 'Category1');
    eval insert into t1(id, title, content, category) values ($cnt, concat('Title ', $cnt), concat($cnt, 'cloud-native database platform supporting multi-tenant architecture and elastic scaling'), 'Category1');
    eval insert into t1(id, title, content, category) values ($cnt, concat('Title ', $cnt), concat($cnt, 'document storage system optimized for modern web applications and JSON data processing'), 'Category1');
    eval insert into t1(id, title, content, category) values ($cnt, concat('Title ', $cnt), concat($cnt, 'in-memory database engine providing ultra-fast data access and real-time analytics capabilities'), 'Category1');
    inc $cnt;
    inc $cnt;
    inc $cnt;
    inc $cnt;
    inc $cnt;
}
--enable_query_log

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

--disable_query_log
connection conn1;
use fts;

# Update some data to create minor sstable
let $cnt = 401;
while($cnt <= 800)
{
    eval insert into t1(id, title, content, category) values ($cnt, concat('Inserted Title ', $cnt), concat('updated document database system ', $cnt, ' with new content'), 'Category1');
    eval insert into t1(id, title, content, category) values ($cnt, concat('Inserted Title ', $cnt), concat('enhanced info ', $cnt, ': fulltext index test'), 'Category1');
    inc $cnt;
    inc $cnt;
}

--enable_query_log

# Minor freeze to create minor sstable
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

--disable_query_log
connection conn1;
use fts;

connection syscon;
--error 0, 1210
alter system set_tp tp_name = "EN_FORCE_REFRESH_TABLE", error_code = 4016, frequency = 1;
--enable_query_log

connection conn1;
use fts;

# Select data with topK retrieval
select id, title, match(content) against('database system') as relevance from t1 where match(content) against('database system') limit 1;
select id, title, match(content) against('database system') as relevance from t1 where match(content) against('database system') limit 2;
select id, title, match(content) against('database system') as relevance from t1 where match(content) against('database system') limit 3;
select id, title, match(content) against('distributed database management system') as relevance from t1 where match(content) against('distributed database management system') limit 1;
select id, title, match(content) against('distributed database management system') as relevance from t1 where match(content) against('distributed database management system') limit 5;
select id, title, match(content) against('distributed database management system') as relevance from t1 where match(content) against('distributed database management system') limit 10;

connection syscon;
--error 0, 1210
alter system set_tp tp_name = "EN_FORCE_REFRESH_TABLE", error_code = 4016, frequency = 0;
--enable_query_log

connection conn1;
drop database fts;