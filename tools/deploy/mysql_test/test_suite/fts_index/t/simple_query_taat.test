# owner: zyx439997
# owner group: storage
# description: basic text retrieval query with fulltext index by taat mode

--disable_warnings
drop database if exists fts;
create database fts;
use fts;
set ob_query_timeout = 10000000000;
--enable_warnings

--result_format 4

# simple Test
create table fts_test(
  seq_id int,
  detail varchar(4096),
  fulltext index i1(detail) WITH PARSER beng);

--disable_warnings
# The following test is currently not in effect. This test is only for local testing and can only be used after modifying the mode(from daat to taat).
select * from fts_test where match(detail) against('test1');
select * from fts_test where match(detail) against('');
select * from fts_test where match(detail) against('test1 test2 but');
select/*+ opt_param('rowsets_enabled', 'false') */ * from fts_test where match(detail) against('test1');
select/*+ opt_param('rowsets_enabled', 'false') */* from fts_test where match(detail) against('');
select/*+ opt_param('rowsets_enabled', 'false') */ * from fts_test where match(detail) against('test1 test2 but');
# over
--enable_warnings

