# owner: zyx439997
# owner group: storage
# description: text retrieval query with functional lookup

--disable_warnings
drop database if exists fts;
create database fts;
use fts;
--enable_warnings

create table t_ir_single_column(
  digest varchar(512),
  detail varchar(262144),
  seq int,
  fulltext index i1(detail),
  fulltext index i2(digest, detail),
  index i3(seq));


# insert 520
--disable_query_log
begin;
--let $loop=100
while($loop > 0)
{
    eval insert into t_ir_single_column (digest, detail, seq) values (CONCAT('test ',$loop), repeat(rand(),10000), 100 - $loop);
    dec $loop;
}
commit;
--enable_query_log
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

explain select * from t_ir_single_column where true or match(digest, detail) against('test');
--disable_result_log
select * from t_ir_single_column where true or match(digest, detail) against('test');
--enable_result_log

--disable_warnings
drop table if exists t_ir_single_column;
drop database fts;
--enable_warnings
