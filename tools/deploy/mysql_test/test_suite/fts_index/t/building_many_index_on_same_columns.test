# owner: youchuan.yc
# owner group: storage
# description: test building many index on same columns

connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connect(mysql_conn, $OBMYSQL_MS0, root,,test, $OBMYSQL_PORT);

connection sys_conn;
alter system set _enable_add_fulltext_index_to_existing_table = true;
sleep 3;

connection mysql_conn;
--disable_warnings
drop table if exists t;
--enable_warnings

create table t (id int, c1 varchar(20), c2 varchar(20), c3 varchar(20), c4 varchar(20), c5 varchar(20));

create fulltext index idx1 on t(c1);
show warnings;
create fulltext index idx2 on t(c1);
show warnings;

create fulltext index idx3 on t(c1, c2);
show warnings;
create fulltext index idx4 on t(c1, c2);
show warnings;

create fulltext index idx5 on t(c1, c2, c3);
show warnings;
create fulltext index idx6 on t(c1, c2, c3);
show warnings;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (id int, c1 varchar(20), c2 varchar(20), c3 varchar(20), c4 varchar(20), c5 varchar(20));

alter table t1 add fulltext index idx7(c1);
show warnings;
alter table t1 add fulltext index idx8(c1);
show warnings;

alter table t1 add fulltext index idx9(c1, c2);
show warnings;
alter table t1 add fulltext index idx10(c1, c2);
show warnings;

alter table t1 add fulltext index idx11(c1, c2, c3);
show warnings;
alter table t1 add fulltext index idx12(c1, c2, c3);
show warnings;

drop table t;
drop table t1;

connection sys_conn;
alter system set _enable_add_fulltext_index_to_existing_table = false;
