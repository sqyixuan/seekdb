# owner: zyx439997
# owner group: storage
# description: fix bug

--disable_warnings
drop database if exists fts;
create database fts;
use fts;
--enable_warnings

alter system set _enable_decimal_int_type = false;
CREATE TABLE articles ( id INT UNSIGNED AUTO_INCREMENT NOT NULL PRIMARY KEY, title VARCHAR(200), body TEXT, FULLTEXT (title,body) ) ;
INSERT INTO articles (title, body) VALUES ('test for session stopwords','this should also be excluded...');
SELECT * FROM articles WHERE MATCH (title,body) AGAINST ('session' IN NATURAL LANGUAGE MODE);
alter system set _enable_decimal_int_type = true;

--disable_warnings
drop table if exists articles;
drop database fts;
--enable_warnings
