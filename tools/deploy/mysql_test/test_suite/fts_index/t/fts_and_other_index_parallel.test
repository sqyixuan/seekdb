# owner: youchuan.yc
# owner group: storage
# description: 

connect (conn_sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);

connection conn_sys;
alter system set debug_sync_timeout = '100s';
alter system set _enable_add_fulltext_index_to_existing_table = true;
sleep 3;

--echo
--echo
--echo "================================== parallel create fts and create fts ==================================="
# BUILD_FTS_INDEX_PREPARE_STATUS

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BUILD_FTS_INDEX_PREPARE_STATUS wait_for continue_signal execute 10000';

connect (conn_user,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn_user;

--disable_warnings
drop database if exists fts_and_other_index;
--enable_warnings

create database fts_and_other_index;

connect (conn_user1,$OBMYSQL_MS0,root,,fts_and_other_index,$OBMYSQL_PORT);
connect (conn_user2,$OBMYSQL_MS0,root,,fts_and_other_index,$OBMYSQL_PORT);
connection conn_user1;
--disable_warnings
drop table if exists t3;
--enable_warnings
create table t3(c1 int, c2 varchar(255), c3 varchar(255), primary key(c1));
sleep 2;

connection conn_user1;
send create fulltext index idx1 on t3(c2);

connection conn_user2;
send create fulltext index idx2 on t3(c3);

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now broadcast continue_signal';
sleep 3;

connection conn_user1;
reap;

connection conn_user2;
reap;

connection conn_user;
select count(*) from oceanbase.__all_table where index_status = 2 and data_table_id = (select table_id from oceanbase.__all_table where table_name = 't3' and database_id = (SELECT database_id FROM oceanbase.__all_database WHERE database_name = 'fts_and_other_index'));

--echo
--echo
--echo "================================== parallel create fts and create multivalue ==================================="
# BUILD_FTS_INDEX_PREPARE_STATUS

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BUILD_FTS_INDEX_PREPARE_STATUS wait_for continue_signal execute 10000';

connection conn_user1;
--disable_warnings
drop table if exists t3;
--enable_warnings
create table t3(c1 int, c2 varchar(255), c3 json, primary key(c1));
sleep 2;

connection conn_user1;
send create fulltext index idx1 on t3(c2);

connection conn_user2;
send create index idx2 on t3 ( (CAST(c3->'$.zipcode' AS UNSIGNED ARRAY)) );

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now broadcast continue_signal';
sleep 3;

connection conn_user1;
reap;

connection conn_user2;
reap;

connection conn_user;
select count(*) from oceanbase.__all_table where index_status = 2 and data_table_id = (select table_id from oceanbase.__all_table where table_name = 't3' and database_id = (SELECT database_id FROM oceanbase.__all_database WHERE database_name = 'fts_and_other_index'));

--echo
--echo
--echo "================================== parallel create fts and create normal index ==================================="
# BUILD_FTS_INDEX_PREPARE_STATUS

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BUILD_FTS_INDEX_PREPARE_STATUS wait_for continue_signal_build_fts execute 10000';

connection conn_user1;
--disable_warnings
drop table if exists t3;
--enable_warnings
create table t3(c1 int, c2 varchar(255), c3 bigint, primary key(c1));
sleep 2;

connection conn_user1;
send create fulltext index idx1 on t3(c2);

connection conn_user2;
send create index idx2 on t3(c3);

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now broadcast continue_signal_build_fts';
sleep 3;

connection conn_user1;
reap;

connection conn_user2;
reap;

connection conn_user;
select count(*) from oceanbase.__all_table where index_status = 2 and data_table_id = (select table_id from oceanbase.__all_table where table_name = 't3' and database_id = (SELECT database_id FROM oceanbase.__all_database WHERE database_name = 'fts_and_other_index'));

--echo
--echo
--echo "================================== parallel create fts and drop normal ==================================="
# BUILD_FTS_INDEX_PREPARE_STATUS

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BUILD_FTS_INDEX_PREPARE_STATUS wait_for continue_signal execute 10000';

connection conn_user1;
--disable_warnings
drop table if exists t3;
--enable_warnings
create table t3(c1 int, c2 bigint, c3 varchar(255), primary key(c1));
sleep 2;

connection conn_user1;
create index idx1 on t3(c2);
send create fulltext index idx2 on t3(c3);

connection conn_user2;
send drop index idx1 on t3;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now broadcast continue_signal';
sleep 3;

connection conn_user1;
reap;

connection conn_user2;
reap;

connection conn_user;
select count(*) from oceanbase.__all_table where index_status = 2 and data_table_id = (select table_id from oceanbase.__all_table where table_name = 't3' and database_id = (SELECT database_id FROM oceanbase.__all_database WHERE database_name = 'fts_and_other_index'));

--echo
--echo
--echo "================================== test rename fts and drop fts ==================================="
# 1. test the fts index is not exists
connection conn_user1;
--disable_warnings
drop table if exists t_for_rename;
--enable_warnings
create table t_for_rename (id int, name varchar(20));
insert into t_for_rename (id, name) values (0, 'John Doe'), (1, 'Jane Smith'), (2, 'Alice Johnson');
--error 1176
alter table t_for_rename rename index idx0 to deleted;

# 2. test drop fts index and rename fts index parallel
# 2.1 first, make rename task stop at rs
connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_RENAME_INDEX wait_for continue_signal_0 execute 10000';
set ob_global_debug_sync = 'DROP_FTS_INDEX_PREPARE_STATUS wait_for continue_signal_1 execute 10000';

connection conn_user1;
--disable_warnings
drop table if exists t_for_rename;
--enable_warnings
create table t_for_rename (c1 int, c2 bigint, c3 varchar(255), primary key(c1));
create fulltext index idx0 on t_for_rename(c3);

send alter table t_for_rename rename index idx0 to deleted;
sleep 3;

connection conn_user2;
send alter table t_for_rename drop index idx0;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now broadcast continue_signal_0';
set ob_global_debug_sync = 'now broadcast continue_signal_1';
sleep 3;

connection conn_user1;
reap;

connection conn_user2;
--error 1091
reap;

# 2.2 second, make drop task stop at rs
connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_RENAME_INDEX wait_for continue_signal_0 execute 10000';
set ob_global_debug_sync = 'DROP_FTS_INDEX_PREPARE_STATUS wait_for continue_signal_1 execute 10000';

connection conn_user1;
--disable_warnings
drop table if exists t_for_rename;
--enable_warnings
create table t_for_rename (c1 int, c2 bigint, c3 varchar(255), primary key(c1));
create fulltext index idx0 on t_for_rename(c3);

connection conn_user2;
send alter table t_for_rename drop index idx0;
sleep 3;

connection conn_user1;
send alter table t_for_rename rename index idx0 to deleted;
sleep 3;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now broadcast continue_signal_0';
set ob_global_debug_sync = 'now broadcast continue_signal_1';
sleep 3;

connection conn_user1;
reap;

connection conn_user2;
reap;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_RENAME_INDEX wait_for continue_signal_0 execute 10000';
set ob_global_debug_sync = 'AFTER_DROP_FTS_SUBMIT_SUBTASK wait_for continue_signal_1 execute 10000';

connection conn_user1;
--disable_warnings
drop table if exists t_for_rename;
--enable_warnings
create table t_for_rename (c1 int, c2 bigint, c3 varchar(255), primary key(c1));
create fulltext index idx0 on t_for_rename(c3);

connection conn_user2;
send alter table t_for_rename drop index idx0;
sleep 5;

connection conn_user1;
send alter table t_for_rename rename index idx0 to deleted;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now broadcast continue_signal_0';
set ob_global_debug_sync = 'now broadcast continue_signal_1';
sleep 3;

connection conn_user1;
--error 1176
reap;

connection conn_user2;
reap;

connection conn_user;

drop database fts_and_other_index;

connection conn_sys;
alter system set debug_sync_timeout = 0;
alter system set _enable_add_fulltext_index_to_existing_table = false;