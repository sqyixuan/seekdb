# owner: yunshan.tys
# owner group: storage
# description: test alter table add fulltext index

connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connection sys_conn;

--disable_warnings
DROP TABLE IF EXISTS fts_table_1;
DROP TABLE IF EXISTS fts_table_add_not_default_parser;
--enable_warnings

# create table with no fulltext index:
CREATE TABLE fts_table_1 (
  id int primary key,
  name varchar(20),
  title varchar(20),
  content varchar(20));

CREATE TABLE fts_table_add_not_default_parser (
  id int,
  name varchar(20),
  title varchar(20),
  content varchar(20));

alter system set _enable_add_fulltext_index_to_existing_table = true;


--echo ================= Try parser with a given parser ========================
ALTER TABLE fts_table_add_not_default_parser add FULLTEXT INDEX fti_ngram(name) WITH PARSER ngram;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE fts_table_add_not_default_parser;

--disable_warnings
ALTER TABLE fts_table_add_not_default_parser add FULLTEXT INDEX fti_beng(name) WITH PARSER beng;
--enable_warnings
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE fts_table_add_not_default_parser;


--echo ================= add first fulltext index ========================
ALTER TABLE fts_table_1 add FULLTEXT INDEX f101(name) WITH PARSER space;

let $data_table_id = query_get_value(SELECT table_id
                                     FROM __all_virtual_table
                                     WHERE table_name = 'fts_table_1'
                                       AND tenant_id = 1, table_id, 1);

# check fts generate columns on fts_table_1 table
--echo ===== fts_table_1 columns =============
--disable_query_log
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $data_table_id
       AND tenant_id = 1;

# expect 4 fts aux index tables
--echo ===== fts index aux tables =====
eval SELECT count(*)
     FROM __all_virtual_table
     WHERE data_table_id = $data_table_id
       AND tenant_id = 1;
--enable_query_log

# get table id of 4 corresponding fts aux index table exists
let $rowkey_doc_table_id = query_get_value(
  SELECT table_id
  FROM __all_virtual_table
  WHERE index_type = 13
    AND tenant_id = 1
    AND data_table_id = $data_table_id, table_id, 1);
let $doc_rowkey_table_id = query_get_value(
  SELECT table_id
  FROM __all_virtual_table
  WHERE index_type = 14
    AND tenant_id = 1
    AND data_table_id = $data_table_id, table_id, 1);
let $f101_fts_index_table_id = query_get_value(
  SELECT table_id
  FROM __all_virtual_table
  WHERE table_name LIKE '%f101'
    AND index_type = 15
    AND tenant_id = 1
    AND data_table_id = $data_table_id, table_id, 1);
let $f101_fts_doc_word_table_id = query_get_value(
  SELECT table_id
  FROM __all_virtual_table
  WHERE table_name LIKE '%f101%'
    AND index_type = 16
    AND tenant_id = 1
    AND data_table_id = $data_table_id, table_id, 1);

--disable_query_log

--echo ===== fts_table_1 fts rowkey doc cols ===
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $rowkey_doc_table_id
       AND tenant_id = 1;

--echo ===== fts_table_1 fts doc rowkey cols ===
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $doc_rowkey_table_id
       AND tenant_id = 1;

--echo ===== f101 fts index cols ======
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $f101_fts_index_table_id
       AND tenant_id = 1;

--echo ===== f101 fts doc word cols ===
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $f101_fts_doc_word_table_id
       AND tenant_id = 1;

--echo ===== fts_table_1 fts rowkey doc parser ===
eval SELECT parser_name
     FROM __all_virtual_table
     WHERE table_id = $rowkey_doc_table_id
       AND tenant_id = 1;

--echo ===== fts_table_1 fts doc rowkey parser ===
eval SELECT parser_name
     FROM __all_virtual_table
     WHERE table_id = $doc_rowkey_table_id
       AND tenant_id = 1;

--echo ===== f101 fts index parser ======
eval SELECT parser_name
     FROM __all_virtual_table
     WHERE table_id = $f101_fts_index_table_id
       AND tenant_id = 1;

--echo ===== f101 fts doc word parser ===
eval SELECT parser_name
     FROM __all_virtual_table
     WHERE table_id = $f101_fts_doc_word_table_id
       AND tenant_id = 1;

--enable_query_log

--echo ================= add fulltext index again ========================
# add a new fulltext index on a table that already contains fulltext index
ALTER TABLE fts_table_1 add FULLTEXT INDEX f102(title, content) WITH PARSER ngram;

# check fts generate columns on fts_table_1 table
--echo ===== fts_table_1 columns =============
--disable_query_log
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $data_table_id
       AND tenant_id = 1;

# expect 6 fts aux index tables
--echo ===== fts index aux tables =====
eval SELECT count(*)
     FROM __all_virtual_table
     WHERE data_table_id = $data_table_id
       AND tenant_id = 1;
--enable_query_log

# get table id of 2 corresponding fts aux index table exists
let $f102_fts_index_table_id = query_get_value(
  SELECT table_id
  FROM __all_virtual_table
  WHERE table_name LIKE '%f102'
    AND index_type = 15
    AND tenant_id = 1
    AND data_table_id = $data_table_id, table_id, 1);
let $f102_fts_doc_word_table_id = query_get_value(
  SELECT table_id
  FROM __all_virtual_table
  WHERE table_name LIKE '%f102%'
    AND index_type = 16
    AND tenant_id = 1
    AND data_table_id = $data_table_id, table_id, 1);

--disable_query_log

--echo ===== f102 fts index cols ======
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $f102_fts_index_table_id
       AND tenant_id = 1;

--echo ===== f102 fts doc word cols ===
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $f102_fts_doc_word_table_id
       AND tenant_id = 1;

--echo ===== f102 fts index parser ======
eval SELECT parser_name
     FROM __all_virtual_table
     WHERE table_id = $f102_fts_index_table_id
       AND tenant_id = 1;

--echo ===== f102 fts doc word parser ===
eval SELECT parser_name
     FROM __all_virtual_table
     WHERE table_id = $f102_fts_doc_word_table_id
       AND tenant_id = 1;

--enable_query_log

--echo ================= add fulltext index again ========================
# add a new fulltext index on a table that already contains fulltext index
ALTER TABLE fts_table_1 add FULLTEXT INDEX f103(content);

# check fts generate columns on fts_table_1 table
--echo ===== fts_table_1 columns =============
--disable_query_log
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $data_table_id
       AND tenant_id = 1;

# expect 8 fts aux index tables
--echo ===== fts index aux tables =====
eval SELECT count(*)
     FROM __all_virtual_table
     WHERE data_table_id = $data_table_id
       AND tenant_id = 1;
--enable_query_log

# get table id of 2 corresponding fts aux index table exists
let $f103_fts_index_table_id = query_get_value(
  SELECT table_id
  FROM __all_virtual_table
  WHERE table_name LIKE '%f103'
    AND index_type = 15
    AND tenant_id = 1
    AND data_table_id = $data_table_id, table_id, 1);
let $f103_fts_doc_word_table_id = query_get_value(
  SELECT table_id
  FROM __all_virtual_table
  WHERE table_name LIKE '%f103%'
    AND index_type = 16
    AND tenant_id = 1
    AND data_table_id = $data_table_id, table_id, 1);

--disable_query_log

--echo ===== f103 fts index cols ======
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $f103_fts_index_table_id
       AND tenant_id = 1;

--echo ===== f103 fts doc word cols ===
eval SELECT column_id, REGEXP_REPLACE(column_name, '[0-9]+', '*') as column_name
     FROM __all_virtual_column
     WHERE table_id = $f103_fts_doc_word_table_id
       AND tenant_id = 1;

--echo ===== f103 fts index parser ======
eval SELECT parser_name
     FROM __all_virtual_table
     WHERE table_id = $f103_fts_index_table_id
       AND tenant_id = 1;

--echo ===== f103 fts doc word parser ===
eval SELECT parser_name
     FROM __all_virtual_table
     WHERE table_id = $f103_fts_doc_word_table_id
       AND tenant_id = 1;
--enable_query_log


--disable_warnings
drop table if exists t_for_alter_table_add_many_index;
--enable_warnings
create table t_for_alter_table_add_many_index (c1 int, c2 varchar(20));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_for_alter_table_add_many_index;

alter table t_for_alter_table_add_many_index add index i1 (c1) global, add fulltext index i2 (c2);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_for_alter_table_add_many_index;

alter table t_for_alter_table_add_many_index drop index i1, drop index i2;
alter table t_for_alter_table_add_many_index add fulltext index i1 (c2), add index i2 (c1) global;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_for_alter_table_add_many_index;

alter table t_for_alter_table_add_many_index drop index i1, drop index i2;
alter table t_for_alter_table_add_many_index add index i1 (c2) global, add index i2 (c1) global;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_for_alter_table_add_many_index;

alter table t_for_alter_table_add_many_index drop index i1, drop index i2;
alter table t_for_alter_table_add_many_index add index i1 (c2), add index i2 (c1);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_for_alter_table_add_many_index;

alter table t_for_alter_table_add_many_index drop index i1, drop index i2;
alter table t_for_alter_table_add_many_index add index i2 (c2) global, add index i1 (c1) global, add fulltext index i3 (c2);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_for_alter_table_add_many_index;

alter table t_for_alter_table_add_many_index drop index i1, drop index i2, drop index i3;
alter table t_for_alter_table_add_many_index add index i2 (c2) global, add index i1 (c1), add fulltext index i3 (c2);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_for_alter_table_add_many_index;

alter table t_for_alter_table_add_many_index drop index i1, drop index i2, drop index i3;
--error 4179
alter table t_for_alter_table_add_many_index add index i1 (c2) global, add fulltext index ft2 (c2) WITH PARSER ngram PARSER_PROPERTIES=(ngram_token_size=3), add fulltext index i3 (c2);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_for_alter_table_add_many_index;

--disable_warnings
drop table if exists t_for_alter_table_add_many_index;
--enable_warnings
disconnect sys_conn;


