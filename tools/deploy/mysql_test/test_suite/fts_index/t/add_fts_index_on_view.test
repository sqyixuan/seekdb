# owner: youchuan.yc
# owner group: storage
# description: test adding fts index on view table

connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connection sys_conn;

--disable_warnings
drop table if exists t;
drop view if exists v;
--enable_warnings
create table t(id int, c1 varchar(20), c2 text);
create view v as select * from t;

--error 1347
create fulltext index idx on v(c1);
--error 1347
alter table v add fulltext index idx(c1);

drop view v;
drop table t;