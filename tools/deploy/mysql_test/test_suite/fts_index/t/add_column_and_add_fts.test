# owner: youchuan.yc
# owner group: storage
# description: fixbug issue-2024102400104801936

connect (conn_sys,$OBMYSQL_MS0,root@sys,,test,$OBMYSQL_PORT);
connection conn_sys;
alter system set _enable_add_fulltext_index_to_existing_table = true;
sleep 3;

connect (conn_user,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn_user;
# alter system set ob_vector_memory_limit_percentage = 20;

--let $loop=1
while($loop > 0)
{
--disable_warnings
drop table if exists t;
--enable_warnings

if ($loop == 1) {
   let $primary_key=primary key;
} 
if ($loop == 2) {
   let $primary_key=;
}
eval create table t(id bigint $primary_key, c1 varchar(255), c2 json, c3 vector(3)); 
--error 1235
alter table t add column c4 int, add fulltext index idx(c1);
--error 1235
alter table t add column c4 int, add index idx( (CAST(c2->'$.zipcode' AS UNSIGNED ARRAY)) );
# TO DO: test vec index in the alter sentence
# --error 1235
# alter table t add column c4 int, add vector index idx(c3) with (distance=l2, type=hnsw);
drop table t;
dec $loop;
}

connection conn_sys;
alter system set _enable_add_fulltext_index_to_existing_table = false;
