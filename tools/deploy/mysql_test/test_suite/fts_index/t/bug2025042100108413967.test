# dml 禁掉 functional lookup
# owner: lijinmao.ljm
# owner group: sql1

--disable_warnings
DROP TABLE IF EXISTS test_fts7x;
--enable_warnings

CREATE TABLE `test_fts7x` (
  `pk1` int(11) NOT NULL,
  `pk2` int(11) NOT NULL,
  `first_name` varchar(100) DEFAULT NULL,
  `last_name` varchar(100) DEFAULT NULL,
  PRIMARY KEY (`pk1`, `pk2`),
  FULLTEXT KEY `last_name` (`last_name`) WITH PARSER ngram PARSER_PROPERTIES=(ngram_token_size=2) BLOCK_SIZE 16384,
  FULLTEXT KEY `last_name_2` (`last_name`, `first_name`) WITH PARSER ngram2 PARSER_PROPERTIES=(min_ngram_size=2,max_ngram_size=3) BLOCK_SIZE 16384,
  FULLTEXT KEY `first_name` (`first_name`) WITH PARSER space PARSER_PROPERTIES=(min_token_size=3,max_token_size=84) BLOCK_SIZE 16384
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'lz4_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 MERGE_ENGINE = DELETE_INSERT WITH COLUMN GROUP(each column);

insert into test_fts7x values(1,1,"fs","abc"), (2,2,"fs","abc"), (3,3,"fs","abc"), (4,4,"fs","abc"), (5,5,"fs","abc"), (6,6,"fs","abc"), (7,7,"fs","abc"), (8,8,"fs","abc"), (9,9,"fs","abc"), (10,10,"fs","abc");
insert into test_fts7x select pk1+10,pk2+10,"fs","abc" from test_fts7x;
insert into test_fts7x select pk1+20,pk2+20,"fs","abc" from test_fts7x;
insert into test_fts7x select pk1+40,pk2+40,"fs","abc" from test_fts7x;
insert into test_fts7x select pk1+80,pk2+80,"fs","abc" from test_fts7x;
insert into test_fts7x select pk1+160,pk2+160,"fs","abc" from test_fts7x;

--result_format 4

update test_fts7x set first_name="fs" where  pk1<500 and match(last_name) against("abc");
update test_fts7x set first_name="fs" where  pk1=10 and match(last_name) against("abc");
update /*+index(test_fts7x last_name)*/ test_fts7x set first_name="fs" where  pk1>10 and match(last_name) against("abc");
update /*+index(test_fts7x primary)*/ test_fts7x set first_name="fs" where  pk1>10 and match(last_name) against("abc");

drop table test_fts7x;