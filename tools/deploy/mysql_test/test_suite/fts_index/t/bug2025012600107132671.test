# match against 禁掉 nlj 条件下推
# owner: lijinmao.ljm
# owner group: sql1

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

alter system _enable_index_merge=false;

create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100), c5 varchar(100));
create FULLTEXT INDEX fidx4 ON t1(c4);
create index c2 on t1(c2) local;
create table t2 (c1 int primary key, c2 int, c3 int, c4 varchar(100), c5 varchar(100));

explain select a.c1,a.c3,b.c1 from t1 a inner join t1 b on a.c2 = b.c2 where a.c1 = 5 or (a.c3 < 390000 and MATCH(b.c4) AGAINST('鄂A1'));
--error 1235
explain select match(A.c4) against("xxxx") from t1 A left join lateral(select A.c1 as zz, A.c2 as yy from t2 where t2.c2=A.c1 order by A.c1,c2 limit 1 offset 1) B on match(A.c4) against("xxxx")=B.zz where B.zz is null order by match(c4) against("xxxx");

alter system _enable_index_merge=true;
drop table t1, t2;