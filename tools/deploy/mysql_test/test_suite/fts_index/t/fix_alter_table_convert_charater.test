
# owner: youchuan.yc
# owner group: storage
# description: test building fts index in prohibited scenarios

connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connect(mysql_conn, $OBMYSQL_MS0, root,,test, $OBMYSQL_PORT);

connection sys_conn;
alter system set _enable_add_fulltext_index_to_existing_table = true;
sleep 3;

--disable_warnings
drop table if exists test_fts12x;
--enable_warnings

CREATE TABLE `test_fts12x` (
  `col14` mediumtext DEFAULT NULL,
  `col16` char(30) DEFAULT NULL,
  `col12` int(11) DEFAULT NULL,
  `col7` varchar(163) DEFAULT '0',
  `col5` longtext DEFAULT NULL,
  `col15` bigint(20) DEFAULT NULL,
  `col9` text NOT NULL,
  `col4` varchar(29) DEFAULT '0',
  `col1` text DEFAULT NULL,
  `col6` text DEFAULT NULL,
  `col2` text DEFAULT NULL,
  `col10` varchar(200) NOT NULL,
  `pk1` int(11) DEFAULT NULL,
  `col11` int(11) DEFAULT NULL,
  `col_generated_source_last_name_1744873758115244` varchar(100) GENERATED ALWAYS AS (concat(`last_name`,'')) VIRTUAL,
  `pk2` int(11) DEFAULT NULL,
  `col3` text DEFAULT NULL,
  `col8` mediumtext DEFAULT NULL,
  `first_name` varchar(100) DEFAULT NULL,
  `col13` text DEFAULT NULL,
  `last_name` varchar(100) DEFAULT NULL,
  FULLTEXT KEY `random_index_col_1744882657033926` (`last_name`) WITH PARSER space PARSER_PROPERTIES=(min_token_size=3,max_token_size=84) BLOCK_SIZE 16384,
  FULLTEXT KEY `random_index_col_1744883121937206` (`col1`, `col9`, `last_name`, `col3`) WITH PARSER ik PARSER_PROPERTIES=(ik_mode="smart") BLOCK_SIZE 16384,
  KEY `random_index_col_1744882822504219` (`col4`, `col_generated_source_last_name_1744873758115244`, `pk1`, `col7`, `col10`, `col12`, `col11`) BLOCK_SIZE 16384 LOCAL,
  KEY `random_index_col_1744882416721392` (`col11`, `col10`, `col4`, `last_name`, `col12`, `col7`, `pk2`) BLOCK_SIZE 16384 LOCAL,
  KEY `random_index_col_1744882973670965` (`pk1`) BLOCK_SIZE 16384 LOCAL,
  KEY `random_index_col_1744882617890293` (`pk1`, `pk2`) BLOCK_SIZE 16384 LOCAL,
  KEY `random_index_col_1744882685069731` (`col11`, `first_name`, `col10`, `pk1`, `last_name`, `col4`, `col15`, `col12`, `pk2`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'snappy_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by hash(pk1)
(partition `p0`) WITH COLUMN GROUP(all columns);

--error 1235
alter table test_fts12x CONVERT TO  character set gb18030;
drop table test_fts12x;



