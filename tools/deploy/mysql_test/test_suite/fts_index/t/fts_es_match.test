SELECT title,content,SCORE()          FROM test         WHERE MATCH(content^2,'Development Exploring', 'operator=or;minimum_should_match=1;type=most_fields;') ;
 SELECT title,content,SCORE()          FROM test         WHERE MATCH(title^1.0,'Development Exploring', 'operator=or;minimum_should_match=1;type=most_fields;') ;
SELECT title,content,SCORE()          FROM test         WHERE MATCH(title^1.0,content^2,'Development Exploring', 'operator=or;minimum_should_match=1;type=most_fields;') ;

CREATE TABLE `document_table` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT,
  `title_tks` varchar(255) DEFAULT NULL,
  `title_sm_tks` varchar(255) DEFAULT NULL,
  `important_kwd` varchar(255) DEFAULT NULL,
  `important_tks` text DEFAULT NULL,
  `question_tks` text DEFAULT NULL,
  `content_ltks` text DEFAULT NULL,
  `content_sm_ltks` text DEFAULT NULL,
  `status` int(11) DEFAULT '1',
  `create_time` datetime DEFAULT CURRENT_TIMESTAMP,
  `user_id` bigint(20) DEFAULT NULL,
  `post_type` varchar(50) DEFAULT NULL,
  PRIMARY KEY (`id`),
  FULLTEXT KEY `ft_idx_title_tks` (`title_tks`) WITH PARSER ik PARSER_PROPERTIES=(ik_mode="smart") BLOCK_SIZE 16384,
  FULLTEXT KEY `ft_idx_title_sm_tks` (`title_sm_tks`) WITH PARSER ik PARSER_PROPERTIES=(ik_mode="smart") BLOCK_SIZE 16384,
  FULLTEXT KEY `ft_idx_important_kwd` (`important_kwd`) WITH PARSER ik PARSER_PROPERTIES=(ik_mode="smart") BLOCK_SIZE 16384,
  FULLTEXT KEY `ft_idx_important_tks` (`important_tks`) WITH PARSER ik PARSER_PROPERTIES=(ik_mode="smart") BLOCK_SIZE 16384,
  FULLTEXT KEY `ft_idx_question_tks` (`question_tks`) WITH PARSER ik PARSER_PROPERTIES=(ik_mode="smart") BLOCK_SIZE 16384,
  FULLTEXT KEY `ft_idx_content_ltks` (`content_ltks`) WITH PARSER ik PARSER_PROPERTIES=(ik_mode="smart") BLOCK_SIZE 16384,
  FULLTEXT KEY `ft_idx_content_sm_ltks` (`content_sm_ltks`) WITH PARSER ik PARSER_PROPERTIES=(ik_mode="smart") BLOCK_SIZE 16384
) ORGANIZATION INDEX AUTO_INCREMENT = 4 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'none' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
INSERT INTO `document_table` 
    (`title_tks`, `title_sm_tks`, `important_kwd`, `important_tks`, `question_tks`, `content_ltks`, `content_sm_ltks`, `status`, `create_time`, `user_id`, `post_type`) 
VALUES 
