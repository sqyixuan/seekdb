    ('事件报告', '重要事件', '华为科技', '华为在科技领域的重要事件', '华为的挑战', '这篇文章讨论了华为的多项发展', '总结：华为与事件', 1, '2025-08-21 20:07:27', 102, 'report'),
    ('技术新闻', '科技发展', '华为技术', '详细分析了华为的技术突破', '科技领域中的华为', '华为技术在行业中的作用', '华为技术新闻', 1, '2025-08-21 20:07:27', 103, 'article');
SELECT SCORE()  FROM document_table  WHERE MATCH(  important_tks^20,    '事^0.4858337040450644332 华为^2147483647 发生^0.24744341320755958',     'operator=or;minimum_should_match=1;boost=1;type=most_fields;score_norm=min-max;' ) order by id;
drop table document_table;

CREATE TABLE `test1` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT,
  `title` varchar(255) NOT NULL,
  `content` text DEFAULT NULL,
  `author` varchar(100) DEFAULT NULL,
  `tags` varchar(255) DEFAULT NULL,
  `status` int(11) DEFAULT '1',
  `create_time` datetime DEFAULT CURRENT_TIMESTAMP,
  `user_id` bigint(20) DEFAULT NULL,
  `post_type` varchar(50) DEFAULT NULL,
  `score` varchar(20) DEFAULT NULL,
  FULLTEXT KEY `content` (`content`) WITH PARSER space PARSER_PROPERTIES=(min_token_size=3,max_token_size=84) BLOCK_SIZE 16384,
  FULLTEXT KEY `content_2` (`content`, `title`, `score`) WITH PARSER space PARSER_PROPERTIES=(min_token_size=3,max_token_size=84) BLOCK_SIZE 16384,
  FULLTEXT KEY `title` (`title`, `content`) WITH PARSER space PARSER_PROPERTIES=(min_token_size=3,max_token_size=84) BLOCK_SIZE 16384,
  FULLTEXT KEY `title_2` (`title`) WITH PARSER ik PARSER_PROPERTIES=(ik_mode="smart") BLOCK_SIZE 16384,
  FULLTEXT KEY `tags` (`tags`) WITH PARSER space PARSER_PROPERTIES=(min_token_size=3,max_token_size=84) BLOCK_SIZE 16384
) ORGANIZATION INDEX AUTO_INCREMENT = 21 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'none' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 LOB_INROW_THRESHOLD=32 ;
