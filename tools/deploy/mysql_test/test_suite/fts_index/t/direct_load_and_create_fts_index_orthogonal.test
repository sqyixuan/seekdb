# owner: youchuan.yc
# owner group: storage
# description: direct load and create fts index orthogonal

connect(conn_sys, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connect(mysql_conn, $OBMYSQL_MS0, root,,test, $OBMYSQL_PORT);
connect(mysql_conn_for_fts, $OBMYSQL_MS0, root,,test, $OBMYSQL_PORT);
connection conn_sys;
alter system set debug_sync_timeout = '100s';
alter system set _enable_add_fulltext_index_to_existing_table = true;
sleep 1;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'AFTER_DIRECT_LOAD_FIRST_CHECK_IS_SUPPORT wait_for continue_signal execute 10000';
connection mysql_conn;
--disable_warnings
drop table if exists t_for_direct_load;
--enable_warnings
create table t_for_direct_load (c0 varchar(255));

send insert /*+ append enable_parallel_dml parallel(4) */ into t_for_direct_load (c0) select randstr(uniform(1, 128, random()), random()) from table(generator(1000));

connection mysql_conn_for_fts;
create fulltext index idx0 on t_for_direct_load(c0);

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now broadcast continue_signal';
sleep 3;

connection mysql_conn;
reap;

connection conn_sys;
alter system set debug_sync_timeout = 0;
alter system set _enable_add_fulltext_index_to_existing_table = false;