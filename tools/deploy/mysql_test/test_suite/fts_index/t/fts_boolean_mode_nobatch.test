# owner: zyx439997
# owner group: storage
# description: text retrieval query with boolean mode

--disable_warnings
drop database if exists fts;
create database fts;
use fts;
--enable_warnings

create table t_ir_single_column(
  digest varchar(512),
  detail varchar(4096),
  seq int, 
  fulltext index i1(detail),
  fulltext index i2(digest, detail),
  index i3(seq));

create table t_dim(
  seq int,
  dim_info varchar(512),
  index i1(seq));

--result_format 4

insert into t_ir_single_column (digest, detail, seq) values
    ("Gerard Salton", "Gerard A. Gerry Salton (8 March 1927 – 28 August 1995) was a professor of Computer Science at Cornell University. Salton was perhaps the leading computer scientist working in the field of information retrieval during his time, and the father of Information Retrieval", 0),
    ("Edgar F. Codd", "Edgar Frank Ted Codd (19 August 1923 – 18 April 2003) was an English computer scientist who, while working for IBM, invented the relational model for database management, the theoretical basis for relational databases and relational database management systems. ", 1),
    ("Michael Stonebraker", "Michael Ralph Stonebraker (born October 11, 1943[6]) is a computer scientist specializing in database systems. Through a series of academic prototypes and commercial startups, Stonebraker's research and products are central to many relational databases. ", 2),
    ("Geoffrey Hinton", "Geoffrey Everest Hinton CC FRS FRSC (born 6 December 1947) is a British-Canadian computer scientist and cognitive psychologist, most noted for his work on artificial neural networks.", 3),
    ("Yann LeCun", "Yann André LeCun[1] (born 8 July 1960) is a Turing Award winning French computer scientist working primarily in the fields of machine learning, computer vision, mobile robotics and computational neuroscience.", 4),
    ("Ken Thompson", "Kenneth Lane Thompson (born February 4, 1943) is an American pioneer of computer science. Thompson worked at Bell Labs for most of his career where he designed and implemented the original Unix operating system. ", 5),
    ("Gordon Plotkin", "Gordon David Plotkin, FRS FRSE MAE (born 9 September 1946) is a theoretical computer scientist in the School of Informatics at the University of Edinburgh. Plotkin is probably best known for his introduction of structural operational semantics (SOS) and his work on denotational semantics.", 6),
    ("Leslie Lamport", "Leslie B. Lamport (born February 7, 1941) is an American computer scientist and mathematician. Lamport is best known for his seminal work in distributed systems, and as the initial developer of the document preparation system LaTeX", 7);

insert into t_dim (seq, dim_info) values
    (1, "dim imfo 1"),
    (3, "dim imfo 3"),
    (4, "dim imfo 4"),
    (7, "dim imfo 7");

alter system set _rowsets_enabled = false;

--sleep 2

# normal
explain select seq from t_ir_single_column where match (detail) against ("" IN BOOLEAN MODE);
select seq from t_ir_single_column where match (detail) against ("" IN BOOLEAN MODE);

explain select seq from t_ir_single_column where match (detail) against (" " IN BOOLEAN MODE);
select seq from t_ir_single_column where match (detail) against (" " IN BOOLEAN MODE);

--error 1149
select seq from t_ir_single_column where match (detail) against (" ~system" IN BOOLEAN MODE);

--error 1149
select seq from t_ir_single_column where match (detail) against (" >system" IN BOOLEAN MODE);

--error 1149
select seq from t_ir_single_column where match (detail) against (" <system" IN BOOLEAN MODE);

--error 1149
select seq from t_ir_single_column where match (detail) against (" system*" IN BOOLEAN MODE);

--error 1149
select seq from t_ir_single_column where match (detail) against (" system@" IN BOOLEAN MODE);

--error 1149
select seq from t_ir_single_column where match (detail) against (" ( system" IN BOOLEAN MODE);

explain select digest from t_ir_single_column where match (detail) against ("+computer system" IN BOOLEAN MODE);
select digest from t_ir_single_column where match (detail) against ("+computer system" IN BOOLEAN MODE);

explain select digest from t_ir_single_column where match (detail) against ("+computer -system" IN BOOLEAN MODE);
select digest from t_ir_single_column where match (detail) against ("+computer -system" IN BOOLEAN MODE);

explain select digest from t_ir_single_column where match (detail) against ("computer +system" IN BOOLEAN MODE);
select digest from t_ir_single_column where match (detail) against ("computer +system" IN BOOLEAN MODE);

explain select digest from t_ir_single_column where match (detail) against ("+system (+computer -system)" IN BOOLEAN MODE);
select digest from t_ir_single_column where match (detail) against ("+system (+computer -system)" IN BOOLEAN MODE);

explain select digest from t_ir_single_column where match (detail) against ("+(+computer system) -system" IN BOOLEAN MODE);
select digest from t_ir_single_column where match (detail) against ("+(+computer system) -system" IN BOOLEAN MODE);

explain select digest from t_ir_single_column where match (detail) against ("+test system ()" IN BOOLEAN MODE);
select digest from t_ir_single_column where match (detail) against ("+test system ()" IN BOOLEAN MODE);

explain select digest from t_ir_single_column where match (detail) against ("+test system (system)" IN BOOLEAN MODE);
select digest from t_ir_single_column where match (detail) against ("+test system (system)" IN BOOLEAN MODE);

# function lookup
explain select digest, match (detail) against ("+computer -system" IN BOOLEAN MODE) as r1, match (detail) against ("computer") as r2 from t_ir_single_column where match (detail) against ("+computer -system" IN BOOLEAN MODE);
select digest, match (detail) against ("+computer -system" IN BOOLEAN MODE) as r1, match (detail) against ("computer") as r2 from t_ir_single_column where match (detail) against ("+computer -system" IN BOOLEAN MODE);

explain select digest, match (detail) against ("+computer -system" IN BOOLEAN MODE) as r1, match (detail) against ("computer") as r2 from t_ir_single_column where match (detail) against ("+computer -system" IN BOOLEAN MODE) > 0.2;
select digest, match (detail) against ("+computer -system" IN BOOLEAN MODE) as r1, match (detail) against ("computer") as r2 from t_ir_single_column where match (detail) against ("+computer -system" IN BOOLEAN MODE) > 0.2;

explain select digest, match (detail) against ("+computer -system" IN BOOLEAN MODE) as r1, match (detail) against ("computer") as r2 from t_ir_single_column where match (detail) against ("computer") > 0.01;
select digest, match (detail) against ("+computer -system" IN BOOLEAN MODE) as r1, match (detail) against ("computer") as r2 from t_ir_single_column where match (detail) against ("computer") > 0.01;

explain select digest, match (detail) against ("system") as r1, match (detail) against ("system computer") as r2 from t_ir_single_column;
select digest, match (detail) against ("system") as r1, match (detail) against ("system computer") as r2 from t_ir_single_column;

explain select digest, match (detail) against ("+system -test" IN BOOLEAN MODE) as r1, match (detail) against ("+system (+computer +system)" IN BOOLEAN MODE) as r2 from t_ir_single_column;
select digest, match (detail) against ("+system -test" IN BOOLEAN MODE) as r1, match (detail) against ("+system (+computer +system)" IN BOOLEAN MODE) as r2 from t_ir_single_column;

explain select digest, match (detail) against ("+computer -system" IN BOOLEAN MODE) as r1, match (detail) against ("+system (+computer +system)" IN BOOLEAN MODE) as r2 from t_ir_single_column;
select digest, match (detail) against ("+computer -system" IN BOOLEAN MODE) as r1, match (detail) against ("+system (+computer +system)" IN BOOLEAN MODE) as r2 from t_ir_single_column;

explain select digest, match (detail) against ("+computer -system" IN BOOLEAN MODE) as r1, match (detail) against ("+system (+computer +system)" IN BOOLEAN MODE) as r2 from t_ir_single_column limit 3;
select digest, match (detail) against ("+computer -system" IN BOOLEAN MODE) as r1, match (detail) against ("+system (+computer +system)" IN BOOLEAN MODE) as r2 from t_ir_single_column limit 3;

explain select digest, match (detail) against ("+computer -system" IN BOOLEAN MODE) as r1, match (detail) against ("+system (+computer +system)" IN BOOLEAN MODE) as r2 from t_ir_single_column order by r1 desc;
select digest, match (detail) against ("+computer -system" IN BOOLEAN MODE) as r1, match (detail) against ("+system (+computer +system)" IN BOOLEAN MODE) as r2 from t_ir_single_column order by r1 desc;

explain select digest, match (detail) against ("+computer -system" IN BOOLEAN MODE) as r1, match (detail) against ("+system (+computer +system)" IN BOOLEAN MODE) as r2 from t_ir_single_column order by r1 desc limit 3;
select digest, match (detail) against ("+computer -system" IN BOOLEAN MODE) as r1, match (detail) against ("+system (+computer +system)" IN BOOLEAN MODE) as r2 from t_ir_single_column order by r1 desc limit 3;

explain select seq, count(seq), digest from t_ir_single_column group by match (detail) against ("system" IN BOOLEAN MODE);
select seq, count(seq), digest from t_ir_single_column group by match (detail) against ("system" IN BOOLEAN MODE);

# topk
explain select digest from t_ir_single_column where match (detail) against ("+work -semantics" IN BOOLEAN MODE) limit 8;
select digest from t_ir_single_column where match (detail) against ("+work -semantics" IN BOOLEAN MODE) limit 8;

explain select digest, match (detail) against ("+work -semantics" IN BOOLEAN MODE) as score from t_ir_single_column where match (detail) against ("+work -semantics" IN BOOLEAN MODE) limit 5;
select digest, match (detail) against ("+work -semantics" IN BOOLEAN MODE) as score from t_ir_single_column where match (detail) against ("+work -semantics" IN BOOLEAN MODE) limit 5;

explain select digest, match (detail) against ("+computer" IN BOOLEAN MODE) as score from t_ir_single_column where match (detail) against ("+work -semantics" IN BOOLEAN MODE) limit 5;
select digest, match (detail) against ("+computer" IN BOOLEAN MODE) as score from t_ir_single_column where match (detail) against ("+work -semantics" IN BOOLEAN MODE) limit 5;

explain select digest, match (detail) against ("known known known operating management" in BOOLEAN MODE) as score from t_ir_single_column where match (detail) against ("known known known operating management" in BOOLEAN MODE) limit 2;
select digest, match (detail) against ("known known known operating management" in BOOLEAN MODE) as score from t_ir_single_column where match (detail) against ("known known known operating management" in BOOLEAN MODE) limit 2;

explain select digest, match (detail) against ("known operating management" in BOOLEAN MODE) as score from t_ir_single_column where match (detail) against ("known operating management" in BOOLEAN MODE) limit 2;
select digest, match (detail) against ("known operating management" in BOOLEAN MODE) as score from t_ir_single_column where match (detail) against ("known operating management" in BOOLEAN MODE) limit 2;

explain select digest, match (detail) against ("computer work -(work -(distributed networks))" in BOOLEAN MODE) as score from t_ir_single_column where match (detail) against ("computer work -(work -(distributed networks))" in BOOLEAN MODE) limit 2;
select digest, match (detail) against ("computer work -(work -(distributed networks))" in BOOLEAN MODE) as score from t_ir_single_column where match (detail) against ("computer work -(work -(distributed networks))" in BOOLEAN MODE) limit 2;

alter system set _rowsets_enabled = true;
--sleep 2
--disable_warnings
drop table if exists t_ir_single_column;
drop table if exists t_dim;
drop database fts;
--enable_warnings
