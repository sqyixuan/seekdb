# owner: zyx439997
# owner group: storage
# description: text retrieval query with match phrase mode

--disable_warnings
drop database if exists fts;
create database fts;
use fts;
--enable_warnings

create table t_ir_single_column(
  digest varchar(512),
  detail varchar(4096),
  seq int, 
  fulltext index i1(detail),
  fulltext index i2(digest, detail),
  index i3(seq));

--result_format 4

insert into t_ir_single_column (digest, detail, seq) values
    ("Gerard Salton", "Gerard A. Gerry Salton (8 March 1927 – 28 August 1995) was a professor of Computer Science at Cornell University. Salton was perhaps the leading computer scientist working in the field of information retrieval during his time, and the father of Information Retrieval", 0),
    ("Edgar F. Codd", "Edgar Frank Ted Codd (19 August 1923 – 18 April 2003) was an English computer scientist who, while working for IBM, invented the relational model for database management, the theoretical basis for relational databases and relational database management systems. ", 1),
    ("Michael Stonebraker", "Michael Ralph Stonebraker (born October 11, 1943[6]) is a computer scientist specializing in database systems. Through a series of academic prototypes and commercial startups, Stonebraker's research and products are central to many relational databases. ", 2),
    ("Geoffrey Hinton", "Geoffrey Everest Hinton CC FRS FRSC (born 6 December 1947) is a British-Canadian computer scientist and cognitive psychologist, most noted for his work on artificial neural networks.", 3),
    ("Yann LeCun", "Yann André LeCun[1] (born 8 July 1960) is a Turing Award winning French computer scientist working primarily in the fields of machine learning, computer vision, mobile robotics and computational neuroscience.", 4),
    ("Ken Thompson", "Kenneth Lane Thompson (born February 4, 1943) is an American pioneer of computer science. Thompson worked at Bell Labs for most of his career where he designed and implemented the original Unix operating system. ", 5),
    ("Gordon Plotkin", "Gordon David Plotkin, FRS FRSE MAE (born 9 September 1946) is a theoretical computer scientist in the School of Informatics at the University of Edinburgh. Plotkin is probably best known for his introduction of structural operational semantics (SOS) and his work on denotational semantics.", 6),
    ("Leslie Lamport", "Leslie B. Lamport (born February 7, 1941) is an American computer scientist and mathematician. Lamport is best known for his seminal work in distributed systems, and as the initial developer of the document preparation system LaTeX", 7);

alter system set _rowsets_enabled = true;

--sleep 2

# normal
explain select seq from t_ir_single_column where match (digest, detail) against ("" IN MATCH PHRASE MODE);
select seq from t_ir_single_column where match (digest, detail) against ("" IN MATCH PHRASE MODE);

explain select match (digest, detail) against ("" IN MATCH PHRASE MODE) from t_ir_single_column where match (digest, detail) against ("" IN MATCH PHRASE MODE);
select match (digest, detail) against ("" IN MATCH PHRASE MODE) from t_ir_single_column where match (digest, detail) against ("" IN MATCH PHRASE MODE);

explain select digest from t_ir_single_column where match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE);
select digest from t_ir_single_column where match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE);

explain select digest from t_ir_single_column where not match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE);
select digest from t_ir_single_column where not match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE);

explain select digest, match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) from t_ir_single_column where not match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE);
select digest, match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) from t_ir_single_column where not match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE);

explain select digest, match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) from t_ir_single_column where match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) > 0.01;
select digest, match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) from t_ir_single_column where match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) > 0.01;

# function lookup
explain select digest, match (digest, detail) against ("Computer Science" IN MATCH PHRASE MODE),match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) from t_ir_single_column;
select digest, match (digest, detail) against ("Computer Science" IN MATCH PHRASE MODE), match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) from t_ir_single_column;

explain select digest, match (digest, detail) against ("Computer Science" IN MATCH PHRASE MODE) from t_ir_single_column where match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) > 0.01;
select digest, match (digest, detail) against ("Computer Science" IN MATCH PHRASE MODE) from t_ir_single_column where match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) > 0.01;

explain select digest, match (digest, detail) against ("Computer Science" IN MATCH PHRASE MODE) from t_ir_single_column where match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) > 0.01 and  match (digest, detail) against ("is a" IN MATCH PHRASE MODE) < 1;
select digest, match (digest, detail) against ("Computer Science" IN MATCH PHRASE MODE) from t_ir_single_column where match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) > 0.01 and match (digest, detail) against ("is a" IN MATCH PHRASE MODE) < 1;

explain select digest, match (digest, detail) against ("Computer Science" IN MATCH PHRASE MODE) from t_ir_single_column where match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) > 0.01 and  match (digest, detail) against ("is a" IN MATCH PHRASE MODE) < 1 and match (digest, detail) against ("for his" IN MATCH PHRASE MODE);
select digest, match (digest, detail) against ("Computer Science" IN MATCH PHRASE MODE) from t_ir_single_column where match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) > 0.01 and match (digest, detail) against ("is a" IN MATCH PHRASE MODE) < 1 and not match (digest, detail) against ("for his" IN MATCH PHRASE MODE);

explain select digest, match (digest, detail) against ("+Computer -Science" IN BOOLEAN MODE) from t_ir_single_column where match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) > 0.01 and  match (digest, detail) against ("is a" IN MATCH PHRASE MODE) < 1 and match (digest, detail) against ("for his" IN MATCH PHRASE MODE);
select digest, match (digest, detail) against ("+Computer -Science" IN BOOLEAN MODE) from t_ir_single_column where match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) > 0.01 and match (digest, detail) against ("is a" IN MATCH PHRASE MODE) < 1 and not match (digest, detail) against ("for his" IN MATCH PHRASE MODE);

explain select digest, match (digest, detail) against ("Computer Science" IN MATCH PHRASE MODE) from t_ir_single_column where match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) > 0.01 and  match (digest, detail) against ("+Computer -Science" IN BOOLEAN MODE);
select digest, match (digest, detail) against ("Computer Science" IN MATCH PHRASE MODE) from t_ir_single_column where match (digest, detail) against ("computer scientist" IN MATCH PHRASE MODE) > 0.01 and match (digest, detail) against ("+Computer -Science" IN BOOLEAN MODE);

--sleep 2
--disable_warnings
drop table if exists t_ir_single_column;
drop database fts;
--enable_warnings
