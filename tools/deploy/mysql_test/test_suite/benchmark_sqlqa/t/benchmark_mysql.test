insert into t2 values (7222,'MAIK','CLERK',7782,'1982-1-23',1300,729,10);
elseif new.deptno = 20 and benchmark(10,trim(' a p qq  ')) then
insert into t2 values (7333,'SON','ANALYST',7566,'1987-4-13',3000,-200,20);
elseif new.deptno = 30 and benchmark(10,atan(10))  then
insert into t2 values (7444,'LEFT','SALESMAN',7698,'1981-2-20',1600,300,30);
else
