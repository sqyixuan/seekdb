drop trigger if exists bt;//
create trigger bt before delete on t1 for each row
begin
if old.loc = 'NEW YORK' and benchmark(10,length('afdfdfq')) = 0 then
delete from t2 where deptno = 10;
elseif old.loc = 'DALLAS' and benchmark(10,pi()) = 0 then
delete from t2 where deptno = 20;
elseif old.loc = 'CHICAGO' and benchmark(10,abs(1900)) = 0 then
delete from t2 where deptno = 30;
else
delete from t2 where deptno = 40;
end if;
end;
//

delete from t1 where loc = 'NEW YORK' and benchmark(10,truncate(19.55,1)) = 0;//
select * from t1;//
select * from t2;//

delimiter ;//


