drop table if exists t1;
drop table if exists t2;
create table t1(DEPTNO int primary key,DNAME varchar(14),LOC varchar(13));
create table t2(EMPNO decimal(6,2),ENAME varchar(10),JOB varchar(9),MGR decimal(6,2),HIREDATE datetime,SAL int,COMM decimal(7,2),DEPTNO decimal(2))partition by range(sal) 
(partition  p1 values  less than(2500),partition  p2 values  less than(5000));
