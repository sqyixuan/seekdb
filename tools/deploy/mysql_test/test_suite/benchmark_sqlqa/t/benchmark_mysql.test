delimiter //;

create function f1() returns varchar(200)
begin
	declare a varchar(20);
	select ename into a from t2 where empno = 7900 and benchmark(10000,(1=1)) = 0 order by empno;
	return a;
end;
//

select f1();//
select benchmark(10,f1());//
select f1(),benchmark(10,least('aaa','qqqq'));//


drop function if exists f1;//
create function f1(v_e int) 
returns varchar(200)
begin
	declare a varchar(20);
	select ename into a from t2 where empno = v_e and benchmark(10000,(1=1)) = 0 order by empno;
	return a;
end;
//

select f1(7902);//
select benchmark(10,f1(7902));//
select f1(7902),benchmark(10,least('aaa','qqqq'));//


create procedure p1(in v_e int)
begin
declare a varchar(20);
select ename into a from t2 where empno =  v_e and benchmark(10000,(1=1)) = 0 order by empno;
if a = 'SMITH' and benchmark(10000,(1=1)) then
select a,benchmark(10,(1=1));
elseif a = 'ALLEN' then
select a,benchmark(10,(select ename from t2 where empno = v_e and benchmark(10000,(1=1)) = 0 order by empno));
else
select benchmark(100,(select ename from t2 where empno = v_e and benchmark(10000,(1=1)) = 0 order by empno));
end if;
end;
//

call p1(7369);//
--error 0,1064
select benchmark(10,(call p1(7499)));//
call p1(benchmark(10,least('qca','caq')));//


drop trigger if exists bt;//
create trigger bt before insert on t1 for each row
begin
if new.deptno = 10 and benchmark(10,abs(-100)) then
insert into t2 values (7222,'MAIK','CLERK',7782,'1982-1-23',1300,729,10);
elseif new.deptno = 20 and benchmark(10,trim(' a p qq  ')) then
insert into t2 values (7333,'SON','ANALYST',7566,'1987-4-13',3000,-200,20);
elseif new.deptno = 30 and benchmark(10,max(10))  then
insert into t2 values (7444,'LEFT','SALESMAN',7698,'1981-2-20',1600,300,30);
else
insert into t2 values (7555,'OUTL','PRESIDENT',NULL,'1981-11-17',4999,-196.7,10);
end if;
end;
