select benchmark(10,(select found_rows()));

select benchmark(10,(select max(sal) from t2 where deptno = 10 group by deptno));
--error 0,1242
select benchmark(10,(select max(sal) from t2 where deptno = 10 group by deptno with rollup));
select benchmark(10,(select max(sal) from t2 where deptno in (10,20) group by deptno having max(sal) > 3000));
select benchmark(10,(select max(sal) from t2 where deptno in (10,20) group by deptno having max(sal) > 4000));

