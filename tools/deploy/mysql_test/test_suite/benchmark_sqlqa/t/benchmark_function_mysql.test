select benchmark(10,(select ename from t2 partition(p1) where job = 'MANAGER' except select ename from t2 partition(p2) where job = 'MANAGER'));
select benchmark(10,(select ename from t2 partition(p1) where job = 'MANAGER' intersect select ename from t2 partition(p1) where job = 'MANAGER'));


