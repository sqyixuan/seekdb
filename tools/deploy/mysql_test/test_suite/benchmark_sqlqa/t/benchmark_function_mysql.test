select benchmark(10,(select job from t2 natural join t1 where loc = 'New York' limit 1));
select benchmark(10,(select job from t2 natural join t1 where loc = 'New York' and ename = 'CLARK'));

select benchmark(10,(select job from t2 e inner join t1 p on e.deptno = p.deptno where loc = 'New York' limit 1));
select benchmark(10,(select job from t2 e inner join t1 p on e.deptno = p.deptno where loc = 'New York' and ename = 'CLARK'));

select benchmark(10,(select job from t2 e cross join t1 p on e.deptno = p.deptno where loc = 'New York' limit 1));
select benchmark(10,(select job from t2 e cross join t1 p on e.deptno = p.deptno where loc = 'New York' and ename = 'CLARK'));

select benchmark(10,(select job from t2 e left join t1 p on e.deptno = p.deptno where loc = 'New York' limit 1));
select benchmark(10,(select job from t2 e left join t1 p on e.deptno = p.deptno where loc = 'New York' and ename = 'CLARK'));

select benchmark(10,(select job from t2 e right join t1 p on e.deptno = p.deptno where loc = 'New York' limit 1));
select benchmark(10,(select job from t2 e right join t1 p on e.deptno = p.deptno where loc = 'New York' and ename = 'CLARK'));

select benchmark(10,(select job from t2 e full join t1 p on e.deptno = p.deptno where loc = 'New York' limit 1));
select benchmark(10,(select job from t2 e full join t1 p on e.deptno = p.deptno where loc = 'New York' and ename = 'CLARK'));

select benchmark(10,(select job from t2 e inner join t1 p using(deptno) where loc = 'New York' limit 1));
select benchmark(10,(select job from t2 e cross join t1 p using(deptno) where loc = 'New York' limit 1));
select benchmark(10,(select job from t2 e left join t1 p using(deptno) where loc = 'New York' limit 1));
select benchmark(10,(select job from t2 e right join t1 p using(deptno) where loc = 'New York' limit 1));
select benchmark(10,(select job from t2 e full join t1 p using(deptno) where loc = 'New York' limit 1));

select benchmark(10,(select row_number() over() from t2 where deptno = 10 limit 1));
select benchmark(10,(select row_number() over(order by sal) from t2 where deptno = 10 limit 1));
select benchmark(10,(select row_number() over(partition by job order by sal) from t2 where deptno = 10 limit 1));

