(7566,'JONES','MANAGER',7839,'1981-4-2',2975,358.69,20),(7654,'MARTIN','SALESMAN',7698,'1981-9-28',1250,1400,30),(7698,'BLAKE','MANAGER',7839,'1981-5-1',2850,-2100,30),
(7782,'CLARK','MANAGER',7839,'1981-6-9',2450,744.9,10),(7788,'SCOTT','ANALYST',7566,'1987-4-13',3000,-200,20),(7839,'KING','PRESIDENT',null,'1981-11-17',4999,-196.7,10),
(7844,'TURNER','SALESMAN',7698,'1981-9-8',1500,0,30),(7876,'ADAMS','CLERK',7788,'1987-5-13',1100,-99.9,20),(7900,'JAMES','CLERK',7698,'1981-12-3',950,-1808,30),
(7902,'FORD','ANALYST',7566,'1981-12-3',3000,753.9,20),(7934,'MILLER','CLERK',7782,'1982-1-23',1300,729,10);

