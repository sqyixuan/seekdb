--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL2
#

# Prepare
--disable_warnings
--result_format 4
drop table if exists t2;
--enable_warnings

--source mysql_test/include/oss_config_for_import.inc

--source mysql_test/include/external_table/replace_oss_config_info.inc

eval CREATE EXTERNAL TABLE t2(
c0 DOUBLE(11, 10) ZEROFILL GENERATED ALWAYS AS (METADATA\$FILECOL1),
c1 VARCHAR(500) GENERATED ALWAYS AS (NVL(METADATA\$FILECOL2,'Nk7XKb4|&Y9epdeP !AO')),
c2 DECIMAL(2, 1) ZEROFILL GENERATED ALWAYS AS (METADATA\$FILECOL3),
c3 MEDIUMINT(193) ZEROFILL GENERATED ALWAYS AS (METADATA\$FILECOL4),
c4 DATETIME GENERATED ALWAYS AS (METADATA\$FILECOL5)) location='oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/fake_dir/' FORMAT(   TYPE = 'CSV',   FIELD_DELIMITER = '|', FIELD_OPTIONALLY_ENCLOSED_BY = '\'', ENCODING = 'UTF8MB4', NULL_IF = ('', '2023-06-12 19:45:20'), TRIM_SPACE = TRUE, SKIP_BLANK_LINES = TRUE, EMPTY_FIELD_AS_NULL = TRUE);

explain basic SELECT /*+ parallel(t2_84, 2) */ t2_84.c3, t2_84.c2, t2_84.c3
FROM t2 AS t2_84
WHERE t2_84.c1 = (SELECT t2_84.c1 FROM t2 AS t2_84 LIMIT 1);

drop table t2;

