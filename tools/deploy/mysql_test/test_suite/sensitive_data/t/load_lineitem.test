--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL2
# description: Test simple case for MySQL load data query
# 

# Prepare
--disable_warnings
drop table if exists t_lineitem;
--enable_warnings
create table t_lineitem(
    l_orderkey           bigint NOT NULL ,
    l_partkey            bigint NOT NULL ,
    l_suppkey            bigint NOT NULL ,
    l_linenumber         bigint NOT NULL ,
    l_quantity           bigint NOT NULL ,
    l_extendedprice      number(10,2) NOT NULL ,
    l_discount           number(10,2) NOT NULL ,
    l_tax                number(10,2) NOT NULL ,
    l_returnflag         char(1) ,
    l_linestatus         char(1) ,
    l_shipdate           date ,
    l_commitdate         date ,
    l_receiptdate        date ,
    l_shipinstruct       char(25) ,
    l_shipmode           char(10) ,
    l_comment            varchar(44),
    primary key(L_ORDERKEY, L_LINENUMBER, l_shipdate, l_partkey)
);


--source mysql_test/include/oss_config_for_import.inc

# TEST 1
--disable_query_log
eval load data remote_oss
infile 'oss://antsys-antsys-oceanbase-rd-sql/tpch_example_data/temp0.dat?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' 
into table t_lineitem
fields terminated by '|'; 
--enable_query_log

select count(*) from t_lineitem;

# Clean Up

drop table t_lineitem;
