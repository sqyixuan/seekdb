# Prepare
--disable_warnings
--result_format 4
drop table if exists t0;
--enable_warnings

--source mysql_test/include/oss_config_for_import.inc

--source mysql_test/include/external_table/replace_oss_config_info.inc

eval CREATE EXTERNAL TABLE t0(
c0 DOUBLE(28, 23),
c1 DOUBLE(18, 11),
c2 DATETIME,
c3 DECIMAL(16, 15) ZEROFILL, 
c4 VARCHAR(500),
c5 FLOAT
)  LOCATION='oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/issue50393870'
FORMAT(
  TYPE = 'CSV',
  FIELD_DELIMITER = ',',
  FIELD_OPTIONALLY_ENCLOSED_BY = '\'',
  ENCODING = 'UTF8MB4',
  NULL_IF = ('eP', '2023-06-19 19:29:04', '0000-00-00 00:00:00'),
  SKIP_BLANK_LINES = TRUE
);

SELECT /*+  PARALLEL(3),enable_parallel_dml  */ count(*) FROM t0 WHERE -1137020140;

drop table t0;

