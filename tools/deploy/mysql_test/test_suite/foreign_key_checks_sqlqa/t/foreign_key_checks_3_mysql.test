#owner:yuanzhi.zy
#owner group:sql2
#tags:ddl
#description:创建父表引用列带有约束、创建父表引用列带有索引、DML 执 行
#author:wb-hjw01054737
--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);



--echo     #foreign_key-9      创建父表引用列带有约束
--echo     #foreign_key-10	 创建父表引用列带有索引
--echo     #foreign_key-11     DML 执 行




--echo     #foreign_key-9      创建父表引用列带有约束
--echo     #foreign_key-9-1    非空约束 (not null)
set FOREIGN_KEY_CHECKS = on;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;
create table test1(c1 int PRIMARY key not null);
create table test2(id int,h1 bigint,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
desc test1;
desc test2;
--error 1171
ALTER TABLE test1 CHANGE COLUMN c1 c1 int NULL;
desc test1;
ALTER TABLE test2 CHANGE COLUMN id id int NOT NULL;
desc test2;
--error 0,1048
insert into test1 values(null);
--error 0,1048
insert into test2 values(null,12);
insert into test1 values(1);
insert into test2 values(1,15);
drop table   test2;
drop table   test1;


create table test1(c1 int UNIQUE not null);
create table test2(id int,h1 bigint,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
desc test1;
desc test2;
ALTER TABLE test1 CHANGE COLUMN c1 c1 int NULL;
desc test1;
ALTER TABLE test2 CHANGE COLUMN id id int NOT NULL;
desc test2;
insert into test1 values(null);
--error 0,1048
insert into test2 values(null,12);
insert into test1 values(1);
insert into test2 values(1,15);
drop table   test2;
drop table   test1;




--echo     #foreign_key-9-2    唯一性约束 (unique)
set FOREIGN_KEY_CHECKS = on;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;
create table test1(c1 int PRIMARY key unique);
create table test2(id int,h1 bigint,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
desc test1;
desc test2;
insert into test1 values(011);
--error 0,1062
insert into test1 values(011);
insert into test2 values(011,12);
--error 0,1452
insert into test2 values(012,13);
ALTER TABLE test1 DROP INDEX c1;
--error 0,1062
insert into test1 values(011);
--error 0,1452
insert into test2 values(012,13);
alter table test1 add unique(c1);
drop table   test2;
drop table   test1;



--echo     #foreign_key-9-3    默认值约束 (Default)
set FOREIGN_KEY_CHECKS = on;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;
create table test1(c1 int PRIMARY key Default 1);
create table test2(id int,h1 bigint,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
desc test1;
desc test2;
insert into test1 values(011);
--error 0,1062
insert into test1 values(011);
insert into test2 values(011,12);
--error 0,1452
insert into test2 values(012,13);
insert into test1 values( );
insert into test2 values( );
ALTER TABLE test2 CHANGE COLUMN id id int DEFAULT 2;
desc test1;
desc test2;
--error 0,1452
insert into test2 values( );
ALTER TABLE test2 CHANGE COLUMN id id int DEFAULT NULL;
desc test2;
--error 0,1171
ALTER TABLE test1 CHANGE COLUMN c1 c1 int DEFAULT NULL;
drop table   test2;
drop table   test1;
create table test1(c1 int UNIQUE Default 1);
create table test2(id int,h1 bigint,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
desc test1;
desc test2;
insert into test1 values(011);
--error 0,1062
insert into test1 values(011);
insert into test2 values(011,12);
--error 0,1452
insert into test2 values(012,13);
insert into test1 values( );
insert into test2 values( );
ALTER TABLE test2 CHANGE COLUMN id id int DEFAULT 2;
desc test1;
desc test2;
--error 0,1452
insert into test2 values( );
ALTER TABLE test2 CHANGE COLUMN id id int DEFAULT NULL;
desc test2;
ALTER TABLE test1 CHANGE COLUMN c1 c1 int DEFAULT NULL;
drop table   test2;
drop table   test1;



--echo     #foreign_key-9-4    自增约束 (AUTO_INCREMENT)
set FOREIGN_KEY_CHECKS = on;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;
create table test1(c1 int PRIMARY key AUTO_INCREMENT,c2 bigint);
create table test2(id int,h1 bigint,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
desc test1;
desc test2;
insert into test1(c2) values(2);
insert into test2(h1) values(4);
desc test1;
desc test2;
--error 0,5320
alter table test2 modify id int auto_increment;
ALTER TABLE test1 MODIFY c1 INT;
drop table   test2;
drop table   test1;
create table test1(c1 int UNIQUE AUTO_INCREMENT,c2 bigint);
create table test2(id int,h1 bigint,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
desc test1;
desc test2;
insert into test1(c2) values(2);
insert into test2(h1) values(4);
desc test1;
desc test2;
--error 0,5320
alter table test2 modify id int auto_increment;
ALTER TABLE test1 MODIFY c1 INT;
desc test1;
--error 0,3940
alter table test2 drop CONSTRAINT wj;
desc test1;
alter table test1 modify c1 int auto_increment;
--error 0,5320
alter table test2 modify id int auto_increment;
drop table   test2;
drop table   test1;






--echo     #foreign_key-10	 创建父表引用列带有索引
--echo     #foreign_key-10-1     普  通   索   引     
set FOREIGN_KEY_CHECKS = on;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;
create table test1(c1 int PRIMARY key ,c2 bigint,index index_1(c1));
create table test2(id int,h1 bigint,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
desc test1;
desc test2;
--error 0,3730
DROP TABLE test1;
set FOREIGN_KEY_CHECKS = off;
--error 0,1051
DROP TABLE test1;
create table test1(c1 int PRIMARY key ,c2 bigint,index index_1(c1));
drop table   test2;
drop table   test1;
create table test1(c1 int PRIMARY key ,c2 bigint);
create table test2(id int,h1 bigint,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
create index index_1 on test1(c1);
drop table   test2;
drop table   test1;
set FOREIGN_KEY_CHECKS = on;




--echo     #foreign_key-10-2	   唯  一   索   引
set FOREIGN_KEY_CHECKS = on;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;
create table test1(c1 int PRIMARY key ,c2 bigint,UNIQUE index index_1(c1));
create table test2(id int,h1 bigint,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
desc test1;
desc test2;
show index from test1;
--error 0,3730
DROP TABLE test1;
set FOREIGN_KEY_CHECKS = off;
--error 0,1051
DROP TABLE test1;
create table test1(c1 int PRIMARY key ,c2 bigint,UNIQUE index index_1(c1));
drop table   test2;
drop table   test1;
create table test1(c1 int PRIMARY key ,c2 bigint);
create table test2(id int,h1 bigint,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
create UNIQUE index index_1 on test1(c1);
drop table   test2;
drop table   test1;
set FOREIGN_KEY_CHECKS = on;




--echo     #foreign_key-10-3     组  合   索   引
set FOREIGN_KEY_CHECKS = on;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;
create table test1(c1 int PRIMARY key ,c2 bigint,index index_1(c1,c2));
create table test2(id int,h1 bigint,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
desc test1;
desc test2;
show index from test1;
--error 0,3730
DROP TABLE test1;
set FOREIGN_KEY_CHECKS = off;
--error 0,1051
DROP TABLE test1;
create table test1(c1 int PRIMARY key ,c2 bigint, index index_1(c1,c2));
drop table   test2;
drop table   test1;
create table test1(c1 int PRIMARY key ,c2 bigint UNIQUE);
create table test2(id int,h1 bigint,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
create index index_1 on test1(c1,c2);
--error 0,1091
alter table test2 drop foreign key wj;
--error 0,1215
ALTER TABLE test2 ADD CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1(c2);
drop table   test2;
drop table   test1;
set FOREIGN_KEY_CHECKS = on;







--echo     #foreign_key-11     DML 执 行
--echo     #foreign_key-11-1     删除父表后设置为on
set FOREIGN_KEY_CHECKS = off;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;
create table test1(c1 int PRIMARY key ,c2 bigint UNIQUE,c3 char(8),c4 time);
create table test2(id int,h1 bigint,h2 varchar(10),h3 date,
CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
desc test1;
desc test2;
insert into test1 values(5,6,'bbb','22:36:59');
insert into test2 values(5,6,'aaaa','2222-06-20');
drop table   test1;
set FOREIGN_KEY_CHECKS = on;
--error 0,1452
insert into test2 values(1,1,'aaaa','2022-6-28');
--error 0,1452
insert into test2 values(null,1,'aaaa','2022-6-28');
--error 0,1452
insert into test2 values(2,1,'aaaa','2022-6-28');
select * from test2;
--error 0,1452
insert into test2 select * from test2;
--error 0,1452
insert into test2(id,h1) select id,h1 from test2;
--error 0,1452
update test2 set id=6 where id=5;
--error 0,1452
update test2 set h1=5 where h1=6;
select * from test2;
--error 0,1452
update test2 set id=6 where h2='aaaa';
--error 0,1146
delete from test2 where id=5;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;



--echo     #foreign_key-11-2     删除父表的约束字段后设置为on
set FOREIGN_KEY_CHECKS = off;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;
create table test1(c1 int PRIMARY key ,c2 bigint UNIQUE,c3 char(8),c4 time);
create table test2(id int,h1 bigint,h2 varchar(10),h3 date,
CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
desc test1;
desc test2;
insert into test1 values(5,6,'bbb','22:36:59');
insert into test2 values(5,6,'aaaa','2222-06-20');
--error 0,5320,1235
ALTER TABLE test1 DROP COLUMN c1;    
ALTER TABLE test1 DROP COLUMN c2;
--error 0,5320,1235
ALTER TABLE test2 DROP COLUMN id; 
set FOREIGN_KEY_CHECKS = on;
drop table   test2;
drop table   test1;



--echo     #foreign_key-11-3	   删除父表后设置为off(报错)
set FOREIGN_KEY_CHECKS = on;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;
create table test1(c1 int PRIMARY key ,c2 bigint UNIQUE,c3 char(8),c4 time);
create table test2(id int,h1 bigint,h2 varchar(10),h3 date,
CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
--error 0,3730
drop table   test1;
set FOREIGN_KEY_CHECKS = off;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;



--echo     #foreign_key-11-4     删除父表的约束字段后设置为off(报错)
set FOREIGN_KEY_CHECKS = on;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;
create table test1(c1 int PRIMARY key ,c2 bigint UNIQUE,c3 char(8),c4 time);
create table test2(id int,h1 bigint,h2 varchar(10),h3 date,
CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
--error 0,5320,1050
ALTER TABLE test1 DROP COLUMN c1;
--error 0,5320,1050
ALTER TABLE test2 DROP COLUMN id;
set FOREIGN_KEY_CHECKS = off;
drop table   test2;
drop table   test1;




--echo     #foreign_key-11-5     设   置  为  off
--echo     #对子表进行dml操作
set FOREIGN_KEY_CHECKS = off;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;
create table test1(c1 int PRIMARY key ,c2 bigint UNIQUE,c3 char(8),c4 time);
create table test2(id int,h1 bigint,h2 varchar(10),h3 date,
CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
insert into test1 values(10,20,'aaaaa','24:00:00');
insert into test2 values(10,15,'ccccc','2022-06-29');
insert into test2(id,h1) select c2,c2 from test1;
insert into test2 values(13,15,'ccccc','2022-06-29');
update test2 set id =26 where id =13;
update test2 set id =10/5 where id =10;
DELETE from test2 where id=20 and 26;
drop table   test2;
drop table   test1;



--echo     #对父表进行dml操作
set FOREIGN_KEY_CHECKS = off;
--error 0,1051
drop table   test2;
--error 0,1051
drop table   test1;
create table test1(c1 int PRIMARY key ,c2 bigint UNIQUE,c3 char(8),c4 time);
create table test2(id int,h1 bigint,h2 varchar(10),h3 date,
CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
insert into test1 values(10,20,'aaaaa','24:00:00');
insert into test2 values(10,15,'ccccc','2022-06-29');
--error 0,1062
insert into test1(c1,c2,c3) select id,h1,h2 from test2;
insert into test1(c1,c2,c3) select id+1,h1,h2 from test2;
--error 0,1062
insert into test1(c1,c2,c3) select id,h1,h2 from test2;
--error 0,1048
insert into test1(c1,c2,c3) values(null,null,null);
--error 0,1062
update test1 set c1=10 where c1=11;
--error 0,1062
update test1 set c1=12 where c1=10;
--error 0,1048
update test1 set c1=null where c1=12;
delete from test1 where c1=12;
delete from test1 where c1=11;
--error 0,5320,1235
ALTER TABLE test1 DROP COLUMN c1;
drop table   test2;
drop table   test1;


set FOREIGN_KEY_CHECKS = off;
--error 0,1051
drop table   tf2;
--error 0,1051
drop table   t2;

create table tf2(c1 int primary key, c2 int, foreign key (c1) references t2 (c1));
create table t2 (c1 int primary key);
drop table t2;
flashback table t2 to before drop rename to tt2;
set FOREIGN_KEY_CHECKS = on;

drop table tt2;
drop table tf2;











--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user hjw@'%' ;
--enable_warnings
