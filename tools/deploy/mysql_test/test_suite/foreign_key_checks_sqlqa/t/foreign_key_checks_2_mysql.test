--echo    #foreign_key-6	 off/on交替
set foreign_key_checks = on;
--error 0,1051
drop table  test2;
--error 0,1051
drop table  test1;
create table test1(c1 int PRIMARY key,c2 int UNIQUE,c3 bigint);
create table test2(id int,h1 bigint,h2 varchar(10),h3 date,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
insert into test1 values(1,2,3);
insert into test2 values(1,2,'eeeeee','2222-1-11');
#select * from test1,test2;
--error 0,1091
alter table test2 drop foreign key wj;
alter table test1 drop primary key;
set foreign_key_checks = off;
alter table test1 add primary key(c3);
desc test1;
ALTER TABLE test2 ADD CONSTRAINT wj FOREIGN KEY (h1) REFERENCES test1(c3);
--error 0,1091
alter table test2 drop foreign key wj;
--error 0,1215
ALTER TABLE test2 ADD CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1(c3);
set foreign_key_checks = on;
set foreign_key_checks = off;
ALTER TABLE test2 ADD CONSTRAINT wj FOREIGN KEY (h1) REFERENCES test1(c3);
--error 0,1091
alter table test2 drop foreign key wj;
alter table test1 drop primary key;
alter table test1 add primary key(c3);
ALTER TABLE test2 ADD CONSTRAINT wj FOREIGN KEY (h1) REFERENCES test1(c3);
delete from test1 where c1=1;
delete from test2 where id=1;
#select * from test1,test2;
--error 0,1022
ALTER TABLE test2 ADD CONSTRAINT wj FOREIGN KEY (h1) REFERENCES test1(c3);
--error 0,1091
alter table test2 drop foreign key wj;
ALTER TABLE test2 ADD CONSTRAINT wj FOREIGN KEY (h1) REFERENCES test1(c3);
set foreign_key_checks = on;
--error 0,1091
alter table test2 drop foreign key wj;
drop table  test2;
drop table  test1;








