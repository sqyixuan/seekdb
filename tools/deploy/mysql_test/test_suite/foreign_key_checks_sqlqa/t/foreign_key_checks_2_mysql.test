--echo    #foreign_key-5       drop
--echo    #foreign_key-5-1	 变量设置为：on
--echo    #删除父表外键约束列
set foreign_key_checks = on;
--error 0,1051
drop table test2;
--error 0,1051
drop table test1;
create table test1(c1 int PRIMARY key,c2 int UNIQUE,c3 bigint);
create table test2(id int,h1 bigint,h2 varchar(10),h3 date,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
--error 0,5320
alter table test1 drop COLUMN c1;
alter table test1 drop COLUMN c2;
alter table test1 change column c1 c2 int;
desc test1;
--error 0,5320,1235
alter table test1 drop COLUMN c2;
drop table  test2;
drop table  test1;
create table test1(c1 int PRIMARY key,c2 int UNIQUE,c3 bigint);
create table test2(id int,h1 bigint,h2 varchar(10),h3 date,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
insert into test1 values(1,2,3);
insert into test2 values(1,2,'eeeeee','2222-1-11');
#select * from test1,test2;
--error 0,5320,1235
alter table test1 drop COLUMN c1;
alter table test1 drop COLUMN c2;
#select * from test1,test2;
alter table test1 change column c1 c2 int;
#select * from test1,test2;
--error 0,5320,1235
alter table test1 drop COLUMN c2;
drop table  test2;
drop table  test1;



