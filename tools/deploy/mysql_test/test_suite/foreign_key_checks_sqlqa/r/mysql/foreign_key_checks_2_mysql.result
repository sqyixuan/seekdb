#时间日期类型
set foreign_key_checks = off;
drop table  test2;
drop table  test1;
create table test1(c1 date PRIMARY key);
create table test2(id date,CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
drop table test1;
alter table test2 modify column id TIME;
alter table test2 modify column id YEAR;
alter table test2 modify column id DATETIME;
alter table test2 modify column id TIMESTAMP;
drop table  test2;
drop table  test1;
