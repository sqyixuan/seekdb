#创建一个父表多个子表
drop table if EXISTS test1;
Warnings:
Note	1051	Unknown table 'test.test1'
set FOREIGN_KEY_CHECKS = on;
create table test1(id int PRIMARY key, h1 bigint unique,h2 varchar(10),h3 date);
#创建多个子表
drop procedure if exists procedure_1;
create procedure procedure_1()
BEGIN
DECLARE i INT;
DECLARE table_name VARCHAR(20);
SET i = 0;
WHILE i<100 DO
IF i<10 THEN
SET table_name = CONCAT('test0',i);
ELSE
SET table_name = CONCAT('test',i);
END IF;
SET @csql = CONCAT('CREATE TABLE ',table_name,'(id int,c1 bigint,c2 varchar(10),c3 date,FOREIGN KEY (id) REFERENCES test1 (id))');
PREPARE create_stmt FROM @csql;
EXECUTE create_stmt;
SET i = i+1;
END WHILE;
END ;
/
call procedure_1();
show tables;
