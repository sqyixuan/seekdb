CONSTRAINT wj FOREIGN KEY (id) REFERENCES test1 (c1));
desc test1;
Field	Type	Null	Key	Default	Extra
c1	int(11)	NO	PRI	NULL	
c2	bigint(20)	YES	UNI	NULL	
c3	char(8)	YES		NULL	
c4	time	YES		NULL	
desc test2;
Field	Type	Null	Key	Default	Extra
id	int(11)	YES		NULL	
h1	bigint(20)	YES		NULL	
h2	varchar(10)	YES		NULL	
h3	date	YES		NULL	
