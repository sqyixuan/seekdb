id	h1	h2	h3
5	6	aaaa	2222-06-20
insert into test2 select * from test2;
insert into test2(id,h1) select id,h1 from test2;
update test2 set id=6 where id=5;
update test2 set h1=5 where h1=6;
select * from test2;
id	h1	h2	h3
5	6	aaaa	2222-06-20
update test2 set id=6 where h2='aaaa';
delete from test2 where id=5;
drop table   test2;
drop table   test1;
