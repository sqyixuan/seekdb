--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);




alter system flush plan cache global;
sleep 3;
set autocommit = 0;
alter system set ob_enable_batched_multi_statement=true;
sleep 3;

--disable_result_log



--echo    #cast
--echo    #回退场景

--error 0,1051
drop table if EXISTS test1;
CREATE TABLE test1(id INT(5) PRIMARY KEY AUTO_INCREMENT,
                h2 FLOAT ,
                h3 DOUBLE NOT NULL,
                h4 CHAR(10) DEFAULT 'A',
                h5 VARCHAR(10) UNIQUE,
                h6 CHAR(10),
                h7 INT,
                h8 TIME,
                h9 YEAR ,CHECK(h9>=2000));
INSERT INTO test1(h2,h3,h4,h5,h6,h7,h8,h9) VALUES(1.0,1.1,'中文','','',0,'11:11:11','2000'),
                     (1.1,1.2,'中!文','A','a',1,'11:11:11','2001'),
                     (1.2,2.2,'中!文','B','a',2,'11:11:11','2002'),
                     (1.3,3.2,'中!文','C','a',3,'11:11:11','2003'),
