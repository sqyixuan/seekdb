--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);




--echo   #update-4     多表执行
--echo      #update-4-6    full join    
--echo      #update-4-7    cross join

alter system flush plan cache global;
sleep 3;
set autocommit = 0;
alter system set ob_enable_batched_multi_statement=true;
sleep 3;



--disable_result_log

--echo      #update-4-6    full join    
--error 0,1051
drop table if EXISTS test1,test2;
create table test1(h1 int PRIMARY key AUTO_INCREMENT,h2 varchar(20) not null,h3 FLOAT not null,h4 date not null,h5 char(20) not null);
create table test2(h1 int PRIMARY key AUTO_INCREMENT,h2 varchar(20) not null,h3 FLOAT not null,h4 date not null,h5 char(20) not null);
insert into test1(h2,h3,h4,h5) values('xiaowang',60.5,'2022-05-01','一组');
insert into test1(h2,h3,h4,h5) values('xiaolizi',65.420,'2022-06-16','二组');
insert into test2(h2,h3,h4,h5) values('zhaoyun',107,'2023-10-01','一组');
insert into test2(h2,h3,h4,h5) values('akeyashi',65.420,'2022-01-01','二组');
select * from test1 full join test2 ON test1.h1=test2.h1;

--echo  	#order by
delimiter //;
UPDATE test1 full join  test2 ON test1.h1=test2.h1 set test1.h3=900 where test2.h3=(select * from (select test2.h3 from test2 order by test2.h3 asc LIMIT 1 )as test2);UPDATE test1 full join  test2 ON test1.h1=test2.h1 set test1.h3=70 where test1.h3=(select * from (select test1.h3 from test1 order by test1.h3 asc LIMIT 1 )as test2);UPDATE test1 full join  test2 ON test1.h3=test2.h1 set test1.h3=null where test2.h3=(select * from (select test2.h3 from test2 order by test2.h3 asc LIMIT 1 )as test2);//
delimiter ;//
select * from test1 full join test2 on test1.h1=test2.h1;
delimiter //;
