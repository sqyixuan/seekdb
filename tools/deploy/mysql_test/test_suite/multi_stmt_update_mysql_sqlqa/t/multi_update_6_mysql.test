--echo   #update-6     分区表执行1
--echo	#update-6-1  list分区
--error 0,1051
drop table if EXISTS test1;
create table test1(id int,h1 bigint not null) PARTITION by list(h1)(PARTITION p1 VALUES in(10,20,-10,-20,30,-30,0,null,100,200,300));
insert into test1 PARTITION(p1) VALUES(1,10);
insert into test1 PARTITION(p1) VALUES(2,20);
insert into test1 PARTITION(p1) VALUES(3,-20);
insert into test1 PARTITION(p1) VALUES(4,-10);
select * from test1 order by id asc;
select * from test1 partition(p1) order by id asc;
delimiter //;
