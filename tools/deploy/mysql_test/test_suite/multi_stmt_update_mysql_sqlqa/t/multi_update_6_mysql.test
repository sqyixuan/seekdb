--echo	#外键约束：foreign key
--error 0,1051
drop table if EXISTS test1;
drop table if EXISTS test2;
create table test2(id int PRIMARY key AUTO_INCREMENT,h1 char(20),h2 int);
insert into test2(h1,h2) value('xiaoli',19);
insert into test2(h1,h2) value('aiai',17);
select * from test2 order by h1 asc;


create table test1(abc int PRIMARY key AUTO_INCREMENT,
	h1 int,
	h2 date,
	foreign key(abc) references test2(id));

insert into test1(h1,h2) values(520,'2022-12-31');
select * from test1 order by h1 asc;
select * from test2 order by id asc;
delimiter //;
--error 0, 1054
update test1 set h1=521 where test2.h2=19;update test1 set h1=521 where h1=520;//
delimiter ;//
delimiter //;
update test2 set h1='linlin' where h1='aiai';update test2 set h1='minmin' where h1='linlin';//
delimiter ;//
select * from test2 order by id asc;
delimiter //;
--error 0, 1054
update test1 set id=2 where id=1;update test1 set id=3 where id=2;update test1 set id=3-2 where id=3;//
delimiter ;//
drop table if EXISTS test1;
drop table if EXISTS test2;




--echo   #update-5-3     索引
--echo	#普通索引

--error 0,1051
drop table if EXISTS test1;
create table test1(abc int PRIMARY key AUTO_INCREMENT,h1 FLOAT not null ,h2 bigint not null,CHECK(h2>=1800));
insert into test1(h1,h2)values(520,20000);
select * from test1;
#CREATE INDEX INDEX_1 ON test1(h1);
drop procedure if EXISTS test_process;
delimiter //;
create procedure test_process()
begin
	declare i int default 1;
	while i<300
	do
		insert into test1(h1,h2)values((select * from (select h1+1 from test1 order by h1 desc LIMIT 1)as a),(select * from (select h2+2 from test1 order by h2 desc LIMIT 1) as a));
	set i=i+1;
	end while;
	commit;
end ;
//
delimiter ;//
call test_process();
select * from test1 order by abc asc;

delimiter //;
update test1 set h1=250 where h1=119;update test1 set h1=220 where h1=550;update test1 set h1=119 where h1=320;//
delimiter ;//
select * from test1 order by abc asc;
delimiter //;
--error 0, 3819
update test1 set h2=180 where h2=2588;update test1 set h2=199 where h2=180;update test1 set h2=170 where h2=179;//
delimiter ;//
select * from test1 order by abc asc;
delimiter //;
update test1 set h2=100 where h2=296 and h1=518;update test1 set h2=150 where h2=190 or h1=360;update test1 set h2=180 where h2=150 and h1= 319 and h1=360;//
delimiter ;//
select * from test1 order by abc asc;
drop procedure if EXISTS test_process;
drop table if EXISTS test1;


