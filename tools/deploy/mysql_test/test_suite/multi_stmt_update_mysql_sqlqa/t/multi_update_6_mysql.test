--echo   #update-5-2	 约束
--echo	#主键约束 ：primary key
--error 0,1051
drop table if EXISTS test1;
create table test1(h1 int,
	h2 char(5),
	h3 FLOAT PRIMARY key AUTO_INCREMENT,
	h4 int ,
	h5 date ,
	h6 time );
insert into test1(h1,h2,h3,h4,h5,h6) values(1,
	'aaaaa',
	22222222222.555555555,
	65346523,
	'2020-10-01',
	'00:00:00'),(
	2,
	'bbbbb',
	3654,
	52344,
	'2000-10-01',
	'23:59:59'),(
	3,
	'ccccc',
	63269,
	-956,
	'1900-10-01',
	'00:00:01');
select * from test1 order by h1 asc;


delimiter //;
