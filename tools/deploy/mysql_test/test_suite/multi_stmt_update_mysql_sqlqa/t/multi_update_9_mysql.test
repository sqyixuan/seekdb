--echo	#while循环语句
drop PROCEDURE if EXISTS procedure_1;
--error 0,1051
drop table if EXISTS test1;
create table test1(id int PRIMARY key AUTO_INCREMENT,h2 FLOAT not null,h3 char(10) not null,h4 time);
insert into test1(h2,h3,h4)values(-122.51,'11','00:00:00');
insert into test1(h2,h3,h4)values(-266.55,'22','00:00:01');
insert into test1(h2,h3,h4)values(-336.56,'33','00:00:02');
insert into test1(h2,h3,h4)values(-446.99,'44','00:00:03');
select * from test1 order by id asc;

delimiter //;
create procedure procedure_1()
begin
	declare i int default 1;
	while i<1500
	do
		update test1 set h2=5000 where h2=-446.99 and h3='44' and h4='00:00:03';
		update test1 set h3=3000 where h2=-336.56 or h3='33' or h4='00:00:02';
		update test1 set h2=3000 where h3=h3 order by h3 desc LIMIT 1;
		update test1 set h2=-446.99 where h2=h2 order by h2 desc LIMIT 1;
		set i=i+1;
	end while;
	commit;
end //
delimiter ;//
call procedure_1();
select * from test1;
drop PROCEDURE procedure_1;
drop table if EXISTS test1;


--echo	#repeat循环语句
drop PROCEDURE if EXISTS procedure_1;
drop PROCEDURE if EXISTS procedure_2;
--error 0,1051
drop table if EXISTS test1;
create table test1(id int PRIMARY key AUTO_INCREMENT,h2 FLOAT not null,h3 char(10) not null,h4 time);
select * from test1 order by id asc;
ALTER TABLE test1 ADD INDEX INDEX_1 (id,h2,h3,h4);
delimiter //;
create procedure procedure_1()
begin
    declare i int;
    set i = 1;
    repeat
	insert into test1(h2,h3,h4)values(-122.51,'11','00:00:00');
	insert into test1(h2,h3,h4)values(-266.55,'22','00:00:01');
	insert into test1(h2,h3,h4)values(-336.56,'33','00:00:02');
	insert into test1(h2,h3,h4)values(-446.99,'44','00:00:03');
    set i = i + 1;
    until i > 200 end repeat;
    select * from test1 order by id asc;
end //
delimiter ;//
call procedure_1();
SELECT DISTINCT h2,h3,h4 from test1 order by id asc;
delimiter //;
create procedure procedure_2()
begin
    declare i int;
    set i = 1;
    repeat
	update test1 set h2=h2+10 where id>=700;
	update test1 set h3=h3+10 where id>=700;
    set i = i + 1;
    until i > 500 end repeat;
    select * from test1 order by id asc;
end;
//
delimiter ;//
call procedure_2();
select * from test1 order by id asc;
drop PROCEDURE if EXISTS procedure_1;
drop PROCEDURE if EXISTS procedure_2;
drop table if EXISTS test1;




