--echo	#loop循环语句
--error 0,1051
drop table if EXISTS test1;
create table test1(id int PRIMARY key AUTO_INCREMENT,h2 FLOAT not null,h3 char(10) not null,h4 time);
insert into test1(h2,h3,h4)values(-12000.51,'11','00:00:00');
insert into test1(h2,h3,h4)values(-22000.55,'22','00:00:01');
insert into test1(h2,h3,h4)values(-33000.56,'33','00:00:02');
insert into test1(h2,h3,h4)values(-44000.99,'44','00:00:03');
select * from test1 order by id asc;
ALTER TABLE test1 ADD INDEX INDEX_1 (id,h2,h3,h4);
drop procedure if exists procedure_1;

delimiter //;
create procedure procedure_1()
begin
    declare i int;
    set i = 1;
    lp : loop
        update test1 set h2=h2+2,h3=h3+20;
        set i = i + 1;
        if i > 200 then
            leave lp;
        end if; 
    end loop;
    select * from test1 order by id asc;
end //
delimiter ;//
call procedure_1(); 
select * from test1 order by id asc;
drop PROCEDURE procedure_1;
