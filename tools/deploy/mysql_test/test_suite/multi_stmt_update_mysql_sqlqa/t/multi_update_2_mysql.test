insert into test1(h2,h3,h4) values('后裔',16,'2022-07-15');
insert into test1(h2,h3,h4) values('诸葛',18,'2022-06-15');
insert into test1(h2,h3,h4) values('廉颇',19,'2022-02-15');
select * from test1 order by h1 asc;
delimiter //;
update test1 set h2='老夫子' where h2='安其拉';update test1 set h2='老夫子' where h2='安其拉';//
update test1 set h2='老夫子' where h2='安其拉';//
delimiter ;//
select * from test1 order by h1 asc;
delimiter //;
--error 0,1292
update test1 set h2='老夫子' where h4='安其拉' and h3=17 and h4 ='2022-09-15';update test1 set h2='老夫子' where h4='安其拉' and h3=17 and h4 ='2022-09-15';//
delimiter ;//
select * from test1 order by h1 asc;
delimiter //;
update test1 set h3=20 where h3=18;update test1 set h3=20 where h3=18;update test1 set h3=20 where h3=18;//
delimiter ;//
select * from test1 order by h1 asc;
delimiter //;
update test1 set h4='2024-01-01' where h4='2022-02-15';//
update test1 set h4='2024-01-01' where h4='2022-02-15';update test1 set h4='2024-01-01' where h4='2022-02-15';//
delimiter ;//
select * from test1 order by h1 asc;
drop table if EXISTS test1;




