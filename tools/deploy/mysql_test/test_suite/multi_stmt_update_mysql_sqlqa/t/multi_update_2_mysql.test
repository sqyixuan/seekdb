--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);



--echo   #update-3     单表执行
--echo   #update-4     多表执行
--echo      #update-4-1    交叉连接     
--echo      #update-4-2    基本连接

--disable_result_log



alter system flush plan cache global;
sleep 3;
set autocommit = 0;
alter system set ob_enable_batched_multi_statement=true;
sleep 3;





--echo   #update-3-2     单表信息更新记录
--error 0,1051
drop table test1;
create table test1(id int PRIMARY key AUTO_INCREMENT,name varchar(20),age int,years date);
insert into test1(name,age,YEARs) values('妲己',15,'2022-05-01');
insert into test1(name,age,YEARs) values('赵云',16,'2023-10-01');
insert into test1(name,age,YEARs) values('阿珂',17,'2022-01-01');
insert into test1(name,age,YEARs) values('亚瑟',18,'2022-08-15');
select * from test1 order by id asc;
delimiter //;
update test1,test1 as b set test1.age=b.age where test1.age=b.age and test1.age=16 and b.age=17;update test1,(select * from test1 where age=20) as b set test1.age=b.age where test1.age=b.age;//
delimiter ;//
select * from test1 order by id asc;
delimiter //;
update test1 set age=19 where age=18;update test1 set years='2022-06-01' where years='2022-01-01';update test1 set name='鲁班' where name='亚瑟';//
delimiter ;//
select * from test1 order by id asc;
delimiter //;
update test1 set age=19 where age=18;update test1 set years='2022-06-01' where years='2022-01-01';update test1 set name='鲁班' where name='亚瑟';//
update test1 set age=19 where age=18;update test1 set years='2022-06-01' where years='2022-01-01';update test1 set name='鲁班' where name='亚瑟';//
update test1 set age=19 where age=18;update test1 set years='2022-06-01' where years='2022-01-01';update test1 set name='鲁班' where name='亚瑟';//
update test1 set age=19 where age=18;update test1 set years='2022-06-01' where years='2022-01-01';update test1 set name='鲁班' where name='亚瑟';//
update test1 set age=19 where age=18;update test1 set years='2022-06-01' where years='2022-01-01';update test1 set name='鲁班' where name='亚瑟';//
delimiter ;//
select * from test1 order by id asc;
delimiter //;
update test1 set age=LOG(age,20) where age=age;update test1 set years=ADDDATE(years, '10') where years=years;update test1 set years=ADDDATE(years, '-5') where years=years;//
delimiter ;//
select * from test1 order by id asc;
delimiter //;
update test1 set age=abs(10)+2 where age=age and id=1;update test1 set age=abs(10)+6 where age=age and id=2;//
update test1 set age=abs(10)+10 where age=age and id=3;update test1 set age=abs(10)+15 where age=age and id=4;//
delimiter ;//
select * from test1 order by id asc;
drop table if EXISTS test1;




--echo   #update-3-3     将不同函数赋值给同一字段
--echo    #数值函数 
--error 0,1051
drop table if EXISTS test1;
create table test1(h1 int PRIMARY key AUTO_INCREMENT,h2 varchar(20),h3 int,h4 date);
insert into test1(h2,h3,h4) values('妲己',15,'2022-05-01');
insert into test1(h2,h3,h4) values('赵云',16,'2023-10-01');
insert into test1(h2,h3,h4) values('阿珂',17,'2022-01-01');
insert into test1(h2,h3,h4) values('亚瑟',18,'2022-08-15');
insert into test1(h2,h3,h4) values('安其拉',17,'2022-09-15');
insert into test1(h2,h3,h4) values('后裔',16,'2022-07-15');
insert into test1(h2,h3,h4) values('诸葛',18,'2022-06-15');
insert into test1(h2,h3,h4) values('廉颇',19,'2022-02-15');
select * from test1 order by h1 asc;
delimiter //;
update test1 set h3=CEIL(20) where h3=19;update test1 set h3=CEILING(25) where h3=CEIL(20);update test1 set h3=SQRT(125) where h3=CEILING(25);//
delimiter ;//
select * from test1 order by h1 asc;
delimiter //;
update test1 set h3=11 where h3=SQRT(125);update test1 set h3=11 where h3=SQRT(125);update test1 set h3=11 where h3=CEILING(25);//
delimiter ;//
select * from test1 order by h1 asc;
delimiter //;
update test1 set h3=12 where h3=SQRT(125);update test1 set h3=CEILING(25) where h3=12;update test1 set h3=CEIL(20) where h3=25;//
delimiter ;//
select * from test1 order by h1 asc;
delimiter //;
--error 0,1064
update test1 set h3=22 where h3=null;update test1 set h3=22 where h3= ;//
delimiter ;//
select * from test1 order by h1 asc;



--echo    #字符串函数 
delimiter //;
--error 0,1292
update test1 set h2='小乔' where h2=ASCII('安其拉');update test1 set h2='孙尚香' where h2=CHARACTER_LENGTH('小乔');//
update test1 set h2='墨子' where h2=REVERSE('孙尚香');//
delimiter ;//
select * from test1 order by h1 asc;
delimiter //;
update test1 set h2='小乔' where h2=RTRIM('安其拉');update test1 set h2='孙尚香' where h2=SUBSTR('小乔',4);//
delimiter ;//
select * from test1 order by h1 asc;
delimiter //;
update test1 set h2='嬴政' where h2=UPPER('小乔');update test1 set h2='刘婵' where h2=UPPER('嬴政');//
delimiter ;//
select * from test1 order by h1 asc;




--echo    #时间日期函数
delimiter //;
--error 0,1064
update test1 set h4='2023-10-01' where h4=CURTIME();update test1 set h4='2023-08-15' where h4=DATE();//
delimiter ;//
select * from test1 order by h1 asc;
delimiter //;
update test1 set h4='2023-10-01' where h4=CURTIME();update test1 set h4='2023-08-15' where h4=DATE('2022-02-15');//
delimiter ;//
select * from test1 order by h1 asc;
delimiter //;
update test1 set h4='2021-08-15' where h4=DATE('2023-08-15')-10;update test1 set h4='2021-08-15' where h4=DATE('2023-08-15');//
delimiter ;//
select * from test1 order by h1 asc;
delimiter //;
update test1 set h4=CURRENT_TIME() where h4='2022-09-15';update test1 set h4=h4+CURRENT_TIME() where h4=CURRENT_TIME();//
delimiter ;//
select * from test1 order by h1 asc;
drop table if EXISTS test1;



--echo   #update-3-4	 多个语句更新相同的字段和数值
--error 0,1051
drop table if EXISTS test1;
create table test1(h1 int PRIMARY key AUTO_INCREMENT,h2 varchar(20),h3 int,h4 date);
insert into test1(h2,h3,h4) values('妲己',15,'2022-05-01');
insert into test1(h2,h3,h4) values('赵云',16,'2023-10-01');
insert into test1(h2,h3,h4) values('阿珂',17,'2022-01-01');
insert into test1(h2,h3,h4) values('亚瑟',18,'2022-08-15');
