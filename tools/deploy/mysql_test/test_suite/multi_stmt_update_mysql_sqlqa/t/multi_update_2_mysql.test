--echo   #update-4     多表执行
--echo   #update-4-1     交叉连接
--echo   #update  select  同上
--error 0,1051
drop table if EXISTS test1,test2;
create table test1(id int PRIMARY key AUTO_INCREMENT,h1 FLOAT,h2 int,h3 date,h4 char(20));
insert into test1(h1,h2,h3,h4) values(30.5,15,'2022-05-01','xiaowang');
select * from test1 order by h1 asc;

create table test2(h1 int PRIMARY key AUTO_INCREMENT,h2 varchar(20),h3 int,h4 date,h5 FLOAT,h6 DOUBLE NOT NULL,CHECK(h5>=2000));
insert into test2(h2,h3,h4,h5,h6) values('妲己',15,'2022-05-01',2001.5,3000.1);
insert into test2(h2,h3,h4,h5,h6) values('赵云',16,'2023-10-01',2002.3,3040.3);
insert into test2(h2,h3,h4,h5,h6) values('阿珂',17,'2022-01-01',2003.8,2009.2);
insert into test2(h2,h3,h4,h5,h6) values('亚瑟',18,'2022-08-15',2020.5,3001.9);
insert into test2(h2,h3,h4,h5,h6) values('安其拉',17,'2022-09-15',2009.3,3020.9);
insert into test2(h2,h3,h4,h5,h6) values('后裔',16,'2022-07-15',2900.2,3120.7);
insert into test2(h2,h3,h4,h5,h6) values('诸葛',18,'2022-06-15',2999.7,3220.5);
insert into test2(h2,h3,h4,h5,h6) values('廉颇',19,'2022-02-15',2320.1,3320.1);
select * from test2 order by h1 asc;
select * from test1,test2;


--echo  	#order by
delimiter //;
update test1,test2 set test1.h3=test2.h4 where test2.h4=(select * from (select h4 from test2 order by h1 asc LIMIT 1)as test2);update test1,test2 set test1.h3=test2.h4 where test2.h4=(select * from (select h4 from test2 order by h1 desc LIMIT 1)as test2);//
delimiter ;//
COMMIT;
select * from test1,test2 order by test1.h1 asc;
delimiter //;
update test1,test2 set test1.h1=test2.h5 where test2.h2=(select * from (select h2 from test2 order by h1 asc LIMIT 1)as test2);update test1,test2 set test1.h1=test2.h5 where test2.h2=(select * from (select h2 from test2 order by h1 desc LIMIT 1)as test2);//
delimiter ;//
COMMIT;
select * from test1,test2 order by test1.h1 asc;
delimiter //;
update test1,test2 set test1.h2=test2.h3 where test2.h3=(select * from (select h3 from test2 order by h1 asc LIMIT 1)as test2);update test1,test2 set test1.h2=test2.h3 where test2.h3=(select * from (select h3 from test2 order by h1 desc LIMIT 1)as test2);//
delimiter ;//
COMMIT;
select * from test1,test2 order by test1.h1 asc;




--echo  	#like
delimiter //;
update test1,test2 set test1.h3=test2.h4 where test2.h4=(select * from (select h4 from test2 where h4 like '%22%' order by h4 asc LIMIT 1)as test2);update test1,test2 set test1.h3=test2.h4 where test2.h4=(select * from (select h4 from test2 where h4 like '%22%' order by h4 desc LIMIT 1)as test2);//
delimiter ;//
COMMIT;
select * from test1,test2 order by test1.h1 asc;
delimiter //;
update test1,test2 set test1.h1=test2.h5 where test2.h5=(select * from (select h5 from test2 where h4 like '%0%' order by h1 asc LIMIT 1)as test2);update test1,test2 set test1.h1=test2.h5 where test2.h5=(select * from (select h5 from test2 where h4 like '%8%' order by h1 asc LIMIT 1)as test1);//
delimiter ;//
COMMIT;
select * from test1,test2 order by test1.h1 asc;
delimiter //;
update test1,test2 set test1.h4=test2.h2 where test2.h2=(select * from (select h2 from test2 where h2 like '%其%' order by h1 asc LIMIT 1)as test2);update test1,test2 set test1.h4=test2.h2 where test2.h2=(select * from (select h2 from test2 where h2 like '%珂%' order by h1 asc LIMIT 1)as test2);//
delimiter ;//
COMMIT;
select * from test1,test2 order by test1.h1 asc;
delimiter //;
update test1,test2 set test1.h4=test2.h2 where test2.h2 like '%22%';update test1,test2 set test1.h4=test2.h2 where test2.h2 like '%02%';//
update test1,test2 set test1.h4=test2.h2 where test2.h2 like '%瑟%';update test1,test2 set test1.h4=test2.h2 where test2.h2 like '%安%';//
delimiter ;//
COMMIT;
select * from test1,test2 order by test1.h1 asc;






--echo  	#group by结合聚合
delimiter //;
update test1,test2 set test1.h4=test2.h2 where test2.h3=(select * from (select max(test2.h3) from test2 group by h3 order by h3 asc LIMIT 1) as test2 );update test1,test2 set test1.h4=test2.h2 where test2.h4=(select * from (select max(test2.h4) from test2 group by h4 order by h4 asc LIMIT 1) as test2 );//
delimiter ;//
COMMIT;
select * from test1,test2 order by test1.h1 asc;
delimiter //;
update test1,test2 set test1.h2=test2.h5 where test2.h5=(select * from (select min(test2.h5) from test2 group by h5 order by h5 asc LIMIT 1) as test2 );update test1,test2 set test1.h2=test2.h5 where test2.h5=(select * from (select min(test2.h5) from test2 group by h5 order by h5 asc LIMIT 1) as test2 );//
delimiter ;//
COMMIT;
select * from test1,test2 order by test1.h1 asc;
delimiter //;
update test1,test2 set test1.h3=test2.h4 where test2.h5=(select * from (select sum(test2.h5) from test2 group by h5 order by h5 asc LIMIT 1) as test2 );update test1,test2 set test1.h3=test2.h4 where test2.h6=(select * from (select sum(test2.h6) from test2 group by h6 order by h6 asc LIMIT 1) as test2 );//
delimiter ;//
COMMIT;
select * from test1,test2 order by test1.h1 asc;
delimiter //;
update test1,test2 set test1.h4=test2.h2 where test2.h3=(select * from (select avg(test2.h3) from test2 group by h3 order by h3 asc LIMIT 1) as test2 );update test1,test2 set test1.h4=test2.h2 where test2.h5=(select * from (select avg(test2.h5) from test2 group by h5 order by h5 asc LIMIT 1) as test2 );//
delimiter ;//
COMMIT;
select * from test1,test2 order by test1.h1 asc;
delimiter //;
update test1,test2 set test1.h1=test2.h6 where test2.h6=(select * from (select COUNT(test2.h6) from test2 group by h6 order by h6 asc LIMIT 1) as test2 );update test1,test2 set test1.h1=test2.h5 where test2.h5=(select * from (select COUNT(test2.h5) from test2 group by h5 order by h5 asc LIMIT 1) as test2 );//
delimiter ;//
COMMIT;
select * from test1,test2 order by test1.h1 asc;



--echo  	#where
--echo       #in,not in
