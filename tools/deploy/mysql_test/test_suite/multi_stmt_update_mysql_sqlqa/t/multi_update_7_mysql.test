create table test1(id int,h1 bigint not null,h2 char(20),h3 time)PARTITION by range(h1)(partition p0 values less than maxvalue);
insert into test1 PARTITION(p0) VALUES(1,-10,'aaa','00:00:01');
insert into test1 PARTITION(p0) VALUES(2,20,'bbb','00:00:02');
insert into test1 PARTITION(p0) VALUES(3,30,'ccc','00:00:03');
insert into test1 PARTITION(p0) VALUES(4,-40,'ddd','00:00:04');
select * from test1 order by id asc;	
select * from test1 partition(p0) order by id asc;
set @a=120;
delimiter //;
--error 0, 1235
update test1 partition(p0) set h1=@a where h1=-40;update test1 partition(p0) set h1=@a+1 where h1=@a;//
delimiter ;//
select * from test1 order by id asc;	
select * from test1 partition(p0) order by id asc;
set @b='ggg';
delimiter //;
--error 0,1210,1235,1292
update test1 partition(p0) set h2=@a where h2='aaa';update test1 partition(p0) set h2=@a where h2=@a;//
delimiter ;//
select * from test1 order by id asc;	
select * from test1 partition(p0) order by id asc;
set @c='00:10:01';
delimiter //;
update test1 partition(p0) set h3=h3+@c where h3=@c;//
delimiter ;//
select * from test1 order by id asc;	
select * from test1 partition(p0) order by id asc;
DELETE from test1;
