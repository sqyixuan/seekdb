insert into test1 PARTITION(p0) VALUES(2,20,'bbb','00:00:02');
insert into test1 PARTITION(p0) VALUES(3,30,'ccc','00:00:03');
insert into test1 PARTITION(p0) VALUES(4,-40,'ddd','00:00:04');
select * from test1 order by id asc;	
select * from test1 partition(p0) order by id asc;
delimiter //;
