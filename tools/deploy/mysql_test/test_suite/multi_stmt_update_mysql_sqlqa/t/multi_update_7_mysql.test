--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);



--echo   #update-6     分区表执行1
--echo   #update-6-2     hash分区     
--echo   #update-6-3     range分区  
--echo   #update-6-4     key分区

alter system flush plan cache global;
sleep 3;
set autocommit = 0;
alter system set ob_enable_batched_multi_statement=true;
sleep 3;


--disable_result_log

--echo   #update-6-2     hash分区    
--error 0,1051
drop table if EXISTS test1;
create table test1(id int,h1 bigint not null,h2 char(20),h3 time) PARTITION by hash(h1);
insert into test1 PARTITION(p0) VALUES(1,10,'aaaaaaaaaaa','00:00:01');
insert into test1 PARTITION(p0) VALUES(2,20,'bbbbbbbbbbb','00:00:02');
insert into test1 PARTITION(p0) VALUES(3,-20,'cccccccccc','00:00:03');
insert into test1 PARTITION(p0) VALUES(4,-10,'dddddddddd','00:00:04');
select * from test1 order by id asc;
select * from test1 partition(p0) order by id asc;

--echo   #update select
--echo	#order by
