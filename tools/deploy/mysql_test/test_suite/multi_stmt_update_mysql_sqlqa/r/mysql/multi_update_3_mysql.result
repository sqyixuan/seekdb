UPDATE test1 LEFT JOIN  test2 ON test1.h1=test2.h1 set test2.h4='1980-01-01' where test1.h4=(select * from (select test1.h4 from test1 order by test1.h4 asc LIMIT 1 )as test1);UPDATE test1 LEFT JOIN  test2 ON test1.h3=null set test1.h3='null' where test2.h3=(select * from (select test2.h3 from test2 order by test2.h3 asc LIMIT 1 )as test2);//
select * from test1 LEFT JOIN test2 on test1.h1=test2.h1;
UPDATE test1 LEFT JOIN  test2 ON test1.h1=test2.h1 set test1.h2='aaaaaaaaaa' where test2.h2=(select * from (select test2.h2 from test2 order by test2.h3 asc LIMIT 1 )as test2);UPDATE test1 LEFT JOIN  test2 ON test1.h1=test2.h1 set test1.h2='bbbbbbbbbb' where test1.h2=(select * from (select test1.h2 from test2 order by test2.h3 asc LIMIT 1 )as test2);UPDATE test1 LEFT JOIN  test2 ON test1.h1=test2.h1 set test2.h2='cccccccccc' where test2.h2=(select * from (select test2.h2 from test1 order by test1.h3 asc LIMIT 1 )as test1);//
