UPDATE test1 LEFT JOIN  test2 ON test1.h3=test2.h1 set test1.h3=null where test2.h3=(select * from (select test2.h3 from test2 order by test2.h3 asc LIMIT 1 )as test2);//
select * from test1 LEFT JOIN test2 on test1.h1=test2.h1;
