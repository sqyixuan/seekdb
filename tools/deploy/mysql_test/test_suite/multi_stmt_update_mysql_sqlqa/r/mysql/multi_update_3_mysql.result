UPDATE test1 LEFT JOIN test2 ON test1.h1=test2.h1 set test1.h3=(select * from(select max(test2.h3) over(PARTITION by test2.h3 order by test2.h3 ROWS BETWEEN 1 preceding AND 1 following) from test2 LIMIT 1)as test);UPDATE test1 LEFT JOIN test2 ON test1.h1=test2.h1 set test1.h3=(select * from(select max(test2.h3) over(PARTITION by test2.h3 order by test2.h3 ROWS BETWEEN 1 preceding AND current row) from test2 LIMIT 1)as test);//
UPDATE test1 LEFT JOIN test2 ON test1.h1=test2.h1 set test1.h3=(select * from(select max(test2.h3) over(PARTITION by test2.h3 order by test2.h3 ROWS BETWEEN current row AND unbounded following) from test2 LIMIT 1)as test);UPDATE test1 LEFT JOIN test2 ON test1.h1=test2.h1 set test1.h3=(select * from(select max(test2.h3) over(PARTITION by test2.h3 order by test2.h3 ROWS BETWEEN unbounded preceding AND current row) from test2 LIMIT 1)as test);//
select * from test1 LEFT JOIN test2 on test1.h1=test2.h1;
UPDATE test1 LEFT JOIN test2 ON test1.h1=test2.h1 set test1.h3=(select * from(select min(test2.h3) over(PARTITION by test2.h3 order by test2.h3 ROWS BETWEEN 1 preceding AND 1 following) from test2 LIMIT 1)as test );UPDATE test1 LEFT JOIN test2 ON test1.h1=test2.h1 set test1.h3=(select * from(select min(test2.h3) over(PARTITION by test2.h3 order by test2.h3 ROWS BETWEEN 1 preceding AND current row) from test2 LIMIT 1)as test);//
UPDATE test1 LEFT JOIN test2 ON test1.h1=test2.h1 set test1.h3=(select * from(select min(test2.h3) over(PARTITION by test2.h3 order by test2.h3 ROWS BETWEEN current row AND unbounded following) from test2 LIMIT 1)as test);UPDATE test1 LEFT JOIN test2 ON test1.h1=test2.h1 set test1.h3=(select * from(select min(test2.h3) over(PARTITION by test2.h3 order by test2.h3 ROWS BETWEEN unbounded preceding AND current row) from test2 LIMIT 1)as test);//
select * from test1 LEFT JOIN test2 on test1.h1=test2.h1;
UPDATE test1 LEFT JOIN test2 ON test1.h1=test2.h1 set test1.h3=(select * from(select sum(test2.h3) over(PARTITION by test2.h3 order by test2.h3 ROWS BETWEEN 1 preceding AND 1 following) from test2 LIMIT 1)as test );UPDATE test1 LEFT JOIN test2 ON test1.h1=test2.h1 set test1.h3=(select * from(select sum(test2.h3) over(PARTITION by test2.h3 order by test2.h3 ROWS BETWEEN 1 preceding AND current row) from test2 LIMIT 1)as test);//
UPDATE test1 LEFT JOIN test2 ON test1.h1=test2.h1 set test1.h3=(select * from(select sum(test2.h3) over(PARTITION by test2.h3 order by test2.h3 ROWS BETWEEN current row AND unbounded following) from test2 LIMIT 1)as test);UPDATE test1 LEFT JOIN test2 ON test1.h1=test2.h1 set test1.h3=(select * from(select sum(test2.h3) over(PARTITION by test2.h3 order by test2.h3 ROWS BETWEEN unbounded preceding AND current row) from test2 LIMIT 1)as test);//
