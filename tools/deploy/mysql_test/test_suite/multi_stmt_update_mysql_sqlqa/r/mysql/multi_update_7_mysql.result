#in,not in
update test1 partition(p0) set h1 in(20) where h1 in(-10);update test1 partition(p0) set h1 in(10) where h1 in(-20);//
update test1 partition(p0) set h1 in(-20) where h1 not in(-10);update test1 partition(p0) set h1 in(-10) where h1 not in(10);//
