#group by结合聚合
drop table if EXISTS test1;
create table test1(id int,h1 bigint not null,h2 char(20),h3 time) PARTITION by hash(h1);
insert into test1 PARTITION(p0) VALUES(1,10,'aaaaaaaaaaa','00:00:01');
insert into test1 PARTITION(p0) VALUES(2,20,'bbbbbbbbbbb','00:00:02');
insert into test1 PARTITION(p0) VALUES(3,-20,'cccccccccc','00:00:03');
insert into test1 PARTITION(p0) VALUES(4,-10,'dddddddddd','00:00:04');
select * from test1 order by id asc;
select * from test1 partition(p0) order by id asc;
update test1 partition(p0) set h1=200  where h1=(select * from (select max(h1) from test1 group by id order by id asc LIMIT 1)as a);update test1 partition(p0) set h1=300  where h1=(select * from (select sum(h1) from test1 group by id order by id asc LIMIT 1)as a);update test1 partition(p0) set h1=150  where h1=(select * from (select avg(h1) from test1 group by id order by id asc LIMIT 1)as a);//
update test1 partition(p0) set h1=650  where h1=(select * from (select count(h1) from test1 group by id order by id asc LIMIT 1)as a);update test1 partition(p0) set h1=750  where h1=(select * from (select min(h1) from test1 group by id order by id asc LIMIT 1)as a);//
select * from test1 partition(p0) order by id asc;
update test1 partition(p0) set h2='qqqqqq' where h2=(select * from (select max(h2) from test1 group by id order by id asc LIMIT 1)as a);update test1 partition(p0) set h2='wwwwww' where h2=(select * from (select sum(h2) from test1 group by id order by id asc LIMIT 1)as a);//
update test1 partition(p0) set h2='rrrrrr' where h2=(select * from (select avg(h2) from test1 group by id order by id asc LIMIT 1)as a);update test1 partition(p0) set h2='tttttt' where h2=(select * from (select count(h2) from test1 group by id order by id asc LIMIT 1)as a);update test1 partition(p0) set h2='yyyyyy' where h2=(select * from (select min(h2) from test1 group by id order by id asc LIMIT 1)as a);//
select * from test1 partition(p0) order by id asc;
update test1 partition(p0) set h3='00:04:04' where h3=(select * from (select max(h3) from test1 group by h3 order by h3 asc LIMIT 1)as a);update test1 partition(p0) set h3='04:04:04' where h3=(select * from (select sum(h3) from test1 group by h3 order by h3 asc LIMIT 1)as a);update test1 partition(p0) set h3='12:04:04' where h3=(select * from (select avg(h3) from test1 group by h3 order by h3 asc LIMIT 1)as a);//
update test1 partition(p0) set h3='58:04:04' where h3=(select * from (select count(h3) from test1 group by h3 order by h3 asc LIMIT 1)as a);update test1 partition(p0) set h3='59:59:59' where h3=(select * from (select min(h3) from test1 group by h3 order by h3 asc LIMIT 1)as a);//
select * from test1 partition(p0) order by id asc;
