update test1 partition(p0) set h2='rrrrrr' where h2=(select * from (select avg(h2) from test1 group by id order by id asc LIMIT 1)as a);update test1 partition(p0) set h2='tttttt' where h2=(select * from (select count(h2) from test1 group by id order by id asc LIMIT 1)as a);update test1 partition(p0) set h2='yyyyyy' where h2=(select * from (select min(h2) from test1 group by id order by id asc LIMIT 1)as a);//
