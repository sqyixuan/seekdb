update test1 PARTITION(p0) set h3='00:03:01' where exists (select * from (select h3 from test1 where h3='00:00:03')as a);update test1 PARTITION(p0) set h3='00:04:01' where exists (select * from (select h3 from test1 where h3='00:00:04')as a);//
