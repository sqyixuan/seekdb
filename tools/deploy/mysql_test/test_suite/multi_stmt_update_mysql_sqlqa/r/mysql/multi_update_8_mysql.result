select * from test1 partition(p0) order by id asc;
COMMIT;
update test1 partition(p1) set h3='00:01:01' where h3=(select * from (select h3 from test1 order by h3 asc LIMIT 1)as a);update test1 partition(p1) set h3='00:02:01' where h3=(select * from (select h3 from test1 order by h3 asc LIMIT 1)as a);update test1 partition(p1) set h3='00:03:01' where h3=(select * from (select h3 from test1 order by h3 asc LIMIT 1)as a);//
select * from test1 partition(p0) order by id asc;
COMMIT;
update test1 partition() set h3='00:01:01' where h3=(select * from (select h3 from test1 order by h3 asc LIMIT 1)as a);update test1 partition() set h3='00:02:01' where h3=(select * from (select h3 from test1 order by h3 asc LIMIT 1)as a);update test1 partition() set h3='00:03:01' where h3=(select * from (select h3 from test1 order by h3 asc LIMIT 1)as a);//
