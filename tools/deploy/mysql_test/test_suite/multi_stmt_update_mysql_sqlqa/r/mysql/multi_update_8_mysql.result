update test1 partition(p0) set h3='01:02:01' where h3=(select * from (select h3 from test1 order by h3 asc LIMIT 1)as a);update test1 partition(p0) set h3='05:03:01' where h3=(select * from (select h3 from test1 order by h3 asc LIMIT 1)as a);//
