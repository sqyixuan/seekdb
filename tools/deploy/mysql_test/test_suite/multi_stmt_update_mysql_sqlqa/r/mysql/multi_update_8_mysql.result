update test1 partition(p0) set h2='zxcvbnm' where h2 not in('cccccccccc');update test1 partition(p0) set h2='qazxswedc' where h2 not in('dddddddddd');//
select * from test1 partition(p0) order by id asc;
COMMIT;
update test1 partition(p0) set h3='01:01:01' where h3 in('00:00:01');update test1 partition(p0) set h3='02:02:02' where h3 in('00:00:02');//
update test1 partition(p0) set h3='03:20:59' where h3 not in('00:00:03');update test1 partition(p0) set h3=h3+1 where h3 not in('03:20:59');//
select * from test1 partition(p0) order by id asc;
COMMIT;
update test1 partition(p0) set h3=h3+1 where h3 in('03:20:59');//
select * from test1 partition(p0) order by id asc;
COMMIT;
