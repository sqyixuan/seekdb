COMMIT;
update test1 partition(p0) set h3='01:51:59' where h3=(select * from (select h3 from test1 where h3 like '%01:51:00%'  LIMIT 1)as a);update test1 partition(p0) set h3 like '%01:51:59%'+1 where h3=(select * from (select h3 from test1 where h3 like '%01:51:59%'  LIMIT 1)as a);//
