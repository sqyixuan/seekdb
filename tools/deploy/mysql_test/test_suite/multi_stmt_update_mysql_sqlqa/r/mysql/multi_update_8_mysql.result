COMMIT;
update test1 partition(p0) set h3='00:20:01' where h3=(select * from (select h3 from test1 where h3 like '%0%' order by h3 asc LIMIT 1)as a);update test1 partition(p0) set h3='22:00:01' where h3=(select * from (select h3 from test1 where h3 like '%0%' order by h3 desc LIMIT 1)as a);update test1 partition(p0) set h3=-800+300 where h3=(select * from (select h3 from test1 where h3 like '%0%' order by h3 asc LIMIT 1)as a);//
select * from test1 partition(p0) order by id asc;
COMMIT;
update test1 partition(p0) set h3='01:50:59' where h3=(select * from (select h3 from test1 where h3 like '%00:00:03%'  LIMIT 1)as a);update test1 partition(p0) set h3='01:51:00' where h3=(select * from (select h3 from test1 where h3 like '%01:50:59%' LIMIT 1)as a);update test1 partition(p0) set h3='01:51:00'+1 where h3=(select * from (select h3 from test1 where h3 like '%01:51:00%'  LIMIT 1)as a);//
