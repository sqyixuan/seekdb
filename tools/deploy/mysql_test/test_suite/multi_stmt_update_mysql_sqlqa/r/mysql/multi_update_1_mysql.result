update test1 set h2=10 where h2=32 and h1=1;update test1 set h2=15 where h2=32 and h1=2;update test1 set h2=20 where h2=32 and h1=35;//
select * from test1 order by h1 asc;
update test1 set h1=18 where h1<h2 and h1=1;update test1 set h1=13 where h1<h2 and h1=2;update test1 set h1=13 where h2<h1 and h1=35;//
select * from test1 order by h1 asc;
update test1 set h1=38 where h1<=h2;update test1 set h1=33 where h1<=h2 ;update test1 set h1=63 where h2<h1;//
select * from test1 order by h1 asc;
update test1 set h1=19 where h1<>h2 or h2=15;//
update test1 set h1=17 where h1<>h2 or h2=15 ;update test1 set h1=63 where h2<0>h1;//
select * from test1 order by h1 asc;
update test1 set h1=19 where h1<15>h2 or h2=15;update test1 set h1=19 where h1<>h2 or h2=10;//
select * from test1 order by h1 asc;
update test1 set h1=19 where h1!=h2;update test1 set h1=19 where h1!=h1;//
select * from test1 order by h1 asc;
update test1 set h1=11 where h1!=20 and h2=10;//
update test1 set h1=12 where h1!=20 and h2=15;update test1 set h1=13 where h1!=20 and h2=20;//
select * from test1 order by h1 asc;
drop table if EXISTS test1;
alter system set ob_enable_batched_multi_statement=false;
alter system set _rowsets_enabled=true;
