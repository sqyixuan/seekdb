#over分析函数
#ROWS BETWEEN 1 preceding AND 1 following; 
drop table if EXISTS test1;
create table test1(h1 int,h2 int);
insert into test1 values(-5,5);
insert into test1 values(0,0);
insert into test1 values(10,-10);
insert into test1 values(100,100);
select * from test1 order by h1 asc;
UPDATE test1 set h1=200  where h1=(select * from (select max(h1) over(PARTITION by h1 order by h2 ROWS BETWEEN 1 preceding AND 1 following) from test1 LIMIT 1) as test1) LIMIT 1;UPDATE test1 set h1=350  where h1=(select * from (select max(h1) over(PARTITION by h1 order by h2 ROWS BETWEEN 1 preceding AND 1 following) from test1 LIMIT 1) as test1) LIMIT 1;//
select * from test1 order by h1 asc;
UPDATE test1 set h2=-400  where h2=(select * from (select min(h2) over(PARTITION by h2 order by h2 ROWS BETWEEN 1 preceding AND 1 following) from test1 LIMIT 1) as test1) LIMIT 1;UPDATE test1 set h2=330  where h2=(select * from (select min(h2) over(PARTITION by h2 order by h2 ROWS BETWEEN 1 preceding AND 1 following) from test1 LIMIT 1) as test1);//
select * from test1 order by h1 asc;
#ROWS BETWEEN 1 preceding AND current row;
UPDATE test1 set h2=-220*2  where h2=(select * from (select min(h2) over(PARTITION by h2 order by h2 ROWS BETWEEN 1 preceding AND current row) from test1 LIMIT 1) as test1) LIMIT 1;UPDATE test1 set h2=330  where h2=(select * from (select min(h2) over(PARTITION by h2 order by h2 ROWS BETWEEN 1 preceding AND 1 following) from test1 LIMIT 1) as test1);//
select * from test1 order by h1 asc;
#ROWS BETWEEN unbounded preceding AND current row;
UPDATE test1 set h2=h2+520 where h2=(select * from (select min(h2) over(PARTITION by h2 order by h2 ROWS BETWEEN unbounded preceding AND current row) from test1 LIMIT 1) as test1) LIMIT 1;UPDATE test1 set h2=330  where h2=(select * from (select min(h2) over(PARTITION by h2 order by h2 ROWS BETWEEN unbounded preceding AND current row) from test1 LIMIT 1) as test1);//
select * from test1 order by h1 asc;
#ROWS BETWEEN current row AND unbounded following;
UPDATE test1 set h1=h2-520 where h1=(select * from (select min(h1) over(PARTITION by h1 order by h2 ROWS BETWEEN current row AND unbounded following) from test1 LIMIT 1) as test1) LIMIT 1;UPDATE test1 set h2=300  where h2=(select * from (select min(h2) over(PARTITION by h2 order by h2 ROWS BETWEEN current row AND unbounded following) from test1 LIMIT 1) as test1);//
select * from test1 order by h1 asc;
drop table if EXISTS test1;
