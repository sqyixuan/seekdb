#all
drop table if EXISTS test1;
drop procedure if exists test_process;
create table test1(h1 int,h2 int);
create procedure test_process()
begin
declare i int default 1;
while i<1001
do
insert into test1 values(-50,-50);
insert into test1 values(0,0);
insert into test1 values(200,abs(100));
set i=i+1;
end while;
commit;
end;
//
call test_process();
select * from test1 order by h1 asc;
update test1 set h1=80 where h1=all(SELECT * from(select h1 from test1 where h1=0) as test1);//
update test1 set h1=40 where h1=all(SELECT * from(select h1 from test1 where h1=80) as test1);update test1 set h1=h1+h2 where h1=all(SELECT * from(select h1 from test1 where h1=80) as test1);//
select DISTINCT h1,h2 from test1 order by h1 asc;
update test1 set h1=80 where h1=all(SELECT * from(select h1 from test1 where h1=0) as test1);update test1 set h1=40 where h1=all(SELECT * from(select h1 from test1 where h1=80) as test1);update test1 set h1=h1+h2 where h1=all(SELECT * from(select h1 from test1 where h1=80) as test1);//
select DISTINCT h1,h2 from test1 order by h1 asc;
drop procedure if exists test_process1;
create procedure test_process1()
begin
declare i int default 1;
while i<1001
do
update test1 set h1=100 where h1=-100;
update test1 set h1=60 where h1=100;
update test1 set h1=-60 where h1=60;
update test1 set h1=-200 where h1=-60;
set i=i+1;
end while;
commit;
end ;
//
call test_process1();
select * from test1 order by h1 asc;
select DISTINCT h1,h2 from test1 order by h1 asc;
update test1 set h2=80 where h2=0;update test1 set h2=h1 where h2=80;//
update test1 set h2=12*25+0-65+34 where h2=40;//
update test1 set h1=80 where h1>all(SELECT * from(select h1 from test1 where h1<40) as test1);update test1 set h1=70 where h1<all(SELECT * from(select h1 from test1 where h1>90) as test1);//
select DISTINCT h1,h2 from test1 order by h1 asc;
drop procedure if exists test_process1;
drop procedure if exists test_process;
drop table if EXISTS test1;
