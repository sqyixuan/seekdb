drop table cs_card;

drop table if exists t1, t2;
create table t1(a int, b int, c int);
create table t2(a int primary key, b int, c int);
insert into t1 values (NULL, NULL, NULL), (1, NULL, 2), (2, 2, 2), (2, 3, 3), (3, 3, NULL), (4, 4, 5);
insert into t2 values (1, 1, 1), (2, 2, 3), (3, NULL, NULL);

select * from t1 left join t2 on t1.a = t2.a where t2.a is null for update;
+------+------+------+---+------+------+
| a    | b    | c    | a | b    | c    |
+------+------+------+---+------+------+
| NULL | NULL | NULL | NULL | NULL | NULL |
|    4 |    4 |    5 | NULL | NULL | NULL |
+------+------+------+---+------+------+
select /*+NO_REWRITE*/ * from t1 left join t2 on t1.a = t2.a where t2.a is null for update;
+------+------+------+---+------+------+
| a    | b    | c    | a | b    | c    |
+------+------+------+---+------+------+
| NULL | NULL | NULL | NULL | NULL | NULL |
|    4 |    4 |    5 | NULL | NULL | NULL |
+------+------+------+---+------+------+
drop table t1;
drop table t2;
