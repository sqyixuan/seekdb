########for update支持rescan, for update分区校验支持生成列##########
purge recyclebin;
result_format: 4
alter system set _enable_defensive_check = 2;

drop table if exists cs_card;
CREATE TABLE `cs_card` (
  `card_no` varchar(24) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL COMMENT '卡号',
  `customer_id` varchar(24) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL COMMENT '客户号',
  `havana_id` bigint(20) DEFAULT NULL COMMENT '集团会员ID',
  `partition_id` varchar(24) GENERATED ALWAYS AS (substr(`card_no`,17,2)) VIRTUAL,
  PRIMARY KEY (`card_no`),
  KEY `idx_customerid` (`customer_id`) BLOCK_SIZE 16384 GLOBAL ,
  KEY `cs_card_havana_id_uk` (`havana_id`) BLOCK_SIZE 16384 GLOBAL 
)
 partition by list columns(partition_id)
