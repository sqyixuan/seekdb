SELECT * FROM W0CASE PARTITION (P0) A RIGHT OUTER JOIN W0CASE B USE INDEX FOR ORDER BY (I0) ON B.W0_TEST0 = A.W0_TEST0;
SELECT * FROM W0CASE PARTITION (P0) A RIGHT OUTER JOIN W0CASE B USE INDEX FOR ORDER BY (I0) ON B.W0_TEST0 = A.W0_TEST0 WHERE B.W0_TEST0 NOT IN (A.W0_TEST0,A.W0_TEST1,A.W0_TEST3);
SELECT * FROM W0CASE PARTITION (P0) A RIGHT OUTER JOIN W0CASE B USE INDEX FOR ORDER BY (I0) ON B.W0_TEST0 = A.W0_TEST0 WHERE B.W0_TEST0 IN (A.W0_TEST0,A.W0_TEST1,A.W0_TEST3) ORDER BY B.W0_TEST0 LIMIT 1;
SELECT * FROM W0CASE PARTITION (P0) A RIGHT OUTER JOIN W0CASE B USE KEY FOR ORDER BY (I0) ON B.W0_TEST0 = A.W0_TEST0 WHERE B.W0_TEST0 IN (A.W0_TEST0,A.W0_TEST1,A.W0_TEST3) ORDER BY B.W0_TEST0 LIMIT 1;
INSERT INTO W0CASE PARTITION (P0) (W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3) SELECT A.W0_TEST0,A.W0_TEST1,A.W0_TEST2,A.W0_TEST3 FROM W0CASE PARTITION (P0) A RIGHT OUTER JOIN W0CASE B USE KEY FOR ORDER BY (I0) ON B.W0_TEST0 = A.W0_TEST0 WHERE B.W0_TEST0 IN (A.W0_TEST0,A.W0_TEST1,A.W0_TEST3) ORDER BY B.W0_TEST0 LIMIT 1;
SELECT * FROM W0CASE;
DROP TABLE W0CASE;

CREATE TABLE W0CASE (W0_TEST0 TINYINT NULL, W0_TEST1 BOOL, W0_TEST2 BOOLEAN, W0_TEST3 SMALLINT, W0_TEST4 MEDIUMINT GENERATED ALWAYS AS ( W0_TEST0 + W0_TEST1 + W0_TEST2 * W0_TEST3 + W0_TEST0) NOT NULL,
                    INDEX I0 USING HASH (W0_TEST4 , W0_TEST0 , W0_TEST1 , W0_TEST2 , W0_TEST3) )
            PARTITION BY RANGE COLUMNS (W0_TEST4,W0_TEST0)
            (PARTITION P0 VALUES LESS THAN (MAXVALUE,MAXVALUE));
