            PARTITION BY LIST COLUMNS (W0_TEST2)
            SUBPARTITION BY KEY(W0_TEST2)
            (PARTITION P0 VALUES IN ('2020-02-20','2021-02-21') (SUBPARTITION P1 ));
INSERT INTO W0CASE PARTITION (P1) (W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3) VALUES ('A','B','2020-02-20','00:00:10');
INSERT INTO W0CASE PARTITION (P1) (W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3) VALUES ( (SELECT 'B'),(SELECT 'C'),(SELECT DATE('2021-02-20')+1),(SELECT '00:00:12') );
