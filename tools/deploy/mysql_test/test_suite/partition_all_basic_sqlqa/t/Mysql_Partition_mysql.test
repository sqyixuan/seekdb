CREATE TABLE W3CASE ( W3_TEST0 INT PRIMARY KEY, W3_TEST1 INTEGER, W3_TEST2 BIGINT, W3_TEST3 DECIMAL, W3_TEST4 DEC AS (W3_TEST0 + W3_TEST1 * W3_TEST2 / W3_TEST3))
            PARTITION BY LIST COLUMNS (W3_TEST0)
            SUBPARTITION BY HASH (W3_TEST0)
            (PARTITION P0 VALUES IN ( 0,1,2,3,4,5 ) (SUBPARTITION P1), PARTITION P2 VALUES IN ( 6,7,8,9,10,11 ) (SUBPARTITION P3));
