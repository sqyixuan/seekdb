CREATE TABLE W0CASE (W0_TEST0 CHAR(10) DEFAULT 'A', W0_TEST1 YEAR DEFAULT 2001, W0_TEST2 INT DEFAULT 2001, W0_TEST3 INT GENERATED ALWAYS AS ( W0_TEST1 * W0_TEST2 ), PRIMARY KEY (W0_TEST0,W0_TEST1,W0_TEST2))
            PARTITION BY LIST COLUMNS (W0_TEST0,W0_TEST2)
            SUBPARTITION BY HASH ( W0_TEST2 )
            (PARTITION P0 VALUES IN ( ('A',1999),('B',2000),('C',2001) ) (SUBPARTITION P1));
INSERT INTO W0CASE PARTITION (P1) (W0_TEST0,W0_TEST1,W0_TEST2) VALUES ('A',1999,1999);
INSERT INTO W0CASE PARTITION (P1) (W0_TEST0,W0_TEST1,W0_TEST2) SELECT 'B',2000,2000;
UPDATE W0CASE SET W0_TEST0 = 'C', W0_TEST2 = DEFAULT;
UPDATE W0CASE SET W0_TEST2 = YEAR(DATE ('2001-02-20')) WHERE W0_TEST2 = YEAR(DATE ('2001-02-20')) ORDER BY W0_TEST1 DESC;
SELECT W0_TEST3 FROM W0CASE UNION SELECT A.W0_TEST1 FROM W0CASE PARTITION (P1) A, W0CASE PARTITION (P0) B;
SELECT W0_TEST3,W0_TEST1 FROM W0CASE UNION SELECT A.W0_TEST1,B.W0_TEST3 FROM W0CASE PARTITION (P1) A, W0CASE PARTITION (P0) B;
SELECT ALL W0_TEST1,W0_TEST3 FROM (SELECT W0_TEST3,W0_TEST1 FROM W0CASE UNION SELECT A.W0_TEST1,B.W0_TEST3 FROM W0CASE PARTITION (P1) A, W0CASE PARTITION (P0) B) C INNER JOIN W0CASE PARTITION (P0) USING (W0_TEST1,W0_TEST3);
SELECT DISTINCT W0_TEST1,W0_TEST3 FROM (SELECT W0_TEST3,W0_TEST1 FROM W0CASE UNION SELECT A.W0_TEST1,B.W0_TEST3 FROM W0CASE PARTITION (P1) A, W0CASE PARTITION (P0) B) C LEFT JOIN W0CASE PARTITION (P0) USING (W0_TEST1,W0_TEST3) ORDER BY 1,2;
SELECT DISTINCT W0_TEST1,W0_TEST3 FROM (SELECT W0_TEST3,W0_TEST1 FROM W0CASE UNION SELECT A.W0_TEST1,B.W0_TEST3 FROM W0CASE PARTITION (P1) A, W0CASE PARTITION (P0) B) C LEFT JOIN W0CASE PARTITION (P0) USING (W0_TEST1,W0_TEST3) GROUP BY W0_TEST1,W0_TEST3 DESC ORDER BY 1,2;
SELECT DISTINCT W0_TEST0 +W0_TEST1,W0_TEST0 +W0_TEST3 FROM (SELECT W0_TEST3,W0_TEST1 FROM W0CASE UNION SELECT A.W0_TEST1,B.W0_TEST3 FROM W0CASE PARTITION (P1) A, W0CASE PARTITION (P0) B) C LEFT JOIN W0CASE PARTITION (P0) USING (W0_TEST1,W0_TEST3) GROUP BY W0_TEST1,W0_TEST3 DESC;
SELECT DISTINCT MAX(W0_TEST0 +W0_TEST1),MIN(W0_TEST0 +W0_TEST3) FROM (SELECT W0_TEST3,W0_TEST1 FROM W0CASE UNION SELECT A.W0_TEST1,B.W0_TEST3 FROM W0CASE PARTITION (P1) A, W0CASE PARTITION (P0) B) C LEFT JOIN W0CASE PARTITION (P0) USING (W0_TEST1,W0_TEST3) GROUP BY W0_TEST1,W0_TEST3 DESC;
INSERT INTO W0CASE PARTITION (P1) (W0_TEST2) SELECT DISTINCT MAX(W0_TEST1) FROM (SELECT W0_TEST3,W0_TEST1 FROM W0CASE UNION SELECT A.W0_TEST1,B.W0_TEST3 FROM W0CASE PARTITION (P1) A, W0CASE PARTITION (P0) B) C LEFT JOIN W0CASE PARTITION (P0) USING (W0_TEST1,W0_TEST3) GROUP BY W0_TEST1,W0_TEST3 DESC ORDER BY W0_TEST0 DESC LIMIT 1 ;
SELECT * FROM W0CASE;
DROP TABLE W0CASE;

