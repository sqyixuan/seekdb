--ECHO #obmysql-mysql_partitions-1-2-1
CREATE TABLE W0CASE (W0_TEST0 BIGINT , W0_TEST1 INT NOT NULL , W0_TEST2 VARCHAR(10) , W0_TEST3 YEAR DEFAULT 1999, W0_TEST4 INT GENERATED ALWAYS AS (W0_TEST0 + W0_TEST1) NULL,
                    INDEX I0 (W0_TEST1))
            PARTITION BY HASH (W0_TEST0 + W0_TEST1)
            (PARTITION P0);
INSERT INTO W0CASE PARTITION (P0) (W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3) VALUES (0,1,2,1999);
INSERT INTO W0CASE PARTITION (P0) (W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3) SELECT 10,11,12,1998 FROM DUAL;
SELECT W0_TEST4 + W0_TEST0 + W0_TEST1 FROM W0CASE PARTITION (P0) GROUP BY W0_TEST0 + W0_TEST1;
INSERT INTO W0CASE PARTITION (P0) (W0_TEST1) SELECT W0_TEST4 + W0_TEST0 + W0_TEST1 FROM W0CASE PARTITION (P0) GROUP BY W0_TEST0 + W0_TEST1;
INSERT INTO W0CASE PARTITION (P0) (W0_TEST1) SELECT * FROM (SELECT W0_TEST4 + W0_TEST0 + W0_TEST1 AS A FROM W0CASE PARTITION (P0) GROUP BY W0_TEST0 + W0_TEST1) A WHERE A IS NOT NULL GROUP BY A DESC;
UPDATE W0CASE SET W0_TEST1 = W0_TEST1 WHERE W0_TEST1 IS NOT NULL;
UPDATE W0CASE PARTITION (P0) SET W0_TEST1 = W0_TEST0 + W0_TEST1 WHERE W0_TEST1 IS NOT NULL AND W0_TEST0 IS NOT NULL;
SELECT W0_TEST0 + W0_TEST1 FROM W0CASE WHERE W0_TEST1 IS NOT NULL AND W0_TEST0 IS NOT NULL;
DELETE FROM W0CASE PARTITION (P0) WHERE W0_TEST0 = W0_TEST4 AND W0_TEST4 IS NULL;
DELETE FROM W0CASE PARTITION (P0) WHERE W0_TEST0 = W0_TEST4 OR W0_TEST4 IS NULL;
SELECT * FROM W0CASE ORDER BY W0_TEST0;
DROP TABLE W0CASE;

CREATE TABLE W0CASE (W0_TEST0 BOOL, W0_TEST1 CHAR(10), W0_TEST2 DATE NOT NULL, W0_TEST3 DOUBLE NULL, W0_TEST4 INT AS (W0_TEST0 * W0_TEST3),INDEX I0 USING HASH (W0_TEST4))
            PARTITION BY KEY( W0_TEST4 )
            (PARTITION P0);
