--ECHO #obmysql-mysql_partitions-3-3
CREATE OR REPLACE VIEW V0 AS SELECT * FROM W0CASE,W1CASE,W2CASE,W3CASE,W4CASE,W5CASE,W6CASE,W7CASE,W8CASE,W9CASE,W10CASE,W11CASE,W12CASE,W13CASE;
SELECT * FROM V0 ORDER BY W0_TEST0,2,3,4 DESC LIMIT 10;
DROP VIEW V0;

CREATE OR REPLACE VIEW V0 AS SELECT * FROM W0CASE PARTITION (P0),W1CASE PARTITION (P0),W2CASE PARTITION (P0),W3CASE PARTITION (P0),W4CASE PARTITION (P0),W5CASE PARTITION (P0),W6CASE PARTITION (P0),W7CASE PARTITION (P0),W8CASE PARTITION (P0),W9CASE PARTITION (P0),W10CASE PARTITION (P0),W11CASE PARTITION (P0),W12CASE PARTITION (P0),W13CASE PARTITION (P0);
SELECT * FROM V0 ORDER BY W0_TEST0,2,3,4 DESC LIMIT 10;
DROP VIEW V0;

CREATE OR REPLACE VIEW V0 AS SELECT * FROM W13CASE PARTITION (P1) INNER JOIN W12CASE PARTITION (P1) ON W12_TEST2 = W13_TEST3;
SELECT * FROM V0 ORDER BY 1,2,3,4,5;
DROP VIEW V0;

CREATE OR REPLACE VIEW V0 AS SELECT * FROM (SELECT W0_TEST4 A FROM W0CASE PARTITION (P0)) C LEFT JOIN (SELECT W11_TEST1 AS A FROM W11CASE PARTITION (P1)) B USING (A) LIMIT 3;
SELECT * FROM V0 ORDER BY 1;
DROP VIEW V0;

CREATE OR REPLACE VIEW V0 AS SELECT * FROM W10CASE PARTITION (P1),W9CASE PARTITION (P0),W0CASE PARTITION (P0),W1CASE PARTITION (P0);
SELECT * FROM V0 ORDER BY 1,2,3,4,5;
SELECT * FROM V0 RIGHT JOIN W0CASE PARTITION (P0) USING (W0_TEST0) ORDER BY W0_TEST0 DESC LIMIT 3;
SELECT W0_TEST0,W10_TEST0,W9_TEST4 FROM V0 RIGHT JOIN W0CASE PARTITION (P0) USING (W0_TEST0) GROUP BY W0_TEST0,W10_TEST0,W9_TEST4 ORDER BY W0_TEST0 DESC LIMIT 3;
#EXPLAIN SELECT W0_TEST0,W10_TEST0,W9_TEST4 FROM V0 RIGHT JOIN W0CASE PARTITION (P0) USING (W0_TEST0) GROUP BY W0_TEST0,W10_TEST0,W9_TEST4 ORDER BY W0_TEST0 DESC LIMIT 3;
DROP VIEW V0;

