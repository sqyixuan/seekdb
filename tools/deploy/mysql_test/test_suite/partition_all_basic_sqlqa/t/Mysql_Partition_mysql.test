CREATE TABLE W0CASE ( W0_TEST0 INTEGER, W0_TEST1 TEXT, W0_TEST2 TIME, W0_TEST3 REAL NULL, W0_TEST4 INT GENERATED ALWAYS AS (W0_TEST0 * W0_TEST3) NOT NULL, INDEX I0 USING BTREE (W0_TEST4,W0_TEST0))
            PARTITION BY RANGE (W0_TEST4)
            (PARTITION P0 VALUES LESS THAN MAXVALUE);
INSERT INTO W0CASE PARTITION (P0) (W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3) SELECT 12,'1234',000001,0001;
INSERT INTO W0CASE PARTITION (P0) (W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3) SELECT W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3 FROM W0CASE GROUP BY W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3 DESC ORDER BY W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3 DESC LIMIT 3;
UPDATE W0CASE PARTITION (P0) SET W0_TEST0 = 13, W0_TEST3 = 00123.000321 ORDER BY W0_TEST4 DESC LIMIT 1;
