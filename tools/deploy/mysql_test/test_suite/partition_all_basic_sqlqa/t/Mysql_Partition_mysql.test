#EXPLAIN SELECT A.A + B.A FROM ( SELECT W1_TEST4 AS A FROM W1CASE PARTITION (P3) ) AS A INNER JOIN ( SELECT W3_TEST0 AS A FROM W3CASE PARTITION (P0) ) AS B ON A.A <> B.A GROUP BY A.A,B.A DESC ORDER BY B.A DESC LIMIT 2;
#EXPLAIN SELECT * FROM W1CASE PARTITION (P0) INNER JOIN W2CASE PARTITION (P0) ON W1_TEST4 = W2_TEST4 OR W1_TEST3 <> W2_TEST3;
#EXPLAIN SELECT * FROM W0CASE PARTITION (P0) LEFT JOIN W2CASE PARTITION (P1) ON W0_TEST0 LIKE W2_TEST1;
#EXPLAIN SELECT * FROM W0CASE PARTITION (P0) LEFT JOIN W2CASE PARTITION (P1) ON W0_TEST0 LIKE W2_TEST1 OR W0_TEST0 NOT LIKE W2_TEST1;
INSERT INTO W3CASE PARTITION (P3) (W3_TEST0,W3_TEST1,W3_TEST2,W3_TEST3) SELECT DISTINCT W2_TEST0+2,W2_TEST2,W0_TEST4,W2_TEST4 FROM (SELECT * FROM W0CASE PARTITION (P0) LEFT JOIN W2CASE PARTITION (P1) ON W0_TEST0 LIKE W2_TEST1 OR W0_TEST0 NOT LIKE W2_TEST1 ) A ORDER BY W2_TEST0 DESC LIMIT 1;
INSERT INTO W1CASE PARTITION (P1) SET W1_TEST3 = (SELECT W3_TEST4 FROM W3CASE PARTITION (P3) ORDER BY W3_TEST4 DESC LIMIT 1);
REPLACE INTO W1CASE PARTITION (P1) SET W1_TEST3 = (SELECT W3_TEST4 FROM W3CASE PARTITION (P3) ORDER BY W3_TEST4 DESC LIMIT 1);
