SELECT CASE WHEN A.W0_TEST0 = B.W0_TEST4 THEN B.W0_TEST2 END FROM W0CASE PARTITION (P0) A USE INDEX (I2,I1,I0) LEFT JOIN W0CASE PARTITION (P0) B USE INDEX (I2,I1,I0) ON A.W0_TEST0 = B.W0_TEST0 WHERE A.W0_TEST0 IS NOT NULL OR B.W0_TEST1 IS NOT NULL GROUP BY B.W0_TEST0,B.W0_TEST1,A.W0_TEST4 ORDER BY B.W0_TEST3 DESC;
SELECT CASE WHEN A.W0_TEST0 + B.W0_TEST1 = B.W0_TEST4 THEN B.W0_TEST4 END FROM W0CASE PARTITION (P0) A USE INDEX (I2,I1,I0) LEFT JOIN W0CASE PARTITION (P0) B USE INDEX (I2,I1,I0) ON A.W0_TEST0 = B.W0_TEST0 WHERE A.W0_TEST0 IS NOT NULL OR B.W0_TEST1 IS NOT NULL GROUP BY B.W0_TEST0,B.W0_TEST1,A.W0_TEST4 ORDER BY B.W0_TEST3 DESC;
