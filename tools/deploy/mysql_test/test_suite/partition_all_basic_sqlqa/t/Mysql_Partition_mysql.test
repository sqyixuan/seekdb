               (SELECT * FROM W0CASE PARTITION (P0) WHERE W0_TEST4 LIKE '%' GROUP BY W0_TEST0,W0_TEST4 DESC ORDER BY W0_TEST0,W0_TEST4 DESC) B USING (W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3,W0_TEST4);
