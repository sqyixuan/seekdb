CREATE TABLE W0CASE (W0_TEST0 DATE NOT NULL, W0_TEST1 INT NULL, W0_TEST2 DATETIME NULL, W0_TEST3 INTEGER, W0_TEST4 INT GENERATED ALWAYS AS ( W0_TEST0 * W0_TEST1 ),
                INDEX I0 USING HASH (W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3))
            PARTITION BY LIST (W0_TEST4)
