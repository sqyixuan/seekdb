CREATE TABLE W0CASE ( W0_TEST0 CHAR(10), W0_TEST1 VARCHAR(10), W0_TEST2 DATE, W0_TEST3 TIME, W0_TEST4 INT AS (W0_TEST2+W0_TEST3),PRIMARY KEY (W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3))
            PARTITION BY LIST (YEAR(W0_TEST2))
            SUBPARTITION BY KEY(W0_TEST2)
            (PARTITION P0 VALUES IN (2020,2021) (SUBPARTITION P1 ));
