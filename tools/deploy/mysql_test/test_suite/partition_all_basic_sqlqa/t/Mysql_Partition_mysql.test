SELECT * FROM ( SELECT W1_TEST4 AS A FROM W1CASE PARTITION (P3) ) AS A INNER JOIN ( SELECT W3_TEST0 AS A FROM W3CASE PARTITION (P0) ) AS B ON A.A <> B.A;
SELECT A.A , B.A FROM ( SELECT W1_TEST4 AS A FROM W1CASE PARTITION (P3) ) AS A INNER JOIN ( SELECT W3_TEST0 AS A FROM W3CASE PARTITION (P0) ) AS B ON A.A <> B.A GROUP BY A.A,B.A DESC ORDER BY B.A DESC LIMIT 2;
SELECT A.A + B.A FROM ( SELECT W1_TEST4 AS A FROM W1CASE PARTITION (P3) ) AS A INNER JOIN ( SELECT W3_TEST0 AS A FROM W3CASE PARTITION (P0) ) AS B ON A.A <> B.A GROUP BY A.A,B.A DESC ORDER BY B.A DESC LIMIT 2;
SELECT * FROM W1CASE PARTITION (P0) INNER JOIN W2CASE PARTITION (P0) ON W1_TEST4 = W2_TEST4 OR W1_TEST3 <> W2_TEST3;
SELECT * FROM W0CASE PARTITION (P0) LEFT JOIN W2CASE PARTITION (P1) ON W0_TEST0 LIKE W2_TEST1;
SELECT * FROM W0CASE PARTITION (P0) LEFT JOIN W2CASE PARTITION (P1) ON W0_TEST0 LIKE W2_TEST1 OR W0_TEST0 NOT LIKE W2_TEST1;
