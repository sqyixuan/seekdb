SELECT * FROM W0CASE PARTITION (P0) AS A USE INDEX FOR GROUP BY (I) LEFT JOIN W0CASE USING (W0_TEST4,W0_TEST0);
INSERT INTO W0CASE PARTITION (P0) (W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3) SELECT A.W0_TEST0,A.W0_TEST1,A.W0_TEST2,A.W0_TEST4 FROM W0CASE PARTITION (P0) AS A USE INDEX FOR GROUP BY (I) LEFT JOIN W0CASE USING (W0_TEST4,W0_TEST0);
UPDATE W0CASE PARTITION (P0) SET W0_TEST3 = (SELECT W0_TEST4 FROM W0CASE PARTITION (P0) AS A USE INDEX FOR GROUP BY (I) LEFT JOIN W0CASE USING (W0_TEST4,W0_TEST0) ORDER BY W0_TEST4 LIMIT 1);
