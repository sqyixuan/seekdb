--ECHO #obmysql-mysql_partitions-3-1-2
delimiter //;
CREATE FUNCTION F0(I VARCHAR(100) ) RETURNS VARCHAR(100)
BEGIN
DECLARE N VARCHAR(100) DEFAULT I;
RETURN CONCAT (N,I);
END;
//
delimiter ;//
SELECT F0(1) FROM W0CASE PARTITION (P0);
SELECT F0((SELECT W11_TEST4 FROM W11CASE PARTITION (P0) GROUP BY W11_TEST4 DESC ORDER BY W11_TEST4 DESC LIMIT 1)) FROM W11CASE PARTITION (P1);
SELECT F0((SELECT W11_TEST4 FROM W11CASE PARTITION (P0) GROUP BY W11_TEST4 DESC ORDER BY W11_TEST4 DESC LIMIT 1))+W11_TEST4 FROM W11CASE PARTITION (P1) GROUP BY W11_TEST4 DESC ORDER BY W11_TEST4 DESC LIMIT 1;
DROP FUNCTION F0;

