                UNIQUE ( W1_TEST0,W1_TEST1,W1_TEST2,W1_TEST3 ))
            PARTITION BY RANGE COLUMNS (W1_TEST0,W1_TEST1,W1_TEST2,W1_TEST3)
            SUBPARTITION BY HASH(W1_TEST0+W1_TEST1+W1_TEST2+W1_TEST3)
            (PARTITION P0 VALUES LESS THAN (10,20,30,40) (SUBPARTITION P1 ), PARTITION P2 VALUES LESS THAN (MAXVALUE,MAXVALUE,MAXVALUE,MAXVALUE) (SUBPARTITION P3));
