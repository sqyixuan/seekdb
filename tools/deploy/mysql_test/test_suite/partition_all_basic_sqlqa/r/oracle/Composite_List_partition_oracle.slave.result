            PARTITION BY LIST (W0_TEST3) SUBPARTITION BY RANGE (W0_TEST3) (PARTITION P0 VALUES (DEFAULT) (SUBPARTITION P1 VALUES LESS THAN (MAXVALUE)));
INSERT INTO W0CASE VALUES ( 0,'20210110','A' );
CREATE OR REPLACE FUNCTION F0 (ARG0 NUMBER, ARG1 NVARCHAR2) RETURN NVARCHAR2 AS
    I NUMBER := 0;
    IA NUMBER := 0;
    FI NUMBER := 0;
    FA NUMBER := 0;
    CURSOR S0 (A NUMBER) IS SELECT A+A FROM W0CASE SUBPARTITION (P1) UNPIVOT (A FOR B IN (W0_TEST0));
BEGIN
    OPEN S0(10);
    LOOP
        FETCH S0 INTO FI;
        I := I + 1;
        IA := IA + ARG0;
        EXIT WHEN S0%NOTFOUND;
    END LOOP;
    CLOSE S0;
    FA := IA + I;
    RETURN FA;
END;
