BEGIN
    FOR I IN CL
    LOOP
        INSERT INTO W0CASE PARTITION (P0) VALUES (F0((SELECT W0_TEST0 FROM W0CASE SUBPARTITION (P1)),12),TO_CHAR(I.AA+'20200202'),TO_CHAR(F0(1,2)));
    END LOOP;
END;
