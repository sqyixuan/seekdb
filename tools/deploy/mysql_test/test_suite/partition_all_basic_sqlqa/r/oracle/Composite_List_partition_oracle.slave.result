CREATE TABLE W0CASE (W0_TEST0 NUMBER NULL, W0_TEST1 BINARY_DOUBLE UNIQUE, W0_TEST2 RAW(10) NOT NULL, W0_TEST3 CHAR(3) CHECK (W0_TEST3 NOT IN ('')), W0_TEST4 AS (POWER (W0_TEST0,W0_TEST1)))
            PARTITION BY LIST ( W0_TEST4 )
            SUBPARTITION BY LIST (W0_TEST0,W0_TEST1)
            SUBPARTITION TEMPLATE (SUBPARTITION P0 VALUES ((0,1),(NULL,NULL),(3,4),(7,8)),SUBPARTITION P1 VALUES (DEFAULT))
            (PARTITION P0 VALUES (0,NULL,81,05764801),PARTITION P1 VALUES (DEFAULT));
INSERT INTO W0CASE (W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3) VALUES (0,1,'A',' ');
INSERT INTO W0CASE SUBPARTITION (P0SP0) (W0_TEST0,W0_TEST1,W0_TEST2,W0_TEST3) VALUES (3,4,'B','  C');
SELECT * FROM W0CASE SUBPARTITION (P0SP0) A JOIN W0CASE PARTITION (P0) B USING (W0_TEST0);
+----------+----------+----------+----------+----------+----------+----------+----------+----------+
| W0_TEST0 | W0_TEST1 | W0_TEST2 | W0_TEST3 | W0_TEST4 | W0_TEST1 | W0_TEST2 | W0_TEST3 | W0_TEST4 |
+----------+----------+----------+----------+----------+----------+----------+----------+----------+
|        0 | 1.0E+000 | 0A       |          |        0 | 1.0E+000 | 0A       |          |        0 |
|        3 | 4.0E+000 | 0B       |   C      | 8.1E+001 | 4.0E+000 | 0B       |   C      | 8.1E+001 |
+----------+----------+----------+----------+----------+----------+----------+----------+----------+
SELECT POWER(POWER (W0_TEST0,W0_TEST1),W0_TEST4) AS W0_TEST4 FROM W0CASE SUBPARTITION (P0SP0);
+-------------------------+
| W0_TEST4                |
+-------------------------+
|                1.0E+000 |
| 3.8662196978715634E+154 |
+-------------------------+
SELECT POWER(POWER (W0_TEST0,W0_TEST1),W0_TEST4) AS W0_TEST4 FROM W0CASE SUBPARTITION (P0SP0) GROUP BY W0_TEST0,W0_TEST1,W0_TEST4 HAVING POWER (W0_TEST0,W0_TEST1) = W0_TEST4;
+-------------------------+
| W0_TEST4                |
+-------------------------+
|                1.0E+000 |
| 3.8662196978715634E+154 |
+-------------------------+
SELECT POWER(POWER (W0_TEST0,W0_TEST1),W0_TEST4) AS W0_TEST4,W0_TEST0,W0_TEST1,W0_TEST4 FROM W0CASE SUBPARTITION (P0SP0) GROUP BY W0_TEST0,W0_TEST1,W0_TEST4 HAVING POWER (W0_TEST0,W0_TEST1) = W0_TEST4;
+-------------------------+----------+----------+----------+
| W0_TEST4                | W0_TEST0 | W0_TEST1 | W0_TEST4 |
+-------------------------+----------+----------+----------+
|                1.0E+000 |        0 | 1.0E+000 |        0 |
| 3.8662196978715634E+154 |        3 | 4.0E+000 | 8.1E+001 |
+-------------------------+----------+----------+----------+
WITH
    W0 AS (SELECT * FROM W0CASE SUBPARTITION (P0SP0))
SELECT * FROM W0CASE;
