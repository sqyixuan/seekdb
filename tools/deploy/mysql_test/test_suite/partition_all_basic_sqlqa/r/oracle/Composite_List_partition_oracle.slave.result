DROP TABLE W1CASE CASCADE CONSTRAINTS PURGE;
DROP TABLE W0CASE CASCADE CONSTRAINTS PURGE;

CREATE TABLE W0CASE (W0_TEST0 NUMBER, W0_TEST1 BINARY_DOUBLE, W0_TEST2 NVARCHAR2(100), W0_TEST3 DATE, W0_TEST4 AS (POWER(W0_TEST0,W0_TEST1) + W0_TEST3),
                    UNIQUE (W0_TEST0,W0_TEST1), CHECK (W0_TEST0 IS NOT NULL AND W0_TEST1 IS NOT NULL))
            PARTITION BY LIST (W0_TEST0,W0_TEST1)
            SUBPARTITION BY LIST ( W0_TEST0,W0_TEST1 )
            SUBPARTITION TEMPLATE ( SUBPARTITION P0 VALUES ((1,2),(3,4),(5,6)),SUBPARTITION P1 VALUES (DEFAULT) )
            (PARTITION P0 VALUES ((1,2),(3,4),(5,6)),PARTITION P1 VALUES (DEFAULT));

CREATE TABLE W1CASE ( W1_TEST0 NUMBER, W1_TEST1 BINARY_DOUBLE, W1_TEST2 CHAR(10), W1_TEST3 DATE, W1_TEST4 GENERATED ALWAYS AS ((POWER(W1_TEST0,W1_TEST1) + W1_TEST3) ),
                    UNIQUE (W1_TEST0,W1_TEST1,W1_TEST2),PRIMARY KEY (W1_TEST0,W1_TEST1), CONSTRAINT AAA FOREIGN KEY (W1_TEST0,W1_TEST1) REFERENCES W0CASE (W0_TEST0,W0_TEST1) )
            PARTITION BY LIST (W1_TEST0,W1_TEST1)
            SUBPARTITION BY LIST (W1_TEST0,W1_TEST1)
            SUBPARTITION TEMPLATE ( SUBPARTITION P0 VALUES ((1,2),(3,4),(5,6)),SUBPARTITION P1 VALUES (DEFAULT) )
            (PARTITION P0 VALUES ((1,2),(3,4),(5,6)),PARTITION P1 VALUES (DEFAULT));

CREATE UNIQUE INDEX LP0 ON W0CASE ( W0_TEST1,W0_TEST0 ) LOCAL;
CREATE INDEX LP1 ON W0CASE ( W0_TEST0 ) GLOBAL PARTITION BY RANGE (W0_TEST0) (PARTITION P0 VALUES LESS THAN (1),PARTITION P1 VALUES LESS THAN (MAXVALUE));
CREATE INDEX LP2 ON W0CASE ( W0_TEST0,W0_TEST1,W0_TEST2 ) GLOBAL PARTITION BY RANGE (W0_TEST0) (PARTITION P0 VALUES LESS THAN (1),PARTITION P1 VALUES LESS THAN (MAXVALUE));
CREATE INDEX SLP0 ON W1CASE ( W1_TEST1,W1_TEST0 ) LOCAL;
CREATE UNIQUE INDEX SLP1 ON W1CASE (W1_TEST4) GLOBAL PARTITION BY HASH (W1_TEST4) (PARTITION P0,PARTITION P1);
CREATE UNIQUE INDEX SLP2 ON W1CASE (W1_TEST0,W1_TEST1,W1_TEST4) GLOBAL PARTITION BY HASH (W1_TEST0,W1_TEST1,W1_TEST4) PARTITIONS 3;
