--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: luofan.zp
# owner group: SQL3
# description: foobar
--disable_info
--disable_metadata
--disable_abort_on_error

--disable_warnings
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--enable_warnings

--disable_query_log
#call oceanbase.drop_tenant_force('tt_3');
#call oceanbase.create_mysql_tenant_mini_with_arg('tt_3', 'charset utf8');
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log

disconnect obsys;
connection default;

let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
connect (conn1,$TE_SERVER_IP,root,,*NO-ONE*,$TE_SERVER_PORT);
--disable_warnings
drop database IF EXISTS test1;
--enable_warnings
create database test1 collate utf8mb4_bin;
use test1;
create table tt_3 (c1 int primary key, c2 char(2) collate utf8mb4_bin, c3 char(2), c4 varchar(5) charset utf8mb4, c5 varchar(4) charset utf8);
connection conn1;
create table tt2 (c1 int primary key, c2 char(2) charset utf8 collate utf8_bin, c3 char(2), c4 varchar(5) charset utf8mb4, c5 varchar(4) charset utf8);
connection conn1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table tt_3;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table tt2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database test1;
drop database test1;

create database test2;
use test2;
create table tt_3(c1 int primary key, c2 char(2), c3 varchar(2) collate utf8mb4_bin, c4 varchar(3) charset utf8);
connection conn1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database test2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table tt_3;
drop database test2;

create database test3 charset utf8 collate utf8_bin;
use test3;
create table test(c1 int primary key, c2 char(2), c3 char(3) collate utf8mb4_bin);
connection conn1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database test3;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table test;
alter table test add column c4 char(3);
connection conn1;
alter table test add column c5 char(4) collate utf8mb4_bin;
connection conn1;
alter table test add column c6 char(5) charset utf8;
connection conn1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table test;
alter table test change c6 charset utf8mb4;
connection conn1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table test;
alter table test change c6 collate utf8_bin;
connection conn1;
drop database test3;

set @tmpcollation_server = @@collation_server;
set @tmpcollation_db = @@collation_database;

select @@collation_server;
set @@collation_server = utf8_general_ci;
create database test3;
use test3;
create table sb(a varchar(123) primary key);
insert into sb values('A');
--error 1062
insert into sb values('a');

set @@collation_server = utf8_bin;
drop database test3;
create database test3;
use test3;
create table sb(a varchar(123) primary key);
insert into sb values('A');
insert into sb values('a');

set @@collation_server = utf8_general_ci;
drop database test3;
create database test3;
use test3;
set @@collation_database = utf8_bin;
create table sb(a varchar(123) primary key);
insert into sb values('A');
--error 1062
insert into sb values('a');
drop table sb;

set @@collation_database = utf8_general_ci;
create table sb(a varchar(123) primary key);
insert into sb values('A');
--error 1062
insert into sb values('a');
drop database test3;

set @@collation_server = utf8_bin;
create database test3 CHARACTER SET utf8 collate utf8_general_ci;
use test3;
create table sb(a varchar(123) primary key);
insert into sb values('A');
--error 1062
insert into sb values('a');
drop table sb;
create table sb(a varchar(123) CHARACTER SET utf8 collate utf8_bin primary key);
insert into sb values('A');
insert into sb values('a');
drop database test3;


set @@collation_server = utf8_general_ci;
create database test3 CHARACTER SET utf8 collate utf8_bin;
use test3;
create table sb(a varchar(123) primary key);
insert into sb values('A');
insert into sb values('a');
drop table sb;
create table sb(a varchar(123) CHARACTER SET utf8 collate utf8_general_ci primary key);
insert into sb values('A');
--error 1062
insert into sb values('a');

drop database test3;
set @@collation_server = @tmpcollation_server;
set @@collation_database = @tmpcollation_db;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
connection obsys;
--disable_query_log
call oceanbase.drop_tenant_force('tt_3');
--enable_query_log
