-- echo --  character-2-1-2-1   创建视图
-- disable_warnings
DROP VIEW IF EXISTS view_emp_rg;
-- enable_warnings
create OR  REPLACE view view_emp_rg as  select * from emp_rg where sal>1500;
select   *  from   view_emp_rg;

-- echo --  character-2-1-2-2   修改视图     ob不支持这类
-- echo ALTER  VIEW  view_emp_rg  AS  SELECT  EMPNO,ename,job  FROM  emp_rg e;
