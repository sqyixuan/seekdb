#数据库设置字符集utf16，存储过程设置gbk字符集
drop database  IF EXISTS  ob200x;
create database ob200x  character set utf16;
use ob200x;

drop function if exists myfun400;
delimiter //;
create function myfun400(username varchar(20) character set gbk)  returns varchar(20)
begin
set @str='';
select username into @str from dual;
return  collation(@str);
end//
DELIMITER ;//
select  myfun400('污水');
select   collation(@str) from   dual;









-- echo    character-8-5    char在字符集下的长度测试               

#char类型utf16下的最大长度测试
drop database  IF EXISTS  ob2000x;
create database ob2000x  character set utf16;
use ob2000x;
drop table if exists userlen;
create table userlen(name char(255)character set utf16)charset=utf16;

drop function if exists myfunlen;
delimiter //;
create function myfunlen(funuser int) returns int
begin
set @sumcount='hello world';
set @cccount=funuser;
set @countstr='';
outer_label: begin
     WHILE @cccount < 300 DO
          SET @cccount = @cccount+1;          
          SET @countstr = concat(@countstr,'国');
          insert into userlen values(@countstr);        
          select count(*) into @sumcount from userlen;
         if CHAR_LENGTH(@countstr)>254   then
		    leave  outer_label; 
	      end if;
		END WHILE;
end outer_label;
return  LENGTH(@countstr); 
end
//

DELIMITER ;//
#select  myfunlen(0);
#select   @countstr, LENGTH(@countstr),CHAR_LENGTH(@countstr) from   dual;
#select   @sumcount  from   dual;
#select  count(*)  from   userlen;




#char类型gbk下的最大长度测试
drop database  IF EXISTS  ob202x;
create database ob202x  character set utf16;
use ob202x;
drop table if exists userleng;
create table userleng(name char(255)character set gbk)charset=utf16;
drop function if exists myfunsecdy;

delimiter //;
create function myfunsecdy(funuser int) returns int
begin
set @sumcooy='hello world';
set @cccounty=funuser;
set @countstry='';
outer_labely: begin
     WHILE @cccounty < 3000 DO
          SET @cccounty = @cccounty+1;          
          SET @countstry = concat(@countstry,'国');
          insert into userleng values(@countstry);        
          select count(*) into @sumcooy from userleng;
         if CHAR_LENGTH(@countstry)>254   then
	      leave  outer_labely; 
	      end if;
		END WHILE;
end outer_labely;
return  LENGTH(@countstry); 
end
//
DELIMITER ;//
#select  myfunsecdy(1);
#select   @countstry, LENGTH(@countstry),CHAR_LENGTH(@countstry) from   dual;
#select   @sumcooy  from   dual;






