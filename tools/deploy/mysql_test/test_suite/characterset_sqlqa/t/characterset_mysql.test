-- disable_warnings
-- echo --   索引
drop TABLE if exists my_test;
create table my_test(
id int(11) not null unique auto_increment,
name varchar(100)  CHARACTER SET  utf16,
age int(11) not null default 0,
address varchar(100) CHARACTER SET  utf16
)charset=utf16;
-- enable_warnings

-- echo --  character-2-1-4-1    #创建普通索引
create index index_001 on  my_test(name); #为表my_text中的列name创建普通索引名称index_001
-- echo --     修改表结构的方式添加索引  
alter table my_test add index index_004(age);


-- echo --  character-2-1-4-2   #降序索引ob不支持
-- echo create index index_002 on my_test(age DESC); 
create index index_002 on my_test(age); 


-- echo --  character-2-1-4-3   #修改索引
create index index_006 on my_test(address); 
DROP INDEX index_006 ON my_test; 
ALTER TABLE my_test ADD index index_006(address);
DROP INDEX index_006 ON my_test; 




-- echo --  character-2-1-4-4  删除索引
drop index index_001 on my_test;
alter table my_test drop index index_002;


-- echo --  character-2-1-4-5    建立复合索引 #建立表列age和name的联合索引；按照age升序后再按照name降序排序
create index index_003 on my_test(age,name);




-- echo --  character-2-1-4-6    创建唯一索引
CREATE UNIQUE INDEX index_005 ON  my_test(address);
ALTER TABLE my_test ADD UNIQUE(address);

#查看表my_test的全部索引
#show index from my_test;
drop TABLE if exists my_test;


 

-- echo --  分区表：
-- echo -- character-2-1-5-1   RANGE分区
-- disable_warnings
drop TABLE if exists employees001;
CREATE TABLE employees001(  
    id INT NOT NULL,  
    fname VARCHAR(30) CHARACTER SET  utf16,  
    lname VARCHAR(30) CHARACTER SET  utf16,  
    hired DATE NOT NULL DEFAULT '1970-01-01',  
    separated DATE NOT NULL DEFAULT '9999-12-31',  
    job_code INT NOT NULL,  
    store_id INT NOT NULL  
) charset=utf16
PARTITION BY RANGE (store_id) (  
    PARTITION p0 VALUES LESS THAN (6),  
    PARTITION p1 VALUES LESS THAN (11),  
    PARTITION p2 VALUES LESS THAN (16),  
    PARTITION p3 VALUES LESS THAN MAXVALUE  
);

insert  into  employees001(id,fname,lname,job_code,store_id) values(1,'中国人民','國軍',10,20);
select   *  from   employees001;

-- echo -- character-2-1-5-2     LIST分区
drop TABLE if exists employees002;
CREATE TABLE employees002 (  
    id INT NOT NULL,  
    fname VARCHAR(30) CHARACTER SET  utf16,  
    lname VARCHAR(30) CHARACTER SET  utf16,  
    hired DATE NOT NULL DEFAULT '1970-01-01',  
    separated DATE NOT NULL DEFAULT '9999-12-31',  
    job_code INT,  
    store_id INT
)charset=utf16
PARTITION BY LIST(store_id) (
    PARTITION pNorth VALUES IN (3,5,6,9,17),
    PARTITION pEast VALUES IN (1,2,10,11,19,20),
    PARTITION pWest VALUES IN (4,12,13,14,18),
    PARTITION pCentral VALUES IN (7,8,15,16)
);

insert  into  employees002(id,fname,lname,job_code,store_id) values(1,'中国人民','國軍',10,20);
select   *  from   employees002;
-- echo -- character-2-1-5-3    普通HASH分区
drop TABLE if exists employees003;      
CREATE TABLE employees003(  
    id INT NOT NULL,  
    fname VARCHAR(30) CHARACTER SET  utf16,   
    lname VARCHAR(30) CHARACTER SET  utf16,  
    hired DATE NOT NULL DEFAULT '1970-01-01',  
    separated DATE NOT NULL DEFAULT '9999-12-31',  
    job_code INT,  
    store_id INT  
)charset=utf16  
PARTITION BY HASH(store_id)  
PARTITIONS 4;

insert  into  employees003(id,fname,lname,job_code,store_id) values(1,'中国人民','國軍',10,20);
select   *  from   employees003;


-- echo -- character-2-1-5-4   KSY分区   ob不支持这个分区
drop TABLE if exists employees004;  
-- echo CREATE TABLE employees004(col1 INT NOT NULL,col2 CHAR(5) CHARACTER SET  utf16,  col3 DATE)charset=utf16 PARTITION BY LINEAR KEY (col1)  PARTITIONS 3;


-- echo -- character-2-1-5-5    线性哈希功能   ob不支持
drop TABLE if exists employees005;  
-- echo CREATE TABLE employees005(id INT NOT NULL,fname VARCHAR(30) CHARACTER SET  utf16,lname VARCHAR(30) CHARACTER SET  utf16,hired DATE NOT NULL DEFAULT '1970-01-01',separated DATE NOT NULL DEFAULT '9999-12-31',  job_code INT,  store_id INT  )charset=utf16   PARTITION BY LINEAR HASH(YEAR(hired)) PARTITIONS 4; 





-- echo -- 子分区：
-- echo -- character-2-1-5-6   不定义每个子分区
drop TABLE if exists employees006;  
CREATE TABLE employees006(id INT, purchased DATE)charset=utf16 
    PARTITION BY RANGE( YEAR(purchased) )
    SUBPARTITION BY HASH( TO_DAYS(purchased) )
    SUBPARTITIONS 2 (
        PARTITION p0 VALUES LESS THAN (1990),
        PARTITION p1 VALUES LESS THAN (2000),
        PARTITION p2 VALUES LESS THAN MAXVALUE
    );
   
insert  into  employees006(id,purchased) values(1,'1970-01-01');
select   *  from   employees006;
   
   
