-- echo --character-5-2-2-3  C：自定义函数使用循环
drop function if exists myfun3;
delimiter //;
create function myfun3(userId int) returns varchar(20)
begin
set @sum004='hello world';
set @tcount=userId;
WHILE userId < 3000 DO
SET userId = userId+1;
insert into t_user values(null, 'Jas'),(null, 'Joy');
select count(*) into @sum004 from t_user;
END WHILE;
	
return @sum004;
end//

DELIMITER ;//
select  myfun3(1);

select   @sum004  from   dual;
select count(*) from t_user;



-- disable_warnings
drop table if exists t_user;
create table t_user (
  id int not null auto_increment,
  name varchar(30005) not null,primary key (id)
)engine=innodb auto_increment=1 default charset=gbk;
-- enable_warnings
truncate table t_user;
drop function if exists myfun4;
delimiter //;
create function myfun4(userId int) returns varchar(20)
begin
set @sum005='hello world';
set @cccount=userId;
set @str='';
outer_label: begin

     WHILE @cccount < 309 DO
          SET @cccount = @cccount+1;
          insert into t_user values(null, concat('Jas',cast(@str as char)));
          SET @str = concat(@str,concat('Jas',cast(@cccount as char)));
          select count(*) into @sum005 from t_user;

         if LENGTH(@str)>300   then
				    leave  outer_label; 
			   end if;

		END WHILE;
end outer_label;
-- echo --  select   *  from   t_user where id =1;#函数内部不能写查询语句，但是可以通过select进行赋值。
-- echo --  set @sum005=99999;#定义的系统变量可以不定义类型，接收多种类型的数据。
-- echo --  return @sum005;
return  LENGTH(@str); 
end//



DELIMITER ;//
select  myfun4(1);
select   @sum005  from   dual;
select count(*) from t_user;
select LENGTH(name)  from t_user e  where  e.id=(select count(*) from t_user);


