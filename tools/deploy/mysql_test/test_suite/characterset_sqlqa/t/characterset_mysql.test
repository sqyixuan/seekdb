-- echo -- character-5-2-1-1   A:无参数的存储过程
drop procedure if exists myproc1;
delimiter //;
create procedure myproc1()
begin
INSERT INTO SALGRADE VALUES (1,700,1200); 
INSERT INTO SALGRADE VALUES (2,1201,1400); 
INSERT INTO SALGRADE VALUES (3,1401,2000); 
INSERT INTO SALGRADE VALUES (4,2001,3000); 
INSERT INTO SALGRADE VALUES (5,3001,9999);
SELECT ename,SUBSTR(hiredate FROM 1 FOR 7) FROM emp ORDER BY SUBSTR(hiredate FROM 6 FOR 2),SUBSTRING(hiredate FROM 1 FOR 4);
end //
DELIMITER ;//
call myproc1();
select  *  from   SALGRADE;

-- echo --  character-5-2-1-2  B:只有一个 in 参数的存储过程
drop procedure if exists myproc2;
delimiter //;
create procedure myproc2(in userId int)
begin
    SELECT * FROM emp
WHERE empno IN(SELECT empno FROM emp WHERE deptno = userId);
end//
DELIMITER ;//
set @dum =10;
call myproc2(@dum);
SELECT * FROM emp   WHERE empno IN(SELECT empno FROM emp WHERE deptno = @dum);

-- echo --   character-5-2-1-3     :包含 in 参数和 out 参数的存储过程,只能将一行的查询到的用户名赋值给username 
drop procedure if exists myproc3;
delimiter //;
create procedure myproc3(in userId int, out username varchar(20))
begin
set username= userId;	
#SELECT d.dname into  username FROM dept d  where  d.deptno in (SELECT a.deptno FROM (SELECT e.deptno FROM emp e,salgrade s  WHERE (e.sal BETWEEN s.loosal AND s.hisal)GROUP BY e.deptno ORDER BY avg(s.grade)) a) LIMIT userId;
SELECT d.dname  FROM dept d where  d.DEPTNO<> username;		
#select  username;
end//
DELIMITER ;//
-- echo --  调用时，传入查询的userid 和 全局变量 @username
call myproc3(10,@username);


-- echo --   character-5-2-1-4   D:包含 inout 参数的存储过程
drop procedure if exists myproc4;
delimiter //;
create procedure myproc4(inout a int)
begin
SELECT d.* FROM dept d 
            WHERE d. deptno NOT IN(SELECT deptno FROM emp WHERE sal < a GROUP BY deptno);

end//

DELIMITER ;//
-- echo --  用户变量 （全局的变量）作用域： 用户变量: 在当前连接（即当前会话）中都有效
set @num =1000;
call  myproc4(@num);





-- echo --   character-5-2-1-5  E:存储过程循环,in p_number int, #要循环的次数,in p_startid int #循环的起始值
drop procedure if exists myproc5;
delimiter //;

create  procedure myproc5(
	in p_number int, 
	in p_startid int
)
begin  
    declare v_val int;  
    set v_val=p_startid;

    loop_label:  loop   
        set v_val=v_val+1; 
		insert into EMP (EMPNO, ENAME, JOB, MGR, HIREDATE, SAL, COMM, DEPTNO)
		values (v_val, concat('MARTIN',cast(v_val as char)), concat('SAMAN',cast(v_val as char)), 1698+v_val,         str_to_date('28-09-1981', '%d-%m-%Y'), 1250+v_val, 1400+v_val, 30);
        if(v_val>p_number)then
            leave  loop_label;  
        end if;
    end loop; 
    select  *   from   emp  e  where   e.EMPNO<1020;
		delete  from   emp   where   EMPNO<5000;
		select  *   from   emp  e;
end//

DELIMITER ;//
call myproc5(4000,1000);


-- echo --   character-5-2-1-6  存储过程结果作为参数传递

drop function  IF EXISTS salemp001;
DELIMITER //;
CREATE FUNCTION salemp001(saller001 int) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;#定义局部变量并初始化
SELECT  AVG(SAL) INTO ag #为局部变量赋值
FROM emp e INNER JOIN dept d ON e.DEPTNO=d.DEPTNO where  e.sal >saller001 GROUP BY d.DEPTNO having d.DEPTNO>20;
RETURN ag;
end//
DELIMITER ;//
SELECT salemp001(100);

##2.有参数的函数，并把函数的返回值当做参数
drop function  IF EXISTS salemp002;
DELIMITER //;
CREATE FUNCTION salemp002(saller002 DOUBLE) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;#定义局部变量并初始化
SELECT  AVG(SAL) INTO ag #为局部变量赋值
FROM emp e INNER JOIN dept d ON e.DEPTNO=d.DEPTNO where  e.sal >saller002 GROUP BY d.DEPTNO having d.DEPTNO>20;
RETURN ag;
end//
DELIMITER ;//
SELECT salemp002(salemp001(100));#在函数里调用函数



drop procedure if exists demo007;
##truncate table emp_rg;
delimiter //;
create procedure demo007(in nummax int)
BEGIN
DECLARE i int DEFAULT 300;
declare a char(255);
WHILE i < nummax-900 DO
set a=concat("测试机构helloworld中國國民黨反動派",cast(i as char));
INSERT INTO emp VALUES(i,'MILLER',a,7782,'1950-09-1',1300,NULL,10);
set i:=i+1;
END WHILE;
END
//
delimiter ;//
call demo007(salemp002(salemp001(100))-1000);#存储过程的参数是函数的返回值
select   *  from   emp;


#游标的应用
drop table  IF EXISTS  store;
CREATE TABLE IF NOT EXISTS store(
id    int(11) NOT NULL AUTO_INCREMENT,
name  varchar(20) NOT NULL,
count int(11) NOT NULL DEFAULT '1',PRIMARY KEY (id)
)DEFAULT CHARSET=gbk AUTO_INCREMENT=9;
 
INSERT INTO store(id, name, count) VALUES(1, 'android', 15),(2, 'iphone', 14),(3, 'iphone', 20),(4, 'android', 5),(5, 'android', 13),(6, 'iphone', 13),(7, 'iphonee', 15),(8, 'iphone9', 19);
select   *  from  store;


delimiter //;
drop procedure if exists StatisticStore//
CREATE PROCEDURE StatisticStore()
begin	
	# 创建接收游标数据的变量
	declare c int;         #获取单条纪录的数量
	declare n varchar(20); #获取名称
	# 创建总数变量
	declare total int default 0;
	# 创建结束标志变量
	declare done int default false;
	# 创建游标 获取name和count的集合
	declare cur cursor for select name,count from store where name = 'iphone';
	# 指定游标循环结束时的返回值
	declare continue HANDLER for not found set done = true;

	# set赋值全局变量时 写在declare的下面。
	set @total002 := 100;
	# 设置初始值：set后的变量要么是前面已经定义过的局部变量，要么set后的变量前面加@定义成系统变量
	set total = 0;#这里是否设置初始值都可以，上面定义变量时已经设置了默认值
	# 打开游标
	open cur;
	# 开始循环游标里的数据
	read_loop:loop
	# 根据游标当前指向的一条数据 插入到上面申明的局部变量中
	fetch cur into n,c;#右边循环结束时会给done赋值
	# 判断游标的循环是否结束
	if done then
		leave read_loop;	# 跳出游标循环
	end if;
	# 获取一条数据时，将count值进行累加操作，这里可以做任意你想做的操作，
	set @totaldone := total + c;# 每次循环都设置一个新变量@totaldone，
	set total := total + c;     #total为历次循环的综合
	# 有loop 就一定要有end loop
	end loop;
	# 关闭游标
	close cur; 
	# 输出结果
	select total;
END//
delimiter ;// 
call StatisticStore();
select @totaldone;

-- enable_warnings

-- echo --  函数
-- echo -- character-5-2-2-1  A：无参数的自定义函数,赋值值from前只能有一个字段
drop function if exists myfun1;
delimiter //;
create function myfun1() returns int
begin
    declare sum001 int default 0;         		
    declare sum002 int; 
SELECT MAX(sal) into sum001  FROM emp GROUP BY deptno HAVING MAX(sal) <= 3000 AND MIN(sal) >=900;
SELECT MIN(sal) into sum002  FROM emp GROUP BY deptno HAVING MAX(sal) <= 3000 AND MIN(sal) >=900;
    return sum001+sum002;
end//
DELIMITER ;//
select  myfun1();


-- echo -- character-5-2-2-2 B：自定义函数，sum003(只能赋一个值，不能一列值)：定义系统会话变量,函数运行后，即使删除函数，系统变量也还是存在的。
drop function if exists myfun2;
delimiter //;
create function myfun2(userId int) returns varchar(20)
begin
	set @sum003='';
	select max(sal) into @sum003 from emp e where e.DEPTNO in(select t.DEPTNO   from  dept t);
		
	return @sum003;
end//

DELIMITER ;//
select  myfun2(1);
drop function if exists myfun2;
select   @sum003  from   dual;


