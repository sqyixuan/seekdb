-- echo -- character-2-1-8   临时表

DROP TABLE IF EXISTS limit_dept;
create TABLE limit_dept(
DEPTNO INT not null auto_increment primary key, 
DNAME VARCHAR(30) CHARACTER SET  utf16,
LOC VARCHAR(40) CHARACTER SET  utf16  
)charset=utf16 ; 
-- enable_warnings

DROP PROCEDURE IF EXISTS limit_pro;
DELIMITER //;
CREATE PROCEDURE limit_pro()
BEGIN

    DECLARE v_i int unsigned DEFAULT 0;
    repeat
    	SET v_i = v_i+1;
        INSERT INTO limit_dept VALUES (null,concat(cast(v_i as char),'ACCOUNTING'),'NEW YORK');
        
    UNTIL v_i >= 40 END REPEAT;
end//
DELIMITER ;//
CALL limit_pro();

select  *  from    limit_dept;

