-- echo --====================================================================普通函数测试===============================================================================================================

-- echo  普通函数测试
drop database  IF EXISTS  variablesandconstants;
create database variablesandconstants character set utf16;
use variablesandconstants;


DROP TABLE IF EXISTS table001;
CREATE TABLE  table001(
c1 INT UNSIGNED AUTO_INCREMENT,
c2 VARCHAR(100) CHARACTER SET gbk NOT NULL,
c3 VARCHAR(200) CHARACTER SET utf16 NOT NULL,
c4 CHAR(200) CHARACTER SET gbk, 
c5 CHAR(200) CHARACTER SET utf16, 
c6 varchar(300) generated always as(concat(c2,c4)),#生成列的两个字段的字符集要保持一致。
PRIMARY KEY(c1)
)CHARSET=gbk;    #表字符集gbk
insert into  table001(c1,c2,c3,c4,c5)values(null,'中国','美国','英国','法国');
insert into  table001(c1,c2,c3,c4,c5)values(null,'中国Longlivethegreatunityofthepeopleoftheworld','美国Longlivethegreatunityofthepeopleoftheworld','英国Longlivethegreatunityofthepeopleoftheworld','法国Longlivethegreatunityofthepeopleoftheworld');
insert into  table001(c1,c2,c3,c4,c5)values(null,'中国','中国・米国・英国・フランス','China, the United Kingdom, France','Chine États-Unis Royaume-Uni France');
select  *  from   table001;

DROP TABLE IF EXISTS table002;
CREATE TABLE  table002(
c1 INT UNSIGNED AUTO_INCREMENT,
c2 VARCHAR(100) CHARACTER SET gbk NOT NULL,
c3 VARCHAR(200) CHARACTER SET utf16 NOT NULL,
c4 CHAR(200) CHARACTER SET gbk, 
c5 CHAR(200) CHARACTER SET utf16, 
c6 varchar(300) generated always as(concat(c2,c4)),#生成列的两个字段的字符集要保持一致。
PRIMARY KEY(c1)
)CHARSET=utf16;  #表字符集utf16
