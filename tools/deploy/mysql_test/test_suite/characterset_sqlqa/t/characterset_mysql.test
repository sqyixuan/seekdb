-- echo --   =====================================================================database:utf16=========================================================================
-- echo --   建库时指定字符集
-- disable_warnings
drop database  IF EXISTS  ob100x;
create database ob100x  character set utf16;
use ob100x;
select database();
select schema();
select collation(schema());
select coercibility(schema());

SET FOREIGN_KEY_CHECKS=1;
-- echo --  character-1-1-1  转移字符
SELECT 'hello', '"hello"', '""hello""', 'hel''lo', '\'hello','hel\nlo', '"hel\tlo"', '""he\rllo""', 'he\bl''lo', 'he\_l\%lo';

SELECT 'This\nIs\nFour\nLines';





-- echo --  character-1-1-2  图形符号
select  '❤❥웃유♋☮✌☏☢☠✔☑♚▲♪✈✞÷↑↓◆◇⊙■□△▽¿─│♥❣♂♀☿Ⓐ✍✉☣☤✘☒♛▼♫⌘☪≈←→✞✛✜✝✙✠✚†‡◉○◌◍◎●◐◑◒◓◔◕◖◗❂☢⊗⊙◘◙';


-- echo --  character-1-1-3  图形符号
select  '~@#￥%……&*（）——+：“》？《.+/';




-- echo --  character-1-2-1-1  简体字
select  '中华人民共和国中华人民共和国中华人民共和国中华人民共和国中华人民共和国中华人民共和国中华人民共和国中华人民共和国';




-- echo --  character-1-2-1-2  繁体字
select  '哎 哀 唉 埃 挨 锿 捱 皑 癌 嗳 矮 蔼 霭 艾 爱 砹 隘 嗌 嫒 碍 暧 瑷 僾 薆 安 桉 氨 庵 谙 腤 鹌 鞍 鮟 盫 啽 垵 俺 唵 埯 铵 揞 犴 岸 按 案 胺 暗 黯 肮 昂 枊 盎 醠 凹 坳 垇 爊 敖 嗷 嶅 廒 獒 遨 熬 璈 翱 聱 螯 謷 鳌 鏖 芺 袄 媪 岙 傲 奡 奥';


-- echo --  character-1-2-1-3   中文：双引号+空格/制表符
select  '“” 	
';


-- echo --  character-1-2-1-4   简体字和繁体字组合
select  '中华人民共和国中华唉 埃 挨 锿 捱 皑 癌 嗳 矮 蔼 霭 艾';



-- echo -- character-1-2-2-1   英文大小写
select  'AAAAAAAAAAAADDSGDFHGFJVGHKGHKGHLGLGLHJOLYSGSHBXsdfdsfdsgdsgdfhdfjgfmbvkyuolyhuj;lhjl.jbhn,.dfgdsgsgs';

-- echo -- character-1-2-2-2   英文：双引号+空格/回车/制表符
select  '"" 
	';



-- echo --  character-1-2-2-1   日韩文字
select  '関数内部には問い合わせ文を書くことはできないが,selectにより代入可能である。';
select  '함수 내부에서 조회 어구를 쓸 수 없지만 선택표를 통해 값을 정할 수 있다.';


-- echo --  character-1-3-1  苏州码子
select  '苏州码子（〡、〢、〣、〤、〥、〦、〧、〨、〩、十）';


-- echo --  character-1-3-2-1   正数、负数                          
select  3245356465475674;
select  -145646547657878;

-- echo --  character-1-3-2-2   整数，小数          
select  100000000000000000000;
select  1.32356464212121221646;


-- echo --   character-1-3-3  罗马数字
select   'Ⅰ Ⅱ Ⅲ Ⅳ Ⅴ Ⅵ Ⅶ Ⅷ Ⅸ Ⅹ Ⅺ Ⅻ';



-- echo --  character-1-3-4-1  2进制                   
select bin(12); 


-- echo --  character-1-3-4-2  8进制                   
select oct(12); 


-- echo --  character-1-3-4-3  10进制                   
select 255;

-- echo --  character-1-3-4-4  16进制                   
select hex(255); 


-- echo --  character-1-4  其他
select  'defedtgtghgfjfhjf股份附 Ⅴ 쓸 수 없지만 선택표를 통해 값을 정할 수 있다わせ文を Ⅵ Ⅶ Ⅷ 加费苏州码子（放到民共和国中华唉 埃 挨 锿 捱〡、〢、〣、〤、〥、〦、〧、〨、〩、十）';


