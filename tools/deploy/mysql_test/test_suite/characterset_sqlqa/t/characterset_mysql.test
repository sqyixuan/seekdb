#select * from   staff e  where   e.name  like  '李_';

-- echo --   character-5-1-1-3   group by[ having]     
select id,name from department where id in (select dep_id from staff group by dep_id having avg(age) > 28);


-- echo --   character-5-1-1-4  排序   
select id,name from department where id in (select dep_id from staff group by dep_id having avg(age) > 28)  order by  id  desc;
select id,name from department where id in (select dep_id from staff group by dep_id having avg(age) > 28)  order by  id  asc;

-- echo --   character-5-1-1-5   子查询
select name from staff where dep_id =(select id from department where name = '销售');
select name from staff where dep_id in (select id from department where name = '销售' or name = '人力资源');
-- echo --    带EXISTS关键字的子查询
select * from staff where exists (select id from department where id=200);
select * from staff  where exists (select id from department where id=204);



-- echo --   character-5-1-1-6   组合查询
select * from staff  left join department on staff.dep_id=department.id
union 
select * from staff  right join department on staff.dep_id=department.id;

select * from staff  left join department on staff.dep_id=department.id
union all
select * from staff  right join department on staff.dep_id=department.id;

select t1.name,t1.age from staff t1  inner join  (select dep_id,avg(age) avg_age from staff group by dep_id) t2
on t1.dep_id = t2.dep_id  where t1.age > t2.avg_age; 



-- echo --   character-5-1-1-7-1  伪列
SELECT @rownum:=@rownum+1 AS rownum, staff.* FROM (SELECT @rownum:=0) r, staff;

