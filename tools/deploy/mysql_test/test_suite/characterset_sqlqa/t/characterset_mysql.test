drop table if exists partdepent;
CREATE TABLE partdepent(
partdepentid int,  # 部门编号
DNAME VARCHAR(14)  character set gbk, 
LOC  VARCHAR(14) character set gbk, CONSTRAINT pk_dept PRIMARY KEY(partdepentid)
) DEFAULT CHARSET=gbk;

drop table if exists prize_table;
CREATE TABLE prize_table(
id int PRIMARY KEY,
name varchar(100) character set gbk,
contry char(200) character set gbk,
company int,
birty DATE,
money float(7,2),
prize float(7,2),
nameprize varchar(100) character set gbk,
workshop int,CONSTRAINT fk_deptno FOREIGN KEY(id) REFERENCES partdepent(partdepentid));
