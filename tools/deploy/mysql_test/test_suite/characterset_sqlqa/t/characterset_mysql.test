#数据库设置字符集gbk，存储过程设置utf16字符集
drop database  IF EXISTS  ob200x;
create database ob200x  character set gbk;
use ob200x;

drop function if exists myfun400;
delimiter //;
create function myfun400(username varchar(20) character set utf16)  returns varchar(20)
begin
set @str='';
