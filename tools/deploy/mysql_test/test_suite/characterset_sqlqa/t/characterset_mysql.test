-- echo -- character-2-2-5-5    线性哈希功能   ob不支持
drop TABLE if exists employees005;  
-- echo CREATE TABLE employees005(id INT NOT NULL,fname VARCHAR(30) CHARACTER SET  gbk,lname VARCHAR(30) CHARACTER SET  gbk,hired DATE NOT NULL DEFAULT '1970-01-01',separated DATE NOT NULL DEFAULT '9999-12-31',  job_code INT,  store_id INT  )charset=gbk   PARTITION BY LINEAR HASH(YEAR(hired)) PARTITIONS 4; 





-- echo -- 子分区：
-- echo -- character-2-2-5-6   不定义每个子分区
drop TABLE if exists employees006;  
CREATE TABLE employees006(id INT, purchased DATE)charset=gbk 
    PARTITION BY RANGE( YEAR(purchased) )
    SUBPARTITION BY HASH( TO_DAYS(purchased) )
    SUBPARTITIONS 2 (
        PARTITION p0 VALUES LESS THAN (1990),
        PARTITION p1 VALUES LESS THAN (2000),
        PARTITION p2 VALUES LESS THAN MAXVALUE
    );
insert   into   employees006(id,purchased) values(1,'1970-01-01');
select   *  from  employees006;
   

