-- echo --  character-5-1-1-1-1  自连接：join ，inner join
select * from staff inner join department on staff.dep_id=department.id;


-- echo --   character-5-1-1-1-2   笛卡尔积
select * from staff,department;




-- echo --  character-5-1-1-1-3    左外连接：left join 

select * from staff left join department on staff.dep_id=department.id;



-- echo --  character-5-1-1-1-4 
select * from staff  left join department on staff.dep_id=department.id
union
select * from staff  right join department on staff.dep_id=department.id;


-- echo --  character-5-1-1-1-5    右外连接
select * from staff right join department on  staff.dep_id=department.id;


-- echo --  character-5-1-1-2-1   =、!=、<>、<、<=、>、>=
select * from   staff e  where   e.id=1;
select * from   staff e  where   e.id!=1;
select * from   staff e  where   e.id<>1;
select * from   staff e  where   e.id<2;
select * from   staff e  where   e.id<=2;
select * from   staff e  where   e.id>1;
select * from   staff e  where   e.id>=1;
select name,age from staff where age > (select avg(age) from staff);



-- echo --  character-5-1-1-2-2
select * from   staff e  where   e.id between 1  and  3;

-- echo --  character-5-1-1-2-3
select * from   staff e  where   e.id in(1,3);
select * from   staff e  where   e.id not in(1,3);
select name from department where id not in (select distinct dep_id from staff);




-- echo --  character-5-1-1-2-4
select * from   staff e  where   e.id!=1  and   e.id!=4;


