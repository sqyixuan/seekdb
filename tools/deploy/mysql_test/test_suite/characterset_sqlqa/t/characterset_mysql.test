use ob100x;
SET FOREIGN_KEY_CHECKS=1;


-- echo --   聚合函数  新建测试表
-- disable_warnings
drop table  IF EXISTS  student;
-- enable_warnings
create table student
(id int(10) primary key,
name varchar(20) CHARACTER SET  gbk not null,
sex varchar(4),
birth year,
department varchar(20) not null,
address varchar(50))charset=utf16;

-- disable_warnings
drop table  IF EXISTS  score;
-- enable_warnings
create table score
(id int(10) primary key,
stu_id int(10) not null,
c_name varchar(20) CHARACTER SET  utf16 not null,
grade int(10))charset=utf16;
