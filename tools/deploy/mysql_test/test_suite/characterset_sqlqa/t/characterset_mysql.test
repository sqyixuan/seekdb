-- echo --   =====================================================================库，表，列UTF16=========================================================================
drop database  IF EXISTS  ob100x;
create database ob100x  character set utf16;
use ob100x;
-- echo --   character-2-1-1   表

drop table  IF EXISTS  characterset;
-- enable_warnings
create table characterset(
id int not null auto_increment primary key,
fuhao varchar(100) character set utf16,
zifu char(100)  character set utf16 not null,
sage tinyint(100) not null,
sdept char(40) not null)DEFAULT CHARACTER SET = utf16,comment = '字符集表';
insert into characterset values(null,'❤❥웃유♋☮✌☏☢☠✔','hello world',100,'文字セット');
select   *  from   characterset;
-- disable_warnings
drop table  IF EXISTS  characterset;
-- enable_warnings

-- echo --  新建基础表
-- disable_warnings
drop table if exists emp_rg;
-- enable_warnings

CREATE TABLE emp_rg(EMPNO int PRIMARY key,
ename varchar(100) character set utf16,
job char(200) character set utf16,
MGR int,HIREDATE DATE,SAL float(7,2),COMM float(7,2),DEPTNO int)CHARACTER SET = utf16;
