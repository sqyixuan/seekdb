#show variables like 'character_set%';




-- disable_warnings
drop table  IF EXISTS  student;
drop table  IF EXISTS  score;
DROP TABLE IF EXISTS course;
-- enable_warnings


-- echo --   character-4-1-6   聚合函数和when  case联合使用
-- echo --  创建表  学生表
-- disable_warnings
drop table  IF EXISTS  edu_student;
CREATE TABLE edu_student(stu_id VARCHAR (16) CHARACTER SET gbk NOT NULL COMMENT '学号',
stu_name VARCHAR (20) NOT NULL COMMENT '学生姓名',PRIMARY KEY (stu_id))charset=utf16;

-- echo --   课程表 
drop table  IF EXISTS  edu_courses;
CREATE TABLE edu_courses(course_no VARCHAR (20) CHARACTER SET gbk NOT NULL COMMENT '课程编号',
course_name VARCHAR (100) NOT NULL,PRIMARY KEY (course_no))COMMENT = '课程表' charset=gbk;

-- echo --   成绩表
drop table  IF EXISTS  edu_score;
CREATE TABLE edu_score(stu_id VARCHAR (16) NOT NULL COMMENT '学号',
course_no VARCHAR (20) CHARACTER SET utf16 NOT NULL COMMENT '课程编号',scores FLOAT NULL DEFAULT NULL COMMENT '得分',
PRIMARY KEY (stu_id, course_no))charset=utf16;

