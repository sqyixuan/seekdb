-- echo -- character-5-1-1-1-1  自连接：join ，inner join
-- echo -- 多表查询：
-- disable_warnings
drop table  IF EXISTS  department;
-- enable_warnings
create table department
(id int,
name varchar(20) CHARACTER SET  utf16 not null
)charset=gbk;

-- disable_warnings
drop table  IF EXISTS  staff;
-- enable_warnings
create table staff(
id int primary key auto_increment,
name varchar(20),
sex enum('male','female') CHARACTER SET gbk not null default 'male',
age int,
dep_id int
)charset=utf16;

