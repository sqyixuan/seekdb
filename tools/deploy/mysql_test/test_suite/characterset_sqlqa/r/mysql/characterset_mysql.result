--   character-5-2-1-5  E:存储过程循环,in p_number int, #要循环的次数,in p_startid int #循环的起始值
drop procedure if exists myproc5;
create  procedure myproc5(
in p_number int, 
in p_startid int
)
begin  
declare v_val int;  
set v_val=p_startid;
loop_label:  loop   
set v_val=v_val+1; 
insert into EMP (EMPNO, ENAME, JOB, MGR, HIREDATE, SAL, COMM, DEPTNO)
values (v_val, concat('MARTIN',cast(v_val as char)), concat('SAMAN',cast(v_val as char)), 1698+v_val,         str_to_date('28-09-1981', '%d-%m-%Y'), 1250+v_val, 1400+v_val, 30);
if(v_val>p_number)then
leave  loop_label;  
end if;
end loop; 
select  *   from   emp  e  where   e.EMPNO<1020;
delete  from   emp   where   EMPNO<5000;
select  *   from   emp  e;
end//
call myproc5(4000,1000);
