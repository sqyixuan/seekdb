--    procedure     存储过程    
--   基础表          charset=utf16;   CHARACTER SET gbk 
drop database  IF EXISTS  ob100x;
create database ob100x  character set utf16;
use ob100x;
drop table if exists salgrade;
CREATE TABLE salgrade(  
grade int, 
loosal int,  
hisal int
) DEFAULT CHARSET=utf16;
drop table if exists DEPT;
create table DEPT
(
DEPTNO int(2) not null,
DNAME varchar(14) CHARACTER SET gbk,
LOC varchar(13) CHARACTER SET utf16,constraint PK_DEPT primary key (DEPTNO)
)CHARSET=utf16;
drop table if exists EMP;
create table EMP
(
EMPNO int(4) not null,
ENAME varchar(10)  CHARACTER SET gbk,
JOB varchar(100) CHARACTER SET utf16,
MGR int(4),
HIREDATE date,
SAL int(7 ),
COMM int(7 ),
DEPTNO int(2),constraint PK_EMP primary key (EMPNO),constraint FK_DEPTNO foreign key (DEPTNO)  references DEPT (DEPTNO)
)charset=gbk;
alter table DEPT  add constraint PK_DEPT primary key (DEPTNO);ob不支持这类语句
alter table EMP  add constraint PK_EMP primary key (EMPNO);
alter table EMP  add constraint FK_DEPTNO foreign key (DEPTNO)  references DEPT (DEPTNO);
