drop database  IF EXISTS  ob100x;
create database ob100x  character set gbk;
use ob100x;
--   character-4-1-6   GROUP_CONCAT
DROP TABLE IF EXISTS course;
CREATE TABLE course (
name varchar(255) CHARACTER SET utf16,
course_name varchar(255) CHARACTER SET gbk,
mes varchar(255) CHARACTER SET gbk
)charset=utf16;
