drop table  IF EXISTS  store;
CREATE TABLE IF NOT EXISTS store(
id    int(11) NOT NULL AUTO_INCREMENT,
name  varchar(20) NOT NULL,
count int(11) NOT NULL DEFAULT '1',PRIMARY KEY (id)
)DEFAULT CHARSET=gbk AUTO_INCREMENT=9;
