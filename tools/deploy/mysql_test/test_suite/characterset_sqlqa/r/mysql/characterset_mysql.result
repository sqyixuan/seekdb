--   聚合函数 sum 配合 case when 的简单函数实现行转列
drop table  IF EXISTS  edu_student;
drop table  IF EXISTS  edu_courses;
drop table  IF EXISTS  edu_score;
--   character-4-2-1   case..when语句
SELECT CASE  5  WHEN 1 THEN 'one'WHEN 2 THEN 'two' ELSE 'more' END;
CASE  5  WHEN 1 THEN 'one'WHEN 2 THEN 'two' ELSE 'more' END
more
SELECT CASE 3   WHEN 1>0 THEN 'true' ELSE 'false' END;
CASE 3   WHEN 1>0 THEN 'true' ELSE 'false' END
false
SELECT CASE BINARY 'B' WHEN 'a' THEN 1 WHEN 'b' THEN 2 END;
CASE BINARY 'B' WHEN 'a' THEN 1 WHEN 'b' THEN 2 END
NULL
drop table  IF EXISTS  type_table;
create table type_table(NAME varchar(20));
insert into  type_table values('helloworld');
--  #枚举这个字段所有可能的值
--   搜索函数搜索函数可以写判断，并且搜索函数只会返回第一个符合条件的值，其他case被忽略,# when 表达式中可以使用 and 连接条件
drop table  IF EXISTS  type_table;
create table type_table(NAME varchar(20),age int);
insert into  type_table values('helloworld',20);
select  NAME '英雄', age '年龄',case
WHEN age < 18 then   '少年'
        WHEN age < 30 then   '青年'
        WHEN age >= 30
AND  age < 50 then     '中年'
        else   '老年'
        END '状态'  from  type_table;
英雄	年龄	状态
helloworld	20	青年
--   character-4-2-2   IF(expr1,expr2,expr3)
SELECT IF(1>2,2,3);
IF(1>2,2,3)
3
SELECT IF(1<2,'yes ','no');
IF(1<2,'yes ','no')
yes 
SELECT IF(STRCMP('test','test1'),'no','yes');
IF(STRCMP('test','test1'),'no','yes')
no
--   character-4-2-3    IFNULL:
SELECT IFNULL(NULL, "RUNOOB");
IFNULL(NULL, "RUNOOB")
RUNOOB
SELECT IFNULL("Hello", "RUNOOB");
IFNULL("Hello", "RUNOOB")
Hello
--   character-4-2-4 
select  NULLIF(1,NULL);
NULLIF(1,NULL)
1
select NULLIF(NULL,1);
NULLIF(NULL,1)
NULL
--   character-4-2-5 
select STRCMP('text', 'text2');
STRCMP('text', 'text2')
-1
select STRCMP('text2', 'text');
STRCMP('text2', 'text')
1
select STRCMP('text', 'text');
STRCMP('text', 'text')
0
--   character-4-3-1  加密函数
select  MD5('abcd');
MD5('abcd')
e2fc714c4727ee9395f324cd2e7f331f
--   character-4-3-2  加密函数
--   character-4-3-3
--   character-4-4-1  CHARSET(str)函数返回字符串str的字符集，一般情况这个字符集就是系统的默认字符集；COLLATION(str)函数返回字符串str的字符排列方式
select  CHARSET('hello');
CHARSET('hello')
utf8mb4
--   character-4-4-2
select   COLLATION('hello');
COLLATION('hello')
utf8mb4_general_ci
--  转换函数
-- character-4-5-1   隐式类型转换
SELECT 1+'1';
1+'1'
2
SELECT concat(2,'test');
concat(2,'test')
2test
-- character-4-5-2     显式类型转换:CAST(expr AS type)
SELECT cast('28.82abc' AS DECIMAL);
cast('28.82abc' AS DECIMAL)
29
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: '28.82abc'
SELECT cast('28.82abc' AS DECIMAL(4));
cast('28.82abc' AS DECIMAL(4))
29
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: '28.82abc'
SELECT cast('28.82abc' AS DECIMAL(1));
cast('28.82abc' AS DECIMAL(1))
9
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: '28.82abc'
SELECT cast('28.82abc' AS DECIMAL(2,1));
cast('28.82abc' AS DECIMAL(2,1))
9.9
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: '28.82abc'
SELECT cast('28.82abc' AS DECIMAL(2,2));
cast('28.82abc' AS DECIMAL(2,2))
0.99
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: '28.82abc'
SELECT cast('28.82abc' AS UNSIGNED);
cast('28.82abc' AS UNSIGNED)
28
Warnings:
Warning	1292	Truncated incorrect INTEGER value: '28.82abc'
SELECT cast('2007-12-25' AS DATETIME);
cast('2007-12-25' AS DATETIME)
2007-12-25 00:00:00
SELECT cast('2007-12-25' AS DATE);
cast('2007-12-25' AS DATE)
2007-12-25
SELECT cast('20:20:20' AS TIME);
cast('20:20:20' AS TIME)
20:20:20
SELECT cast('25-12-2007' AS DATETIME);
cast('25-12-2007' AS DATETIME)
NULL
SELECT cast('2007-may-25' AS DATETIME);
cast('2007-may-25' AS DATETIME)
NULL
SELECT cast(123 AS CHAR);
cast(123 AS CHAR)
123
SELECT cast(123 AS BINARY);
cast(123 AS BINARY)
123
-- character-4-5-3           Convert函数
SELECT convert('abc' USING utf16);
convert('abc' USING utf16)
abc
SELECT convert('你好' USING gbk);
convert('你好' USING gbk)
你好
-- character-5-1-1-1-1  自连接：join ，inner join
-- 多表查询：
drop table  IF EXISTS  department;
create table department
(id int,
name varchar(20) CHARACTER SET  utf16 not null
)charset=gbk;
drop table  IF EXISTS  staff;
create table staff(
id int primary key auto_increment,
name varchar(20),
sex enum('male','female') CHARACTER SET gbk not null default 'male',
age int,
dep_id int
)charset=utf16;
