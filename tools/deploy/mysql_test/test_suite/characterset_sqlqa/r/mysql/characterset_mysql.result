--#3.普通函数测试
--  character-3-1-1    返回字符串str的第一个字符的ascii值(str是空串时返回0) 
select ascii(2);
ascii(2)
50
select ascii('dete');
ascii('dete')
100
select ascii('');
ascii('')
0
select ascii('    ');
ascii('    ')
32
--  character-3-1-2   #如果字符串str句首是单字节返回与ascii()函数返回的相同值。
select ord('2');
--  character-3-1-3    
select conv("a",16,2);
select conv("6e",18,8);
select conv(-17,10,-18);
select conv(10+"10"+'10'+0xa,10,10);
select conv(c2,1,2),conv(c3,18,8)  from   table001 ;
select conv(c2,10,2),conv(c3,18,8)  from   table002 ;
--  character-3-1-4   
select bin(12);
select bin(c3) from   table001;
--  character-3-1-5   
select oct(12);
select oct(c3) from   table001;
--  character-3-1-6 
select hex(255);
select hex(c3) from   table001;
select hex(c2) from   table001;
select hex(c3) from   table002;
select hex(c2) from   table002;
--  character-3-1-7    返回由参数n,...对应的ascii代码字符组成的一个字串(参数是n,...是数字序列,null值被跳过)  
select char(77,121,83,81,'76');
select char(77,77.3,'77.3');
select char(77,77.3,null,'','77.3');
--  character-3-1-8 把参数连成一个长字符串并返回(任何参数是null时返回null) 
select concat('my', 's', 'ql');
select concat('my', null, 'ql');
select concat(14.3);
select  concat(c2, c3),concat(c4, c5) 连接   from   table001;
select  concat(c2, c3),concat(c4, c5) 连接   from   table002;
--  character-3-1-9 返回字符串str的长度
select length('text');
--  character-3-1-10   返回字符串substr在字符串str第一次出现的位置(str不包含substr时返回0)    substr函数
select position('bar' in 'foobarbar');
SELECT concat(SUBSTR(c2,6),SUBSTR(c3,6),6)     from   table001;
SELECT SUBSTR(c2 FROM 6)     from   table001;
SELECT SUBSTR(c3 FROM 6)     from   table001;
SELECT SUBSTR(c2,6,9)    from   table001;
SELECT SUBSTR(c3 FROM 6 FOR 9)   from   table001;
--  character-3-1-11  返回字符串substr在字符串str第一次出现的位置(str不包含substr时返回0)
select locate('bar', 'foobarbar');
select locate('xbar', 'foobar');
select locate('bar', 'foobarbar',5);
--  character-3-1-12
select instr('foobarbar', 'bar');
select instr('xbar', 'foobar');
select instr(c3, '中国')  from   table001;
--  character-3-1-13
select lpad('hi',4,'??');
select lpad(c2,40,'@')  from   table001;
select lpad(c2,40,'@')  from   table002;
--  character-3-1-14
select rpad('hi',5,'?');
select rpad(c2,40,'@')  from   table001;
--  character-3-1-15
select left('foobarbar', 5);
select left(c2, 5)   from   table001;
select left(c3, 5)   from   table001;
--  character-3-1-16
select right('foobarbar', 4);
--  character-3-1-17
select substring('quadratically',5,6);
select substring('quadratically',5);
select substring('foobarbar' from 4);
select substring(c2,5,6)   from   table001;
select substring(c3,5,6)   from   table001;
--  character-3-1-18
select substring_index('www.mysql.com', '.', 2);
select substring_index('www.mysql.com', '.', -2);
--  character-3-1-19
select ltrim('  barbar');
select ltrim(c2) from   table001;
select ltrim(c3) from   table001;
--  character-3-1-20   rtrim(str)  返回删除了右空格的字符串str 
select rtrim('barbar   ');
select rtrim(c2) from   table001;
select rtrim(c3) from   table001;
--  character-3-1-21     trim([[both | leading | trailing] [remstr] from] str)  
select trim('  bar   ');
select trim(leading 'x' from 'xxxbarxxx');
select trim(both 'x' from 'xxxbarxxx');
select trim(trailing 'xyz' from 'barxxyz');
select trim(c2) from   table001;
select trim(c3) from   table001;
select trim(concat(space(6),c2))  from   table001;
--  character-3-1-22
select concat(space(6),c2) from   table001;
select concat(space(6),c3) from   table001;
--  character-3-1-23     
select replace('www.mysql.com', 'w', 'ww');
--  character-3-1-24     repeat(str,count)  
select repeat('mysql', 3);
--  character-3-1-25    reverse(str) 
select reverse('abc');
select reverse(c2) from   table001;
select reverse(c3) from   table001;
--  character-3-1-26     insert(str,pos,len,newstr)  
select insert('quadratic', 3, 4, 'what');
--  character-3-1-27     elt(n,str1,str2,str3,...)  
select elt(1, 'ej', 'heja', 'hej', 'foo');
select elt(4, 'ej', 'heja', 'hej', 'foo');
select elt(1, c2, c3, c4, c5) from   table001;
select elt(4, c2, c3, c4, c5) from   table001;
select elt(1, c2, c3, c4, c5) from   table002;
select elt(4, c2, c3, c4, c5) from   table002;
--  character-3-1-28      field(str,str1,str2,str3,...)  
select field('ej', 'hej', 'ej', 'heja', 'hej','foo');
select elt(4, 'ej', 'heja', 'hej', 'foo');
select field('中国', 'hej', c2, c3, 'hej','foo') from   table001;
select field('中国', 'hej', c2, c3, 'hej','foo') from   table002;
--  character-3-1-29     find_in_set(str,strlist)  
select find_in_set('b','a,b,c,d');
--  character-3-1-30       make_set(bits,str1,str2,...) 
select make_set(1,'a','b','c');
select make_set(1 | 4,'hello','nice','world');
select make_set(0,'a','b','c');
select make_set(1,c2,c3,c4) from   table001;
select make_set(1 | 4,c2,c3,c4) from   table001;
--  character-3-1-31     小写字母
select lcase('quadratically');
select lower('quadratically');
select lcase(c2) from   table001;
select lower(c3) from   table001;
select concat(lower(c3),lcase(c2)) from   table001;
select concat(lower(c3),lcase(c2)) from   table002;
--  character-3-1-32   大写字母
select ucase('quadratically');
select upper('quadratically');
select ucase(c2) from   table001;
select concat(upper(c3),ucase(c2)) from   table001;
select concat(upper(c3),ucase(c2)) from   table002;
--  character-3-1-33      STRCMP(s1,s2)比较字符串 s1 和 s2，如果 s1 与 s2 相等返回 0 ，如果 s1>s2 返回 1，如果 s1<s2 返回 -1
SELECT STRCMP("runoob", "runoob");
SELECT STRCMP(c2, c4) from   table001;
SELECT STRCMP(c2, c4) from   table002;
--  character-3-1-34       FORMAT(x,n)函数可以将数字 x 进行格式化 “#,###.##”, 将 x 保留到小数点后 n 位，最后一位四舍五入
--====================================================================日期函数===============================================================================================================
drop database  IF EXISTS  ob100x;
create database ob100x  character set utf16;
use ob100x;
--  日期函数
--  character-3-2-1
select dayofweek('1998-02-03');
--  character-3-2-2 
select weekday('1997-10-04 22:23:00');
select weekday('1997-11-05');
--  character-3-2-3  
select dayofmonth('1998-02-03');
--  character-3-2-4
select dayofyear('1998-02-03');
--  character-3-2-5  
select month('1998-02-03');
--  dayname(date)  不存在 
--  character-3-2-2 #select dayname("1998-02-05");   
--  monthname(date)  不存在 
-- select monthname("1998-02-05");   
--  character-3-2-6 
--  select quarter('98-04-01');   ob报错mysql支持
--  character-3-2-7 
select week('1998-02-20');
select week('1998-02-20',0);
select week('1998-02-20',1);
--  character-3-2-8
select year('98-02-03');
--  character-3-2-9
select hour('10:05:03');
--  character-3-2-10 
select minute('98-02-03 10:05:03');
--  character-3-2-11
select second('10:05:03');
--   period_add(p,n)  #不存在 
--   #select period_add(9801,2);   
--  character-3-2-12 
select period_diff(9802,199703);
--  character-3-2-13 
select "1997-12-31 23:59:59" + interval 1 second;
select "1998-01-01" - interval 1 second;
select date_add("1997-12-31 23:59:59",interval 1 second);
select date_add("1997-12-31 23:59:59",interval 1 day);
select date_add("1997-12-31 23:59:59",interval "1:1" minute_second);
select date_add("1998-01-01 00:00:00",interval "11:1:1" day_second);
select date_add("1998-01-01 00:00:00", interval "-110" day_hour);
select date_sub("1998-01-02", interval 31 day);
select extract(year from "1999-07-02");
select extract(year_month from "1999-07-02 01:02:03");
select extract(day_minute from "1999-07-02 01:02:03");
--   #EXTRACT(type FROM d)从日期 d 中获取指定的值，type 指定返回的值
SELECT EXTRACT(MINUTE FROM '2011-12-13 14:15:16');
--  character-3-2-14  
select to_days(950501);
select to_days('1997-10-07');
--  character-3-2-15  
select from_days(729669);
--  character-3-2-16  
select date_format('1997-10-04 22:23:00','%w %m %y');
select date_format('1997-10-04 22:23:00','%h:%i:%s');
select date_format('1997-10-04 22:23:00','%d %y %a %d %m %b %j');
--  character-3-2-17   
select unix_timestamp('1997-10-04 22:23:00');
--  character-3-2-18   
select from_unixtime(875996580);
select from_unixtime(875996580) + 0;
--  character-3-2-19  sec_to_time(seconds)   
select sec_to_time(2378);
select sec_to_time(2378) + 0;
--  character-3-2-20  .time_to_sec(time)   
select time_to_sec('22:23:00');
select time_to_sec('00:39:38');
--  数学函数
--   character-3-3-1
select abs(2);
abs(2)
