--   character-5-2-1-6  存储过程结果作为参数传递
drop function  IF EXISTS salemp001;
CREATE FUNCTION salemp001(saller001 int) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;#定义局部变量并初始化
SELECT  AVG(SAL) INTO ag #为局部变量赋值
FROM emp e INNER JOIN dept d ON e.DEPTNO=d.DEPTNO where  e.sal >saller001 GROUP BY d.DEPTNO having d.DEPTNO>20;
RETURN ag;
end//
SELECT salemp001(100);
salemp001(100)
1566.666666666
drop function  IF EXISTS salemp002;
CREATE FUNCTION salemp002(saller002 DOUBLE) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;#定义局部变量并初始化
SELECT  AVG(SAL) INTO ag #为局部变量赋值
FROM emp e INNER JOIN dept d ON e.DEPTNO=d.DEPTNO where  e.sal >saller002 GROUP BY d.DEPTNO having d.DEPTNO>20;
RETURN ag;
end//
SELECT salemp002(salemp001(100));
salemp002(salemp001(100))
