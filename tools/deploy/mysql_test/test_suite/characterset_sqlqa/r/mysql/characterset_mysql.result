INSERT INTO course VALUES ('叶问', '阅读赏析','六号');
INSERT INTO course VALUES ('叶问', '法语','七号');
select t.name as '姓名',GROUP_CONCAT(t.course_name )  as '课程' from course t  group by t.name ;
姓名	课程
叶问	阅读赏析,法语
李明	阅读赏析,太极剑,摄影
