drop database  IF EXISTS  ob100x;
create database ob100x  character set gbk;
use ob100x;
--   character-2-2-1   表
drop table  IF EXISTS  characterset;
create table characterset(
id int not null auto_increment primary key,
fuhao varchar(100) character set gbk,
zifu char(100)  character set gbk not null,
sage tinyint(100) not null,
