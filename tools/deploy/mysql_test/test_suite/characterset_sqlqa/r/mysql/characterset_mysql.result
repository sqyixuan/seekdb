drop procedure if exists StatisticStore//
CREATE PROCEDURE StatisticStore()
begin	
# 创建接收游标数据的变量
declare c int;         #获取单条纪录的数量
declare n varchar(20); #获取名称
# 创建总数变量
declare total int default 0;
# 创建结束标志变量
declare done int default false;
# 创建游标 获取name和count的集合
declare cur cursor for select name,count from store where name = 'iphone';
# 指定游标循环结束时的返回值
declare continue HANDLER for not found set done = true;
# set赋值全局变量时 写在declare的下面。
set @total002 := 100;
# 设置初始值：set后的变量要么是前面已经定义过的局部变量，要么set后的变量前面加@定义成系统变量
set total = 0;#这里是否设置初始值都可以，上面定义变量时已经设置了默认值
# 打开游标
open cur;
# 开始循环游标里的数据
read_loop:loop
# 根据游标当前指向的一条数据 插入到上面申明的局部变量中
fetch cur into n,c;#右边循环结束时会给done赋值
# 判断游标的循环是否结束
if done then
leave read_loop;	# 跳出游标循环
end if;
# 获取一条数据时，将count值进行累加操作，这里可以做任意你想做的操作，
set @totaldone := total + c;# 每次循环都设置一个新变量@totaldone，
set total := total + c;     #total为历次循环的综合
# 有loop 就一定要有end loop
end loop;
# 关闭游标
close cur; 
# 输出结果
select total;
END//
call StatisticStore();
total
47
select @totaldone;
@totaldone
47
--  函数
-- character-5-2-2-1  A：无参数的自定义函数,赋值值from前只能有一个字段
drop function if exists myfun1;
create function myfun1() returns int
begin
declare sum001 int default 0;         		
declare sum002 int; 
SELECT MAX(sal) into sum001  FROM emp GROUP BY deptno HAVING MAX(sal) <= 3000 AND MIN(sal) >=900;
SELECT MIN(sal) into sum002  FROM emp GROUP BY deptno HAVING MAX(sal) <= 3000 AND MIN(sal) >=900;
return sum001+sum002;
end//
select  myfun1();
myfun1()
3800
-- character-5-2-2-2 B：自定义函数，sum003(只能赋一个值，不能一列值)：定义系统会话变量,函数运行后，即使删除函数，系统变量也还是存在的。
drop function if exists myfun2;
create function myfun2(userId int) returns varchar(20)
begin
set @sum003='';
select max(sal) into @sum003 from emp e where e.DEPTNO in(select t.DEPTNO   from  dept t);
return @sum003;
end//
select  myfun2(1);
myfun2(1)
5000
drop function if exists myfun2;
select   @sum003  from   dual;
@sum003
5000
drop table if exists t_user;
create table t_user (
id int not null auto_increment,
name varchar(30005) not null,primary key (id)
)auto_increment=1 default charset=gbk;
--character-5-2-2-3  C：自定义函数使用循环
drop function if exists myfun3;
create function myfun3(userId int) returns varchar(20)
begin
set @sum004='hello world';
set @tcount=userId;
WHILE userId < 3000 DO
SET userId = userId+1;
insert into t_user values(null, 'Jas'),(null, 'Joy');
select count(*) into @sum004 from t_user;
END WHILE;
return @sum004;
end//
select  myfun3(1);
myfun3(1)
5998
select   @sum004  from   dual;
@sum004
5998
select count(*) from t_user;
count(*)
5998
drop table if exists t_user;
create table t_user (
id int not null auto_increment,
name varchar(30005) not null,primary key (id)
)engine=innodb auto_increment=1 default charset=gbk;
truncate table t_user;
drop function if exists myfun4;
create function myfun4(userId int) returns varchar(20)
begin
set @sum005='hello world';
set @cccount=userId;
set @str='';
outer_label: begin
WHILE @cccount < 309 DO
SET @cccount = @cccount+1;
insert into t_user values(null, concat('Jas',cast(@str as char)));
SET @str = concat(@str,concat('Jas',cast(@cccount as char)));
select count(*) into @sum005 from t_user;
if LENGTH(@str)>300   then
leave  outer_label; 
end if;
END WHILE;
end outer_label;
-- echo --  select   *  from   t_user where id =1;#函数内部不能写查询语句，但是可以通过select进行赋值。
-- echo --  set @sum005=99999;#定义的系统变量可以不定义类型，接收多种类型的数据。
-- echo --  return @sum005;
return  LENGTH(@str); 
end//
select  myfun4(1);
myfun4(1)
302
select   @sum005  from   dual;
@sum005
62
select count(*) from t_user;
count(*)
62
select LENGTH(name)  from t_user e  where  e.id=(select count(*) from t_user);
LENGTH(name)
300
--   character-5-2-3  触发器
DROP TABLE IF EXISTS user;
CREATE TABLE user(
id bigint(20) NOT NULL AUTO_INCREMENT,
account varchar(255)character set utf16  DEFAULT null ,
name varchar(255)character set gbk  DEFAULT NULL,
address varchar(255) character set gbk DEFAULT NULL,
PRIMARY KEY(id)
)DEFAULT CHARSET=gbk;
DROP TABLE IF EXISTS user_history;
CREATE TABLE user_history(
id bigint(20) NOT NULL AUTO_INCREMENT,
user_id bigint(20) NOT NULL,
operatetype varchar(200)character set gbk NOT NULL,
operatetime datetime NOT NULL,
PRIMARY KEY(id)
)DEFAULT CHARSET=utf16;
