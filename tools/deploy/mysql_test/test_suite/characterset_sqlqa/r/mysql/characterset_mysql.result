DROP TABLE IF EXISTS table002;
CREATE TABLE  table002(
c1 INT UNSIGNED AUTO_INCREMENT,
c2 VARCHAR(100) CHARACTER SET gbk NOT NULL,
c3 VARCHAR(200) CHARACTER SET utf16 NOT NULL,
c4 CHAR(200) CHARACTER SET gbk, 
c5 CHAR(200) CHARACTER SET utf16, 
c6 varchar(300) generated always as(concat(c2,c4)),#生成列的两个字段的字符集要保持一致。
PRIMARY KEY(c1)
)CHARSET=utf16;
insert into  table002(c1,c2,c3,c4,c5)values(null,'中国','美国','英国','法国');
