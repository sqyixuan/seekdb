--   列和约束
SET FOREIGN_KEY_CHECKS=1;
drop table if exists partdepent;
CREATE TABLE partdepent(
partdepentid int,  # 部门编号
DNAME VARCHAR(14)  character set utf16, 
LOC  VARCHAR(14) character set utf16, CONSTRAINT pk_dept PRIMARY KEY(partdepentid)
)DEFAULT CHARSET=utf16;
drop table if exists prize_table;
CREATE TABLE prize_table(
id int PRIMARY KEY,
name varchar(100) character set utf16,
contry char(200) character set utf16,
company int,
birty DATE,
money float(7,2),
prize float(7,2),
nameprize varchar(100) character set utf16,
workshop int,CONSTRAINT fk_deptno FOREIGN KEY(id) REFERENCES partdepent(partdepentid));
--   character-2-1-3-1   #删除主键约束：
alter table prize_table drop primary key;
--  #添加主键约束
alter table prize_table add constraint PK_id primary key prize_table(id);
--   character-2-1-3-2   非空约束
ALTER TABLE prize_table MODIFY contry varchar(150)  not null;
--   character-2-1-3-3   唯一约束
ALTER TABLE prize_table  ADD CONSTRAINT some_name UNIQUE (NAME);
--   character-2-1-3-4  #添加外键约束，空表才可以添加 主建才鞥设置为外键 ： ob不支持
--   ALTER TABLE partdepent ADD CONSTRAINT fk_sid FOREIGN KEY(partdepentid) REFERENCES prize_table(id);
