--   建库时指定字符集
drop database  IF EXISTS  ob100x;
create database ob100x  character set utf16;
use ob100x;
drop   table  IF EXISTS   abc;
CREATE TABLE abc(id int(11) DEFAULT NULL, c varchar(100) DEFAULT null  )DEFAULT CHARSET=gbk;
insert into abc values(1,'我们');
select   *  from   abc;
id	c
1	我们
select * from abc;
id	c
1	我们
SELECT CHARSET(CHAR(100)), CHARSET(CHAR('aaa' USING gbk)),CHARSET(90);
CHARSET(CHAR(100))	CHARSET(CHAR('aaa' USING gbk))	CHARSET(90)
binary	gbk	binary
insert into abc values(2,concat('cardName:校园网',char(59 using utf16),'offlineCardType:campus'));
select * from abc;
id	c
1	我们
2	cardName:校园网;offlineCardType:campus
TRUNCATE   table  abc;
insert into abc values(2,char(59));
select * from abc;
id	c
2	;
--   建库时指定字符集
drop database  IF EXISTS  ob100x;
create database ob100x  character set utf16;
use ob100x;
select concat('cardName:校园网',char(59),'offlineCardType:campus');
concat('cardName:校园网',char(59),'offlineCardType:campus')
cardName:校园网;offlineCardType:campus
drop   table  IF EXISTS   abc;
CREATE TABLE abc(id int(11) DEFAULT NULL,c varchar(100) DEFAULT NULL)DEFAULT CHARSET=utf16;
insert into abc values(2,concat('我',char(59)));
select * from abc;
id	c
2	鄻
drop   table  IF EXISTS   abc;
character-8-8   utf16和utf8混合测试                                    
drop database  IF EXISTS  ob100x;
create database ob100x character set gbk;
use ob100x;
drop database  IF EXISTS  table001;
CREATE TABLE IF NOT EXISTS table001(
c1 INT UNSIGNED AUTO_INCREMENT,
c2 VARCHAR(100) CHARACTER SET gbk NOT NULL,
c3 VARCHAR(200) CHARACTER SET utf16 NOT NULL,
c4 CHAR(200) CHARACTER SET gbk, 
c5 CHAR(200) CHARACTER SET utf16, 
PRIMARY KEY(c1)
)CHARSET=utf16;
insert into  table001(c1,c2,c3,c4,c5)values(null,'中国','美国','英国','法国');
select  *  from   table001;
c1	c2	c3	c4	c5
1	中国	美国	英国	法国
select concat(e.c3, 'aâ')   from   table001   e;
concat(e.c3, 'aâ')
美国aâ
select concat(e.c5, 'aâ')   from   table001   e;
concat(e.c5, 'aâ')
法国aâ
select concat(e.c2,e.c3)   from   table001   e;
concat(e.c2,e.c3)
中国美国
select concat(concat(concat(e.c2,e.c3),e.c4),e.c5)   from   table001   e;
concat(concat(concat(e.c2,e.c3),e.c4),e.c5)
中国美国英国法国
select   char(e.c2 using utf16) from   table001   e;
char(e.c2 using utf16)
␀
select   char(e.c2 using gbk) from   table001   e;
char(e.c2 using gbk)
␀
select   char(e.c3 using utf16) from   table001   e;
char(e.c3 using utf16)
␀
select   char(e.c3 using gbk) from   table001   e;
char(e.c3 using gbk)
␀
select   char(e.c4 using utf16) from   table001   e;
char(e.c4 using utf16)
␀
select   char(e.c4 using gbk) from   table001   e;
char(e.c4 using gbk)
␀
select   char(e.c5 using utf16) from   table001   e;
char(e.c5 using utf16)
␀
select   char(e.c5 using gbk) from   table001   e;
char(e.c5 using gbk)
␀
