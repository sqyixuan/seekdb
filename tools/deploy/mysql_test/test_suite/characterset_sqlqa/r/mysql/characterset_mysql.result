=====================================================其他===========================================================
character-8-1   修改数据库字符集                          
drop database  IF EXISTS  enterprises;
create database enterprises  character set utf16;
use enterprises;
alter database enterprises character set gbk;
character-8-2    #修改数据表字符集
drop table if exists employees;
create table employees(c4 int,name char(10));
select  *   from  employees;
c4	name
character-8-3     修改表字段字符集
insert into employees values(1,'中国');
select  collation(name)   from  employees;
collation(name)
gbk_chinese_ci
insert into employees values(1,'中国');
character-8-4     数据库设置字符集gbk，存储过程不设置字符集
drop database  IF EXISTS  ob200x;
create database ob200x  character set gbk;
use ob200x;
drop function if exists myfun400;
create function myfun400(username varchar(20))  returns varchar(20)
begin
set @str='';
select username into @str from dual;
return  collation(@str);
end
//
drop database  IF EXISTS  ob200x;
create database ob200x  character set utf16;
use ob200x;
drop function if exists myfun400;
create function myfun400(username varchar(20))  returns varchar(20)
begin
set @str='';
select username into @str from dual;
return  collation(@str);
end//
select  myfun400('污水');
myfun400('污水')
utf8mb4_general_ci
select   collation(@str) from   dual;
collation(@str)
utf8mb4_general_ci
