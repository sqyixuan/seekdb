DROP TABLE IF exists tableclass;
CREATE TABLE tableclass(uid int auto_increment,a01_int_unsigned int unsigned,a02_int_signed int signed,
b01_tinyint_unsigned tinyint unsigned,b02_tinyint_signed tinyint signed,
c01_decimal_30_5_unsigned decimal(30,5) unsigned,c02_decimal_30_signed decimal(30,5) signed,
d01_float     float(6,3), d02_double   double(6,3),  #character  set = utf16,
e01_smallint_unsigned smallint unsigned,e02_smallint   smallint,
f01_mediumint_unsigned mediumint unsigned,f02_mediumint mediumint, #character set gbk,
g01_bigint_unsigned bigint unsigned,g02_bigint bigint,
h01_integer_unsigned integer unsigned,h02_integer_signed integer signed,
i01_char_30_gbk char(30)  character set gbk,i02_char_20_utf16 varchar(20)  character set utf16,
j001_date date,j002_timestamp timestamp NULL DEFAULT NULL,j003_datetime datetime,m001  time,m002  year,
k001  tinytext   CHARACTER SET utf16,k002  text    CHARACTER SET  gbk,k003  mediumtext   CHARACTER set utf16,k008  longtext   CHARACTER SET  utf16,
n001 bit(8),n002 bit(8),
u001 TinyBlob,u002 Blob,u003 MediumBlob,u004 longblob,primary key (uid));
