--   索引
drop TABLE if exists my_test;
create table my_test(
id int(11) not null unique auto_increment,
name varchar(100)  CHARACTER SET  gbk,
age int(11) not null default 0,
address varchar(100) CHARACTER SET  gbk
)charset=gbk;
--  character-2-2-4-1    #创建普通索引
create index index_001 on  my_test(name);
--     修改表结构的方式添加索引  
alter table my_test add index index_004(age);
--  character-2-2-4-2   #降序索引ob不支持
create index index_002 on my_test(age DESC); 
create index index_002 on my_test(age);
--  character-2-2-4-3   #修改索引
create index index_006 on my_test(address);
DROP INDEX index_006 ON my_test;
ALTER TABLE my_test ADD index index_006(address);
DROP INDEX index_006 ON my_test;
--  character-2-2-4-4  删除索引
drop index index_001 on my_test;
alter table my_test drop index index_002;
--  character-2-2-4-5    建立复合索引 #建立表列age和name的联合索引；按照age升序后再按照name降序排序
create index index_003 on my_test(age,name);
--  character-2-2-4-6    创建唯一索引
CREATE UNIQUE INDEX index_005 ON  my_test(address);
ALTER TABLE my_test ADD UNIQUE(address);
drop TABLE if exists my_test;
--  分区表：
-- character-2-2-5-1   RANGE分区
drop TABLE if exists employees001;
CREATE TABLE employees001(  
id INT NOT NULL,  
fname VARCHAR(30) CHARACTER SET  gbk,  
lname VARCHAR(30) CHARACTER SET  gbk,  
hired DATE NOT NULL DEFAULT '1970-01-01',  
separated DATE NOT NULL DEFAULT '9999-12-31',  
job_code INT NOT NULL,  
store_id INT NOT NULL  
)engine=innodb charset=gbk
PARTITION BY RANGE (store_id) (  
PARTITION p0 VALUES LESS THAN (6),  
PARTITION p1 VALUES LESS THAN (11),  
PARTITION p2 VALUES LESS THAN (16),  
PARTITION p3 VALUES LESS THAN MAXVALUE  
);
insert   into   employees001(id,fname,lname,job_code,store_id) values(1,'中華人民共和國','中華人民共和國',10,20);
select   *  from  employees001;
id	fname	lname	hired	separated	job_code	store_id
1	中華人民共和國	中華人民共和國	1970-01-01	9999-12-31	10	20
-- character-2-2-5-2     LIST分区
drop TABLE if exists employees002;
CREATE TABLE employees002 (  
id INT NOT NULL,  
fname VARCHAR(30) CHARACTER SET  gbk,  
lname VARCHAR(30) CHARACTER SET  gbk,  
hired DATE NOT NULL DEFAULT '1970-01-01',  
separated DATE NOT NULL DEFAULT '9999-12-31',  
job_code INT,  
store_id INT
)charset=gbk
PARTITION BY LIST(store_id) (
PARTITION pNorth VALUES IN (3,5,6,9,17),
PARTITION pEast VALUES IN (1,2,10,11,19,20),
PARTITION pWest VALUES IN (4,12,13,14,18),
PARTITION pCentral VALUES IN (7,8,15,16)
);
insert   into   employees002(id,fname,lname,job_code,store_id) values(1,'中華人民共和國','中華人民共和國',10,20);
select   *  from  employees002;
id	fname	lname	hired	separated	job_code	store_id
1	中華人民共和國	中華人民共和國	1970-01-01	9999-12-31	10	20
-- character-2-2-5-3    普通HASH分区
drop TABLE if exists employees003;
CREATE TABLE employees003(  
id INT NOT NULL,  
fname VARCHAR(30) CHARACTER SET  gbk,   
lname VARCHAR(30) CHARACTER SET  gbk,  
hired DATE NOT NULL DEFAULT '1970-01-01',  
separated DATE NOT NULL DEFAULT '9999-12-31',  
job_code INT,  
store_id INT  
)charset=gbk  
PARTITION BY HASH(store_id)  
PARTITIONS 4;
insert   into   employees003(id,fname,lname,job_code,store_id) values(1,'中華人民共和國','中華人民共和國',10,20);
select   *  from  employees003;
id	fname	lname	hired	separated	job_code	store_id
1	中華人民共和國	中華人民共和國	1970-01-01	9999-12-31	10	20
-- character-2-2-5-4   KSY分区   ob不支持这个分区
drop TABLE if exists employees004;
CREATE TABLE employees004(col1 INT NOT NULL,col2 CHAR(5) CHARACTER SET  gbk,  col3 DATE)charset=gbk PARTITION BY LINEAR KEY (col1)  PARTITIONS 3;
-- character-2-2-5-5    线性哈希功能   ob不支持
drop TABLE if exists employees005;
CREATE TABLE employees005(id INT NOT NULL,fname VARCHAR(30) CHARACTER SET  gbk,lname VARCHAR(30) CHARACTER SET  gbk,hired DATE NOT NULL DEFAULT '1970-01-01',separated DATE NOT NULL DEFAULT '9999-12-31',  job_code INT,  store_id INT  )charset=gbk   PARTITION BY LINEAR HASH(YEAR(hired)) PARTITIONS 4; 
-- 子分区：
-- character-2-2-5-6   不定义每个子分区
drop TABLE if exists employees006;
CREATE TABLE employees006(id INT, purchased DATE)charset=gbk 
PARTITION BY RANGE( YEAR(purchased) )
SUBPARTITION BY HASH( TO_DAYS(purchased) )
SUBPARTITIONS 2 (
PARTITION p0 VALUES LESS THAN (1990),
PARTITION p1 VALUES LESS THAN (2000),
PARTITION p2 VALUES LESS THAN MAXVALUE
);
insert   into   employees006(id,purchased) values(1,'1970-01-01');
select   *  from  employees006;
id	purchased
1	1970-01-01
-- character-2-2-5-6   定义每个子分区   ob不支持
drop TABLE if exists employees007;
CREATE TABLE employees007(id INT, purchased DATE)charset=gbk PARTITION BY RANGE( YEAR(purchased) )SUBPARTITION BY HASH( TO_DAYS(purchased) ) (PARTITION p0 VALUES LESS THAN (1990) (SUBPARTITION s0,SUBPARTITION s1),PARTITION p1 VALUES LESS THAN (2000) (SUBPARTITION s2,SUBPARTITION s3),PARTITION p2 VALUES LESS THAN MAXVALUE (SUBPARTITION s4,SUBPARTITION s5));   
-- character-2-2-5-7   普通表转分区表
drop TABLE if exists employees001;
drop TABLE if exists employees002;
drop TABLE if exists employees003;
drop TABLE if exists employees004;
drop TABLE if exists employees005;
drop TABLE if exists employees006;
drop TABLE if exists employees007;
-- character-2-2-6    虚拟列  ob不支持 json
drop TABLE if exists user001;
drop TABLE if exists t;
create table t( x varchar(20) CHARACTER SET  gbk, y varchar(20)CHARACTER SET  gbk, z varchar(20) CHARACTER SET  gbk generated always as(concat(x,y)))charset=gbk;
insert into t(x,y) values('中华人民共和国','中華人民共和國');
select   *  from   t;
x	y	z
中华人民共和国	中華人民共和國	中华人民共和国中華人民共和國
drop TABLE if exists t;
-- character-2-2-7   别名
SELECT 100%89 AS 结果;
结果
11
drop TABLE if exists user002;
create table user002(age int(4), name varchar(20));
insert into user002 values(21, 'Jack'), (23, 'Rose'), (35, 'Ann'), (56, 'Mike');
select * from user002 s where age > 30;
age	name
35	Ann
56	Mike
select age as student_age, name as student_name from user002;
student_age	student_name
21	Jack
23	Rose
35	Ann
56	Mike
drop TABLE if exists user002;
-- character-2-2-8   临时表
DROP TABLE IF EXISTS limit_dept;
create TABLE limit_dept(
DEPTNO INT not null auto_increment primary key, 
DNAME VARCHAR(30) CHARACTER SET  gbk,
LOC VARCHAR(40) CHARACTER SET  gbk  
)charset=gbk;
DROP PROCEDURE IF EXISTS limit_pro//
CREATE PROCEDURE limit_pro()
BEGIN
DECLARE v_i int unsigned DEFAULT 0;
repeat
SET v_i = v_i+1;
INSERT INTO limit_dept VALUES (null,concat(cast(v_i as char),'ACCOUNTING'),'NEW YORK');    
UNTIL v_i >= 40 END REPEAT;
END//
CALL limit_pro();
DROP TABLE IF EXISTS tmp_table001;
-- #直接将查询结果导入临时表  ob不支持这种方式建立临时表
CREATE TEMPORARY TABLE tmp_table001 SELECT * FROM limit_dept;
--   #查询临时表
select * from tmp_table001;
--   #删除临时表和基表
drop table tmp_table001;
--====================================================================普通函数测试===============================================================================================================
普通函数测试
drop database  IF EXISTS  variablesandconstants;
create database variablesandconstants character set utf16;
use variablesandconstants;
DROP TABLE IF EXISTS table001;
CREATE TABLE  table001(
c1 INT UNSIGNED AUTO_INCREMENT,
c2 VARCHAR(100) CHARACTER SET gbk NOT NULL,
c3 VARCHAR(200) CHARACTER SET utf16 NOT NULL,
c4 CHAR(200) CHARACTER SET gbk, 
c5 CHAR(200) CHARACTER SET utf16, 
c6 varchar(300) generated always as(concat(c2,c4)),#生成列的两个字段的字符集要保持一致。
PRIMARY KEY(c1)
)CHARSET=gbk;
insert into  table001(c1,c2,c3,c4,c5)values(null,'中国','美国','英国','法国');
