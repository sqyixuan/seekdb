character-8-9  回滚
drop database  IF EXISTS  ob100x;
create database ob100x character set gbk;
use ob100x;
drop table  IF EXISTS  runoob_transaction_test;
CREATE TABLE runoob_transaction_test( id int(5),name varchar(20) CHARACTER SET gbk)CHARSET=utf16;
select * from runoob_transaction_test;
id	name
begin;
insert into runoob_transaction_test value(1,'中国');
insert into runoob_transaction_test value(2,'美国');
commit;
select * from runoob_transaction_test;
id	name
1	中国
2	美国
begin;
insert into runoob_transaction_test values(3,'日本');
rollback;
select * from runoob_transaction_test;
id	name
1	中国
2	美国
alter database ob100x character set utf16;
select * from runoob_transaction_test;
id	name
1	中国
2	美国
