2<3
1
select 2<=3;
2<=3
1
select 2>3;
2>3
0
select 2>=3;
2>=3
0
select 5 between 1 and 10;
5 between 1 and 10
1
select 5 in (1,2,3,4,5);
5 in (1,2,3,4,5)
1
select 5 not in (1,2,3,4,5);
5 not in (1,2,3,4,5)
0
select null is NULL;
null is NULL
1
select 'a' is NULL;
'a' is NULL
0
select null IS NOT NULL;
null IS NOT NULL
0
select 'a' IS NOT NULL;
'a' IS NOT NULL
1
