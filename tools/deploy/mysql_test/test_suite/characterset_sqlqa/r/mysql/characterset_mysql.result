--   character-5-2-1-3     :包含 in 参数和 out 参数的存储过程,只能将一行的查询到的用户名赋值给username 
drop procedure if exists myproc3;
create procedure myproc3(in userId int, out username varchar(20))
begin
set username= userId;	
#SELECT d.dname into  username FROM dept d  where  d.deptno in (SELECT a.deptno FROM (SELECT e.deptno FROM emp e,salgrade s  WHERE (e.sal BETWEEN s.loosal AND s.hisal)GROUP BY e.deptno ORDER BY avg(s.grade)) a) LIMIT userId;
SELECT d.dname  FROM dept d where  d.DEPTNO<> username;		
#select  username;
end//
--  调用时，传入查询的userid 和 全局变量 @username
call myproc3(10,@username);
dname
RESEARCH
SALES
OPERATIONS
--   character-5-2-1-4   D:包含 inout 参数的存储过程
drop procedure if exists myproc4;
create procedure myproc4(inout a int)
begin
SELECT d.* FROM dept d 
WHERE d. deptno NOT IN(SELECT deptno FROM emp WHERE sal < a GROUP BY deptno);
end//
--  用户变量 （全局的变量）作用域： 用户变量: 在当前连接（即当前会话）中都有效
set @num =1000;
call  myproc4(@num);
