#owner: xuqijia.xqj
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Base test of roaringbitmap type.
--echo # ----------------------------------------------------------------------

--disable_warnings
drop table if exists t1;
drop table if exists tt1, tt2, tt3, tt4, tt5;
--enable_warnings

# empty
SET @p1 = x'0100';
# single: 1
SET @p2 = x'010101000000';
# single: 2
SET @p3 = x'010102000000';
# set: 1,2,3
SET @p4 = x'010303010000000200000003000000';
# set: 2,3,4
SET @p5 = x'010303020000000300000004000000';
# bitmap: 0~32
SET @p6 = x'01060100000000000000000000003a30000001000000000020001000000000000100020003000400050006000700080009000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f002000';
# bitmap: 10~42
SET @p7 = x'01060100000000000000000000003a3000000100000000002000100000000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f0020002100220023002400250026002700280029002a00';

create table t1 (id int, rb roaringbitmap);
insert into t1 values (0, NULL), (1, @p1), (2, @p2), (3, @p3), (4, @p4), (5, @p5), (6, @p6), (7, @p7); 
select id, hex(rb) from t1;
--error 5083
select id, hex(rb) from t1 where rb = NULL;
--error 5083
select id, hex(rb) from t1 where rb != NULL;
--error 5083
select id, hex(rb) from t1 where rb = rb_build_empty();
--error 5083
select id, hex(rb) from t1 where rb != rb_build_empty();
--error 5083
select id, hex(rb) from t1 where rb = x'0100';
--error 5083
select id, hex(rb) from t1 where rb != x'0100';
--error 5083
select id, hex(rb) from t1 where rb = rb_build_varbinary(x'0100');
--error 1111
select id, hex(rb) from t1 where rb = rb_build_agg(1);
--error 5083
select id, hex(rb) from t1 where rb = rb_from_string('1');
--error 5083
select id, hex(rb) from t1 where rb > NULL;
--error 5083
select id, hex(rb) from t1 where rb < x'0100';
--error 5083
select id, hex(rb) from t1 where rb <= rb_build_empty();

--error 1210
select sum(rb) from t1;
--error 1210
select min(rb) from t1;
--error 1210
select max(rb) from t1;
--error 1210
select avg(rb) from t1;

# bugfix: 57369525
create table tt1(id int,a varbinary(1000),r roaringbitmap);
insert into tt1 values(1,rb_from_string('1'),rb_from_string('1'));
insert into tt1 values(2,rb_build_empty(),rb_build_empty());
insert into tt1 values(3,rb_from_string('1,3'),rb_from_string('1,3'));
select id, hex(a), hex(r) from tt1 where rb_build_empty() like rb_build_empty() ;
select id, hex(a), hex(r) from tt1 where  rb_from_string('1,2,3,4') like rb_from_string('1,2,3,4');
select id, hex(a), hex(r) from tt1 where  rb_build_varbinary(0x01030401000000020000000300000004000000) like rb_build_varbinary(0x01030401000000020000000300000004000000);

# bugfix: 57361164
select hex(cast(rb_build_empty() as binary));
select hex(cast(rb_from_string('1,2,3,4') as binary));
select hex(cast (rb_build_varbinary(0x01030401000000020000000300000004000000) as binary));

# bugfix: 57362779
--error 5083
select cast(rb_build_empty() as SIGNED);
--error 5083
select cast(rb_from_string('1,2,3,4') as date);
--error 5083
select cast (rb_build_varbinary(0x01030401000000020000000300000004000000) as DECIMAL);
--error 5083
select cast(rb_build_empty() as MULTIPOINT);

# bugfix: 57512498
create table tt2 (id int, rb roaringbitmap);
insert into tt2 values (1, @p1), (2, @p2), (3, @p3), (4, @p4), (5, @p5), (6, @p6), (7, @p7);
select /*+ ENABLE_PARALLEL_DML parallel(1) */  id, hex(rb) from tt2;
select /*+ ENABLE_PARALLEL_DML parallel(2) */  id, hex(rb) from tt2;

# bugfix: 57374952
--error 5083
select * from tt2 order by rb;
--error 5083
select rb from tt2 order by rb;
--error 5083
select * from tt2 group by rb;
--error 5083
select rb from tt2 group by rb;

# bugfix: 57645068
create table tt3 (rb roaringbitmap);
insert into tt3 values (x'0100');
--error 4070
update tt3 set rb=x'1111';
--error 1235
update tt3 set rb='josn';
--error 1235
update tt3 set rb=4;

# bugfix: 57728532
select hex(cast( x'0100' as roaringbitmap));
select hex(cast( x'010101000000' as roaringbitmap));
select hex(cast( x'01020100000001000000' as roaringbitmap));
select hex(cast( x'0103020100000002000000' as roaringbitmap));
select hex(cast( x'01040201000000000000000200000000000000' as roaringbitmap));
select hex(cast( x'01053a30000001000000000020001000000000000100020003000400050006000700080009000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f002000' as roaringbitmap));
select hex(cast( x'01060200000000000000000000003a30000001000000ffff000010000000ffff010000003a3000000100000000001f001000000000000100020003000400050006000700080009000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f00' as roaringbitmap));

# bugfix: 57667611
SELECT hex( CASE WHEN 1=1 THEN rb_build_agg(1)  ELSE rb_build_empty()  END );
SELECT hex( CASE WHEN 1>1 THEN rb_build_agg(1)  ELSE rb_build_empty()  END );
--error 5083
SELECT rb_to_string( CASE rb_build_agg(1) WHEN rb_build_agg(2) THEN rb_build_agg(2) WHEN rb_build_agg(1) THEN rb_build_agg(1) END );
--error 5083
SELECT rb_to_string( CASE rb_build_agg(1) WHEN rb_build_agg(2) THEN rb_build_agg(2) WHEN 0x010101000000 THEN rb_build_agg(1) END );
--error 1210
SELECT rb_to_string( CASE rb_build_agg(1) WHEN rb_build_agg(2) THEN rb_build_agg(2) WHEN 0x010101000000 THEN 1 END );
--error 5083
SELECT CASE rb_build_agg(1) WHEN rb_build_agg(2) THEN 1 WHEN rb_build_agg(1) THEN 2 END;
SELECT hex( CASE 1 WHEN 1 THEN rb_build_agg(1) WHEN 2 THEN rb_build_agg(2) END );
SELECT hex( CASE 1 WHEN 1 THEN 0x010101000000 WHEN 2 THEN rb_build_agg(2) END );
--error 5083
SELECT CASE rb_build_agg(1) WHEN rb_build_agg(2) THEN 1 WHEN rb_build_agg(1) THEN 2 END;

# bugfix: 57664425
--error 5083
select rb from tt2 where id = 1 union select rb from tt2 where id = 2;
--error 5083
select rb from t1 union select rb from tt2;
--error 5083
select rb from tt2 union select rb_from_string('1');
--error 5083
select rb_build_empty() union select rb_from_string('1');

# bugfix: 57366663
select distinct rb_build_empty();
create table tt4 (rb roaringbitmap);
--error 5083
select distinct rb from tt4;
insert into tt4 values (rb_from_string('1,2'));
--error 5083
select distinct rb from tt4;

# bugfix: 57758076
select hex(IFNULL(null,rb_from_string('3')));
select hex(IFNULL(rb_from_string('2'), rb_from_string('3')));
--error 5083
select hex(IFNULL(x'0100', rb_from_string('3')));
--error 1210
select hex(NULLIF(rb_build_agg(1),rb_from_string('1')));
--error 1210
select hex(NULLIF(rb_from_string('1'),rb_from_string('3')));
select hex(IF(false,rb_from_string('2'),rb_from_string('3')));
select hex(IF(true,rb_from_string('2'),rb_from_string('3')));

# bugfix: 57972605
create table tt5 (id int primary key, rb roaringbitmap);
insert into tt5 values (1, rb_from_string('1'));
replace into tt5 values (1, rb_from_string('2'));
select id, hex(rb) from tt5;

# bugfix: 2024072500103925846
--error 5083
select  rb_from_string('1,2') BETWEEN rb_from_string('1') and rb_from_string('1,2,3') from tt1;
--error 5083
select * from tt1 where r BETWEEN r and r;
--error 5083
select * from tt1 where r BETWEEN r and 'a';

# bugfix: 2025043000108670471
select nullif(cast(null as ROARINGBITMAP), null);

# cleanup
--disable_warnings
drop table if exists t1;
drop table if exists tt1, tt2, tt3, tt4, tt5;
--enable_warnings
