drop table if exists tt2;
create table tt2(id int primary key ,a0 varchar(1000),a varbinary(1000),r roaringbitmap,r1 roaringbitmap)PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
); 

