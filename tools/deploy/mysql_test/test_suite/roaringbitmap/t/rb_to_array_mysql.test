#owner: tengzhen.lk
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Base test of roaringbitmap rb_to_array.
--echo # ----------------------------------------------------------------------


--echo #
--echo # Setup test.
--echo #
--disable_warnings
drop table if exists t1, t2, t3, t4, t5;
drop table if exists tt1;
--enable_warnings

select rb_to_array(null);
--error 3064
select rb_to_array('');
--error 4070
select rb_to_array(x'');
--error 3064
select rb_to_array('aa');
--error 3064
select rb_to_array(2);

--echo test: rb_to_array from binary
# 00->EMPTY
select rb_to_array(x'0100');
--error 4070
select rb_to_array(x'0200');
# 01->SINGLE_32
select rb_to_array(x'010101000000');
select rb_to_array(x'0101FFFFFFFF');
--error 4070
select rb_to_array(x'01010100000000000000');
# 02->SINGLE_64
select rb_to_array(x'01020100000001000000');
select rb_to_array(x'0102FFFFFFFFFFFFFFFF');
--error 4070
select rb_to_array(x'010201000000');
# 03->SET_32
--error 4070
select rb_to_array(x'0103');
--error 4070
select rb_to_array(x'010300');
--error 4070
select rb_to_array(x'010301');
--error 4070
select rb_to_array(x'01030101000000');
--error 4070
select rb_to_array(x'010301FFFFFFFF');
select rb_to_array(x'0103020100000002000000');
--error 4070
select rb_to_array(x'0103010100000002000000');
# 04->SET_64
--error 4070
select rb_to_array(x'0104');
--error 4070
select rb_to_array(x'010400');
--error 4070
select rb_to_array(x'010401');
--error 4070
select rb_to_array(x'01040101000000');
--error 4070
select rb_to_array(x'0104010100000000000000');
--error 4070
select rb_to_array(x'0104010100000001000000');
--error 4070
select rb_to_array(x'010401FFFFFFFFFFFFFFFF');
select rb_to_array(x'01040201000000000000000200000000000000');
select rb_to_array(x'01040201000000010000000100000002000000');
# 05->BITMAP_32
--error 4070
select rb_to_array(x'0105');
select rb_to_array(x'01053a30000000000000');
select rb_to_array(x'01053a3000000100000000000000100000000100');
select rb_to_array(x'01053a30000001000000000001001000000001000200');
select rb_to_array(x'01053a3000000100000000001f001000000000000100020003000400050006000700080009000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f00');
select rb_to_array(x'01053a3000000200000000000000ffff0000180000001a0000000000ffff');
# 06->BITMAP_64
--error 4070
select rb_to_array(x'0106');
select rb_to_array(x'01060000000000000000');
select rb_to_array(x'01060100000000000000000000003a3000000100000000000000100000000100');
select rb_to_array(x'01060100000000000000010000003a3000000100000000000000100000000000');
select rb_to_array(x'01060100000000000000000000003a30000001000000000001001000000001000200');
select rb_to_array(x'01060200000000000000000000003a3000000100000000000000100000000100010000003a3000000100000000000000100000000000');
select rb_to_array(x'01060100000000000000000000003a3000000100000000001f001000000000000100020003000400050006000700080009000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f00');
select rb_to_array(x'01060200000000000000000000003a30000001000000ffff000010000000ffff010000003a3000000100000000001e001000000000000100020003000400050006000700080009000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e00');
select rb_to_array(x'');
select rb_to_array(x'01060200000000000000000000003a3000000100000000000000100000000000ffffffff3a30000001000000ffff000010000000ffff');

--echo test: rb_from_string value range
select rb_to_array(rb_from_string('0'));
select rb_to_array(rb_from_string('1'));
select rb_to_array(rb_from_string('-1'));
select rb_to_array(rb_from_string('18446744073709551615'));
--error 4019
select rb_to_array(rb_from_string('18446744073709551616'));
--error 4019
select rb_to_array(rb_from_string('-2147483649'));
select rb_to_array(rb_from_string('-2147483648'));
select rb_to_array(rb_from_string('9223372036854775806'));
select rb_to_array(rb_from_string('9223372036854775807'));
select rb_to_array(rb_from_string('9223372036854775808'));
--error 4019
select rb_to_array(rb_from_string('-18446744073709551615'));

--echo test: rb_from_string string format

select rb_from_string(null);
--error 3064
select rb_from_string(x'');
--error 3064
select rb_from_string(2);

select rb_to_array(rb_from_string(''));
select rb_to_array(rb_from_string(' '));
--error 4070
select rb_to_array(rb_from_string(' , '));
--error 4070
select rb_to_array(rb_from_string(' , , '));
--error 4070
select rb_to_array(rb_from_string(',1'));
select rb_to_array(rb_from_string(' 0 '));
--error 4070
select rb_to_array(rb_from_string(' 1, '));
select rb_to_array(rb_from_string(' 1 , 2, 4'));
--error 4070
select rb_to_array(rb_from_string(' 1 , 2, , 4'));
--error 4070
select rb_to_array(rb_from_string(' - 1 '));
--error 4070
select rb_to_array(rb_from_string(' --1 '));
select rb_to_array(rb_from_string(' +1 '));
--error 4070
select rb_to_array(rb_from_string(' ++1 '));
select rb_to_array(rb_from_string('12,-1'));
--error 4070
select rb_to_array(rb_from_string('  a '));
--error 4070
select rb_to_array(rb_from_string('11,a'));
--error 4070
select rb_to_array(rb_from_string('1, 2, 3 a'));
--error 4070
select rb_to_array(rb_from_string('{1,2,3}'));

# invalid number of input parameters
--error 1582
select rb_to_array(rb_from_string('1,2,3,4'), 2, 3);
--error 1582
select rb_to_array(rb_from_string('1,2,3,4'), 3);
--error 1582
select rb_to_array(rb_from_string('1,2,3,4'), 2, 3, 4);

# invalid type
--error 3064
select rb_to_array([1,2,3]);
--error 3064
select rb_to_array(map(1,2,3,4));
--error 3064
select rb_to_array("hello world");
--error 3064
select rb_to_array(1);
--error 3064
select rb_to_array(1.2);
--error 3064
select rb_to_array(true);
--error 3064
select rb_to_array(1.2);
--error 3064
select rb_to_array("1");
--error 3064
select rb_to_array([1,2,3]);
--error 3064
select rb_to_array(map(1,2));

# array 表达式嵌套
select array_append(rb_to_array(rb_from_string('1,2,3,4')), 1);
select array_avg(rb_to_array(rb_from_string('1,2,3,4')));
select cardinality(rb_to_array(rb_from_string('1,2,3,4')));
select array_compact(rb_to_array(rb_from_string('1,2,3,4')));
select array_contains(rb_to_array(rb_from_string('1,2,3,4')), 1);
select array_difference(rb_to_array(rb_from_string('1,2,3,4')));
select array_max(rb_to_array(rb_from_string('1,2,3,4')));
select array_remove(rb_to_array(rb_from_string('1,2,3,4')), 1);
select array_slice(rb_to_array(rb_from_string('1,2,3,4')), 1, 2);
select array_to_string(rb_to_array(rb_from_string('1,2,3,4')), ',');
select element_at(rb_to_array(rb_from_string('1,2,3,4')), 1);
select array_distinct(rb_to_array(rb_from_string('1,2,3,4')));

--disable_warnings
drop table if exists t1, dml_test;
--enable_warnings

# empty
SET @p1 = x'0100';
# single: 1
SET @p2 = x'010101000000';
# single: 2
SET @p3 = x'010102000000';
# set: 1,2,3
SET @p4 = x'010303010000000200000003000000';
# set: 2,3,4
SET @p5 = x'010303020000000300000004000000';
# bitmap: 0~32
SET @p6 = x'01060100000000000000000000003a30000001000000000020001000000000000100020003000400050006000700080009000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f002000';
# bitmap: 10~42
SET @p7 = x'01060100000000000000000000003a3000000100000000002000100000000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f0020002100220023002400250026002700280029002a00';

CREATE TABLE t1 (k int, rb roaringbitmap);
INSERT INTO t1 VALUES
  (1, NULL),
  (1, @p1),
  (1, @p2),
  (2, @p1),
  (2, @p2),
  (3, @p2),
  (3, @p1),
  (4, @p1),
  (4, @p4),
  (5, @p4),
  (5, @p1),
  (6, @p1),
  (6, @p6),
  (7, @p6),
  (7, @p1),
  (8, @p2),
  (8, @p3),
  (9, @p2),
  (9, @p4),
  (10, @p4),
  (10, @p2),
  (11, @p2),
  (11, @p6),
  (12, @p6),
  (12, @p2),
  (13, @p4),
  (13, @p5),
  (14, @p4),
  (14, @p6),
  (15, @p6),
  (15, @p4),
  (16, @p6),
  (16, @p7);

# vec 2.0
select rb_to_string(rb) from t1;
select rb_to_array(rb) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ rb_to_array(rb) from t1;

# DML
CREATE TABLE dml_test ( 
pk bigint not null AUTO_INCREMENT,
i_1   Array(BigInt)
);

insert into dml_test(i_1)
select rb_to_array(rb) 
from t1;
select pk, i_1 from dml_test;

update dml_test
set i_1 = rb_to_array(rb_from_string('1,2,3,4'))
where i_1 =  rb_to_array(rb_from_string('5,6,7,8'));
select * from dml_test;

delete from dml_test
where i_1 = rb_to_array(rb_from_string('5,6,7,8'));
select * from dml_test;

# bug fix 2025040200107963098
drop table if exists tt1;
create table tt1(id int ,a0 varchar(1000),a varbinary(1000),r roaringbitmap,r1 roaringbitmap);

