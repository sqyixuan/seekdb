#owner: xuqijia.xqj
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Base test of rb_iterate.
--echo # ----------------------------------------------------------------------


--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

# empty
SET @p1 = x'0100';
# single: 1
SET @p2 = x'010101000000';
# single: 2
SET @p3 = x'010102000000';
# set: 1,2,3
SET @p4 = x'010303010000000200000003000000';
# set: 2,3,4
SET @p5 = x'010303020000000300000004000000';
# bitmap: 0~32
SET @p6 = x'01060100000000000000000000003a30000001000000000020001000000000000100020003000400050006000700080009000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f002000';
# bitmap: 10~42
SET @p7 = x'01060100000000000000000000003a3000000100000000002000100000000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f0020002100220023002400250026002700280029002a00';

create table t1 (id int, rb roaringbitmap);
create table t2 (id int, rb1 roaringbitmap, rb2 roaringbitmap);
insert into t1 values (1, @p1),(2, @p2), (3, @p3), (4, @p4), (5, @p5), (6, @p6), (7, @p7);
insert into t2 values (1, @p2, @p3), (2, @p4, @p5), (3, @p6, @p7);

# after from
select id, rb_iterate from t1,rb_iterate(rb);
explain select id, rb_iterate from t1,rb_iterate(rb);
select * from rb_iterate(rb_from_string('0,18446744073709551615'));
explain select * from rb_iterate(rb_from_string('0,18446744073709551615'));
select t_def from t1,rb_iterate(rb) as t_def where id = 4;
select t_def from t1,rb_iterate(rb) t_def where id = 4;
select id, rb_iterate, t_def from t1,rb_iterate(rb),rb_iterate(rb_from_string('1,2,3')) as t_def;
explain select id, rb_iterate, t_def from t1,rb_iterate(rb),rb_iterate(rb_from_string('1,2,3')) as t_def;
select id, rb_iterate, t_def from t1,rb_iterate(rb),rb_iterate(rb) as t_def where id = 5;
select rb_iterate from rb_iterate(rb_from_string('1,2,3'));
select rb_iterate from rb_iterate(@p6);
select id, t_def from t1, rb_iterate(rb_from_string('1,2,3')) t_def;
explain select id, t_def from t1, rb_iterate(rb_from_string('1,2,3')) t_def;
select id, t_rb1, t_rb2 from t2,rb_iterate(rb1) as t_rb1, rb_iterate(rb2) as t_rb2;
select t_def from rb_iterate(rb_from_string('1,2,3')) as t_def;
select t_def.* from rb_iterate(rb_from_string('1,2,3')) as t_def;
select t_def.* from rb_iterate(rb_from_string('1,2,3')) as t_def(col);
--error 1054
select t_def from rb_iterate(rb_from_string('1,2,3')) as t_def(col);
select col from rb_iterate(rb_from_string('1,2,3')) as t_def(col);
--error 1064
select col from rb_iterate(rb_from_string('1,2,3')) as t_def(col, col2);

# after select
select rb_iterate(rb_from_string('1,2,3'));
explain select rb_iterate(rb_from_string('1,2,3'));
select rb_iterate(rb_from_string('0,18446744073709551615'));
select rb_iterate(@p7) t_def;
select rb_iterate(@p6) as t_def1, rb_iterate(@p5) as t_def2;
explain select rb_iterate(@p6) as t_def1, rb_iterate(@p5) as t_def2;
select rb_iterate(rb) from t1;
explain select rb_iterate(rb) from t1;
select id, rb_iterate(rb1), rb_iterate(rb2) from t2;
explain select id, rb_iterate(rb1), rb_iterate(rb2) from t2;
select id, rb_iterate(rb1), rb_iterate(rb2), rb_iterate(rb_from_string('11,22,33')) from t2;
explain select id, rb_iterate(rb1), rb_iterate(rb2), rb_iterate(rb_from_string('11,22,33')) from t2;
select rb_iterate(rb_from_string('1,2,3')), rb_iterate(rb_from_string('11,22,33'));
select rb_iterate(rb_from_string('1,2,3')), rb_iterate(rb_from_string('11,22'));
explain select rb_iterate(rb_from_string('1,2,3')), rb_iterate(rb_from_string('11,22'));
select rb_iterate(rb_from_string('1,2')), rb_iterate(rb) from t1 where id = 5;
select rb_iterate(rb), rb_iterate(rb_from_string('1,2')) from t1 where id = 5;
select rb_iterate(rb), rb_iterate(rb) from t1 where id = 5;

# both in from and select
select id, t_def, rb_iterate(rb_from_string('1,2,3')) from t1, rb_iterate(rb) t_def where id = 5;
explain select id, t_def, rb_iterate(rb_from_string('1,2,3')) from t1, rb_iterate(rb) t_def where id = 5;
select id, rb_iterate, rb_iterate(rb_from_string('1,2,3')) from t1, rb_iterate(rb) where id = 5;
select id, t_def, rb_iterate(rb) from t1, rb_iterate(rb_from_string('1,2,3')) t_def where id = 5;
explain select id, t_def, rb_iterate(rb) from t1, rb_iterate(rb_from_string('1,2,3')) t_def where id = 5;
select t_def, rb_iterate(rb_from_string('1,2,3')) from rb_iterate(rb_from_string('11,22')) t_def;
select t_def, rb_iterate(rb_from_string('1,2,3')), rb_iterate(rb_from_string('2,3,4')) from rb_iterate(rb_from_string('11,22')) t_def;
select id, rb_iterate, rb_iterate(rb1), rb_iterate(rb2) from t2, rb_iterate(rb_from_string('1,2,3'));

# NULL / other type
select rb_iterate(null);
--error 3064
select rb_iterate('a');
select rb_iterate(null), rb_iterate(null);
select rb_iterate(rb_from_string('1,2,3')), rb_iterate(NULL);
select rb_iterate(null), rb_iterate(rb_from_string('1,2,3'));
select rb_iterate(null), rb_iterate(rb) from t1 where id = 5;
select rb_iterate(rb), rb_iterate(null) from t1 where id = 5;

# agg function
--error 1111
select * from t1, rb_iterate(rb_or_agg(rb));
--error 1111
select * from t1, rb_iterate(rb_build_agg(id));
--error 1111
select * from rb_iterate(rb_or_agg(@p6));
--error 1111
select * from rb_iterate(rb_build_agg(1));
--error 1111
select rb_iterate(rb_or_agg(@p6));
--error 1111
select rb_iterate(rb_build_agg(1));
--error 1111
select rb_iterate(rb_or_agg(rb)) from t1;
--error 1111
select rb_iterate(rb_build_agg(id)) from t1;
# diff with PG
select sum(1), rb_iterate(@p6);

# other
--error 1235
select sum(rb_iterate(rb_from_string('1,2,3')));
create table t3(id int, val int);
insert into t3 values (1, 11), (2, 22), (3, 33);
select * from t3 where id in (select rb_iterate(rb) from t1 where id = 5);
select * from t3 where id in (select rb_iterate(rb) from (select rb_or_agg(rb) as rb from t1 where id < 5));

--error 0, 1051
drop view v;
CREATE VIEW v AS SELECT * from rb_iterate(rb_from_string('1,2,3'));
SELECT * FROM v;
SHOW CREATE VIEW v;
DROP VIEW v;

--error 0, 1051
drop view v;
CREATE VIEW v AS SELECT * from rb_iterate(rb_from_string('1,2,3')) as test;
SELECT * FROM v;
SHOW CREATE VIEW v;
DROP VIEW v;

--error 0, 1051
drop view v;
CREATE VIEW v AS SELECT * from rb_iterate(rb_from_string('1,2,3')) test(test_col);
SELECT * FROM v;
SHOW CREATE VIEW v;
DROP VIEW v;

--error 0, 1051
drop view v;
CREATE VIEW v AS SELECT * from t1, rb_iterate(rb);
SELECT rb_iterate FROM v;
SHOW CREATE VIEW v;
DROP VIEW v;

--error 0, 1051
drop view v;
CREATE VIEW v AS SELECT rb_iterate(rb_from_string('1,2,3'));
SELECT * FROM v;
SHOW CREATE VIEW v;
DROP VIEW v;

--error 0, 1051
drop view v;
CREATE VIEW v AS SELECT rb_iterate(rb_from_string('1,2,3')) as test;
SELECT * FROM v;
SHOW CREATE VIEW v;
DROP VIEW v;

--error 0, 1051
drop view v;
CREATE VIEW v AS SELECT rb_iterate(rb) from t1;
SELECT * FROM v;
SHOW CREATE VIEW v;
DROP VIEW v;

--error 0, 1051
drop view v;
CREATE VIEW v AS SELECT rb_iterate(rb_from_string('1,2,3')) from t1, rb_iterate(rb);
SELECT * FROM v;
SHOW CREATE VIEW v;
DROP VIEW v;

--error 0, 1051
drop view v;
--error 1060
CREATE VIEW v AS SELECT rb_iterate(rb_from_string('1,2,3')), rb_iterate(rb_from_string('2,3,4'));
--error 1235
CREATE VIEW v AS SELECT rb_iterate(rb_from_string('1,2,3')), rb_iterate(rb_from_string('2,3,4')) as test;

--error 0, 1051
drop table t_num;
CREATE TABLE t_num(i INT);

--error 0, 1051
drop table t_create;
create table t_create as (select id, rb_iterate from t1, rb_iterate(rb));
select * from t_create;
--replace_regex / REPLICA_NUM = [0-9]*/ REPLICA_NUM = /
