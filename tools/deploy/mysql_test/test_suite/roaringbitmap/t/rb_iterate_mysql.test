# bugfix: 2024091200104455403
--error 0, 1051
drop table tt1;
create table tt1 (c1 varchar(100));
--error 1235
insert into tt1 values(rb_iterate(rb_from_string('1,2,3')));
--error 1235
replace into tt1 values(rb_iterate(rb_from_string('1,2,3')));
insert into tt1 select * from rb_iterate(rb_from_string('1,2,3'));
insert into tt1 select rb_iterate(rb_from_string('4,5,6'));
replace into tt1 select * from rb_iterate(rb_from_string('1,2,3'));
replace into tt1 select rb_iterate(rb_from_string('4,5,6'));
select * from tt1;
--error 0, 1051
drop table tt1;
--error 0, 1051
drop table tt2;
create table tt2 (c1 int, c2 int);
insert into tt2 select rb_iterate(rb_from_string('1,2,3')), rb_iterate(rb_from_string('4,5'));
insert into tt2 select rb_iterate(rb_from_string('11,22')), rb_iterate(rb_from_string('44,55,66'));
select * from tt2;

