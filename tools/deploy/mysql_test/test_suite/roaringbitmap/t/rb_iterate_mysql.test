--error 0, 1051
drop table t_create;
create table t_create as (select id, a.*, b.*, rb_iterate(rb_from_string('1,2,3')) from t2, rb_iterate(rb1) as a, rb_iterate(rb2) as b);
select * from t_create;
--replace_regex / REPLICA_NUM = [0-9]*/ REPLICA_NUM = /
