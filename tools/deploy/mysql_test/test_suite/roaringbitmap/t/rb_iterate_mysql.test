select * from test order by rb_iterate(r);
--error 1235
select * from test order by rb_iterate(rb_from_string('1,2,3'));
--error 1235
select  rb_iterate(r) from test group by rb_iterate(r);
--error 1235
select  rb_iterate(rb_from_string('1,2,3')) from test group by rb_iterate(rb_from_string('1,2,3'));
