# vectorize 2.0
--disable_warnings
drop table if exists t1, dml_test, t2;
--enable_warnings

# empty
SET @p1 = x'0100';
# single: 1
SET @p2 = x'010101000000';
# single: 2
SET @p3 = x'010102000000';
# set: 1,2,3
SET @p4 = x'010303010000000200000003000000';
# set: 2,3,4
SET @p5 = x'010303020000000300000004000000';
# bitmap: 0~32
SET @p6 = x'01060100000000000000000000003a30000001000000000020001000000000000100020003000400050006000700080009000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f002000';
# bitmap: 10~42
SET @p7 = x'01060100000000000000000000003a3000000100000000002000100000000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f0020002100220023002400250026002700280029002a00';

CREATE TABLE t1 (k int, rb roaringbitmap);
INSERT INTO t1 VALUES
  (1, NULL),
  (1, @p1),
  (1, @p2),
  (2, @p1),
  (2, @p2),
  (3, @p2),
  (3, @p1),
  (4, @p1),
  (4, @p4),
  (5, @p4),
  (5, @p1),
  (6, @p1),
  (6, @p6),
  (7, @p6),
  (7, @p1),
  (8, @p2),
  (8, @p3),
  (9, @p2),
  (9, @p4),
  (10, @p4),
  (10, @p2),
  (11, @p2),
  (11, @p6),
  (12, @p6),
  (12, @p2),
  (13, @p4),
  (13, @p5),
  (14, @p4),
  (14, @p6),
  (15, @p6),
  (15, @p4),
  (16, @p6),
  (16, @p7);

# vec 2.0
select rb_contains(rb, k) from t1;
select rb_contains(rb, 1) from t1;
select rb_contains(rb, 9223372036854775808) from t1;
select rb_contains(rb, rb_from_string('1,2')) from t1;
select rb_contains(rb_from_string('1,2'), rb) from t1;
--error 3064
select rb_contains([1,2,3], rb) from t1;

--error 3064
select rb_contains(rb, -18446744073709551615) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */  rb_contains(rb, 1) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */  rb_contains(rb, k) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */  rb_contains(rb, 9223372036854775808) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */  rb_contains(rb, rb_from_string('1,2')) from t1;
--error 3064
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */  rb_contains(rb, -18446744073709551615) from t1;

# DML
CREATE TABLE dml_test ( 
pk bigint not null AUTO_INCREMENT,
i_1   BigInt
);

insert into dml_test(i_1)
select rb_contains(rb, k) 
from t1;
select pk, i_1 from dml_test;

update dml_test
set i_1 = rb_contains(rb_from_string('1,2,3,4'), 1)
where i_1 =  rb_contains(rb_from_string('1,2,3,4'), rb_from_string('6,7,8'));
select * from dml_test;

delete from dml_test
where i_1 = rb_contains(rb_from_string('1,2,3,4'), 1);
select * from dml_test;

# contains null with table
create table t2 (id int not null auto_increment, i_1 int, i_2 int, rb roaringbitmap);
insert into t2(i_1) values (1);
insert into t2(i_1) values (2);
insert into t2(i_1) values (3);
insert into t2(i_2) values (4);
insert into t2(i_2) values (5);
insert into t2(i_2) values (6);
select * from t2;
select rb_contains(rb_from_string('1,2,3'), i_1) from t2;
select rb_contains(rb_from_string('1,2,3'), i_2) from t2;
select rb_contains(rb, i_2) from t2;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ rb_contains(rb_from_string('1,2,3'), i_1) from t2;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ rb_contains(rb_from_string('1,2,3'), i_2) from t2;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ rb_contains(rb, i_2) from t2;

