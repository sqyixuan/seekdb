# ----------------------------------------------------------------------
# Base test of roaringbitmap type.
# ----------------------------------------------------------------------
drop table if exists t1;
drop table if exists tt1, tt2, tt3, tt4, tt5;
SET @p1 = x'0100';
SET @p2 = x'010101000000';
SET @p3 = x'010102000000';
SET @p4 = x'010303010000000200000003000000';
SET @p5 = x'010303020000000300000004000000';
SET @p6 = x'01060100000000000000000000003a30000001000000000020001000000000000100020003000400050006000700080009000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f002000';
SET @p7 = x'01060100000000000000000000003a3000000100000000002000100000000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f0020002100220023002400250026002700280029002a00';
create table t1 (id int, rb roaringbitmap);
insert into t1 values (0, NULL), (1, @p1), (2, @p2), (3, @p3), (4, @p4), (5, @p5), (6, @p6), (7, @p7);
select id, hex(rb) from t1;
id	hex(rb)
0	NULL
1	0100
2	010101000000
3	010102000000
4	010303010000000200000003000000
5	010303020000000300000004000000
6	01060100000000000000000000003A30000001000000000020001000000000000100020003000400050006000700080009000A000B000C000D000E000F0010001100120013001400150016001700180019001A001B001C001D001E001F002000
7	01060100000000000000000000003A3000000100000000002000100000000A000B000C000D000E000F0010001100120013001400150016001700180019001A001B001C001D001E001F0020002100220023002400250026002700280029002A00
select id, hex(rb) from t1 where rb = NULL;
ERROR 22000: Invalid data type for the operation
select id, hex(rb) from t1 where rb != NULL;
ERROR 22000: Invalid data type for the operation
select id, hex(rb) from t1 where rb = rb_build_empty();
ERROR 22000: Invalid data type for the operation
select id, hex(rb) from t1 where rb != rb_build_empty();
ERROR 22000: Invalid data type for the operation
select id, hex(rb) from t1 where rb = x'0100';
ERROR 22000: Invalid data type for the operation
select id, hex(rb) from t1 where rb != x'0100';
ERROR 22000: Invalid data type for the operation
select id, hex(rb) from t1 where rb = rb_build_varbinary(x'0100');
ERROR 22000: Invalid data type for the operation
select id, hex(rb) from t1 where rb = rb_build_agg(1);
ERROR HY000: Invalid use of group function
select id, hex(rb) from t1 where rb = rb_from_string('1');
ERROR 22000: Invalid data type for the operation
select id, hex(rb) from t1 where rb > NULL;
ERROR 22000: Invalid data type for the operation
select id, hex(rb) from t1 where rb < x'0100';
ERROR 22000: Invalid data type for the operation
select id, hex(rb) from t1 where rb <= rb_build_empty();
ERROR 22000: Invalid data type for the operation
select sum(rb) from t1;
ERROR HY000: Invalid argument
select min(rb) from t1;
ERROR HY000: Invalid argument
select max(rb) from t1;
ERROR HY000: Invalid argument
select avg(rb) from t1;
ERROR HY000: Invalid argument
create table tt1(id int,a varbinary(1000),r roaringbitmap);
insert into tt1 values(1,rb_from_string('1'),rb_from_string('1'));
insert into tt1 values(2,rb_build_empty(),rb_build_empty());
insert into tt1 values(3,rb_from_string('1,3'),rb_from_string('1,3'));
select id, hex(a), hex(r) from tt1 where rb_build_empty() like rb_build_empty() ;
id	hex(a)	hex(r)
1	010101000000	010101000000
2	0100	0100
3	0103020100000003000000	0103020100000003000000
select id, hex(a), hex(r) from tt1 where  rb_from_string('1,2,3,4') like rb_from_string('1,2,3,4');
id	hex(a)	hex(r)
1	010101000000	010101000000
2	0100	0100
3	0103020100000003000000	0103020100000003000000
select id, hex(a), hex(r) from tt1 where  rb_build_varbinary(0x01030401000000020000000300000004000000) like rb_build_varbinary(0x01030401000000020000000300000004000000);
id	hex(a)	hex(r)
1	010101000000	010101000000
2	0100	0100
3	0103020100000003000000	0103020100000003000000
select hex(cast(rb_build_empty() as binary));
hex(cast(rb_build_empty() as binary))
0100
select hex(cast(rb_from_string('1,2,3,4') as binary));
hex(cast(rb_from_string('1,2,3,4') as binary))
01030401000000020000000300000004000000
select hex(cast (rb_build_varbinary(0x01030401000000020000000300000004000000) as binary));
hex(cast (rb_build_varbinary(0x01030401000000020000000300000004000000) as binary))
01030401000000020000000300000004000000
select cast(rb_build_empty() as SIGNED);
ERROR 22000: Invalid data type for the operation
select cast(rb_from_string('1,2,3,4') as date);
