hex(cast( x'01060200000000000000000000003a30000001000000ffff000010000000ffff010000003a3000000100000000001f001000000000000100020003000400050006000700080009000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f00' as roarin
01060200000000000000000000003A30000001000000FFFF000010000000FFFF010000003A3000000100000000001F001000000000000100020003000400050006000700080009000A000B000C000D000E000F0010001100120013001400150016001700180019001A001B001C001D001E001F00
SELECT hex( CASE WHEN 1=1 THEN rb_build_agg(1)  ELSE rb_build_empty()  END );
hex( CASE WHEN 1=1 THEN rb_build_agg(1)  ELSE rb_build_empty()  END )
010101000000
SELECT hex( CASE WHEN 1>1 THEN rb_build_agg(1)  ELSE rb_build_empty()  END );
hex( CASE WHEN 1>1 THEN rb_build_agg(1)  ELSE rb_build_empty()  END )
0100
SELECT rb_to_string( CASE rb_build_agg(1) WHEN rb_build_agg(2) THEN rb_build_agg(2) WHEN rb_build_agg(1) THEN rb_build_agg(1) END );
ERROR 22000: Invalid data type for the operation
