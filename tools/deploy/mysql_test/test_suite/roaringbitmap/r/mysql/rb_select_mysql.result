drop table test;
create table test(b boolean,b1 bool,b2 TINYINT);
insert into test values(true,true,true);
insert into test values(0,0,0);
insert into test values(-5,-5,-5);
select rb_to_string(rb_select(rb_from_string('1,2,3'),1,0,b)) from test;
rb_to_string(rb_select(rb_from_string('1,2,3'),1,0,b))
3
1
3
select rb_to_string(rb_select(rb_from_string('1,2,3'),1,0,b1)) from test;
rb_to_string(rb_select(rb_from_string('1,2,3'),1,0,b1))
3
1
3
select rb_to_string(rb_select(rb_from_string('1,2,3'),1,0,b2)) from test;
