create table t1 (id int, rb roaringbitmap);
insert into t1 values (1, @p1), (2, @p2), (3, @p3);
select id, rb_to_string(rb_select(rb, 3, 1, false)) from t1;
id	rb_to_string(rb_select(rb, 3, 1, false))
1	
2	2,3,4
3	2,3,4
select id, rb_to_string(rb_select(rb, 3, 1, true)) from t1;
id	rb_to_string(rb_select(rb, 3, 1, true))
1	
2	2,3,4
3	30,31,32
select rb_to_string(rb_select(rb_build_agg(id), 3, 1)) from t1;
rb_to_string(rb_select(rb_build_agg(id), 3, 1))
2,3
