# ----------------------------------------------------------------------
# Base test of roaringbitmap rb_contains.
# ----------------------------------------------------------------------
test: rb_contains from other exprs
select rb_contains(rb_from_string('1,2,3,4'), 1);
rb_contains(rb_from_string('1,2,3,4'), 1)
1
select rb_contains(rb_from_string('1,2,3,4'), 9223372036854775808);
rb_contains(rb_from_string('1,2,3,4'), 9223372036854775808)
0
select rb_contains(rb_from_string('1,2,3,4,9223372036854775808'), 9223372036854775808);
rb_contains(rb_from_string('1,2,3,4,9223372036854775808'), 9223372036854775808)
1
select rb_contains(rb_from_string(''), 1);
rb_contains(rb_from_string(''), 1)
0
select rb_contains(rb_from_string('1,2,3,4'), rb_from_string('1,2,3,4'));
rb_contains(rb_from_string('1,2,3,4'), rb_from_string('1,2,3,4'))
1
select rb_contains(rb_from_string('1,2,3,4'), rb_from_string('1,2,3'));
rb_contains(rb_from_string('1,2,3,4'), rb_from_string('1,2,3'))
1
select rb_contains(rb_from_string('1,2,3,4'), rb_from_string('1,2,3,4,5'));
rb_contains(rb_from_string('1,2,3,4'), rb_from_string('1,2,3,4,5'))
0
select rb_contains(rb_from_string('1,2,3,4'), rb_from_string('1,2,3,5'));
rb_contains(rb_from_string('1,2,3,4'), rb_from_string('1,2,3,5'))
0
select rb_contains(rb_from_string('1,2,3,4'), rb_from_string(''));
rb_contains(rb_from_string('1,2,3,4'), rb_from_string(''))
1
select rb_contains(rb_from_string(''), rb_from_string('1,2,3,4'));
rb_contains(rb_from_string(''), rb_from_string('1,2,3,4'))
0
select rb_contains(rb_from_string('-4294967'), -4294967);
rb_contains(rb_from_string('-4294967'), -4294967)
1
select rb_contains(rb_from_string('-4294967'), -9223372036854775808);
ERROR HY000: Size overflow
select rb_contains(rb_from_string('2147483648'), -2147483649);
ERROR HY000: Size overflow
select rb_contains(rb_from_string('2147483648'), -2147483648);
rb_contains(rb_from_string('2147483648'), -2147483648)
1
select rb_contains(rb_from_string('2147483647'), -2147483647);
rb_contains(rb_from_string('2147483647'), -2147483647)
0
select rb_contains(rb_from_string('-2147483647'), -2147483647);
rb_contains(rb_from_string('-2147483647'), -2147483647)
1
test: null/empty as param
select rb_contains(null, rb_from_string('1,2,3,4'));
rb_contains(null, rb_from_string('1,2,3,4'))
NULL
select rb_contains(null, null);
rb_contains(null, null)
NULL
select rb_contains(null, rb_from_string(''));
rb_contains(null, rb_from_string(''))
NULL
select rb_contains(rb_from_string(''), null);
rb_contains(rb_from_string(''), null)
NULL
select rb_contains(rb_from_string(''), rb_from_string(''));
rb_contains(rb_from_string(''), rb_from_string(''))
1
select rb_contains(rb_from_string(''), rb_from_string('1,2,3,4'));
rb_contains(rb_from_string(''), rb_from_string('1,2,3,4'))
0
select rb_contains(rb_from_string('1,2,3,4'), 2, 3);
ERROR 42000: Incorrect parameter count in the call to native function 'rb_contains'
select rb_contains(rb_from_string('1,2,3,4'));
ERROR 42000: Incorrect parameter count in the call to native function 'rb_contains'
select rb_contains(rb_from_string('1,2,3,4'), 2, 3, 4);
ERROR 42000: Incorrect parameter count in the call to native function 'rb_contains'
select rb_contains([1,2,3], 3);
ERROR HY000: invalid type given for an argument
select rb_contains(map(1,2,3,4), 3);
ERROR HY000: invalid type given for an argument
select rb_contains("hello world", 3);
ERROR HY000: invalid type given for an argument
select rb_contains(1, 3);
ERROR HY000: invalid type given for an argument
select rb_contains(1.2, 3);
ERROR HY000: invalid type given for an argument
select rb_contains(rb_from_string('1,2,3,4'), true);
ERROR HY000: invalid type given for an argument
select rb_contains(rb_from_string('1,2,3,4'), 1.2);
ERROR HY000: invalid type given for an argument
select rb_contains(rb_from_string('1,2,3,4'), "1");
ERROR HY000: invalid type given for an argument
select rb_contains(rb_from_string('1,2,3,4'), [1,2,3]);
ERROR HY000: invalid type given for an argument
select rb_contains(rb_from_string('1,2,3,4'), map(1,2));
ERROR HY000: invalid type given for an argument
select rb_contains([1,2,3], null);
ERROR HY000: invalid type given for an argument
select rb_contains(true, null);
ERROR HY000: invalid type given for an argument
select rb_contains(map(1,2), null);
ERROR HY000: invalid type given for an argument
select rb_contains(1.2, null);
ERROR HY000: invalid type given for an argument
select rb_contains(null, 1.2);
ERROR HY000: invalid type given for an argument
select rb_contains(null, "tengzhen.lk");
ERROR HY000: invalid type given for an argument
select rb_contains(null, [1,2,3]);
ERROR HY000: invalid type given for an argument
select rb_contains(null, map(1,2));
ERROR HY000: invalid type given for an argument
test: rb_contains from binary
select rb_contains(x'0100', 1);
rb_contains(x'0100', 1)
0
select rb_contains(x'0100', x'0100');
rb_contains(x'0100', x'0100')
1
select rb_contains(x'0200', 1);
ERROR HY000: Invalid data
select rb_contains(x'0200', x'0200');
ERROR HY000: Invalid data
select rb_contains(x'010101000000', 1);
rb_contains(x'010101000000', 1)
1
select rb_contains(x'0101FFFFFFFF', 1);
