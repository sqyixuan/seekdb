test: rb_from_string value range
select rb_contains(rb_from_string('0'), 1);
rb_contains(rb_from_string('0'), 1)
0
select rb_contains(rb_from_string('1'), 1);
rb_contains(rb_from_string('1'), 1)
1
select rb_contains(rb_from_string('-1'), 1);
rb_contains(rb_from_string('-1'), 1)
0
select rb_contains(rb_from_string('18446744073709551615'), 1);
rb_contains(rb_from_string('18446744073709551615'), 1)
0
select rb_contains(rb_from_string('18446744073709551616'), 1);
ERROR HY000: Size overflow
select rb_contains(rb_from_string('-2147483649'), 1);
ERROR HY000: Size overflow
select rb_contains(rb_from_string('-2147483648'), 1);
rb_contains(rb_from_string('-2147483648'), 1)
0
select rb_contains(rb_from_string('9223372036854775806'), 1);
rb_contains(rb_from_string('9223372036854775806'), 1)
0
select rb_contains(rb_from_string('9223372036854775807'), 1);
rb_contains(rb_from_string('9223372036854775807'), 1)
0
select rb_contains(rb_from_string('9223372036854775808'), 1);
rb_contains(rb_from_string('9223372036854775808'), 1)
0
select rb_contains(rb_from_string('-18446744073709551615'), 1);
ERROR HY000: Size overflow
drop table if exists t1, dml_test, t2;
SET @p1 = x'0100';
SET @p2 = x'010101000000';
SET @p3 = x'010102000000';
SET @p4 = x'010303010000000200000003000000';
SET @p5 = x'010303020000000300000004000000';
SET @p6 = x'01060100000000000000000000003a30000001000000000020001000000000000100020003000400050006000700080009000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f002000';
SET @p7 = x'01060100000000000000000000003a3000000100000000002000100000000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f0020002100220023002400250026002700280029002a00';
