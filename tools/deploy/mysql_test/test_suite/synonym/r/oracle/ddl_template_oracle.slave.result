result_format: 4
#########################################################################
############### SQL新增功能在DDL语句中的测试模板 ########################
#########################################################################
####################### PREPATE TEST RESOURCE ###########################


drop user ddl_user cascade;
create user ddl_user identified by 123456;
alter session set current_schema=ddl_user;

create table t1(c1 int primary key, c2 int unique key);
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'key)' at line 1
create table t1(c1 int key, c2 int unique);
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'key, c2 int unique)' at line 1
create table t1(c1 int primary key, c2 int unique);
insert into t1 values(1, 1),(2,2),(3,3);
create synonym s1 for t1;
########   测试新添加功能在创建索引时的正确性性             ###########
create index idx1 on s1(c1, c2);

create table t2(c1 int primary key, c2 int);
insert into t2 values(2,2),(3,3);
create synonym s2 for t2;

####################### TEST FOR CREATE TABLE ###########################
########   测试新添加功能在create table中的正确性             ###########
### test for same name with synonym ###
create table s1(c1 int);
ERROR HY000: name is already used by an existing object
create table s1 like t1;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'like t1' at line 1
create table if not exists s1 like t1;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'not exists s1 like t1' at line 1

### test for rename table #####
rename t1 to s1;
ERROR HY000: name is already used by an existing object

####################### TEST FOR ALTER TABLE ###########################
alter table t1 rename to s1;
ERROR HY000: name is already used by an existing object

####################### TEST FOR CREATE INDEX #########################
####################### TEST FOR CREATE VIEW ###########################
########   测试新添加功能在创建索引时的正确性性             ###########
create view s1 as select * from t1;
ERROR HY000: name is already used by an existing object
create or replace view s1 as select * from t1;
ERROR HY000: name is already used by an existing object

####################### TEST FOR CREATE OUTLINE ###########################
### test for outline data table_scan ###
drop index idx1;
create or replace outline ol1 on select * from t1;
select outline_content from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id= 1002 and a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ddl_user' and a.name like 'ol1';
+---------------------------------------------------------------------------------------------------------------+
| outline_content                                                                                               |
+---------------------------------------------------------------------------------------------------------------+
| /*+BEGIN_OUTLINE_DATA FULL(@"SEL$1" "DDL_USER"."T1"@"SEL$1") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/ |
+---------------------------------------------------------------------------------------------------------------+

create or replace outline ol2 on select * from t1 tt1;
select outline_content from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id= 1002 and a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ddl_user' and a.name like 'ol2';
