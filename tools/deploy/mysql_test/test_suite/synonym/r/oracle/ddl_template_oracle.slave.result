| outline_content                                                                                     |
+-----------------------------------------------------------------------------------------------------+
| /*+BEGIN_OUTLINE_DATA FULL(@"SEL$1" "TT1"@"SEL$1") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/ |
+-----------------------------------------------------------------------------------------------------+

create or replace synonym s1 for t1;
create or replace outline ol3 on select * from s1;
select outline_content from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id= 1002 and a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ddl_user' and a.name like 'ol3';
+---------------------------------------------------------------------------------------------------------------+
| outline_content                                                                                               |
+---------------------------------------------------------------------------------------------------------------+
| /*+BEGIN_OUTLINE_DATA FULL(@"SEL$1" "DDL_USER"."S1"@"SEL$1") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/ |
+---------------------------------------------------------------------------------------------------------------+

create or replace outline ol4 on select * from s1 ss1;
select outline_content from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id= 1002 and a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ddl_user' and a.name like 'ol4';
