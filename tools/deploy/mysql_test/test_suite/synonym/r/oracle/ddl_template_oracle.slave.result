### test for outline data join ###
create or replace outline ol5 on select /*+ LEADING(s1, t2) */ t2.c1 from t2, s1;
select outline_content from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id= 1002 and a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ddl_user' and a.name like 'ol5';
+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| outline_content                                                                                                                                                                                                                                                                                                            |
+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| /*+BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("DDL_USER"."S1"@"SEL$1" "DDL_USER"."T2"@"SEL$1")) USE_NL(@"SEL$1" "DDL_USER"."T2"@"SEL$1") USE_NL_MATERIALIZATION(@"SEL$1" "DDL_USER"."T2"@"SEL$1") FULL(@"SEL$1" "DDL_USER"."S1"@"SEL$1") FULL(@"SEL$1" "DDL_USER"."T2"@"SEL$1") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/ |
+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+

create or replace outline ol6 on select /*+ LEADING(ss1, t2) */ t2.c1 from t2, s1 ss1;
select outline_content from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id= 1002 and a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ddl_user' and a.name like 'ol6';
+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| outline_content                                                                                                                                                                                                                                                                                        |
+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| /*+BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("SS1"@"SEL$1" "DDL_USER"."T2"@"SEL$1")) USE_NL(@"SEL$1" "DDL_USER"."T2"@"SEL$1") USE_NL_MATERIALIZATION(@"SEL$1" "DDL_USER"."T2"@"SEL$1") FULL(@"SEL$1" "SS1"@"SEL$1") FULL(@"SEL$1" "DDL_USER"."T2"@"SEL$1") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/ |
+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+

### test for outline subplan ###
create or replace view v1 as select max(c1) as c1 from t2;
create or replace synonym sv1 for v1;
create or replace outline ol7 on select t2.c1 from sv1 join t2 on sv1.c1 = t2.c1;
select outline_content from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id= 1002 and a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ddl_user' and a.name like 'ol7';
+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| outline_content                                                                                                                                                                                                                                                                                                                                  |
+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| /*+BEGIN_OUTLINE_DATA LEADING(@"SEL$C6D21C0F" ("DDL_USER"."SV1"@"SEL$1" "DDL_USER"."T2"@"SEL$1")) USE_MERGE(@"SEL$C6D21C0F" "DDL_USER"."T2"@"SEL$1") FULL(@"SEL$7E047C3E" "DDL_USER"."T2"@"SEL$2") FULL(@"SEL$C6D21C0F" "DDL_USER"."T2"@"SEL$1") OUTER_TO_INNER(@"SEL$1") FAST_MINMAX(@"SEL$2") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/ |
+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+

create or replace outline ol8 on select t2.c1 from sv1 ssv1, t2 where ssv1.c1 = t2.c1;
select outline_content from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id= 1002 and a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ddl_user' and a.name like 'ol8';
+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| outline_content                                                                                                                                                                                                                                                                          |
+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| /*+BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("SSV1"@"SEL$1" "DDL_USER"."T2"@"SEL$1")) USE_MERGE(@"SEL$1" "DDL_USER"."T2"@"SEL$1") FULL(@"SEL$7E047C3E" "DDL_USER"."T2"@"SEL$2") FULL(@"SEL$1" "DDL_USER"."T2"@"SEL$1") FAST_MINMAX(@"SEL$2") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/ |
+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+

