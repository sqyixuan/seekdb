result_format: 4
alter session set current_schema=test;

drop table root_oracle_t1;
alter system flush plan cache global;


create table root_oracle_t1 (c1 int primary key, c2 varchar(1000)) partition by hash(c1) partitions 3;
select * from root_oracle_t1;
+----+------+
| C1 | C2   |
+----+------+
+----+------+
select /*+no_use_px*/ * from root_oracle_t1;
+----+------+
| C1 | C2   |
+----+------+
+----+------+
select * from root_oracle_t1 where c1 = 1;
+----+------+
| C1 | C2   |
+----+------+
+----+------+


