drop table if exists t1,t2,t3,t4;
result_format: 4
##  add -> drop -> add
create table t1 (c1 int primary key ,c2 int ,c3 int)partition by range(c1) (partition p0 values less than (10), partition p1 values less than (100),partition p2 values less than (1000));
insert into t1 values(9,9,9);
insert into t1 values(99,99,99);
insert into t1 values(999,999,999);
alter table t1 add partition(partition p3 values less than(maxvalue));
insert into t1 values(9999,9999,9999);
alter table t1 drop partition (p2);
create table t2 (c1 int);
insert into t2 values(9);
insert into t2 values(99);
insert into t2 values(999);
insert into t2 values(9999);
explain select * from t1,t2 where t1.c1 = t2.c1;
Query Plan
=====================================================================
|ID|OPERATOR                         |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------
|0 |PX COORDINATOR                   |        |3       |18          |
|1 |└─EXCHANGE OUT DISTR             |:EX10001|3       |16          |
|2 |  └─HASH JOIN                    |        |3       |12          |
|3 |    ├─EXCHANGE IN DISTR          |        |4       |5           |
|4 |    │ └─EXCHANGE OUT DISTR (PKEY)|:EX10000|4       |4           |
|5 |    │   └─TABLE FULL SCAN        |t2      |4       |3           |
|6 |    └─PX PARTITION ITERATOR      |        |3       |7           |
|7 |      └─TABLE FULL SCAN          |t1      |3       |7           |
=====================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t2.c1)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t2.c1)]), filter(nil), rowset=16
      dop=1
  2 - output([t1.c1], [t2.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      equal_conds([t1.c1 = t2.c1]), other_conds(nil)
  3 - output([t2.c1]), filter(nil), rowset=16
  4 - output([t2.c1]), filter(nil), rowset=16
      (#keys=1, [t2.c1]), is_single, dop=1
  5 - output([t2.c1]), filter(nil), rowset=16
      access([t2.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  6 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      affinitize, force partition granule
  7 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(MIN ; MAX)always true
select * from t1,t2 where t1.c1 = t2.c1;
