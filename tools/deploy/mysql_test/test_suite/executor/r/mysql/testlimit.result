DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
col_bigint bigint,
col_char_12 char(12) ,
col_bigint_key bigint,
col_char_12_key char(12),
pk bigint ,
PRIMARY KEY (pk)
);
create index i1 on t1(col_bigint_key);
create index i2 on t1(col_char_12_key);
