result_format: 4
use test;

drop table if exists root_t1;

create table root_t1 (c1 int primary key, c2 varchar(1000)) partition by hash(c1) partitions 3;
select * from root_t1;
+----+------+
| c1 | c2   |
+----+------+
+----+------+
select /*+no_use_px*/ * from root_t1;
+----+------+
| c1 | c2   |
+----+------+
+----+------+
select * from root_t1 where c1 = 1;
+----+------+
| c1 | c2   |
+----+------+
+----+------+


//dist plan use px
+-----------------------------+---------+
| operator                    | name    |
+-----------------------------+---------+
| PHY_VEC_PX_FIFO_COORD       | NULL    |
|  PHY_VEC_PX_REDUCE_TRANSMIT | NULL    |
|   PHY_VEC_GRANULE_ITERATOR  | NULL    |
|    PHY_VEC_TABLE_SCAN       | root_t1 |
+-----------------------------+---------+

//dist plan no use px
+-----------------------------+---------+
| operator                    | name    |
+-----------------------------+---------+
| PHY_VEC_PX_FIFO_COORD       | NULL    |
|  PHY_VEC_PX_REDUCE_TRANSMIT | NULL    |
|   PHY_VEC_GRANULE_ITERATOR  | NULL    |
|    PHY_VEC_TABLE_SCAN       | root_t1 |
+-----------------------------+---------+

// local plan
+----------------------+---------+
| operator             | name    |
+----------------------+---------+
| PHY_DIRECT_RECEIVE   | NULL    |
|  PHY_DIRECT_TRANSMIT | NULL    |
|   PHY_VEC_TABLE_SCAN | root_t1 |
+----------------------+---------+
drop table root_t1;
