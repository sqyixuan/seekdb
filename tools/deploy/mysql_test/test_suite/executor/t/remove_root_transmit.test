#owner: xiaoyi.xy
#owner group: SQL1
#tags: optimizer

--result_format 4

use test;

--disable_warnings
drop table if exists root_t1;
--enable_warnings

let $default_tenant_id = query_get_value(select effective_tenant_id(), effective_tenant_id(), 1);

create table root_t1 (c1 int primary key, c2 varchar(1000)) partition by hash(c1) partitions 3;
select * from root_t1;
select /*+no_use_px*/ * from root_t1;
select * from root_t1 where c1 = 1;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--sleep 5
connection obsys;
--echo
--echo //dist plan use px
let $plan_id = query_get_value("select plan_id from oceanbase.__all_virtual_plan_stat where svr_ip=HOST_IP() AND svr_port=RPC_PORT() and is_serving_tenant(svr_ip, svr_port, $default_tenant_id) and (tenant_id = $default_tenant_id or $default_tenant_id = 1) and statement = 'select * from root_t1'", plan_id, 1);
--disable_query_log
eval select operator, name FROM oceanbase.__all_virtual_plan_cache_plan_explain WHERE svr_ip=HOST_IP() AND svr_port=RPC_PORT() and is_serving_tenant(svr_ip, svr_port, $default_tenant_id) and ($default_tenant_id=1 or TENANT_ID=$default_tenant_id) and plan_id = $plan_id and tenant_id = $default_tenant_id;
--enable_query_log

--echo
--echo //dist plan no use px
let $plan_id = query_get_value("select plan_id from oceanbase.__all_virtual_plan_stat where svr_ip=HOST_IP() AND svr_port=RPC_PORT() and is_serving_tenant(svr_ip, svr_port, $default_tenant_id) and (tenant_id = $default_tenant_id or $default_tenant_id = 1) and statement = 'select /*+no_use_px*/ * from root_t1'", plan_id, 1);
--disable_query_log
eval select operator, name FROM oceanbase.__all_virtual_plan_cache_plan_explain WHERE svr_ip=HOST_IP() AND svr_port=RPC_PORT() and is_serving_tenant(svr_ip, svr_port, $default_tenant_id) and ($default_tenant_id=1 or TENANT_ID=$default_tenant_id) and plan_id = $plan_id and tenant_id = $default_tenant_id;
--enable_query_log

--echo
--echo // local plan
let $plan_id = query_get_value("select plan_id from oceanbase.__all_virtual_plan_stat where svr_ip=HOST_IP() AND svr_port=RPC_PORT() and is_serving_tenant(svr_ip, svr_port, $default_tenant_id) and (tenant_id = $default_tenant_id or $default_tenant_id = 1) and statement = 'select * from root_t1 where c1 = ?'", plan_id, 1);
--disable_query_log
eval select operator, name FROM oceanbase.__all_virtual_plan_cache_plan_explain WHERE svr_ip=HOST_IP() AND svr_port=RPC_PORT() and is_serving_tenant(svr_ip, svr_port, $default_tenant_id) and ($default_tenant_id=1 or TENANT_ID=$default_tenant_id) and plan_id = $plan_id and tenant_id = $default_tenant_id;
--enable_query_log

connection default;
drop table root_t1;
