#owner : xiaoyi.xy
#owner group : sql2
# tags: optimizer

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings
--result_format 4
##  add -> drop -> add
create table t1 (c1 int primary key ,c2 int ,c3 int)partition by range(c1) (partition p0 values less than (10), partition p1 values less than (100),partition p2 values less than (1000));
insert into t1 values(9,9,9);
insert into t1 values(99,99,99);
insert into t1 values(999,999,999);
alter table t1 add partition(partition p3 values less than(maxvalue));
insert into t1 values(9999,9999,9999);
alter table t1 drop partition (p2);
create table t2 (c1 int);
insert into t2 values(9);
insert into t2 values(99);
insert into t2 values(999);
insert into t2 values(9999);
explain select * from t1,t2 where t1.c1 = t2.c1;
select * from t1,t2 where t1.c1 = t2.c1;


##  add -> add -> add
create table t3(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) subpartition by hash(c2) subpartitions 3 (partition p0 values less than(10));
alter table t3 add partition (partition p1 values less than(20));
alter table t3 add partition (partition p2 values less than(30));

insert into t3 values(15,1); # p1sp1
insert into t3 values(25,1); # p2sp1
insert into t3 values(25,2); # p2sp2
insert into t3 values(25,3); # p2sp0

create table t4(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) subpartition by hash(c2) subpartitions 3
(partition p0 values less than(10),
partition p1 values less than(20),
partition p2 values less than(30));

insert into t4 values(15,1); # p1sp1
insert into t4 values(25,1); # p2sp1
insert into t4 values(25,2); # p2sp2
insert into t4 values(25,3); # p2sp0

explain select t3.c1, t4.c2 from t3 join t4 on t3.c1 = t4.c1;
--sorted_result
select t3.c1, t4.c2 from t3 join t4 on t3.c1 = t4.c1;

alter table t4 drop partition (p1);

explain select t3.c1, t4.c2 from t3 join t4 on t3.c1 = t4.c1;
--sorted_result
select t3.c1, t4.c2 from t3 join t4 on t3.c1 = t4.c1;

alter table t4 add partition (partition p1 values less than(40));

explain select t3.c1, t4.c2 from t3 join t4 on t3.c1 = t4.c1;
--sorted_result
select t3.c1, t4.c2 from t3 join t4 on t3.c1 = t4.c1;

