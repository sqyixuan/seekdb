--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: sql1
# tags: optimizer
--source mysql_test/test_suite/executor/include/load_data_11388669.inc
--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats('TEST', 'T1');
call dbms_stats.gather_table_stats('TEST', 'T2');
call dbms_stats.gather_table_stats('TEST', 'T3');
--sleep 3
--result_format 4
--explain_protocol 2
select /*+use_nl(t1 t2 t3)*/ * from t1 left join t2 on t1.a = t2.a and t1.a = 1 and t2.a = 1 left join t3 on t2.a = t3.a and t3.a in (1, 2) order by t1.a;
