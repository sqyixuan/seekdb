#无参自定义函数if表达式加子查询
drop function if exists t_fun;//
create function t_fun()
returns varchar(20)
begin
declare i int;
set i = (select e.deptno from t2 e where e.mgr is not null);
if i = 10 and exists (select * from t2 e where e.ename = 'KING') then
return i;
elseif i > 10 and i > (select e.deptno from t2 e where sal = 3000 ) then
return i+1;
else
return false;
end if;
end;
//
select t_fun();
//
drop function if exists t_fun;//
create function t_fun()
returns varchar(20)
begin
declare i int;
set i = (select e.deptno from t2 e where e.mgr is not null);
case i when
i = 10 and exists (select * from t2 e where e.ename = 'KING') then
return i;
when i > 10 and i > (select e.deptno from t2 e where sal = 3000 ) then
return i+1;
else
return false;
end case;
end;
//
select t_fun();
//
带参数的自定义函数if表达式加子查询
drop function if exists t_fun;//
create function t_fun(a int)
returns int 
begin
if a = 10 and exists(select * from t2 where empno=(select mgr from t2 where ename='FORD')) then
return (a + (select sal from t2 where ename = 'CLARK'));
elseif a = 20 and a in (select deptno from t2 where sal > 3000) then
return concat(a,(select sal from t2 where job = 'CLERK' and sal + comm > 2000));
elseif a = 30 and a > any(select deptno from t2 where job in ('ANALYST','SALESMAN')) then
return a and exists(select * from t2 where sal > 3999);
else
return a;
end if;
end;
