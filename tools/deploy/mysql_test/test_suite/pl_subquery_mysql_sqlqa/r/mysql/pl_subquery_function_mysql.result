t_fun('BLAKE',30,2000)
3
select t_fun('BLAKE',40,700);//
t_fun('BLAKE',40,700)
5
drop function t_fun;//
create function t_fun(a varchar(20),b int,c int)
returns varchar(50)
begin
declare msg varchar(50);
set msg = '';
if b = 10 and c between (select sal from t2 where ename = a) and (select max(sal) from t2 where ename != a) then
set msg = concat(1,'name',a,'sal',c);
elseif b = 20 and c = (select sal from t2 where ename = a) then
set msg = concat(2,'name',a,'sal',c);
elseif b = 30 and a is not null or c is null then 
set msg = concat(3,'name',a,'sal',c);
elseif b = 40 and a like '%P%' and c not in (select sal from t2 where comm > 0) then
set msg = concat(4,'name',a,'sal',c);
elseif b = 50 and c >=all(select sal from t2 where ename = a) then
set msg = concat(5,'name',a,'sal',c);
elseif b = 60 and c = (select * from (select p.sal from t1 e,t2 p where e.deptno = p.deptno and e.dname = a order by 1,empno)e limit 1) then
set msg = concat(6,'name',a,'sal',c);
else
set msg = concat(msg,'error');
end if;
return msg;
end;
