return concat(a,(select job from t2 where ename = a),1);
elseif b > 10 and a not in (select e.ename from t2 e,t1 p where e.deptno = p.deptno and p.loc = 'NEW YORK' and e.sal > 2000) then
return concat(a,(select job from t2 where ename = a),2);
else
return concat(a,(select job from t2 where ename = a),3);
end if;
end;
