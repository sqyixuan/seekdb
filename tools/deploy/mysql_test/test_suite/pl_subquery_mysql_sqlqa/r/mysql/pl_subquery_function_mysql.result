带参数的自定义函数if表达式加any\all\some子查询
drop function if exists t_fun;//
create function t_fun(a int)
returns int
begin
if a > all(select distinct deptno from t2 where job in ('ANALYST','SALESMAN')) then
return a + 10;
elseif a > any(select distinct deptno from t2 where job in ('ANALYST','SALESMAN')) then
return a + 20;
elseif a > some(select distinct deptno from t2 where job in ('ANALYST','SALESMAN')) then
return a + 30;
else 
return a;
end if;
end;
//
select t_fun(20);
//
t_fun(20)
20
select t_fun(30);
//
t_fun(30)
50
select t_fun(40);
//
t_fun(40)
50
drop function if exists t_fun;//
create function t_fun(a int)
returns int 
begin
if a > 40 and a > all(select distinct deptno from t2 where job in ('ANALYST','SALESMAN')) then
return a + 15;
elseif a > 30 and a > any(select distinct deptno from t2 where job in ('ANALYST','SALESMAN')) then
return a + 20;
elseif a < 40 and a > some(select distinct deptno from t2 where job in ('ANALYST','SALESMAN')) then
return a + 25;
else 
return a;
end if;
end;
