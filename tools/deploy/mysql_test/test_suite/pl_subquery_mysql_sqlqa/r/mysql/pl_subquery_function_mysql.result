#子查询嵌套过滤谓词
drop function t_fun;//
create function t_fun(a varchar(20),b int,c int)
returns varchar(50)
begin
declare msg varchar(50);
set msg = '';
if b = 10 and a in (select p.ename from t1 e,t2 p where e.deptno = p.deptno and e.loc in ('DALLAS','CHICAGO') and p.sal > c) then
set msg = concat('name:',a,'编号:',b,'dname:',(select e.dname from t1 e,t2 p where e.deptno = p.deptno and p.ename = a),'低');
elseif b = 20 and a not in (select p.ename from t1 e left join t2 p on e.deptno = p.deptno where e.dname not in ('ACCOUNTING','OPERATIONS') and p.sal > c) then
set msg = concat('name:',a,'编号:',b,'dname:',(select e.dname from t1 e,t2 p where e.deptno = p.deptno and p.ename = a),'一般');
elseif b = 30 and exists (select * from t1 e,t2 p where e.deptno = p.deptno and p.ename = a and p.sal > c) then
set msg = concat('name:',a,'编号:',b,'dname:',(select e.dname from t1 e,t2 p where e.deptno = p.deptno and p.ename = a),'中');
elseif b = 40 and not exists (select * from t1 e left join t2 p on e.deptno = p.deptno where p.ename = a and p.sal > c) then
set msg = concat('name:',a,'编号:',b,'dname:',(select e.dname from t1 e,t2 p where e.deptno = p.deptno and p.ename = a),'高');
else 
set msg = concat('name:',a,'编号:',b,' ','error');
end if;
return msg;
end;
//
select t_fun('WARD',10,1000);//
t_fun('WARD',10,1000)
name:WARD编号:10dname:SALES低
select t_fun('KING',20,2000);//
t_fun('KING',20,2000)
name:KING编号:20dname:ACCOUNTING一般
select t_fun('BLAKE',30,2000);//
t_fun('BLAKE',30,2000)
name:BLAKE编号:30dname:SALES中
select t_fun('JONES',40,3000);//
t_fun('JONES',40,3000)
name:JONES编号:40dname:RESEARCH高
select t_fun('BLAKE',40,700);//
t_fun('BLAKE',40,700)
name:BLAKE编号:40 error
select t_fun('KOBE',50,2000);//
t_fun('KOBE',50,2000)
name:KOBE编号:50 error
drop function t_fun;//
create function t_fun(a varchar(20),b int,c int)
returns varchar(50)
begin
declare msg varchar(50);
set msg = '';
if b = 10 and a in (select p.ename from t1 e,t2 p where e.deptno = p.deptno and e.loc in ('DALLAS','CHICAGO') and p.sal > c) then
set msg = 1;
elseif b = 20 and a not in (select p.ename from t1 e left join t2 p on e.deptno = p.deptno where e.dname not in ('ACCOUNTING','OPERATIONS') and p.sal > c) then
set msg = 2;
elseif b = 30 and exists (select * from t1 e,t2 p where e.deptno = p.deptno and p.ename = a and p.sal > c) then
set msg = 3;
elseif b = 40 and not exists (select * from t1 e left join t2 p on e.deptno = p.deptno where p.ename = a and p.sal > c) then
set msg = 4;
else 
set msg = 5;
end if;
return msg;
end;
