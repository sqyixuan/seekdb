drop function t_fun;//
create function t_fun(a varchar(20), b int,c int)
returns varchar(20)
begin
declare msg varchar(20);
set msg = '';
if b = 10 and exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where p.ename = a and p.sal > c) then 
set msg = concat('编码',b,' ','姓名',a,' ','低');
elseif b = 20 and c in (select p.sal from t1 e right join t2 p on e.deptno = p.deptno  where p.ename = a union all select p.sal from t1 e right join t2 p on e.deptno = p.deptno where p.ename = a) then
set msg = concat('编码',b,' ','姓名',a,' ','中');
elseif b = 30 and c > all (select p.sal from t1 e natural join t2 p  where p.ename = a union select p.sal from t1 e natural join t2 p  where p.ename = a) then
set msg = concat('编码',b,' ','姓名',a,' ','高');
elseif b = 40 and c > any(select e.sal from t2 e,t2 p where e.mgr = p.empno and p.ename = a) then
set msg = concat('编码',b,' ','姓名',a,' ','很高');
else 
set msg = concat(msg,'姓名编号错误');
end if;
return msg;
end;
