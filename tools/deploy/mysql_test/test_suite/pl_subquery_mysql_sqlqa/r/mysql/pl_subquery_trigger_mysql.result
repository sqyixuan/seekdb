Warnings:
Note	1360	Trigger does not exist
create trigger p1 after insert on t1 for each row
begin
case when new.deptno = 50 and exists(select * from t2 where sal > 3000) then
update t2 set  job = 'A' where sal > 4000;
when new.deptno = 60 and exists(select * from t2 where sal = 3000) then 
update t2 set job = 'B' where sal = 3000;
when new.deptno = 70 and exists(select * from t2 where sal < 3000) then 
update t2 set job = 'C' where sal < 3000;
else 
update t2 set job = 'B+' where sal between 3001 and 4001;
end case;
end;
