begin
declare duplicatekey condition for sqlstate '23000';
declare continue handler for duplicatekey 
begin 
declare b int; 
select sal from t2 where job = 'CLERK' and sal < 1000 and comm > 0 into b;
if b > 500 and exists(select * from t2 where sal = b and deptno = new.deptno) then
insert into t2 values (1,'MILLER','CLERK',7782,'1982-1-23',b,729,10); 
elseif b = 500 and exists(select * from t2 where sal = b and deptno = new.deptno) then
insert into t2 values (2,'MILLER','CLERK',7782,'1982-1-23',b,729,10); 
else
insert into t2 values (3,'MILLER','CLERK',7782,'1982-1-23',b,729,10); 
end if;
end;
