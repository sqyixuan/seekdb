DROP PROCEDURE p_test01;
CREATE  PROCEDURE p_test01()
begin
declare i int;
set i=1;
while i<= (with temp as (select * from t3) select id from temp) DO
update t1 set name = ((select name from t2 where id =10)) where t1.id =20;
set i = i + 1;
end WHILE;
end;
//
call p_test01();
if表达式
drop table t1;
create table t1( id int,name varchar(30),t date);
insert into t1 values(1,'test01','2020-10-10');
insert into t1 values(10,'test02','2020-10-11');
insert into t1 values(20,'test03','2020-10-12');
drop table t2;
create table t2( id int,name varchar(30),t date);
insert into t2 values(1,'test01','2020-10-10');
insert into t2 values(10,'test02','2020-10-20');
insert into t2 values(20,'test03','2021-03-04');
insert into t2 values(1,'test04','2015-04-15');
insert into t2 values(20,'test03',null);
drop table t3;
create table t3( id int,name varchar(30));
insert into t3 values(1,'test01');
DROP PROCEDURE p_test01;
CREATE  PROCEDURE p_test01(in a int)
begin
declare i int;
declare b int;
set i=10;
select a into b;
if i = a then
select b;
insert into t1 values(a,(select name from t3),(select date('2011-11-1')));
update t1 set id=a,name=(select 'test10'),t=(select t from t2 where t='2015-04-15') where id in(a);
elseif i >a then
select (b+1);
insert into t1 values((a+(select 1)),(select name from t3),(select date('2011-11-2')));
update t1 set id=a,name=(select 'test11'),t=(select t from t2 where t='2015-04-15') where id in(a);
else 
select (b+2);
insert into t1 values(a+2,(select name from t3),(select date('2011-11-3')));
update t1 set id=a,name=(select 'test12'),t=(select t from t2 where t='2015-04-15') where id in(a);
end if;
end;
//
CALL p_test01((select 10));
b
10
select * from t1 order by id;
id	name	t
1	test01	2020-10-10
10	test10	2015-04-15
