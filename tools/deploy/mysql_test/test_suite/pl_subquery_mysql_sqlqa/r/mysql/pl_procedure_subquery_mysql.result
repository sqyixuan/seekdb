drop database IF EXISTS oblrp;
create database oblrp;
use oblrp;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
ob_pl_subquery_2_3 存储过程表达式支持子查询
drop table t1;
create table t1( id int,name varchar(30),t date);
insert into t1 values(1,'test01','2020-10-10');
insert into t1 values(10,'test02','2020-10-11');
insert into t1 values(20,'test03','2020-10-12');
drop table t2;
create table t2( id int,name varchar(30));
insert into t2 values(1,'test01');
insert into t2 values(10,'test02');
insert into t2 values(20,'test03');
insert into t2 values(1,'test04');
insert into t2 values(20,'test03');
drop table t3;
create table t3( id int,name varchar(30));
insert into t3 values(1,'test01');
drop table t4;
create table t4( id int);
insert into t4 values(2);
ob_pl_subquery_2_3_1 参数输入in
DROP PROCEDURE p_test01;
CREATE  PROCEDURE p_test01(in a int)
begin
declare i int;
declare b int;
declare c int;
set c=a;
set i=1;
set @d=a;
select a into b;
while i <= a DO
insert into t1(id) values(a),(b),(c),(@d);
set i = i + 1;
end WHILE;
end;
//
CALL p_test01((select 10));
select * from t1 order by id;
id	name	t
