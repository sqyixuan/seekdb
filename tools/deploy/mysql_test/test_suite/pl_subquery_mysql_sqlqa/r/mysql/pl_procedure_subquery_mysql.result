drop table t1;
create table t1( id int,name varchar(30),t date);
insert into t1 values(1,'test01','2020-10-10');
insert into t1 values(10,'test02','2020-10-11');
insert into t1 values(20,'test03','2020-10-12');
drop table t2;
create table t2( id int,name varchar(30));
insert into t2 values(1,'test01');
insert into t2 values(10,'test02');
insert into t2 values(20,'test03');
insert into t2 values(1,'test04');
insert into t2 values(20,'test03');
drop table t3;
create table t3( id int,name varchar(30));
insert into t3 values(1,'test01');
DROP PROCEDURE p_test01;
CREATE  PROCEDURE p_test01()
begin
declare i int;
set i=1;
while (select 5 from (select * from t3) a)>=i DO
update t1 set name = ((select name from t2 where id =10)) where t1.id =20;
set i = i + 1;
end WHILE;
end;
//
输出的信息数量ob和mysql不一样
call p_test01();
select * from t1 order by id;
id	name	t
1	test01	2020-10-10
10	test02	2020-10-11
20	test02	2020-10-12
DROP PROCEDURE p_test01;
CREATE  PROCEDURE p_test01()
begin
declare i int;
declare c varchar(20);
set i=1;
set @b=(select id from t3);
set c=(select id from t3 where exists(select id from t2));
while i>=(select id from t3 where exists(select id from t2)) and i<=10 DO
select @b;
select (select 'xiaolai');
set i = i + (select 1);
end WHILE;
select c;
select (select date('2010-12-1'));
insert into t1 values((select 1),(select UPPER('test')),(select date('2011-11-1')));
update t1 set id=(select id from t3),name=(select name from t2 where id=10),t=(select date('2010-11-11'));
end;
