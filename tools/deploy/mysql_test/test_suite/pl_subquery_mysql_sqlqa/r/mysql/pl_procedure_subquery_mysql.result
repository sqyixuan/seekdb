DROP PROCEDURE p_test01;
CREATE  PROCEDURE p_test01(in a int,in b int,out c int,out d int)
begin
declare i int default (select id from t3);
declare aa int;
declare bb int;
select i;
select (select id from t3),a into c,d;
while i <=b and not exists(select * from t3 where id =2)DO
if a = (select(select 5)) or b=(select 6) then
insert into t1(id) values(a);
update t1 set id =(a) where id =1;
elseif a>(select(select 5)) and not exists(select * from t3 where id =2) then
insert into t1(id) values(a+1);
update t1 set id=(a+1) where id =1;
select c;
else
insert into t1(id) values(a+2);
update t1 set id =(a+2) where id =1;
select d;
end if;
set i = i + 1;
end WHILE;
end;
