DROP PROCEDURE p_test01;
CREATE  PROCEDURE p_test01()
begin
declare i int;
set i=1;
while i<= (select id 
from t2) DO
update t1 set name = ((select name from t2 where id =10)) where t1.id =20;
set i = i + 1;
end WHILE;
end;
//
call p_test01();
ERROR 21000: Subquery returns more than 1 row
