	declare done int default 0 ;
	declare mc cursor for  select p.ename,e.loc,p.sal from t1 e inner join t2 p on e.deptno = p.deptno order by 1,2,3;
	declare continue handler for not found set done = 1;	
    open mc;
	loop_label:loop 
	set msg = '';
	fetch mc into b,c,a;
	if done = 1 then
	leave loop_label;
    end if;
	case when (length(c) = 6) and exists(select * from t1 e left join t2 p on e.deptno = p.deptno where p.sal >= any(select sal from t2 where sal = a and ename = b) and e.loc = c ) then
	set msg = concat(a,' ',b,' ','低');
	select msg;
	when (length(c) = 7) and exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where  p.sal <= some(select sal from t2 where sal = a and ename = b) and e.loc = c) then
	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	when (length(c) = 8) and exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where p.sal != all(select sal from t2 where sal = a and ename = b) and e.loc = c ) then
	set msg = concat(a,' ',b,' ','中');
	select msg;	
	else
	set msg = concat(msg,b,'error');
	select msg;
	end case;
	end loop;
	close mc;   
end;
//


call p1();//




