create procedure p1()
begin
	declare a int;
	declare b varchar(50) character set utf8;
	declare c varchar(50) character set utf8;
	declare msg varchar(50) character set utf8;
	declare done int default 0 ;
	declare mc cursor for  select p.ename,e.loc,p.sal from t1 e left join t2 p on e.deptno = p.deptno order by 1,2,3;
	declare continue handler for not found set done = 1;	
    open mc;
	loop_label:loop 
	set msg = '';
	fetch mc into b,c,a;
	if (length(c) = 6) and not exists(select * from t1 e left join t2 p on e.deptno = p.deptno where p.sal = a and p.ename = b and e.loc = c and p.mgr is null and p.job is not null) and done != 1 then
	set msg = concat(a,' ',b,' ','低');
	select msg;
	elseif (length(c) = 7) and exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where p.sal = a and p.ename = b and e.loc != (select * from (select loc from t1 where loc != c order by 1)e limit 1))and done != 1 then
	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	elseif (length(c) = 8) and exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where p.sal = all(select sal from t2 where sal = a) and p.ename = b and e.loc = c ) and done != 1 then
	set msg = concat(a,' ',b,' ','中');
	select msg;	
	else
	set msg = concat(msg,b,'error');
	select msg;
	if done = 1 then
	leave loop_label;
	end if;
    end if;
	end loop;
	close mc;   
end;
