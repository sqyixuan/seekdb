	case when (c = 'CLERK') and exists (select * from t2 where ename = b and job = c)  then
	set msg = concat((select b),' ',(select a),' ','低');
	select msg;
	when (c = 'SALESMAN') and exists (select * from t2 where ename = b and job = c)  then
	set msg = concat((select b),' ',(select a),' ','一般');
	select msg;
	when (c = 'MANAGER') and exists (select * from t2 where ename = b and job = c) then
	set msg = concat((select b),' ',(select a),' ','中');
	select msg;
	when (c = 'ANALYST') and exists (select * from t2 where ename = b and job = c)then
	set msg = concat((select b),' ',(select a),' ','高');
	select msg;
	when (c = 'PRESIDENT') and exists (select * from t2 where ename = b and job = c)  then
	set msg = concat((select b),' ',(select a),' ','很高');
	select msg;
	else 
	set msg = concat(msg,b,'error');
	select msg;
	end case;
	end loop;
	close mc;
end;
