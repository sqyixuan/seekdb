	declare done int default 0 ;
	declare mc cursor for  select p.ename,e.loc,p.sal from t1 e left join t2 p on e.deptno = p.deptno order by 1,2,3;
	declare continue handler for not found set done = 1;	
    open mc;
	loop_label:loop 
	set msg = '';
	fetch mc into b,c,a;
	if ((length(c) = 6) or not exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where p.sal = a and p.ename not in (select ename from t2 where ename = b) and e.loc in (select loc from t1 where loc != c))) and done != 1 then
	set msg = concat(a,' ',b,' ','低');
	select msg;
	elseif ((length(c) = 7) or not exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where p.sal = a and not exists(select * from t2 where ename = b) and exists(select * from t1 where loc = c ))) and done != 1 then
