create procedure p1()
begin
	declare a int;
	declare b varchar(50) character set utf8;
	declare c varchar(50) character set utf8;
	declare msg varchar(50) character set utf8;
	declare done int default 0 ;
	declare mc cursor for  select p.ename,e.loc,p.sal from t1 e inner join t2 p on e.deptno = p.deptno order by 1,2,3;
	declare continue handler for not found set done = 1;	
    open mc;
	loop_label:loop 
	set msg = '';
	fetch mc into b,c,a;
	case when (length(c) = 6) and a in (select p.sal from t1 e,t2 p where e.deptno = p.deptno and e.loc = c) and done != 1 then
	set msg = concat(a,' ',b,' ','低');
	select msg;
	when (length(c) = 7) and a not in (select p.sal from t1 e,t2 p where e.deptno = p.deptno and e.loc != c) and done != 1 then
	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	when (length(c) = 8) and a between (select min(p.sal) from t1 e,t2 p where e.deptno = p.deptno and e.loc = c) and  (select max(p.sal) from t1 e,t2 p where e.deptno = p.deptno and e.loc = c) and done != 1 then
	set msg = concat(a,' ',b,' ','中');
	select msg;	
	else
	set msg = concat(msg,b,'error');
	select msg;
	if done = 1 then
	leave loop_label;
    end if;
	end case;
	end loop;
	close mc;   
end;
//

call p1();//


drop procedure if exists p1;//

create procedure p1()
begin
	declare a int;
	declare b varchar(50) character set utf8;
	declare c varchar(50) character set utf8;
	declare msg varchar(50) character set utf8;
	declare done int default 0 ;
	declare mc cursor for  select p.ename,e.loc,p.sal from t1 e inner join t2 p on e.deptno = p.deptno order by 1,2,3;
	declare continue handler for not found set done = 1;	
    open mc;
	loop_label:loop 
	set msg = '';
	fetch mc into b,c,a;
	if done = 1 then
	leave loop_label;
    end if;
	case when ((length(c) = 6) and (select e.loc from t1 e, t2 p where e.deptno = p.deptno and p.ename = b ) is not null or (select p.mgr from t1 e,t2 p where e.deptno = p.deptno and p.sal = a) is null)then
	set msg = concat(a,' ',b,' ','低');
	select msg;
	when ((length(c) = 7) and (select e.loc from t1 e,t2 p where e.deptno = p.deptno and p.sal = a) like concat('%',c,'%') and (select e.loc from t1 e,t2 p where e.deptno = p.deptno and p.ename = b limit 1) not like concat('%',c,'%')) then
	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	when ((length(c) = 8) and a >= all(select sal from t2 where ename = b) and a >= any(select p.sal from t1 e,t2 p where e.deptno = p.deptno and e.loc = c)) then
	set msg = concat(a,' ',b,' ','中');
	select msg;	
	else
	set msg = concat(msg,b,'error');
	select msg;
	end case;
	end loop;
	close mc;   
end;
//

call p1();//


