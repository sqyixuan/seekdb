	fetch mc into b,c,a;
	if (length(c) = 6) and exists(select * from t1 e natural join t2 p  where p.sal = a and p.ename = b and e.loc = c) and done != 1 then
	set msg = concat(a,' ',b,' ','低');
	select msg;
	elseif (length(c) = 7) and exists(select * from t1 e cross join t2 p where p.sal = a and p.ename = b and e.loc = c) and done != 1 then
	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	elseif (length(c) = 8) and exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where p.sal = a and p.ename = b and e.loc = c union all select * from t1 e left join t2 p on e.deptno = p.deptno where p.sal = a and p.ename = b and e.loc = c) and done != 1 then
	set msg = concat(a,' ',b,' ','中');
	select msg;	
	else
	set msg = concat(msg,b,'error');
	select msg;
	if done = 1 then
	leave loop_label;
