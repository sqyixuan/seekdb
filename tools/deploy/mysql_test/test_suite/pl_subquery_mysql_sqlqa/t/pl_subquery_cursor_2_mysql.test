	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	when ((length(c) = 8) or exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where p.sal between a and 5000 and p.ename = b and e.loc = c )) and done != 1 then
	set msg = concat(a,' ',b,' ','中');
	select msg;	
	else
	set msg = concat(msg,b,'error');
	select msg;
	if done = 1 then
	leave loop_label;
    end if;
	end case;
	end loop;
	close mc;   
end;
