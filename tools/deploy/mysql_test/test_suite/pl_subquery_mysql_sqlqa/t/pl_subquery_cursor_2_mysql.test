	open mc;
	loop_label:loop 
	set msg = '';
	fetch mc into b,c,a;
	case when (length(c) = 5) and a >= (select avg(sal) from t2 where job = c group by b) and done != 1 then
	set msg = concat(a,' ',b,' ','低');
	select msg;
	when (length(c) = 8) and a <= some(select max(sal) from t2 where job = c group by b having max(sal) > a) and done != 1 then
	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	when (length(c) = 7) and not exists (select sal from t2 where job like concat('%',c,'%') and ename like concat('%',b,'%')) and done != 1 then
	set msg = concat(a,' ',b,' ','中');
	select msg;	
	else
	set msg = concat(msg,b,'error');
	select msg;
	if done = 1 then
	leave loop_label;
    end if;
	end case;
	end loop;
	close mc;
end;
