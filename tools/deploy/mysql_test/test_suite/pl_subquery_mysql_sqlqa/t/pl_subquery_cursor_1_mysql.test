	set msg = concat(a,' ',b,' ',c,'高');
	select msg;
	elseif i between 31 and 40 and exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where p.ename = b and e.loc = c and p.sal = a) then
	set msg = concat(a,' ',b,' ',c,'超');
	select msg;
	else
	set msg = concat(msg,b,'error');
	select msg;
	end if;
	end if;
	end while;
	close mc;
end;
