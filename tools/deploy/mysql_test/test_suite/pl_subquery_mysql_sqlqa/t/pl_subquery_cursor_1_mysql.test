drop procedure if exists p1;//
create procedure p1()
begin
	declare a int;
	declare b varchar(50) character set utf8;
	declare c varchar(50) character set utf8;
	declare msg varchar(50) character set utf8;
	declare done int default 0 ;
	declare mc cursor for  select ename,job,sal from t2 order by 1,2,3;
	declare continue handler for sqlstate '02000' set done=1;	
	open mc;
	repeat
	set msg = '';
	fetch mc into b,c,a;
	if (length(c) = 5) and a >= all(select sal from t2 where job = c and ename = b) then
	set msg = concat(a,' ',b,' ','低');
	select msg;
	elseif (length(c) = 8) and a >=  some(select sal from t2 where job = c and ename = b) then
	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	elseif (length(c) = 7) and a in (select sal from t2 where job like concat('%',c,'%') and ename like concat('%',b,'%')) then
	set msg = concat(a,' ',b,' ','中');
	select msg;	
	else
	set msg = concat(msg,b,'error');
	select msg;
    end if;
	until  done end repeat;
	close mc;
end;
//

call p1();//



drop procedure if exists p1;//
create procedure p1()
begin
	declare a int;
	declare b varchar(50) character set utf8;
	declare c varchar(50) character set utf8;
	declare msg varchar(50) character set utf8;
	declare done int default 0 ;
	declare mc cursor for  select ename,job,sal from t2 order by 1,2,3;
	declare continue handler for sqlstate '02000' set done=1;	
	open mc;
	repeat
	set msg = '';
	fetch mc into b,c,a;
	if (length(c) = 5) and a >= (select avg(sal) from t2 where job = c group by b)  then
	set msg = concat(a,' ',b,' ','低');
	select msg;
	elseif (length(c) = 8) and a <= some(select max(sal) from t2 where job = c group by b having max(sal) > a) then
	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	elseif (length(c) = 7) and not exists (select sal from t2 where job like concat('%',c,'%') and ename like concat('%',b,'%')) then
	set msg = concat(a,' ',b,' ','中');
	select msg;	
	else
	set msg = concat(msg,b,'error');
	select msg;
    end if;
	until done end repeat;
	close mc;
end;
//

