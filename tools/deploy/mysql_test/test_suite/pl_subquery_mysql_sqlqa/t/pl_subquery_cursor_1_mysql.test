--echo ##动态执行
delimiter //;
drop procedure if exists p1;//
create procedure p1(in i int)
begin
	declare a int;
	declare b varchar(50) character set utf8;
	declare c varchar(50) character set utf8;
	declare msg varchar(50) character set utf8;
	declare done int default 0;
	declare mc cursor for select p.ename,e.loc,p.sal from t1 e left join t2 p on e.deptno = p.deptno where p.sal > 3000 and exists(select * from t2 where empno = (select mgr from t2 where ename = 'FORD'));
	declare continue handler for not found set done = 1;
	open mc;
	while done != 1 do
	fetch mc into b,c,a;
	if done != 1 then 
	if i = 10 and exists (select * from t2 where deptno = i and ename = b and sal = a) then
	set @d = 'select p.ename,e.loc,p.sal from t1 e,t2 p where e.deptno = p.deptno and p.ename = ? and e.loc = ? and p.sal = ?';
	set @b = b;
	set @a = a;
	set @c = c;
	prepare stmt from @d;
	execute stmt using @b,@c,@a;
	deallocate prepare stmt;
	elseif i = 20 and exists(select * from t1 where deptno = i and loc = c) then
	set @q = 'insert into t1(dname,loc) values(?,?)';
	set @b = b;
	set @c = c;
	prepare stmt from @q;
	execute stmt using @b,@c;
	deallocate prepare stmt;
	elseif i = 30 and exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where e.loc = c and p.sal = a and p.ename = b) then
	set @w = 'delete from t2 where ename = ? and sal = ?';
	set @b = b;
	set @a = a;
	prepare stmt from @w;
	execute stmt using @b,@a;
	deallocate prepare stmt;
	else
	set @q = 'delete from t1 where loc = ?';
	set @c = c;
	prepare stmt from @q;
	execute stmt using @c;
	deallocate prepare stmt;
	end if;
	end if;
	end while;
	close mc;
end;
//

call p1(10);//
call p1(20);//
call p1(30);//
call p1(40);//
select * from t1 order by 1,2,3;//
select * from t2 order by 1,2,3;//

delimiter ;//

