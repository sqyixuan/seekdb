	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	elseif (length(c) = 8) and a between (select min(p.sal) from t1 e,t2 p where e.deptno = p.deptno and e.loc = c) and  (select max(p.sal) from t1 e,t2 p where e.deptno = p.deptno and e.loc = c) and done != 1 then
	set msg = concat(a,' ',b,' ','中');
