drop procedure if exists p1;//
create procedure p1(in i varchar(20))
begin
	declare a int;
	declare b varchar(50) character set utf8;
	declare c varchar(50) character set utf8;
	declare msg varchar(50) character set utf8;
	declare done int default 0;
	declare mc cursor for select p.ename,e.loc,p.sal from t1 e left join t2 p on e.deptno = p.deptno where exists(select * from t2 where empno = (select mgr from t2 where ename = 'FORD'));
	declare continue handler for not found set done = 1;	
	open mc;
	while done != 1 do
	fetch mc into b,c,a;
	set msg = '';
	if done != 1 and i in (c) then
	if a <= 2000 and exists (select * from t1 e inner join t2 p on e.deptno = p.deptno where e.loc = c and p.ename = b and p.sal = a) then
	set msg = concat(a,' ',b,' ',c,'低');
	select msg;
	elseif a <= 3000 and exists (select * from t1 e inner join t2 p on e.deptno = p.deptno where e.loc = c and p.ename = b and p.sal = a) then
	set msg = concat(a,' ',b,' ',c,'中');
	select msg;
	elseif a <= 4000 and exists (select * from t1 e inner join t2 p on e.deptno = p.deptno where e.loc = c and p.ename = b and p.sal = a) then
	set msg = concat(a,' ',b,' ',c,'高');
	select msg;
	else 
	set msg = concat(a,' ',b,' ',c,'超');
	select msg;
	end if;
	end if;
	end while;
	close mc;
end;
