	declare continue handler for sqlstate '02000' set done=1;
	open mc;
	repeat
	set msg = '';
	fetch mc into b,c,a;
	case when (length(c) = 5) and a >= (select avg(sal) from t2 where job = c group by b) then
	set msg = concat(a,' ',b,' ','低');
	select msg;
	when (length(c) = 8) and a <= some(select max(sal) from t2 where job = c group by b having max(sal) > a)  then
	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	when (length(c) = 7) and not exists (select sal from t2 where job like concat('%',c,'%') and ename like concat('%',b,'%')) then
	set msg = concat(a,' ',b,' ','中');
	select msg;	
	else
	set msg = concat(msg,b,'error');
	select msg;
	end case;
	until  done = 1 end repeat;
	close mc;
end;
