	case when (length(c) = 6) or not exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where p.sal = a and p.ename not in (select ename from t2 where ename = b) and e.loc in (select loc from t1 where loc != c)) then
	set msg = concat(a,' ',b,' ','低');
	select msg;
	when (length(c) = 7) or exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where p.sal = a and not exists(select * from t2 where ename = b) and exists(select * from t1 where loc = c )) then
	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	when (length(c) = 8) or exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where p.sal between a and 5000 and p.ename = b and e.loc = c ) then
	set msg = concat(a,' ',b,' ','中');
	select msg;	
	else
	set msg = concat(msg,b,'error');
	select msg;
	end case;
	until  done end repeat;
	close mc;   
end;
