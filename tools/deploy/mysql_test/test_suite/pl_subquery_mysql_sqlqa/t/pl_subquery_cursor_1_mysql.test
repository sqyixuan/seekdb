	declare continue handler for sqlstate '02000' set done=1;
    open mc;
	repeat
	set msg = '';
	fetch mc into b,c,a;
	case when (length(c) = 6) and a in (select p.sal from t1 e,t2 p where e.deptno = p.deptno and e.loc = c) then
	set msg = concat(a,' ',b,' ','低');
	select msg;
	when (length(c) = 7) and a not in (select p.sal from t1 e,t2 p where e.deptno = p.deptno and e.loc != c) then
	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	when (length(c) = 8) and a between (select min(p.sal) from t1 e,t2 p where e.deptno = p.deptno and e.loc = c) and  (select max(p.sal) from t1 e,t2 p where e.deptno = p.deptno and e.loc = c)then
	set msg = concat(a,' ',b,' ','中');
	select msg;	
	else
	set msg = concat(msg,b,'error');
	select msg;
	end case;
	until  done  end repeat;
	close mc;   
end;
