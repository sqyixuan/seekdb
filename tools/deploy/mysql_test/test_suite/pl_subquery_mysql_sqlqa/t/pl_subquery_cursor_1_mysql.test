--echo ob_pl_subquery_2_4
--echo #游标 repeat if 循环

delimiter //;
drop procedure if exists p1;//
create procedure p1()
begin
	declare a int;
	declare b varchar(50) character set utf8;
	declare msg varchar(50) character set utf8;
	declare done int default 0;
	declare mc cursor for select ename,sal from t2 where sal > 2000;
	declare continue handler for not found set done = 1;	
	open mc;
	repeat
	set msg = '';
	fetch mc into b,a;
	if (length(b)) = 4 and exists (select * from t2 where ename = b and sal = a) and done != 1 then
	set msg = concat((select b),' ',(select a),' ','success');
	select msg;
	else 
	set msg = concat(msg,b,'error');
	select msg; 
	end if;
	until done = 1
	end repeat;
	close mc;
end;
//

call p1();//

drop procedure if exists p1;//
create procedure p1()
begin
	declare a int;
	declare b varchar(50) character set utf8;
	declare msg varchar(50) character set utf8;
	declare done int default 0;
	declare mc cursor for select ename,sal from t2 where sal > 2000;
	declare continue handler for sqlstate '02000' set done=1;	
	open mc;
	repeat
	set msg = '';
	fetch mc into b,a;
	if (length(b)) = 4 and exists (select * from t2 where ename = b and sal = a)  then
	set msg = concat((select b),' ',(select a),' ','success');
	select msg;
	else 
	set msg = concat(msg,b,'error');
	select msg; 
	end if;
	until done end repeat;
	close mc;
end;
//

call p1();//




drop procedure if exists p1;//
create procedure p1()
begin
	declare a int;
	declare b varchar(50) character set utf8;
	declare c varchar(50) character set utf8;
	declare msg varchar(50) character set utf8;
	declare done int default 0;
	declare mc cursor for select ename,sal,job from t1 e inner join t2 p on e.deptno = p.deptno order by 1,2,3;
	declare continue handler for sqlstate '02000' set done=1;	
	open mc;
	repeat
	set msg = '';
	fetch mc into b,a,c;
	if (c = 'CLERK') and exists (select * from t2 where ename = b and job = c) then
	set msg = concat((select b),' ',(select a),' ','低');
	select msg;
	elseif (c = 'SALESMAN') and exists (select * from t2 where ename = b and job = c) then
	set msg = concat((select b),' ',(select a),' ','一般');
	select msg;
	elseif (c = 'MANAGER') and exists (select * from t2 where ename = b and job = c) then
	set msg = concat((select b),' ',(select a),' ','中');
	select msg;
	elseif (c = 'ANALYST') and exists (select * from t2 where ename = b and job = c)  then
	set msg = concat((select b),' ',(select a),' ','高');
	select msg;
	elseif (c = 'PRESIDENT') and exists (select * from t2 where ename = b and job = c) then
	set msg = concat((select b),' ',(select a),' ','很高');
	select msg;
	else 
	set msg = concat(msg,b,'error');
	select msg;
	end if;
	until done
	end repeat;
	close mc;
end;
//

call p1();//


