--echo #连接谓词
drop procedure if exists p1;//

create procedure p1()
begin
	declare a int;
	declare b varchar(50) character set utf8;
	declare c varchar(50) character set utf8;
	declare msg varchar(50) character set utf8;
	declare done int default 0 ;
	declare mc cursor for  select p.ename,e.loc,p.sal from t1 e inner join t2 p on e.deptno = p.deptno order by 1,2,3;
    declare continue handler for not found set done = 1;	
	open mc;
	repeat
	set msg = '';
	fetch mc into b,c,a;
	if (length(c) = 6) and exists(select * from t1 e left join t2 p on e.deptno = p.deptno where p.sal = a and p.ename = b and e.loc = c)and done != 1 then
	set msg = concat(a,' ',b,' ','低');
	select msg;
	elseif (length(c) = 7) and exists(select * from t1 e right join t2 p on e.deptno = p.deptno where p.sal = a and p.ename = b and e.loc = c) and done != 1 then
	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	elseif (length(c) = 8) and exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where p.sal = a and p.ename = b and e.loc = c) and done != 1 then
	set msg = concat(a,' ',b,' ','中');
	select msg;	
	else
	set msg = concat(msg,b,'error');
	select msg;
    end if;
	until  done = 1 end repeat;
	close mc;
end;
//

call p1();//



drop procedure if exists p1;//

create procedure p1()
begin
	declare a int;
	declare b varchar(50) character set utf8;
	declare c varchar(50) character set utf8;
	declare msg varchar(50) character set utf8;
	declare done int default 0 ;
	declare mc cursor for  select p.ename,e.loc,p.sal from t1 e inner join t2 p on e.deptno = p.deptno order by 1,2,3;
    declare continue handler for not found set done = 1;	
	open mc;
	repeat
	set msg = '';
	fetch mc into b,c,a;
	if (length(c) = 6) and exists(select * from t1 e natural join t2 p  where p.sal = a and p.ename = b and e.loc = c) and done != 1 then
	set msg = concat(a,' ',b,' ','低');
	select msg;
	elseif (length(c) = 7) and exists(select * from t1 e cross join t2 p where p.sal = a and p.ename = b and e.loc = c) and done != 1 then
	set msg = concat(a,' ',b,' ','一般');
	select msg;	
	elseif (length(c) = 8) and exists(select * from t1 e inner join t2 p on e.deptno = p.deptno where p.sal = a and p.ename = b and e.loc = c union all select * from t1 e left join t2 p on e.deptno = p.deptno where p.sal = a and p.ename = b and e.loc = c) and done != 1 then
	set msg = concat(a,' ',b,' ','中');
	select msg;	
	else
	set msg = concat(msg,b,'error');
	select msg;
    end if;
	until  done = 1 end repeat;
	close mc;
end;
//

call p1();//


