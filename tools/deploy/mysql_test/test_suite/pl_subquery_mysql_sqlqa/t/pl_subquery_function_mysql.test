--echo 自定义函数if表达式加exists\not exists子查询

drop function if exists t_fun;//
create function t_fun(a int)
returns int 
begin
	if a > 10 and exists (select * from t1 e,t2 p where e.deptno = p.deptno and e.loc = 'NEW YORK' and p.sal > 2000) then 
	return a + (select sal from t2 where deptno = a);
	elseif a < 10 and not exists (select * from t1 e,t2 p where e.deptno = p.deptno and e.loc = 'NEW YORK' and p.sal > 5000) then
	return a; 
	else
	return a + (select min(sal) from t2 where deptno = a);
	end if;
end;
//

select t_fun(11);
//
select t_fun(9);
//
select t_fun(10);
//


