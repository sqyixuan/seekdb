returns int 
begin
	case when a = 10 and exists(select * from t2 where empno=(select mgr from t2 where ename='FORD')) then
	return (a + (select sal from t2 where ename = 'CLARK'));
	when a = 20 and a in (select deptno from t2 where sal > 3000) then
	return concat(a,(select sal from t2 where job = 'CLERK' and sal + comm > 2000));
	when a = 30 and a > any(select deptno from t2 where job in ('ANALYST','SALESMAN')) then
	return a and exists(select * from t2 where sal > 3999);
	else
	return a;
	end case;
end;
