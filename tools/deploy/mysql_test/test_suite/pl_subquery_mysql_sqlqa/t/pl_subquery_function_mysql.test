--echo 自定义函数if表达式加 子查询，子查询加like

drop function if exists t_fun;//
create function t_fun(a varchar(20))
returns varchar(20)
begin
	declare name varchar(20);
	set name = 'BLAKE';
	if(select ename from t2 where ename like concat('%',a,'%')) = name then
	return concat(a,name);
	else 
	return a;
	end if;
end;
//

select t_fun('b');//
select t_fun('q');//


drop function if exists t_fun;//
create function t_fun(a varchar(20),b int)
returns varchar(20)
begin
	declare name varchar(20);
	if (b < 20) and exists (select * from t1 e,t2 p where e.deptno = p.deptno and e.loc like concat('%',a,'%') and p.ename like concat('%',a,'%') ) then
	return concat(a,b);
	elseif(b > 20) and not exists(select * from t1 e,t2 p where e.deptno = p.deptno and p.deptno = b and e.loc like concat('%',a,'%')) then
	return concat(b,' ','不存在');
	else 
	return concat(a,b,'错误');
	end if;
end;
//

select t_fun('a',10);//
select t_fun('c',30);//
select t_fun('c',40);//



drop function if exists t_fun;//
create function t_fun(a varchar(20),b int)
returns varchar(20)
begin
	declare name varchar(20);
	set name = '';
	if (!(length(a) = 5)) and exists (select * from t2 where empno = b) then
	set name = concat(a,' ','error');
	elseif (length(a) = 5) and exists (select * from t2 where empno = b) then 
	set name = concat(a,(select sal from t2 where ename = a));
	else 
	set name = concat(a,'',b,' ','error');
	end if;
	return name;
end;
//

select t_fun('SMITH',7369);
//
select t_fun('SMI',7369);
//
select t_fun('SMI',736);
//


