drop function if exists t_fun;//
create function t_fun(a int)
returns int 
begin
	if exists (select * from t1 e,t2 p where e.deptno = p.deptno and e.loc = 'NEW YORK' and p.sal > a) then 
	return a + (select max(sal) from t2 where sal > a);
	elseif not exists (select * from t1 e,t2 p where e.deptno = p.deptno and e.loc = 'NEW YORK' and p.sal > a) then
	return a; 
	else
	return a + (select min(sal) from t2 where sal < a);
	end if;
end;
