--echo 带参数自定义函数if表达式加in\not in 子查询
drop function if exists t_fun;//
create function t_fun(a varchar(20))
returns varchar(20)
begin
	if a in (select ename from t2 where sal > 2600 and job in ('SALESMAN','MANAGER')) then
	return concat(a,(select job from t2 where ename = a),1);
	elseif a not in (select e.ename from t2 e,t1 p where e.deptno = p.deptno and p.loc = 'NEW YORK' and e.sal > 2000) then
	return concat(a,(select job from t2 where ename = a),2);
	else
	return concat(a,(select job from t2 where ename = a),3);
	end if;
end;
//

select t_fun('JONES');
//
select t_fun('WARD');
//
select t_fun('CLARK');
//


drop function if exists t_fun;//
create function t_fun(a varchar(20),b int)
returns varchar(20)
begin
	if b < 10 and a in (select ename from t2 where sal > 2600 and job in ('SALESMAN','MANAGER')) then
	return concat(a,(select job from t2 where ename = a),1);
	elseif b > 10 and a not in (select e.ename from t2 e,t1 p where e.deptno = p.deptno and p.loc = 'NEW YORK' and e.sal > 2000) then
	return concat(a,(select job from t2 where ename = a),2);
	else
	return concat(a,(select job from t2 where ename = a),3);
	end if;
end;
