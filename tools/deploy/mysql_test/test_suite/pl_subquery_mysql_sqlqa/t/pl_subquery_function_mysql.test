--echo #子查询嵌套过滤谓词

drop function t_fun;//
create function t_fun(a varchar(20),b int,c int)
returns varchar(50)
begin
	declare msg varchar(50);
	set msg = '';
	if b = 10 and a in (select p.ename from t1 e,t2 p where e.deptno = p.deptno and e.loc in ('DALLAS','CHICAGO') and p.sal > c) then
	set msg = concat('name:',a,'编号:',b,'dname:',(select e.dname from t1 e,t2 p where e.deptno = p.deptno and p.ename = a),'低');
	elseif b = 20 and a not in (select p.ename from t1 e left join t2 p on e.deptno = p.deptno where e.dname not in ('ACCOUNTING','OPERATIONS') and p.sal > c) then
	set msg = concat('name:',a,'编号:',b,'dname:',(select e.dname from t1 e,t2 p where e.deptno = p.deptno and p.ename = a),'一般');
	elseif b = 30 and exists (select * from t1 e,t2 p where e.deptno = p.deptno and p.ename = a and p.sal > c) then
	set msg = concat('name:',a,'编号:',b,'dname:',(select e.dname from t1 e,t2 p where e.deptno = p.deptno and p.ename = a),'中');
	elseif b = 40 and not exists (select * from t1 e left join t2 p on e.deptno = p.deptno where p.ename = a and p.sal > c) then
	set msg = concat('name:',a,'编号:',b,'dname:',(select e.dname from t1 e,t2 p where e.deptno = p.deptno and p.ename = a),'高');
	else 
	set msg = concat('name:',a,'编号:',b,' ','error');
	end if;
	return msg;
end;
//

select t_fun('WARD',10,1000);//
select t_fun('KING',20,2000);//
select t_fun('BLAKE',30,2000);//
select t_fun('JONES',40,3000);//
select t_fun('BLAKE',40,700);//
select t_fun('KOBE',50,2000);//


drop function t_fun;//
create function t_fun(a varchar(20),b int,c int)
returns varchar(50)
begin
	declare msg varchar(50);
	set msg = '';
	if b = 10 and a in (select p.ename from t1 e,t2 p where e.deptno = p.deptno and e.loc in ('DALLAS','CHICAGO') and p.sal > c) then
	set msg = 1;
	elseif b = 20 and a not in (select p.ename from t1 e left join t2 p on e.deptno = p.deptno where e.dname not in ('ACCOUNTING','OPERATIONS') and p.sal > c) then
	set msg = 2;
	elseif b = 30 and exists (select * from t1 e,t2 p where e.deptno = p.deptno and p.ename = a and p.sal > c) then
	set msg = 3;
	elseif b = 40 and not exists (select * from t1 e left join t2 p on e.deptno = p.deptno where p.ename = a and p.sal > c) then
	set msg = 4;
	else 
	set msg = 5;
	end if;
	return msg;
end;
//

select t_fun('KING',20,2000);//
select t_fun('BLAKE',30,2000);//
select t_fun('BLAKE',40,700);//




drop function t_fun;//
create function t_fun(a varchar(20),b int,c int)
returns varchar(50)
begin
	declare msg varchar(50);
	set msg = '';
	if b = 10 and c between (select sal from t2 where ename = a) and (select max(sal) from t2 where ename != a) then
	set msg = concat(1,'name',a,'sal',c);
	elseif b = 20 and c = (select sal from t2 where ename = a) then
	set msg = concat(2,'name',a,'sal',c);
	elseif b = 30 and a is not null or c is null then 
	set msg = concat(3,'name',a,'sal',c);
	elseif b = 40 and a like '%P%' and c not in (select sal from t2 where comm > 0) then
	set msg = concat(4,'name',a,'sal',c);
	elseif b = 50 and c >=all(select sal from t2 where ename = a) then
	set msg = concat(5,'name',a,'sal',c);
	elseif b = 60 and c = (select * from (select p.sal from t1 e,t2 p where e.deptno = p.deptno and e.dname = a order by 1,empno)e limit 1) then
	set msg = concat(6,'name',a,'sal',c);
	else
	set msg = concat(msg,'error');
	end if;
	return msg;
end;
//


select t_fun('WARD',10,2000);//
select t_fun('SMITH',20,800);//
select t_fun('KOBO',30,1000);//
select t_fun('KOBO',null,null);//
select t_fun('PETQ',40,3000);//
select t_fun('SCOTT',50,4721);//
select t_fun('ACCOUNTING',60,1300)//
select t_fun('QPWU',40,3010);//




drop function t_fun;//
create function t_fun(a varchar(20),b int,c int)
returns varchar(50)
begin
	declare msg varchar(50);
	set msg = '';
	if b = 10 and exists (select p.ename from t1 e,t2 p where e.deptno = p.deptno and e.loc in ('DALLAS','CHICAGO') and p.sal > c and p.ename in (a)) then
	set msg = concat('name:',a,'编号:',b,'dname:',(select e.dname from t1 e,t2 p where e.deptno = p.deptno and p.ename = a),'低');
	elseif b = 20 and exists (select p.ename from t1 e left join t2 p on e.deptno = p.deptno where e.dname not in ('ACCOUNTING','OPERATIONS') and p.sal > c and p.ename not in (a)) then
	set msg = concat('name:',a,'编号:',b,'dname:',(select e.dname from t1 e,t2 p where e.deptno = p.deptno and p.ename = a),'一般');
	elseif b = 30 and exists (select * from t1 where exists(select * from t2 where empno = (select mgr from t2 where ename = a)and sal > c) ) then
	set msg = concat('name:',a,'编号:',b,'dname:',(select e.dname from t1 e,t2 p where e.deptno = p.deptno and p.ename = a),'中');
	elseif b = 40 and exists (select * from t1 where not exists(select * from t2 where empno = (select mgr from t2 where ename = a)and sal > c)) then
	set msg = concat('name:',a,'编号:',b,'dname:',(select e.dname from t1 e,t2 p where e.deptno = p.deptno and p.ename = a),'高');
	else 
	set msg = concat('name:',a,'编号:',b,' ','error');
	end if;
	return msg;
end;
//

select t_fun('SCOTT',10,2000);//
select t_fun('KING',20,3000);//
select t_fun('FORD',30,2500);//
select t_fun('KING',40,1500);//
select t_fun('KOBE',40,2000);//
select t_fun('BLAKE',40,700);//
select t_fun('FORD',30,3000);//




drop function t_fun;//
create function t_fun(a varchar(20),b int,c int)
returns varchar(20)
begin
	declare msg varchar(20);
	set msg = '';
	if b = 10 and exists (select * from t2 where sal between 1000 and c and ename = a) then
	set msg = concat(1,'name',a,'sal',c);
	elseif b = 20 and exists (select * from t2 where ename = a and sal = c) then
	set msg = concat(2,'name',a,'sal',c);
	elseif b = 30 and exists (select * from t2 where ename = a and sal > c and mgr is null and hiredate is not null) then 
	set msg = concat(3,'name',a,'sal',c);
	elseif b = 40 and exists (select * from t1 e,t2 p where e.deptno = p.deptno and p.ename = a and e.dname like '%A%' and p.sal > c and p.job  not in ('ANALYST','PRESIDENT')) then
	set msg = concat(4,'name',a,'sal',c);
	elseif b = 50 and exists(select * from t1 e,t2 p where e.deptno = p.deptno and p.sal > all(select sal from t2 where ename = a and p.sal > c)) then
	set msg = concat(5,'name',a,'sal',c);
	elseif b = 60 and exists(select * from (select p.sal from t1 e,t2 p where e.deptno = p.deptno and p.sal != c and p.ename != a order by p.empno,1) e limit 1) then
	set msg = concat(6,'name',a,'sal',c);
	else
	set msg = concat(msg,'error');
	end if;
	return msg;
end;
//



select t_fun('WARD',10,3000);//
select t_fun('SMITH',20,800);//
select t_fun('KING',30,4900);//
select t_fun('CLARK',40,2500);//
select t_fun('SMITH',50,500);//
select t_fun('ADAMS',60,3999);//
select t_fun('CLARK',70,2500);//

delimiter ;//

drop table if exists t1;
drop table if exists t2;

