--echo # update触发器 before
delimiter //;
drop trigger if exists p1;//
create trigger p1 before update on t1 for each row
begin
	if old.loc = 'NEW YORK' and exists(select * from t2 where deptno = 10) then 
	set new.dname = 'A';
	elseif old.loc = 'DALLAS' and exists(select * from t2 where deptno = 20) then
	set new.dname = 'B';
	elseif old.loc = 'CHICAGO' and exists(select * from t2 where deptno = 30)then
	set new.dname = 'C';
	else
	set new.dname = 'D';
	end if;
end;
