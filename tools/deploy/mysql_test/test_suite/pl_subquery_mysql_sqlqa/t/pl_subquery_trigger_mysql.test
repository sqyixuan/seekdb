delimiter //;
drop trigger if exists p1;//
create trigger p1 after insert on t1 for each row
begin
	if new.loc = 'NEW YORK' and exists(select * from t2 where deptno = 10) then 
	update t2 set job = 'A' where deptno = 10;
	elseif new.loc = 'DALLAS' and exists(select * from t2 where deptno = 20) then
	update t2 set job = 'B' where deptno = 20;
	elseif new.loc = 'CHICAGO' and exists(select * from t2 where deptno = 30)then
	update t2 set job = 'C' where deptno = 30;
	else
	update t2 set job = 'D' where deptno = 40;
	end if;
end;
