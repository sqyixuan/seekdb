delimiter //;
drop trigger if exists p1;//
create trigger p1 before insert on t1 for each row 
begin
	declare a int;
	declare b varchar(50) character set utf8;
	declare c varchar(50) character set utf8;
	declare done int default 0;
	declare msg varchar(50) character set utf8;
	declare mc cursor for select p.ename,p.job,p.sal from t2 p  where p.sal > 3000 and exists(select * from t2 where empno = (select mgr from t2 where ename = 'FORD'));
	declare continue handler for not found set done = 1;
	set msg = '';
	open mc;
	while done != 1 do
	fetch mc into b,c,a;
	if done != 1 then
	case 
	when (length(c) = 6) and exists(select * from  t2 p where p.sal = a and p.ename = b) then
	insert into t2(ename,sal,deptno,job) values(b,a,1,c);
	when (length(c) = 7) and exists(select * from  t2 p where p.sal = a and p.ename = b ) then
	insert into t2(ename,sal,deptno,job) values(b,a,2,c);
	when (length(c) = 8) and exists(select * from  t2 p where p.sal = a and p.ename = b ) then
	insert into t2(ename,sal,deptno,job) values(b,a,3,c);
	else
	insert into t2(ename,sal,deptno,job) values(b,a,4,c);
	end case;
	end if;
	end while;
	close mc;
end;
//
delimiter ;//


