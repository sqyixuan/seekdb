delimiter //;
drop trigger if exists p1;//
create trigger p1 before insert on t1 for each row 
begin
	declare duplicatekey condition for sqlstate '23000';
	declare continue handler for duplicatekey 
	begin 
	declare b int; 
	select sal from t2 where job = 'CLERK' and sal < 1000 and comm > 0 into b;
	if b > 500 and exists(select * from t2 where sal = b and deptno = new.deptno) then
	insert into t2 values (1,'MILLER','CLERK',7782,'1982-1-23',b,729,10); 
	elseif b = 500 and exists(select * from t2 where sal = b and deptno = new.deptno) then
	insert into t2 values (2,'MILLER','CLERK',7782,'1982-1-23',b,729,10); 
	else
	insert into t2 values (3,'MILLER','CLERK',7782,'1982-1-23',b,729,10); 
	end if;
	end;
	if new.deptno = 10 and exists(select * from t2 where deptno = 10 and sal > 3000 ) then
	insert into t2 values (7934,'MILLER','CLERK',7782,'1982-1-23',1300,729,10);
	elseif new.deptno = 20 and exists(select * from t2 where deptno = 20 and sal = 3000) then
	insert into t2 values (7534,'SCOTT','ANALYST',7566,'1987-4-13',3000,-200,20);
	elseif new.deptno = 30 and exists(select * from t2 where deptno = 30 and sal = 1600) then
	insert into t2 values (7651,'ALLEN','SALESMAN',7698,'1981-2-20',1600,300,30);
	else
	insert into t2 values (8201,'KING','PRESIDENT',NULL,'1981-11-17',4999,-196.7,10);
	end if;
end;
//
delimiter ;//

