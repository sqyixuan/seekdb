--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user longpy@'%';
--enable_warnings
create user longpy identified by 'longpy';
grant all on *.* to longpy WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,longpy,longpy,test,$OBMYSQL_PORT);

--source mysql_test/test_suite/pl_subquery_mysql_sqlqa/t/create_partition_table.inc
--source mysql_test/test_suite/pl_subquery_mysql_sqlqa/t/pl_subquery_partition_mysql.inc

