--source mysql_test/test_suite/pl_subquery_mysql_sqlqa/t/pl_subquery_partition_mysql.inc

--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user longpy@'%' ;
--enable_warnings
