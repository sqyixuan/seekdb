#description:view、index
#author: wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--echo	#view
--echo	#view select
create  table   t1(id  int,name  char(20),a1  double,a2  double);
create view v1_test as select * from t1;
insert  into    v1_test   values(1,'aaaaaa1',-1,0.8),(1,'aaaaaa2',0.5,-0.4);
insert  into    v1_test   values(2,'bbbbbb1',pi(),0.3),(2,'bbbbbb2',asin(1),-0.7);
insert  into    v1_test   values(3,'cccccc1',5,acos(0)),(3,'cccccc2',-1.5,atan(1));
insert  into    v1_test   values(4,'dddddd1',atan(1,1),cot(1)),(4,'dddddd2',8,radians(10));
insert  into    v1_test   values(5,'eeeeee1',-10,15),(5,'eeeeee2',acos(1),degrees(-15));
insert  into    v1_test   values(6,'ffffff1',2,asin(-1)),(6,'ffffff2',radians(180),degrees(0));
select    *    from   v1_test ;

--echo	#view where
select * from v1_test where degrees(a1)>0 and degrees(a2) >1;
select * from v1_test where a1 > degrees(10) or a2 < degrees(0);

--echo	#order by
select * from v1_test order by degrees(a1) desc;
select * from v1_test order by degrees(a2) asc;
select * from v1_test where a1 > degrees(0) or a2 <degrees(0) order by degrees(a1) desc;
select * from v1_test where id >3 and a1 > degrees(-1) order by degrees(a2) asc;

--echo	#group by
select * from v1_test group by degrees(id);
select * from v1_test group by degrees(id) order by degrees(a1) desc;
select * from v1_test where a1 < degrees(2) and a2 > degrees(-2) group by degrees(id);
select * from v1_test where a1 > degrees(-1) and a2 < degrees(1) group by degrees(id) order by degrees(a2) asc;

--echo	#group by having
select * from v1_test group by degrees(id) having degrees(a1)>0;
select * from v1_test group by degrees(id) having degrees(a2)>0 order by degrees(a1) desc;
select * from v1_test where a1 < degrees(1) and a2 > degrees(-2) group by degrees(id) having degrees(a1)>0;
select * from v1_test where a1 <> degrees(0) and a2 <> degrees(0) group by degrees(id) having degrees(a2)>0 order by degrees(a2) desc;

--echo 	#case when
select id,name,a1,max(a2) ,case a2 when a2 < degrees(-1) then degrees(1) else degrees(radians(730)) end as c1 from v1_test  group  by  degrees(id)  having degrees(max(a2)) > degrees(0) order  by  degrees(id) desc;
select id,name,a1,a2, case a1 when a1> degrees(0.5) then degrees(-0.5) else degrees(radians(77)) end as c1 from v1_test  where a1 <degrees(0) and a2 > degrees(0) order by degrees(id) desc;
select id,name,a1,a2, case when a1>degrees(-0.5) and a1 <degrees(0.5) then degrees(1) else degrees(-1) end as c1 from v1_test where a1>degrees(0) and a2 < degrees(0.9) group by degrees(id) order by degrees(id) desc;

--echo	#distinct
select distinct degrees(id) from v1_test where degrees(a1) > 1;
select distinct degrees(a1) from v1_test where a1 > degrees(0) or a2 <degrees(0) order by degrees(a1) desc;

--echo 	#view insert
create  table   t2(id  int,name  char(20),a1  double,a2  double);
create  view    v2_test as select * from t2;

--echo	#单列多列
insert  into    v2_test values(1,'aa',0.1,pi());
insert  into    v2_test values(2,'bb',1.5,atan(1)),(3,'cc',3.0,-0.333);
select * from v2_test;

--echo	#insert...select
--echo	#insert...order by
insert  into    v2_test select * from v1_test order by degrees(a2) asc;
insert  into    v2_test select * from v1_test order by degrees(a1) desc;
select * from v2_test;

--echo	#insert ...group by /group by having
insert  into    v2_test  select * from v1_test group by degrees(id);
insert  into    v2_test  select * from v1_test group by degrees(id) having degrees(a1)>0;
select * from v2_test;

--echo	#insert...where
insert  into    v2_test  select * from v1_test where a1 > degrees(10) or a2 < degrees(0);
--echo  #insert...where...order by
insert  into    v2_test  select * from v1_test where id >3 and a1 > degrees(-1) order by degrees(a2) asc;
select * from v2_test;
--echo  #insert ...select...where...order by+group by
insert  into    v2_test  select * from v1_test group by degrees(id) order by degrees(a1) desc;
--echo  #insert ...select...where...order by+group by having
insert  into    v2_test  select * from v1_test where a1 <> degrees(0) and a2 <> degrees(0) group by degrees(id) having degrees(a2)>0 order by degrees(a2) desc;
select * from v2_test;
drop table t2;
drop view v2_test;

--echo  #int
create table t2(c1 int,c2 int,c3 int);
create view v2_test as select * from t2;
insert into v2_test values(degrees(0.1),degrees(-0.5),degrees(pi()));
select * from v2_test;
drop table t2;
drop view v2_test;

--echo  #float
create table t2(c1 float,c2 float,c3 float);
create view v2_test as select * from t2;
insert into v2_test values(degrees(asin(1)),degrees(20),degrees(-10));
select * from v2_test;
drop table t2;
drop view v2_test;

--echo  #double
create table t2(c1 double,c2 double,c3 double);
create view v2_test as select * from t2;
insert into v2_test values(degrees(acos(0)),degrees(5),degrees(-6));
select * from v2_test;
drop table t2;
drop view v2_test;

--echo  #char
create table t2(c1 char(30),c2 char(30),c3 char(30));
create view v2_test as select * from t2;
insert into v2_test values(degrees(atan(2)),degrees(atan(1,2)),degrees(-2));
select * from v2_test;
drop table t2;
drop view v2_test;

--echo  #varchar
create table t2(c1 varchar(60),c2 varchar(60),c3 varchar(60));
create view v2_test as select * from t2;
insert into v2_test values(degrees(cos(pi())),degrees(3.5),degrees(-4));
select * from v2_test;
drop table t2;
drop view v2_test;

--echo  #date
create table t2(c1 date,c2 date,c3 date);
create view v2_test as select * from t2;
--error 1292
insert into v2_test values(degrees(cot(111)),degrees(20),degrees(-19));
drop table t2;
drop view v2_test;

--echo  #time
create table t2(c1 time,c2 time,c3 time);
create view v2_test as select * from t2;
--error 1292
insert into v2_test values(degrees(cot(111)),degrees(20),degrees(-19));
drop table t2;
drop view v2_test;

--echo  #year
create table t2(c1 year,c2 year,c3 year);
create view v2_test as select * from t2;
##OB 1235,MYSQL执行成功,degrees函数返回值大于100 mysql报错。
## mysql support range [0,99.5) and [1900.5,2155.5);
insert into v2_test values(degrees(radians(2020)),degrees(0.1111),degrees(1.1));
drop table t2;
drop view v2_test;

--echo  #datetime
create table t2(c1 datetime,c2 datetime,c3 datetime);
create view v2_test as select * from t2;
--error 1292
insert into v2_test values(degrees(0.5),degrees(1.7),degrees(0.9));
drop table t2;
drop view v2_test;

--echo  #timestamp
create table t2(c1 timestamp,c2 timestamp,c3 timestamp);
create view v2_test as select * from t2;
--error 1292
insert into v2_test values(degrees(0.5),degrees(1.7),degrees(0.9));
drop table t2;
drop view v2_test;

--echo  #decimal
create table t2(c1 decimal(30,20),c2 decimal(30,10),c3 decimal(60,15));
create view v2_test as select * from t2;
insert into v2_test values(degrees(atan(1,1)),degrees(asin(0.5)),degrees(cot(1.1)));
select * from v2_test;
drop table t2;
drop view v2_test;

--echo  #bit
create table t2(c1 bit(64),c2 bit(64),c3 bit(64));
create view v2_test as select * from t2;
insert into v2_test values(degrees(radians(180)),degrees(-0.5),degrees(pi()));
select hex(c1),hex(c2),hex(c3) from v2_test;
drop table t2;
drop view v2_test;


--echo  # view update
--echo  #单行多行
update v1_test set a1 = degrees(pi()) where degrees(a1)<0 and a2 =0.8;
update v1_test set a1 = degrees(radians(20)) where id<2;
select * from v1_test;

--echo  #set,嵌套order 子句
update v1_test set a2 = degrees(radians(30)) order by degrees(id) desc limit 1;
select * from v1_test;

--echo  #嵌套group by + having子句
update v1_test set a1 = degrees(0) where id = (select id  from v1_test group by degrees(id) limit 1);
update v1_test set a2 = degrees(0) where id = (select id from v1_test group by degrees(id) having degrees(a2)>0 limit 1);
select * from v1_test;

--echo  #where
update v1_test set a1 = degrees(radians(1)) where  id < degrees(0.02);
--echo  #where +order by
update v1_test set id = degrees(pi()) where a1 < degrees(2) and a1 > degrees(0) order by id asc limit 1;
select * from v1_test;
--echo  #where + group by having + order by
update v1_test set a2 = degrees(0) where id = (select id from v1_test group by degrees(id) having degrees(a2)<0 limit 1);
update v1_test set a1 = degrees(radians(55)) where id = (select id from v1_test where a1 <> degrees(0) and a2 <> degrees(0) group by degrees(id) having degrees(a2)>0 order by degrees(a2) desc limit 1);
select * from v1_test;

--echo  #delete
--echo  #单行
delete from v1_test where id = degrees(radians(180));
select * from v1_test;
--echo  #多行
delete from v1_test where a1 > degrees(0) and a2 < degrees(0) limit 2;
select * from v1_test;
--echo  #where
delete from v1_test where a1 > degrees(0) and id < degrees(0.019);
select * from v1_test;
--echo  #order by
delete from v1_test where a1> degrees(0) order by degrees(a2) desc limit 2;
--echo  #group by having + order by
delete from v1_test where id =(select id from v1_test where degrees(a1) < 0 and degrees(a2) != degrees(0) group by degrees(id) order by degrees(a1)desc limit 1);
delete from v1_test;

--echo  #replace
replace into v1_test values(1,'zhangsan',degrees(0.5),degrees(pi()));
replace into v1_test values(2,'lisi',degrees(-1.5),degrees(cos(111)));
replace into v1_test(a1,a2) values(degrees(9999999999),degrees(asin(1)));
replace into v1_test(id,name,a1,a2) values(3,'wangwu',degrees(7777),degrees(acos(0)));
select * from v1_test;
drop table t1;
drop view v1_test;

--echo	#约束
create table tt1(c1 double,c2 double ,constraint w_check  check (c1 between degrees(radians(-10)) and degrees(radians(10))));
drop table tt1;
create table t1(c1 double,c2 double not null);
insert into t1 values(degrees(1),degrees(acos(1)));
insert into t1 values(degrees(asin(0)),degrees(0));
--error 1136
insert into t1 values(degrees(null));
--error 1235
alter table t1 add c3 double primary key;
update t1 set c1 = degrees(cot(1)) where c2 = degrees(0);
select * from t1;
delete from t1 where c1>degrees(0);
drop table t1;

--echo	#index
create table t1(c1 double,c2 double);
insert into t1 values (degrees(1),degrees(atan(1))),(degrees(acos(-1)),degrees(cos(1)));
create index z_index on t1(c1);
insert into t1 values(degrees(asin(1)),degrees(0));
update t1 set c1 = degrees(radians(10)) where c2 = degrees(atan(1));
select degrees(c1),degrees(c2) from t1;
delete from t1 where degrees(c1)>0;
drop table t1;

--echo	#多表查询
create  table   t1(tid  int,name  char(20),c1  double,c2  double);
insert  into    t1   values(1,'zhang1',-1,0.8),(1,'zhang2',0.5,-0.4);
insert  into    t1   values(2,'wang1',pi(),0.3),(2,'wang2',asin(1),-0.7);
insert  into    t1   values(3,'dong1',5,acos(0)),(3,'dong2',-1.5,atan(1));
insert  into    t1   values(4,'meng1',atan(1,1),cot(1)),(4,'meng2',8,radians(10));
insert  into    t1   values(5,'chen1',-10,15),(5,'chen2',acos(1),degrees(-15));
insert  into    t1   values(6,'hang1',2,asin(-1)),(6,'hang2',radians(180),degrees(0));
select * from t1;

create table t2(id int,sex char(2),a1 double,a2 double);
insert into t2 values(1,'0',acos(1),0.5),(1,'1',-0.8,asin(1));
insert into t2 values(2,'1',1.5,cos(1)),(2,'0',-2,cot(-1));
insert into t2 values(3,'0',atan(2,2),-0.9),(3,'1',radians(15),0);
select * from t2;

--echo	#inner join
--sorted_result
select * from t1 inner join t2 on t1.tid=t2.id;
--sorted_result
select * from t1 inner join t2 on t1.tid=t2.id where degrees(c1)<degrees(0) and c2!=degrees(0)order by degrees(a2) asc;
--sorted_result
select * from t1 inner join t2 on t1.tid=t2.id where degrees(c1)>degrees(-1) and degrees(c2)<degrees(1) group by degrees(c1) order by degrees(a1) desc;
--sorted_result
select * from t1 inner join t2 on t1.tid=t2.id where degrees(c2)<>degrees(0) and degrees(a2) <degrees(0) group by degrees(tid) having degrees(c2)>degrees(0);

--echo	#left join
--sorted_result
select * from t1 left join t2 on t1.tid = t2.id;
--sorted_result
select * from t1 left join t2 on t1.tid = t2.id where degrees(c2)<degrees(1) and a2<>degrees(-0.1)order by degrees(a2) asc;
--sorted_result
select * from t1 left join t2 on t1.tid = t2.id where degrees(a1)>degrees(0.111111111) and degrees(a2)>degrees(-1) group by degrees(a1) order by degrees(a2) asc ;
--sorted_result
select * from t1 left join t2 on t1.tid = t2.id where degrees(c2)>degrees(0.3216431) and degrees(a2) <degrees(0) group by degrees(tid) having degrees(c2)>degrees(0);

--echo	#right join
--sorted_result
select * from t1 right join t2 on t1.tid = t2.id;
--sorted_result
select * from t1 right join t2 on t1.tid = t2.id where degrees(c2)<degrees(0.5) and a1>degrees(-1)order by degrees(a1) desc;
--sorted_result
select * from t1 right join t2 on t1.tid = t2.id where degrees(a1)>degrees(-0.6) and degrees(c2)<degrees(0.6) group by degrees(tid) order by atan(a2) desc ;
--sorted_result
select * from t1 right join t2 on t1.tid = t2.id where degrees(c1)<degrees(0.7) and degrees(a2) <degrees(0.1) group by degrees(tid) having degrees(c2)>degrees(0);

--echo	#子查询
--echo	#in
select tid from t1 where tid in(select id from t2 where degrees(a1)>degrees(0) and degrees(a2)<degrees(0));
--echo	#比较运算符
select * from t2 where degrees(id) >(select degrees(tid) from t1 where degrees(c2) > degrees(-0.11111111111) or degrees(c1) <> degrees(0) limit 1);
select * from t1 where degrees(tid) <(select degrees(id) from t2 where degrees(a1)>degrees(-0.5) and degrees(a2)<degrees(0.22222222) limit 1);
select * from t1 where degrees(c1) >=(select degrees(id) from t2 where degrees(a1)>degrees(-0.33333333) and degrees(a1)<degrees(0.6) limit 1);
select * from t2 where id <=(select tid from t1 where degrees(c1) > degrees(0) and degrees(c1)>degrees(-0.3333333) limit 1);
select * from t1 where tid <>(select id from t2 where degrees(a1) != degrees(0) or degrees(a2)>degrees(0.1245613) limit 1);
select * from t2 where degrees(id) !=(select tid from t1 where degrees(c1) >degrees(-0.32156123) or degrees(c2)>degrees(0.1245613) limit 1);
--echo	#exists
select * from t1 where exists(select id from t2 where degrees(a1)<>degrees(0.1) and degrees(a2) > degrees(-0.6));
--echo	#any
select * from t2 where id > any(select tid from t1 where degrees(c1) > degrees(0) and degrees(c2)>degrees(0));

--echo	#update
update t1 set tid =degrees(radians(100)) where tid = (select id from t2 where degrees(id) >(select degrees(tid) from t1 where degrees(c2) > degrees(-0.11111111111) or degrees(c1) <> degrees(0) limit 1)limit 1);
select * from t1;
update t2 set id =degrees(atan(1)) where id in(select tid from t1 where tid <>(select id from t2 where degrees(a1) != degrees(0) or degrees(a2)>degrees(0.1)limit 1));
select * from t2;
update t1 set tid =degrees(asin(1)) where exists(select id from t2 where degrees(a1)<>degrees(0.1) and degrees(a2) > degrees(-0.6));
select * from t1;
update t2 set id =degrees(cot(1)) where id<any(select tid from t1 where degrees(c1) > degrees(1) and degrees(c1)>degrees(-0.5) limit 1);
select * from t2;

--echo	#delete
delete from t1 where tid > (select id from t2 where degrees(a1)>0 and degrees(a2)>0);

#drop table t1,t2;
#drop database db1;


















