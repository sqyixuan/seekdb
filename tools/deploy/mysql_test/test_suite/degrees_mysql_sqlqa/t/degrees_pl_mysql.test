--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--echo	# PL
--echo  # procedure
--echo	# 无参数
drop  table     if exists t1;
drop  procedure if exists pro1;
delimiter //;

create procedure pro1()
begin
    declare i double;
    declare a double;
    declare c double;
    set i = 1.5;
    set a = -2;
    set c = pi();
    create table t1(c1 double ,c2 double ,c3 double);
    insert into t1 values(degrees(i),degrees(a),degrees(c));
    select * from t1;
end//

delimiter ;//
call pro1();
select  *  from  t1;


--echo	# 有参数
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa double,bb double);
delimiter //;
create procedure pro1(a1 double, a2 double)
begin
       insert into t1 values(degrees(a1),degrees(a2));
       insert into t1 values(degrees(a2),degrees(a1));
       select sum(a1),sum(a2)  from  t1;
end//
delimiter ;//
call   pro1(degrees(0.1),degrees(cos(-1)));
select   *   from  t1;


--echo	# 条件语句
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa double,bb double);
delimiter //;
create procedure pro1(a double)
begin
        declare  i int;
        set  i  =  3;
        if    i<a   then
        insert into t1 values(degrees(1),degrees(asin(1)));
        end if;
        insert into t1 values(degrees(-1),degrees(acos(0)));
end//
delimiter ;//
call   pro1(degrees(1));
select   *   from  t1;

--echo	# 循环语句
--echo	# repeat循环

drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1()
begin
Declare a1 double default 0.1;
Declare sum double default 0;
repeat
set sum=sum+degrees(a1);
set a1 = a1+0.1;
until a1>=1
end repeat;
select sum;
end//
delimiter ;//
call pro1();

--echo  # while循环
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa double,bb double);
delimiter //;
create procedure pro1(a int)
begin
      declare i int;
      set i =1;
      while i<a
      do
           insert into t1 values(degrees(1/i),degrees(1/(i+1)));
           set i=i+1;
      end while;
end//
delimiter ;//
call pro1(3);
select * from t1;

--echo #  loop循环

drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa double);
delimiter //;
create procedure pro1()
begin
	Declare tem int default 1;
	label:loop
	insert into t1 values(degrees(atan(0.1,-0.1)));
	set tem = tem + 1;
	if tem>10 then leave label;
	end if;
	end loop label;
	select  * from t1;
end//
delimiter ;//
call pro1();
select * from t1;

--echo	# function 
--echo	# 条件语句
drop   table      if   exists   t1;
drop   function   if   exists   func1;
create table  t1 (aa  double , bb double);
delimiter //;
create  function  func1()   returns  double
begin
      declare  i    int;
      set   i = 1;
      if    i < degrees(1)  then
        insert into t1 values(degrees(0.1),degrees(radians(30)));
      end if;
        return degrees(atan(1));
end//
delimiter ;//
select func1();
select   *   from   t1;

--echo	# 循环语句
--echo	# repeat循环
drop   table     if   exists   t1;
drop   function if   exists   func1;
delimiter //;
create function func1() returns double
begin
Declare a1 double default 0.1;
Declare sum double default 0;
repeat
set sum=sum+degrees(a1);
set a1 = a1+0.1;
until a1>=1
end repeat;
return degrees(asin(1));
end//
delimiter ;//
select func1;

--echo 	#  while循环
drop   table     if   exists   t1;
drop   function if   exists   func1;
create table t1(aa double,bb double);
delimiter //;
create function func1(a int) returns double
begin
      declare i int;
      set i =1;
      while i<a
      do
           insert into t1 values(degrees(1/i),degrees(1/(i+1)));
           set i=i+1;
      end while;
      return degrees(-1);
end//
delimiter ;//
select func1(3);
select * from t1;


--echo 	#  loop循环
drop   table     if   exists   t1;
drop   function if   exists   func1;
create table t1(aa double);
delimiter //;
create function func1() returns double
begin
        Declare tem int default 1;
        label:loop
        insert into t1 values(degrees(1/tem));
        set tem = tem + 1;
        if tem>5 then leave label;
        end if;
        end loop label;
        return degrees(0.5);
end//
delimiter ;//
select func1();
select * from t1;

drop table t1;
drop database db1;

