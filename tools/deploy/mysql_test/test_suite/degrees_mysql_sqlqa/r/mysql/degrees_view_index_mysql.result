drop database if exists db1;
create database db1;
use db1;
#view
#view select
create  table   t1(id  int,name  char(20),a1  double,a2  double);
create view v1_test as select * from t1;
insert  into    v1_test   values(1,'aaaaaa1',-1,0.8),(1,'aaaaaa2',0.5,-0.4);
insert  into    v1_test   values(2,'bbbbbb1',pi(),0.3),(2,'bbbbbb2',asin(1),-0.7);
insert  into    v1_test   values(3,'cccccc1',5,acos(0)),(3,'cccccc2',-1.5,atan(1));
insert  into    v1_test   values(4,'dddddd1',atan(1,1),cot(1)),(4,'dddddd2',8,radians(10));
insert  into    v1_test   values(5,'eeeeee1',-10,15),(5,'eeeeee2',acos(1),degrees(-15));
insert  into    v1_test   values(6,'ffffff1',2,asin(-1)),(6,'ffffff2',radians(180),degrees(0));
select    *    from   v1_test ;
