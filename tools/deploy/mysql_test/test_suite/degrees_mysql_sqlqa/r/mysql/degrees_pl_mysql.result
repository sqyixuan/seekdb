drop   function if   exists   func1;
create table t1(aa double,bb double);
create function func1(a int) returns double
begin
declare i int;
set i =1;
while i<a
do
insert into t1 values(degrees(1/i),degrees(1/(i+1)));
set i=i+1;
end while;
return degrees(-1);
end//
