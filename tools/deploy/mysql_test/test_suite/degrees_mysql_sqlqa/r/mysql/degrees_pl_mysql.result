# 条件语句
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa double,bb double);
create procedure pro1(a double)
begin
declare  i int;
set  i  =  3;
if    i<a   then
insert into t1 values(degrees(1),degrees(asin(1)));
end if;
insert into t1 values(degrees(-1),degrees(acos(0)));
end//
call   pro1(degrees(1));
select   *   from  t1;
aa	bb
57.29577951308232	90
-57.29577951308232	90
# 循环语句
# repeat循环
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create procedure pro1()
begin
Declare a1 double default 0.1;
Declare sum double default 0;
repeat
set sum=sum+degrees(a1);
set a1 = a1+0.1;
until a1>=1
end repeat;
select sum;
end//
call pro1();
sum
315.12678732195275
# while循环
drop   table     if   exists   t1;
Warnings:
Note	1051	Unknown table 'db1.t1'
drop   procedure if   exists   pro1;
create table t1(aa double,bb double);
create procedure pro1(a int)
begin
declare i int;
set i =1;
while i<a
do
insert into t1 values(degrees(1/i),degrees(1/(i+1)));
set i=i+1;
end while;
end//
call pro1(3);
select * from t1;
aa	bb
