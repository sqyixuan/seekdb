#  loop循环
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa double);
create procedure pro1()
begin
Declare tem int default 1;
label:loop
insert into t1 values(degrees(atan(0.1,-0.1)));
set tem = tem + 1;
if tem>10 then leave label;
end if;
end loop label;
select  * from t1;
end//
call pro1();
