# PL
# procedure
# 无参数
drop  table     if exists t1;
Warnings:
Note	1051	Unknown table 'db1.t1'
drop  procedure if exists pro1;
create procedure pro1()
begin
declare i double;
declare a double;
declare c double;
set i = 1.5;
set a = -2;
set c = pi();
create table t1(c1 double ,c2 double ,c3 double);
insert into t1 values(degrees(i),degrees(a),degrees(c));
select * from t1;
end//
call pro1();
