# 循环语句
# repeat循环
drop   table     if   exists   t1;
drop   function if   exists   func1;
create function func1() returns double
begin
Declare a1 double default 0.1;
Declare sum double default 0;
repeat
set sum=sum+degrees(a1);
set a1 = a1+0.1;
until a1>=1
end repeat;
return degrees(asin(1));
end//
select func1;
func1
