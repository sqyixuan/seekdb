# 有参数
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa double,bb double);
create procedure pro1(a1 double, a2 double)
begin
insert into t1 values(degrees(a1),degrees(a2));
insert into t1 values(degrees(a2),degrees(a1));
select sum(a1),sum(a2)  from  t1;
end//
call   pro1(degrees(0.1),degrees(cos(-1)));
sum(a1)	sum(a2)
