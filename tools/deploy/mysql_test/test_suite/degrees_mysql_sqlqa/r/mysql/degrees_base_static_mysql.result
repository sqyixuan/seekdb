select degrees(pi()*2),degrees(-pi()-pi());
degrees(pi()*2)	degrees(-pi()-pi())
360	-360
#asin()
select degrees(asin(1)),degrees(asin(-1));
degrees(asin(1))	degrees(asin(-1))
