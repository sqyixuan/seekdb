drop table t2;
#在不同字段中插入degrees函数
#int
create table t2(c1 int,c2 int,c3 int);
insert into t2 values(degrees(0.1),degrees(-0.5),degrees(pi()));
select * from t2;
c1	c2	c3
6	-29	180
drop table t2;
#float
create table t2(c1 float,c2 float,c3 float);
