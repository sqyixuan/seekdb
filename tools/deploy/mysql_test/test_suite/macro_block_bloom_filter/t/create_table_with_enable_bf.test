# owner: baichangmin.bcm
# tags: storage
# description: Create table with enable_macro_block_bloom_filter opened


connect (obsys, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, TEST, $OBMYSQL_PORT);
connect (test, $OBMYSQL_MS0, admin, admin, test, $OBMYSQL_PORT);


--disable_query_log
--disable_warnings


set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
set _show_ddl_in_compat_mode = 0;


--enable_warnings
--enable_query_log


# 1. 关闭并行建表
alter system set _enable_parallel_table_creation = false;
--echo "1. disable parallel table creation"


# 定义常量
let $table_name = test_table;
let $index_name = test_index;


# 1.1 create table 开启 macro block bloom filter
--echo "1.1 create table"
connection test;
--disable_query_log
--disable_warnings
eval DROP TABLE IF EXISTS $table_name;
--enable_warnings
eval CREATE TABLE $table_name (
    id INT PRIMARY KEY,
    val INT
)
enable_macro_block_bloom_filter = true;
--enable_query_log

connection test;
--disable_query_log
eval select enable_macro_block_bloom_filter from oceanbase.__all_table where table_name='$table_name';
--enable_query_log


# 获取 table id
connection test;
--disable_query_log
let $table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='$table_name', table_id, 1);
--enable_query_log


# 1.2 show 语句检查
--echo "1.2 show create table"
connection test;
--disable_query_log
--source mysql_test/include/show_create_table_old_version_replica2.inc
eval show create table $table_name;
--enable_query_log


# 1.3 create index 语句检查
--echo "1.3 create index"
connection test;
--disable_query_log
eval CREATE INDEX $index_name ON $table_name (
    val
);
--enable_query_log

connection test;
--disable_query_log
eval select enable_macro_block_bloom_filter from oceanbase.__all_table where data_table_id=$table_id;
--enable_query_log


# 1.4 alter table 语句检查
--echo "1.4 alter table"
connection test;
--disable_query_log
eval ALTER TABLE $table_name ENABLE_MACRO_BLOCK_BLOOM_FILTER = false;

eval select enable_macro_block_bloom_filter from oceanbase.__all_table where table_name='$table_name';
eval select enable_macro_block_bloom_filter from oceanbase.__all_table where data_table_id=$table_id;

eval ALTER TABLE $table_name ENABLE_MACRO_BLOCK_BLOOM_FILTER = true;

eval select enable_macro_block_bloom_filter from oceanbase.__all_table where table_name='$table_name';
eval select enable_macro_block_bloom_filter from oceanbase.__all_table where data_table_id=$table_id;
--enable_query_log


# 2. 开启并行建表
alter system set _enable_parallel_table_creation = true;
--echo "2. enable parallel table creation"


# 定义常量
let $parallel_table_name = test_parallel_table;
let $parallel_index_name = test_parallel_index;


# 2.1 create table 开启 macro block bloom filter
--echo "2.1 create table"
connection test;
--disable_query_log
--disable_warnings
eval DROP TABLE IF EXISTS $parallel_table_name;
--enable_warnings
eval CREATE TABLE $parallel_table_name (
    id INT PRIMARY KEY,
    val INT
)
enable_macro_block_bloom_filter = true;
--enable_query_log

connection test;
--disable_query_log
eval select enable_macro_block_bloom_filter from oceanbase.__all_table where table_name='$parallel_table_name';
--enable_query_log


# 获取 table id
connection test;
--disable_query_log
let $table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='$parallel_table_name', table_id, 1);
--enable_query_log


# 2.2 show 语句检查
--echo "2.2 show create table"
connection test;
--disable_query_log
--source mysql_test/include/show_create_table_old_version_replica2.inc
eval show create table $parallel_table_name;
--enable_query_log


# 2.3 create index 语句检查
--echo "2.3 create index"
connection test;
--disable_query_log
eval CREATE INDEX $parallel_index_name ON $parallel_table_name (
    val
);
--enable_query_log

connection test;
--disable_query_log
eval select enable_macro_block_bloom_filter from oceanbase.__all_table where data_table_id=$table_id;
--enable_query_log


# 2.4 alter table 语句检查
--echo "2.4 alter table"
connection test;
--disable_query_log
eval ALTER TABLE $parallel_table_name ENABLE_MACRO_BLOCK_BLOOM_FILTER = false;

eval select enable_macro_block_bloom_filter from oceanbase.__all_table where table_name='$parallel_table_name';
eval select enable_macro_block_bloom_filter from oceanbase.__all_table where data_table_id=$table_id;

eval ALTER TABLE $parallel_table_name ENABLE_MACRO_BLOCK_BLOOM_FILTER = true;

eval select enable_macro_block_bloom_filter from oceanbase.__all_table where table_name='$parallel_table_name';
eval select enable_macro_block_bloom_filter from oceanbase.__all_table where data_table_id=$table_id;
--enable_query_log
