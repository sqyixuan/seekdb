# owner: baichangmin.bcm
# tags: storage
# description: Create table with _show_ddl_in_compat_mode


connect (obsys, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, TEST, $OBMYSQL_PORT);
connect (test, $OBMYSQL_MS0, admin, admin, test, $OBMYSQL_PORT);


--disable_query_log
--disable_warnings


set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
set _show_ddl_in_compat_mode = 1;


--enable_warnings
--enable_query_log


# 定义常量
let $table_enable = test_table_enable;
let $table_disable = test_table_disable;


# 创建表，开启 macro block bloom filter
--echo "create table enable"
connection test;
--disable_query_log
--disable_warnings
eval DROP TABLE IF EXISTS $table_enable;
--enable_warnings
eval CREATE TABLE $table_enable (
    id INT PRIMARY KEY,
    val INT
)
enable_macro_block_bloom_filter = true;
--enable_query_log

connection test;
--disable_query_log
eval select enable_macro_block_bloom_filter from oceanbase.__all_table where table_name='$table_enable';
--enable_query_log


# show 语句检查
--echo "show create table"
connection test;
--disable_query_log
--source mysql_test/include/show_create_table_old_version_replica2.inc
eval show create table $table_enable;
--enable_query_log


# 创建表，关闭 macro block bloom filter
--echo "create table disable"
connection test;
--disable_query_log
--disable_warnings
eval DROP TABLE IF EXISTS $table_disable;
--enable_warnings
eval CREATE TABLE $table_disable (
    id INT PRIMARY KEY,
    val INT
);
--enable_query_log

connection test;
--disable_query_log
eval select enable_macro_block_bloom_filter from oceanbase.__all_table where table_name='$table_disable';
--enable_query_log


# show 语句检查
--echo "show create table"
connection test;
--disable_query_log
--source mysql_test/include/show_create_table_old_version_replica2.inc
eval show create table $table_disable;
--enable_query_log
