# owner: zuojiao.hzj
# owner group: sql2
# tags: warnings
# description:
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

--echo where conditions
create table t1 (c1 int, c2 varchar(100));
insert into t1 values (0, '全部明细');
insert into t1 values (1, '其他');
insert into t1 values (0, '全部明细');

select * from t1 where c1 = '全部明细';
select * from t1 where c1 = cast('全部明细' as decimal);
select * from t1 where c1 = c2;
select * from t1 where c1 = cast(c2 as decimal);

set sql_mode = 'strict_all_tables';
--error 1292
delete from t1 where c1 = '全部明细';
--error 1292
delete from t1 where c1 = cast('全部明细' as decimal);
--error 1292
delete from t1 where c1 = c2;
--error 1292
delete from t1 where c1 = cast(c2 as decimal);

set sql_mode = '';
set autocommit = 0;
delete from t1 where c1 = '全部明细';
rollback;

delete from t1 where c1 = cast('全部明细' as decimal);
rollback;

delete from t1 where c1 = c2;
rollback;

delete from t1 where c1 = cast(c2 as decimal);
rollback;

set autocommit = 1;
set sql_mode = 'strict_all_tables';
select * from t1;

drop table t1;

--echo dml operator
--echo decimal_int
create table t1 (c1 decimal, c2 decimal(10, 2));
--error 1366
insert into t1 values ('全部明细', null);
--error 1366
insert into t1 values (null, '全部明细');
insert into t1 values ('1.23', null);
insert into t1 values (null, '2.345');
select * from t1;

set sql_mode = '';
insert into t1 values ('全部明细', null);
insert into t1 values (null, '全部明细');
insert into t1 values ('1.23', null);
insert into t1 values (null, '2.345');
select * from t1;

set sql_mode = 'strict_all_tables';
--error 1366
update t1 set c1 = '全部明细';
update t1 set c1 = '1.23';
--error 1366
update t1 set c2 = '全部明细';
update t1 set c2 = '2.345';
select * from t1;

set sql_mode = '';
update t1 set c1 = '全部明细';
update t1 set c1 = '1.23';
update t1 set c2 = '全部明细';
update t1 set c2 = '2.345';
select * from t1;

truncate table t1;

set sql_mode = 'strict_all_tables';
create table t2 (c1 varchar(200));
insert into t2 values ('全部明细'), ('1.23'), ('2.345');

--error 1366
insert into t1(c1) select * from t2;
--error 1366
insert into t1(c2) select * from t2;

set sql_mode = '';
insert into t1(c1) select * from t2;
insert into t1(c2) select * from t2;

drop table t1, t2;
alter system set _enable_decimal_int_type = false;
--sleep 5

set sql_mode = 'strict_all_tables';
--echo number
create table t1 (c1 decimal, c2 decimal(10, 2));
--error 1366
insert into t1 values ('全部明细', null);
--error 1366
insert into t1 values (null, '全部明细');
insert into t1 values ('1.23', null);
insert into t1 values (null, '2.345');
select * from t1;

set sql_mode = '';
insert into t1 values ('全部明细', null);
insert into t1 values (null, '全部明细');
insert into t1 values ('1.23', null);
insert into t1 values (null, '2.345');
select * from t1;

set sql_mode = 'strict_all_tables';
--error 1366
update t1 set c1 = '全部明细';
update t1 set c1 = '1.23';
--error 1366
update t1 set c2 = '全部明细';
update t1 set c2 = '2.345';
select * from t1;

set sql_mode = '';
update t1 set c1 = '全部明细';
update t1 set c1 = '1.23';
update t1 set c2 = '全部明细';
update t1 set c2 = '2.345';
select * from t1;

truncate table t1;

set sql_mode = 'strict_all_tables';
create table t2 (c1 varchar(200));
insert into t2 values ('全部明细'), ('1.23'), ('2.345');

--error 1366
insert into t1(c1) select * from t2;
--error 1366
insert into t1(c2) select * from t2;

set sql_mode = '';
insert into t1(c1) select * from t2;
insert into t1(c2) select * from t2;

drop table t1, t2;

alter system set _enable_decimal_int_type = true;
--sleep 5

create table t1 (z0_test0 decimal(10,2));
