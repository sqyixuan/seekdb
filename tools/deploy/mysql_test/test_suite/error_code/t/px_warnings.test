##owner: xiaoyi.xy
###owner group: SQL2
### tags: pl,px
#description: test warnings in PX

--disable_warnings
drop table if exists t2;
drop table if exists t1_part;
drop table if exists t1_error;
--enable_warnings

create table t2 (c1 bit(36), c2 varchar(20), c3 char(20), c4 int) partition by hash(c4) partitions 3;
insert into t2 values (0xffffff, "lalalalalalaaa", "b2bbbbbbbb3", 3);
select c1+ c2, c1 * c2, c1 - c2 from t2;
select  /*+ parallel(3) */  c1+ c2, c1 * c2, c1 - c2 from t2;
select  /*+ parallel(4) */  c1+ c2, c1 * c2, c1 - c2 from t2;




set cte_max_recursion_depth = 4;

create table t1_part(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
create table t1_error (c1 int) partition by hash(c1) partitions 3;

insert into t1_part values (1, 2), (4, 5), (5, 8),(20, 11),(40, 14),(30, 17);
--error 3636
with RECURSIVE cte1 (a,b,c) as (select 1,1,1 from dual union all select a+1,b+1,c+1 from cte1 where cte1.a < 20) select * from cte1;
--error 3636
with RECURSIVE cte1 (a,b,c) as (select 1,1,1 from dual union all select a+1,b+1,c+1 from cte1) select * from cte1,t1_part where cte1.a=t1_part.c1;
--error 3636
with RECURSIVE cte1 (a,b,c) as (select 1,1,1 from dual union all select a+1,b+1,c+1 from cte1 where cte1.a < 20) select * from cte1,t1_error;
--error 3636
with RECURSIVE cte1 (a,b,c) as (select 1,1,1 from dual union all select a+1,b+1,c+1 from cte1) select /*+ parallel(3) */ * from cte1,t1_part where cte1.a=t1_part.c1;


