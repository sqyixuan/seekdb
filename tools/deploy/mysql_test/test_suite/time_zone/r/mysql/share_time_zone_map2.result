call oceanbase.drop_tenant_force('tenant1');
call oceanbase.create_mysql_tenant_mini('tenant1');
call oceanbase.drop_tenant_force('tenant1');
call oceanbase.create_mysql_tenant_mini('tenant1');
call oceanbase.drop_tenant_force('tenant1');
call oceanbase.drop_tenant_force('tenant7');
call oceanbase.create_mysql_tenant_mini('tenant7');
delete from test.mem_used_new;
insert into test.mem_used_new select tenant_id, label, ctx_name, mod_type, mod_id, mod_name, used, count from __all_virtual_memory_info
where label like '%TZ%' and SVR_IP=HOST_IP() and SVR_PORT=RPC_PORT() order by tenant_id, label;
## expect allocate huge memory.
select a.tenant_id, a.label, a.ctx_name, a.mod_type, a.mod_id, a.mod_name, a.used - b.used, a.count - b.count
from test.mem_used_new a, test.mem_used  b where a.tenant_id = b.tenant_id and a.label = b.label and a.mod_id = b.mod_id order by tenant_id, label;
tenant_id	label	ctx_name	mod_type	mod_id	mod_name	a.used - b.used	a.count - b.count
500	HasNodTzInfM	DEFAULT_CTX_ID	user	0	HasNodTzInfM	0	0
500	ObTZIDHashNode	DEFAULT_CTX_ID	user	0	ObTZIDHashNode	55552	7
500	ObTZNameHashNod	DEFAULT_CTX_ID	user	0	ObTZNameHashNod	87296	11
500	ObTZNameIDInfo	DEFAULT_CTX_ID	user	0	ObTZNameIDInfo	63488	8
500	TenantTZ	DEFAULT_CTX_ID	user	0	TenantTZ	6400	2
500	TZInfoArray	DEFAULT_CTX_ID	user	0	TZInfoArray	16641792	1082
500	TZInfoMgrMap	DEFAULT_CTX_ID	user	0	TZInfoMgrMap	3145824	3
set time_zone = 'Africa/Accra';
set time_zone = 'Africa/Abidjan';
