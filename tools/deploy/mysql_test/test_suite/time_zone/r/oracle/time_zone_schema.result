

************************ test for table definition *********************
desc oceanbase.__all_time_zone;
Field	Type	Null	Key	Default	Extra
Time_zone_id	bigint(20)	NO	PRI	NULL	auto_increment
Use_leap_seconds	varchar(8)	NO		N	
Version	bigint(20)	YES		NULL	
desc oceanbase.__all_time_zone_name;
Field	Type	Null	Key	Default	Extra
Name	varchar(64)	NO	PRI	NULL	
Time_zone_id	bigint(20)	NO		NULL	
Version	bigint(20)	YES		NULL	
desc oceanbase.__all_time_zone_transition;
Field	Type	Null	Key	Default	Extra
Time_zone_id	bigint(20)	NO	PRI	NULL	
Transition_time	bigint(20)	NO	PRI	NULL	
Transition_type_id	bigint(20)	NO		NULL	
Version	bigint(20)	YES		NULL	
desc oceanbase.__all_time_zone_transition_type;
Field	Type	Null	Key	Default	Extra
Time_zone_id	bigint(20)	NO	PRI	NULL	
Transition_type_id	bigint(20)	NO	PRI	NULL	
Offset	bigint(20)	NO		0	
Is_DST	bigint(20)	NO		0	
Abbreviation	varchar(8)	NO			
Version	bigint(20)	YES		NULL	


