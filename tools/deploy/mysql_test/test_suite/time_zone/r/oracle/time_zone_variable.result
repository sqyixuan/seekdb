set @@global.error_on_overlap_time = -1;
ERROR 42000: Variable 'error_on_overlap_time' can't be set to the value of '-1'
set @@global.error_on_overlap_time = true;
set @@global.error_on_overlap_time = TRUE;
set @@global.error_on_overlap_time = false;
set @@global.error_on_overlap_time = FALSE;
set @@global.error_on_overlap_time = 'true';
ERROR 42000: Variable 'error_on_overlap_time' can't be set to the value of 'true'
set @@global.error_on_overlap_time = 'FALSE';
ERROR 42000: Variable 'error_on_overlap_time' can't be set to the value of 'FALSE'

##### test for error_on_overlap_time == false
set @@session.error_on_overlap_time = false;
set @@global.error_on_overlap_time = false;

###  test for gap ###
set @@session.time_zone="Canada/Yukon";
insert into t1 values(1, "2036-03-09 02:00:00");
ERROR 22007: Incorrect value
insert into t1 values(1, "2036-03-09 02:59:59");
ERROR 22007: Incorrect value
insert into t1 values(1, "2036-03-09 03:00:00");
select * from t1;
c1	c2
1	2036-03-09 03:00:00

###  test for overlap , default value is the standard time region###
truncate table t1;
set @@session.time_zone="Canada/Yukon";
insert into t1 values(1, "2036-11-02 01:00:00");
insert into t1 values(2, "2036-11-02 01:59:59");
insert into t1 values(3, "2036-11-02 02:00:00");
select * from t1;
c1	c2
1	2036-11-02 01:00:00
2	2036-11-02 01:59:59
3	2036-11-02 02:00:00
set @@session.time_zone="UTC";
select * from t1;
c1	c2
1	2036-11-02 09:00:00
2	2036-11-02 09:59:59
3	2036-11-02 10:00:00

##### test for error_on_overlap_time == true
set @@session.error_on_overlap_time = true;
set @@global.error_on_overlap_time = true;

###  test for gap ###
set @@session.time_zone="Canada/Yukon";
insert into t1 values(1, "2036-03-09 02:00:00");
ERROR 22007: Incorrect value
insert into t1 values(1, "2036-03-09 02:59:59");
ERROR 22007: Incorrect value
insert into t1 values(1, "2036-03-09 03:00:00");
select * from t1;
c1	c2
1	2036-11-02 01:00:00
2	2036-11-02 01:59:59
3	2036-11-02 02:00:00
1	2036-03-09 03:00:00

###  test for overlap , default value is the standard time region###
truncate table t1;
set @@session.time_zone="Canada/Yukon";
insert into t1 values(1, "2036-11-02 01:00:00");
ERROR 22007: Incorrect value
insert into t1 values(2, "2036-11-02 01:59:59");
ERROR 22007: Incorrect value
insert into t1 values(3, "2036-11-02 02:00:00");
select * from t1;
c1	c2
3	2036-11-02 02:00:00
set @@session.time_zone="UTC";
select * from t1;
c1	c2
3	2036-11-02 10:00:00
** clean **

SET @@SESSION.time_zone = @session_time_zone;
SET @@GLOBAL.time_zone = @global_time_zone;
SET @@SESSION.error_on_overlap_time = @session_error_on_overlap_time;
SET @@GLOBAL.error_on_overlap_time = @global_error_on_overlap_time;
drop database tzdb;
