#### test for error_on_overlap_time diffrent value
set @@session.error_on_overlap_time = 1;
set @@session.error_on_overlap_time = 0;
set @@session.error_on_overlap_time = 2;
ERROR 42000: Variable 'error_on_overlap_time' can't be set to the value of '2'
