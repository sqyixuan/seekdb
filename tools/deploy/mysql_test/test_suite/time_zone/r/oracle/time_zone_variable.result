@@session.time_zone
UTC
set @@global.time_zone = 'UTC';
select @@global.time_zone;
@@global.time_zone
UTC
time_zone_name: W-SU;
set @@session.time_zone = 'W-SU';
select @@session.time_zone;
@@session.time_zone
W-SU
set @@global.time_zone = 'W-SU';
select @@global.time_zone;
@@global.time_zone
W-SU
