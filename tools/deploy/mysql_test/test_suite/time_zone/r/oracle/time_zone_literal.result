drop database if exists tzdb;
create database tzdb;
use tzdb;
** Setup **

SET @session_time_zone = @@SESSION.time_zone;
SET @global_time_zone = @@GLOBAL.time_zone;
SET @session_error_on_overlap_time = @@SESSION.error_on_overlap_time;
SET @global_error_on_overlap_time = @@GLOBAL.error_on_overlap_time;
create table t1(c1 int, c2 datetime);
create table t2(c1 int, c2 timestamp);


#############  case 1 : test for valid string literal to datetime   ##############
insert into t1 values(1, '2012-01-02 01:01:01');
insert into t1 values(2, '2012-01-02 01:01:01');
select * from t1;
c1	c2
1	2012-01-02 01:01:01
2	2012-01-02 01:01:01


#############  case 2 : test for invalid string literal to datetime   ##############
insert into t1 values(3, '1990-09-15 23:00:00 Asia/Shanghai CDT');
ERROR 22007: Incorrect value
insert into t1 values(4, '1990-09-15 23:00:00 asia/shanghai cst');
ERROR 22007: Incorrect value
insert into t1 values(5, '1990-09-15 23:00:00 Asia/Shanghai');
ERROR 22007: Incorrect value
insert into t1 values(6, '1990-09-15 23:00:00 Asia/Shanghaiiii');
ERROR 22007: Incorrect value
insert into t1 values(6, '1990-09-15 23:00:00 Asia/Shanghai abc');
ERROR 22007: Incorrect value
insert into t1 values(6, '1990-09-15 23:00:00 Asia/Shanghai LMT');
ERROR 22007: Incorrect value
select * from t1;
c1	c2
1	2012-01-02 01:01:01
2	2012-01-02 01:01:01


#############  case 3 : test for valid string literal to timestamp   ##############
set @@session.error_on_overlap_time=TRUE;
set @@session.time_zone='UTC';
insert into t2 values(0, '1990-09-15 23:00:00 Asia/Shanghai LMT');
ERROR 22007: Incorrect value
insert into t2 values(0, '1990-09-15 23:00:00 asia/shanghai abc');
ERROR 22007: Incorrect value
insert into t2 values(0, '1990-09-15 23:00:00 Asia/Shanghaiiii');
ERROR 22007: Incorrect value
insert into t2 values(1, '1990-09-15 23:00:00 Asia/Shanghai CDT');
insert into t2 values(2, '1990-09-15 23:00:00 asia/shanghai cst');
insert into t2 values(3, '1990-09-15 23:00:00 asia/shanghai');
ERROR 22007: Incorrect value
insert into t2 values(4, '1989-04-16 00:00:00 asia/shanghai');
ERROR 22007: Incorrect value
insert into t2 values(5, '1990-09-16 00:00:00 asia/shanghai cst');
insert into t2 values(6, '1990-09-16 00:00:00 asia/shanghai cdt');
ERROR 22007: Incorrect value
set @@session.error_on_overlap_time=FALSE;
insert into t2 values(6, '1990-09-16 00:00:00 asia/shanghai cdt');
ERROR 22007: Incorrect value
insert into t2 values(0, '1990-09-15 23:00:00 Asia/Shanghai LMT');
ERROR 22007: Incorrect value
insert into t2 values(0, '1990-09-15 23:00:00 asia/shanghai abc');
ERROR 22007: Incorrect value
insert into t2 values(7, '1990-09-15 23:00:00 asia/shanghai');
select * from t2;
c1	c2
1	1990-09-15 14:00:00
2	1990-09-15 15:00:00
5	1990-09-15 16:00:00
7	1990-09-15 15:00:00
** clean **

SET @@SESSION.time_zone = @session_time_zone;
SET @@GLOBAL.time_zone = @global_time_zone;
SET @@SESSION.error_on_overlap_time = @session_error_on_overlap_time;
SET @@GLOBAL.error_on_overlap_time = @global_error_on_overlap_time;
drop database tzdb;
