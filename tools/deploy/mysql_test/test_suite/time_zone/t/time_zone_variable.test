#owner: dachuan.sdc
#owner group: SQL4
#description:  测试time_zone系统变量的设置和使用
#tags: time_zone


--disable_warnings
drop database if exists tzdb;
--enable_warnings
create database tzdb;
use tzdb;

--echo ** Setup **
--echo
#
# Setup
#

SET @session_time_zone = @@SESSION.time_zone;
SET @global_time_zone = @@GLOBAL.time_zone;
SET @session_error_on_overlap_time = @@SESSION.error_on_overlap_time;
SET @global_error_on_overlap_time = @@GLOBAL.error_on_overlap_time;
create table t1(c1 int, c2 timestamp);

--echo
--echo
--echo #############  case 1 : test for empty time zone table   ##############
#--error 1298
#set @@time_zone='Africa/Abidjan';
#--error 1298
#set @@global.time_zone='Africa/Banjul';
set @@time_zone="+8:00";

--echo
--echo
--echo #############  case 2 : test for set all time zone name   ##############

--source mysql_test/test_suite/otimestamp/t/otimestamp_import_time_zone_mysql.inc

let $tz_cnt = query_get_value(select count(name) from oceanbase.__all_tenant_time_zone_name, count(name), 1);
--echo time_zone_count : $tz_cnt
let $tz_id = 1;
while($tz_id <= $tz_cnt)
{
  let $tz_name = query_get_value(select name from oceanbase.__all_tenant_time_zone_name, name, $tz_id);
  --echo time_zone_name: $tz_name;
  eval set @@session.time_zone = '$tz_name';
  select @@session.time_zone;
  eval set @@global.time_zone = '$tz_name';
  select @@global.time_zone;
  inc $tz_id;
}
connection default;

--echo
--echo
--echo #############  case 3 : test for case sensitive   ##############
set @@session.time_zone = 'Africa/Abidjan';
select @@session.time_zone;
set @@session.time_zone = 'AFRICA/ABIDJAN';
select @@session.time_zone;
set @@session.time_zone = 'africa/abidjan';
select @@session.time_zone;
set @@global.time_zone = 'Africa/Abidjan';
select @@global.time_zone;
set @@global.time_zone = 'AFRICA/ABIDJAN';
select @@global.time_zone;
set @@global.time_zone = 'africa/abidjan';
select @@global.time_zone;

--echo
--echo
--echo #############  case 5 : test for special time zone value   ##############

--echo ### test for trailing space ###
set @@session.time_zone = 'Africa/Abidjan ';
select @@session.time_zone;
set @@session.time_zone = 'AFRICA/ABIDJAN  ';
select @@session.time_zone;
set @@session.time_zone = 'africa/abidjan   ';
select @@session.time_zone;
set @@global.time_zone = 'Africa/Abidjan    ';
select @@global.time_zone;
set @@global.time_zone = 'AFRICA/ABIDJAN     ';
select @@global.time_zone;
set @@global.time_zone = 'africa/abidjan     ';
select @@global.time_zone;

--error 1298
set @@session.time_zone = ' Africa/Abidjan ';
--error 1298
set @@session.time_zone = ' Africa/Abidjan';
--error 1298
set @@session.time_zone = "+8:00 ";
--error 1298
set @@global.time_zone = "+8:00 ";

--echo ### test for empty string ###
--error 1298
set @@session.time_zone="";
--error 1298
set @@global.time_zone="";

--echo
--echo
--echo #############  case 5 : test for error_on_overlap_time  ##############
--echo
--echo #### test for error_on_overlap_time diffrent value
set @@session.error_on_overlap_time = 1;
set @@session.error_on_overlap_time = 0;
--error 1231
set @@session.error_on_overlap_time = 2;
--error 1231
set @@session.error_on_overlap_time = -1;
set @@session.error_on_overlap_time = true;
set @@session.error_on_overlap_time = TRUE;
set @@session.error_on_overlap_time = false;
set @@session.error_on_overlap_time = FALSE;
--error 1231
set @@session.error_on_overlap_time = 'true';
--error 1231
set @@session.error_on_overlap_time = 'FALSE';

set @@global.error_on_overlap_time = 1;
set @@global.error_on_overlap_time = 0;
--error 1231
set @@global.error_on_overlap_time = 2;
--error 1231
set @@global.error_on_overlap_time = -1;
set @@global.error_on_overlap_time = true;
set @@global.error_on_overlap_time = TRUE;
set @@global.error_on_overlap_time = false;
set @@global.error_on_overlap_time = FALSE;
--error 1231
set @@global.error_on_overlap_time = 'true';
--error 1231
set @@global.error_on_overlap_time = 'FALSE';


--echo
--echo ##### test for error_on_overlap_time == false
set @@session.error_on_overlap_time = false;
set @@global.error_on_overlap_time = false;

--echo
--echo ###  test for gap ###
set @@session.time_zone="Canada/Yukon";
--error 1292
insert into t1 values(1, "2036-03-09 02:00:00");
--error 1292
insert into t1 values(1, "2036-03-09 02:59:59");
insert into t1 values(1, "2036-03-09 03:00:00");
select * from t1;


--echo
--echo ###  test for overlap , default value is the standard time region###
truncate table t1;
set @@session.time_zone="Canada/Yukon";
insert into t1 values(1, "2036-11-02 01:00:00");
insert into t1 values(2, "2036-11-02 01:59:59");
insert into t1 values(3, "2036-11-02 02:00:00");
select * from t1;
set @@session.time_zone="UTC";
select * from t1;

--echo
--echo ##### test for error_on_overlap_time == true
set @@session.error_on_overlap_time = true;
set @@global.error_on_overlap_time = true;
--echo
--echo ###  test for gap ###
set @@session.time_zone="Canada/Yukon";
--error 1292
insert into t1 values(1, "2036-03-09 02:00:00");
--error 1292
insert into t1 values(1, "2036-03-09 02:59:59");
insert into t1 values(1, "2036-03-09 03:00:00");
select * from t1;


--echo
--echo ###  test for overlap , default value is the standard time region###
truncate table t1;
set @@session.time_zone="Canada/Yukon";
--error 1292
insert into t1 values(1, "2036-11-02 01:00:00");
--error 1292
insert into t1 values(2, "2036-11-02 01:59:59");
insert into t1 values(3, "2036-11-02 02:00:00");
select * from t1;
set @@session.time_zone="UTC";
select * from t1;

--echo ** clean **
--echo
#
# clean
#

SET @@SESSION.time_zone = @session_time_zone;
SET @@GLOBAL.time_zone = @global_time_zone;
SET @@SESSION.error_on_overlap_time = @session_error_on_overlap_time;
SET @@GLOBAL.error_on_overlap_time = @global_error_on_overlap_time;

drop database tzdb;