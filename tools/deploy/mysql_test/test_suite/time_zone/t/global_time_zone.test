#owner: dachuan.sdc
#owner group: SQL2
#description:  test for global time_zone variable
#tags: global time_zone

--source mysql_test/test_suite/otimestamp/t/otimestamp_import_time_zone_mysql.inc
select @@time_zone;
select @@global.time_zone;
set time_zone='+0:0';
show variables like 'time_zone';
set global time_zone='+0:0';
show global variables like 'time_zone';
set global time_zone='-0:0';
show global variables like 'time_zone';
set global time_zone='+10:0';
show global variables like 'time_zone';
set global time_zone='-10:0';
show global variables like 'time_zone';
set global time_zone='+13:0';
show global variables like 'time_zone';
--error 1298
set global time_zone='-13:0';
show global variables like 'time_zone';
SET @@global.time_zone = "+12:00";
SELECT @@global.time_zone;
SET @@global.time_zone = "-12:00";
SELECT @@global.time_zone;
SET @@global.time_zone = "+12:59";
SELECT @@global.time_zone;
SET @@global.time_zone = "-12:59";
SELECT @@global.time_zone;
SET @@global.time_zone = "-11:30";
SELECT @@global.time_zone;
--error 1298
SET @@global.time_zone = "11:30";
SELECT @@global.time_zone;
SET @@global.time_zone = "-00:00";
SELECT @@global.time_zone;
SET @@global.time_zone = "+00:00";
SELECT @@global.time_zone;
--error 1298
SET @@global.time_zone = "+00:00 ";
SELECT @@global.time_zone;
--error 1298
SET @@global.time_zone = " +00:00";
SELECT @@global.time_zone;
--error 1298
SET @@global.time_zone = "+ 00:00";
SELECT @@global.time_zone;
--error 1298
SET @@global.time_zone = "+0 0:00";
SELECT @@global.time_zone;
--error 1298
SET @@global.time_zone = "+00 :00";
SELECT @@global.time_zone;

--error 1298
SET @@global.time_zone = "+24:00";
--error 1298
SET @@global.time_zone = "+23:59";
#--Error ER_UNKNOWN_TIME_ZONE
--error 1298
SET @@global.time_zone = "+13:01";
--error 1298
SET @@global.time_zone = "-13:01";

#--error 1298
set @@global.time_zone = 'Africa/Abidjan';
select @@global.time_zone;
#--error 1298
set @@global.time_zone = 'Africa/Abidjan    ';
select @@global.time_zone;
#--error 1298
set @@global.time_zone = 'AFRICA/ABIDJAN     ';
select @@global.time_zone;
#--error 1298
set @@global.time_zone = 'africa/abidjan     ';
select @@global.time_zone;
--error 1232
set time_zone=123;
show variables like 'time_zone';
--error 1232
set global time_zone=123;
show global variables like 'time_zone';

set time_zone='+8:0';
set global time_zone = '+8:0';


