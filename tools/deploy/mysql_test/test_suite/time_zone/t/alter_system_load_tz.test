#owner: dachuan.sdc
#owner group: SQL2
#description:  测试使用alter system命令导入timezone
#tags: time_zone

connect (sys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys1;
--disable_query_log
--disable_warnings
#call oceanbase.drop_tenant_force('test_tz');
#call oceanbase.create_tenant('test_tz', 'mysql', '1c2g');
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

connection sys1;
drop user if exists st;
create user st identified by "123";
grant select on test.* to st;

connect (sys2,$OBMYSQL_MS0,st@sys,123,,$OBMYSQL_PORT);
connection sys2;
--enable_warnings
--enable_query_log

--error 1227
alter SYSTEM load MODULE DATA module = 'timezone' tenant = 'sys' INFILE = 'etc/';

connection sys1;
grant all on *.* to st;

alter system set_tp tp_name = EN_LOAD_TIME_ZONE_INFO_FAILED, error_code = 4016, frequency = 1;

connect (sys3,$OBMYSQL_MS0,st@sys,123,,$OBMYSQL_PORT);
connection sys3;
--error 4016
alter SYSTEM load MODULE DATA module = 'timezone' tenant = 'sys' INFILE = 'etc/';
--echo 失败了但是__all_tenant_time_zone仍然有数据，因为load data是单独开事务，只要__all_sys_stat中没插入version即可。
connection conn1;
select count(*) from oceanbase.__all_tenant_time_zone;
select tenant_id, name, name, data_type, value, info from oceanbase.__all_sys_stat where name = 'current_timezone_version';

connection sys1;
alter system set_tp tp_name = EN_LOAD_TIME_ZONE_INFO_FAILED, error_code = 0, frequency = 1;

connection sys3;
alter SYSTEM load MODULE DATA module = 'timezone' tenant = 'sys';

connection conn1;
select count(*) from oceanbase.__all_tenant_time_zone;
select count(*) from oceanbase.__all_tenant_time_zone_name;
select count(*) from oceanbase.__all_tenant_time_zone_transition;
select count(*) from oceanbase.__all_tenant_time_zone_transition_type;
select distinct tenant_id from oceanbase.__all_tenant_time_zone;
select distinct tenant_id from oceanbase.__all_tenant_time_zone_name;
select distinct tenant_id from oceanbase.__all_tenant_time_zone_transition;
select distinct tenant_id from oceanbase.__all_tenant_time_zone_transition_type;
select tenant_id, name, name, data_type, value, info from oceanbase.__all_sys_stat where name = 'current_timezone_version';
--disable_warnings
drop table if exists t0;
--enable_warnings
create table t0(c1 timestamp);
insert into t0 values('1990-06-10 12:00:00');
select * from t0;
--disable_query_log
let $wait_count=1;
while ($wait_count < 20)
{
  --error 0, 1298
  set time_zone = 'Asia/Shanghai';
  let $result= query_get_value(select @@time_zone as c1 from dual, c1, 1);
  if ($result != 'Asia/Shanghai') {
    sleep 1;
    inc $wait_count;
  }
  if ($result == 'Asia/Shanghai') {
    let $wait_count = 20;
  }
}
--enable_query_log
set time_zone = 'Asia/Shanghai';
select * from t0;

connection sys1;
let $tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);
--disable_query_log
eval select count(*) from oceanbase.__all_virtual_time_zone where tenant_id = $tenant_id;
eval select count(*) from oceanbase.__all_virtual_time_zone_name where tenant_id = $tenant_id;
eval select count(*) from oceanbase.__all_virtual_time_zone_transition where tenant_id = $tenant_id;
eval select count(*) from oceanbase.__all_virtual_time_zone_transition_type where tenant_id = $tenant_id;
--enable_query_log
#call oceanbase.drop_tenant_force('test_tz');
