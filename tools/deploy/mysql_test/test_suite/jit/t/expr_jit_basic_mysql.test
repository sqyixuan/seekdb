#owner: xiaoyi.xy
#owner group: sql1
##
## Test Name: expr_jit_basic

## Date: 2017-05-05

--disable_info
--disable_metadata
--disable_abort_on_error

--disable_warnings
drop database if exists expr_jit_db;
--enable_warnings
--disable_query_log
--disable_result_log
create database expr_jit_db;
use expr_jit_db;
set ob_enable_jit = 1;
set ob_enable_plan_cache = 1;
set ob_query_timeout = 50000000;

source mysql_test/test_suite/jit/t/jit_table_init.sql;
--disable_warnings
source mysql_test/test_suite/jit/t/expr_jit.sql;

--enable_query_log
--enable_result_log
source mysql_test/test_suite/jit/t/expr_jit.sql;
--enable_warnings

--disable_warnings
drop database if exists expr_jit_db;
--enable_warnings
