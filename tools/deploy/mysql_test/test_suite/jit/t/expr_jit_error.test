#owner: xiaoyi.xy
#owner group: sql1
##
## Test Name: expr_jit_error

## Date: 2017-05-23

--disable_info
--disable_metadata
--disable_abort_on_error

--disable_warnings
drop database if exists expr_jit_db;
--enable_warnings
--disable_query_log
--disable_result_log
create database expr_jit_db;
use expr_jit_db;
set ob_enable_jit = 1;
set ob_enable_plan_cache = 1;
set ob_query_timeout = 50000000;

--enable_query_log
--enable_result_log
--echo
--echo ******* test check overflow ****
create table tt (c1 bigint, c2 bigint);
insert into tt values(9223372036854775806, 9223372036854775806);
--echo //expected error
--error 1690
select c1+c1 from tt;
drop table tt;

--disable_warnings
drop database if exists expr_jit_db;
--enable_warnings
