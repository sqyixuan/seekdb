--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhenling.zzg
# # owner group: SQL3
# # Test of functions sin
# # tags: sin, datatype,静态sql,dual,CRUD

--disable_warnings
drop database if exists sin_test;
create database sin_test;
use sin_test;

drop table if exists w0case;
drop table if exists w1case;
--enable_warnings

--echo # obmysql-sin 通过性测试
create table w0case(w_test varchar(100));
insert into w0case values('100');
select round(sin(w_test),5) from w0case;

--echo # obmysql-sin 参数数量
--error 01582
select sin() from w0case;
select round(sin(12),5) from dual;
--error 01582
select sin(12,1) from dual;
drop table w0case;
--disable_warnings
--echo # obmysql-sin char类型
create table w0case(w_test char(200));
insert into w0case values('111');
insert into w0case values('a');
insert into w0case values('a11');
insert into w0case values('33.4456456142f');
insert into w0case values('-33.445645614245d');
select round(sin(w_test),5) from w0case where w_test = '111';
select sin(w_test) from w0case where w_test = 'a';
select sin(w_test) from w0case where w_test = 'a11';
select sin(w_test) from w0case where w_test = '33.4456456142f';
select sin(w_test) from w0case where w_test = '-33.445645614245d';
drop table w0case;

--echo # obmysql-sin varchar type
create table w0case(w_test varchar(100));
insert into w0case values('111');
insert into w0case values('33.4456456142f');
insert into w0case values('-33.445645614245d');
select round(sin(w_test),5) from w0case where w_test = '111';
select sin(w_test) from w0case where w_test = '33.4456456142f';
select sin(w_test) from w0case where w_test = '-33.445645614245d';
--enable_warnings
--echo # obmysql date/datetime/interval type
SELECT ROUND(sin('20200601'),5) FROM dual;
SELECT sin('2020-06-01') FROM dual;
select sin('2020:06:01') from  dual;
select ROUND(sin('20191001030204'),5) from dual;
select sin('2020-06-01 03:02:05') from dual;
drop table w0case;

--echo # obmysql number type
CREATE TABLE w0case(w_test decimal(38,10));
INSERT INTO w0case VALUES (222);
INSERT INTO w0case VALUES (33.4);
INSERT INTO w0case VALUES(335.11111);
SELECT ROUND(sin(W_TEST),5) FROM W0CASE WHERE W_TEST = 222;
SELECT ROUND(sin(W_TEST),5) FROM W0CASE WHERE W_TEST = 33.4;
SELECT ROUND(sin(W_TEST),5) FROM W0CASE WHERE W_TEST = 335.11111;
SELECT ROUND(sin(-1.0e-130)) FROM dual;
SELECT sin(1.0e+126) FROM dual;

--echo # mysql及ob在超越边界值是返回值为0
SELECT sin(-1.0e-131) FROM dual;
--echo # mysql返回未0，ob返回为数值
SELECT sin(1.0e+125) FROM dual;
DROP TABLE W0CASE;
CREATE TABLE W0CASE(w_test varchar(100));
INSERT INTO W0CASE values('12h3');
DROP TABLE W0CASE;
--echo # obmysql blob type
CREATE TABLE W0CASE(w_test blob);
INSERT INTO W0CASE VALUES ('123');
SELECT ROUND(sin(w_test)) FROM W0CASE;
DROP TABLE W0CASE;

--echo # obmysql 特殊符号，空格等
--error 01064
SELECT sin(1 23) FROM dual;
--error 01064
SELECT sin(123%) FROM dual;
--echo # obmysql 函数嵌套
SELECT ROUND(sin(45),5) FROM dual;
SELECT sin(sin(12)) FROM dual;
SELECT sin(MOD(11,4)) FROM dual;
SELECT sin(POWER(3,2)) FROM  dual;

--echo # obmysql 多级函数嵌套/被嵌套
SELECT ROUND(POWER(sin(15),2),5) FROM dual;
SELECT ROUND(sin(POWER(2,3)),5) FROM dual WHERE sin(POWER(2,3))>sin(POWER(2,4));
SELECT ROUND(POWER(ROUND(ATAN(ROUND(sin(45),5)),5),2),5) FROM dual;
SELECT sin(ROUND(POWER(ROUND(ATAN(ROUND(sin(45),5)),5),2),5)) FROM dual;
SELECT ROUND(sin(POWER(2,3)),5) FROM dual WHERE sin(45) = sin(45);
SELECT sin(CAST('2019-05-20' AS DATE)) FROM dual;
SELECT sin(CAST('19.2' as decimal(10,2))) FROM dual;

--echo # obmysql 基础运算
SELECT sin(235-123) FROM dual;
SELECT sin(12*12) FROM dual;
SELECT sin(12+12) FROM dual;
SELECT sin(12/12) FROM dual;
SELECT sin(POWER(2,3)+POWER(2,2)) FROM dual;
CREATE TABLE w0case(w_test decimal(38,10));
INSERT INTO w0case VALUES(0);
INSERT INTO w0case VALUES(1);
INSERT INTO w0case VALUES(2);
INSERT INTO w0case VALUES(3);
SELECT sin(w_test) FROM w0case WHERE w_test IS NULL;
SELECT sin(w_test) FROM w0case WHERE w_test IS NOT NULL;
SELECT sin(w_test) FROM w0case WHERE w_test IN (0,1,2,3,4);
SELECT sin(w_test) FROM w0case WHERE w_test NOT IN (4,5,6);
SELECT sin(w_test) FROM w0case WHERE w_test BETWEEN 0 AND 4;
SELECT sin(w_test) FROM w0case WHERE w_test NOT BETWEEN 4 AND 6;
DROP TABLE W0CASE;

--echo # obmysql sin特殊值
SELECT TAN(0 * 3.14159265359/180) FROM dual;
SELECT TAN(45 * 3.14159265359/180) FROM dual;
SELECT TAN(90 * 3.14159265359/180) FROM dual;
SELECT TAN(180 * 3.14159265359/180) FROM dual;
SELECT TAN(270 * 3.14159265359/180) FROM dual;
SELECT TAN(360 * 3.14159265359/180) FROM dual;

--echo # obmysql 静态sql
--echo # obmysql select operation
CREATE TABLE w0case(w_test0 decimal(38,10),w_test1 varchar(11));
--echo # 空值查询
SELECT sin(W_TEST0) FROM W0CASE;
INSERT INTO w0case VALUES(0,'a');
--echo # 单值查询
SELECT sin(w_test0) FROM w0case;
INSERT INTO w0case VALUES(1,'b');
INSERT INTO w0case VALUES(2,'c');
INSERT INTO w0case VALUES(3,'d');
INSERT INTO w0case VALUES(4,'e');
INSERT INTO w0case VALUES(5,'f');
INSERT INTO w0case VALUES(15,'15');
INSERT INTO w0case VALUES(15,'15f');

--echo # 多值查询
SELECT sin(w_test0) FROM w0case;
--echo # group by having
SELECT sin(w_test0) FROM W0CASE GROUP BY w_test0;
SELECT sin(w_test0),w_test1 FROM W0CASE GROUP BY w_test0,w_test1 HAVING w_test1 = 'c';
SELECT sin(w_test0),w_test1 FROM W0CASE GROUP BY w_test0,w_test1 HAVING w_test1 IN ('a','b','c');
SELECT sin(w_test0),w_test1 FROM W0CASE GROUP BY w_test0,w_test1 HAVING w_test0 BETWEEN 0 AND 4;
SELECT sin(w_test0),w_test1 FROM W0CASE GROUP BY w_test0,w_test1 HAVING sin(w_test0)>0;
SELECT sin(w_test0),sin(w_test1) FROM W0CASE GROUP BY w_test0,w_test1 HAVING sin(w_test0)>0 AND w_test1 NOT IN('a','b','c','d','e','f') ;
SELECT sin(w_test0),sin(w_test1) FROM W0CASE GROUP BY w_test0,w_test1 HAVING w_test1 NOT IN('a','b','c','d','e','f','15') ;

--echo # order by 
SELECT sin(w_test0) FROM W0CASE ORDER BY w_test0;
SELECT sin(w_test0) FROM W0CASE ORDER BY w_test0 DESC;
SELECT sin(w_test0) FROM W0CASE ORDER BY w_test0 ASC;
SELECT sin(w_test0),w_test1 FROM W0CASE ORDER BY w_test1;
SELECT sin(w_test0),w_test1 FROM W0CASE ORDER BY w_test1 DESC;
SELECT sin(w_test0),w_test1 FROM W0CASE ORDER BY w_test1 ASC;
SELECT sin(w_test0),w_test1 FROM W0CASE GROUP BY w_test0,w_test1 HAVING sin(w_test0)>0 ORDER BY w_test0 DESC;

--echo # case when
SELECT CASE w_test0 WHEN 5 THEN sin(w_test0)+100 END AS si FROM W0CASE;
SELECT sin(CASE WHEN w_test0<100 THEN sin(w_test0) END)+sin(45) AS si FROM W0CASE;
SELECT sin(CASE WHEN w_test0>100 THEN sin(w_test0) ELSE 100 END)/sin(10) AS si FROM W0CASE;
--echo # distinct
SELECT DISTINCT sin(w_test0),w_test1 FROM W0CASE;
DROP TABLE W0CASE;
--echo # obmysql insert operation
CREATE TABLE W0CASE(w_test varchar(100));
--echo # 插入单条语句
INSERT INTO W0CASE VALUES(DEFAULT);
INSERT INTO W0CASE SELECT sin(10) FROM dual;
INSERT INTO W0CASE SELECT sin(10)*2 FROM dual;
INSERT INTO W0CASE SELECT sin(10)/2 FROM dual;
DROP TABLE W0CASE;

--echo # obmysql DELETE operation
CREATE TABLE w0case(w_test varchar(100));
INSERT INTO w0case VALUES ('100');
--echo # 单行/多行
DELETE FROM W0CASE we WHERE sin(we.w_test)<sin(20) ;
--echo # where
INSERT INTO w0case VALUES ('500');
DELETE FROM w0case WHERE sin(w_test) = (SELECT sin(w_test) FROM W0CASE WHERE w_test >ROUND(sin(W_TEST ),5) GROUP BY W_TEST HAVING ROUND(sin(W_TEST ),6 )>0 ) ; 
INSERT INTO w0case VALUES ('400');
INSERT INTO w0case VALUES ('300');
DELETE FROM W0CASE WHERE sin(W_TEST) > ( SELECT * FROM ( SELECT MIN(sin(W_TEST ) ) FROM W0CASE WHERE sin(W_TEST ) < 100 ORDER BY sin(W_TEST ) ) );
INSERT INTO w0case VALUES ('200');
DELETE FROM W0CASE WHERE sin(W_TEST ) IN (SELECT sin(W_TEST ) FROM W0CASE );
INSERT INTO w0case VALUES ('800');
DELETE FROM W0CASE WHERE sin(W_TEST) = ( SELECT sin(W_TEST) FROM ( SELECT * FROM W0CASE ORDER BY sin(W_TEST ) DESC ));
DROP TABLE IF EXISTS W0CASE;
DROP TABLE IF EXISTS w1case;

--echo # obmysql dual operation
SELECT sin(45) * sin(45) FROM dual;
SELECT sin(45) / sin(45) FROM dual;
SELECT sin(45) + sin(45) FROM dual;
SELECT sin(45) - sin(45) FROM dual;

--echo # cleanup
drop database sin_test;
