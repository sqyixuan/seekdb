drop database if exists sin_test;
create database sin_test;
use sin_test;
drop table if exists w0case;
drop table if exists w1case;
# obmysql-sin 通过性测试
create table w0case(w_test varchar(100));
insert into w0case values('100');
select round(sin(w_test),5) from w0case;
round(sin(w_test),5)
-0.50637
# obmysql-sin 参数数量
select sin() from w0case;
ERROR 42000: Incorrect parameter count in the call to native function 'sin'
select round(sin(12),5) from dual;
round(sin(12),5)
-0.53657
select sin(12,1) from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'sin'
drop table w0case;
