DROP TABLE W0CASE;
# obmysql insert operation
CREATE TABLE W0CASE(w_test varchar(100));
# 插入单条语句
INSERT INTO W0CASE VALUES(DEFAULT);
INSERT INTO W0CASE SELECT sin(10) FROM dual;
INSERT INTO W0CASE SELECT sin(10)*2 FROM dual;
INSERT INTO W0CASE SELECT sin(10)/2 FROM dual;
DROP TABLE W0CASE;
# obmysql DELETE operation
CREATE TABLE w0case(w_test varchar(100));
INSERT INTO w0case VALUES ('100');
# 单行/多行
DELETE FROM W0CASE we WHERE sin(we.w_test)<sin(20) ;
# where
INSERT INTO w0case VALUES ('500');
DELETE FROM w0case WHERE sin(w_test) = (SELECT sin(w_test) FROM W0CASE WHERE w_test >ROUND(sin(W_TEST ),5) GROUP BY W_TEST HAVING ROUND(sin(W_TEST ),6 )>0 ) ;
INSERT INTO w0case VALUES ('400');
INSERT INTO w0case VALUES ('300');
DELETE FROM W0CASE WHERE sin(W_TEST) > ( SELECT * FROM ( SELECT MIN(sin(W_TEST ) ) FROM W0CASE WHERE sin(W_TEST ) < 100 ORDER BY sin(W_TEST ) ) );
INSERT INTO w0case VALUES ('200');
DELETE FROM W0CASE WHERE sin(W_TEST ) IN (SELECT sin(W_TEST ) FROM W0CASE );
INSERT INTO w0case VALUES ('800');
DELETE FROM W0CASE WHERE sin(W_TEST) = ( SELECT sin(W_TEST) FROM ( SELECT * FROM W0CASE ORDER BY sin(W_TEST ) DESC ));
DROP TABLE IF EXISTS W0CASE;
DROP TABLE IF EXISTS w1case;
