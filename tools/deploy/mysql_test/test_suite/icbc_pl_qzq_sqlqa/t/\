  PROCEDURE proc_get_pre_taskinfo(i_task_id             IN VARCHAR2,
                                  o_flag                OUT VARCHAR2,
                                  o_pre_task_name       OUT VARCHAR2,
                                  o_pre_task_transition OUT VARCHAR2) IS

  BEGIN
