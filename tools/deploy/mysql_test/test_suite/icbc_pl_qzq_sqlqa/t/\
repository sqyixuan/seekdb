  PROCEDURE proc_get_subsys_url(i_sys_code IN VARCHAR2, --系统编码
                                o_flag     OUT VARCHAR2, --返回标志
                                o_url      OUT VARCHAR2 --url
                                ) IS
    v_count VARCHAR2(4);

  BEGIN
    o_flag := '0';
    SELECT COUNT(1)
      INTO v_count
