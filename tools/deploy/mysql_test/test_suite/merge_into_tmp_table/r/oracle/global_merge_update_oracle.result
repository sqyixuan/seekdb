create global temporary table sourcetable(id int, sales int) on commit preserve rows;
create table targettable(id int primary key, sales int) partition by hash(id) partitions 4;
create index gkey on targetTable(sales) global;
create view targetView as select * from targetTable;
truncate table targetTable;
truncate table sourceTable;
insert into targetTable values(1,1),(2,2),(3,3);
insert into sourceTable values(1,2),(2,4),(3,6),(4,8);
explain merge into targetTable t1 using sourceTable t2 on (t1.id = t2.id) when matched then update set t1.sales = t2.sales;
