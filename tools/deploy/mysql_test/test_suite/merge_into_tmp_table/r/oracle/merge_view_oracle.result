drop table t_s;
drop table t_sp;
drop table t1;
drop table t2;
drop table tp1;
drop table tp2;
create global temporary table t_s(c1 int, c2 int, c3 int) on commit preserve rows;
create table t_sp(c1 int, c2 int, c3 int) partition by hash(c1) partitions 2;
create global temporary table t1(c1 int, c2 int, c3 int) on commit preserve rows;
create global temporary table t2(c1 int primary key, c2 int, c3 int, index idx_c2 (c2)) on commit preserve rows;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'index idx_c2 (c2)) on commit preserve rows' at line 1
create global temporary table t2(c1 int primary key, c2 int, c3 int) on commit preserve rows;
create index idx_c2 on t2(c2);
create table tp1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 2;
create table tp2(c1 int primary key, c2 int, c3 int, index idx(c2)) partition by hash(c1) partitions 2;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'index idx(c2)) partition by hash(c1) partitions 2' at line 1
create table tp2(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 2;
create index idx on tp2(c2);
insert into t_s values(1,1,1), (2,2,2), (3,3,3), (4,4,4), (5,5,5);
insert into t_sp select * from t_s;
insert into t1 values(0,0,0), (1,1,1), (3,3,3), (5,5,5), (7,7,7);
insert into t2 select * from t1;
insert into tp1 select * from t1;
insert into tp2 select * from t1;
create or replace view v1 as select * from t1;
create or replace view v2 as select * from t1;
create or replace view v3 as select * from tp1;
create or replace view v4 as select * from tp2;
create or replace view v5 as select * from t1 with read only;
result_format: 4
set autocommit = 0;

