drop table t1;
drop table t2;
create global temporary table t1 (c1 int primary key, c2 int, 
c3 decimal generated always as (c1 + c2), 
c4 int generated always as ((c1 + c2) * (c1 - c2)), 
c5 varchar(64) generated always as (to_char(c1 - c2)),
c6 decimal generated always as (c1 + c2 + 0) virtual) on commit preserve rows;
create global temporary table t2 (c1 int primary key, c2 decimal) on commit preserve rows;
insert into t2 values (1, 2.5), (2, 6.2), (3, 4.1);
result_format: 4
explain
merge into t1 using t2 on (t1.c1 = t2.c1) when not matched then insert (c1, c2) values (t2.c1, t2.c2);
