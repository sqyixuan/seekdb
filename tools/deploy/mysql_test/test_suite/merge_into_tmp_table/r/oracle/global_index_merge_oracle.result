result_format: 4
create table t1(c1 int, c2 int, c3 int, primary key(c1)) partition by hash(c1) partitions 4;
insert into t1 values(1, 1, 1);
insert into t1 values(2, 2, 2);
insert into t1 values(3, 3, 3);
insert into t1 values(4, 4, 4);
insert into t1 values(5, 5, 5);

create global temporary table t2(c1 int primary key, c2 int) on commit preserve rows;
insert into t2 values(1, 2);
insert into t2 values(2, 3);

explain merge into t1 using t2 on (t1.c1 = t2.c2) when matched then update set t1.c2 = t2.c2 when not matched then insert (t1.c1, t1.c2) values(t2.c1, t2.c2);
Query Plan
=======================================================================
|ID|OPERATOR                           |NAME    |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------------
|0 |DISTRIBUTED MERGE                  |        |2       |17          |
|1 |└─PX COORDINATOR                   |        |2       |17          |
|2 |  └─EXCHANGE OUT DISTR             |:EX10001|2       |16          |
|3 |    └─HASH OUTER JOIN              |        |2       |16          |
|4 |      ├─EXCHANGE IN DISTR          |        |2       |7           |
|5 |      │ └─EXCHANGE OUT DISTR (PKEY)|:EX10000|2       |5           |
|6 |      │   └─SUBPLAN SCAN           |VIEW1   |2       |3           |
|7 |      │     └─TABLE RANGE SCAN     |T2      |2       |3           |
|8 |      └─PX PARTITION ITERATOR      |        |5       |9           |
|9 |        └─TABLE FULL SCAN          |T1      |5       |9           |
=======================================================================
