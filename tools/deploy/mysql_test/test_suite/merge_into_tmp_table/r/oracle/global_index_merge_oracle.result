### 测试merge的delete、udpate和insert功能
drop table t1;
drop table t2;
create table t1(c1 int primary key, c2 int) partition by hash(c1) partitions 4;
create global temporary table t2(c1 int, c2 int) on commit preserve rows;

create index gkey on t1(c2) global;
insert into t1 values(1, 1);
insert into t1 values(2, 2);

insert into t2 values(1, 2);

merge into t1 using t2 on (t1.c1 = t2.c1) when matched then update set t1.c2 = t2.c2 delete where (t1.c2 = 2);
select * from t1;
+----+------+
| C1 | C2   |
+----+------+
|  2 |    2 |
+----+------+

truncate table t1;
truncate table t2;

insert into t1 values(1, 1);

insert into t2 values(2, 2);
merge into t1 using t2 on (t1.c1 = t2. c1) when not matched then insert(t1.c1, t1.c2) values(t2.c1, t2.c2);
select * from t1;
+----+------+
| C1 | C2   |
+----+------+
|  1 |    1 |
|  2 |    2 |
+----+------+

delete from t2;
insert into t2 values(2, 3);
merge into t1 using t2 on (t1.c1 = t2.c1) when matched then update set t1.c2 = t2.c2;
select * from t1;
+----+------+
| C1 | C2   |
+----+------+
|  1 |    1 |
|  2 |    3 |
+----+------+

truncate table t1;
truncate table t2;
insert into t1 values(1, 1);
insert into t2 values(1, 2);
insert into t2 values(1, 3);
merge into t1 using t2 on (t1.c1 = t2.c1) when matched then update set t1.c2 = t2.c2;
ERROR HY000: unable to get a stable set of rows in the source tables

drop table t1;
drop table t2;
create table t1(c1 int primary key, c2 int) partition by hash(c1) partitions 4;
create index gkey on t1(c2) global;
create global temporary table t2(c1 int, c2 int) on commit preserve rows;
insert into t1 values(1, 2);
insert into t1 values(2, 3);
insert into t2 values(1, 1);
insert into t2 values(2, 2);
create view vv as select c1, c2 from t2;
explain merge into t1 using vv on (t1.c1 = vv.c1) when matched then update set t1.c2 = 100;
