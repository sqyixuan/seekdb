###### create table ... like
drop table table1;
create table table1 (
 c0 char(50) charset utf8mb4, 
 c1 nchar(50), 
 c2 NATIONAL CHARACTER(50), 
 c3 NVARCHAR(50), 
 c4 NATIONAL VARCHAR(50), 
 c5 NATIONAL CHARACTER VARYING(50), 
 c6 NATIONAL CHAR VARYING(50),
 c7 NCHAR VARCHAR(50)
) default charset gbk;
insert into table1 values(N'char', N'nchar', N'NATIONAL CHARACTER', N'NVARCHAR', N'NATIONAL VARCHAR', N'NATIONAL CHARACTER VARYING', N'NATIONAL CHAR VARYING', N'NCHAR VARCHAR');
drop table table2;
create table table2 like table1;
insert into table2 values(N'富强', N'民主', N'文明', N'和谐', N'友善', N'爱国', N'敬业', N'自强');
