purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';
---------------------------------------------------------------------------------
########################### 标签：n_constant-1 N常量值 ###########################
select N'NULL',n'NULL';
+---------+---------+
| N'NULL' | n'NULL' |
+---------+---------+
| NULL    | NULL    |
+---------+---------+
select N'TRUE',n'TRUE';
+---------+---------+
| N'TRUE' | n'TRUE' |
+---------+---------+
| TRUE    | TRUE    |
+---------+---------+
select N'FALSE',n'FALSE';
+----------+----------+
| N'FALSE' | n'FALSE' |
+----------+----------+
| FALSE    | FALSE    |
+----------+----------+
select N'',n'';
+-----+-----+
| N'' | n'' |
+-----+-----+
|     |     |
+-----+-----+
select N'     ',n'     ';
