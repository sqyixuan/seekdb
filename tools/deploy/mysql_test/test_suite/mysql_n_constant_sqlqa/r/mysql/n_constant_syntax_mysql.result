DROP TABLE datatype_table1;
CREATE TABLE datatype_table1(
  id int,
  c1 tinyint, 
  c2 smallint,
  c3 mediumint, 
  c4 int, 
  c5 bigint, 
  c6 float, 
  c7 double, 
  c8 decimal(5,2), 
  c9 bit(10),
  c10 bool,
  c11 CHAR(10), 
  c12 VARCHAR(100), 
  c13 BINARY(100),
  c14 VARBINARY(100), 
  c15 ENUM('星期一', '星期二', '星期三', '星期四', '星期五', '星期六'), 
  c16 SET('a', 'b', 'c', 'd', 'e'),
  c17 date, 
  c18 time, 
  c19 year, 
  c20 datetime, 
  c21 timestamp,
  c22 blob,
  c23 tinyblob,
  c24 mediumblob,
  c25 longblob,
  c26 text,
  c27 tinytext,
  c28 mediumtext,
  c29 longtext,
  c30 json
);
