| 子查询    | id   | c11         |
+-----------+------+-------------+
| 子查询    |    2 | char-类型   |
+-----------+------+-------------+
SELECT N'子查询-exists' as '子查询', c1,c11 
FROM datatype_table1 
where exists (select N'子查询-exists',id from table2 where c0 = N'表 table2') ORDER BY 1;
+------------------+------+-------------+
| 子查询           | c1   | c11         |
+------------------+------+-------------+
| 子查询-exists    | NULL | NULL        |
| 子查询-exists    |    0 | char-类型   |
+------------------+------+-------------+
SELECT id,N'子查询-any' as '子查询', c1,c11 
FROM datatype_table1 
where id >= any (select id from table2 where c0 = N'表 table2') ORDER BY 1;
