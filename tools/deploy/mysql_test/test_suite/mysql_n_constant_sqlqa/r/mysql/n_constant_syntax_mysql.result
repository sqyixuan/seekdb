###### replace
drop table table3;
create table table3 (
 id int PRIMARY KEY,
 c0 char(50) charset utf8mb4, 
 c1 nchar(50), 
 c2 NATIONAL CHARACTER(50), 
 c3 NVARCHAR(50)
) default charset gbk;
replace into table3 values (1,n'replace into 1', n'N常量1', n'测试1', n'mysql模式1');
replace into table3 values (1,n'replace into 2', n'N常量2', n'测试2', n'mysql模式2');
SELECT N'update',table3.* FROM table3 ORDER BY id;
+-----------+----+----------------+----------+---------+--------------+
| N'update' | id | c0             | c1       | c2      | c3           |
+-----------+----+----------------+----------+---------+--------------+
| update    |  1 | replace into 2 | N常量2   | 测试2   | mysql模式2   |
+-----------+----+----------------+----------+---------+--------------+
############ 标签：n_constant-3-3 预处理语句
SET @var = N'PREPARE';
PREPARE stmt1 FROM 'select N''预处理语句'',? from dual';
EXECUTE stmt1 USING @var;
+--------------------+---------+
| N'预处理语句'      | ?       |
+--------------------+---------+
| 预处理语句         | PREPARE |
+--------------------+---------+
