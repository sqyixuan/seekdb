drop table table1;
create table table1 (
 c0 char(50) charset utf8mb4, 
 c1 nchar(50), 
 c2 NATIONAL CHARACTER(50), 
 c3 NVARCHAR(50), 
 c4 NATIONAL VARCHAR(50), 
 c5 NATIONAL CHARACTER VARYING(50), 
 c6 NATIONAL CHAR VARYING(50),
 c7 NCHAR VARCHAR(50)
) default charset gbk;
