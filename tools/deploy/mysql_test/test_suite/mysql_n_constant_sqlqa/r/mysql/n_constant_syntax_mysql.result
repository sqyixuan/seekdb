| id   | 子查询        | c1   | c11         |
+------+---------------+------+-------------+
|    2 | 子查询-any    |    0 | char-类型   |
+------+---------------+------+-------------+
SELECT id,N'子查询-all' as '子查询', id,c11 
FROM datatype_table1 
where id >= all (select id from table2 where c0 = N'表 table2') ORDER BY 1;
