purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';

--echo ---------------------------------------------------------------------------------
--echo ########################### 标签：n_constant-1 N常量值 ###########################
select N'NULL',n'NULL';
select N'TRUE',n'TRUE';
select N'FALSE',n'FALSE';
select N'',n'';
select N'     ',n'     ';
select N'oceanbase',n'oceanbase';
select N'ｏｃｅａｎｂａｓｅ',n'ｏｃｅａｎｂａｓｅ';
select N'MYSQL', N'mysql',n'MYSQL', n'mysql';
select N'mysql', N'包含单引号 '' ', N'包含双引号 " ';
select n'mysql', n'包含单引号 '' ', n'包含双引号 " ';

select n'"包含多个单双引号"' from dual;
--error 1064
select n''"包含多个单双引号"'' from dual;
select n'''"包含多个单双引号"''' from dual;
--error 1064
select n''''"包含多个单双引号"'''' from dual;

--error 1054
select N"mysql";
--error 1054
select N"包含单引号 ' ";
--error 1054
select N"包含双引号 "" ";
select N'-10',N'0', N'10', N'3.1415926';
select n'-10',n'0', n'10', n'3.1415926';
select N'2023-05-25', N'12:00:00', N'2023-05-25 12:00:00';
select n'2023-05-25', n'12:00:00', n'2023-05-25 12:00:00';
select N'中国', N'中國',n'中国', n'中國';
select N'안녕하세요', n'안녕하세요';
select N'こんにちは', N'コンニチハ', n'こんにちは', n'コンニチハ';
select N'!@#$%^&*、？', n'!@#$%^&*、？';
select N'\0', n'\0';
select N'\n', n'\n';
select N'\r', n'\r';
select N'\t', n'\t';
select N'\b', n'\b';
select N'\Z', n'\Z';
select N'\'', n'\'';
select N'\"', n'\"';
select N'\\', n'\\';
select N'\%', n'\%';
select N'\_', n'\_';
select N'abcdefghijklmnopqrstuvwxyz1234567890abcdefghijklmnopqrstuvwxyz1234567890abcdefghijklmnopqrstuvwxyz1234567890abcdefghijklmnopqrstuvwxyz1234567890
abcdefghijklmnopqrstuvwxyz1234567890abcdefghijklmnopqrstuvwxyz1234567890abcdefghijklmnopqrstuvwxyz1234567890abcdefghijklmnopqrstuvwxyz1234567890';
