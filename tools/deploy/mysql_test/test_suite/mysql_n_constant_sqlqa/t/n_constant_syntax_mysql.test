--echo ########################### 标签：n_constant-3 SQL场景 ###########################
--echo ############ 标签：n_constant-3-1 DDL操作
--echo ###### create table
--echo ### 普通表
--echo ## 约束 - check 约束
--error 0,1051
drop table table1;
create table table1 (c1 nchar(50) check (c1 <> N'空'));

--error 3819
insert into table1 values('空');
--error 3819
insert into table1 values('空 ');
--error 3819
insert into table1 values(N'空');
--error 3819
insert into table1 values(_utf8'空');
--error 3819
insert into table1 values(_utf8mb4'空');
--error 3819
insert into table1 values(_binary'空');

insert into table1 values(' 空 ');
insert into table1 values(_gbk'空');
insert into table1 values(_latin1'空');
insert into table1 values(_gb18030'空');
insert into table1 values(_utf16'空');


--echo ## 约束 - default 约束
--error 0,1051
drop table table1;

create table table1 (id int, c1 nchar(50) default N'默认值');

insert into table1 (id) values(1);
select * from table1;

--echo ## 索引
--error 0,1051
drop table table1;
create table table1 (c1 nchar(50), index idx1 ((concat(N'2023-',c1))));


--echo ## 生成列表达式包含N常量
--error 0,1051
drop table table1;
create table table1 (c1 nchar(50), c2 nchar(50) as (concat(N'2023-',c1)));

insert into table1 (c1) values('05-26');
select * from table1;


--echo ## N常量作为表名
--error 1064
drop table N'table1';
--error 1064
create table N'table1'(c1 nchar(50));


--echo ### 分区表
--error 0,1051
drop table table1;
--error 1697
CREATE TABLE table1 ( 
  id INT NOT NULL,
  c1 int)  
PARTITION BY RANGE (abs(N'2'+c1))( 
PARTITION p0 VALUES LESS THAN (6), 
PARTITION p1 VALUES LESS THAN MAXVALUE);


--echo ###### alter table
--echo ### 添加列
--error 0,1051
drop table table1;
create table table1 (
  id int, 
  c0 NVARCHAR(50));

alter table table1 add column c1 NVARCHAR(50) default N'默认值';

--echo # bug2:
#--error 4016
alter table table1 add column c2 NVARCHAR(50) check (c2 <> N'0');
alter table table1 add column c3 NVARCHAR(50) as (concat(N'2023-',c0));

#show create table table1;
insert into table1(id,c0) values(1,N'05-26');
--error 3819
insert into table1(id,c2) values(2,N'0');
#--error 1054
insert into table1(id,c2) values(3,N'2023');

--sorted_result
select * from table1;


--echo ### 修改列
--error 0,1051
drop table table1;
create table table1 (
  id int, 
  c0 NVARCHAR(50), 
  c1 NVARCHAR(50));

alter table table1 alter column c0 set default N'c0 默认值';
alter table table1 change column c1 new_c1 NVARCHAR(50) default N'new_c1 默认值';

show create table table1;
insert into table1(id) values(1);

--sorted_result
select * from table1;


--echo ### 添加约束
--error 0,1051
drop table table1;
create table table1 (
  id int, 
  c0 NVARCHAR(50));

alter table table1 add CONSTRAINT ck1 check (c0 <> N'0');
alter table table1 add index indx1 ((concat(N'2023-',c0)));

show create table table1;

--error 3819
insert into table1(id,c0) values(1,N'0');
insert into table1(id,c0) values(2,N'05-26');

--sorted_result
select * from table1;


--echo ###### create table ... select
--error 0,1051
drop table table1;
create table table1 select N'N常量测试' from dual;
insert into table1 values(N'mysql');

--sorted_result
select * from table1;

--error 0,1051
drop table table1;
create table table1 (
 c0 char(50) charset utf8mb4, 
 c1 nchar(50), 
 c2 NATIONAL CHARACTER(50), 
 c3 NVARCHAR(50), 
 c4 NATIONAL VARCHAR(50), 
 c5 NATIONAL CHARACTER VARYING(50), 
 c6 NATIONAL CHAR VARYING(50),
 c7 NCHAR VARCHAR(50)
) default charset gbk;
insert into table1 values(N'char', N'nchar', N'NATIONAL CHARACTER', N'NVARCHAR', N'NATIONAL VARCHAR', N'NATIONAL CHARACTER VARYING', N'NATIONAL CHAR VARYING', N'NCHAR VARCHAR');

--error 0,1051
drop table table2;
create table table2 select N'N常量1',table1.* from table1;
insert into table2 values(N'N常量2',N'富强', N'民主', N'文明', N'和谐', N'友善', N'爱国', N'敬业', N'自强');

--sorted_result
select * from table2;


--echo ###### create table ... like
--error 0,1051
drop table table1;
create table table1 (
 c0 char(50) charset utf8mb4, 
 c1 nchar(50), 
 c2 NATIONAL CHARACTER(50), 
 c3 NVARCHAR(50), 
 c4 NATIONAL VARCHAR(50), 
 c5 NATIONAL CHARACTER VARYING(50), 
 c6 NATIONAL CHAR VARYING(50),
 c7 NCHAR VARCHAR(50)
) default charset gbk;
insert into table1 values(N'char', N'nchar', N'NATIONAL CHARACTER', N'NVARCHAR', N'NATIONAL VARCHAR', N'NATIONAL CHARACTER VARYING', N'NATIONAL CHAR VARYING', N'NCHAR VARCHAR');

--error 0,1051
drop table table2;
create table table2 like table1;
insert into table2 values(N'富强', N'民主', N'文明', N'和谐', N'友善', N'爱国', N'敬业', N'自强');

--sorted_result
select * from table2;


--echo ############ 标签：n_constant-3-2 DML操作
--echo ###### select
--echo ### select
--error 0,1051
DROP TABLE datatype_table1;
CREATE TABLE datatype_table1(
  id int,
  c1 tinyint, 
  c2 smallint,
  c3 mediumint, 
  c4 int, 
  c5 bigint, 
  c6 float, 
  c7 double, 
  c8 decimal(5,2), 
  c9 bit(10),
  c10 bool,
  c11 CHAR(10), 
  c12 VARCHAR(100), 
  c13 BINARY(100),
  c14 VARBINARY(100), 
  c15 ENUM('星期一', '星期二', '星期三', '星期四', '星期五', '星期六'), 
  c16 SET('a', 'b', 'c', 'd', 'e'),
  c17 date, 
  c18 time, 
  c19 year, 
  c20 datetime, 
  c21 timestamp,
  c22 blob,
  c23 tinyblob,
  c24 mediumblob,
  c25 longblob,
  c26 text,
  c27 tinytext,
  c28 mediumtext,
  c29 longtext,
  c30 json
);
insert into datatype_table1 values(1,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,b'0',FALSE,NULL,NULL,NULL,NULL,NULL,NULL,'2023-05-29','12:59:59.99999999','2022','2023-01-01 23:59:59.999999','2024-01-01 01:30:07.999999','blob1','TINYBLOB1','MEDIUBLOB1','LONGBLOB1','TEXT1','TINYTEXT1','MEDIUTEXT1','LONGTEXT1','{"a":1,"b":1}');
insert into datatype_table1 values(2,0,1,2,3,4,5.0,6.0,7.0,b'0',FALSE,'char-类型','VARCHAR-类型','BINARY-类型','VARBINARY-类型','星期一','a,b,c','9999-12-31','23:59:59.99999999','2023','2023-12-31 23:59:59.999999','2025-01-01 03:30:07.999999','blob2','TINYBLOB2','MEDIUBLOB2','LONGBLOB2','TEXT2','TINYTEXT2','MEDIUTEXT2','LONGTEXT2','{"a":1,"b":1}');

--error 0,1051
drop table table2;
create table table2 (
 id int,
 c0 char(50) charset utf8mb4, 
 c1 nchar(50), 
 c2 NATIONAL CHARACTER(50), 
 c3 NVARCHAR(50), 
 c4 NATIONAL VARCHAR(50), 
 c5 NATIONAL CHARACTER VARYING(50), 
 c6 NATIONAL CHAR VARYING(50),
 c7 NCHAR VARCHAR(50)
) default charset gbk;
insert into table2 values(2,N'表 table2', N'nchar', N'NATIONAL CHARACTER', N'NVARCHAR', N'NATIONAL VARCHAR', N'NATIONAL CHARACTER VARYING', N'NATIONAL CHAR VARYING', N'NCHAR VARCHAR');
insert into table2 values(3,N'表 table2', N'自', N'强', N'不', N'息', N'爱', N'国', N'！');

--sorted_result
select N'oceanbase 模式',N'N常量测试' as 'N别名' ,c1,c11,c17,c22 from datatype_table1;
--error 1064
select N'N常量测试' as N'N别名'  from datatype_table1;


--echo ### from 子句
--echo ### select
--error 0,1051
DROP view view1;
CREATE view view1 as select * from datatype_table1;

--sorted_result
select N'oceanbase 模式',N'N常量测试' as 'N别名' ,c1,c11,c17,c22 from view1;
select N'oceanbase 模式',N'N常量测试' as 'N别名';
select N'oceanbase 模式',N'N常量测试' as 'N别名' from dual;
--error 1064
select N'oceanbase 模式' from datatype_table1 as 'N别名';


--echo ### where 子句
--sorted_result
select id,N'where 子句',c1,c11,c17,c22 from datatype_table1 where c2 >= N'1' order by 1;
select id,N'where 子句',c1,c11,c17,c22 from datatype_table1 where c11 = N'char-类型' order by 1;
select id,N'where 子句',c1,c11,c17,c22 from datatype_table1 where c12 like N'VARCHAR-类型' order by 1;
select id,N'where 子句',c1,c11,c17,c22 from datatype_table1 where c19 = N'2023' order by 1;


--echo ### order by 子句
--sorted_result
select id,N'order by 子句',c1,c11,c17,c22 from datatype_table1 order by N'1';
select id,N'order by 子句',c1,c11,c17,c22 from datatype_table1 order by N'N常量';


--echo ### group by having 子句
--sorted_result
select id,N'group by having 子句',c1,c2,count(*) from datatype_table1 group by c1 having c2 >= N'1' order by 1;


--echo ### distinct
--sorted_result
select distinct N'distinct',N'N常量测试' as 'N别名' from datatype_table1 order by 1;


--echo ### case when
--sorted_result
SELECT id,c1,c11,CASE WHEN c11 = N'char-类型' THEN N'case-when 分支' ELSE N'else 分支' END FROM datatype_table1 ORDER BY 1;


--echo ### 连接查询
--sorted_result
SELECT left1.id,N'等值连接' as '连接查询', left1.c11, right1.c0 FROM datatype_table1 left1,table2 right1 where left1.id=right1.id ORDER BY 1;
SELECT left1.id,N'左连接' as '连接查询', left1.c11, right1.c0 FROM datatype_table1 left1 left join table2 right1 on left1.id=right1.id ORDER BY 1;
SELECT left1.id,N'右连接' as '连接查询', left1.c11, right1.c0 FROM datatype_table1 left1 right join table2 right1 on left1.id=right1.id ORDER BY 1;
SELECT left1.id,N'内连接' as '连接查询', left1.c11, right1.c0 FROM datatype_table1 left1 inner join table2 right1 on left1.id=right1.id ORDER BY 1;


--echo ### 子查询
--sorted_result
SELECT N'子查询' as '子查询', id,c11 
FROM datatype_table1 
where ( N'子查询',id) in (select N'子查询',id from table2) ORDER BY 1;

SELECT N'子查询-exists' as '子查询', c1,c11 
FROM datatype_table1 
where exists (select N'子查询-exists',id from table2 where c0 = N'表 table2') ORDER BY 1;

SELECT id,N'子查询-any' as '子查询', c1,c11 
FROM datatype_table1 
where id >= any (select id from table2 where c0 = N'表 table2') ORDER BY 1;

SELECT id,N'子查询-all' as '子查询', id,c11 
FROM datatype_table1 
where id >= all (select id from table2 where c0 = N'表 table2') ORDER BY 1;

UPDATE datatype_table1 e 
INNER JOIN  table2 p ON e.c1 = p.id 
SET e.c11 = N'update' where p.id = 1;
--sorted_result
SELECT id,N'update set',c1,c11 FROM datatype_table1 ORDER BY 1;

WITH a AS (
SELECT id,N'WITH as 子查询',upper(c11)
FROM datatype_table1) 
SELECT * FROM a ORDER BY 1;

--sorted_result
SELECT id,N'Like 查询',c11 FROM datatype_table1 where upper(c11) like N'CHAR-类型' ORDER BY 1;

--echo ### select ... into 语句
select N'select into 语句',c11 into @p1,@p2 from datatype_table1 where id = 2 ORDER BY 1;
select @p1, @p2;


--echo ###### 集合运算
--echo ### UNION
SELECT id,N'UNION table1'
FROM datatype_table1
UNION
SELECT id,N'UNION table2'
FROM table2 ORDER BY 1;

--echo ### INTERSECT
SELECT id,N'UNION table1'
FROM datatype_table1 
INTERSECT
SELECT id,N'UNION table1'
FROM table2 ORDER BY 1;

--echo ### EXCEPT
SELECT id,N'UNION table1'
FROM datatype_table1 
EXCEPT
SELECT id,N'UNION table1'
FROM table2 ORDER BY 1;


--echo ###### insert
insert into table2 values(4,N'insert into', N'mysql', N'oracle', N'sql', N'pl/sql', N'oceanbase', N'dba', N'china');
insert into table2 values(5,n'insert into', n'nchar', n'nvarchar', n'national character', n'nchar varchar', n'national', n'character', n'varying');
insert into table2 select 6,N'INSERT INTO', N'NCHAR', N'NVARCHAR', N'NATIONAL CHARACTER', N'NCHAR VARCHAR', N'NATIONAL', N'CHARACTER', N'VARYING' from dual;
--sorted_result
SELECT N'insert',* FROM table2 ORDER BY id;

insert into datatype_table1(id,c1,c2,c3,c4,c5,c6,c7,c8,c9,c10) values(3,N'11',N'12',N'13',N'14',N'15',N'16',N'17',N'18',N'1',N'1');
insert into datatype_table1(id,c11,c12,c13,c14,c15,c16)values(4,N'char',N'VARCHAR',N'BINARY',N'VARBINARY',N'1',N'1');
insert into datatype_table1(id,c17,c18,c19,c20,c21)values(5,N'2023-05-29',N'12:00:00.000000',N'2023',N'2023-12-31 23:59:59.999999',N'2024-01-01 01:01:01.000000');
insert into datatype_table1(id,c22,c23,c24,c25,c26,c27,c28,c29,c30)values(6,N'blob5',N'TINYBLOB5',N'MEDIUBLOB5',N'LONGBLOB5',N'TEXT5',N'TINYTEXT5',N'MEDIUTEXT5',N'LONGTEXT5',N'{"a":5,"b":5}');
--sorted_result
SELECT N'insert number',id,c1,c2,c3,c4,c5,c6,c7,c8,c9,c10 FROM datatype_table1 ORDER BY id;
SELECT N'insert char',id,c11,c12,c13,c14,c15,c16 FROM datatype_table1 ORDER BY id;
SELECT N'insert date',id,c17,c18,c19,c20,c21 FROM datatype_table1 ORDER BY id;
SELECT N'insert blob',id,c22,c23,c24,c25,c26,c27,c28,c29,c30 FROM datatype_table1 ORDER BY id;


--echo ######  update      
update table2 set c1 = N'',c2 = N'update',c3 = N'更新' where id = N'2';
--sorted_result
SELECT N'update',table2.* FROM table2 ORDER BY id;


--echo ######  delete
--sorted_result
SELECT N'delete',datatype_table1.* FROM datatype_table1 where c29 = N'LONGTEXT5' and id = 6 ORDER BY id;
delete from datatype_table1 where c29 = N'LONGTEXT5' and id = 6;
--sorted_result
SELECT N'delete',datatype_table1.* FROM datatype_table1 where c29 = N'LONGTEXT5' and id = 6 ORDER BY id;


--echo ###### replace
--error 0,1051
drop table table3;
create table table3 (
 id int PRIMARY KEY,
 c0 char(50) charset utf8mb4, 
 c1 nchar(50), 
 c2 NATIONAL CHARACTER(50), 
 c3 NVARCHAR(50)
) default charset gbk;

replace into table3 values (1,n'replace into 1', n'N常量1', n'测试1', n'mysql模式1');
replace into table3 values (1,n'replace into 2', n'N常量2', n'测试2', n'mysql模式2');

--sorted_result
SELECT N'update',table3.* FROM table3 ORDER BY id;


