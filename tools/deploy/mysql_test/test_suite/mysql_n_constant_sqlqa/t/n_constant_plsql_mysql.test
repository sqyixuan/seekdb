# owner: zhanyue.zzy
# owner group: SQL-优化器
# description: mysql模式N常量的写法 - PL/SQL场景，N常量间运算
# tags: DDL,DML
# author: whh01047778


purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';

--echo ---------------------------------------------------------------------------------
--echo ########################### 标签：n_constant-4 PL/SQL场景 #######################
--echo ############ 标签：n_constant-4-1 存储过程
--echo ###### 存储过程创建
DELIMITER //;
--error 1064
CREATE PROCEDURE N'pro1'()
begin
  null;
END;
//
DELIMITER ;//

--echo ###### 存储过程参数
--echo ### 无参数的存储过程
--echo ## 变量声明-N常量作为局部变量默认值，N常量赋值给局部变量
--error 0,1051
drop table table1;
create table table1 (
 id int PRIMARY KEY,
 c0 char(50) charset utf8mb4, 
 c1 nchar(50), 
 c2 NATIONAL CHARACTER(50), 
 c3 NVARCHAR(50)
) default charset gbk;

set @user_var =N'N常量->用户自定义变量';

DELIMITER //;
--error 0,1305
DROP PROCEDURE pro1;//
CREATE PROCEDURE pro1()
begin
  declare var1 char(50) charset utf8mb4 default N'N常量->局部变量 var1';
  declare var2 VARCHAR(50) CHARACTER SET utf8;
  set var2 = N'N常量->局部变量 var2';
  insert into table1 values (1,N'pro1', @user_var,var1, var2);
END;
//
DELIMITER ;//

CALL pro1();
SELECT * FROM table1 ORDER BY 1;

--echo ## 只有一个in参数的存储过程
--echo ## 存储过程的调用-N常量作为实参传递
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro2;//
CREATE PROCEDURE pro2(in invalue VARCHAR(50) CHARACTER SET utf8)
begin
  declare var1 char(50) charset utf8mb4 default N'N常量->局部变量 var1';
  insert into table1 values (2,N'pro2', @user_var, var1,invalue);
END;
//
DELIMITER ;//

CALL pro2(N'N常量->实参');
SELECT * FROM table1 ORDER BY 1;

--echo ## 包含out参数的存储过程
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro3;//
CREATE PROCEDURE pro3(out outa VARCHAR(50) CHARACTER SET utf8)
begin
  declare var1 char(50) charset utf8mb4 default N'N常量->局部变量 var1';
  select N'N常量->out参数' into outa from dual;
  insert into table1 values (3,N'pro3', @user_var,var1,outa);
END;
//
DELIMITER ;//

CALL pro3(@outa);
SELECT * FROM table1 ORDER BY 1;
SELECT N'@outa=',@outa;

--echo ## 包含inout参数的存储过程
--echo ## 存储过程的调用-N常量赋值给用户自定义变量，用户自定义变量作为实参
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro4;//
CREATE PROCEDURE pro4(INOUT inouta VARCHAR(50) CHARACTER SET utf8)
begin
  declare var1 char(50) charset utf8mb4 default N'N常量->局部变量 var1';
  declare var2 char(50) charset utf8mb4;
  set var2 = inouta;
  select N'N常量->修改inout参数' into inouta from dual;
  insert into table1 values (4,N'pro4',inouta,var1,var2);
END;
//
DELIMITER ;//

SET @inouta = N'N常量->inout参数';
CALL pro4(@inouta);
SELECT * FROM table1 ORDER BY 1;
SELECT @inouta;


--echo ###### 存储过程体
--echo ### dml语句
--echo ## 条件语句
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro5;//
CREATE PROCEDURE pro5(IN invalue VARCHAR(50) CHARACTER SET utf8)
begin
  IF invalue = N'N常量' THEN 
    insert into table1 values (5,N'pro5',N'IF 分支',invalue,N'');
  ELSE 
    insert into table1 values (6,N'pro5',N'ELSE 分支',invalue,N'');
  END IF;
END;
//
DELIMITER ;//

SET @invalue := N'N常量';
CALL pro5(@invalue);
SELECT * FROM table1 ORDER BY 1;


SET @invalue := N'N常量ELSE';
CALL pro5(@invalue);
SELECT * FROM table1 ORDER BY 1;

--echo ## 循环语句
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro6;//
CREATE PROCEDURE pro6()
begin
  declare i int default 7;
  declare var VARCHAR(50) CHARACTER SET utf8 default N'N常量->var default';
  WHILE i <= 9 do
    INSERT INTO table1 VALUES(i,N'pro6',n'While循环',@user_var,var);
    set i := i+1;
  END WHILE;
  
  loop_name:LOOP
    INSERT INTO table1 VALUES(i,N'pro6',n'Loop循环',@user_var,var);
    SET i := i+1;
    IF i > 11 THEN 
      LEAVE loop_name;
    END IF;
  END LOOP loop_name;
  
  REPEAT
    INSERT INTO table1 VALUES(i,N'pro6',n'Repeat循环',@user_var,var);
    SET i := i+1;
    until i > 13	
  END REPEAT;
END;
//
DELIMITER ;//

CALL pro6();
SELECT * FROM table1 ORDER BY 1;


--echo ### 变量声明
--echo ## 声明游标
--error 0,1051
drop table table2;
create table table2 (
 id int PRIMARY KEY,
 c0 char(50) charset utf8mb4, 
 c1 nchar(50), 
 c2 NATIONAL CHARACTER(50), 
 c3 NVARCHAR(50)
) default charset gbk;

DELIMITER //;
--error 0,1305
DROP PROCEDURE pro7;//
CREATE PROCEDURE pro7()
BEGIN
  DECLARE n int;
  DECLARE a VARCHAR(50) CHARACTER SET utf8;
  DECLARE b VARCHAR(50) CHARACTER SET utf8;  
  DECLARE done INT DEFAULT 0;
  DECLARE cur1 CURSOR FOR SELECT id,N'table1 c3=',c3 FROM table1 where id < 5;
  DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
  
  OPEN cur1;
  FETCH cur1 INTO n,a,b;
  WHILE done <> 1 DO
    INSERT INTO table2 VALUES(n,N'pro7',N'声明游标',a,b);
    FETCH cur1 INTO n,a,b;
  END WHILE;
  CLOSE cur1;
END;
//
DELIMITER ;//

CALL pro7();
SELECT * FROM table2 ORDER BY 1;


--echo ### 动态sql
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro8;//
CREATE PROCEDURE pro8()
BEGIN
  SET @s = 'INSERT INTO table2 VALUES(5,N''pro8'',N''动态sql INSERT'',?,?);';
  PREPARE stm1 FROM @s;
  SET @a = N'N常量->@a';
  SET @b = N'N常量->@b';
  EXECUTE stm1 USING @a,@b;

  SET @s = 'SELECT * FROM table2 WHERE id = 5';
  PREPARE stmt2 FROM @s;
  EXECUTE stmt2; 
END;
//
DELIMITER ;//

CALL pro8();

DELIMITER //;
--error 0,1305
DROP PROCEDURE pro9;//
CREATE PROCEDURE pro9()
BEGIN
  SET @s = 'update table2 set c2 = ?,c3 = ? WHERE id = 5;';
  PREPARE stmt1 FROM @s;
  SET @a = N'N常量->@a update';
  SET @b = N'N常量->@b update';
  EXECUTE stmt1 USING @a,@b;

  SET @s = 'SELECT * FROM table2 WHERE id = 5';
  PREPARE stmt2 FROM @s;
  EXECUTE stmt2; 
  
  SET @s = 'delete FROM table2 WHERE c2 = ?';
  PREPARE stmt4 FROM @s;
  SET @a = N'N常量->@a update';
  EXECUTE stmt4 USING @a;

  SET @s = 'SELECT * FROM table2 WHERE c2 = ?';
  PREPARE stmt5 FROM @s;
  SET @a = N'N常量->@a update';
  EXECUTE stmt5 USING @a;
END;
//
DELIMITER ;//

CALL pro9();


--echo ############ 标签：n_constant-4-2 自定义函数
--echo ###### 函数创建
DELIMITER //;
--error 1064
CREATE FUNCTION N'fun1'() returns varchar(200) READS SQL DATA 
begin
  null;
END;
//
DELIMITER ;//


--echo ###### 函数参数
--echo ### 无参的函数，函数的调用
DELIMITER //;
--error 0,1305
DROP FUNCTION fun2;//
CREATE FUNCTION fun2() returns VARCHAR(50) CHARACTER SET utf8 READS SQL DATA 
begin
  declare a VARCHAR(50) CHARACTER SET utf8;
  SELECT N'N常量->fun2' into a FROM dual;
  return a;
END;
//
DELIMITER ;//

SELECT fun2();


--echo ### 有参的函数 
DELIMITER //;
--error 0,1305
DROP FUNCTION fun3;//
CREATE FUNCTION fun3(invalue varchar(200)) returns  varchar(200) READS SQL DATA 
begin
  declare a VARCHAR(50) CHARACTER SET utf8;
  SELECT invalue into a FROM dual;
  return a;
END ;
//
DELIMITER ;//

SELECT fun3(N'N常量->实参');

--echo ###### 函数体，函数返回值
--echo ### dml语句，变量声明
--echo ## 条件语句
DELIMITER //;
--error 0,1305
DROP FUNCTION fun4;//
CREATE FUNCTION fun4 (invalue VARCHAR(50) CHARACTER SET utf8) returns  varchar(200) READS SQL DATA 
begin
  IF invalue = N'N常量' THEN 
    insert into table1 values (21,N'fun4',N'IF 分支',invalue,N'2023-05-30');
  ELSE 
    insert into table1 values (22,N'fun4',N'ELSE 分支',invalue,N'2023-05-30');
  END IF;
  return N'N常量->fun4 条件语句 OK';
END;
//
DELIMITER ;//

SET @invalue := N'N常量';
SELECT fun4(@invalue);
SELECT * FROM table1 where id >20 ORDER BY 1;


SET @invalue := N'N常量ELSE';
SELECT fun4(@invalue);
SELECT * FROM table1 where id >20 ORDER BY 1;


--echo ## 循环语句
DELIMITER //;
--error 0,1305
DROP FUNCTION fun5;//
CREATE FUNCTION fun5() returns varchar(200) READS SQL DATA 
begin
  declare i int default 23;
  declare var1 VARCHAR(50) CHARACTER SET utf8 default N'N常量->var1 default';
  declare var2 VARCHAR(50) CHARACTER SET utf8;
  set var2 = N'N常量->var2';
  WHILE i <= 25 do
    INSERT INTO table1 VALUES(i,N'fun5',n'While循环',var1,var2);
    set i := i+1;
  END WHILE;
  
  loop_name:LOOP
    INSERT INTO table1 VALUES(i,N'fun5',n'Loop循环',var1,var2);
    SET i := i+1;
    IF i > 27 THEN 
      LEAVE loop_name;
    END IF;
  END LOOP loop_name;
  
  REPEAT
    INSERT INTO table1 VALUES(i,N'fun5',n'Repeat循环',var1,var2);
    SET i := i+1;
    until i > 29	
  END REPEAT;
  return N'N常量->fun5 循环语句 OK';
END;
//
DELIMITER ;//

SELECT fun5();
SELECT * FROM table1 where id >20 ORDER BY 1;


--echo ############ 标签：n_constant-4-3 触发器
--echo ###### 触发器创建
--error 0,1051
DROP TABLE table3;
CREATE TABLE table3(id int,c1 NVARCHAR(50));

DELIMITER //;
--error 1064
CREATE TRIGGER N'tri1' BEFORE INSERT ON table3 FOR EACH ROW
BEGIN
  null;
END;
//
DELIMITER ;//


--echo ###### 触发器体
DELIMITER //;
--error 0,1360
DROP TRIGGER tri2;//
CREATE TRIGGER tri2 BEFORE INSERT ON table3 FOR EACH ROW
BEGIN
  declare a int;
  declare var1 VARCHAR(50) CHARACTER SET utf8 default N'N常量->var1 default';
  declare var2 VARCHAR(50) CHARACTER SET utf8;
  set var2 = N'N常量->var2';
  set a = 31;
  loop1: LOOP
    if a < 36 then
      INSERT INTO table1 VALUES(a,N'tri2',n'N常量->INSERT',var1,var2);
    elseif a = 37 then
      update table1 set c1 = 'N常量->update' WHERE id >= 34;
      LEAVE loop1;
    else
      delete FROM table1 WHERE id = 33;	
    end if;
    set a = a + 1;
  end LOOP loop1;
END;
//
DELIMITER ;//

INSERT INTO table3 VALUES(1,N'INSERT ON table3 触发触发器');
SELECT * FROM table1 where id >30 ORDER BY 1;


--echo ---------------------------------------------------------------------------------
--echo ######################## 标签：n_constant-5 N常量间运算 #########################
--echo ############ 标签：n_constant-5-1 算术运算符
select N'算术运算符',N'2' + N'3' - N'12' / N'3' from dual;
select N'算术运算符',N'14' DIV N'3',  N'14' MOD N'3' from dual;


--echo ############ 标签：n_constant-5-2 逻辑运算符
select N'逻辑运算符',not N'2' and N'3' or N'12' xor N'3' from dual;


--echo ############ 标签：n_constant-5-3 位运算符
select N'位运算符', N'2' & N'3' | ! N'12' ^ N'3' from dual;
select N'位运算符', N'2' << N'3' , N'2' >> N'3' from dual;


--echo ############ 标签：n_constant-5-4 比较运算符 
select N'比较运算符 =', N'Oceanbase' = N'OCEANBASE' from dual;
select N'比较运算符 >', N'数据库' > N'數據庫' from dual;
select N'比较运算符 <', N'3.1415' < N'3.14150' from dual;
select N'比较运算符 !=', N'N常量' != N'N常量' from dual;
select N'比较运算符 <>', N'3.1415' <> N'3.14150' from dual;
select N'比较运算符 in', N'3.1415' in (N'3.14',N'3.141',N'3.1415',N'3.14150') from dual;
select N'比较运算符 not in', N'欢' not in (N'欢欢',N'欢欢欢',N'欢欢欢欢') from dual;
select N'比较运算符 between and', N'5' between N'1' and N'5' from dual;
select N'比较运算符 not between and', N'菠' not between N'爱' and N'测' from dual;
select N'比较运算符 <=>', N'11' <=> N'NULL' from dual;
select N'比较运算符 <=>', N'11' <=> NULL from dual;
select N'比较运算符 <=>', N'NULL' <=> N'NULL' from dual;
select N'比较运算符 LIKE', N'NULL' LIKE N'NULL' from dual;
select N'比较运算符 LIKE', N'NULL' LIKE N'%NULL%' from dual;
select N'比较运算符 LIKE', N'china' LIKE N'CHINA' from dual;
select N'比较运算符 LIKE', N'china' LIKE N'%na%' from dual;
select N'比较运算符 LIKE', N'chinb' LIKE N'%chin_%' from dual;
select N'比较运算符 LIKE', N'https://dev.mysql.com' LIKE N'%//%' from dual;
select N'比较运算符 LIKE', N'https://dev.mysql.com' LIKE N'%://%' ESCAPE N'/' from dual;
select N'比较运算符 REGEXP', N'https://dev.mysql.com' REGEXP N'^http.*com$' from dual;
select N'比较运算符 RLIKE', N'https://dev.mysql.com' RLIKE N'com$' from dual;


--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user whh@'%';
--enable_warnings
