# description: mysql模式N常量的写法 - N常量作为函数参数
# tags: DDL,DML
# author: whh01047778


purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';


--echo ---------------------------------------------------------------------------------
--echo ###################### 标签：n_constant-6 N常量作为函数参数 #####################
--echo ############ 标签：n_constant-6-1 数字函数

select ABS(N'N常量'),ABS(N'-123') from dual;
select AVG(N'N常量'),AVG(N'123') from dual;
select CEIL(N'N常量'),CEIL(N'3.1415926') from dual;
select SIGN(N'N常量'),SIGN(N'3.1415926') from dual;
