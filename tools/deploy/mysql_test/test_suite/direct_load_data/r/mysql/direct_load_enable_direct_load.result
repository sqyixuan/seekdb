use test;
alter system set direct_load_allow_fallback=False;
create table t1 (c1 int, c2 int);
insert into t1 values(1,2),(3,4);
================ test mview complete refresh =========
create materialized view mv1 refresh complete as select * from t1;
ERROR 0A000: Not supported feature or function
================ test insert overwrite =========
create table t2 (c1 int, c2 int);
insert overwrite t2 select * from t1;
ERROR 0A000: normal table overwrite using non-direct insert is not supported
drop table t1;
drop table t2;
alter system set direct_load_allow_fallback=True;
