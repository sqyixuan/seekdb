set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 1000000000000;
create table t1 (c1 int primary key, c2 int, c3 int);
create table t2 (c1 int primary key, c2 int, c3 int);
create table t3 (c1 int primary key, c2 int, c3 int);
create table t4 (c1 int primary key, c2 int, c3 int) partition by range(c1) (
partition p0 values less than(10),
partition p1 values less than(20),
partition p2 values less than(30),
partition p3 values less than (MAXVALUE)
);
insert into t1 values (1,1,1), (11,11,11), (21,21,21), (31,31,31);
insert into t2 values (2,2,2), (12,12,12);
insert into t3 values (23,23,23), (33,33,33);
begin;
insert /*+ direct(true, 0, 'inc') enable_parallel_dml(2) parallel(2) */ into t4 select * from t1;
# query obj lock
2
2
2
2
commit;
begin;
insert /*+ direct(true, 0, 'inc') enable_parallel_dml(2) parallel(2) */ into t4 partition(p0, p1) select * from t2;
# query obj lock
2
2
0
0
begin;
insert /*+ direct(true, 0, 'inc') enable_parallel_dml(2) parallel(2) */ into t4 partition(p2, p3) select * from t3;
# query obj lock
2
2
2
2
commit;
# query obj lock
0
0
2
2
commit;
select count(*) from t4;
count(*)
8
drop table if exists t1, t2, t3, t4;
