set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
alter system set schema_history_recycle_interval = '0s';
alter system set schema_history_expire_time = '1m';
# range partition
create table t1_ins_overwrt (c1 int primary key, c2 int) partition by range(c1)(
partition p0 values less than(10),
partition p1 values less than (MAXVALUE)
);
create table t2_ins_overwrt (c1 int primary key, c2 int) partition by range(c1)(
partition p0 values less than(10),
partition p1 values less than (MAXVALUE)
);
insert into t1_ins_overwrt values (3, 20), (7, 40);
insert into t2_ins_overwrt values (3, 60), (8, 80), (17, 170), (26, 260), (29, 290), (142, 1420);
insert overwrite t2_ins_overwrt partition(p0) select * from t1_ins_overwrt;
create table t3_ins_overwrt (c1 int primary key, c2 int);
create table t4_ins_overwrt (c1 int primary key, c2 int)
partition by range(c1)
subpartition by hash(c1) subpartitions 2
(
partition p0 values less than (10),
Partition p1 values less than (MAXVALUE)
);
insert into t3_ins_overwrt values (1, 10), (2, 20), (11, 110), (12, 120);
insert overwrite t4_ins_overwrt partition (p0sp1) select * from t3_ins_overwrt where c1 = 1;
set @@session.recyclebin = off;
set @@session.ob_enable_truncate_flashback = off;
alter system set schema_history_recycle_interval = '10s';
alter system major freeze tenant=sys;
alter system major freeze tenant=all_user;
alter system major freeze tenant=all_meta;
alter system major freeze tenant=sys;
alter system major freeze tenant=all_user;
alter system major freeze tenant=all_meta;
alter system major freeze tenant=sys;
alter system major freeze tenant=all_user;
alter system major freeze tenant=all_meta;
alter system major freeze tenant=sys;
alter system major freeze tenant=all_user;
alter system major freeze tenant=all_meta;
part_name	part_idx	is_deleted
p0	0	0
sub_part_name	sub_part_idx	is_deleted
p0sp1	1	0
drop table t1_ins_overwrt;
drop table t2_ins_overwrt;
drop table t3_ins_overwrt;
drop table t4_ins_overwrt;
