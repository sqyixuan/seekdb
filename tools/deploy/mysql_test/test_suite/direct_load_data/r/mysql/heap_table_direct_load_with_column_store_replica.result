drop tenant if exists tenant1 force;
DROP RESOURCE POOL if exists pool_1;
DROP RESOURCE UNIT if exists unit_1;
drop table if exists t1;
drop table if exists tload;
drop sequence if exists s1;
set @@ob_query_timeout=1000000000;
alter system set _rowsets_max_rows = 512;
create table t1 (k int, v1 int, v2 int, v3 int);
create table tload (k int, v1 int, v2 int, v3 int);
create sequence s1 cache 1000000 noorder;
insert into tload select s1.nextval, s1.nextval, s1.nextval, s1.nextval from table(generator(100000));
insert /*+ enable_parallel_dml parallel(2) append*/ into t1 select * from tload;
drop table t1;
drop table tload;
drop sequence s1;
drop tenant tenant1 force;
DROP RESOURCE POOL pool_1;
DROP RESOURCE UNIT unit_1;
