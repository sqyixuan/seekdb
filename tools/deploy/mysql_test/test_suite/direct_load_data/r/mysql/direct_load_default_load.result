use test;
alter system set direct_load_allow_fallback=False;
================ test default load mode =========
create table t1 (c1 int, c2 int);
create table t2 (c1 int, c2 int);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
alter system set default_load_mode='DISABLED';
explain extended_noaddr insert /*+ enable_parallel_dml parallel(2) */ into t2 select * from t1;
