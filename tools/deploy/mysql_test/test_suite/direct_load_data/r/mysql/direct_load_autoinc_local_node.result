# TEST 6
drop table if exists t1;
create table t1(
id bigint NOT NULL AUTO_INCREMENT,
name  varchar(40)  NOT NULL
);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
INSERT INTO t1 (id, name) VALUES (500, 'id=500 insert');
INSERT INTO t1 (id, name) VALUES (null, 'id=null insert');
select count(*) from t1;
count(*)
15
# TEST 7
drop table if exists t1;
create table t1(
id bigint NOT NULL AUTO_INCREMENT,
name  varchar(40)  NOT NULL,
primary key (id)
)partition by key(id) partitions 10;
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
INSERT INTO t1 (id, name) VALUES (500, 'id=500 insert');
INSERT INTO t1 (id, name) VALUES (null, 'id=null insert');
select count(*) from t1;
count(*)
15
select id from t1 where id=501;
id
501
drop table t1;
alter system set direct_load_allow_fallback=True;
