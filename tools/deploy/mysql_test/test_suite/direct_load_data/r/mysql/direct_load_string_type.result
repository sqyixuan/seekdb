alter system set direct_load_allow_fallback=False;
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
================ test insert into select =========
create table t1(c1 string, c2 string, c3 string, primary key(c1));
create sequence seq_c1 cache 1000000 noorder;
insert /*+ enable_parallel_dml parallel(4) append */ into t1 select RANDSTR(20000, seq_c1.nextval), RANDSTR(10, random(1)), RANDSTR(10, random(1)) from table(generator(1));
ERROR 42000: Specified key was too long; max key length is 16384 bytes
insert /*+ enable_parallel_dml parallel(4) append */ into t1 select RANDSTR(2000, seq_c1.nextval), RANDSTR(10, random(1)), RANDSTR(10, random(1)) from table(generator(1));
select length(c1),length(c2), length(c3) from t1;
length(c1)	length(c2)	length(c3)
2000	10	10
set _enable_rich_vector_format=false;
insert /*+ enable_parallel_dml parallel(4) append */ into t1 select RANDSTR(20000, seq_c1.nextval), RANDSTR(10, random(1)), RANDSTR(10, random(1)) from table(generator(1));
ERROR 42000: Specified key was too long; max key length is 16384 bytes
insert /*+ enable_parallel_dml parallel(4) append */ into t1 select RANDSTR(2000, seq_c1.nextval), RANDSTR(10, random(1)), RANDSTR(10, random(1)) from table(generator(1));
select length(c1),length(c2), length(c3) from t1;
length(c1)	length(c2)	length(c3)
2000	10	10
2000	10	10
alter system set _rowsets_enabled=False;
insert /*+ enable_parallel_dml parallel(4) append */ into t1 select RANDSTR(20000, seq_c1.nextval), RANDSTR(10, random(1)), RANDSTR(10, random(1)) from table(generator(1));
ERROR 42000: Specified key was too long; max key length is 16384 bytes
insert /*+ enable_parallel_dml parallel(4) append */ into t1 select RANDSTR(2000, seq_c1.nextval), RANDSTR(10, random(1)), RANDSTR(10, random(1)) from table(generator(1));
select length(c1),length(c2), length(c3) from t1;
length(c1)	length(c2)	length(c3)
2000	10	10
2000	10	10
2000	10	10
set _enable_rich_vector_format=True;
alter system set _rowsets_enabled=True;
================ test row length larger than limit chunk size =========
insert /*+ enable_parallel_dml parallel(4) append */ into t1 select RANDSTR(2000, seq_c1.nextval), RANDSTR(10485760, random(1)), RANDSTR(10485760, random(1)) from table(generator(10));
select length(c1), length(c2), length(c3) from t1 order by length(c2);
length(c1)	length(c2)	length(c3)
2000	10	10
2000	10	10
2000	10	10
2000	10485760	10485760
2000	10485760	10485760
2000	10485760	10485760
2000	10485760	10485760
2000	10485760	10485760
2000	10485760	10485760
2000	10485760	10485760
2000	10485760	10485760
2000	10485760	10485760
2000	10485760	10485760
drop table t1;
drop sequence seq_c1;
================ test load data =========
create table lineitem(
l_orderkey           string NOT NULL ,
l_partkey            bigint NOT NULL ,
l_suppkey            bigint NOT NULL ,
l_linenumber         bigint NOT NULL ,
l_quantity           bigint NOT NULL ,
l_extendedprice      decimal(10,2) NOT NULL ,
l_discount           decimal(10,2) NOT NULL ,
l_tax                decimal(10,2) NOT NULL ,
l_returnflag         char(1) ,
l_linestatus         char(1) ,
l_shipdate           date ,
l_commitdate         date ,
l_receiptdate        date ,
l_shipinstruct       char(25) ,
l_shipmode           char(10) ,
l_comment            varchar(44),
primary key(l_orderkey, l_linenumber)
);
ERROR 42000: Specified key was too long
length(l_orderkey)
2000
drop table lineitem;
alter system set direct_load_allow_fallback=True;
