alter system set direct_load_allow_fallback=False;
drop table if exists spatial_index_dml;
drop table if exists spatial_index_dml2;
CREATE TABLE spatial_index_dml (i int, g GEOMETRY NOT NULL SRID 0, PRIMARY KEY (i));
CREATE INDEX idx ON spatial_index_dml (g);
CREATE TABLE spatial_index_dml2 (i int, g GEOMETRY NOT NULL SRID 0, PRIMARY KEY (i));
INSERT INTO spatial_index_dml2 VALUES (1, ST_GEOMFROMTEXT('POINT(0 0)', 0));
insert /*+ direct(true,100) enable_parallel_dml parallel(2) */ into spatial_index_dml select * from spatial_index_dml2;
ERROR 0A000: direct-load does not support table with spatial index
drop table spatial_index_dml;
drop table spatial_index_dml2;
alter system set direct_load_allow_fallback=True;
