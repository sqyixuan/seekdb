alter system set direct_load_allow_fallback=False;
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
# create tables
create table partition_test_t1 (c1 int primary key, c2 int, c3 int) partition by range(c1) (
partition p0 values less than(10),
partition p1 values less than(20),
partition p2 values less than(30),
partition p3 values less than (MAXVALUE)
);
create table partition_test_t2 (c1 int primary key, c2 int, c3 int) partition by range(c1) (
partition p0 values less than(10),
partition p1 values less than(20),
partition p2 values less than(30),
partition p3 values less than (MAXVALUE)
);
# insert into select to all partitions
# tablet id before insert into select to all partitions
insert /*+ enable_parallel_dml parallel(3) append */ into partition_test_t2 select * from partition_test_t1;
# tablet id after insert into select to all partitions
# judge tablet_id is equal after insert into select to all partitions
old_p0_tablet_id != new_p0_tablet_id
old_p1_tablet_id != new_p1_tablet_id
old_p2_tablet_id != new_p2_tablet_id
old_p3_tablet_id != new_p3_tablet_id
# insert into select to partition p0, p3
drop table if exists partition_test_t2;
create table partition_test_t2 (c1 int primary key, c2 int, c3 int) partition by range(c1) (
partition p0 values less than(10),
partition p1 values less than(20),
partition p2 values less than(30),
partition p3 values less than (MAXVALUE)
);
# tablet id before insert into select to partition p0, p3
insert /*+ enable_parallel_dml parallel(3) append */ into partition_test_t2 partition(p0, p3) select * from partition_test_t1 partition(p0, p3);
# tablet id after insert into select to partition p0, p3
# judge tablet_id is equal after insert into select to partition p0, p3
old_p0_tablet_id != new_p0_tablet_id
old_p1_tablet_id == new_p1_tablet_id
old_p2_tablet_id == new_p2_tablet_id
old_p3_tablet_id != new_p3_tablet_id
# insert into select to partition p1, p2
# tablet id before insert into select to partition p1, p2
insert /*+ enable_parallel_dml parallel(3) append */ into partition_test_t2 partition(p1, p2) select * from partition_test_t1 partition(p1, p2);
# tablet id after insert into select to partition p1, p2
# judge tablet_id is equal after insert into select to partition p1, p2
old_p0_tablet_id == new_p0_tablet_id
old_p1_tablet_id != new_p1_tablet_id
old_p2_tablet_id != new_p2_tablet_id
old_p3_tablet_id == new_p3_tablet_id
drop table if exists partition_test_t2;
# insert into select partition for table with local index
create table partition_test_t2 (c1 int primary key, c2 int, c3 int) partition by range(c1) (
partition p0 values less than(10),
partition p1 values less than(20),
partition p2 values less than(30),
partition p3 values less than (MAXVALUE)
);
create index idx1 on partition_test_t2(c1, c2) local;
# tablet id after insert into select to partition p1, p2
insert /*+ enable_parallel_dml parallel(3) append */ into partition_test_t2 partition(p1, p2) select * from partition_test_t1 partition(p1, p2);
# tablet id after insert into select to partition p1, p2
# judge tablet_id is equal after insert into select to partition p1, p2
old_p0_tablet_id == new_p0_tablet_id
old_p1_tablet_id != new_p1_tablet_id
old_p2_tablet_id != new_p2_tablet_id
old_p3_tablet_id == new_p3_tablet_id
drop table if exists partition_test_t2;
# insert into select partition for table with global index
create table partition_test_t2 (c1 int primary key, c2 int, c3 int) partition by range(c1) (
partition p0 values less than(10),
partition p1 values less than(20),
partition p2 values less than(30),
partition p3 values less than (MAXVALUE)
);
create index idx1 on partition_test_t2(c1, c2) global;
ERROR 0A000: partition level direct-load for table has global index is not supported
drop table if exists partition_test_t2;
# insert into select partition for duplicate table
create table partition_test_t2 (c1 int primary key, c2 int, c3 int)  partition by range(c1) (
partition p0 values less than(10),
partition p1 values less than(20),
partition p2 values less than(30),
partition p3 values less than (MAXVALUE)
);
drop table if exists partition_test_t2;
# insert table with hash partition type
create table partition_test_t2 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 5;
insert /*+ enable_parallel_dml parallel(3) append */ into partition_test_t2 partition(p1, p2) select * from partition_test_t1 partition(p1, p2);
select * from partition_test_t2;
c1	c2	c3
11	11	11
21	21	21
drop table if exists partition_test_t2;
# list partitions
drop table if exists partition_test_t1;
create table partition_test_t1 (c1 int primary key, c2 int, c3 int) partition by list(c1)(
partition p0 values in (1, 2, 3, 4),
partition p1 values in (11, 12, 13, 14),
partition p2 values in (21, 22, 23, 24),
partition p3 values in (31, 32, 33, 34)
);
create table partition_test_t2 (c1 int primary key, c2 int, c3 int) partition by list(c1)(
partition p0 values in (1, 2, 3, 4),
partition p1 values in (11, 12, 13, 14),
partition p2 values in (21, 22, 23, 24),
partition p3 values in (31, 32, 33, 34)
);
# insert into select to all list partitions
