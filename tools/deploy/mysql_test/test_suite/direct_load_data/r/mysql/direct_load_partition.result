# load data partition for subpartition
create table partition_test_t1 (c1 int primary key, c2 int, c3 int)
partition by list(c1) subpartition by range(c1)
subpartition template
(
subpartition p0 values less than (10),
subpartition p1 values less than (20),
subpartition p2 values less than (30),
subpartition p3 values less than (MAXVALUE)
)
(
partition p0 values in (1, 6, 11, 16, 21, 26, 31, 36),
partition p1 values in (2, 7, 12, 17, 22, 27, 32, 37),
partition p2 values in (3, 8, 13, 18, 23, 28, 33, 38),
partition p3 values in (4, 9, 14, 19, 24, 29, 34, 39)
);
old_p0_tablet_id == new_p0_tablet_id
old_p1_tablet_id == new_p1_tablet_id
old_p2_tablet_id == new_p2_tablet_id
old_p3_tablet_id == new_p3_tablet_id
old_p0sp0_tablet_id != new_p0sp0_tablet_id
old_p0sp1_tablet_id == new_p0sp1_tablet_id
old_p0sp2_tablet_id == new_p0sp2_tablet_id
old_p0sp3_tablet_id == new_p0sp3_tablet_id
old_p1sp0_tablet_id == new_p1sp0_tablet_id
old_p1sp1_tablet_id != new_p1sp1_tablet_id
old_p1sp2_tablet_id == new_p1sp2_tablet_id
old_p1sp3_tablet_id == new_p1sp3_tablet_id
old_p2sp0_tablet_id == new_p2sp0_tablet_id
old_p2sp1_tablet_id == new_p2sp1_tablet_id
old_p2sp2_tablet_id != new_p2sp2_tablet_id
old_p2sp3_tablet_id == new_p2sp3_tablet_id
old_p3sp0_tablet_id == new_p3sp0_tablet_id
old_p3sp1_tablet_id == new_p3sp1_tablet_id
old_p3sp2_tablet_id == new_p3sp2_tablet_id
old_p3sp3_tablet_id != new_p3sp3_tablet_id
drop table if exists partition_test_t1;
alter system set direct_load_allow_fallback=True;
