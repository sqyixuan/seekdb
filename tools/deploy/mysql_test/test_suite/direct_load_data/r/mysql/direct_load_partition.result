alter system set direct_load_allow_fallback=False;
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
create table partition_test_t1 (c1 int primary key, c2 int, c3 int) partition by range(c1) (
partition p0 values less than(10),
partition p1 values less than(20),
partition p2 values less than(30),
partition p3 values less than (MAXVALUE)
);
# load data partition all partitions
# tablet_id before load data partition all partitions
# tablet_id after load data partition all partitions
# judge tablet_id is equal after load data partition all partitions
old_p0_tablet_id_1 != new_p0_tablet_id_1
old_p1_tablet_id_1 != new_p1_tablet_id_1
old_p2_tablet_id_1 != new_p2_tablet_id_1
old_p3_tablet_id_1 != new_p3_tablet_id_1
# load data partition p0, p1, p2
# tablet_id before load data partition p0, p1, p2
# tablet_id after load data partition p0, p1, p2
# judge tablet_id is equal after load data partition p0, p1, p2
old_p0_tablet_id_2 != new_p0_tablet_id_2
old_p1_tablet_id_2 != new_p1_tablet_id_2
old_p2_tablet_id_2 != new_p2_tablet_id_2
old_p3_tablet_id_2 == new_p3_tablet_id_2
# load data partition p0, p3
# tablet_id before load data partition p0, p3
# tablet_id after load data partition p0, p3
# judge tablet_id is equal after load data partition p0, p3
old_p0_tablet_id_3 != new_p0_tablet_id_3
old_p1_tablet_id_3 == new_p1_tablet_id_3
old_p2_tablet_id_3 == new_p2_tablet_id_3
old_p3_tablet_id_3 != new_p3_tablet_id_3
# load data partition not all data hit the partition
ERROR HY000: Table has no partition for value
drop table partition_test_t1;
# load data partition table with auto_increment columns
create table partition_test_t1 (c1 int auto_increment, c2 int, c3 int) partition by range(c2) (
partition p0 values less than(10),
partition p1 values less than(20),
partition p2 values less than(30),
partition p3 values less than (MAXVALUE)
);
ERROR 0A000: partition level direct-load for table has auto increment column is not supported
drop table partition_test_t1;
# load data partition for table with global index
create table partition_test_t1 (c1 int primary key, c2 int, c3 int) partition by range(c1) (
partition p0 values less than(10),
partition p1 values less than(20),
partition p2 values less than(30),
partition p3 values less than (MAXVALUE)
);
create index idx1 on partition_test_t1(c1, c2) global;
ERROR 0A000: partition level direct-load for table has global index is not supported
drop table if exists partition_test_t1;
# load data partition for table with local index
create table partition_test_t1 (c1 int primary key, c2 int, c3 int) partition by range(c1) (
partition p0 values less than(10),
partition p1 values less than(20),
partition p2 values less than(30),
partition p3 values less than (MAXVALUE)
);
create index idx1 on partition_test_t1(c1, c2) local;
# tablet_id after load data partition p0, p3
# judge tablet_id is equal after load data partition p0, p3
old_p0_tablet_id_3 != new_p0_tablet_id_3
old_p1_tablet_id_3 != new_p1_tablet_id_3
old_p2_tablet_id_3 != new_p2_tablet_id_3
old_p3_tablet_id_3 == new_p3_tablet_id_3
drop table if exists partition_test_t1;
# load data partition for duplicate table
create table partition_test_t1 (c1 int primary key, c2 int, c3 int) partition by range(c1) (
partition p0 values less than(10),
partition p1 values less than(20),
partition p2 values less than(30),
partition p3 values less than (MAXVALUE)
);
drop table if exists partition_test_t1;
# insert table with hash partition type
create table partition_test_t1 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 5;
select * from partition_test_t1;
c1	c2	c3
13	13	13
23	23	23
3	3	3
drop table if exists partition_test_t1;
# list partitions
create table partition_test_t1 (c1 int primary key, c2 int, c3 int) partition by list(c1)(
partition p0 values in (1, 2, 3, 4),
partition p1 values in (11, 12, 13, 14),
partition p2 values in (21, 22, 23, 24),
partition p3 values in (31, 32, 33, 34)
);
# load data partition all partitions
# tablet_id before load data partition all partitions
# tablet_id after load data partition all partitions
# judge tablet_id is equal after load data partition all partitions
old_p0_tablet_id_1 != new_p0_tablet_id_1
old_p1_tablet_id_1 != new_p1_tablet_id_1
old_p2_tablet_id_1 != new_p2_tablet_id_1
old_p3_tablet_id_1 != new_p3_tablet_id_1
