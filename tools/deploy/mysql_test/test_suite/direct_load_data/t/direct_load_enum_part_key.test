--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: cyh438514
# owner group: Storage
# description: direct load enum part key case

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc
--source mysql_test/test_suite/direct_load_data/include/copy_data_for_direct_load.inc

--disable_warnings
--disable_query_log
drop table if exists t1;
--enable_query_log
--enable_warnings

set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;

create table t1(c1 int, c2 int, c3 enum('a', 'b', 'c'), c4 enum('d','e','f')) partition by key(c3) partitions 2 subpartition by key(c4) subpartitions 2;
--disable_query_log
eval load data /*+ parallel(10) direct(true, 0) */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/bugfix/2025041600108293360.csv' into table t1 fields terminated by '|' lines terminated by '\n';
--enable_query_log

select * from t1 order by c1;

# Clean Up
drop table t1;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_true.inc
