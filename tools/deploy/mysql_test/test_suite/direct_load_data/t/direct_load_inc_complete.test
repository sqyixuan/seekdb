--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jianming.cjq
# owner group: Storage
# description: direct load inc case

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc
--source mysql_test/test_suite/direct_load_data/include/copy_data_for_direct_load.inc

--disable_warnings
--disable_query_log
drop table if exists t_pqTly6tEb1;
drop table if exists t1_pqTly6tEb1;
drop table if exists t2_pqTly6tEb1;
drop table if exists t3_pqTly6tEb1;
drop table if exists t4_pqTly6tEb1;
drop table if exists t5_pqTly6tEb1;
drop table if exists t6_pqTly6tEb1;
drop table if exists lineitem;
drop view if exists tab_stat_view;
drop view if exists col_stat_view;
drop view if exists modified_data_view;
--enable_query_log
--enable_warnings

--echo ================ test heap table with with multi unique index =========
create table t1_pqTly6tEb1  (c1 int, c2 varchar(1000));
create table t2_pqTly6tEb1  (c1 int, c2 varchar(1000));
create unique index i1 on t2_pqTly6tEb1(c1);
create unique index i2 on t2_pqTly6tEb1(c2);
insert into t1_pqTly6tEb1 values(1,'hello'), (2, 'world'), (3, 'maybe very long text longer than ten chars'), (4, 'kkk');
--error 1235
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;

drop table t1_pqTly6tEb1;
drop table t2_pqTly6tEb1;

--echo ================ test heap table with single local unique index =========
create table t1_pqTly6tEb1  (c1 int, c2 varchar(1000));
create table t2_pqTly6tEb1  (c1 int, c2 varchar(1000));
create table t3_pqTly6tEb1  (c1 int, c2 varchar(1000));
create index i1 on t3_pqTly6tEb1(c1);
create unique index i2 on t3_pqTly6tEb1(c2);

insert into t1_pqTly6tEb1 values(1,'hello'), (2, 'world'), (3, 'maybe very long text longer than ten chars'), (4, 'kkk');
insert into t2_pqTly6tEb1 values(7,'hello'), (8, 'world');

let $idx1 = query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id = 
(select table_id from oceanbase.__all_virtual_table where table_name = 't3_pqTly6tEb1') and table_name like "%i1%", table_name, 1);

let $idx2 = query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id = 
(select table_id from oceanbase.__all_virtual_table where table_name = 't3_pqTly6tEb1') and table_name like "%i2%", table_name, 1);

insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t3_pqTly6tEb1 select * from t1_pqTly6tEb1;
--disable_query_log
set ob_enable_index_direct_select = 1;
eval select * from t3_pqTly6tEb1  order by c1;
eval select * from $idx1  order by c1;
eval select * from $idx2  order by c2;
--enable_query_log


insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t3_pqTly6tEb1 select * from t2_pqTly6tEb1;
--disable_query_log
set ob_enable_index_direct_select = 1;
eval select * from t3_pqTly6tEb1  order by c1;
eval select * from $idx1  order by c1;
eval select * from $idx2  order by c2;
--enable_query_log

drop table t1_pqTly6tEb1;
drop table t2_pqTly6tEb1;
drop table t3_pqTly6tEb1;

--echo ================ test heap table with single local unique index with lob ====
create table t1_pqTly6tEb1  (c1 int, c2 text);
create table t2_pqTly6tEb1  (c1 int, c2 text) lob_inrow_threshold = 0;
create unique index i1 on t2_pqTly6tEb1(c1);

insert into t1_pqTly6tEb1 values(1, 'aa'), (2, 'bb');
insert into t2_pqTly6tEb1 values(1, 'cc'), (2, 'dd'), (3, 'ee');

insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;
--disable_query_log
eval select * from t2_pqTly6tEb1  order by c1;
--enable_query_log

drop table t1_pqTly6tEb1;
drop table t2_pqTly6tEb1;

--echo ================ test heap table with single local unique index ignore ====
create table t1_pqTly6tEb1  (c1 int, c2 varchar(1000));
create unique index i1 on t1_pqTly6tEb1(c2);

insert into t1_pqTly6tEb1 values(1,'hello'), (2, 'world'), (3, 'maybe very long text longer than ten chars');
--disable_query_log
eval load data /*+ direct(true, 0, 'inc') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/load_data_inc3.csv' ignore into table t1_pqTly6tEb1 fields terminated by ',';
--enable_query_log
let $idx1 = query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id = 
(select table_id from oceanbase.__all_virtual_table where table_name = 't1_pqTly6tEb1') and table_name like "%i1%", table_name, 1);
--disable_query_log
set ob_enable_index_direct_select = 1;
eval select * from t1_pqTly6tEb1  order by c1;
eval select * from $idx1  order by c2;
--enable_query_log

drop table t1_pqTly6tEb1;

--echo ================ test heap table with single local unique index with fault-tolerant ====
create table t1_pqTly6tEb1  (c1 int, c2 varchar(1000));
create unique index i1 on t1_pqTly6tEb1(c2);

--disable_query_log
eval load data /*+ direct(true, 10, 'inc') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/load_data_inc3.csv' into table t1_pqTly6tEb1 fields terminated by ',';
--enable_query_log
let $idx1 = query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id = 
(select table_id from oceanbase.__all_virtual_table where table_name = 't1_pqTly6tEb1') and table_name like "%i1%", table_name, 1);
--disable_query_log
set ob_enable_index_direct_select = 1;
eval select * from t1_pqTly6tEb1  order by c1;
eval select * from $idx1  order by c2;
--enable_query_log

drop table t1_pqTly6tEb1;

--echo ================ test heap table with single local unique index ignore with lob ====
create table t1_pqTly6tEb1  (c1 int, c2 text) lob_inrow_threshold = 0;
create unique index i1 on t1_pqTly6tEb1(c1);

insert into t1_pqTly6tEb1 values(4,'aaa'), (5, 'bbb'), (6, 'bbb');
--disable_query_log
eval load data /*+ direct(true, 0, 'inc') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/load_data_inc3.csv' ignore into table t1_pqTly6tEb1 fields terminated by ',';
--enable_query_log
let $idx1 = query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id = 
(select table_id from oceanbase.__all_virtual_table where table_name = 't1_pqTly6tEb1') and table_name like "%i1%", table_name, 1);
--disable_query_log
set ob_enable_index_direct_select = 1;
eval select * from t1_pqTly6tEb1  order by c1;
eval select * from $idx1  order by c1;
--enable_query_log

drop table t1_pqTly6tEb1;

--echo ================ test index organized table with unique index =========
create table t1_pqTly6tEb1  (c1 int primary key, c2 varchar(1000));
create table t2_pqTly6tEb1  (c1 int primary key, c2 varchar(1000));
create unique index i1 on t2_pqTly6tEb1(c2);

insert into t1_pqTly6tEb1 values(1,'hello'), (2, 'world'), (3, 'maybe very long text longer than ten chars'), (4, 'kkk');
--error 1235
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;

drop table t1_pqTly6tEb1;
drop table t2_pqTly6tEb1;

--echo ================ test insert into select direct load mode =========
create table t1_pqTly6tEb1  (c1 int primary key, c2 text) lob_inrow_threshold = 0;
create table t2_pqTly6tEb1  (c1 int primary key, c2 text) lob_inrow_threshold = 0;
insert into t1_pqTly6tEb1 values(1,'hello'), (2, 'world'), (3, repeat('1', 7000)), (4, 'kkk');
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;

--error 1062
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;

drop table t1_pqTly6tEb1;
drop table t2_pqTly6tEb1;

--echo ================ test load data direct load mode =========
create table lineitem(
l_orderkey           bigint NOT NULL ,
l_partkey            bigint NOT NULL ,
l_suppkey            bigint NOT NULL ,
l_linenumber         bigint NOT NULL ,
l_quantity           bigint NOT NULL ,
l_extendedprice      decimal(10,2) NOT NULL ,
l_discount           decimal(10,2) NOT NULL ,
l_tax                decimal(10,2) NOT NULL ,
l_returnflag         char(1) ,
l_linestatus         char(1) ,
l_shipdate           date ,
l_commitdate         date ,
l_receiptdate        date ,
l_shipinstruct       char(25) ,
l_shipmode           char(10) ,
l_comment            varchar(44),
primary key(L_ORDERKEY, L_LINENUMBER)
) partition by hash(l_orderkey) partitions 10;
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;

--disable_query_log
eval load data /*+ parallel(2) direct(true, 0, 'inc') */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k.tbl" into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
eval load data /*+ parallel(2) direct(true, 0, 'inc') */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k.tbl" ignore into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';

--error 1235
eval load data /*+ parallel(2) direct(true, 0, 'inc_replace') */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k.tbl" replace into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--error 1235
eval load data /*+ parallel(2) direct(true, 0, 'inc_replace') */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k.tbl" ignore into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--error 1235
eval load data /*+ parallel(2) direct(true, 0, 'inc') */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k.tbl" replace into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--enable_query_log

drop table lineitem;

--echo ================ test delete lob_id =========
create table t1_pqTly6tEb1  (c1 int primary key, c2 text) lob_inrow_threshold = 0;
create table t2_pqTly6tEb1  (c1 int primary key, c2 text) lob_inrow_threshold = 0;
insert into t1_pqTly6tEb1 values(1,'hello'), (2, 'world'), (3, repeat('1', 7000)), (4, 'kkk');
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;

let $__table_name__ = 't2_pqTly6tEb1';
--source mysql_test/test_suite/direct_load_data/include/query_lob_meta_line_count.inc

insert into t1_pqTly6tEb1 values(5,'aaa');
insert into t2_pqTly6tEb1 values(5,'aaa');
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;

let $__table_name__ = 't2_pqTly6tEb1';
--source mysql_test/test_suite/direct_load_data/include/query_lob_meta_line_count.inc

drop table t1_pqTly6tEb1;
drop table t2_pqTly6tEb1;

--echo ============= test delete insert engine whether delete row is full =======
create table t1_pqTly6tEb1 (c1 int primary key, c2 varchar (20)) merge_engine = delete_insert;
create table t2_pqTly6tEb1 (c1 int primary key, c2 varchar (20));
create table t3_pqTly6tEb1 (c1 int primary key, c2 varchar (20));
insert into t2_pqTly6tEb1 values (1, "fwef"), (2, "gref"), (3, "fewgoremog");
insert into t3_pqTly6tEb1 values (2, "mgionroem");
insert /*+ direct(true, 0, 'full') enable_parallel_dml parallel(2) */ INTO t1_pqTly6tEb1 select * from t2_pqTly6tEb1;
insert /*+ direct(true, 0, 'inc_replace') enable_parallel_dml parallel(2) */ INTO t1_pqTly6tEb1 select * from t3_pqTly6tEb1;
delete from t1_pqTly6tEb1 where c2 > "f";

drop table t1_pqTly6tEb1;
drop table t2_pqTly6tEb1;
drop table t3_pqTly6tEb1;
--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_true.inc
