# owner: cyh438514
# owner group: Storage Group
# description: direct load data

connection default;
--enable_query_log
use test;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc

# create table
--disable_warnings
drop table if exists fts_t1;
drop table if exists fts_t2;
--enable_warnings

create table fts_t1 (c1 int primary key, c2 varchar(4096));
create table fts_t2 (c1 int primary key, c2 varchar(4096), fulltext index idx(c2));

# insert data into fts_t1
insert into fts_t1 values(1, "Gerard A. Gerry Salton (8 March 1927 – 28 August 1995) was a professor of Computer Science at Cornell University. Salton was perhaps the leading computer scientist working in the field of information retrieval during his time, and the father of Information Retrieval");
insert into fts_t1 values(2, "Edgar Frank Ted Codd (19 August 1923 – 18 April 2003) was an English computer scientist who, while working for IBM, invented the relational model for database management, the theoretical basis for relational databases and relational database management systems. ");
insert into fts_t1 values(3, "Michael Ralph Stonebraker (born October 11, 1943[6]) is a computer scientist specializing in database systems. Through a series of academic prototypes and commercial startups, Stonebraker's research and products are central to many relational databases. ");
insert into fts_t1 values(4, "Geoffrey Everest Hinton CC FRS FRSC (born 6 December 1947) is a British-Canadian computer scientist and cognitive psychologist, most noted for his work on artificial neural networks.");
insert into fts_t1 values(5, "Yann André LeCun[1] (born 8 July 1960) is a Turing Award winning French computer scientist working primarily in the fields of machine learning, computer vision, mobile robotics and computational neuroscience.");
insert into fts_t1 values(6, "Kenneth Lane Thompson (born February 4, 1943) is an American pioneer of computer science. Thompson worked at Bell Labs for most of his career where he designed and implemented the original Unix operating system. ");
insert into fts_t1 values(7, "Gordon David Plotkin, FRS FRSE MAE (born 9 September 1946) is a theoretical computer scientist in the School of Informatics at the University of Edinburgh. Plotkin is probably best known for his introduction of structural operational semantics (SOS) and his work on denotational semantics.");
insert into fts_t1 values(8, "Leslie B. Lamport (born February 7, 1941) is an American computer scientist and mathematician. Lamport is best known for his seminal work in distributed systems, and as the initial developer of the document preparation system LaTeX");
insert into fts_t1 values(9, "asdavoiajf oweirjweoifjsofmcspodkow cmdowm owejocwpe fowecofow ow weor pksdkm foe owei");
insert into fts_t1 values(10, "pqowepqo pweuijkfn dmclsjrqowep kdlsnvkfdjh oweifj oqfj oewijfpqwo kpew jfpqokd wpqkc owq");

# direct load data into t2
insert /*+ direct(true, 0, 'full') enable_parallel_dml parallel(2) query_timeout(100000000000) */ into fts_t2 select * from fts_t1;

# qeury t2
select count(*) from fts_t2;
select * from fts_t2;

# Clean Up
drop table fts_t1;
drop table fts_t2;
--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_true.inc
