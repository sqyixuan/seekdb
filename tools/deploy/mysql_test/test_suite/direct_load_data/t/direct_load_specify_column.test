show variables like 'explicit_defaults_for_timestamp';

set explicit_defaults_for_timestamp = OFF;
create table t_pqTly6tEb1 (
    c1 int,
    c2 int,
    c3 int,

    c_timestamp_1 timestamp null,
    c_timestamp_2 timestamp, # šľöŤá™Śä®Śä†šłänot null defult '0000-00-00 00:00:00'
    c_timestamp_def1 timestamp default '2024-08-06',
    c_timestamp_def2 timestamp default '2024-08-06 10:00:00'
);
--disable_query_log
eval load data /*+ direct(true, 0, 'full') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t_pqTly6tEb1 fields terminated by ',' (c3, c1, c2);
--enable_query_log
insert into t_pqTly6tEb1 (c1, c2, c3) values (1111, 2222, 3333);
select * from t_pqTly6tEb1;
drop table t_pqTly6tEb1;

create table t_pqTly6tEb1 (
    c1 int,
    c2 int,
    c3 int,

    c_timestamp timestamp # šľöŤá™Śä®Śä†šłänot null default current_timestamp
);
--disable_query_log
--error 1235
eval load data /*+ direct(true, 0, 'full') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t_pqTly6tEb1 fields terminated by ',' (c3, c1, c2);
--enable_query_log
drop table t_pqTly6tEb1;

set explicit_defaults_for_timestamp = ON;
create table t_pqTly6tEb1 (
    c1 int,
    c2 int,
    c3 int,

    c_timestamp_1 timestamp,
    c_timestamp_def1 timestamp default '2024-08-06',
    c_timestamp_def2 timestamp default '2024-08-06 10:00:00'
);
--disable_query_log
eval load data /*+ direct(true, 0, 'full') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t_pqTly6tEb1 fields terminated by ',' (c3, c1, c2);
--enable_query_log
insert into t_pqTly6tEb1 (c1, c2, c3) values (1111, 2222, 3333);
select * from t_pqTly6tEb1;
drop table t_pqTly6tEb1;

# ŤŅėŚéü
set explicit_defaults_for_timestamp = OFF;

create table t_pqTly6tEb1 (
    c1 int,
    c2 int,
    c3 int,

    c_char char(16),
    c_char_def char(16) default 'hello world',

    c_varchar varchar(16),
    c_varchar_def varchar(16) default 'hello world'
);
--disable_query_log
eval load data /*+ direct(true, 0, 'full') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t_pqTly6tEb1 fields terminated by ',' (c3, c1, c2);
--enable_query_log
insert into t_pqTly6tEb1 (c1, c2, c3) values (1111, 2222, 3333);
select * from t_pqTly6tEb1;
drop table t_pqTly6tEb1;

create table t_pqTly6tEb1 (
    c1 int,
    c2 int,
    c3 int,

    c_binary binary(8),
    c_binary_def binary(8) default 'ABC',

    c_varbinary varbinary(8),
    c_varbinary_def varbinary(8) default 'B'
);
--disable_query_log
eval load data /*+ direct(true, 0, 'full') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t_pqTly6tEb1 fields terminated by ',' (c3, c1, c2);
--enable_query_log
insert into t_pqTly6tEb1 (c1, c2, c3) values (1111, 2222, 3333);
select * from t_pqTly6tEb1;
drop table t_pqTly6tEb1;

create table t_pqTly6tEb1 (
    c1 int,
    c2 int,
    c3 int,

    c_enum enum('a', 'b', 'c'),
    c_enum_not_null enum('a', 'b', 'c') not null,
    c_enum_def enum('a', 'b', 'c') default 'b',

    c_set set('a', 'b', 'c'),
    c_set_def set('a', 'b', 'c') default 'c'
);
--disable_query_log
eval load data /*+ direct(true, 0, 'full') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t_pqTly6tEb1 fields terminated by ',' (c3, c1, c2);
--enable_query_log
insert into t_pqTly6tEb1 (c1, c2, c3) values (1111, 2222, 3333);
select * from t_pqTly6tEb1;
drop table t_pqTly6tEb1;

create table t_pqTly6tEb1 (
    c1 int,
    c2 int,
    c3 int,

    c_tinyblob tinyblob,

    c_blob blob,

    c_mediumblob mediumblob,

    c_longblob longblob,

    c_tinytext tinytext,

    c_text text,

    c_mediumtext mediumtext,

    c_longtext longtext,

    c_json json
);
--disable_query_log
eval load data /*+ direct(true, 0, 'full') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t_pqTly6tEb1 fields terminated by ',' (c3, c1, c2);
--enable_query_log
insert into t_pqTly6tEb1 (c1, c2, c3) values (1111, 2222, 3333);
select * from t_pqTly6tEb1;
drop table t_pqTly6tEb1;

create table t_pqTly6tEb1  (c1 int, c2 int, c3 int, c4 int not null);
--disable_query_log
--error 1364
eval load data /*+ direct(true, 0, 'full') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t_pqTly6tEb1 fields terminated by ',' (c3, c1, c2);
--enable_query_log
drop table t_pqTly6tEb1;

create table t_pqTly6tEb1  (c1 int, c2 int, c3 int, c4 timestamp default current_timestamp);
--disable_query_log
--error 1235
eval load data /*+ direct(true, 0, 'full') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t_pqTly6tEb1 fields terminated by ',' (c3, c1, c2);
--enable_query_log
drop table t_pqTly6tEb1;

--echo ================ test specify invisible column =========
CREATE TABLE lineitem (
    l_orderkey BIGINT NOT NULL,
    l_partkey BIGINT NOT NULL,
    l_suppkey INTEGER NOT NULL,
    l_linenumber INTEGER NOT NULL,
    l_quantity DECIMAL(15,2) NOT NULL,
    l_extendedprice DECIMAL(15,2) NOT NULL,
    l_discount DECIMAL(15,2) NOT NULL,
    l_tax DECIMAL(15,2) NOT NULL,
    l_returnflag char(1) NOT NULL,
    l_linestatus char(1) NOT NULL,
    l_shipdate date NOT NULL,
    l_commitdate date NOT NULL,
    l_receiptdate date NOT NULL,
    l_shipinstruct char(25) NOT NULL,
    l_shipmode char(10) NOT NULL,
    l_comment varchar(44) ,
    primary key(l_orderkey, l_linenumber));
alter table lineitem modify l_suppkey int(11) invisible;
alter table lineitem modify l_shipdate date invisible;
--disable_query_log
eval LOAD DATA  /*+ direct(true, 0) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k.tbl" INTO TABLE lineitem FIELDS TERMINATED BY '|' (l_orderkey, l_partkey, l_suppkey, l_linenumber, l_quantity, l_extendedprice, l_discount, l_tax, l_returnflag, l_linestatus, l_shipdate, l_commitdate, l_receiptdate, l_shipinstruct, l_shipmode, l_comment);
--enable_query_log
drop table lineitem;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_true.inc
