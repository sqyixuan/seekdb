--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: suzhi.yt
# owner group: Storage
# description: direct load specify column

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc
--source mysql_test/test_suite/direct_load_data/include/copy_data_for_direct_load.inc
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;

--disable_warnings
--disable_query_log
drop table if exists t_pqTly6tEb1;
drop table if exists lineitem;
--enable_query_log
--enable_warnings

--echo ================ test specify column order =========
create table t_pqTly6tEb1  (c1 int, c2 int, c3 int);
--disable_query_log
eval load data /*+ direct(true, 0, 'full') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t_pqTly6tEb1 fields terminated by ',' (c3, c1, c2);
--enable_query_log
select * from t_pqTly6tEb1;
drop table t_pqTly6tEb1;

--echo ================ test default column =========
create table t_pqTly6tEb1 (
    c1 int,
    c2 int,
    c3 int,
    c_autoinc int not null auto_increment,

    c_bool bool,
    c_bool_def1 bool default false,
    c_bool_def2 bool default true,
    c_boolean boolean,
    c_boolean_def1 boolean default false,
    c_boolean_def2 boolean default false,

    c_tinyint tinyint,
    c_tinyint_def tinyint default -4,
    c_tinyint_u tinyint unsigned,
    c_tinyint_u_def tinyint unsigned default 4,

    c_smallint smallint,
    c_smallint_def smallint default -5,
    c_smallint_u smallint unsigned,
    c_smallint_u_def smallint unsigned default 5,

    c_mediumint mediumint,
    c_mediumint_def mediumint default -6,
    c_mediumint_u mediumint unsigned,
    c_mediumint_u_def mediumint unsigned default 6,

    c_int int,
    c_int_def int default -7,
    c_int_u int unsigned,
    c_int_u_def int unsigned default 7,

    c_integer integer,
    c_integer_def integer default -8,
    c_integer_u integer unsigned,
    c_integer_u_def integer unsigned default 8,

    c_bigint bigint,
    c_bigint_def bigint default -9,
    c_bigint_u bigint unsigned,
    c_bigint_u_def bigint unsigned default 9,

    c_decimal decimal(6, 2),
    c_decimal_def decimal(6, 2) default -10.01,
    c_decimal_u decimal(6, 2) unsigned,
    c_decimal_u_def decimal(6, 2) unsigned default 10.01,

    c_numeric numeric(6, 2),
    c_numeric_def numeric(6, 2) default -11.11,
    c_numeric_u numeric(6, 2) unsigned,
    c_numeric_u_def numeric(6, 2) unsigned default 11.11,

    c_float float,
    c_float_def float default -12.21,
    c_float_u float unsigned,
    c_float_u_def float unsigned default 12.21,

    c_double double,
    c_double_def double default -13.31,
    c_double_u double unsigned,
    c_double_u_def double unsigned default 13.31
);
--disable_query_log
eval load data /*+ direct(true, 0, 'full') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t_pqTly6tEb1 fields terminated by ',' (c3, c1, c2);
--enable_query_log
insert into t_pqTly6tEb1 (c1, c2, c3) values (1111, 2222, 3333);
select * from t_pqTly6tEb1;
drop table t_pqTly6tEb1;

create table t_pqTly6tEb1 (
    c1 int,
    c2 int,
    c3 int,

    c_bit bit(8),
    c_bit_def bit(8) default 10

    #c_bitmap roaringbitmap,
    #c_bitmap_def roaringbitmap default x'0100'
);
--disable_query_log
eval load data /*+ direct(true, 0, 'full') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t_pqTly6tEb1 fields terminated by ',' (c3, c1, c2);
--enable_query_log
insert into t_pqTly6tEb1 (c1, c2, c3) values (1111, 2222, 3333);
select c1, c2, c3, hex(c_bit), hex(c_bit_def) from t_pqTly6tEb1;
drop table t_pqTly6tEb1;

create table t_pqTly6tEb1 (
    c1 int,
    c2 int,
    c3 int,

    c_date date,
    c_date_def1 date default '2024-08-06',
    c_date_def2 date default '2024-08-06 10:00:00',

    c_time time,
    c_time_def time default '123:32:45',

    c_datetime datetime,
    c_datetime_def datetime default '2024-08-06 10:00:00',

    c_year year,
    c_year_def year default 2024
);
--disable_query_log
eval load data /*+ direct(true, 0, 'full') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t_pqTly6tEb1 fields terminated by ',' (c3, c1, c2);
--enable_query_log
insert into t_pqTly6tEb1 (c1, c2, c3) values (1111, 2222, 3333);
select * from t_pqTly6tEb1;
drop table t_pqTly6tEb1;

