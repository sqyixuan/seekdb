--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jianlin.cjl
# owner group: Storage
# description: _ob_enable_direct_load parameter case

connection default;
use test;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc

--disable_warnings
--disable_query_log
drop table if exists t1;
drop table if exists t2;
drop materialized view if exists mv1;
--enable_query_log
--enable_warnings

let $__tenant_id__=NULL;
let $__parameter_name__=_ob_enable_direct_load;
let $__parameter_value__=False;
--source mysql_test/test_suite/direct_load_data/include/disable_direct_load.inc
--source mysql_test/test_suite/direct_load_data/include/check_parameter.inc

create table t1 (c1 int, c2 int);
insert into t1 values(1,2),(3,4);

--echo ================ test mview complete refresh =========
--error 1235
create materialized view mv1 refresh complete as select * from t1;

--echo ================ test insert overwrite =========
create table t2 (c1 int, c2 int);
--error 1235
insert overwrite t2 select * from t1;

let $__parameter_value__=True;
--source mysql_test/test_suite/direct_load_data/include/enable_direct_load.inc
--source mysql_test/test_suite/direct_load_data/include/check_parameter.inc

drop table t1;
drop table t2;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_true.inc
