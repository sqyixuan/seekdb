--echo ================ test generated column =========
create table t1_pqTly6tEb1(
    c1 int,
    c2 int,
    c3 int,

    c_vg int GENERATED ALWAYS AS (c2 + c3) virtual
);
alter table t1_pqTly6tEb1 drop column c_vg;

--disable_query_log
eval load data /*+ direct(true, 0) */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t1_pqTly6tEb1 fields terminated by ',';
--enable_query_log
select * from t1_pqTly6tEb1 order by c1;
delete from t1_pqTly6tEb1;

insert /*+ enable_parallel_dml parallel(2) append */ into t1_pqTly6tEb1 select * from t_pqTly6tEb1;
select * from t1_pqTly6tEb1 order by c1;
drop table t1_pqTly6tEb1;

create table t1_pqTly6tEb1(
    c1 int,
    c2 int,
    c3 int,

    c_vg int GENERATED ALWAYS AS (c2 + c3) stored
);
alter table t1_pqTly6tEb1 drop column c_vg;

--disable_query_log
eval load data /*+ direct(true, 0) */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t1_pqTly6tEb1 fields terminated by ',';
--enable_query_log
select * from t1_pqTly6tEb1 order by c1;
delete from t1_pqTly6tEb1;

insert /*+ enable_parallel_dml parallel(2) append */ into t1_pqTly6tEb1 select * from t_pqTly6tEb1;
select * from t1_pqTly6tEb1 order by c1;
drop table t1_pqTly6tEb1;

create table t1_pqTly6tEb1(
    c1 int,
    c_vg1 int GENERATED ALWAYS AS (c1 / 2), 
    c2 int,
    c_vg2 int GENERATED ALWAYS AS (c1 + c2) stored,
    c3 int,
    c_vg3 int GENERATED ALWAYS AS (c3 - c1)
);
alter table t1_pqTly6tEb1 drop column c_vg1;
alter table t1_pqTly6tEb1 drop column c_vg2;
alter table t1_pqTly6tEb1 drop column c_vg3;
--disable_query_log
eval load data /*+ direct(true, 0) */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t1_pqTly6tEb1 fields terminated by ',';
--enable_query_log
select * from t1_pqTly6tEb1 order by c1;
delete from t1_pqTly6tEb1;

insert /*+ enable_parallel_dml parallel(2) append */ into t1_pqTly6tEb1 select * from t_pqTly6tEb1;
select * from t1_pqTly6tEb1 order by c1;
drop table t1_pqTly6tEb1;

--echo ================ test partition exchange =========
create table t1_pqTly6tEb1(
    c1 int,
    c2 int,
    c3 int,

    c_int int
) partition by range(c1) (
    partition p0 values less than(1000),
    partition p1 values less than(2000),
    partition p2 values less than (MAXVALUE)
);
alter table t1_pqTly6tEb1 drop column c_int;

--disable_query_log
--error 1235
eval load data /*+ direct(true, 0) */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t1_pqTly6tEb1 partition(p0) fields terminated by ',';
--enable_query_log
select * from t1_pqTly6tEb1 order by c1;
delete from t1_pqTly6tEb1;

--error 1235
insert /*+ enable_parallel_dml parallel(2) append */ into t1_pqTly6tEb1 partition(p0) select * from t_pqTly6tEb1;
select * from t1_pqTly6tEb1 order by c1;
drop table t1_pqTly6tEb1;

# autoinc
create table t1_pqTly6tEb1(
    c1 int,
    c2 int,
    c3 int,

    c_autoinc int AUTO_INCREMENT
) partition by range(c1) (
    partition p0 values less than(1000),
    partition p1 values less than(2000),
    partition p2 values less than (MAXVALUE)
);
alter table t1_pqTly6tEb1 drop column c_autoinc;

--disable_query_log
eval load data /*+ direct(true, 0) */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t1_pqTly6tEb1 partition(p0) fields terminated by ',';
--enable_query_log
select * from t1_pqTly6tEb1 order by c1;
delete from t1_pqTly6tEb1;

insert /*+ enable_parallel_dml parallel(2) append */ into t1_pqTly6tEb1 partition(p0) select * from t_pqTly6tEb1;
select * from t1_pqTly6tEb1 order by c1;
drop table t1_pqTly6tEb1;

# cleanup
drop table t_pqTly6tEb1;

