--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: suzhi.yt
# owner group: Storage
# description: direct load unused column case

--source mysql_test/test_suite/direct_load_data/include/copy_data_for_direct_load.inc
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc

--disable_warnings
--disable_query_log
drop table if exists t_pqTly6tEb1;
drop table if exists t1_pqTly6tEb1;
--enable_query_log
--enable_warnings

create table t_pqTly6tEb1(c1 int, c2 int, c3 int);
--disable_query_log
eval load data /*+ direct(true, 0) */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t_pqTly6tEb1 fields terminated by ',';
--enable_query_log

--echo ================ test autoinc column =========
# generated always as identity
create table t1_pqTly6tEb1(
    c1 int,
    c2 int,
    c3 int,

    c_autoinc int AUTO_INCREMENT
);
alter table t1_pqTly6tEb1 drop column c_autoinc;

--disable_query_log
eval load data /*+ direct(true, 0) */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/specify_column_0.csv' into table t1_pqTly6tEb1 fields terminated by ',';
--enable_query_log
select * from t1_pqTly6tEb1 order by c1;
delete from t1_pqTly6tEb1;

insert /*+ enable_parallel_dml parallel(2) append */ into t1_pqTly6tEb1 select * from t_pqTly6tEb1;
select * from t1_pqTly6tEb1 order by c1;
drop table t1_pqTly6tEb1;

--echo ================ test nomal column =========
