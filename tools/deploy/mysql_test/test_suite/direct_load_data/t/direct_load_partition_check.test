# owner: yuya.yu
# owner group: Storage
# description: partition-level direct load check

--disable_warnings
--disable_query_log
drop table if exists t1_ins_overwrt;
drop table if exists t2_ins_overwrt;
drop table if exists t3_ins_overwrt;
drop table if exists t4_ins_overwrt;
--enable_query_log
--enable_warnings

set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;

connect (connsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection connsys;
alter system set schema_history_recycle_interval = '0s';
alter system set schema_history_expire_time = '1m';

connection default;
--echo # range partition
create table t1_ins_overwrt (c1 int primary key, c2 int) partition by range(c1)(
  partition p0 values less than(10),
  partition p1 values less than (MAXVALUE)
);
create table t2_ins_overwrt (c1 int primary key, c2 int) partition by range(c1)(
  partition p0 values less than(10),
  partition p1 values less than (MAXVALUE)
);
let $part_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 't2_ins_overwrt', table_id, 1);
let $target_part_id = query_get_value(select part_id from oceanbase.__all_part where table_id = $part_table_id and part_name = 'p0', part_id, 1);
insert into t1_ins_overwrt values (3, 20), (7, 40);
insert into t2_ins_overwrt values (3, 60), (8, 80), (17, 170), (26, 260), (29, 290), (142, 1420);
insert overwrite t2_ins_overwrt partition(p0) select * from t1_ins_overwrt;

# range + hash partition
create table t3_ins_overwrt (c1 int primary key, c2 int);
create table t4_ins_overwrt (c1 int primary key, c2 int)
partition by range(c1)
subpartition by hash(c1) subpartitions 2
(
partition p0 values less than (10),
Partition p1 values less than (MAXVALUE)
);
let $sub_part_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 't4_ins_overwrt', table_id, 1);
let $target_sub_part_id = query_get_value(select sub_part_id from oceanbase.__all_sub_part where table_id = $sub_part_table_id and sub_part_name = 'p0sp1', sub_part_id, 1);
insert into t3_ins_overwrt values (1, 10), (2, 20), (11, 110), (12, 120);
insert overwrite t4_ins_overwrt partition (p0sp1) select * from t3_ins_overwrt where c1 = 1;

set @@session.recyclebin = off;
set @@session.ob_enable_truncate_flashback = off;

# wait merge finished
connection connsys;
alter system set schema_history_recycle_interval = '10s';

let $idx = 0;
while ($idx <= 3)
{
  connection connsys;
  alter system major freeze tenant=sys;
  alter system major freeze tenant=all_user;
  alter system major freeze tenant=all_meta;
  --source mysql_test/include/wait_daily_merge.inc
  inc $idx;
}

#######################################################
# check result
#######################################################
connection default;
--disable_query_log
let $idx = 0;
while ($idx <= 60)
{
  --sleep 1
  let $result_count = query_get_value(select count(*) as cnt from oceanbase.__all_part_history where table_id = $part_table_id and part_id = $target_part_id and is_deleted = 1, cnt, 1);
  if ($result_count == 0)
  {
    $idx = 60;
  }
  inc $idx;
}
eval select part_name, part_idx, is_deleted from oceanbase.__all_part_history where table_id = $part_table_id and part_id = $target_part_id order by schema_version desc limit 1;
--enable_query_log

--disable_query_log
let $idx = 0;
while ($idx <= 60)
{
  --sleep 1
  let $result_count = query_get_value(select count(*) as cnt from oceanbase.__all_part_history where table_id = $part_table_id and part_id = $target_part_id and is_deleted = 1, cnt, 1);
  if ($result_count == 0)
  {
    $idx = 60;
  }
  inc $idx;
}
eval select sub_part_name, sub_part_idx, is_deleted from oceanbase.__all_sub_part_history where table_id = $sub_part_table_id and sub_part_id = $target_sub_part_id order by schema_version desc limit 1;
--enable_query_log

drop table t1_ins_overwrt;
drop table t2_ins_overwrt;
drop table t3_ins_overwrt;
drop table t4_ins_overwrt;