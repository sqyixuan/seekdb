--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jianming.cjq
# owner group: Storage Group
# description: direct load bugfix timestap case

--source mysql_test/test_suite/direct_load_data/include/copy_data_for_direct_load.inc
connect (conn_query,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection default;
use test;
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc

# Case 49485000
--echo # Case 49485000
--source mysql_test/test_suite/direct_load_data/include/enable_defensive_check.inc
--disable_warnings
drop table if exists test1;
--enable_warnings
create table test1(c79 timestamp not null, c90 float not null, c1 int(149) default null) partition by key(c79) subpartition by key(c90) subpartitions 49 partitions 9;
--disable_query_log
eval load data /*+ parallel(10) direct(true, 0) */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/bugfix/49485000.csv' into table test1 fields terminated by '|' enclosed by '''' lines starting by '' terminated by '\n';
--enable_query_log
select c79,c90 from test1 where c1=1 limit 1 for update;
drop table test1;
--source mysql_test/test_suite/direct_load_data/include/disable_defensive_check.inc

# Case 49754646
--echo # Case 49754646
--disable_warnings
drop table if exists lineitem;
--enable_warnings
create table lineitem(
    l_orderkey           bigint NOT NULL ,
    l_partkey            bigint NOT NULL ,
    l_suppkey            bigint NOT NULL ,
    l_linenumber         bigint NOT NULL ,
    l_quantity           bigint NOT NULL ,
    l_extendedprice      decimal(10,2) NOT NULL ,
    l_discount           decimal(10,2) NOT NULL ,
    l_tax                decimal(10,2) NOT NULL ,
    l_returnflag         char(1) ,
    l_linestatus         char(1) ,
    l_shipdate           date ,
    l_commitdate         date ,
    l_receiptdate        date ,
    l_shipinstruct       char(25) ,
    l_shipmode           char(10) ,
    l_comment            varchar(44)
);
--let $loop=0
while ($loop < 10)
{
  if ($loop==0) {
    let $DATA_FILES =$OBSERVER_DIR/$DATA_FOLDER_NAME/bugfix/49754646_0$loop.csv;
  }
  if ($loop>0) {
    let $DATA_FILES = $DATA_FILES,$OBSERVER_DIR/$DATA_FOLDER_NAME/bugfix/49754646_0$loop.csv;
  }
  inc $loop;
}
--disable_query_log
eval load data /*+ parallel(16) direct(true, 0) */ infile '$DATA_FILES' into table lineitem fields terminated by '|';
--enable_query_log
select count(*) from lineitem;
drop table lineitem;

# Case 2024082000104197291
--echo # Case 2024082000104197291
drop table if exists lineitem;
create table lineitem(
    l_orderkey           bigint NOT NULL ,
    l_partkey            bigint NOT NULL ,
    l_suppkey            bigint NOT NULL ,
    l_linenumber         bigint NOT NULL ,
    l_quantity           bigint NOT NULL ,
    l_extendedprice      decimal(10,2) NOT NULL ,
    l_discount           decimal(10,2) NOT NULL ,
    l_tax                decimal(10,2) NOT NULL ,
    l_returnflag         char(1) ,
    l_linestatus         char(1) ,
    l_shipdate           date ,
    l_commitdate         date ,
    l_receiptdate        date ,
    l_shipinstruct       char(25) ,
    l_shipmode           char(10) ,
    l_comment            varchar(44),
    l_test               bigint
) partition by hash(l_test) partitions 8;
--let $loop=0
while ($loop < 3)
{
  --disable_query_log
  eval load data /*+ direct(true,0) parallel(20) load_batch_size(100) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k.tbl" into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n' 
    (l_orderkey, l_partkey, l_suppkey, l_linenumber, l_quantity, l_extendedprice, l_discount, l_tax, l_returnflag, l_linestatus, l_shipdate, l_commitdate, l_receiptdate, l_shipinstruct, l_shipmode, l_comment);
  --enable_query_log
  select count(*) from lineitem;
  inc $loop;
}
drop table lineitem;

