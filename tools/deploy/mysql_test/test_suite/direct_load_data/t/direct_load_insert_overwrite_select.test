--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: wyh329796
# description: direct load support 'INSERT OVERWRITE SELECT' test

--source mysql_test/test_suite/direct_load_data/include/copy_data_for_direct_load.inc
connect (conn_query,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connect (conn_query1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
--disable_warnings

connection conn_query;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc
connection conn_query;

drop table if exists test_fk;
drop table if exists test_fk1;
drop table if exists test_fk2;

create table test_fk (id int);
create table test_fk1 (id int);
create table test_fk2 (id int, primary key(id));

alter system set debug_sync_timeout = '100000s';
set global ob_query_timeout = 100000000000;
set ob_global_debug_sync = 'BEFORE_CREATE_HIDDEN_TABLE_IN_LOAD wait_for signalxxx execute 10000';

insert into test_fk1 values(1);
commit;
send insert overwrite test_fk select * from test_fk1;

connection conn_query1;
ALTER TABLE test_fk ADD CONSTRAINT fk_foreign_id
FOREIGN KEY (id) REFERENCES test_fk2(id)
ON DELETE CASCADE;

set ob_global_debug_sync = 'now signal signalxxx';

connection conn_query;
--error 5785
reap;
set ob_global_debug_sync = 'BEFORE_CREATE_HIDDEN_TABLE_IN_LOAD clear';

connection default;
--enable_query_log
use test;


#===============================主键表=======================================

#-----------------------------------PDML--------------------------------

#TEST1 主键表，源表和目标表均为非分区表，pdml
# Create source table
--disable_warnings
drop table if exists lineitem;
--enable_warnings
create table lineitem (
    c01 int(255) NOT NULL,
    c02 numeric,
    c03 bit(64),
    c04 char(4),
    c05 binary(255),
    c06 varbinary(255),
    c07 datetime(6),
    c08 timestamp(6) NULL DEFAULT NULL,
    tchar char(64) not null,
    ttinyint tinyint,
    tsmallint smallint,
    tmediumint mediumint,
    tinteger integer,
    tbigint bigint,
    tfloat float,
    tdouble double,
    tdecimal decimal(10,5),
    tdate date,
    ttime time,
    tyear year,
    tdatetime datetime,
    ttimestamp timestamp NULL DEFAULT NULL,
    tvarchar varchar(128),
    ttinyint1 tinyint(1),
    ttinyint4 tinyint(4),
    tblob blob,
    tjson json,
    primary key (c01)
);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
# Start load data
--disable_query_log
eval load data /*+ direct(true,0) parallel(1) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-empty-table.tbl" into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--enable_query_log
# Query table
select count(*) from lineitem;
# Create target table
--disable_warnings
drop table if exists lineitem1;
--enable_warnings
create table lineitem1 (
    c01 int(255) NOT NULL,
    c02 numeric,
    c03 bit(64),
    c04 char(4),
    c05 binary(255),
    c06 varbinary(255),
    c07 datetime(6),
    c08 timestamp(6) NULL DEFAULT NULL,
    tchar char(64) not null,
    ttinyint tinyint,
    tsmallint smallint,
    tmediumint mediumint,
    tinteger integer,
    tbigint bigint,
    tfloat float,
    tdouble double,
    tdecimal decimal(10,5),
    tdate date,
    ttime time,
    tyear year,
    tdatetime datetime,
    ttimestamp timestamp NULL DEFAULT NULL,
    tvarchar varchar(128),
    ttinyint1 tinyint(1),
    ttinyint4 tinyint(4),
    tblob blob,
    tjson json,
    primary key (c01)
);
# Start insert overwrite select
insert /*+ enable_parallel_dml parallel(3) */ overwrite lineitem1 select * from lineitem;
# Query table
select count(*) from lineitem1;
# Repeat insert overwrite select
insert /*+ enable_parallel_dml parallel(3) */ overwrite lineitem1 select * from lineitem;
# Query table
select count(*) from lineitem1;

