--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jianlin.cjl
# owner group: Storage
# description: direct load default load case

--source mysql_test/test_suite/direct_load_data/include/copy_data_for_direct_load.inc
connect (conn_query,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection default;
use test;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc

--disable_warnings
--disable_query_log
drop table if exists t1;
drop table if exists t2;
drop table if exists lineitem;
--enable_query_log

--echo ================ test default load mode =========
create table t1 (c1 int, c2 int);
create table t2 (c1 int, c2 int);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
alter system set default_load_mode='DISABLED';
let $__parameter_name__=default_load_mode;
let $__parameter_value__=DISABLED;
--source mysql_test/test_suite/direct_load_data/include/check_parameter.inc
# not direct load
explain extended_noaddr insert /*+ enable_parallel_dml parallel(2) */ into t2 select * from t1;
alter system set default_load_mode='INC_DIRECT_WRITE';
let $__parameter_name__=default_load_mode;
let $__parameter_value__=INC_DIRECT_WRITE;
--source mysql_test/test_suite/direct_load_data/include/check_parameter.inc
# full direct load
explain extended_noaddr insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'full') */ into t2 select * from t1;
# inc direct load
explain extended_noaddr insert /*+ enable_parallel_dml parallel(2) */ into t2 select * from t1;
# insert ignore into select not optimized to use direct load
explain extended_noaddr insert /*+ enable_parallel_dml parallel(2) */ ignore into t2 select * from t1;
# not direct load
explain extended_noaddr insert /*+ enable_parallel_dml parallel(2) no_direct */ into t2 select * from t1;
# generate default parallel(2)
explain extended_noaddr insert /*+ enable_parallel_dml */ into t2 select * from t1;
# not direct load because of parallel(1)
--error 1235
explain extended_noaddr insert /*+ enable_parallel_dml parallel(1) */ into t2 select * from t1;
explain extended_noaddr insert /*+ enable_parallel_dml parallel(2) */ into t2 (c1, c2) select c1, c2 from t1 ON DUPLICATE KEY UPDATE c2 = VALUES(c2);

--echo ================ test direct_load_allow_fallback =========
create table lineitem(
    l_orderkey           bigint NOT NULL ,
    l_partkey            bigint NOT NULL ,
    l_suppkey            bigint NOT NULL ,
    l_linenumber         bigint NOT NULL ,
    l_quantity           bigint NOT NULL ,
    l_extendedprice      decimal(10,2) NOT NULL ,
    l_discount           decimal(10,2) NOT NULL ,
    l_tax                decimal(10,2) NOT NULL ,
    l_returnflag         char(1) ,
    l_linestatus         char(1) ,
    l_shipdate           date ,
    l_commitdate         date ,
    l_receiptdate        date ,
    l_shipinstruct       char(25) ,
    l_shipmode           char(10) ,
    l_comment            varchar(44)
);

--disable_query_log
# replace for inc load method in direct load is not supported
--error 1235
eval load data infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k.tbl" replace into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--enable_query_log

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_true.inc

--disable_query_log
let $__table_name__ = 'lineitem';
let $__start_time__ = query_get_value(select now() as c, c, 1);
# Degenerate into a normal import
eval load data infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k.tbl" replace into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
sleep 1;
let $__finish_time__ = query_get_value(select now() as c, c, 1);
--source mysql_test/test_suite/direct_load_data/include/check_direct_load.inc
--enable_query_log

--disable_query_log
let $__start_time__ = query_get_value(select now() as c, c, 1);
eval load data infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k.tbl" into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
sleep 1;
let $__finish_time__ = query_get_value(select now() as c, c, 1);
--source mysql_test/test_suite/direct_load_data/include/check_direct_load.inc
--enable_query_log

--disable_query_log
# Degenerate into a normal insert into select
eval insert /*+ enable_parallel_dml parallel(2) */ into t2 select * from t1;
--enable_query_log

alter system set default_load_mode='DISABLED';
let $__parameter_name__=default_load_mode;
let $__parameter_value__=DISABLED;
--source mysql_test/test_suite/direct_load_data/include/check_parameter.inc

drop table t1;
drop table t2;
drop table lineitem;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_true.inc
