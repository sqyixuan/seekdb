--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuya.yu
# owner group: Storage
# description: direct load data ctas

--source mysql_test/test_suite/direct_load_data/include/copy_data_for_direct_load.inc

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--disable_warnings
connection default;
--enable_query_log
use test;
set _optimizer_gather_stats_on_load = 1;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc

# Create table
--disable_warnings
drop table if exists lineitem;
drop table if exists lineitem2;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings
create table lineitem(
    l_orderkey           bigint NOT NULL ,
    l_partkey            bigint NOT NULL ,
    l_suppkey            bigint NOT NULL ,
    l_linenumber         bigint NOT NULL ,
    l_quantity           bigint NOT NULL ,
    l_extendedprice      decimal(10,2) NOT NULL ,
    l_discount           decimal(10,2) NOT NULL ,
    l_tax                decimal(10,2) NOT NULL ,
    l_returnflag         char(1) ,
    l_linestatus         char(1) ,
    l_shipdate           date ,
    l_commitdate         date ,
    l_receiptdate        date ,
    l_shipinstruct       char(25) ,
    l_shipmode           char(10) ,
    l_comment            varchar(44),
    primary key(L_ORDERKEY, L_LINENUMBER)
) partition by hash(l_orderkey) partitions 10;

set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
set global ob_sql_audit_percentage = 50;
set autocommit = 1;
alter system set default_load_mode='DISABLED';
let $__parameter_name__=default_load_mode;
let $__parameter_value__=DISABLED;
--source mysql_test/test_suite/direct_load_data/include/check_parameter.inc
--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc

# Start load data

--disable_query_log
eval load data /*+ direct(true,0) parallel(2) load_batch_size(100) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k.tbl" into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--enable_query_log

let $__table_name__ = '__ctas%';
let $__start_time__ = query_get_value(select now() as c, c, 1);
create /*+ PARALLEL(8) */table lineitem2 as select * from lineitem;
sleep 1;
let $__finish_time__ = query_get_value(select now() as c, c, 1);
--source mysql_test/test_suite/direct_load_data/include/check_direct_load.inc
select substring_index(substring_index(QUERY_SQL, '/*+', -1), '*/', 1) as hint from oceanbase.gv$ob_sql_audit where query_sql like 'insert /*+ ENABLE_PARALLEL_DML %' order by request_time desc limit 1;
select count(*) from lineitem2;

drop table lineitem2;
let $__start_time__ = query_get_value(select now() as c, c, 1);
create /*+ PARALLEL(2) */table lineitem2 as select * from lineitem;
sleep 1;
let $__finish_time__ = query_get_value(select now() as c, c, 1);
--source mysql_test/test_suite/direct_load_data/include/check_direct_load.inc
select substring_index(substring_index(QUERY_SQL, '/*+', -1), '*/', 1) as hint from oceanbase.gv$ob_sql_audit where query_sql like 'insert /*+ ENABLE_PARALLEL_DML %' order by request_time desc limit 1;

drop table lineitem2;
let $__start_time__ = query_get_value(select now() as c, c, 1);
create /*+ PARALLEL(0) */table lineitem2 as select * from lineitem;
sleep 1;
let $__finish_time__ = query_get_value(select now() as c, c, 1);
--source mysql_test/test_suite/direct_load_data/include/check_direct_load.inc
select substring_index(substring_index(QUERY_SQL, '/*+', -1), '*/', 1) as hint from oceanbase.gv$ob_sql_audit where query_sql like 'insert /*+ ENABLE_PARALLEL_DML %' order by request_time desc limit 1;

# ------test direct load hint can be passed to inner sql-------
let $__table_name__ = '__ctas%';

# test no hint
drop table lineitem2;
let $__start_time__ = query_get_value(select now() as c, c, 1);
create table lineitem2 as select * from lineitem;
sleep 1;
let $__finish_time__ = query_get_value(select now() as c, c, 1);
--source mysql_test/test_suite/direct_load_data/include/check_direct_load.inc
select substring_index(substring_index(QUERY_SQL, '/*+', -1), '*/', 1) as hint from oceanbase.gv$ob_sql_audit where query_sql like 'insert /*+ ENABLE_PARALLEL_DML %' order by request_time desc limit 1;
select count(*) from lineitem2;

# test no hint with autocommit off
