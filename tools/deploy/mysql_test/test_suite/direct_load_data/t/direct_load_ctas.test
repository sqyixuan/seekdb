    l_returnflag         char(1) ,
    l_linestatus         char(1) ,
    l_shipdate           date ,
    l_commitdate         date ,
    l_receiptdate        date ,
    l_shipinstruct       char(25) ,
    l_shipmode           char(10) ,
    l_comment            varchar(44),
    primary key(L_ORDERKEY, L_LINENUMBER),
    index my_idx(l_suppkey)
) as select * from lineitem;
sleep 1;
let $__finish_time__ = query_get_value(select now() as c, c, 1);
--source mysql_test/test_suite/direct_load_data/include/check_direct_load.inc
select substring_index(substring_index(QUERY_SQL, '/*+', -1), '*/', 1) as hint from oceanbase.gv$ob_sql_audit where query_sql like 'insert /*+ ENABLE_PARALLEL_DML %' order by request_time desc limit 1;
select count(*) from lineitem2;

#test serial attribute
create table t1(c1 int);
let $__start_time__ = query_get_value(select now() as c, c, 1);
create /*+ parallel(2) direct(true, 0) */ table t2 (c2 serial) as select * from t1;
sleep 1;
let $__finish_time__ = query_get_value(select now() as c, c, 1);
--source mysql_test/test_suite/direct_load_data/include/check_direct_load.inc
select substring_index(substring_index(QUERY_SQL, '/*+', -1), '*/', 1) as hint from oceanbase.gv$ob_sql_audit where query_sql like 'insert /*+ ENABLE_PARALLEL_DML %' order by request_time desc limit 1;

#test some conditions that don't support direct load

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_true.inc

drop table t1;
drop table t2;
create table t1(column1 serial);
let $__start_time__ = query_get_value(select now() as c, c, 1);
create /*+ parallel(2) direct(true, 0) */ table t2 (column1 serial primary key) as select * from t1;
sleep 1;
let $__finish_time__ = query_get_value(select now() as c, c, 1);
--source mysql_test/test_suite/direct_load_data/include/check_direct_load.inc
select substring_index(substring_index(QUERY_SQL, '/*+', -1), '*/', 1) as hint from oceanbase.gv$ob_sql_audit where query_sql like 'insert /*+ ENABLE_PARALLEL_DML %' order by request_time desc limit 1;

drop table t1;
drop table t2;
create table t1(column1 int);
create table t2(column1 int unique);
let $__start_time__ = query_get_value(select now() as c, c, 1);
create /*+ parallel(2) direct(true, 0) */ table t3(column1 int,CONSTRAINT foreign_key1 FOREIGN KEY (column1) REFERENCES t2(column1))  as select * from t1;
sleep 1;
let $__finish_time__ = query_get_value(select now() as c, c, 1);
--source mysql_test/test_suite/direct_load_data/include/check_direct_load.inc
select substring_index(substring_index(QUERY_SQL, '/*+', -1), '*/', 1) as hint from oceanbase.gv$ob_sql_audit where query_sql like 'insert /*+ ENABLE_PARALLEL_DML %' order by request_time desc limit 1;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc

# ------test CTAS with global config------
alter system set default_load_mode='FULL_DIRECT_WRITE';
let $__parameter_name__=default_load_mode;
let $__parameter_value__=FULL_DIRECT_WRITE;
--source mysql_test/test_suite/direct_load_data/include/check_parameter.inc
