--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jianming.cjq
# owner group: Storage Group
# description: test macro write how to handle the buffer not enough 

--source mysql_test/test_suite/direct_load_data/include/copy_data_for_direct_load.inc

connect (conn_query,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

--disable_warnings

connection default;
--enable_query_log
use test;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc

# Create table
--disable_warnings
drop table if exists test_table_for_macro_writer1;
drop table if exists test_table_for_macro_writer2;
--enable_warnings

create table test_table_for_macro_writer1 (c1 int, c2 MEDIUMTEXT) lob_inrow_threshold = 262144; # 128k
create table test_table_for_macro_writer2 (c1 int, c2 MEDIUMTEXT) lob_inrow_threshold = 262144 with column group (each column); # 128k

insert into test_table_for_macro_writer1 values(1, repeat('a', 131072));
insert into test_table_for_macro_writer1 values(2, repeat('a', 131072));
insert into test_table_for_macro_writer1 values(3, repeat('a', 131072));
insert into test_table_for_macro_writer1 values(4, repeat('a', 131072));
insert into test_table_for_macro_writer1 values(5, repeat('a', 131072));

insert /*+ append enable_parallel_dml parallel(2) */ into test_table_for_macro_writer2 select * from test_table_for_macro_writer1;


select c1, left(c2, 5) from test_table_for_macro_writer2 order by c1;


truncate test_table_for_macro_writer1;
truncate test_table_for_macro_writer2;


insert into test_table_for_macro_writer1 values(1, repeat('a', 8192));
insert into test_table_for_macro_writer1 values(2, repeat('a', 8192));
insert into test_table_for_macro_writer1 values(3, repeat('a', 8192));
insert into test_table_for_macro_writer1 values(4, repeat('a', 8192));
insert into test_table_for_macro_writer1 values(5, repeat('a', 8192));

insert /*+ append enable_parallel_dml parallel(2) */ into test_table_for_macro_writer2 select * from test_table_for_macro_writer1;

select c1, left(c2, 5) from test_table_for_macro_writer2 order by c1;

drop table test_table_for_macro_writer1;
drop table test_table_for_macro_writer2;


create table test_table_for_macro_writer1 (c1 varbinary(9000), c2 int);
create table test_table_for_macro_writer2 (c1 varbinary(9000) primary key, c2 int) with column group (each column);


insert into test_table_for_macro_writer1(c2, c1) values(1, repeat('a', 8192));
insert into test_table_for_macro_writer1(c2, c1) values(2, repeat('b', 8192));
insert into test_table_for_macro_writer1(c2, c1) values(3, repeat('c', 8192));
insert into test_table_for_macro_writer1(c2, c1) values(4, repeat('d', 8192));
insert into test_table_for_macro_writer1(c2, c1) values(5, repeat('e', 8192));

insert /*+ append enable_parallel_dml parallel(2) */ into test_table_for_macro_writer2 select * from test_table_for_macro_writer1;

select c2, left(c1, 5) from test_table_for_macro_writer2 order by c2;

drop table test_table_for_macro_writer1;
drop table test_table_for_macro_writer2;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_true.inc
