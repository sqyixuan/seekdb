--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jianlin.cjl
# owner group: Storage
# description: direct load string type case

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc
--source mysql_test/test_suite/direct_load_data/include/copy_data_for_direct_load.inc

--disable_warnings
--disable_query_log
drop table if exists lineitem;
drop table if exists t1;
drop sequence if exists seq_c1;
--enable_query_log
--enable_warnings

set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;


--echo ================ test insert into select =========
create table t1(c1 string, c2 string, c3 string, primary key(c1));
create sequence seq_c1 cache 1000000 noorder;
--error 1071
insert /*+ enable_parallel_dml parallel(4) append */ into t1 select RANDSTR(20000, seq_c1.nextval), RANDSTR(10, random(1)), RANDSTR(10, random(1)) from table(generator(1));
insert /*+ enable_parallel_dml parallel(4) append */ into t1 select RANDSTR(2000, seq_c1.nextval), RANDSTR(10, random(1)), RANDSTR(10, random(1)) from table(generator(1));
select length(c1),length(c2), length(c3) from t1;

set _enable_rich_vector_format=false;
--error 1071
insert /*+ enable_parallel_dml parallel(4) append */ into t1 select RANDSTR(20000, seq_c1.nextval), RANDSTR(10, random(1)), RANDSTR(10, random(1)) from table(generator(1));
insert /*+ enable_parallel_dml parallel(4) append */ into t1 select RANDSTR(2000, seq_c1.nextval), RANDSTR(10, random(1)), RANDSTR(10, random(1)) from table(generator(1));
select length(c1),length(c2), length(c3) from t1;

alter system set _rowsets_enabled=False;
let $__parameter_name__=_rowsets_enabled;
let $__parameter_value__=False;
--source mysql_test/test_suite/direct_load_data/include/check_parameter.inc
--error 1071
insert /*+ enable_parallel_dml parallel(4) append */ into t1 select RANDSTR(20000, seq_c1.nextval), RANDSTR(10, random(1)), RANDSTR(10, random(1)) from table(generator(1));
insert /*+ enable_parallel_dml parallel(4) append */ into t1 select RANDSTR(2000, seq_c1.nextval), RANDSTR(10, random(1)), RANDSTR(10, random(1)) from table(generator(1));
select length(c1),length(c2), length(c3) from t1;

set _enable_rich_vector_format=True;
alter system set _rowsets_enabled=True;
let $__parameter_name__=_rowsets_enabled;
let $__parameter_value__=True;
--source mysql_test/test_suite/direct_load_data/include/check_parameter.inc

--echo ================ test row length larger than limit chunk size =========
# mysql租户在这个并发场景下，get_sort_memory获取到的大小是10M左右, c2和c3列生成数据都为10M
insert /*+ enable_parallel_dml parallel(4) append */ into t1 select RANDSTR(2000, seq_c1.nextval), RANDSTR(10485760, random(1)), RANDSTR(10485760, random(1)) from table(generator(10));
select length(c1), length(c2), length(c3) from t1 order by length(c2);

drop table t1;
drop sequence seq_c1;


--echo ================ test load data =========
create table lineitem(
    l_orderkey           string NOT NULL ,
    l_partkey            bigint NOT NULL ,
    l_suppkey            bigint NOT NULL ,
    l_linenumber         bigint NOT NULL ,
    l_quantity           bigint NOT NULL ,
    l_extendedprice      decimal(10,2) NOT NULL ,
    l_discount           decimal(10,2) NOT NULL ,
    l_tax                decimal(10,2) NOT NULL ,
    l_returnflag         char(1) ,
    l_linestatus         char(1) ,
    l_shipdate           date ,
    l_commitdate         date ,
    l_receiptdate        date ,
    l_shipinstruct       char(25) ,
    l_shipmode           char(10) ,
    l_comment            varchar(44),
    primary key(l_orderkey, l_linenumber)
);

--disable_query_log
--error 1071
eval load data /*+ parallel(4) append */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-string-rowkey-error.tbl" replace into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
eval load data /*+ parallel(4) append */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-string-rowkey.tbl" replace into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
select length(l_orderkey) from lineitem;
--enable_query_log

drop table lineitem;


--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_true.inc
