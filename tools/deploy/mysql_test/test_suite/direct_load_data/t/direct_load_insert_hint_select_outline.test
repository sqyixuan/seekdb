--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc

drop table if exists hint_outline_t;
create table hint_outline_t(c1 int primary key, c2 int);

explain insert into hint_outline_t select * from hint_outline_t;

--error 1235
explain insert /*+append*/ into hint_outline_t select * from hint_outline_t;

#In order to limit reduce column_convert() optimization in import bypass scenario 
#So far outline in select will invalidate insert hint
#so below sql would not enable import bypass
#column_convert expr would be remain
#need to fix this in the future
drop table hint_outline_t;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_true.inc
