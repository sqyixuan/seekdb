eval load data /*+ direct(true,0) parallel(1) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/autoinc/autoinc-notnull.csv" into table t1 fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--enable_query_log
INSERT INTO t1 (id, name) VALUES (null, 'id=null insert');
