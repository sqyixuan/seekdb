--echo # TEST 5
# Create table
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(
    id bigint NOT NULL AUTO_INCREMENT,
    name  varchar(40)  NOT NULL
);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
# Start load data
--disable_query_log
eval load data /*+ direct(false,0) parallel(1) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/autoinc/autoinc-identity.csv" into table t1 fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--enable_query_log
INSERT INTO t1 (id, name) VALUES (null, 'id=null insert');
# Query table
select count(*) from t1;

--echo # TEST 6
# Create table
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(
    id bigint NOT NULL AUTO_INCREMENT,
    name  varchar(40)  NOT NULL
);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
# Start load data
INSERT INTO t1 (id, name) VALUES (500, 'id=500 insert');
--disable_query_log
eval load data /*+ direct(false,0) parallel(1) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/autoinc/autoinc-identity.csv" into table t1 fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--enable_query_log
INSERT INTO t1 (id, name) VALUES (null, 'id=null insert');
# Query table
select count(*) from t1;

--echo # TEST 7
# Create table
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(
    id bigint NOT NULL AUTO_INCREMENT,
    name  varchar(40)  NOT NULL,
    primary key (id)
)partition by key(id) partitions 10;
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
# Start load data
INSERT INTO t1 (id, name) VALUES (500, 'id=500 insert');
--disable_query_log
eval load data /*+ direct(true,0) parallel(1) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/autoinc/autoinc-identity.csv" into table t1 fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--enable_query_log
INSERT INTO t1 (id, name) VALUES (null, 'id=null insert');
# Query table
select count(*) from t1;
select id from t1 where id=501;

disconnect conn_query;

# Clean Up
drop table t1;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_true.inc
