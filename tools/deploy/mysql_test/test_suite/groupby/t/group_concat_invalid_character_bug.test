--disable_warnings
DROP TABLE IF EXISTS course;
--enable_warnings
CREATE TABLE course (
name varchar(255) CHARACTER SET utf16,
course_name varchar(255) CHARACTER SET gbk,
mes varchar(255) CHARACTER SET gbk
)charset=utf16;
INSERT INTO course VALUES ('李明', '阅读赏析','一号');
INSERT INTO course VALUES ('李明', '摄影','二号');
INSERT INTO course VALUES ('李明', '太极剑','三号');
INSERT INTO course VALUES ('司马光', '马克思主义基本原理','四号');
INSERT INTO course VALUES ('司马光', '摄影','五号');
INSERT INTO course VALUES ('叶问', '阅读赏析','六号');
INSERT INTO course VALUES ('叶问', '法语','七号');
select t.name as '姓名',GROUP_CONCAT(t.course_name ) as '课程' from course t group by t.name ;

select group_concat(name), group_concat(course_name) from course;
select group_concat(name separator 'abc'), group_concat(course_name separator 'def') from course;
