select a from t1 group by grouping sets(a,(),()),grouping sets(a,(),());
--sorted_result
select max(a), sum(b), min(c) over(partition by d order by e) from t1 group by a, grouping sets(b, c), grouping sets(d, e);
--sorted_result
select a,b from t1 group by grouping sets(a,()),grouping sets(a,()),b;
--sorted_result
select grouping(a) from t1 group by grouping sets(a,b);

