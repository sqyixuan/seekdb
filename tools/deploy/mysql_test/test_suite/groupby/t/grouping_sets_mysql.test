--sorted_result
select /*+use_px parallel(2)*/t1.a,t1.b,t1.c,sum(t2.b) from t1,t2 where t1.a=t2.a group by grouping sets(t1.a,t1.b,t1.c);
select /*+use_px parallel(1)*/t1.a,t1.b,t1.c,sum(t2.b) from t1,t2 where t1.a=t2.a group by grouping sets(t1.a,t1.b,t1.c);
--sorted_result
select /*+use_px, parallel(2)*/t1.a,t1.b,t1.c,sum(t1.b+t2.b) from t1 join t2 on t1.c=t2.c group by grouping sets(t1.a,t1.b,t1.c);
select /*+use_px, parallel(1)*/t1.a,t1.b,t1.c,sum(t1.b+t2.b) from t1 join t2 on t1.c=t2.c group by grouping sets(t1.a,t1.b,t1.c);
--sorted_result
select /*+use_px, parallel(2)*/t1.a,t1.b,t1.c,sum(t1.b+t2.b) from t1 left join t2 on t1.c=t2.c group by grouping sets(t1.a,t1.b,t1.c);
select /*+use_px, parallel(1)*/t1.a,t1.b,t1.c,sum(t1.b+t2.b) from t1 left join t2 on t1.c=t2.c group by grouping sets(t1.a,t1.b,t1.c);
--sorted_result
select /*+use_px, parallel(2)*/t1.a,t1.b,t1.c,sum(t1.b+t2.b) from t1 right join t2 on t1.c=t2.c group by grouping sets(t1.a,t1.b,t1.c);
select /*+use_px, parallel(1)*/t1.a,t1.b,t1.c,sum(t1.b+t2.b) from t1 right join t2 on t1.c=t2.c group by grouping sets(t1.a,t1.b,t1.c);
--sorted_result
select /*+use_px, parallel(2)*/t1.a,t1.b,t1.c,sum(t1.b+t2.b) from t1 full join t2 on t1.c=t2.c group by grouping sets(t1.a,t1.b,t1.c);
