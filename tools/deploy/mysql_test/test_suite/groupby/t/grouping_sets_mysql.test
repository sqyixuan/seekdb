select nvl(a, b), c from t1 group by grouping sets(nvl(a, b), c);

select nvl(a, 1), c from t1 group by grouping sets(a, c);

select c, a + b from t1 group by grouping sets(a+b,c);

select a, b from t1 group by grouping sets(a, b) having max(a) < 5 or a > 1 or b > 1 or max(b) < 3;

select a, b, c, d from t1 group by grouping sets(a, b, c, d) having a > 1 or b > 1 or c > 1 or d > 1;

