# owner group: sql1
# tags: optimizer, cross_validation
# description: 


--disable_warnings
--disable_query_log
--disable_result_log
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

CREATE TABLE t1(a INT);
CREATE TABLE t2(c INT);
CREATE TABLE t3(b BLOB NOT NULL);

--enable_query_log
--enable_result_log
--result_format 4
--explain_protocol 2
select (select count(t1.a) from t2) from t1;

select (select count(t1.a+t2.c) from t2) from t1;

SELECT
 (SELECT 1 FROM t1
  WHERE (SELECT c FROM t2 ORDER BY COUNT(t3.b))
 )
FROM t3;

drop table t1,t2,t3;