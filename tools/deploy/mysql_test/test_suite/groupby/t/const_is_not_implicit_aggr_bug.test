explain SELECT /*+ PQ_DISTRIBUTE(t5_2131 Broadcast, None) use_nl(t5_2131) */ SUM(t6_1170.c6) FROM ( SELECT t6_1170.c1, t6_1170.c2, t6_1170.c4, 1 AS c6, ( SELECT t6_1170.c7 FROM t6 AS t6_1170 ORDER BY 1 LIMIT 1 ) AS c7, t6_1170.c10 FROM t6 AS t6_1170 ) AS t6_1170 LEFT OUTER JOIN t5 AS t5_2131 ON t6_1170.c7 < 678 WHERE t6_1170.c2 < 78 GROUP BY t6_1170.c2;

SELECT /*+ PQ_DISTRIBUTE(t5_2131 Broadcast, None) use_nl(t5_2131) */ SUM(t6_1170.c6) FROM ( SELECT t6_1170.c1, t6_1170.c2, t6_1170.c4, 1 AS c6, ( SELECT t6_1170.c7 FROM t6 AS t6_1170 ORDER BY 1 LIMIT 1 ) AS c7, t6_1170.c10 FROM t6 AS t6_1170 ) AS t6_1170 LEFT OUTER JOIN t5 AS t5_2131 ON t6_1170.c7 < 678 WHERE t6_1170.c2 < 78 GROUP BY t6_1170.c2;

drop table t5;
drop table t6;
