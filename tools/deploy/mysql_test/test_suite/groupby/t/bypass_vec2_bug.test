#owner: zongmei.zzm
#owner group: SQL2

--result_format 4

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;

alter system set_tp tp_no = 254, error_code = 2147483647, frequency = 1;
alter system set_tp tp_no = 2211, error_code=4016, frequency=1;

connection default;

--disable_warnings
drop table if exists ls_752;
--enable_warnings

CREATE TABLE `ls_752` (
  `col_48447` int(11) NOT NULL,
  `col_48370` int(11) NOT NULL,
  `col_48396` text NOT NULL,
  `col_48405` varchar(16) NOT NULL,
  `col_48426` int(11) NOT NULL DEFAULT '1971',
  `col_48434` int(11) NOT NULL DEFAULT '-15591',
  `col_48435` int(11) NOT NULL,
  `col_48463` bigint(20) NOT NULL,
  `col_48461` bigint(20) unsigned DEFAULT '218140214339573725',
  `col_48449` int(10) unsigned DEFAULT '14814359',
  `col_48433` int(11) DEFAULT '-6303',
  `col_48453` varchar(20) DEFAULT NULL,
  `col_48381` int(11) DEFAULT NULL,
  `col_48477` varbinary(426) NOT NULL DEFAULT 'X%Mw@Z',
  `col_48368` bigint(20) unsigned NOT NULL,
  `col_48390` int(11) NOT NULL DEFAULT '1',
  PRIMARY KEY (`col_48434`, `col_48477`, `col_48426`),
  UNIQUE KEY `idx_699` (`col_48434`, `col_48405`) BLOCK_SIZE 16384 GLOBAL,
  UNIQUE KEY `idx_702` (`col_48434`, `col_48463`, `col_48368`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx_701` (`col_48449`, `col_48433`, `col_48453`, `col_48461`, `col_48381`) BLOCK_SIZE 16384 GLOBAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

insert /*+enable_parallel_dml parallel(8)*/into ls_752
  select uniform(-1000, 1000, random(1)) as col_48447,
         uniform(-1000, 1000, random(2)) as col_48370,
         randstr(9999, random(3)) as col_48396,
         randstr(15, random(4)) as col_48405,
         uniform(-1000, 1000, random(5)) as col_48426,
         uniform(-1000, 1000, random(6)) as col_48434,
         uniform(-1000, 1000, random(7)) as col_48435,
         uniform(-1000, 1000, random(8)) as col_48463,
         uniform(0, 1000, random(9)) as col_48461,
         uniform(0, 1000, random(10)) as col_48449,
         uniform(-1000, 1000, random(11)) as col_48433,
         randstr(20, random(12)) as col_48453,
         uniform(-1000, 1000, random(13)) as col_48381,
         randstr(426, random(14)) as col_48477,
         uniform(0, 1000, random(15)) as col_48368,
         uniform(-1000, 1000, random(16)) as col_48390 from table(generator(1000));

--disable_result_log
select
  /*+  NO_USE_HASH_AGGREGATION ,  PARALLEL( 10 )*/ ls_752.col_48396 as r1,
  sum(distinct ls_752.col_48370) as r4,
  min(distinct ls_752.col_48390) as r6,
  BIT_OR (ls_752.col_48435) as r7
from
  ls_752
group by
  ls_752.col_48370;

--enable_result_log

drop table ls_752;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(a int, b int, c int, d int);
insert into t1 select uniform(1, 1000, random(1)) as a, uniform(1, 1000, random(2)) as b, uniform(1, 1000, random(3)) as c, uniform(1, 1000, random(4)) as d from table(generator(1000));
--sorted_result
select   /*+parallel(2)*/grouping(b), grouping(c), count( a) from t1 group by b, c, d with rollup order by 1,2, 3;

connection syscon;
alter system set_tp tp_no = 254, error_code = 2147483647, frequency = 0;
alter system set_tp tp_no = 2211, error_code=4016, frequency=0;
