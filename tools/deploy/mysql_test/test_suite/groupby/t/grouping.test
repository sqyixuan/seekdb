#窗口函数暂不支持分区表
#结果一致
select grouping(school)+grouping(class), sum(score) , max(score) over(partition by (grouping(school))) from score_tbl group by school, class, score with rollup order by 1, 2, 3;
select grouping(school)+grouping(class), sum(score) , max(score) over(partition by (grouping(school)+grouping(class))) from score_tbl group by school, class, score with rollup order by 1, 2, 3;
select school, class, grouping(school), grouping(class), sum(score), ROW_NUMBER() OVER (partition by grouping(school)+grouping(class) order by class)  from score_tbl group by school, class with rollup;
select school, class, grouping(school), grouping(class) ,sum(score), ROW_NUMBER() OVER (partition by grouping(class) order by class)  from score_tbl group by school,class with rollup ;
select school, class, grouping(school), grouping(class), cume_dist() OVER(partition by grouping(school)+grouping(class) order by class)  from score_tbl group by school, class with rollup;
select school, class, grouping(school), grouping(class), cume_dist() OVER(partition by grouping(class) order by class)  from score_tbl group by school, class with rollup;
select school, class, grouping(school), grouping(class), sum(score), ntile(2) over (partition by grouping(school)+grouping(class) order by class) from score_tbl group by school, class with rollup;

#need check
select school, class, grouping(class), grouping(school), sum(score), lead(school) over ( partition by grouping(school)+grouping(class) order by class) from score_tbl group by school, class with rollup;
select school, class, grouping(class), grouping(school), sum(score), lag(school) over ( partition by grouping(school)+grouping(class) order by class) from score_tbl group by school, class with rollup;

