--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zongmei.zzm
# owner group: sql2
# tags: optimizer
#
# Test file for plans (with/without partition) generated by aggregate function APPROX_COUNT_DISTINCT, APPROX_COUNT_DISTINCT_SYNOPSIS and APPROX_COUNT_DISTINCT_SYNOPSIS_MERGE

# table t1 is used to test normal table (without partition).
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (
  a1 char(64), a2 char(64), b char(16), c char(16) not null, d char(16), dummy char(248) default ' ');

explain select approx_count_distinct(c) from t1 group by a1;
explain select approx_count_distinct_synopsis(c) from t1 group by a1;
explain select approx_count_distinct_synopsis_merge(c) from t1 group by a1;

# table t2 is another normal table (without partition)
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2 (num bigint, partition_key bigint, non_partition_key bigint);

# group by with partition key
explain select approx_count_distinct(num) from t2 group by partition_key;
explain select approx_count_distinct_synopsis(num) from t2 group by partition_key;
--error 1235
explain select approx_count_distinct_synopsis_merge(num) from t2 group by partition_key;

# group by with non-partition key
explain select approx_count_distinct(num) from t2 group by non_partition_key;
explain select approx_count_distinct_synopsis(num) from t2 group by non_partition_key;
--error 1235
explain select approx_count_distinct_synopsis_merge(num) from t2 group by non_partition_key;


# table t3 is a table with hash partition
--disable_warnings
drop table if exists t3;
--enable_warnings
create table t3 (num bigint, partition_key bigint, non_partition_key bigint) PARTITION BY HASH(partition_key) PARTITIONS 10;

# group by with partition key
explain select approx_count_distinct(num) from t3 group by partition_key;
explain select approx_count_distinct_synopsis(num) from t3 group by partition_key;
--error 1235
explain select approx_count_distinct_synopsis_merge(num) from t3 group by partition_key;

# group by with non-partition key
explain select approx_count_distinct(num) from t3 group by non_partition_key;
explain select approx_count_distinct_synopsis(num) from t3 group by non_partition_key;
--error 1235
explain select approx_count_distinct_synopsis_merge(num) from t3 group by non_partition_key;

#table t4 is a table with range partition
--disable_warnings
drop table if exists t4;
--enable_warnings
create table t4 (num bigint, partition_key bigint, non_partition_key bigint) PARTITION BY RANGE(partition_key) (
    PARTITION p0 VALUES LESS THAN (-2000000000000),
    PARTITION p1 VALUES LESS THAN (-1000000000000),
    PARTITION p2 VALUES LESS THAN (0),
    PARTITION p3 VALUES LESS THAN (1000000000000),
    PARTITION p4 VALUES LESS THAN (2000000000000),
    PARTITION p5 VALUES LESS THAN MAXVALUE
);

# group by with partition key
explain select approx_count_distinct(num) from t4 group by partition_key;
explain select approx_count_distinct_synopsis(num) from t4 group by partition_key;
--error 1235
explain select approx_count_distinct_synopsis_merge(num) from t4 group by partition_key;

# group by with non-partition key
explain select approx_count_distinct(num) from t4 group by non_partition_key;
explain select approx_count_distinct_synopsis(num) from t4 group by non_partition_key;
--error 1235
explain select approx_count_distinct_synopsis_merge(num) from t4 group by non_partition_key;

#table t5 is a table with range+hash partition
--disable_warnings
drop table if exists t5;
--enable_warnings
create table t5 (num bigint, partition_key bigint, non_partition_key bigint, another_partition_key bigint)
  PARTITION BY RANGE(partition_key)
  SUBPARTITION BY HASH(another_partition_key)
  SUBPARTITIONS 3
  (
    PARTITION p0 VALUES LESS THAN (-2000000000000),
    PARTITION p1 VALUES LESS THAN (-1000000000000),
    PARTITION p2 VALUES LESS THAN (0),
    PARTITION p3 VALUES LESS THAN (1000000000000),
    PARTITION p4 VALUES LESS THAN (2000000000000),
    PARTITION p5 VALUES LESS THAN MAXVALUE
);

# group by with one partition key
explain select approx_count_distinct(num) from t5 group by partition_key;
explain select approx_count_distinct_synopsis(num) from t5 group by partition_key;
--error 1235
explain select approx_count_distinct_synopsis_merge(num) from t5 group by partition_key;

# group by with all partition keys
explain select approx_count_distinct(num) from t5 group by partition_key, another_partition_key;
explain select approx_count_distinct_synopsis(num) from t5 group by partition_key, another_partition_key;
--error 1235
explain select approx_count_distinct_synopsis_merge(num) from t5 group by partition_key, another_partition_key;

# group by with non-partition key
explain select approx_count_distinct(num) from t5 group by non_partition_key;
explain select approx_count_distinct_synopsis(num) from t5 group by non_partition_key;
--error 1235
explain select approx_count_distinct_synopsis_merge(num) from t5 group by non_partition_key;

--disable_warnings
drop table if exists t6;
--enable_warnings
# issue 
create table t6(c1 int, c2 int) partition by range(c1) (partition p1 values less than(2), partition p2 values less than(3),partition p3 values less than(MAXVALUE));
insert into t6 values (1,2),(2,2),(3,2);
explain select count(distinct c1), approx_count_distinct(c2), count(distinct c2) from t6;
select count(distinct c1), approx_count_distinct(c2), count(distinct c2) from t6;
explain select count(distinct c1), approx_count_distinct_synopsis(c2), count(distinct c2) from t6;
select count(distinct c1), approx_count_distinct_synopsis(c2), count(distinct c2) from t6;

drop table t1, t2, t3, t4, t5, t6; 

create table t1 (c1 date, c2 datetime, c3 timestamp, c4 time, c5 year);

alter table t1 modify c1 binary(256);
insert into t1(c1, c2)  values (3, null), (2, null), (4, null);

--error 1210
select APPROX_COUNT_DISTINCT_SYNOPSIS_MERGE(c1) over (partition by c1) from t1;
--error 1210
select APPROX_COUNT_DISTINCT_SYNOPSIS_MERGE(c1) from t1;

--error 1210
select /*+opt_param("enable_rich_vector_format", "false")*/APPROX_COUNT_DISTINCT_SYNOPSIS_MERGE(c1) over (partition by c1) from t1;
--error 1210
select /*+opt_param("enable_rich_vector_format", "false")*/APPROX_COUNT_DISTINCT_SYNOPSIS_MERGE(c1) from t1;

drop table t1;
create table t1 (c1 varchar(1024), c2 datetime, c3 timestamp, c4 time, c5 year);
insert into t1(c1, c2)  values (repeat(3,1024), null), (repeat(2, 1024), null), (repeat(4, 1024), null);


select APPROX_COUNT_DISTINCT_SYNOPSIS_MERGE(c1) over (partition by c1) from t1;
select APPROX_COUNT_DISTINCT_SYNOPSIS_MERGE(c1) from t1;
select /*+opt_param("enable_rich_vector_format", "false")*/APPROX_COUNT_DISTINCT_SYNOPSIS_MERGE(c1) over (partition by c1) from t1;
select /*+opt_param("enable_rich_vector_format", "false")*/APPROX_COUNT_DISTINCT_SYNOPSIS_MERGE(c1) from t1;