--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# owner group: SQL2
# tags: groupby, optimizer
# description: 
#

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1(c1 set('Alice','Bob','Charlie','David'), c2 varchar(100));
insert into t1 values('David', 'Asz');
create table t2(c1 smallint(6));

select /*+ opt_param('enable_rich_vector_format', 'false') */ max( distinct t1.c2) from t1 where not(t1.c1 in (select c1 from t2));
select /*+ opt_param('enable_rich_vector_format', 'true') */ max( distinct t1.c2) from t1 where not(t1.c1 in (select c1 from t2));

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings


