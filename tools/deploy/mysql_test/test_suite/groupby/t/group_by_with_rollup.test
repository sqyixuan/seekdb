--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zongmei.zzm
#owner group: sql1
#tags: pl, optimizer, groupby

## Test Name: group_by_with_rollup
## Scope: test function of group by with rollup
## Date: 2016-12-7
--disable_warnings
drop table if exists test1;
drop table if exists ctas_1;
drop table if exists ctas_2;
--enable_warnings

create table test1 (id1 int, id2 int, count int);
insert into test1 values (1,1,1),(1,1,2),(1,1,3),(1,2,3),(1,2,3),(1,2,4),(1,3,1),(1,3,5),(2,1,3),(2,1,4),(2,1,null),(2,2,null),(2,null,1),(2,null,2),(2,null,1);
select id1, id2, max(count), max(distinct count), min(count), min(distinct count), sum(count), sum(distinct count), count(*), count(count), count(distinct count)from test1 group by id1, id2 with rollup;
select id1, id2, avg(count), avg(distinct count), group_concat(count), group_concat(distinct count), group_concat(distinct count order by count), group_concat(distinct count order by count separator ':') from test1 group by id1, id2 with rollup;
select id1, id2, max(count), max(distinct count), min(count), min(distinct count), sum(count), sum(distinct count), count(*), count(count), count(distinct count)from test1 group by id1 with rollup;
select id1, id2, avg(count), avg(distinct count), group_concat(count), group_concat(distinct count), group_concat(distinct count order by count), group_concat(distinct count order by count separator ':') from test1 group by id1 with rollup;
select id1, id2, max(count), max(distinct count), min(count), min(distinct count), sum(count), sum(distinct count), count(*), count(count), count(distinct count)from test1 group by id2 with rollup;
select id1, id2, avg(count), avg(distinct count), group_concat(count), group_concat(distinct count), group_concat(distinct count order by count), group_concat(distinct count order by count separator ':') from test1 group by id2 with rollup;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(a int, b int, c int, d int);

--disable_query_log
insert into t1 values(1, 2, 3, 4);
insert into t1 values(1, 2, 3, 6);
insert into t1 values(1, 2, 4, 5);
insert into t1 values(1, 3, 4, 5);
insert into t1 values(1, 3, 5, 6);
insert into t1 values(2, 3, 4, 5);
--enable_query_log

--disable_query_log
--disable_result_log
select * from t1;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

select a,b,sum(c) from t1 where a > 0 group by a desc, b desc with rollup;
create table ctas_1 as select a,b,sum(c) from t1 where a > 0 group by a desc, b desc with rollup;
select * from ctas_1 order by a;
drop table ctas_1;
select a+b,sum(c) from t1 where a > 0 group by a desc, b desc with rollup;
create table ctas_1 as select a+b as a1,sum(c) from t1 where a > 0 group by a desc, b desc with rollup;
select * from ctas_1 order by a1;

select a,b,sum(c) from t1 where a > 0 group by a desc, b asc with rollup;
create table ctas_2 as select a,b,sum(c) from t1 where a > 0 group by a desc, b asc with rollup;
select * from ctas_2 order by a;
drop table ctas_2;
select a+b,sum(c) from t1 where a > 0 group by a desc, b asc with rollup;
create table ctas_2 as select a+b as a1,sum(c) from t1 where a > 0 group by a desc, b asc with rollup;
select * from ctas_2 order by a1;

drop table t1;
drop table ctas_1;
drop table ctas_2;

--disable_warnings
drop table if exists Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(Z0_TEST0 char(100), Z0_TEST1 date,Z0_TEST2 int);

--disable_query_log
--disable_result_log
INSERT INTO Z0CASE (Z0_TEST0,Z0_TEST1,Z0_TEST2)values('abcABC','2011-11-11',1);
INSERT INTO Z0CASE (Z0_TEST0,Z0_TEST1,Z0_TEST2)values('abcABC','2011/11/11',2);
INSERT INTO Z0CASE (Z0_TEST0,Z0_TEST1,Z0_TEST2)values('111','2011-11-11 01:00:00',11);
INSERT INTO Z0CASE (Z0_TEST0,Z0_TEST1,Z0_TEST2)values(NULL ,'2011-11-11 13:00:00',0);
INSERT INTO Z0CASE (Z0_TEST0,Z0_TEST1,Z0_TEST2)values('123','2011-11-11 00:00:00',100);
INSERT INTO Z0CASE (Z0_TEST0,Z0_TEST1,Z0_TEST2)values('123','2011/11/11 01:00:00 ',100);
INSERT INTO Z0CASE (Z0_TEST0,Z0_TEST1,Z0_TEST2)values('abc123456bc','2011/11/11 01:00:00',0);
INSERT INTO Z0CASE (Z0_TEST0,Z0_TEST1,Z0_TEST2)values('abc123456bc','2011/11/11 00:00:00',0);
SELECT COUNT(*) FROM Z0CASE;
--enable_query_log
--enable_result_log

##bug:

SELECT Z0_TEST2-2 FROM Z0CASE GROUP BY Z0_TEST2-2 with ROLLUP;

##bug:

SELECT GROUPING(z0_test0||z0_test1)FROM Z0CASE GROUP BY z0_test0||z0_test1 with ROLLUP;

##bug:

SELECT UPPER(z0_test1) FROM Z0CASE GROUP BY UPPER(z0_test1) with ROLLUP ORDER BY 1;

