insert into t1 values (100);
explain select s1, s2, count(distinct s2) from (select c1 as s1, c1 + c1 as s2 from t1) group by s1 with rollup;
select s1, s2, count(distinct s2) from (select c1 as s1, c1 + c1 as s2 from t1) group by s1 with rollup;
explain select c1, c1 + c1, count(distinct c1 + c1) from t1 group by c1 with rollup;
