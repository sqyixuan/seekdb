explain basic select /*+ parallel(3) */ c1, count(c3),sum(distinct c1) from t1 group by c1 order by 1,2,3;
select /*+ parallel(3) */ c1, count(c3),sum(distinct c1) from t1 group by c1 order by 1,2,3;

