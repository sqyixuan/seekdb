--echo "test hash-aggregate for three stage aggregation"

alter system set _sqlexec_disable_hash_based_distagg_tiv=false;
alter system flush plan cache global;
sleep 2;

analyze table t1 update histogram on c1, c2, c3 with 1 buckets;

explain select /*+ parallel(2) */ c1, sum(distinct c2),count(distinct c3) from t1 group by c1;
## test distinct aggregation
select /*+ parallel(2) */ c1, sum(distinct c2),count(distinct c3) from t1 group by c1 order by 1,2,3;

## test distinct aggregation
explain select /*+ parallel(2) */ c1, avg(distinct c2) from t1 group by c1;
select /*+ parallel(2) */ c1, avg(distinct c2) from t1 group by c1 order by 1,2;

##test mix distinct and non-distinct aggregate function
explain select /*+ parallel(3) */ c1, avg(c2), count(distinct c2),sum(distinct c2),avg(distinct c2) from t1 group by c1;
select /*+ parallel(3) */ c1, avg(c2), count(distinct c2),sum(distinct c2),avg(distinct c2) from t1 group by c1 order by 1,2,3,4,5;

explain basic select /*+ parallel(2) */ c1, sum(distinct c1),count(c3) from t1 group by c1 order by 1,2,3;
