alter system set _rowsets_enabled = true;
alter system flush plan cache;
sleep 2;
drop table t1;
--disable_warnings
--error 0, 942, 1051
drop table t2;
--enable_warnings

create table t1 (c1 int);
insert into t1 values(1);
insert into t1 values(2);
insert into t1 values(3);
insert into t1 values(4);
insert into t1 values(5);
insert into t1 values(6);

insert into t1 select * from t1;

create table t2 as select * from t1;


select /*+parallel(2)*/ * from ((select count(t1.c1), count(distinct t1.c1) from t1) B1 , (select count(t2.c1), count(distinct t2.c1) from t2) B2);

select count(distinct null) FROM t1 ;

drop table t1;
drop table t2;

connection syscon;
alter system set_tp tp_no = 365, error_code = 0, frequency = 1;
alter system set_tp tp_no = 254, error_code = 0, frequency = 1;
