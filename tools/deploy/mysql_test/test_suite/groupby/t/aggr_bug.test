##bug:

--disable_warnings
--error 0,942
drop table if exists t1;
drop view if exists v1;
--enable_warnings

create table t1(c1 int);

create or replace view v1 as select hex(approx_count_distinct_synopsis(c1)) from t1;
select * from v1;

# approx_count_distinct_synopsis_merge does not allow types other than string
--error 1235
create or replace view v1 as select hex(approx_count_distinct_synopsis_merge(c1)) from t1;
select * from v1;

drop table t1;
drop view v1;

