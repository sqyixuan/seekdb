connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 254, error_code = 1, frequency = 1;
alter system flush plan cache global;
sleep 1;
connection default;

--disable_warnings
--error 0,942
drop table if exists t2;
--enable_warnings


alter system set _rowsets_max_rows = 1;
create table t2 (c1 date);
insert into t2 values('2020-01-01');
insert into t2 values('2020-01-01');
insert into t2 values('2021-01-01');
insert into t2 values('2021-01-01');
insert into t2 values('2022-01-01');
insert into t2 values('2022-01-01');
insert into t2 values('2023-01-01');
insert into t2 values('2024-01-01');
--enable_sorted_result
select /*+ parallel(2) no_rewrite*/ DATE_ADD(DATE_FORMAT(c1,'%Y-%m-%01 %T'), INTERVAL 2 MONTH ) from t2 group by DATE_FORMAT(DATE_ADD(DATE_FORMAT(c1,'%Y-%m-%01 %T'), INTERVAL 2 MONTH ), '%Y%m'), DATE_ADD(DATE_FORMAT(c1,'%Y-%m-%01 %T'), INTERVAL 2 MONTH );
drop table t2;
alter system set _rowsets_max_rows = 256;
connection conn_admin;
alter system set_tp tp_no = 254, error_code = 1, frequency = 0;