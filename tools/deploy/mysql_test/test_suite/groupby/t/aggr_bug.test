##bug:

--disable_warnings
--error 0,942
drop table if exists ob_causal_ordering1;
--enable_warnings

CREATE TABLE `ob_causal_ordering1` (
  `grp_num` bigint(20) NOT NULL,
  `row_num` bigint(20) NOT NULL,
  `version` bigint(20) NOT NULL DEFAULT '0',
  `gm_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
  `gm_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),
  PRIMARY KEY (`grp_num`, `row_num`, `version`),
  KEY `version` (`version`) BLOCK_SIZE 16384 LOCAL
);

select cast(coalesce(33,  VAR_SAMP(cast(70 as DECIMAL)) over (partition by grp_num order by row_num)) as DECIMAL) as c4 from ob_causal_ordering1;

drop table ob_causal_ordering1;

##bug:

--disable_warnings
--error 0,942
drop table if exists obright, obmother;
--enable_warnings

CREATE TABLE `obright` (
  `grp_id` bigint(20) NOT NULL,
  `dec1` decimal(16,4) DEFAULT NULL
);

CREATE TABLE `obmother` (
  `id` varchar(20) NOT NULL
);

insert into obright values(50097587,1.0000),(2,2.0000),(3,3.0000),(74802970,4.0000),(5,5.0000),(6, 302610335030.0000),(7,7.0000),(90392191,8.0000),(9,9.0000),(10,10.0000);
insert into obmother values('TGHv58YctC2upE'),('  '),('3Yl83kYDMs0HlB4KoSB');

select cast(coalesce(ref_26.id, (select APPROX_COUNT_DISTINCT(grp_id) from obright order by 1) ) as CHAR) as c2,
(select VAR_SAMP(dec1) from obright order by 1)  as c5 from  obmother as ref_26 limit 112;

drop table obright, obmother;

