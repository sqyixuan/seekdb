# owner: lijinmao.ljm
# owner group: sql1
# description:
# tag: optimizer

--result_format 4
--explain_protocol 1

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 float);
create table t2(c1 float);
select sum(distinct t2.c1) as a from t1 left join t2 on false group by t2.c1 with rollup having a > 0;

drop table t1,t2;