drop table t1;
create table t1 (col_decimal decimal(20,0),col_bigint bigint,pk bigint);
insert into t1 values (123, 2, 1);
select pk from t1 group by pk having 10 not in (select 1 from t1 where pk <> (count(1)));
pk
1
select 1 from t1 where  (select 1 from t1 group by pk having  (select 1 from t1 where count(1)));
1
1
select 1 from t1 group by pk having  (select 1 from dual where (select 1 from t1 where count(1)));
1
1
select pk from t1 group by pk having 10 not in (select pk,count(1) from t1);
