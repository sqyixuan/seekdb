result_format: 4
drop table if exists llm10;
CREATE TABLE `llm10` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `a1` int(11) DEFAULT NULL,
  `a2` int(11) DEFAULT NULL,
  `a3` int(11) DEFAULT NULL,
  `a4` int(11) DEFAULT NULL,
  `a5` int(11) DEFAULT NULL,
  `a6` int(11) DEFAULT NULL,
  `a7` bigint(20) DEFAULT NULL,
  `a8` bigint(20) DEFAULT NULL,
  `a9` char(256) DEFAULT NULL,
  `a10` char(256) DEFAULT NULL,
  `a11` decimal(30,8) DEFAULT NULL,
  `a12` decimal(40,30) DEFAULT NULL,
  `a13` varchar(1000) DEFAULT NULL,
  `a14` varchar(1000) DEFAULT NULL,
  `a15` date DEFAULT NULL,
  `a16` timestamp(6) NULL DEFAULT NULL,
  PRIMARY KEY (`id`)
);

explain select /*+ PARALLEL(16) opt_param('use_hash_rollup', 'auto')*/ SQL_CALC_FOUND_ROWS a10,a11,a12,count(distinct a8),sum(distinct a2),avg(a3) from llm10 group by a10,a11,a12 with rollup order by 1,2,3,4,5,6 limit 1,10;
