INSERT INTO course VALUES ('叶问', '法语','七号');
select t.name as '姓名',GROUP_CONCAT(t.course_name ) as '课程' from course t group by t.name ;
姓名	课程
叶问	阅读赏析,法语
李明	阅读赏析,太极剑,摄影
司马光	马克思主义基本原理,摄影
select group_concat(name), group_concat(course_name) from course;
group_concat(name)	group_concat(course_name)
李明,李明,李明,司马光,司马光,叶问,叶问	阅读赏析,摄影,太极剑,马克思主义基本原理,摄影,阅读赏析,法语
select group_concat(name separator 'abc'), group_concat(course_name separator 'def') from course;
group_concat(name separator 'abc')	group_concat(course_name separator 'def')
李明abc李明abc李明abc司马光abc司马光abc叶问abc叶问	阅读赏析def摄影def太极剑def马克思主义基本原理def摄影def阅读赏析def法语
