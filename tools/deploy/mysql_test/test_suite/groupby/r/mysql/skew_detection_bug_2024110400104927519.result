result_format: 4
drop database if exists test_skew;
Warnings:
Note	1008	Can't drop database 'test_skew'; database doesn't exist
create database test_skew;
use test_skew;

create table t1(c1 bigint, c2 bigint, c3 bigint) with column group(each column);
set session ob_query_timeout = 120000000;
insert /*+ append enable_parallel_dml parallel(8) */ignore into t1(c1,c2,c3) (select 5, 5, 5 from table(generator(1000000)));
insert /*+ append enable_parallel_dml parallel(8) */ignore into t1(c1,c2,c3) (select uniform(200,1000000000,random()), uniform(200,1000000000,random()), uniform(200,1000000000,random()) from table(generator(1000000)));

create table tt1 as (select * from t1 order by random());
insert /*+ append enable_parallel_dml parallel(8) */ignore into tt1(c1,c2,c3) (select 5, 5, 5 from table(generator(512)));

create table t2(c1 bigint, c2 bigint, c3 bigint, c4 bigint, primary key(c1,c2,c3,c4)) with column group(each column);
