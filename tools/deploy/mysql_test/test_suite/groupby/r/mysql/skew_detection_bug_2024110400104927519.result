alter system set _enable_hgby_skew_detection = true;
alter system flush plan cache global;
select /*+ parallel(2) */ max(c) from (select count(*) c, sum(c2) s2, sum(c3) s3, c1 from (select * from tt1 union all select /*+ USE_HASH(l h) */ l.c1,l.c2,h.c3 FROM t2 h, t2 l where l.c1=h.c1 and h.c4+l.c4<=2 and l.c1<10) group by c1);
+---------+
| max(c)  |
+---------+
| 1000518 |
+---------+
alter system set _enable_hgby_skew_detection = false;
alter system flush plan cache global;
