drop table if exists t1;
create table t1(a int, b int, c int, d int);
result_format: 4
explain_protocol: 2
EXPLAIN select a,b,sum(c) from t1 where a > 0 group by a desc, b desc with rollup;
Query Plan
=====================================================
|ID|OPERATOR             |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------
|0 |SORT                 |    |1       |3           |
|1 |└─HASH GROUP BY      |    |1       |3           |
|2 |  └─EXPANSION        |    |2       |3           |
|3 |    └─TABLE FULL SCAN|t1  |1       |3           |
=====================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a], [t1.b], [T_FUN_SUM(t1.c)]), filter(nil), rowset=16
      sort_keys([t1.a, DESC], [t1.b, DESC])
  1 - output([t1.a], [t1.b], [T_FUN_SUM(t1.c)]), filter(nil), rowset=16
      group([t1.a], [t1.b], [GROUPING_ID]), agg_func([T_FUN_SUM(t1.c)])
  2 - output([t1.a], [t1.b], [GROUPING_ID], [t1.c]), filter(nil), rowset=16
      repeat(3)[(t1.a, t1.b), (t1.a, NULL), (NULL, NULL)]
  3 - output([t1.a], [t1.b], [t1.c]), filter([t1.a > 0]), rowset=16
      access([t1.a], [t1.b], [t1.c]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select a,b,sum(c) from t1 where a > 0 group by a desc, b desc with rollup;
+------+------+--------+
| a    | b    | sum(c) |
+------+------+--------+
|    2 |    3 |      4 |
|    2 | NULL |      4 |
|    1 |    3 |      9 |
|    1 |    2 |     10 |
|    1 | NULL |     19 |
| NULL | NULL |     23 |
+------+------+--------+
