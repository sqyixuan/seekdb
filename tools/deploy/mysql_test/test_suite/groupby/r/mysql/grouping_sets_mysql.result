      access([requests.os], [requests.device]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([requests.__pk_increment]), range(MIN ; MAX)always true
  5 - output([cast(NULL, CHAR(20))], [cast(NULL, CHAR(20))], [requests.city], [T_FUN_COUNT(*)]), filter(nil), rowset=16
      group([requests.city]), agg_func([T_FUN_COUNT(*)])
  6 - output([requests.city]), filter(nil), rowset=16
