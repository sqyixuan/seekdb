result_format: 4
explain_protocol: 2
# MaxCompute 语法兼容测试
DROP TABLE IF EXISTS REQUESTS;
# 使用 select 语句分组
EXPLAIN select NULL, NULL, NULL, count(*)
from requests
union all
select os, device, NULL, count(*)
from requests group by os, device
union all
select null, null, city, count(*)
from requests group by city;
Query Plan
=======================================================
|ID|OPERATOR           |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------
|0 |UNION ALL          |        |15      |11          |
|1 |├─SCALAR GROUP BY  |        |1       |3           |
|2 |│ └─TABLE FULL SCAN|requests|7       |3           |
|3 |├─HASH GROUP BY    |        |7       |5           |
|4 |│ └─TABLE FULL SCAN|requests|7       |3           |
|5 |└─HASH GROUP BY    |        |7       |5           |
|6 |  └─TABLE FULL SCAN|requests|7       |3           |
=======================================================
