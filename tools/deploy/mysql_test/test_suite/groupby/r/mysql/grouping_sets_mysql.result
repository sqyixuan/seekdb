      pushdown_aggregation([T_FUN_COUNT(*)])
  3 - output([requests.os], [requests.device], [cast(NULL, CHAR(20))], [T_FUN_COUNT(*)]), filter(nil), rowset=16
      group([requests.os], [requests.device]), agg_func([T_FUN_COUNT(*)])
