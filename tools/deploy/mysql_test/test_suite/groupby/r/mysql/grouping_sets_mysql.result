select
  if(grouping(os) = 0, os, 'ALL') as os,
  if(grouping(device) = 0, device, 'ALL') as device,
  if(grouping(city) = 0, city, 'ALL') as city, 
  count(*) as count 
from requests 
group by grouping sets((os, device), (city), ());
+---------+--------+--------------+-------+
| os      | device | city         | count |
+---------+--------+--------------+-------+
| ALL     | ALL    | ALL          |     7 |
| ALL     | ALL    | Beijing      |     4 |
| ALL     | ALL    | Shijiazhuang |     3 |
| ios     | Phone  | ALL          |     1 |
| linux   | PC     | ALL          |     1 |
| linux   | Phone  | ALL          |     1 |
| windows | PC     | ALL          |     3 |
| windows | Phone  | ALL          |     1 |
+---------+--------+--------------+-------+

