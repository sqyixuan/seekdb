alter system set_tp tp_no = 365, error_code = 1, frequency = 1;
drop table t1;
create table t1(c0 int, c1 int,c2 int,c3 int) partition by hash(c0) partitions 16;
insert into t1 values(0,1,1,1);
insert into t1 values(1,1,2,1);
insert into t1 values(2,1,0,2);
insert into t1 values(3,0,1,0);
insert into t1 values(4,3,2,1);
insert into t1 values(5,3,0,1);
commit;
"test merge-aggregate for three stage aggregation"
alter system set _sqlexec_disable_hash_based_distagg_tiv=true;
analyze table t1 update histogram on c1, c2, c3 with 1 buckets;
explain select /*+ parallel(2) */ c1, sum(distinct c2),count(distinct c3) from t1 group by c1;
