set autocommit = 0;
drop table t3;
drop table t4;

create table t3(a int, b int);
create table t4(a int, b int) partition by hash(a) partitions 5;

EXPLAIN delete t3 where  1 in (select  max(b) b from t1 group by grouping sets(a, b));
delete t3 where  1 in (select  max(b) b from t1 group by grouping sets(a, b));
EXPLAIN delete t4 where  1 in (select  max(b) b from t1 group by grouping sets(a, b));
delete t4 where  1 in (select  max(b) b from t1 group by grouping sets(a, b));
rollback;

EXPLAIN insert into t3 select  a, max(b) b from t1 group by grouping sets(a, b);
insert into t3 select  a, max(b) b from t1 group by grouping sets(a, b);
EXPLAIN insert into t4 select  a, max(b) b from t1 group by grouping sets(a, b);
insert into t4 select  a, max(b) b from t1 group by grouping sets(a, b);
rollback;

EXPLAIN insert into t3 select  a, max(b) b from t1 group by grouping sets(a, b) union all select a, max(b) b from t2 group by grouping sets(a, b);
insert into t3 select  a, max(b) b from t1 group by grouping sets(a, b) union all select a, max(b) b from t2 group by grouping sets(a, b);
EXPLAIN insert into t4 select  a, max(b) b from t1 group by grouping sets(a, b) union all select a, max(b) b from t2 group by grouping sets(a, b);
insert into t4 select  a, max(b) b from t1 group by grouping sets(a, b) union all select a, max(b) b from t2 group by grouping sets(a, b);
rollback;

EXPLAIN update t3 set a = 4 where exists (select max(b) b from t1 group by grouping sets(a, b));
update t3 set a = 4 where exists (select max(b) b from t1 group by grouping sets(a, b));
EXPLAIN update t4 set a = 4 where exists (select max(b) b from t1 group by grouping sets(a, b));
update t4 set a = 4 where exists (select max(b) b from t1 group by grouping sets(a, b));
rollback;

EXPLAIN update t3 set a = 4 where exists (select max(b) b from t1 group by grouping sets(a, b)) and exists (select sum(b) b from t1 group by grouping sets(a, b));
update t3 set a = 4 where exists (select max(b) b from t1 group by grouping sets(a, b)) and exists (select sum(b) b from t1 group by grouping sets(a, b));
EXPLAIN update t4 set a = 4 where exists (select max(b) b from t1 group by grouping sets(a, b)) and exists (select sum(b) b from t1 group by grouping sets(a, b));
update t4 set a = 4 where exists (select max(b) b from t1 group by grouping sets(a, b)) and exists (select sum(b) b from t1 group by grouping sets(a, b));
rollback;

explain merge into t3 A using t2 B on (exists (select max(b) b from t1 group by grouping sets(a, b))) when matched then update set A.a = B.a, A.b = B.b;
merge into t3 A using t2 B on (exists (select max(b) b from t1 group by grouping sets(a, b))) when matched then update set A.a = B.a, A.b = B.b;
rollback;

## merge into with partition table
explain merge into t4 A using t2 B on (exists (select max(b) b from t1 group by grouping sets(a, b))) when matched then update set A.a = B.a, A.b = B.b;
merge into t4 A using t2 B on (exists (select max(b) b from t1 group by grouping sets(a, b))) when matched then update set A.a = B.a, A.b = B.b;
rollback;

explain merge into t3 A using t2 B on (exists (select max(b) b from t1 group by grouping sets(a, b))) when matched then update set A.a = B.a, A.b = (select max(b) from (select min(b) b from t1 group by grouping sets(a, b)));
merge into t3 A using t2 B on (exists (select max(b) b from t1 group by grouping sets(a, b))) when matched then update set A.a = B.a, A.b = (select max(b) from (select min(b) b from t1 group by grouping sets(a, b)));
rollback;

explain merge into t4 A using t2 B on (exists (select max(b) b from t1 group by grouping sets(a, b))) when matched then update set A.a = B.a, A.b = (select max(b) from (select min(b) b from t1 group by grouping sets(a, b)));
merge into t4 A using t2 B on (exists (select max(b) b from t1 group by grouping sets(a, b))) when matched then update set A.a = B.a, A.b = (select max(b) from (select min(b) b from t1 group by grouping sets(a, b)));
rollback;

set autocommit = 1;

## test partition table return into, bug to fix for slave mode
select a return into @var from t1 group by grouping sets(a, b, c);
ERROR 42000: exact fetch returns more than requested number of rows
select /*+use_px parallel(2)*/a return into @var from t1 group by grouping sets(a, b, c);
ERROR 42000: exact fetch returns more than requested number of rows
select a return into @var from t1 group by grouping sets(t1.a, t1.b, t1.c) order by a;
ERROR 42000: exact fetch returns more than requested number of rows
select /*+use_px parallel(2)*/a return into @var from t1 group by grouping sets(t1.a, t1.b, t1.c) order by a;
ERROR 42000: exact fetch returns more than requested number of rows

drop table t1;
drop table t2;
drop table t3;
drop table t4;
create table t1(a int, b int, c int, d int, e int, primary key(a, b, c, d)) partition by hash(a,b) partitions 2;
create table t2(a int, b int, c int, d int, primary key(a,b)) partition by hash(a,b) partitions 2;

