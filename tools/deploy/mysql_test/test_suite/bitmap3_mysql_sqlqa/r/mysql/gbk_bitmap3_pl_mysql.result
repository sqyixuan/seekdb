purge recyclebin;
set names gbk;
drop database IF EXISTS oblrp;
create database oblrp character set gbk;
use oblrp;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
SET SESSION group_concat_max_len = 100000000;
set ob_default_lob_inrow_threshold = 0;
result_format: 4
drop table tt2;
drop view vtt2;
drop PROCEDURE p_test01;
CREATE  PROCEDURE p_test01()
begin
create table tt2(id int,a longtext,b longblob,r roaringbitmap) character set gbk;
create view vtt2 as select * from tt2;
end;
//
call p_test01();
drop PROCEDURE p_test01;
CREATE  PROCEDURE p_test01(a varbinary(1000))
begin
select rb_iterate(a);
end;
//
call p_test01(rb_from_string('1'));
