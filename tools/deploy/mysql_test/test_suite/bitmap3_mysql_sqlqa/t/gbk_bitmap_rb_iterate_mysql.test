#函数嵌套
select sum(rb_iterate) from rb_iterate(rb_from_string('1,2,3,45,58067,5656'));
select count(rb_iterate) from rb_iterate(rb_from_string('1,2,3,45,58067,5656'));
select avg(rb_iterate) from rb_iterate(rb_from_string('1,2,3,45,58067,5656'));
select min(rb_iterate) from rb_iterate(rb_from_string('1,2,3,45,58067,5656'));
select max(rb_iterate) from rb_iterate(rb_from_string('1,2,3,45,58067,5656'));

select sum(rb_iterate) from tt1,rb_iterate(r);
select count(rb_iterate) from tt1,rb_iterate(r);
select avg(rb_iterate) from tt1,rb_iterate(r);
select min(rb_iterate) from tt1,rb_iterate(r);
select max(rb_iterate) from tt1,rb_iterate(r);
select CONCAT(rb_iterate||rb_iterate) from tt1,rb_iterate(r);

select ABS(rb_iterate) from rb_iterate(rb_from_string('1,2,3,45,58067,5656'));
select GREATEST(rb_iterate,1) from rb_iterate(rb_from_string('1,2,3,45,58067,5656'));
select ISNULL(rb_iterate) from rb_iterate(rb_from_string('1,2,3,45,58067,5656'));
select IF(rb_iterate,rb_iterate,2) from rb_iterate(rb_from_string('1,2,3,45,58067,5656'));

