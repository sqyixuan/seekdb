drop table tt2;
create table tt2(id int , a varchar(50),r roaringbitmap,r1 roaringbitmap) partition by list columns (id)(
  PARTITION p0 VALUES in(10,1,2,3),
  PARTITION p1 VALUES in(50,25,12,20)
);
--error 0,1051
drop view vtt2;
create view vtt2 as select * from tt2;
