insert into tt2 values(50,'test',rb_from_string('60,70,80,90'),rb_from_string('100,110,120,130,140'));
select distinct id,rb_iterate(r) from tt2;
select  sum(id),rb_iterate(r) from tt2;

select  *,rb_iterate(r) from tt2;
select  *,rb_iterate(r) from vtt2;

