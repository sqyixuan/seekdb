--error 0,1305
drop PROCEDURE p_test01;
delimiter //;
CREATE  PROCEDURE p_test01()
begin
create table tt2(id int,a longtext,b longblob,r roaringbitmap);
create view vtt2 as select * from tt2;
end;
//
delimiter ;//
call p_test01();

