--error 0,1305
drop PROCEDURE p_test01;
delimiter //;
CREATE  PROCEDURE p_test01()
begin
declare b varbinary(100);
set b=rb_select(rb_build_varbinary(0x010303040000000600000007000000),10,0,true);
select b;
select rb_select(rb_build_varbinary(0x010303040000000600000007000000),10) into b;
select b;
select rb_select(rb_build_varbinary(0x010303040000000600000007000000),10);
select 1;
delete from tt2;
insert into tt2 values(1,'test','test',rb_select(rb_from_string('12,3,4,5,6,7,8,9'),20));
replace into tt2 values(2,'test','test', rb_select(rb_build_varbinary(x'01020000000001000000'),3));
insert into vtt2 values(1,'test','test', rb_select(rb_build_varbinary(x'01020000000001000000'),3));
replace into vtt2 values(2,'test','test', rb_select(rb_build_varbinary(x'01020000000001000000'),3));
select * from tt2;
update tt2 set r=rb_select(rb_build_varbinary(0x010303040000000600000007000000),10);
update vtt2 set r=rb_select(rb_build_varbinary(x'01060200000000000000000000003A3000000100000000001F00100000000100020003000400050006000700080009000A000B000C000D000E000F0010001100120013001400150016001700180019001A001B001C001D001E001F002000FFFFFFFF3A30000001000000FFFF000010000000FFFF'),12);
select * from vtt2;
end;
//
delimiter ;//
call p_test01();


