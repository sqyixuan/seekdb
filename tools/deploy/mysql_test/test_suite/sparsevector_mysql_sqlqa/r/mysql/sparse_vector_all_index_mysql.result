purge recyclebin;
drop database IF EXISTS obljh;
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
alter system set ob_vector_memory_limit_percentage =44;
drop table if exists t1;
create table t1 (c1 int primary key, c2 sparsevector,c3 sparsevector, index idx1((inner_product(c2,c3))), VECTOR INDEX idx2(c3) WITH (distance=inner_product));
