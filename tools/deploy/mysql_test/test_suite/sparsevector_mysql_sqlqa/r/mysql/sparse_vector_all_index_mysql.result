select /*+ ENABLE_PARALLEL_DML parallel(256) */t1.c1, ST_AsText(tt1.g) from t1 ,tt1 where t1.g=tt1.g order by negative_inner_product(tt1.v, '{1:2}') approx limit 1;
c1	ST_AsText(tt1.g)
7	POINT(3 3)
select /*+ opt_param('rowsets_enabled', 'false') */t1.c1, ST_AsText(tt1.g) from t1 ,tt1 where t1.g=tt1.g order by negative_inner_product(tt1.v, '{1:2}') approx limit 1;
c1	ST_AsText(tt1.g)
