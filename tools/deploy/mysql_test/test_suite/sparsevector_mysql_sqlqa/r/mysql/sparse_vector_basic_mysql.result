drop table if exists  t1;
create table t1 (c1 int primary key, c2 sparsevector,c3 varchar(30),c4 sparsevector,VECTOR INDEX vector_idx(c2) WITH (distance=inner_product));
insert into t1(c1,c2,c3,c4) values(1,'{1:1.3,1:2.6}','{1:1.3,1:2.6}','{1:1.3,1:2.6}');
insert into t1(c1,c2,c3,c4) values(2,'{1:1.3,1:2.6}','{1:1.3,1:2.6}',map('100',1));
