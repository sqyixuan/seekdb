drop table if exists  t1;
create table t1 (c1 int primary key, c2 sparsevector,c3 sparsevector, VECTOR INDEX vector_idx(c3) WITH (distance=inner_product));
insert into t1(c1,c2,c3) values(1,'{1:1.3,1:2.6}','{1:1.3,1:2.6}');
select * from t1 order by negative_inner_product(c3, null) approx limit 2;
ERROR 42000: Null value
select * from t1 order by negative_inner_product(c3, '{0:0}') approx limit 2;
c1	c2	c3
drop table if exists  t1;
create table t1 (c1 int primary key, c2 sparsevector,c3 sparsevector, VECTOR INDEX vector_idx(c3) WITH (distance=inner_product));
insert into t1(c1,c2,c3) values(1,null,null);
select * from t1 a,t1 b where a.c3=b.c3;
c1	c2	c3	c1	c2	c3
select * from t1 order by negative_inner_product(c3, '{1:2}') approx limit 2;
c1	c2	c3
drop table if exists  t1;
create table t1 (c1 int primary key, c2 vector(3),vector index idx1(c2) with (distance=l2, type=hnsw));
insert into t1(c1,c2) values(1,[1,2,3]);
select * from t1 order by l2_distance(c2, null) approx limit 2;
ERROR HY000: Invalid argument
select * from t1 order by l2_distance(c2, [0,0,0]) approx limit 2;
c1	c2
1	[1,2,3]
