purge recyclebin;
drop database IF EXISTS obljh;
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
alter system set ob_vector_memory_limit_percentage =44;
##字符集测试
##设置binary
drop table if exists  t1;
create table t1 (c1 int primary key,c2 sparsevector,c3 sparsevector,c4 varchar(20), vector index idx1(c2) with (distance=inner_product))default character set binary;
insert into t1(c1,c2,c3,c4) values(1,'{1:1.3,1:2.6}','{1:1.3,1:2.6}','{1:1.3,1:2.6}');
insert into t1(c1,c2,c3,c4) values(2,'{}','{1:false}','{1:1.3,1:2.6}');
insert into t1(c1,c2,c3,c4) values(3,'{2:3,1:2}','{}','{1:1.3,1:2.6}');
insert into t1(c1,c2,c3,c4) values(4,null,null,null);
update /*+ ENABLE_PARALLEL_DML parallel(256) */t1 set c2='{2:3}' where c1=1;
delete from t1 where c2='{}' ;
select c1,c2,c3,c4 from t1 order by c1;
c1	c2	c3	c4
1	{2:3}	{1:2.6}	{1:1.3,1:2.6}
3	{1:2,2:3}	{}	{1:1.3,1:2.6}
4	NULL	NULL	NULL
desc t1 ;
Field	Type	Null	Key	Default	Extra
c1	int(11)	NO	PRI	NULL	
c2	SPARSEVECTOR	YES		NULL	
c3	SPARSEVECTOR	YES		NULL	
c4	varbinary(20)	YES		NULL	
##设置utf8mb4
drop table if exists  t1;
create table t1 (c1 int primary key,c2 sparsevector,c3 sparsevector,c4 varchar(20), vector index idx1(c2) with (distance=inner_product))default character set utf8mb4;
insert into t1(c1,c2,c3,c4) values(1,'{1:1.3,1:2.6}','{1:1.3,1:2.6}','{1:1.3,1:2.6}');
insert into t1(c1,c2,c3,c4) values(2,'{}','{1:false}','{1:1.3,1:2.6}');
insert into t1(c1,c2,c3,c4) values(3,'{2:3,1:2}','{}','{1:1.3,1:2.6}');
insert into t1(c1,c2,c3,c4) values(4,null,null,null);
update /*+ ENABLE_PARALLEL_DML parallel(256) */t1 set c2=map(1,2,3,4,4,6) where c1=1;
delete from t1 where c2='{}' ;
select c1,c2,c3,c4 from t1 order by c1;
c1	c2	c3	c4
1	{1:2,3:4,4:6}	{1:2.6}	{1:1.3,1:2.6}
3	{1:2,2:3}	{}	{1:1.3,1:2.6}
4	NULL	NULL	NULL
desc t1 ;
Field	Type	Null	Key	Default	Extra
c1	int(11)	NO	PRI	NULL	
c2	SPARSEVECTOR	YES		NULL	
c3	SPARSEVECTOR	YES		NULL	
c4	varchar(20)	YES		NULL	
##设置gbk
drop table if exists  t1;
create table t1 (c1 int primary key,c2 sparsevector comment '注释c2',c3 sparsevector comment '注释c3',c4 varchar(20) comment '注释c4', vector index idx1(c2) with (distance=inner_product))default character set gbk;
insert into t1(c1,c2,c3,c4) values(1,'{1:1.3,1:2.6}','{1:1.3,1:2.6}','{1:1.3,1:2.6}');
insert into t1(c1,c2,c3,c4) values(2,'{}','{1:false}','{1:1.3,1:2.6}');
insert into t1(c1,c2,c3,c4) values(3,'{2:3,1:2}','{}','{1:1.3,1:2.6}');
insert into t1(c1,c2,c3,c4) values(4,null,null,null);
update /*+ ENABLE_PARALLEL_DML parallel(256) */t1 set c2=map(1,2,3,4,4,6) where c1=1;
delete from t1 where c2='{}' ;
select c1,c2,c3,c4 from t1 order by c1;
c1	c2	c3	c4
1	{1:2,3:4,4:6}	{1:2.6}	{1:1.3,1:2.6}
3	{1:2,2:3}	{}	{1:1.3,1:2.6}
4	NULL	NULL	NULL
desc t1 ;
Field	Type	Null	Key	Default	Extra
c1	int(11)	NO	PRI	NULL	
c2	SPARSEVECTOR	YES		NULL	
c3	SPARSEVECTOR	YES		NULL	
c4	varchar(20)	YES		NULL	
##设置gb18030
drop table if exists  t1;
create table t1 (c1 int primary key,c2 sparsevector,c3 sparsevector,c4 varchar(20), vector index idx1(c2) with (distance=inner_product))default character set gb18030;
insert into t1(c1,c2,c3,c4) values(1,'{1:1.3,1:2.6}','{1:1.3,1:2.6}','{1:1.3,1:2.6}');
insert into t1(c1,c2,c3,c4) values(2,'{}','{1:false}','{1:1.3,1:2.6}');
insert into t1(c1,c2,c3,c4) values(3,'{2:3,1:2}','{}','{1:1.3,1:2.6}');
insert into t1(c1,c2,c3,c4) values(4,null,null,null);
update /*+ ENABLE_PARALLEL_DML parallel(256) */t1 set c2=map(1,2,3,4,4,6) where c1=1;
delete from t1 where c2='{}' ;
select c1,c2,c3,c4 from t1 order by c1;
c1	c2	c3	c4
1	{1:2,3:4,4:6}	{1:2.6}	{1:1.3,1:2.6}
3	{1:2,2:3}	{}	{1:1.3,1:2.6}
4	NULL	NULL	NULL
desc t1 ;
Field	Type	Null	Key	Default	Extra
c1	int(11)	NO	PRI	NULL	
c2	SPARSEVECTOR	YES		NULL	
c3	SPARSEVECTOR	YES		NULL	
c4	varchar(20)	YES		NULL	
