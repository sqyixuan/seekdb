purge recyclebin;
drop database IF EXISTS obljh;
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
alter system set ob_vector_memory_limit_percentage =44;
drop table if exists  t1;
create table t1(c1 int primary key,c2 sparsevector,c3 vector(3),c4 varchar(200), vector index idx1(c2) with (distance=inner_product),vector index idx2(c3) with (distance=l2, type=hnsw));
