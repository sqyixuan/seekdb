insert into t1(c1,c2,c3,c4) values(1,'{1:1.3,1:2.6}','{1:1.3,1:2.6}',map(1,2,3,4,5,7000000));
insert into t1(c1,c2,c3,c4) values(2,'{1:1.3,1:2.6}','{1:1.3,1:2.6}',null);
select * from t1 where  c4 is null  order by negative_inner_product(c2, '{0:1.3,1:2.6}') approximate  limit 1;
c1	c2	c3	c4	c5
2	{1:2.6}	{1:2.6}	NULL	NULL
select /*+ index(t1 idx2)*/* from t1 where  c4 is null or  c5 is null order by negative_inner_product(c2, '{0:1.3,1:2.6}') approximate  limit 1;
c1	c2	c3	c4	c5
2	{1:2.6}	{1:2.6}	NULL	NULL
drop table if exists t1;
create table t1 (c1 int primary key, c2 sparsevector,c3 sparsevector,c4 vector(3),c5 sparsevector as (c4), VECTOR INDEX vector_idx(c2) WITH (distance=inner_product));
insert into t1(c1,c2,c3,c4) values(1,'{1:1.3,1:2.6}','{1:1.3,1:2.6}','[1,2,5]');
ERROR HY000: Invalid argument
insert into t1(c1,c2,c3,c4) values(2,'{1:1.3,1:2.6}','{1:1.3,1:2.6}',null);
ALTER TABLE t1 DROP COLUMN c5;
select * from t1 where  c4 is null  order by negative_inner_product(c2, '{0:1.3,1:2.6}') approximate  limit 1;
c1	c2	c3	c4
2	{1:2.6}	{1:2.6}	NULL
drop table if exists t1;
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(20),c3 sparsevector as (c2));
insert into t1(c1,c2) values(1,'{1:1.3,1:2.6}');
ALTER TABLE t1 DROP COLUMN c3;
drop table if exists t1;
create table t1 (c1 int primary key, c2 sparsevector,c3 sparsevector,c4 date,c5 sparsevector as (c4));
ALTER TABLE t1 DROP COLUMN c3;
ALTER TABLE t1 DROP COLUMN c4;
ERROR HY000: Column 'c4' has a generated column dependency
ALTER TABLE t1 DROP COLUMN c5;
desc t1;
Field	Type	Null	Key	Default	Extra
c1	int(11)	NO	PRI	NULL	
c2	SPARSEVECTOR	YES		NULL	
