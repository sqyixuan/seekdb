##日期和时间类型  重点测试--增加dml操作
##date
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int auto_increment, c2 sparsevector not null,primary key(c1));
insert into t1(c2) values('{1:2,1.4:2.1,3:10000}');
replace into t1(c2) values('{1:2,1.4:2.1,3:10000}');
--error 5083
alter table t1 modify c2 DATE not null;


--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2(c1 json, c2 date not null);
insert into t2 values('20241130', '20241130');
--error 5083
insert t2(c2) select c2 from t1;
--error 1235
insert t1(c2) select c2 from t2;
select * from t1 order by c1,c2;



