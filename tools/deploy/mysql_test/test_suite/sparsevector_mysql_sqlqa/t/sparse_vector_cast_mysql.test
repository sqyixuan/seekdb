purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set sql_mode = '';

##测试主要场景以下几种
##数值类型
##日期和时间类型
##字符串类型
##json互相转换
##cast转换

##数值类型转换
##int
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 json, c2 sparsevector not null);
insert into t1 values('12121212.1212121212', '{1:2,1.4:2.1,3:10000}');
--error 5083
alter table t1 modify c2 INT  not null;


--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2(c1 json, c2 sparsevector not null);
insert into t2 values('12121212.1212121212', '{1:2,1.4:2.1,3:10000}');
insert t2(c2) select c2 from t1;
insert t1(c2) select c2 from t2;
select * from t1 order by c1;

