##多模类型间互转
##GIS
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 json, c2 sparsevector not null);
insert into t1 values('12121212.1212121212', '{1:2,1.4:2.1,3:10000}');
--error 1138
alter table t1 modify c2 GEOMETRY   not null;

--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2(c1 json, c2 GEOMETRY  not null);
insert into t2 values('11111111.11111111', ST_GeomFromText('POLYGON((7 1,6 2,6 3,10 3,10 1,7 1))'));
--error 5083
insert t2(c2) select c2 from t1;
--error 5083
insert t1(c2) select c2 from t2;
--error 5083
select * from t1 order by c1,c2;
##select * from t2 order by c1,c2;

##JSON
