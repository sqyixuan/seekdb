##cast
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 json, c2 sparsevector not null);
insert into t1 values('12121212.1212121212', '{1:2,1.4:2.1,3:10000}');
insert into t1 values('12121212.1212121212', '{1:2,1.4:2.1,3:10000}');
--error 5083
select cast(c2 as BINARY(10)) from t1;
--error 5083
select cast(c2 as CHAR(10)) from t1;
--error 5083
select cast(c2 as DATE) from t1;
--error 5083
select cast(c2 as TIME) from t1;
--error 5083
select cast(c2 as DECIMAL(10,2)) from t1;
--error 5083
select cast(c2 as SIGNED ) from t1;
--error 5083
select cast(c2 as UNSIGNED ) from t1;



