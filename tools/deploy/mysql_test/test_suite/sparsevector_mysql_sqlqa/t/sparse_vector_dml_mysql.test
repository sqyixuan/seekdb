drop table if exists  t1;
--enable_warnings
create table t1(c1 int primary key,c2 sparsevector,c3 vector(3),c4 varchar(200), vector index idx1(c2) with (distance=inner_product),vector index idx2(c3) with (distance=l2, type=hnsw));
insert into t1(c1,c2,c3,c4) values(1,'{0:1.3,1:2.6}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(2,'{}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(3,'{1.123:2.123,3.123:4.123,10:2}',[1,2,4],'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(4,'{1:2}',[1,2,4],'{1.123:-1}');
