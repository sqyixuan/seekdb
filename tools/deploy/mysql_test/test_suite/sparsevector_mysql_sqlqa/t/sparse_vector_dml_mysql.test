select /*+index(t1 idx1) */c1,c2,c4,negative_inner_product(c2, c4) from t1 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;

select /*+index(t1 idx1) */c1,c2,c4,negative_inner_product(c2, c4) from t1 where c2 is null and c1 =3 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select /*+index(t1 idx1) */c1,c2,c4,negative_inner_product(c2, c4) from t1 where c2 is not null and c1 =3 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select /*+index(t1 idx1) */c1,c2,c4,negative_inner_product(c2, c4) from t1 where c2 is not null and c1 is true order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
