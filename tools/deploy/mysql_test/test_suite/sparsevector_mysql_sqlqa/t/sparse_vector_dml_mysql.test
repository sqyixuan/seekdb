insert into t1(c1,c2,c3,c4) values(1,'{0:1.3,1:2.6}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(2,'{}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(3,'{1.123:2.123,3.123:4.123,10:2}',[1,2,4],'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(4,'{1:2}',[1,2,4],'{1.123:-1}');
insert into t1(c1,c2,c3,c4) values(5,null,null,null);

select *,(select /*+index(t1 idx1) */negative_inner_product(c4, c2) from t1 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 1 ) from t1 order by c1;
select /*+index(t1 idx1) */a.c1,a.c2,b.c4,negative_inner_product(a.c2, b.c4) from t1 a,(select /*+index(t1 idx2) */* from t1  order by l2_distance(c3, '[1,2,3]') APPROXIMATE limit 1) b order by b.c1;
select /*+index(t1 idx1) */a.c1,a.c2,b.c4,negative_inner_product(a.c2, b.c4) from t1 a,(select /*+index(t1 idx2) */* from t1  order by l2_distance(c3, '[1,2,3]') APPROXIMATE limit 1) b order by negative_inner_product(a.c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 1;


##join
--disable_warnings
drop table if exists  t1;
--enable_warnings
create table t1(c1 int primary key,c2 sparsevector,c3 vector(3),c4 varchar(200), vector index idx1(c2) with (distance=inner_product),vector index idx2(c3) with (distance=l2, type=hnsw));
insert into t1(c1,c2,c3,c4) values(1,'{0:1.3,1:2.6}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(2,'{}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(3,'{1.123:2.123,3.123:4.123,10:2}',[1,2,4],'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(4,'{1:2}',[1,2,4],'{1.123:-1}');
insert into t1(c1,c2,c3,c4) values(5,null,null,null);
--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select /*+ ENABLE_PARALLEL_DML parallel(256) */c1,c2,c4,negative_inner_product(c2, c4) from t1  where c2= '{1:2}' and c3 is not null and c4 ='{1.123:-1}' order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 1 ;

--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select /*+ ENABLE_PARALLEL_DML parallel(256) */* from t1   order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;


select * from t1,mv1 where t1.c2=mv1.c2  order by negative_inner_product(t1.c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 2 ;
select * from t1,mv1 where t1.c2<>mv1.c2  order by negative_inner_product(t1.c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 2 ;
select * from t1 a,t1 b where a.c2<>b.c2  order by negative_inner_product(a.c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 2 ;
select * from t1 left join mv1 on t1.c2=mv1.c2 order by negative_inner_product(t1.c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 2 ;
select * from t1 right join mv1 on t1.c2=mv1.c2 order by negative_inner_product(t1.c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 2 ;
select * from t1 full join mv1 on t1.c2=mv1.c2 order by negative_inner_product(t1.c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 2 ;
select * from t1 inner join mv1 on t1.c2=mv1.c2 order by negative_inner_product(t1.c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 2 ;

select * from t1 a,t1 b where a.c2=b.c2  order by negative_inner_product(a.c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 2 ;
select * from t1 a left join t1 b on a.c2=b.c2 order by negative_inner_product(a.c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 2 ;
select * from t1 a right join t1 b on a.c2=b.c2 order by negative_inner_product(a.c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 2 ;
select * from t1 a full join t1 b on a.c2=b.c2 order by negative_inner_product(a.c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 2 ;
select * from t1 a inner join t1 b on a.c2=b.c2 order by negative_inner_product(a.c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 2 ;
select * from t1,mv1 where t1.c2<>mv1.c2  order by negative_inner_product(t1.c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 2 ;

