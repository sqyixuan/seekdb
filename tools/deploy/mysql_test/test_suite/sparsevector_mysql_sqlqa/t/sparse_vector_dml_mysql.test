purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
alter system set ob_vector_memory_limit_percentage =44;
sleep 5;


##重建向量索引后dml
--disable_warnings
--disable_warnings
drop table if exists  t1;
--enable_warnings
--enable_warnings
create table t1(c1 int primary key,c2 sparsevector,c3 vector(3),c4 varchar(200), vector index idx1(c2) with (distance=inner_product),vector index idx2(c3) with (distance=l2, type=hnsw));
insert into t1(c1,c2,c3,c4) values(1,'{0:1.3,1:2.6}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(2,'{2:2}',[2,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(3,'{1.123:2.123,3.123:4.123,10:2}',[3,2,4],'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(4,'{1:-2}',[4,2,4],'{1.123:-1}');
insert into t1(c1,c2,c3,c4) values(5,null,null,null);
select /*+index(t1 idx2) */* from t1 a,(select * from t1   order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,3:false}') APPROXIMATE limit 100 ) b where a.c1=b.c1   order by l2_distance(b.c3, '[1,2,3]') APPROXIMATE limit 1 ;

select /*+index(t1 idx1) */* from t1  order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,3:false}') APPROXIMATE limit 1 ;
##explain select /*+index(t1 idx1) */* from t1  order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,3:false}') APPROXIMATE limit 1 ;
select /*+index(t1 idx2) */* from t1  order by l2_distance(c3, '[1,2,3]') APPROXIMATE limit 1 ;
##explain select /*+index(t1 idx2) */* from t1  order by l2_distance(c3, '[1,2,3]') APPROXIMATE limit 1 ;
--disable_warnings
drop table if exists  tt1;
--enable_warnings
create table tt1 like t1;
select /*+index(t1 idx2) */* from t1  order by l2_distance(c3, '[1,2,3]') APPROXIMATE limit 1 ;
##explain select /*+index(t1 idx2) */* from t1  order by l2_distance(c3, '[1,2,3]') APPROXIMATE limit 1 ;


##call dbms_vector.rebuild_index('idx2','t1','c3');
replace into t1(c1,c2,c3,c4) values(1,'{0:1.3,1:2.6}',[1,2,4],'{}');
replace into t1(c1,c2,c3,c4) values(2,'{}',[1,2,4],'{}');
replace into t1(c1,c2,c3,c4) values(3,'{1.123:2.123,3.123:4.123,10:2}',[1,2,4],'{1.123:2.123,3.123:4.123,10:3}');
replace into t1(c1,c2,c3,c4) values(4,'{1:-2}',[1,2,4],'{1.123:-1}');
replace into t1(c1,c2,c3,c4) values(5,null,null,null);
update /*+ ENABLE_PARALLEL_DML parallel(256) */t1 set c2 = map(1,20000000,30000000,4,5,6,7,10000) where c3 is null;
select /*+index(t1 idx1) */* from t1   order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,3:false}') APPROXIMATE limit 100 ;
select /*+index(t1 idx2) */* from t1   order by l2_distance(c3, '[1,2,3]') APPROXIMATE limit 100 ;

select /*+index(t1 idx2) */* from t1 a,(select /*+index(t1 idx1) */* from t1   order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,3:false}') APPROXIMATE limit 100 ) b where a.c1=b.c1   order by l2_distance(b.c3, '[1,2,3]') APPROXIMATE limit 100 ;

select /*+index(t1 idx2) */* from t1   order by l2_distance(c3, '[1,2,3]') APPROXIMATE limit 100 ;

##虚拟列过滤报错4016
--disable_warnings
--disable_warnings
drop table if exists  t1;
--enable_warnings
--enable_warnings
create table t1(c1 int, c2 int, c3 BOOL , c4 sparsevector, c5 int as (inner_product(c4,'{1:2}')),primary key(c1), vector index idx1(c4) with (distance=inner_product));
insert into t1(c1,c2,c3,c4) values(1,1,1,'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(2,2,2,'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(3,3,3,'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(4,4,4,'{1.123:-1}');
insert into t1(c1,c2,c3,c4) values(5,null,null,null);
SELECT * FROM t1 where c5 =0  order by negative_inner_product(c4, '{1:10000000000000,2:1000000000000,3:false}') APPROXIMATE limit 1 ;
SELECT * FROM t1 where c4 ='{1.123:-1}'  order by negative_inner_product(c4, '{1:10000000000000,2:1000000000000,3:false}') APPROXIMATE limit 1 ;


##标量过滤查询无数据
--disable_warnings
--disable_warnings
drop table if exists  t1;
--enable_warnings
--enable_warnings
create table t1(c1 int primary key, c2 varchar(30),c3 sparsevector ,c4 sparsevector,c5  sparsevector,c6 sparsevector as (c2) , vector index idx1(c3) with (distance=inner_product), vector index idx2(c4) with (distance=inner_product), vector index idx3(c5) with (distance=inner_product))PARTITION BY KEY(c1) PARTITIONS 4;
insert into t1(c1,c2,c3,c4,c5) values(1,'{1.123:2.123,3.123:4.123,10:3}','{1.123:2.123,3.123:4.123,10:3}','{1.123:2.123,3.123:4.123,10:3}','{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4,c5) values(2,'{1.123:2.123,3.123:4.123,10:3}','{1.123:2.123,3.123:4.123,10:3}','{1.123:2.123,3.123:4.123,10:3}','{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4,c5) values(3,'{1.123:2.123,3.123:4.123,10:3}','{1.123:2.123,3.123:4.123,10:3}','{1.123:2.123,3.123:4.123,10:3}','{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4,c5) values(4,'{1.123:2.123,3.123:4.123,10:3}','{1.123:2.123,3.123:4.123,10:3}','{1.123:-1}','{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4,c5) values(5,null,null,null,null);
alter system major freeze;
select * from t1 where  c1<5  order by negative_inner_product(c4, '{1:10000000000000,2:1000000000000,10:10}') APPROXIMATE limit 10 ;
select * from t1 where  c1<5  order by negative_inner_product(c4, '{1:10000000000000,2:1000000000000,10:10}')  limit 10 ;
select * from t1 where  c5=c4  order by negative_inner_product(c4, '{1:10000000000000,2:1000000000000,10:10}') APPROXIMATE limit 10 ;
select * from t1 where  c5=c4  order by negative_inner_product(c4, '{1:10000000000000,2:1000000000000,10:10}')  limit 10 ;

select * from t1  order by negative_inner_product(c4, '{1:10000000000000,2:1000000000000,10:10}') APPROXIMATE limit 10 ;
select * from t1 where  c6=c2  order by negative_inner_product(c4, '{1:10000000000000,2:1000000000000,10:10}') APPROXIMATE limit 1 ;


##truncate表
--disable_warnings
--disable_warnings
drop table if exists  t1;
--enable_warnings
--enable_warnings
create table t1(c1 int, c2 sparsevector, primary key(c1), vector index idx1(c2) with (distance=inner_product)) partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p3 values less than (100000),partition p4 values less than (1000000));
insert into t1(c1,c2) values(1,'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2) values(2,'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2) values(999999,'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2) values(999,'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2) values(5,null);
select negative_inner_product(c2,c2) from t1;
select inner_product(c2,c2) from t1;

select * from t1 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,10:10}') APPROXIMATE  limit 10;

##查询无数据
select * from t1 partition(p1) where c1<1000 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select * from t1 partition(p1) where c1<1000 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}')  limit 10 ;
delete from t1 partition(p1) order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}')  limit 1 ;
update t1 partition(p0) set c2='{1:2,3:2}' where c1<3 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}')  limit 10 ;
select * from t1 partition(p0) where c1<1000 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select * from t1 partition(p0) where c1<1000 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}')  limit 10 ;
drop index idx1 on t1;
truncate t1;


