##表达式过滤
--disable_warnings
drop table if exists  t1;
--enable_warnings
create table t1(c1 int primary key,c2 sparsevector,c3 vector(3),c4 varchar(200), vector index idx1(c2) with (distance=inner_product),vector index idx2(c3) with (distance=l2, type=hnsw));
insert into t1(c1,c2,c3,c4) values(1,'{0:1.3,1:2.6}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(2,'{}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(3,'{1.123:2.123,3.123:4.123,10:2}',[1,2,4],'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(4,'{1:2}',[1,2,4],'{1.123:-1}');
insert into t1(c1,c2,c3,c4) values(5,null,null,null);

select /*+index(t1 idx1) */c1,c2,c4,negative_inner_product(c2, c4) from t1 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select /*+index(t1 idx1) */c1,c2,c4,negative_inner_product(c2, c4) from t1 where c4='{1.123:-1}' order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select /*+index(t1 idx1) */c1,c2,c4,negative_inner_product(c2, c4) from t1 where c4>'{1.123:-1}' order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;

select /*+index(t1 idx1) */c1,c2,c4,LENGTH(c4) from t1 where LENGTH(c4) =10  or LENGTH(c4)= 7 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select /*+index(t1 idx1) */c1,c2,c4,CONCAT(c4,c4) from t1 where CONCAT(c4,c4)='{1.123:2.123,3.123:4.123,10:3}{1.123:2.123,3.123:4.123,10:3}' or c4 is not null order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select /*+index(t1 idx1) */c1,c2,c4,upper(c4) from t1 where upper(c4)='{1.123:2.123,3.123:4.123,10:3}' or c4 is not null order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select /*+index(t1 idx1) */c1,c2,c4,lower(c4) from t1 where lower(c4)='{1.123:2.123,3.123:4.123,10:3}' or c4 is not null order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select /*+index(t1 idx1) */c1,c2,c4,TO_BASE64(c4) from t1 where TO_BASE64(c4)='ezEuMTIzOjIuMTIzLDMuMTIzOjQuMTIzLDEwOjN9' or c4 is not null order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;

select /*+index(t1 idx1) */c1,c2,c4,LENGTH(c4) from t1 where LENGTH(c4) =10  and LENGTH(c4)= 7 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select /*+index(t1 idx1) */c1,c2,c4,CONCAT(c4,c4) from t1 where CONCAT(c4,c4)='{1.123:2.123,3.123:4.123,10:3}{1.123:2.123,3.123:4.123,10:3}' and c4 is not null order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select /*+index(t1 idx1) */c1,c2,c4,upper(c4) from t1 where upper(c4)='{1.123:2.123,3.123:4.123,10:3}' and c4 is not null order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select /*+index(t1 idx1) */c1,c2,c4,lower(c4) from t1 where lower(c4)='{1.123:2.123,3.123:4.123,10:3}' and c4 is not null order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select /*+index(t1 idx1) */c1,c2,c4,TO_BASE64(c4) from t1 where TO_BASE64(c4)='ezEuMTIzOjIuMTIzLDMuMTIzOjQuMTIzLDEwOjN9' and c4 is not null order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;


select /*+index(t1 idx1) */c1,c2,c4,LENGTH(c4) from t1 where abs(-4) = c1  order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select /*+index(t1 idx1) */c1,c2,c4,LENGTH(c4) from t1 where SQRT(c1) <> l2_distance(c3, [1,2,3])  order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;

--disable_warnings
drop table if exists  t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 DATE,c3 TIME,c4 DATETIME(6),c5 TIMESTAMP,c6 YEAR,c7 sparsevector, vector index idx1(c7) with (distance=inner_product));
INSERT INTO t1 (c1, c2, c3, c4, c5, c6,c7) VALUES (1, '2023-04-01', '12:34:56', '2023-04-01 12:34:56', '2023-04-01 12:34:56', 2023,null);
INSERT INTO t1 (c1, c2, c3, c4, c5, c6,c7) VALUES (2, '2023-04-02', '13:45:00', NULL, '2023-04-02 13:45:00', 2023,'{1.123:2.123,3.123:4.123,10:2}');
INSERT INTO t1 (c1, c2, c3, c4, c5, c6,c7) VALUES (3, NULL, NULL, '2023-04-03 01:23:45', '2023-04-03 01:23:45', 2023,null);
INSERT INTO t1 (c1, c2, c3, c4, c5, c6,c7) VALUES (4, NULL, NULL, NULL, '2023-04-04 00:00:00', NULL,'{0:1.3,1:2.6}');
INSERT INTO t1 (c1, c2, c3, c4, c5, c6,c7) VALUES (5, '2023-04-30', '02:30:00', '2023-04-05 02:30:00', '2023-04-05 02:30:00', NULL,'{}');
create index idx2 on t1(c2) global;

select a.c1,b.c2,negative_inner_product(a.c7, a.c7) from t1 a,t1 b where a.c2=b.c2  order by negative_inner_product(a.c7, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 1 ;
select a.c1,b.c2,negative_inner_product(a.c7, a.c7) from t1 a,t1 b where a.c2=b.c2  order by negative_inner_product(a.c7, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 2 ;
select a.c1,b.c2,negative_inner_product(a.c7, a.c7) from t1 a,t1 b where a.c2=b.c2  order by negative_inner_product(a.c7, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;

select /*+index(t1 idx1) */c1,c2,c4,negative_inner_product(c7, c7) from t1 where DATE(c2)='2023-04-02' or c7 ='{}' order by negative_inner_product(c7, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;
select /*+index(t1 idx1) */c1,c2,c4,abs(negative_inner_product(c7, c7)) from t1 where LAST_DAY(c2)='2023-04-03' or c7 is not null order by negative_inner_product(c7, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10 ;



