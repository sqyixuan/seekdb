select c1,c2,c3,c4 from t1 where c2 = '{}' or c3 is not null order by negative_inner_product(c2, '{1:2,3:4,5:6}') APPROXIMATE limit 100 ;
select c1,c2,c3,c4 from t1 where c2 = '{}' or c3 is not null order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100;
select c1,c2,c3,c4 from t1 where c2 = map(1,-2) order by negative_inner_product(c2, '{1:2,3:4,5:6}') APPROXIMATE limit 100 ;
select c1,c2,c3,c4 from t1 where c2 = '{}' order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100;
select c1,c2,c3,c4 from t1 where c2 <> map(1,-2) order by negative_inner_product(c2, '{1:2,3:4,5:6}') APPROXIMATE limit 100 ;
--error 1210
select c1,c2,c3,c4 from t1 order by negative_inner_product(c2, '1') APPROXIMATE limit 100 ;

SELECT CASE WHEN c2=c2   THEN 1 ELSE 2 END from t1 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 100 ;
SELECT CASE WHEN c2!=c2   THEN 1 ELSE 2 END from t1 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 100 ;

select c1,c2,c3,c4 from t1 where c2 = '{}' or c3 is not null order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROXIMATE limit 10000;
select c1,c2,c3,c4 from t1 where c2 = '{}' or c3 is not null order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 10000;
