select negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}')  from t1  order by c1 limit 1;
select negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}')  from t1  order by c1 limit 1,1;
