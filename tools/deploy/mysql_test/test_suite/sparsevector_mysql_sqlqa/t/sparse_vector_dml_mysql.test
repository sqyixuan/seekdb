##主键验证
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key,c2 sparsevector,c3 vector(3),c4 varchar(200), vector index idx1(c2) with (distance=inner_product),vector index idx2(c3) with (distance=l2, type=hnsw));
insert into t1(c1,c2,c3,c4) values(1,'{2:1.3,1:2.6}',[1,2,4],'{2:2,3:5}');
insert into t1(c1,c2,c3,c4) values(2,'{}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(3,'{1.123:2.123,3.123:4.123,10:2}',[1,2,4],'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(4,'{1:2}',[1,2,4],'{1.123:-1}');
insert into t1(c1,c2,c3,c4) values(5,null,null,null);
drop table if exists t2;
create table t2(a1 int primary key,a2 sparsevector,a3 vector(3),a4 varchar(200), vector index idx1(a2) with (distance=inner_product),vector index idx2(a3) with (distance=l2, type=hnsw));
insert into t2 select c1,c2,c3,c4 from t1 where c3 is not null and c4 is not null;

ALTER TABLE t2 ADD CONSTRAINT fk_a1 FOREIGN KEY (a1) REFERENCES t1(c1) ;
--error 1215
ALTER TABLE t2 ADD CONSTRAINT fk_a2 FOREIGN KEY (a2) REFERENCES t1(c2) ;

--error 1451
delete from t1 where c2 ='{1:2}';
--error 1451
delete from t1 where c1 =3;
insert into t1(c1,c2,c3,c4) values(6,'{1:2}',[1,2,4],'{1.123:-1}');
update t1 set c1=10 where c4 is null;

##存在外键
--disable_warnings
drop table if exists t2;
drop table if exists t1;
--enable_warnings


create table t1(c1 int primary key,c2 sparsevector,c3 vector(3),c4 varchar(200), vector index idx1(c2) with (distance=inner_product),vector index idx2(c3) with (distance=l2, type=hnsw));
insert into t1(c1,c2,c3,c4) values(1,'{2:1.3,1:2.6}',[1,2,4],'{2:2,3:5}');
insert into t1(c1,c2,c3,c4) values(2,'{}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(3,'{1.123:2.123,3.123:4.123,10:2}',[1,2,4],'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(4,'{1:2}',[1,2,4],'{1.123:-1}');
insert into t1(c1,c2,c3,c4) values(5,null,null,null);
create table t2(a1 int primary key,a2 sparsevector,a3 vector(3),a4 varchar(200), vector index idx1(a2) with (distance=inner_product),vector index idx2(a3) with (distance=l2, type=hnsw));
insert into t2 select c1,c2,c3,c4 from t1 where c3 is not null and c4 is not null;
ALTER TABLE t2 ADD CONSTRAINT fk_a1 FOREIGN KEY (a1) REFERENCES t1(c1) ON DELETE CASCADE ON UPDATE CASCADE;
delete from t1 where c2 ='{1:2}';
delete from t1 where c1 =3;
insert into t1(c1,c2,c3,c4) values(6,'{1:2}',[1,2,4],'{1.123:-1}');
update t1 set c1=10 where c4 is null;
TRUNCATE TABLE t2;
drop table if exists t2;
drop table if exists t1;

