select * from t1 join t2 on negative_inner_product(c2, c4)=negative_inner_product(c2, c4) order by c1;
select * from t1 join t2 on negative_inner_product(c2, null)=negative_inner_product(c2, null) order by c1;

##with as 
--disable_warnings
drop table if exists  t1;
--enable_warnings
create table t1(c1 int primary key,c2 sparsevector,c3 vector(3),c4 varchar(200), vector index idx1(c2) with (distance=inner_product),vector index idx2(c3) with (distance=l2, type=hnsw));
insert into t1(c1,c2,c3,c4) values(1,'{2:1.3,1:2.6}',[1,2,4],'{2:2,3:5}');
insert into t1(c1,c2,c3,c4) values(2,'{}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(3,'{1.123:2.123,3.123:4.123,10:2}',[1,2,4],'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(4,'{1:2}',[1,2,4],'{1.123:-1}');
insert into t1(c1,c2,c3,c4) values(5,null,null,null);

--disable_warnings
drop table if exists t2;
--enable_warnings

create table t2(a1 int ,a2 sparsevector,a3 vector(3),a4 varchar(200), vector index idx1(a2) with (distance=inner_product),vector index idx2(a3) with (distance=l2, type=hnsw));
insert into t2 select c1,c2,c3,c4 from t1; 
insert into t2 select c1,c2,c3,c4 from t1 where c1>1 and c2 is not null order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROX limit 10; 


with ct1 AS(
select c2 from t1 order by c1)
select c2 from t1 where c1 >2 order by c1 ;

with ct1 as(
select negative_inner_product(c2, c4) from t1 order by c1)
select negative_inner_product(c2, c4) from t1 where c3 is not null order by c1 ;

with ct1 as(
select negative_inner_product(c2, c4) from t1 order by c1)
select negative_inner_product(c2, c4) from t1 join t2 on negative_inner_product(c2, c4)=negative_inner_product(a2, a4) order by c1;

with ct1 as(
select negative_inner_product(c2, c4) from t1 order by c1)
select negative_inner_product(c2, c4) from t1 join t2 on negative_inner_product(c2, c4)=negative_inner_product(a2, a4) order by c1;

with CTE1 as(
select negative_inner_product(c2, c4) a from t1 order by c1)
,CTE2 AS (
    SELECT negative_inner_product(a2, a4) b from t2 order by a1
)
select * from CTE1,CTE2  where a =0 order by b;

##case when
--disable_warnings
drop table if exists  t1;
--enable_warnings
create table t1(c1 int primary key,c2 sparsevector,c3 vector(3),c4 varchar(200), vector index idx1(c2) with (distance=inner_product),vector index idx2(c3) with (distance=l2, type=hnsw));
insert into t1(c1,c2,c3,c4) values(1,'{2:1.3,1:2.6}',[1,2,4],'{2:2,3:5}');
insert into t1(c1,c2,c3,c4) values(2,'{}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(3,'{1.123:2.123,3.123:4.123,10:2}',[1,2,4],'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(4,'{1:2}',[1,2,4],'{1.123:-1}');
insert into t1(c1,c2,c3,c4) values(5,null,null,null);

--disable_warnings
drop table if exists t2;
--enable_warnings

create table t2(a1 int ,a2 sparsevector,a3 vector(3),a4 varchar(200), vector index idx1(a2) with (distance=inner_product),vector index idx2(a3) with (distance=l2, type=hnsw));
insert into t2 select c1,c2,c3,c4 from t1; 
insert into t2 select c1,c2,c3,c4 from t1 where c1>1 and c2 is not null order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROX limit 10; 


SELECT count(c1), CASE WHEN negative_inner_product(c2, c4) > negative_inner_product(c2, '{1:10000}') THEN 'High' ELSE 'Low' END AS A FROM T1,t2 ;
SELECT count(*) FROM t1,t2 where  negative_inner_product(t1.c2, t2.a4) < 0.5;
SELECT C1, CASE WHEN negative_inner_product(c2, c4) > 5 THEN 'High' ELSE 'Low' END AS A FROM T1,t2 ;
SELECT t1.C1, 
       CASE 
           WHEN negative_inner_product(c2, c4) > 10 THEN 'Far'
           WHEN negative_inner_product(c2, c4) BETWEEN 5 AND 10 THEN 'Medium'
           ELSE 'Close'
       END AS a,
       avg(t1.C3) OVER (PARTITION BY t1.C1) AS avg_vector
FROM T1 t1
JOIN T2 t2 ON t1.C1 = t2.A1
WHERE negative_inner_product(c2, c4) < 0.5 order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROX limit 10;


