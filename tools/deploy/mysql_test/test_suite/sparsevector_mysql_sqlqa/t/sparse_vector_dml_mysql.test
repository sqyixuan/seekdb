select c1 a,negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') a  from t1 order by c1;
select c1 a,negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') a,negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') a  from t1 order by c1;
select negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}')  a  from t1 order by c1;
select negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}')  a ,* from t1 order by c1;
select negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}')  中文 ,* from t1 order by c1;
select negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') + negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') - negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}')  中文 ,negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') + negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') - negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') 中文 from t1 order by c1;
select negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') + negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') - negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}')  a ,negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') + negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') - negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') b from t1 order by c1;


select c1 a,negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') a  from t1 where negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') is not null order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROX limit 10;


##update
--disable_warnings
drop table if exists  t1;
--enable_warnings
create table t1(c1 int primary key,c2 sparsevector,c3 vector(3),c4 varchar(200), vector index idx1(c2) with (distance=inner_product),vector index idx2(c3) with (distance=l2, type=hnsw));
insert into t1(c1,c2,c3,c4) values(1,'{2:1.3,1:2.6}',[1,2,4],'{2:2,3:5}');
insert into t1(c1,c2,c3,c4) values(2,'{}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(3,'{1.123:2.123,3.123:4.123,10:2}',[1,2,4],'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(4,'{1:2}',[1,2,4],'{1.123:-1}');
insert into t1(c1,c2,c3,c4) values(5,null,null,null);
update t1 set c1 = 10 where c1 =5;
update t1 set c2 = map(1,100,2,1) where c1 =4;
update t1 set c2 = '{2:3,100:200}' where c1 =10;
update t1 set c1 = negative_inner_product(c2, '{1:1,2:1000,2:false}') where c3 = '[1,2,4]';

select * from t1 order by c1;
show create table t1;
call dbms_vector.refresh_index('idx2','t1','c3',1,'FAST');
call dbms_vector.rebuild_index('idx2','t1');


##update join
--disable_warnings
drop table if exists  t1;
--enable_warnings
create table t1(c1 int primary key,c2 sparsevector,c3 vector(3),c4 varchar(200), vector index idx1(c2) with (distance=inner_product),vector index idx2(c3) with (distance=l2, type=hnsw));
insert into t1(c1,c2,c3,c4) values(1,'{2:1.3,1:2.6}',[1,2,4],'{2:2,3:5}');
insert into t1(c1,c2,c3,c4) values(2,'{}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(3,'{1.123:2.123,3.123:4.123,10:2}',[1,2,4],'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(4,'{1:2}',[1,2,4],'{1.123:-1}');
insert into t1(c1,c2,c3,c4) values(5,null,null,null);

--disable_warnings
drop table if exists t2;
--enable_warnings

create table t2(a1 int ,a2 sparsevector,a3 vector(3),a4 varchar(200), vector index idx1(a2) with (distance=inner_product),vector index idx2(a3) with (distance=l2, type=hnsw));
insert into t2 select c1,c2,c3,c4 from t1; 
insert into t2 select c1,c2,c3,c4 from t1 where c1>1 and c2 is not null order by negative_inner_product(c2, '{1:10000000000000,2:1000000000000,2:false}') APPROX limit 10; 
select * from t1 union  select * from t2;

select negative_inner_product(c2, '{1:1,2:1000,2:false}')  from t1 union  select negative_inner_product(a2, '{1:1,2:1000,2:false}')  from t2;

update t1 set c2 ='{}' where c1 in (select c1 from t1 inner join t2 on c2=a2);
update t1 join t2 on c2 =a2 set c2 ='{1:2,2:3}' where a3 is null;
update t1 set c1 = negative_inner_product(c2, '{1:1,2:1000,2:false}') where c1 in (select c1<2 from t1 inner join t2 on c2=a2);
update t1 join t2 on c2 =a2 set c1 = negative_inner_product(c2, '{1:1,2:1000,2:false}') where a3 is null;

