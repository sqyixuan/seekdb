create table t1(c1 int ,c2 sparsevector,c3 vector(3),c4 varchar(200), vector index idx1(c2) with (distance=inner_product),vector index idx2(c3) with (distance=l2, type=hnsw));
insert into t1(c1,c2,c3,c4) values(1,'{2:1.3,1:2.6}',[1,2,4],'{2:2,3:5}');
insert into t1(c1,c2,c3,c4) values(2,'{}',[1,2,4],'{}');
insert into t1(c1,c2,c3,c4) values(3,'{1.123:2.123,3.123:4.123,10:2}',[1,2,4],'{1.123:2.123,3.123:4.123,10:3}');
insert into t1(c1,c2,c3,c4) values(4,'{1:2}',[1,2,4],'{1.123:-1}');
insert into t1(c1,c2,c3,c4) values(5,null,null,null);

insert into t1(c1) values(l2_distance([1],[3]))ON DUPLICATE KEY UPDATE c1='[1,1,3]';
insert into t1(c2,c3,c4) values('{2:2,5:200}','[1,3,4]','{2:4,7:200}') ON DUPLICATE KEY UPDATE c2='{1:2}';
insert into t1(c2,c3,c4) values('{2:9,9:200}','[4,5,7]','{2:3,7:200}') ON DUPLICATE KEY UPDATE c2='{2:9,9:200}';

