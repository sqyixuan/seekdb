drop table if exists t1;

# create index on newly added char with default value with PAD_CHAR_TO_FULL_LENGTH
set sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
create table t1(c1 char(10), c2 char(10) default null, c3 char(10) default 'a', c4 char(10) default 'a ', c5 char(10) default '', c6 char(10) default ' ');
insert into t1(c1, c2, c3, c4, c5, c6) values ('11', '12', '13', '14', '15', '16');
insert into t1(c1, c2, c3, c4, c5, c6) values ('', '', '', '', '', '');
insert into t1(c1, c2, c3, c4, c5, c6) values (' ', ' ', ' ', ' ', ' ', ' ');
insert into t1(c1, c2, c3, c4, c5, c6) values (null, null, null, null, null, null);
alter table t1 add a1 char(10);
alter table t1 add a2 char(10) default null;
alter table t1 add a3 char(10) default 'a';
alter table t1 add a4 char(10) default 'a ';
alter table t1 add a5 char(10) default '';
alter table t1 add a6 char(10) default ' ';
create index i1 on t1(c1, c2, c3, c4, c5, c6, a1, a2, a3, a4, a5, a6);
select /*+index(t1 primary)*/ c1, c2, c3, c4, c5, c6, a1, a2, a3, a4, a5, a6 from t1 order by c1, c2, c3, c4, c5, c6, a1, a2, a3, a4, a5, a6;
c1	c2	c3	c4	c5	c6	a1	a2	a3	a4	a5	a6
NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL	a         	a         	          	          
          	          	          	          	          	          	NULL	NULL	a         	a         	          	          
          	          	          	          	          	          	NULL	NULL	a         	a         	          	          
11        	12        	13        	14        	15        	16        	NULL	NULL	a         	a         	          	          
select /*+index(t1 i1)*/ c1, c2, c3, c4, c5, c6, a1, a2, a3, a4, a5, a6 from t1 order by c1, c2, c3, c4, c5, c6, a1, a2, a3, a4, a5, a6;
c1	c2	c3	c4	c5	c6	a1	a2	a3	a4	a5	a6
NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL	a         	a         	          	          
          	          	          	          	          	          	NULL	NULL	a         	a         	          	          
          	          	          	          	          	          	NULL	NULL	a         	a         	          	          
11        	12        	13        	14        	15        	16        	NULL	NULL	a         	a         	          	          
drop table t1;

