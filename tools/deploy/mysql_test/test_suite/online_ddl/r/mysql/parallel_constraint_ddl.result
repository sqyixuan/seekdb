drop table if exists t1;
drop table if exists t2;
drop table if exists t1x;
drop table if exists t2x;
drop database if exists db;
alter system set debug_sync_timeout = '60s';
alter system set _ob_ddl_timeout = '1000s';
alter system set rpc_timeout = '1000s';
set ob_global_debug_sync = 'reset';

# rs switch after modify column type and not null take effect
create table t1(c1 int);
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'CONSTRAINT_SET_VALID wait_for continue_signal execute 1';
alter table t1 modify c1 char(10) not null;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
select ddl_stmt_str from oceanbase.__all_ddl_operation where table_id = (select table_id from oceanbase.__all_table where table_name = 't1') and ddl_stmt_str != '';
ddl_stmt_str
drop table t1;

# rs switch after modify not null take effect
create table t1(c1 int);
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'CONSTRAINT_SET_VALID wait_for continue_signal execute 1';
alter table t1 modify c1 int not null;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
select ddl_stmt_str from oceanbase.__all_ddl_operation where table_id = (select table_id from oceanbase.__all_table where table_name = 't1') and ddl_stmt_str != '';
ddl_stmt_str
create table t1(c1 int)
alter table t1 modify c1 int not null
drop table t1;

# FIXME: rename column before modify not null validated
create table t1(c1 int);
insert into t1 values (1);
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'CONSTRAINT_BEFORE_SET_CHECK_CONSTRAINT_VALIDATED_BEFORE_ALTER_TABLE wait_for continue_signal execute 1';
alter table t1 modify c1 int not null;
alter table t1 rename column c1 to c1x;
select left(constraint_name, 13), check_expr, constraint_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_constraint where table_id = (select table_id from oceanbase.__all_table where table_name = 't1');
left(constraint_name, 13)	check_expr	constraint_type	rely_flag	enable_flag	validate_flag
t1_OBNOTNULL_	(`c1x` is not null)	4	0	1	0
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and ddl_stmt_str not like '%PURGE%' and table_id = (select table_id from oceanbase.__all_table where table_name = 't1') order by schema_version;
ddl_stmt_str
create table t1(c1 int)
alter table t1 rename column c1 to c1x
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
ERROR 42S22: Unknown column
select constraint_name, check_expr, constraint_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_constraint where table_id = (select table_id from oceanbase.__all_table where table_name = 't1');
constraint_name	check_expr	constraint_type	rely_flag	enable_flag	validate_flag
drop table t1;

