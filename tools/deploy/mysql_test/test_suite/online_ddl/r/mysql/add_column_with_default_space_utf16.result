drop table if exists test_utf16;
create table test_utf16(c1 int, c2 char(10) default '', c3 char(10) default ' ', c4 char(10) default '  ') character set=utf16;
insert into test_utf16 (c1) values(1);
alter table test_utf16 add column c5 char(10) default '  ';
select hex(c2), hex(c3), hex(c4), hex(c5) from test_utf16;
hex(c2)	hex(c3)	hex(c4)	hex(c5)
			
insert into test_utf16 (c1) values(2);
select hex(c2), hex(c3), hex(c4), hex(c5) from test_utf16;
hex(c2)	hex(c3)	hex(c4)	hex(c5)
			
			
alter table test_utf16 drop column c1;
drop table if exists test_utf16;
create table test_utf16(c1 int, c2 char(10) default '', c3 char(10) default ' ', c4 char(10) default '  ') character set=utf16;
insert into test_utf16 (c1) values(1);
alter table test_utf16 add column c5 char(10) default '123 ';
select hex(c2), hex(c3), hex(c4), hex(c5) from test_utf16;
hex(c2)	hex(c3)	hex(c4)	hex(c5)
			003100320033
alter table test_utf16 add column c6 char(10) default '  ' after c1;
select hex(c2), hex(c3), hex(c4), hex(c5), hex(c6) from test_utf16;
hex(c2)	hex(c3)	hex(c4)	hex(c5)	hex(c6)
			003100320033	
drop table if exists test_utf16;
create table test_utf16(c1 int, c2 varchar(20) default '   ', c3 varchar(20) default '123  ');
insert into test_utf16(c1) values(1);
select c1, hex(c2), hex(c3) from test_utf16;
c1	hex(c2)	hex(c3)
1	202020	3132332020
drop table if exists test_utf16;
