1. primary key related
drop table if exists t101;
create table t101(c1 int, c2 int, c3 char(10), primary key(c1));
insert into t101 values(1, 1, 1), (2, 2, 2);
alter table t101 modify c3 varchar(10);
alter table t101 drop column c1;
ERROR 0A000: drop rowkey column is not supported
alter table t101 drop primary key;
alter table t101 drop column c1, drop column c2;
alter table t101 drop column c3;
ERROR 42000: You can't delete all columns with ALTER TABLE; use DROP TABLE instead
drop table t101;
2. partition key related
drop table if exists t201;
create table t201(c1 int, c2 char(10)) partition by hash(c1) partitions 2;
insert into t201 values(1, 'null'), (2, 'test');
alter table t201 drop column c1;
ERROR HY000: Column 'c1' has a partitioning function dependency and cannot be dropped or renamed.
alter table t201 drop column c1, drop column c2;
ERROR HY000: Column 'c1' has a partitioning function dependency and cannot be dropped or renamed.
alter table t201 drop column c2, drop column c1;
ERROR HY000: Column 'c1' has a partitioning function dependency and cannot be dropped or renamed.
drop table t201;
create table t1(c1 int, c2 char(10), c3 char(10));
create index idx on t1(c1, c3) partition by hash(c1) partitions 3;
alter table t1 drop column c1;
ERROR HY000: Column 'c1' has a partitioning function dependency and cannot be dropped or renamed.
alter table t1 drop index idx;
alter table t1 drop column c1;
drop table t1;
3. index related
drop table if exists t301;
create table t301(c1 int, c2 char(10), c3 int, c4 int);
create unique index unique_idx1 on t301(c1, c2, c3);
create index non_unique_idx1 on t301(c1, c2, c3, c4);
insert into t301 values(1, 'abcd', 3, 4);
insert into t301 values(1, 'abcd', 4, 5);
alter table t301 drop column c4;
alter table t301 drop column c3;
ERROR 23000: Duplicated primary key
alter table t301 drop column c1;
insert into t301 (c2, c3) values ('abcd', 4);
ERROR 23000: Duplicate entry 'abcd-4' for key 'unique_idx1'
show create table t301;
Table	Create Table
t301	CREATE TABLE `t301` (
  `c2` char(10) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  UNIQUE KEY `unique_idx1` (`c2`, `c3`) BLOCK_SIZE 16384 LOCAL,
  KEY `non_unique_idx1` (`c2`, `c3`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
drop table t301;
4. foreign key related
drop table if exists t401;
drop table if exists t402;
create table t401(c1 int primary key, c2 int);
insert into t401 values (1, 1), (2, 2);
create table t402(c2 int, c3 int, c1 int, foreign key(c1) references t401(c1));
insert into t402 values (1, 1, 1), (2, 2, 2);
alter table t402 drop column c1;
ERROR HY000: 'c1': used in a foreign key constraint
alter table t402 drop column c2, drop column c1;
ERROR HY000: 'c1': used in a foreign key constraint
alter table t401 drop column c1;
ERROR HY000: 'c1': used in a foreign key constraint
alter table t402 drop column c2;
drop table t401;
drop table t402;
drop table t401;
5. generated column related (VIRTUAL AND STORED)
drop table if exists t501;
create table t501(c1 int, c2 int, c3 char(10), c4 char(10), c5 int generated always as (c1 + 2) stored, c6 varchar(20) generated always as (concat(c3, c4)));
insert into t501 (c1, c2, c3, c4) values (1, 1, 'null1', 'test1');
insert into t501 (c1, c2, c3, c4) values (2, 2, 'null2', 'test2');
alter table t501 drop column c1;
ERROR HY000: Column 'c1' has a generated column dependency
alter table t501 drop column c3;
ERROR HY000: Column 'c3' has a generated column dependency
alter table t501 drop column c5;
alter table t501 drop column c1;
alter table t501 drop column c3, drop column c4, drop column c6;
ERROR HY000: Column 'c3' has a generated column dependency
alter table t501 drop column c6, drop column c3, drop column c4;
ERROR HY000: Column 'c3' has a generated column dependency
drop table t501;
6. unique, not null, check, default related
drop table if exists t601;
create table t601(c1 char(10), c2 char(10), c3 char(10), c4 char(10) not null, c5 char(10), c6 char(10), c7 char(10) default 'Test', unique(c1, c2), unique(c3), constraint cst1 check(c5 = c6));
insert into t601 values('test1', 'test2', 'test3', 'test4', 'test5', 'test6', 'test7');
ERROR HY000: check constraint violated
insert into t601 values('null1', 'null2', 'null3', 'null4', 'null5', 'null5', 'null7');
alter table t601 drop column c1, drop column c2;
alter table t601 drop column c3;
alter table t601 drop column c4;
alter table t601 drop column c5;
ERROR HY000: Check constraint 'cst1' uses column 'c5', hence column cannot be dropped or renamed.
alter table t601 drop column c6;
ERROR HY000: Check constraint 'cst1' uses column 'c6', hence column cannot be dropped or renamed.
alter table t601 drop column c7;
drop table t601;
7. trigger related
drop table if exists t701;
create table t701(c1 int, c2 int, c3 int, c4 char(20));
insert into t701 values(1, 1, 1, 'ab'), (2, 2, 2, 'abcd');
create trigger trig1 before delete on t701 
for each row
begin
insert into t701 values(3, 3, 3);
end;
/
alter table t701 modify column c4 varchar(20);
alter table t701 drop column c2;
drop table t701;
8. multiple ddl
drop table if exists t801;
create table t801(c1 int, c2 int, c3 char(10), c4 char(10));
insert into t801 values(1, 1, 'null', 'null');
insert into t801 values(2, 2, 'test', 'test');
alter table t801 add column c0 char(10) default 'mysql' before c1, drop column c2;
select * from t801;
c0	c1	c3	c4
mysql	1	null	null
mysql	2	test	test
alter table t801 modify column c4 varchar(10), drop column c1;
select * from t801;
c0	c3	c4
mysql	null	null
mysql	test	test
alter table t801 add column c1 char(10) default 'oracle' after c0, drop column c3, modify column c4 varchar(10);
select * from t801;
c0	c1	c4
mysql	oracle	null
mysql	oracle	test
alter table t801 drop column c0, drop column c4;
select * from t801;
c1
oracle
oracle
drop table t801;
9. with LOB
drop table if exists t901;
create table t901(c1 int, c2 char(10), c3 longtext) partition by hash(c1);
insert into t901 values(1, 'null', repeat('a', 1000000));
insert into t901 values(2, 'test', repeat('b', 1000000));
alter table t901 drop column c2;
alter table t901 drop column c3;
drop table t901;
10. compare the state of constraints before and after drop column op
create table t1001(c1 int, c2 int, c3 char(10), c4 char(10), constraint cst2 check(c1=c2));
create table t1003(c1 int primary key, c2 int);
insert into t1003 values (1, 1), (2, 2);
create table t1004(c2 int, c3 int, c1 int, foreign key(c1) references t1003(c1));
insert into t1004 values (1, 1, 1), (2, 2, 2);
constraint_type	check_expr	rely_flag	enable_flag	validate_flag
3	(`c1` = `c2`)	0	1	1
update_action	delete_action	enable_flag	ref_cst_type	ref_cst_id	validate_flag	rely_flag
1	1	1	1	-1	1	0
update_action	delete_action	enable_flag	ref_cst_type	ref_cst_id	validate_flag	rely_flag
1	1	1	1	-1	1	0
alter table t1001 drop column c4;
alter table t1003 drop column c2;
alter table t1004 drop column c2;
constraint_type	check_expr	rely_flag	enable_flag	validate_flag
3	(`c1` = `c2`)	0	1	1
update_action	delete_action	enable_flag	ref_cst_type	ref_cst_id	validate_flag	rely_flag
1	1	1	1	-1	1	0
update_action	delete_action	enable_flag	ref_cst_type	ref_cst_id	validate_flag	rely_flag
1	1	1	1	-1	1	0
11. drop column and drop constraint in one sql.
test drop column and drop check constraint.
create table t1101(c0 int, c1 int, c2 int, c3 char(10), constraint chk1 check(c1 = c2), constraint chk2 check(c3 = 'test'));
insert into t1101 values(0, 1, 1, 'test');
alter table t1101 drop column c1;
ERROR HY000: Check constraint 'chk1' uses column 'c1', hence column cannot be dropped or renamed.
alter table t1101 drop column c3;
alter table t1101 drop constraint chk1, drop column c1;
alter table t1101 drop column c2, drop constraint chk2, drop column c0;
ERROR HY000: Constraint 'chk2' does not exist.
drop table t1101;
test drop column and drop foreign key.
create table t1100(c1 int primary key, c2 int);
create table t1101(c1 int, c2 int, primary key(c1));
create table t1102(c1 int, c2 int, c3 int, constraint fk1 foreign key (c1) references t1100(c1), constraint fk2 foreign key(c1) references t1101(c1));
drop table if exists t0;
drop table if exists t2;
create table t0(c1 int primary key, c2 int);
create table t1(c1 int, c2 int, primary key(c1));
create table t2(c1 int, c2 int, c3 int, constraint fk1 foreign key (c1) references t0(c1), constraint fk2 foreign key(c1) references t1(c1));
ERROR 23000: Can't write; duplicate key in table 't2'
alter table t1101 drop column c1;
ERROR HY000: 'c1': used in a foreign key constraint
alter table t1102 drop column c1;
ERROR HY000: 'c1': used in a foreign key constraint
alter table t1102 drop column c1, drop foreign key fk;
ERROR HY000: 'c1': used in a foreign key constraint
alter table t1102 drop foreign key fk1, drop column c1, drop foreign key fk2;
drop table t1100;
drop table t1101;
drop table t1102;
12. to test drop index column.
drop table if exists z0case;
to test table with specified primary key.
create table z0case(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, primary key(c1, c2));
create unique index unique_index1 on z0case(c2, c3) storing (c1, c3, c4);
create unique index unique_index2 on z0case(c3) storing (c1, c2, c5);
create unique index unique_index3 on z0case(c2, c4) storing (c1, c3, c4);
create unique index unique_index4 on z0case(c4) storing (c2, c5);
create unique index unique_index5 on z0case(c5) storing (c3, c2);
create unique index unique_index6 on z0case(c5) storing (c4, c1);
create index idx1 on z0case(c2, c3, c4);
create index idx2 on z0case(c3);
create index idx3 on z0case(c4);
