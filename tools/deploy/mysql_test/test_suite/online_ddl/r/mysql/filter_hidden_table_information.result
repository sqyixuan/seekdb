drop table if exists t1;
drop table if exists t2;
drop database if exists db;
alter system set debug_sync_timeout = '120s';
alter system set _ob_ddl_timeout = '1000s';
alter system set rpc_timeout = '1000s';
set ob_global_debug_sync = 'reset';

#create table t1, t2 , create constraint on t1
create table t1(c0 int, c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int) partition by range(c1)
subpartition by range(c0)
(
partition p0 values less than (10000000)
(
subpartition p0sp0 values less than (10000000),
subpartition p0sp1 values less than (20000000),
subpartition p0sp2 values less than (30000000)
),
partition p1 values less than (20000000)
(
subpartition p1sp0 values less than (10000000),
subpartition p1sp1 values less than (20000000),
subpartition p1sp2 values less than (30000000)
),
partition p2 values less than (30000000)
(
subpartition p2sp0 values less than (10000000),
subpartition p2sp1 values less than (20000000),
subpartition p2sp2 values less than (30000000)
)
);
create table t2(i int auto_increment, k bigint, primary key(i)) partition by hash(i) partitions 128;
ALTER TABLE t1 ADD CONSTRAINT users_fk FOREIGN KEY (c1) REFERENCES t2 (i) ON UPDATE RESTRICT ON DELETE CASCADE;

#create index on t1, t2, alter table t1 drop column c2
create index idx0 on t1(c0) global;
create index idx1 on t1(c1) global;
create index idx2 on t1(c2) local;
create index idx3 on t1(c3) local;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'TABLE_REDEFINITION_REPLICA_BUILD wait_for continue_signal execute 10000';
alter table t1 drop column c2;

