drop table if exists test;
create table test(c1 int, c2 int, c3 int as (c1 + c2) VIRTUAL);
insert into test(c1, c2) values (1, '2');
insert into test(c1, c2) values (10, '20');
alter table test modify c1 char(100);
select * from test;
c1	c2	c3
1	2	3
10	20	30
drop table test;
drop table if exists test;
create table test(c1 int, c2 int, c3 int as (c1 + c2) STORED);
insert into test(c1, c2) values (1, '2');
insert into test(c1, c2) values (10, '20');
alter table test modify c1 char(100);
select * from test;
c1	c2	c3
1	2	3
10	20	30
