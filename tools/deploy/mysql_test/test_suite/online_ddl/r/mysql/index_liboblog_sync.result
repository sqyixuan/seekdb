DROP TABLE IF EXISTS T1;

to test normal index.
alter system set _enable_drop_and_add_index = true;
CREATE TABLE T1(C1 INT, C2 INT, C3 INT);
INSERT INTO T1 VALUES(1, 1, 1), (2, 2, 1);
CREATE INDEX MYSQL_INDEX_LIBOBLOG_SYNC_TEST_1 ON T1(C1);
ALTER TABLE T1 ADD INDEX MYSQL_INDEX_LIBOBLOG_SYNC_TEST_2 (C1, C2);
CREATE UNIQUE INDEX MYSQL_INDEX_LIBOBLOG_SYNC_TEST_3 ON T1(C3);
ERROR 23000: Duplicate entry '1' for key 'MYSQL_INDEX_LIBOBLOG_SYNC_TEST_3'
ALTER TABLE T1 ADD UNIQUE INDEX MYSQL_INDEX_LIBOBLOG_SYNC_TEST_4 (C3), ADD UNIQUE INDEX MYSQL_INDEX_LIBOBLOG_SYNC_TEST_5 (C1, C2), DROP INDEX MYSQL_INDEX_LIBOBLOG_SYNC_TEST_1;
ERROR 23000: Duplicate entry '1' for key 'MYSQL_INDEX_LIBOBLOG_SYNC_TEST_4'
SHOW INDEX FROM T1;
Table	Non_unique	Key_name	Seq_in_index	Column_name	Collation	Cardinality	Sub_part	Packed	Null	Index_type	Comment	Index_comment	Visible	Expression
t1	1	MYSQL_INDEX_LIBOBLOG_SYNC_TEST_2	1	C1	A	NULL	NULL	NULL	YES	BTREE	available		YES	NULL
t1	1	MYSQL_INDEX_LIBOBLOG_SYNC_TEST_2	2	C2	A	NULL	NULL	NULL	YES	BTREE	available		YES	NULL
t1	0	MYSQL_INDEX_LIBOBLOG_SYNC_TEST_5	1	C1	A	NULL	NULL	NULL	YES	BTREE	available		YES	NULL
t1	0	MYSQL_INDEX_LIBOBLOG_SYNC_TEST_5	2	C2	A	NULL	NULL	NULL	YES	BTREE	available		YES	NULL
SHOW CREATE TABLE T1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `C1` int(11) DEFAULT NULL,
  `C2` int(11) DEFAULT NULL,
  `C3` int(11) DEFAULT NULL,
  UNIQUE KEY `MYSQL_INDEX_LIBOBLOG_SYNC_TEST_5` (`C1`, `C2`) BLOCK_SIZE 16384 LOCAL,
  KEY `MYSQL_INDEX_LIBOBLOG_SYNC_TEST_2` (`C1`, `C2`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
SELECT TABLE_NAME, DDL_STMT_STR FROM OCEANBASE.__ALL_VIRTUAL_DDL_OPERATION WHERE DDL_STMT_STR LIKE '%MYSQL_INDEX_LIBOBLOG_SYNC_TEST%' ORDER BY GMT_CREATE;
TABLE_NAME	DDL_STMT_STR
	CREATE INDEX MYSQL_INDEX_LIBOBLOG_SYNC_TEST_1 ON T1(C1)
	ALTER TABLE T1 ADD INDEX MYSQL_INDEX_LIBOBLOG_SYNC_TEST_2 (C1, C2)
	ALTER TABLE T1 ADD UNIQUE INDEX MYSQL_INDEX_LIBOBLOG_SYNC_TEST_4 (C3), ADD UNIQUE INDEX MYSQL_INDEX_LIBOBLOG_SYNC_TEST_5 (C1, C2), DROP INDEX MYSQL_INDEX_LIBOBLOG_SYNC_TEST_1
	drop index MYSQL_INDEX_LIBOBLOG_SYNC_TEST_4 on t1
DROP TABLE T1;

to test inner expr index.
drop table if exists t1;
create table t1(id int, g1 geometry not null srid 2284);
create spatial index MYSQL_yiren_test_spatial_index0 on t1(g1);
alter table t1 drop index MYSQL_yiren_test_spatial_index0;
create spatial index MYSQL_yiren_test_spatial_index1 on t1(g1) global;
alter table t1 drop index MYSQL_yiren_test_spatial_index1;
alter table t1 add spatial index MYSQL_yiren_test_spatial_index2 (g1);
alter table t1 drop index MYSQL_yiren_test_spatial_index2;
alter table t1 add spatial index MYSQL_yiren_test_spatial_index3 (g1) global;
alter table t1 drop index MYSQL_yiren_test_spatial_index3;
drop table t1;
SELECT TABLE_NAME, DDL_STMT_STR FROM OCEANBASE.__ALL_VIRTUAL_DDL_OPERATION WHERE DDL_STMT_STR LIKE '%MYSQL_yiren_test_spatial_index%' ORDER BY GMT_CREATE;
TABLE_NAME	DDL_STMT_STR
	create spatial index MYSQL_yiren_test_spatial_index0 on t1(g1)
	alter table t1 drop index MYSQL_yiren_test_spatial_index0
	create spatial index MYSQL_yiren_test_spatial_index1 on t1(g1) global
	alter table t1 drop index MYSQL_yiren_test_spatial_index1
	alter table t1 add spatial index MYSQL_yiren_test_spatial_index2 (g1)
	alter table t1 drop index MYSQL_yiren_test_spatial_index2
	alter table t1 add spatial index MYSQL_yiren_test_spatial_index3 (g1) global
	alter table t1 drop index MYSQL_yiren_test_spatial_index3

to test some special character index name.
CREATE TABLE t1 (c1 INT , c2 varchar(20));
INSERT INTO t1 VALUES(1,"孔子"), (1,"孟子");
/*! CREATE UNIQUE INDEX MYSQL_yiren_mult_char_index1 ON t1(c1) */;
ERROR 23000: Duplicate entry '1' for key 'MYSQL_yiren_mult_char_index1'
/*! alter table t1 add unique index MYSQL_yiren_mult_char_index1_cReaTe  (c1) */;
ERROR 23000: Duplicate entry '1' for key 'MYSQL_yiren_mult_char_index1_cReaTe'
/*! CREATE INDEX MYSQL_yiren_mult_char_index2_ALTER ON t1(c1, c2) */;
/*! CREATE INDEX MYSQL_yiren_mult_char_index3_alter ON t1(c2) */;
aLTer table t1 add index MYSQL_yiren_mult_char_index4_cReate     (c1);
drop index MYSQL_yiren_mult_char_index4_cReate ON t1;
drop index MYSQL_yiren_mult_char_index3_alter on t1;
alter table t1 drop index MYSQL_yiren_mult_char_index2_ALTER;
SELECT TABLE_NAME, DDL_STMT_STR FROM OCEANBASE.__ALL_VIRTUAL_DDL_OPERATION WHERE DDL_STMT_STR LIKE '%MYSQL_yiren_mult_char_index%' ORDER BY GMT_CREATE;
TABLE_NAME	DDL_STMT_STR
	/*! alter table t1 add unique index MYSQL_yiren_mult_char_index1_cReaTe  (c1) */
	drop index MYSQL_yiren_mult_char_index1_cReaTe on t1
	/*! CREATE INDEX MYSQL_yiren_mult_char_index2_ALTER ON t1(c1, c2) */
	/*! CREATE INDEX MYSQL_yiren_mult_char_index3_alter ON t1(c2) */
	aLTer table t1 add index MYSQL_yiren_mult_char_index4_cReate     (c1)
	drop index MYSQL_yiren_mult_char_index4_cReate ON t1
	drop index MYSQL_yiren_mult_char_index3_alter on t1
	alter table t1 drop index MYSQL_yiren_mult_char_index2_ALTER
drop table t1;
alter system set _enable_drop_and_add_index = false;
