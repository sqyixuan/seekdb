drop table if exists t1;
create table t1(id int primary key, name tinytext, age int, description varchar(65535)) tablet_size=104857600 compression='none';
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
alter table t1 modify name varchar(256);
update t1 set name = 'oceanbase_v5' where id = 3000;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select id, name from t1 where id >= 3000 limit 10;
id	name
3000	oceanbase_v5
3001	oceanbase
3002	oceanbase
3003	oceanbase
3004	oceanbase
3005	oceanbase
3006	oceanbase
3007	oceanbase
3008	oceanbase
3009	oceanbase
drop table t1;
