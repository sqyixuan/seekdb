drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int);
create index i1 on t1(c1);
alter system set _enable_drop_and_add_index = false;
alter table t1 add index i3(c1,c3), drop index i1, add index i2(c1, c2);
ERROR HY000: Dropping and adding indexes at the same time is a high-risk operation, which is not supported
alter table t1 add index i3(c1,c3), add index i2(c1, c2), drop index i1;
ERROR HY000: Dropping and adding indexes at the same time is a high-risk operation, which is not supported
alter table t1 drop index i1, add index i2(c2), add index i3(c3);
ERROR HY000: Dropping and adding indexes at the same time is a high-risk operation, which is not supported
alter table t1 add index i3(c2);
alter system set _enable_drop_and_add_index = true;
alter table t1 drop index i3, add index i2(c1, c2);
alter system set _enable_drop_and_add_index = false;
drop table t1;
