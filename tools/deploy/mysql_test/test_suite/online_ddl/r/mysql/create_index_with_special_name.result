drop table if exists t1;
drop table if exists `t``1`;

# special partition name
create table t1(c1 int primary key) partition by range(c1) (partition `1` values less than (10), partition `2` values less than (20), partition `p``3` values less than (30));
insert into t1 values (1), (15);
create index i1 on t1(c1) local;
select * from t1 order by c1;
c1
1
15
select /*+index(t1 i1)*/ * from t1 order by c1;
c1
1
15
drop table t1;
