alter system set debug_sync_timeout = '60s';
set ob_global_debug_sync = 'reset';

CASE 1. index is dropped by user firstly, use `drop index` syntax.
set ob_global_debug_sync = 'CREATE_INDEX_FAILED wait_for continue_signal execute 10000';
DROP TABLE IF EXISTS T1;
CREATE TABLE T1(C1 INT, C2 INT);
INSERT INTO T1 VALUES(1, 1), (1, 2);
CREATE UNIQUE INDEX IDX1 ON T1(C1);
DROP INDEX IDX1 ON T1;
ERROR 0A000: dropping a building or dropping index is not supported
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
ERROR 23000: Duplicate entry '1' for key 'IDX1'
DROP TABLE T1;

CASE 2. index is dropped by user firstly, use `alter table drop index` syntax.
set ob_global_debug_sync = 'CREATE_INDEX_FAILED wait_for continue_signal execute 10000';
DROP TABLE IF EXISTS T1;
CREATE TABLE T1(C1 INT, C2 INT);
INSERT INTO T1 VALUES(1, 1), (1, 2);
CREATE UNIQUE INDEX IDX1 ON T1(C1);
ALTER TABLE T1 DROP INDEX IDX1;
ERROR 0A000: dropping a building or dropping index is not supported
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
ERROR 23000: Duplicate entry '1' for key 'IDX1'
DROP TABLE T1;

CASE 3. index is dropped by user firstly, use `alter table drop index` syntax with complex ddl.
set ob_global_debug_sync = 'CREATE_INDEX_FAILED wait_for continue_signal execute 10000';
DROP TABLE IF EXISTS T1;
CREATE TABLE T1(C1 INT, C2 INT);
INSERT INTO T1 VALUES(1, 1), (1, 2);
CREATE UNIQUE INDEX IDX1 ON T1(C1);
ALTER TABLE T1 DROP INDEX IDX1, ADD INDEX IDX2 (C2), ADD COLUMN C3 INT;
ERROR HY000: Dropping and adding indexes at the same time is a high-risk operation, which is not supported
SHOW CREATE TABLE T1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `C1` int(11) DEFAULT NULL,
  `C2` int(11) DEFAULT NULL,
  UNIQUE KEY `IDX1` (`C1`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
ERROR 23000: Duplicate entry '1' for key 'IDX1'
DROP TABLE T1;

CASE 4. index is dropped by internal firstly.
DROP TABLE IF EXISTS T1;
CREATE TABLE T1(C1 INT, C2 INT);
INSERT INTO T1 VALUES(1, 1), (1, 2);
CREATE UNIQUE INDEX IDX1 ON T1(C1);
ERROR 23000: Duplicate entry '1' for key 'IDX1'
ALTER TABLE T1 DROP INDEX IDX1;
ERROR 42000: Can't DROP 'IDX1'; check that column/key exists
DROP INDEX IDX1 ON T1;
ERROR 42000: Can't DROP 'IDX1'; check that column/key exists
