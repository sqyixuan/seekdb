to test rebuild multiple fk.
create table t0(c1 int primary key, c2 int, c3 int);
create table t1(c1 int primary key, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int, c4 char(10),
constraint fk00 foreign key(c1) references t0(c1),
constraint fk01 foreign key(c2) references t0(c1),
constraint fk02 foreign key(c3) references t0(c1),
constraint fk11 foreign key(c1) references t1(c1), 
constraint fk12 foreign key(c2) references t1(c1));
alter table t2 modify c4 varchar(10);
alter table t2 modify c4 char(9);
drop table t2;
drop table t1;
to execute offline ddl in parent table mainly.
create table t1(a int primary key, b int, c int);
create table t2 (a int primary key, b int, c int, foreign key (b) references t1(a));
alter table t2 add constraint a foreign key (a) references t1(a);
alter table t2 add constraint b foreign key (b) references t1(a);
alter table t1 modify c mediumint;
alter table t1 drop column c;
alter table t2 modify c mediumint;
alter table t2 drop column c;
drop table t2;
drop table t1;
