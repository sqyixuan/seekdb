alter system set default_table_store_format = 'row';
drop table if exists xingrui_table;
create table xingrui_table(col1 int, col2 int);
alter table xingrui_table drop column col2;
alter system set default_table_store_format = 'compound';
drop table xingrui_table;
create table xingrui_table(col1 int, col2 int);
alter table xingrui_table drop column col2;
alter system set default_table_store_format = 'row';
