drop table if exists t1;
create table t1(id int primary key, name varchar(3000), age int, description varchar(3000)) compression='none' row_format = compact;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
alter table t1 modify name text;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
"alter column reuse macro block"
update t1 set name = 'oceanbase' where id = 10;
delete from t1 where id = 1000;
insert into t1 values(20000, 'oceanbase', 200, 'oceanbase');
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
drop table t1;
