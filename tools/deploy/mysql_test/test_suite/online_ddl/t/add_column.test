# owner: lihongqin.lhq
# owner group: storage
# description:this case is use for test add columns
#

--disable_warnings
drop table if exists t2;
drop table if exists t1;
--enable_warnings

# test add column first/before/after
create table t1(c2 int, c4 int);
alter table t1 add column c1 smallint first;
desc t1;
insert into t1 values (11, 21, 41);
alter table t1 add column c0 tinyint before c1;
desc t1;
insert into t1 values (02, 12, 22, 42);
alter table t1 add column c3 bigint after c2;
desc t1;
insert into t1 values (03, 13, 23, 33, 43);
select * from t1;
drop table t1;

# test reshape
create table t1(c1 int);
insert into t1 values (1);
alter table t1 add c0 binary(10) not null first;
select c1, hex(c0) from t1;
set sql_mode = 'STRICT_TRANS_TABLES,PAD_CHAR_TO_FULL_LENGTH';
alter table t1 add c11 char(10) not null after c0;
select c1, hex(c0), length(c11) from t1;
set sql_mode = 'STRICT_TRANS_TABLES';
alter table t1 add c12 char(10) not null after c11;
select c1, hex(c0), hex(c11), hex(c12) from t1;
--error 1048
insert into t1 values (null, '', '', 2);
--error 1048
insert into t1 values ('', null, '', 2);
--error 1048
insert into t1 values ('', '', null, 2);
insert into t1 values ('', '', '', 3);
insert into t1 values (' ', ' ', '  ', 4);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
drop table t1;

# TODO(lihongqin.lhq): add primary key
create table t1(c1 int, c3 int);
insert into t1 values (1, 2);
insert into t1 values (1, 2);
--error 1235
alter table t1 add c2 int primary key after c1;
truncate table t1;
insert into t1 values (1, 2);
--error 1235
alter table t1 add c0 int primary key first;
select * from t1;
--error 1235
alter table t1 add c2 int primary key after c1;
drop table t1;

# FIXME: 
--echo add column with dropped name
create table t1(c1 int, c2 int);
insert into t1 values (1, 2);
--error 1060
alter table t1 drop c1, add c1 char(10) default 'a';
desc t1;
select * from t1;
drop table t1;

# insert column into primary key
create table t1(c1 int, c3 bigint, primary key (c1, c3));
insert into t1 values (1, 2);
insert into t1 values (2, 0);
insert into t1 values (3, 1);
alter table t1 add column c2 int after c1;
select * from t1;
drop table t1;

# test generated column
create table t1(c1 int, c2 char(10), c3 int as (c1 + c2));
insert into t1(c1, c2) values (11, '21');
alter table t1 add column c0 char(11) as (c2 - c1) before c1;
insert into t1(c1, c2) values (12, '22');
select * from t1;
drop table t1;

# test partition table after adding columns
create table t1(c1 int, c2 int) partition by hash(c1);
insert into t1 values (1, 2);
alter table t1 add column c0 int before c1;
select * from t1;
drop table t1;

# test rowkey after adding columns
create table t1(c1 int primary key, c2 int);
insert into t1 values (1, 2);
alter table t1 add column c0 int default 0 before c1;
insert into t1(c0, c1, c2) values (0, 2, 2); # pk is not c0 or c2
--error 1062
insert into t1(c1) values (1);
--error 1062
insert into t1(c1) values (2);
drop table t1;

# test index after adding columns
create table t1(c1 int, c2 char(10));
insert into t1 values (1, "a");
create index i1 on t1(c1);
insert into t1 values (2, "b");
create index i2 on t1(c2);
alter table t1 add column c0 int before c1;
select * from t1 where c1 = 1;
select * from t1 where c2 = "b";
show index from t1;
drop table t1;

# test constraint after adding columns
create table t1(c1 int not null, c3 int);
alter table t1 add column c0 int before c1;
insert into t1(c0, c1, c3) values (null, 0, 0);
--error 1048
insert into t1(c0, c1, c3) values (0, null, 0);
insert into t1(c0, c1, c3) values (0, 0, null);
alter table t1 add column c2 int default 0 not null after c1;
insert into t1(c0, c1, c2, c3) values (null, 0, 0, 0);
--error 1048
insert into t1(c0, c1, c2, c3) values (0, null, 0, 0);
--error 1048
insert into t1(c0, c1, c2, c3) values (0, 0, null, 0);
insert into t1(c0, c1, c2, c3) values (0, 0, 0, null);
drop table t1;

create table t1(c1 int, c2 int);
insert into t1 values (1, 2);
alter table t1 add column c0 int default 99 not null before c1;
--error 1048
insert into t1(c0, c1, c2) values (null, 0, 0);
insert into t1(c0, c1, c2) values (0, null, 0);
insert into t1(c0, c1, c2) values (0, 0, null);
drop table t1;

# test auto increment column after adding columns
create table t1(c1 int primary key auto_increment, c2 int);
insert into t1(c2) values (1);
insert into t1(c2) values (2);
alter table t1 add column c0 int before c1;
insert into t1(c0, c2) values (0, 0);
select c0, c2 from t1 order by c1;
drop table t1;

# test foreign key after adding columns in parent table
create table t1(c1 int primary key, c2 int);
create table t2(c1 int, c2 int, foreign key (c2) references t1(c1));
insert into t1 values (1, 2);
alter table t1 add column c0 int before c1;
insert into t1(c0, c1) values (0, 3);
insert into t2(c1) values (4); # not t2(c1) references t1(c0) or t1(c1) or t1(c2)
insert into t2(c2) values (1), (3); # is t2(c2) references t1(c1)
--error 1452
insert into t2(c2) values (0); # not t2(c2) references t1(c0)
--error 1452
insert into t2(c2) values (2); # not t2(c2) references t1(c2)
drop table t2;
drop table t1;

# test foreign key after insert columns among parent table' primary key
create table t1(c1 int, c3 int, primary key(c3, c1));
create table t2(c1 int, c2 int, foreign key (c1, c2) references t1(c1, c3));
insert into t1 values (1, 2);
insert into t2 values (1, 2);
alter table t1 add column c2 int after c1;
drop table t2;
drop table t1;

# test foreign key after adding columns in child table
create table t1(c1 int primary key, c2 int);
create table t2(c1 int, c2 int, foreign key (c2) references t1(c1));
insert into t1 values (1, 2);
--error 4714
alter table t1 drop primary key;
alter table t2 add column c0 int before c1;
insert into t2(c0) values (0); # not t2(c0) references t1(c1) or t1(c2)
insert into t2(c1) values (0); # not t2(c1) references t1(c1) or t1(c2)
--error 1452
insert into t2(c2) values (2); # not t2(c2) references t1(c1)
--error 1452
insert into t2(c2) values (0); # is t2(c2) references t1(c1)
insert into t2(c2) values (1); # is t2(c2) references t1(c1)
drop table t2;
drop table t1;

--echo
--echo # add column first with check constraint
create table t1(c1 int, c2 int);
alter table t1 add c3 int check(c3>1) after c1;
select column_name from oceanbase.__all_column where (table_id,column_id) in (select table_id,column_id from oceanbase.__all_tenant_constraint_column where table_id = (select table_id from oceanbase.__all_table where table_name = 't1')) order by 1;
alter table t1 drop column c2;
select column_name from oceanbase.__all_column where (table_id,column_id) in (select table_id,column_id from oceanbase.__all_tenant_constraint_column where table_id = (select table_id from oceanbase.__all_table where table_name = 't1')) order by 1;
drop table t1;

