# owner: lihongqin.lhq
# owner group: storage
# description:this case is use for test modify decimal columns
#

--disable_warnings
drop table if exists t1;
--enable_warnings

set sql_mode = "STRICT_TRANS_TABLES";

create table t1(c1 decimal(3,1));
insert into t1 values (50.1);

# d1 <= d2 and m1-d1 <= m2-d2
alter table t1 modify c1 decimal(4,2);
alter table t1 modify c1 decimal(5,2);
insert into t1 values (0.01);
insert into t1 values (999.01);

# d1 <= d2 and m1-d1 > m2-d2
--error 1264
alter table t1 modify c1 decimal(3,2);
--error 1264
alter table t1 modify c1 decimal(4,2);
--error 1264
alter table t1 modify c1 decimal(4,3);
--error 1264
alter table t1 modify c1 decimal(5,3);

# d1 > d2 and m1-d1 <= m2-d2
--error 1064
alter table t1 modify c1 decimal(1,-3);
--error 1064
alter table t1 modify c1 decimal(1,-2);
--error 1064
alter table t1 modify c1 decimal(2,-1);
--error 1064
alter table t1 modify c1 decimal(3,-1);
# data truncated, same as mysql
alter table t1 modify c1 decimal(3,0);
alter table t1 modify c1 decimal(5,2);
insert into t1 values (999.01);

# d1 > d2 and m1-d1 > m2-d2
--error 1064
alter table t1 modify c1 decimal(0,-1);
--error 1264
alter table t1 modify c1 decimal(1,0);
--error 1264
alter table t1 modify c1 decimal(2,0);
--error 1264
alter table t1 modify c1 decimal(2,1);
--error 1264
alter table t1 modify c1 decimal(3,1);

drop table t1;

# m < 0
--error 1064
create table t1(c1 decimal(-1,0));
--error 1064
create table t1(c1 decimal(-1,1));
--error 1064
create table t1(c1 decimal(-1,65));
--error 1064
create table t1(c1 decimal(-1,66));
create table t1(c1 decimal(1, 0));
insert into t1 values (0);
insert into t1 values (1);
insert into t1 values (9);
--error 1064
alter table t1 modify c1 decimal(-2,0);
--error 1064
alter table t1 modify c1 decimal(-1,-1);
--error 1064
alter table t1 modify c1 decimal(-1,0);
--error 1064
alter table t1 modify c1 decimal(-1,1);
--error 1064
alter table t1 modify c1 decimal(-1,64);
--error 1064
alter table t1 modify c1 decimal(-1,65);
--error 1064
alter table t1 modify c1 decimal(-1,66);
drop table t1;

# m in [0,65] and d < 0
--error 1064
create table t1(c1 decimal(0,-1));
--error 1064
create table t1(c1 decimal(65,-1));
create table t1(c1 decimal(0,0));
--error 1064
alter table t1 modify c1(0,-1);
--error 1064
alter table t1 modify c1(65,-1);
drop table t1;

# m in [0,65] and d in [0,65]
create table t1(c1 decimal(1,0), c2 decimal(1, 1));
insert into t1 values (1, 0.1);
--error 1264
alter table t1 modify c1 decimal(1, 1);
--error 1427
alter table t1 modify c1 decimal(1, 2);
--error 1425
alter table t1 modify c1 decimal(64, 65);
--error 1425
alter table t1 modify c1 decimal(65, 65);
alter table t1 modify c1 decimal(65, 0);
alter table t1 modify c1 decimal(65);
insert into t1 values (1e64, 0.1);
--error 1264
alter table t1 modify c1 decimal(64, 0);
--error 1264
alter table t1 modify c1 decimal(65, 1);
# data truncated, same as mysql
alter table t1 modify c2 decimal(65, 0);
drop table t1;

# m in [0,65] and d > 65
--error 1425
create table t1(c1 decimal(0,66));
--error 1425
create table t1(c1 decimal(65,66));
create table t1(c1 decimal(0,0));
--error 1425
alter table t1 modify c1 decimal(0,66);
--error 1425
alter table t1 modify c1 decimal(1,66);
--error 1425
alter table t1 modify c1 decimal(64,66);
--error 1425
alter table t1 modify c1 decimal(65,66);
drop table t1;

# m > 65
--error 1064
create table t1(c1 decimal(66,-1));
--error 1426
create table t1(c1 decimal(66,0));
--error 1426
create table t1(c1 decimal(66,1));
--error 1426
create table t1(c1 decimal(66,65));
--error 1426
create table t1(c1 decimal(66,66));
create table t1(c1 decimal(0, 0));
--error 1064
alter table t1 modify c1 decimal(66, -1);
--error 1426
alter table t1 modify c1 decimal(66, 0);
--error 1426
alter table t1 modify c1 decimal(66, 1);
--error 1426
alter table t1 modify c1 decimal(66, 65);
drop table t1;

# signed to unsigned
create table t1(c1 decimal(3, 0));
insert into t1 values (101);
alter table t1 modify c1 decimal(3, 0) unsigned;
alter table t1 modify c1 decimal(3, 0);
insert into t1 values (-101);
--error 1264
alter table t1 modify c1 decimal(3, 0) unsigned;
drop table t1;

# unsigned to signed
create table t1(c1 decimal(3, 0) unsigned);
insert into t1 values (999);
--error 1264
insert into t1 values (-999);
--error 1264
alter table t1 modify c1 decimal(2, 0);
--error 1264
alter table t1 modify c1 decimal(3, 1);
--error 1264
alter table t1 modify c1 decimal(4, 2);
alter table t1 modify c1 decimal(4, 1);
