# owner : xingrui.cwh
# owner group : rs
# description : this case is used for test alter table, add column instant and modify column

connect(mysql_conn,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection mysql_conn;
set @@session.recyclebin = off;
sleep 2;

--disable_query_log
--disable_warnings
--disable_result_log
drop table if exists xingrui_normal_table;
drop table if exists xingrui_comment_table;
drop table if exists xingrui_default_table;
drop table if exists xingrui_not_null_table;
drop table if exists xingrui_virtual_table;
drop table if exists xingrui_stored_table;
drop table if exists xingrui_increment_table;
drop table if exists xingrui_primary_table;
drop table if exists xingrui_check_table;
drop table if exists xingrui_unique_table;
--enable_query_log
--enable_warnings
--enable_result_log

#case 1. add normal column and modify column
#case 1.1 add mormal column and modify column accuracy
#普通列char变长
#online
create table xingrui_normal_table (a char(10), b int);
alter table xingrui_normal_table add column c int after a, modify column a char(20);
insert into xingrui_normal_table values('1234567890', 1, 2);
select * from xingrui_normal_table;

#普通列bit变长
#online
drop table xingrui_normal_table;
create table xingrui_normal_table (a bit(10), b int);
alter table xingrui_normal_table add column c int after a, modify column a bit(20);
insert into xingrui_normal_table values(1, 2, 1);
select * from xingrui_normal_table;

#主键bit变长
#online
drop table xingrui_normal_table;
create table xingrui_normal_table (a bit(10) primary key, b int);
