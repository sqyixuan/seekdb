# owner: jianyun.sjy
# owner group: storage
# description:this case is use for changing column type: tiny_text to varchar
#
--disable_warnings
drop table if exists t1;
create table t1(id int primary key, name tinytext, age int, description varchar(65535)) tablet_size=104857600 compression='none';
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
# alter system set minor_compact_trigger=0;
let $database_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'test' limit 1, database_id, 1);
let $data_table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1' and database_id = '$database_id', table_id, 1);
disconnect obsys;

# prepare data
connection default;
let $pkey=0;
let $i=0;
while($i < 10000)
{
  --disable_query_log
  --disable_result_log
  eval insert into t1 values($pkey, 'oceanbase', 0, repeat(rand(),900));
  --enable_query_log
  --enable_result_log
  inc $i;
  inc $pkey;
}

# minor freeze
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc

# change column type
connection default;
alter table t1 modify name varchar(256);
--sleep 10
update t1 set name = 'oceanbase_v5' where id = 3000;

# major freeze
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

connection default;
select id, name from t1 where id >= 3000 limit 10;
drop table t1;
