# owner: xingrui.cwh
# owner group: RS
# CASE_DESC:
#    验证mysql快速删列在列存副本的场景是否走online ddl

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connection sys;
let $unit1 = xingrui_unit;
let $pool1 = xingrui_pool;
let $z1 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 3, zone, 1);
let $z2 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 3, zone, 2);
let $z2_ip         = query_get_value(select svr_ip     from oceanbase.__all_server where zone = '$z2', svr_ip,     1);
let $z2_mysql_port = query_get_value(select inner_port from oceanbase.__all_server where zone = '$z2', inner_port, 1);

--disable_warnings
#drop tenant if exists xingrui_mysql_tenant force;
#eval DROP RESOURCE POOL if exists $pool1;
#eval DROP RESOURCE UNIT if exists $unit1;
--disable_query_log
#eval CREATE RESOURCE UNIT if not exists $unit1 MAX_CPU=1, MEMORY_SIZE='2G';
#eval create resource pool if not exists $pool1 unit='$unit1', unit_num = 1, zone_list = ('$z1', '$z2');
#eval create tenant xingrui_mysql_tenant resource_pool_list=('$pool1'), replica_num=2, zone_list=('$z1','$z2'), locality = 'F@$z1, C@$z2' set ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_warnings

connection sys;
let $tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'sys', tenant_id, 1);


connect (mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection mysql;
alter system set default_table_store_format = 'row';
sleep 5;
--disable_warnings
drop table if exists xingrui_table;
--enable_warnings
create table xingrui_table(col1 int, col2 int);

connection sys;
let $before_table_id = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_table' and tenant_id = $tenant_id, table_id, 1);

connection mysql;
alter table xingrui_table drop column col2;

connection sys;
let $after_table_id = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_table' and tenant_id = $tenant_id, table_id, 1);

if ($before_table_id != $after_table_id)
{
    --echo "!!!ERROR, tenant with C replica, drop column instant in mysql mode should do online ddl"
}

connection mysql;
alter system set default_table_store_format = 'compound';
sleep 5;
drop table xingrui_table;
create table xingrui_table(col1 int, col2 int);

connection sys;
let $before_table_id = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_table' and tenant_id = $tenant_id, table_id, 1);

connection mysql;
alter table xingrui_table drop column col2;
alter system set default_table_store_format = 'row';
sleep 2;

connection sys;
let $after_table_id = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_table' and tenant_id = $tenant_id, table_id, 1);

if ($before_table_id != $after_table_id)
{
    --echo "!!!ERROR, tenant with C replica, drop column instant in mysql mode should do online ddl"
}

#drop tenant if exists xingrui_mysql_tenant force;
#eval DROP RESOURCE POOL if exists $pool1;
#eval DROP RESOURCE UNIT if exists $unit1;
