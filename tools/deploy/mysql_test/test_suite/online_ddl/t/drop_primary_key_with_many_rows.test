# owner: jianyun.sjy
# owner group: storage
# description: Create a primary key table, load 10 million rows via table(generator),
#              run DROP PRIMARY KEY DDLs, then check hidden pk.

--disable_warnings
drop table if exists t1;
drop sequence if exists s1;
--enable_warnings

create table t1 (c1 bigint primary key, c2 bigint);
create sequence s1 cache 1000000 noorder;
set ob_query_timeout = 100000000000;
insert/*+ parallel(8) append enable_parallel_dml */ into t1 select s1.nextval c1, random() c2 from table(generator(10000000));
alter table t1 drop primary key;
select /*+opt_param('hidden_column_visible','true')*/  `__pk_increment` from t1 where `__pk_increment` % 5000000 = 0;

--disable_warnings
drop table if exists t1;
drop sequence if exists s1;
--enable_warnings

