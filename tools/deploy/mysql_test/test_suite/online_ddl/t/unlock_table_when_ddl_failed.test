--disable_warnings
DROP TABLE IF EXISTS Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(Z0_TEST0 TINYINT, Z0_TEST1 SMALLINT,Z0_TEST2 MEDIUMINT, Z0_TEST3 INT, Z0_TEST4 BIGINT);
INSERT INTO Z0CASE (z0_test0,z0_test1,Z0_TEST2,Z0_TEST3,z0_test4)values(0,0,0,0,0);
INSERT INTO Z0CASE (z0_test0,z0_test1,Z0_TEST2,Z0_TEST3,z0_test4)values(111,111,111,111,111);
INSERT INTO Z0CASE (z0_test0,z0_test1,Z0_TEST2,Z0_TEST3,z0_test4)values(127,127.333,127.333,127.333,127.333);
INSERT INTO Z0CASE (z0_test0,z0_test1,Z0_TEST2,Z0_TEST3,z0_test4)values(-3.3333,-128.333,-128.333,-128.333,-128.333);
INSERT INTO Z0CASE (z0_test0,z0_test1,Z0_TEST2,Z0_TEST3,z0_test4)values(-3.3333,-129.333,-129.333,-129.333,-129.333);

--error 1264
ALTER TABLE Z0CASE modify column Z0_TEST3 TINYINT default 0;
--error 1264
ALTER TABLE Z0CASE modify column Z0_TEST4 TINYINT default 0;
ALTER TABLE Z0CASE modify column Z0_TEST4 INT default 0;
INSERT INTO Z0CASE (z0_test0,z0_test1,Z0_TEST2,Z0_TEST3,z0_test4) values(-3.3333,-129.333,-129.333,-129.333,-129.333);
DESC Z0CASE;
