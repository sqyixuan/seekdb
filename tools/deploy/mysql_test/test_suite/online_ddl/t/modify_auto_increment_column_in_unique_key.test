# owner: zhenjiang.xzj
# owner group: storage
# description:this case test modify int to bigint, but the hash index uses old hash function
#
--disable_warnings
drop table if exists t1;

CREATE TABLE `t1` (
       `DBID_` bigint(20) NOT NULL AUTO_INCREMENT,
       `ID_` decimal(19,0) DEFAULT NULL COMMENT '编码ID',
       `TYPEKEY_` varchar(255) COLLATE gbk_bin NOT NULL COMMENT '类型名称，包括活动类型、Tab类型、属性类型',
       `NAME_` varchar(255) COLLATE gbk_bin DEFAULT NULL COMMENT '具体的含义名称',
       `PARENT_ID` decimal(19,0) DEFAULT NULL COMMENT '父编码',
       `VISIABLE_` decimal(1,0) DEFAULT '1' COMMENT '是否需要显示',
       `REQUIRED_` decimal(1,0) DEFAULT NULL COMMENT '必须配置项，节点必须参数',
       `REMARK_` varchar(512) COLLATE gbk_bin DEFAULT NULL COMMENT '关键配置介绍',
       `MODEL_ISVISIABLE_` decimal(1,0) DEFAULT '1' COMMENT '固化模型属性可见性',
       `MODEL_CANMODIFY_` decimal(1,0) DEFAULT '1' COMMENT '固化模型属性可修改性',
      `MODEL_CANDELETE_` decimal(1,0) DEFAULT NULL COMMENT '固化模型属性可删除性',
      `SYSTEM_ID_` varchar(255) COLLATE gbk_bin DEFAULT NULL COMMENT '系统号',
      `COMPANY_ID_` varchar(255) COLLATE gbk_bin DEFAULT NULL COMMENT '租户号',
      PRIMARY KEY (`DBID_`),
      UNIQUE KEY `CST_DESIGNCONFIG` (`ID_`, `SYSTEM_ID_`, `COMPANY_ID_`) BLOCK_SIZE 16384 LOCAL
    );

alter table t1 modify column DBID_ BIGINT auto_increment not null COMMENT '主键ID';
drop table t1;
