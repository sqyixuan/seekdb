# owner: liujixiong.ljx
# owner group: storage
# description: test ddl on generated column.

--disable_warnings
drop table if exists test;
--enable_warnings

create table test(c0 float, c1 float, c2 float as(c0/c1) virtual, c3 float as (c0/c1) stored, c4 int, c5 int);
insert into test (c0, c1, c4, c5) values(100, 80, 50, 30);

--echo virtual_column -> physical_stored_column: FORBIDDEN.
--error 3106
alter table test modify c3 float as (c0/c1) virtual;
--error 3106
alter table test modify c5 float as (c0/c1) virtual;

--echo physical_stored_column -> virtual_column: FORBIDDEN.
--error 3106
alter table test modify c2 float as (c0/c1) stored;
--error 3106
alter table test modify c2 float;

--echo FIXME, virtual_column -> virtual_column: ALLOW.
--error 1235
alter table test modify c2 int as (c0+c1) virtual;
alter table test modify c2 int as (c0/c1) virtual;

--echo FIXME, physical_stored_column -> physical_stored_column: ALLOW.
--error 1235
alter table test modify c3 int as (c0+c1) stored;
--error 3106
alter table test modify c5 int as(c0 / c1) stored;
alter table test modify c3 int as (c0 / c1) stored;

drop table test;