# owner: lihongqin.lhq
# owner group: storage
# description:this case is use for create index test
#
--disable_warnings
drop table if exists t1;
create table t1(id int primary key, name varchar(3000), age int, description varchar(3000)) compression='none' row_format = compact;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $database_id = query_get_value(select * from oceanbase.__all_virtual_database where database_name = 'test', database_id, 1);
let $tenant_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
disconnect obsys;
connection default;

let $table_size = 0;
let $pkey=0;
let $version=2;
let $i=0;
--disable_result_log
--disable_query_log
while($i < 10000)
{
  eval insert into t1 values($pkey, repeat(rand(),60), $i, repeat(rand(),60));
  inc $i;
  inc $pkey;
}
--enable_result_log
--enable_query_log

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

alter table t1 modify name text;

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $version = query_get_value(select LAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION,LAST_SCN,1);
let $table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1' and database_id = '$database_id', table_id, 1);
let $tablet_id = query_get_value(select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id, tablet_id, 1);

let $macro_block_cnt = `select multiplexed_macro_block_count from oceanbase.__all_virtual_tablet_compaction_history where tablet_id=$tablet_id and compaction_scn = '$version' limit 1`;
if ($macro_block_cnt > 4) {
  echo "alter column reuse macro block";
}
disconnect obsys;
connection default;

update t1 set name = 'oceanbase' where id = 10;
delete from t1 where id = 1000;
insert into t1 values(20000, 'oceanbase', 200, 'oceanbase');

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
drop table t1;
