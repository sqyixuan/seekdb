# owner: liujixiong.ljx
# owner group: storage
# description: this case is used to test the redefinition task when table contains foreign key.

# notice that the column c1 in t4 is not the first column.
connect (obsys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '100000s';
sleep 3;
set ob_global_debug_sync = 'reset';
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
--disable_warnings
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
drop table if exists t0;
--enable_warnings

--echo test offline_ddl/create_index/cst_task on child table when parent table is executing offline ddl.
connection conn1;
--disable_warnings
drop table if exists t1, t2;
--enable_warnings

connection obsys;
alter system set debug_sync_timeout = '100000s';
sleep 2;
set ob_global_debug_sync = 'TABLE_REDEFINITION_REPLICA_BUILD wait_for continue_signal execute 10000';
sleep 2;

connection default;
create table t1(c1 int primary key, c2 int);
create table t2(c1 int, c2 int, c3 int, c4 int auto_increment, constraint fk foreign key(c1) references t1(c1));
send alter table t1 modify c2 mediumint;

connection conn1;
sleep 5;
--error 4179
alter table t2 modify c3 mediumint;
--error 4179
alter table t2 drop column c4;
--error 4179
alter table t2 add index idx1 (c2);
--error 4179
create index idx2 on t2(c2);
--error 4179
alter table t2 add constraint chk check(c2 = c3);
--error 4179
alter table t2 add constraint fk2 foreign key(c2) references t1(c1);

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
sleep 2;

connection default;
reap;
drop table t2;
drop table t1;

--echo test offline_ddl/create_index/cst_task on child table when parent table is creating index.
connection conn1;
--disable_warnings
drop table if exists t1, t2;
--enable_warnings

connection obsys;
set ob_global_debug_sync = 'CREATE_INDEX_REPLICA_BUILD wait_for continue_signal execute 10000';
sleep 2;

connection default;
create table t1(c1 int primary key, c2 int);
create table t2(c1 int, c2 int, c3 int, c4 int auto_increment, constraint fk foreign key(c1) references t1(c1));
send create index idx on t1(c1);

connection conn1;
sleep 5;
--error 4179
alter table t2 modify c3 mediumint;
--error 4179
alter table t2 drop column c4;
alter table t2 add constraint chk check(c2 = c3);
alter table t2 add constraint fk2 foreign key(c2) references t1(c1);

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
sleep 2;

connection default;
reap;
drop table t2;
drop table t1;


--echo test offline_ddl/create_index/cst_task on parent table when child table is adding cst.
connection conn1;
--disable_warnings
drop table if exists t1, t2;
--enable_warnings

connection obsys;
set ob_global_debug_sync = 'CONSTRAINT_VALIDATE wait_for continue_signal execute 10000';
sleep 2;

connection default;
create table t0(c1 int primary key);
create table t1(c1 int primary key, c2 int, c3 int auto_increment);
create table t2(c1 int, c2 int, c3 int, constraint fk foreign key(c1) references t1(c1));
send alter table t2 add constraint fk2 foreign key(c1) references t0(c1);

connection conn1;
sleep 5;
--error 4179
alter table t1 modify c2 mediumint;
--error 4179
alter table t1 drop column c3;
alter table t1 add index idx1 (c2);
create index idx2 on t1(c2);

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
sleep 2;

connection default;
reap;
drop table t2;
drop table t1;
drop table t0;

--echo 
--echo 2. to test related table offline ddl, and then add fk, drop fk modify fk.
create table t0(c1 int primary key, c2 int);
create table t1(c1 int, c2 int, constraint cst_fk foreign key(c1) references t0(c1));
create table t2(c1 int, c2 int);

connection obsys;
set ob_global_debug_sync = 'TABLE_REDEFINITION_REPLICA_BUILD wait_for continue_signal execute 10000';
sleep 2;
connection default;
send alter table t0 modify c2 tinyint;

connection conn1;
sleep 5;
SET @@foreign_key_checks = 0;
--error 4179
alter table t1 drop constraint cst_fk;
--error 4179
alter table t2 add constraint cst_test_fk foreign key(c1) references t0(c1);

SET @@foreign_key_checks = 1;
--error 4179
alter table t1 drop constraint cst_fk;
--error 4179
alter table t2 add constraint cst_test_fk foreign key(c1) references t0(c1);

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
sleep 2;

connection default;
reap;

alter table t1 drop constraint cst_fk;
alter table t2 add constraint cst_test_fk foreign key(c1) references t0(c1);

drop table t2, t1, t0;


--echo 
--echo 3. to test related table online ddl, and then add fk, drop fk modify fk.
create table t0(c1 int primary key, c2 int);
create table t1(c1 int, c2 int, constraint cst_fk foreign key(c1) references t0(c1));
create table t2(c1 int, c2 int);

connection obsys;
set ob_global_debug_sync = 'CREATE_INDEX_WAIT_TRANS_END wait_for continue_signal execute 10000';
sleep 2;
connection default;
send create index idx_test on t0(c1, c2);

connection conn1;
sleep 5;
SET @@foreign_key_checks = 1;
alter table t1 drop constraint cst_fk;
alter table t2 add constraint cst_test_fk foreign key(c1) references t0(c1);

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
sleep 2;

connection default;
reap;

drop table t2, t1, t0;


--echo 
--echo 4. to test related table has constraint task, and then execute online ddl, offline ddl.
create table t0(c1 int primary key, c2 int);
create table t1(c1 int, c2 int);

connection obsys;
set ob_global_debug_sync = 'CONSTRAINT_WAIT_TRANS_END wait_for continue_signal execute 10000';
sleep 2;
connection default;
SET @@foreign_key_checks = 1;
send alter table t1 add constraint cst_fk foreign key(c1) references t0(c1);

connection conn1;
sleep 5;
create index idx_test on t0(c1, c2);
alter table t0 drop index idx_test;
--error 4179
alter table t0 modify c2 tinyint;

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
sleep 2;

connection default;
reap;

alter table t0 modify c2 tinyint;
drop table t1, t0;
