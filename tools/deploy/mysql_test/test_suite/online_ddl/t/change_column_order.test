# owner: lihongqin.lhq
# owner group: storage
# description:this case is use for test changing column order
#

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection default;

let $tenant_id = `select effective_tenant_id() from dual`;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

# basic
create table t1(c1 int, c2 smallint, c3 bigint);
insert into t1 values (1, 2, 3);
alter table t1 modify c1 char(11) before c3;
desc t1;
alter table t1 modify c3 char(13) first;
desc t1;
alter table t1 modify c2 char(12) after c1;
desc t1;
alter table t1 change c2 c2 int before c1;
desc t1;
select * from t1;

# change order and name, not supported
alter table t1 change c2 c2x int before c1;
--error 1054
alter table t1 change c1 c1x int after c1;
alter table t1 change c1 c1x int after c1x;
desc t1;

# invalid column name
--error 1054
alter table t1 modify c1 int after cx;

drop table t1;

# online ddl if no order changed
create table t1(c1 int, c2 int, c3 int as (c1 + c2));
insert into t1(c1, c2) values (1, 2);
alter table t1 change c1 c1x int first;
desc t1;
alter table t1 change c1x c1 int before c2;
desc t1;
alter table t1 change c2 c2x int after c1;
desc t1;
alter table t1 change c2x c2 int before c3;
desc t1;
alter table t1 change c3 c3x int as (c1 + c2) after c2;
desc t1;
select * from t1;
drop table t1;

# change generated column order
create table t1(c1 int, c2 int as (c1+1), c3 int as (c1) stored);
alter table t1 modify c2 int as ((c1 + 1)) first;
desc t1;
alter table t1 change c2 c2x int as (c1+1) after c1;
desc t1;
alter table t1 modify c2x int as (c1+1) before c3;
alter table t1 modify c3 int as (c1) stored first;
desc t1;
alter table t1 change c3 c3x int as (((c1))) stored before c1;
alter table t1 modify c3x int as (c1) stored after c2x;
desc t1;
drop table t1;

# case sensitive
create table t1(c1 int);
insert into t1 values (1);
alter table t1 add c2 int;
alter table t1 modify C2 char(10) first;
select * from t1;
alter table t1 modify C2 int after C1;
alter table t1 add c3 int after C2;
alter table t1 change C1 C1x int first;
desc t1;
alter table t1 change c1X c1 int before C2;
desc t1;
alter table t1 change C2 C2x int after C1;
desc t1;
drop table t1;

# hidden column
create table t1(c1 int, c2 char(10));
insert into t1 values (1, 'abc');
create index i1 on t1(c2(3));
alter table t1 add c3 int;
desc t1;
alter table t1 change c1 c1x int first;
desc t1;
alter table t1 change c1x c1 int before c2;
desc t1;
alter table t1 change c2 c2x char(10) after c1;
desc t1;
alter table t1 change c2x c2 char(10) before c3;
desc t1;
alter table t1 change c3 c3x int after c2;
desc t1;
drop table t1;

# primary key
create table t1(c1 int primary key, c2 smallint);
insert into t1 values (1, 2);
alter table t1 modify c1 int after c2;
drop table t1;

# joint primary key
create table t1(c1 int, c2 int, primary key (c1, c2));
insert into t1 values (1, 2);
insert into t1 values (2, 1);
alter table t1 modify c1 char(10) after c2;
select * from t1;
drop table t1;

# generated columns
create table t1(c1 int, c2 int, c3 int as (c1 + c2));
insert into t1(c1, c2) values (1, 2);
--error 1235,3106
alter table t1 modify c1 int as (c2 + 2) after c3;
--error 1235,3106
alter table t1 modify c3 int as (c1 - c2) before c2;
alter table t1 modify c3 int as (c1 + c2) before c2;
select * from t1;
insert into t1(c1, c2) values (3, 4);
select * from t1;
drop table t1;

# non-partition table with index
create table t1(c1 int, c2 smallint, c3 bigint);
insert into t1 values (1, 2, 3);
insert into t1 values (11, 9, -1);
insert into t1 values (31, 42, 33);
create index i1 on t1(c1);
create index i2 on t1(c2);
create index i3 on t1(c3);
alter table t1 modify c1 char(10) after c3;
create index i3_x on t1(c3);
select c1 from t1 where c1 = 1 order by c1;
select c2 from t1 where c2 = 9 order by c2;
select c3 from t1 where c3 = -1 order by c3;
drop table t1;

# partition table
create table t1(c1 int, c2 int, c3 int) partition by hash(c1) subpartition by hash(c2);
insert into t1 values (1, 2, 4);
insert into t1 values (10, -10, 33);
alter table t1 modify c1 smallint after c3;
select * from t1 order by c1;
drop table t1;

# partition table with index
create table t1(c1 int, c2 int, c3 char(10)) partition by range(c2) subpartition by hash(c1)
subpartitions 3 (
    partition p0 values less than (5),
    partition p1 values less than (10),
    partition p2 values less than maxvalue
);
insert into t1 values (1, 2, 'ab');
insert into t1 values (2, 3, 'abc');
insert into t1 values (5, 5, 'abcd');
insert into t1 values (6, -10, '12 ');
insert into t1 values (10, 10, '12 a');
insert into t1 values (11, 15, '12    a');
insert into t1 values (100, -15, null);
create index i1 on t1(c2, c3(3));
alter table t1 modify c1 smallint after c3;
select * from t1 order by c1;
drop table t1;

# with constraint unique
create table t1(c1 int unique, c2 int);
insert into t1 values (1, 2);
alter table t1 modify c2 int first;
insert into t1 values (1, 2);
--error 1062
insert into t1 values (1, 1);
--error 1062
insert into t1 values (2, 1);
drop table t1;

# with constraint not null
create table t1(c1 int, c2 int not null);
insert into t1 values (1, 2);
alter table t1 modify c1 int after c2;
insert into t1 values (1, null);
--error 1048
insert into t1 values (null, 1);
drop table t1;

# with foreign key case 1
create table t1(c1 int primary key, c2 smallint, c3 bigint);
insert into t1 values (0, 1, 4);
insert into t1 values (2, 3, 5);
create table t2(c1 int, c2 int, foreign key (c2) references t1(c1));
insert into t2 values (1, 0);
--error 1452
insert into t2 values (0, 1);
alter table t2 modify c1 int after c2;
insert into t2 values (2, 3);
--error 1452
insert into t2 values (3, 2);
desc t1;
select * from t2 order by c1;
drop table t2;
drop table t1;

# with foreign key case 2
create table t1(c1 int, c2 smallint, c3 bigint, primary key(c2, c1));
create table t2(c1 int primary key, c2 smallint, c3 bigint, foreign key (c1, c2) references t1(c1, c2));
insert into t1 values (1, 2, 3);
insert into t2 values (1, 2, 3);
alter table t1 modify c3 int first;
drop table t2;
drop table t1;

# empty table
create table t1(c1 int, c2 smallint, c3 bigint);
alter table t1 modify c1 char(10) after c3;
insert into t1 values (2, 3, '1');
select * from t1;
drop table t1;

# order not changed
create table t1(c1 int, c2 smallint, c3 bigint);
insert into t1 values (1, 2, 3);
alter table t1 modify c1 int first;
desc t1;
alter table t1 modify c1 int before c1;
desc t1;
alter table t1 modify c1 int after c1;
desc t1;
alter table t1 modify c2 int before c3;
desc t1;
alter table t1 modify c2 int after c1;
desc t1;
alter table t1 modify c3 int before c3;
desc t1;
alter table t1 modify c3 int after c3;
desc t1;
select * from t1;
drop table t1;

# single column
create table t1(c1 int);
alter table t1 modify c1 int first;
desc t1;
alter table t1 modify c1 int before c1;
desc t1;
alter table t1 modify c1 int after c1;
desc t1;
drop table t1;

--echo column id of partition key, hidden columns, shadow columns, index
create table t1(c1 char(10), C2 int, c3 char(10) as (c1 + c2), c4 int) partition by hash(c2) partitions 3;
insert into t1(c1, c2) values ("1", 2);
create index i1 on t1(c2, c1) local;
create index i2 on t1(c1(3)) local;
create unique index i3 on t1(c1(4), c2) local;
create index i4 on t1(c1(2)) global;
create index i5 on t1(c2, c3, c1) global partition by hash(c2) partitions 10;
create index i6 on t1(c2, c1) storing(c3, c2) local;
create index i7 on t1(c3, c1) storing(c1, c2) local;

insert into t1(c1, c2, c4) values ("11", 12, 13);
insert into t1(c1, c2, c4) values ("21", 22, 23);
insert into t1(c1, c2, c4) values ("31", 32, 33);

alter table t1 change c2 c2 int first;
alter table t1 change c2 c2 int after c1;
--source include/check_table_schema.inc

alter table t1 change c1 c1 char(10) default "abc";
alter table t1 change c2 c2 int default 100;
alter table t1 change c2 C2 int;
alter table t1 change c4 c4 int default 200;
--source include/check_table_schema.inc

create index i10 on t1(c4);
alter table t1 change c4 c4 int first;
--source include/check_table_schema.inc

alter table t1 drop c4;
--source include/check_table_schema.inc

insert into t1(c1, c2) values ("41", 42);
select /*+ index(t1 i1) */ * from t1 order by c1, c2, c3;
select /*+ index(t1 i2) */ * from t1 order by c1, c2, c3;
select /*+ index(t1 i3) */ * from t1 order by c1, c2, c3;
select /*+ index(t1 i4) */ * from t1 order by c1, c2, c3;
select /*+ index(t1 i5) */ * from t1 order by c1, c2, c3;
select /*+ index(t1 i6) */ * from t1 order by c1, c2, c3;
select /*+ index(t1 i7) */ * from t1 order by c1, c2, c3;

drop table t1;

--echo test index column order after ddl
create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int);
create index i1 on t1(c4, c1, c10, c3, c2, c6) storing (c3, c9, c8, c2, c7);
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;

alter table t1 modify c2 char(10);

--source mysql_test/include/show_create_table_old_version.inc
show create table t1;

alter table t1 change c1 c1 int comment "comment 1"; 
alter table t1 change c2 c2 int comment "comment 2"; 
alter table t1 change c3 c3 int comment "comment 3"; 
alter table t1 change c4 c4 int comment "comment 4"; 
alter table t1 change c5 c5 int comment "comment 5"; 
alter table t1 change c6 c6 int comment "comment 6"; 
alter table t1 change c7 c7 int comment "comment 7"; 
alter table t1 change c8 c8 int comment "comment 8"; 
alter table t1 change c9 c9 int comment "comment 9"; 
alter table t1 change c10 c10 int comment "comment 10"; 

--source mysql_test/include/show_create_table_old_version.inc
show create table t1;

--source include/check_table_schema.inc

drop table t1;

create table t1(col_11805 char(168), col_11807 int, col_11808 bigint unsigned, col_11809 decimal (4, 3), col_11810 int, col_11811 float, col_11823 smallint, col_11824 json not null, col_11825 char(253), col_11826 bit(22), col_11827 json, col_11828 varbinary(471), col_11871 json, col_11872 time, col_11873 bit(15), col_11874 json, col_11875 tinyint, col_11876 mediumint, col_11883 tinyint, key idx_160(col_11825(1), col_11809) local) partition by hash(col_11807) partitions 300;
call dbms_stats.gather_table_stats(NULL, 't1');
alter table t1 add column col_22202 char(147) before col_11874;
drop table t1;

--echo
--echo # modify not null and change column order
CREATE TABLE t1(c0 INT(5),c1 FLOAT);
ALTER TABLE t1 MODIFY c0 INT(4) ZEROFILL NOT NULL DEFAULT 0 AFTER c1;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop table t1;

--echo
--echo # modify check constraint and change column order
create table t1(c1 int, c2 int);
alter table t1 modify c1 int check(c1<10) after c2;
select column_name from oceanbase.__all_column where (table_id,column_id) in (select table_id,column_id from oceanbase.__all_tenant_constraint_column where table_id = (select table_id from oceanbase.__all_table where table_name = 't1')) order by 1;
alter table t1 drop column c2;
select column_name from oceanbase.__all_column where (table_id,column_id) in (select table_id,column_id from oceanbase.__all_tenant_constraint_column where table_id = (select table_id from oceanbase.__all_table where table_name = 't1')) order by 1;
drop table t1;

