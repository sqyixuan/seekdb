# owner: lihongqin.lhq
# owner group: storage
# description:this case is use for test modify varchar to char
#
--disable_warnings
--disable_query_log
--source mysql_test/include/index_quick_major.inc

drop table if exists test01;
create table test01 (c1 int, c2 char(10), primary key(c1));
let $cnt =1;
while ($cnt < 10)
{
	eval insert into test01(c1, c2) values($cnt, 'oceanbase');
	inc $cnt;
}

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--disable_result_log
while ($cnt < 20)
{
	eval insert into test01(c1, c2) values($cnt, 'oceanbase');
	inc $cnt;
}

while ($cnt < 30)
{
	eval insert into test01(c1, c2) values($cnt, 'oceanbase');
	inc $cnt;
}
--enable_result_log

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $data_table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 'test01' and tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = '$TENANT'), table_id, 1);
disconnect obsys;
connection default;
alter table test01 modify c2 varchar(20);
alter table test01 modify c2 tinytext;
alter table test01 modify c2 text;
alter table test01 modify c2 mediumtext;
alter table test01 modify c2 longtext;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--sleep 3
drop table test01;
