# owner: lihongqin.lhq
# owner group: storage
# description: this case is use for testing create index on column with empty chars
#

--disable_warnings
drop table if exists t1;
--enable_warnings

# local index
create table t1(c1 char(10), c2 varchar(10));
insert into t1 values (' ', ' ');
insert into t1 values ('', '');
insert into t1 values (null, null);

select * from t1 where c1 = ' ';
select * from t1 where c1 = '';
select * from t1 where c1 is null;
select * from t1 where c2 = ' ';
select * from t1 where c2 = '';
select * from t1 where c2 is null;

create index i1 on t1(c1);
select c1 from t1 where c1 = ' ';
select c1 from t1 where c1 = '';
select c1 from t1 where c1 is null;
create index i2 on t1(c2);
select c2 from t1 where c2 = ' ';
select c2 from t1 where c2 = '';
select c2 from t1 where c2 is null;

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

drop table t1;

# mysql has no global index

# local unique index
create table t1(c1 char(10), c2 varchar(10));
insert into t1 values (' ', ' ');
insert into t1 values ('', '');
insert into t1 values (null, null);
select * from t1 where c1 = ' ';
select * from t1 where c1 = '';
select * from t1 where c1 is null;
select * from t1 where c2 = ' ';
select * from t1 where c2 = '';
select * from t1 where c2 is null;
drop table t1;

create table t1(c1 char(10), c2 varchar(10));
insert into t1 values (' ', ' ');
insert into t1 values ('', '');
--error 1062
create unique index i1 on t1(c1);
--error 1062
create unique index i2 on t1(c2);
drop table t1;

create table t1(c1 char(10), c2 varchar(10));
insert into t1 values ('', '');
insert into t1 values (null, null);
create unique index i1 on t1(c1);
select c1 from t1 where c1 = '';
select c1 from t1 where c1 is null;
create unique index i2 on t1(c2);
select c2 from t1 where c2 = '';
select c2 from t1 where c2 is null;

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

drop table t1;

create table t1(c1 char(10), c2 varchar(10));
insert into t1 values (' ', ' ');
insert into t1 values (null, null);
create unique index i1 on t1(c1);
select c1 from t1 where c1 = ' ';
select c1 from t1 where c1 is null;
create unique index i2 on t1(c2);
select c2 from t1 where c2 = ' ';
select c2 from t1 where c2 is null;

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

