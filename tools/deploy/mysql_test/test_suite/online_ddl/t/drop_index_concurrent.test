# owner: liujixiong.ljx
# owner group: storage
# description: this test is used to test the drop index concurrently triggered by user and internal.

--disable_warnings
connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '60s';
sleep 3;
set ob_global_debug_sync = 'reset';
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--echo 
--echo CASE 1. index is dropped by user firstly, use `drop index` syntax.
connection obsys;
set ob_global_debug_sync = 'CREATE_INDEX_FAILED wait_for continue_signal execute 10000';
sleep 10;

connection conn1;
DROP TABLE IF EXISTS T1;
CREATE TABLE T1(C1 INT, C2 INT);
INSERT INTO T1 VALUES(1, 1), (1, 2);
send CREATE UNIQUE INDEX IDX1 ON T1(C1);
sleep 3;

connection conn2;
## user cannot drop building index.
--error 1235
DROP INDEX IDX1 ON T1;

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
sleep 3;

connection conn1;
--error 1062
reap;
DROP TABLE T1;

--echo 
--echo CASE 2. index is dropped by user firstly, use `alter table drop index` syntax.
connection obsys;
set ob_global_debug_sync = 'CREATE_INDEX_FAILED wait_for continue_signal execute 10000';
sleep 3;

connection conn1;
DROP TABLE IF EXISTS T1;
CREATE TABLE T1(C1 INT, C2 INT);
INSERT INTO T1 VALUES(1, 1), (1, 2);
send CREATE UNIQUE INDEX IDX1 ON T1(C1);
sleep 3;

connection conn2;
## user cannot drop building index.
--error 1235
ALTER TABLE T1 DROP INDEX IDX1;

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
sleep 3;

connection conn1;
--error 1062
reap;
DROP TABLE T1;

--echo 
--echo CASE 3. index is dropped by user firstly, use `alter table drop index` syntax with complex ddl.
connection obsys;
set ob_global_debug_sync = 'CREATE_INDEX_FAILED wait_for continue_signal execute 10000';
sleep 3;

connection conn1;
DROP TABLE IF EXISTS T1;
CREATE TABLE T1(C1 INT, C2 INT);
INSERT INTO T1 VALUES(1, 1), (1, 2);
send CREATE UNIQUE INDEX IDX1 ON T1(C1);
sleep 3;

connection conn2;
## user cannot drop building index.
--error 4179
ALTER TABLE T1 DROP INDEX IDX1, ADD INDEX IDX2 (C2), ADD COLUMN C3 INT;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE T1;

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
sleep 3;

connection conn1;
--error 1062
reap;
DROP TABLE T1;


--echo 
--echo CASE 4. index is dropped by internal firstly.
DROP TABLE IF EXISTS T1;
CREATE TABLE T1(C1 INT, C2 INT);
INSERT INTO T1 VALUES(1, 1), (1, 2);
--error 1062
CREATE UNIQUE INDEX IDX1 ON T1(C1);
--error 1091
ALTER TABLE T1 DROP INDEX IDX1;
--error 1091
DROP INDEX IDX1 ON T1;
