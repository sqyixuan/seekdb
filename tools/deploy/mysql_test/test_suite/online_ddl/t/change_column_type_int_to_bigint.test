# owner: lihongqin.lhq
# owner group: storage
# description:this case is use for create index test
#
--disable_warnings
drop table if exists t1;
create table t1(id int primary key, name int, age int unsigned, description varchar(65525)) tablet_size=104857600 compression='none' row_format = compact;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tenant_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $database_id = query_get_value(select * from oceanbase.__all_virtual_database where database_name = 'test', database_id, 1);
let $data_table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1' and database_id = '$database_id', table_id, 1);
disconnect obsys;
connection default;

# prepare data
let $table_size = 0;
let $pkey=0;
while($table_size < 7291456)
{
  let $i=0;
  while($i < 10000)
  {
    --disable_query_log
    --disable_result_log
    eval insert into t1 values($pkey, $pkey, 0, repeat(rand(), 900));
    --enable_query_log
    --enable_result_log
    inc $i;
    inc $pkey;
  }
  --source mysql_test/include/tenant_major_freeze.inc
  --source mysql_test/include/wait_daily_merge.inc
  connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
  connection obsys;
 let $data_tablet_id = query_get_value(select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $data_table_id, tablet_id, 1);
 let $table_size = query_get_value(select sum(size) as sz from oceanbase.__all_virtual_table_mgr where tablet_id in (
 select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $data_table_id), sz, 1);
  disconnect obsys;
  connection default;
}

--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_daily_merge.inc

let $cnt=0;
while ($cnt < 20)
{
  eval insert into t1 values($pkey, $pkey, 0, repeat(rand(), 900));
  inc $cnt;
  inc $pkey;
}

update t1 set name = name + 10 where id = 3000;

--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_daily_merge.inc

update t1 set name = 1000 where id = 2000;
alter table t1 modify name bigint;
alter table t1 modify age bigint unsigned;

--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_daily_merge.inc

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $version = query_get_value(select MAX(frozen_scn) as last_merged_version from oceanbase.__all_virtual_freeze_info where tenant_id = '$tenant_id',last_merged_version,1);
let $table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1' and database_id = '$database_id', table_id, 1);
let $tablet_id = query_get_value(select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id, tablet_id, 1);

let $macro_block_cnt = `select multiplexed_macro_block_count from oceanbase.__all_virtual_tablet_compaction_history where tablet_id=$tablet_id and compaction_scn = $version limit 1`;
if ($macro_block_cnt >= 75)
{
  echo "modify column with reuse macro block";
}
disconnect obsys;
connection default;
select id, name from t1 where id > 4000 and id < 4010;
create index i1 on t1(name);
create index i2 on t1(age);
--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_daily_merge.inc
drop table t1;
