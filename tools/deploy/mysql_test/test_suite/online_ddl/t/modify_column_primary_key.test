# owner: lihongqin.lhq
# owner group: storage
# description: modify column primary key

set sql_mode = "STRICT_TRANS_TABLES";

--disable_warnings
drop table if exists t1;
--enable_warnings

# basic case
create table t1(c1 int);
insert into t1 values (1);
insert into t1 values (123);
alter table t1 modify c1 char(10) primary key;
select * from t1;
drop table t1;

# with index
create table t1(c1 int, c2 int, c3 int);
insert into t1 values (1, 1, 1);
insert into t1 values (2, 2, 2);
insert into t1 values (3, 3, 3);
create index i1 on t1(c2, c1);
alter table t1 modify c3 char(10) primary key;
select * from t1 where c2 = 2;
drop table t1;

# duplicate primary key
create table t1(c1 int, c2 int);
--error 1068
alter table t1 modify c1 int primary key, modify c2 int primary key;
--error 1068
alter table t1 modify c1 int primary key, add c3 int primary key;
--error 1235
alter table t1 add c3 int primary key, modify c1 int primary key;
alter table t1 modify c1 int primary key;
--error 1068
alter table t1 modify c2 int primary key;
drop table t1;

# modify newly added column to primary key
create table t1(c1 int);
insert into t1 values (1);
--error 1054
alter table t1 add c0 int first, modify c0 char(10) primary key;
drop table t1;

# null primary key
# FIXME: mysql returns 1265
create table t1(c1 int);
insert into t1 values (null);
--error 1138
alter table t1 modify c1 bigint primary key;
--error 1138
alter table t1 modify c1 char(10) primary key;
drop table t1;

# lob cannot be primary key
# FIXME: mysql returns 1170
create table t1(c1 int);
--error 1167
alter table t1 modify c1 tinytext primary key;
--error 1167
alter table t1 modify c1 text primary key;
--error 1167
alter table t1 modify c1 mediumtext primary key;
--error 1167
alter table t1 modify c1 text primary key;
--error 1167
alter table t1 modify c1 blob primary key;
drop table t1;

# partition key as primary key
create table t1(c1 char(10)) partition by key(c1);
insert into t1 values ('1');
insert into t1 values ('2');
insert into t1 values ('3');
alter table t1 modify c1 int primary key;
select * from t1 order by c1;
--error 1048
insert into t1 values (null);
drop table t1;

# stored generated column as primary key
# FIXME: mysql succeeds
create table t1(c1 int, c2 int, c3 int) partition by hash(c3);
insert into t1 values (2, 1, 3);
insert into t1 values (1, 2, 3);
--error 3106
alter table t1 modify c3 int as (c1 + c2) stored primary key;
drop table t1;

# virtual generated column as primary key
create table t1(c1 int, c2 int, c3 int as (c1-c2));
insert into t1 (c1, c2) values (1, 1);
--error 3106
alter table t1 modify c3 int as(c1+c2) primary key;
drop table t1;

# drop primary key
create table t1(c1 int);
insert into t1 values (1);
alter table t1 modify c1 char(10) primary key;
alter table t1 drop primary key;
--error 1048
insert into t1 values (null);
drop table t1;
