create table t1_ddl_prog(c1 int primary key, c2 int);
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $progressive_merge_round = `select progressive_merge_round from oceanbase.__all_virtual_table where table_name = 't1_ddl_prog' and tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = '$TENANT')`;
echo $progressive_merge_round;
disconnect obsys;
connection default;

