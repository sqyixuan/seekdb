#owner: lihongqin.lhq
#owner group: storage
#description: Alter table with generated columns.
#tags: ddl

# Case 1: Alter table with virtual generated columns.
--disable_warnings
drop table if exists test;
--enable_warnings

create table test(c1 int, c2 int, c3 int as (c1 + c2) VIRTUAL);

insert into test(c1, c2) values (1, '2');
insert into test(c1, c2) values (10, '20');

alter table test modify c1 char(100);
select * from test;
drop table test;

# Case 2: Alter table with stored generated columns.
--disable_warnings
drop table if exists test;
--enable_warnings

create table test(c1 int, c2 int, c3 int as (c1 + c2) STORED);

insert into test(c1, c2) values (1, '2');
insert into test(c1, c2) values (10, '20');

alter table test modify c1 char(100);
select * from test;
