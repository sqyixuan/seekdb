# owner: lihongqin.lhq
# owner group: storage
# description: this case is use for verifying that if user views and tables have filtered hidden table information in oceanbase mysql mode
#

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop database if exists db;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '120s';
alter system set _ob_ddl_timeout = '1000s';
alter system set rpc_timeout = '1000s';
sleep 3;
set ob_global_debug_sync = 'reset';
connect (conn,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--echo
--echo #create table t1, t2 , create constraint on t1
connection default;
create table t1(c0 int, c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int) partition by range(c1)
subpartition by range(c0)
(
  partition p0 values less than (10000000)
  (
    subpartition p0sp0 values less than (10000000),
    subpartition p0sp1 values less than (20000000),
    subpartition p0sp2 values less than (30000000)
  ),
  partition p1 values less than (20000000)
  (
    subpartition p1sp0 values less than (10000000),
    subpartition p1sp1 values less than (20000000),
    subpartition p1sp2 values less than (30000000)
  ),
  partition p2 values less than (30000000)
  (
    subpartition p2sp0 values less than (10000000),
    subpartition p2sp1 values less than (20000000),
    subpartition p2sp2 values less than (30000000)
  )
);
create table t2(i int auto_increment, k bigint, primary key(i)) partition by hash(i) partitions 128;
ALTER TABLE t1 ADD CONSTRAINT users_fk FOREIGN KEY (c1) REFERENCES t2 (i) ON UPDATE RESTRICT ON DELETE CASCADE;
sleep 3;

--echo
--echo #create index on t1, t2, alter table t1 drop column c2
connection default;
create index idx0 on t1(c0) global;
create index idx1 on t1(c1) global;
create index idx2 on t1(c2) local;
create index idx3 on t1(c3) local;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'TABLE_REDEFINITION_REPLICA_BUILD wait_for continue_signal execute 10000';
connection default;
send alter table t1 drop column c2;
sleep 3;

--echo
--echo #check views and tables have filtered hidden table information
--echo
--echo #check mysql tenant's database oceanbase whether have been filtered hidden table information in view and table.
connection conn;
set ob_query_timeout=10000000000;
let $sub_query_hidden_table = select table_name from oceanbase.__all_table where table_name like '%hidden%';
let $sub_query_hidden_table_id = select table_id from oceanbase.__all_table where table_name like '%hidden%';
let $sub_query_tablet_id = select tablet_id from oceanbase.__all_tablet_to_ls where table_id in ($sub_query_hidden_table_id);
let $sub_query_normal_table = select table_name from oceanbase.__all_table where table_mode >> 12 & 15 in (0,1);
eval select count(*) from oceanbase.__all_table where table_name in ($sub_query_hidden_table) ;

eval select count(*) from oceanbase.DBA_RECYCLEBIN where original_name in ($sub_query_hidden_table) ;
#eval select count(*) from oceanbase.V\$OB_ENCRYPTED_TABLES where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_OB_TABLET_TO_LS where tablet_id in ($sub_query_tablet_id) ;
eval select count(*) from oceanbase.DBA_OB_TABLEGROUP_TABLES where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_OBJECTS where object_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_PART_TABLES where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_PART_KEY_COLUMNS where name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_SUBPART_KEY_COLUMNS where name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_TAB_PARTITIONS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_TAB_SUBPARTITIONS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_SUBPARTITION_TEMPLATES where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_PART_INDEXES where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_IND_PARTITIONS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_IND_SUBPARTITIONS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_TAB_STATISTICS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_TAB_COL_STATISTICS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_PART_COL_STATISTICS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_SUBPART_COL_STATISTICS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_TAB_HISTOGRAMS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_PART_HISTOGRAMS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_SUBPART_HISTOGRAMS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_TAB_STATS_HISTORY where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_IND_STATISTICS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_TAB_MODIFICATIONS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_OB_KV_TTL_TASKS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_OB_KV_TTL_TASK_HISTORY where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_OB_TABLE_OPT_STAT_GATHER_HISTORY where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_OB_EXTERNAL_TABLE_FILES where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.ALL_OB_EXTERNAL_TABLE_FILES where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.DBA_OB_TABLE_STAT_STALE_INFO where table_name in ($sub_query_hidden_table) ;
sleep 2;
--echo
--echo #check mysql tenant's database information_schema whether have been filtered hidden table information in view and table.
connection conn;
set ob_query_timeout=10000000000;
eval select count(*) from information_schema.STATISTICS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from information_schema.VIEWS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from information_schema.TABLES where table_name in ($sub_query_hidden_table) ;
eval select count(*) from information_schema.KEY_COLUMN_USAGE where table_name in ($sub_query_hidden_table) ;
eval select count(*) from information_schema.VIEW_TABLE_USAGE where table_name in ($sub_query_hidden_table) ;
eval select count(*) from information_schema.REFERENTIAL_CONSTRAINTS where table_name in ($sub_query_hidden_table)  or referenced_table_name in ($sub_query_hidden_table) ;
eval select count(*) from information_schema.TABLE_CONSTRAINTS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from information_schema.TRIGGERS where event_object_table in ($sub_query_hidden_table) ;
eval select count(*) from information_schema.PARTITIONS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from information_schema.ST_GEOMETRY_COLUMNS where table_name in ($sub_query_hidden_table) ;

--echo
--echo #check sys tenant's database oceanbase whether have been filtered hidden table information in view and table.
connection obsys;
set ob_query_timeout=10000000000;
eval select count(*) from oceanbase.CDB_OB_TABLEGROUP_TABLES where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_OBJECTS where object_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_TABLES where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_TAB_COLS_V\$ where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_INDEXES where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_IND_COLUMNS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_PART_TABLES where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_TAB_PARTITIONS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_TAB_SUBPARTITIONS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_SUBPARTITION_TEMPLATES where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_PART_KEY_COLUMNS where name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_SUBPART_KEY_COLUMNS where name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_PART_INDEXES where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_IND_PARTITIONS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_IND_SUBPARTITIONS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_OB_KV_TTL_TASKS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_OB_KV_TTL_TASK_HISTORY where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_OB_TABLE_LOCATIONS where table_name in ($sub_query_hidden_table) ;
eval select count(*) from oceanbase.CDB_OB_EXTERNAL_TABLE_FILES where table_name in ($sub_query_hidden_table) ;

connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection default;
reap;
