# owner: lihongqin.lhq
# owner group: storage
# description:this case is use for test add subpartition to paritions
#
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (Z0_TEST0 int, Z0_TEST1 varchar(100)) partition by key (Z0_TEST0) (partition p1, partition p2, partition p3);

INSERT INTO t1 (Z0_TEST0,Z0_TEST1) values(-1,'111');
INSERT INTO t1 (Z0_TEST0,Z0_TEST1) values(0,'111');
INSERT INTO t1 (Z0_TEST0,Z0_TEST1) values('111','111');

alter table t1 partition by key(Z0_TEST0) subpartition by key(Z0_TEST1, Z0_TEST0) (partition part_1, partition part_2);

drop table t1;