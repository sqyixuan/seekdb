# owner: lihongqin.lhq
# owner group: storage
# description:this case is use for create index test
#
--disable_warnings
drop table if exists t1;
create table t1(id int primary key, name varchar(15), age int, description varchar(65525)) tablet_size=104857600 compression='none' row_format = compact;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);
let $database_id = query_get_value(select * from oceanbase.__all_virtual_database where database_name = 'test' and tenant_id = '$tenant_id', database_id, 1);
let $data_table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1' and database_id = '$database_id' and tenant_id = '$tenant_id', table_id, 1);
disconnect obsys;
connection default;

# prepare data
let $table_size = 0;
let $pkey=0;
let $i = 0;
while($i < 10000)
{
  --disable_query_log
    --disable_result_log
    eval insert into t1 values($pkey, 'oceanbase', 0, repeat(rand(), 900));
  --enable_query_log
    --enable_result_log
    inc $i;
  inc $pkey;
}
--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $table_size = query_get_value(select sum(size) as sz from oceanbase.__all_virtual_table_mgr where tablet_id in (
  select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $data_table_id), sz, 1);
disconnect obsys;
connection default;

--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc

let $cnt=0;
while ($cnt < 20)
{
  eval insert into t1 values($pkey, 'oceanbase', 0, repeat(rand(), 900));
  inc $cnt;
  inc $pkey;
}

update t1 set name = 'oceanbase_v5' where id = 3000;

--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc

update t1 set name = 'oceanbase_v5' where id = 2000;
alter table t1 modify name varchar(20);

--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $version = query_get_value(select MAX(frozen_scn) as last_merged_version from oceanbase.__all_virtual_freeze_info where tenant_id = '$tenant_id',last_merged_version,1);
let $table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1' and database_id = '$database_id' and tenant_id = '$tenant_id', table_id, 1);
let $ls_id = query_get_value(select ls_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id, ls_id, 1);
let $tablet_id = query_get_value(select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id, tablet_id, 1);

let $macro_block_cnt = `select multiplexed_macro_block_count from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$tenant_id and ls_id=$ls_id and tablet_id=$tablet_id and compaction_scn = $version limit 1`;
if ($macro_block_cnt > 75)
{
  echo "alter column reuse macro block";
}
disconnect obsys;
connection default;
select id, name from t1 where id > 4000 and id < 4010;
drop table t1;
