# owner: liujixiong.ljx
# owner group: storage
# description: this case is used for test changing the column type in the partitions.

# key分区, 分区键是主键, 测试修改分区键类型(bigint->int->char(1)->char(5)->char(20)->float->double->float->int->char(5))
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 bigint, c2 float) partition by key(c1) partitions 3;
insert into t1 values(1, 10);
insert into t1 values(30, 20);
insert into t1 values(15, 30);
alter table t1 modify column c1 int;
--error 1406
alter table t1 modify column c1 char(1);
alter table t1 modify column c1 char(5);
alter table t1 modify column c1 char(20);
alter table t1 modify column c1 float;
alter table t1 modify column c1 double;
alter table t1 modify column c1 float;
alter table t1 modify column c1 int;
drop table t1;

# key分区, 分区键是主键, 测试修改分区键类型(bigint->int->char(1)->char(5)->char(20)->float->double->float->int->char(5))
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 bigint primary key, c2 float) partition by key(c1) partitions 3;
insert into t1 values(1, 10);
insert into t1 values(30, 20);
insert into t1 values(15, 30);
alter table t1 modify column c1 int;
--error 1406
alter table t1 modify column c1 char(1);
alter table t1 modify column c1 char(5);
alter table t1 modify column c1 char(20);
alter table t1 modify column c1 float;
alter table t1 modify column c1 double;
alter table t1 modify column c1 float;
alter table t1 modify column c1 int;
drop table t1;

# hash分区, 分区键是主键, 测试修改分区键类型(bigint->int->char(5), float, double)
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 bigint primary key, c2 float) partition by hash(c1) partitions 3;
insert into t1 values(1, 10);
insert into t1 values(30, 20);
insert into t1 values(15, 30);
alter table t1 modify column c1 int;
--error 1659
alter table t1 modify column c1 char(5);
--error 1659
alter table t1 modify column c1 float;
--error 1659
alter table t1 modify column c1 double;
drop table t1;

--echo
--echo /// [bugfix]
create table t1(c0 float,
c1 int,
c2 varchar(10))
PARTITION BY RANGE COLUMNS(c2)
SUBPARTITION BY HASH(c1) SUBPARTITIONS 4
(PARTITION r1 values less than('10'),
partition r2 values less than('20'),
partition r3 values less than('30'),
partition r4 values less than('40'));
INSERT INTO t1 VALUES(1,1,'1'),(2,2,'2'),(3,0,'3'),(4,-20,'-5'),(5,6,'-10'),(6,-10,'11'),(7,7,'15');
alter table t1 modify c2 varchar(10) default '0' not null;
drop table t1;
