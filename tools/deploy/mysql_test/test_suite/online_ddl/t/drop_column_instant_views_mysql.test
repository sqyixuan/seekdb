# owner: xingrui.cwh
# owner group: RS
# CASE_DESC:
#    验证mysql快速删列相关视图
connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection sys;
alter system set _enable_add_fulltext_index_to_existing_table = false;
sleep 5;
connection mysql;
alter system set default_table_store_format = 'compound';
sleep 5;

connection mysql;
--error 0,1051
drop table xingrui_normal_table;
create table xingrui_normal_table(col1 int, col2 int, col3 int);
connection sys;
select column_name from CDB_TAB_COL_STATISTICS where table_name = "xingrui_normal_table" order by column_name;
select column_name from CDB_TAB_COLS where table_name = "xingrui_normal_table" order by column_name;
select column_name from CDB_TAB_COLS_V$ where table_name = "xingrui_normal_table" order by column_name;
select column_name from information_schema.columns where table_name = "xingrui_normal_table" order by column_name;
connection mysql;
show columns from xingrui_normal_table;

connection mysql;
alter table xingrui_normal_table drop column col1;

--echo #删列之后
connection sys;
select column_name from CDB_TAB_COL_STATISTICS where table_name = "xingrui_normal_table" order by column_name;
select column_name from CDB_TAB_COLS where table_name = "xingrui_normal_table" order by column_name;
--replace_regex /SYS_C.*/SYC_C_TAG_DELETED_COLUMN/g
select column_name from CDB_TAB_COLS_V$ where table_name = "xingrui_normal_table" order by column_name;
select column_name from information_schema.columns where table_name = "xingrui_normal_table" order by column_name;
connection mysql;
show columns from xingrui_normal_table;

--disable_warnings
drop table if exists xingrui_geo;
--enable_warnings
create table xingrui_geo(c1 int, c2 geometry, c3 geometry);
select count(*) from INFORMATION_SCHEMA.ST_GEOMETRY_COLUMNS where TABLE_SCHEMA = 'test' and TABLE_NAME = 'xingrui_geo' ORDER BY COLUMN_NAME;

alter table xingrui_geo drop column c2;
select count(*) from INFORMATION_SCHEMA.ST_GEOMETRY_COLUMNS where TABLE_SCHEMA = 'test' and TABLE_NAME = 'xingrui_geo' ORDER BY COLUMN_NAME;
alter system set default_table_store_format = 'row';
sleep 2;

