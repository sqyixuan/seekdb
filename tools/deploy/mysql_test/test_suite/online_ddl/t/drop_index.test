# owner: liujixiong.ljx
# owner group: storage
# description: this test is used to test drop index op.

#--disable_query_log
--disable_warnings
drop table if exists z0case;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '60s';
sleep 3;
set ob_global_debug_sync = 'TABLE_REDEFINITION_REPLICA_BUILD wait_for continue_signal execute 10000';
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection default;
create table z0case (c1 int, c2 int, c3 int);
create index idx1 on z0case(c1, c2);
create index idx2 on z0case(c2, c3);
send alter table z0case add primary key(c1, c2);
sleep 2;

connection conn1;
--error 4179
alter table z0case drop index idx1;
--error 4179
drop index idx2 on z0case;

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';

connection default;
reap;
alter table z0case drop index idx1;
drop index idx2 on z0case;
drop table z0case;

--echo ========================= test cancel drop index task start =========================
--echo to test alter table xxx drop index xx syntax.
connection default;
sleep 3;
create table z0case(c1 int, c2 int);
create index idx1 on z0case(c1);
create unique index idx2 on z0case(c2);
show index from z0case;

connection obsys;
set ob_global_debug_sync = 'BEFORE_UPDATE_GLOBAL_INDEX_STATUS wait_for continue_signal execute 10000';
sleep 3;

connection default;
let $sess_1 = query_get_value(select connection_id() as id,id,1);
send alter table z0case drop index idx1;
sleep 2;

connection conn1;
--replace_regex /kill [0-9]+/kill session/g
eval kill $sess_1;

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
sleep 3;

connection conn1;
sleep 3;
show index from z0case;

--echo to test drop index xxx on xx syntax.
connection obsys;
set ob_global_debug_sync = 'BEFORE_UPDATE_GLOBAL_INDEX_STATUS wait_for continue_signal execute 10000';
sleep 3;

connection conn1;
let $sess_2 = query_get_value(select connection_id() as id,id,1);
send drop index idx2 on z0case;
sleep 2;

connection conn2;
--replace_regex /kill [0-9]+/kill session/g
eval kill $sess_2;

connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
sleep 3;

connection conn2;
sleep 3;
show index from z0case;
drop table z0case;
--echo ========================= test cancel drop index task end =========================
