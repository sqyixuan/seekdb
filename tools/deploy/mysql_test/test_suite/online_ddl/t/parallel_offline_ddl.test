# owner: lihongqin.lhq
# owner group: storage
# description: this case is use for testing parallel offline ddl
#

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t1x;
drop table if exists t2x;
drop database if exists db;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '60s';
sleep 3;
set ob_global_debug_sync = 'reset';
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn5,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn6,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn7,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn8,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn9,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--echo
--echo # drop partition/subpartitions rebuild global index
connection default;
create table t1(c1 int, c2 int, c3 int, c4 int)
partition by range(c1)
subpartition by range(c2)
(
  partition p0 values less than (10)
  (
    subpartition p0sp0 values less than (10),
    subpartition p0sp1 values less than (20),
    subpartition p0sp2 values less than (30)
  ),
  partition p1 values less than (20)
  (
    subpartition p1sp0 values less than (10),
    subpartition p1sp1 values less than (20),
    subpartition p1sp2 values less than (30)
  ),
  partition p2 values less than (30)
  (
    subpartition p2sp0 values less than (10),
    subpartition p2sp1 values less than (20),
    subpartition p2sp2 values less than (30)
  )
);
insert into t1 values (1, 1, 1, 1), (1, 10, 1, 2), (1, 20, 1, 3);
insert into t1 values (10, 1, 2, 1), (10, 10, 2, 2), (10, 20, 2, 3);
insert into t1 values (20, 1, 3, 1), (20, 10, 3, 2), (20, 20, 3, 3);
create index i1 on t1(c3) global;
create index i2 on t1(c2) global;
connection obsys;
set ob_global_debug_sync = 'CREATE_INDEX_REPLICA_BUILD wait_for continue_signal execute 10000';
connection default;
send alter table t1 drop partition p0;
sleep 3;
connection obsys;
select count(*), lock_mode, op_type from __all_virtual_obj_lock where owner_id in (select min(task_id) from __all_virtual_ddl_task_status where ddl_type = 5) group by lock_id, lock_mode, op_type order by 1, 2, 3;
select count(*), lock_mode, op_type from __all_virtual_obj_lock where owner_id in (select max(task_id) from __all_virtual_ddl_task_status where ddl_type = 5) group by lock_id, lock_mode, op_type order by 1, 2, 3;
select ddl_type, status from oceanbase.__all_ddl_task_status;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
connection default;
reap;
connection obsys;
set ob_global_debug_sync = 'CREATE_INDEX_REPLICA_BUILD wait_for continue_signal execute 10000';
connection default;
send alter table t1 drop subpartition p2sp0,p2sp2;
sleep 3;
connection obsys;
select count(*), lock_mode, op_type from __all_virtual_obj_lock where owner_id in (select min(task_id) from __all_virtual_ddl_task_status where ddl_type = 5) group by lock_id, lock_mode, op_type order by 1, 2, 3;
select count(*), lock_mode, op_type from __all_virtual_obj_lock where owner_id in (select max(task_id) from __all_virtual_ddl_task_status where ddl_type = 5) group by lock_id, lock_mode, op_type order by 1, 2, 3;
select ddl_type, status from oceanbase.__all_ddl_task_status;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
connection default;
reap;
drop table t1;

--echo
--echo # drop single partition rebuild global index
create table t1(c1 int, c2 int, key idx1(c2) global) partition by list(c1) (partition p0 values in (1));
connection obsys;
set ob_global_debug_sync = 'CREATE_INDEX_REPLICA_BUILD wait_for continue_signal execute 10000';
connection default;
send alter table t1 truncate partition p0;
sleep 3;
connection obsys;
select count(*), lock_mode, op_type from __all_virtual_obj_lock where owner_id in (select min(task_id) from __all_virtual_ddl_task_status where ddl_type = 5) group by lock_id, lock_mode, op_type order by 1, 2, 3;
select ddl_type, status from oceanbase.__all_ddl_task_status;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
connection default;
reap;
drop table t1;

