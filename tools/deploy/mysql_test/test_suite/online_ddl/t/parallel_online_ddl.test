create table t1(c1 int, c2 int);
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);
insert into t1 values (1, 2);
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_CHECK_FK_DATA_VALID_SEND_SQL wait_for continue_signal execute 10000';
connection conn1;
send alter table t1 add foreign key (c1) references t2(c1);
connection default;
sleep 3;
alter table t1 change c1 c1x int;
alter table t2 change c1 c1xx int;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection conn1;
--disable_result_log
--error 5785,1054
reap;
insert into t1 values (1, 2);
--enable_result_log
drop table t1;
drop table t2;
--disable_query_log
eval select ddl_stmt_str from oceanbase.__all_ddl_operation where table_id = $table_id and ddl_stmt_str != '' and ddl_stmt_str not like '%PURGE%' order by schema_version;
