--echo
--echo # create index and offline ddl
connection conn1;
create table t1(c1 int, c2 int);
insert into t1 values (1, 2);
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'CREATE_INDEX_TAKE_EFFECT wait_for continue_signal execute 10000';
connection conn1;
send create unique index i1 on t1(c1);
connection default;
sleep 3;
send alter table t1 modify c2 char(10);
sleep 3;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
connection conn1;
reap;
connection default;
reap;
drop index i1 on t1;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'CREATE_INDEX_TAKE_EFFECT wait_for continue_signal execute 10000';
alter system set _ob_ddl_timeout = '10s';
connection conn1;
send create unique index i1 on t1(c1);
connection default;
sleep 3;
set ob_query_timeout = 10000000;
send alter table t1 modify c2 int;
sleep 15;
--error 4012
reap;
set ob_query_timeout = 1000000000;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
alter system set _ob_ddl_timeout = '1000s';
connection conn1;
reap;
connection default;
insert into t1 values (2, 'abc');
select * from t1;
drop table t1;

--echo
--echo # create index and rename table
connection conn1;
create table t1(c1 integer);
insert into t1 values (1);
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_INDEX_SSTABLE_BUILD_TASK_SEND_SQL wait_for continue_signal execute 10000';
connection conn1;
send create unique index i1 on t1(c1);
connection default;
sleep 3;
send rename table t1 to t2;
connection conn2;
sleep 3;
--error 1050
create table t1(c1 int);
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection conn1;
reap;
connection default;
reap;
drop table t2;

--echo
--echo # create index and rename table and create table
connection conn1;
create table t1(c1 integer);
insert into t1 values (1);
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_INDEX_SSTABLE_BUILD_TASK_SEND_SQL wait_for continue_signal execute 10000';
connection conn1;
send create unique index i1 on t1(c1);
connection default;
sleep 3;
send rename table t1 to t2;
connection conn2;
sleep 3;
--error 1050
create table t1(c1 real zerofill not null, c2 int);
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection conn1;
reap;
connection default;
reap;
create table t1(c1 real zerofill not null, c2 int);
insert into t1 values (32829, 1);
select /*+index(t2 i1)*/ * from t2;
drop table t1, t2;

--echo
--echo # create index and rename column
connection conn1;
create table t1(c1 int, c2 int);
insert into t1 values (1, 2);
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_INDEX_SSTABLE_BUILD_TASK_SEND_SQL wait_for continue_signal execute 10000';
connection conn1;
send create unique index i1 on t1(c1);
connection default;
sleep 3;
alter table t1 change c1 c2x int;
alter table t1 change c2 c1 int;
alter table t1 change c2x c2 int;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection conn1;
reap;
select /*+index(t1 i1)*/ * from t1;
drop table t1;

--echo
--echo # create index and drop table before send sql
connection conn1;
create table t1(c1 int, c2 int);
insert into t1 values (1, 2);
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_INDEX_SSTABLE_BUILD_TASK_SEND_SQL wait_for continue_signal execute 10000';
connection conn1;
send create unique index i1 on t1(c1);
connection default;
sleep 3;
send drop table t1;
sleep 3;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection default;
reap;
connection conn1;
reap;
purge recyclebin;

--echo
--echo # create index and drop table before finish
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'CREATE_INDEX_VERIFY_CHECKSUM wait_for continue_signal execute 10000';
connection conn1;
create table t1(c1 int, c2 int);
insert into t1 values (1, 2);
send create index i1 on t1(c1);
connection default;
sleep 3;
send drop table t1;
sleep 3;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection default;
reap;
connection conn1;
reap;
purge recyclebin;

--echo
--echo # drop local index and drop table
connection default;
create table t1(c1 int);
create index i1 on t1(c1);
create index i2 on t1(c1);
insert into t1 values (1);
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_UPDATE_GLOBAL_INDEX_STATUS wait_for continue_signal execute 10000';
connection default;
send drop index i1 on t1;
connection conn2;
send alter table t1 drop index i2;
sleep 3;
connection conn1;
send drop table t1;
sleep 3;
connection conn3;
select lock_mode, op_type from oceanbase.__all_virtual_obj_lock where owner_id in (select task_id from oceanbase.__all_ddl_task_status) group by lock_id, lock_mode, op_type, owner_id order by 1, 2;
select ddl_type from oceanbase.__all_ddl_task_status;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
connection default;
reap;
connection conn2;
reap;
connection conn1;
reap;

--echo
--echo # drop global index and drop table
connection default;
create table t1(c1 int) partition by hash(c1) partitions 3;
create index i1 on t1(c1) global;
create index i2 on t1(c1) global;
insert into t1 values (1);
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_UPDATE_GLOBAL_INDEX_STATUS wait_for continue_signal execute 10000';
connection default;
send alter table t1 drop index i1;
connection conn2;
send drop index i2 on t1;
sleep 3;
connection conn1;
send drop table t1;
sleep 3;
connection conn3;
select lock_mode, op_type from oceanbase.__all_virtual_obj_lock where owner_id in (select task_id from oceanbase.__all_ddl_task_status) group by lock_id, lock_mode, op_type, owner_id order by 1, 2;
select ddl_type from oceanbase.__all_ddl_task_status;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
connection default;
reap;
connection conn2;
reap;
connection conn1;
reap;

--echo
--echo # add foreign key failed
create table t2(c1 int primary key, c2 int);
create table t1(c1 int, c2 int);
insert into t1 values (1, 2);
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);
--disable_result_log
--error 5785
alter table t1 add foreign key (c1) references t2(c1);
--enable_result_log
drop table t1;
drop table t2;
--disable_query_log
eval select ddl_stmt_str from oceanbase.__all_ddl_operation where table_id = $table_id and ddl_stmt_str != '' and ddl_stmt_str not like '%PURGE%' order by schema_version;
--enable_query_log

