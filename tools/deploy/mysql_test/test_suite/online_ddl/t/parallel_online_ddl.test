# owner: lihongqin.lhq
# owner group: storage
# description: this case is use for testing parallel online ddl 
# note: ob do mysqltest --suite=online_ddl --test_set=parallel_online_ddl -n bug

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t1x;
drop table if exists t2x;
drop database if exists db;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '60s';
alter system set _ob_ddl_timeout = '1000s';
alter system set rpc_timeout = '1000s';
sleep 3;
set ob_global_debug_sync = 'reset';
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn5,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn6,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn7,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn8,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn9,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--echo
--echo # parallel create index
create table t1(c0 int, c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int) partition by hash(c1) partitions 128;
connection conn1;
set ob_query_timeout = 1000000000;
send create index i1 on t1(c1) local;
connection conn2;
set ob_query_timeout = 1000000000;
send create index i2 on t1(c2) local;
connection conn3;
set ob_query_timeout = 1000000000;
send create index i3 on t1(c3) local;
connection conn4;
set ob_query_timeout = 1000000000;
send create index i4 on t1(c4) local;
connection conn5;
set ob_query_timeout = 1000000000;
send create index i5 on t1(c5) local;
connection conn6;
set ob_query_timeout = 1000000000;
send create index i6 on t1(c6) local;
connection conn7;
set ob_query_timeout = 1000000000;
send create index i7 on t1(c7) local;
connection conn8;
set ob_query_timeout = 1000000000;
send create index i8 on t1(c8) local;
connection conn9;
set ob_query_timeout = 1000000000;
send create index i9 on t1(c9) local;
connection conn1;
reap;
connection conn2;
reap;
connection conn3;
reap;
connection conn4;
reap;
connection conn5;
reap;
connection conn6;
reap;
connection conn7;
reap;
connection conn8;
reap;
connection conn9;
reap;
drop table t1;

--echo
--echo # create table as select
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_EXECUTE_CTAS_CLEAR_SESSION_ID wait_for continue_signal execute 10000';
connection conn1;
send create table t1(c1 int) as select 10;
connection default;
sleep 3;
create table t1(c1 int not null primary key, b varchar(10));
insert into t1 values (1, 2);
alter table t1 add index i1(c1);
select /*+index(t1 i1)*/ * from t1;
drop table t1;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection conn1;
reap;
drop table t1;

--echo
--echo # create table as select failed
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_EXECUTE_CTAS_CLEAR_SESSION_ID wait_for continue_signal execute 10000';
connection conn1;
send create table t1(c1 int) as select 10;
connection default;
sleep 3;
create table t1(c1 int not null primary key, b varchar(10));
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection conn1;
--error 1050
reap;
drop table t1;

