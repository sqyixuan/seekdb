# owner: lihongqin.lhq
# owner group: storage
# description:this case is use for test renaming column
#

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection default;

let $tenant_id = `select effective_tenant_id() from dual`;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

# partition expr, hidden columns, shadow columns, index
create table t1(c1 char(10), C2 int, c3 char(10) as (c1 + c2), c4 int) partition by hash(c2);
insert into t1(c1, c2) values ("1", 2);
create index i1 on t1(c2, c1);
# create index i2 on t1(c1(3)); # prefix index column is disallowed to execute offline ddl.
create index i2 on t1(c1);
# create unique index i3 on t1(c1(4), c2); # prefix index column is disallowed to execute offline ddl.
create unique index i3 on t1(c1, c2);
--error 1235 # FIXME:
create unique index i4 on t1(c3(2), c2);
# create index i4 on t1(c1(2)) global; # prefix index column is disallowed to execute offline ddl.
create index i4 on t1(c1) global;
create index i5 on t1(c2, c3, c1, c4) global partition by hash(c4);

alter table t1 add constraint cst1 unique (c2);
alter table t1 add constraint cst2 check (c3 = 3);

alter table t1 change c1 c1x char(10);
--source include/check_table_schema.inc
--error 3819
insert into t1(c1x, c2) values (2, 3);

alter table t1 change c1x C1x char(10);
--source include/check_table_schema.inc
--error 3819
insert into t1(C1x, c2) values (2, 3);

alter table t1 change c2 c2x int; 
--source include/check_table_schema.inc
--error 3819
insert into t1(C1x, C2X) values (2, 3);

alter table t1 change c2x C2x int;
--source include/check_table_schema.inc
--error 3819
insert into t1(C1x, C2x) values (2, 3);

alter table t1 change c2x c0 int first, modify c1x varchar(9), add c00 int first;
--source include/check_table_schema.inc
--error 3819
insert into t1(c00, c0, c1x) values (1, 3, 2);

alter table t1 modify C0 int;
--source include/check_table_schema.inc
--error 3819
insert into t1(c00, c0, c1x) values (1, 3, 2);

alter table t1 change c1x c1 int, change c0 c2 int after c1;
--source include/check_table_schema.inc
--error 3819
insert into t1(c00, c1, c2) values (1, 3, 2);

# not supported
# alter table t1 change c3 c3x char(10) as (c1x + C2x);
# --source include/check_table_schema.inc
# --error 3819
# insert into t1(c1x, c2x) values (2, 3);
# alter table t1 change c3x C3x char(10) as (c1x + c2x);
# --source include/check_table_schema.inc
# --error 3819
# insert into t1(c1x, c2x) values (2, 3);

drop table t1;

--echo subpartition
CREATE TABLE t1 (c1 INT, c2 DATE) PARTITION BY RANGE( YEAR(c2) )
SUBPARTITION BY HASH( TO_DAYS(c2) )
SUBPARTITIONS 2 (
    PARTITION p0 VALUES LESS THAN (1990),
    PARTITION p1 VALUES LESS THAN (2000),
    PARTITION p2 VALUES LESS THAN MAXVALUE
);
alter table t1 change c1 C1x int;
--source include/check_table_schema.inc
alter table t1 change c2 C2 date;
--source include/check_table_schema.inc
drop table t1;

create table t1 (c1 int, c2 int, c3 int) partition by range(c1) subpartition by key(c2) subpartitions 5
    (partition p0 values less than(0), partition p1 values less than(100));
insert into t1 values (1, -1, 1);
insert into t1 values (2, 3, 4);
alter table t1 change c2 c0 int first, change c1 c4 int after c3;
--source include/check_table_schema.inc
drop table t1;

# add case-sensitive column name
--error 1060
create table t1(ab int, Ab int, aB int, AB int);
create table t1(ab varchar(10));
insert into t1 values ('1');
--error 1060
alter table t1 add AB varchar(10);
--error 1060
alter table t1 add ab varchar(11);
--error 1060
alter table t1 add Ab varchar(12);
--error 1060
alter table t1 add aB varchar(13);

alter table t1 modify aB varchar(14);
desc t1;
alter table t1 modify ab varchar(15);
desc t1;
alter table t1 modify Ab varchar(16);
desc t1;
alter table t1 modify aB varchar(17);
desc t1;

alter table t1 add ba int;

--error 1060
alter table t1 change column ba ab int;
--error 1060
alter table t1 change column ba Ab int;
--error 1060
alter table t1 change column bA AB int;

alter table t1 change aB Ab int;
desc t1;
alter table t1 change ab ab int;
desc t1;

drop table t1;

--echo auto increment
create table t1(c1 float, c2 int, c3 int);
insert into t1 values (1, 2, 3);
alter table t1 drop c3, change C1 C1x int auto_increment after c2;
desc t1;
insert into t1(c2) values (3);
insert into t1(c2) values (4);
insert into t1(c2) values (5);
select * from t1;
drop table t1;

--echo partitioned index
create table t1(c1 int, c2 int, c3 int);
insert into t1 values (1, 2, 3);
insert into t1 values (4, 5, 6);
create index i1 on t1(c2, c1) global partition by hash(c1);
alter table t1 change c2 c2x int, modify c3 char(10);
--source include/check_table_schema.inc
drop table t1;

--echo foreign key
create table t2(c1 int primary key);
create table t1(c1 int, c2 int, constraint fk foreign key (c2) references t2(c1));
insert into t2 values (1), (2);
insert into t1 values (11, 1), (12, 2);
alter table t2 add c2 int, change c1 c1x int;
--error 5320
alter table t1 modify c1 char(10), change c2 c2x char(10);
alter table t1 modify c1 char(10), change c2 c2x int;
--error 1452
insert into t1 value (13, 3);
insert into t1 values (13, 1), (14, 2);
insert into t2 values (3, 10);
insert into t1 values (15, 3);
select * from t1;
select * from t2;
drop table t1;
drop table t2;

--echo primary key
create table t1(c1 int, c2 int);
insert into t1 values (1, 2);
alter table t1 change c1 c1x int primary key;
desc t1;
select * from t1;
drop table t1;

--echo primary key with key partition
create table t1(pk int primary key) partition by key() partitions 2;
alter table t1 change pk a int;
insert into t1 values (1), (2);
desc t1;
select * from t1;

drop table t1;
