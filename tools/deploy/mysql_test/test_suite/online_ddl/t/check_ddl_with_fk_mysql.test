# owner: liujixiong.ljx
# owner group: storage
# description: this case is used to test the redefinition task when table contains foreign key.

# notice that the column c1 in t4 is not the first column.
--disable_warnings
drop table if exists t2;
drop table if exists t1;
drop table if exists t4;
drop table if exists t3;
--enable_warnings

create table t1(c1 int primary key, c2 int, c3 char(23));
insert into t1 values (1, 1, 'ab'), (2, 2, 'cd');
create table t2(c2 int, c3 char(11), c1 int, foreign key(c1) references t1(c1));
insert into t2 values (1, 'ab', 1), (2, 'cd', 2);
# success expected
alter table t1 modify c3 varchar(33);
alter table t2 modify c3 varchar(33);
--source mysql_test/include/replace_object_name_created_by_sys.inc
--error 3730
drop table t1;
drop table t2;
drop table t1;

# notice that the column c1 in t4 is the first column.
create table t1(c1 int primary key, c2 int, c3 char(23));
insert into t1 values (1, 1, 'ab'), (2, 2, 'cd');
create table t2(c1 int, c2 int, c3 char(11), foreign key(c1) references t1(c1));
insert into t2 values (1, 1, 'ab'), (2, 2, 'cd');
# success expected
alter table t1 modify c3 varchar(33);
alter table t2 modify c3 varchar(33);
--source mysql_test/include/replace_object_name_created_by_sys.inc
--error 3730
drop table t1;
drop table t2;
drop table t1;

# to compare the state of fk state before and after ddl.
# step 1: connect to common tenant, then create tables with foreign key;
# step 2: connect to sys tenant, then show some related infos about foreign key;
# step 3: connect to common tenant, then execute modify column column type of parent table;
# step 4: connect to sys tenant, then show some related infos about foreign key.
# step 5: connect to common tenant, then execute modify column column type of child table;
# step 6: connect to sys tenant, then show some related infos about foreign key.

connect (obsys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '60s';
sleep 3;
set ob_global_debug_sync = 'reset';
connection default;
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn1;
set ob_query_timeout = 100000000;
--sleep 2
create table t3(c1 int primary key, c2 int, c3 char(20));
insert into t3 values (1, 1, 'abcd'), (2, 2, 'test');
create table t4(c2 int, c3 char(20), c1 int, foreign key(c1) references t3(c1));
insert into t4 values (1, 'test', 1), (2, 'abcd', 2);

connection obsys;
--sleep 2
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'test', database_id, 1);
let $t3_id = query_get_value(select table_id from oceanbase.__all_virtual_table where database_id = $db_id and table_name = 't3', table_id, 1);
let $t4_id = query_get_value(select table_id from oceanbase.__all_virtual_table where database_id = $db_id and table_name = 't4', table_id, 1);

--disable_query_log
# foreign key infos before drop column.
eval select update_action, delete_action, enable_flag, ref_cst_type, ref_cst_id, validate_flag, rely_flag from oceanbase.__all_virtual_foreign_key 
where parent_table_id = $t3_id; 
eval select update_action, delete_action, enable_flag, ref_cst_type, ref_cst_id, validate_flag, rely_flag from oceanbase.__all_virtual_foreign_key 
where child_table_id = $t4_id; 
--enable_query_log

connection conn1;
--sleep 2
alter table t3 modify c3 varchar(20);
select * from t3;
select * from t4;

connection obsys;
--sleep 2
# get updated table id
let $t3_id = query_get_value(select table_id from oceanbase.__all_virtual_table where database_id = $db_id and table_name = 't3', table_id, 1);

--disable_query_log
# foreign key infos after drop column.
eval select update_action, delete_action, enable_flag, ref_cst_type, ref_cst_id, validate_flag, rely_flag from oceanbase.__all_virtual_foreign_key 
where parent_table_id = $t3_id; 
eval select update_action, delete_action, enable_flag, ref_cst_type, ref_cst_id, validate_flag, rely_flag from oceanbase.__all_virtual_foreign_key 
where child_table_id = $t4_id; 
--enable_query_log

connection conn1;
--sleep 2
alter table t4 modify c3 varchar(20);
select * from t3;
select * from t4;

connection obsys;
--sleep 2
# get updated table id
let $t4_id = query_get_value(select table_id from oceanbase.__all_virtual_table where database_id = $db_id and table_name = 't4', table_id, 1);

--disable_query_log
# foreign key infos after drop column.
eval select update_action, delete_action, enable_flag, ref_cst_type, ref_cst_id, validate_flag, rely_flag from oceanbase.__all_virtual_foreign_key 
where parent_table_id = $t3_id; 
eval select update_action, delete_action, enable_flag, ref_cst_type, ref_cst_id, validate_flag, rely_flag from oceanbase.__all_virtual_foreign_key 
where child_table_id = $t4_id; 
--enable_query_log

connection conn1;
drop table t4;
drop table t3;

--disable_warnings
drop table if exists t2;
drop table if exists t1;
drop table if exists t0;
drop table if exists t4;
drop table if exists t3;
--enable_warnings

--echo to test rebuild multiple fk.
create table t0(c1 int primary key, c2 int, c3 int);
create table t1(c1 int primary key, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int, c4 char(10),
constraint fk00 foreign key(c1) references t0(c1),
constraint fk01 foreign key(c2) references t0(c1),
constraint fk02 foreign key(c3) references t0(c1),
constraint fk11 foreign key(c1) references t1(c1), 
constraint fk12 foreign key(c2) references t1(c1));
alter table t2 modify c4 varchar(10);
alter table t2 modify c4 char(9);
drop table t2;
drop table t1;

--echo to execute offline ddl in parent table mainly.
create table t1(a int primary key, b int, c int);
create table t2 (a int primary key, b int, c int, foreign key (b) references t1(a));
alter table t2 add constraint a foreign key (a) references t1(a);
alter table t2 add constraint b foreign key (b) references t1(a);
alter table t1 modify c mediumint;
alter table t1 drop column c;
alter table t2 modify c mediumint;
alter table t2 drop column c;
drop table t2;
drop table t1;

--echo child table dml with parent table in ddl
connection obsys;
set ob_global_debug_sync = 'TABLE_REDEFINITION_COPY_TABLE_INDEXES wait_for continue_signal execute 10000';
connection default;
create table t3(c1 int primary key);
create table t2(c1 int primary key, c2 int, c3 int, c4 int,
    constraint fk_t2c2_t3c1 foreign key(c2) references t3(c1), constraint fk_t2c3_t2c1 foreign key (c3) references t2(c1));
create table t1(c1 int, c2 int, constraint fk_t1c1_t2c1 foreign key (c1) references t2(c1));
insert into t3 values (10);
insert into t2 values (1, 10, 1, 100);
insert into t1 values (1, 3);
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't2') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't2');
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't2') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't3');
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't1') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't2');
send alter table t2 modify c4 char(10);
connection conn1;
sleep 3;
send insert into t1 values (1, 2);
sleep 3;
connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
sleep 3;
connection conn1;
reap;
connection default;
reap;
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't2') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't2');
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't2') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't3');
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't1') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't2');
select * from t1;
select * from t2;
insert into t1 values (1, 4);
--error 1452
insert into t1 values (2, 5);
--error 1452
insert into t2 values (2, 10, 3, 101);
--error 1452
insert into t2 values (2, 6, 2, 101);
--error 1451
delete from t3 where c1 = 10;
insert into t3 values (7);
insert into t2 values (2, 7, 2, 101);
insert into t1 values (2, 8);
drop table t1;
drop table t2;
drop table t3;

--echo child table dml with parent table ddl succeed but not finished
connection obsys;
set ob_global_debug_sync = 'TABLE_REDEFINITION_TAKE_EFFECT wait_for continue_signal execute 10000';
connection default;
create table t3(c1 int primary key);
create table t2(c1 int primary key, c2 int, c3 int, c4 int,
    constraint fk_t2c2_t3c1 foreign key(c2) references t3(c1), constraint fk_t2c3_t2c1 foreign key (c3) references t2(c1));
create table t1(c1 int, c2 int, constraint fk_t1c1_t2c1 foreign key (c1) references t2(c1));
insert into t3 values (10);
insert into t2 values (1, 10, 1, 100);
insert into t1 values (1, 3);
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't2') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't2');
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't2') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't3');
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't1') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't2');
send alter table t2 modify c4 char(10);
connection conn1;
sleep 3;
send insert into t1 values (1, 2);
sleep 3;
connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
sleep 3;
connection conn1;
reap;
connection default;
reap;
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't2') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't2');
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't2') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't3');
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't1') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't2');
select * from t1;
select * from t2;
insert into t1 values (1, 4);
--error 1452
insert into t1 values (2, 5);
--error 1452
insert into t2 values (2, 10, 3, 101);
--error 1452
insert into t2 values (2, 6, 2, 101);
--error 1451
delete from t3 where c1 = 10;
insert into t3 values (7);
insert into t2 values (2, 7, 2, 101);
insert into t1 values (2, 8);
drop table t1;
drop table t2;
drop table t3;

--echo parent table dml with child table in ddl
connection obsys;
set ob_global_debug_sync = 'TABLE_REDEFINITION_COPY_TABLE_INDEXES wait_for continue_signal execute 10000';
connection default;
create table t3(c1 int primary key);
create table t2(c1 int primary key, c2 int, c3 int, c4 int,
    constraint fk_t2c2_t3c1 foreign key(c2) references t3(c1), constraint fk_t2c3_t2c1 foreign key (c3) references t2(c1));
create table t1(c1 int, c2 int, constraint fk_t1c1_t2c1 foreign key (c1) references t2(c1));
insert into t3 values (10);
insert into t2 values (1, 10, 1, 100);
insert into t1 values (1, 3);
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't2') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't2');
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't2') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't3');
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't1') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't2');
send alter table t2 modify c4 char(10);
sleep 3;
connection conn1;
send delete from t3 where c1 = 10;
sleep 3;
connection obsys;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
sleep 3;
connection conn1;
--error 1146,1451
reap;
connection default;
reap;
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't2') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't2');
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't2') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't3');
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag from oceanbase.__all_foreign_key where
    child_table_id = (select table_id from oceanbase.__all_table where table_name = 't1') and
    parent_table_id = (select table_id from oceanbase.__all_table where table_name = 't2');
select * from t1;
select * from t2;
insert into t1 values (1, 4);
--error 1452
insert into t1 values (2, 5);
--error 1452
insert into t2 values (2, 10, 3, 101);
--error 1452
insert into t2 values (2, 6, 2, 101);
--error 1451
delete from t3 where c1 = 10;
insert into t3 values (7);
insert into t2 values (2, 7, 2, 101);
insert into t1 values (2, 8);
drop table t1;
drop table t2;
drop table t3;
