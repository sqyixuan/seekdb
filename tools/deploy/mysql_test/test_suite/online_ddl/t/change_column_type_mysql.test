# owner: luofan.zp
# owner group: sql2
# description:this case is use for test modify column type
#
--disable_warnings
--disable_query_log

drop table if exists t2;
drop table if exists t1;
#带Check约束的列在MySQL模式下不支持修改列类型
create table t1(c1 int, c2 int, c3 int, constraint cst1 check(c1 = c2));
alter table t1 modify c3 bigint;
--error 1235
alter table t1 modify c1 varchar(64);
drop table t1;

#测试外键约束
#参考列/被参考列是float(m,n)，支持更改精度，改大改小都可以
create table t1(c1 int, c2 float(8,2), c3 float(8,2), unique(c2, c3));
desc t1;
create table t2(c1 int, c2 float(8,2), c3 float(8,2), unique(c2, c3), constraint fk_12 foreign key(c2, c3) references t1 (c2, c3));
alter table t1 modify c2 float(5,2);
desc t1;
drop table t2;
drop table t1;

#参考列/被参考列是double(m,n)，支持更改精度，改大改小都可以
create table t1(c1 int, c2 double(8,2), c3 double(8,2), unique(c2, c3));
desc t1;
create table t2(c1 int, c2 double(8,2), c3 double(8,2), unique(c2, c3), constraint fk_12 foreign key(c2, c3) references t1 (c2, c3));
alter table t1 modify c2 double(10,4);
desc t1;
alter table t1 modify c2 double(5,2);
desc t1;
drop table t2;
drop table t1;

#参考列/被参考列是varchar(m)，支持改大，不支持改小。不支持改成char类型
create table t1(c1 int, c2 varchar(64), c3 varchar(64), unique(c2, c3));
create table t2(c1 int, c2 varchar(64), c3 varchar(64), unique(c2, c3), constraint fk_12 foreign key(c2, c3) references t1 (c2, c3));
alter table t1 modify c2 varchar(128);
desc t1;
--error 1235
alter table t1 modify c2 varchar(32);
--error 5320
alter table t1 modify c2 char(64);
drop table t2;
drop table t1;

#测试整型相同大类型提升
create table t1 (c1 tinyint);
desc t1;
alter table t1 modify c1 smallint;
desc t1;
alter table t1 modify c1 mediumint;
desc t1;
alter table t1 modify c1 int;
desc t1;
alter table t1 modify c1 bigint;
desc t1;
drop table t1;

#测试字符串类型大类型提升包括char、varchar、tinytext、text、mediumtext、longtext，其中对于char类型，只能是其他类型转换成char类型，char类型转换成其他类型时需要重写数据；
create table t1 (c1 varchar(32));
desc t1;
alter table t1 modify c1 tinytext;
desc t1;
alter table t1 modify c1 text;
desc t1;
alter table t1 modify c1 mediumtext;
alter table t1 modify c1 longtext;
desc t1;
alter table t1 modify c1 char(64);
desc t1;

#测试char类型转换成其他类型时需要重写数据
alter table t1 modify c1 varchar(128);
desc t1;
drop table t1;

#测试二进制类型大类型提升包括binary、varbinary、blob，tinyblob，mediumblob，longblob，其中对于binary类型，其他类型不能转成binary，binary转其他类型时需要重写数据；
create table t1 (c1 tinyblob, c2 binary(64));
desc t1;
alter table t1 modify c1 blob;
desc t1;
alter table t1 modify c1 mediumblob;
alter table t1 modify c1 longblob;
desc t1;
alter table t1 modify c1 tinyblob;
desc t1;
alter table t1 modify c1 binary(256);

#测试binary转其他类型时需要重写数据
alter table t1 modify c2 blob;
drop table t1;

#测试其他提升需要重写，例如浮点数类型包括decimal(m, n), float, double
create table t1 (c1 float(8,2));
desc t1;
alter table t1 modify c1 double(10, 4);
desc t1;
alter table t1 modify c1 decimal(20, 4);
desc t1;
drop table t1;

#测试整型相同大类型改短
create table t1 (c1 bigint);
desc t1;
alter table t1 modify c1 int;
desc t1;
alter table t1 modify c1 mediumint;
desc t1;
alter table t1 modify c1 smallint;
desc t1;
alter table t1 modify c1 tinyint;
desc t1;
drop table t1;

#测试字符串类型大类型改短包括char、varchar、tinytext、text、mediumtext、longtext
create table t1 (c1 varchar(128));
desc t1;
alter table t1 modify c1 varchar(64);
desc t1;
drop table t1;
create table t1 (c1 longtext);
desc t1;
alter table t1 modify c1 mediumtext;
desc t1;
alter table t1 modify c1 text;
desc t1;
alter table t1 modify c1 tinytext;
desc t1;
drop table t1;

#测试二进制类型大类型改短包括binary、varbinary、blob，tinyblob，mediumblob，longblob
create table t1 (c1 longblob);
desc t1;
alter table t1 modify c1 mediumblob;
desc t1;
alter table t1 modify c1 blob;
desc t1;
alter table t1 modify c1 tinyblob;
desc t1;
drop table t1;

#测试其他类型改短需要重写，例如浮点数类型包括decimal(m, n), float, double
create table t1 (c1 decimal(20,4));
desc t1;
alter table t1 modify c1 double(10, 4);
desc t1;
alter table t1 modify c1 float(5, 4);
desc t1;
drop table t1;

#测试相同类型变长,对于相同类型变长时，大部分场景是不需要重写的（char变长在OceanBase里是不需要重写的），除以下特殊情况：
#binary类型变长需要重写
create table t1 (c1 binary(32));
desc t1;
alter table t1 modify c1 binary(64);
desc t1;
drop table t1;

#decimal类型变长需要重写
create table t1 (c1 decimal(10, 2));
desc t1;
alter table t1 modify c1 decimal(20, 2);
desc t1;
drop table t1;

#enum类型变长需要重写
create table t1 (c1 enum('1', '2'));
desc t1;
alter table t1 modify c1 enum('1', '2', '3');
desc t1;
drop table t1;

#set类型变长需要重写
create table t1 (c1 set('1', '2'));
desc t1;
alter table t1 modify c1 set('1', '2', '3');
desc t1;
drop table t1;


#测试对于相同类型变短时，都需要重写数据，除以下特殊情况：
#float(m,d)修改只影响显示位数，不修改存储
create table t1 (c1 float(10, 2));
desc t1;
alter table t1 modify c1 float(8, 2);
desc t1;
drop table t1;


#double(m,n)修改只影响显示位数，不修改存储
create table t1 (c1 double(10, 2));
desc t1;
alter table t1 modify c1 double(8, 2);
desc t1;
drop table t1;

#测试varchar变长
create table t1 (c1 varchar(32));
desc t1;
alter table t1 modify c1 varchar(64);
desc t1;
drop table t1;

#测试char变长
create table t1 (c1 char(32));
desc t1;
alter table t1 modify c1 char(64);
desc t1;
drop table t1;

#测试不同大类型的列类型变更都需要重写
#int --> varchar
create table t1 (c1 int);
desc t1;
alter table t1 modify c1 varchar(64);
desc t1;
drop table t1;

#varchar --> int
create table t1 (c1 varchar(32));
desc t1;
alter table t1 modify c1 int;
desc t1;
drop table t1;

#double --> int
create table t1 (c1 double(10, 2));
desc t1;
alter table t1 modify c1 int;
desc t1;
drop table t1;

#int --> double
create table t1 (c1 int);
desc t1;
alter table t1 modify c1 double(10,2);
desc t1;
drop table t1;

#varchar类型测试
create table t1 (c1 varchar(128));
desc t1;
#测试varchar类型变短
alter table t1 modify c1 varchar(64);
desc t1;
#测试varchar类型转换成char类型
alter table t1 modify c1 char(64);
desc t1;
#测试char类型转换成varchar类型
alter table t1 modify c1 varchar(64);
desc t1;
#测试varchar类型转换成char类型变长
alter table t1 modify c1 char(256);
desc t1;
drop table t1;

#char类型测试
create table t1 (c1 char(128));
desc t1;
#测试char类型变短
alter table t1 modify c1 char(64);
desc t1;
#测试char类型转换成varchar类型变短
alter table t1 modify c1 varchar(32);
desc t1;
drop table t1;

set @org_mode=@@sql_mode;
set @@sql_mode="";
#varchar类型测试超过数据长度
create table t1 (c1 varchar(32));
desc t1;
insert into t1 values ('qwertyuiopqwertyuiopqwertyuiop');
insert into t1 values ('qwertyuiopqwertyuiopqwertyuiop');
insert into t1 values ('qwertyuiopqwertyuiopqwertyuiop');
#测试varchar类型变短超过数据长长度
alter table t1 modify c1 varchar(16);
#测试varchar类型转换成char类型变短超过数据长度
alter table t1 modify c1 char(16);
desc t1;
#测试varchar2类型转换成char类型变长
alter table t1 modify c1 char(64);
desc t1;
drop table t1;

#char类型测试超过数据长度
create table t1 (c1 char(32));
desc t1;
insert into t1 values ('qwertyuiopqwertyuiopqwertyuiop');
insert into t1 values ('qwertyuiopqwertyuiopqwertyuiop');
insert into t1 values ('qwertyuiopqwertyuiopqwertyuiop');
#测试char类型变短超过数据长度
alter table t1 modify c1 char(16);
#测试char类型转换成varchar类型变短超过数据长度
alter table t1 modify c1 varchar(16);
desc t1;
#测试char类型转换成varchar类型变长
alter table t1 modify c1 varchar(64);
desc t1;
drop table t1;

set @@sql_mode='strict_all_tables';
#varchar类型测试超过数据长度
create table t1 (c1 varchar(32));
desc t1;
insert into t1 values ('qwertyuiopqwertyuiopqwertyuiop');
insert into t1 values ('qwertyuiopqwertyuiopqwertyuiop');
insert into t1 values ('qwertyuiopqwertyuiopqwertyuiop');
#测试varchar类型变短超过数据长度报错
--error 1406
alter table t1 modify c1 varchar(16);
#测试varchar类型转换成char类型变短超过数据长度报错
--error 1406
alter table t1 modify c1 char(16);
desc t1;
#测试varchar2类型转换成char类型变长
alter table t1 modify c1 char(64);
desc t1;
drop table t1;

#char类型测试超过数据长度
create table t1 (c1 char(32));
desc t1;
insert into t1 values ('qwertyuiopqwertyuiopqwertyuiop');
insert into t1 values ('qwertyuiopqwertyuiopqwertyuiop');
insert into t1 values ('qwertyuiopqwertyuiopqwertyuiop');
#测试char类型变短超过数据长度报错
--error 1406
alter table t1 modify c1 char(16);
#测试char类型转换成varchar类型变短超过数据长度报错
--error 1406
alter table t1 modify c1 varchar(16);
desc t1;
#测试char类型转换成varchar类型变长
alter table t1 modify c1 varchar(64);
desc t1;
drop table t1;

--echo #修复varbinary到blob的转换与oracle不兼容
create table t1(v1 varchar(10), v2 varchar(20), tt1 tinytext, t1 text, mt1 mediumtext, lt1 longtext, vb1 varbinary(10), vb2 varbinary(10), tb1 tinyblob, b1 blob, mb1 mediumblob, lb1 longblob);
alter table t1 modify column v1 varchar(20), modify column v2 tinytext, modify column tt1 text, modify column vb1 varbinary(20), modify column vb2 tinyblob, modify column tb1 blob;
desc t1;
drop table t1;

--echo #外键约束下enum类型修改类型为自身应该成功
create table t1(c1 enum('1111.1111', '2011', '20111111', 'abc') primary key);
create table t2(c1 enum('1111.1111', '2011', '20111111', 'abc') primary key, constraint fk_1 foreign key(c1) references t1(c1));
desc t2;
alter table t2 modify column c1 enum('1111.1111', '2011', '20111111', 'abc');
desc t2;
drop table t2;
drop table t1;

--echo #[bugfix]:
CREATE TABLE t1 (Z0_TEST0 BIT(25),Z0_TEST1 TINYINT)
PARTITION BY RANGE (Z0_TEST0)
(
PARTITION part_1 VALUES LESS THAN (20),
PARTITION part_2 VALUES LESS THAN (100),
PARTITION part_3 VALUES LESS THAN ( MAXVALUE ));
desc t1;
INSERT INTO t1 (Z0_TEST0,Z0_TEST1)VALUES(b'000011111100101','111');
INSERT INTO t1 (Z0_TEST0,Z0_TEST1)VALUES(0,'2');
INSERT INTO t1 (Z0_TEST0,Z0_TEST1)VALUES(b'1010101','30');
INSERT INTO t1 (Z0_TEST0,Z0_TEST1)VALUES(b'101','111');
ALTER TABLE t1 MODIFY column z0_test0 INT;
desc t1;
drop table t1;

create table t1(c1 int, c2 bit(25), c3 int, primary key(c1, c2)) partition by hash(c1)
subpartition by range(c2) subpartition template (
subpartition p0 values less than(10),
subpartition p1 values less than(20),
subpartition p2 values less than(30)) partitions 10;
desc t1;
INSERT INTO t1 VALUES(1, 0, 2);
INSERT INTO t1 VALUES(2, 0, 3);
ALTER TABLE t1 MODIFY column c2 INT;
desc t1;
drop table t1;

--echo #[bugfix]:
CREATE TABLE t1 (
  c1 int(11) DEFAULT NULL,
  c2 int(11) DEFAULT NULL,
  c3 int(11) DEFAULT NULL
)
partition by hash(c1) subpartition by list columns(c2, c3) subpartition template (
subpartition p0 values in ((1,1),(2,2),(3,3)),
subpartition p1 values in ((4,4),(5,5),(6,6)),
subpartition p2 values in (DEFAULT));

--error 1654
alter table t1 modify c2 varchar(1024);
drop table t1;

set @@sql_mode=@org_mode;

