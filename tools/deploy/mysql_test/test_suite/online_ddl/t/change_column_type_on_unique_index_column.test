# owner: lihongqin.lhq
# owner group: storage
# description: test modifying column type behavior when the target column is binding with unique index
#
--disable_warnings

drop table if exists t1;
drop table if exists t2;
# varchar -> int should be processed successfully when there is no unique constraint
create table t1(c1 varchar(100));
insert into t1 values('0');
insert into t1 values('1');
insert into t1 values('01');
alter table t1 modify column c1 int;
select c1 from t1;
drop table t1;

# varchar -> int should throw error 1062 if the result breaks unique constraint
create table t2(c1 varchar(100));
insert into t2 values('0');
insert into t2 values('1');
insert into t2 values('01');
alter table t2 add unique index i1(c1);
--error 1062
alter table t2 modify column c1 int;
drop table t2;

# modify column unique key.
create table t1(c1 int, c2 int unique);
insert into t1 values(1, 1);
show index from t1;
alter table t1 modify c2 smallint unique key;
show index from t1;
--error 1062
insert into t1 values(1, 1);
alter table t1 modify c2 bigint unique key;
show index from t1;
--error 1062
insert into t1 values(1, 1);
drop table t1;

create table t1(c1 int, c2 int, c3 int, unique(c2, c3));
insert into t1 values(1, 1, 1);
alter table t1 modify c2 mediumint unique key;
show index from t1;
--error 1062
insert into t1 values(1, 1, 2);
insert into t1 values(1, 2, 1);
drop table t1;
