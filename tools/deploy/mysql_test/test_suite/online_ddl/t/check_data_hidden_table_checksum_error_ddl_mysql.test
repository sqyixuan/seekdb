# owner: liujixiong.ljx
# owner group: storage
# description: this case is used for test the checksum validation between data table and hidden table.

--disable_warnings
drop table if exists test01;
--enable_warnings

# tinyint ->smallint 
create table test01(c1 int, c2 tinyint);
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt);
  inc $cnt;
}

alter table test01 modify c2 smallint;
select * from test01;

# tinyint -> mediumint
drop table test01;
create table test01(c1 int, c2 tinyint);
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt);
  inc $cnt;
}
alter table test01 modify c2 mediumint;
select * from test01;

# tinyint -> int
drop table test01;
create table test01(c1 int, c2 tinyint);
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt);
  inc $cnt;
}
alter table test01 modify c2 int;
select * from test01;

