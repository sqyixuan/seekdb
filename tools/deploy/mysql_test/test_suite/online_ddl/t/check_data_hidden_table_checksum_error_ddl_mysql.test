# ob1.mysql alter system major freeze tenant = sys;
# ob1.mysql alter system major freeze tenant = all_user;
# ob1.mysql alter system major freeze tenant = all_meta;
# ob1.check_version 2;
# success expected
alter table test01 modify column c2 mediumint;
drop table test01;

# mediumint ->int, 有依赖对象为主键、分区键、check约束等时，需要offline
create table test01(c1 int, c2 mediumint) partition by range(c2)
(
  partition p1 values less than(5),
  partition p2 values less than(maxvalue)
);
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt);
  inc $cnt;
}
# success expected
alter table test01 modify c2 int;
drop table test01;

# char(m) -> {char(<m) -> varchar  -> char(>m 有依赖对象)}
create table test02(c1 int, c2 char(30));
insert into test02 values(1, 'Test1'), (2, 'Test2'), (3, 'Test3');
# success expected
alter table test02 modify column c2 char(20);
# success expected
alter table test02 modify column c2 varchar(18);
drop table test02;

# char类型长度变长，有依赖对象，需要offline
create table test02(c1 int, c2 char(30) primary key);
insert into test02 values(1, 'Test1'), (2, 'Test2'), (3, 'Test3');
# success expected
alter table test02 modify column c2 char(50);
drop table test02;

# varchar(m) -> {varchar(<m), char(<m), char(>m 有依赖对象)}
create table test02(c1 int, c2 varchar(30));
insert into test02 values(1, 'Test1'), (2, 'Test2'), (3, 'Test3');
# success expected
alter table test02 modify column c2 varchar(15);
# success expected
alter table test02 modify column c2 char(10);
drop table test02;

create table test02(c1 int, c2 varchar(30) primary key);
insert into test02 values(1, 'Test1'), (2, 'Test2'), (3, 'Test3');
# success expected
alter table test02 modify column c2 char(50);
drop table test02;

create table t1(c1 varchar(10));
insert into t1 values('   ');
insert into t1 values('');
create index i1 on t1(c1);
alter table t1 modify c1 char(10);
drop table t1;

# char to varchar with different character set
create table t1(c1 char(10));
insert into t1 values ('abc');
alter table t1 modify c1 varchar(9) character set 'utf16';
drop table t1;
create table t1(c1 char(10));
insert into t1 values ('abc');
alter table t1 modify c1 varchar(10) character set 'utf16';
drop table t1;
create table t1(c1 char(10));
insert into t1 values ('abc');
alter table t1 modify c1 varchar(11) character set 'utf16';
drop table t1;

--echo test set/enum
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 enum('is_not_null', 'is_null', 'between', 'like', 'rightlike', 'leftlike') NULL DEFAULT NULL);
insert into t1 (c1, c2) values(1, 'is_not_null');
insert into t1 (c1, c2) values(2, 'is_null');
--error 1265
alter table t1 modify c2 enum('is_null', 'between', 'like', 'rightlike', 'leftlike', 'eq');
select c1, c2, c2+0 from t1;
alter table t1 modify c2 enum('is_not_null', 'is_null', 'between', 'like', 'rightlike', 'leftlike', 'eq');
select c1, c2, c2+0 from t1;
# column value is changed due to order changed.
alter table t1 modify c2 enum('is_null', 'is_not_null', 'between', 'like', 'rightlike', 'leftlike');
select c1, c2, c2+0 from t1;
drop table t1;

--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2(c1 int, color set('red', 'green'));
insert into t2 (c1, color) values(1, 'red');
insert into t2 (c1, color) values(2, 'green');
select c1, color, color+0 from t2;
--error 1265
alter table t2 modify color set('blue');
select c1, color, color+0 from t2;
alter table t2 modify color set('red', 'green', 'blue');
select c1, color, color+0 from t2;
# column value is changed due to order changed.
alter table t2 modify color set('blue', 'green', 'red');
select c1, color, color+0 from t2;
drop table t2;
