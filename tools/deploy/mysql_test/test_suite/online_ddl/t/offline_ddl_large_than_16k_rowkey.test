# owner: zhenjiang.xzj
# owner group: storage
# description:this case is testing whether we can reject ddl when the final rowkey length exceeds our limit
#

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 varchar(4096), c2 varchar(2));
--error 1071
alter table t1 add primary key(c1,c2);

drop table t1;
create table t1(c1 int, c2 varchar(1000), c3 int);
create index idx1 on t1(c2, c3);
--error 1071
alter table t1 modify column c3 varchar(10000);

drop table if exists t1;
