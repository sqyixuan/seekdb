# owner: lihongqin.lhq
# owner group: storage
# description:this case is use for changing column type: varbinary to binary
#
--disable_warnings

drop table if exists t1;
create table t1(c1 varbinary(10), c2 int);
insert into t1 values (2, 2);
alter table t1 modify c1 binary(11);
select hex(c1) from t1;
update t1 set c1 = 'abc' where c2 = 2;
select hex(c1) from t1;
