# owner: liujixiong.ljx
# owner group: storage
# description: this case is used for test partition create and repartition

# 测试无分区数据经过range分区，存在数据无法映射到range分区
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int);
insert into t1(c1) values(-100), (-10), (1), (10), (100);
--error 1526
alter table t1 partition by range(c1)(partition part_1 values less than (10), partition part_2 values less than (100));
drop table t1;

# 测试无分区数据经过list分区，存在数据无法映射到list分区
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int);
insert into t1(c1) values(-100), (-10), (1), (10), (100);
--error 1526
alter table t1 partition by list(c1)(partition part_1 values in (-10, 1), partition part_2 values in (10, 100));
drop table t1;

# 测试range分区重分区为list分区时, 唯一的数据缺少映射的list分区
# 未debug版本OB报Internal Error, debug后报Table has no partition for value
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 bigint, c2 bigint)partition by range (c1)(partition part_1 values less than (20), partition part_2 values less than (100), partition part_3 values less than (maxvalue));
INSERT INTO t1 (c1, c2) values('16.00','1');
--error 1526
alter table t1 partition by list (c1)(partition part_1 values in (1, 3), partition part_2 values in (2, 4), partition part_3 values in (10, 15));
drop table t1;

# 测试range分区重分区为list分区时, 存在部分数据缺乏映射的list分区
# 未debug版本OB报Invalid Argument, debug后报Table has no partition for value
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 bigint, c2 bigint)partition by range (c1)(partition part_1 values less than (20), partition part_2 values less than (100), partition part_3 values less than (maxvalue));
INSERT INTO t1 (c1, c2) values('2.22','2');
INSERT INTO t1 (c1, c2) values('1.00','111');
INSERT INTO t1 (c1, c2) values('16.00','1');
--error 1526
alter table t1 partition by list (c1)(partition part_1 values in (1, 3), partition part_2 values in (2, 4), partition part_3 values in (10, 15));
drop table t1;

# 测试list分区重分区为range分区时, 数据缺少映射的range分区
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int)partition by list (c1)(partition part_1 values in (1, 3), partition part_2 values in (5, 7));
INSERT INTO t1 (c1) values(1), (3), (5), (7);
--error 1526
alter table t1 partition by range(c1)(partition part_1 values less than (2), partition part_2 values less than (6));
drop table t1;

# 测试hash区重分区为range分区时, 数据缺少映射的range分区
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int)partition by hash (c1) partitions 3;
INSERT INTO t1 (c1) values(1), (3), (5), (7);
--error 1526
alter table t1 partition by range(c1)(partition part_1 values less than (2), partition part_2 values less than (6));
drop table t1;

# 测试hash区重分区为list分区时, 数据缺少映射的list分区
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int)partition by hash (c1) partitions 3;
INSERT INTO t1 (c1) values(1), (3), (5), (7);
--error 1526
alter table t1 partition by list(c1)(partition part_1 values in (1, 3), partition part_2 values in (4, 5));
drop table t1;