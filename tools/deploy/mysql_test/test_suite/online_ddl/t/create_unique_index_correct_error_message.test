# owner: lihongqin.lhq
# owner group: storage
# description:this case is used for showing correct error message when creating unique index failed
#
--disable_warnings
drop table if exists t1;
create table t1(id int, value int, name varchar(2000));
connection default;
let $i = 0;
--source mysql_test/include/index_quick_major.inc

insert into t1 values(1, 2, "a");
insert into t1 values(1, 2, "bc");

#major freeze
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--error 1062
create unique index idx1 on t1(id, value);

insert into t1 values(2, 2, "bc");
--error 1062
create unique index idx2 on t1(value, name);

insert into t1 values(3, 3, "de");
insert into t1 values(3, 3, "de");
--error 1062
create unique index idx3 on t1(id, value, name);

drop table t1;

create table t1(id int, value int) partition by hash(id) partitions 2;
insert into t1 values (1, 2), (1, 2), (2, 1), (2, 2);
--error 1062
create unique index idx4 on t1(id, value) partition by hash(value) partitions 2;
--error 1062
create unique index idx5 on t1(id, value) local;

drop table t1;
