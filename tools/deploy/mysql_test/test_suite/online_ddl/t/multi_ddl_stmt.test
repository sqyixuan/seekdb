# owner: lihongqin.lhq
# owner group: storage
# description:this case is use for test stmt with multiple ddl command
#

--disable_warnings
drop table if exists t1;
--enable_warnings

# basic cases
create table t1(c1 int, c2 int);
insert into t1 values (1, 2);
--error 1091 # drop twice
alter table t1 drop c2, drop c2;
--error 1091 # drop newly added
alter table t1 add c0 int first, drop c0;
# FIXME: ob succeed now
# --error 1054 # modify dropped
# alter table t1 drop c2, modify c2 char(10);
# --error 1054 # drop modified
# alter table t1 modify c2 char(10), drop c2;
drop table t1;

# partition table
create table t1(c1 int, c2 int) partition by hash(c1) partitions 3;
insert into t1 values (1, 1);
insert into t1 values (2, 2);
insert into t1 values (3, 3);
create index i1 on t1(c2);
alter table t1 add column c3 int, modify c2 char(10) first, add c4 char(10);
select * from t1 order by c1;
select /*+ index(t1 i1) */ c2 from t1 order by c2;
drop table t1;

# subpartition table
create table t1(c1 int, c2 int, c3 int) partition by range(c1) subpartition by hash(c2)
subpartitions 3 (
    partition p3 values less than (5),
    partition p2 values less than (10),
    partition p1 values less than maxvalue
);
insert into t1 values (1, 1, 1);
insert into t1 values (7, 2, 3);
insert into t1 values (10, 3, 4);
create index i1 on t1(c2);
alter table t1 add column c4 int, modify c3 char(10) first, add c5 char(10);
select * from t1 order by c1;
select /*+ index(t1 i1) */ c2 from t1 order by c2;
drop table t1;

# virtual generated column
create table t1(c1 int, c2 int as (c1 + 1));
insert into t1(c1) values (1);
alter table t1 drop c2, modify c1 char(10);
insert into t1 values ('abc');
select * from t1;
drop table t1;

# stored generated column
create table t1(c1 int, c2 int as (c1 + 1) stored);
insert into t1(c1) values (1);
alter table t1 drop c2, modify c1 char(10);
select * from t1;
drop table t1;

# auto increment and change column order
create table t1(c1 int, c2 int primary key);
insert into t1 values (1, 99);
alter table t1 modify c2 int auto_increment, modify c1 char(10) after c2;
insert into t1(c1) values ('abc');
insert into t1(c1) values ('x');
select * from t1 order by c1;
drop table t1;

# auto increment and add, drop column
create table t1(c1 int, c2 int primary key);
insert into t1 values (1, 99);
alter table t1 modify c2 int auto_increment, add c0 char(10) first, drop c1;
insert into t1(c0) values ('abc');
insert into t1(c0) values ('123');
select * from t1 order by c0;
drop table t1;

# with constraint
create table t1(c1 int, c2 int not null, c3 int not null);
insert into t1 values (1, 2, 3);
alter table t1 add c0 int not null default 100 first, modify c2 char(10), drop c1;
select * from t1;
--error 1048
insert into t1 values (null, 'c2', 3);
--error 1048
insert into t1 values (1, 'c2', null);
insert into t1 values (1, null, 3);
select * from t1 order by c0, c2;
drop table t1;

# with failed not null constraint 
create table t1(c1 int);
insert into t1 values (null);
--error 1138
alter table t1 add c2 int, modify c1 int not null;
drop table t1;

# rename column
create table t1(c1 int);
insert into t1 values (1);
--error 1054
alter table t1 add c2 int, change c2 C2 char(10);
alter table t1 add c2 int;
--error 1091
alter table t1 change c2 c2x char(10), drop c2x;
drop table t1;

# cannot modify/change newly added columns
create table t1(c1 int);
--error 1054
alter table t1 add c2 int, modify c2 int;
--error 1054
alter table t1 modify c2 int, add c2 int;
--error 1054
alter table t1 add c2 int, modify c2 char(10);
--error 1054
alter table t1 modify c2 char(10), add c2 int;
--error 1054
alter table t1 add c2 int, change c2 c3 int;
--error 1054
alter table t1 change c2 c3 int, add C2 int;
--error 1054
alter table t1 add c2 int, change C2 c3 char(10);
--error 1054
alter table t1 change c2 c3 char(10), add c2 int;

# FIXME: cannot modify/change dropped columns
# alter table t1 add c2 int;
# alter table t1 drop c2, modify c2 int;
# alter table t1 drop c2, change c2 C2 int;
# alter table t1 change c2 c2 int, drop c2; # mysql failed, because it always do drop first
# alter table t1 add c2 int;
# alter table t1 modify c2 int, drop c2; # mysql failed
drop table t1;

# cannot rename twice
create table t1(c1 int);
--error 1054
alter table t1 change c1 c1x int, change c1 c1xx int;
--error 1054
alter table t1 change c1 c1x int, change c1x c1xx int;
drop table t1;

# can only drop original columns
create table t1(c1 int);
--error 1091
alter table t1 change c1 c1x int, drop c1x;

# cannot rename to newly added columns
--error 1060
alter table t1 add c2 int, change c1 c2 int;
--error 1060
alter table t1 add C2 int, change c1 c2 int;
--error 1060
alter table t1 add c2 int, change c1 C2 int;
--error 1060
alter table t1 change c1 c2 int, add c2 int;
--error 1060
alter table t1 change c1 c2 int, add C2 int;
--error 1060
alter table t1 change c1 C2 int, add c2 int;
drop table t1;

# rename with order changed
create table t1(c1 int, c2 int, c3 int);
alter table t1 change c2 c2x int, add c2xx int after c2x;
desc t1;
alter table t1 drop c2x, drop c2xx;
alter table t1 add c1x int after c1, modify c1 int after c1x;
desc t1;
drop table t1;
