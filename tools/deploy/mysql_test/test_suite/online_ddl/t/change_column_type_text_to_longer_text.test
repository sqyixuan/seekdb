# strict mode
set sql_mode = 'STRICT_TRANS_TABLES';
create table t1(c1 tinytext);
insert into t1 values (repeat('1', 255));
--error 1406
insert into t1 values (repeat('1', 256));
alter table t1 modify c1 text;
insert into t1 values (repeat('1', 65535));
--error 1406
insert into t1 values (repeat('1', 65536));
alter table t1 modify c1 mediumtext;
# MySQL 5.6 shows Result of repeat() was larger than max_allowed_packet (4194304) - truncated
# insert into t1 values (repeat('1', 16777215));
# --error 1406
# insert into t1 values (repeat('1', 16777216));
# alter table t1 modify c1 longtext;
# insert into t1 values (repeat('1', 4294967295));
# --error 1406
# insert into t1 values (repeat('1', 4294967296));
drop table t1;

create table t1(c1 longtext);
insert into t1 values (repeat('1', 65536));
--error 1406
alter table t1 modify c1 text;
truncate table t1;
insert into t1 values (repeat('1', 65535));
alter table t1 modify c1 text;

--error 1406
alter table t1 modify c1 tinytext;
truncate table t1;
insert into t1 values (repeat('1', 256));
--error 1406
alter table t1 modify c1 tinytext;
truncate table t1;
insert into t1 values (repeat('1', 255));
alter table t1 modify c1 tinytext;
drop table t1;
