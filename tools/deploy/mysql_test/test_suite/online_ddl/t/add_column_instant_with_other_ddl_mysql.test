drop table xingrui_exchange_table1,xingrui_exchange_table2;
create table xingrui_exchange_table1 (col1 int, col2 int) partition by range(col1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
