# owner : xingrui.cwh
# owner group : rs
# description : this case is used for test alter table, add column instant with other ddl
# case 1.add column instant with drop column should be offline
# case 2.add column instant with modify column offline should be offline
# case 3.add column instant with change column should be offline
# case 4.add column instant with alter column should be offline
# case 5.add column instant with primary key should be offline
# case 6.add column instant with index should be offline
# case 7.add column instant with partition should be offline
# case 8.add column instant with constraint should be offline
# case 9.add column instant with character should be offline
# case 10.add column instant with foreign key should be offline
# case 11.create table like after add column instant
# case 12.truncate table after add column instant
# case 13.do offline ddl after add column instant
# case 14.add column instant with lob_inrow
# case 15.add column instant with direct load data
# case 16.exchange partition after add column instant
# case 17.split partition after add column instant
# case 18.column group with add column instant


connect(sys_conn,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connect(mysql_conn,$OBMYSQL_MS0,root@sys,,test,$OBMYSQL_PORT);
connection mysql_conn;
set @@session.recyclebin = off;
alter system set default_table_store_format = "row";
sleep 2;

--disable_query_log
--disable_warnings
--disable_result_log
drop table if exists xingrui_drop_column_table;
drop table if exists xingrui_modify_column_table;
drop table if exists xingrui_change_column_table;
drop table if exists xingrui_alter_column_table;
drop table if exists xingrui_primary_key_table;
drop table if exists xingrui_index_column_table;
drop table if exists xingrui_partition_table;
drop table if exists xingrui_constraint_table;
drop table if exists xingrui_character_table;
drop table if exists xingrui_fk_child_table;
drop table if exists xingrui_fk_parent_table;
drop table if exists xingrui_normal_table;
drop table if exists xingrui_create_like_table;
drop table if exists xingrui_create_like_orig;
drop table if exists xingrui_truncate_table;
drop table if exists xingrui_offline_table;
drop table if exists xingrui_lob_inrow_table;
drop table if exists xingrui_load_data_table1;
drop table if exists xingrui_load_data_table2;
drop table if exists xingrui_exchange_table1;
drop table if exists xingrui_exchange_table2;
drop table if exists xingrui_split_partition_table;
drop table if exists xingrui_column_group_table;
--enable_query_log
--enable_warnings
--enable_result_log

connection sys_conn;
let $alter_tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'sys', tenant_id, 1);

#case 1.add column instant with drop column should be offline
connection mysql_conn;
create table xingrui_drop_column_table(col1 int, col2 varchar(10), col3 int);
insert into xingrui_drop_column_table values(1, 'a', 3);
connection sys_conn;
let $before_drop_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_drop_column_table' and tenant_id = $alter_tenant_id, table_id, 1);

connection mysql_conn;
alter table xingrui_drop_column_table add column col4 bigint after col1, drop column col3;
insert into xingrui_drop_column_table values(1, 2, '3');
select * from xingrui_drop_column_table;

connection sys_conn;
let $after_drop_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_drop_column_table' and tenant_id = $alter_tenant_id, table_id, 1);
if ($after_drop_column == $before_drop_column)
{
  --echo "error table id should change after add column instant with drop column"
}

#case 2.add column instant with modify column
#case 2.1 add column instant with modify column offline
connection mysql_conn;
create table xingrui_modify_column_table(col1 int, col2 varchar(10), col3 int);
insert into xingrui_modify_column_table values(1, 'a', 2);
connection sys_conn;
let $before_modify_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_modify_column_table' and tenant_id = $alter_tenant_id, table_id, 1);

connection mysql_conn;
alter table xingrui_modify_column_table add col4 int after col1, modify col2 varchar(10) after col3;
insert into xingrui_modify_column_table values(1, 2, 3, '4');
select * from xingrui_modify_column_table;

connection sys_conn;
let $after_modify_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_modify_column_table' and tenant_id = $alter_tenant_id, table_id, 1);
if ($before_modify_column == $after_modify_column)
{
  --echo "error table id should change after add column instant with modify column offline"
}

#case 2.2 add column instant with modify column online
connection sys_conn;
let $before_modify_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_modify_column_table' and tenant_id = $alter_tenant_id, table_id, 1);

connection mysql_conn;
alter table xingrui_modify_column_table add col5 int after col1, modify col3 int;
insert into xingrui_modify_column_table values(1, 2, 3, 4, '5');
select * from xingrui_modify_column_table;

connection sys_conn;
let $after_modify_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_modify_column_table' and tenant_id = $alter_tenant_id, table_id, 1);
if ($before_modify_column != $after_modify_column)
{
  --echo "error table id should not change after add column instant with modify column online"
}

#case 3.add column instant with change column should be offline
connection mysql_conn;
create table xingrui_change_column_table(col1 int, col2 bigint, col3 int);
insert into xingrui_change_column_table values(1, 2, 3);
connection sys_conn;
let $before_modify_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_change_column_table' and tenant_id = $alter_tenant_id, table_id, 1);

connection mysql_conn;
alter table xingrui_change_column_table add col4 int after col1, change col2 col2 int;
insert into xingrui_change_column_table values(1, 2, 3, 4);
select * from xingrui_change_column_table;

connection sys_conn;
let $after_modify_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_change_column_table' and tenant_id = $alter_tenant_id, table_id, 1);
if ($before_modify_column == $after_modify_column)
{
  --echo "error table id should change after add column instant with change column"
}

#case 4.add column instant with alter column should be offline
connection mysql_conn;
create table xingrui_alter_column_table(col1 int, col2 varchar(10), col3 int);
insert into xingrui_alter_column_table values(1, 'a', 2);
connection sys_conn;
let $before_modify_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_alter_column_table' and tenant_id = $alter_tenant_id, table_id, 1);

connection mysql_conn;
alter table xingrui_alter_column_table add col4 int after col1, alter column col1 set default 100;
insert into xingrui_alter_column_table values(1, 2, '3', 4);
select * from xingrui_alter_column_table;

connection sys_conn;
let $after_modify_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_alter_column_table' and tenant_id = $alter_tenant_id, table_id, 1);
if ($before_modify_column == $after_modify_column)
{
  --echo "error table id should change after add column instant with alter column offline"
}

#case 5.add column instant with primary_key should be offline
connection mysql_conn;
create table xingrui_primary_key_table(col1 int, col2 varchar(10), col3 int);
insert into xingrui_primary_key_table values(1, 'a', 2);
#case 5.1 add column instant with add primary_key
connection mysql_conn;
--error 1235
alter table xingrui_primary_key_table add col4 int after col1, add primary key(col1);
insert into xingrui_primary_key_table values(3, 'a', 4);
select * from xingrui_primary_key_table;

#case 5.2 add column instant with drop primary_key
connection mysql_conn;
alter table xingrui_primary_key_table add primary key(col1);
connection mysql_conn;
--error 1235
alter table xingrui_primary_key_table add col5 int after col1, drop primary key;
insert into xingrui_primary_key_table values(5, 'b', 6);
select * from xingrui_primary_key_table;

#case 5.3 add column instant with alter primary_key
connection mysql_conn;
#mysql #mysql is no such syntax
--error 1064
alter table xingrui_primary_key_table add col6 int after col1, modify primary key(col1, col3);
insert into xingrui_primary_key_table values(7, 'a', 8);
select * from xingrui_primary_key_table;

#case 6 add column instant with index
#case 6.1 add column instant with add index
connection mysql_conn;
create table xingrui_index_column_table(col1 int, col2 int, col3 int);
insert into xingrui_index_column_table values(1, 2, 3);
connection sys_conn;
let $before_index_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_index_column_table' and tenant_id = $alter_tenant_id, table_id, 1);

connection mysql_conn;
alter table xingrui_index_column_table add col4 int after col1, add index xingrui_index(col3);
insert into xingrui_index_column_table values(1, 2, 3, 4);
select * from xingrui_index_column_table;

connection sys_conn;
let $after_index_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_index_column_table' and tenant_id = $alter_tenant_id, table_id, 1);
if ($before_index_column == $after_index_column)
{
  --echo "error table id should change after add column instant with index column offline"
}

#case 6.2 add column instant with rebuild index
connection mysql_conn;
drop table xingrui_index_column_table;
create table xingrui_index_column_table (col1 int, col2 int) partition by range(col1) (partition p1 values less than(1), partition p2 values less than(2));
create index xingrui_index on xingrui_index_column_table(col1) global;
insert into xingrui_index_column_table values(1, 2);
connection sys_conn;
let $before_index_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_index_column_table' and tenant_id = $alter_tenant_id, table_id, 1);
connection mysql_conn;
#mysql is no such syntax
--error 1064
alter table xingrui_index_column_table add col3 int after col1, truncate partition p1;
select * from xingrui_index_column_table;

#case 6.3 add column instant with drop index
connection mysql_conn;
drop table xingrui_index_column_table;
create table xingrui_index_column_table(col1 int, col2 varchar(10), col3 int);
insert into xingrui_index_column_table values(1, 'a', 2);
alter table xingrui_index_column_table add index xingrui_index(col3);
--error 1235
alter table xingrui_index_column_table add col4 int after col1, drop index xingrui_index;
select * from xingrui_index_column_table;

#case 6.4 add column instant with alter index
connection mysql_conn;
--error 1235
alter table xingrui_index_column_table add col4 int after col1, alter index xingrui_index invisible;
select * from xingrui_index_column_table;

#case 6.5 add column instant with alter index parallel
connection mysql_conn;
--error 1235
alter table xingrui_index_column_table add col4 int after col1, alter index xingrui_index parallel 2;
select * from xingrui_index_column_table;

#case 6.6 add column instant with rename index
connection sys_conn;
let $before_index_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_index_column_table' and tenant_id = $alter_tenant_id, table_id, 1);

connection mysql_conn;
alter table xingrui_index_column_table add col4 int after col1, rename index xingrui_index to xingrui_index1;
insert into xingrui_index_column_table values(1, 2, 3, 4);
select * from xingrui_index_column_table;

connection sys_conn;
let $after_index_column = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_index_column_table' and tenant_id = $alter_tenant_id, table_id, 1);
if ($before_index_column == $after_index_column)
{
  --echo "error table id should change after add column instant with rename index column"
}

#case 7 add column instant with partition
#case 7.1 add column instant with repartition
connection mysql_conn;
create table xingrui_partition_table(col1 int, col2 int, col3 int);
insert into xingrui_partition_table values(1, 2, 3);
#mysql is no such syntax
--error 1064
alter table xingrui_partition_table add column col4 int after col1, partition by range(col1) (partition p1 values less than(1), partition p2 values less than(2));
select * from xingrui_partition_table;

#case 7.2 add column instant with add partition
connection mysql_conn;
alter table xingrui_partition_table partition by range(col1) (partition p1 values less than(1), partition p2 values less than(2));
#mysql is no such syntax
--error 1064
alter table xingrui_partition_table add column col4 int after col1, add partition(partition p3 values less than(3));
select * from xingrui_partition_table;

#case 8 add column instant with constraint should be offline
connection mysql_conn;
create table xingrui_constraint_table(col1 int, col2 int, col3 int);
insert into xingrui_constraint_table values(1, 2, 3);

#case 8.1 add column instant with add constraint
--error 1235
alter table xingrui_constraint_table add column col3 int after col1, add constraint xingrui_constraint check(col3 > 0);
select * from xingrui_constraint_table;
alter table xingrui_constraint_table add constraint xingrui_constraint check(col3 > 0);

#case 8.2 add column instant with drop constraint
alter table xingrui_constraint_table add column col4 int after col1, drop constraint xingrui_constraint;
select * from xingrui_constraint_table;

#case 8.3 add column instant with alter constraint
--error 1064
#mysql is no such syntax
alter table xingrui_constraint_table add column col5 int after col1, modify constraint xingrui_constraint disable;
select * from xingrui_constraint_table;

#case 9 add column instant with character
connection mysql_conn;
create table xingrui_character_table(col1 int,col2 int,col3 int);
connection sys_conn;
let $before_character = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_character_table' and tenant_id = $alter_tenant_id, table_id, 1);

connection mysql_conn;
alter table xingrui_character_table add column col4 int after col1,convert to character set 'utf16' COLLATE 'utf16_bin';
insert into xingrui_character_table values(1, 2, 3, 4);
select * from xingrui_character_table;

connection sys_conn;
let $after_character = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_character_table' and tenant_id = $alter_tenant_id, table_id, 1);
if ($before_character == $after_character)
{
  --echo "error table id should change after add column instant with change character column offline"
}

#case 10.add column instant with add foreign
connection mysql_conn;
create table xingrui_fk_parent_table (id int primary key, number int);
create table xingrui_fk_child_table (parent_id int, number int);
#case 10.1 add column with add foreign key
--error 1235
alter table xingrui_fk_child_table add column child_id int after parent_id, add constraint child_fk foreign key (parent_id) references xingrui_fk_parent_table(id);
select * from xingrui_fk_child_table;

alter table xingrui_fk_child_table add constraint child_fk foreign key (parent_id) references xingrui_fk_parent_table(id);
#case 10.2 add column instant,drop foreign key
connection sys_conn;
let $before_drop_foreign_key = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_fk_child_table' and tenant_id = $alter_tenant_id, table_id, 1);

connection mysql_conn;
alter table xingrui_fk_child_table add column child_id int after parent_id,
  drop foreign key child_fk;
insert into xingrui_fk_child_table values(1, 2, 3);
select * from xingrui_fk_child_table;

connection sys_conn;
let $after_drop_foreign_key = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_fk_child_table' and tenant_id = $alter_tenant_id, table_id, 1);
if ($before_drop_foreign_key == $after_drop_foreign_key)
{
  --echo "table id should change after drop foreign key with add column instant"
}

#case 10.3 add column instant, modify foreign key
connection sys_conn;
let $before_drop_foreign_key = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_fk_child_table' and tenant_id = $alter_tenant_id, table_id, 1);
connection mysql_conn;
--error 1064
#mysql is no such syntax
alter table xingrui_fk_child_table add column modify_foreign_key1 int after parent_id,
    modify constraint child_fk disable;
select * from xingrui_fk_child_table;

# case 11.create table like after add column
connection mysql_conn;
create table xingrui_normal_table (col1 int, col2 varchar(10));
insert into xingrui_normal_table values (1,'a');
alter table xingrui_normal_table add column col3 int after col1;
connection sys_conn;
let $before_create_like = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where table_name = 'xingrui_normal_table' and tenant_id = $alter_tenant_id) and column_name = "col3" and tenant_id = $alter_tenant_id, column_id, 1);

connection mysql_conn;
create table xingrui_create_like_table like xingrui_normal_table;
insert into xingrui_create_like_table values (1, 2, 'a');
select * from xingrui_create_like_table;

#column id should change after create table like
connection sys_conn;
let $after_create_like = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where table_name = 'xingrui_create_like_table' and tenant_id = $alter_tenant_id) and column_name = "col3" and tenant_id = $alter_tenant_id, column_id, 1);
if ($before_create_like != $after_create_like)
{
  --echo "error column id should not change after create table like"
}

connection mysql_conn;
drop table xingrui_create_like_table;
create table xingrui_create_like_orig(col1 int, col2 int, col3 int, key index_1(col2));
alter table xingrui_create_like_orig add column col4 int after col1;
create table xingrui_create_like_table like xingrui_create_like_orig;
connection sys_conn;
let $data_table_col = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where table_name = 'xingrui_create_like_table' and tenant_id = $alter_tenant_id) and column_name = "col2" and tenant_id = $alter_tenant_id, column_id, 1);
let $data_table_id = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_create_like_table' and tenant_id = $alter_tenant_id, table_id, 1);
let $index_table_col = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where data_table_id = $data_table_id and tenant_id = $alter_tenant_id) and column_name = "col2" and tenant_id = $alter_tenant_id, column_id, 1);
if ($data_table_col != $index_table_col)
{
  --echo "error column id should not change after create table like"
}

# case 12.truncate table after add column
# case 12.1 serial truncate
connection sys_conn;
alter system set _parallel_ddl_control = "TRUNCATE_TABLE:OFF" tenant = all;
sleep 2;
connection mysql_conn;
create table xingrui_truncate_table(col1 int, col2 varchar(10));
insert into xingrui_truncate_table values (1,'a');
alter table xingrui_truncate_table add column col3 bigint after col1;
connection sys_conn;
let $before_truncate = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where table_name = 'xingrui_truncate_table' and tenant_id = $alter_tenant_id) and column_name = "col3" and tenant_id = $alter_tenant_id, column_id, 1);

connection mysql_conn;
truncate table xingrui_truncate_table;
select * from xingrui_truncate_table;

connection sys_conn;
let $after_truncate = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where table_name = 'xingrui_truncate_table' and tenant_id = $alter_tenant_id) and column_name = "col3" and tenant_id = $alter_tenant_id, column_id, 1);
if ($before_truncate != $after_truncate)
{
  --echo "error column id should not change after old truncate table"
}

connection mysql_conn;
drop table xingrui_truncate_table;
create table xingrui_truncate_table(col1 int, col2 int, col3 int, key index_1(col2));
alter table xingrui_truncate_table add column col4 int after col2;
truncate table xingrui_truncate_table;

connection sys_conn;
let $data_table_col = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where table_name = 'xingrui_truncate_table' and tenant_id = $alter_tenant_id) and column_name = "col2" and tenant_id = $alter_tenant_id, column_id, 1);
let $data_table_id = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_truncate_table' and tenant_id = $alter_tenant_id, table_id, 1);
let $index_table_col = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where data_table_id = $data_table_id and tenant_id = $alter_tenant_id) and column_name = "col2" and tenant_id = $alter_tenant_id, column_id, 1);
if ($data_table_col != $index_table_col)
{
  --echo "error column id should not change after old truncate table"
}

# case 12.2 parallel truncate
connection sys_conn;
alter system set _parallel_ddl_control = "TRUNCATE_TABLE:ON" tenant = all;
sleep 2;
connection mysql_conn;
drop table xingrui_truncate_table;
create table xingrui_truncate_table(col1 int, col2 varchar(10));
insert into xingrui_truncate_table values (1,'a');
alter table xingrui_truncate_table add column col3 bigint after col1;
connection sys_conn;
let $before_truncate = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where table_name = 'xingrui_truncate_table' and tenant_id = $alter_tenant_id) and column_name = "col3" and tenant_id = $alter_tenant_id, column_id, 1);

connection mysql_conn;
truncate table xingrui_truncate_table;
select * from xingrui_truncate_table;

connection sys_conn;
let $after_truncate = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where table_name = 'xingrui_truncate_table' and tenant_id = $alter_tenant_id) and column_name = "col3" and tenant_id = $alter_tenant_id, column_id, 1);
if ($before_truncate != $after_truncate)
{
  --echo "error column id should not change after parallel truncate table"
}

# case 13 offline ddl after add column instant
connection mysql_conn;
create table xingrui_offline_table(col1 int, col2 varchar(10));
insert into xingrui_offline_table values (1,'a');
alter table xingrui_offline_table add column col3 bigint after col1;
connection sys_conn;
let $before_offline = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where table_name = 'xingrui_offline_table' and tenant_id = $alter_tenant_id) and column_name = "col3" and tenant_id = $alter_tenant_id, column_id, 1);

connection mysql_conn;
alter table xingrui_offline_table change column col1 col1 int after col3;
insert into xingrui_offline_table values(1, 2, 'a');
select * from xingrui_offline_table;

connection sys_conn;
let $after_offline = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where table_name = 'xingrui_offline_table' and tenant_id = $alter_tenant_id) and column_name = "col3" and tenant_id = $alter_tenant_id, column_id, 1);
if ($before_offline == $after_offline)
{
  --echo "error add column instant's column id should change after offline ddl"
}

#case 14 add column instant with lob inrow
connection mysql_conn;
create table xingrui_lob_inrow_table (col1 text, col2 text) DEFAULT_LOB_INROW_THRESHOLD=1024;
insert into xingrui_lob_inrow_table values (1,1);
connection sys_conn;
let $before_offline = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where table_name = 'xingrui_lob_inrow_table' and tenant_id = $alter_tenant_id) and column_name = "col3" and tenant_id = $alter_tenant_id, column_id, 1);
connection mysql_conn;
alter table xingrui_lob_inrow_table add column col3 int after col1, set lob_inrow_threshold = 2000;
insert into xingrui_lob_inrow_table values(1, 2, 'a');
select * from xingrui_lob_inrow_table;

connection sys_conn;
let $after_offline = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where table_name = 'xingrui_lob_inrow_table' and tenant_id = $alter_tenant_id) and column_name = "col3" and tenant_id = $alter_tenant_id, column_id, 1);
if ($before_offline == $after_offline)
{
  --echo "error add column instant's column id should change with set lob_inrow_threshold"
}

#case 15 add column instant with direct_load_data
connection mysql_conn;
create table xingrui_load_data_table1 (col1 int primary key, col2 int);
insert into xingrui_load_data_table1 values(1,2);
insert into xingrui_load_data_table1 values(3,2);
