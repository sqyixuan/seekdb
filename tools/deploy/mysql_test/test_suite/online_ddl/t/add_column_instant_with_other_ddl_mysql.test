connection sys_conn;
let $before = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where table_name = 'xingrui_load_data_table1' and tenant_id = $alter_tenant_id) and column_name = "col3" and tenant_id = $alter_tenant_id, column_id, 1);

connection mysql_conn;
insert /*+ append enable_parallel_dml parallel(2) */ into xingrui_load_data_table1 select * from xingrui_load_data_table2;

connection sys_conn;
let $after = query_get_value(select column_id from __all_virtual_column where table_id in (select table_id from __all_virtual_table where table_name = 'xingrui_load_data_table1' and tenant_id = $alter_tenant_id) and column_name = "col3" and tenant_id = $alter_tenant_id, column_id, 1);
connection mysql_conn;
select * from xingrui_load_data_table1;
if ($before != $after)
{
  --echo "error add column instant's column id should not change after direct_load_data"
}

