#case 16.3 exchange partition with add column instant should be OFFLINE DDL
connection mysql_conn;
drop table xingrui_exchange_table1,xingrui_exchange_table2;
create table xingrui_exchange_table1 (col1 int, col2 int) partition by range(col1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
insert into xingrui_exchange_table1 values(1,2);
create table xingrui_exchange_table2 (col1 int, col2 int);
insert into xingrui_exchange_table2 values(1, 2);
#should be not support error, need cangdi to fix
#--error 1235
alter table xingrui_exchange_table1 exchange partition M1 with table xingrui_exchange_table2 WITHOUT VALIDATION, add column col3 int after col1;

#after offline ddl, can exchange table;
alter table xingrui_exchange_table1 add column col3 int generated always as (col1 * 2) stored;
alter table xingrui_exchange_table2 add column col3 int generated always as (col1 * 2) stored;
alter table xingrui_exchange_table1 exchange partition M1 with table xingrui_exchange_table2 WITHOUT VALIDATION;

#case 17 split partition after add column instant
#case 17.1 split partition after add column instant
alter system SET enable_auto_split = false;
sleep 5;
create table xingrui_split_partition_table (col1 int, col2 int, col3 int, primary key(col1))
    PARTITION BY RANGE(col1) (
        PARTITION p0 VALUES LESS THAN (30),
        PARTITION p1 VALUES LESS THAN (40),
        PARTITION p2 VALUES LESS THAN (50)
    );
insert into xingrui_split_partition_table values(1,2,3);
alter table xingrui_split_partition_table add index test(col1);
alter table xingrui_split_partition_table add column col4 int first;
connection sys_conn;
let $before_table_id = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_split_partition_table' and tenant_id = $alter_tenant_id, table_id, 1);
let $before_column_id = query_get_value(select column_id from __all_virtual_column where table_id = table_id and column_name = "col4" and tenant_id = $alter_tenant_id, column_id, 1);

connection mysql_conn;
insert into xingrui_split_partition_table values(4,2,2,3);
alter table xingrui_split_partition_table REORGANIZE PARTITION p2 INTO (
    PARTITION aaaaaa123 VALUES LESS THAN (45),
    PARTITION p2 VALUES LESS THAN (50)
);
connection sys_conn;
let $after_table_id = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_split_partition_table' and tenant_id = $alter_tenant_id, table_id, 1);
let $after_column_id = query_get_value(select column_id from __all_virtual_column where table_id = table_id and column_name = "col4" and tenant_id = $alter_tenant_id, column_id, 1);
if ($before_table_id != $after_table_id) {
  --echo "error split partition after add column instant's table_id should not change";
}
if ($before_column_id != $after_column_id) {
  --echo "error split partition after add column instant's column_id should not change";
}

connection mysql_conn;
#base on add column instant's column to split partition
--error 1503
#primary key must contain all column to partition by
alter table xingrui_split_partition_table partition by range(col4) (partition p0 values less than(30), partition p1 values less than(40));
sleep 5;
alter table xingrui_split_partition_table drop primary key;
delete from xingrui_split_partition_table;
insert into xingrui_split_partition_table values(1, 2, 3, 4);
alter table xingrui_split_partition_table add primary key(col1, col2, col3, col4);
alter table xingrui_split_partition_table partition by range(col4) (partition p0 values less than(30), partition p1 values less than(40));
insert into xingrui_split_partition_table values(6,7,8,9);

#case 17.2 split partition with add column instant should be OFFLINE DDL
connection mysql_conn;
drop table xingrui_split_partition_table;
alter system SET enable_auto_split = false;
create table xingrui_split_partition_table (col1 int, col2 int, col3 int, primary key(col1))
    PARTITION BY RANGE(col1) (
        PARTITION p0 VALUES LESS THAN (30),
        PARTITION p1 VALUES LESS THAN (40),
        PARTITION p2 VALUES LESS THAN (50)
    );
insert into xingrui_split_partition_table values(1,2,3);
alter table xingrui_split_partition_table add index test(col1);
connection sys_conn;
let $before_table_id = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_split_partition_table' and tenant_id = $alter_tenant_id, table_id, 1);

connection mysql_conn;
insert into xingrui_split_partition_table values(2,3,4);
#should be not support error, need pingzhou to fix
--error 4016
alter table xingrui_split_partition_table REORGANIZE PARTITION p2 INTO (
    PARTITION p5 VALUES LESS THAN (45),
    PARTITION p2 VALUES LESS THAN (50)
), add column col4 int first;
connection sys_conn;
let $after_table_id = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_split_partition_table' and tenant_id = $alter_tenant_id, table_id, 1);
if ($before_table_id == $after_table_id) {
  --echo "error split partition after add column instant's column_id should change";
}

#case 17.3 auto split partition with add column instant
connection mysql_conn;
drop table xingrui_split_partition_table;
alter system SET enable_auto_split = true;
create table xingrui_split_partition_table(col1 int auto_increment primary key, col2 VARCHAR(150), col3 int, col4 VARCHAR(4000)) partition by range() size('unlimited');
alter table xingrui_split_partition_table add column col5 text after col1;
create index xingrui_split_partition_table on xingrui_split_partition_table(col1) local;
alter table xingrui_split_partition_table partition by range() size('128MB');

connection sys_conn;
--disable_query_log
eval select auto_part,auto_part_size,part_func_type,part_level from __all_virtual_table where table_name = 'xingrui_split_partition_table' and tenant_id = $alter_tenant_id;
let $before_count = query_get_value(select count(*) as cnt from __all_virtual_part where table_id in (select table_id from __all_virtual_table where table_name = "xingrui_split_partition_table" and tenant_id = $alter_tenant_id), cnt, 1);
--enable_query_log

connection mysql_conn;
set session ob_query_timeout=1000000000;
insert into xingrui_split_partition_table(col2,col3,col4,col5) select
  randstr(150, random()),
  uniform(1, 100000000, random()),
  randstr(4000, random()),
  randstr(100, random())
from
  table(generator(10));
commit;

connection mysql_conn;
alter system SET enable_auto_split = false;

#case 18.add column group with add column instant
#case 18.1 table with all/each column group before
connection mysql_conn;
alter system set default_table_store_format = "compound";
create table xingrui_column_group_table(col1 int, col2 int) with column group(all columns, each column);
insert into xingrui_column_group_table values(1, 2);
alter table xingrui_column_group_table add column col3 int after col1;
create index xingrui_index on xingrui_column_group_table(col3) with column group(all columns, each column);
insert into xingrui_column_group_table values(1, 3, 2);
alter table xingrui_column_group_table add column col4 int generated always as (col1 * 2) virtual after col1;
connection sys_conn;
let $table_id = query_get_value(select table_id from __all_virtual_table where table_name = 'xingrui_column_group_table' and tenant_id = $alter_tenant_id, table_id, 1);
let $table_column_id = query_get_value(select column_id from __all_virtual_column where table_id = $table_id and column_name = "col3" and tenant_id = $alter_tenant_id, column_id, 1);
--disable_query_log
eval select column_group_id from __all_virtual_column_group where table_id = $table_id and column_group_name like "%col3%" and tenant_id = $alter_tenant_id;
eval select column_group_id,column_id from __all_virtual_column_group_mapping where table_id = $table_id and column_id = $table_column_id and tenant_id = $alter_tenant_id;
--enable_query_log
connection mysql_conn;
alter table xingrui_column_group_table drop column group(all columns, each column);


