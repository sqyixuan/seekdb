# owner: lihongqin.lhq
# owner group: storage
# description: this case is use for testing create index on char prefix
#

--disable_warnings
drop table if exists t1;
--enable_warnings

set sql_mode='PAD_CHAR_TO_FULL_LENGTH';

create table t1(c1 int, c2 char(10), c3 varchar(10));
insert into t1 values (1, 'a', 'b');
insert into t1 values (2, '', '');
insert into t1 values (3, ' ', ' ');
insert into t1 values (4, '  ', '  ');

create index i1 on t1(c2);
create index i2 on t1(c2(5));
create index i3 on t1(c3(5));

select * from t1;
select c2 from t1 where c2 like ' %';
select c2 from t1 where c2 like '%';
select c2 from t1 where c2 like 'a%';
select c2 from t1 where c2 like 'a  %';
select /*+ index(t1 i3) */ c3 from t1;
select /*+ index(t1 i1) */ c2 from t1;

drop table t1;

# unique index
create table t1(c1 int, c2 char(10), c3 varchar(10));
insert into t1 values (1, ' ', '');
insert into t1 values (2, ' a', 'x');
insert into t1 values (3, ' aa', ' ');
--error 1062
create unique index i1 on t1(c2(2));
create unique index i2 on t1(c2(3));
create unique index i3 on t1(c2(5));

select * from t1 where c2 like ' %';
select * from t1 where c2 like 'a%';
select * from t1 where c2 like 'aa%';
select * from t1 where c2 like ' a%';

drop table t1;

create table t1(c1 char(10));
create index i1 on t1(c1(4));
insert into t1 values ('123    a');
insert into t1 values ('ab    12');

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

create index i2 on t1(c1(4));

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

drop table t1;