####测试grouping相关基础语法####
####所有非多模数据类型在grouping中使用
--error 0,1051
drop table zct1_grouping;
CREATE TABLE zct1_grouping(c1 TINYINT,c2 SMALLINT,c3 MEDIUMINT,c4 int,c5 BIGINT,c6 DECIMAL(5,2),c7 float(5,2),c8 double(5,2),c9 bit(50),c10 TINYINT(255) UNSIGNED,c11 SMALLINT(255) UNSIGNED,c12 MEDIUMINT(255) UNSIGNED,c13 int (255) UNSIGNED,c14 bigint(255) UNSIGNED,c15 decimal(10,2) UNSIGNED,c16 float(5,2) UNSIGNED,c17 double(5,2) UNSIGNED,c18 datetime,c19 timestamp,c20 date,c21 time,c22 year,c23 char,c24 varchar(50),c25 binary(7),c26 varbinary(50),c27 TINYBLOB,c28 BLOB,c29 MEDIUMBLOB,c30 LONGBLOB,c31 TINYTEXT,c32 TEXT,c33 MEDIUMTEXT,c34 LONGTEXT);

