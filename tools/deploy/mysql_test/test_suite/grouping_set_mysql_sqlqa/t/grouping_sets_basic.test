####不同属性的字段
##index
alter table zct1_grouping add index (c1);
select c1 from zct1_grouping group by grouping sets(c1) order by c1;
select c1 from zct1_grouping group by rollup(c1) order by c1;
select c1 from zct1_grouping group by cube(c1) order by c1;

alter table zct1_grouping add index idx_zct1_eachcol(c1,c2,c3) WITH COLUMN GROUP(each column);
select c1,c2,c3 from zct1_grouping group by grouping sets(c1,c2,c3) order by c1,c2,c3;
select c1,c2,c3 from zct1_grouping group by rollup(c1,c2,c3) order by c1,c2,c3;
select c1,c2,c3 from zct1_grouping group by cube(c1,c2,c3) order by c1,c2,c3;

##CONSTRAINT
--error 0,1051
drop table zct1_grouping2;
create table zct1_grouping2(a int, b varchar(5), c date);
insert into zct1_grouping2 values(1, 'a', '2020-01-01');
insert into zct1_grouping2 values(2, 'b', '2020-01-02');
insert into zct1_grouping2 values(3, 'c', '2020-01-03');
insert into zct1_grouping2 values(4, 'd', '2020-01-04');
insert into zct1_grouping2 values(5, 'e', '2020-01-05');

alter table zct1_grouping2 add constraint zct1_a_unique unique(a);
select a from zct1_grouping2 group by grouping sets(a) order by a;
select a from zct1_grouping2 group by rollup(a) order by a;
select a from zct1_grouping2 group by cube(a) order by a;

--error 0,1051
drop table zct1_grouping3;
create table zct1_grouping3(a int, b varchar(5) ,primary key( a));
insert into zct1_grouping3 values( 1, 'a'), (2, 'b'), (3, 'c'), (4, 'd'), (5, 'e');

alter table zct1_grouping2 add constraint zct1_a_for foreign key(a) references zct1_grouping3(a);
select a from zct1_grouping2 group by grouping sets(a) order by a;
select a from zct1_grouping2 group by rollup(a) order by a;
select a from zct1_grouping2 group by cube(a) order by a;

##primary
select /*+parallel(3) INDEX(zct1_grouping3 PRIMARY)*/a from zct1_grouping3 group by grouping sets(a) having a > 1 order by a;
select /*+parallel(3) INDEX(zct1_grouping3 PRIMARY)*/a from zct1_grouping3 group by rollup(a) having a > 1 order by a;
select /*+parallel(3) INDEX(zct1_grouping3 PRIMARY)*/a from zct1_grouping3 group by cube(a) having a > 1 order by a;

select * from zct1_grouping3 group by cube(a,b)  having a > 1 order by a,b;
select * from zct1_grouping3 group by rollup(a,b)  having a > 1 order by a,b;
select * from zct1_grouping3 group by grouping sets(a,b)  having a > 1 order by a,b;

##AUTO_INCREMENT
alter table zct1_grouping2 add ai int AUTO_INCREMENT COMMENT 'auto increment' first;
select ai from zct1_grouping2 group by grouping sets(ai) having ai > 1 order by ai;
select ai from zct1_grouping2 group by rollup(ai) having ai > 1 order by ai;
select ai from zct1_grouping2 group by cube(ai) having ai > 1 order by ai;

##生成列
alter table zct1_grouping2 add gc int GENERATED ALWAYS AS (a+b) VIRTUAL;
select gc from zct1_grouping2 group by grouping sets(gc) having gc > 1 order by gc;
select gc from zct1_grouping2 group by rollup(gc) having gc > 1 order by gc;
select gc from zct1_grouping2 group by cube(gc)  having gc > 1 order by gc;

alter table zct1_grouping2 drop column ai;
alter table zct1_grouping2 drop column gc;

####视图
--error 0,1051
DROP VIEW ZCV1;
create view zcv1 as select * from zct1_grouping2 group by grouping sets(rollup(a,b,c),cube(a,b,c));

####mv
--error 0,9755
DROP MATERIALIZED VIEW LOG ON zct1_grouping2;
--error 0,9757
DROP MATERIALIZED VIEW ZC_MV1;

CREATE MATERIALIZED VIEW LOG ON zct1_grouping2 parallel 1 WITH PRIMARY KEY,ROWID,SEQUENCE(a)INCLUDING NEW VALUES;

create materialized view ZC_MV1 REFRESH FORCE ON DEMAND enable query rewrite AS
select a,b,c from zct1_grouping2 ZT2 group by grouping sets(a,b,c);

####PARALLEL table
ALTER TABLE zct1_grouping2 PARALLEL 2;

####partition table
##hash
--error 0,1051
drop table zct1_par_ha;
create table zct1_par_ha(a int, b varchar(10),c date) partition by hash(a) partitions 3;
INSERT INTO zct1_par_ha (a, b, c) VALUES
(1, 'apple', '2021-01-01'),
(2, 'banana', '2021-02-01'),
(3, 'orange', '2021-03-01');

##list
--error 0,1051
drop table zct1_par_li;
create table zct1_par_li( A int, b varchar(10),c date) partition by list( A) (
partition p0 values in (1, 2, 3),
partition p1 values in (4, 5, 6),
partition p2 values in (7, 8, 9));

INSERT INTO zct1_par_li ( A, b, c) VALUES
(1, 'apple', '2021-01-01'),
(2, 'banana', '2021-02-01'),
(3, 'orange', '2021-03-01'),
(4, 'grape', '2021-04-01'),
(5, 'kiwi', '2021-05-01'),
(6, 'mango', '2021-06-01'),
(7, 'pear', '2021-07-01'),
(8, 'strawberry', '2021-08-01'),
(9, 'watermelon', '2021-09-01');

##range
--error 0,1051
drop table zct1_par_ra;
create table zct1_par_ra( A int, b varchar(10),c date) partition by range( A) (
partition p0 values less than (5),
partition p1 values less than (10),
partition p2 values less than (MAXVALUE));

INSERT INTO zct1_par_ra ( A, b, c) VALUES
(1, 'apple', '2021-01-01'),
(2, 'banana', '2021-02-01'),
(3, 'orange', '2021-03-01'),
(4, 'grape', '2021-04-01'),
(5, 'kiwi', '2021-05-01'),
(6, 'mango', '2021-06-01'),
(7, 'pear', '2021-07-01'),
(8, 'strawberry', '2021-08-01'),
(9, 'watermelon', '2021-09-01');

##复合分区
--error 0,1051
drop table zct1_par_ra_ha;
create table zct1_par_ra_ha( A int, b varchar(10),c date) partition by range( A) subpartition by hash( A) (
partition p0 values less than (5) (
subpartition sp0,
subpartition sp1,
subpartition sp2),
partition p1 values less than (10) (
subpartition sp3,
subpartition sp4,
subpartition sp5),
partition p2 values less than (MAXVALUE) (
subpartition sp6,
subpartition sp7,
subpartition sp8));

