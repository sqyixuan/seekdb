##external table
--error 0,1051
drop table ex_t1;
--source mysql_test/test_suite/grouping_set_mysql_sqlqa/include/copy_data_for_external_table.inc
create external table ex_t1 (
a varCHAR(10) AS (metadata$filecol1),
b varCHAR(10) AS (metadata$filecol3),
c varCHAR(10) AS (metadata$filecol4),
d varCHAR(20) AS (metadata$filecol5)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv',
    SKIP_HEADER = 1
)
PATTERN = 'test.csv'
;

select a from ex_t1 group by grouping sets(a) order by a;
select a from ex_t1 group by rollup(a) order by a;
select a from ex_t1 group by cube(a) order by a;

