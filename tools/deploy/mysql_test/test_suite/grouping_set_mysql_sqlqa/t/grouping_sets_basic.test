SELECT B FROM ZCT1_PAR_RA  GROUP BY ROLLUP(B) HAVING COUNT(B) IN (1.1,-1) AND B IS NOT NULL ORDER BY B ASC;
SELECT A FROM ZCT1_PAR_LI  GROUP BY ROLLUP(A,B,A) HAVING COUNT(A) BETWEEN 1e-1 AND 1 AND A IS NOT NULL ORDER BY A ASC;
SELECT A FROM ZC_MV1 GROUP BY CUBE(A) HAVING COUNT(A) <= 1e-1 AND A IS NOT NULL ORDER BY 1 DESC;
SELECT B FROM ZCT1_PAR_LI PARTITION(p1) GROUP BY GROUPING SETS(B) HAVING COUNT(B) >= 1.1 AND B IS NOT NULL ORDER BY B ASC;
SELECT A FROM ZCT1_PAR_RA  GROUP BY CUBE(A) HAVING COUNT(A) >= -1 AND A IS NOT NULL ORDER BY 1 ASC;
SELECT B FROM zct1_grouping2 GROUP BY GROUPING SETS(B) HAVING COUNT(B) >= 1e-1 AND B IS NOT NULL ORDER BY B DESC;
SELECT A FROM ZCV1 GROUP BY CUBE(A,NULL) HAVING COUNT(A) < -0.1 AND A IS NOT NULL ORDER BY 1 DESC;
SELECT B FROM ZCV1 GROUP BY GROUPING SETS(B,NULL,A) HAVING COUNT(B) NOT IN (1e-1,1) AND B IS NOT NULL ORDER BY 1 DESC;
SELECT B FROM ZCT1_PAR_RA_HA PARTITION(sp1) GROUP BY CUBE(B,NULL,NULL) HAVING COUNT(B) >= 0 AND B IS NOT NULL ORDER BY 1 DESC;
SELECT A FROM zct1_grouping2 GROUP BY GROUPING SETS(A) HAVING COUNT(A) >= -0.1 AND A IS NOT NULL ORDER BY A ASC;
SELECT A FROM ZCT1_PAR_LI  GROUP BY ROLLUP(A,A) HAVING COUNT(A) IN (0,0) AND A IS NOT NULL ORDER BY A ASC;
SELECT A FROM ZCT1_PAR_RA_HA PARTITION(sp1) GROUP BY GROUPING SETS(A,NULL,NULL) HAVING COUNT(A) <= 1.1 AND A IS NOT NULL ORDER BY 1 ASC;
SELECT B FROM ZCT1_PAR_RA_HA PARTITION(p0) GROUP BY ROLLUP(B) HAVING COUNT(B) IN (1,1e-1) AND B IS NOT NULL ORDER BY B ASC;
SELECT A FROM ZCV1 GROUP BY ROLLUP(A,NULL,A) HAVING COUNT(A) >= -1 AND A IS NOT NULL ORDER BY A DESC;
SELECT B FROM ZCT1_PAR_RA  GROUP BY CUBE(B) HAVING B IS NOT NULL ORDER BY 1 DESC;
SELECT B FROM ZCT1_PAR_RA_HA PARTITION(sp1) GROUP BY CUBE(B,NULL,NULL) HAVING COUNT(B) != -0.1 AND B IS NOT NULL ORDER BY 1 DESC;
SELECT B FROM ZCT1_PAR_HA GROUP BY GROUPING SETS(B,A,B) HAVING COUNT(B) BETWEEN -1 AND 1 AND B IS NOT NULL ORDER BY B ASC;
SELECT A FROM ZCV1 GROUP BY CUBE(A,B) HAVING A IS NOT NULL ORDER BY A DESC;
SELECT A FROM zct1_grouping2 GROUP BY GROUPING SETS(A,B,B) HAVING A LIKE '' AND A IS NOT NULL ORDER BY 1 DESC;
SELECT B FROM ZCT1_PAR_RA_HA PARTITION(sp1) GROUP BY CUBE(B) HAVING COUNT(B) IN (1,0) AND B IS NOT NULL ORDER BY 1 ASC;
SELECT B FROM ZCT1_PAR_RA_HA PARTITION(p0) GROUP BY CUBE(B,NULL,NULL) HAVING COUNT(B) != 0 AND B IS NOT NULL ORDER BY B ASC;
SELECT A FROM ZCT1_PAR_HA GROUP BY CUBE(A) HAVING COUNT(A) >= 1.1 AND A IS NOT NULL ORDER BY A ASC;
SELECT B FROM zct1_grouping2 GROUP BY ROLLUP(B,NULL) HAVING COUNT(B) < -1 AND B IS NOT NULL ORDER BY 1 DESC;
SELECT A FROM ZCT1_PAR_RA_HA PARTITION(sp1) GROUP BY GROUPING SETS(A,A,NULL) HAVING COUNT(A) <= 1.1 AND A IS NOT NULL ORDER BY 1 ASC;
SELECT B FROM ZCT1_PAR_LI PARTITION(p1) GROUP BY ROLLUP(B,B) HAVING COUNT(B) NOT IN (-1,1e-1) AND B IS NOT NULL ORDER BY B ASC;
SELECT B FROM ZC_MV1 GROUP BY CUBE(B,NULL) HAVING COUNT(B) NOT IN (1,1e+1) AND B IS NOT NULL ORDER BY B DESC;
SELECT B FROM ZCT1_PAR_LI  GROUP BY CUBE(B,NULL,NULL) HAVING COUNT(B) <= 1 AND B IS NOT NULL ORDER BY B DESC;
SELECT A FROM zct1_grouping2 GROUP BY ROLLUP(A,B,NULL) HAVING COUNT(A) <= -0.1 AND A IS NOT NULL ORDER BY 1 ASC;
SELECT A FROM ZCT1_PAR_RA_HA PARTITION(sp1) GROUP BY CUBE(A,NULL) HAVING A LIKE ' ' AND A IS NOT NULL ORDER BY 1 DESC;
SELECT B FROM zct1_grouping2 GROUP BY ROLLUP(B,NULL,NULL) HAVING COUNT(B) != 0 AND B IS NOT NULL ORDER BY B ASC;




