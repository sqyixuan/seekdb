SELECT ALL A C1,GROUPING(A) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(A,NULL,ROLLUP(A,NULL),CUBE(A,B)) HAVING A IS NOT NULL MINUS SELECT DISTINCT A C1,GROUPING_ID(A,A) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(A,NULL) HAVING COUNT(A) BETWEEN 1 AND -0.1 AND A IS NOT NULL;
