####连接查询
SELECT ALL A,GROUPING(A),GROUPING_ID(A,A),MIN(C13) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(ROLLUP(A,NULL)) HAVING COUNT(A) NOT IN (1,1e-1) AND A IS NOT NULL ORDER BY A ASC;
SELECT DISTINCT A,GROUPING(A),GROUPING_ID(A,A),MAX(C8) FROM zct1_grouping T1, zct1_grouping3 T2 WHERE T1.C1=T2.A GROUP BY CUBE(A,C27) HAVING A IS NOT NULL ORDER BY A ASC;
SELECT  C23,GROUPING(C23),GROUPING_ID(C23,C23),MIN(C17) FROM zct1_grouping T1, zct1_grouping3 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(C23,NULL) HAVING C23 IS NOT NULL ORDER BY C23 ASC;
SELECT  C31,GROUPING(C31),GROUPING_ID(C31,C31),MIN(C32) FROM zct1_grouping T1 INNER JOIN zct1_grouping2 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(C31,C28,ROLLUP(C31,NULL)) HAVING COUNT(C31) != 1e-1 AND C31 IS NOT NULL ORDER BY C31 DESC;
SELECT  B,GROUPING(B),GROUPING_ID(B,B),MIN(C33) FROM zct1_grouping T1 INNER JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(CUBE(B,C2)) HAVING COUNT(B) IN (1.1,1.1) AND B IS NOT NULL ORDER BY B DESC;
SELECT DISTINCT C12,GROUPING(C12),GROUPING_ID(C12,C12),COUNT(C18) FROM zct1_grouping T1 LEFT JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(ROLLUP(C12,C17),CUBE(C12,NULL)) HAVING COUNT(C12) = 1e+1 AND C12 IS NOT NULL ORDER BY C12 DESC;
SELECT  C19,GROUPING(C19),GROUPING_ID(C19,C19),COUNT(C5) FROM zct1_grouping T1 FULL JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(ROLLUP(C19,NULL)) HAVING COUNT(C19) > 1 AND C19 IS NOT NULL ORDER BY C19 ASC;
SELECT  A,GROUPING(A),GROUPING_ID(A,A),MIN(C27) FROM zct1_grouping T1, zct1_grouping3 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(A,C32,ROLLUP(A,NULL),CUBE(A,C19)) HAVING COUNT(A) NOT IN (1e-1,1e-1) AND A IS NOT NULL ORDER BY A ASC;
SELECT ALL C3,GROUPING(C3),GROUPING_ID(C3,C3),MAX(C28) FROM zct1_grouping T1, zct1_grouping3 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(C3,NULL,ROLLUP(C3,C26)) HAVING COUNT(C3) != -1 AND C3 IS NOT NULL ORDER BY C3 DESC;
SELECT  C18,GROUPING(C18),GROUPING_ID(C18,C18),MAX(C2) FROM zct1_grouping T1 LEFT JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY CUBE(C18,NULL) HAVING COUNT(C18) = 1e+1 AND C18 IS NOT NULL ORDER BY C18 ASC;
SELECT  A,GROUPING(A),GROUPING_ID(A,A),COUNT(A) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(A,C4) HAVING COUNT(A) BETWEEN 0 AND 0 AND A IS NOT NULL ORDER BY A ASC;
SELECT  C11,GROUPING(C11),GROUPING_ID(C11,C11),MIN(C1) FROM zct1_grouping T1 FULL JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY ROLLUP(C11,C5) HAVING COUNT(C11) != -1 AND C11 IS NOT NULL ORDER BY C11 DESC;
SELECT DISTINCT C6,GROUPING(C6),GROUPING_ID(C6,C6),COUNT(C1) FROM zct1_grouping T1 FULL JOIN zct1_grouping2 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(ROLLUP(C6,NULL),CUBE(C6,C31)) HAVING COUNT(C6) BETWEEN 1e-1 AND 1.1 AND C6 IS NOT NULL ORDER BY C6 DESC;
SELECT ALL C3,GROUPING(C3),GROUPING_ID(C3,C3),MIN(C22) FROM zct1_grouping T1 LEFT JOIN zct1_grouping2 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(ROLLUP(C3,NULL),CUBE(C3,C31)) HAVING COUNT(C3) = -0.1 AND C3 IS NOT NULL ORDER BY C3 ASC;
SELECT DISTINCT C19,GROUPING(C19),GROUPING_ID(C19,C19),MIN(C34) FROM zct1_grouping T1 INNER JOIN zct1_grouping2 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(C19,NULL,ROLLUP(C19,C3)) HAVING COUNT(C19) > 1 AND C19 IS NOT NULL ORDER BY C19 ASC;
SELECT  C31,GROUPING(C31),GROUPING_ID(C31,C31),MAX(C23) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(CUBE(C31,C10)) HAVING COUNT(C31) < 1e+1 AND C31 IS NOT NULL ORDER BY C31 DESC;
SELECT UNIQUE B,GROUPING(B),GROUPING_ID(B,B),MAX(C32) FROM zct1_grouping T1 RIGHT JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(ROLLUP(B,NULL),CUBE(B,NULL)) HAVING COUNT(B) BETWEEN 1.1 AND -1 AND B IS NOT NULL ORDER BY B ASC;
SELECT UNIQUE C3,GROUPING(C3),GROUPING_ID(C3,C3),MIN(C26) FROM zct1_grouping T1 LEFT JOIN zct1_grouping2 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(ROLLUP(C3,C28),CUBE(C3,NULL)) HAVING COUNT(C3) >= 1e-1 AND C3 IS NOT NULL ORDER BY C3 ASC;
SELECT  C5,GROUPING(C5),GROUPING_ID(C5,C5),COUNT(C11) FROM zct1_grouping T1 INNER JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY ROLLUP(C5,NULL) HAVING C5 LIKE '1' AND C5 IS NOT NULL ORDER BY C5 DESC;
SELECT  C25,GROUPING(C25),GROUPING_ID(C25,C25),MAX(C8) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(C25,C25,ROLLUP(C25,C15),CUBE(C25,C27)) HAVING COUNT(C25) BETWEEN 1e+1 AND 1e+1 AND C25 IS NOT NULL ORDER BY C25 DESC;
SELECT  C5,GROUPING(C5),GROUPING_ID(C5,C5),COUNT(C7) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(C5,NULL,ROLLUP(C5,C8)) HAVING COUNT(C5) <= 1e+1 AND C5 IS NOT NULL ORDER BY C5 DESC;
SELECT ALL C26,GROUPING(C26),GROUPING_ID(C26,C26),MIN(C30) FROM zct1_grouping T1, zct1_grouping3 T2 WHERE T1.C1=T2.A GROUP BY ROLLUP(C26,C31) HAVING C26 IS NOT NULL ORDER BY C26 ASC;
SELECT UNIQUE C20,GROUPING(C20),GROUPING_ID(C20,C20),MAX(C15) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY ROLLUP(C20,C16) HAVING COUNT(C20) != 1e-1 AND C20 IS NOT NULL ORDER BY C20 DESC;
SELECT  C5,GROUPING(C5),GROUPING_ID(C5,C5),MAX(C16) FROM zct1_grouping T1 FULL JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(ROLLUP(C5,C12)) HAVING COUNT(C5) = 1 AND C5 IS NOT NULL ORDER BY C5 DESC;
SELECT DISTINCT C12,GROUPING(C12),GROUPING_ID(C12,C12),COUNT(C21) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(ROLLUP(C12,C1),CUBE(C12,C23)) HAVING COUNT(C12) <= 0 AND C12 IS NOT NULL ORDER BY C12 ASC;
SELECT DISTINCT C16,GROUPING(C16),GROUPING_ID(C16,C16),MAX(C8) FROM zct1_grouping T1 FULL JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(C16,NULL) HAVING COUNT(C16) = -0.1 AND C16 IS NOT NULL ORDER BY C16 ASC;
SELECT  C18,GROUPING(C18),GROUPING_ID(C18,C18),MAX(C23) FROM zct1_grouping T1, zct1_grouping3 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(ROLLUP(C18,C19)) HAVING C18 LIKE '' AND C18 IS NOT NULL ORDER BY C18 ASC;
SELECT  C11,GROUPING(C11),GROUPING_ID(C11,C11),COUNT(C13) FROM zct1_grouping T1 FULL JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(C11,NULL,CUBE(C11,C8)) HAVING COUNT(C11) = 1.1 AND C11 IS NOT NULL ORDER BY C11 ASC;
SELECT DISTINCT C19,GROUPING(C19),GROUPING_ID(C19,C19),MIN(C29) FROM zct1_grouping T1 RIGHT JOIN zct1_grouping2 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(CUBE(C19,C29)) HAVING COUNT(C19) < -0.1 AND C19 IS NOT NULL ORDER BY C19 ASC;
SELECT  C32,GROUPING(C32),GROUPING_ID(C32,C32),MIN(C23) FROM zct1_grouping T1 RIGHT JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(CUBE(C32,B)) HAVING COUNT(C32) NOT IN (-0.1,1) AND C32 IS NOT NULL ORDER BY C32 ASC;
SELECT  C14,GROUPING(C14),GROUPING_ID(C14,C14),MAX(C21) FROM zct1_grouping T1, zct1_grouping3 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(CUBE(C14,C21)) HAVING COUNT(C14) BETWEEN 0 AND 1 AND C14 IS NOT NULL ORDER BY C14 ASC;
SELECT  C32,GROUPING(C32),GROUPING_ID(C32,C32),MAX(C26) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(C32,C24,CUBE(C32,C33)) HAVING COUNT(C32) = -0.1 AND C32 IS NOT NULL ORDER BY C32 ASC;
SELECT  C24,GROUPING(C24),GROUPING_ID(C24,C24),COUNT(C18) FROM zct1_grouping T1 LEFT JOIN zct1_grouping2 T2 ON T1.C1=T2.A GROUP BY ROLLUP(C24,NULL) HAVING COUNT(C24) NOT IN (0,1e+1) AND C24 IS NOT NULL ORDER BY C24 DESC;
SELECT  C12,GROUPING(C12),GROUPING_ID(C12,C12),MAX(C29) FROM zct1_grouping T1 FULL JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(C12,C17,ROLLUP(C12,NULL),CUBE(C12,NULL)) HAVING COUNT(C12) = 0 AND C12 IS NOT NULL ORDER BY C12 DESC;
SELECT  B,GROUPING(B),GROUPING_ID(B,B),COUNT(B) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(B,C29,ROLLUP(B,NULL),CUBE(B,C21)) HAVING COUNT(B) BETWEEN 0 AND -0.1 AND B IS NOT NULL ORDER BY B DESC;
SELECT ALL C16,GROUPING(C16),GROUPING_ID(C16,C16),MAX(C28) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY ROLLUP(C16,NULL) HAVING COUNT(C16) BETWEEN -1 AND 0 AND C16 IS NOT NULL ORDER BY C16 DESC;
SELECT  C12,GROUPING(C12),GROUPING_ID(C12,C12),MIN(C21) FROM zct1_grouping T1 LEFT JOIN zct1_grouping2 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(CUBE(C12,C15)) HAVING COUNT(C12) != 1.1 AND C12 IS NOT NULL ORDER BY C12 ASC;
SELECT UNIQUE C24,GROUPING(C24),GROUPING_ID(C24,C24),COUNT(C26) FROM zct1_grouping T1 RIGHT JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY ROLLUP(C24,C12) HAVING COUNT(C24) = -1 AND C24 IS NOT NULL ORDER BY C24 ASC;
SELECT  C28,GROUPING(C28),GROUPING_ID(C28,C28),MAX(C1) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(ROLLUP(C28,A),CUBE(C28,C19)) HAVING C28 LIKE '数据' AND C28 IS NOT NULL ORDER BY C28 ASC;
SELECT  B,GROUPING(B),GROUPING_ID(B,B),COUNT(C4) FROM zct1_grouping T1 RIGHT JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(B,NULL) HAVING COUNT(B) <= -0.1 AND B IS NOT NULL ORDER BY B ASC;
SELECT  C14,GROUPING(C14),GROUPING_ID(C14,C14),COUNT(C3) FROM zct1_grouping T1 FULL JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(C14,C4,CUBE(C14,NULL)) HAVING COUNT(C14) = 1e+1 AND C14 IS NOT NULL ORDER BY C14 ASC;
SELECT  C13,GROUPING(C13),GROUPING_ID(C13,C13),MIN(C33) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(C13,C6,ROLLUP(C13,NULL)) HAVING COUNT(C13) != -0.1 AND C13 IS NOT NULL ORDER BY C13 DESC;
SELECT ALL C25,GROUPING(C25),GROUPING_ID(C25,C25),MAX(C7) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(CUBE(C25,C27)) HAVING COUNT(C25) NOT IN (1,-0.1) AND C25 IS NOT NULL ORDER BY C25 ASC;
SELECT  C17,GROUPING(C17),GROUPING_ID(C17,C17),MAX(C34) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(C17,NULL,ROLLUP(C17,NULL)) HAVING C17 LIKE '' AND C17 IS NOT NULL ORDER BY C17 DESC;
SELECT UNIQUE C3,GROUPING(C3),GROUPING_ID(C3,C3),COUNT(C5) FROM zct1_grouping T1 FULL JOIN zct1_grouping3 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(C3,A,ROLLUP(C3,C4)) HAVING COUNT(C3) <= -1 AND C3 IS NOT NULL ORDER BY C3 ASC;
SELECT  C26,GROUPING(C26),GROUPING_ID(C26,C26),MAX(C31) FROM zct1_grouping T1 RIGHT JOIN zct1_grouping2 T2 ON T1.C1=T2.A GROUP BY ROLLUP(C26,C6) HAVING C26 IS NOT NULL ORDER BY C26 ASC;
SELECT UNIQUE C14,GROUPING(C14),GROUPING_ID(C14,C14),COUNT(C16) FROM zct1_grouping T1, zct1_grouping3 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(ROLLUP(C14,NULL)) HAVING COUNT(C14) <= 1e-1 AND C14 IS NOT NULL ORDER BY C14 DESC;
SELECT  C17,GROUPING(C17),GROUPING_ID(C17,C17),COUNT(C22) FROM zct1_grouping T1, zct1_grouping2 T2 WHERE T1.C1=T2.A GROUP BY ROLLUP(C17,C34) HAVING COUNT(C17) > 1e-1 AND C17 IS NOT NULL ORDER BY C17 DESC;
SELECT UNIQUE C3,GROUPING(C3),GROUPING_ID(C3,C3),MIN(C24) FROM zct1_grouping T1 INNER JOIN zct1_grouping2 T2 ON T1.C1=T2.A GROUP BY GROUPING SETS(ROLLUP(C3,C27)) HAVING COUNT(C3) IN (1,1) AND C3 IS NOT NULL ORDER BY C3 ASC;
SELECT  C6,GROUPING(C6),GROUPING_ID(C6,C6),MIN(C8) FROM zct1_grouping T1, zct1_grouping3 T2 WHERE T1.C1=T2.A GROUP BY GROUPING SETS(C6,NULL,ROLLUP(C6,C29)) HAVING COUNT(C6) != 0 AND C6 IS NOT NULL ORDER BY C6 ASC;

####union
select c1,grouping(c1) from zct1_grouping group by grouping sets(c1)  union select c1,grouping(c1) from zct1_grouping group by grouping sets(c1) order by c1;
select c1,c2,grouping_id(c1,c2) from zct1_grouping group by grouping sets(c1,c2) UNION ALL select c1,c2,grouping_id(c1,c2) from zct1_grouping group by grouping sets(c1,c2) order by c1,c2;
select c1,grouping(c1) from zct1_grouping group by rollup(c1) MINUS select c1,grouping(c1) from zct1_grouping group by rollup(c1) order by c1;
select c1,c2,grouping_id(c1,c2) from zct1_grouping group by rollup(c1,c2) INTERSECT select c1,c2,grouping_id(c1,c2) from zct1_grouping group by rollup(c1,c2) order by c1,c2;
select c1,grouping(c1) from zct1_grouping group by cube(c1) union select c1,grouping_id(c1,c2) from zct1_grouping group by cube(c1,c2) order by c1;

SELECT UNIQUE A C1,GROUPING_ID(A,A) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(A,A,ROLLUP(A,B)) HAVING COUNT(A) <= 1.1 AND A IS NOT NULL INTERSECT SELECT DISTINCT A C1,GROUPING(A) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(ROLLUP(A,A),CUBE(A,B)) HAVING COUNT(A) = 1e+1 AND A IS NOT NULL;
SELECT  B C1,GROUPING(B) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(ROLLUP(B,A)) HAVING COUNT(B) BETWEEN 1e-1 AND 1 AND B IS NOT NULL MINUS SELECT ALL B C1,GROUPING(B) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY CUBE(B,NULL) HAVING COUNT(B) >= 1e+1 AND B IS NOT NULL;
SELECT  B C1,GROUPING_ID(B,B) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY ROLLUP(B,A) HAVING COUNT(B) > 1.1 AND B IS NOT NULL union all SELECT  B C1,GROUPING_ID(B,B) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(CUBE(B,B)) HAVING B LIKE ' ' AND B IS NOT NULL;
SELECT  A C1,GROUPING_ID(A,A) C2,COUNT(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(ROLLUP(A,NULL),CUBE(A,NULL)) HAVING COUNT(A) NOT IN (1,0) AND A IS NOT NULL MINUS SELECT UNIQUE A C1,GROUPING_ID(A,A) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(CUBE(A,B)) HAVING COUNT(A) < -1 AND A IS NOT NULL;
SELECT  A C1,GROUPING(A) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY CUBE(A,B) HAVING COUNT(A) < 1.1 AND A IS NOT NULL MINUS SELECT ALL A C1,GROUPING(A) C2,COUNT(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(CUBE(A,A)) HAVING COUNT(A) = 1e-1 AND A IS NOT NULL;
SELECT DISTINCT A C1,GROUPING_ID(A,A) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY ROLLUP(A,B) HAVING COUNT(A) NOT IN (1e+1,1.1) AND A IS NOT NULL union SELECT DISTINCT A C1,GROUPING_ID(A,A) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(A,B,CUBE(A,B)) HAVING COUNT(A) = 1e+1 AND A IS NOT NULL;
SELECT DISTINCT A C1,GROUPING(A) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(A,NULL,CUBE(A,A)) HAVING COUNT(A) BETWEEN 0 AND 0 AND A IS NOT NULL union SELECT ALL A C1,GROUPING_ID(A,A) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(A,B,CUBE(A,B)) HAVING A IS NOT NULL;
SELECT  B C1,GROUPING_ID(B,B) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(CUBE(B,NULL)) HAVING COUNT(B) <= 1 AND B IS NOT NULL INTERSECT SELECT DISTINCT B C1,GROUPING(B) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(CUBE(B,NULL)) HAVING B IS NOT NULL;
SELECT  A C1,GROUPING_ID(A,A) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY ROLLUP(A,A) HAVING COUNT(A) != 1.1 AND A IS NOT NULL union SELECT ALL A C1,GROUPING_ID(A,A) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(ROLLUP(A,NULL),CUBE(A,NULL)) HAVING COUNT(A) <= -1 AND A IS NOT NULL;
SELECT ALL B C1,GROUPING_ID(B,B) C2,COUNT(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(B,NULL,CUBE(B,NULL)) HAVING COUNT(B) NOT IN (1e+1,-0.1) AND B IS NOT NULL union SELECT ALL B C1,GROUPING_ID(B,B) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(CUBE(B,A)) HAVING COUNT(B) < 1e+1 AND B IS NOT NULL;
SELECT UNIQUE A C1,GROUPING_ID(A,A) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(A,NULL,ROLLUP(A,B)) HAVING COUNT(A) > 0 AND A IS NOT NULL union all SELECT DISTINCT A C1,GROUPING(A) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(ROLLUP(A,A)) HAVING COUNT(A) BETWEEN -1 AND 0 AND A IS NOT NULL;
SELECT  B C1,GROUPING(B) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(ROLLUP(B,A),CUBE(B,NULL)) HAVING COUNT(B) > 1 AND B IS NOT NULL INTERSECT SELECT  B C1,GROUPING_ID(B,B) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(ROLLUP(B,NULL),CUBE(B,B)) HAVING COUNT(B) IN (1,1) AND B IS NOT NULL;
SELECT DISTINCT A C1,GROUPING(A) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(ROLLUP(A,B),CUBE(A,A)) HAVING COUNT(A) IN (1,-0.1) AND A IS NOT NULL MINUS SELECT UNIQUE A C1,GROUPING(A) C2,COUNT(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(A,B) HAVING COUNT(A) != 1e+1 AND A IS NOT NULL;
SELECT  B C1,GROUPING(B) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY CUBE(B,NULL) HAVING COUNT(B) >= 0 AND B IS NOT NULL union SELECT  B C1,GROUPING_ID(B,B) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(B,NULL,ROLLUP(B,A),CUBE(B,NULL)) HAVING COUNT(B) > 1e-1 AND B IS NOT NULL;
SELECT ALL B C1,GROUPING(B) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY CUBE(B,NULL) HAVING COUNT(B) > -0.1 AND B IS NOT NULL MINUS SELECT ALL B C1,GROUPING(B) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(B,NULL,CUBE(B,A)) HAVING COUNT(B) = 0 AND B IS NOT NULL;
