--error 0,1051
drop table zct1_grouping3;
create table zct1_grouping3(a int, b varchar(5) ,primary key( a));
insert into zct1_grouping3 values( 1, 'a'), (2, 'b'), (3, 'c'), (4, 'd'), (5, 'e');

select c1,grouping(c1) from zct1_grouping group by grouping sets(c1) order by c1;
select c1,c2,grouping_id(c1,c2) from zct1_grouping group by grouping sets(c1,c2) order by c1,c2;
select c1,grouping(c1) from zct1_grouping group by rollup(c1) order by c1;
select c1,c2,grouping_id(c1,c2) from zct1_grouping group by rollup(c1,c2) order by c1,c2;
select c1,grouping(c1) from zct1_grouping group by cube(c1) order by c1;
select c1,c2,grouping_id(c1,c2) from zct1_grouping group by cube(c1,c2) order by c1,c2;


####子查询
##from
select c1,grouping(c1) from (select c1,grouping(c1) from zct1_grouping group by grouping sets(c1)) group by grouping sets(c1) order by c1;
select c1,c2,grouping_id(c1,c2) from (select c1,c2,grouping_id(c1,c2) from zct1_grouping group by grouping sets(c1,c2)) group by grouping sets(c1,c2) order by c1,c2;
select c1,grouping(c1) from (select c1,grouping(c1) from zct1_grouping group by rollup(c1)) group by rollup(c1) order by c1;
select c1,c2,grouping_id(c1,c2) from (select c1,c2,grouping_id(c1,c2) from zct1_grouping group by rollup(c1,c2)) group by rollup(c1,c2) order by c1,c2;
select c1,grouping(c1) from (select c1,grouping(c1) from zct1_grouping group by cube(c1)) group by cube(c1) order by c1;
select c1,c2,grouping_id(c1,c2) from (select c1,c2,grouping_id(c1,c2) from zct1_grouping group by cube(c1,c2)) group by cube(c1,c2) order by c1,c2;

SELECT ALL T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MIN(T.C3) FROM (SELECT  B C1,GROUPING(B) C2,MIN(A) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(B,A,CUBE(B,A)) HAVING COUNT(B) != 1 AND B IS NOT NULL ORDER BY B ASC  ) T GROUP BY CUBE(C2,C2);
SELECT ALL T.C1,GROUPING(T.C1),GROUPING_ID(T.C1,T.C1),MAX(T.C3) FROM (SELECT DISTINCT A C1,GROUPING_ID(A,A) C2,MAX(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(CUBE(A,NULL)) HAVING COUNT(A) >= 1.1 AND A IS NOT NULL ORDER BY A DESC  ) T GROUP BY GROUPING SETS(C1,C2,ROLLUP(C1,C3));
SELECT  T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MIN(T.C3) FROM (SELECT  B C1,GROUPING(B) C2,MIN(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(CUBE(B,B)) HAVING COUNT(B) IN (1.1,1.1) AND B IS NOT NULL ORDER BY B DESC  ) T GROUP BY GROUPING SETS(C2,C3,CUBE(C2,C1));
SELECT  T.C3,GROUPING(T.C3),GROUPING_ID(T.C3,T.C3),COUNT(T.C3) FROM (SELECT  A C1,GROUPING_ID(A,A) C2,MAX(B) C3 FROM zct1_grouping3 GROUP BY CUBE(A,NULL) HAVING COUNT(A) NOT IN (-0.1,1e+1) AND A IS NOT NULL ORDER BY A DESC  ) T GROUP BY ROLLUP(C3,C3);
SELECT ALL T.C1,GROUPING(T.C1),GROUPING_ID(T.C1,T.C1),COUNT(T.C3) FROM (SELECT UNIQUE B C1,GROUPING(B) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(B,B) HAVING COUNT(B) < -0.1 AND B IS NOT NULL ORDER BY B DESC  ) T GROUP BY GROUPING SETS(C1,C2,ROLLUP(C1,C3),CUBE(C1,C2));
SELECT ALL T.C3,GROUPING(T.C3),GROUPING_ID(T.C3,T.C3),COUNT(T.C1) FROM (SELECT  A C1,GROUPING(A) C2,MAX(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(A,B,CUBE(A,B)) HAVING COUNT(A) = 1e+1 AND A IS NOT NULL ORDER BY A ASC  ) T GROUP BY GROUPING SETS(C3,C2,CUBE(C3,C1));
SELECT  T.C1,GROUPING(T.C1),GROUPING_ID(T.C1,T.C1),MIN(T.C2) FROM (SELECT UNIQUE A C1,GROUPING(A) C2,MAX(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(A,B,CUBE(A,B)) HAVING A IS NOT NULL ORDER BY A ASC  ) T GROUP BY GROUPING SETS(ROLLUP(C1,C1));
SELECT DISTINCT T.C1,GROUPING(T.C1),GROUPING_ID(T.C1,T.C1),COUNT(T.C1) FROM (SELECT DISTINCT A C1,GROUPING_ID(A,A) C2,MAX(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(A,A,ROLLUP(A,NULL),CUBE(A,A)) HAVING COUNT(A) NOT IN (0,1.1) AND A IS NOT NULL ORDER BY A ASC  ) T GROUP BY ROLLUP(C1,C1);
SELECT UNIQUE T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MIN(T.C2) FROM (SELECT DISTINCT A C1,GROUPING_ID(A,A) C2,MIN(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(A,NULL,ROLLUP(A,A)) HAVING COUNT(A) > 1 AND A IS NOT NULL ORDER BY A ASC  ) T GROUP BY ROLLUP(C2,C3);
SELECT UNIQUE T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MIN(T.C2) FROM (SELECT  A C1,GROUPING_ID(A,A) C2,MIN(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(CUBE(A,NULL)) HAVING COUNT(A) IN (1e-1,1) AND A IS NOT NULL ORDER BY A DESC  ) T GROUP BY GROUPING SETS(CUBE(C2,C3));
SELECT UNIQUE T.C1,GROUPING(T.C1),GROUPING_ID(T.C1,T.C1),COUNT(T.C3) FROM (SELECT ALL A C1,GROUPING(A) C2,MIN(A) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(A,B,ROLLUP(A,NULL)) HAVING A LIKE 'a' AND A IS NOT NULL ORDER BY A DESC  ) T GROUP BY GROUPING SETS(C1,C3,CUBE(C1,C1));
SELECT UNIQUE T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),COUNT(T.C1) FROM (SELECT  B C1,GROUPING_ID(B,B) C2,MAX(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(B,B,ROLLUP(B,A),CUBE(B,B)) HAVING COUNT(B) BETWEEN 1e+1 AND 1e+1 AND B IS NOT NULL ORDER BY B DESC  ) T GROUP BY CUBE(C2,C1);
SELECT DISTINCT T.C1,GROUPING(T.C1),GROUPING_ID(T.C1,T.C1),MIN(T.C3) FROM (SELECT  A C1,GROUPING_ID(A,A) C2,COUNT(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(CUBE(A,NULL)) HAVING COUNT(A) IN (1,0) AND A IS NOT NULL ORDER BY A ASC  ) T GROUP BY GROUPING SETS(ROLLUP(C1,C3));
SELECT UNIQUE T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MAX(T.C3) FROM (SELECT  A C1,GROUPING(A) C2,MIN(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(A,NULL,CUBE(A,NULL)) HAVING COUNT(A) > -0.1 AND A IS NOT NULL ORDER BY A DESC  ) T GROUP BY GROUPING SETS(ROLLUP(C2,C2));
SELECT UNIQUE T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MAX(T.C2) FROM (SELECT DISTINCT A C1,GROUPING(A) C2,MAX(A) C3 FROM zct1_grouping2 GROUP BY CUBE(A,NULL) HAVING A LIKE 'a' AND A IS NOT NULL ORDER BY A ASC  ) T GROUP BY GROUPING SETS(C2,C3);
SELECT DISTINCT T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MAX(T.C3) FROM (SELECT DISTINCT A C1,GROUPING_ID(A,A) C2,COUNT(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(A,NULL,CUBE(A,B)) HAVING COUNT(A) > -1 AND A IS NOT NULL ORDER BY A ASC  ) T GROUP BY GROUPING SETS(C2,C1);
SELECT DISTINCT T.C1,GROUPING(T.C1),GROUPING_ID(T.C1,T.C1),MAX(T.C1) FROM (SELECT UNIQUE B C1,GROUPING(B) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY CUBE(B,NULL) HAVING B LIKE '' AND B IS NOT NULL ORDER BY B DESC  ) T GROUP BY GROUPING SETS(ROLLUP(C1,C2),CUBE(C1,C1));
SELECT ALL T.C3,GROUPING(T.C3),GROUPING_ID(T.C3,T.C3),MAX(T.C2) FROM (SELECT  A C1,GROUPING_ID(A,A) C2,COUNT(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(A,NULL,ROLLUP(A,NULL)) HAVING A LIKE ' ' AND A IS NOT NULL ORDER BY A ASC  ) T GROUP BY ROLLUP(C3,C1);
SELECT  T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MAX(T.C1) FROM (SELECT  A C1,GROUPING_ID(A,A) C2,MIN(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(A,B,ROLLUP(A,NULL)) HAVING A LIKE '1' AND A IS NOT NULL ORDER BY A DESC  ) T GROUP BY GROUPING SETS(C2,C3,ROLLUP(C2,C3),CUBE(C2,C3));
SELECT  T.C1,GROUPING(T.C1),GROUPING_ID(T.C1,T.C1),COUNT(T.C1) FROM (SELECT DISTINCT B C1,GROUPING_ID(B,B) C2,MAX(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(B,NULL,ROLLUP(B,NULL),CUBE(B,NULL)) HAVING B LIKE ' ' AND B IS NOT NULL ORDER BY B ASC  ) T GROUP BY GROUPING SETS(C1,C3,CUBE(C1,C1));
SELECT ALL T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MIN(T.C2) FROM (SELECT ALL A C1,GROUPING_ID(A,A) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(ROLLUP(A,NULL)) HAVING COUNT(A) < 1 AND A IS NOT NULL ORDER BY A ASC  ) T GROUP BY GROUPING SETS(C2,C1,CUBE(C2,C1));
SELECT  T.C3,GROUPING(T.C3),GROUPING_ID(T.C3,T.C3),COUNT(T.C2) FROM (SELECT ALL B C1,GROUPING_ID(B,B) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY ROLLUP(B,NULL) HAVING COUNT(B) < 0 AND B IS NOT NULL ORDER BY B ASC  ) T GROUP BY CUBE(C3,C3);
SELECT UNIQUE T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MAX(T.C1) FROM (SELECT DISTINCT A C1,GROUPING(A) C2,MAX(A) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(A,NULL,ROLLUP(A,NULL)) HAVING COUNT(A) IN (-0.1,1e-1) AND A IS NOT NULL ORDER BY A DESC  ) T GROUP BY GROUPING SETS(C2,C2,ROLLUP(C2,C3),CUBE(C2,C2));
SELECT  T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MAX(T.C3) FROM (SELECT UNIQUE A C1,GROUPING(A) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY ROLLUP(A,B) HAVING COUNT(A) > 1e-1 AND A IS NOT NULL ORDER BY A DESC  ) T GROUP BY GROUPING SETS(C2,C1);
SELECT  T.C1,GROUPING(T.C1),GROUPING_ID(T.C1,T.C1),COUNT(T.C3) FROM (SELECT DISTINCT A C1,GROUPING_ID(A,A) C2,MAX(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(ROLLUP(A,NULL),CUBE(A,NULL)) HAVING COUNT(A) = 1e+1 AND A IS NOT NULL ORDER BY A ASC  ) T GROUP BY GROUPING SETS(C1,C1,CUBE(C1,C3));
