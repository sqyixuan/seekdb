SELECT DISTINCT A C1,GROUPING(A) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(A,NULL,ROLLUP(A,NULL)) HAVING COUNT(A) = -1 AND A IS NOT NULL INTERSECT SELECT  A C1,GROUPING(A) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(ROLLUP(A,NULL)) HAVING COUNT(A) < 1.1 AND A IS NOT NULL;
SELECT  A C1,GROUPING(A) C2,COUNT(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(ROLLUP(A,B)) HAVING A IS NOT NULL INTERSECT SELECT DISTINCT A C1,GROUPING_ID(A,A) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(A,NULL,ROLLUP(A,NULL)) HAVING COUNT(A) < -0.1 AND A IS NOT NULL;
SELECT  A C1,GROUPING(A) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(ROLLUP(A,B),CUBE(A,B)) HAVING A LIKE '1' AND A IS NOT NULL INTERSECT SELECT UNIQUE A C1,GROUPING(A) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(ROLLUP(A,NULL)) HAVING A IS NOT NULL;
SELECT DISTINCT B C1,GROUPING(B) C2,COUNT(A) C3 FROM zct1_grouping2 GROUP BY CUBE(B,NULL) HAVING COUNT(B) <= 1e+1 AND B IS NOT NULL MINUS SELECT  B C1,GROUPING_ID(B,B) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY ROLLUP(B,A) HAVING COUNT(B) >= 1e+1 AND B IS NOT NULL;
SELECT DISTINCT B C1,GROUPING(B) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY CUBE(B,NULL) HAVING COUNT(B) BETWEEN -1 AND 1e-1 AND B IS NOT NULL union all SELECT UNIQUE B C1,GROUPING_ID(B,B) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(B,B) HAVING COUNT(B) NOT IN (-0.1,-0.1) AND B IS NOT NULL;
SELECT ALL B C1,GROUPING(B) C2,COUNT(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(ROLLUP(B,A)) HAVING COUNT(B) != 1 AND B IS NOT NULL union SELECT  B C1,GROUPING_ID(B,B) C2,COUNT(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(B,A,CUBE(B,NULL)) HAVING COUNT(B) < 1e+1 AND B IS NOT NULL;
SELECT  A C1,GROUPING_ID(A,A) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(ROLLUP(A,B),CUBE(A,NULL)) HAVING COUNT(A) = -0.1 AND A IS NOT NULL INTERSECT SELECT  A C1,GROUPING_ID(A,A) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(A,B,CUBE(A,A)) HAVING COUNT(A) NOT IN (1e-1,-1) AND A IS NOT NULL;
SELECT  B C1,GROUPING(B) C2,COUNT(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(B,B,ROLLUP(B,NULL),CUBE(B,NULL)) HAVING COUNT(B) BETWEEN 1e+1 AND 1 AND B IS NOT NULL MINUS SELECT  B C1,GROUPING_ID(B,B) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY CUBE(B,NULL) HAVING B IS NOT NULL;
SELECT  A C1,GROUPING_ID(A,A) C2,COUNT(A) C3 FROM zct1_grouping2 GROUP BY CUBE(A,B) HAVING COUNT(A) NOT IN (-0.1,1e-1) AND A IS NOT NULL union all SELECT ALL A C1,GROUPING_ID(A,A) C2,COUNT(A) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(A,B,ROLLUP(A,NULL),CUBE(A,B)) HAVING A IS NOT NULL;
