SELECT DISTINCT T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MIN(T.C3) FROM (SELECT DISTINCT B C1,GROUPING_ID(B,B) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY CUBE(B,NULL) HAVING COUNT(B) < -0.1 AND B IS NOT NULL ORDER BY B ASC  ) T GROUP BY CUBE(C2,C2);
SELECT  T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),COUNT(T.C2) FROM (SELECT ALL A C1,GROUPING(A) C2,MIN(A) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(ROLLUP(A,NULL)) HAVING COUNT(A) BETWEEN 1e+1 AND 1 AND A IS NOT NULL ORDER BY A ASC  ) T GROUP BY GROUPING SETS(ROLLUP(C2,C3),CUBE(C2,C1));
SELECT ALL T.C3,GROUPING(T.C3),GROUPING_ID(T.C3,T.C3),MIN(T.C1) FROM (SELECT UNIQUE A C1,GROUPING_ID(A,A) C2,COUNT(B) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(A,B) HAVING COUNT(A) BETWEEN -1 AND -0.1 AND A IS NOT NULL ORDER BY A DESC  ) T GROUP BY GROUPING SETS(C3,C2,ROLLUP(C3,C2));
SELECT ALL T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),COUNT(T.C2) FROM (SELECT UNIQUE A C1,GROUPING(A) C2,MIN(B) C3 FROM zct1_grouping3 GROUP BY CUBE(A,B) HAVING COUNT(A) >= 0 AND A IS NOT NULL ORDER BY A ASC  ) T GROUP BY GROUPING SETS(C2,C1,ROLLUP(C2,C2));
SELECT ALL T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),COUNT(T.C3) FROM (SELECT  B C1,GROUPING_ID(B,B) C2,MIN(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(B,NULL,CUBE(B,NULL)) HAVING COUNT(B) < -0.1 AND B IS NOT NULL ORDER BY B DESC  ) T GROUP BY GROUPING SETS(C2,C1);
SELECT UNIQUE T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MAX(T.C2) FROM (SELECT  B C1,GROUPING_ID(B,B) C2,COUNT(B) C3 FROM zct1_grouping3 GROUP BY GROUPING SETS(B,NULL,ROLLUP(B,A),CUBE(B,NULL)) HAVING COUNT(B) > 1e-1 AND B IS NOT NULL ORDER BY B ASC  ) T GROUP BY GROUPING SETS(C2,C1,CUBE(C2,C2));
SELECT UNIQUE T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MAX(T.C3) FROM (SELECT ALL A C1,GROUPING_ID(A,A) C2,COUNT(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(ROLLUP(A,NULL)) HAVING COUNT(A) > 1e-1 AND A IS NOT NULL ORDER BY A DESC  ) T GROUP BY GROUPING SETS(C2,C1);
SELECT  T.C2,GROUPING(T.C2),GROUPING_ID(T.C2,T.C2),MAX(T.C3) FROM (SELECT DISTINCT B C1,GROUPING(B) C2,MAX(A) C3 FROM zct1_grouping2 GROUP BY GROUPING SETS(B,NULL,ROLLUP(B,NULL),CUBE(B,A)) HAVING B IS NOT NULL ORDER BY B ASC  ) T GROUP BY GROUPING SETS(C2,C1,CUBE(C2,C3));

