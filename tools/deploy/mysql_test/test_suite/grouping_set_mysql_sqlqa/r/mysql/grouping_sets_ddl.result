####create table as select
drop table if exists zct1;
drop table if exists zct2;
drop table if exists zct3;
drop table if exists zct4;
drop table if exists zct5;
drop table if exists zct6;
create table zct1 as select c1 a,grouping(c1) b from zct1_grouping group by grouping sets(c1) order by c1;
create table zct2 as select c1 a,c2 b,grouping_id(c1,c2) c from zct1_grouping group by grouping sets(c1,c2) order by c1,c2;
create table zct3 as select c1 a,grouping(c1) b from zct1_grouping group by rollup(c1) order by c1;
create table zct4 as select c1 a,c2 b,grouping_id(c1,c2) c from zct1_grouping group by rollup(c1,c2) order by c1,c2;
create table zct5 as select c1 a,grouping(c1) b from zct1_grouping group by cube(c1) order by c1;
create table zct6 as select c1 a,c2 b,grouping_id(c1,c2) c from zct1_grouping group by cube(c1,c2) order by c1,c2;
