##fm test
select ora_trunc(str_to_date('2020-10-20 01:02:03', '%Y-%m-%d %H:%i:%S.%f'), 'fmyyyy') from dual;
select ora_trunc(str_to_date('2020-10-20 01:02:03', '%Y-%m-%d %H:%i:%S.%f'), 'monthfm') from dual;
select ora_trunc(str_to_date('2020-10-20 01:02:03', '%Y-%m-%d %H:%i:%S.%f'), 'fmdayfm') from dual;
select ora_trunc(str_to_date('2020-10-20 01:02:03', '%Y-%m-%d %H:%i:%S.%f'), 'fmfmscc') from dual;
select ora_trunc(str_to_date('2020-10-20 01:02:03', '%Y-%m-%d %H:%i:%S.%f'), 'qfmfmfm') from dual;
select ora_trunc(str_to_date('2020-10-20 01:02:03', '%Y-%m-%d %H:%i:%S.%f'), 'fmhhfmfm') from dual;
select ora_trunc(str_to_date('2020-10-20 01:02:03', '%Y-%m-%d %H:%i:%S.%f'), 'fmiyyy') from dual;
select ora_trunc(str_to_date('2020-10-20 01:02:03', '%Y-%m-%d %H:%i:%S.%f'), 'dddfm') from dual;
select ora_trunc(str_to_date('2020-10-20 01:02:03', '%Y-%m-%d %H:%i:%S.%f'), 'fmwwfm') from dual;
select ora_trunc(str_to_date('2020-10-20 01:02:03', '%Y-%m-%d %H:%i:%S.%f'), 'fmfmiw') from dual;
select ora_trunc(str_to_date('2020-10-20 01:02:03', '%Y-%m-%d %H:%i:%S.%f'), 'wfmfmfm') from dual;
select ora_trunc(str_to_date('2020-10-20 01:02:03', '%Y-%m-%d %H:%i:%S.%f'), 'fmfmmifm') from dual;
