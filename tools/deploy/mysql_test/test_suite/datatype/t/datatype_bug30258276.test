# owner group: SQL1
# tags: datatype

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t0;
--enable_warnings

CREATE TABLE IF NOT EXISTS t0(c0 VARCHAR(500)  NULL, c1 DECIMAL ZEROFILL ) ;
CREATE UNIQUE INDEX i1816 ON t0(c1, c0(3)) INVISIBLE;
INSERT  INTO t0(c0, c1) VALUES('243370086', 0.0);
INSERT  INTO t0(c0) VALUES("L2l[pp*10DB9>h)/t<h");
INSERT INTO t0(c0) VALUES('/.'), ('G');

SELECT /*+ USE_LATE_MATERIALIZATION  */ ALL t0.c0 AS ref0 FROM t0;
SELECT /*+ USE_LATE_MATERIALIZATION  */ ALL t0.c0 AS ref0 FROM t0 WHERE (t0.c1) IN (6.27138951E8, '-51925448');
SELECT /*+ USE_LATE_MATERIALIZATION  */ ALL t0.c0 AS ref0 FROM t0 WHERE (NOT ((t0.c1) IN (6.27138951E8, '-51925448')));
SELECT /*+ USE_LATE_MATERIALIZATION  */ t0.c0 AS ref0 FROM t0 WHERE ((t0.c1) IN (6.27138951E8, '-51925448')) IS UNKNOWN;

drop table t0;