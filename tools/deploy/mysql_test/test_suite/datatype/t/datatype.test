--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--result_format 4
# owner: luofan.zp
# owner group: SQL3
# Test of datatype functions

set sql_mode='';
--disable_warnings
drop table if exists t;
--enable_warnings
create table t(id int primary key auto_increment,
  int_val smallint,
  uint_val smallint unsigned,
  flt_val float(5, 3),
  dbl_val double(7, 4),
  dec_val decimal(5, 3),
  dt_val datetime(3),
  t_val time(3),
  vc_val varchar(2));
insert into t(int_val, uint_val, flt_val, dbl_val, dec_val, dt_val, t_val, vc_val) values
  ( 184467440737095516150,  184467440737095516150, 345.67890, 345.67890,  345.67890, '2015-7-9 1:2:3.123456', '1:2:3.123456', '123456'),
  (-184467440737095516150, -184467440737095516150,  0.444444,  0.444444,   0.444444, '1860-7-9 1:2:3.456789', '1:2:3.456789', '987654'),
  (                  NULL,                   NULL, -0.555555, -0.555555,  -0.555555, '0000-1-1 0:0:0',        '8765:43:21.1', '阿里巴巴'),
  (                 16150,                  16150,  45.67890,  15.67890,         14, '0000-0-0 0:0:0',        '1:2:3',        '34');

select * from t order by id;
select avg(int_val), avg(uint_val), avg(dec_val) from t;
update t set int_val = 123456789, uint_val = -123456789, flt_val = 98765.43210, dbl_val = 98765.43210, dec_val = 98765.43210, dt_val = '1970-1-1 9:8:7.654321', t_val = '10 9:8:7.654321', vc_val = '支付宝';
select * from t order by id limit 1;
drop table t;
--disable_warnings
drop table if exists t1k,t2k,t3k,t4k;
--enable_warnings
CREATE TABLE t1k(a varchar(20), b INT primary key, c INT , d DECIMAL(12,2), e REAL);
INSERT INTO t1k VALUES('iynfj', 1, 1, 1, 1);
INSERT INTO t1k VALUES('innfj', 2, 2, 2, 2);
--sorted_result
SELECT * FROM t1k GROUP BY a HAVING a IN ( AVG( 1 ), 1 + a,0);
drop table t1k;
CREATE TABLE t1k(a varchar(20));
INSERT INTO t1k VALUES('123');
INSERT INTO t1k VALUES('456');
INSERT INTO t1k VALUES('abc');
select * from t1k where a>123;
select * from t1k where a>=123;
select * from t1k where a<123;
select * from t1k where a<=123;
select * from t1k where a>=0;
select * from t1k where a!=456;
drop table t1k;
create table t1k(a time(6));
insert into t1k values("12:34:56");
insert into t1k values("22:34:56");
create table t2k(b varchar(200));
insert into t2k values("12:34:56");
insert into t2k values("23:34:56");
select * from t1k,t2k where a=b;
--sorted_result
select * from t1k,t2k where a!=b;
set @tmp_time_zone = @@time_zone;
set @@time_zone = '+8:00';
create table t3k(c1 timestamp(6), c2 datetime(5));
insert into t3k values(time '23:13:30' ,time '23:13:30');
select UNIX_TIMESTAMP(c1) - UNIX_TIMESTAMP(c2) from t3k;
set @@time_zone = '-5:00';
insert into t3k values(time '15:13:30' ,time '15:13:30');
set @@time_zone = '-4:00';
select UNIX_TIMESTAMP(c1) - UNIX_TIMESTAMP(c2) from t3k;
set @@time_zone = @tmp_time_zone;
set sql_mode='STRICT_ALL_TABLES';
--error 1292
insert into t3k(c1) values(0.1);
insert into t3k(c2) values(0.1);
insert into t3k(c1) values(20150708120209);
insert into t3k(c2) values(20150708120209);
insert into t3k(c1) values(20150708120209.199);
insert into t3k(c2) values(20150708120209.1999);
--error 1292
insert into t3k(c1) values(0.199);
insert into t3k(c2) values(0.1999);
--error 1292
insert into t3k(c1) values(-0.199);
--error 1292
insert into t3k(c2) values(-0.1999);
--error 1292
insert into t3k(c1) values(-20150708120209);
--error 1292
insert into t3k(c2) values(-20150708120209);
--error 1292
insert into t3k(c1) values(-20150708120209.199);
--error 1292
insert into t3k(c2) values(-20150708120209.1999);
--error 1292
insert into t3k(c2) values('-20150708120209.1999');
--error 1292
insert into t3k(c1) values('-20150708120209.199');
create table t4k(a varchar(5) primary key);
set @tmp_sql_mode = @@sql_mode;
set  @@sql_mode = '';
insert into t4k values("99999999999999");
delete from t4k;
select * from t4k;
drop table t4k;
create table t4k(a bigint, b bigint unsigned, c bigint);
insert into t4k values(-1,1,-9223372036854775808);
--error 1690
select c div a from t4k;
--error 1690
select a div b from t4k;
select CAST('2008-05-16 05:22:01' AS DATETIME) = CAST(-2074083328.884604928 AS DECIMAL);
select (TIMESTAMP '2008-09-23 19:45:09.003598' != -1273298944);
select CAST('2000-11-10 20:04:41' AS DATETIME) IN (-1);
select ifnull(cast ("2018-01-01" as date), NULL);
select date_format("","");
select date_format("xxxxx","");
select date_format("2010-15-01","");
select date_format("2010-01-01", "");
select from_unixtime(123456789, "");
set @@sql_mode = @tmp_sql_mode;
drop table t1k,t2k,t3k,t4k;
create table t1k(a binary(24));
insert into t1k values(NULL);
insert into t1k values("");
insert into t1k values(" ");
insert into t1k values("宝网司群事据付司");
--enable_metadata
select * from t1k;
--disable_metadata
drop table t1k;
create table t1k(a varchar(123), b binary(123));
insert into t1k values("1e100", "1E100");
insert into t1k values("1E100", "1e100");
insert into t1k values("1e100", "1e100");
insert into t1k values("1E100", "1E100");
select a, hex(b) from t1k where a = "1e100";
select a, hex(b) from t1k where a = "1E100";
drop table t1k;
select strcmp(binary "1E100", 1e100);
select strcmp(binary "1E100", 1E100);
create table t1k(a binary(5), b double);
insert into t1k values("1e100", 1e100);
insert into t1k values("1e100", 1E100);
insert into t1k values("1E100", 1E100);
insert into t1k values("1E100", 1e100);
select strcmp(_binary "1E100", b) from t1k;
select strcmp(_binary "1e100", b) from t1k;
select strcmp(a, 1e100) from t1k;
select strcmp(a, 1E100) from t1k;
drop table t1k;

