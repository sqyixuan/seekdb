# owner: dachuan.sdc
# owner group: SQL1
# Test of time functions
# tags: datatype

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

SET timestamp=UNIX_TIMESTAMP('2001-01-01 00:00:00');
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (a TIME(6));
INSERT INTO t1 (a) VALUES ('10:10:10.999999');
set time_zone ="+8:00";
select cast(a as DATETIME(6)), now() from t1;

set time_zone ="-8:00";
select cast(a as DATETIME(6)), now() from t1;

set time_zone ="-0:00";
select cast(a as DATETIME(6)), now() from t1;

set time_zone ="+0:00";
select cast(a as DATETIME(6)), now() from t1;


SET timestamp=UNIX_TIMESTAMP('2001-01-01 12:00:00');
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (a TIME(6));
INSERT INTO t1 (a) VALUES ('10:10:10.999999');
set time_zone ="+8:00";
select cast(a as DATETIME(6)), now() from t1;

set time_zone ="-8:00";
select cast(a as DATETIME(6)), now() from t1;

set time_zone ="-0:00";
select cast(a as DATETIME(6)), now() from t1;

set time_zone ="+0:00";
select cast(a as DATETIME(6)), now() from t1;

SET timestamp=UNIX_TIMESTAMP('2001-01-01 18:00:00');
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (a TIME(6));
INSERT INTO t1 (a) VALUES ('10:10:10.999999');
set time_zone ="+8:00";
select cast(a as DATETIME(6)), now() from t1;

set time_zone ="-8:00";
select cast(a as DATETIME(6)), now() from t1;

set time_zone ="-0:00";
select cast(a as DATETIME(6)), now() from t1;

set time_zone ="+0:00";
select cast(a as DATETIME(6)), now() from t1;




SET timestamp=UNIX_TIMESTAMP('2001-01-01 18:00:00');
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 timestamp(6));
insert into t1(c1) values( time '23:13:30' );
set time_zone ="+8:00";
select * from t1;

set time_zone ="-8:00";
select * from t1;
set time_zone ="-0:00";
select * from t1;

drop table t1;
