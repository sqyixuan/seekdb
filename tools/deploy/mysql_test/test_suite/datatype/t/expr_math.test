# owner: dachuan.sdc
# owner group: SQL2
# Test of mathematical functions for all data types.
# tags: datatype

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# prepare data.
source mysql_test/test_suite/datatype/t/prepare_data.sql;

# mathematical functions.
source mysql_test/test_suite/datatype/t/expr_abs.sql;
source mysql_test/test_suite/datatype/t/expr_ceil.sql;
source mysql_test/test_suite/datatype/t/expr_floor.sql;
source mysql_test/test_suite/datatype/t/expr_round.sql;

# clear data.
source mysql_test/test_suite/datatype/t/clear_data.sql;
