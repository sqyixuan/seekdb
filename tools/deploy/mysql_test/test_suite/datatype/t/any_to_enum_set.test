# 测试 ob_obj_cast 里面的 date/datetime/time/year 转 set/enum
--disable_warnings
create table test(
  col_date DATE,
  col_datetime DATETIME(6),
  col_timestamp TIMESTAMP(6),
  col_time TIME(6),
  col_year YEAR,
  col_year2 YEAR
);
--enable_warnings
insert into test(col_date, col_datetime, col_timestamp, col_time, col_year, col_year2) VALUES('0', '0', '0', '0', '0', '0000');
