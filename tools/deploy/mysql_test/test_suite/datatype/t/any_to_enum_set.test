# owner: lihongqin.lhq
# owner group: storage
# description: conversion from string/int/float/date to ENUM/SET should behave the same as MySQL 5.6
# Due to a bug in MySQL, OB behaves differently, when converting to SET with 64 elements.
# tags: datatype

# 启用非严格模式
set sql_mode = "";

# 测试 ob_datum_cast 里面的 text/varchar 转 set/enum
--disable_warnings
drop table if exists test;
drop table if exists dst;
create table test (col_blob blob, col_varchar varchar(10));
--enable_warnings
insert into test (col_blob, col_varchar) values(NULL, NULL);
insert into test (col_blob, col_varchar) values("123", "-1");
insert into test (col_blob, col_varchar) values("123,123", "0");
insert into test (col_blob, col_varchar) values("123,", "1");
insert into test (col_blob, col_varchar) values("123,,", "2");
insert into test (col_blob, col_varchar) values("123,1234", "3");
insert into test (col_blob, col_varchar) values("123 1234", "4");
insert into test (col_blob, col_varchar) values("123 ,1234", "5");
insert into test (col_blob, col_varchar) values("abc123xxx123", "6");
insert into test (col_blob, col_varchar) values("123x", NULL);
insert into test (col_blob, col_varchar) values("63", NULL);
insert into test (col_blob, col_varchar) values("123,abc", NULL);
insert into test (col_blob, col_varchar) values("123, abc", NULL);
insert into test (col_blob, col_varchar) values("123, x, abc", NULL);
insert into test (col_blob, col_varchar) values("123, x, abc", NULL);
insert into test (col_blob, col_varchar) values("123,,,,,abc", NULL);
insert into test (col_blob, col_varchar) values("123,, ,,,abc", NULL);
insert into test (col_blob, col_varchar) values("123, abc, x", NULL);
insert into test (col_blob, col_varchar) values("123,abc, x", NULL);
insert into test (col_blob, col_varchar) values("123,abc,x", NULL);
create table dst(
    c1 set('1', '2', '3', '4', '5', '123', 'abc'),
    c2 enum('1', '2', '3', 'a', 'b')
);
insert into dst select * from test;
select * from dst;
drop table dst;
drop table test;

# 测试 ob_datum_cast 里面的 int/uint 转 set
--disable_warnings
create table test (col_tint tinyint, col_utint tinyint unsigned, col_bint bigint, col_ubint bigint unsigned);
--enable_warnings
insert into test (col_tint, col_utint, col_bint, col_ubint) values(-128, 0, -9223372036854775808, 9223372036854775808);
insert into test (col_tint, col_utint, col_bint, col_ubint) values(127, 255, NULL, NULL);
insert into test (col_tint, col_utint, col_bint, col_ubint) values(-127, 127, NULL, NULL);
