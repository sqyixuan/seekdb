# Test of time functions
# tags: datatype

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

select date_add(TIME '16:25:46.635', INTERVAL 2 hour);
select date_add('16:25:46.635', INTERVAL 20 hour);
select date_add('2008-12-29 16:25:46.635', INTERVAL 20 hour);
select date_add(STR_TO_DATE('10:00 PM', '%h:%i %p'), INTERVAL 2 hour);
SELECT STR_TO_DATE('10:00 PM', '%h:%i %p') + INTERVAL 10 MINUTE;


select date_add('2008-12-29 16:25:46.635', INTERVAL 2 day);
select date_add('2008-12-29 16:25:46.635', INTERVAL 2 hour);
select date_add('2008-12-29 16:25:46.635', INTERVAL 2 minute);
select date_add('2008-12-29 16:25:46.635', INTERVAL 2 second);
select date_add('2008-12-29 16:25:46.635', INTERVAL 2 microsecond);
select date_add('2008-12-29 16:25:46.635', INTERVAL 2 week);
select date_add('2008-12-29 16:25:46.635', INTERVAL 2 month);
select date_add('2008-12-29 16:25:46.635', INTERVAL 2 quarter);
select date_add('2008-12-29 16:25:46.635', INTERVAL 2 year);

select date_add('2008-12-29 16:25:46.635', INTERVAL '01:15:30' hour_second);
select date_add('2008-12-29 16:25:46.635', INTERVAL '1 2' hour_minute);
select date_add('2008-12-29 16:25:46.635', INTERVAL '1 2' hour_microsecond);

select date_add('2008-12-29 16:25:46.635', INTERVAL '1 2' minute_second);
select date_add('2008-12-29 16:25:46.635', INTERVAL '1 2' minute_microsecond);

select date_add('2008-12-29 16:25:46.635', INTERVAL '1 01:15:30' day_second);
select date_add('2008-12-29 16:25:46.635', INTERVAL '1 1:1:1' day_second);
select date_add('2008-12-29 16:25:46.635', INTERVAL '1 2' day_hour);
select date_add('2008-12-29 16:25:46.635', INTERVAL '1 2' day_minute);
select date_add('2008-12-29 16:25:46.635', INTERVAL '1 2' day_microsecond);

select date_add('2008-12-29 16:25:46.635', INTERVAL '1 2' year_month);

select date_add('2008-12-29 16:25:46.635', INTERVAL '1 2' second_microsecond);


select date_add(TIME '16:25:46.635', INTERVAL 2 day);
select date_add(TIME '16:25:46.635', INTERVAL 2 hour);
