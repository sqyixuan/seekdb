--disable_warnings
drop table if exists tt;
--enable_warnings
create table tt( a date, b datetime, c time, d int, e varchar(100), f timestamp(6));
insert into tt values('2008-12-29', '2008-12-29 16:25:46.635', '16:25:46.635', 20151111, '2008-12-29 16:25:46.635', '2008-12-29 16:25:46.635');
select date_add(a, INTERVAL 2 day) from tt;
select date_add(a, INTERVAL 2 hour) from tt;
select date_add(a, INTERVAL 2 minute) from tt;
select date_add(a, INTERVAL 2 second) from tt;
select date_add(a, INTERVAL 2 microsecond) from tt;
select date_add(a, INTERVAL 2 week) from tt;
