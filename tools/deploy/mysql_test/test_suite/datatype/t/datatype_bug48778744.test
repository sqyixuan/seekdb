# owner: yibo.tyf
# owner group: SQL1
# tags: datatype

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings
set sql_mode=default;
create table t1(c1 bigint unsigned, c2 int, c3 bigint);

insert into t1(c1) values(0xFFFFFFFFFFFFFC08);
--error 1264
insert into t1(c2) values(0xFFFFFFFFFFFFFC08);
--error 1264
insert into t1(c3) values(0xFFFFFFFFFFFFFC08);

set sql_mode='';
insert into t1 values(0xFFFFFFFFFFFFFC08,0xFFFFFFFFFFFFFC08,0xFFFFFFFFFFFFFC08);
select * from t1;
select * from t1 where c1 = 0xFFFFFFFFFFFFFC08;
select * from t1 where c2 = 0xFFFFFFFFFFFFFC08;
select * from t1 where c3 = 0xFFFFFFFFFFFFFC08;

select cast(0xFFFFFFFFFFFFFC08 as signed);

drop table t1;