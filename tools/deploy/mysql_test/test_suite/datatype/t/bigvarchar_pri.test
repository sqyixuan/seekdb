--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL1
# Test of functions bigvarchar_pri
#--disable_abort_on_error
--source mysql_test/include/index_quick_major.inc
--disable_warnings
drop table if exists test,test2;
--enable_warnings
create table test(a varchar(4090) primary key);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table test;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 'test', table_id, 1);
--disable_query_log
eval select data_length from oceanbase.__all_virtual_column where column_name='a' and table_id=$table_id;
disconnect obsys;
connection default;
--enable_query_log
--error 1074
create table test2(a varchar(262145) primary key);
create table test2(a int ,b varchar(4096) primary key);
create index idx on test2(a);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
insert into  test2 values(1,'1') ;
insert into  test2 values(2,'2') ;
insert into  test2 values(3,'3') ;
insert into  test2 values(4,'4') ;
insert into  test2 values(5,'5') ;
insert into  test2 values(6,'6') ;
insert into  test2 values(7,'7') ;
insert into  test2 values(8,'8') ;
insert into  test2 values(9,'9') ;
insert into  test2 values(10,'0') ;
--let $a=''
--disable_query_log
eval update test2 set b=concat('1',repeat($a,10)) where a=1;
eval update test2 set b=concat('2',repeat($a,10)) where a=2;
eval update test2 set b=concat('3',repeat($a,10)) where a=3;
eval update test2 set b=concat('4',repeat($a,10)) where a=4;
eval update test2 set b=concat('5',repeat($a,10)) where a=5;
eval update test2 set b=concat('6',repeat($a,10)) where a=6;
eval update test2 set b=concat('7',repeat($a,10)) where a=7;
eval update test2 set b=concat('8',repeat($a,10)) where a=8;
eval update test2 set b=concat('9',repeat($a,10)) where a=9;
eval update test2 set b=concat('10',repeat($a,10)) where a=10;

--error 1406
eval update test2 set b=concat('1',repeat($a,11)) where a=1;
eval update test2 set b=concat(concat('1',repeat($a,10)),substr($a,1,3)) where a=2;
#eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=2;
#eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=3;
#eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=4;
#eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=5;
#eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=6;
#eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=7;
#eval update test2 set b=concat(b,'abcdefghijk123456789abcd') where a=8;
select count(*) from test2;
select a,length(b) from test2;
#delete from test2 where a=1;
delete from test2 ;
#--disable_parsing
alter table test2 set EXPIRE_INFO (a >= 5);
sleep 5;

--source mysql_test/include/check_all_idx_ok_unq.inc
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
--source mysql_test/include/wait_daily_merge.inc

alter table test2 set EXPIRE_INFO (length(b) <26264);
sleep 2;

--source mysql_test/include/check_all_idx_ok_unq.inc
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
--source mysql_test/include/wait_daily_merge.inc

select /*+index(test2 primary)*/ a,length(b) from test2;
delete from test2 where a=1;
select *  from test2 where a=1;
delete from test2 where a in (2,3);
select * from test2 where a in (2,3);

#--enable_parsing

drop table test,test2;
