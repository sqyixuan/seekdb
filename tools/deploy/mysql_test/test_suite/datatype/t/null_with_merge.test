--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: zuojiao.hzj
#### owner group: sql3
#### description: 测试每日合并（带NULL）
--disable_warnings
drop table if exists t1;
--enable_warnings

--real_sleep 1
create table t1(pk int primary key,extra int);

insert into t1(pk,extra) values(1,NULL);
--let $v=2
while($v < 10)
{
  eval insert into t1(pk) values($v);
  inc $v;
}
update t1 set pk=1 where pk is NULL;
--error 1062
update t1 set pk=2 where pk=1;

delete from t1 where pk is NULL;
delete from t1 where pk=0;
select * from t1;
insert into t1 values(100,NULL);
select * from t1;

--source mysql_test/include/majorfreeze.inc
select * from t1;
--source mysql_test/include/wait_daily_merge.inc
select * from t1;

--error 1062
insert into t1(pk,extra) values(100,NULL);

drop table t1;

