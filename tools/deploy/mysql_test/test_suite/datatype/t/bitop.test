--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: zuojiao.hzj
#### owner group: sql3
#### description: bitop test
select 1 ^ 2;
select 1 | 2;
select 1 & 2;
select 1.2 ^ 2.6;
select 1.2 & 2.6;
select 1.2 | 2.6;
select '1.2' ^ '2.6';
select '1.2' & '2.6';
select '1.2' | '2.6';
select -1 ^ -3;
select -1 & -3;
select -1 | -3;
select -3 ^ 2.6;
select -3 & 2.6;
select -3 | 2.6;
select 123456789 ^ 0;
select 123456789 | 0;
select 123456789 & 0;
--disable_warnings
drop table if exists t;
--enable_warnings
create table t select ~1;
select * from t;
drop table t;
select ~1.2;
select ~(2 << 63);
select 123456789 >> 4;
select 123456789 >> 4.2;
select -1 & 9223372036854775807;
select -1 | 9223372036854775807;
select -1 ^ 9223372036854775807;
select -1 & 9223372036854775808;
select -1 | 9223372036854775808;
select -1 ^ 9223372036854775808;
