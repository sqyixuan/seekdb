# owner: dachuan.sdc
# owner group: SQL3
# Test of dml operation for all data types.
# tags: datatype

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t;
--enable_warnings
create table t(
  id              int primary key auto_increment,
  col_int8        tinyint,
  col_int16       smallint,
  col_int24       mediumint,
  col_int32       int,
  col_int64       bigint,
  col_uint8       tinyint unsigned,
  col_uint16      smallint unsigned,
  col_uint24      mediumint unsigned,
  col_uint32      int unsigned,
  col_uint64      bigint unsigned,
  col_float       float,
  col_double      double,
  col_ufloat      float unsigned,
  col_udouble     double unsigned,
  col_decimal     decimal(20, 2),
  col_udecimal    decimal(20, 4) unsigned,
  col_datetime    datetime(2),
  col_timestamp   timestamp(3) null default null,
  col_date        date,
  col_time        time(4),
  col_year        year(4),
  col_varchar     varchar(6),
  col_char        char(5),
  col_varbinary   varbinary(5),
  col_binary      binary(4),
  col_varchar0    varchar(0),
  col_varbinary0  varbinary(0)
);
set sql_mode='strict_all_tables';
source mysql_test/test_suite/datatype/t/dml_insert.sql;
source mysql_test/test_suite/datatype/t/dml_select.sql;
exec sed -i 's/--error/#error/' mysql_test/test_suite/datatype/t/dml_insert.sql;
set sql_mode='';
source mysql_test/test_suite/datatype/t/dml_insert.sql;
source mysql_test/test_suite/datatype/t/dml_select.sql;
exec sed -i 's/#error/--error/' mysql_test/test_suite/datatype/t/dml_insert.sql;

--disable_warnings
drop table if exists t;
--enable_warnings
