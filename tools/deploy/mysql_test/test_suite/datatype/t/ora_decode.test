create table t1 as select ora_decode(1,1,1.1,0.1) d, sum(ora_decode(1, 1, 1.1, 0.1)) sum_, max(ora_decode(1,1,1.1,0.1)) max_, min(ora_decode(1,1,1.1,0.1)) min_ from dual;
