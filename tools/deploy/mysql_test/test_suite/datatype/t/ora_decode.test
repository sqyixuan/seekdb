create table sb(a int);
insert into sb values(1), (2), (3), (4);
select a, ora_decode(1, a, 1, '01', 2222, 1, 3333) as decode from sb order by a;
drop table sb;

create table sb(a varchar(100) collate utf8mb4_general_ci, b bigint);
insert into sb values ('1st', 1), ('2nd', 2), ('3rd', 3), ('other', 100), (null, null);
select a, ora_decode(a, '1st', 1, '2nd', 2, '3rd', 3, 100) as decode from sb order by a;
drop table sb;

