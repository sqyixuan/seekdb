# owner: dachuan.sdc
# owner group: SQL2
# Test of time functions
# tags: datatype、date_add
 
--result_format 4
 
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
 
alter system flush plan cache;
 
# 0. table column
# 1. index column
# 2. add column
# 3. udf
# SUBDATE
# ADDDATE
# DATE_ADD
# DATE_SUB
 
--disable_warnings
drop table if exists t0, t1, t2, t3, t4, t5, t6, t7, t8;
--enable_warnings
 
## 0.0 create table using adddate func
CREATE TABLE t0(c1 date, c2 text AS (ADDDATE(c1, c1))stored);
CREATE TABLE t1(c1 date, c2 text AS (SUBDATE(c1, c1))stored);
CREATE TABLE t2(c1 date, c2 text AS (DATE_ADD(c1, interval 1 day))stored);
CREATE TABLE t3(c1 date, c2 text AS (DATE_SUB(c1, interval 1 day))stored);
CREATE TABLE t4(c1 date, c2 text AS (c1 + interval 1 day)stored);
CREATE TABLE t5(c1 date, c2 text AS (interval 1 day + c1)stored);
CREATE TABLE t6(c1 date, c2 text AS (c1 - interval 1 day)stored);
 
## 1.0 create index using adddate func
create table t7(c1 time, c2 date);
#--error 3758
#create index i1 on t7((adddate(c1, 1)));
create index i1 on t7((adddate(c2, 1)));
create index i2 on t7((subdate(c2, 1)));
create index i3 on t7((date_add(c2, interval 1 day)));
create index i4 on t7((date_sub(c2, interval 1 day)));
--error 1064
create index i4 on t7(c2 + interval 1 day);
--error 1064
create index i4 on t7(interval 1 day + c2);
--error 1064
create index i4 on t7(c2 - interval 1 day);
 
## 2.0 add column using adddate func
CREATE TABLE t8(sidea int(10), sideb DOUBLE, sided DATE, sidec DATE AS (TO_DAYS(sidea)))DEFAULT CHARACTER SET = utf8;
alter table t8 add column c6 int generated always as (DAYOFWEEK(sided)) virtual;
alter table t8 drop column sidec;
INSERT INTO t8 (sidea, sideb,sided) VALUES(950501,950501,'20200920');
alter table t8 add column c7 DATE generated always as (DATE_ADD(sided, INTERVAL '-1 10' DAY_HOUR)) virtual;
alter table t8 add column c8 DATE generated always as (DATE_SUB(sided, INTERVAL '-1 10' DAY_HOUR)) virtual;
alter table t8 add column c9 DATE generated always as (ADDDATE(sided, 1)) virtual;
alter table t8 add column c10 DATE generated always as (SUBDATE(sided, 1)) virtual;
alter table t8 add column c11 DATE generated always as (sided + INTERVAL '-1 10' DAY_HOUR) virtual;
alter table t8 add column c12 DATE generated always as (sided + INTERVAL '-1 10' DAY_HOUR) virtual;
alter table t8 add column c13 DATE generated always as (sided - INTERVAL '-1 10' DAY_HOUR) virtual;
 
## 3.0 udf
# When udf was established, there was no resolve time date_ Add function, there is a resolve when executing udf
DROP FUNCTION IF EXISTS UDF_R;
 
DELIMITER //;
CREATE FUNCTION UDF_R() RETURNS INT
BEGIN
  DECLARE a DATE DEFAULT '2022-06-06';
  DECLARE b DATE DEFAULT 0;
  DECLARE c DATE DEFAULT 0;
  DECLARE d DATE DEFAULT 0;
  DECLARE e DATE DEFAULT 0;
  DECLARE f DATE DEFAULT 0;
  DECLARE g DATE DEFAULT 0;
  DECLARE h DATE DEFAULT 0;
  SELECT adddate(a, 1) INTO b FROM t1;
  SELECT subdate(a, 1) INTO c FROM t1;
  SELECT date_add(a, interval 1 day) INTO d FROM t1;
  SELECT date_sub(a, interval 1 day) INTO e FROM t1;
  SELECT a + interval 1 day INTO f FROM t1;
  SELECT a - interval 1 day INTO g FROM t1;
  SELECT interval 1 day + a INTO h FROM t1;
 
  RETURN b;
END
//
 
DELIMITER ;//
select UDF_R() from dual;
 
drop table t0, t1, t2, t3, t4, t5, t6, t7, t8;
DROP FUNCTION UDF_R;
