--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL1
# Test of a bug 
# https://dev.mysql.com/doc/refman/5.7/en/hexadecimal-literals.html
--result_format 4
--disable_warnings
drop procedure if exists p36363295;
--enable_warnings



##  Values written using 0xval notation that contain an odd number of digits are treated as having an extra leading 0. For example, 0xaaa is interpreted as 0x0aaa.
select 0x94142;

delimiter //;
create procedure p36363295()
  begin
    select 0x94142;
  end//
delimiter ;//
call p36363295();
drop procedure p36363295;


select 0x094142;

delimiter //;
create procedure p36363295()
  begin
    select 0x094142;
  end//
delimiter ;//
call p36363295();
drop procedure p36363295;


select 0x94142 = 0x094142;

delimiter //;
create procedure p36363295()
  begin
    select 0x94142 = 0x094142;
  end//
delimiter ;//
call p36363295();
drop procedure p36363295;



## Values written using X'val' notation must contain an even number of digits or a syntax error occurs. To correct the problem, pad the value with a leading zero.
--error 1064
select X'94142';

delimiter //;
--error 1064
create procedure p36363295()
  begin
    select X'94142';
  end//
delimiter ;//


select X'094142';

delimiter //;
create procedure p36363295()
  begin
    select X'094142';
  end//
delimiter ;//
call p36363295();
drop procedure p36363295;

