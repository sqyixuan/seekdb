# owner: dachuan.sdc
# owner group: SQL2
# Test of time functions
# tags: datatype、fast parser

--result_format 4
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 1170, error_code = 4001, frequency = 1;
connection default;

alter system flush plan cache;
select INTERVAL '3' HOUR + DATE('2019-12-25 12:30:12') R from dual;
select INTERVAL '6' HOUR + DATE('2019-12-25 12:30:12') R from dual;
select DATE('2019-12-25 12:30:12') + INTERVAL '3' HOUR R from dual;
select DATE('2019-12-25 12:30:12') + INTERVAL '6' HOUR R from dual;

alter system flush plan cache;
--echo
--echo *********************select INTERVAL '3' HOUR + DATE('2019-12-25 12:30:12') R from dual *********************
--echo *********************select INTERVAL '6' HOUR + DATE('2019-12-25 12:30:12') R from dual *********************
--disable_query_log
--disable_result_log
select INTERVAL '3' HOUR + DATE('2019-12-25 12:30:12') R from dual;
select INTERVAL '6' HOUR + DATE('2019-12-25 12:30:12') R from dual;
--enable_result_log
select  hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select INTERVAL ? HOUR + DATE(?) R from dual";

--echo
--echo *********************select DATE('2019-12-25 12:30:12') + INTERVAL '3' HOUR R from dual *********************
--echo *********************select DATE('2019-12-25 12:30:12') + INTERVAL '6' HOUR R from dual *********************
--disable_query_log
--disable_result_log
select DATE('2019-12-25 12:30:12') + INTERVAL '3' HOUR R from dual;
select DATE('2019-12-25 12:30:12') + INTERVAL '6' HOUR R from dual;
--enable_result_log
select  hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like "select DATE(?) + INTERVAL ? HOUR R from dual";