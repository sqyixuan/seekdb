--let $head =create table t1(a0 timestamp(6) 
--let $sql =
--let $column=100

--let $x=, c
--let $y= timestamp(6) default  '2014-10-30 11:40:10' 
while($column)
{

    --let $sql=$sql$x$column $y
    dec $column;
}
 --let $column2=56
 --let $z=)
 --let $prik=,primary key(a0
 --let $sql=$sql$prik
while($column2)
{

    --let $sql=$sql$x$column2
    dec $column2;
}
--let $sql=$sql$z
#--echo  $head$sql$z;
#--disable_parsing
eval $head$sql$z;
create index idx1 on t1(a0,c1);
--source mysql_test/include/check_all_idx_ok.inc
let $a=1000;
--disable_query_log
while($a)
{
   eval insert into t1(a0,c1) values(usec_to_time($a),usec_to_time($a+1000));
   dec $a;
}
--enable_query_log

select c1 from t1 limit 1;
select a0,c1,c2,c3 from t1 limit 1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
connect (many_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
if ($TENANT == 'mysql') {
let $tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);
let $idx11 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where tenant_id = $tenant_id and table_name='t1' and database_id = (select database_id from oceanbase.__all_virtual_database where tenant_id = $tenant_id and database_name = 'test')) b on a.data_table_id=b.table_id, table_name, 1);
}
if ($TENANT == 'oracle') {
let $tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'oracle', tenant_id, 1);
let $idx11 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where tenant_id = $tenant_id and table_name='t1' and database_id = (select database_id from oceanbase.__all_virtual_database where tenant_id = $tenant_id and database_name = 'test')) b on a.data_table_id=b.table_id, table_name, 1);
}
connection default;
select a0,c1 from t1  limit 1;
--disable_query_log
set ob_enable_index_direct_select=true;
eval select a0,c1 from $idx11 limit 1;
--enable_query_log

drop table t1;

