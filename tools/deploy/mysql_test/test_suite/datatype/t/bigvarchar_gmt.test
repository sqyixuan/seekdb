--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL1
# Test of functions bigvarchar_gmt

set global  max_allowed_packet=3145728;
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
--source mysql_test/include/index_quick_major.inc
--disable_warnings
drop table if exists test11;
--enable_warnings
create table test11 (gmt_create datetime default now(), gmt_modify datetime default now(),i1 int, i2 varchar(4090),i4 float, i5 datetime(6),i6 decimal(5,3),i7 varchar(65535),i8 varchar(65535),i9 varchar(65535),i10 varchar(65535), primary key(i1,i2,i5));
--source mysql_test/include/bigvarchar.inc
set @@session.sql_mode='';
eval set @a='';
--disable_query_log
--let $loop=499
while  ($loop)
{
eval insert into test11(i1, i2,i4,i5,i6,i7,i8,i9,i10) values($loop, concat($loop,substr(@a,1,16381)),1.25,'2014-10-01 00:12:11',-1.345,@a,@a,@a,@a);
dec $loop;
}
--enable_query_log
select i1,length(i2),length(i7),length(i8),length(i9) from test11 limit 10;
select count(*) from test11 where length(i2)=16382;
select count(*) from test11 where length(i2)=16383;
select count(*) from test11 where length(i2)=16384;

--sorted_result
select count(*) from test11 group by length(i2);
--sorted_result
select length(i2), count(*) from test11 group by length(i2);
--sorted_result
select length(i2) as len, count(*) from test11 group by len;
--sorted_result
select substr(i2,1,3) as len, count(*) from test11 where i1 between 101 and 150 group by substr(i2,1,3);
select length(i2) as len, count(*) from test11 order by i2;
select length(i2) as len, count(*) from test11 order by i2;
select length(i2) as len, count(*) from test11 order by i2;
set @@ob_query_timeout=50000000;
--sorted_result
select length(i2), count(*) from test11 group by  i7;
select length(i2) as len  from test11 order by i2 limit 10;
eval insert into test11(i1,i2,i4,i5,i6,i7,i8,i9,i10)  values(1001,substr(@a,1,16384),1.25,'2014-10-01 00:12:11',-1.345,@a,@a,@a,@a);
select i1,length(i2) from test11 where i2 like '2defghijk123456789abcdefghijk123456789abcdefghijk123456789a%';
select count(*) from test11 where i7 like 'defghijk123456789abcdefghijk123456789abcdefghijk123456789a%';
select i1,substr(i2,1,10) from test11 where i2 like concat('2','defghijk123456789abcdefghijk123456789abcdefghijk123456789a%');
select i1,count(*) from test11 where i7 like concat('','defghijk123456789abcdefghijk123456789abcdefghijk123456789a%');
select i1,count(*) from test11 where i7 like  '%ijk123456789abcdefghijk123456789abcdefghijk123';
select i1,count(*) from test11 where i7 like  '%456789abcd';
select i1,count(*) from test11 where i2 like  '%456789abcd';
select i1,count(*),substr(i7,-10) from test11 where i7 like  '%456789abcd';
select i1,count(*),substr(i7,-10) from test11 where i2 like  '%456789abcd';
select i1,count(*) from test11 where i2 not like  '%456789abcd';
eval alter table test11 set EXPIRE_INFO (i2=@a);
eval set @c=substr(@a,1,1000);
eval alter table test11 set EXPIRE_INFO (i2=@c);
sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select count(*) from test11;
select count(*) from test11 where i1=1001;
eval alter table test11 set EXPIRE_INFO (substr(i2,1,491)=@c);
sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select count(*) from test11;
select count(*) from test11 where i1=1001;
select count(*) from test11 where i7 like concat('2','defghijk123456789abcdefghijk123456789abcdefghijk123456789a');

eval alter table test11 set EXPIRE_INFO (i7<@c);
sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select count(*) from test11;
select count(*) from test11 where i1=1001;

eval insert into test11(i1,i2,i4,i5,i6,i7,i8,i9,i10)  values(1000,substr(@a,1,16384),1.25,'2014-10-01 00:12:11',-1.345,@a,@a,@a,@a);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select count(*) from test11;
select i1,i2,i4,i5,i6,i7,i8,i9,i10  from test11 where i2  like  '%456789abcd' limit 1;
select i1,i4,length(i8) from test11 group by i7 asc limit 1;
select length(upper(i2)),length(upper(i7)) from test11 limit 10;
select length(lower(i2)),length(lower(i7)) from test11 limit 10;
select length(trim(concat('  ',i2))) from test11 where i1=1;
select length(trim(concat('  ',i7))) from test11 where i1=1;
select coalesce(i1,i7,i8,null) from test11 limit 1;
select length(nvl(null,i2)) from test11 limit 1;
select length(nvl('abc',i2)) from test11 limit 1;
--disable_query_log
eval select case when i7=@a then 'true' else 'false' end  from test11 where i1=10 ;
eval select case when i2=concat('10',substr(@a,1,16381)) then 'true' else 'false' end  from test11 where i1=10 ;
--enable_query_log
select count(*) from test11 where i1 in (1,2,3) or i1 between 10 and 13;
set global  max_allowed_packet=1048576;

drop table test11;
