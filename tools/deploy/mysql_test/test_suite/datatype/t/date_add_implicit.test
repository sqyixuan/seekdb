select '2008-12-29 16:25:46.635' + INTERVAL 20 hour;
select STR_TO_DATE('10:00 PM', '%h:%i %p') + INTERVAL 2 hour;
SELECT STR_TO_DATE('10:00 PM', '%h:%i %p') + INTERVAL 10 MINUTE;

select  INTERVAL 2 hour + TIME('16:25:46.635');
