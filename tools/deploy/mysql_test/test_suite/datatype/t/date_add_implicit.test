# Test of time functions
# tags: datatype

--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log


alter system flush plan cache;
select TIME('16:25:46.635') +  INTERVAL 2 hour;
