--result_format 3
create table tt(c1 timestamp);
insert into tt values ('2019-10:31 10:32:21.232');
select c1, case when 1 then c1 + interval 1 second
                when 2 then c1 - interval 1 second
                else null end from tt;
drop table tt;
create table tt(c1 datetime(1), c2 time(1), c3 date);
insert into tt values('1970-01-01 00:00:00.1', '00:00:00.1', '1970-01-01');
select c1, c1 + interval 1 second from tt;
select c1, c1 + interval '1.12' second from tt;
select c1, c1 + interval 1.12 second from tt;
select c1, c1 + interval 1 microsecond from tt;
select c1, c1 + interval 1 day from tt;
select c2, c2 + interval 1 second from tt;
select c2, c2 + interval '1.12' second from tt;
select c2, c2 + interval 1.12 second from tt;
select c2, c2 + interval 1 microsecond from tt;
select c2, c2 + interval 1 day from tt;
select c3, c3 + interval 1 day from tt;
select c3, c3 + interval '1.12' second from tt;
select c3, c3 + interval 1.12 second from tt;
select c3, c3 + interval 1 microsecond from tt;

select interval 1 second + c1, c1 from tt;
select interval '1.12' second + c1, c1 from tt;
select interval 1.12 second + c1, c1 from tt;
select interval 1 microsecond + c1, c1 from tt;
select interval 1 day + c1, c1 from tt;
select interval 1 second + c2, c2 from tt;
select interval '1.12' second + c2, c2 from tt;
select interval 1.12 second + c2, c2 from tt;
select interval 1 microsecond + c2, c2 from tt;
select interval 1 day + c2, c2 from tt;
select interval 1 day + c3, c3 from tt;
select interval '1.12' second +  c3, c3 from tt;
select interval 1.12 second + c3, c3 from tt;
select interval 1 microsecond + c3, c3 from tt;

drop table tt;

select INTERVAL 1 DAY + '2018-12-31';
select '2018-12-31' + INTERVAL 1 DAY;
--error 1064
SELECT INTERVAL 1 DAY - '2018-12-31';

alter system flush plan cache;
select INTERVAL '3' HOUR + DATE('2019-12-25 12:30:12') R from dual;
select INTERVAL '6' HOUR + DATE('2019-12-25 12:30:12') R from dual;
select DATE('2019-12-25 12:30:12') + INTERVAL '3' HOUR R from dual;
select DATE('2019-12-25 12:30:12') + INTERVAL '3' HOUR R from dual;

create view v1 as select INTERVAL '3' HOUR + DATE('2019-12-25 12:30:12') R from dual;
create view v2 as select DATE('2019-12-25 12:30:12') + INTERVAL '3' HOUR R from dual;
drop view v1;
drop view v2;
