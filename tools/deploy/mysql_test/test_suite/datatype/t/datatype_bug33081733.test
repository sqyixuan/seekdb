# owner: jim.wjh
# owner group: SQL3
# Test of ddl operation for text.
# tags: datatype


--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 text);
drop table t1;

create table t1(c1 text(100));
drop table t1;

create table t1(c1 tinytext);
drop table t1;

create table t1(c1 mediumtext);
drop table t1;

create table t1(c1 longtext);
drop table t1;

--error 1064
create table t1(c1 tinytext(10));

--error 1064
create table t1(c1 mediumtext(10));

--error 1064
create table t1(c1 longtext(10));


