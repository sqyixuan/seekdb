--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: zuojiao.hzj
#### owner group: sql3
#### description: 测试每日合并（带NULL）
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--disable_abort_on_error
connection conn1;
--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

#alter system set min_drop_cache_wait_time='10s' server_type=chunkserver;
--real_sleep 1 

create table t1(i1 int, s1 char(124), d1 datetime(6),i2 int, primary key(i2));

insert into t1 values(NULL,'s1','2013-1-25',1);
insert into t1 values(1,NULL,'2013-1-25',2);
insert into t1 values(1,'s1',NULL,3);
insert into t1 values(NULL,'s1',NULL,4);
insert into t1 values(NULL,NULL,'2013-1-25',5);
insert into t1 values(1,NULL,NULL,6);
insert into t1 values(NULL,NULL,NULL,7);
select * from t1;

insert into t1 values(NULL,NULL,'2013-1-26',8);
--error 1048
insert into t1 values(NULL,NULL,NULL,NULL);
--error 1048
insert into t1 values(NULL,NULL,NULL,NULL);

update t1 set i2=1 where i1=NULL and s1=NULL;
select * from t1;
update t1 set i2=1 where i1=NULL and s1=NULL and d1=NULL;
select * from t1;

delete from t1 where i1=NULL and s1=NULL and d1=NULL;
delete from t1 where i1=NULL and s1='s1' and d1=NULL;
delete from t1 where i1=1 and s1='s1' and d1=NULL;
select * from t1;
delete from t1 where i1 is NULL and s1 is NULL and d1 is NULL;
delete from t1 where i1 is NULL and s1='s1' and d1 is NULL;
delete from t1 where i1=1 and s1='s1' and d1 is NULL;
select * from t1;
insert into t1 values(NULL,'s2',NULL,10);
insert into t1 values(NULL,'s1',NULL,11);
select * from t1;

--source mysql_test/include/majorfreeze.inc
select * from t1;
--source mysql_test/include/wait_daily_merge.inc
select * from t1;

insert into t1 values(NULL,'s2',NULL,100);
insert into t1 values(NULL,'s1',NULL,101);
insert into t1 values(1,'s1',NULL,102);
select * from t1;

--source mysql_test/include/majorfreeze.inc
select * from t1;
--source mysql_test/include/wait_daily_merge.inc
select * from t1;

insert into t1 values(NULL,'s2',NULL,106);
insert into t1 values(NULL,'s1',NULL,107);
insert into t1 values(1,'s1',NULL,108);
select * from t1;
drop table t1;
