# owner: guohanyun.ghy
# owner group: SQL1
# description: test merge result type
# tags: datatype

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

CREATE TABLE t1(c0 int, c1 char(10), c2 enum('a','b','c'));

SELECT COALESCE(c0, c2) FROM t1;
SELECT COALESCE(c1, c2) FROM t1;
SELECT COALESCE(0, c1, c2) FROM t1;
SELECT COALESCE(c2, 0, c1) FROM t1;
SELECT COALESCE(c0, c1, c2) FROM t1;
SELECT COALESCE(c2, c0, c1) FROM t1;


--disable_warnings
DROP TABLE IF EXISTS table1_falcon;
--enable_warnings

CREATE TABLE `table1_falcon` (
  `col_set_key` set('a','b','c','d','e','f','g','h','i','j','k','l','m','n','o','p','q','r','s','t','u','v','w','x','y','z') DEFAULT NULL,
  `col_bit_key` bit(1) DEFAULT NULL,
  `col_enum` enum('a','b','c','d','e','f','g','h','i','j','k','l','m','n','o','p','q','r','s','t','u','v','w','x','y','z') DEFAULT NULL,
  `col_char_255_key` char(255) DEFAULT NULL,
  `col_blob` blob DEFAULT NULL,
  `col_bit` bit(1) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_set` set('a','b','c','d','e','f','g','h','i','j','k','l','m','n','o','p','q','r','s','t','u','v','w','x','y','z') DEFAULT NULL,
  `col_enum_key` enum('a','b','c','d','e','f','g','h','i','j','k','l','m','n','o','p','q','r','s','t','u','v','w','x','y','z') DEFAULT NULL,
  `pk` int(11) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_char_255` char(255) DEFAULT NULL,
  KEY `idx9` (`col_set_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx1` (`col_bit_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx5` (`col_char_255_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx7` (`col_enum_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx3` (`col_int_key`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

SELECT * FROM table1_falcon WHERE col_set_key <=> SUBSTR( CONCAT( COALESCE( CAST( CONCAT( col_bit_key , CAST( CONCAT( col_char_255_key , col_char_255 ) AS CHAR) ) AS CHAR), col_bit, col_blob) , CONCAT( CONCAT( COALESCE( col_set_key, col_char_255_key, col_blob) , -0.198 ) , COALESCE( 0.00, col_char_255, col_enum) ) ) , 1, 10);

DROP TABLE t1;
DROP TABLE table1_falcon;