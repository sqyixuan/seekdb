# owner: yibo.tyf
# owner group: SQL1
# description: can_cmp_without_cast function miss text type when checking string type
# tags: datatype

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
create table t1 (c1 mediumtext) charset = utf16;
--enable_warnings

SELECT * FROM t1 WHERE '2010-02-01 09:31:02.0' >= c1;

drop table t1;