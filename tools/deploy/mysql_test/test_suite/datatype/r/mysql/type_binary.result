drop table if exists binary_padding;
CREATE TABLE `binary_padding` ( `c1` char(200) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL, `c2` binary(19) DEFAULT '17', `c4` decimal(10,0) DEFAULT NULL, `c5` binary(1) DEFAULT NULL, KEY `i1` (`c5`, `c2`) global );
insert into binary_padding values ('2','1',1,'2');
select /*+index(binary_padding i1)*/ hex(c2), hex(c5) from binary_padding;
hex(c2)	hex(c5)
31000000000000000000000000000000000000	32
select hex(c2), hex(c5) from binary_padding;
hex(c2)	hex(c5)
31000000000000000000000000000000000000	32
update binary_padding set c2 = NULL where c1 = '2';
select /*+index(binary_padding i1)*/ hex(c2), hex(c5) from binary_padding;
hex(c2)	hex(c5)
NULL	32
select hex(c2), hex(c5) from binary_padding;
hex(c2)	hex(c5)
NULL	32
drop table binary_padding;
