drop table if exists t;
create table t(id int primary key auto_increment,
  int_val smallint,
  uint_val smallint unsigned,
  flt_val float(5, 3),
  dbl_val double(7, 4),
  dec_val decimal(5, 3),
  dt_val datetime(3),
  t_val time(3),
  vc_val varchar(2));
