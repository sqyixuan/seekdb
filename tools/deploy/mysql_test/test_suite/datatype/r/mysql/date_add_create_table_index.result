## 2.0 add column using adddate func
CREATE TABLE t8(sidea int(10), sideb DOUBLE, sided DATE, sidec DATE AS (TO_DAYS(sidea)))DEFAULT CHARACTER SET = utf8;
alter table t8 add column c6 int generated always as (DAYOFWEEK(sided)) virtual;
