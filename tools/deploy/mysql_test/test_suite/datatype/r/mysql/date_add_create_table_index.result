alter table t8 add column c8 DATE generated always as (DATE_SUB(sided, INTERVAL '-1 10' DAY_HOUR)) virtual;
alter table t8 add column c9 DATE generated always as (ADDDATE(sided, 1)) virtual;
alter table t8 add column c10 DATE generated always as (SUBDATE(sided, 1)) virtual;
alter table t8 add column c11 DATE generated always as (sided + INTERVAL '-1 10' DAY_HOUR) virtual;
