## 3.0 udf
DROP FUNCTION IF EXISTS UDF_R;
CREATE FUNCTION UDF_R() RETURNS INT
BEGIN
  DECLARE a DATE DEFAULT '2022-06-06';
  DECLARE b DATE DEFAULT 0;
  DECLARE c DATE DEFAULT 0;
  DECLARE d DATE DEFAULT 0;
  DECLARE e DATE DEFAULT 0;
  DECLARE f DATE DEFAULT 0;
  DECLARE g DATE DEFAULT 0;
  DECLARE h DATE DEFAULT 0;
  SELECT adddate(a, 1) INTO b FROM t1;
  SELECT subdate(a, 1) INTO c FROM t1;
  SELECT date_add(a, interval 1 day) INTO d FROM t1;
  SELECT date_sub(a, interval 1 day) INTO e FROM t1;
  SELECT a + interval 1 day INTO f FROM t1;
  SELECT a - interval 1 day INTO g FROM t1;
  SELECT interval 1 day + a INTO h FROM t1;
 
  RETURN b;
END
//
select UDF_R() from dual;
+---------+
| UDF_R() |
+---------+
|       0 |
+---------+
drop table t0, t1, t2, t3, t4, t5, t6, t7, t8;
DROP FUNCTION UDF_R;
