#
# Bug#12546965 - 60990: INCORRECT DATE COMPARISON
#
CREATE TABLE t1 (first_usage DATE, last_recharge DATETIME, life_time SMALLINT(4) UNSIGNED);
INSERT INTO t1 VALUES ('2011-04-27', null, 900);
SELECT DATE_ADD(GREATEST(first_usage, IFNULL(last_recharge, first_usage)), INTERVAL life_time DAY ) as dt, DATE_ADD(GREATEST(first_usage, IFNULL(last_recharge, first_usage)), INTERVAL life_time DAY ) < DATE('2011-04-28') as exp FROM t1;
dt	exp
2013-10-13 00:00:00	0
DROP TABLE t1;
