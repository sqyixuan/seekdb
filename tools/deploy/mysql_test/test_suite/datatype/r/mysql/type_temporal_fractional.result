a	CAST(a AS DATETIME)
99991231235959.0000009	9999-12-31 23:59:59
99991231235959.9000000	NULL
20010101101010.9999994	2001-01-01 10:10:11
20010101101010.9999995	2001-01-01 10:10:11
DROP TABLE t1;
