#
# Testing rounding when casting from DECIMAL to TIME(N)
#
CREATE TABLE t1 (a DECIMAL(23,4));
INSERT INTO t1 VALUES (NULL),(101010.9999),(-101010.9999);
INSERT INTO t1 VALUES (9999999999999999999999.1), (999999.1);
SELECT a, CAST(a AS TIME) FROM t1 order by a;
a	CAST(a AS TIME)
NULL	NULL
-101010.9999	-10:10:11
101010.9999	10:10:11
999999.1000	NULL
9999999999999999999.9999	NULL
DROP TABLE t1;
#
# Testing that CAST converts days to hours, while EXTRACT/HOUR do not
#
SELECT CAST('1 00:00:00' as TIME), EXTRACT(HOUR FROM '1 00:00:00');
CAST('1 00:00:00' as TIME)	EXTRACT(HOUR FROM '1 00:00:00')
24:00:00	24
CREATE TABLE t1 (a VARCHAR(30));
INSERT INTO t1 VALUES ('1 00:00:00');
SELECT CAST(a AS TIME), EXTRACT(HOUR FROM a) FROM t1 order by a;
CAST(a AS TIME)	EXTRACT(HOUR FROM a)
24:00:00	24
DROP TABLE t1;
