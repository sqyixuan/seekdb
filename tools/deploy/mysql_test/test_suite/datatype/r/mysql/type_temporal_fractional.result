#
# Testing IN
#
CREATE TABLE t1 (a TIME(6));
INSERT INTO t1 VALUES ('-99:00:00.000000');
INSERT INTO t1 VALUES ('-99:00:00.000001');
INSERT INTO t1 VALUES ('-99:00:00.000002');
INSERT INTO t1 VALUES ('-00:00:00.000001');
