CREATE TABLE t1 (a VARCHAR(32));
INSERT INTO t1 VALUES('9999-12-31 23:59:59.0000009'), ('9999-12-31 23:59:59.9'),('2001-01-01 10:10:10.9999994'), ('2001-01-01 10:10:10.9999995');
SELECT a, CAST(a AS DATETIME) FROM t1;
a	CAST(a AS DATETIME)
9999-12-31 23:59:59.0000009	9999-12-31 23:59:59
9999-12-31 23:59:59.9	NULL
2001-01-01 10:10:10.9999994	2001-01-01 10:10:11
2001-01-01 10:10:10.9999995	2001-01-01 10:10:11
DROP TABLE t1;
CREATE TABLE t1 (a DECIMAL(30, 7));
