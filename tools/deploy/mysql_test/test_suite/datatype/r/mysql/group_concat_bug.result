drop database if exists group_concat_bug_db;
create database group_concat_bug_db;
use group_concat_bug_db;
create table nn1(c1 int, c2 int, c3 varchar(10));
create table nn2(d1 int, d2 int, d3 varchar(10));
create table t1(a varchar(100), b bigint);
create procedure insert_p_nn1nn2() 
begin
declare i int;
insert into nn1 values(null, null, null);
insert into nn2 values(null, null, null);
set i = 0;
while i < 100 do
insert into nn1 values(mod(i, 7), mod(i, 6), concat('hello1', mod(i, 3)));
insert into nn2 values(mod(i, 5), mod(i, 3), concat('hello1', mod(i, 2)));
set i = i + 1;
end while;
end 
//
call insert_p_nn1nn2();
result_format: 4
#Q1 最简重现
explain 
(SELECT GROUP_CONCAT(a) AS a FROM t1 WHERE a = 'a') 
UNION 
(SELECT GROUP_CONCAT(b) AS a FROM t1 WHERE a = 'b');
Query Plan
====================================================
|ID|OPERATOR            |NAME|EST.ROWS|EST.TIME(us)|
----------------------------------------------------
|0 |MERGE UNION DISTINCT|    |2       |5           |
|1 |├─SCALAR GROUP BY   |    |1       |3           |
|2 |│ └─TABLE FULL SCAN |t1  |1       |3           |
|3 |└─SCALAR GROUP BY   |    |1       |3           |
|4 |  └─TABLE FULL SCAN |t1  |1       |3           |
====================================================
Outputs & filters:
-------------------------------------
  0 - output([UNION([1])]), filter(nil), rowset=16
  1 - output([T_FUN_GROUP_CONCAT(t1.a)]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_GROUP_CONCAT(t1.a)])
  2 - output([t1.a]), filter([t1.a = 'a']), rowset=16
      access([t1.a]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  3 - output([T_FUN_GROUP_CONCAT(cast(t1.b, VARCHAR(65536)))]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_GROUP_CONCAT(cast(t1.b, VARCHAR(65536)))])
  4 - output([t1.b]), filter([t1.a = 'b']), rowset=16
      access([t1.a], [t1.b]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true

(select group_concat(c3) as a from nn1) union (select group_concat(d3) as b from nn2);
