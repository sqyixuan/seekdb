result_format: 4
drop procedure if exists p36363295;

##  Values written using 0xval notation that contain an odd number of digits are treated as having an extra leading 0. For example, 0xaaa is interpreted as 0x0aaa.
select 0x94142;
+---------+
| 0x94142 |
+---------+
| 	AB     |
+---------+

create procedure p36363295()
  begin
    select 0x94142;
  end//
call p36363295();
+---------+
| 0x94142 |
+---------+
| 	AB     |
+---------+
drop procedure p36363295;

select 0x094142;
+----------+
| 0x094142 |
+----------+
| 	AB      |
+----------+

create procedure p36363295()
  begin
    select 0x094142;
  end//
call p36363295();
+----------+
| 0x094142 |
+----------+
| 	AB      |
+----------+
drop procedure p36363295;

select 0x94142 = 0x094142;
+--------------------+
| 0x94142 = 0x094142 |
+--------------------+
|                  1 |
+--------------------+

create procedure p36363295()
  begin
    select 0x94142 = 0x094142;
  end//
call p36363295();
+--------------------+
| 0x94142 = 0x094142 |
+--------------------+
|                  1 |
+--------------------+
drop procedure p36363295;


## Values written using X'val' notation must contain an even number of digits or a syntax error occurs. To correct the problem, pad the value with a leading zero.
select X'94142';
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'X'94142'' at line 1

create procedure p36363295()
  begin
    select X'94142';
  end//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'select X'94142'' at line 3

select X'094142';
+-----------+
| X'094142' |
+-----------+
| 	AB       |
+-----------+

create procedure p36363295()
  begin
    select X'094142';
  end//
call p36363295();
+-----------+
| X'094142' |
+-----------+
| 	AB       |
+-----------+
drop procedure p36363295;

