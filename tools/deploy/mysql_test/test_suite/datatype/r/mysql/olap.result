SELECT a, LENGTH(a), COUNT(*) FROM t1 GROUP BY a;
DESC v1;
Field	Type	Null	Key	Default	Extra
a	int(11)	NO		NULL	
LENGTH(a)	bigint(20)	NO		NULL	
COUNT(*)	bigint(20)	NO			
SELECT * FROM v1;
a	LENGTH(a)	COUNT(*)
1	1	1
2	1	1
DROP VIEW v1;
