drop database if exists group_concat_bug_db;
create database group_concat_bug_db;
use group_concat_bug_db;
create table nn1(c1 int, c2 int, c3 varchar(10));
create table nn2(d1 int, d2 int, d3 varchar(10));
create table t1(a varchar(100), b bigint);
create procedure insert_p_nn1nn2() 
begin
declare i int;
insert into nn1 values(null, null, null);
insert into nn2 values(null, null, null);
set i = 0;
while i < 100 do
insert into nn1 values(mod(i, 7), mod(i, 6), concat('hello1', mod(i, 3)));
insert into nn2 values(mod(i, 5), mod(i, 3), concat('hello1', mod(i, 2)));
set i = i + 1;
end while;
end 
//
call insert_p_nn1nn2();
result_format: 4
#Q1 最简重现
explain 
(SELECT GROUP_CONCAT(a) AS a FROM t1 WHERE a = 'a') 
UNION 
(SELECT GROUP_CONCAT(b) AS a FROM t1 WHERE a = 'b');
Query Plan
=============================================
|ID|OPERATOR            |NAME|EST. ROWS|COST|
---------------------------------------------
|0 |MERGE UNION DISTINCT|    |2        |1914|
|1 | SORT               |    |1        |946 |
|2 |  SCALAR GROUP BY   |    |1        |946 |
|3 |   TABLE SCAN       |t1  |2        |945 |
|4 | SORT               |    |1        |968 |
|5 |  SCALAR GROUP BY   |    |1        |968 |
|6 |   TABLE SCAN       |t1  |2        |967 |
=============================================

Outputs & filters: 
-------------------------------------
  0 - output([UNION(T_FUN_GROUP_CONCAT(t1.a), cast(T_FUN_GROUP_CONCAT(t1.b), VARCHAR(65536)))]), filter(nil)
  1 - output([T_FUN_GROUP_CONCAT(t1.a)]), filter(nil), sort_keys([T_FUN_GROUP_CONCAT(t1.a), ASC])
  2 - output([T_FUN_GROUP_CONCAT(t1.a)]), filter(nil), 
      group(nil), agg_func([T_FUN_GROUP_CONCAT(t1.a)])
  3 - output([t1.a]), filter([t1.a = 'a']), 
      access([t1.a]), partitions(p0)
  4 - output([cast(T_FUN_GROUP_CONCAT(t1.b), VARCHAR(65536))]), filter(nil), sort_keys([cast(T_FUN_GROUP_CONCAT(t1.b), VARCHAR(65536)), ASC])
  5 - output([cast(T_FUN_GROUP_CONCAT(t1.b), VARCHAR(65536))]), filter(nil), 
      group(nil), agg_func([T_FUN_GROUP_CONCAT(t1.b)])
  6 - output([t1.b]), filter([t1.a = 'b']), 
      access([t1.a], [t1.b]), partitions(p0)


