# owner: xiaoyi.xy
# owner group: sql2
--disable_abort_on_error
--result_format 4

connect (con, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
connection con;
alter system flush sql audit global;



############################### alter system set ##################################

alter system set enable_sql_audit = true;
alter system set enable_sql_audit = true tenant = sys;
alter system set enable_sql_audit = true tenant = all_user;
alter system set enable_sql_audit = true tenant = all_meta;
alter system set enable_sql_audit = 'unexpected';
alter system set backup_dest = 'unexpected';
alter system set log_archive_dest = 'unexpected';
alter system set log_restore_source = 'unexpected';


################################## show sql audit ##################################

select query_sql from oceanbase.GV$OB_SQL_AUDIT where query_sql like 'alter system set %';



############ drop user or role not exists will return different error #############
############ so, make rare name for them instead of drop user or role #############


################################## user with password #############################

create user bx_user identified by 'oceanbase_bx';
grant select on *.* to bx_user identified by 'oceanbase_bx';
set password for bx_user = password('oceanbase_bx');
alter user bx_user identified by 'oceanbase_bx';


################################## show user #######################################

select user from mysql.user where user = 'bx_user';


################################## show sql audit ##################################

select query_sql from oceanbase.GV$OB_SQL_AUDIT where query_sql like '%oceanbase_bx%';


################################## drop user #######################################

drop user bx_user;
