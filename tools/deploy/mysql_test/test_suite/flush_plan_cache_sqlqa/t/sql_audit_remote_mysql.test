
# owner: xiaoyi.xy
# owner group: sql2
--disable_abort_on_error
--result_format 4

alter system flush sql audit global;

create table t_remote(c int);
create table t_distribute(c int);


set ob_enable_plan_cache = off;
select  * from t_remote;
select sql_id, db_id, user_id, request_type, query_sql from oceanbase.gv$ob_sql_audit where sql_id = '4DB27732192CAF8599682A74A091B9EB' order by request_type;
select /*+ parallel(2) */ * from t_distribute;
select sql_id, db_id, user_id, request_type, query_sql from oceanbase.gv$ob_sql_audit where sql_id = '32364B55633B831936146DB8F758A672' order by request_type;

alter system flush sql audit global;

set ob_enable_plan_cache = on;
select  * from t_remote;
select sql_id, db_id, user_id, request_type, query_sql from oceanbase.gv$ob_sql_audit where sql_id = '4DB27732192CAF8599682A74A091B9EB' order by request_type;
select /*+ parallel(2) */ * from t_distribute;
select sql_id, db_id, user_id, request_type, query_sql from oceanbase.gv$ob_sql_audit where sql_id = '32364B55633B831936146DB8F758A672' order by request_type;


drop table t_remote;
drop table t_distribute;
