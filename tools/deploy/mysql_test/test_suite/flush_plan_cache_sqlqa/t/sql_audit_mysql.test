# owner: xiaoyi.xy
# owner group: sql2
--disable_abort_on_error
--result_format 4

connect (con, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
connection con;
alter system flush sql audit global;
set global ob_sql_audit_percentage = 50;

--sleep 1
connection default;
set ob_enable_plan_cache = off;

--disable_warnings
drop table if exists sql_id_display_t1, sql_id_display_t2, sql_id_display_t3;
--enable_warnings


ALTER SYSTEM FLUSH PLAN CACHE sql_id = '04C41477CC0984AFC9B1E0D4852C3688';
ALTER SYSTEM FLUSH PLAN CACHE tenant = 'mysql';
ALTER SYSTEM FLUSH PLAN CACHE sql_id = '04C41477CC0984AFC9B1E0D4852C3688' tenant = 'mysql';

oceanbase.dbms_plan_cache.PURGE(NULL,ucharset,GLOBAL);
oceanbase.dbms_plan_cache.PURGE(ucharset,GLOBAL);
oceanbase.dbms_plan_cache.PURGE();

create table sql_id_display_t1(c1 int);
create table sql_id_display_t2(c1 int);
create table sql_id_display_t3(c1 int);

insert into sql_id_display_t1 values(1);
insert into sql_id_display_t2 values(1);
insert into sql_id_display_t3 values(1);

select * from sql_id_display_t1;
select * from sql_id_display_t2;
select * from sql_id_display_t3;


select sql_id, query_sql from oceanbase.GV$OB_SQL_AUDIT where query_sql like '%ALTER SYSTEM FLUSH PLAN CACHE%' ;
select sql_id, query_sql from oceanbase.GV$OB_SQL_AUDIT where query_sql like '%oceanbase.dbms_plan_cache.PURGE%' ;

select sql_id, query_sql from oceanbase.GV$OB_SQL_AUDIT where query_sql like '%insert into sql_id_display_t%' ;
select sql_id, query_sql from oceanbase.GV$OB_SQL_AUDIT where query_sql like '%insert into sql_id_display_t%' ;
select sql_id, query_sql from oceanbase.GV$OB_SQL_AUDIT where query_sql like '%select * from sql_id_display_t%' ;


drop table sql_id_display_t1, sql_id_display_t2, sql_id_display_t3;

connection con;
alter system flush sql audit global;
set global ob_sql_audit_percentage = 3;