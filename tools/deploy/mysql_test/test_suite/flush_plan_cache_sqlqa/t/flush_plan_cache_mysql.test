purge recyclebin;
let $char_charset = 'UTF8';

--source mysql_test/test_suite/flush_plan_cache_sqlqa/include/conn_tenant_mysql.inc

--echo  ##################MYSQL,分别设置global、local来测试  flush_plan_cache-03####################################

--disable_warnings
drop database IF EXISTS ucharsetmysql;
--enable_warnings

create database ucharsetmysql  character set utf8;
use ucharsetmysql;

--source mysql_test/test_suite/flush_plan_cache_sqlqa/t/base_data_mysql.inc

--echo  ###粗粒度，当前租户 flush_plan_cache-03-01-01/flush_plan_cache-03-01-01-01###
