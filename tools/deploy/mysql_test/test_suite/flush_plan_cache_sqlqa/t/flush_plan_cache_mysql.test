--echo  ###not global###
ALTER SYSTEM FLUSH PLAN CACHE;

--disable_result_log
select sql_id, query_sql from oceanbase.GV$OB_SQL_AUDIT;
select * from oceanbase.V$OB_PLAN_CACHE_STAT;
select * from oceanbase.GV$OB_PLAN_CACHE_STAT;
select * from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT;
