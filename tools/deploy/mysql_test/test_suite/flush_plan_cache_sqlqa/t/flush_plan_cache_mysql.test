####边界值/异常验证用例补充flush_plan_cache-04-02及之下所有########
###理论没有最大值，如果系统表中不存在，则不删除，也不报错###
--error 1210
ALTER SYSTEM FLUSH PLAN CACHE sql_id = '69F7FBAAE42A8ED23687B1834F8106A5,69F7FBAAE42A8ED23687B1834F8106A5'  databases ='ucharset,zzz,nnn,mmm' tenant = 'tenant_charset_test,zzz,nnn,mmm,mysql' global;
--error 1227,5160
