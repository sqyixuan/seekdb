# owner: xiaoyi.xy
# owner group: sql2
--disable_abort_on_error
--result_format 4

connect (con, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
connection con;
alter system flush sql audit global;
alter system flush plan cache global;
set ob_query_timeout = 120000000;
-- sleep 1
--disable_warnings
drop table if exists request_memory_used_test;
--disable_warnings

create table request_memory_used_test(c0 bigint primary key, c1 varchar(4000), c2 varchar(4000), c3 varchar(4000),c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 longtext);
insert into request_memory_used_test values(1,repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('a',2000));
insert into request_memory_used_test select c0+1,c1,c2,c3,c4,c5,c6,c7 from request_memory_used_test;
insert into request_memory_used_test select c0+2,c1,c2,c3,c4,c5,c6,c7 from request_memory_used_test;
insert into request_memory_used_test select c0+4,c1,c2,c3,c4,c5,c6,c7 from request_memory_used_test;
insert into request_memory_used_test select c0+8,c1,c2,c3,c4,c5,c6,c7 from request_memory_used_test;
insert into request_memory_used_test select c0+16,c1,c2,c3,c4,c5,c6,c7 from request_memory_used_test;
insert into request_memory_used_test select c0+32,c1,c2,c3,c4,c5,c6,c7 from request_memory_used_test;
insert into request_memory_used_test select c0+64,c1,c2,c3,c4,c5,c6,c7 from request_memory_used_test;
insert into request_memory_used_test select c0+128,c1,c2,c3,c4,c5,c6,c7 from request_memory_used_test;
insert into request_memory_used_test select c0+256,c1,c2,c3,c4,c5,c6,c7 from request_memory_used_test;
insert into request_memory_used_test select c0+512,c1,c2,c3,c4,c5,c6,c7 from request_memory_used_test;
insert into request_memory_used_test select c0+1024,c1,c2,c3,c4,c5,c6,c7 from request_memory_used_test;
insert into request_memory_used_test select c0+2048,c1,c2,c3,c4,c5,c6,c7 from request_memory_used_test;
insert into request_memory_used_test select c0+4096,c1,c2,c3,c4,c5,c6,c7 from request_memory_used_test;
insert into request_memory_used_test select c0+8192,c1,c2,c3,c4,c5,c6,c7 from request_memory_used_test;

select c1 > 'a' from request_memory_used_test order by c1 > 'ab' desc limit 16383, 1;

select request_memory_used > 50000000 from oceanbase.GV$OB_SQL_AUDIT where sql_id = '544FC78287F39127D763D5FACD091F60' order by request_memory_used desc limit 1;

alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
drop table if exists request_memory_used_test;
