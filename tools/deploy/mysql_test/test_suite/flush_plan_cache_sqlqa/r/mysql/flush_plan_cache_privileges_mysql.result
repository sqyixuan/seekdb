C0	C1	C2	C3	C4	C5	C6	C7	C8	C9
select * from gbktable t where length(t.c1) = 7;
C0	C1	C2	C3	C4	C5	C6	C7	C8	C9
select * from gbktable t where concat(t.c1,t.c2) = '中文测试001中文测试001' and concat(t.c1,t.c2) = concat(t.c2,t.c1);
