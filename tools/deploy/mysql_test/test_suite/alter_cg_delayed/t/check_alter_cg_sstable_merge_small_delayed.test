# owner: zhanghuidong.zhd
# owner group: storage
# description: sstable has adaptive strategy to merge into row store major with column store schema, delayed column store merge will ignore this rule and generate column store major directly 

--result_format 4
connect (conn0,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn0;
let $table_name = "t_column_store_merge";
--disable_warnings
drop table if exists t_column_store_merge;
--enable_warnings
create table t_column_store_merge (c1 int primary key, c2 int, c3 int, c4 int, c5 int, c6 int);
--disable_query_log
let $cnt = 0;
while ($cnt < 1000)
{
  eval insert into t_column_store_merge values ($cnt, $cnt+1, $cnt+2, $cnt+3, $cnt+4, $cnt+5);
  inc $cnt;
}
--enable_query_log
# case for add column group each with 1000 rows
let $mode = 0;
alter table t_column_store_merge add column group (each column) delayed;
--source check_sys_table_mysql.inc
--source tenant_major_freeze.inc
--source check_tenant_tablet_sstable_status.inc
--source tenant_major_freeze.inc
--source check_tenant_tablet_sstable_status.inc
# case for add column group all/each with 1000 rows
alter table t_column_store_merge drop column group (each column);
alter table t_column_store_merge add column group (each column, all columns) delayed;
--source check_sys_table_mysql.inc
--source tenant_major_freeze.inc
--source check_tenant_tablet_sstable_status.inc
--source tenant_major_freeze.inc
--source check_tenant_tablet_sstable_status.inc
drop table t_column_store_merge;
disconnect conn0;
connection default;