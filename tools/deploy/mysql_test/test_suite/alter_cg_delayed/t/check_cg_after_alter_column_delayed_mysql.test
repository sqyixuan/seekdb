# owner: zhanghuidong.zhd
# owner group: storage
# description: copy test cases from check_cg_after_alter_column_mysql and fine tune, check the impact of column transformation on column group system tables

--result_format 4
connect (obsys,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);

connection obsys;
--disable_info
--disable_metadata
--disable_warnings
drop table if exists t1;
drop table if exists foo;
--enable_warnings


# case for calc checksum on column_store table
create table t1 (c1 int unique, c2 varchar(30) unique, c3 varchar(30) unique, c4 varchar(40), c7 int generated always as (c1), c8 text);
alter table t1 add column group(each column) delayed;

let $data_cnt0 = 0;
--disable_query_log
while($data_cnt0 < 500)
{
  eval  insert into t1(c1, c2, c3, c4) values($data_cnt0, 'c2_$data_cnt0', 'c3_$data_cnt0', 'c4_$data_cnt0');
  inc $data_cnt0;
}
--enable_query_log

alter table t1 drop column c2;
drop table t1;

create table t1 (c1 int, c2 varchar(30), c3 varchar(30), c4 varchar(40), c6 int generated always as (c1));
alter table t1 add column group(all columns, each column) delayed;
drop table t1;
create table t1 (c1 int unique, c2 varchar(30) unique, c3 varchar(30) unique, c4 varchar(40), c7 int generated always as (c1) virtual, c8 text);

let $data_cnt = 0;
--disable_query_log
while($data_cnt < 500)
{
  eval  insert into t1(c1, c2, c3, c4) values($data_cnt, 'c2_$data_cnt', 'c3_$data_cnt', 'c4_$data_cnt');
  inc $data_cnt;
}
--enable_query_log

create index idx1 on t1(c1, c2);

let $cnt = 4;
while($cnt)
{   
    # preprocess
    if ($cnt == 4) 
    {
        # only default
        select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;
    }
    if ($cnt == 3)
    {
        # only each
        alter table t1 add column group(each column) delayed;
        select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;
    }
    if ($cnt == 2)
    {
        # only all
        alter table t1 add column group(all columns);
        select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;
    }
    if ($cnt == 1)
    {
        # each + all
        alter table t1 add column group(all columns, each column) delayed;
        select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;
    }

    # add column online
    alter table t1 add column c5 int;
    select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;


    # rename
    alter table t1 change column c5 c6 int;
    select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;

    alter table t1 rename column c6 to c5;
    select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;

    # rename virtual column
    alter table t1  rename column c7 to c10 ;
    select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;

    alter table t1  rename column c10 to c7;
    select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;


    # drop column
    alter table t1 drop column c5;
    alter table t1 force;
    select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;

    alter table t1 add column c5 int generated always as (c1+1);
    select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;


    # drop column
    alter table t1 drop column c5;
    alter table t1 force;
    select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;
    
    # add column 
    alter table t1 add column c1_5 int after c1;
    select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;
    
    # drop column    
    alter table t1 drop column c1_5;
    alter table t1 force;
    select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;

    # add primary key
    alter table t1 add primary key(c1);
    select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;
    
    # drop primary key 
    alter table t1 drop primary key;
    select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;

    if ($cnt == 4) 
    {
      # only default
    }
    if ($cnt == 3)
    {
      # only each
      alter table t1 drop column group(each column);
    }
    if ($cnt == 2)
    {
      # only all
      alter table t1 drop column group(all columns);
    }
    if ($cnt == 1)
    {
      # each + all
      alter table t1 drop column group(all columns, each column);
    }
    dec $cnt;
}

drop table t1;
select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='t1') order by __all_column_group.column_group_name, __all_column.column_name;

# for bug fix 54454407
CREATE TABLE foo (   a varchar(100) COLLATE utf8mb4_bin DEFAULT NULL,   b int(11) NOT NULL,   PRIMARY KEY (b),   UNIQUE KEY a (a) BLOCK_SIZE 16384 LOCAL ) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = COMPRESSED COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
alter table foo add column group(all columns, each column) delayed;
alter table foo add column added_3 bigint NOT NULL default -1 after b, add column added_41 varchar(10) default NULL after b;

select  __all_column_group.column_group_name, __all_column_group.column_group_type, __all_column.column_name from  __all_column_group left join (__all_column_group_mapping left join __all_column on __all_column.table_id = __all_column_group_mapping.table_id and __all_column.column_id = __all_column_group_mapping.column_id) on __all_column_group.column_group_id = __all_column_group_mapping.column_group_id and __all_column_group.table_id = __all_column_group_mapping.table_id  where __all_column_group.table_id = (select max(table_id) from __all_table where table_name='foo') order by __all_column_group.column_group_name, __all_column.column_name;

drop table foo;

purge recyclebin;
select l.column_group_name, l.column_group_type, r.column_id, r.is_deleted from (select * from __all_column_group_history where table_id = (select table_id from __all_table_history where table_name='t1' order by table_id desc limit 1)) l left join (select * from __all_column_group_mapping_history where table_id = (select table_id from __all_table_history where table_name='t1' order by table_id desc limit 1)) r on l.table_id = r.table_id and l.column_group_id = r.column_group_id and l.is_deleted = r.is_deleted order by column_group_name, column_id, is_deleted desc;
# case for bug get_cg_idx  which not skip all_cg while single column in full table

create table t1(c1 int primary key);
insert into t1 values(1),(2),(3);
alter table t1 add column group(all columns, each column) delayed;
select column_group_name, column_group_id from __all_column_group where table_id in (select max(table_id) from __all_table where table_name like "t1");
select c1 from t1 where c1 < 2;
drop table t1;
disconnect obsys;
connection default;