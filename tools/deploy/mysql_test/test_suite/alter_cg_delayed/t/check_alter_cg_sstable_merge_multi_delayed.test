# owner: zhanghuidong.zhd
# owner group: storage
# description: case with multiple tablet merge

--result_format 4
connect (conn0,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn0;
--disable_warnings
drop table if exists t_column_store_merge1;
drop table if exists t_column_store_merge2;

# case for multiple tablets 
create table t_column_store_merge1 (c1 int primary key, c2 int, c3 int, c4 int, c5 int, c6 int);
create table t_column_store_merge2 (c1 int primary key, c2 int, c3 int, c4 int, c5 int, c6 int);
--disable_query_log
let $cnt = 0;
while ($cnt < 1000)
{
  eval insert into t_column_store_merge1 values ($cnt, $cnt+1, $cnt+2, $cnt+3, $cnt+4, $cnt+5);
  eval insert into t_column_store_merge2 values ($cnt, $cnt+1, $cnt+2, $cnt+3, $cnt+4, $cnt+5);
  inc $cnt;
}
--enable_query_log
let $mode = 0;
alter table t_column_store_merge1 add column group (each column) delayed;
--source tenant_major_freeze.inc
let $table_name = "t_column_store_merge1";
--source check_sys_table_mysql.inc
--source check_tenant_tablet_sstable_status.inc
let $table_name = "t_column_store_merge2";
--source check_sys_table_mysql.inc
--source check_tenant_tablet_sstable_status.inc
drop table t_column_store_merge1;
drop table t_column_store_merge2;
disconnect conn0;
connection default;