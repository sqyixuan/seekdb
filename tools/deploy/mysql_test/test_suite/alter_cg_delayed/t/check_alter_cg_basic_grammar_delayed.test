# owner: zhanghuidong.zhd
# owner group: storage
# description: check the results of the basic syntax, only allow add column store based on row store in delayed mode

--result_format 4
connect (conn0,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--disable_warnings
drop table if exists t_column_store_basic_grammar;
--enable_warnings

# table schema with default cg
create table t_column_store_basic_grammar (c1 int primary key, c2 int, c3 int, c4 int, c5 int, c6 int);
## drop first
--error 1235
alter table t_column_store_basic_grammar drop column group (each column) delayed;
--error 1235
alter table t_column_store_basic_grammar drop column group (all columns) delayed;
--error 1235
alter table t_column_store_basic_grammar drop column group (each column, all columns) delayed;

## add each first
alter table t_column_store_basic_grammar add column group (each column) delayed;
--error 1060
alter table t_column_store_basic_grammar add column group (each column);
--error 1235
alter table t_column_store_basic_grammar add column group (all columns) delayed;
--error 1060
alter table t_column_store_basic_grammar add column group (each column, all columns) delayed;
--error 1060
alter table t_column_store_basic_grammar add column group (each column, all columns);
alter table t_column_store_basic_grammar drop column group (each column);

## add all first
--error 1235
alter table t_column_store_basic_grammar add column group (all columns) delayed;
alter table t_column_store_basic_grammar add column group (each column) delayed;
--error 1060
alter table t_column_store_basic_grammar add column group (each column);
--error 1060
alter table t_column_store_basic_grammar add column group (each column, all columns) delayed;
--error 1060
alter table t_column_store_basic_grammar add column group (each column, all columns);
alter table t_column_store_basic_grammar drop column group (each column);

## add each/all first
alter table t_column_store_basic_grammar add column group (each column, all columns) delayed;
--error 1060
alter table t_column_store_basic_grammar add column group (each column, all columns);
--error 1060
alter table t_column_store_basic_grammar add column group (each column) delayed;
--error 1060
alter table t_column_store_basic_grammar add column group (each column);
--error 1235
alter table t_column_store_basic_grammar add column group (all columns) delayed;
--error 1060
alter table t_column_store_basic_grammar add column group (all columns);
alter table t_column_store_basic_grammar drop column group (each column, all columns);
drop table t_column_store_basic_grammar;

