# owner: zhanghuidong.zhd
# owner group: storage
# description: test add column group delayed with concurrent ddl and dml

--result_format 4
# conn0 create table and execute ddl
connect (conn0,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn0;
--disable_warnings
drop table if exists t_column_store_concurrent_ddl;
drop table if exists t_column_store_concurrent_dml;
--enable_warnings
create table t_column_store_concurrent_ddl (c1 int primary key, c2 int, c3 int, c4 int, c5 int, c6 int);
create table t_column_store_concurrent_dml (c1 int primary key, c2 int, c3 int, c4 int, c5 int, c6 int);

--disable_query_log
let $cnt = 0;
while ($cnt < 1000)
{
  eval insert into t_column_store_concurrent_ddl values (1*$cnt, 2*$cnt, 3*$cnt, 4*$cnt, 5*$cnt, 6*$cnt);
  eval insert into t_column_store_concurrent_dml values (1*$cnt, 2*$cnt, 3*$cnt, 4*$cnt, 5*$cnt, 6*$cnt);
  inc $cnt;
}
--enable_query_log

# case for concurrent ddl
connection conn1;
send alter table t_column_store_concurrent_ddl add column group (each column) delayed;

connection conn2;
sleep 0.05;
--error 1060
alter table t_column_store_concurrent_ddl add column group (each column, all columns) delayed;
connection conn1;
reap;

# case for concurrent dml
connection conn3;
set autocommit=0;
send insert into t_column_store_concurrent_dml values (20000, 20000, 20000, 20000, 20000, 20000),
                                                      (20001, 20001, 20001, 20001, 20001, 20001),
                                                      (20002, 20002, 20002, 20002, 20002, 20002),
                                                      (20003, 20003, 20003, 20003, 20003, 20003),
                                                      (20004, 20004, 20004, 20004, 20004, 20004),
                                                      (20005, 20005, 20005, 20005, 20005, 20005),
                                                      (20006, 20006, 20006, 20006, 20006, 20006),
                                                      (20007, 20007, 20007, 20007, 20007, 20007),
                                                      (20008, 20008, 20008, 20008, 20008, 20008),
                                                      (20009, 20009, 20009, 20009, 20009, 20009);

connection conn4;
alter table t_column_store_concurrent_dml add column group (each column, all columns) delayed;

connection conn3;
reap;
commit;

# check concurrent result
connection conn3;
--source tenant_major_freeze.inc
let $mode = 0;
let $table_name = "t_column_store_concurrent_ddl";
--source check_sys_table_mysql.inc
--source check_tenant_tablet_sstable_status.inc
select count(*) from t_column_store_concurrent_ddl;
let $table_name = "t_column_store_concurrent_dml";
--source check_sys_table_mysql.inc
--source check_tenant_tablet_sstable_status.inc
select count(*) from t_column_store_concurrent_dml;

drop table t_column_store_concurrent_ddl;
drop table t_column_store_concurrent_dml;
disconnect conn0;
disconnect conn1;
disconnect conn2;
disconnect conn3;
disconnect conn4;
connection default;