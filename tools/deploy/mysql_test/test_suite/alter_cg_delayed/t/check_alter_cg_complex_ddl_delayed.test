# owner: zhanghuidong.zhd
# owner group: storage
# description: after delayed column transform modifies schema, ddl operations that need to rewrite data should be able to generate column store sstables

--result_format 4
# conn0 create table and execute ddl
connect (conn0,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn0;
--disable_warnings
drop table if exists t_column_store_complex_ddl;
--enable_warnings
create table t_column_store_complex_ddl (c1 int primary key, c2 int, c3 int, c4 int, c5 int, c6 int);

--disable_query_log
let $cnt = 0;
while ($cnt < 1000)
{
  eval insert into t_column_store_complex_ddl values (1*$cnt, 2*$cnt, 3*$cnt, 4*$cnt, 5*$cnt, 6*$cnt);
  inc $cnt;
}
--enable_query_log

# case for complex ddl and major merge
connection conn0;
let $table_name = "t_column_store_complex_ddl";
alter table t_column_store_complex_ddl add column group (each column) delayed;
alter table t_column_store_complex_ddl add constraint cst3 check (c3 >= 0);
alter table t_column_store_complex_ddl set progressive_merge_num = 10;
alter table t_column_store_complex_ddl add column c7 blob;
alter table t_column_store_complex_ddl modify c5 int not null;
alter table t_column_store_complex_ddl block_size = 8192;
alter table t_column_store_complex_ddl set compression = 'none';
let $mode = 1;
--source check_tenant_tablet_sstable_status.inc
--disable_query_log
insert into t_column_store_complex_ddl values (10000, 10000, 10000, 10000, 10000, 10000, 10000);
insert into t_column_store_complex_ddl values (10001, 10001, 10001, 10001, 10001, 10001, 10001);
insert into t_column_store_complex_ddl values (10002, 10002, 10002, 10002, 10002, 10002, 10002);
--enable_query_log
--source check_sys_table_mysql.inc
--source tenant_major_freeze.inc
let $mode = 0;
--source check_tenant_tablet_sstable_status.inc

alter table t_column_store_complex_ddl drop column group (each column);
alter table t_column_store_complex_ddl add column group (each column, all columns) delayed;
alter table t_column_store_complex_ddl add column c8 int generated always as (c2*2) stored;
--disable_query_log
insert into t_column_store_complex_ddl(c1, c2, c3, c4, c5, c6, c7) values (10003, 10003, 10003, 10003, 10003, 10003, 'frewg');
insert into t_column_store_complex_ddl(c1, c2, c3, c4, c5, c6, c7) values (10004, 10004, 10004, 10004, 10004, 10004, 'effewgerg');
insert into t_column_store_complex_ddl(c1, c2, c3, c4, c5, c6, c7) values (10005, 10005, 10005, 10005, 10005, 10005, 'ewgrret');
--enable_query_log
--source check_sys_table_mysql.inc
let $mode = 1;
--source check_tenant_tablet_sstable_status.inc

alter table t_column_store_complex_ddl drop column group (each column, all columns);
alter table t_column_store_complex_ddl add column group (all columns, each column) delayed;
alter table t_column_store_complex_ddl add c9 int auto_increment;
--disable_query_log
insert into t_column_store_complex_ddl(c1, c2, c3, c4, c5, c6, c7) values (10006, 10006, 10006, 10006, 10006, 10006, 'dgsgrieoig');
insert into t_column_store_complex_ddl(c1, c2, c3, c4, c5, c6, c7) values (10007, 10007, 10007, 10007, 10007, 10007, 'fgjerhigbn');
insert into t_column_store_complex_ddl(c1, c2, c3, c4, c5, c6, c7) values (10008, 10008, 10008, 10008, 10008, 10008, 'oihguefwnjq');
insert into t_column_store_complex_ddl(c1, c2, c3, c4, c5, c6, c7) values (10009, 10009, 10009, 10009, 10009, 10009, 'weqwewqet');
--enable_query_log
--source check_sys_table_mysql.inc
let $mode = 1;
--source check_tenant_tablet_sstable_status.inc

select count(*) from t_column_store_complex_ddl;

drop table t_column_store_complex_ddl;
disconnect conn0;
connection default;