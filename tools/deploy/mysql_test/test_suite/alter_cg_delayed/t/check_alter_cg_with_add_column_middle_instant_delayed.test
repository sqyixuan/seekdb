# owner: zhanghuidong.zhd
# owner group: storage
# description : test add column instant with delayed column transformation
connect(sys_conn,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connect(mysql_conn,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection mysql_conn;
alter system set default_table_store_format = "row";
--disable_warnings
drop table if exists column_store_table;
--enable_warnings
connection sys_conn;
let $tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'sys', tenant_id, 1);
let $table_name = "column_store_table";
let $mode = 0;

# add (each column, all columns)
connection mysql_conn;
create table column_store_table(col1 int, col2 int);
insert into column_store_table values(1, 2);
alter table column_store_table add column col3 int after col1;
alter table column_store_table add column group (each column, all columns) delayed;
create index index1 on column_store_table(col3) with column group(all columns, each column);
insert into column_store_table values(1, 3, 2);
alter table column_store_table add column col4 int generated always as (col1 * 2) virtual after col1;
--source tenant_major_freeze.inc
--source check_sys_table_mysql.inc
--source check_tenant_tablet_sstable_status.inc
alter table column_store_table drop column group(each column);
alter table column_store_table drop column group(all columns);

drop table column_store_table;
create table column_store_table(col1 int, col2 int);
insert into column_store_table values(1, 2);
alter table column_store_table add column col3 int after col1;
create index index1 on column_store_table(col3) with column group(all columns, each column);
insert into column_store_table values(1, 3, 2);
alter table column_store_table add column col4 int generated always as (col1 * 2) virtual after col1;
alter table column_store_table add column group (each column, all columns) delayed;
--source tenant_major_freeze.inc
--source check_sys_table_mysql.inc
--source check_tenant_tablet_sstable_status.inc
alter table column_store_table drop column group(all columns, each column);

# add (each column)
connection mysql_conn;
drop table column_store_table;
create table column_store_table(col1 int, col2 int) with column group(all columns);
insert into column_store_table values(1, 2);
create index index1 on column_store_table(col2) storing(col1) with column group(each column);
alter table column_store_table add column col3 int after col1;
create index index2 on column_store_table(col3) with column group(all columns);
alter table column_store_table add column group (each column) delayed;
insert into column_store_table values(1, 3, 2);
alter table column_store_table add column col4 int generated always as (col1 * 2) virtual after col1;
--source tenant_major_freeze.inc
--source check_sys_table_mysql.inc
--source check_tenant_tablet_sstable_status.inc
alter table column_store_table drop column group(all columns, each column);

connection mysql_conn;
drop table column_store_table;
create table column_store_table(col1 int, col2 int);
insert into column_store_table values(1, 2);
alter table column_store_table add column group (each column) delayed;
alter table column_store_table add column col3 int after col1;
create index index1 on column_store_table(col3) with column group(all columns, each column);
insert into column_store_table values(1, 2, 3);
alter table column_store_table add column col4 int generated always as (col1 * 2) virtual after col1;
--source tenant_major_freeze.inc
--source check_sys_table_mysql.inc
--source check_tenant_tablet_sstable_status.inc
alter table column_store_table drop column group(each column);

drop table column_store_table;