# owner: zhanghuidong.zhd
# owner group: storage
# description: copy test cases from mini_click_bench and fine tune, check query correctness in row store major with column store schema

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
--disable_warnings
drop table if exists hits;
--enable_warnings
set session ob_query_timeout=100000000000;
set session ob_trx_timeout=100000000000;
set global parallel_servers_target=200;

let $LOAD_SOURCE_DATA_FOLDER = "$PWD/mysql_test/test_suite/column_store/data/click.tar.gz";
let $UNZIP_FILE= "click.tar.gz";
let $table_name = "hits";
let $tenant_name = "mysql";
--source mysql_test/include/copy_data_and_unzip.inc

connection conn1;
# create table
CREATE TABLE `hits` (
  `WatchID` bigint(20) NOT NULL,
  `JavaEnable` smallint(6) NOT NULL,
  `Title` text NOT NULL,
  `GoodEvent` smallint(6) NOT NULL,
  `EventTime` timestamp NOT NULL,
  `EventDate` date NOT NULL,
  `CounterID` int(11) NOT NULL,
  `ClientIP` int(11) NOT NULL,
  `RegionID` int(11) NOT NULL,
  `UserID` bigint(20) NOT NULL,
  `CounterClass` smallint(6) NOT NULL,
  `OS` smallint(6) NOT NULL,
  `UserAgent` smallint(6) NOT NULL,
  `URL` text NOT NULL,
  `Referer` text NOT NULL,
  `IsRefresh` smallint(6) NOT NULL,
  `RefererCategoryID` smallint(6) NOT NULL,
  `RefererRegionID` int(11) NOT NULL,
  `URLCategoryID` smallint(6) NOT NULL,
  `URLRegionID` int(11) NOT NULL,
  `ResolutionWidth` smallint(6) NOT NULL,
  `ResolutionHeight` smallint(6) NOT NULL,
  `ResolutionDepth` smallint(6) NOT NULL,
  `FlashMajor` smallint(6) NOT NULL,
  `FlashMinor` smallint(6) NOT NULL,
  `FlashMinor2` text NOT NULL,
  `NetMajor` smallint(6) NOT NULL,
  `NetMinor` smallint(6) NOT NULL,
  `UserAgentMajor` smallint(6) NOT NULL,
  `UserAgentMinor` varchar(255) NOT NULL,
  `CookieEnable` smallint(6) NOT NULL,
  `JavascriptEnable` smallint(6) NOT NULL,
  `IsMobile` smallint(6) NOT NULL,
  `MobilePhone` smallint(6) NOT NULL,
  `MobilePhoneModel` text NOT NULL,
  `Params` text NOT NULL,
  `IPNetworkID` int(11) NOT NULL,
  `TraficSourceID` smallint(6) NOT NULL,
  `SearchEngineID` smallint(6) NOT NULL,
  `SearchPhrase` text NOT NULL,
  `AdvEngineID` smallint(6) NOT NULL,
  `IsArtifical` smallint(6) NOT NULL,
  `WindowClientWidth` smallint(6) NOT NULL,
  `WindowClientHeight` smallint(6) NOT NULL,
  `ClientTimeZone` smallint(6) NOT NULL,
  `ClientEventTime` timestamp NOT NULL,
  `SilverlightVersion1` smallint(6) NOT NULL,
  `SilverlightVersion2` smallint(6) NOT NULL,
    SilverlightVersion3 INTEGER NOT NULL,
    SilverlightVersion4 SMALLINT NOT NULL,
    PageCharset TEXT NOT NULL,
    CodeVersion INTEGER NOT NULL,
    IsLink SMALLINT NOT NULL,
    IsDownload SMALLINT NOT NULL,
    IsNotBounce SMALLINT NOT NULL,
    FUniqID BIGINT NOT NULL,
    OriginalURL TEXT NOT NULL,
    HID INTEGER NOT NULL,
    IsOldCounter SMALLINT NOT NULL,
    IsEvent SMALLINT NOT NULL,
    IsParameter SMALLINT NOT NULL,
    DontCountHits SMALLINT NOT NULL,
    WithHash SMALLINT NOT NULL,
    HitColor CHAR NOT NULL,
    LocalEventTime TIMESTAMP NOT NULL,
    Age SMALLINT NOT NULL,
    Sex SMALLINT NOT NULL,
    Income SMALLINT NOT NULL,
    Interests SMALLINT NOT NULL,
    Robotness SMALLINT NOT NULL,
    RemoteIP INTEGER NOT NULL,
    WindowName INTEGER NOT NULL,
    OpenerName INTEGER NOT NULL,
    HistoryLength SMALLINT NOT NULL,
    BrowserLanguage TEXT NOT NULL,
    BrowserCountry TEXT NOT NULL,
    SocialNetwork TEXT NOT NULL,
    SocialAction TEXT NOT NULL,
    HTTPError SMALLINT NOT NULL,
    SendTiming INTEGER NOT NULL,
    DNSTiming INTEGER NOT NULL,
    ConnectTiming INTEGER NOT NULL,
    ResponseStartTiming INTEGER NOT NULL,
    ResponseEndTiming INTEGER NOT NULL,
    FetchTiming INTEGER NOT NULL,
    SocialSourceNetworkID SMALLINT NOT NULL,
    SocialSourcePage TEXT NOT NULL,
    ParamPrice BIGINT NOT NULL,
    ParamOrderID TEXT NOT NULL,
    ParamCurrency TEXT NOT NULL,
    ParamCurrencyID SMALLINT NOT NULL,
    OpenstatServiceName TEXT NOT NULL,
    OpenstatCampaignID TEXT NOT NULL,
    OpenstatAdID TEXT NOT NULL,
    OpenstatSourceID TEXT NOT NULL,
    UTMSource TEXT NOT NULL,
  `UTMMedium` text NOT NULL,
  `UTMCampaign` text NOT NULL,
  `UTMContent` text NOT NULL,
  `UTMTerm` text NOT NULL,
  `FromTag` text NOT NULL,
  `HasGCLID` smallint(6) NOT NULL,
  `RefererHash` bigint(20) NOT NULL,
  `URLHash` bigint(20) NOT NULL,
  `CLID` int(11) NOT NULL,
  PRIMARY KEY (`CounterID`, `EventDate`, `UserID`, `EventTime`, `WatchID`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = condensed COMPRESSION = 'none' BLOCK_SIZE = 65536 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

# load data
load data /*+ parallel(10) direct(true, 0) */ infile 'data_for_mysqltest_loaddata/click.csv' into table hits FIELDS TERMINATED BY ',' ENCLOSED BY '\"';

# add column group
alter table hits add column group (all columns, each column) delayed;

# clickbench querys
select count(1) from hits;
CALL DBMS_STATS.GATHER_TABLE_STATS ('test', 'hits',  granularity=>'global', degree=>4);
SELECT  /*+ q1  parallel(16) */ COUNT(*) FROM hits;
SELECT  /*+ q2  parallel(16) */ COUNT(*) FROM hits WHERE AdvEngineID <> 0;
SELECT  /*+ q3  parallel(16) */ SUM(AdvEngineID), COUNT(*), AVG(ResolutionWidth) FROM hits;
SELECT  /*+ q4  parallel(16) */ AVG(UserID) FROM hits;
SELECT  /*+ q5  parallel(16) */ COUNT(DISTINCT UserID) FROM hits;
SELECT  /*+ q6  parallel(16) */ COUNT(DISTINCT SearchPhrase) FROM hits;
SELECT  /*+ q7  parallel(16) */ MIN(EventDate), MAX(EventDate) FROM hits;

SELECT  /*+ q8  parallel(16) */ AdvEngineID, COUNT(*) FROM hits WHERE AdvEngineID <> 0 GROUP BY AdvEngineID ORDER BY COUNT(*) DESC;

SELECT  /*+ q9  parallel(16) */ RegionID, COUNT(DISTINCT UserID) AS u FROM hits GROUP BY RegionID ORDER BY u DESC LIMIT 10;

SELECT  /*+ q10 parallel(16) */ RegionID, SUM(AdvEngineID), COUNT(*) AS c, AVG(ResolutionWidth), COUNT(DISTINCT UserID) FROM hits GROUP BY RegionID ORDER BY c DESC LIMIT 10;

SELECT  /*+ q11 parallel(16) */ MobilePhoneModel, COUNT(DISTINCT UserID) AS u FROM hits WHERE MobilePhoneModel <> '' GROUP BY MobilePhoneModel ORDER BY u desc, MobilePhoneModel DESC LIMIT 10;

SELECT  /*+ q12 parallel(16) */ MobilePhone, MobilePhoneModel, COUNT(DISTINCT UserID) AS u FROM hits WHERE MobilePhoneModel <> '' GROUP BY MobilePhone, MobilePhoneModel ORDER BY u desc, MobilePhone desc, MobilePhoneModel DESC LIMIT 10;

SELECT  /*+ q13 parallel(16) */ SearchPhrase, COUNT(*) AS c FROM hits WHERE SearchPhrase <> '' GROUP BY SearchPhrase ORDER BY c desc, SearchPhrase DESC LIMIT 10;

SELECT  /*+ q14 parallel(16) */ SearchPhrase, COUNT(DISTINCT UserID) AS u FROM hits WHERE SearchPhrase <> '' GROUP BY SearchPhrase ORDER BY u DESC LIMIT 10;

SELECT  /*+ q15 parallel(16) */ SearchEngineID, SearchPhrase, COUNT(*) AS c FROM hits WHERE SearchPhrase <> '' GROUP BY SearchEngineID, SearchPhrase ORDER BY c DESC LIMIT 10;

SELECT  /*+ q16 parallel(16) */ UserID, COUNT(*) FROM hits GROUP BY UserID ORDER BY COUNT(*) DESC LIMIT 10;

SELECT  /*+ q17 parallel(16) */ UserID, SearchPhrase, COUNT(*) FROM hits GROUP BY UserID, SearchPhrase ORDER BY COUNT(*) DESC LIMIT 10;

#add order by for result
SELECT  /*+ q18 parallel(16) */ UserID, SearchPhrase, COUNT(*) FROM hits GROUP BY UserID, SearchPhrase order by 1, 2 LIMIT 10;

#add order by for result
SELECT  /*+ q19 parallel(16) */ UserID, extract(minute FROM EventTime) AS m, SearchPhrase, COUNT(*) FROM hits GROUP BY UserID, m, SearchPhrase ORDER BY COUNT(*) desc, UserID DESC LIMIT 10;

SELECT  /*+ q20 parallel(16) */ UserID FROM hits WHERE UserID = 435090932899640449;

SELECT  /*+ q21 parallel(16) */ COUNT(*) FROM hits WHERE URL LIKE '%google%';

SELECT  /*+ q22 parallel(16) */ SearchPhrase, MIN(URL), COUNT(*) AS c FROM hits WHERE URL LIKE '%google%' AND SearchPhrase <> '' GROUP BY SearchPhrase ORDER BY c DESC LIMIT 10;

SELECT  /*+ q23 parallel(16) */ SearchPhrase, MIN(URL), MIN(Title), COUNT(*) AS c, COUNT(DISTINCT UserID) FROM hits WHERE Title LIKE '%Google%' AND URL NOT LIKE '%.google.%' AND SearchPhrase <> '' GROUP BY SearchPhrase ORDER BY c desc, SearchPhrase DESC LIMIT 10;
SELECT  /*+ q24 parallel(16) */ * FROM hits WHERE URL LIKE '%google%' ORDER BY EventTime, WatchID LIMIT 10;
SELECT  /*+ q25 parallel(16) */ SearchPhrase FROM hits WHERE SearchPhrase <> '' ORDER BY EventTime, SearchPhrase LIMIT 10;
SELECT  /*+ q26 parallel(16) */ SearchPhrase FROM hits WHERE SearchPhrase <> '' ORDER BY SearchPhrase LIMIT 10;
SELECT  /*+ q27 parallel(16) */ SearchPhrase FROM hits WHERE SearchPhrase <> '' ORDER BY EventTime, SearchPhrase LIMIT 10;
SELECT  /*+ q28 parallel(16) */ CounterID, AVG(length(URL)) AS l, COUNT(*) AS c FROM hits WHERE URL <> '' GROUP BY CounterID HAVING COUNT(*) > 100000 ORDER BY l DESC LIMIT 25;
SELECT  /*+ q29 parallel(16) */ REGEXP_REPLACE(Referer, '^https?://(?:www\.)?([^/]+)/.*$', '\1') AS k, AVG(length(Referer)) AS l, COUNT(*) AS c, MIN(Referer) FROM hits WHERE Referer <> '' GROUP BY k HAVING COUNT(*) > 100000 ORDER BY l DESC LIMIT 25;
SELECT  /*+ q30 parallel(16) */ SUM(ResolutionWidth), SUM(ResolutionWidth + 1), SUM(ResolutionWidth + 2), SUM(ResolutionWidth + 3), SUM(ResolutionWidth + 4), SUM(ResolutionWidth + 5), SUM(ResolutionWidth + 6), SUM(ResolutionWidth + 7), SUM(ResolutionWidth + 8), SUM(ResolutionWidth + 9), SUM(ResolutionWidth + 10), SUM(ResolutionWidth + 11), SUM(ResolutionWidth + 12), SUM(ResolutionWidth + 13), SUM(ResolutionWidth + 14), SUM(ResolutionWidth + 15), SUM(ResolutionWidth + 16), SUM(ResolutionWidth + 17), SUM(ResolutionWidth + 18), SUM(ResolutionWidth + 19), SUM(ResolutionWidth + 20), SUM(ResolutionWidth + 21), SUM(ResolutionWidth + 22), SUM(ResolutionWidth + 23), SUM(ResolutionWidth + 24), SUM(ResolutionWidth + 25), SUM(ResolutionWidth + 26), SUM(ResolutionWidth + 27), SUM(ResolutionWidth + 28), SUM(ResolutionWidth + 29), SUM(ResolutionWidth + 30), SUM(ResolutionWidth + 31), SUM(ResolutionWidth + 32), SUM(ResolutionWidth + 33), SUM(ResolutionWidth + 34), SUM(ResolutionWidth + 35), SUM(ResolutionWidth + 36), SUM(ResolutionWidth + 37), SUM(ResolutionWidth + 38), SUM(ResolutionWidth + 39), SUM(ResolutionWidth + 40), SUM(ResolutionWidth + 41), SUM(ResolutionWidth + 42), SUM(ResolutionWidth + 43), SUM(ResolutionWidth + 44), SUM(ResolutionWidth + 45), SUM(ResolutionWidth + 46), SUM(ResolutionWidth + 47), SUM(ResolutionWidth + 48), SUM(ResolutionWidth + 49), SUM(ResolutionWidth + 50), SUM(ResolutionWidth + 51), SUM(ResolutionWidth + 52), SUM(ResolutionWidth + 53), SUM(ResolutionWidth + 54), SUM(ResolutionWidth + 55), SUM(ResolutionWidth + 56), SUM(ResolutionWidth + 57), SUM(ResolutionWidth + 58), SUM(ResolutionWidth + 59), SUM(ResolutionWidth + 60), SUM(ResolutionWidth + 61), SUM(ResolutionWidth + 62), SUM(ResolutionWidth + 63), SUM(ResolutionWidth + 64), SUM(ResolutionWidth + 65), SUM(ResolutionWidth + 66), SUM(ResolutionWidth + 67), SUM(ResolutionWidth + 68), SUM(ResolutionWidth + 69), SUM(ResolutionWidth + 70), SUM(ResolutionWidth + 71), SUM(ResolutionWidth + 72), SUM(ResolutionWidth + 73), SUM(ResolutionWidth + 74), SUM(ResolutionWidth + 75), SUM(ResolutionWidth + 76), SUM(ResolutionWidth + 77), SUM(ResolutionWidth + 78), SUM(ResolutionWidth + 79), SUM(ResolutionWidth + 80), SUM(ResolutionWidth + 81), SUM(ResolutionWidth + 82), SUM(ResolutionWidth + 83), SUM(ResolutionWidth + 84), SUM(ResolutionWidth + 85), SUM(ResolutionWidth + 86), SUM(ResolutionWidth + 87), SUM(ResolutionWidth + 88), SUM(ResolutionWidth + 89) FROM hits;
SELECT  /*+ q31 parallel(16) */ SearchEngineID, ClientIP, COUNT(*) AS c, SUM(IsRefresh), AVG(ResolutionWidth) FROM hits WHERE SearchPhrase <> '' GROUP BY SearchEngineID, ClientIP ORDER BY c desc, SearchEngineID desc, ClientIP DESC LIMIT 10;

# add order by for result
SELECT  /*+ q32 parallel(16) */ WatchID, ClientIP, COUNT(*) AS c, SUM(IsRefresh), AVG(ResolutionWidth) FROM hits WHERE SearchPhrase <> '' GROUP BY WatchID, ClientIP ORDER BY c desc, WatchID DESC LIMIT 10;
# add order by for result
SELECT  /*+ q33 parallel(16) */ WatchID, ClientIP, COUNT(*) AS c, SUM(IsRefresh), AVG(ResolutionWidth) FROM hits GROUP BY WatchID, ClientIP ORDER BY c desc, WatchID DESC LIMIT 10;

SELECT  /*+ q34 parallel(16) */ URL, COUNT(*) AS c FROM hits GROUP BY URL ORDER BY c DESC LIMIT 10;
SELECT  /*+ q35 parallel(16) */ 1, URL, COUNT(*) AS c FROM hits GROUP BY 1, URL ORDER BY c DESC LIMIT 10;
SELECT  /*+ q36 parallel(16) */ ClientIP, ClientIP - 1, ClientIP - 2, ClientIP - 3, COUNT(*) AS c FROM hits GROUP BY ClientIP, ClientIP - 1, ClientIP - 2, ClientIP - 3 ORDER BY c desc, ClientIP DESC LIMIT 10;
SELECT  /*+ q37 parallel(16) */ URL, COUNT(*) AS PageViews FROM hits WHERE CounterID = 62 AND EventDate >= date'2013-07-01' AND EventDate <= date'2013-07-31' AND DontCountHits = 0 AND IsRefresh = 0 AND URL <> '' GROUP BY URL ORDER BY PageViews DESC LIMIT 10;
SELECT  /*+ q38 parallel(16) */ Title, COUNT(*) AS PageViews FROM hits WHERE CounterID = 62 AND EventDate >= date'2013-07-01' AND EventDate <= date'2013-07-31' AND DontCountHits = 0 AND IsRefresh = 0 AND Title <> '' GROUP BY Title ORDER BY PageViews DESC LIMIT 10;
SELECT  /*+ q39 parallel(16) */ URL, COUNT(*) AS PageViews FROM hits WHERE CounterID = 62 AND EventDate >= date'2013-07-01' AND EventDate <= date'2013-07-31' AND IsRefresh = 0 AND IsLink <> 0 AND IsDownload = 0 GROUP BY URL ORDER BY PageViews DESC LIMIT 10 OFFSET 1000;
SELECT  /*+ q40 parallel(16) */ TraficSourceID, SearchEngineID, AdvEngineID, CASE WHEN (SearchEngineID = 0 AND AdvEngineID = 0) THEN Referer ELSE '' END AS Src, URL AS Dst, COUNT(*) AS PageViews FROM hits WHERE CounterID = 62 AND EventDate >= date'2013-07-01' AND EventDate <= date'2013-07-31' AND IsRefresh = 0 GROUP BY TraficSourceID, SearchEngineID, AdvEngineID, Src, Dst ORDER BY PageViews DESC LIMIT 10 OFFSET 1000;
SELECT  /*+ q41 parallel(16) */ URLHash, EventDate, COUNT(*) AS PageViews FROM hits WHERE CounterID = 62 AND EventDate >= date'2013-07-01' AND EventDate <= date'2013-07-31' AND IsRefresh = 0 AND TraficSourceID IN (-1, 6) AND RefererHash = 3594120000172545465 GROUP BY URLHash, EventDate ORDER BY PageViews DESC LIMIT 10 OFFSET 100;
SELECT  /*+ q42 parallel(16) */ WindowClientWidth, WindowClientHeight, COUNT(*) AS PageViews FROM hits WHERE CounterID = 62 AND EventDate >= date'2013-07-01' AND EventDate <= date'2013-07-31' AND IsRefresh = 0 AND DontCountHits = 0 AND URLHash = 2868770270353813622 GROUP BY WindowClientWidth, WindowClientHeight ORDER BY PageViews DESC LIMIT 10 OFFSET 10000;
SELECT  /*+ q43 parallel(16) */ DATE_FORMAT(EventTime, '%Y-%m-%d %H:00:00') AS M, COUNT(*) AS PageViews FROM hits WHERE CounterID = 62 AND EventDate >= date'2013-07-14' AND EventDate <= date'2013-07-15' AND IsRefresh = 0 AND DontCountHits = 0 GROUP BY DATE_FORMAT(EventTime, '%Y-%m-%d %H:00:00') ORDER BY DATE_FORMAT(EventTime, '%Y-%m-%d %H:00:00') LIMIT 10 OFFSET 1000;

# clean up
drop table hits;
disconnect conn1;
connection default;