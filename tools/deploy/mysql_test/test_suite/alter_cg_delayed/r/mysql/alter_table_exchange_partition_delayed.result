drop table if exists pt;
drop table if exists nt;
create table pt (c1 bigint primary key, c2 bigint, c3 blob) partition by range(c1) (partition M1  VALUES LESS THAN (50000), partition M2 VALUES LESS THAN (100000), partition M3 VALUES LESS THAN (200000));
create table nt (c1 bigint primary key, c2 bigint, c3 blob);
alter table nt add column group (each column) delayed;
alter table pt exchange partition M3 with table nt without validation;
ERROR HY000: Non matching attribute 'COLUMN_STORAGE_FORMAT' between partition and table
drop table pt;
drop table nt;
drop table if exists test1;
drop table if exists test2;
create table test1(c1 int primary key, c2 varchar(30)) partition by range (c1)(
partition c1_15 values less than (15),
partition c1_35 values less than (35),
partition c1_50 values less than (50));
create table test2(c1 int primary key, c2 varchar(30));
alter table test1 add column group (each column) delayed;
alter table test2 add column group (each column);
alter table test1 exchange partition c1_35 with table test2 without validation;
