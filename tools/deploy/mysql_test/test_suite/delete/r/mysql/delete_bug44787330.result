-------------------------------------
  0 - output(nil), filter(nil)
      table_columns([{tt1: ({t1: (tt1.__pk_increment, tt1.c1, tt1.c2)}), hash_distinct}], [{t2: ({t2: (t2.__pk_increment, t2.c1)}), hash_distinct}])
  1 - output([tt1.__pk_increment], [tt1.c1], [tt1.c2], [t2.__pk_increment], [t2.c1]), filter(nil), rowset=16
      equal_conds([tt1.c2 = t2.c1]), other_conds(nil)
  2 - output([t2.__pk_increment], [t2.c1]), filter(nil), rowset=16
      access([t2.__pk_increment], [t2.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  3 - output([tt1.__pk_increment], [tt1.c2], [tt1.c1]), filter(nil), rowset=16
      access([tt1.__pk_increment], [tt1.c2], [tt1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([tt1.__pk_increment]), range(MIN ; MAX)always true
delete tt1, tt2 from t1 as tt1 left join v2 as tt2 on tt1.c2 = tt2.c1;
drop table t1,t2;
drop view v2;
