--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yibo.tyf
#owner group: sql1
# tags: delete,dml

--disable_warnings
drop table if exists test;
--enable_warnings

create table test (c1 int primary key, c2 int ,c3 int, c4 int,c5 int, unique key u_idx(c4,c5) global) partition by hash(c1) partitions 2;
set binlog_row_image='MINIMAL';
insert into test values(1, 1, 1, null, null);

explain DELETE FROM test;
DELETE FROM test;

drop table test;