--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group: SQL1
#description:
#tags: delete, dml

--echo case 1: int + 1 row
#alter system set min_drop_cache_wait_time='10s' server_type=chunkserver;
--real_sleep 2 

--echo case 3: varchar 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table  t1(c0 int primary key,c1 varchar(1024)) EXPIRE_INFO (c1 = 'd');

insert into t1 values(1,'i'),(2,'s'),(3,'D');

--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
delete from t1 where c0=1;
delete from t1 where c0=2;
delete from t1 where c0=3;

--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

insert into t1 values(1,'i'),(2,'s'),(3,'D');

--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
delete from t1 where c0=1;
delete from t1 where c0=2;
delete from t1 where c0=3;

--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
insert into t1 values(1,'i'),(2,'s'),(3,'D');
