--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
#owner group: sql2
# tags: delete,dml

#--disable_parsing
--disable_warnings
drop table if exists sbtest;
--enable_warnings

--disable_query_log

CREATE TABLE sbtest (id INTEGER  NOT NULL , k integer  DEFAULT '0' NOT NULL, c char(120) DEFAULT '' NOT NULL, pad char(60) DEFAULT '' NOT NULL, PRIMARY KEY  (id) ) ;
--disable_query_log

--let $count=1
--let $prefix=0001
while($count < 21)
{ 
    --let $batch=10000
    --let $id=$count$prefix
    --let $stmt=replace INTO sbtest(id, k, c, pad) VALUES($count,0,' ','qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt')
    while($batch)
    {
        --let $value=,($id,0,' ','qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt')
        --let $stmt=$stmt$value
        dec $batch;
        inc $id;
        
    }
    --error 0,4119
    eval $stmt;
    inc $count; 
}
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--disable_query_log
connection default;
--let $count=21
--let $prefix=0001
while($count < 41)
{ 
    --let $batch=10000
    --let $id=$count$prefix
    --let $stmt=replace INTO sbtest(id, k, c, pad) VALUES($count,0,' ','qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt')
    while($batch)
    {
        --let $value=,($id,0,' ','qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt')
        --let $stmt=$stmt$value
        dec $batch;
        inc $id;
        
    }
    --error 0,4119
    eval $stmt;
    inc $count; 
}
#--enable_parsing
--let $id=250000
while($id > 200000)
{
    eval DELETE from sbtest where id=$id;
    dec $id;
}
drop table sbtest;
