select c1 from files(location = 'external_table_tmp_url_sqlqa_data/data3/'
FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    SKIP_BLANK_LINES = true
)
PATTERN 'test03.csv'
);
