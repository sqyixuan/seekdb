select c1+0 AS ID,cast(c2 as char(10)) AS NAME,round(c3,1) AS MON,c2||c4 AS AGE,cast(c5 as decimal(5,2)) AS DEC,cast(c6 as date) AS BIR from files(location = 'external_table_tmp_url_sqlqa_data/data5/'
FORMAT (
    type = 'csv',
	FIELD_DELIMITER = ',',
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34),
	ENCODING = 'UTF8MB4',
	SKIP_HEADER = 0,
	EMPTY_FIELD_AS_NULL = true
)
);
