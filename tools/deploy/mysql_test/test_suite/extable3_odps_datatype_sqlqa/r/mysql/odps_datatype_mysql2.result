drop table zcext4;
create external table if not exists zcext4 (
c1 varchar(100) AS (external$tablecol1),
c2 varchar(100) AS (external$tablecol2),
c3 double AS (external$tablecol3),
par1 VARCHAR(10) AS (metadata$partition_list_col1),
par2 VARCHAR(10) AS (metadata$partition_list_col2)
)
AUTO_REFRESH = IMMEDIATE
PROPERTIES =(
type = "odps"
#ODPS_ACCESSID#
#ODPS_ACCESSKEY#
PROJECT_NAME = "mysqltest_regression_sqlqa"
ENDPOINT = "http://service.cn-hangzhou.maxcompute.aliyun.com/api"
TABLE_NAME ="sale_detail"
)
partition by (par1,par2);
select * from zcext4;
+------+------+-------+------+----------+
| c1   | c2   | c3    | par1 | par2     |
+------+------+-------+------+----------+
| null | c5   |  NULL | 2014 | shanghai |
| s1   | c1   | 100.1 | 2013 | china    |
| s2   | c2   | 100.2 | 2013 | china    |
| s3   | c3   | 100.3 | 2013 | china    |
| s6   | c6   | 100.4 | 2014 | shanghai |
| s7   | c7   | 100.5 | 2014 | shanghai |
+------+------+-------+------+----------+
##clone partition table
drop table zcext4;
create external table if not exists zcext4 (
c1 varchar(100) AS (external$tablecol1),
c2 varchar(100) AS (external$tablecol2),
c3 double AS (external$tablecol3),
par1 VARCHAR(5) AS (metadata$partition_list_col1),
par2 VARCHAR(5) AS (metadata$partition_list_col2)
)
AUTO_REFRESH = IMMEDIATE
PROPERTIES =(
type = "odps"
#ODPS_ACCESSID#
#ODPS_ACCESSKEY#
PROJECT_NAME = "mysqltest_regression_sqlqa"
ENDPOINT = "http://service.cn-hangzhou.maxcompute.aliyun.com/api"
TABLE_NAME ="sale_detail_clone"
)
partition by (par1,par2);
select * from zcext4;
+------+------+-------+------+-------+
| c1   | c2   | c3    | par1 | par2  |
+------+------+-------+------+-------+
| s1   | c1   | 100.1 | 2013 | china |
| s2   | c2   | 100.2 | 2013 | china |
| s3   | c3   | 100.3 | 2013 | china |
+------+------+-------+------+-------+
##view(not support)
drop table zcext4;
create external table if not exists zcext4 (
c1 varchar(100) AS (external$tablecol1),
c2 varchar(100) AS (external$tablecol2),
c3 double AS (external$tablecol3),
par1 VARCHAR(5) AS (metadata$partition_list_col1),
par2 VARCHAR(5) AS (metadata$partition_list_col2)
)
AUTO_REFRESH = IMMEDIATE
PROPERTIES =(
type = "odps"
#ODPS_ACCESSID#
#ODPS_ACCESSKEY#
PROJECT_NAME = "mysqltest_regression_sqlqa"
ENDPOINT = "http://service.cn-hangzhou.maxcompute.aliyun.com/api"
TABLE_NAME ="sale_detail_view"
)
partition by (par1,par2);
