drop table zcext4;
create external table zcext4 (
c9 STRING AS (external$tablecol9)
)
PROPERTIES =(
type = "odps"
#ODPS_ACCESSID#
#ODPS_ACCESSKEY#
PROJECT_NAME = "mysqltest_regression_sqlqa"
ENDPOINT = "http://service.cn-hangzhou.maxcompute.aliyun.com/api"
TABLE_NAME ="T4"
);
select * from zcext4;
