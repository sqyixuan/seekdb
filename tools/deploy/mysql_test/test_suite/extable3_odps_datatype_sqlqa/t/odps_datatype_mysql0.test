##导入时区信息
--source mysql_test/test_suite/extable3_odps_datatype_sqlqa/include/import_time_zone_mysql.inc
SET time_zone ='UTC';

select * from zcext2;

set time_zone = 'Asia/Shanghai';

--error 0,1051
drop table zcext2;

