# owner: sanquan.qz
# owner group: 技术部-SQL-执行器
# tags: external_table
# description: odps数据类型映射

--enable_sorted_result
--result_format 4
purge recyclebin;
--source mysql_test/include/odps_config_for_cloud.inc
set ob_query_timeout= 100000000;

####odps数据被删除时可以执行该inc创建测试数据
##--disable_result_log
##--source mysql_test/test_suite/extable3_odps_datatype_sqlqa/include/import_odps_data.inc
##--enable_result_log

--disable_query_log
connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connect(mysql_conn,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection sys_conn;
alter system set _use_odps_jni_connector = false;
connection mysql_conn;
--enable_query_log


####简单验证分区场景
##clone table
--error 0,1051
drop table zcext4;

--source mysql_test/test_suite/extable3_odps_datatype_sqlqa/include/replace_odps_info.inc
eval create external table zcext4 (
c1 TINYINT AS (external\$tablecol1),
c2 SMALLINT AS (external\$tablecol2),
c3 INT AS (external\$tablecol3),
c4 BIGINT AS (external\$tablecol4),
c5 FLOAT AS (external\$tablecol5),
c6 DOUBLE AS (external\$tablecol6),
c7 DECIMAL(38,18) AS (external\$tablecol7),
c8 BOOLEAN AS (external\$tablecol8),
c9 VARCHAR(100) AS (external\$tablecol9),
c10 VARCHAR(100) AS (external\$tablecol10),
c11 CHAR(100) AS (external\$tablecol11),
c12 VARBINARY(100) AS (external\$tablecol12),
c13 TIMESTAMP(6) AS (external\$tablecol13),
c14 DATE AS (external\$tablecol14),
c15 DATETIME(6) AS (external\$tablecol15),
c16 DATETIME(3) AS (external\$tablecol16)
)
PROPERTIES =(
type = "odps"
ACCESSID = "$ODPS_ACCESSID"
ACCESSKEY = "$ODPS_ACCESSKEY"
PROJECT_NAME = "mysqltest_regression_sqlqa"
ENDPOINT = "http://service.cn-hangzhou.maxcompute.aliyun.com/api"
TABLE_NAME ="T4"
);

select * from zcext4;

--error 0,1051
drop table zcext4;

--source mysql_test/test_suite/extable3_odps_datatype_sqlqa/include/replace_odps_info.inc
eval create external table zcext4 (
c9 STRING AS (external\$tablecol9)
)
PROPERTIES =(
type = "odps"
ACCESSID = "$ODPS_ACCESSID"
ACCESSKEY = "$ODPS_ACCESSKEY"
PROJECT_NAME = "mysqltest_regression_sqlqa"
ENDPOINT = "http://service.cn-hangzhou.maxcompute.aliyun.com/api"
TABLE_NAME ="T4"
);

select * from zcext4;

--error 0,1051
drop table zcext4;

--source mysql_test/test_suite/extable3_odps_datatype_sqlqa/include/replace_odps_info.inc
eval create external table if not exists zcext4 (
c1 varchar(100) AS (external\$tablecol1),
c2 varchar(100) AS (external\$tablecol2),
c3 double AS (external\$tablecol3),
par1 VARCHAR(10) AS (metadata\$partition_list_col1),
par2 VARCHAR(10) AS (metadata\$partition_list_col2)
)
AUTO_REFRESH = IMMEDIATE
PROPERTIES =(
type = "odps"
ACCESSID = "$ODPS_ACCESSID"
ACCESSKEY = "$ODPS_ACCESSKEY"
PROJECT_NAME = "mysqltest_regression_sqlqa"
ENDPOINT = "http://service.cn-hangzhou.maxcompute.aliyun.com/api"
TABLE_NAME ="sale_detail"
)
partition by (par1,par2);

select * from zcext4;

