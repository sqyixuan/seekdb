TABLE_NAME ="sale_detail_view"
)
partition by (par1,par2);

set ob_query_timeout= 10000000;

--disable_query_log
connection sys_conn;
alter system set _use_odps_jni_connector = true;
connection mysql_conn;
--enable_query_log
