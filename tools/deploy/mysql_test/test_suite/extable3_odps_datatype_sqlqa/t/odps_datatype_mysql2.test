##clone partition table
--error 0,1051
drop table zcext4;

--source mysql_test/test_suite/extable3_odps_datatype_sqlqa/include/replace_odps_info.inc
eval create external table if not exists zcext4 (
c1 varchar(100) AS (external\$tablecol1),
c2 varchar(100) AS (external\$tablecol2),
c3 double AS (external\$tablecol3),
par1 VARCHAR(5) AS (metadata\$partition_list_col1),
par2 VARCHAR(5) AS (metadata\$partition_list_col2)
)
AUTO_REFRESH = IMMEDIATE
PROPERTIES =(
type = "odps"
ACCESSID = "$ODPS_ACCESSID"
ACCESSKEY = "$ODPS_ACCESSKEY"
PROJECT_NAME = "mysqltest_regression_sqlqa"
ENDPOINT = "http://service.cn-hangzhou.maxcompute.aliyun.com/api"
TABLE_NAME ="sale_detail_clone"
)
partition by (par1,par2);

select * from zcext4;

