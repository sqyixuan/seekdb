--echo # 环境清理
purge recyclebin;
--result_format 4


let $char_charset = 'UTF8';
--enable_result_log


--explain_protocol 0


--echo TIME-TC-1
--echo expr1->time
select subtime(time '11:00:00',1);
select subtime(time '11:00:00',0);
select subtime('11:00:00',1);
select subtime('11:00:00',0);
select subtime(time '11:00:00',null);
select subtime(time '11:00:00','');
select subtime(time '11:00:00','1:1');
select subtime(time '11:00:00','0:1:1');
select subtime('23:59:59', '-1') ;
select subtime('23:59:59', '-1:0:2');
select subtime('11:00:00',59);
select subtime(time'11:00:00',60);
select subtime(time'11:00:00',59);
select subtime('11:00:00',60);
select subtime(time '11:00:00',100);
select subtime(time '11:00:00',110);
select subtime(time '11:00:00',160);
select subtime(time '11:00:00',200);
select subtime('11:00:00',259);
select subtime('11:00:00',6000);
select subtime('11:00:00',0.000001);
select subtime('11:00:00',-0.000001);
select subtime('11:00:00',-61);
select subtime('11:00:00',-100);
--echo 时间最大最小值验证   expr1和expr2的最大最小值为'±838:59:59'
select subtime('400:59:59','-400:59:59');
select subtime('838:59:59','0');
select subtime('839:00:00','0');
select subtime('0','838:59:59');
select subtime('0','839:00:00');
select subtime('500:59:59','-499:00:00');
select subtime('500:59:59','-499:00:01');
select subtime('838:59:59','-838:59:59');
select subtime('839:59:59','-839:59:59');
select subtime('1839:59:59','-1839:59:59');

select subtime('-400:59:59','400:59:59');
select subtime('-838:59:59','0');
select subtime('-839:00:00','0');
select subtime('0','-838:59:59');
select subtime('0','-839:00:00');
select subtime('-500:59:59','499:00:00');
select subtime('-500:59:59','499:00:01');
select subtime('-838:59:59','838:59:59');
select subtime('-839:59:59','839:59:59');

--echo expr1->date
select subtime(date'2007-12-31', '1') ;
select subtime(date'2007-12-31', '1 01:01:01') ;
select subtime(date'2007-12-31', null) ;
select subtime(date'2007-12-31', '') ;
select subtime('2007-12-31', '1') ;
select subtime('2007-12-31', '01:01:01') ;
select subtime('2007-12-31', null) ;
select subtime('2007-12-31', '') ;
select subtime(date '2008-01-01', '34 00:00:00') ;
--echo 超过第二个参数的最大值'±34 22:59:59'
select subtime(date '2008-01-01', '35 00:00:00') ;
select subtime(date '2008-01-01', '34 22:59:59') ;
select subtime(date '2008-06-01', '-34 22:59:59') ;
select subtime(date '2008-06-01', '-34 23:00:00') ;

--echo expr1->year
select subtime('2007', '0') ;
select subtime('2007', '100') ;
select subtime('2007', 'null') ;
select subtime('2007', '') ;

--echo expr1->timedate
--error 1583
select subtime(datetime '2007-12-31 23:59:59', '-01:01:01') ;
--error 1583
select subtime(datetime'2007-02-28 23:59:59', '-1') ;
--error 1583
select subtime(datetime'2007-03-01 00:00:00', '-1') ;
--error 1583
select subtime(datetime '2022-10-30 23:58:59','0:1:1');
select subtime('2007-12-31 23:59:59', '1') ;
select subtime('2007-02-28 23:59:59', '1') ;
select subtime('2007-03-01 00:00:00', '-1') ;
select subtime('2007-12-31 23:59:59', '1 1:1:1.000001') ;
select subtime('2007-12-31 23:59:59', '1 1:1:1.000002') ;
select subtime('2021-4-20 11:00:00', 61) ;
select subtime('2021-4-20 11:00:00', 100.000001) ;
select subtime('2021-4-20 11:00:00', null) ;
select subtime('2021-4-20 11:00:00', '') ;

--echo expr1->timestamp
select subtime(timestamp '2008-01-01 00:00:00.999999', '1:1:1.000001') ;
select subtime('2007-12-01 23:59:59.999999', '1 1:1:1.000002') ;
select subtime('2007-12-31 23:59:59.999999', null) ;
select subtime('2007-12-31 23:59:59.999999', '') ;
SELECT subtime('2020-10-31 23:59:59','0:1:1'),subtime('10:30:59','5:10:37') ;

select subtime(null,'01:00:00') ;
select subtime('','01:00:00') ;

--echo expr1->varchar
select subtime('20220905',0);
select subtime('20220905000000',0);
select subtime(20220905000000,0);
select subtime(202209050000000,0);
select subtime(0,0);

--echo 参数1时间格式不对
select subtime('1970-00-00 00:00:00.000000','0.000001') ;
select subtime('1970-01-00 00:00:00.000000','0.000001') ;
select subtime('1970-00-01 00:00:00.000000','0.000001') ;
select subtime('-0000-01-01 00:00:00.000000','0.000001') ;

--echo 参数2为日期表达式
select subtime('2008-01-01 00:00:00', '01-01 1:1:1.000001') ;
select subtime('2008-01-01 00:00:00', '02-02-02') ;

--echo 参数2为布尔
select subtime('2008-01-01 00:00:00', true) ;
select subtime('2008-01-01 00:00:00', false) ;

--echo 缺少参数
--error 1582
select subtime('2022-09-05 11:00:00') ;
--error 1582
select subtime('01:01:01') ;
--error 1582
select subtime();
--echo 参数多余
--error 1582
select subtime('1970-00-00 00:00:00.000000','0.000001',true);



--echo TIME-TC-2
