delete from t1 where c1 = subtime('11:11:11','01:01:01') and c2 = subtime(date '2022-09-05','25:00:00') limit 1;
delete from t1 where c1 = subtime('11:11:11','01:01:01') and c2 = cast(subtime(date '2022-09-05','25:00:00') as date) limit 1;
