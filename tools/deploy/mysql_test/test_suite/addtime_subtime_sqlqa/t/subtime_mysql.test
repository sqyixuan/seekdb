--disable_result_log
select subtime(now(),'01:00:00') ;
select subtime(curdate(),'01:00:00') ;
select subtime(curtime(),'01:00:00') ;
select subtime(curtime(),'100') ;
--enable_result_log

select subtime(subtime('2007-12-31 23:59:59.999999', 1), 1) ;

--disable_result_log
select subtime(current_timestamp(),100) as result ;
select subtime(localtime(),100) as result ;
select subtime(localtime,100) as result ;
select subtime(localtimestamp(),100) as result ;
select subtime(localtimestamp,100) as result ;
select subtime(sysdate(),100) as result ;
--enable_result_log

select subtime(TIMESTAMP('2017-05-15'), 1) as result ;
--error 1064
select subtime('2022-09-05 11:00:00',interval 1 day);
select subtime(date_add('2022-09-05 11:00:00',interval 1 year), 1) as result ;
select subtime(date_sub('2022-09-05 11:00:00',interval 1 year), 1) as result ;
select subtime(adddate('2022-09-05',interval '1' day),100) as result;
select subtime(adddate(DATE '2022-09-05',interval '1' day),100) as result;
select subtime(convert_tz('2022-01-01 12:00:00','+00:00','+10:00'),'100') as result;
select subtime('2022-09-05 11:00:00',datediff('2022-01-22 23:59:59','2022-1-21')) as result;
