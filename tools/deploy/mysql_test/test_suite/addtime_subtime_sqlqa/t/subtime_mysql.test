select dayname(subtime('2007-12-31 23:59:59.999999', 1)) as result;
select dayofweek(subtime('2007-12-31 23:59:59.999999', 1)) as result;
select dayofyear(subtime('2007-12-31 23:59:59.999999', 1)) as result;
select subtime(from_unixtime('1647738565','%Y %M %D %h:%i:%s'),0);
select last_day(subtime('2022-09-05 11:00:00',000)) as result;
select subtime(makedate(2022,1),100) as result;
select subtime(maketime(11,11,11),200) as result;
select subtime('2022-09-05 11:00:00',time('2022-09-05 11:00:00')) as result;



--disable_result_log
select subtime(date_add(current_timestamp(),interval 1 year), 1) as result ;
select subtime(date_sub(current_timestamp(),interval 1 year), 1) as result ;
--enable_result_log

select concat('datetime:',subtime('1970-09-05 00:00:00',0)) ;

select nullif(subtime('1970-09-05 00:00:00',1),subtime('1970-09-05 00:00:00',1));
select nullif(subtime('1970-09-05 00:00:00',1),subtime('1970-09-05 00:00:00',0));

select ifnull(null,subtime('1970-09-05 00:00:00','01:01:01')) as result;

select coalesce(null,null,subtime('1970-09-05 00:00:00',1)) ;

--error 0,1051
drop table t1;
create table t1(c1 int,c2 datetime);
insert into t1 values(1,'1970-09-05 00:00:00');
insert into t1 values(2,'1980-09-05 00:00:00');
insert into t1 values(3,'1990-09-05 00:00:00');

select case c2 when subtime('1970-09-05 00:00:00','0') then subtime('1970-09-05 00:00:00','100')
               else '2022-09-05 00:00:00'
end as c3
from t1;

select case  when c2 < subtime('1980-09-05 00:00:00','100') then subtime('1970-09-05 00:00:00','0')
             else '2022-09-05 00:00:00'
end as c3
from t1;

select if(subtime('1970-09-05 00:00:00','0') = '1970-09-05 00:00:00',1,0) as result;
select if(subtime('1970-09-05 00:00:00','01:01:01') = '1970-09-05 00:00:00',1,0) as result;

#select abs(subtime('1970-09-05 00:00:00',0)) ;






