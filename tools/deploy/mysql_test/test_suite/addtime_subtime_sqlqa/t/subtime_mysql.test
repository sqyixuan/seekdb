drop table t1;
create table t1(
c1 time default null,
c2 date default null,
c3 datetime default null,
c4 timestamp default null,
c5 varchar(20) default null) DEFAULT CHARSET = utf8;

insert into t1(c1) values(subtime(time '01:01:01','01:01:01'));
insert into t1(c2) values(subtime(date '2022-09-05','01:01:01'));
insert into t1(c3) values(subtime('2022-09-05 01:01:01','01:01:01'));
insert into t1(c4) values(subtime(timestamp '2022-09-05 01:01:01.000001','01:01:01.000001'));
