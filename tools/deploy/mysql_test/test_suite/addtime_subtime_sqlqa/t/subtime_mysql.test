--echo 存储过程中的使用

--error 0,1305
drop procedure p1;
delimiter /;
create procedure p1(in aa datetime)
 begin
  case 
  when aa < subtime('2022-09-05 00:00:00',0) then
    select '之前的时间' as result;
  when aa > subtime('2022-09-05 00:00:00',0) then
    select '以后的时间' as result;
  else
  select '就是现在' as result;
  end case;
 end /
delimiter ;/
--error 1064
call p1(subtime('2022-09-05 00:00:00',0);

call p1('2022-09-05 00:00:00');
call p1('2022-09-04 00:00:00');


--error 0,1305
drop procedure p1;
delimiter /;
create procedure p1(in aa datetime,out bb datetime)
 begin
  set bb = '2022-09-05 00:00:00';
  while aa > bb do
    set bb = subtime(bb,'1 00:00:00');
    end while;
  select bb;
 end /
delimiter ;/

call p1('2022-09-10 00:00:00',@bb);


--echo 触发器
--error 0,1051
drop table t1;
create table t1(c1 datetime,c2 datetime);
--error 0,1051
drop table t2;
create table t2(c1 datetime,c2 datetime);
--error 0,1360
drop trigger trg_subtime;
create trigger trg_subtime
after insert on t1
for each row
insert into t2
values(subtime(new.c1,'01:00:00'),subtime(new.c2,'01:00:00'));

insert into t1 values(subtime('2022-09-10 00:00:00',0),subtime('2023-09-10 00:00:00',0));
