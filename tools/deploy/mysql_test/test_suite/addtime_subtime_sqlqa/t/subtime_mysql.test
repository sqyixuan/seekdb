--echo TIME-TC-4
--echo DML
--error 0,1051
drop table t1;
create table t1(c1 datetime);
insert into t1 values('2022-09-05 11:00:00');
insert into t1 values('2022-09-05 11:03:00');
insert into t1 values('2022-09-05 11:05:00');

select c1,subtime('2022-09-05 11:00:00',0) from t1;
select subtime('2022-09-05 11:00:00',1) as result from dual order by 1;
select subtime('2022-09-05 11:00:00',1) as result from dual group by 1;

insert into t1 values(subtime('2022-09-05 12:00:00',0));
alter table t1 add c2 datetime default null;
insert into t1(c1,c2) values(subtime('2022-09-05 12:00:00',0),subtime('2023-09-05 12:00:00',0));

insert into t1(c1,c2) values(subtime('2022-09-05 13:00:00',0),subtime('2023-09-05 13:00:00',0)),
(subtime('2022-09-05 14:00:00',0),subtime('2023-09-05 14:00:00',0)),
(subtime('2022-09-05 15:00:00',0),subtime('2023-09-05 15:00:00',0));


update t1 set c1 = subtime('2022-09-05 11:00:00','0');

update t1 set
c1 = subtime('2022-09-06 11:00:00','0'),
c2 = subtime('2022-09-07 11:00:00','0');


delete from t1 where c2 = subtime('2022-09-07 11:00:00','0');

--echo 运算符
insert into t1(c1,c2) values(subtime('2022-09-05 13:00:00',0),subtime('2023-09-05 13:00:00',0)),
(subtime('2022-09-05 14:00:00',0),subtime('2023-09-05 14:00:00',0)),
(subtime('2022-09-05 15:00:00',0),subtime('2023-09-05 15:00:00',0));

select c1 from t1 where c1 = subtime('2022-09-05 13:00:00',0);
select c1 from t1 where c1 < subtime('2022-09-05 14:00:00',0);
select c1 from t1 where c1 <= subtime('2022-09-05 14:00:00',1);
select c1 from t1 where c1 > subtime('2022-09-05 14:00:00',1);
select c1 from t1 where c1 >= subtime('2022-09-05 14:00:00',0);
select c1 from t1 where c1 != subtime('2022-09-05 15:00:00',0);
select c1 from t1 where c1 <> subtime('2022-09-05 15:00:00',1);

select c1,c2 from t1 where c1 = subtime('2022-09-05 14:00:01',-1) and c2 = subtime('2023-09-05 13:59:59',1);
select c1,c2 from t1 where c1 = subtime('2022-09-05 14:00:01',-1) or c2 = subtime('2023-09-05 14:59:59',1);
select c1,c2 from t1 where not c1 = subtime('2022-09-05 14:00:01',-1); 

select c1,c2 from t1 where c1 = subtime('2022-09-05 14:00:01',-1) and c2 is null;
select c1,c2 from t1 where c1 = subtime('2022-09-05 14:00:01',-1) and c2 is not null;

select c1,c2 from t1 where c1 in (subtime('2022-09-05 14:00:01',-1),subtime('2022-09-05 15:00:01',-1));
select c1,c2 from t1 where exists (select c1 from t1 where c1 = subtime('2022-09-05 13:00:00',0));
select c1,c2 from t1 where not exists (select c1 from t1 where c1 = subtime('2022-09-05 13:00:00',0));

select c1,c2 from t1 where c1 > any(select c1 from t1 where c1 > subtime('2022-09-05 13:00:00','-1'));
select c1,c2 from t1 where c1 < all(select c1 from t1 where c1 > subtime('2022-09-05 15:00:00','1'));
select c1,c2 from t1 where c1 between subtime('2022-09-05 13:00:00',1) and subtime('2022-09-05 15:00:00',-1);




--echo TIME-TC-5
--echo 分区表
--error 0,1051
drop table t1;
CREATE TABLE t1(c1 DATETIME)
PARTITION BY RANGE(day(c1))
(
PARTITION p10 VALUES LESS THAN (10),
 PARTITION p20 VALUES LESS THAN (20),
 PARTITION pmax VALUES LESS THAN (maxvalue)
);

insert into t1 values(subtime('2022-09-01 00:00:00','1 01:01:01')),
(subtime('2022-09-05 00:00:00','-1 02:02:02')),
(subtime('2022-09-11 00:00:00','1 03:03:03')),
(subtime('2022-09-19 00:00:00','-1 04:04:04')),
(subtime('2022-09-25 00:00:00','1 05:05:05'));

update t1 set c1 = subtime('2022-09-01 00:00:00','22 01:01:01') where c1 = subtime('2022-09-01 00:00:00','1 01:01:01');
select * from t1 partition(pmax) where c1 = subtime('2022-09-25 00:00:00','1 05:05:05');


--error 0,1051
drop table t1;
CREATE TABLE t1 (c1 INT, c2 varchar(20), c3 datetime) PARTITION BY RANGE(c1) 
SUBPARTITION BY KEY(c2, c3) SUBPARTITIONS 5
(PARTITION p0 VALUES LESS THAN(100), PARTITION p1 VALUES LESS THAN(10000000));

insert into t1(c1,c3) values(1,subtime('2022-09-01 00:00:00','1 01:01:01')),
(11,subtime('2022-09-05 00:00:00','-1 02:02:02')),
(111,subtime('2022-09-11 00:00:00','1 03:03:03')),
(1111,subtime('2022-09-19 00:00:00','-1 04:04:04')),
(11111,subtime('2022-09-25 00:00:00','1 05:05:05'));

select * from t1 partition (p0) order by 1;
select * from t1 partition (p1) order by 1;

update t1 set c2 = subtime(c3,'1 00:00:00') where c3 <= subtime('2022-09-10 00:00:00','100');
update t1 set c2 = subtime(c3,'-1 00:00:00') where c3 > subtime('2022-09-10 00:00:00','100');

delete from t1 where c2 = subtime('2022-09-11 00:00:00','03:03:03');
--disable_result_log
select *,subtime(sysdate(),0)from t1 order by 1;
--enable_result_log


--echo 视图
--error 0,1051
drop view v1;
create view v1 as select c1,c3 from t1;
select * from v1 order by 1;
insert into v1 values(111,subtime('2022-11-11 00:00:00',0));
delete from t1 where c3 = subtime('2022-09-25 01:01:01','1 04:04:04');
update t1 set c3 = subtime('2022-09-01 00:00:00','25:00:00') where c3 = subtime('2022-09-02 00:00:00','01:01:01');
select * from v1 order by 1;


