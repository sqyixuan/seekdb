select cast(subtime('1970-09-05 00:00:00',0) as char(20)) ;
select convert(subtime('1970-09-05 00:00:00',0),char(20)) ;


select subtime('2022-09-05 11:00:00',second('2017-05-15 10:37:14.123456')) as result ;
#select subtime('2022-09-05 11:00:00',minute('2017-05-15 10:37:14.123456')) as result ;
