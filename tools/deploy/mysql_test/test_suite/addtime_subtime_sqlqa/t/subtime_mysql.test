--echo 自定义函数
--error 0,1305
drop function f1;
delimiter /;
create function f1(aa datetime,bb time) returns varchar(20)
begin
	return subtime(aa,bb);
end;
/
delimiter ;/
select f1('2022-09-10 00:00:00','01:01:01');





