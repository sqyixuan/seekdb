             else '2022-09-05 00:00:00'
end as c3
from t1;
+---------------------+
| c3                  |
+---------------------+
| 1970-09-05 00:00:00 |
| 1970-09-05 00:00:00 |
| 2022-09-05 00:00:00 |
+---------------------+
