insert into t1(c2) values(addtime(date '2022-09-05','01:01:01'));
insert into t1(c3) values(addtime('2022-09-05 01:01:01','01:01:01'));
insert into t1(c4) values(addtime(timestamp '2022-09-05 01:01:01.000001','01:01:01.000001'));
insert into t1(c5) values(addtime('20220905010101','01:01:01'));
select * from t1;
