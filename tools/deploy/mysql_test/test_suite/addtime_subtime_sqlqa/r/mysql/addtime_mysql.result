insert into t1 values(1,'1970-09-05 00:00:00');
insert into t1 values(2,'1980-09-05 00:00:00');
insert into t1 values(3,'1990-09-05 00:00:00');
select case c2 when addtime('1970-09-05 00:00:00','0') then addtime('1970-09-05 00:00:00','100')
               else '2022-09-05 00:00:00'
end as c3
from t1;
