分区表
drop table t1;
CREATE TABLE t1(c1 DATETIME)
PARTITION BY RANGE(day(c1))
(
PARTITION p10 VALUES LESS THAN (10),
 PARTITION p20 VALUES LESS THAN (20),
 PARTITION pmax VALUES LESS THAN (maxvalue)
);
insert into t1 values(addtime('2022-09-01 00:00:00','1 01:01:01')),
(addtime('2022-09-05 00:00:00','-1 02:02:02')),
(addtime('2022-09-11 00:00:00','1 03:03:03')),
(addtime('2022-09-19 00:00:00','-1 04:04:04')),
(addtime('2022-09-25 00:00:00','1 05:05:05'));
update t1 set c1 = addtime('2022-09-01 00:00:00','22 01:01:01') where c1 = addtime('2022-09-01 00:00:00','1 01:01:01');
select * from t1 partition(pmax) where c1 = addtime('2022-09-25 00:00:00','1 05:05:05');
+---------------------+
| c1                  |
+---------------------+
| 2022-09-26 05:05:05 |
+---------------------+
drop table t1;
CREATE TABLE t1 (c1 INT, c2 varchar(20), c3 datetime) PARTITION BY RANGE(c1) 
SUBPARTITION BY KEY(c2, c3) SUBPARTITIONS 5
(PARTITION p0 VALUES LESS THAN(100), PARTITION p1 VALUES LESS THAN(10000000));
