drop procedure p1;
create procedure p1(in aa datetime)
 begin
  case 
  when aa < addtime('2022-09-05 00:00:00',0) then
    select '之前的时间' as result;
  when aa > addtime('2022-09-05 00:00:00',0) then
    select '以后的时间' as result;
  else
  select '就是现在' as result;
  end case;
 end /
call p1(addtime('2022-09-05 00:00:00',0);
