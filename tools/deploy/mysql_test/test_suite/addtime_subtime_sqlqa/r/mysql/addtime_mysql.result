| result       |
+--------------+
| 就是现在     |
+--------------+
call p1('2022-09-04 00:00:00');
+-----------------+
| result          |
+-----------------+
| 之前的时间      |
+-----------------+
drop procedure p1;
create procedure p1(in aa datetime,out bb datetime)
 begin
  set bb = '2022-09-05 00:00:00';
  while aa > bb do
    set bb = addtime(bb,'1 00:00:00');
    end while;
  select bb;
 end /
call p1('2022-09-10 00:00:00',@bb);
+---------------------+
| bb                  |
+---------------------+
| 2022-09-10 00:00:00 |
+---------------------+
触发器
drop table t1;
create table t1(c1 datetime,c2 datetime);
drop table t2;
create table t2(c1 datetime,c2 datetime);
drop trigger trg_addtime;
create trigger trg_addtime
after insert on t1
for each row
insert into t2
values(addtime(new.c1,'01:00:00'),addtime(new.c2,'01:00:00'));
insert into t1 values(addtime('2022-09-10 00:00:00',0),addtime('2023-09-10 00:00:00',0));
select * from t1;
+---------------------+---------------------+
| c1                  | c2                  |
+---------------------+---------------------+
| 2022-09-10 00:00:00 | 2023-09-10 00:00:00 |
+---------------------+---------------------+
select * from t2;
+---------------------+---------------------+
| c1                  | c2                  |
+---------------------+---------------------+
| 2022-09-10 01:00:00 | 2023-09-10 01:00:00 |
+---------------------+---------------------+
自定义函数
drop function f1;
create function f1(aa datetime,bb time) returns varchar(20)
begin
	return addtime(aa,bb);
end;
/
select f1('2022-09-10 00:00:00','01:01:01');
+--------------------------------------+
| f1('2022-09-10 00:00:00','01:01:01') |
+--------------------------------------+
| 2022-09-10 01:01:01                  |
+--------------------------------------+
TIME-TC-6 
字符集
