CREATE TABLE E_MP_DAY_READ(
    METER_ID VARCHAR(10),
    DATA_DATE DATE,
    COL_TIME DATE,
    INPUT_TIME DATE,
    PAP_R VARCHAR(10),
    PAP_R1 VARCHAR(10),
    PAP_R2 VARCHAR(10),
    PAP_R3 VARCHAR(10),
    PAP_R4 VARCHAR(10),
    PAP_ACQ_TIME DATE,
    PAP_R_QUALITY VARCHAR(10),
    PAP_R_DIFF_VALUE VARCHAR(10),
    RAP_R VARCHAR(10),
    RAP_R1 VARCHAR(10),
    RAP_R2 VARCHAR(10),
    RAP_R3 VARCHAR(10),
    RAP_R4 VARCHAR(10),
    RAP_ACQ_TIME DATE,
    RAP_R_QUALITY VARCHAR(10),
    RAP_R_DIFF_VALUE VARCHAR(10)
)PARTITION BY RANGE(DATA_DATE) (
    PARTITION P1 VALUES LESS THAN (TO_DATE('2023-07-02','YYYY-MM-DD')),
    PARTITION P2 VALUES LESS THAN (TO_DATE('2023-07-03','YYYY-MM-DD')),
    PARTITION P3 VALUES LESS THAN (TO_DATE('2023-07-04','YYYY-MM-DD'))
);

explain basic
MERGE INTO E_MP_DAY_READ f USING (
  SELECT
    '1' AS METER_ID,
    TO_DATE('2023-07-01', 'YYYY-MM-DD') AS DATA_DATE,
    TO_DATE('2023-07-01', 'YYYY-MM-DD') AS COL_TIME,
    TO_DATE('2023-07-01', 'YYYY-MM-DD') AS INPUT_TIME,
    'A' AS PAP_R,
    'B' AS PAP_R1,
    'C' AS PAP_R2,
    'D' AS PAP_R3,
    'E' AS PAP_R4,
    TO_DATE('2023-07-01', 'YYYY-MM-DD') AS PAP_ACQ_TIME,
    'F' AS PAP_R_QUALITY,
    'G' AS PAP_R_DIFF_VALUE,
    'H' AS RAP_R,
    'I' AS RAP_R1,
    'J' AS RAP_R2,
    'K' AS RAP_R3,
    'L' AS RAP_R4,
    TO_DATE('2023-07-01', 'YYYY-MM-DD') AS RAP_ACQ_TIME,
    'M' AS RAP_R_QUALITY,
    'N' AS RAP_R_DIFF_VALUE
  FROM
    DUAL
) S ON (
  F.METER_ID = S.METER_ID
  AND F.DATA_DATE = S.DATA_DATE
)
WHEN NOT MATCHED THEN
INSERT
  (
    F.METER_ID,
    F.DATA_DATE,
    F.COL_TIME,
    F.INPUT_TIME,
    F.PAP_R,
    F.PAP_R1,
    F.PAP_R2,
    F.PAP_R3,
    F.PAP_R4,
    F.PAP_ACQ_TIME,
    F.PAP_R_QUALITY,
    F.PAP_R_DIFF_VALUE,
    F.RAP_R,
    F.RAP_R1,
    F.RAP_R2,
    F.RAP_R3,
    F.RAP_R4,
    F.RAP_ACQ_TIME,
    F.RAP_R_QUALITY,
    F.RAP_R_DIFF_VALUE
  )
  values
  (
    s.METER_ID,
    s.DATA_DATE,
    s.COL_TIME,
    s.INPUT_TIME,
    s.PAP_R,
    s.PAP_R1,
    s.PAP_R2,
    s.PAP_R3,
    s.PAP_R4,
    s.PAP_ACQ_TIME,
    s.PAP_R_QUALITY,
    s.PAP_R_DIFF_VALUE,
    s.RAP_R,
    s.RAP_R1,
    s.RAP_R2,
    s.RAP_R3,
    s.RAP_R4,
    s.RAP_ACQ_TIME,
    s.RAP_R_QUALITY,
    s.RAP_R_DIFF_VALUE
  )
  WHEN MATCHED THEN
UPDATE
