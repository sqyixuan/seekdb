drop table t1;
drop table t2;
drop table tp1;
drop table tp2;
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
create table tp1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 2;
create table tp2(c1 int, c2 int, c3 int) partition by hash(c1) partitions 2;
create or replace view v1 as select * from tp1 order by 1;
create or replace view v2 as select * from tp1 where c1 = 3;
insert into t1 values (0,0,0);
insert into t1 values (1,1,1);
insert into t1 values (3,3,3);
insert into t1 values (4,4,4);
insert into t2 values (1,1,1);
insert into t2 values (2,2,2);
insert into t2 values (3,3,3);
insert into t2 values (4,4,4);
insert into t2 values (5,5,5);
insert into tp1 select * from t1;
insert into tp2 select * from t2;
result_format: 4
set autocommit = 0;

############################ test for insert ################################
explain basic
merge into t1 t1 using t2 t2 on (t1.c1 = t2.c1)
when not matched then insert values (t2.c1, t2.c2, t2.c3);
Query Plan
====================================
|ID|OPERATOR                 |NAME |
------------------------------------
|0 |INSERT                   |     |
|1 |└─SUBPLAN SCAN           |VIEW1|
|2 |  └─HASH RIGHT ANTI JOIN |     |
|3 |    ├─TABLE FULL SCAN    |T1   |
|4 |    └─TABLE FULL SCAN    |T2   |
====================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{T1: ({T1: (T1.__pk_increment, T1.C1, T1.C2, T1.C3)})}]), partitions(p0), 
      column_values([T_HIDDEN_PK], [column_conv(NUMBER,PS:(-1,0),NULL,VIEW1.T2.C1)], [column_conv(NUMBER,PS:(-1,0),NULL,VIEW1.T2.C2)], [column_conv(NUMBER,
      PS:(-1,0),NULL,VIEW1.T2.C3)])
  1 - output([VIEW1.T2.C1], [VIEW1.T2.C2], [VIEW1.T2.C3]), filter(nil), rowset=16
      access([VIEW1.T2.C1], [VIEW1.T2.C2], [VIEW1.T2.C3])
  2 - output([T2.C1], [T2.C2], [T2.C3]), filter(nil), rowset=16
      equal_conds([T1.C1 = T2.C1]), other_conds(nil)
  3 - output([T1.C1]), filter(nil), rowset=16
      access([T1.C1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T1.__pk_increment]), range(MIN ; MAX)always true
  4 - output([T2.C1], [T2.C2], [T2.C3]), filter(nil), rowset=16
      access([T2.C1], [T2.C2], [T2.C3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T2.__pk_increment]), range(MIN ; MAX)always true
merge into t1 t1 using t2 t2 on (t1.c1 = t2.c1)
when not matched then insert values (t2.c1, t2.c2, t2.c3);
select * from t1 order by 1;
+------+------+------+
| C1   | C2   | C3   |
+------+------+------+
|    0 |    0 |    0 |
|    1 |    1 |    1 |
|    2 |    2 |    2 |
|    3 |    3 |    3 |
|    4 |    4 |    4 |
|    5 |    5 |    5 |
+------+------+------+
rollback;

