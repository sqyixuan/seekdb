create table stu(s1 number primary key, s2 nvarchar2(64) not null, s3 integer default trunc(66.6666666,5), constraint stu_ch check( s2>1));
create table stu1(s1 number primary key, s2 nvarchar2(128) not null, s3 integer default trunc(88.8888888,5), constraint stu1_ch check(s1>1 and s2>1 and s3>1));
