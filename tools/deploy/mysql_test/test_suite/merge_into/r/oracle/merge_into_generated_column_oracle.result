drop table t1;
drop table t2;
create table t1 (c1 int primary key, c2 int, 
c3 decimal generated always as (c1 + c2), 
c4 int generated always as ((c1 + c2) * (c1 - c2)), 
c5 varchar(64) generated always as (to_char(c1 - c2)),
c6 decimal generated always as (c1 + c2 + 0) virtual);
create table t2 (c1 int primary key, c2 decimal);
insert into t2 values (1, 2.5), (2, 6.2), (3, 4.1);
result_format: 4
explain
merge into t1 using t2 on (t1.c1 = t2.c1) when not matched then insert (c1, c2) values (t2.c1, t2.c2);
Query Plan
======================================================
|ID|OPERATOR             |NAME |EST.ROWS|EST.TIME(us)|
------------------------------------------------------
|0 |INSERT               |     |2       |25          |
|1 |└─SUBPLAN SCAN       |VIEW1|2       |5           |
|2 |  └─MERGE ANTI JOIN  |     |2       |5           |
|3 |    ├─TABLE FULL SCAN|T2   |3       |3           |
|4 |    └─TABLE FULL SCAN|T1   |1       |3           |
======================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{T1: ({T1: (T1.C1, T1.C2)})}]), partitions(p0), 
      column_values([column_conv(NUMBER,PS:(-1,0),NOT NULL,VIEW1.T2.C1)], [column_conv(NUMBER,PS:(-1,0),NULL,VIEW1.T2.C2)])
  1 - output([VIEW1.T2.C1], [VIEW1.T2.C2]), filter(nil), rowset=16
      access([VIEW1.T2.C1], [VIEW1.T2.C2])
  2 - output([T2.C1], [T2.C2]), filter(nil), rowset=16
      equal_conds([T1.C1 = T2.C1]), other_conds(nil)
      merge_directions([ASC])
  3 - output([T2.C1], [T2.C2]), filter(nil), rowset=16
      access([T2.C1], [T2.C2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T2.C1]), range(MIN ; MAX)always true
  4 - output([T1.C1]), filter(nil), rowset=16
      access([T1.C1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T1.C1]), range(MIN ; MAX)always true
merge into t1 using t2 on (t1.c1 = t2.c1) when not matched then insert (c1, c2) values (t2.c1, t2.c2);
