drop database if exists mi_db;
create database mi_db;
use mi_db;
create table sourceTable(id int, sales int);
create table targetTable(id int, sales int);
create view targetView as select * from targetTable;
truncate table targetTable;
truncate table sourceTable;
insert into targetTable values(1,1),(2,2),(3,3);
insert into sourceTable values(1,2),(2,4),(3,6),(4,8);
merge into targetTable t1 using (select * from sourceTable) t2 on (t1.id = t2.id) when matched then update set t1.sales = t2.sales;
select * from targetTable;
id	sales
1	2
2	4
3	6
merge into targetTable t1 using (select * from sourceTable) t2 on (t1.id = t2.id) when matched then update set t1.sales = t2.sales * 2;
select * from targetTable;
id	sales
1	4
2	8
3	12
create table t1(c1 int primary key, c2 int);
create table t2(c1 int primary key, c2 int);
insert into t1 values(1,1),(2,2),(3,3);
insert into t2 values(1,2),(2,4),(3,6),(4,8);
merge into t1 using (select * from t2) t2 on (t1.c2 * 2 = t2.c2) when matched then update set t1.c1 = t2.c1 * 10;
select * from t1;
c1	c2
10	1
20	2
30	3
drop table t1,t2;
create table t1(c1 int, c2 int, c3 int, primary key(c1, c2));
create table t2(c1 int, c2 int, c3 int, primary key(c1, c2));
insert into t1 values(1,1,1),(2,2,2),(3,3,3);
insert into t2 values(1,2,2),(2,4,4),(3,6,6),(4,8,8);
merge into t1 using (select * from t2) t2 on (t1.c1 = t2.c1) when matched then update set t1.c2 = t2.c2;
select * from t1;
c1	c2	c3
1	2	1
2	4	2
3	6	3
drop table t1,t2;
create table t1(c1 int, c2 int, c3 int, unique key(c3, c2));
create table t2(c1 int, c2 int, c3 int, unique key(c3, c2));
insert into t1 values(1,1,1),(2,2,2),(3,3,3);
insert into t2 values(1,2,2),(2,4,4),(3,6,6),(4,8,8);
merge into t1 using (select * from t2) t2 on (t1.c1 = t2.c1) when matched then update set t1.c2 = t2.c2;
select * from t1;
c1	c2	c3
1	2	1
2	4	2
3	6	3
