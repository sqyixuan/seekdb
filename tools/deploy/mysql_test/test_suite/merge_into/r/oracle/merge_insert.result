2	2
3	3
4	8
5	9
delete from targetTable where id = 4 or id = 5;
merge into targetTable t1 using sourceTable t2 on (t1.id = t2.id) when not matched then insert(t1.id, t1.sales) values(t2.id, t2.sales) where t2.id > 4;
select * from targetTable;
id	sales
1	1
2	2
3	3
5	9
delete from targetTable where id = 4 or id = 5;
merge into targetTable t1 using sourceTable t2 on (t1.id = t2.id) when not matched then insert(t1.id, t1.sales) values(t2.id, t2.sales) where t2.id * 2 =  t2.sales;
select * from targetTable;
id	sales
1	1
2	2
3	3
4	8
truncate table targetTable;
truncate table sourceTable;
insert into targetTable values(1,1),(2,2),(3,3);
insert into sourceTable values(-1,-1),(-2,-2);
merge into targetTable t1 using sourceTable t2 on (t1.id < t2.id) when not matched then insert(t1.id, t1.sales) values(t2.id, t2.sales);
select * from targetTable;
id	sales
1	1
2	2
3	3
-1	-1
-2	-2
merge into targetTable t1 using sourceTable t2 on (1 = 2) when not matched then insert(t1.id, t1.sales) values(t2.id, t2.sales);
select * from targetTable;
