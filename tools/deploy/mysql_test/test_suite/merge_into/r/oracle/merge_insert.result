truncate table targetTable;
truncate table sourceTable;
insert into targetTable values(1,1),(2,2),(3,3);
insert into sourceTable values(1,2),(2,4),(3,6),(4,8),(5,9);
merge into targetTable t1 using sourceTable t2 on (t1.id = t2.id) when not matched then insert(t1.id, t1.sales) values(t2.id, t2.sales) where t2.id > 1;
select * from targetTable;
id	sales
