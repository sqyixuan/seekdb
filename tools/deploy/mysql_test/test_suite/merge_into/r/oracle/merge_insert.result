drop database if exists mi_db;
create database mi_db;
use mi_db;
create table sourceTable(id int, sales int);
create table targetTable(id int, sales int);
create view targetView as select * from targetTable;
truncate table targetTable;
truncate table sourceTable;
insert into targetTable values(1,1),(2,2),(3,3);
insert into sourceTable values(1,2),(2,4),(3,6),(4,8);
merge into targetTable t1 using sourceTable t2 on (t1.id = t2.id) when not matched then insert(t1.id, t1.sales) values(t2.id, t2.sales);
select * from targetTable;
id	sales
1	1
2	2
3	3
4	8
delete from targetTable where id = 4;
merge into targetTable t1 using sourceTable t2 on (t1.id = t2.id) when not matched then insert(t1.id, t1.sales) values(t2.id, 999);
select * from targetTable;
id	sales
1	1
2	2
3	3
4	999
delete from targetTable where id = 4;
merge into targetTable t1 using sourceTable t2 on (t1.id = t2.id) when not matched then insert(t1.id, t1.sales) values(4, 999);
select * from targetTable;
