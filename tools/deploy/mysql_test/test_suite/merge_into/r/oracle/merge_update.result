insert into t2 values(1,2,2),(2,4,4),(3,6,6),(4,8,8);
merge into t1 using t2 on (t1.c1 = t2.c1) when matched then update set t1.c2 = t1.c2 + t2.c2;
select * from t1;
c1	c2	c3
1	3	1
2	6	2
3	9	3
merge into t1 using t2 on (t1.c1 = t2.c1) when matched then update set t1.c2 = t2.c2 ,t1.c3=t2.c3;
select * from t1;
c1	c2	c3
1	2	2
2	4	4
3	6	6
merge into t1 using t2 on (t1.c1 = t2.c1) when matched then update set t1.c2 = abs(t2.c2 * -1) + 100;
select * from t1;
c1	c2	c3
1	102	2
2	104	4
3	106	6
