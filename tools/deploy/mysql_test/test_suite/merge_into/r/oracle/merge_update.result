create table a1(c1 int auto_increment, c2 int);
create table a2(c1 int, c2 int);
insert into a1 values(1,1),(2,2),(3,3);
insert into a2 values(1,2),(2,4),(3,6),(4,8);
merge into a1 using a2 on (a1.c1 = a2.c1) when matched then update set a1.c2 = a2.c2;
select * from a1;
c1	c2
1	2
2	4
3	6
truncate table a1;
truncate table a2;
insert into a1 values(1,1),(2,2),(3,3);
insert into a2 values(1,2),(2,4),(3,6),(4,8);
merge into a1 using a2 on (2 * a1.c2 = a2.c2) when matched then update set a1.c1 =  2* a2.c2;
select * from a1;
c1	c2
4	1
8	2
12	3
