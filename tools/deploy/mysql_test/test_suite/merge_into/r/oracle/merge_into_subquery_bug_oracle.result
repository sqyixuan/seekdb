create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create table tp(c1 int, c2 int) partition by hash(c1) partitions 5;
CREATE TABLE Z0CASE (z0_test0 CHAR(100),z0_test1 VARCHAR2(100) ,z0_test2 NCHAR(100), z0_test3 NVARCHAR2(100),z0_test4 DATE,z0_test5 NUMBER,z0_test6 CLOB,z0_test7 BLOB);
CREATE TABLE Z1CASE (z1_test0 CHAR(100),z1_test1 VARCHAR2(100) ,z1_test2 NCHAR(100), z1_test3 NVARCHAR2(100),z1_test4 DATE,z1_test5 NUMBER,z1_test6 CLOB,z1_test7 BLOB);
explain MERGE INTO Z0CASE a
USING z1case b
ON (a.z0_test1=(SELECT z1_test1+1 from(SELECT * FROM Z1CASE)WHERE z1_test0= 'abcabc') )
when matched then update set a.z0_test0=b.z1_test1;
