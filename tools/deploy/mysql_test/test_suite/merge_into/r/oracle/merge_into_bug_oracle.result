drop table t1;
CREATE TABLE t1 (
c0 VARCHAR2(1000),
c1 NUMBER(22, 6),
c2 NUMBER(22, 6),
c3 DATE
) partition by list(c3)
(partition "D20180731" values  (TO_DATE(' 2018-07-31 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN')),
partition "D20180831" values  (TO_DATE(' 2018-08-31 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN')),
partition "D20180930" values  (TO_DATE(' 2018-09-30 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN')));
explain MERGE INTO t1 a1
USING (
SELECT b1.c0,
MAX(b1.c1) AS c1_max,
MAX(b1.c2) AS c2_max
FROM t1 b1
WHERE b1.c3 = DATE '2024-6-30'
    GROUP BY b1.c0
) a2
ON (a1.c3 = DATE '2024-6-30' AND a1.c0 = a2.c0)
WHEN MATCHED THEN
UPDATE SET
a1.c1 = a2.c1_max,
a1.c2 = a2.c2_max
WHERE a1.c3 = DATE '2024-6-30';
Query Plan
=======================================================
|ID|OPERATOR               |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------------
|0 |MERGE                  |    |1       |6           |
|1 |└─HASH JOIN            |    |1       |6           |
|2 |  ├─SUBPLAN SCAN       |A2  |1       |3           |
|3 |  │ └─HASH GROUP BY    |    |1       |3           |
|4 |  │   └─TABLE FULL SCAN|B1  |1       |3           |
|5 |  └─TABLE FULL SCAN    |A1  |1       |3           |
=======================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{A1: ({T1: (A1.__pk_increment, A1.C0, A1.C1, A1.C2, A1.C3)})}]),
      update([A1.C1=column_conv(DECIMAL_INT,PS:(22,6),NULL,A2.C1_MAX)], [A1.C2=column_conv(DECIMAL_INT,PS:(22,6),NULL,A2.C2_MAX)]), 
      insert_conds(nil), update_conds(nil), delete_conds(nil)
  1 - output([A1.__pk_increment], [A1.C0], [A1.C1], [A1.C2], [A1.C3], [A2.C1_MAX], [A2.C2_MAX]), filter(nil), rowset=16
      equal_conds([A1.C0 = A2.C0]), other_conds(nil)
  2 - output([A2.C0], [A2.C1_MAX], [A2.C2_MAX]), filter(nil), rowset=16
      access([A2.C0], [A2.C1_MAX], [A2.C2_MAX])
  3 - output([B1.C0], [T_FUN_MAX(B1.C1)], [T_FUN_MAX(B1.C2)]), filter(nil), rowset=16
      group([B1.C0]), agg_func([T_FUN_MAX(B1.C1)], [T_FUN_MAX(B1.C2)])
  4 - output([B1.C0], [B1.C1], [B1.C2]), filter([B1.C3 = '2024-06-30 00:00:00']), rowset=16
      access([B1.C3], [B1.C0], [B1.C1], [B1.C2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([B1.__pk_increment]), range(MIN ; MAX)always true
  5 - output([A1.__pk_increment], [A1.C3], [A1.C0], [A1.C1], [A1.C2]), filter([A1.C3 = '2024-06-30 00:00:00']), rowset=16
      access([A1.__pk_increment], [A1.C3], [A1.C0], [A1.C1], [A1.C2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([A1.__pk_increment]), range(MIN ; MAX)always true
