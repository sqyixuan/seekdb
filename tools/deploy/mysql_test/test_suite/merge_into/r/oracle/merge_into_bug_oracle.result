create table Orders(
order_num int,
order_date date default sysdate,
cust_id varchar(10),
CONSTRAINT index_num UNIQUE (order_num));
insert into Orders values(110012345,to_date('2020-11-11 00:00:00','yyyy-mm-dd hh24:mi:ss'),'Kelly');
insert into Orders values(110012346,to_date('2020-12-12 12:12:12','yyyy-mm-dd hh24:mi:ss'),'Julie');
create table OrderItems(
order_num int  primary key REFERENCES Orders(order_num),
order_item int,
prod_id int,
foreign key(prod_id) REFERENCES Products(prod_id) ,
quantity int default 1,
item_price number(8,2));
insert into OrderItems values(110012345,998772,1254,100,399.33);
insert into OrderItems values(110012346,998772,1254,200,299.99);
explain merge into OrderItems c using Products e
on (c.prod_id=e.prod_id and e.prod_id=1254)
when matched then
update set c.item_price=e.price
when not matched then 
insert values(110012347,998772,1254,300,588.99);
