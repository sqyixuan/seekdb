drop table test;
drop table test2;
CREATE TABLE test(f1 NUMBER,f2 binary_float,f3 nchar(10),f4 DATE);
INSERT INTO test VALUES(10,101,'aaa',TO_DATE('19700101','yyyymmdd'));
INSERT INTO test VALUES(11,111,'bbb',TO_DATE('19800101','yyyymmdd'));
INSERT INTO test VALUES(12,121,'ccc',TO_DATE('19900101','yyyymmdd'));
INSERT INTO test VALUES(13,131,'ddd',TO_DATE('20000101','yyyymmdd'));
INSERT INTO test VALUES(14,141,'eee',TO_DATE('20100101','yyyymmdd'));
INSERT INTO test VALUES(18,181,'iii',TO_DATE('20500101','yyyymmdd'));
INSERT INTO test VALUES(19,191,'jjj',TO_DATE('20600101','yyyymmdd'));
COMMIT;
CREATE TABLE test2(f1 NUMBER,f2 binary_float PRIMARY KEY,f3 nchar(10),f4 DATE);
DELETE FROM test2;
INSERT INTO test2 SELECT * FROM test;
COMMIT;
MERGE INTO test2 a USING test b
ON (a.f1=b.f1)
WHEN MATCHED THEN
UPDATE SET f2=a.f2+20, f3=rtrim(a.f3)||'_1', f4=a.f4+numtoyminterval(20,'year')
DELETE WHERE a.f2>=141;
COMMIT;
SELECT * FROM test2 ORDER BY 1;
