CREATE TABLE Z1CASE (z1_test0 varchar2(100),z1_test1 NUMBER ,z1_test2 binary_float);
INSERT INTO Z1CASE VALUES ('11111.1111',4,6.666);
INSERT INTO Z1CASE VALUES ('!@#$%^&*',3,7.777);
INSERT INTO Z1CASE VALUES ('abc中文 字符123',2,8.888);
INSERT INTO Z1CASE VALUES (' ',1,9.999);
MERGE INTO Z0CASE a USING Z1CASE b ON (a.z0_test1=b.z1_test1)
WHEN matched THEN UPDATE SET a.z0_test0=b.z1_test0
DELETE WHERE (z0_test0, z0_test1) IN (WITH myCTE(ZA1,ZB1) AS (SELECT z1_test0 AS ZA1, z1_test1+2 AS ZB1 FROM Z1CASE WHERE z1_test1>3 UNION ALL SELECT Z0.z0_test0, Z0.z0_test1 FROM Z0CASE Z0 INNER JOIN myCTE ON myCTE.ZB1=Z0.z0_test1 WHERE Z0.z0_test1 IS NOT NULL) SELECT * FROM myCTE);
COMMIT;
