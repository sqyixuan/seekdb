CREATE TABLE Z1CASE (z1_test0 CHAR(100),z1_test1 VARCHAR2(100) ,z1_test2 NCHAR(100), z1_test3 NVARCHAR2(100),z1_test4 DATE,z1_test5 NUMBER,z1_test6 CLOB,z1_test7 BLOB);
MERGE INTO Z0CASE a USING (SELECT ZA ,ZB,ZC FROM (SELECT z1_test6 ZA,z1_test5 ZB,z1_test2 ZC FROM Z1CASE Z1 ) ) b
ON (a.z0_test5=b.ZB) when   matched then UPDATE SET z0_test0=(SELECT z1_test6 FROM (SELECT * FROM Z1CASE) WHERE z1_test5=5)
WHERE ZA <some (SELECT z0_test0 FROM  (SELECT * FROM z0case));
