create table stu(s1 number, s2 nvarchar2(64) not null, s3 integer default trunc(66.6666666,5), CONSTRAINT "STUOBPK1" PRIMARY KEY (s1), constraint stu_ch check( s2>1)) partition by hash(s1);
create index stu_index on stu(s3) global;
create table stu1(s1 number, s2 nvarchar2(128) not null, s3 integer default trunc(88.8888888,5), CONSTRAINT "STU1OBPK1" PRIMARY KEY (s1), constraint stu1_ch check(s1>1 and s2>1 and s3>1));
