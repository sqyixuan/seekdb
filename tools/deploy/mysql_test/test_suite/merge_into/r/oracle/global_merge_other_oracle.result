create table t1(c1 int, c2 int, CONSTRAINT "T1OBPK1" PRIMARY KEY (c1)) partition by hash(c1) partitions 4;
create table t2(c1 int, c2 int, CONSTRAINT "T2OBPK1" PRIMARY KEY (c1));
create index gkey on t1(c2) global;
insert into t1 values(1, 2);
insert into t2 values(1, 4);
insert into t2 values(2, 5);
alter table t1 enable row movement;

explain merge into t1 using t2 on (t2.c1 = t1.c1) when matched then update set t1.c2 = 10 delete where t1.c2 = 10 when not matched then insert values(1, 100);
