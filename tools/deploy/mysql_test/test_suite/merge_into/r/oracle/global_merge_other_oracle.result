drop table gindex_table;
drop table gindex_table2;
create table gindex_table(c1 number primary key, c2 number, c3 number) enable row movement partition by hash(c1) partitions 5;

create table gindex_table2(c1 number primary key, c2 number, c3 number) enable row movement partition by hash(c1) partitions 5;

create unique index gindex_table_idx on gindex_table(c2) global partition by hash(c2) partitions 4;
create index gindex_table2_idx on gindex_table2(c2) global partition by hash(c2) partitions 4;

merge into gindex_table t1 using gindex_table2 t2 on (t1.c2 = t2.c2) WHEN MATCHED THEN UPDATE SET t1.c3 = t2.c3 WHEN NOT MATCHED THEN insert (t1.c1,t1.c2,t1.c3) values(t2.c1,t2.c2,t2.c3);

## bug: 
drop table t1;
drop table t2;
drop sequence s1;

create table t1 (c1 int, c2 int);
create table t2 (c1 int, c2 int);
create sequence s1;

insert into t1 values (1, 0);
insert into t1 values (4, 0);
insert into t1 values (5, 0);
insert into t2 values (1, -1);
insert into t2 values (2, -1);
insert into t2 values (3, -1);
insert into t2 values (5, -1);

start transaction;
merge into t1 using t2 on (t1.c1 = t2.c1)
  when matched then update set t1.c2 = s1.nextval
  when not matched then insert values (s1.nextval, s1.currval);

select * from t1;
+------+------+
| C1   | C2   |
+------+------+
|    1 |    1 |
|    3 |    3 |
|    4 |    0 |
|    4 |    4 |
|    5 |    2 |
+------+------+
rollback;

start transaction;
merge into t1 using t2 on (t1.c1 = t2.c1)
  when matched then update set t1.c2 = -3
  when not matched then insert values (s1.nextval, -2);

select * from t1;
+------+------+
| C1   | C2   |
+------+------+
|    1 |   -3 |
|    4 |    0 |
|    5 |   -3 |
|    7 |   -2 |
|    8 |   -2 |
+------+------+
rollback;

create index idx_test_merge on t1 (c1) partition by hash(c1) partitions 4;
start transaction;
merge into t1 using t2 on (t1.c1 = t2.c1)
  when matched then update set t1.c2 = s1.nextval
  when not matched then insert values (s1.nextval, s1.currval);

select * from t1;
+------+------+
| C1   | C2   |
+------+------+
|    1 |    9 |
|    4 |    0 |
|    5 |   10 |
|   11 |   11 |
|   12 |   12 |
+------+------+
rollback;

start transaction;
merge into t1 using t2 on (t1.c1 = t2.c1)
  when matched then update set t1.c2 = -3
  when not matched then insert values (s1.nextval, -2);

select * from t1;
+------+------+
| C1   | C2   |
+------+------+
|    1 |   -3 |
|    4 |    0 |
|    5 |   -3 |
|   15 |   -2 |
|   16 |   -2 |
+------+------+
rollback;

## corner cases
merge into t1 using (select s1.nextval x1, s1.currval x2 from dual) v on (v.x1 = t1.c1)
  when matched then update set t1.c2 = v.x1;
ERROR HY000: sequence number not allowed here

merge into t1 using t2 on (t1.c1 = t2.c1) when not matched then insert (s1.nextval, c2) values (t2.c1, t2.c2);
ERROR 42S22: invalid identifier 'S1.NEXTVAL' in 'field list'

merge into t1 using t2 on (t1.c1 = t2.c1) when matched then update set s1.nextval = t2.c2;
ERROR 42S22: invalid identifier 'S1.NEXTVAL' in 'field list'

drop table t1;
drop table t2;
drop sequence s1;
