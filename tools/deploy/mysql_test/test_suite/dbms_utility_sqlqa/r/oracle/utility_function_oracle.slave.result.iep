##存在循环及判断+不同调用语句
create or replace procedure cai_pro1 is
type cai_nested is table of number;
v_nested cai_nested:=cai_nested(dbms_utility.get_hash_value('aa',1,2),dbms_utility.get_hash_value('aa',1,2));
a number:=0;
begin
for i in v_nested.first ..v_nested.last loop
if a=dbms_utility.get_hash_value('aa',1,2) then
 dbms_output.put_line('if中 get_hash_value: '||dbms_utility.get_hash_value('aa',1,2));
 case a when dbms_utility.get_hash_value('aa',1,2) then
 dbms_output.put_line('case中 get_hash_value: '||dbms_utility.get_hash_value('aa',1,2));
 end case;
end if;
dbms_output.put_line('循环中get_hash_value: '||dbms_utility.get_hash_value('aa',1,2));
end loop;
end;
//

call cai_pro1();//
select println() from dual;//
