##复杂数据类型（collect+record）+匿名块
##由于 get_time 不停变化，故暂不输出
declare
type cai_nested is table of varchar2(200);
v_nested cai_nested:=cai_nested(dbms_utility.get_endianness,dbms_utility.port_string,dbms_utility.old_current_schema,dbms_utility.old_current_user,dbms_utility.get_time);

a varchar2(20);
type cai_array is table of varchar2(200) index by pls_integer;
v_array cai_array;

type cai_varry is varray(5) of varchar2(200);
v_varry cai_varry:=cai_varry(dbms_utility.get_endianness,dbms_utility.port_string,dbms_utility.old_current_schema,dbms_utility.old_current_user,dbms_utility.get_time);

type cai_record is record (r_put1 varchar2(200),r_put2 varchar2(200),r_put3 varchar2(200),r_put4 varchar2(200),r_put5 varchar2(200));
v_record cai_record;

begin
a:=v_nested.first;
dbms_output.put_line('a:'||a||'   v_nested(a): '||v_nested(1)||' '||v_nested(2)||' '||v_nested(3)||' '||v_nested(4));
--dbms_output.put_line('v_nested(5): '||v_nested(5));

v_array(1):=dbms_utility.get_endianness;
v_array(2):=dbms_utility.port_string;
v_array(3):=dbms_utility.old_current_schema;
v_array(4):=dbms_utility.old_current_user;
v_array(5):=dbms_utility.get_time;
dbms_output.put_line('v_array(2):'||v_array(1)||' '||v_array(2)||' '||v_array(3)||' '||v_array(4));
--dbms_output.put_line('v_array(5): '||v_array(5));

a:=v_varry.first;
dbms_output.put_line('a:'||a||'   v_varry(a): '||v_varry(1)||' '||v_varry(2)||' '||v_varry(3)||' '||v_varry(4));
--dbms_output.put_line('v_varry(5): '||v_varry(5));

v_record.r_put1:=dbms_utility.get_endianness;
v_record.r_put2:=dbms_utility.port_string;
v_record.r_put3:=dbms_utility.old_current_schema;
v_record.r_put4:=dbms_utility.old_current_user;
v_record.r_put5:=dbms_utility.get_time;
dbms_output.put_line('v_record.r_put1: '||v_record.r_put1||' '||v_record.r_put2||' '||v_record.r_put3||' '||v_record.r_put4);
--dbms_output.put_line('v_record.r_put5: '||v_record.r_put5);
end;
