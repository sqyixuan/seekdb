a varchar2(20);
type cai_array is table of varchar2(2000) index by pls_integer;
v_array cai_array;

type cai_varry is varray(5) of varchar2(2000);
v_varry cai_varry:=cai_varry(dbms_utility.format_call_stack);

type cai_record is record (r_put varchar2(2000));
v_record cai_record;

begin
a:=v_nested.first;
