+-----------------------------------------------------------+------------------------------------------------+-------------------------------------------------------------+
| DBMS_UTILITY.IS_BIT_SET(UTL_RAW.CAST_TO_RAW('5247'),22)+1 | TO_CHAR(DBMS_UTILITY.IS_BIT_SET('52476546',9)) | LENGTH(DBMS_UTILITY.IS_BIT_SET(HEXTORAW('524765464545'),9)) |
