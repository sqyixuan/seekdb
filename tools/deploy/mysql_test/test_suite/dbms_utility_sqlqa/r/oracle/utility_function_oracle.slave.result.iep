##type+占位符
create or replace type cai_type as object(
a number,
member procedure type_pro,
member function type_func return boolean
);
//
create or replace type body cai_type is
member procedure type_pro is
a number;
b boolean:=true;
begin
select count(*) into a from cai_1 where id=(case dbms_utility.is_cluster_database when b then 1 else 0 end);
dbms_output.put_line('a:'||a);
end;
member function type_func return boolean is
a number;
b boolean:=true;
begin
select count(*) into a from cai_1 where id=(case dbms_utility.is_cluster_database when b then 1 else 0 end);
dbms_output.put_line('a:'||a);
return dbms_utility.is_cluster_database;
end;
end;
//

declare
a boolean:=false;
v_type cai_type:=cai_type(1);
begin
v_type.type_pro();
a:=v_type.type_func();
case a when true then dbms_output.put_line('is true');
when false then dbms_output.put_line('is false');
end case;
end;
