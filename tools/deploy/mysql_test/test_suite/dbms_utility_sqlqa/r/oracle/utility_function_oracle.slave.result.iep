##嵌套使用（匿名块嵌匿名块，匿名块嵌过程等）
begin
 for i in 1 ..2 loop
 begin
 dbms_output.put_line('第 '||i||' 次');
 dbms_output.put_line(dbms_utility.get_endianness||' '||dbms_utility.port_string||' '||dbms_utility.old_current_schema||' '||dbms_utility.old_current_user);
 end;
 end loop;
