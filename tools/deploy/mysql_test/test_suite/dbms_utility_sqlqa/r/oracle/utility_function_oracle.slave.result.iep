| PRINTLN() |
+-----------+
| NULL      |
+-----------+

##作为return 返回值(存在链接符+存在运算符)
create or replace function cai_func return varchar2 is
begin
return dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22)||dbms_utility.is_bit_set('52476546',9)||dbms_utility.is_bit_set(HEXTORAW('524765464545'),9);
end;
//
