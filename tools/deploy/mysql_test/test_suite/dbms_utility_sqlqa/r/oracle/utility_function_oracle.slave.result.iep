##嵌套使用（匿名块嵌匿名块，匿名块嵌过程等）
begin
 for i in 1 ..2 loop
 begin
 dbms_output.put_line('第 '||i||' 次');
 dbms_output.put_line(dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22)||dbms_utility.is_bit_set('52476546',9)||dbms_utility.is_bit_set(HEXTORAW('524765464545'),9));
 end;
 end loop;
dbms_output.put_line('嵌套匿名块外的输出'||dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22)||dbms_utility.is_bit_set('52476546',9)||dbms_utility.is_bit_set(HEXTORAW('524765464545'),9));
end;
//
select println() from dual;//
+--------------------------------------------------------------------+
| PRINTLN()                                                          |
+--------------------------------------------------------------------+
| 第 1 次
  111
  第 2 次
  111
  嵌套匿名块外的输出111              |
+--------------------------------------------------------------------+

declare
 procedure an_pro is
  begin
  dbms_output.put_line('嵌套存储过程的输出'||dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22)||dbms_utility.is_bit_set('52476546',9)||dbms_utility.is_bit_set(HEXTORAW('524765464545'),9));
  end;
begin
  an_pro;
end;
//
select println() from dual;//
+--------------------------------+
| PRINTLN()                      |
+--------------------------------+
| 嵌套存储过程的输出111          |
+--------------------------------+

