##type类型+自定义+预定义（pls_integer）
create or replace type cai_type1 is table of number;
//
create or replace package cai_pack1 is
 subtype cai_simple is number;
 v_value1 cai_simple:=dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22);
 v_value2 cai_simple:=dbms_utility.is_bit_set('52476546',9);
 v_value3 cai_simple:=dbms_utility.is_bit_set(HEXTORAW('524765464545'),9);
 v_value4 cai_type1:=cai_type1();
 v_value5 pls_integer:=dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22);
 v_value6 pls_integer:=dbms_utility.is_bit_set('52476546',9);
 v_value7 pls_integer:=dbms_utility.is_bit_set(HEXTORAW('524765464545'),9);
end;
//
##调用语句
begin
cai_pack1.v_value4:=cai_type1(dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22),dbms_utility.is_bit_set('52476546',9),dbms_utility.is_bit_set(HEXTORAW('524765464545'),9));
dbms_output.put_line('自定义：'||cai_pack1.v_value1||' '||cai_pack1.v_value2||' '||cai_pack1.v_value3);
dbms_output.put_line('type类：'||cai_pack1.v_value4(1)||' '||cai_pack1.v_value4(2)||' '||cai_pack1.v_value4(3));
dbms_output.put_line('预定义：'||cai_pack1.v_value5||' '||cai_pack1.v_value6||' '||cai_pack1.v_value7);
end;
//
select println() from dual;//
+---------------------------------------------------------+
| PRINTLN()                                               |
+---------------------------------------------------------+
| 自定义：1 1 1
  type类：1 1 1
  预定义：1 1 1           |
+---------------------------------------------------------+

##作为参数+参数类型为in out inout+嵌套pl
create or replace procedure cai_pro(a number,b in out number,c out number) is
begin
c:=b;
dbms_output.put_line('a:  '||a);
dbms_output.put_line('b:  '||b);
dbms_output.put_line('c:  '||c);
end;
//
declare
procedure cai_pro1 is
c number:=dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22);
begin
cai_pro(dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22),c,c);

c:=dbms_utility.is_bit_set('52476546',9);
cai_pro(dbms_utility.is_bit_set('52476546',9),c,c);

c:=dbms_utility.is_bit_set(HEXTORAW('524765464545'),9);
cai_pro(dbms_utility.is_bit_set(HEXTORAW('524765464545'),9),c,c);
end;

begin
cai_pro1;
end;
//
select println() from dual;//
+-----------------------------------------------------------------------+
| PRINTLN()                                                             |
+-----------------------------------------------------------------------+
| a:  1
  b:  1
  c:  1
  a:  1
  b:  1
  c:  1
  a:  1
  b:  1
  c:  1 |
+-----------------------------------------------------------------------+

##in out 类型参数中传入固定值，oracle报错，ob成功，为已知问题
call cai_pro(dbms_utility.is_bit_set('52476546',9),1,1);//
ERROR HY000: wrong number or types of arguments in call to procedure
select println() from dual;//
