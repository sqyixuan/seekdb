##循环输出每个值
declare
a raw(50):='6524511';
b number:=(length(a)-8)*0.5*8+72;
c number:=-((length(a)-8)*0.5*8+6);
begin
dbms_output.put_line('传入raw值为：'||a);
for i in c ..b loop
dbms_output.put_line('i：'||i||' 值为：'||dbms_utility.is_bit_set(a,i));
end loop;
end;
//
select println() from dual;
