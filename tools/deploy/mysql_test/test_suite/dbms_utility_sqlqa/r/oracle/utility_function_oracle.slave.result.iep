##存在循环及判断+不同调用语句
create or replace procedure cai_pro1 is
a number:=1;
c varchar2(2000);
begin
loop
if a<3 then
dbms_output.put_line('--------------');
c:=dbms_utility.format_call_stack;
select regexp_replace(c,'0x[a-z0-9]{12}','1') into c from dual;
dbms_output.put_line('c: '||c);
a:=a+1;
else
dbms_output.put_line('介是最后一次啦');
c:=dbms_utility.format_call_stack;
select regexp_replace(c,'0x[a-z0-9]{12}','1') into c from dual;
dbms_output.put_line('c: '||c);
return;
end if;
end loop;
end;
//
##32135756，[pl dbms_utility]验证存储过程中format_call_stack，call调用和匿名块调用输出的结果不一致（稳定复现），预期结果：ob执行结果等同于oracle结果
call cai_pro1();//
select println() from dual;//
