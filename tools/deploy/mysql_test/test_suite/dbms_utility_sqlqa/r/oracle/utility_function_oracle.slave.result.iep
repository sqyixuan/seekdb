##游标（显式+弱游标+游标变量）
declare
Type cai_cursor IS Ref Cursor;
a number;
b varchar2(2000);
c varchar2(2000);
v_c cai_cursor;
begin
a:='a';
exception when others then 
open v_c for select dbms_utility.format_error_backtrace,dbms_utility.FORMAT_ERROR_STACK from dual;
fetch v_c into b,c;
dbms_output.put_line('b:'||b||'  c:'||c);
dbms_output.put_line('a: '||dbms_utility.format_error_backtrace||' b: '||dbms_utility.FORMAT_ERROR_STACK);
end;
//
select println() from dual;//
+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                                                                                |
+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| b:at anonymous block, line: 8
  c:OBE-13fa: OBE-01722: invalid number
at anonymous block, line: 8

  a: at anonymous block, line: 8
 b: OBE-13fa: OBE-01722: invalid number
at anonymous block, line: 8
 |
+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+

declare
a number;
cursor v_c is select dbms_utility.format_error_backtrace b,dbms_utility.FORMAT_ERROR_STACK c from dual;
begin
a:='a';
exception when others then 
for v_cursor in v_c loop
dbms_output.put_line('b:'||v_cursor.b||'  c:'||v_cursor.c);
end loop;
dbms_output.put_line('a: '||dbms_utility.format_error_backtrace||' b: '||dbms_utility.FORMAT_ERROR_STACK);
end;
//
select println() from dual;//
+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                                                                                |
+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| b:at anonymous block, line: 5
  c:OBE-13fa: OBE-01722: invalid number
at anonymous block, line: 5

  a: at anonymous block, line: 5
 b: OBE-13fa: OBE-01722: invalid number
at anonymous block, line: 5
 |
+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+

declare
a number;
cursor v_c(b varchar2,c varchar2) is select b,c from dual;
begin
a:='a';
exception when others then 
for v_cursor in v_c(dbms_utility.format_error_backtrace,dbms_utility.FORMAT_ERROR_STACK) loop
dbms_output.put_line('b:'||v_cursor.b||'  c:'||v_cursor.c);
end loop;
end;
