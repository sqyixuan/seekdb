##collect+record
declare
a number;
type cai_nested is table of varchar2(2000);
v_nested cai_nested:=cai_nested();

type cai_array is table of varchar2(2000) index by pls_integer;
v_array cai_array;

type cai_varry is varray(5) of varchar2(2000);
v_varry cai_varry:=cai_varry();

type cai_record is record (r_put varchar2(2000),r_put2 varchar2(2000));
v_record cai_record;

begin
a:='a';
exception when others then
v_nested:=cai_nested(dbms_utility.format_error_backtrace,dbms_utility.format_error_stack);
dbms_output.put_line('a:'||v_nested.first||'   v_nested(v_nested.first): '||v_nested(v_nested.first)||'a:'||v_nested.next(0)||'   v_nested(v_nested.next): '||v_nested(v_nested.next(0)));

v_array(1):=dbms_utility.format_error_backtrace;
v_array(2):=dbms_utility.format_error_stack;
dbms_output.put_line('v_array(1):'||v_array(1)||' v_array(2):'||v_array(2));

v_varry:=cai_varry(dbms_utility.format_error_backtrace,dbms_utility.format_error_stack);
dbms_output.put_line('a:'||v_varry.first||'   v_varry(v_varry.first): '||v_varry(v_varry.first)||'a:'||v_varry.next(0)||'   v_varry(v_varry.next): '||v_varry(v_varry.next(0)));

v_record.r_put:=dbms_utility.format_error_backtrace;
v_record.r_put2:=dbms_utility.format_error_stack;
dbms_output.put_line('v_record.r_put: '||v_record.r_put||' v_record.r_put2: '||v_record.r_put2);
end;
