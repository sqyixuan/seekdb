##package+dml+sql 
create or replace package cai_pack as
procedure pack_pro;
function pack_func return number;
end;
//
create or replace package body cai_pack as
procedure pack_p_proc is
c number;
begin
select (dbms_utility.get_hash_value('aa',1,2))b into c from dual;
dbms_output.put_line('查看get_hash_value:'||c);
end;
procedure pack_pro is
type cai_nested is table of number;
v_nested cai_nested:=cai_nested();
begin
for i in 1 ..2 loop
insert into cai_3 values(dbms_utility.get_hash_value('aa',1,2),2) return id3 bulk collect into v_nested;
end loop;
dbms_output.put_line('v_nested(1):'||v_nested(1));
insert into cai_3 select (dbms_utility.get_hash_value('aa',1,2)) b,2 from dual;
pack_p_proc();
end;
function pack_func return number is
c number;
begin
update cai_3 set id3=dbms_utility.get_hash_value('aa',1,2) where name3=1 return id3 into c;
return c;
end;
end cai_pack;
//

call cai_pack.pack_pro();//
select println() from dual;//
+----------------------------------------+
| PRINTLN()                              |
+----------------------------------------+
| v_nested(1):2
  查看get_hash_value:2   |
+----------------------------------------+

declare
a number;
begin
a:=cai_pack.pack_func;
dbms_output.put_line('a:'||a);
end;
//
select println() from dual;//
+-----------+
| PRINTLN() |
+-----------+
| a:2       |
+-----------+
select * from cai_3;//
+------+-------+
| ID3  | NAME3 |
+------+-------+
|    2 |     1 |
|    2 |     2 |
|    2 |     2 |
|    2 |     2 |
+------+-------+

##type+delete+动态sql执行
create or replace type cai_type as object(
a number,
member procedure type_pro,
member function type_func return varchar2
);
//
create or replace type body cai_type is
member procedure type_pro is
begin
execute immediate 'delete from cai_3 where id3 like :1' using dbms_utility.get_hash_value('aa',1,2);
end;
member function type_func return varchar2 is
a number;
begin
insert into cai_3 values(dbms_utility.get_hash_value('aa',1,2),1);
execute immediate 'select dbms_utility.get_hash_value(''aa'',1,2) from dual' into a;
return a;
end;
end;
//

declare
v_type cai_type:=cai_type(1);
a number;
begin
v_type.type_pro;
a:=v_type.type_func();
dbms_output.put_line('a:'||a);
end;
