 procedure an_pro is
  begin
  dbms_output.put_line('嵌套存储过程的输出: '||dbms_utility.get_endianness||' '||dbms_utility.port_string||' '||dbms_utility.old_current_schema||' '||dbms_utility.old_current_user);
  end;
begin
  an_pro;
end;
