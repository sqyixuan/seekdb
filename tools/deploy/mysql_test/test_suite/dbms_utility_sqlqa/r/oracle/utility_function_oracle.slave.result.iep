##触发器+函数（to_char，运算等）
create table c2(v2 varchar2(2000),v22 varchar2(2000),remark varchar2(2000));//
delete from c1;//
delete from c2;//
create or replace trigger cai_trig  after insert or delete or update on c1
for each row
declare
a varchar2(2000);
begin
a:=to_date(1);
exception when others then
if inserting then
insert into c2 select to_char(dbms_utility.format_error_backtrace),to_char(dbms_utility.format_error_stack),1 from dual;
end if;

if updating then
update c2 set v2=length(dbms_utility.format_error_backtrace),v22=substr(dbms_utility.format_error_stack,1,5),remark=dbms_utility.format_error_backtrace||dbms_utility.format_error_stack;
end if;

if deleting then
execute immediate 'select dbms_utility.format_error_backtrace||dbms_utility.format_error_stack from dual' into a;
dbms_output.put_line('a:'||a);
end if;
end;
