##创建warning的type
create or replace type cai_type as object(
a varchar2(2000),
static procedure type_pro,
member function type_func return varchar2
);
//
create or replace type body cai_type is
static procedure type_pro is
b number;
begin
select 'a' into b from dual;
exception when others then 
dbms_output.put_line('format_error_backtrace: '||dbms_utility.format_error_backtrace||' FORMAT_ERROR_STACK: '||dbms_utility.FORMAT_ERROR_STACK);
end;

member function type_func return varchar2 is
b number;
begin
select 'a' into b from dual;
exception when others then 
dbms_output.put_line('format_error_backtrace: '||dbms_utility.format_error_backtrace||' FORMAT_ERROR_STACK: '||dbms_utility.FORMAT_ERROR_STACK);
return 1;
end;
end;
