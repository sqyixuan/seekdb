##嵌套使用（匿名块嵌匿名块，匿名块嵌过程等）
begin
 for i in 1 ..2 loop
 begin
 dbms_output.put_line('第 '||i||' 次');
 dbms_output.put_line(dbms_utility.get_hash_value('aa',1,2));
 end;
 end loop;
dbms_output.put_line('嵌套匿名块外的输出'||dbms_utility.get_hash_value('aa',1,2));
end;
//
select println() from dual;//
+--------------------------------------------------------------+
| PRINTLN()                                                    |
+--------------------------------------------------------------+
| 第 1 次
  2
  第 2 次
  2
  嵌套匿名块外的输出2              |
+--------------------------------------------------------------+

declare
 procedure an_pro is
  begin
  dbms_output.put_line('嵌套存储过程的输出'||dbms_utility.get_hash_value('aa',1,2));
  end;
begin
  an_pro;
end;
//
select println() from dual;//
+------------------------------+
| PRINTLN()                    |
+------------------------------+
| 嵌套存储过程的输出2          |
+------------------------------+

