##复杂数据类型（collect+record）+匿名块
declare
type cai_nested is table of number;
v_nested cai_nested:=cai_nested(dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22),dbms_utility.is_bit_set('52476546',9),dbms_utility.is_bit_set(HEXTORAW('524765464545'),9));

a varchar2(20);
type cai_array is table of number index by pls_integer;
v_array cai_array;

type cai_varry is varray(5) of number;
v_varry cai_varry:=cai_varry(dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22),dbms_utility.is_bit_set('52476546',9),dbms_utility.is_bit_set(HEXTORAW('524765464545'),9));

type cai_record is record (r_put1 number,r_put2 number,r_put3 number);
v_record cai_record;

begin
a:=v_nested.first;
dbms_output.put_line('a:'||a||'   v_nested(a): '||v_nested(1)||' '||v_nested(2)||' '||v_nested(3));

v_array(2):=dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22);
v_array(3):=dbms_utility.is_bit_set('52476546',9);
v_array(5):=dbms_utility.is_bit_set(HEXTORAW('524765464545'),9);
dbms_output.put_line('v_array(2):'||v_array(2)||' '||v_array(3)||' '||v_array(5));

a:=v_varry.first;
dbms_output.put_line('a:'||a||'   v_varry(a): '||v_varry(1)||' '||v_varry(2)||' '||v_varry(3));

v_record.r_put1:=dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22);
v_record.r_put2:=dbms_utility.is_bit_set('52476546',9);
v_record.r_put3:=dbms_utility.is_bit_set(HEXTORAW('524765464545'),9);
dbms_output.put_line('v_record.r_put: '||v_record.r_put1||' '||v_record.r_put2||' '||v_record.r_put3);
end;
//
select println() from dual;//
+-----------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                     |
+-----------------------------------------------------------------------------------------------+
| a:1   v_nested(a): 1 1 1
  v_array(2):1 1 1
  a:1   v_varry(a): 1 1 1
  v_record.r_put: 1 1 1 |
+-----------------------------------------------------------------------------------------------+

