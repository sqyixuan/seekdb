##复杂数据类型（collect+record）+匿名块+case when +if else
declare
type cai_nested is table of boolean;
v_nested cai_nested:=cai_nested(dbms_utility.is_cluster_database);

a varchar2(20);
type cai_array is table of boolean index by pls_integer;
v_array cai_array;

type cai_varry is varray(5) of boolean;
v_varry cai_varry:=cai_varry(dbms_utility.is_cluster_database);

type cai_record is record (r_put boolean);
v_record cai_record;

begin
v_array(2):=dbms_utility.is_cluster_database;
v_record.r_put:=dbms_utility.is_cluster_database;

if v_nested(1)=true and v_array(2)=true and v_varry(1)=true and v_record.r_put=true then
dbms_output.put_line('is true');
elsif v_nested(1)=false and v_array(2)=false and v_varry(1)=false and v_record.r_put=false then
dbms_output.put_line('is false');
end if;

case v_nested(1) and v_array(2) and v_varry(1) and v_record.r_put when true then dbms_output.put_line('is true');
when false then dbms_output.put_line('is false');
end case;

end;
//
select println() from dual;//
+-------------------+
| PRINTLN()         |
+-------------------+
| is true
  is true |
+-------------------+

