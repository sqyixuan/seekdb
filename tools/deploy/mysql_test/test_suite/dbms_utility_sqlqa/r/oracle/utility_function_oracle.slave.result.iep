##对象：procedure，package，function，trigger，type，table，view+pl嵌套
##存在循环及判断+不同调用语句
##判断中由于存在bug，故暂时以目前结果进行判断，后期修复后再进行修改
create or replace procedure cai_pro1 is
type cai_nested is table of varchar(100);
v_nested cai_nested:=cai_nested(dbms_utility.get_endianness,dbms_utility.port_string,dbms_utility.old_current_schema,dbms_utility.old_current_user,dbms_utility.get_time);
begin
for i in v_nested.first ..v_nested.last-1 loop
if dbms_utility.get_endianness like 2 and dbms_utility.port_string like 'x86_64-Linux' and dbms_utility.old_current_schema like 'oceanbase' and dbms_utility.old_current_user like 'CWX' then
 dbms_output.put_line('if中均判断成功 ');
 case dbms_utility.get_endianness when 2 then
  case dbms_utility.port_string when 'x86_64-Linux' then
   case dbms_utility.old_current_schema when 'oceanbase' then
    case dbms_utility.old_current_user when 'CWX' then
      dbms_output.put_line('case中均判断成功');
    end case;
   end case;
  end case;
 end case;
end if;
dbms_output.put_line('循环中输出 i: '||v_nested(i));
end loop;
dbms_output.put_line('循环外各个输出: '||dbms_utility.get_endianness||' '||dbms_utility.port_string||' '||dbms_utility.old_current_schema||' '||dbms_utility.old_current_user);
end;
//

call cai_pro1();//
select println() from dual;//
+----------------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                                |
+----------------------------------------------------------------------------------------------------------------------------------------------------------+
| 循环中输出 i: 2
  循环中输出 i: x86_64-Linux
  循环中输出 i: CWX
  循环中输出 i: CWX
  循环外各个输出: 2 x86_64-Linux CWX CWX                            |
+----------------------------------------------------------------------------------------------------------------------------------------------------------+

begin
cai_pro1;
end;
//
select println() from dual;//
+----------------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                                |
+----------------------------------------------------------------------------------------------------------------------------------------------------------+
| 循环中输出 i: 2
  循环中输出 i: x86_64-Linux
  循环中输出 i: CWX
  循环中输出 i: CWX
  循环外各个输出: 2 x86_64-Linux CWX CWX                            |
+----------------------------------------------------------------------------------------------------------------------------------------------------------+

drop table cai_3;//
create table cai_3(id3 number,name3 varchar(100),sex3 varchar(100),high3 varchar(100),wight3 number);//
##package+dml+sql 
create or replace package cai_pack as
a number;
b varchar(100);
c varchar(100);
d varchar(100);
e number;
procedure pack_pro;
function pack_func return varchar;
end;
//
create or replace package body cai_pack as
procedure pack_p_proc is
begin
select dbms_utility.get_endianness,dbms_utility.port_string,dbms_utility.old_current_schema,dbms_utility.old_current_user,dbms_utility.get_time into a,b,c,d,e from dual;
dbms_output.put_line('查看: a: '||a||' b：'||b||' c：'||c||' d：'||d);
end;
procedure pack_pro is
begin
insert into cai_3 values(dbms_utility.get_endianness,dbms_utility.port_string,dbms_utility.old_current_schema,dbms_utility.old_current_user,dbms_utility.get_time) 
return id3,name3,sex3,high3,wight3 into a,b,c,d,e;
insert into cai_3 select dbms_utility.get_endianness,dbms_utility.port_string,dbms_utility.old_current_schema,dbms_utility.old_current_user,dbms_utility.get_time from dual;
pack_p_proc();
dbms_output.put_line('查看: a: '||a||' b：'||b||' c：'||c||' d：'||d);
end;
function pack_func return varchar is
type cai_nested is table of varchar(100);
v_nested1 cai_nested:=cai_nested();
v_nested2 cai_nested:=cai_nested();
v_nested3 cai_nested:=cai_nested();
v_nested4 cai_nested:=cai_nested();
v_nested5 cai_nested:=cai_nested();
begin
update cai_3 set id3=dbms_utility.get_endianness||'1',name3=dbms_utility.port_string||'b',sex3=dbms_utility.old_current_schema||'c',high3=dbms_utility.old_current_user||'d',wight3=dbms_utility.get_time 
return id3,name3,sex3,high3,wight3  bulk collect into v_nested1,v_nested2,v_nested3,v_nested4,v_nested5;
dbms_output.put_line('v_nested：'||v_nested1(1)||' 2：'||v_nested2(2)||' 3：'||v_nested3(1)||' 4：'||v_nested4(2));
dbms_output.put_line('v_nested count：'||v_nested1.count||' 2：'||v_nested2.count||' 3：'||v_nested3.count||' 4：'||v_nested4.count);
return 1;
end;
end cai_pack;
//

call cai_pack.pack_pro();//
select println() from dual;//
+-----------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                     |
+-----------------------------------------------------------------------------------------------+
| 查看: a: 2 b：x86_64-Linux c：CWX d：CWX
  查看: a: 2 b：x86_64-Linux c：CWX d：CWX           |
+-----------------------------------------------------------------------------------------------+
select cai_pack.pack_func from dual;//
ERROR HY000: cannot perform a DML operation inside a query
at anonymous block , line : 23, col : 1
select println() from dual;//
+-----------+
| PRINTLN() |
+-----------+
| NULL      |
+-----------+

declare
a number;
begin
a:=cai_pack.pack_func;
end;
//
select println() from dual;//
+------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                |
+------------------------------------------------------------------------------------------+
| v_nested：21 2：x86_64-Linuxb 3：CWXc 4：CWXd
  v_nested count：2 2：2 3：2 4：2         |
+------------------------------------------------------------------------------------------+
select  id3,name3,sex3,high3 from cai_3;//
+------+---------------+------+-------+
| ID3  | NAME3         | SEX3 | HIGH3 |
+------+---------------+------+-------+
|   21 | x86_64-Linuxb | CWXc | CWXd  |
|   21 | x86_64-Linuxb | CWXc | CWXd  |
+------+---------------+------+-------+

##type+delete+动态sql执行
create or replace type cai_type as object(
a number,
member procedure type_pro,
member function type_func return varchar2
);
//
create or replace type body cai_type is
member procedure type_pro is
begin
execute immediate 'delete from cai_3 where id3 like :1 and name3 like :1 and sex3 like :1 and high3 like :1' 
using dbms_utility.get_endianness||'1',dbms_utility.port_string||'b',dbms_utility.old_current_schema||'c',dbms_utility.old_current_user||'d';
end;
member function type_func return varchar2 is
a number;
b varchar(100);
c varchar(100);
d varchar(100);
e number;
begin
execute immediate 'insert into cai_3 values(dbms_utility.get_endianness,dbms_utility.port_string,dbms_utility.old_current_schema,dbms_utility.old_current_user,dbms_utility.get_time)';
execute immediate 'select dbms_utility.get_endianness,dbms_utility.port_string,dbms_utility.old_current_schema,dbms_utility.old_current_user,dbms_utility.get_time from dual' into a,b,c,d,e;
dbms_output.put_line('查看: a: '||a||' b：'||b||' c：'||c||' d：'||d);
return 1;
end;
end;
//

declare
v_type cai_type:=cai_type(1);
a number;
begin
v_type.type_pro;
a:=v_type.type_func();
dbms_output.put_line('a:'||a);
end;
//
select println() from dual;//
+-----------------------------------------------------+
| PRINTLN()                                           |
+-----------------------------------------------------+
| 查看: a: 2 b：x86_64-Linux c：CWX d：CWX
  a:1      |
+-----------------------------------------------------+
select  id3,name3,sex3,high3 from cai_3;//
+------+--------------+------+-------+
| ID3  | NAME3        | SEX3 | HIGH3 |
+------+--------------+------+-------+
|    2 | x86_64-Linux | CWX  | CWX   |
+------+--------------+------+-------+

##触发器+view
drop trigger cai_trig ;//
drop table cai_3;//
create table cai_3(id3 number,name3 varchar(100),sex3 varchar(100),high3 varchar(100),wight3 number);//
drop view cai_view;//
drop table cai_4;//
delete from cai_3;//
insert into cai_3 values(1,1,1,1,1);//
create view cai_view as select  id3,name3,sex3,high3,wight3 from cai_3;//
create table cai_4(id4 number);//
create or replace trigger cai_trig 
before insert or delete or update on cai_4
for each row
declare
a number;
b varchar(100);
c varchar(100);
d varchar(100);
e number;
begin
if inserting then
insert into cai_view select dbms_utility.get_endianness,dbms_utility.port_string,dbms_utility.old_current_schema,dbms_utility.old_current_user,dbms_utility.get_time from dual;
insert into cai_view values(dbms_utility.get_endianness,dbms_utility.port_string,dbms_utility.old_current_schema,dbms_utility.old_current_user,dbms_utility.get_time);
end if;

if updating then
update cai_view set id3=dbms_utility.get_endianness,name3=dbms_utility.port_string,sex3=dbms_utility.old_current_schema,high3=dbms_utility.old_current_user,wight3=dbms_utility.get_time where name3='1';
end if;

if deleting then
execute immediate 'select dbms_utility.get_endianness,dbms_utility.port_string,dbms_utility.old_current_schema,dbms_utility.old_current_user,dbms_utility.get_time from dual' into a,b,c,d,e;
dbms_output.put_line('查看: a: '||a||' b：'||b||' c：'||c||' d：'||d);
end if;
end;
