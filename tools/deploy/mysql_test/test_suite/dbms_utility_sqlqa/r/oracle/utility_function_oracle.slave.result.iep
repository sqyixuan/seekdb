##嵌套procedure+匿名块+自定义exception（raise+exception_init）+判断+dml+select into
##32992238,proxy模式下，将format_error_backtrace+FORMAT_ERROR_STACK插入表中后进行查询，ob显示为null，oracle正常;预期结果：ob执行同oracle
##同32259462
##由于proxy执行结果不同于obs0，故暂时结果不计入文件中
declare
v_value number;
e exception;
pragma exception_init(e,-5114);
--pragma exception_init(e,-6502); --oracle中的错误码
 procedure cai_pro is
 a exception;
 b varchar2(2000);
 c varchar2(2000);
 begin
 raise a;
 exception when a then
 insert into c1(v1,v12) values(dbms_utility.format_error_backtrace,dbms_utility.FORMAT_ERROR_STACK);
 select dbms_utility.format_error_backtrace,dbms_utility.FORMAT_ERROR_STACK into b,c from dual;
 if b=dbms_utility.format_error_backtrace then
  case c when dbms_utility.FORMAT_ERROR_STACK then
   dbms_output.put_line('format_error_backtrace:  '||dbms_utility.format_error_backtrace);
   dbms_output.put_line('FORMAT_ERROR_STACK:  '||dbms_utility.FORMAT_ERROR_STACK);
   when null then
    dbms_output.put_line('c 不为 FORMAT_ERROR_STACK');
  end case;
 else 
   dbms_output.put_line('b 不为 format_error_backtrace');
 end if;
 end;
begin
cai_pro;
v_value:='a';
exception when e then 
dbms_output.put_line('e中的backtrace:  '||dbms_utility.format_error_backtrace);
dbms_output.put_line('e中的STACK:  '||dbms_utility.FORMAT_ERROR_STACK);
end;
//
select println() from dual;//
