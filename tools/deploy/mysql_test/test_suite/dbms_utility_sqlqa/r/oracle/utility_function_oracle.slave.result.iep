delete from cai_3;//
insert into cai_3 select regexp_replace(dbms_utility.format_call_stack,'0x[a-z0-9]{12}','1'),to_char(regexp_replace(dbms_utility.format_call_stack,'0x[a-z0-9]{12}','1')) from dual;//
