procedure package2_procedure2 is
begin
package2_procedure3;
end;

procedure package2_procedure1 is
begin
package2_procedure2;
end;

function package2_procedure_function return number is
begin
package2_procedure1;
return 1;
end;

procedure package2_procedure is
begin
dbms_output.put_line(package2_function);
end;

function package2_function return number is
begin
dbms_output.put_line(package2_procedure_function);
return 1;
end;
end cai_package2;
//
