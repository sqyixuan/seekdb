##merge into
drop table cai_5;
create table cai_5(id5 number,name5 varchar(100),sex5 varchar(100),high5 varchar(100),wight5 number);
delete from cai_5;
insert into cai_5 values(1,3,1,1,1);
merge into cai_5 c5 using (select dbms_utility.get_endianness a,dbms_utility.port_string b,dbms_utility.old_current_schema c,dbms_utility.old_current_user d,dbms_utility.get_time e from dual) d5 
on (d5.a=id5)
when not matched then
insert(id5,name5,sex5,high5,wight5) values(dbms_utility.get_endianness,dbms_utility.port_string,dbms_utility.old_current_schema,dbms_utility.old_current_user,dbms_utility.get_time);

