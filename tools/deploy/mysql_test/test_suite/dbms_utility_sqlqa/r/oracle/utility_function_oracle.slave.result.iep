select (case id3 when dbms_utility.get_hash_value('aa',1,2) then 1 else 0 end) a from cai_3;
+---+
| A |
+---+
| 1 |
+---+

delete from cai_3;
insert into cai_3 select 2,to_char(dbms_utility.get_hash_value('aa',1,2)) from dual;
select id3 from cai_3 where id3=case name3 when dbms_utility.get_hash_value('aa',1,2) then 2 else 0 end;
+------+
| ID3  |
+------+
|    2 |
+------+

