##type+重复执行+占位符
delete from c1;//
delete from c_view;//
create or replace type cai_type as object(
a varchar2(2000),
member procedure type_pro,
member function type_func return varchar2
);
//
create or replace type body cai_type is
member procedure type_pro is
begin
a:=to_date(1);
exception when others then
execute immediate 'delete from c1 where v1 like :1 and v12 like :2' using dbms_utility.format_error_backtrace,dbms_utility.format_error_stack;
end;
member function type_func return varchar2 is
a varchar2(2000);
b varchar2(2000);
begin
a:=to_date(1);
exception when others then
insert into c1(v1,v12) values(dbms_utility.format_error_backtrace,dbms_utility.format_error_stack);
execute immediate 'select dbms_utility.format_error_backtrace,dbms_utility.format_error_stack from dual' into a,b;
dbms_output.put_line('a:'||a||'  b:'||b);
execute immediate 'select dbms_utility.format_error_backtrace,dbms_utility.format_error_stack from dual' into a,b;
dbms_output.put_line('a:'||a||'  b:'||b);
return a;
end;
end;
//
