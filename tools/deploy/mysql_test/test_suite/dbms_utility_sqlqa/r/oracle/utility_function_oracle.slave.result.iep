##format_call_stack 验证
##执行结果中的object handle列无需在意
##由于object handle不稳定（ob+oracle均如此），故本case中使用regexp_replace功能替换掉不稳定的部分
##对象：procedure，package，function，trigger，type，table，view+参数类型（in out in out），pl嵌套
create or replace procedure cai_pro(a in varchar2,b out varchar2,d in out varchar2) is 
c varchar2(2000);
begin
b:=2;
d:=1;
c:=dbms_utility.format_call_stack;
dbms_output.put_line('a: '||a ||'  b:'||b||'  d:'||d);
select regexp_replace(c,'0x[a-z0-9]{12}','1') into c from dual;
dbms_output.put_line('c: '||c);
end;
//
##32133662，[pl dbms_utility]验证format_call_stack，存在与procedure中，调用时，ob结果中的line number与oracle不一致（稳定复现），预期结果：ob执行结果中line number值同oracle
declare
b number;
d number;
begin
cai_pro(1,b,d);
end;
//
select println() from dual;//
+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                                                                                  |
+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| a: 1  b:2  d:1
  c: ----- PL/SQL Call Stack -----
object handle              line number      object name
1              6             procedure CWX.CAI_PRO
1              5             anonymous block
 |
+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+

