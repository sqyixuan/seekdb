declare
Type cai_cursor IS Ref Cursor;
v_c cai_cursor;
type cai_record is record (r_put1 number,r_put2 varchar2(200),r_put3 varchar2(200),r_put4 varchar2(200),r_put5 number);
v_record cai_record;
begin
open v_c for select dbms_utility.get_endianness,dbms_utility.port_string,dbms_utility.old_current_schema,dbms_utility.old_current_user,dbms_utility.get_time from dual;
fetch v_c into v_record;
dbms_output.put_line('v_record.r_put1: '||v_record.r_put1||' '||v_record.r_put2||' '||v_record.r_put3||' '||v_record.r_put4);
--dbms_output.put_line('v_record.r_put5: '||v_record.r_put5);
