## is_cluster_database 验证
##由于目前oracle为非集群，ob为集群且无权限配置oracle，故此功能暂仅验证ob行为
##由于ob为集群模式，无法更改，故仅验证true场景
##boolean类型中很多表现与oracle不同，且均为已知问题
##参数验证
declare
a boolean:=dbms_utility.is_cluster_database();
begin
if a = true then
dbms_output.put_line('已设置集群');
elsif a = false then
dbms_output.put_line('未设置集群');
end if;
end;
//
select println() from dual;//
+-----------------+
| PRINTLN()       |
+-----------------+
| 已设置集群      |
+-----------------+

##存在判断（if，case）+循环
##ob支持内置函数中使用boolean类型，oracle不支持
begin
for  i in 1 ..length(dbms_utility.is_cluster_database) loop
if dbms_utility.is_cluster_database() = true then
 case dbms_utility.is_cluster_database() when true then
 dbms_output.put_line('已设置集群');
 end case;
end if;
end loop;
end;
//
select println() from dual;//
+-----------------+
| PRINTLN()       |
+-----------------+
| 已设置集群      |
+-----------------+

