| PRINTLN() |
+-----------+
| a:2       |
+-----------+
select * from cai_3;//
+------+-------+
| ID3  | NAME3 |
+------+-------+
|    2 |     1 |
+------+-------+

##触发器+view
drop table cai_3;//
create table cai_3(id3 number,name3 number);//
drop view cai_view;//
drop table cai_4;//
delete from cai_3;//
insert into cai_3 values(1,1);//
create view cai_view as select * from cai_3;//
create table cai_4(id4 number);//

create or replace trigger cai_trig 
before insert or delete or update on cai_4
for each row
declare
a varchar2(2000);
begin
if inserting then
insert into cai_view select dbms_utility.get_hash_value('aa',1,2),to_char(dbms_utility.get_hash_value('aa',1,2)) from dual;
insert into cai_view values(dbms_utility.get_hash_value('aa',1,2),3);
end if;

if updating then
update cai_view set name3=dbms_utility.get_hash_value('aa',1,2) where name3=3;
end if;

if deleting then
execute immediate 'select ''get_hash_value的输出结果''||dbms_utility.get_hash_value(''aa'',1,2) from dual' into a;
dbms_output.put_line('a:'||a);
end if;
end;
//

insert into cai_4 values(1);
select println() from dual;
+-----------+
| PRINTLN() |
+-----------+
| NULL      |
+-----------+
update cai_4 set id4=2;
select println() from dual;
+-----------+
| PRINTLN() |
+-----------+
| NULL      |
+-----------+
delete from cai_4;
select println() from dual;
+----------------------------------+
| PRINTLN()                        |
+----------------------------------+
| a:get_hash_value的输出结果2      |
+----------------------------------+
select id3,name3 from cai_view;
+------+-------+
| ID3  | NAME3 |
+------+-------+
|    1 |     1 |
|    2 |     2 |
|    2 |     2 |
+------+-------+
drop trigger cai_trig ;

