##function
##虽然官方手册上是只支持procdure+trigger，但实际中oracle执行同样可以输出format_call_stack信息
create or replace function cai_func return varchar is
c varchar2(2000);
begin
c:=dbms_utility.format_call_stack;
select regexp_replace(c,'0x[a-z0-9]{12}','1') into c from dual;
return c;
end;
//
##同32135756
select cai_func from dual;//
+-------------------------------------------------------------------------------------------------------------------------------------+
| CAI_FUNC                                                                                                                            |
+-------------------------------------------------------------------------------------------------------------------------------------+
| ----- PL/SQL Call Stack -----
object handle              line number      object name
1              4             anonymous block
 |
+-------------------------------------------------------------------------------------------------------------------------------------+
select println() from dual;//
+-----------+
| PRINTLN() |
+-----------+
| NULL      |
+-----------+

declare
c varchar2(2000);
begin
c:=cai_func;
dbms_output.put_line('c: '||c);
end;
//
select println() from dual;//
+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                                                                 |
+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| c: ----- PL/SQL Call Stack -----
object handle              line number      object name
1              4             function CWX.CAI_FUNC
1              4             anonymous block
 |
+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+

create table cai_3(id3 varchar2(2000),name3 number);//
delete from cai_3;//
insert into cai_3 values (1,1);//
##package+dml+sql 
create or replace package cai_pack as
procedure pack_pro;
function pack_func return varchar2;
end;
//
create or replace package body cai_pack as
procedure pack_p_proc is
c varchar2(2000);
begin
select (dbms_utility.format_call_stack)b into c from dual;
select regexp_replace(c,'0x[a-z0-9]{12}','1') into c from dual;
dbms_output.put_line('查看format_call_stack:'||c);
end;
procedure pack_pro is
begin
insert into cai_3 select (regexp_replace(dbms_utility.format_call_stack,'0x[a-z0-9]{12}','1')) b,2 from dual;
pack_p_proc();
end;
function pack_func return varchar2 is
c varchar2(2000);
begin
update cai_3 set id3=(regexp_replace(dbms_utility.format_call_stack,'0x[a-z0-9]{12}','1')) where name3=1 return id3 into c;
return c;
end;
end cai_pack;
//
##32159716,[pl dbms_utility]验证format_call_stack，使用select into，ob及oracle结果不一致（稳定复现）,预期结果：ob执行结果等同于oracle结果
##32173694,[pl dbms_utility]pl中使用dml验证format_call_stack时，ob及oracle结果不一致（稳定复现），预期结果：ob执行结果等同于oracle结果
begin
cai_pack.pack_pro();
end;
