a:=v_varry.first;
select regexp_replace(v_varry(1),'0x[a-z0-9]{12}','1') into v_varry(1) from dual;
dbms_output.put_line('a:'||a||'   v_varry(a): '||v_varry(1));

v_record.r_put:=dbms_utility.format_call_stack;
select regexp_replace(v_record.r_put,'0x[a-z0-9]{12}','1') into v_record.r_put from dual;
dbms_output.put_line('v_record.r_put: '||v_record.r_put);
end;
