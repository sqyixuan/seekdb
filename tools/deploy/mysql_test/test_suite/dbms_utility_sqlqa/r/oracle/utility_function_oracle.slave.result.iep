##验证返回值最多2000字节
create or replace package cai_package2 is
procedure package2_procedure;
function package2_function return number;
end cai_package2;
//
create or replace package body cai_package2 is
procedure package2_procedure20 is
a number;
begin
dbms_output.put_line('存在嵌套的输出'||(regexp_replace(dbms_utility.format_call_stack,'0x[a-z0-9]{12}','1')));
a:='a';
exception when others then
dbms_output.put_line('format_error_backtrace: '||dbms_utility.format_error_backtrace ||'  format_error_stack: '||dbms_utility.format_error_stack);
end;
procedure package2_procedure19 is
begin
package2_procedure20;
end;
procedure package2_procedure18 is
