##对象：procedure，package，function，trigger，type，table，view+pl嵌套
##存在循环及判断+不同调用语句
create or replace procedure cai_pro1 is
type cai_nested is table of number;
v_nested cai_nested:=cai_nested(dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22),dbms_utility.is_bit_set('52476546',9),dbms_utility.is_bit_set(HEXTORAW('524765464545'),9));
begin
for i in v_nested.first ..v_nested.last loop
if 1=dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22) and 1=dbms_utility.is_bit_set('52476546',9) and 1=dbms_utility.is_bit_set(HEXTORAW('524765464545'),9) then
 dbms_output.put_line('if中 is_bit_set: '||dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22)||dbms_utility.is_bit_set('52476546',9)||dbms_utility.is_bit_set(HEXTORAW('524765464545'),9));
 case 1 when dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22) then
  case 1 when dbms_utility.is_bit_set('52476546',9) then
   case 1 when dbms_utility.is_bit_set(HEXTORAW('524765464545'),9) then
    dbms_output.put_line('case中 is_bit_set: '||dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22)||dbms_utility.is_bit_set('52476546',9)||dbms_utility.is_bit_set(HEXTORAW('524765464545'),9));
   end case;
  end case;
 end case;
end if;
end loop;
end;
//

call cai_pro1();//
select println() from dual;//
+-----------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                           |
+-----------------------------------------------------------------------------------------------------------------------------------------------------+
| if中 is_bit_set: 111
  case中 is_bit_set: 111
  if中 is_bit_set: 111
  case中 is_bit_set: 111
  if中 is_bit_set: 111
  case中 is_bit_set: 111       |
+-----------------------------------------------------------------------------------------------------------------------------------------------------+

begin
cai_pro1;
end;
//
select println() from dual;//
+-----------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                           |
+-----------------------------------------------------------------------------------------------------------------------------------------------------+
| if中 is_bit_set: 111
  case中 is_bit_set: 111
  if中 is_bit_set: 111
  case中 is_bit_set: 111
  if中 is_bit_set: 111
  case中 is_bit_set: 111       |
+-----------------------------------------------------------------------------------------------------------------------------------------------------+

drop table cai_3;//
create table cai_3(id3 number,name3 number,sex3 number);//
delete from cai_3;//
insert into cai_3 values (dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22),dbms_utility.is_bit_set('52476546',9),dbms_utility.is_bit_set(HEXTORAW('524765464545'),9));//
##package+dml+sql 
create or replace package cai_pack as
procedure pack_pro;
function pack_func return number;
end;
//
create or replace package body cai_pack as
procedure pack_p_proc is
c number;
begin
select (dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22)+dbms_utility.is_bit_set('52476546',9)+dbms_utility.is_bit_set(HEXTORAW('524765464545'),9))b into c from dual;
dbms_output.put_line('查看is_bit_set之和:'||c);
end;
procedure pack_pro is
type cai_nested is table of number;
v_nested1 cai_nested:=cai_nested();
v_nested2 cai_nested:=cai_nested();
v_nested3 cai_nested:=cai_nested();
begin
for i in 1 ..2 loop
insert into cai_3 values(dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22),dbms_utility.is_bit_set('52476546',9),dbms_utility.is_bit_set(HEXTORAW('524765464545'),9)) 
return id3,name3,sex3 bulk collect into v_nested1,v_nested2,v_nested3;
end loop;
dbms_output.put_line('v_nested(1):'||v_nested1(1)||v_nested2(1)||v_nested3(1));
insert into cai_3 select dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22),dbms_utility.is_bit_set('52476546',9),dbms_utility.is_bit_set(HEXTORAW('524765464545'),9) from dual;
pack_p_proc();
end;
function pack_func return number is
c number;
d number;
e number;
begin
update cai_3 set id3=dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22)+2,name3=dbms_utility.is_bit_set('52476546',9)*2,sex3=dbms_utility.is_bit_set(HEXTORAW('524765464545'),9)-3
 where name3=1 return id3,name3,sex3 into c,d,e;
return c+d+e;
end;
end cai_pack;
//

declare
a number;
begin
a:=cai_pack.pack_func;
dbms_output.put_line('a:'||a);
end;
//
select println() from dual;//
+-----------+
| PRINTLN() |
+-----------+
| a:3       |
+-----------+
call cai_pack.pack_pro();//
select println() from dual;//
+--------------------------------------------+
| PRINTLN()                                  |
+--------------------------------------------+
| v_nested(1):111
  查看is_bit_set之和:3     |
+--------------------------------------------+
select * from cai_3;//
+------+-------+------+
| ID3  | NAME3 | SEX3 |
+------+-------+------+
|    3 |     2 |   -2 |
|    1 |     1 |    1 |
|    1 |     1 |    1 |
|    1 |     1 |    1 |
+------+-------+------+

##type+delete+动态sql执行
create or replace type cai_type as object(
a number,
member procedure type_pro,
member function type_func return varchar2
);
//
create or replace type body cai_type is
member procedure type_pro is
begin
execute immediate 'delete from cai_3 where id3 like :1 and name3 like :1 and sex3 like :1' 
using dbms_utility.is_bit_set('52476546',9),dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22),dbms_utility.is_bit_set(HEXTORAW('524765464545'),9);
end;
member function type_func return varchar2 is
a number;
begin
insert into cai_3 values(dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22),dbms_utility.is_bit_set('52476546',9),dbms_utility.is_bit_set(HEXTORAW('524765464545'),9));
execute immediate 'select dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW(''5247''),22)+dbms_utility.is_bit_set(''52476546'',9)+dbms_utility.is_bit_set(HEXTORAW(''524765464545''),9) from dual' into a;
return a;
end;
end;
//

declare
v_type cai_type:=cai_type(1);
a number;
begin
v_type.type_pro;
a:=v_type.type_func();
dbms_output.put_line('a:'||a);
end;
//
select println() from dual;//
+-----------+
| PRINTLN() |
+-----------+
| a:3       |
+-----------+
select * from cai_3;//
+------+-------+------+
| ID3  | NAME3 | SEX3 |
+------+-------+------+
|    3 |     2 |   -2 |
|    1 |     1 |    1 |
+------+-------+------+

##触发器+view
drop view cai_view;//
delete from cai_3;//
insert into cai_3 values(1,1,1);//
create view cai_view as select * from cai_3;//
drop table cai_4;//
create table cai_4(id4 number);//
create or replace trigger cai_trig 
before insert or delete or update on cai_4
for each row
declare
a number;
begin
if inserting then
insert into cai_view select dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22)+2,to_char(dbms_utility.is_bit_set('52476546',9))-5,dbms_utility.is_bit_set(HEXTORAW('524765464545'),9)*3 from dual;
insert into cai_view values(dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22),dbms_utility.is_bit_set('52476546',9),dbms_utility.is_bit_set(HEXTORAW('524765464545'),9));
end if;

if updating then
update cai_view set id3=dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22)+5,name3=dbms_utility.is_bit_set('52476546',9)-6,sex3=dbms_utility.is_bit_set(HEXTORAW('524765464545'),9)+2 where id3=3;
end if;

if deleting then
execute immediate 'select dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW(''5247''),22)+dbms_utility.is_bit_set(''52476546'',9)+dbms_utility.is_bit_set(HEXTORAW(''524765464545''),9) from dual' 
into a;
dbms_output.put_line('a:'||a);
end if;
end;
//
insert into cai_4 values(1);
select println() from dual;
+-----------+
| PRINTLN() |
+-----------+
| NULL      |
+-----------+
update cai_4 set id4=2;
select println() from dual;
+-----------+
| PRINTLN() |
+-----------+
| NULL      |
+-----------+
delete from cai_4;
select println() from dual;
+-----------+
| PRINTLN() |
+-----------+
| a:3       |
+-----------+
select id3,name3,sex3 from cai_view;
+------+-------+------+
| ID3  | NAME3 | SEX3 |
+------+-------+------+
|    1 |     1 |    1 |
|    6 |    -5 |    3 |
|    1 |     1 |    1 |
+------+-------+------+
drop trigger cai_trig ;

##merge into
drop table cai_5;
create table cai_5(id5 number,name5 number,sex5 number);
delete from cai_5;
insert into cai_5 values(1,3,5);
merge into cai_5 c5 using 
(select dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22) a,dbms_utility.is_bit_set('52476546',9) b,dbms_utility.is_bit_set(HEXTORAW('524765464545'),9) c from dual) dc on (dc.a=c5.id5)
when matched then
update set c5.name5=dc.b,c5.sex5=dc.c;
select * from cai_5;
+------+-------+------+
| ID5  | NAME5 | SEX5 |
+------+-------+------+
|    1 |     1 |    1 |
+------+-------+------+

delete from cai_5;
insert into cai_5 values(2,3,3);
merge into cai_5 c5 using 
(select dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22) a,dbms_utility.is_bit_set('52476546',9) b,dbms_utility.is_bit_set(HEXTORAW('524765464545'),9) c from dual) dc on (dc.a=c5.id5)
when not matched then
insert(id5,name5,sex5) values(dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22),dbms_utility.is_bit_set('52476546',9),dbms_utility.is_bit_set(HEXTORAW('524765464545'),9));
select * from cai_5;
+------+-------+------+
| ID5  | NAME5 | SEX5 |
+------+-------+------+
|    2 |     3 |    3 |
|    1 |     1 |    1 |
+------+-------+------+

##dml单独使用
delete from cai_view;
insert into cai_view select dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22)+1,to_char(dbms_utility.is_bit_set('52476546',9)),length(dbms_utility.is_bit_set(HEXTORAW('524765464545'),9)) from dual;
insert into cai_view values(dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22)-2,to_char(dbms_utility.is_bit_set('52476546',9)),length(dbms_utility.is_bit_set(HEXTORAW('524765464545'),9)));
update cai_view set id3=dbms_utility.is_bit_set(utl_raw.CAST_TO_RAW('5247'),22)+5,name3=dbms_utility.is_bit_set('52476546',9)-6,sex3=dbms_utility.is_bit_set(HEXTORAW('524765464545'),9)+2 where id3<0;
select id3,name3,sex3 from cai_view order by id3;
+------+-------+------+
| ID3  | NAME3 | SEX3 |
+------+-------+------+
