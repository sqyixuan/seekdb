##procedure+insert into select+循环+dml+return (bulk collect) into+collect+record+merfe into 
##由于ob及oracle输出的FORMAT_ERROR_STACK，format_error_backtrace长度均不同，所以loop时输出次数会有差异
delete from c1;//
insert into c1(v1,v12) values(1,1);//
insert into c1(v1,v12) values(1,1);//
create or replace procedure cai_pro is
type cai_record is record(r_v1 varchar2(2000),r_v12 varchar2(2000));
v_record cai_record;
type cai_array is table of varchar2(2000) index by pls_integer;
v_array cai_array;
type cai_nested is table of varchar2(2000);
v_nested cai_nested:=cai_nested();
a number;
e exception;
begin
a:=1;
raise e;
exception when e then
for i in length(dbms_utility.FORMAT_ERROR_STACK)*0.1 ..length(dbms_utility.format_error_backtrace)*0.1+3 loop
insert into c1(v1,v12) values(dbms_utility.format_error_backtrace,dbms_utility.FORMAT_ERROR_STACK) return v1,v12 into v_record;
dbms_output.put_line('r_v1: '||v_record.r_v1||'  r_v12: '||v_record.r_v12);
end loop;
update c1 set v1=dbms_utility.format_error_backtrace,v12=dbms_utility.FORMAT_ERROR_STACK where v1!=dbms_utility.format_error_backtrace and v12 !=dbms_utility.FORMAT_ERROR_STACK 
 return v1,v12 bulk collect into v_array,v_nested;
dbms_output.put_line('format_error_backtrace: '||v_array(1) ||'  FORMAT_ERROR_STACK: '||v_nested(1));
update c1 set remark='format_error_backtrace: '||dbms_utility.format_error_backtrace ||'  format_error_stack: '||dbms_utility.format_error_stack;
insert into c1(v1,v12) select dbms_utility.format_error_backtrace,dbms_utility.FORMAT_ERROR_STACK from dual;
merge into c1 a_tab using (select dbms_utility.format_error_backtrace b_bt,dbms_utility.format_error_stack c_es from dual) d on (a_tab.remark='format_error_backtrace: '||d.b_bt||'  format_error_stack: '||d.c_es)
when matched then
update set a_tab.v1=d.c_es
when not matched then
insert(v1,v12,remark) values(d.c_es,d.b_bt,'v1为format_error_stack，v12为format_error_backtrace');
end;
//
##同 32992238
##由于proxy执行结果不同于obs0，故暂时结果不计入文件中
call cai_pro();//
select println() from dual;//
select v1,v12,remark from c1 order by v1,v12,remark;//

##case when 
delete from c1;//
##32287396,[pl dbms_utility]验证format_error_backtrace+format_error_stack在表中的case when用法，ob执行失败，oracle成功（稳定复现）,预期结果：ob执行成功
##目前proxy模式下执行为成功，但结果为a: 0  b:0；oracle结果为a: 1  b:1
##由于proxy执行结果不同于obs0故暂时结果不计入文件中
declare
a number;
b number;
e exception;
begin
a:=2;
raise e;
exception when e then
insert into c1(v1,v12) values(dbms_utility.format_error_backtrace,dbms_utility.FORMAT_ERROR_STACK);
select (case v1 when dbms_utility.format_error_backtrace then 1 else 0 end )c ,(case v12 when dbms_utility.FORMAT_ERROR_STACK then 1 else 0 end )d into a,b from c1;
dbms_output.put_line('a: '||a||'  b:'||b);
end;
//
select println() from dual;//

delete from c1;//
create view c_view as select * from c1;//
##package+动态sql+view+with as+私有程序
create or replace package cai_pack is 
procedure p_proc;
function p_func return varchar2;
end cai_pack;
//
create or replace package body cai_pack is
function p_func1 return varchar2 is
type cai_array is table of varchar2(2000) index by pls_integer;
a cai_array;
b cai_array;
begin
a('a'):=1;
exception when others then
insert into c_view(v1,v12) values(dbms_utility.format_error_backtrace,dbms_utility.format_error_stack) return v1,v12 bulk collect into a,b;
dbms_output.put_line('format_error_backtrace: '||dbms_utility.format_error_backtrace ||'  format_error_stack: '||dbms_utility.format_error_stack);
insert into c1(v1,v12) select dbms_utility.format_error_backtrace,dbms_utility.format_error_stack from dual;
update c_view set remark='format_error_backtrace: '||dbms_utility.format_error_backtrace ||'  format_error_stack: '||dbms_utility.format_error_stack;
delete from c1 where v1 like dbms_utility.format_error_backtrace and v12 like dbms_utility.FORMAT_ERROR_STACK return v1,v12 bulk collect into a,b;
dbms_output.put_line('a:'||a(1) ||'  b:'||b(1));
return 'format_error_backtrace: '||dbms_utility.format_error_backtrace ||'  format_error_stack: '||dbms_utility.format_error_stack;
end p_func1;

procedure p_proc is
a varchar2(2000);
begin
a:=p_func();
dbms_output.put_line('a:'||a);
end p_proc;

function p_func return varchar2 is
a varchar2(2000);
b varchar2(2000);
e exception;
begin
a:=p_func1();
dbms_output.put_line('a: '||a);
raise e;
exception when e then
execute immediate 'with a as (select dbms_utility.format_error_backtrace from dual),b as (select dbms_utility.format_error_stack from dual) select * from a,b' into a,b;
dbms_output.put_line('a:'||a ||'  b:'||b);
execute immediate 'insert into c_view(v1,v12) select dbms_utility.format_error_backtrace,dbms_utility.format_error_stack from dual';
return '1';
end p_func;

end cai_pack;
//

