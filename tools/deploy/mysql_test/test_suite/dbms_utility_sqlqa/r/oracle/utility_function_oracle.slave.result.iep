##嵌套使用（匿名块嵌匿名块，匿名块嵌过程等）
begin
 for i in 1 ..2 loop
 begin
 dbms_output.put_line('第 '||i||' 次');
 dbms_output.put_line((regexp_replace(dbms_utility.format_call_stack,'0x[a-z0-9]{12}','1')));
 end;
 end loop;
dbms_output.put_line('嵌套匿名块外的输出'||(regexp_replace(dbms_utility.format_call_stack,'0x[a-z0-9]{12}','1')));
end;
