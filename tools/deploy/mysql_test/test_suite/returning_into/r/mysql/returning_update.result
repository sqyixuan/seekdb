drop database if exists lemon_db;
create database lemon_db;
use lemon_db;
create table t1(c1 int primary key, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
result_format: 4
############################### insert returning ############################
insert into t1 values(1, 2, 3);
insert into t1 values(2, 2, 3), (3, 2, 3);
select * from t1;
+----+------+------+
| c1 | c2   | c3   |
+----+------+------+
|  1 |    2 |    3 |
|  2 |    2 |    3 |
|  3 |    2 |    3 |
+----+------+------+
#### 测试普通情况
update t1 set c3 = 100 where c1 = 1 returning c1, c2, c3;
+----+------+------+
| c1 | c2   | c3   |
+----+------+------+
|  1 |    2 |  100 |
+----+------+------+
update t1 set c2 = 20 where c1 = 3 returning c1, c2 * c3;
+----+---------+
| c1 | c2 * c3 |
+----+---------+
|  3 |      60 |
+----+---------+
select * from t1;
+----+------+------+
| c1 | c2   | c3   |
+----+------+------+
|  1 |    2 |  100 |
|  2 |    2 |    3 |
|  3 |   20 |    3 |
+----+------+------+
#### 测试聚集函数
update t1 set c2 = 30 returning sum(c1 + c2), sum(c3);
+--------------+---------+
| sum(c1 + c2) | sum(c3) |
+--------------+---------+
|           96 |     106 |
+--------------+---------+

insert into t2 values(1, 2, 3);
insert into t2 values(2, 2, 3), (3, 2, 3);
update t2 set c3 = 100 where c1 = 1;
update t2 set c2 = 20 where c1 = 3;
select * from t2;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
|    1 |    2 |  100 |
|    2 |    2 |    3 |
|    3 |   20 |    3 |
+------+------+------+
update t2 set c2 = 30 returning sum(c1 + c2), sum(c3);
+--------------+---------+
| sum(c1 + c2) | sum(c3) |
+--------------+---------+
|           96 |     106 |
+--------------+---------+

drop table t1, t2;
drop database lemon_db;
