drop database if exists lemon_db;
create database lemon_db;
use lemon_db;
create table t1(c1 int primary key, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
result_format: 4
############################### insert returning ############################
insert into t1 values(1, 2, 3);
insert into t1 values(2, 2, 3), (3, 2, 3);
insert into t1 values(4, 2, 4), (5, 1, 3);
select * from t1;
+----+------+------+
| c1 | c2   | c3   |
+----+------+------+
|  1 |    2 |    3 |
|  2 |    2 |    3 |
|  3 |    2 |    3 |
|  4 |    2 |    4 |
|  5 |    1 |    3 |
+----+------+------+
#### 测试复杂一点表达式
delete from t1 where c1 = 1 or c1 = 2 returning c1, c2 + 3, c3;
+----+--------+------+
| c1 | c2 + 3 | c3   |
+----+--------+------+
|  1 |      5 |    3 |
|  2 |      5 |    3 |
+----+--------+------+
select * from t1;
+----+------+------+
| c1 | c2   | c3   |
+----+------+------+
|  3 |    2 |    3 |
|  4 |    2 |    4 |
|  5 |    1 |    3 |
+----+------+------+
delete from t1 where c1 = 3 returning c1, c2 + c3;
+----+---------+
| c1 | c2 + c3 |
+----+---------+
|  3 |       5 |
+----+---------+
select * from t1;
+----+------+------+
| c1 | c2   | c3   |
+----+------+------+
|  4 |    2 |    4 |
|  5 |    1 |    3 |
+----+------+------+
delete from t1;
insert into t1 values(2, 2, 3), (3, 2, 3);
insert into t1 values(4, 2, 4), (5, 1, 3);
#### 测试普通情况
delete from t1 where c1 = 2 returning c1, c2, c3;
+----+------+------+
| c1 | c2   | c3   |
+----+------+------+
|  2 |    2 |    3 |
+----+------+------+
#### 测试聚集函数
delete from t1 returning sum(c1), sum(c2);
+---------+---------+
| sum(c1) | sum(c2) |
+---------+---------+
|      12 |       5 |
+---------+---------+

insert into t2 values(1, 2, 3);
insert into t2 values(2, 2, 3), (3, 2, 3);
insert into t2 values(4, 2, 4), (5, 1, 3);
select * from t2;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
|    1 |    2 |    3 |
|    2 |    2 |    3 |
|    3 |    2 |    3 |
|    4 |    2 |    4 |
|    5 |    1 |    3 |
+------+------+------+
delete from t2 where c1 = 1 or c1 = 2 returning c1, c2 + 3, c3;
+------+--------+------+
| c1   | c2 + 3 | c3   |
+------+--------+------+
|    1 |      5 |    3 |
|    2 |      5 |    3 |
+------+--------+------+
select * from t2;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
|    3 |    2 |    3 |
|    4 |    2 |    4 |
|    5 |    1 |    3 |
+------+------+------+
delete from t2 where c1 = 3 returning c1, c2 + c3;
+------+---------+
| c1   | c2 + c3 |
+------+---------+
|    3 |       5 |
+------+---------+
select * from t2;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
|    4 |    2 |    4 |
|    5 |    1 |    3 |
+------+------+------+
delete from t2;
insert into t2 values(2, 2, 3), (3, 2, 3);
insert into t2 values(4, 2, 4), (5, 1, 3);
delete from t2 where c1 = 2 returning c1, c2, c3;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
|    2 |    2 |    3 |
+------+------+------+
delete from t2 returning sum(c1), sum(c2);
+---------+---------+
| sum(c1) | sum(c2) |
+---------+---------+
|      12 |       5 |
+---------+---------+

drop table t1, t2;
drop database lemon_db;
