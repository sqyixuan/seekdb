select round(avg(sal)) from emp001 a  where    a.SAL   like     '%3%'  order by  empno;

-- echo  linefun-5-15
select replace(a.ename,'A','B') from emp001 a  where   a.SAL   BETWEEN    1000 AND 2000  order by  empno;
select replace(a.ename,'A','B') from emp001 a  where    a.SAL   like     '%3%'  order by  empno;


-- echo  fun-6-1-1  一个字段             
SELECT deptno  FROM   emp001 e  where   e.SAL   BETWEEN    1000 AND 2000  GROUP    BY   e.deptno  order by  empno;
SELECT deptno  FROM   emp001 e where   e.SAL   like     '%3%' GROUP    BY   e.deptno  order by  empno;


-- echo  fun-6-1-2  多个字段                
SELECT deptno,sal  FROM   emp001 e  where   e.SAL   BETWEEN    1000 AND 2000  GROUP    BY   e.deptno ,e.sal  order by  empno;
SELECT deptno,sal  FROM   emp001 e  where   e.SAL   like     '%3%' GROUP    BY   e.deptno ,e.sal  order by  empno;

-- echo  fun-6-2  group by + having
SELECT deptno  FROM   emp001 e  where   e.SAL   BETWEEN    1000 AND 2000  GROUP    BY   e.deptno  HAVING e.deptno >10  order by  empno;
SELECT deptno  FROM   emp001 e where   e.SAL   like     '%3%' GROUP    BY   e.deptno HAVING e.deptno >10  order by  empno;



-- echo  fun-6-3  group by + order by                              
SELECT deptno  FROM   emp001 e  where   e.SAL   BETWEEN    1000 AND 2000  GROUP    BY   e.deptno  order by     e.deptno , empno;
SELECT deptno  FROM   emp001 e where   e.SAL   like     '%3%'  GROUP    BY   e.deptno  order by     e.deptno,empno;


-- echo  fun-6-4  group by + having + order by                                
SELECT deptno  FROM   emp001 e  where   e.SAL   BETWEEN    1000 AND 2000  GROUP    BY   e.deptno  HAVING e.deptno >10   order by     e.deptno, empno;
SELECT deptno  FROM   emp001 e where   e.SAL   like     '%3%' GROUP    BY   e.deptno HAVING e.deptno >10  order by     e.deptno,empno;


-- echo  fun-6-5  where + group by  + having + order by                 
SELECT deptno  FROM   emp001 e  where    e.EMPNO>0 AND    e.SAL   BETWEEN    1000 AND 2000  GROUP    BY   e.deptno  HAVING e.deptno >10   order by     e.deptno, empno;
SELECT deptno  FROM   emp001 e where    e.EMPNO>0 AND   e.SAL   like     '%3%' GROUP    BY   e.deptno HAVING e.deptno >10  order by     e.deptno,empno;


-- echo  fun-6-6   distinct与all测试                                   
SELECT DISTINCT(DEPTNO)  FROM  EMP001  e  where   e.SAL   BETWEEN    1000 AND 2000  order by  empno;
SELECT DISTINCT(DEPTNO)  FROM   emp001 e where   e.SAL   like     '%3%'  order by  empno; 

SELECT all(DEPTNO)  FROM  EMP001 e where   e.SAL   BETWEEN    1000 AND 2000  order by  empno;
SELECT all(DEPTNO)  FROM  EMP001 e where   e.SAL   like     '%3%'  order by  empno; 


-- echo  fun-6-7   嵌套测试           
SELECT *  FROM   emp001 e  where   e.sal   BETWEEN    (SELECT   1000   FROM   dual)     AND     (SELECT   2000   FROM   dual)   order by  empno;

SELECT *  FROM   emp001 e  where   e.sal   BETWEEN   (SELECT sum(sal-2000)  FROM  EMP001 e where   e.SAL   like     '%3%')      AND    (SELECT sum(sal-1000)  FROM  EMP001 e where   e.SAL   like     '%3%')   order by  empno;

-- echo  fun-6-8-1     select                    
SELECT *  FROM   emp001 e  where   e.sal   IN   (SELECT   e.sal   FROM   emp001 e  where   e.sal   BETWEEN    (SELECT   1000   FROM   dual)     AND     (SELECT   2000   FROM   dual))  order by  empno;

SELECT *  FROM   emp001 e  where   e.sal   IN   (SELECT   e.sal   FROM   emp001 e  where   e.SAL   like     '%3%')  order by  empno;

-- echo  fun-6-8-2    
SELECT hiredate,empno,sal  FROM    emp001 e    group    BY   hiredate,empno,sal    HAVING    e.sal  >any(select    avg(t.SAL)    from     emp001     t     where   t.SAL   BETWEEN    1000 AND 2000  group    BY  hiredate,empno,sal)  order by  empno;
SELECT hiredate,empno,sal  FROM    emp001 e    group    BY   hiredate,empno,sal    HAVING    e.sal  <some(select    avg(t.SAL)    from     emp001     t   where   t.SAL   BETWEEN    1000 AND 2000   group    BY hiredate,empno,sal)  order by  empno;
SELECT hiredate,empno,sal  FROM    emp001 e       where   EXISTS(select    avg(t.SAL)    from     emp001     t   where   t.SAL   BETWEEN    1000 AND 2000    group    BY    hiredate,empno,sal)    order by  empno;


SELECT hiredate,empno,sal  FROM    emp001 e    group    BY   hiredate,empno,sal    HAVING    e.sal  >any(select    avg(t.SAL)    from     emp001     t     where   t.SAL   like     '%3%'     group    BY  hiredate,empno,sal)  order by  empno;
SELECT hiredate,empno,sal  FROM    emp001 e    group    BY   hiredate,empno,sal    HAVING    e.sal  <some(select    avg(t.SAL)    from     emp001     t   where   t.SAL   like     '%3%'   group    BY hiredate,empno,sal)  order by  empno;
SELECT hiredate,empno,sal  FROM    emp001 e       where   EXISTS(select    avg(t.SAL)    from     emp001     t   where   t.SAL   like     '%3%'    group    BY    hiredate,empno,sal)    order by  empno;

-- echo  fun-6-8-3    
drop   table  if  exists   EMP003;
create table emp003  as   SELECT *  FROM   emp001 e  where   e.sal   BETWEEN    (SELECT   1000   FROM   dual)     AND     (SELECT   2000   FROM   dual);

drop   table  if  exists   EMP003;
create table emp004  as   SELECT *  FROM   emp001 e  where   e.SAL   like     '%3%';



--echo fun-7-1-1 无参数的存储过程
drop procedure if exists myproc1;
delimiter //;
create procedure myproc1()
begin  
DECLARE  a int;
DECLARE  b int;	
SELECT      sum(sal)  INTO  a    FROM      emp001   e   WHERE   e.SAL   BETWEEN    1000 AND 2000;
SELECT      sum(comm)  INTO  b      FROM      emp001  e   WHERE   e.SAL    like     '%1%';  
end;
// 
call  myproc1();//

--echo  fun-7-1-2   只有一个 in 参数的存储过程    
drop procedure if exists myproc1;//

create procedure myproc1(in num int)
begin  
DECLARE  a int;
DECLARE  b int;	
SELECT      sum(sal)  INTO  a    FROM      emp001   e   WHERE   e.SAL   BETWEEN    num AND 2000;
SELECT      sum(comm)  INTO  b      FROM      emp001  e   WHERE   e.SAL    like     '%1%';  
end;
// 
call  myproc1(1000);//


--echo   fun-7-2-1 无参数的自定义函数 
drop function  IF EXISTS fun_test;//

CREATE FUNCTION fun_test()RETURNS DOUBLE
begin
DECLARE   a int;  
DECLARE   b int; 
SELECT      sum(sal)  INTO  a    FROM      emp001   e   WHERE   e.SAL   BETWEEN    1000  AND 2000;
SELECT      sum(comm)  INTO  b      FROM      emp001  e   WHERE   e.SAL    like     '%1%';  
return(a*b);
end;
//
select  fun_test();//


--echo    fun-7-2-2        自定义函数  有参数                             

drop function  IF EXISTS fun_test;//
CREATE FUNCTION fun_test(c DOUBLE)RETURNS DOUBLE
begin
DECLARE   a int;  
DECLARE   b int; 
SELECT      sum(sal)  INTO  a    FROM      emp001   e   WHERE   e.SAL   BETWEEN   c  AND 2000;
SELECT      sum(comm)  INTO  b      FROM      emp001  e   WHERE   e.SAL    like     '%1%';  
return(a*b);
end;
//
select  fun_test(1000);//
delimiter  ;//

