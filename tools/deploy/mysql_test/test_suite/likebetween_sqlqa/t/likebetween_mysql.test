--disable_warnings
drop database  IF EXISTS  ob100x;
#create database ob100x  character set utf16;
create database ob100x  character set gbk;
use ob100x;
select database();

-- echo  虚拟表dual测试
-- echo   fun-1-1 数字测试
SELECT     1    from    dual   WHERE   1   BETWEEN    1     AND    10;
SELECT     2    from    dual   WHERE   0   BETWEEN    1     AND    10;
SELECT     3    from    dual   WHERE   10   BETWEEN  1     AND    10;
SELECT     4    from    dual   WHERE   11   BETWEEN   10   AND  10;

SELECT     1    from    dual   WHERE   1   LIKE    1;
SELECT     2    from    dual   WHERE   1   LIKE    0;
SELECT     3    from    dual   WHERE   1   LIKE    -1;
SELECT     4    from    dual   WHERE   1   LIKE    10;



-- echo   fun-1-2  字符串类型
SELECT     1   from    dual   WHERE   '1'   BETWEEN    '1'     AND    '10';
SELECT     2    from    dual   WHERE   '0'   BETWEEN    '1'     AND    '10';
SELECT     3    from    dual   WHERE   '10'   BETWEEN  '1'     AND    '10';
SELECT     4    from    dual   WHERE   '11'   BETWEEN   '10'   AND  '10';


SELECT     1    from    dual   WHERE   '1'   LIKE    '1';
SELECT     2    from    dual   WHERE   '1'   LIKE    '0';
SELECT     3    from    dual   WHERE   '1'   LIKE   '-1';
SELECT     4    from    dual   WHERE   '1'   LIKE    '10';



-- echo   fun-1-3  null测试
SELECT     null         from    dual   WHERE   null   BETWEEN    '1'     AND   '10';
SELECT     null         from    dual   WHERE   1   BETWEEN    null     AND     '10';
SELECT    1       from    dual   WHERE   null   BETWEEN  null    AND    null;
SELECT     null    from    dual   WHERE   null   BETWEEN  null    AND    null;


SELECT     1   from    dual   WHERE  null  LIKE    '1';
SELECT    2    from    dual   WHERE   '1'   LIKE    null;
SELECT    3    from    dual   WHERE   null  LIKE   null;
SELECT     null    from    dual   WHERE   null   LIKE    '10';



-- echo   fun-1-4  空测试
SELECT    ''        from    dual   WHERE   '  '   BETWEEN    '1'     AND   '10';
SELECT     '  '         from    dual   WHERE   '  '   BETWEEN    null     AND     '10';
SELECT   1       from    dual   WHERE   '  '   BETWEEN  null    AND    null;
SELECT     null    from    dual   WHERE   null   BETWEEN  null    AND    '  ';


SELECT     1    from    dual   WHERE  '  '  LIKE    '1';
SELECT     2    from    dual   WHERE   '1'   LIKE    '  ';
SELECT     ' '    from    dual   WHERE   '  '  LIKE   null;
SELECT     null    from    dual   WHERE   null   LIKE    '  ';



-- echo   fun-1-5  其他测试  
SELECT    '  '，null       from    dual   WHERE   '  '   BETWEEN    '1'     AND   '10';
SELECT     '  '，NULL,100        from    dual   WHERE   '  '   BETWEEN    null     AND     '';
SELECT     '  '，NULL,0         from    dual   WHERE   '  '   BETWEEN  1    AND    null;
SELECT      '  '，NULL,100    from    dual   WHERE   null   BETWEEN  ''    AND    '  ';

SELECT   1   from    dual   WHERE   1   BETWEEN    100     AND    10;
SELECT    100    from    dual   WHERE   1   BETWEEN    100     AND    100;

SELECT    1                       from    dual   WHERE  '  '  LIKE    '1';
SELECT    ''                       from    dual   WHERE   '1'   LIKE    '  ';
SELECT     null                 from    dual   WHERE   1 LIKE   null;
SELECT     '  '，NULL,100  from    dual   WHERE   null   LIKE    '  ';
SELECT   10    from    dual   WHERE   1  LIKE    1000;



