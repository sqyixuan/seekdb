-- echo fun-5-1  concat
select  concat(a.ename,a.job)  from emp001  a  where   a.SAL   BETWEEN    1000 AND 2000  order by  empno;
select  concat(a.ename,a.job)  from emp001  a  where   a.SAL   like     '%3%'  order by  empno;


-- echo  linefun-5-3
select   instr(a.ename,'A')  from emp001  a  where   a.SAL   BETWEEN    1000 AND 2000  order by  empno;
select   instr(a.ename,'A')  from emp001  a  where   a.SAL   like     '%3%'  order by  empno;

-- echo  linefun-5-4
select   length(a.ename)   from  emp001  a  where   a.SAL   BETWEEN    1000 AND 2000  order by  empno;
select   length(a.ename)   from  emp001  a  where   a.SAL   like     '%3%'  order by  empno;

-- echo  linefun-5-6
select   lower(a.ename)   from  emp001  a  where   a.SAL   BETWEEN    1000 AND 2000  order by  empno;
select   lower(a.ename)   from  emp001  a  where   a.SAL   like     '%3%'  order by  empno;

-- echo  linefun-5-7
select   upper(a.ename)   from  emp001  a  where   a.SAL   BETWEEN    1000 AND 2000  order by  empno;
select   upper(a.ename)   from  emp001  a  where   a.SAL   like     '%3%'  order by  empno;

-- echo  linefun-5-8
select lpad(a.ename,20,'*') from  emp001  a  where   a.SAL   BETWEEN    1000 AND 2000  order by  empno;
select lpad(a.ename,20,'*') from  emp001  a  where   a.SAL   like     '%3%'  order by  empno;

-- echo  linefun-5-9
select rpad(a.ename,20,'*') from  emp001  a  where   a.SAL   BETWEEN    1000 AND 2000  order by  empno;
select rpad(a.ename,20,'*') from  emp001  a  where   a.SAL   like     '%3%'  order by  empno;


-- echo  linefun-5-10
SELECT trim(both  'a' from a.ename) asdf FROM emp001  a  where   a.SAL   BETWEEN    1000 AND 2000  order by  empno;
SELECT trim(both  'a' from a.ename) asdf FROM emp001  a  where     a.SAL   like     '%3%'  order by  empno;

-- echo  linefun-5-11
select abs(a.sal-5000) from emp001  a  where   a.SAL   BETWEEN    1000 AND 2000  order by  empno;
select abs(a.sal-5000) from emp001  a  where  a.SAL   like     '%3%'  order by  empno;


-- echo  linefun-5-12
select ceil(avg(sal)) from emp001 a  where   a.SAL   BETWEEN    1000 AND 2000  order by  empno;
select ceil(avg(sal)) from emp001 a  where    a.SAL   like     '%3%'  order by  empno;

-- echo  linefun-5-13
select floor(avg(sal)) from emp001 a  where   a.SAL   BETWEEN    1000 AND 2000  order by  empno;
select floor(avg(sal)) from emp001 a  where    a.SAL   like     '%3%'  order by  empno;

 
-- echo  linefun-5-14
