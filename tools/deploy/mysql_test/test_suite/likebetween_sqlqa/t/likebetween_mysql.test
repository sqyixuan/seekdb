-- echo   fun-3-1     算术运算符               
SELECT * FROM emp001     where    deptno-20    BETWEEN   -10   AND      0   order by  empno;
SELECT * FROM emp001     where    deptno+20    BETWEEN   -10   AND     0   order by  empno;
SELECT * FROM emp001     where    deptno*20    BETWEEN   -10   AND      0   order by  empno;
SELECT * FROM emp001     where    deptno/20*10    BETWEEN   10   AND  10   order by  empno;

SELECT * FROM emp001     where    deptno+20     LIKE  '%1%'   order by  empno;
SELECT * FROM emp001     where    deptno-20     LIKE  '%1%'   order by  empno;
SELECT * FROM emp001     where    deptno*20     LIKE  '%1%'   order by  empno;
SELECT * FROM emp001     where    deptno/20     LIKE  '%1%'   order by  empno;


SELECT * FROM emp002     where    deptno-20    BETWEEN   -10   AND      0   order by  empno;
SELECT * FROM emp002     where    deptno+20    BETWEEN   -10   AND     0   order by  empno;
SELECT * FROM emp002     where    deptno*20    BETWEEN   -10   AND      0   order by  empno;
SELECT * FROM emp002     where    deptno/20*10    BETWEEN   10   AND  10   order by  empno;

SELECT * FROM emp002     where    deptno+20     LIKE  '%1%'   order by  empno;
SELECT * FROM emp002     where    deptno-20     LIKE  '%1%'   order by  empno;
SELECT * FROM emp002     where    deptno*20     LIKE  '%1%'   order by  empno;
SELECT * FROM emp002     where    deptno/20     LIKE  '%1%'   order by  empno;


-- echo   fun-3-2    比较，逻辑运算符               
SELECT    *     FROM    emp001     where    deptno    BETWEEN   -10   AND    10  AND  deptno<=0   AND  deptno   >=-10   order by  empno;
SELECT    *     FROM    emp001     where    deptno    BETWEEN   -10   AND    10  AND  deptno<=10   AND  deptno   >=-10   order by  empno;
SELECT    *     FROM    emp001     where    deptno    BETWEEN   -10   AND    10  AND  deptno<10   AND  deptno   >-10   order by  empno;
SELECT    *     FROM    emp001     where    deptno    BETWEEN   -10   AND    10  AND  deptno !=10   order by  empno;

SELECT * FROM emp001     where    deptno    LIKE  '%2%'   AND  deptno<20   order by  empno;
SELECT * FROM emp001     where    deptno    LIKE  '%2%'   AND  deptno=20   order by  empno;

SELECT    *     FROM    emp002     where    deptno    BETWEEN   -10   AND    10  AND  deptno<=0   AND  deptno   >=-10   order by  empno;
SELECT    *     FROM    emp002     where    deptno    BETWEEN   -10   AND    10  AND  deptno<=10   AND  deptno   >=-10   order by  empno;
SELECT    *     FROM    emp002     where    deptno    BETWEEN   -10   AND    10  AND  deptno<10   AND  deptno   >-10   order by  empno;
SELECT    *     FROM    emp002     where    deptno    BETWEEN   -10   AND    10  AND  deptno !=10   order by  empno;

SELECT * FROM emp002     where    deptno    LIKE  '%2%'   AND  deptno<20   order by  empno;
SELECT * FROM emp002     where    deptno    LIKE  '%2%'   AND  deptno=20   order by  empno;

 

-- echo   fun-3-3   连接运算符               
