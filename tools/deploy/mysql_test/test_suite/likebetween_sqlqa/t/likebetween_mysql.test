-- echo   fun-4-1-8  1万条数据
TRUNCATE TABLE  emp001;
drop procedure if exists myproc1;
delimiter //;
create procedure myproc1()
begin
declare  i  BIGINT  default   0;
set  i=0;
while  i<1000  do
insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (i, 'atom', 'CLERK', 7782, '1111-01-01', 1300, null, 10);
insert into EMP002 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (i, 'atom', 'CLERK', 7782, '1211-01-01', 1300, null, 10);
set i=i+1;
end while;
end;
//

DELIMITER ;//
call  myproc1();
select count(*)   from  EMP001;
select count(*)   from  EMP002;
SELECT        *     FROM      emp001   e     WHERE   e.empno   BETWEEN    999  AND 1000  order by  empno;
SELECT        *     FROM      emp002   e     WHERE   e.empno   BETWEEN    999  AND 1000  order by  empno;

SELECT        *     FROM      emp001   e     WHERE     e.empno   like     '%100%'  order by  empno;  
SELECT        *     FROM      emp002   e     WHERE     e.empno   like     '%100%'  order by  empno;



-- echo   多表查询测试        
#普通表
