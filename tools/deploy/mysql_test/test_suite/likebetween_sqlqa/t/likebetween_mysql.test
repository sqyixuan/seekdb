--echo   fun-8-9
drop database  IF EXISTS  ob100x;
create database ob100x  character set gbk;
use ob100x;
select database();

drop   table  if  exists   EMP001;
create table EMP001(empno bigint,ename VARCHAR(100) character set gbk,job VARCHAR(100)  character set utf8,mgr int,hiredate DATE,sal float(7,0),comm float(9,0),deptno int) CHARACTER SET = utf8;


insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7499, 'SMITH', 'smith', 7698, '1981-05-06', 1600, 300, 30);
insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7369, 'SMITH', 'SMITH', 7902, '1980-05-06', 800, null, 20);
select * from EMP001 e where  e.ename    like '%H'  order by  empno;

insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (1, 'dog', 'dog', 7369,'2018-05-06', 5000, 5000, 10);
select * from EMP001 e where  e.ename    like  job   order by  e.empno;

insert     into   EMP001(empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7934, 'd%a', 'CLERK', 7782,'1992-05-06', 1300, null, 10);
SELECT   *  FROM    EMP001  e   WHERE   e.ENAME    like '%\%%'  escape  '\\' order by  e.empno;

insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7935, 'd%a', 'CLERK', 7782,'1992-05-06', 1300, null, 10);
SELECT   *  FROM    EMP001  e   WHERE   e.ENAME    like   '%\%%'  order by  e.empno; 


insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7521, 'ハハ中国人民は立ち上がった', 'ハハ中国人民は立ち上がった', 7698, '1982-05-06', 1250, 500, 30);
SELECT   *  FROM    EMP001  e   WHERE   e.ENAME    like   'ハハ%' order by  e.empno; 

--error 1366
insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7566, '♫ 중국인들은 일어섰고 ♫', 'MANAGER', 7839, '1983-05-06', 2975, null, 20);

SELECT   *  FROM    EMP001  e   WHERE   e.ENAME    like   '♫%';
--error 1366
insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7566, '중국인들은 일어섰고', 'MANAGER', 7839, '1983-05-06', 2975, null, 20);

SELECT   *  FROM    EMP001  e   WHERE   e.ENAME    like   '중%'; 

insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7654, 'Китайский народ встал на ноги', 'SALESMAN', 7698,'1984-05-06', 1250, 1400, 30);
SELECT   *  FROM    EMP001  e   WHERE   e.ENAME    like   'Ки%'  order by  e.empno; 

insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7698, '!@#$%', '!@#$%', 7839, '1985-05-06', 2850, null, 30);
SELECT   *  FROM    EMP001  e   WHERE   e.ENAME    like   '!%' order by  e.empno; 

insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7788, '@@@###$$$', '$$$%%%^^^', 7566,'1986-05-06', 3000, null, 20);
SELECT   *  FROM    EMP001  e   WHERE   e.ENAME    like   '@%'  order by  e.empno; 

insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7839, '张三三', '张三三', null,'1987-05-06', 5000, null, 10);
SELECT   *  FROM    EMP001  e   WHERE   e.ENAME    like   '张%'  order by  e.empno; 
truncate table  emp001;
insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7844, '李四四', '王五五', 7698, '1988-05-06', 1500, 0, 30);
SELECT   *  FROM    EMP001  e   WHERE   e.ENAME    like   '%四'   or     e.ENAME  like   '%五'   order by  e.empno; 
sleep 3;
insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7876, 'ADAMS', 'null', 7788,'1989-05-06', 1100, null, 20);
SELECT   *  FROM    EMP001  e   WHERE   e.ENAME    like   '%四'   or     e.ENAME  like   null  order by  e.empno;

insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7900, '%****%', 'CLERK', 7698,'1990-05-06', 950, null, 30);
SELECT   *  FROM    EMP001  e   WHERE   e.ENAME    like   '%%'  order by  e.empno; 

insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7902, 'FORD', 'ANALYST', 7566,'1991-05-06', 3000, 3000, 20);
SELECT   *  FROM    EMP001  e   WHERE   e.ENAME    like   'F%'  order by  e.empno; 

insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno)values (7934, 'MILLER', 'CLERK', 7782,'1992-05-06', 1300, null, 10);
SELECT   *  FROM    EMP001  e   WHERE   e.hiredate    like   '19%'  order by  e.empno; 

select * from EMP001 e where  e.ename    like  job  order by  empno;



drop database  IF EXISTS  ob100x;
create database ob100x  character set utf16;
use ob100x;
select database();

