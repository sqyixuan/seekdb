--disable_result_log
-- echo  fun-4-1-9-1  内连接
SELECT        *     FROM      emp001  a,emp002  b     WHERE   a.SAL   BETWEEN    1000 AND 2000   AND   b.SAL  BETWEEN    2000 AND 3000 ;
SELECT        *     FROM      emp001  a,emp002  b     WHERE   a.SAL    like     '%3%';  

-- echo fun-4-1-9-2   全连接full join
SELECT * FROM emp001 a
LEFT JOIN emp002 b on a.SAL   BETWEEN    1000 AND 2000   AND   b.SAL  BETWEEN    2000 AND 3000
UNION
SELECT * FROM emp001 a
RIGHT JOIN emp002 b on a.SAL   BETWEEN    1000 AND 2000   AND   b.SAL  BETWEEN    2000 AND 3000;


SELECT * FROM emp001 a
LEFT JOIN emp002 b on    a.SAL    like     '%3%'
UNION
SELECT * FROM emp001 a
RIGHT JOIN emp002 b on    a.SAL    like     '%3%';


-- echo fun-4-1-9-3 #左连接  左外连接
select * from emp001 a  left  join  emp002 b on a.SAL   BETWEEN    1000 AND 2000   AND   b.SAL  BETWEEN    2000 AND 3000 ;
select * from emp001 a  left  outer join  emp002 b on a.SAL   BETWEEN    1000 AND 2000   AND   b.SAL  BETWEEN    2000 AND 3000 ;

select * from emp001 a  left  join  emp002 b on    a.SAL    like     '%3%';  
select * from emp001 a  left  outer join  emp002 b  on    a.SAL    like     '%3%';  

-- echo  fun-4-1-9-4 #右连接  右外连接
select * from emp001 a  right  join  emp002 b on a.SAL   BETWEEN    1000 AND 2000   AND   b.SAL  BETWEEN    2000 AND 3000 ;
select * from emp001 a  right   OUTER   join  emp002 b on a.SAL   BETWEEN    1000 AND 2000   AND   b.SAL  BETWEEN    2000 AND 3000 ;

select * from emp001 a  right  join  emp002 b on    a.SAL    like     '%3%';  
select * from emp001 a  right   OUTER   join  emp002 b on    a.SAL    like     '%3%';  


-- echo   fun-4-2-1   视图 
create     or     replace       view        emp_view   as   SELECT    *     from    emp001;
SELECT         *     FROM      emp_view   e     WHERE   e.ename   BETWEEN    'A'  AND 'B';
SELECT        *      from       emp_view  a   WHERE    a.SAL    like     '%3%';


-- echo  fun-4-2-2  内，外，左，右连接
#内连接
SELECT        *     FROM      emp_view  a,emp_view  b     WHERE   a.SAL   BETWEEN    1000 AND 2000   AND   b.SAL  BETWEEN    2000 AND 3000 ;
SELECT        *     FROM      emp_view  a,emp_view  b     WHERE   a.SAL    like     '%3%';  


#全连接full join
SELECT * FROM emp_view a
LEFT JOIN emp_view b on a.SAL   BETWEEN    1000 AND 2000   AND   b.SAL  BETWEEN    2000 AND 3000
UNION
SELECT * FROM emp_view a
RIGHT JOIN emp_view b on a.SAL   BETWEEN    1000 AND 2000   AND   b.SAL  BETWEEN    2000 AND 3000;


SELECT * FROM emp_view a
LEFT JOIN emp_view b on    a.SAL    like     '%3%'
UNION
SELECT * FROM emp_view a
RIGHT JOIN emp_view b on    a.SAL    like     '%3%';

#左连接  左外连接
select * from emp_view a  left  join  emp_view b on a.SAL   BETWEEN    1000 AND 2000   AND   b.SAL  BETWEEN    2000 AND 3000 ;
select * from emp_view a  left  outer join  emp_view b on a.SAL   BETWEEN    1000 AND 2000   AND   b.SAL  BETWEEN    2000 AND 3000 ;

select * from emp_view a  left  join  emp_view b on    a.SAL    like     '%3%';  
select * from emp_view a  left  outer join  emp_view b  on    a.SAL    like     '%3%';  

#右连接  右外连接
select * from emp_view a  right  join  emp_view b on a.SAL   BETWEEN    1000 AND 2000   AND   b.SAL  BETWEEN    2000 AND 3000 ;
select * from emp_view a  right   OUTER   join  emp_view b on a.SAL   BETWEEN    1000 AND 2000   AND   b.SAL  BETWEEN    2000 AND 3000 ;
select * from emp_view a  right  join  emp_view b on    a.SAL    like     '%3%';  
select * from emp_view a  right   OUTER   join  emp_view b on    a.SAL    like     '%3%';  


