#约束
#OB不支持此函数check约束，MYSQL正常执行
create table test1(c1 datetime,c2 datetime,CONSTRAINT t_check CHECK(c1 BETWEEN convert_tz('2010-10-01 00:00:00','+00:00','+00:00') and convert_tz('2021-10-01 00:00:00','+00:00','+00:00')));
drop table test1;
create table test1(c1 datetime,c2 datetime not null);
