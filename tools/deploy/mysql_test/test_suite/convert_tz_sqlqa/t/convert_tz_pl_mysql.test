#description:procedure/function
#author: wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--echo	#procedure
--echo	#无参数
drop  table  if exists t1;
drop  procedure if exists pro1;

delimiter //;
create procedure pro1()
begin
    declare c1 timestamp;
    declare c2 timestamp;
    declare c3 timestamp;
    set c1= '2022-05-06 10:00:00';
    set c2 = '1999-09-09 22:00:00';
    set c3 = '2000-01-01 01:00:00';
    create table t1(c1 timestamp,c2 timestamp,c3 timestamp);
    insert into t1 values(convert_tz(c1,'-10:00','+05:00'),
	   	   convert_tz(c2,'+07:00','+10:00'),
		   convert_tz(c3,'+00:00','+00:00')
    );
    select * from t1;
end//

delimiter ;//
call pro1();
select  *  from  t1;

--echo	#有参数
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa timestamp,bb timestamp);
delimiter //;
create procedure pro1(a1 timestamp, a2 timestamp)
begin
       insert into t1 values('2022-05-06 10:00:00','2022-05-06 10:00:00');
       insert into t1 values('2000-01-01 01:00:00','2000-01-01 01:00:00');
       select sum(a1),sum(a2)  from  t1;
end//
delimiter ;//
call   pro1(convert_tz('2004-02-29 12:00:00','+00:00','+10:00'),convert_tz('2012-12-12 12:12:12','+00:00','+00:00'));
select   *   from  t1;


--echo	#条件语句
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa timestamp,bb timestamp);
delimiter //;
create procedure pro1(a timestamp)
begin
        declare  i timestamp;
        set  i  = convert_tz('2021-10-28 14:14:00','+00:00','+00:00') ;
        if    i<a   then
        insert into t1 values('2022-05-06 10:00:00','2022-05-06 10:00:00');
        end if;
        insert into t1 values('2000-01-01 01:00:00','2000-01-01 01:00:00');
end//
delimiter ;//
call   pro1(convert_tz('2020-10-10 10:00:00','+00:00','+00:00'));
select   *   from  t1;



--echo	#循环语句
--echo	#repeat
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1()
begin
Declare a1 timestamp default convert_tz('2000-01-01 08:00:00','+00:00','+00:00');
Declare sum timestamp default convert_tz('2010-01-01 08:00:00','+00:00','+00:00');
repeat
set sum=sum+convert_tz('2000-01-01 08:00:00','+00:00','+00:00');
set a1 = a1+convert_tz('1010-01-01 08:00:00','+00:00','+00:00');
until a1>=convert_tz('2000-01-01 08:00:00','+00:00','+00:00')
end repeat;
select sum;
end//
delimiter ;//
call pro1();

--echo	#where
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa timestamp,bb timestamp);
delimiter //;
create procedure pro1(a timestamp)
begin
      declare i timestamp;
      set i =convert_tz('2021-10-01 08:00:00','+00:00','+00:00');
      while i>a
      do
           insert into t1 values(i,a);
           set i=i+'0001-01-01 01:00:00';
      end while;
end//
delimiter ;//
call pro1(convert_tz('2021-09-01 08:00:00','+00:00','+00:00'));
select * from t1;


--echo	#loop


--echo	#function 
--echo	#无参数

drop  table  if exists t1;
drop  function if exists func1;
create table t1(c1 timestamp,c2 timestamp,c3 timestamp);
delimiter //;
create function  func1()   returns  timestamp
begin
    declare c1 timestamp;
    declare c2 timestamp;
    declare c3 timestamp;
    set c1= '2022-05-06 10:00:00';
    set c2 = '1999-09-09 22:00:00';
    set c3 = '2000-01-01 01:00:00';
    insert into t1 values(convert_tz(c1,'-10:00','+05:00'),
                   convert_tz(c2,'+07:00','+10:00'),
                   convert_tz(c3,'+00:00','+00:00')
    );
    return convert_tz('2020-10-10 10:10:00','+07:00','+10:00');
end//

delimiter ;//
select func1();
select  *  from  t1;


--echo	#有参数

drop   table     if   exists   t1;
drop   function if exists func1;
create table t1(aa timestamp,bb timestamp);
delimiter //;
create function  func1(a1 timestamp, a2 timestamp)  returns  timestamp
begin
       insert into t1 values('2022-05-06 10:00:00','2022-05-06 10:00:00');
       insert into t1 values('2000-01-01 01:00:00','2000-01-01 01:00:00');
       return convert_tz('2004-02-29 12:00:00','+00:00','+10:00');
end//
delimiter ;//
select   func1(convert_tz('2004-02-29 12:00:00','+00:00','+10:00'),convert_tz('2012-12-12 12:12:12','+00:00','+00:00'));
select   *   from  t1;

--echo	#条件语句
drop   table      if   exists   t1;
drop   function   if   exists   func1;
create table  t1 (aa  timestamp, bb timestamp);
delimiter //;
create  function  func1()   returns  timestamp
begin
      declare  i    timestamp;
      set   i = convert_tz('2000-01-01 08:00:00','+00:00','+00:00');
      if    i < convert_tz('1998-01-01 08:00:00','+00:00','+00:00')  then
          insert into t1 values('2022-05-06 10:00:00','2022-05-06 10:00:00');
      end if;
        return convert_tz('2018-08-08 08:00:00','+00:00','+00:00');
end//
delimiter ;//
select func1();
select   *   from   t1;


--echo	#循环语句
drop   table     if   exists   t1;
drop   function if   exists   func1;
create table t1(aa timestamp,bb timestamp);
delimiter //;
create function func1(a timestamp) returns timestamp
begin
      declare i timestamp;
      set i =convert_tz('2010-01-01 08:00:00','+00:00','+00:00');
      while i>a
      do
           insert into t1 values('2022-05-06 10:00:00','2022-05-06 10:00:00');
           set i=i+'0001-01-01 01:00:00';
      end while;
      return convert_tz('2018-08-08 08:00:00','+00:00','+00:00');
end//
delimiter ;//
select func1(convert_tz('2022-05-06 10:00:00','+00:00','+00:00'));
select * from t1;

drop table t1;
drop database db1;
