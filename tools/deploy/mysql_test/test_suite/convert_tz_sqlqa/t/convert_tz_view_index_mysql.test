select  convert_tz('2021-10-01 08:00:00','+00:00','+00:00') >= null;

select  convert_tz('2021-10-01 08:00:00','+00:00','+00:00') <= '2021-10-01 08:00:00';
select  convert_tz('2021-10-01 08:00:00','+00:00','+00:00') <= convert_tz('2021-10-01 08:00:00','+00:00','+00:00');
select  convert_tz('2021-10-01 08:00:00','+00:00','+00:00') <= '202110010800';
select  convert_tz('2021-10-01 08:00:00','+00:00','+00:00') <= 123;
select  convert_tz('2021-10-01 08:00:00','+00:00','+00:00') <= 'abcd';
select  convert_tz('2021-10-01 08:00:00','+00:00','+00:00') <= '张三';
select  convert_tz('2021-10-01 08:00:00','+00:00','+00:00') <= '￥%……&*';
select  convert_tz('2021-10-01 08:00:00','+00:00','+00:00') <= null;

select  convert_tz('2021-10-01 08:00:00','+00:00','+00:00') != '2021-10-01 08:00:00';
select  convert_tz('2021-10-01 08:00:00','+00:00','+00:00') != convert_tz('2021-10-01 08:00:00','+00:00','+00:00');
