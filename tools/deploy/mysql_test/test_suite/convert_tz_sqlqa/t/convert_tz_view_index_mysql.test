#tags: mysql
#description:view、index
#author: wb-zwc01059807
--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--echo	#VIEW
create table test1(a1 int,a2 year,c1 datetime,c2 datetime);
create view v1_test as select * from test1;
insert into v1_test values(1,'1998','1998-12-12 12:12:12','2038-01-19 03:14:07');
insert into v1_test values(2,'2002','2002-02-02 10:00:00','2034-02-22 00:50:20');
insert into v1_test values(3,'2006','2006-04-15 06:06:20','2038-01-19 03:14:07');
insert into v1_test values(4,'2012','2012-12-12 12:12:12','2030-08-16 14:05:50');
select * from v1_test;
--echo	#where
select * from v1_test where convert_tz(c1,'+00:00','+02:00')>'2000-09-23 10:36:20';
select * from v1_test where convert_tz(c1,'+00:00','+02:00')>'2000-09-23 10:36:20' and convert_tz(c2,'+10:00','+00:00')<'2034-02-22 00:50:20';
select * from v1_test where convert_tz(c1,'+00:00','+00:00')>'2006-04-15 06:06:20' or convert_tz(c2,'+00:00','+10:00')='2034-02-22 10:50:20';

--echo	#order by
select * from v1_test order by convert_tz(c1,'+00:00','+05:00') desc;
select * from v1_test order by convert_tz(c2,'+00:00','+05:00') asc;
select * from v1_test where convert_tz(c1,'+00:00','+02:00')>'2000-09-23 10:36:20' order by convert_tz(c1,'+00:00','+05:00') desc;

--echo	#group by
select * from v1_test group by convert_tz(c1,'+06:50','+00:00');
select * from v1_test group by convert_tz(c2,'+00:00','+05:05');

--echo	#group having
select * from v1_test group by convert_tz(c1,'+00:00','+00:00') having convert_tz(c1,'+00:00','+00:00')>'2006-04-15 06:06:20';
select * from v1_test where convert_tz(c2,'+00:00','+00:00')>'2030-08-16 14:05:50' group by convert_tz(c2,'+10:00','+10:00') having convert_tz(c2,'+00:00','+00:00')<'2038-01-19 03:14:07';

--echo	#case when
select c1,c2 ,case c1 when convert_tz(c1,'+06:00','+00:00')<'2006-04-15 06:06:20' then convert_tz('2020-02-02 02:02:02','+00:00','+00:00') else convert_tz('1999-09-09 09:09:09','+00:00','+00:00') end as c1 from v1_test;

--echo	#distinct
select distinct convert_tz(c2,'+00:00','+10:00') from v1_test;
select distinct convert_tz(c1,'+00:00','+10:00') from v1_test;
drop table test1;
drop view v1_test;

--echo	#INSERT
create table test1(c1 datetime,c2 datetime);
create view v1_test as select * from test1;
insert into v1_test(c1) values(convert_tz('1998-12-12 12:12:12','+01:01','+10:01'));
select * from v1_test;
insert into v1_test(c2) values(convert_tz('2000-01-01 10:10:10','+00:00','+00:00'));
select * from v1_test;
drop table test1;
drop view v1_test;

--echo	#视图表中插入函数
