--echo	#分区
--echo	#hash分区
--error 1659
create table test1(c1 timestamp) partition by hash(c1);
--error 1659
create table test1(c1 datetime) partition by hash(c1);

--echo	#list分区
--error 1659
create table test1(c1 timestamp) partition by list(c1)(partition p2 values in(convert_tz('2021-10-01 08:00:00','+00:00','+00:00'),convert_tz('1998-10-01 08:00:00','+00:00','+00:00')));
--error 1659
create table test1(c1 datetime) partition by list(c1)(partition p2 values in(convert_tz('2021-10-01 08:00:00','+00:00','+00:00'),convert_tz('1998-10-01 08:00:00','+00:00','+00:00')));


--echo	#key 分区
create table test1(c1 timestamp) partition by key(c1);
insert into test1 partition(p0) values(convert_tz('2021-10-01 08:00:00','+00:00','+00:00'));
REPLACE into test1 partition(p0) values(convert_tz('1998-10-01 08:00:00','+00:00','+00:00'));
update test1 partition(p0) set c1 = convert_tz('2020-10-01 08:00:00','+00:00','+00:00') where c1 = convert_tz('2021-10-01 08:00:00','+00:00','+00:00');
delete from test1 partition(p0) where c1<convert_tz('2020-10-01 08:00:00','+00:00','+00:00');
SELECT * from  test1 partition(p0);
drop table test1;

create table test1(c1 datetime) partition by key(c1);
insert into test1 partition(p0) values(convert_tz('2021-10-01 08:00:00','+00:00','+00:00'));
REPLACE into test1 partition(p0) values(convert_tz('1998-10-01 08:00:00','+00:00','+00:00'));
update test1 partition(p0) set c1 = convert_tz('2020-10-01 08:00:00','+00:00','+00:00') where c1 = convert_tz('2021-10-01 08:00:00','+00:00','+00:00');
delete from test1 partition(p0) where c1<convert_tz('2020-10-01 08:00:00','+00:00','+00:00');
SELECT * from  test1 partition(p0);
drop table test1;


--echo	#range分区
--error 1659
create table test1(c1 timestamp) partition by range(c1)(partition p0 VALUES less than MAXVALUE);


drop database db1;
