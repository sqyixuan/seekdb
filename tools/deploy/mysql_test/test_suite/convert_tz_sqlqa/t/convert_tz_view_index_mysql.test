--echo	#UPDATE   view
create table test1(a1 int,a2 year,c1 datetime,c2 datetime);
create view v1_test as select * from test1;
insert into v1_test values(1,'1998',convert_tz('1998-12-12 12:12:12','+00:00','+00:00'),convert_tz('2038-01-19 03:14:07','+00:00','+00:00'));
insert into v1_test values(2,'2002',convert_tz('2002-02-02 10:00:00','+00:00','+00:00'),convert_tz('2034-02-22 00:50:20','+00:00','+00:00'));
insert into v1_test values(3,'2006',convert_tz('2006-04-15 06:06:20','+00:00','+00:00'),convert_tz('2026-05-08 05:16:50','+00:00','+00:00'));
insert into v1_test values(4,'2012',convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2030-08-16 14:05:50','+00:00','+00:00'));
select * from v1_test;
--echo	#单行
update v1_test set c1 = convert_tz('2020-10-14 08:50:00','+00:00','+00:00') where c2 =convert_tz('2026-05-08 05:16:50','+00:00','+00:00');
select * from v1_test;
--echo	#多行
update v1_test set c1 = convert_tz('2008-08-08 08:50:00','+00:00','+00:00') where c2 >convert_tz('2030-08-16 14:05:50','+00:00','+00:00');
select * from v1_test;

--echo	#delete view
--echo	#单行
delete from v1_test where c1 = convert_tz('2008-08-08 08:50:00','+00:00','+00:00') and c2=convert_tz('2038-01-19 03:14:07','+00:00','+00:00');
select * from v1_test;
--echo	#多行
delete from v1_test where c2 > convert_tz('2026-05-08 05:16:50','+00:00','+00:00');
select * from v1_test;
delete from v1_test;
drop table test1;
drop view v1_test;

--echo	#约束
--echo	#OB不支持此函数check约束，MYSQL正常执行
create table test1(c1 datetime,c2 datetime,CONSTRAINT t_check CHECK(c1 BETWEEN convert_tz('2010-10-01 00:00:00','+00:00','+00:00') and convert_tz('2021-10-01 00:00:00','+00:00','+00:00')));
drop table test1;
create table test1(c1 datetime,c2 datetime not null);
--echo	#OB报错，MYSQL执行成功。
--error 1048
insert into test1 values(convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz(null,null,null));
insert into test1 values(convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2012-12-12 12:12:12','+00:00','+00:00'));
--echo	#OB不支持。
--error 1235
alter table test1 add c3 timestamp PRIMARY key;
update test1 set c1 = convert_tz('2021-10-01 10:00:00','+00:00','+00:00') where c1 = convert_tz('2012-12-12 12:12:12','+00:00','+00:00');
select * from test1;
delete from test1 where c2 = convert_tz('2012-12-12 12:12:12','+00:00','+00:00');
select * from test1;
drop table test1;

--echo	#索引
create table test1(c1 datetime,c2 datetime);
insert into test1 values(convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2012-12-12 12:12:12','+00:00','+00:00'));
create index t_index on test1(c1);
insert into test1 values(convert_tz('1998-12-12 12:12:12','+00:00','+00:00'),convert_tz('2020-12-12 12:12:12','+00:00','+00:00'));
update test1 set c1 = convert_tz('2000-01-01 00:00:00','+00:00','+00:00') where c2 = convert_tz('2020-12-12 12:12:12','+00:00','+00:00');
select convert_tz(c1,'+00:00','+10:00') from test1;
delete from test1 where c2 = convert_tz('2012-12-12 12:12:12','+00:00','+00:00');
drop table test1;

--echo	#运算符
--echo	#算术运算符
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')-convert_tz('2000-12-12 12:12:12','+00:00','+00:00');
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')-123;
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')-'202109271534';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')-'2000-12-12 12:12:12';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')-'aaccccccdddddddddd';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')-'张三';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')-'@#$%^&*';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')-null;

select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')+convert_tz('2000-12-12 12:12:12','+00:00','+00:00');
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')+123;
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')+'123';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')+'2000-12-12 12:12:12';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')+'aaccccccdddddddddd';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')+'张三';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')+'@#$%^&*';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')+null;

select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')*convert_tz('2000-12-12 12:12:12','+00:00','+00:00');
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')*123;
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')*'123';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')*'2000-12-12 12:12:12';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')*'aaccccccdddddddddd';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')*'张三';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')*'@#$%^&*';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')*null;

select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')/convert_tz('2000-12-12 12:12:12','+00:00','+00:00');
--echo	#OB与MYSQL不一致，MYSQL更高
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')/123;
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')/'123';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')/'2000-12-12 12:12:12';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')/'aaccccccdddddddddd';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')/'张三';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')/'@#$%^&*';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')/null;

select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')%convert_tz('2000-12-12 12:12:12','+00:00','+00:00');
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')%123;
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')%'123';
select convert_tz('2012-12-12 12:12:12','+00:00','+00:00')%'2000-12-12 12:12:12';
