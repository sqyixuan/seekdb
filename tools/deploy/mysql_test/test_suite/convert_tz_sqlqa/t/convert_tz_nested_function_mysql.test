#owner: dachuan.sdc
#owner group: SQL-SQL2
#tags: mysql
#description:函数嵌套
#author: wb-zwc01059807
--disable_warnings
drop database if exists db1;
--enable_warnings

set timestamp = 1600000000;

create database db1;
use db1;
--echo	#now
select convert_tz(now(),'-12:00','+00:00');

--echo	#date
select date(convert_tz('2020-10-01 08:00:00','-10:00','+12:00'));
select convert_tz(date('2021-10-01 08:00:00'),'+10:00','-05:00');

--echo	#curdate
select convert_tz(curdate(),'-10:00','+12:00');
select convert_tz(curdate() + 0,'-10:00','+12:00');

--echo	#date_add
SELECT DATE_ADD(convert_tz('2020-10-01 08:00:00','+00:00','+00:00'),INTERVAL 1 DAY);
SELECT DATE_ADD(convert_tz('2020-10-01 08:00:00','+00:00','+00:00'),INTERVAL 1 SECOND);
SELECT DATE_ADD(convert_tz('2020-10-01 08:00:00','+00:00','+00:00'),INTERVAL 1 YEAR);
SELECT DATE_ADD(convert_tz('2020-10-01 08:00:00','+00:00','+00:00'),INTERVAL '1:1' MINUTE_SECOND);
SELECT DATE_ADD(convert_tz('2020-10-01 08:00:00','+00:00','+00:00'),INTERVAL '1 1:1:1' DAY_SECOND);
SELECT DATE_ADD(convert_tz('2020-10-01 08:00:00','+00:00','+00:00'),INTERVAL '-1 10' DAY_HOUR);
SELECT DATE_ADD(convert_tz('2020-10-01 08:00:00','+00:00','+00:00'),INTERVAL 31 DAY);
SELECT DATE_ADD(convert_tz('2020-10-01 08:00:00','+00:00','+00:00'),INTERVAL '1.999999' SECOND_MICROSECOND);

select convert_tz(DATE_ADD('2018-05-01',INTERVAL 1 DAY),'+10:00','+02:00');
select convert_tz(DATE_SUB('2018-05-01',INTERVAL 1 YEAR),'+10:00','+02:00');
select convert_tz(DATE_ADD('2020-12-31 23:59:59',INTERVAL 1 SECOND),'+10:00','+02:00');
select convert_tz(DATE_ADD('2018-12-31 23:59:59',INTERVAL 1 DAY),'+10:00','+02:00');
select convert_tz(DATE_ADD('2100-12-31 23:59:59',INTERVAL '1:1' MINUTE_SECOND),'+10:00','+02:00');
select convert_tz(DATE_SUB('2025-01-01 00:00:00',INTERVAL '1 1:1:1' DAY_SECOND),'+10:00','+02:00');
select convert_tz(DATE_ADD('1900-01-01 00:00:00',INTERVAL '-1 10' DAY_HOUR),'+10:00','+02:00');
select convert_tz(DATE_SUB('1998-01-02', INTERVAL 31 DAY),'+10:00','+02:00');
select convert_tz(DATE_ADD('1992-12-31 23:59:59.000002',INTERVAL '1.999999' SECOND_MICROSECOND),'+10:00','+02:00');

--echo	#date_format
SELECT DATE_FORMAT(convert_tz('2021-10-08 14:14:00','+00:00','+00:00'), '%W %M %Y');
SELECT DATE_FORMAT(convert_tz('2021-10-08 14:14:00','+00:00','+00:00'), '%H:%i:%s');
SELECT DATE_FORMAT(convert_tz('2021-10-08 14:14:00','+00:00','+00:00'), '%D %y %a %d %m %b %j');
SELECT DATE_FORMAT(convert_tz('2021-10-08 14:14:00','+00:00','+00:00'), '%H %k %I %r %T %S %w');
SELECT DATE_FORMAT(convert_tz('2021-10-08 14:14:00','+00:00','+00:00'), '%X %V');
SELECT DATE_FORMAT(convert_tz('2021-10-08 14:14:00','+00:00','+00:00'), '%d');

select convert_tz(DATE_FORMAT('2009-10-04 22:23:00', '%W %M %Y'),'+00:00','+00:00');
select convert_tz(DATE_FORMAT('2007-10-04 22:23:00', '%H:%i:%s'),'+00:00','+00:00');
select convert_tz(DATE_FORMAT('1900-10-04 22:23:00','%D %y %a %d %m %b %j'),'+00:00','+00:00');
select convert_tz(DATE_FORMAT('1997-10-04 22:23:00','%H %k %I %r %T %S %w'),'+00:00','+00:00');
select convert_tz(DATE_FORMAT('1999-01-01', '%X %V'),'+00:00','+00:00');
select convert_tz(DATE_FORMAT('2006-06-00', '%d'),'+00:00','+00:00');

--echo	#dayname   
SELECT DAYNAME(convert_tz('2020-10-01 08:00:00','+00:00','+00:00'));

--echo	#dayofmonth
SELECT dayofmonth(convert_tz('2020-10-01 08:00:00','+00:00','+00:00'));

--echo	#dayofweek
select dayofweek(CONVERT_TZ(CURDATE(),'+00:00','+00:00'));
select dayofweek(CONVERT_TZ('2021-10-08 14:26:00','+00:00','+10:00'));


--echo	#dayofyear
select DAYOFYEAR(CONVERT_TZ(CURDATE(),'+00:00','+00:00'));
select DAYOFYEAR(CONVERT_TZ('2021-10-08 14:26:00','+00:00','+00:00'));

--echo	#extract
SELECT EXTRACT(YEAR FROM convert_tz('2021-10-08 14:14:00','+00:00','+00:00'));
SELECT EXTRACT(YEAR_MONTH FROM convert_tz('2021-10-08 14:14:00','+00:00','+00:00'));
--echo	#OB与Mysql结果不一致。
SELECT EXTRACT(DAY_MINUTE FROM convert_tz('2021-10-08 14:14:00','+00:00','+00:00'));
SELECT EXTRACT(MICROSECOND FROM convert_tz('2021-10-08 14:14:00','+00:00','+00:00'));


--echo	#concat
select concat(convert_tz('2021-10-08 14:14:00','+00:00','+00:00'),convert_tz('2021-10-08 14:14:00','+00:00','+00:00'));
select convert_tz(concat('20211008','151000'),'+00:00','+00:00');
select convert_tz(concat('2021-10-08','15:10:00'),'+00:00','+00:00');
select convert_tz(concat('2021-10-08',' 15:10:00'),'+00:00','+00:00');

--echo	#ceil
select ceil(CONVERT_TZ('2021-10-08 14:26:00','+00:00','+00:00'));
select convert_tz(ceil('2021-10-08 14:26:00'),'+00:00','+00:00');
select convert_tz(ceil('20211008142600'),'+10:00','-10:00');

--echo	#cast
--error 1064
select cast(convert_tz('2021-10-08 14:14:00','+00:00','+00:00') as int);
select cast(convert_tz('2021-10-08 14:14:00','+00:00','+00:00') as double);
select cast(convert_tz('2021-10-08 14:14:00','+00:00','+00:00') as float);
select cast(convert_tz('2021-10-08 14:14:00','+00:00','+00:00') as char(100));
--error 1064
select cast(convert_tz('2021-10-08 14:14:00','+00:00','+00:00') as varchar(100));
select cast(convert_tz('2021-10-08 14:14:00','+00:00','+00:00') as date);
select cast(convert_tz('2021-10-08 14:14:00','+00:00','+00:00') as time);
select cast(convert_tz('2021-10-08 14:14:00','+00:00','+00:00') as datetime);
--error 1064
select cast(convert_tz('2021-10-08 14:14:00','+00:00','+00:00') as timestamp);
select cast(convert_tz('2021-10-08 14:14:00','+00:00','+00:00') as decimal(15,5));

select convert_tz(cast('2021-10-08 14:14:00' as double),'+00:00','+00:00');
select convert_tz(cast('2021-10-08 14:14:00' as char(100)),'+00:00','+00:00');
select convert_tz(cast('2021-10-08 14:14:00' as date),'+00:00','+00:00');
select convert_tz(cast('2021-10-08 14:14:00' as time),'+00:00','+00:00');
select convert_tz(cast('2021-10-08 14:14:00' as datetime),'+00:00','+00:00');
select convert_tz(cast('2021-10-08 14:14:00' as decimal(15,5)),'+00:00','+00:00');

--echo	#length
select length(convert_tz('2021-10-08 14:14:00','+00:00','+00:00'));
select convert_tz(length(11111111111111111111111111111),'+00:00','+00:00');

--echo	#substr
select substr(convert_tz('2021-10-08 14:14:00','+00:00','+00:00'),5);
select substr(convert_tz('2021-10-08 14:14:00','+00:00','+00:00') from 8);
select substr(convert_tz('2021-10-08 14:14:00','+00:00','+00:00'),5,10);
select convert_tz(substr('1212021-10-08 14:14:00',4),'+10:00','-06:00');


select convert_tz(substr('1212021-10-08 14:14:00',8),'+10:00','-06:00');
select convert_tz(substr('12021-10-08 14:14:00',2,10),'+10:00','-06:00');
select convert_tz(substr(120211011 from 2),'+10:00','-06:00');

--echo	#reverse
select reverse(substr(convert_tz('2021-10-08 14:14:00','+00:00','+00:00'),5));
select convert_tz(reverse('12021-10-08 14:14:00'),'+02:00','+10:00');
select convert_tz(reverse('1231561321531'),'+02:00','+10:00');

--echo	#instr
select instr(convert_tz('2021-10-08 14:14:00','+00:00','+00:00'),'14');
select convert_tz(instr(convert_tz('2021-10-08 14:14:00','+00:00','+00:00'),'14'),'+00:00','+10:00');

--echo	#聚合函数
create table test1(a1 int,a2 year,c1 datetime,c2 datetime);
insert into test1 values(1,'1998',convert_tz('1998-12-12 12:12:12','+00:00','+00:00'),convert_tz('2038-01-19 03:14:07','+00:00','+00:00'));
insert into test1 values(2,'2002',convert_tz('2002-02-02 10:00:00','+00:00','+00:00'),convert_tz('2034-02-22 00:50:20','+00:00','+00:00'));
insert into test1 values(3,'2006',convert_tz('2006-04-15 06:06:20','+00:00','+00:00'),convert_tz('2026-05-08 05:16:50','+00:00','+00:00'));
insert into test1 values(4,'2012',convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2030-08-16 14:05:50','+00:00','+00:00'));
select * from test1;

--echo	#count
select count(c1) from test1;
select count(c2) from test1;
select convert_tz(count(c1),'+00:00','+10:00') from test1;
select convert_tz(count(c2),'-10:00','+10:00') from test1;

--echo	#sum
select sum(c1) from test1;
select sum(c2) from test1;
select convert_tz(sum(c1),'+00:00','+10:00') from test1;
select convert_tz(sum(c2),'-10:00','+10:00') from test1;

--echo	#max
select max(c1) from test1;
select max(c2) from test1;
select convert_tz(max(c1),'+00:00','+10:00') from test1;
select convert_tz(max(c2),'-10:00','+10:00') from test1;

--echo	#min
select min(c1) from test1;
select min(c2) from test1;
select convert_tz(min(c1),'+00:00','+10:00') from test1;
select convert_tz(min(c2),'-10:00','+10:00') from test1;

--echo	#avg
select avg(c1) from test1;
select avg(c2) from test1;
select convert_tz(avg(c1),'+00:00','+10:00') from test1;
select convert_tz(avg(c2),'-10:00','+10:00') from test1;

drop table test1;


drop database db1;
--enable_result_log
