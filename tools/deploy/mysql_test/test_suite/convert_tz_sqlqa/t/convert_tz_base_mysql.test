#owner group: SQL-SQL2
#tags: mysql
#description:参数、基本sql功能
#author: wb-zwc01059807
--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;


--echo	#边界值测试 ，OB变化，mysql不变
SELECT CONVERT_TZ('1970-01-01 00:00:00','+01:00','+00:00');
--echo	#OB变化，mysql不变
SELECT CONVERT_TZ('1970-01-01 00:00:00','+00:00','-01:00');

SELECT CONVERT_TZ('2038-01-19 03:14:07','+00:00','+13:00');
--echo	#OB变化，mysql不变
SELECT CONVERT_TZ('2038-01-19 03:14:07','-01:00','+00:00');


SELECT CONVERT_TZ('2004-01-01 12:00:00','-12:00','+10:00');


SELECT CONVERT_TZ('2004-01-01 12:00:00','-13:00','+10:00');
SELECT CONVERT_TZ('2004-01-01 12:00:00','-12:00','+14:00');
SELECT CONVERT_TZ('2004-01-01 12:00:00','-12:00','+13:00');

SELECT CONVERT_TZ('','-12:00','+10:00');
SELECT CONVERT_TZ(' ','-12:00','+10:00');

SELECT CONVERT_TZ(NULL,'-12:00','+10:00');

SELECT CONVERT_TZ('aa','-12:00','+10:00');

SELECT CONVERT_TZ('张三','-12:00','+10:00');

SELECT CONVERT_TZ('1asd561ad','-12:00','+10:00');

SELECT CONVERT_TZ('￥￥%……&*￥','-12:00','+10:00');

SELECT CONVERT_TZ('2004-01-01 12:00:00',NULL,'+10:00');
SELECT CONVERT_TZ('2004-01-01 12:00:00','+00:00',NULL);
SELECT CONVERT_TZ('2004-01-01 12:00:00',NULL,NULL);

--echo	#参数为不同类型测试。
--echo	#INT
create table test1(c1 int , c2 int);
insert into test1 values(123456,20210918);
SELECT CONVERT_TZ(c1,'+00:00','+00:00') from test1;
SELECT CONVERT_TZ(c2,'+00:00','+00:00') from test1;
drop table test1;

--echo	#FLOAT
create table test1(c1 float , c2 float);
insert into test1 values(123.456,2021.0918);
SELECT CONVERT_TZ(c1,'+00:00','+00:00') from test1;
SELECT CONVERT_TZ(c2,'+00:00','+00:00') from test1;
drop table test1;

--echo	#DOUBLE
create table test1(c1 double , c2 double);
insert into test1 values(123.456,2021.0918);
SELECT CONVERT_TZ(c1,'+00:00','+00:00') from test1;
SELECT CONVERT_TZ(c2,'+00:00','+00:00') from test1;
drop table test1;

--echo	#CHAR
create table test1(c1 char(100),c2 char(100));
insert into test1 values('20210918','asd15131');
SELECT CONVERT_TZ(c1,'+00:00','+00:00') from test1;
SELECT CONVERT_TZ(c2,'+00:00','+00:00') from test1;
drop table test1;

--echo	#varchar
create table test1(c1 varchar(100),c2 varchar(100));
insert into test1 values('20210918','asd15131');
SELECT CONVERT_TZ(c1,'+00:00','+00:00') from test1;
SELECT CONVERT_TZ(c2,'+00:00','+00:00') from test1;
drop table test1;

--echo	#date
create table test1(c1 date,c2 date);
insert into test1 values('1000-01-01','10000101');
SELECT CONVERT_TZ(c1,'+00:00','+00:00') from test1;
SELECT CONVERT_TZ(c2,'+00:00','+00:00') from test1;
select * from test1;
drop table test1;

--echo	#time
create table test1(c1 time,c2 time);
insert into test1 values('10:10:10','15:41:20');
SELECT CONVERT_TZ('2004-01-01 12:00:00',c1,c2) from test1;
SELECT CONVERT_TZ('2004-01-01 12:00:00',c2,c1) from test1;
select * from test1;
drop table test1;

--echo	#year
create table test1(c1 year,c2 year);
insert into test1 values('1901','2155');
SELECT CONVERT_TZ(c1,'+00:00','+00:00') from test1;
SELECT CONVERT_TZ(c2,'+00:00','+00:00') from test1;
select * from test1;
drop table test1;

--echo	#datetime
create table test1(c1 datetime,c2 datetime);
insert into test1 values('9999-12-31 23:59:59','1000-01-01 00:00:00');
--echo	#OB与MYSQL结果不一致
SELECT CONVERT_TZ(c1,'+00:00','+10:00') from test1;
--echo	#OB与MYSQL结果不一致
SELECT CONVERT_TZ(c2,'+10:00','+00:00') from test1;
drop table test1;

--echo	#timestamp
create table test1(c1 timestamp,c2 timestamp);
--echo #OB执行成功，MYSQL报错。
insert into test1 values('1970-01-01 00:00:01','2038-01-19 03:14:07');
SELECT CONVERT_TZ(c1,'+00:00','+10:00') from test1;
SELECT CONVERT_TZ(c2,'+10:00','+00:00') from test1;
drop table test1;

--echo	#decimal
create table test1(c1 decimal(5,2),c2 decimal(15,5));
insert into test1 values(202.12,202109.221030);
SELECT CONVERT_TZ(c1,'+00:00','+10:00') from test1;
SELECT CONVERT_TZ(c2,'+10:00','+00:00') from test1;
drop table test1;

--echo	#bit
create table test1(c1 bit(64),c2 bit(1));
insert into test1 values(b'10101010101010',b'1');
SELECT CONVERT_TZ(c1,'+00:00','+10:00') from test1;
SELECT CONVERT_TZ(c2,'+10:00','+00:00') from test1;
drop table test1;

--echo	#enum
create table test1(c1 enum('1111','111111','11111111'));
insert into test1 values('1111');
insert into test1 values('111111');
--echo	#OB与MYSQL结果不一致
insert into test1 values('11111111');
SELECT CONVERT_TZ(c1,'+00:00','+10:00') from test1;
drop table test1;

--echo	#set
create table test1(c1 set('1111','111111','11111111'));
insert into test1 values('1111');
insert into test1 values('111111');
--echo	#OB与MYSQL结果不一致
insert into test1 values('11111111');
SELECT CONVERT_TZ(c1,'+00:00','+10:00') from test1;
drop table test1;


--echo	#基础SQL功能
--echo	#select
create table test1(a1 int,a2 year,c1 datetime,c2 datetime);
insert into test1 values(1,'1998','1998-12-12 12:12:12','2038-01-19 03:14:07');
insert into test1 values(2,'2002','2002-02-02 10:00:00','2034-02-22 00:50:20');
insert into test1 values(3,'2006','2006-04-15 06:06:20','2038-01-19 03:14:07');
insert into test1 values(4,'2012','2012-12-12 12:12:12','2030-08-16 14:05:50');
select * from test1;
--echo	#where
select * from test1 where convert_tz(c1,'+00:00','+02:00')>'2000-09-23 10:36:20';
select * from test1 where convert_tz(c1,'+00:00','+02:00')>'2000-09-23 10:36:20' and convert_tz(c2,'+10:00','+00:00')<'2034-02-22 00:50:20';
select * from test1 where convert_tz(c1,'+00:00','+00:00')>'2006-04-15 06:06:20' or convert_tz(c2,'+00:00','+10:00')='2034-02-22 10:50:20';

--echo	#order by
select * from test1 order by convert_tz(c1,'+00:00','+05:00') desc;
select * from test1 order by convert_tz(c2,'+00:00','+05:00') asc;
select * from test1 where convert_tz(c1,'+00:00','+02:00')>'2000-09-23 10:36:20' order by convert_tz(c1,'+00:00','+05:00') desc;

--echo	#group by
select * from test1 group by convert_tz(c1,'+06:50','+00:00');
select * from test1 group by convert_tz(c2,'+00:00','+05:05');

--echo	#group having
select * from test1 group by convert_tz(c1,'+00:00','+00:00') having convert_tz(c1,'+00:00','+00:00')>'2006-04-15 06:06:20';
select * from test1 where convert_tz(c2,'+00:00','+00:00')>'2030-08-16 14:05:50' group by convert_tz(c2,'+10:00','+10:00') having convert_tz(c2,'+00:00','+00:00')<'2038-01-19 03:14:07';

--echo	#case when
select c1,c2 ,case c1 when convert_tz(c1,'+06:00','+00:00')<'2006-04-15 06:06:20' then convert_tz('2020-02-02 02:02:02','+00:00','+00:00') else convert_tz('1999-09-09 09:09:09','+00:00','+00:00') end as c1 from test1;

--echo	#distinct
select distinct convert_tz(c2,'+00:00','+10:00') from test1;
select distinct convert_tz(c1,'+00:00','+10:00') from test1;
drop table test1;

--echo	#INSERT
create table test1 (c1 datetime,c2 datetime);
insert into test1(c1) values(convert_tz('1998-12-12 12:12:12','+01:01','+10:01'));
insert into test1(c2) values(convert_tz('2000-01-01 10:10:10','+00:00','+00:00'));
select * from test1;

--echo	#多列插入
insert into test1 values(convert_tz('1998-12-12 12:12:12','+01:01','+10:01'),convert_tz('1998-12-12 12:12:12','+01:01','+10:01'));
insert into test1 values(CONVERT_TZ('2004-01-01 12:00:00','+00:00','+10:00'),CONVERT_TZ('2021-09-23 14:56:50','+00:00','+01:00'));
select * from test1;
drop table test1;

--echo	#不同类型的字段中插入函数
--echo	#INT
create table test1(c1 int,c2 int);
--error 1264
insert into test1 values(CONVERT_TZ('2004-01-01 12:00:00','+00:00','+10:00'),CONVERT_TZ('2004-01-01 12:00:00','+00:00','+10:00'));
drop table test1;

--echo	#float
create table test1(c1 float,c2 float);
insert into test1 values(CONVERT_TZ('2012-11-01 10:11:00','+10:00','+05:00'),CONVERT_TZ('1996-06-06 09:00:00','+00:00','+10:00'));
select * from test1;
drop table test1;

--echo	#double
create table test1(c1 double,c2 double);
insert into test1 values(CONVERT_TZ('2012-11-01 10:11:00','+10:00','+05:00'),CONVERT_TZ('1996-06-06 09:00:00','+00:00','+10:00'));
select * from test1;
drop table test1;

--echo	#char
create table test1(c1 char(100),c2 char(100));
insert into test1 values(CONVERT_TZ('2012-11-01 10:11:00','+10:00','+05:00'),CONVERT_TZ('1996-06-06 09:00:00','+00:00','+10:00'));
select * from test1;
drop table test1;

--echo	#varchar
create table test1(c1 varchar(100),c2 varchar(100));
insert into test1 values(CONVERT_TZ('2012-11-01 10:11:00','+10:00','+05:00'),CONVERT_TZ('1996-06-06 09:00:00','+00:00','+10:00'));
select * from test1;
drop table test1;

--echo	#date
create table test1(c1 date,c2 date);
insert into test1 values(CONVERT_TZ('2012-11-01 15:11:00','+00:00','+10:00'),CONVERT_TZ('1996-06-06 09:00:00','+00:00','+10:00'));
select * from test1;
drop table test1;

--echo	#time
create table test1(c1 time,c2 time);
insert into test1 values(CONVERT_TZ('2012-11-01 15:11:00','+00:00','+10:00'),CONVERT_TZ('1996-06-06 09:00:00','+00:00','+10:00'));
select * from test1;
drop table test1;

--echo	#year
create table test1(c1 year,c2 year);
insert into test1 values(CONVERT_TZ('2012-11-01 15:11:00','+00:00','+10:00'),CONVERT_TZ('1996-06-06 09:00:00','+00:00','+10:00'));
select * from test1;
drop table test1;

--echo	#datetime
create table test1(c1 datetime,c2 datetime);
insert into test1 values(CONVERT_TZ('2012-11-01 15:11:00','+00:00','+10:00'),CONVERT_TZ('1996-06-06 09:00:00','+00:00','+10:00'));
select * from test1;
drop table test1;

--echo	#timestamp
create table test1(c1 timestamp,c2 timestamp);
insert into test1 values(CONVERT_TZ('2012-11-01 15:11:00','+00:00','+10:00'),CONVERT_TZ('1996-06-06 09:00:00','+00:00','+10:00'));
select * from test1;
drop table test1;

--echo	#decmimal
create table test1(c1 decimal(20,2),c2 decimal(20,2));
insert into test1 values(CONVERT_TZ('2012-11-01 15:11:00','+00:00','+10:00'),CONVERT_TZ('1996-06-06 09:00:00','+00:00','+10:00'));
select * from test1;
drop table test1;

--echo	#bit
create table test1(c1 bit(64),c2 bit(64));
--error 1406
insert into test1 values(CONVERT_TZ('2012-11-01 15:11:00','+00:00','+10:00'),CONVERT_TZ('1996-06-06 09:00:00','+00:00','+10:00'));
select * from test1;
drop table test1;

--echo	#enum
create table test1(c1 enum('2012-11-01 15:11:00','1996-06-06 09:00:00','2004-01-01 12:00:00','1998-12-12 12:12:12'));
--echo	#OB报错，MYSQL执行成功
--error 1265
insert into test1 values(CONVERT_TZ('2012-11-01 15:11:00','+00:00','+00:00'));
select * from test1;
drop table test1;

--echo	#set
create table test1(c1 set('2012-11-01 15:11:00','1996-06-06 09:00:00','2004-01-01 12:00:00','1998-12-12 12:12:12'));
--echo  #OB报错，MYSQL执行成功
--error 1265
insert into test1 values(CONVERT_TZ('2012-11-01 15:11:00','+00:00','+00:00'));
select * from test1;
drop table test1;

--echo	#update
create table test1(a1 int,a2 year,c1 datetime,c2 datetime);
insert into test1 values(1,'1998',convert_tz('1998-12-12 12:12:12','+00:00','+00:00'),convert_tz('2038-01-19 03:14:07','+00:00','+00:00'));
insert into test1 values(2,'2002',convert_tz('2002-02-02 10:00:00','+00:00','+00:00'),convert_tz('2034-02-22 00:50:20','+00:00','+00:00'));
insert into test1 values(3,'2006',convert_tz('2006-04-15 06:06:20','+00:00','+00:00'),convert_tz('2026-05-08 05:16:50','+00:00','+00:00'));
insert into test1 values(4,'2012',convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2030-08-16 14:05:50','+00:00','+00:00'));
select * from test1;
--echo	#单行
update test1 set c1 = convert_tz('2020-10-14 08:50:00','+00:00','+00:00') where c2 =convert_tz('2026-05-08 05:16:50','+00:00','+00:00');
select * from test1;
--echo	#多行
update test1 set c1 = convert_tz('2008-08-08 08:50:00','+00:00','+00:00') where c2 >convert_tz('2030-08-16 14:05:50','+00:00','+00:00');
select * from test1;

--echo	#delete
--echo	#单行
delete from test1 where c1 = convert_tz('2008-08-08 08:50:00','+00:00','+00:00') and c2=convert_tz('2038-01-19 03:14:07','+00:00','+00:00');
select * from test1;
--echo	#多行
delete from test1 where c2 > convert_tz('2026-05-08 05:16:50','+00:00','+00:00');
select * from test1;
delete from test1;
drop table test1;

--echo	#多表
create table test1(a1 int,a2 year,c1 datetime,c2 datetime);
insert into test1 values(1,'1998',convert_tz('1998-12-12 12:12:12','+00:00','+00:00'),convert_tz('2038-01-19 03:14:07','+00:00','+00:00'));
insert into test1 values(2,'2002',convert_tz('2002-02-02 10:00:00','+00:00','+00:00'),convert_tz('2034-02-22 00:50:20','+00:00','+00:00'));
insert into test1 values(3,'2006',convert_tz('2006-04-15 06:06:20','+00:00','+00:00'),convert_tz('2026-05-08 05:16:50','+00:00','+00:00'));
insert into test1 values(4,'2012',convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2030-08-16 14:05:50','+00:00','+00:00'));
select * from test1;

create table test2(t1 int,t2 datetime,t3 datetime);
insert into test2 values(1,convert_tz('1980-01-01 01:01:01','+00:00','+00:00'),convert_tz('1982-02-02 02:02:02','+00:00','+00:00'));
insert into test2 values(2,convert_tz('1986-03-03 03:03:03','+00:00','+00:00'),convert_tz('1988-04-04 04:04:04','+00:00','+00:00'));
insert into test2 values(3,convert_tz('1990-05-05 05:05:05','+00:00','+00:00'),convert_tz('1992-06-06 06:06:06','+00:00','+00:00'));
insert into test2 values(4,convert_tz('1994-07-07 07:07:07','+00:00','+00:00'),convert_tz('1996-08-08 08:08:08','+00:00','+00:00'));
select * from test2;

--echo	#inner join
select * from test1 inner join test2 on test1.a1=test2.t1;
select * from test1 inner join test2 on test1.a1=test2.t1 where convert_tz(c1,'+10:00','+05:00')>'2002-02-02 10:00:00';
select * from test1 inner join test2 on test1.a1=test2.t1 where convert_tz(c1,'+10:00','+05:00')>'2002-02-02 10:00:00' and convert_tz(t2,'+05:00','+01:00')<'1994-07-07 07:07:07';
select * from test1 inner join test2 on test1.a1=test2.t1 where convert_tz(c1,'+10:00','+05:00')>'2002-02-02 10:00:00' and convert_tz(t2,'+05:00','+01:00')<'1994-07-07 07:07:07' order by convert_tz(t2,'+00:00','+00:00') desc;

--echo	#left join
select * from test1 left join test2 on test1.a1=test2.t1;
select * from test1 left join test2 on test1.a1=test2.t1 where convert_tz(c1,'+10:00','+05:00')>'2002-02-02 10:00:00';
select * from test1 left join test2 on test1.a1=test2.t1 where convert_tz(c1,'+10:00','+05:00')>'2002-02-02 10:00:00' and convert_tz(t2,'+05:00','+01:00')<'1994-07-07 07:07:07';
select * from test1 left join test2 on test1.a1=test2.t1 where convert_tz(c1,'+10:00','+05:00')>'2002-02-02 10:00:00' and convert_tz(t2,'+05:00','+01:00')<'1994-07-07 07:07:07' order by convert_tz(t2,'+00:00','+00:00') desc;

--echo	#right join
select * from test1 right join test2 on test1.a1=test2.t1;
select * from test1 right join test2 on test1.a1=test2.t1 where convert_tz(c1,'+10:00','+05:00')>'2002-02-02 10:00:00';
select * from test1 right join test2 on test1.a1=test2.t1 where convert_tz(c1,'+10:00','+05:00')>'2002-02-02 10:00:00' and convert_tz(t2,'+05:00','+01:00')<'1994-07-07 07:07:07';
select * from test1 right join test2 on test1.a1=test2.t1 where convert_tz(c1,'+10:00','+05:00')>'2002-02-02 10:00:00' and convert_tz(t2,'+05:00','+01:00')<'1994-07-07 07:07:07' order by convert_tz(t2,'+00:00','+00:00') desc;

drop table test1;
drop table test2;

--echo	#子查询
create table test1(a1 int,a2 year,c1 datetime,c2 datetime);
insert into test1 values(1,'1998',convert_tz('1998-12-12 12:12:12','+00:00','+00:00'),convert_tz('2038-01-19 03:14:07','+00:00','+00:00'));
insert into test1 values(2,'2002',convert_tz('2002-02-02 10:00:00','+00:00','+00:00'),convert_tz('2034-02-22 00:50:20','+00:00','+00:00'));
insert into test1 values(3,'2006',convert_tz('2006-04-15 06:06:20','+00:00','+00:00'),convert_tz('2026-05-08 05:16:50','+00:00','+00:00'));
insert into test1 values(4,'2012',convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2030-08-16 14:05:50','+00:00','+00:00'));
create table test2(t1 int,t2 datetime,t3 datetime);
insert into test2 values(1,convert_tz('1980-01-01 01:01:01','+00:00','+00:00'),convert_tz('2026-05-08 05:16:50','+00:00','+00:00'));
insert into test2 values(2,convert_tz('2002-02-02 10:00:00','+00:00','+00:00'),convert_tz('2034-02-22 00:50:20','+00:00','+00:00'));
insert into test2 values(3,convert_tz('1990-05-05 05:05:05','+00:00','+00:00'),convert_tz('1992-06-06 06:06:06','+00:00','+00:00'));
insert into test2 values(4,convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('1996-08-08 08:08:08','+00:00','+00:00'));
select * from test1;
select * from test2;

--echo	#带in关键字
select * from test1 where c1 in (select t2 from test2);
select * from test1 where c2 in (select t3 from test2);
select * from test2 where t2 in (select c1 from test1 where convert_tz(c1,'+00:00','+00:00')>'2006-04-15 06:06:20');
select * from test2 where t3 in (select c2 from test1 where convert_tz(c2,'+00:00','+00:00')<'2034-02-22 00:50:20 ');

--echo  #带比较运算符
select * from test1 where c1 = (select t2 from test2 where convert_tz(t2,'+00:00','+00:00')>'1990-05-05 05:05:05' and convert_tz(t2,'+00:00','+00:00')<'2012-12-12 12:12:12');
select * from test1 where c2 > (select t3 from test2 where convert_tz(t3,'+00:00','+00:00')='2026-05-08 05:16:50');
select * from test2 where t2 <(select c1 from test1 where convert_tz(c1,'+00:00','+00:00')='2002-02-02 10:00:00 ');
select * from test1 where c2 >= (select t3 from test2 where convert_tz(t3,'+00:00','+00:00')='2026-05-08 05:16:50');
select * from test2 where t2 <=(select c1 from test1 where convert_tz(c1,'+00:00','+00:00')='2002-02-02 10:00:00 ');
select * from test1 where c2 != (select t3 from test2 where convert_tz(t3,'+00:00','+00:00')='2026-05-08 05:16:50');

--echo	#带exists关键字
select * from test1 where exists (select t2 from test2 where convert_tz(t2,'+00:00','+00:00')>'1990-05-05 05:05:05' and convert_tz(t2,'+00:00','+00:00')<'2012-12-12 12:12:12');

--echo	#带any关键字
select * from test1 where c2 > any (select t3 from test2 where convert_tz(t3,'+00:00','+00:00')='2026-05-08 05:16:50');

drop table test1;
drop table test2;


drop database db1;
