drop table if exists triangle23;
CREATE TABLE triangle23 (
sidea VARCHAR(100),
sideb VARCHAR(100),
##  sidec VARCHAR(200) AS (LAST_INSERT_ID()),
sided VARCHAR(200) AS (CHARSET(CONVERT('中文' USING GBK))),
sidee VARCHAR(200) AS (COLLATION(_utf8mb4'abc')),
sidef VARCHAR(200) AS (REVERSE(sidea)),
sideg VARCHAR(200) AS (MAKE_SET(1 | 4,'hello','nice',NULL,'world')),
sideh VARCHAR(200) AS (char_length(sideb)),
sidei VARCHAR(200) AS (CONCAT_WS(',','First name','Second name','Last Name'))
##  sidek VARCHAR(200) AS (ROW_COUNT()),
##  sidel VARCHAR(200) AS (FOUND_ROWS())
)
DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle23 (sidea, sideb) VALUES('chaerre','chaerr');
INSERT INTO triangle23 (sidea, sideb) VALUES('中文测试','中文测试1');
INSERT INTO triangle23 (sidea, sideb) VALUES('中文混合adfso441','中文混合adfso442');
INSERT INTO triangle23 (sidea, sideb) VALUES('20000101','19920202');
SELECT * FROM triangle23;
sidea	sideb	sided	sidee	sidef	sideg	sideh	sidei
chaerre	chaerr	gbk	utf8mb4_general_ci	erreahc	hello	6	First name,Second name,Last Name
中文测试	中文测试1	gbk	utf8mb4_general_ci	试测文中	hello	5	First name,Second name,Last Name
中文混合adfso441	中文混合adfso442	gbk	utf8mb4_general_ci	144osfda合混文中	hello	12	First name,Second name,Last Name
20000101	19920202	gbk	utf8mb4_general_ci	10100002	hello	8	First name,Second name,Last Name
desc triangle23;
Field	Type	Null	Key	Default	Extra
sidea	varchar(100)	YES		NULL	
sideb	varchar(100)	YES		NULL	
sided	varchar(200)	YES		charset(convert('中文' using 'GBK'))	VIRTUAL GENERATED
sidee	varchar(200)	YES		collation('abc')	VIRTUAL GENERATED
sidef	varchar(200)	YES		reverse(`sidea`)	VIRTUAL GENERATED
sideg	varchar(200)	YES		MAKE_SET((1 | 4),'hello','nice',NULL,'world')	VIRTUAL GENERATED
sideh	varchar(200)	YES		char_length(`sideb`)	VIRTUAL GENERATED
sidei	varchar(200)	YES		CONCAT_WS(',','First name','Second name','Last Name')	VIRTUAL GENERATED
drop table if exists triangle23;
