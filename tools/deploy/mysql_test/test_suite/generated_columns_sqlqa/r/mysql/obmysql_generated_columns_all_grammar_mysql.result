########utf8||DDL-Mysql全量ddl限制验证generated_column-1-1-1-2及之下所有####################
drop database  IF EXISTS  ob35x;
create database ob35x  character set utf8;
use ob35x;
SET NAMES utf8;
drop table if exists triangle;
CREATE TABLE triangle (
sidea DOUBLE,
sideb DOUBLE,
sidec DOUBLE AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle (sidea, sideb) VALUES(1,1),(3,4),(6,8);
SELECT * FROM triangle;
sidea	sideb	sidec
1	1	1.4142135623730951
3	4	5
6	8	10
########用户自定义函数generated_column-1-1-1-2-3####################
DROP FUNCTION IF EXISTS genPerson;
CREATE FUNCTION genPerson(name varchar(20)) RETURNS varchar(50)
BEGIN
DECLARE str VARCHAR(50) DEFAULT '';
SET @tableName=name;
SET str=CONCAT('create table ', @tableName,'(id int, name varchar(20));');
return str;
END /
drop table if exists triangle2;
CREATE TABLE triangle2 (
sidea VARCHAR(10),
sideb VARCHAR(10),
sidec VARCHAR(100) AS (genPerson(sidea))
)DEFAULT CHARACTER SET = utf8;
Got one of the listed errors
########子查询####################
drop table if exists triangle3;
CREATE TABLE triangle3 (
sidea VARCHAR(10),
sideb VARCHAR(10),
sidec VARCHAR(100) AS ((select sidea from triangle limit 1))
)DEFAULT CHARACTER SET = utf8;
Got one of the listed errors
########类型转换generated_column-1-1-1-2-7####################
drop table if exists triangle5;
CREATE TABLE triangle5 (
sidea int(10),
sideb DOUBLE,
sided DATE,
sidec DATE AS (TO_DAYS(sidea))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle5 (sidea, sideb,sided) VALUES(950501,950501,'20200920');
ERROR 22007: Incorrect datetime value for column 'sidec' at row 1
alter table triangle5 add column c6 int generated always as (DAYOFWEEK(sided)) virtual;
alter table triangle5 drop column sidec;
INSERT INTO triangle5 (sidea, sideb,sided) VALUES(950501,950501,'20200920');
alter table triangle5 add column c7 DATE generated always as (DATE_ADD(sided,INTERVAL '-1 10' DAY_HOUR)) virtual;
SELECT * FROM triangle5;
sidea	sideb	sided	c6	c7
950501	950501	2020-09-20	1	2020-09-18
########类型转换BLOB,text/generated_column-1-1-1-2-7####################
drop table if exists triangle5;
CREATE TABLE triangle5 (
sidea BLOB,
sideb TEXT,
sided LONGBLOB,
sidec LONGBLOB AS (cast(sided as CHAR))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle5 (sidea, sideb,sided) VALUES(950501,950501,'20200920');
alter table triangle5 add column c7 DATE generated always as (DATE_ADD(sided,INTERVAL '-1 10' DAY_HOUR)) virtual;
INSERT INTO triangle5 (sidea, sideb,sided) VALUES(950501,950501,'20200920');
SELECT * FROM triangle5;
sidea	sideb	sided	sidec	c7
950501	950501	20200920	20200920	2020-09-18
950501	950501	20200920	20200920	2020-09-18
desc triangle5;
Field	Type	Null	Key	Default	Extra
sidea	blob	YES		NULL	
sideb	text	YES		NULL	
sided	longblob	YES		NULL	
sidec	longblob	YES		cast(`sided` as char charset utf8mb4)	VIRTUAL GENERATED
c7	date	YES		(`sided` + interval '-1 10' day_hour)	VIRTUAL GENERATED
update triangle5 t set t.c7 = default;
INSERT INTO triangle5 (sidea, sideb,sided,sidec,c7) VALUES(950501,950501,'20200920',default,default);
SELECT * FROM triangle5;
sidea	sideb	sided	sidec	c7
950501	950501	20200920	20200920	2020-09-18
950501	950501	20200920	20200920	2020-09-18
950501	950501	20200920	20200920	2020-09-18
desc triangle5;
Field	Type	Null	Key	Default	Extra
sidea	blob	YES		NULL	
sideb	text	YES		NULL	
sided	longblob	YES		NULL	
sidec	longblob	YES		cast(`sided` as char charset utf8mb4)	VIRTUAL GENERATED
c7	date	YES		(`sided` + interval '-1 10' day_hour)	VIRTUAL GENERATED
INSERT INTO triangle5 (sidea, sideb,sided,sidec,c7) VALUES(950501,950501,'20200920',NULL,NULL);
ERROR HY000: The value specified for generated column 'sidec' in table 'triangle5' is not allowed
########生成列外键generated_column-1-1-1-2-11/generated_column-1-1-1-2-12####################
drop table if exists triangle5;
drop table if exists triangle6;
drop table if exists ChineseCharInfo;
drop table if exists triangle6;
CREATE TABLE triangle5 (
sidea DOUBLE,
sideb DOUBLE,
sidec DOUBLE AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle5 (sidea, sideb) VALUES(1,1),(3,4),(6,8);
SELECT * FROM triangle5;
sidea	sideb	sidec
1	1	1.4142135623730951
3	4	5
6	8	10
CREATE TABLE triangle6 (
sidea DOUBLE,
sideb DOUBLE,
sidec DOUBLE AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle6 (sidea, sideb) VALUES(1,1),(3,4),(6,8);
ALTER TABLE triangle6 ADD FOREIGN KEY (sidea) REFERENCES triangle5(sidec) ON DELETE CASCADE;
ERROR HY000: Cannot add foreign key constraint
ALTER TABLE triangle6 ADD FOREIGN KEY (sidea) REFERENCES triangle5(sidea) ON DELETE CASCADE;
ERROR HY000: Cannot add foreign key constraint
create table ChineseCharInfo
(
ID int not null auto_increment,
Hanzi varchar(10) not null,
sidec int AS (Hanzi),
primary key (ID)
);
create table ChinesePinyinInfo
(
ID int not null auto_increment,
CharID int null,
Pinyin varchar(10) null,
Tone tinyint unsigned null,
primary key (ID),
-- 方式一：不指定外键名称，数据库自动生成
foreign key (CharID) references ChineseCharInfo(sidec) on delete cascade on update cascade
-- 方式二：指定外键名称为(FK_Name)
-- constraint FK_Name foreign key (CharID) references ChineseCharInfo(sidec) on delete cascade on update cascade 
);
ERROR HY000: Cannot add foreign key constraint
########生成列default值插入generated_column-1-1-1-2-13####################
drop table if exists t4;
CREATE TABLE t4 (
first_name VARCHAR(10),
last_name VARCHAR(10),
full_name VARCHAR(255) GENERATED ALWAYS AS (CONCAT(first_name,last_name)) VIRTUAL NOT NULL
);
insert into t4(first_name,last_name,full_name) values ('xiao','feng',default);
insert into t4(first_name,last_name,full_name) values ('xiao','feng',default1);
ERROR 42S22: Unknown column 'default1' in 'field list'
insert into t4(first_name,last_name,full_name) values ('xiao','feng',NULL);
ERROR HY000: The value specified for generated column 'full_name' in table 't4' is not allowed
update t4 set t4.full_name = '';
ERROR HY000: The value specified for generated column 'full_name' in table 't4' is not allowed
update t4 set t4.full_name = default;
REPLACE INTO t4 VALUES('xiao1','feng2',default);
REPLACE INTO t4 VALUES('xiao1','feng2');
ERROR 21S01: Column count doesn't match value count at row 1
REPLACE INTO t4(first_name,last_name) VALUES('xiao3','feng3');
select * from t4;
first_name	last_name	full_name
xiao	feng	xiaofeng
xiao1	feng2	xiao1feng2
xiao3	feng3	xiao3feng3
