########utf8||DDL-Mysql生成列示范示例##########
drop database  IF EXISTS  ob35x;
create database ob35x  character set utf8;
use ob35x;
SET NAMES utf8;
drop table if exists triangle;
CREATE TABLE triangle (
sidea DOUBLE,
sideb DOUBLE,
sidec DOUBLE AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle (sidea, sideb) VALUES(1,1),(3,4),(6,8);
SELECT * FROM triangle;
sidea	sideb	sidec
1	1	1.4142135623730951
3	4	5
6	8	10
drop table if exists triangle;
########utf8||生成列示范示例2##########
drop table if exists t1;
drop view if exists v1;
drop table if exists person;
drop table if exists employees;
CREATE TABLE t1 (
first_name VARCHAR(10),
last_name VARCHAR(10),
full_name VARCHAR(255) AS (CONCAT(first_name,' ',last_name))
);
SELECT CONCAT(first_name,' ',last_name) AS full_name FROM t1;
full_name
CREATE VIEW v1 AS
SELECT *, CONCAT(first_name,' ',last_name) AS full_name2 FROM t1;
SELECT full_name FROM v1;
full_name
SELECT full_name FROM t1;
full_name
SELECT full_name2 FROM v1;
full_name2
CREATE TABLE person (
first_name VARCHAR(10) NOT NULL COMMENT '名',
last_name VARCHAR(10) NOT NULL COMMENT '姓',
full_name VARCHAR(21) GENERATED ALWAYS AS (CONCAT(first_name,' ',last_name)) STORED NOT NULL COMMENT '全名'
);
ALTER TABLE person ADD full_name_gc VARCHAR(21) 
GENERATED ALWAYS AS (CONCAT(first_name,'_',last_name)) VIRTUAL NOT NULL COMMENT '全名(虚拟列)';
insert into person(first_name,last_name) values ('xiao','feng');
select * from person;
first_name	last_name	full_name	full_name_gc
xiao	feng	xiao feng	xiao_feng
CREATE TABLE `employees` (
`emp_no` int(11) NOT NULL,
`birth_date` date NOT NULL,
`first_name` varchar(14) NOT NULL,
`last_name` varchar(16) NOT NULL,
`gender` enum('M','F') NOT NULL,
`hire_date` date NOT NULL,
`full_name` VARCHAR(30) AS (CONCAT(first_name,'
',last_name)),
PRIMARY KEY (`emp_no`),
KEY `name` (`first_name`,`last_name`)
)DEFAULT CHARSET=utf8mb4;
INSERT INTO employees (emp_no, birth_date,
first_name, last_name, gender, hire_date) VALUES
(123456, '1987-10-02', 'ABC' , 'XYZ', 'F', '2008-07-28');
INSERT INTO employees (emp_no, birth_date,
first_name, last_name, gender, hire_date, full_name)
VALUES (123459, '1987-10-02', 'ABC' , 'XYZ', 'F',
'2008-07-28', DEFAULT);
INSERT INTO employees (emp_no, birth_date,
first_name, last_name, gender, hire_date, full_name)
VALUES (123457, '1987-10-02', 'ABC' , 'XYZ', 'F',
'2008-07-28');
ERROR 21S01: Column count doesn't match value count at row 1
INSERT INTO employees (emp_no, birth_date,
first_name, last_name, gender, hire_date, full_name)
VALUES (123456, '1987-10-02', 'ABC' , 'XYZ', 'F',
'2008-07-28', 'HAHAHAH');
ERROR HY000: The value specified for generated column 'full_name' in table 'employees' is not allowed
SELECT * FROM employees WHERE emp_no=123456;
emp_no	birth_date	first_name	last_name	gender	hire_date	full_name
123456	1987-10-02	ABC	XYZ	F	2008-07-28	ABC
XYZ
ALTER TABLE employees ADD hire_date_year YEAR as (YEAR(hire_date)) VIRTUAL;
INSERT INTO employees (emp_no, birth_date,
first_name, last_name, gender, hire_date) VALUES
(1234555, '1987-10-02', 'ABC' , 'XYZ', 'F', '2020-07-28');
SELECT * FROM employees WHERE emp_no=1234555;
emp_no	birth_date	first_name	last_name	gender	hire_date	full_name	hire_date_year
1234555	1987-10-02	ABC	XYZ	F	2020-07-28	ABC
XYZ	2020
drop table if exists t1;
drop view if exists v1;
drop table if exists person;
drop table if exists employees;
########utf8||DDL-Mysql生成列示范示例3##########
drop table if exists test;
CREATE TABLE test (
id INT (11) UNSIGNED NOT NULL AUTO_INCREMENT,
chinese DOUBLE NOT NULL DEFAULT '0',
math DOUBLE NOT NULL DEFAULT '0',
english DOUBLE NOT NULL DEFAULT '0',
total_score DOUBLE AS (chinese + math + english),
PRIMARY KEY (id)
)DEFAULT CHARSET=utf8mb4;
insert into test(chinese, math, english) values(66, 72, 54);
select * from test;
id	chinese	math	english	total_score
1	66	72	54	192
insert into test(chinese, math, english, total_score) values(33, 44, 55, DEFAULT);
alter table test add column times_score double generated always as (chinese * math * english) stored;
alter table test drop column total_score;
alter table test add column total_score double generated always as (chinese + math + english) stored;
drop table if exists test;
########utf8||生成列的语法验证generated_column-1-1-1-1及之下所有##########
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t5;
drop table if exists t6;
drop table if exists t7;
drop table if exists t8;
########语法验证generated_column-1-1-1-1-1-1/generated_column-1-1-1-1-1-2##########
CREATE TABLE t1 (
first_name VARCHAR(10),
last_name VARCHAR(10),
full_name VARCHAR(255) GENERATED ALWAYS AS (CONCAT(first_name,' ',last_name)) VIRTUAL
);
insert into t1(first_name,last_name) values ('xiao','feng');
########语法验证generated_column-1-1-1-1-1-3##########
CREATE TABLE t2 (
first_name VARCHAR(10),
last_name VARCHAR(10),
full_name VARCHAR(255) GENERATED ALWAYS AS (CONCAT(first_name,' ',last_name)) STORED
);
insert into t2(first_name,last_name) values ('xiao','feng');
########语法验证generated_column-1-1-1-1-1-4##########
CREATE TABLE t3 (
first_name VARCHAR(10),
last_name VARCHAR(10),
full_name VARCHAR(255) GENERATED ALWAYS AS (CONCAT(first_name,' ',last_name)) STORED NULL
);
insert into t3(first_name,last_name) values ('xiao','feng');
insert into t3(first_name,last_name) values ('','');
select * from t3;
first_name	last_name	full_name
xiao	feng	xiao feng
		 
CREATE TABLE t4 (
first_name VARCHAR(10),
last_name VARCHAR(10),
full_name VARCHAR(255) GENERATED ALWAYS AS (CONCAT(first_name,last_name)) VIRTUAL NOT NULL
);
insert into t4(first_name,last_name) values ('xiao','feng');
insert into t4(first_name,last_name) values (NULL,NULL);
ERROR 23000: Column 'full_name' cannot be null
select * from t4;
first_name	last_name	full_name
xiao	feng	xiaofeng
########语法验证generated_column-1-1-1-1-1-5##########
CREATE TABLE t6 (
first_name VARCHAR(10),
last_name VARCHAR(10),
full_name VARCHAR(255) GENERATED ALWAYS AS (CONCAT(first_name,' ',last_name)) STORED NOT NULL,
unique(full_name)
);
insert into t6(first_name,last_name) values ('xiao','feng');
insert into t6(first_name,last_name) values ('xiao','feng');
ERROR 23000: Duplicate entry 'xiao feng' for key 'full_name'
CREATE TABLE t7 (
first_name VARCHAR(10),
last_name VARCHAR(10),
full_name VARCHAR(255) GENERATED ALWAYS AS (CONCAT(first_name,' ',last_name)) STORED NOT NULL,
unique(first_name,full_name)
);
insert into t7(first_name,last_name) values ('xiao','feng');
insert into t7(first_name,last_name) values ('xiao','feng');
ERROR 23000: Duplicate entry 'xiao-xiao feng' for key 'first_name'
########语法验证generated_column-1-1-1-1-1-6##########
CREATE TABLE t8 (
first_name VARCHAR(10),
last_name VARCHAR(10),
full_name VARCHAR(255) GENERATED ALWAYS AS (CONCAT(first_name,' ',last_name)) STORED NOT NULL comment '全名',
unique(first_name,last_name,full_name)
);
insert into t8(first_name,last_name) values ('萧','峰');
insert into t8(first_name,last_name) values ('萧','峰');
ERROR 23000: Duplicate entry '萧-峰-萧 峰' for key 'first_name'
CREATE INDEX idx_c8 ON t8(full_name);
########语法验证generated_column-1-1-1-2-8/generated_column-1-1-1-2-9##########
drop table if exists t8_as;
drop table if exists t8_like;
drop view if exists t8_as_view;
create table t8_as as select * from t8;
desc t8_as;
Field	Type	Null	Key	Default	Extra
first_name	varchar(10)	YES		NULL	
last_name	varchar(10)	YES		NULL	
full_name	varchar(255)	NO		NULL	
create table t8_like like t8;
desc t8_like;
Field	Type	Null	Key	Default	Extra
first_name	varchar(10)	YES	MUL	NULL	
last_name	varchar(10)	YES		NULL	
full_name	varchar(255)	NO	MUL	CONCAT(`first_name`,' ',`last_name`)	STORED GENERATED
create view t8_as_view as select * from t8;
desc t8_as_view;
Field	Type	Null	Key	Default	Extra
first_name	varchar(10)	YES		NULL	
last_name	varchar(10)	YES		NULL	
full_name	varchar(255)	NO			
drop table if exists t8_as;
drop table if exists t8_like;
drop view if exists t8_as_view;
