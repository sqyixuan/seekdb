CREATE TABLE t9 (
sidea DOUBLE,
sideb DOUBLE,
first_name VARCHAR(10),
last_name VARCHAR(10),
sidec DOUBLE AS (SQRT(sidea * sidea + sideb * sideb)),
full_name VARCHAR(255) AS (CONCAT(first_name,' ',last_name)) VIRTUAL,
full_name2 VARCHAR(255) AS (CONCAT(first_name,' + ',last_name)) stored
);
INSERT INTO t9 (sidea, sideb, first_name, last_name) VALUES (1,1,'xiao','feng'),(3,4,'萧','峰'),(6,8,'xiao萧','feng峰'),(12,14,'萧峰1','萧峰2');
CREATE INDEX idx_c81 ON t9(full_name);
CREATE INDEX idx_c82 ON t9(full_name,full_name2);
CREATE INDEX idx_c83 ON t9(full_name,full_name2,sidec);
CREATE INDEX idx_c84 ON t9(full_name,first_name,sidea);
CREATE INDEX idx_c85 ON t9(full_name2,first_name,sidea);
CREATE INDEX idx_c86 ON t9(full_name2);
CREATE UNIQUE INDEX idx_c9 ON t9(full_name2);
CREATE TABLE t10 (id INT, purchased DATE,purchased_date DATE AS (purchased))
PARTITION BY RANGE( YEAR(purchased_date) )
SUBPARTITION BY HASH( TO_DAYS(purchased_date) )
SUBPARTITIONS 2 (
PARTITION p0 VALUES LESS THAN (1990),
PARTITION p1 VALUES LESS THAN (2000),
PARTITION p2 VALUES LESS THAN MAXVALUE
);
CREATE TABLE t11 (id INT,
first_name VARCHAR(10),
last_name VARCHAR(10),
full_name VARCHAR(255) AS (CONCAT(first_name,' ',last_name)))
PARTITION BY RANGE(full_name)
SUBPARTITION BY HASH(full_name)
SUBPARTITIONS 2 (
PARTITION p0 VALUES LESS THAN (1990),
PARTITION p1 VALUES LESS THAN (2000),
PARTITION p2 VALUES LESS THAN MAXVALUE
);
ERROR HY000: Field 'full_name' is of a not allowed type for this type of partitioning
CREATE TABLE t12 (id INT, purchased DATE,purchased_date DATE AS (purchased))
PARTITION BY RANGE( YEAR(purchased_date) )
SUBPARTITION BY HASH( TO_DAYS(purchased_date) ) (
PARTITION p0 VALUES LESS THAN (1990) (
SUBPARTITION s0,
SUBPARTITION s1
),
PARTITION p1 VALUES LESS THAN (2000) (
SUBPARTITION s2,
SUBPARTITION s3
),
PARTITION p2 VALUES LESS THAN MAXVALUE (
SUBPARTITION s4,
SUBPARTITION s5
)
);
drop table if exists t12;
CREATE TABLE t12 (id INT, purchased DATE,purchased_date DATE AS (purchased))
PARTITION BY RANGE( YEAR(purchased_date) )
SUBPARTITION BY HASH( TO_DAYS(purchased_date) ) (
PARTITION p0 VALUES LESS THAN (1990) (
SUBPARTITION s0,
SUBPARTITION s1
),
PARTITION p1 VALUES LESS THAN (2000) (
SUBPARTITION s2
),
PARTITION p2 VALUES LESS THAN MAXVALUE (
SUBPARTITION s4,
SUBPARTITION s5
)
);
drop table if exists t12;
CREATE TABLE t12 (id INT, purchased DATE,purchased_date DATE AS (purchased))
PARTITION BY RANGE( YEAR(purchased_date) )
SUBPARTITION BY HASH( TO_DAYS(purchased_date) ) (
PARTITION p0 VALUES LESS THAN (1990) (
SUBPARTITION s0,
SUBPARTITION s1
),
PARTITION p1 VALUES LESS THAN (2000),
PARTITION p2 VALUES LESS THAN MAXVALUE (
