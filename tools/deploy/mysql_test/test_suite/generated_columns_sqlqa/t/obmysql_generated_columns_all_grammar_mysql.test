--echo  ########utf8||DDL-Mysql全量ddl限制验证generated_column-1-1-1-2及之下所有####################
--disable_warnings
drop database  IF EXISTS  ob35x;
--enable_warnings
create database ob35x  character set utf8;
use ob35x;

SET NAMES utf8;
###--character_set utf8

--disable_warnings
drop table if exists triangle;
--enable_warnings

CREATE TABLE triangle (
  sidea DOUBLE,
  sideb DOUBLE,
  sidec DOUBLE AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle (sidea, sideb) VALUES(1,1),(3,4),(6,8);

SELECT * FROM triangle;

--echo  ########用户自定义函数generated_column-1-1-1-2-3####################
--disable_warnings
DROP FUNCTION IF EXISTS genPerson;
--enable_warnings

DELIMITER /;

CREATE FUNCTION genPerson(name varchar(20)) RETURNS varchar(50)
BEGIN
  DECLARE str VARCHAR(50) DEFAULT '';
  SET @tableName=name;
  SET str=CONCAT('create table ', @tableName,'(id int, name varchar(20));');
  return str;
END /
DELIMITER ;/

--disable_warnings
drop table if exists triangle2;
--enable_warnings

--error 1054,1235,3102
CREATE TABLE triangle2 (
  sidea VARCHAR(10),
  sideb VARCHAR(10),
  sidec VARCHAR(100) AS (genPerson(sidea))
)DEFAULT CHARACTER SET = utf8;
###INSERT INTO triangle2 (sidea, sideb) VALUES('a','b');
###SELECT * FROM triangle2;


