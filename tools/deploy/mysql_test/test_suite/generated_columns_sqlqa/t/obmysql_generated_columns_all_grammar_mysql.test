--echo  ########类型转换generated_column-1-1-1-2-7####################
--disable_warnings
drop table if exists triangle5;
--enable_warnings


CREATE TABLE triangle5 (
  sidea int(10),
  sideb DOUBLE,
  sided DATE,
  sidec DATE AS (TO_DAYS(sidea))
)DEFAULT CHARACTER SET = utf8;
--error 1292
INSERT INTO triangle5 (sidea, sideb,sided) VALUES(950501,950501,'20200920');

alter table triangle5 add column c6 int generated always as (DAYOFWEEK(sided)) virtual;

alter table triangle5 drop column sidec;
INSERT INTO triangle5 (sidea, sideb,sided) VALUES(950501,950501,'20200920');

alter table triangle5 add column c7 DATE generated always as (DATE_ADD(sided,INTERVAL '-1 10' DAY_HOUR)) virtual;


SELECT * FROM triangle5;



--echo  ########类型转换BLOB,text/generated_column-1-1-1-2-7####################
--disable_warnings
drop table if exists triangle5;
--enable_warnings


CREATE TABLE triangle5 (
  sidea BLOB,
  sideb TEXT,
  sided LONGBLOB,
  sidec LONGBLOB AS (cast(sided as CHAR))
)DEFAULT CHARACTER SET = utf8;

INSERT INTO triangle5 (sidea, sideb,sided) VALUES(950501,950501,'20200920');

alter table triangle5 add column c7 DATE generated always as (DATE_ADD(sided,INTERVAL '-1 10' DAY_HOUR)) virtual;
INSERT INTO triangle5 (sidea, sideb,sided) VALUES(950501,950501,'20200920');

SELECT * FROM triangle5;
desc triangle5;

update triangle5 t set t.c7 = default;

INSERT INTO triangle5 (sidea, sideb,sided,sidec,c7) VALUES(950501,950501,'20200920',default,default);
SELECT * FROM triangle5;
desc triangle5;

--error 3105
INSERT INTO triangle5 (sidea, sideb,sided,sidec,c7) VALUES(950501,950501,'20200920',NULL,NULL);


--echo  ########生成列外键generated_column-1-1-1-2-11/generated_column-1-1-1-2-12####################
--disable_warnings
drop table if exists triangle5;
drop table if exists triangle6;
drop table if exists ChineseCharInfo;
drop table if exists triangle6;
--enable_warnings

CREATE TABLE triangle5 (
  sidea DOUBLE,
  sideb DOUBLE,
  sidec DOUBLE AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle5 (sidea, sideb) VALUES(1,1),(3,4),(6,8);

SELECT * FROM triangle5;

CREATE TABLE triangle6 (
  sidea DOUBLE,
  sideb DOUBLE,
  sidec DOUBLE AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle6 (sidea, sideb) VALUES(1,1),(3,4),(6,8);

--error 1215
ALTER TABLE triangle6 ADD FOREIGN KEY (sidea) REFERENCES triangle5(sidec) ON DELETE CASCADE;
--error 1215
ALTER TABLE triangle6 ADD FOREIGN KEY (sidea) REFERENCES triangle5(sidea) ON DELETE CASCADE;


create table ChineseCharInfo
(
ID int not null auto_increment,
Hanzi varchar(10) not null,
sidec int AS (Hanzi),
primary key (ID)
);
 
--error 1215
create table ChinesePinyinInfo
(
ID int not null auto_increment,
CharID int null,
Pinyin varchar(10) null,
Tone tinyint unsigned null,
primary key (ID),
-- 方式一：不指定外键名称，数据库自动生成
foreign key (CharID) references ChineseCharInfo(sidec) on delete cascade on update cascade

-- 方式二：指定外键名称为(FK_Name)
-- constraint FK_Name foreign key (CharID) references ChineseCharInfo(sidec) on delete cascade on update cascade 
);


--echo  ########生成列default值插入generated_column-1-1-1-2-13####################
--disable_warnings
drop table if exists t4;
--enable_warnings


CREATE TABLE t4 (
  first_name VARCHAR(10),
  last_name VARCHAR(10),
  full_name VARCHAR(255) GENERATED ALWAYS AS (CONCAT(first_name,last_name)) VIRTUAL NOT NULL
);
insert into t4(first_name,last_name,full_name) values ('xiao','feng',default);
--error 1054
insert into t4(first_name,last_name,full_name) values ('xiao','feng',default1);
--error 3105
insert into t4(first_name,last_name,full_name) values ('xiao','feng',NULL);
--error 3105
update t4 set t4.full_name = '';

update t4 set t4.full_name = default;

REPLACE INTO t4 VALUES('xiao1','feng2',default);
--error 1136
REPLACE INTO t4 VALUES('xiao1','feng2');

REPLACE INTO t4(first_name,last_name) VALUES('xiao3','feng3');

select * from t4;


--echo  ########生成列altergenerated_column-1-1-1-2-14####################
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 INT);
ALTER TABLE t1 ADD COLUMN c2 INT GENERATED ALWAYS AS (c1 + 1) STORED;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 INT, c2 INT GENERATED ALWAYS AS (c1 + 1) STORED);
--error 1235,3106
ALTER TABLE t1 MODIFY COLUMN c2 TINYINT GENERATED ALWAYS AS (c1 + 5) STORED;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 INT, c2 INT GENERATED ALWAYS AS (c1 + 1) STORED);
ALTER TABLE t1 CHANGE c2 c3 INT GENERATED ALWAYS AS (c1 + 1) STORED;
ALTER TABLE t1 DROP COLUMN c3;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 INT, c2 INT GENERATED ALWAYS AS (c1 + 1) VIRTUAL);
--error 1235,3106
ALTER TABLE t1 MODIFY COLUMN c2 TINYINT GENERATED ALWAYS AS (c1 + 5) STORED;
ALTER TABLE t1 DROP COLUMN c2;
ALTER TABLE t1 ADD COLUMN c2 INT GENERATED ALWAYS AS (c1 + 1) STORED;


--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 INT, c2 INT);
--error 1235,3106
ALTER TABLE t1 MODIFY COLUMN c2 INT GENERATED ALWAYS AS (c1 + 1) STORED;


--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 INT, c2 INT GENERATED ALWAYS AS (c1 + 1) STORED);
--error 1235,3106
ALTER TABLE t1 MODIFY COLUMN c2 INT;

--echo  ####生成列与索引混合测试#####

--disable_warnings
drop table if exists givt_test1, givt_test2, givt_test3,givt_test4;
--enable_warnings

create table givt_test1 (c1 int, c2 int, c3 int, c4 varchar(20), c5 varchar(20), primary key (c1, c2));
insert into givt_test1 (c1, c2, c3, c4, c5) values (1, 1, 1, 'a', 'b');
insert into givt_test1 (c1, c2, c3, c4, c5) values (2, 4, 4, 'b', 'a');
insert into givt_test1 (c1, c2, c3, c4, c5) values (3, 4, 5, 'd', 'c');

create table givt_test2 (c1 int, c2 int, c3 int, c4 varchar(20), c5 varchar(20), primary key (c1, c2));
insert into givt_test2 (c1, c2, c3, c4, c5) values (1, 1, 1, 'a', 'b');
insert into givt_test2 (c1, c2, c3, c4, c5) values (2, 4, 4, 'b', 'a');
insert into givt_test2 (c1, c2, c3, c4, c5) values (3, 4, 5, 'd', 'c');

create table givt_test3 (c1 int, c2 int, c3 int, c4 varchar(4000), c5 varchar(4000), primary key (c1, c2));
insert into givt_test3 (c1, c2, c3, c4, c5) values (1, 1, 1, 'a', 'b');
insert into givt_test3 (c1, c2, c3, c4, c5) values (2, 4, 4, 'b', 'a');
insert into givt_test3 (c1, c2, c3, c4, c5) values (3, 4, 5, 'd', 'c');

alter table givt_test1 add column c6 int generated always as (SQRT(c2 * c3 + c2 * c3)) virtual;
alter table givt_test2 add column c7 int generated always as (SQRT(c1 * c3 + c1 * c3)) stored;
alter table givt_test3 add column c8 varchar(80) generated always as (concat(c4, c5)) virtual;
alter table givt_test3 add column c9 varchar(4000) generated always as (cast(cast(c4 as SIGNED INTEGER) as CHAR(3))) virtual;
alter table givt_test3 add column c10 varchar(4000) generated always as (DAYOFWEEK('2016-01-16 00:00:00')) virtual;

--error 1366,1292
insert into givt_test3 (c1, c2, c3, c4, c5) values (4, 5, 6, 'd', 'c');
