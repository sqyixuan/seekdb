--disable_warnings
drop table if exists triangle3;
--enable_warnings

--error 1235,3102
CREATE TABLE triangle3 (
  sidea VARCHAR(10),
  sideb VARCHAR(10),
  sidec VARCHAR(100) AS ((select sidea from triangle limit 1))
)DEFAULT CHARACTER SET = utf8;
###INSERT INTO triangle3 (sidea, sideb) VALUES('a','b');
