####create table as /create table like йӘҢиҜҒ
--disable_warnings
drop table if exists t8_as;
drop table if exists t8_like;
drop view if exists t8_as_view;
--enable_warnings

##еҪ“еҗҜз”Ё enforce_gtid_consistency еҠҹиғҪзҡ„ж—¶еҖҷпјҢMySQLеҸӘе…Ғи®ёиғҪеӨҹдҝқйҡңдәӢеҠЎе®үе…ЁпјҢе№¶дё”иғҪеӨҹиў«ж—Ҙеҝ—и®°еҪ•зҡ„SQLиҜӯеҸҘиў«жү§иЎҢпјҢеғҸcreate table вҖҰ select е’Ң create ##temporarytableиҜӯеҸҘпјҢд»ҘеҸҠеҗҢж—¶жӣҙж–°дәӢеҠЎиЎЁе’ҢйқһдәӢеҠЎиЎЁзҡ„SQLиҜӯеҸҘжҲ–дәӢеҠЎйғҪдёҚе…Ғи®ёжү§иЎҢгҖӮ
#set @@GLOBAL.GTID_MODE=ON_PERMISSIVE;
#set @@GLOBAL.GTID_MODE=OFF_PERMISSIVE;
#set global GTID_MODE = off;
#SET GLOBAL ENFORCE_GTID_CONSISTENCY = off;

create table t8_as as select * from t8;
##show table status like 't8_as';
##show index from t8_as;
desc t8_as;

create table t8_like like t8;
##show table status like 't8_like';
##show index from t8_like;
desc t8_like;

create view t8_as_view as select * from t8;
##show table status like 't8_as_view';
##show index from t8_as_view;
desc t8_as_view;

--disable_warnings
drop table if exists t8_as;
drop table if exists t8_like;
drop view if exists t8_as_view;
--enable_warnings


