)  
partition BY RANGE (store_id) (  
    partition p0 VALUES LESS THAN (6),  
    partition p1 VALUES LESS THAN (8),  
    partition p2 VALUES LESS THAN (18),  
    partition p3 VALUES LESS THAN (32)  
);

