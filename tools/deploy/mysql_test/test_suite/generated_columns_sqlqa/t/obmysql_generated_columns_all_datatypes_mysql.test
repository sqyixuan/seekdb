--echo  ########utf8||DDL-Mysql类型转换验证generated_column-1-1-2-1及之下所有####################
--disable_warnings
drop database  IF EXISTS  ob35x;
--enable_warnings
create database ob35x  character set utf8;
use ob35x;

SET NAMES utf8;
###--character_set utf8

--disable_warnings
drop table if exists triangle;
--enable_warnings

CREATE TABLE triangle (
  sidea DOUBLE,
  sideb DOUBLE,
  sidec DOUBLE AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle (sidea, sideb) VALUES(1.7976931348623157,1.7976931348623157),(-1.7976931348623157,-1.7976931348623157);

SELECT * FROM triangle;

--disable_warnings
drop table if exists triangle;
--enable_warnings

###数字类型转换数字类型generated_column-1-1-2-1-1-1-1/generated_column-1-1-2-1-1-1-2

--disable_warnings
drop table if exists triangle2;
--enable_warnings

CREATE TABLE triangle2 (
  sidea TINYINT,
  sideb TINYINT,
  sidec TINYINT AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
--error 1264
INSERT INTO triangle2 (sidea, sideb) VALUES(-128,-128);
--error 1264
INSERT INTO triangle2 (sidea, sideb) VALUES(127,127);
INSERT INTO triangle2 (sidea, sideb) VALUES(60,80);

SELECT * FROM triangle2;

--disable_warnings
drop table if exists triangle2;
--enable_warnings

--disable_warnings
drop table if exists triangle3;
--enable_warnings

CREATE TABLE triangle3 (
  sidea SMALLINT,
  sideb SMALLINT,
  sidec SMALLINT AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
--error 1264
INSERT INTO triangle3 (sidea, sideb) VALUES (-32768,-32768),(32767,32767),(6,8);
INSERT INTO triangle3 (sidea, sideb) VALUES (6,8);

SELECT * FROM triangle3;

--disable_warnings
drop table if exists triangle3;
--enable_warnings

--disable_warnings
drop table if exists triangle4;
--enable_warnings

CREATE TABLE triangle4 (
  sidea MEDIUMINT,
  sideb MEDIUMINT,
  sidec MEDIUMINT AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
--error 1264
INSERT INTO triangle4 (sidea, sideb) VALUES(-8388608,-8388608),(8388607,8388607),(6,8);
INSERT INTO triangle4 (sidea, sideb) VALUES(6,8);

SELECT * FROM triangle4;

--disable_warnings
drop table if exists triangle4;
--enable_warnings

--disable_warnings
drop table if exists triangle5;
--enable_warnings

