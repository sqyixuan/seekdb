  sidea MEDIUMINT,
  sideb FLOAT,
  sidec CHAR(20) AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle10 (sidea, sideb) VALUES(1,1),(3,4),(6,8);

SELECT * FROM triangle10;
desc triangle10;

--disable_warnings
drop table if exists triangle10;
--enable_warnings

