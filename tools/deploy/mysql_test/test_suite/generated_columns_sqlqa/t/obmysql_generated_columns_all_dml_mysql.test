SELECT e.c1,count(e.c2) from mailbakup e INNER JOIN mailbakup d on e.c20 = d.c20 where e.c1 = d.c1 and e.c1 ='中文测试1' group by e.c1 having count(e.c20) > 1 order by e.c1;

