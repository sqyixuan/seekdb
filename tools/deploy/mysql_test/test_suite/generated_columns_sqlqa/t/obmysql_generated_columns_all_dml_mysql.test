--echo  ########utf8||DDL-Mysql全量表达式验证generated_column-1-1-2及之下所有####################
--disable_warnings
drop database  IF EXISTS  ob35x;
--enable_warnings
create database ob35x  character set utf8;
use ob35x;

SET NAMES utf8;
###--character_set utf8

--disable_warnings
drop table if exists triangle;
--enable_warnings

CREATE TABLE triangle (
  sidea DOUBLE,
  sideb DOUBLE,
  sidec DOUBLE AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle (sidea, sideb) VALUES(1,1),(3,4),(6,8);

SELECT * FROM triangle;

--disable_warnings
drop table if exists triangle;
--enable_warnings

--disable_warnings
drop table if exists mail;
--enable_warnings

create table mail
(
t int,
srcuser varchar(100) primary key,
srchost char(200),
dstuser varchar(200),
dsthost char(200),
tablesize decimal(10,2)
);

--error 1091
alter table mail drop column c18;
ALTER TABLE mail ADD c18 varchar(200) GENERATED ALWAYS AS (cast(srcuser as CHAR)) VIRTUAL;

--error 1091
alter table mail drop column c19;
ALTER TABLE mail ADD c19 varchar(200) GENERATED ALWAYS AS (cast(dstuser as CHAR)) VIRTUAL;

