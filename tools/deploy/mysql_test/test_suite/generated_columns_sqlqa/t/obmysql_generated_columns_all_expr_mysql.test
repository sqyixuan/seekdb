CREATE TABLE triangle23 (
  sidea CHAR(100),
  sideb CHAR(100),
  sidec CHAR(200) AS (COALESCE(NULL,sidea,NULL))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle23 (sidea, sideb) VALUES('chaerre','chaerre'),('中文测试','中文测试'),('中文混合adfso441','中文混合adfso441');

