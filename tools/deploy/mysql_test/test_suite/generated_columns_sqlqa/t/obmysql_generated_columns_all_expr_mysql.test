CREATE TABLE triangle23 (
  sidea VARCHAR(100),
  sideb VARCHAR(100),
  sidec VARCHAR(200) AS (STRCMP(sidea, sideb)),
  sided VARCHAR(200) AS (SUBSTRING_INDEX('www.mysql.com', '.', -2)),
  sidee VARCHAR(200) AS (MD5(sidea)),
  sidef VARCHAR(200) AS (DATE_SUB('1998-01-02', INTERVAL 31 DAY)),
  sideg VARCHAR(200) AS (SUBTIME('2007-12-31 23:59:59.999999','1 1:1:1.000002')),
  sideh VARCHAR(200) AS (DATEDIFF('2007-12-31 23:59:59','2007-12-30')),
  sidei VARCHAR(200) AS (TIMESTAMPDIFF(MINUTE,'2003-02-01','2003-05-01 12:05:55')),
  sidek VARCHAR(200) AS (RPAD(sidea,1,'?')),
  sidel VARCHAR(200) AS (LPAD(sideb,4,'??')),
  sidem VARCHAR(200) AS (LPAD(sidea,1,'??')),
  siden VARCHAR(200) AS (TO_DAYS(950501))
  )
DEFAULT CHARACTER SET = utf8;

INSERT INTO triangle23 (sidea, sideb) VALUES('chaerre','chaerr');
INSERT INTO triangle23 (sidea, sideb) VALUES('中文测试','中文测试1');
INSERT INTO triangle23 (sidea, sideb) VALUES('中文混合adfso441','中文混合adfso442');
INSERT INTO triangle23 (sidea, sideb) VALUES('20000101','19920202');

SELECT * FROM triangle23;
desc triangle23;

