###MYSQL全量内置函数验证generated_column-1-1-1-2-1

--disable_warnings
drop table if exists triangle23;
--enable_warnings

CREATE TABLE triangle23 (
  sidea CHAR(100),
  sideb CHAR(100),
  sidec CHAR(200) AS (sidea))
DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle23 (sidea, sideb) VALUES('chaerre','chaerre'),('中文测试','中文测试'),('中文混合adfso441','中文混合adfso441');

SELECT * FROM triangle23;

--disable_warnings
drop table if exists triangle23;
--enable_warnings


#to_type(MYSQL官网没此函数)
#char
#SELECT HEX(CHAR(1,0)), HEX(CHAR(256));
#SELECT HEX(CHAR(1,0,0)), HEX(CHAR(256*256));
#SELECT CHARSET(CHAR(X'65')), CHARSET(CHAR(X'65' USING utf8));

CREATE TABLE triangle23 (
  sidea VARCHAR(100),
  sideb VARCHAR(100),
  sidec INT as (HEX(sidea)))
DEFAULT CHARACTER SET = utf8;
--error 1264
INSERT INTO triangle23 (sidea, sideb) VALUES('chaerre','chaerre');
--error 1366
INSERT INTO triangle23 (sidea, sideb) VALUES('中文测试','中文测试');
--error 1366
INSERT INTO triangle23 (sidea, sideb) VALUES('中文混合adfso441','中文混合adfso441');

INSERT INTO triangle23 (sidea, sideb) VALUES('c','a');
SELECT * FROM triangle23;

--disable_warnings
drop table if exists triangle23;
--enable_warnings

#convert
#SELECT CONVERT('abc' USING utf8mb4);


CREATE TABLE triangle23 (
  sidea VARCHAR(100),
  sideb VARCHAR(100),
  sidec VARCHAR(200) AS (CONVERT(sidea USING utf8mb4)))
DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle23 (sidea, sideb) VALUES('chaerre','chaerre'),('中文测试','中文测试'),('中文混合adfso441','中文混合adfso441');

SELECT * FROM triangle23;

--disable_warnings
drop table if exists triangle23;
--enable_warnings

