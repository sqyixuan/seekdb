###全量表达式，分别对应数字、日期和字符，通过以上函数来验证即可

--disable_warnings
drop table if exists triangle23;
--enable_warnings

CREATE TABLE triangle23 (
  sidea VARCHAR(100),
  sideb VARCHAR(100),
##  sidec VARCHAR(200) AS (LAST_INSERT_ID()),
  sided VARCHAR(200) AS (CHARSET(CONVERT('中文' USING GBK))),
  sidee VARCHAR(200) AS (COLLATION(_utf8mb4'abc')),
  sidef VARCHAR(200) AS (REVERSE(sidea)),
  sideg VARCHAR(200) AS (MAKE_SET(1 | 4,'hello','nice',NULL,'world')),
  sideh VARCHAR(200) AS (char_length(sideb)),
  sidei VARCHAR(200) AS (CONCAT_WS(',','First name','Second name','Last Name'))
##  sidek VARCHAR(200) AS (ROW_COUNT()),
##  sidel VARCHAR(200) AS (FOUND_ROWS())
  )
DEFAULT CHARACTER SET = utf8;

INSERT INTO triangle23 (sidea, sideb) VALUES('chaerre','chaerr');
INSERT INTO triangle23 (sidea, sideb) VALUES('中文测试','中文测试1');
INSERT INTO triangle23 (sidea, sideb) VALUES('中文混合adfso441','中文混合adfso442');
INSERT INTO triangle23 (sidea, sideb) VALUES('20000101','19920202');

SELECT * FROM triangle23;
desc triangle23;

--disable_warnings
drop table if exists triangle23;
--enable_warnings


