#=
##SELECT 1 = 1, NULL = NULL, 1 = NULL;
###<=>
##SELECT 1 <=> 1, NULL <=> NULL, 1 <=> NULL;
##SELECT 1 = 1, NULL = NULL, 1 = NULL;
###get_user_var(MYSQL官网没此函数)
###>=
##SELECT 2 >= 2;
###>
##SELECT 2 > 2;


CREATE TABLE triangle23 (
  sidea VARCHAR(100),
  sideb VARCHAR(100),
  sidec VARCHAR(200) AS (NULL = NULL),
  sided VARCHAR(200) AS (NULL <=> NULL),
  sidee VARCHAR(200) AS (2 >= 2),
  sidef VARCHAR(200) AS (1 <=> NULL)
  )
DEFAULT CHARACTER SET = utf8;

INSERT INTO triangle23 (sidea, sideb) VALUES('chaerre','chaerre');
INSERT INTO triangle23 (sidea, sideb) VALUES('中文测试','中文测试');
INSERT INTO triangle23 (sidea, sideb) VALUES('中文混合adfso441','中文混合adfso441');
INSERT INTO triangle23 (sidea, sideb) VALUES('20000101','19920202');

SELECT * FROM triangle23;
desc triangle23;

--disable_warnings
drop table if exists triangle23;
--enable_warnings

#greatest
##SELECT GREATEST(2,0);
##SELECT GREATEST(34.0,3.0,5.0,767.0);
##SELECT GREATEST('B','A','C');

CREATE TABLE triangle23 (
  sidea VARCHAR(100),
  sideb VARCHAR(100),
  sidec VARCHAR(200) AS (GREATEST(2,0)),
  sided VARCHAR(200) AS (GREATEST(34.0,3.0,5.0,767.0)),
  sidee VARCHAR(200) AS (GREATEST('B','A','C')),
  sidef VARCHAR(200) AS (GREATEST(sidea,sideb))
  )
DEFAULT CHARACTER SET = utf8;

INSERT INTO triangle23 (sidea, sideb) VALUES('chaerre','chaerr');
INSERT INTO triangle23 (sidea, sideb) VALUES('中文测试','中文测试1');
INSERT INTO triangle23 (sidea, sideb) VALUES('中文混合adfso441','中文混合adfso442');
INSERT INTO triangle23 (sidea, sideb) VALUES('20000101','19920202');

SELECT * FROM triangle23;
desc triangle23;

--disable_warnings
drop table if exists triangle23;
--enable_warnings
