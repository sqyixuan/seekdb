--echo  ########utf8||Mysql:MYSQL全量内置函数验证generated_column-1-1-1-2-1####################
--disable_warnings
drop database  IF EXISTS  ob35x;
--enable_warnings
create database ob35x  character set utf8;
use ob35x;

SET NAMES utf8;
###--character_set utf8

--disable_warnings
drop table if exists triangle;
--enable_warnings

CREATE TABLE triangle (
  sidea DOUBLE,
  sideb DOUBLE,
  sidec DOUBLE AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle (sidea, sideb) VALUES(1.7976931348623157,1.7976931348623157),(-1.7976931348623157,-1.7976931348623157);

SELECT * FROM triangle;

--disable_warnings
drop table if exists triangle;
--enable_warnings

