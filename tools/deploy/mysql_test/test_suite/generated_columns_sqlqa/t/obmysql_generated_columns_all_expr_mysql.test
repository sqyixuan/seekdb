CREATE TABLE triangle14 (
  sidea DATE,
  sideb DATE,
  sidec DATE AS (date(sidea))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle14 (sidea, sideb) VALUES('1001-01-01','1001-01-01'),('9998-12-31','9998-12-31'),('2020-12-31','2020-12-31');

SELECT * FROM triangle14;
desc triangle14;

--disable_warnings
drop table if exists triangle14;
