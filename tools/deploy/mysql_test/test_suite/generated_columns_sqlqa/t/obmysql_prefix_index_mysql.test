###varchar前缀索引；generated_column-1-2-2//generated_column-1-2-2-1
--disable_warnings
DROP TABLE IF EXISTS testtable2;
--enable_warnings


CREATE TABLE testtable2 (
  old_kefuid VARCHAR(10),
  new_kefuid VARCHAR(10),
  INDEX (new_kefuid(5))
)DEFAULT CHARACTER SET = utf8;


INSERT INTO testtable2 (old_kefuid, new_kefuid) VALUES('老的111','新的111'),('老的2222','新的22222'),('老的3333','新的333');
##插入超长字段，边界值验证//generated_column-1-2-2-2//generated_column-1-2-2-1
--error 1406
INSERT INTO testtable2 (old_kefuid, new_kefuid) VALUES('老的1111111111111111','新的1111111111111');
INSERT INTO testtable2 (old_kefuid, new_kefuid) VALUES('老的22222222','新的22222222');
INSERT INTO testtable2 (old_kefuid, new_kefuid) VALUES('老的1111','新的111'),('老的22222','新的222222'),('老的333333','新的33333333');

select left(new_kefuid,10) as 右边5位10长度,count(*) as 总数 from testtable2 GROUP by left(new_kefuid,10);
##explain select left(new_kefuid,10) as 右边5位10长度,count(*) as 总数 from testtable2 GROUP by left(new_kefuid,10);

select * from testtable2 order by old_kefuid,new_kefuid;
##explain select * from testtable2;

###引用前缀索引
select * from testtable2 where new_kefuid like '新的1111%';
###explain select * from testtable2 where new_kefuid like '新的1111%';

--disable_warnings
DROP TABLE IF EXISTS testtable2;
--enable_warnings

