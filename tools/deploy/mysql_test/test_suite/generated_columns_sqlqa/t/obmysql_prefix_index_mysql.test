###各种类型查询

--disable_warnings
DROP TABLE IF EXISTS testtable3;
--enable_warnings

CREATE TABLE testtable3 (
  C1 CHAR(6),
  C2 VARCHAR(7),
  C3 BINARY,
  C4 VARBINARY(7),
  C5 BLOB,
  C6 TEXT,
  INDEX (C1(6))
)DEFAULT CHARACTER SET = GBK;

--error 1089
CREATE TABLE testtable3 (
  C1 CHAR(6),
  C2 VARCHAR(7),
  C3 BINARY,
  C4 VARBINARY(7),
  C5 BLOB,
  C6 TEXT,
  INDEX (C1(6)),
  INDEX (C2(6)),
  INDEX (C3(6)),
  INDEX (C4(6)),
  INDEX (C5(6)),
  INDEX (C6(6))	
)DEFAULT CHARACTER SET = GBK;

DROP TABLE IF EXISTS testtable3;
--error 1167,1170
CREATE TABLE testtable3 (
  C1 CHAR(6),
  C2 VARCHAR(7),
  C3 BINARY,
  C4 VARBINARY(7),
  C5 BLOB,
  C6 TEXT,
  INDEX (C3),
  INDEX (C5),
  INDEX (C6)	
)DEFAULT CHARACTER SET = GBK;



DROP TABLE IF EXISTS testtable3;
CREATE TABLE testtable3 (
  C1 CHAR(6),
  C2 VARCHAR(7),
  C3 BINARY,
  C4 VARBINARY(7),
  C5 BLOB,
  C6 TEXT,
  INDEX (C3),
  INDEX (C5(1)),
  INDEX (C6(2))	
)DEFAULT CHARACTER SET = GBK;



INSERT INTO testtable3 VALUES('A','aaaaaa','a','aa','aaa','aaaaa');
###引用前缀索引
select * from testtable3 where c3 like 'a%';
###explain select * from testtable3 where c3 like 'a%';

select * from testtable3 where c5 like 'a%';
###explain select * from testtable3 where c5 like 'a%';

select * from testtable3 where c6 like 'a%';
###explain select * from testtable3 where c6 like 'a%';

--disable_warnings
DROP TABLE IF EXISTS testtable3;
--enable_warnings



###前缀索引-运算符验证
--disable_warnings
DROP TABLE IF EXISTS testtable2;
--enable_warnings

CREATE TABLE testtable2 (
  a CHAR(10) primary key,
  b CHAR(10),
  index i1(b(5))
)DEFAULT CHARACTER SET = utf8;


INSERT INTO testtable2 (a, b) VALUES('aaaaa','aaaaa');
INSERT INTO testtable2 (a, b) VALUES('bbbbb','bbbbb');
INSERT INTO testtable2 (a, b) VALUES('ccccc','ccccc');
INSERT INTO testtable2 (a, b) VALUES('aaaaaa','aaaaaa');
INSERT INTO testtable2 (a, b) VALUES('bbbbbb','bbbbbb');
INSERT INTO testtable2 (a, b) VALUES('cccccc','cccccc');
INSERT INTO testtable2 (a, b) VALUES('aaaa','aaaa');
INSERT INTO testtable2 (a, b) VALUES('bbbb','bbbb');
INSERT INTO testtable2 (a, b) VALUES('cccc','cccc');
INSERT INTO testtable2 (a, b) VALUES('abcde','abcde');
INSERT INTO testtable2 (a, b) VALUES('cdeab','cdeab');
INSERT INTO testtable2 (a, b) VALUES('bcdeA',NULL);
INSERT INTO testtable2 (a, b) VALUES('cdeaD',null);


###引用前缀索引
select * from testtable2 where b like 'aaa%';
###explain select * from testtable2 where b like 'aaa%';

select * from testtable2 where b > 'aaaaa';
###explain select * from testtable2 where b > 'aaaaa';

select * from testtable2 where b = 'aaaaa';
###explain select * from testtable2 where b = 'aaaaa';

select * from testtable2 where b < 'abcde';
###explain select * from testtable2 where b < 'abcde';

select * from testtable2 where b <= 'abcde';
###explain select * from testtable2 where b <= 'abcde';

###generated_column-1-2-2-3
select * from testtable2 where b <= 'abcde' group by b order by a;
###explain select * from testtable2 where b <= 'abcde' group by b order by a;

select * from testtable2 where b >= 'abcde';
###explain select * from testtable2 where b >= 'abcde';

select * from testtable2 where b between 'aaaaa' and 'ddddd';
###explain select * from testtable2 where b between 'aaaaa' and 'ddddd';

select * from testtable2 where b not between 'aaaaa' and 'ddddd';
###explain select * from testtable2 where b not between 'aaaaa' and 'ddddd';

select * from testtable2 where b in( 'aaaaa','abcde','ddddd');
###explain select * from testtable2 where b in( 'aaaaa','abcde','ddddd');

select * from testtable2 where b not in( 'aaaaa','abcde','ddddd');
###explain select * from testtable2 where b not in( 'aaaaa','abcde','ddddd');

select * from testtable2 where b <=> 'abcde';
###explain select * from testtable2 where b <=> 'abcde';

select * from testtable2 where b <=> 'abcde';
###explain select * from testtable2 where b <=> 'abcde';

select * from testtable2 where b is NULL;
###explain select * from testtable2 where b is NULL;

select * from testtable2 where b is not NULL;
###explain select * from testtable2 where b is not NULL;

select * from testtable2 where b REGEXP '^aaa';
###explain select * from testtable2 where b REGEXP '^aaa';


--disable_warnings
DROP TABLE IF EXISTS testtable2;
--enable_warnings


