alter table tb_function add key idx_create_time(create_time);
select * from tb_function where date(create_time)='2020-07-01';
###explain select * from tb_function where date(create_time)='2020-07-01';
select * from tb_function where create_time>='2020-07-01' and create_time<date_add('2020-07-01',INTERVAL 1 day);
