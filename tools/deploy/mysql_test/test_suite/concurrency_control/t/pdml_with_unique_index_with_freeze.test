# owner: handora.qc
# owner group: Transaction 2
# description: case for pdml insert into the same row of unique index with freeze

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int, b int) partition by hash(c1) partitions 2;
create unique index i1 on t1(b, c1);
insert into t1 values(1, 1), (2, 2);
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

let $i=0;
--disable_query_log
--disable_warnings
while($i < 1000)
{
  --error 1062
  update /*+parallel(10), enable_parallel_dml*/ t1 set b=0, c1=0;
  inc $i;
}
--enable_warnings
--enable_query_log

drop table if exists t1;
