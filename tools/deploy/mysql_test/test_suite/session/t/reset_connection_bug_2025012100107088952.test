# owner: xiaoqiu.wy
# owner group: SQL2
# description: test reset connection sysvar bug

connect (obmysql, $OBMYSQL_MS0, root, , test, $OBMYSQL_PORT);
--disable_query_log
connection obmysql;
--enable_query_log

set global ob_query_timeout = 1234567890;
set global ob_trx_timeout = 1234567890;
disconnect obmysql;

connect (obmysql, $OBMYSQL_MS0, root, , test, $OBMYSQL_PORT);
connection obmysql;
select @@ob_query_timeout;
select @@ob_trx_timeout;

--reset_connection
select @@ob_query_timeout;
select @@ob_trx_timeout;
disconnect obmysql;

connect (obmysql, $OBMYSQL_MS0, root, , test, $OBMYSQL_PORT);
connection obmysql;
select @@ob_query_timeout;
select @@ob_trx_timeout;

--reset_connection
select @@ob_query_timeout;
select @@ob_trx_timeout;
disconnect obmysql;

connect (obmysql, $OBMYSQL_MS0, root, , test, $OBMYSQL_PORT);
connection obmysql;
select @@ob_query_timeout;
select @@ob_trx_timeout;

--reset_connection
select @@ob_query_timeout;
select @@ob_trx_timeout;
disconnect obmysql;

connect (obmysql, $OBMYSQL_MS0, root, , test, $OBMYSQL_PORT);
connection obmysql;
select @@ob_query_timeout;
select @@ob_trx_timeout;

--reset_connection
select @@ob_query_timeout;
select @@ob_trx_timeout;
disconnect obmysql;

connect (obmysql, $OBMYSQL_MS0, root, , test, $OBMYSQL_PORT);
connection obmysql;
select @@ob_query_timeout;
select @@ob_trx_timeout;

--reset_connection
select @@ob_query_timeout;
select @@ob_trx_timeout;
disconnect obmysql;

connect (obmysql, $OBMYSQL_MS0, root, , test, $OBMYSQL_PORT);
connection obmysql;
select @@ob_query_timeout;
select @@ob_trx_timeout;

--reset_connection
select @@ob_query_timeout;
select @@ob_trx_timeout;
set global ob_query_timeout = 10000000;
set global ob_trx_timeout = 86400000000;
disconnect obmysql;

connect (obmysql, $OBMYSQL_MS0, root, , test, $OBMYSQL_PORT);
connection obmysql;
select @@ob_query_timeout;
select @@ob_trx_timeout;

--reset_connection
select @@ob_query_timeout;
select @@ob_trx_timeout;
disconnect obmysql;