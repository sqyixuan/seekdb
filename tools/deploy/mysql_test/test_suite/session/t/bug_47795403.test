--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# Test for BUG#47795403 defragment_sys_variable has memory allocation failure wild pointer problem
# Double buffer optimization

--let $i=1000
while ($i)
{
  --eval set default_authentication_plugin = '';
  --eval set default_authentication_plugin = '';
  --dec $i
}
