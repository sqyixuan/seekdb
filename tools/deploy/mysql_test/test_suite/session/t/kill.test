--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL1
# description: test for kill session_id

--error 1054
kill abc;
--error 1094
kill 123;
--error 0,1396
drop user kill_user;
create user 'kill_user' identified by 'kill_user';
GRANT ALL ON *.* TO 'kill_user';

## --echo ## expect 1 session ##
## --replace_column 1 id 3 host 5 command 6 time 7 state 8 info
## show processlist;
connect (ki_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
let $a=query_get_value(select id from oceanbase.__all_virtual_processlist  where info like '%select%',id,1);
connection default;

--source mysql_test/include/check_schema_sync.inc
--echo a new connection named by conn1
connect (conn1,$OBMYSQL_MS0,kill_user,kill_user,test,$OBMYSQL_PORT);
let $b=query_get_value(select connection_id() as id,id,1);

--echo a new connection named by conn2
connect (conn2,$OBMYSQL_MS0,kill_user,kill_user,test,$OBMYSQL_PORT);
let $c=query_get_value(select connection_id() as id,id,1);
--echo ## expect 2 session ##
#--replace_column 1 id 3 host 5 command 6 time 7 state 8 info
#show processlist;
connection ki_obsys;
select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';
connection default;

## --echo ## kill the default connection, expect 2 session remaining ##
## --disable_query_log
## eval kill  $a;
## --enable_query_log
## ## --replace_column 1 id 3 host 5 command 6 time 7 state 8 info
## ## show processlist;
## select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';


--echo ## use conn1, expect 2 session remaining ##
connection conn1;
## --replace_column 1 id 3 host 5 command 6 time 7 state 8 info
## show processlist;
connection ki_obsys;
select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';
connection default;

--echo ## kill conn2, expect 1 session ##
--disable_query_log
eval kill $c;
--enable_query_log
## --replace_column 1 id 3 host 5 command 6 time 7 state 8 info
## show processlist;
connection ki_obsys;
select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';
connection default;

## test kill expr
set @session_id = 0;
--error 1094
kill @session_id;
kill query @session_id;
--error 1094
kill connection @session_id;
--error 1094
kill 2-1-1;
--error 1094
kill 'aaaa';
--error 1094
kill '0000';
--error 1094
kill concat('000','000');
--error 1054
kill c1+c2;

--echo a new connection named by conn3
connect (conn3,$OBMYSQL_MS0,kill_user,kill_user,test,$OBMYSQL_PORT);
let $d=query_get_value(select connection_id() as id,id,1);
--echo ## expect 2 session remaining ##
## --replace_column 1 id 3 host 5 command 6 time 7 state 8 info
## show processlist;
connection ki_obsys;
select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';
connection conn3;

--echo a new connection named by conn4
connect (conn4,$OBMYSQL_MS0,kill_user,kill_user,test,$OBMYSQL_PORT);
--echo ## expect 3 session remaining ##
## --replace_column 1 id 3 host 5 command 6 time 7 state 8 info
## show processlist;
connection ki_obsys;
select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';
connection conn4;

set @sess_id=connection_id();
let $f=query_get_value(select @sess_id as id,id,1);
--echo kill session use connection_id()
--disable_query_log
eval kill $d;
--enable_query_log

connection conn1;
--echo kill session use user_variable
--disable_query_log
eval kill $f;
--enable_query_log
--echo ## expect 1 session remaining ##
## --replace_column 1 id 3 host 5 command 6 time 7 state 8 info
## show processlist;
connection ki_obsys;
select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';
connection conn1;

--echo kill self,conn1
--disable_query_log
--disable_result_log
--error 2013
eval kill $b;
--enable_query_log
--enable_result_log
#这里本来应该返回2006 server gone才对，但是由于服务端关连接比较慢，导致下一个请求还是发出去了(服务端保证这个请求是不会被处理的)，报错变成2013
--error 2006, 2013
show processlist;
