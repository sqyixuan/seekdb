--echo    minus-2-1-1    char               
drop   table  if  exists   EMP001;
create table EMP001(a char(20),b TEXT(100));
insert into EMP001 values('helloworld','ab');
insert into EMP001 values('hello','ab');
insert into EMP001 values('','ab');
insert into EMP001 values(null,'ab');


drop   table  if  exists   EMP002;
create table EMP002(a char(20),b TEXT(100));
insert into EMP002 values('helloworld','ab');
insert into EMP002 values('hello','ab');
insert into EMP002 values('','ab');
insert into EMP002 values(null,'ab');

select    count(*)    FROM     (select     a,b   FROM    EMP001    minus  select      a,a       FROM    EMP002) e;   
select    count(*)    FROM     (select     a,b  FROM    EMP001    UNION  select    a,a       FROM    EMP002) e;
--error    1060
select    count(*)    FROM     (select     b,b  FROM    EMP001    UNION  select    a,a       FROM    EMP002) e;   
select    count(*)    FROM     (select      *   FROM    EMP001    UNION  all  select      *        FROM    EMP002) e;  
select    count(*)    FROM     (select      *   FROM    EMP001    INTERSECT  select      *        FROM    EMP002) e;   
--error    1060
select    count(*)    FROM     (select      *   FROM    EMP001    JOIN   (select      *   FROM    EMP001    minus  select      *        FROM    EMP002) ON    1=1) e; 
--error    1060
select    count(*)    FROM     (select      *   FROM    EMP001    JOIN   (select      *   FROM    EMP001    UNION  select      *        FROM    EMP002) r   ON    1=1) e;   
select    count(*)    FROM     (select      y.a  FROM    EMP001 y    JOIN   (select     a  FROM    EMP001    UNION  all  select      a      FROM    EMP002)  r ON    1=1)e;   
select    count(*)    FROM     (select     b   FROM    EMP001    JOIN   (select     a  FROM    EMP001    INTERSECT  select      a       FROM    EMP002) r    ON    1=1)e;   
select    count(*)    FROM     (select     b   FROM    EMP001    JOIN   (select      a   FROM    EMP001    minus  select     a       FROM    EMP002) ON    (select     b  FROM    EMP001    minus  select     b       FROM    EMP002)= (select      b  FROM    EMP001    minus  select      b     FROM    EMP001));
--error   1222
