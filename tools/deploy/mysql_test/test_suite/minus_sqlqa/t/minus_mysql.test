SELECT   *  FROM   (SELECT   *  FROM   (SELECT     *      FROM    EMP001_VIEW      minus    select    *     FROM    EMP002_VIEW)      MINUS  SELECT   *  FROM   (SELECT     *      FROM    EMP002_VIEW      INTERSECT    select    *     FROM    EMP001_VIEW))  e  ORDER  BY  e.EMPNO,e.HIREDATE,e.sal;
 


--echo   minus-4-1-1-1-3  聚合函数
SELECT    sum(empno)     FROM    EMP001     minus    select    sum(sal)        FROM    EMP001_VIEW;
SELECT   *  FROM   (SELECT    avg(empno)  eee    FROM    EMP001     UNION    select    avg(comm)        FROM    EMP002_VIEW)  t   ORDER BY   eee;
SELECT   *  FROM   (SELECT    max(empno) eee    FROM    EMP001     UNION  all    select    max(empno)        FROM    EMP002_VIEW)  t   ORDER BY   eee;
SELECT    min(empno)     FROM    EMP001     INTERSECT    select    sum(sal)        FROM    EMP002_VIEW;
 


