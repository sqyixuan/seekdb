drop procedure if exists onehundredthousand;  
DELIMITER /;
create  procedure onehundredthousand()
begin  
declare i INTEGER;
while i < 100000 do  
INSERT INTO EMP001 VALUES(1,CONCAT('SMITH003',i,'CLERK',7903,'1998-12-21','dd-mm-yyyy'),1000,NULL,40,i);
INSERT INTO EMP002 VALUES(1,CONCAT('SMITH003',i,'CLERK',7903,'1997-12-12','dd-mm-yyyy'),1000,NULL,40,i);
end while;  
end;
/

DELIMITER ;/
CALL   onehundredthousand();
SELECT   count(*)   FROM   (SELECT     *      FROM    EMP001      MINUS    select    *     FROM    EMP002)e;
SELECT   count(*)   FROM   (SELECT     *      FROM    EMP001      UNION    select    *     FROM    EMP002)e;
SELECT   count(*)   FROM   (SELECT     *      FROM    EMP001      UNION  all    select    *     FROM    EMP002)e;
SELECT   count(*)   FROM   (SELECT     *      FROM    EMP001      INTERSECT    select    *     FROM    EMP002)e;

 


