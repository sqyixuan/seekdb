SELECT    sum(e.empno) , sum(e.sal),sum(r.empno) , sum(r.sal)   FROM      (SELECT     *      FROM    EMP001      INTERSECT    select    *     FROM    EMP002)   e    left outer      join EMP001 r  on e.empno = r.empno   ORDER BY  e.empno;

 

