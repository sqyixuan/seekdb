create table  emp001   as select * from   emp;
create table  emp002   as select * from   emp;





SELECT    sum(e.empno)  z, sum(e.sal) x,sum(r.empno) c , sum(r.sal) v  FROM      (SELECT     *      FROM    EMP001      minus    select    *     FROM    EMP002)   e                     join EMP001 r  on e.empno = r.empno   ORDER BY  z,x,c,v;
SELECT    sum(e.empno)  z, sum(e.sal) x,sum(r.empno) c , sum(r.sal) v  FROM      (SELECT     *      FROM    EMP001      UNION    select    *     FROM    EMP002)   e                     join EMP001 r  on e.empno = r.empno    ORDER BY  z,x,c,v;
SELECT    sum(e.empno)  z, sum(e.sal) x,sum(r.empno) c , sum(r.sal) v  FROM      (SELECT     *      FROM    EMP001      UNION  all    select    *     FROM    EMP002)   e                     join EMP001 r  on e.empno = r.empno    ORDER BY  z,x,c,v;
SELECT    sum(e.empno)  z, sum(e.sal) x,sum(r.empno) c , sum(r.sal) v  FROM      (SELECT     *      FROM    EMP001      INTERSECT    select    *     FROM    EMP002)   e                     join EMP001 r  on e.empno = r.empno    ORDER BY  z,x,c,v;



