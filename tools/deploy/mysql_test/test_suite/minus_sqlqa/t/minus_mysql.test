--echo  minus-6-1-1 无参数的存储过程
DELIMITER /;
drop procedure if exists pl_test;/
create  procedure pl_test()  
begin  
declare  i TINYINT;  
SELECT   COUNT(*)   FROM    (SELECT     1   FROM     dual  minus   SELECT     1     FROM     dual)e;
SELECT   COUNT(*)   FROM    (SELECT     1   FROM     dual  UNION   SELECT     1     FROM     dual)e;
SELECT   COUNT(*)   FROM    (SELECT     1   FROM     dual  union  all   SELECT     1     FROM     dual)e;
SELECT   COUNT(*)   FROM    (SELECT     1   FROM     dual  INTERSECT   SELECT     1     FROM     dual)e;
end;
/
call  pl_test();/

--echo  minus-6-1-2    只有一个 in 参数的存储过程
drop procedure if exists pl_test;/
create  procedure pl_test (in numb int)
BEGIN
INSERT INTO EMP VALUES((SELECT   numb   FROM   dual   MINUS   SELECT   numb     FROM   dual),'99FORD','ANALYST',7566,'1997-12-14',1101,400,20,'分部5');
INSERT INTO EMP VALUES((SELECT   numb   FROM   dual   UNION   SELECT   numb     FROM   dual),'99FORD','ANALYST',7566,'1997-12-14',1101,400,20,'分部5');
INSERT INTO EMP VALUES((SELECT   numb   FROM   dual   union  all   SELECT   numb     FROM   dual),'99FORD','ANALYST',7566,'1997-12-14',1101,400,20,'分部5');
INSERT INTO EMP VALUES((SELECT   numb   FROM   dual   INTERSECT   SELECT   numb     FROM   dual),'99FORD','ANALYST',7566,'1997-12-14',1101,400,20,'分部5');
end;
/
--error  1242
call   pl_test(1000);/




--echo  minus-6-1-3  
drop procedure if exists pl_test;/
CREATE  PROCEDURE pl_test(out num int)
BEGIN	
SELECT     COUNT(*)  INTO num   FROM (SELECT     empno   FROM   EMP  MINUS  SELECT     empno    FROM   EMP);
SELECT     COUNT(*)  INTO num   FROM (SELECT     empno   FROM   EMP  UNION  SELECT     empno    FROM   EMP);
SELECT     COUNT(*)  INTO num   FROM (SELECT     empno   FROM   EMP  union  all  SELECT     empno    FROM   EMP);
SELECT     COUNT(*)  INTO num   FROM (SELECT     empno   FROM   EMP  INTERSECT  SELECT     empno    FROM   EMP);
END;
/

call   pl_test(@num);/





--echo  minus-6-1-4     包含 inout 参数的存储过程,in需要穿参数   out的传变量，in  out 的作in使用就按照in处理 作out使用就按照out处理     ###in out作out使用
drop procedure if exists pl_test;/
CREATE  PROCEDURE pl_test(OUT p1  int,inout p2 int,OUT p3  int)
BEGIN	
SELECT     COUNT(*)  INTO p1    FROM (SELECT     empno   FROM   EMP  MINUS  SELECT     empno    FROM   EMP);
SELECT     COUNT(*)  INTO p2    FROM (SELECT     empno   FROM   EMP  UNION  SELECT     empno    FROM   EMP);
SELECT     COUNT(*)  INTO p3    FROM (SELECT     empno   FROM   EMP  UNION  all  SELECT     empno    FROM   EMP);
SELECT     COUNT(*)  INTO p3    FROM (SELECT     empno   FROM   EMP  INTERSECT  SELECT     empno    FROM   EMP);
INSERT INTO emp   VALUES(1,(SELECT   1  FROM   dual  MINUS   SELECT  2  FROM   dual),'ANALYST',7566,'1998-12-12',p1+p2+p3,400,20,'分部5');
END;
/
call   pl_test(@p1,@p2,@p3);/




--echo  minus-6-1-5
###in out作in使用
drop procedure if exists pl_test;/
CREATE  PROCEDURE pl_test(OUT p1  int,inout p2 int,OUT p3  int)
BEGIN	
SELECT     COUNT(*)  INTO p1    FROM (SELECT     empno   FROM   EMP  MINUS  SELECT     empno    FROM   EMP);
SELECT     COUNT(*)  INTO p2    FROM (SELECT     empno   FROM   EMP  UNION  SELECT     empno    FROM   EMP);
SELECT     COUNT(*)  INTO p3    FROM (SELECT     empno   FROM   EMP  UNION  all  SELECT     empno    FROM   EMP);
SELECT     COUNT(*)  INTO p3    FROM (SELECT     empno   FROM   EMP  INTERSECT  SELECT     empno    FROM   EMP);
INSERT INTO emp   VALUES(1,(SELECT   1  FROM   dual  MINUS   SELECT  2  FROM   dual),'ANALYST',7566,'1998-12-12',p1+p2+p3,400,20,'分部5');
END;
/
set @num01 =350;/
call   pl_test(@p1,@num01,@p3);/





--echo  --echo  minus-6-1-6    函数的结果作为存储过程的参数传递
drop function if exists fun_test;/
create  function fun_test()
RETURNS int    
begin   
declare 	result01   int  DEFAULT 0; 
declare 	result02   int  DEFAULT 0; 
declare 	result03  int  DEFAULT 0; 
declare 	result04   int  DEFAULT 0; 
SELECT   count(*)    INTO   result01  FROM    (select   comm      from       EMP     MINUS    select   sal      from       EMP);   
SELECT   count(*)    INTO   result02  FROM    (select   comm      from       EMP     UNION    select   sal      from       EMP);   
SELECT   count(*)    INTO   result03  FROM    (select   comm      from       EMP     union  all    select   sal      from       EMP);   
SELECT   count(*)    INTO   result04  FROM    (select   comm      from       EMP     INTERSECT    select   sal      from       EMP);   
return  result01+result02+result03+result04;  
end;
/
select  fun_test()  from  dual;/



drop procedure if exists pl_test;/
CREATE  PROCEDURE pl_test(in p1  int)
BEGIN	
declare  i INT DEFAULT 1;
while
       i < 100 DO
      INSERT INTO EMP   VALUES(i,(SELECT   1  FROM   dual  MINUS   SELECT  2  FROM   dual),'ANALYST',7566,'1998-12-14',p1,400,20,'分部5');
      SET i = i + 1;
END WHILE;
END;
/
set @num02 =fun_test();/
CALL  pl_test(@num02);/

select  count(*)  from emp  e  ORDER BY e.EMPNO,e.sal;/

 



--echo   minus-6-2-1  无参数的自定义函数
drop function if exists fun_test;/
create  function fun_test()
RETURNS int    
begin   
declare 	result01   int  DEFAULT 0; 
declare 	result02   int  DEFAULT 0; 
declare 	result03   int  DEFAULT 0; 
declare 	result04   int  DEFAULT 0; 
SELECT   count(*)    INTO   result01  FROM    (select   comm      from       EMP     MINUS    select   sal      from       EMP);   
SELECT   count(*)    INTO   result01  FROM    (select   comm      from       EMP     UNION    select   sal      from       EMP);   
SELECT   count(*)    INTO   result01  FROM    (select   comm      from       EMP     union  all    select   sal      from       EMP);   
SELECT   count(*)    INTO   result01  FROM    (select   comm      from       EMP     INTERSECT    select   sal      from       EMP);   
return  result01+result02+result03+result04;  
end;
/
select  fun_test()  from  dual;/

--echo   minus-6-2-2   自定义函数  有参数
drop function if exists fun_test;/
create  function fun_test(saller002 int)
RETURNS int    
begin   
declare 	result01   int  DEFAULT 0; 
declare 	result02   int  DEFAULT 0; 
declare 	result03   int  DEFAULT 0; 
declare 	result04   int  DEFAULT 0; 
SELECT   count(*)    INTO   result01  FROM    (select   comm      from       EMP     MINUS    select   sal      from       EMP) e   where   e.comm>saller002;   
SELECT   count(*)    INTO   result02  FROM    (select   comm      from       EMP     UNION    select   sal      from       EMP) e   where   e.comm>saller002;   
SELECT   count(*)    INTO   result03  FROM    (select   comm      from       EMP     union  all    select   sal      from       EMP) e   where   e.comm>saller002;   
SELECT   count(*)    INTO   result04  FROM    (select   comm      from       EMP     INTERSECT    select   sal      from       EMP) e   where   e.comm>saller002;   
return  result01+result02+result03+result04;  
end;
/
select  fun_test(100)  from  dual;/





--echo  minus-6-3-1     游标   cursor............. is      
drop procedure if exists pl_test;/
CREATE PROCEDURE pl_test()  
BEGIN  
    declare c int;  
    declare n varchar(20);  
    declare total int default 0;  
    declare done int default false;  
    declare cur cursor for select  ename, comm      from       EMP     minus    select  ename, sal      from       EMP;
    declare continue HANDLER for not found set done = true;  
    set total = 0;  
    open cur;  
    read_loop:loop  
    fetch cur into n,c;  
    if done then  
        leave read_loop;    
    end if;  
    set total = total + c;  
    end loop;  
    close cur;  
    select total;  
END;
/
call pl_test();/

drop procedure if exists pl_test;/
CREATE PROCEDURE pl_test()  
BEGIN  
    declare c int;  
    declare n varchar(20);  
    declare total int default 0;  
    declare done int default false;  
    declare cur cursor for select  ename, comm      from       EMP     UNION    select  ename, sal      from       EMP;
    declare continue HANDLER for not found set done = true;  
    set total = 0;  
    open cur;  
    read_loop:loop  
    fetch cur into n,c;  
    if done then  
        leave read_loop;    
    end if;  
    set total = total + c;  
    end loop;  
    close cur;  
    select total;  
END;
/
call pl_test();/

drop procedure if exists pl_test;/
CREATE PROCEDURE pl_test()  
BEGIN  
    declare c int;  
    declare n varchar(20);  
    declare total int default 0;  
    declare done int default false;  
    declare cur cursor for select  ename, comm      from       EMP     union  all    select  ename, sal      from       EMP;
    declare continue HANDLER for not found set done = true;  
    set total = 0;  
    open cur;  
    read_loop:loop  
    fetch cur into n,c;  
    if done then  
        leave read_loop;    
    end if;  
    set total = total + c;  
    end loop;  
    close cur;  
    select total;  
END;
/
call pl_test();/

drop procedure if exists pl_test;/
CREATE PROCEDURE pl_test()  
BEGIN  
    declare c int;  
    declare n varchar(20);  
    declare total int default 0;  
    declare done int default false;  
    declare cur cursor for select  ename, comm      from       EMP     INTERSECT    select  ename, sal      from       EMP;
    declare continue HANDLER for not found set done = true;  
    set total = 0;  
    open cur;  
    read_loop:loop  
    fetch cur into n,c;  
    if done then  
        leave read_loop;    
    end if;  
    set total = total + c;  
    end loop;  
    close cur;  
    select total;  
END;
/
call pl_test();/




delimiter ;/

alter system set _rowsets_max_rows = 2;
alter system flush plan cache;
--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int);
create table t2 (c1 int);
create table t3 (c1 int, c2 int, primary key(c1, c2));

insert into t1 values(1,1,1);
insert into t1 values(2,1,1);
insert into t1 values(2,1,2);
insert into t1 values(2,1,3);
insert into t1 values(2,2,1);

insert into t2 values(2);

insert into t3 values(2,1);

explain select /*+no_rewrite*/c1, c2 from (select c1, c2, c3 from t1 order by 1,2,3) t where not exists(select * from t2 where t.c3 = t2.c1) except select c1, c2 from t3;

select /*+no_rewrite*/c1, c2 from (select c1, c2, c3 from t1 order by 1,2,3) t where not exists(select * from t2 where t.c3 = t2.c1) except select c1, c2 from t3;

drop table t1;
drop table t2;
drop table t3;
alter system set _rowsets_max_rows = 256;

drop database  IF EXISTS  ob100x;
