--echo     select 普通查询      minus-3-1-1-1          
SELECT   *  FROM   (SELECT     *      FROM    EMP001      minus    select    *     FROM    EMP002)  e   ORDER  BY    e.empno,e.ename,e.job,e.mgr,e.hiredate,e.sal,e.comm,e.deptno,e.comid;
 
SELECT   *  FROM   (SELECT     *      FROM    EMP001      UNION    select    *     FROM    EMP002)  e   ORDER  BY    e.empno,e.ename,e.job,e.mgr,e.hiredate,e.sal,e.comm,e.deptno,e.comid;
 
SELECT   *  FROM   (SELECT     *      FROM    EMP001      union  all    select    *     FROM    EMP002)  e   ORDER  BY    e.empno,e.ename,e.job,e.mgr,e.hiredate,e.sal,e.comm,e.deptno,e.comid;
 
SELECT   *  FROM   (SELECT     *      FROM    EMP001      INTERSECT    select    *     FROM    EMP002)  e   ORDER  BY    e.empno,e.ename,e.job,e.mgr,e.hiredate,e.sal,e.comm,e.deptno,e.comid;



--echo   minus-3-1-1-1  select嵌套 
SELECT   *  FROM   (SELECT   *  FROM   (SELECT     *      FROM    EMP001      minus    select    *     FROM    EMP002)      MINUS  SELECT   *  FROM   (SELECT     *      FROM    EMP002      minus    select    *     FROM    EMP001))  e   ORDER  BY    e.empno,e.ename,e.job,e.mgr,e.hiredate,e.sal,e.comm,e.deptno,e.comid;
SELECT   *  FROM   (SELECT   *  FROM   (SELECT     *      FROM    EMP001      UNION    select    *     FROM    EMP002) h      UNION  SELECT   *  FROM   (SELECT     *      FROM    EMP002      union all    select    *     FROM    EMP001) j)  e  ORDER  BY    e.empno,e.ename,e.job,e.mgr,e.hiredate,e.sal,e.comm,e.deptno,e.comid;
SELECT   *  FROM   (SELECT   *  FROM   (SELECT     *      FROM    EMP001      UNION   all   select    *     FROM    EMP002) h      UNION  SELECT   *  FROM   (SELECT     *      FROM    EMP002      union all    select    *     FROM    EMP001) j)  e  ORDER  BY    e.empno,e.ename,e.job,e.mgr,e.hiredate,e.sal,e.comm,e.deptno,e.comid;
SELECT   *  FROM   (SELECT   *  FROM   (SELECT     *      FROM    EMP001      INTERSECT    select    *     FROM    EMP002) h      INTERSECT  SELECT   *  FROM   (SELECT     *      FROM    EMP002      union all    select    *     FROM    EMP001) j)  e  ORDER  BY    e.empno,e.ename,e.job,e.mgr,e.hiredate,e.sal,e.comm,e.deptno,e.comid;
SELECT   *  FROM   (SELECT   *  FROM   (SELECT     *      FROM    EMP001      UNION    select    *     FROM    EMP002)  q      union  all    SELECT   *  FROM   (SELECT     k.*      FROM    EMP002  k      JOIN     (select    *     FROM    EMP001)   y    ON    1=1       )  v   )  e  ORDER  BY    e.empno,e.ename,e.job,e.mgr,e.hiredate,e.sal,e.comm,e.deptno,e.comid;





--echo   minus-3-1-1-3    聚合函数
SELECT    sum(empno)     FROM    EMP001     minus    select    sum(empno)        FROM    EMP002;
SELECT    avg(empno)     FROM    EMP001     minus    select    avg(empno)        FROM    EMP002;
SELECT    max(empno)     FROM    EMP001     minus    select    max(empno)        FROM    EMP002;
SELECT    min(empno)     FROM    EMP001     minus    select    sum(empno)        FROM    EMP002;


SELECT     sum(empno)   rrr       FROM    EMP001     UNION      select    sum(empno)        FROM    EMP002   ORDER BY   rrr;
SELECT    avg(empno)  rrr    FROM    EMP001      UNION  all    select    avg(empno)        FROM    EMP002   ORDER BY   rrr;
SELECT    max(empno)  rrr    FROM    EMP001     INTERSECT    select    max(empno)        FROM    EMP002     ORDER BY   rrr;
SELECT    min(e.empno)    rrr     FROM    EMP001    e   JOIN   EMP002   r    ON   1=2;
 
 



--echo   minus-3-1-1-4    create as        

DROP VIEW    IF exists    EMP001_create;

DROP TABLE   IF exists    EMP001_create;
create TABLE    EMP001_create   as  SELECT    sum(empno)   eee   FROM    EMP001     minus    select    sum(empno)        FROM    EMP002;
SELECT  *  FROM     EMP001_create   ORDER BY   eee;

DROP TABLE   IF exists    EMP001_create;
create TABLE    EMP001_create   as  SELECT    sum(empno)   eee   FROM    EMP001     union    select    sum(empno)        FROM    EMP002;
SELECT  *  FROM     EMP001_create   ORDER BY   eee;

DROP TABLE   IF exists    EMP001_create;
create TABLE    EMP001_create   as  SELECT    sum(empno)   eee   FROM    EMP001     union  all    select    sum(empno)        FROM    EMP002;
SELECT  *  FROM     EMP001_create   ORDER BY   eee;

DROP TABLE   IF exists    EMP001_create;
create TABLE    EMP001_create   as  SELECT    sum(empno)   eee   FROM    EMP001     INTERSECT    select    sum(empno)        FROM    EMP002;
SELECT  *  FROM     EMP001_create   ORDER BY   eee;






 
--echo   minus-3-1-2   where  语句    
SELECT   *  FROM   (SELECT     *      FROM    EMP001   WHERE   empno  < 2         minus    select    *     FROM    EMP002  e   WHERE   e.EMPNO<3)  ORDER   BY   EMPNO;
SELECT   *  FROM   (SELECT     *      FROM    EMP001   WHERE   empno  < 2         union    select    *     FROM    EMP002  e   WHERE   e.EMPNO<3)  ORDER   BY   EMPNO;
SELECT   *  FROM   (SELECT     *      FROM    EMP001   WHERE   empno  < 2         UNION  all    select    *     FROM    EMP002  e   WHERE   e.EMPNO<3)  ORDER   BY   EMPNO;
SELECT   *  FROM   (SELECT     *      FROM    EMP001   WHERE   empno  < 2         INTERSECT    select    *     FROM    EMP002  e   WHERE   e.EMPNO<3)  ORDER   BY   EMPNO;



--echo   minus-3-1-3     order by 子句
SELECT   *  FROM   (SELECT     *      FROM    EMP001   WHERE   empno  < 2         minus    select    *     FROM    EMP002  e   WHERE   e.EMPNO<3)    ORDER   BY   EMPNO;
SELECT   *  FROM   (SELECT     *      FROM    EMP001   WHERE   empno  < 2         UNION    select    *     FROM    EMP002  e   WHERE   EMPNO>3)  e     ORDER  BY    empno,ename,job,mgr,hiredate,sal,comm,deptno,comid;
SELECT   *  FROM   (SELECT     *      FROM    EMP001   WHERE   empno  < 2         UNION all    select    *     FROM    EMP002  e   WHERE   e.EMPNO>3)  e     ORDER  BY    empno,ename,job,mgr,hiredate,sal,comm,deptno,comid;
SELECT   *  FROM   (SELECT     *      FROM    EMP001   WHERE   empno  < 2         INTERSECT    select    *     FROM    EMP002  e   WHERE   e.EMPNO<3) e       ORDER  BY    empno,ename,job,mgr,hiredate,sal,comm,deptno,comid;





--echo   minus-3-1-4     group by   子句
SELECT        *      FROM   (SELECT    empno      FROM    EMP001     GROUP  BY    empno            minus    SELECT    empno      FROM    EMP002     GROUP  BY    empno)  e  ORDER  BY    empno;
SELECT        *      FROM   (SELECT    empno      FROM    EMP001     GROUP  BY    empno            UNION    SELECT    empno      FROM    EMP002     GROUP  BY    empno) e  ORDER  BY    empno;
SELECT        *      FROM   (SELECT    empno      FROM    EMP001     GROUP  BY    empno            UNION all    SELECT    empno      FROM    EMP002     GROUP  BY    empno) e  ORDER  BY    empno;
SELECT        *      FROM   (SELECT    empno      FROM    EMP001     GROUP  BY    empno            INTERSECT    SELECT    empno      FROM    EMP002     GROUP  BY    empno) e  ORDER  BY    empno;
 



--echo   minus-3-1-5     group by  having   子句
SELECT        *      FROM         (SELECT    empno      FROM    EMP001     GROUP  BY    empno,sal   having    sal>100       minus    SELECT    empno      FROM    EMP002     GROUP  BY    empno  having    empno>1000) e   ORDER   BY   EMPNO;
