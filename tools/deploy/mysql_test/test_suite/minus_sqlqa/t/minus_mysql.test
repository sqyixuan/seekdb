drop   table  if  exists   EMP001_create;
create TABLE    EMP001_create   as  SELECT    sum(empno)  eee     FROM    EMP001_VIEW     minus    select    sum(empno)        FROM    EMP002_VIEW;
SELECT  *  FROM     EMP001_create e ORDER  BY eee;
 

drop   table  if  exists   EMP001_create;
