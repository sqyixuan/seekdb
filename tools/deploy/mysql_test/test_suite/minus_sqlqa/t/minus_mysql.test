--echo    minus-3-5      CASE WHEN语句
SELECT   sum(empno)  eee,  COUNT (CASE WHEN  (SELECT    10    FROM    dual      minus    select   50   FROM    dual)>50  THEN 1 
ELSE       NULL      END) rrr     FROM    EMP001 e    GROUP  BY e.empno,e.sal   ORDER BY  eee,rrr;

SELECT   sum(empno)  eee,  COUNT (CASE WHEN  (SELECT    10    FROM    dual      INTERSECT    select   50   FROM    dual)>50  THEN 1 
ELSE       NULL      END) rrr     FROM    EMP001 e    GROUP  BY e.empno,e.sal   ORDER BY  eee,rrr;


drop   table  if  exists   emp001;
drop   table  if  exists   emp002;
create table  emp001   as select * from   emp;
create table  emp002   as select * from   emp;

DROP TABLE  IF exists    EMP001_VIEW;                
CREATE OR  REPLACE  VIEW EMP001_VIEW AS   SELECT  *    FROM   EMP001;

DROP TABLE  IF exists    EMP002_VIEW;                
CREATE OR  REPLACE  VIEW EMP002_VIEW AS   SELECT  *    FROM   EMP002;


--echo     minus-4-1-1-1-1    select     select 普通查询           
SELECT   *  FROM   (SELECT     *      FROM    EMP001_VIEW      minus    select    *     FROM    EMP002_VIEW)  e   ORDER  BY  e.EMPNO,e.HIREDATE,e.sal;
SELECT   *  FROM   (SELECT     *      FROM    EMP001_VIEW      UNION    select    *     FROM    EMP002_VIEW)  e   ORDER  BY  e.EMPNO,e.HIREDATE,e.sal;
SELECT   *  FROM   (SELECT     *      FROM    EMP001_VIEW      UNION   all    select    *     FROM    EMP002_VIEW)  e   ORDER  BY  e.EMPNO,e.HIREDATE,e.sal;
SELECT   *  FROM   (SELECT     *      FROM    EMP001_VIEW      INTERSECT    select    *     FROM    EMP002_VIEW)  e   ORDER  BY  e.EMPNO,e.HIREDATE,e.sal;
 



--echo     minus-4-1-1-1-2    select嵌套 
SELECT   *  FROM   (SELECT   *  FROM   (SELECT     *      FROM    EMP001_VIEW      minus    select    *     FROM    EMP002_VIEW)      MINUS  SELECT   *  FROM   (SELECT     *      FROM    EMP002_VIEW      minus    select    *     FROM    EMP001_VIEW))  e  ORDER  BY  e.EMPNO,e.HIREDATE,e.sal;
 
SELECT   *  FROM   (SELECT   *  FROM   (SELECT     *      FROM    EMP001_VIEW      minus    select    *     FROM    EMP002_VIEW)      MINUS  SELECT   *  FROM   (SELECT     *      FROM    EMP002_VIEW      UNION    select    *     FROM    EMP001_VIEW))  e  ORDER  BY  e.EMPNO,e.HIREDATE,e.sal;
 
