--disable_warnings
drop database  IF EXISTS  ob100x;
create database ob100x  character set utf16;
use ob100x;
select database();

--echo    没有参数          minus-1-1      
select  100  minus  select  300;
select  300   from   dual  UNION  select  300    from   dual;
select  300  from   dual     UNION  all   select   300   from   dual;
select  300  INTERSECT  select  300;


--echo    参数为空           minus-1-2      
select  ''     minus  select   ''    from dual;
select  ''     UNION  select   ''    from dual;
select  ''      UNION ALL   select   ''    from dual;
select  ''      INTERSECT   select   ''    from dual;
 



--echo     参数为空格       minus-1-3        
select  '     '      minus  select   '     '    from dual;
select  '     '      UNION  select   '     '    from dual;
select  '     '       UNION ALL   select   '     '    from dual;
select  '     '       INTERSECT   select   '     '    from dual;





--echo     参数为null       minus-1-4        
select  null      minus  select   null    from dual;
select  null      UNION  select   null    from dual;
select  null       UNION ALL   select   null    from dual;
select  null       INTERSECT   select   null    from dual;







--echo     参数为普通字符    minus-1-5     
select  'helloworld'     minus  select    'hello';
select   *    from    (select  'helloworld'     eee    UNION  select    'hello')   order   by   eee;
select   *    from    (select  'hello'   eee   UNION   ALL   select    'hello')  order   by   eee;
select   *    from    (select  'hello'   eee     UNION    ALL    select    'helloworld')  order   by   eee;


select  'hello'             FROM    dual   union   select    'hello';
select  'hello'             FROM    dual   INTERSECT   select    'hello';
select  'helloworld'    FROM     dual    INTERSECT   select    'hello';
select  'hello'            FROM     dual    INTERSECT   select    'helloworld';






--echo     参数为普通数字      minus-1-6     
select       1     minus  select   1    from dual;
select       1     UNION  select   1    from dual;
select       1     UNION   ALL    select   1    from dual;
select       1     INTERSECT   select   1    from dual;



--echo     参数为普通日期      minus-1-7     
SELECT   str_to_date('2006-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss')    FROM   dual      MINUS       SELECT   str_to_date('2004-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss')    FROM   dual;
SELECT   str_to_date('2004-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss')    FROM   dual      UNION       SELECT   str_to_date('2004-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss')    FROM   dual;
SELECT   str_to_date('2004-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss')    FROM   dual      UNION   all     SELECT   str_to_date('2004-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss')    FROM   dual;
SELECT   str_to_date('2004-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss')    FROM   dual      INTERSECT     SELECT   str_to_date('2004-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss')    FROM   dual;
 




--echo     多个参数           minus-1-8     
select   *  from    (select       100    aaa,'hello'  bbb           minus  select    100,'hello'      from dual)    order   by   aaa,bbb;
select   *  from    (select       1000  aaa,'hello'   bbb       minus  select   100,'hello'      from dual)        order   by   aaa,bbb;
select   *  from    (select       100  aaa,'hello1'   bbb       minus  select   100,'hello'      from dual)        order   by   aaa,bbb;

select   *  from    (select       100    aaa,'hello'  bbb           UNION  select    100,'hello'      from dual)    order   by   aaa,bbb;
select   *  from    (select       1000  aaa,'hello'   bbb       UNION  select   100,'hello'      from dual)        order   by   aaa,bbb;
select   *  from    (select       100  aaa,'hello1'   bbb       UNION  select   100,'hello'      from dual)        order   by   aaa,bbb;

select   *  from    (select       100    aaa,'hello'  bbb           union  all  select    100,'hello'      from dual)    order   by   aaa,bbb;
select   *  from    (select       1000  aaa,'hello'   bbb        union  all  select   100,'hello'      from dual)        order   by   aaa,bbb;
select   *  from    (select       100  aaa,'hello1'   bbb        union  all  select   100,'hello'      from dual)        order   by   aaa,bbb;

select   *  from    (select       100    aaa,'hello'  bbb        INTERSECT  select    100,'hello'      from dual)    order   by   aaa,bbb;
select   *  from    (select       1000  aaa,'hello'   bbb       INTERSECT  select   100,'hello'      from dual)        order   by   aaa,bbb;
select   *  from    (select       100  aaa,'hello1'   bbb       INTERSECT  select   100,'hello'      from dual)        order   by   aaa,bbb;




