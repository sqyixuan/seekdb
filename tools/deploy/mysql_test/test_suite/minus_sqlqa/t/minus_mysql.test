SELECT  sum(empno)   eee,sum(sal)   rrr    FROM   (SELECT     *      FROM    EMP001_VIEW      INTERSECT    select    *     FROM    EMP002)  e     GROUP  BY    empno,sal         ORDER  BY  eee,rrr;





--echo  minus-4-1-3            update语句              

