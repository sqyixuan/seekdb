SELECT   count(*)    INTO   result01  FROM    (select   comm      from       EMP     UNION    select   sal      from       EMP);   
SELECT   count(*)    INTO   result01  FROM    (select   comm      from       EMP     union  all    select   sal      from       EMP);   
