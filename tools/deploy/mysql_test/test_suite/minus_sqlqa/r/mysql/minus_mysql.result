--echo  minus-6-1-6    函数的结果作为存储过程的参数传递
drop function if exists fun_test;/
create  function fun_test()
RETURNS int    
begin   
declare 	result01   int  DEFAULT 0; 
declare 	result02   int  DEFAULT 0; 
declare 	result03  int  DEFAULT 0; 
declare 	result04   int  DEFAULT 0; 
SELECT   count(*)    INTO   result01  FROM    (select   comm      from       EMP     MINUS    select   sal      from       EMP);   
SELECT   count(*)    INTO   result02  FROM    (select   comm      from       EMP     UNION    select   sal      from       EMP);   
SELECT   count(*)    INTO   result03  FROM    (select   comm      from       EMP     union  all    select   sal      from       EMP);   
SELECT   count(*)    INTO   result04  FROM    (select   comm      from       EMP     INTERSECT    select   sal      from       EMP);   
return  result01+result02+result03+result04;  
end;
/
select  fun_test()  from  dual;/
fun_test()
100
