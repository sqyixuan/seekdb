minus-3-2-3    插入 使用子查询        
INSERT INTO  EMP002 VALUES((SELECT  sum(empno)  FROM   (SELECT     *      FROM    EMP001      minus    select    *     FROM    EMP002)  e  ),'SMITH002','CLERK',4,'1981-12-12',9000,NULL,30,20);
INSERT INTO  EMP002 VALUES((SELECT  sum(empno)  FROM   (SELECT     *      FROM    EMP001      UNION    select    *     FROM    EMP002)  e  ),'SMITH002','CLERK',4,'1981-12-12',9000,NULL,30,20);
INSERT INTO  EMP002 VALUES((SELECT  sum(empno)  FROM   (SELECT     *      FROM    EMP001      union  all    select    *     FROM    EMP002)  e  ),'SMITH002','CLERK',4,'1981-12-12',9000,NULL,30,20);
INSERT INTO  EMP002 VALUES((SELECT  sum(empno)  FROM   (SELECT     *      FROM    EMP001      INTERSECT    select    *     FROM    EMP002)  e  ),'SMITH002','CLERK',4,'1981-12-12',9000,NULL,30,20);
