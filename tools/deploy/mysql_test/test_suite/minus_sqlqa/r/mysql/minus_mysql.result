min(empno)
1
SELECT     sum(empno)   rrr       FROM    EMP001     UNION      select    sum(empno)        FROM    EMP002   ORDER BY   rrr;
rrr
13315
SELECT    avg(empno)  rrr    FROM    EMP001      UNION  all    select    avg(empno)        FROM    EMP002   ORDER BY   rrr;
rrr
