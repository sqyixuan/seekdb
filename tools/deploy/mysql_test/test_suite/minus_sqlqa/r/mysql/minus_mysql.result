BEGIN	
declare  i INT DEFAULT 1;
while
i < 100 DO
INSERT INTO EMP   VALUES(i,(SELECT   1  FROM   dual  MINUS   SELECT  2  FROM   dual),'ANALYST',7566,'1998-12-14',p1,400,20,'分部5');
SET i = i + 1;
END WHILE;
END;
/
set @num02 =fun_test();/
