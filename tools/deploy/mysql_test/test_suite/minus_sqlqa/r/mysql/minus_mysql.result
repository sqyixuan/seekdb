minus-6-2-2   自定义函数  有参数
drop function if exists fun_test;/
create  function fun_test(saller002 int)
RETURNS int    
begin   
declare 	result01   int  DEFAULT 0; 
declare 	result02   int  DEFAULT 0; 
declare 	result03   int  DEFAULT 0; 
declare 	result04   int  DEFAULT 0; 
SELECT   count(*)    INTO   result01  FROM    (select   comm      from       EMP     MINUS    select   sal      from       EMP) e   where   e.comm>saller002;   
SELECT   count(*)    INTO   result02  FROM    (select   comm      from       EMP     UNION    select   sal      from       EMP) e   where   e.comm>saller002;   
SELECT   count(*)    INTO   result03  FROM    (select   comm      from       EMP     union  all    select   sal      from       EMP) e   where   e.comm>saller002;   
SELECT   count(*)    INTO   result04  FROM    (select   comm      from       EMP     INTERSECT    select   sal      from       EMP) e   where   e.comm>saller002;   
return  result01+result02+result03+result04;  
end;
/
select  fun_test(100)  from  dual;/
fun_test(100)
183
minus-6-3-1     游标   cursor............. is      
drop procedure if exists pl_test;/
CREATE PROCEDURE pl_test()  
BEGIN  
declare c int;  
declare n varchar(20);  
declare total int default 0;  
declare done int default false;  
declare cur cursor for select  ename, comm      from       EMP     minus    select  ename, sal      from       EMP;
declare continue HANDLER for not found set done = true;  
set total = 0;  
open cur;  
read_loop:loop  
fetch cur into n,c;  
if done then  
leave read_loop;    
end if;  
set total = total + c;  
end loop;  
close cur;  
select total;  
END;
/
call pl_test();/
total
NULL
