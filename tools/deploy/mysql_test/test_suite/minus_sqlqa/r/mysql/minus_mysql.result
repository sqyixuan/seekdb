alter system set _rowsets_max_rows = 2;
alter system flush plan cache;
drop table if exists t1, t2, t3;
create table t1 (c1 int, c2 int, c3 int);
create table t2 (c1 int);
create table t3 (c1 int, c2 int, primary key(c1, c2));
insert into t1 values(1,1,1);
insert into t1 values(2,1,1);
insert into t1 values(2,1,2);
insert into t1 values(2,1,3);
insert into t1 values(2,2,1);
insert into t2 values(2);
insert into t3 values(2,1);
explain select /*+no_rewrite*/c1, c2 from (select c1, c2, c3 from t1 order by 1,2,3) t where not exists(select * from t2 where t.c3 = t2.c1) except select c1, c2 from t3;
Query Plan
=======================================================
|ID|OPERATOR               |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------------
|0 |MERGE EXCEPT DISTINCT  |    |3       |96          |
|1 |├─SUBPLAN FILTER       |    |3       |93          |
|2 |│ ├─SUBPLAN SCAN       |t   |5       |4           |
|3 |│ │ └─SORT             |    |5       |4           |
|4 |│ │   └─TABLE FULL SCAN|t1  |5       |3           |
|5 |│ └─TABLE FULL SCAN    |t2  |1       |18          |
|6 |└─TABLE FULL SCAN      |t3  |1       |3           |
=======================================================
Outputs & filters:
-------------------------------------
  0 - output([EXCEPT([1])], [EXCEPT([2])]), filter(nil), rowset=2
  1 - output([t.c1], [t.c2]), filter([(T_OP_NOT_EXISTS, subquery(1))]), rowset=2
      exec_params_([t.c3(:0)]), onetime_exprs_(nil), init_plan_idxs_(nil), use_batch=false
  2 - output([t.c3], [t.c1], [t.c2]), filter(nil), rowset=2
      access([t.c3], [t.c1], [t.c2])
  3 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=2
      sort_keys([t1.c1, ASC], [t1.c2, ASC], [t1.c3, ASC])
  4 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=2
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  5 - output([t2.c1]), filter([:0 = t2.c1]), rowset=2
      access([t2.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  6 - output([t3.c1], [t3.c2]), filter(nil), rowset=2
      access([t3.c1], [t3.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t3.c1], [t3.c2]), range(MIN,MIN ; MAX,MAX)always true
select /*+no_rewrite*/c1, c2 from (select c1, c2, c3 from t1 order by 1,2,3) t where not exists(select * from t2 where t.c3 = t2.c1) except select c1, c2 from t3;
c1	c2
1	1
2	2
