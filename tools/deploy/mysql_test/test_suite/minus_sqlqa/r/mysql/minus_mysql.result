minus-5-2-1  参与字段没有重复数据
select SUM(id)   FROM   (select id   from t_user where id<10 minus select id from t_user where id between 3 and 7)e;
SUM(id)
20
select SUM(id)   FROM   (select id   from t_user where id<10 UNION select id from t_user where id between 3 and 7)e;
SUM(id)
45
select SUM(id)   FROM   (select id   from t_user where id<10 UNION  ALL select id from t_user where id between 3 and 7)e;
SUM(id)
120
select SUM(id)   FROM   (select id   from t_user where id<10 INTERSECT select id from t_user where id between 3 and 7)e;
SUM(id)
25
minus-5-2-2  参与字段有重复数据
select age,level_no   EEE   from t_user where id<8 minus select age,level_no from t_user where level_no=3  ORDER BY  age,EEE;
age	EEE
25	1
30	2
45	1
select age,level_no+100   EEE  from t_user where id<8 minus select age,level_no from t_user where level_no=3  ORDER BY  age,EEE;
age	EEE
25	101
30	102
35	103
45	101
select age,level_no   EEE   from t_user where id<8 UNION select age,level_no from t_user where level_no=3  ORDER BY  age,EEE;
age	EEE
