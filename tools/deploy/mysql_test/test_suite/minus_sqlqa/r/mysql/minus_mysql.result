minus-3-1-1-4    create as        
DROP VIEW    IF exists    EMP001_create;
DROP TABLE   IF exists    EMP001_create;
create TABLE    EMP001_create   as  SELECT    sum(empno)   eee   FROM    EMP001     minus    select    sum(empno)        FROM    EMP002;
SELECT  *  FROM     EMP001_create   ORDER BY   eee;
eee
DROP TABLE   IF exists    EMP001_create;
create TABLE    EMP001_create   as  SELECT    sum(empno)   eee   FROM    EMP001     union    select    sum(empno)        FROM    EMP002;
SELECT  *  FROM     EMP001_create   ORDER BY   eee;
eee
