drop procedure if exists pl_test;/
CREATE  PROCEDURE pl_test(OUT p1  int,inout p2 int,OUT p3  int)
BEGIN	
SELECT     COUNT(*)  INTO p1    FROM (SELECT     empno   FROM   EMP  MINUS  SELECT     empno    FROM   EMP);
SELECT     COUNT(*)  INTO p2    FROM (SELECT     empno   FROM   EMP  UNION  SELECT     empno    FROM   EMP);
SELECT     COUNT(*)  INTO p3    FROM (SELECT     empno   FROM   EMP  UNION  all  SELECT     empno    FROM   EMP);
SELECT     COUNT(*)  INTO p3    FROM (SELECT     empno   FROM   EMP  INTERSECT  SELECT     empno    FROM   EMP);
INSERT INTO emp   VALUES(1,(SELECT   1  FROM   dual  MINUS   SELECT  2  FROM   dual),'ANALYST',7566,'1998-12-12',p1+p2+p3,400,20,'分部5');
END;
