--echo    #并行insert======>parallel,no_GATHER_OPTIMIZER_STATISTICS,GATHER_OPTIMIZER_STATISTICS
--error 0,1051
DROP TABLE test1;
--error 0,1051
DROP TABLE test2;
CREATE TABLE test2(c1 number,c2 varchar(20),c3 date);
INSERT INTO test2 values(22222,'张三','2023-01-01');
INSERT INTO test2 values(45678,'李四','2024-01-01');
INSERT INTO test2 values(12345,'赵六','2025-01-01');
SELECT * FROM test2 ORDER BY c1 asc;
CREATE TABLE test1 AS SELECT /*+ parallel(10),NO_GATHER_OPTIMIZER_STATISTICS,GATHER_OPTIMIZER_STATISTICS */ * FROM test2;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(NULL,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
EXPLAIN basic INSERT /*+ parallel(10),NO_GATHER_OPTIMIZER_STATISTICS,GATHER_OPTIMIZER_STATISTICS */ INTO test1 SELECT * FROM test2;
INSERT /*+ parallel(10),NO_GATHER_OPTIMIZER_STATISTICS,GATHER_OPTIMIZER_STATISTICS */ INTO test1 SELECT * FROM test2;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(NULL,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
EXPLAIN basic INSERT /*+ parallel(10),NO_GATHER_OPTIMIZER_STATISTICS,GATHER_OPTIMIZER_STATISTICS */ INTO test1 VALUES(5462,'翠翠翠翠','2025-01-01');
INSERT /*+ parallel(10),NO_GATHER_OPTIMIZER_STATISTICS,GATHER_OPTIMIZER_STATISTICS */ INTO test1 VALUES(5462,'翠翠翠翠','2025-01-01');
