--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);


--disable_result_log


--echo  #Online-3  insert into select
set _optimizer_gather_stats_on_load =true;
--error 0,1051
drop view table_view;
--error 0,1051
drop view table_col_view;
--error 0,1051
drop view partition_view;
--error 0,1051
drop view subpartition_view;

create view table_view as select TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, NUM_ROWS, AVG_ROW_LEN, OBJECT_TYPE from oceanbase.dba_tab_statistics;
create view table_col_view as select TABLE_NAME, COLUMN_NAME,NUM_DISTINCT, NUM_NULLS,LOW_VALUE,AVG_COL_LEN from oceanbase.dba_tab_col_statistics;
create view partition_view as select TABLE_NAME, COLUMN_NAME, NUM_DISTINCT,LOW_VALUE,HIGH_VALUE,NUM_NULLS,AVG_COL_LEN from oceanbase.dba_part_col_statistics;
create view subpartition_view as select TABLE_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,NUM_NULLS, AVG_COL_LEN from oceanbase.dba_subpart_col_statistics;




--echo    #Online-3-3  数据类型
--echo    #数据类型======>字符串类型
--error 0,1051
DROP TABLE test1;
--error 0,1051
DROP TABLE test2;
CREATE TABLE test2(c1 char(3),c2 varchar(15),c3 text);
INSERT INTO test2 values('aaa','李','王aaa');
SELECT * FROM test2 ;
CREATE TABLE test1(c1 char(3));
EXPLAIN basic INSERT /*+ GATHER_OPTIMIZER_STATISTICS */INTO test1 SELECT c1 FROM test2;
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */INTO test1 SELECT c1 FROM test2;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(null,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
ALTER TABLE test1 ADD c2 varchar(5);
EXPLAIN basic INSERT /*+ GATHER_OPTIMIZER_STATISTICS */INTO test1 SELECT c1,c2 FROM test2;
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */INTO test1 SELECT c1,c2 FROM test2;
SELECT * FROM test1 ORDER BY c2 DESC;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(null,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
ALTER TABLE test1 ADD c3 text;
EXPLAIN basic INSERT /*+ GATHER_OPTIMIZER_STATISTICS */INTO test1 SELECT c1,c2,c3 FROM test2;
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */INTO test1 SELECT c1,c2,c3 FROM test2;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(null,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
DROP TABLE test2;
DROP TABLE test1;





