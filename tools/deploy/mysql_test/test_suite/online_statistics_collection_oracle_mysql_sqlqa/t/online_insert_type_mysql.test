--echo    #指定列插入======>结合转换函数将值插入
--error 0,1051
DROP TABLE test1;
--error 0,1051
DROP TABLE test2;
CREATE TABLE test2(c1 number,c2 float,c3 INTEGER,c4 varchar(20),c5 date);
INSERT INTO test2 values(1,55,32.2,'孔杰','2023-01-01');
INSERT INTO test2 values(2,66,33.5,'赵刚','2023-01-01');
INSERT INTO test2 values(3,77,36.25,'李云龙','2023-01-01');
INSERT INTO test2 values(4,88,33,'楚云飞','2023-01-01');
INSERT INTO test2 values(5,99,0.3,'丁伟','2023-01-01');
SELECT * FROM test2 ORDER BY c1 ASC;
CREATE TABLE test1 AS SELECT /*+ GATHER_OPTIMIZER_STATISTICS */ c1,c2,c3 FROM test2 WHERE c1=9;
EXPLAIN basic INSERT /*+ GATHER_OPTIMIZER_STATISTICS */INTO test1(c3) SELECT CAST(c1 AS number) FROM test2;
--error 0,600
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */INTO test1(c3) SELECT CAST(c1 AS number) FROM test2;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(null,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
--error 0,1064
EXPLAIN basic INSERT /*+ GATHER_OPTIMIZER_STATISTICS */INTO test1(c4) SELECT CAST(c1 AS varchar(20)) FROM test2;
--error 0,1064
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */INTO test1(c4) SELECT CAST(c1 AS varchar(20)) FROM test2;
drop view table_view;
drop view table_col_view;
drop view partition_view;
drop view subpartition_view;

DROP TABLE test1;
DROP TABLE test2;
--enable_result_log




