partition p5 VALUES less than(66666),
partition p6 VALUES less than(77777),
partition p7 VALUES less than(88888),
partition p8 VALUES less than(88899),
partition p9 VALUES less than(99000),
partition p10 VALUES less than(99966),
partition p11 VALUES less than(maxvalue));
