#Environmental cleaning
drop user hjw@'%';
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
set _optimizer_gather_stats_on_load =true;
drop view table_view;
drop view table_col_view;
drop view partition_view;
drop view subpartition_view;
create view table_view as select TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, NUM_ROWS, AVG_ROW_LEN, OBJECT_TYPE from oceanbase.dba_tab_statistics;
create view table_col_view as select TABLE_NAME, COLUMN_NAME,NUM_DISTINCT, NUM_NULLS,LOW_VALUE,AVG_COL_LEN from oceanbase.dba_tab_col_statistics;
create view partition_view as select TABLE_NAME, COLUMN_NAME, NUM_DISTINCT,LOW_VALUE,HIGH_VALUE,NUM_NULLS,AVG_COL_LEN from oceanbase.dba_part_col_statistics;
create view subpartition_view as select TABLE_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,NUM_NULLS, AVG_COL_LEN from oceanbase.dba_subpart_col_statistics;
#Online-1  系统变量
#Online-2  表类型
#Online-1  系统变量
#Online-2  表类型
#Online-2-1  创建普通表
#不带hint
drop table test1;
drop table test2;
CREATE TABLE test1(c1 bigint,c2 varchar(30),c3 date);
INSERT INTO test1 values(22222,'aaaaaaaa','2023-01-01');
INSERT INTO test1 values(33333,'bbbbbbbb','2024-01-01');
INSERT INTO test1 values(44444,'cccccccc','2025-01-01');
INSERT INTO test1 values(null,null,null);
SELECT * FROM test1 ORDER BY c1 asc;
CREATE TABLE test2 AS SELECT * FROM test1;
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
CALL dbms_stats.gather_table_stats(NULL,'TEST2');
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
delete from test2 where c1 is null;
delete from test1 where c1 is null;
SELECT * FROM test2 ORDER BY c1 asc;
SELECT * FROM test1 ORDER BY c1 asc;
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
CALL dbms_stats.gather_table_stats(NULL,'TEST2');
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
DROP TABLE test1;
DROP TABLE test2;
CREATE TABLE test1(c1 bigint,c2 varchar(30),c3 date);
INSERT INTO test1 values(22222,'aaaaaaaa','2023-01-01');
INSERT INTO test1 values(33333,'bbbbbbbb','2024-01-01');
INSERT INTO test1 values(44444,'cccccccc','2025-01-01');
CREATE TABLE test2 AS SELECT * FROM test1;
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
CALL dbms_stats.gather_table_stats(NULL,'TEST2');
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
DROP TABLE test1;
DROP TABLE test2;
#append
CREATE TABLE test1(c1 bigint,c2 varchar(30),c3 date);
INSERT INTO test1 values(22222,'zhangsan','2023-01-01');
INSERT INTO test1 values(33333,'张三','2024-01-01');
INSERT INTO test1 values(44444,'赵六','2025-01-01');
CREATE TABLE test2 AS SELECT /*+ append */* FROM test1;
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
CALL dbms_stats.gather_table_stats(NULL,'TEST2');
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
DROP TABLE test1;
DROP TABLE test2;
#GATHER_OPTIMIZER_STATISTICS
CREATE TABLE test1(c1 bigint,c2 varchar(30),c3 date);
INSERT INTO test1 values(22222,'张三','2023-01-01');
INSERT INTO test1 values(22223,'张三','2023-01-01');
INSERT INTO test1 values(22224,'张三','2023-01-01');
CREATE TABLE test2 AS SELECT /*+ GATHER_OPTIMIZER_STATISTICS */* FROM test1;
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
CALL dbms_stats.gather_table_stats(NULL,'TEST2');
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */INTO test2 SELECT * FROM test1 WHERE c1=22223;
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
CALL dbms_stats.gather_table_stats(NULL,'TEST2');
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
DROP TABLE test1;
DROP TABLE test2;
#NO_GATHER_OPTIMIZER_STATISTICS
CREATE TABLE test1(c1 bigint,c2 varchar(30),c3 date);
INSERT INTO test1 values(22222,'张三','2023-01-01');
INSERT INTO test1 values(22223,'张三','2023-01-01');
INSERT INTO test1 values(22224,'张三','2023-01-01');
CREATE TABLE test2 AS SELECT /* +NO_GATHER_OPTIMIZER_STATISTICS */* FROM test1;
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
CALL dbms_stats.gather_table_stats(NULL,'TEST2');
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
INSERT /*+ NO_GATHER_OPTIMIZER_STATISTICS */INTO test2 SELECT * FROM test1 WHERE c1=22223;
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
CALL dbms_stats.gather_table_stats(NULL,'TEST2');
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
CALL dbms_stats.gather_table_stats(NULL,'TEST2');
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
DROP TABLE test1;
DROP TABLE test2;
#三种hint混合
CREATE TABLE test1(c1 bigint,c2 varchar(30),c3 date);
INSERT INTO test1 values(22222,'张三','2023-01-01');
INSERT INTO test1 values(22223,'张三','2023-01-01');
INSERT INTO test1 values(22224,'张三','2023-01-01');
CREATE TABLE test2 AS SELECT /*+ append,GATHER_OPTIMIZER_STATISTICS */* FROM test1;
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
CALL dbms_stats.gather_table_stats(NULL,'TEST2');
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
DROP TABLE test2;
CREATE TABLE test2 AS SELECT /*+ append,NO_GATHER_OPTIMIZER_STATISTICS */* FROM test1;
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
CALL dbms_stats.gather_table_stats(NULL,'TEST2');
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
DROP TABLE test2;
CREATE TABLE test2 AS SELECT /*+ GATHER_OPTIMIZER_STATISTICS,NO_GATHER_OPTIMIZER_STATISTICS */* FROM test1;
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
CALL dbms_stats.gather_table_stats(NULL,'TEST2');
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
CALL dbms_stats.gather_table_stats(NULL,'TEST2');
SELECT * FROM table_view WHERE table_name='TEST2';
SELECT * FROM table_col_view WHERE table_name='TEST2';
DROP TABLE test2;
#Online-2-2  创建临时表     临时表暂不测试
#Online-2-2-2  事务级临时表
#不带hint
drop view table_view;
drop view table_col_view;
drop view partition_view;
drop view subpartition_view;
# Clean up users
drop user hjw@'%' ;
