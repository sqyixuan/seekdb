SELECT * FROM table_col_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(NULL,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
EXPLAIN basic INSERT /*+ append */ INTO test1 SELECT 1-1,'🏀',c3 FROM test2;
set session ob_query_timeout=10000000;
INSERT /*+ append */ INTO test1 SELECT 1-1,'🏀',c3 FROM test2;
set session ob_query_timeout=10000000;
INSERT /*+ append */ INTO test1 SELECT 1-1,'🏀',c3 FROM test2;
set session ob_query_timeout=10000000;
INSERT /*+ append */ INTO test1 SELECT 1-1,'🏀',c3 FROM test2;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(NULL,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
EXPLAIN basic INSERT /*+ append */ INTO test1 VALUES(5200,'abc','2099-01-01');
set session ob_query_timeout=10000000;
INSERT /*+ append */ INTO test1 VALUES(5200,'abc','2099-01-01');
set session ob_query_timeout=10000000;
