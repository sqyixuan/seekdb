#Environmental cleaning
drop user hjw@'%';
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
#Online-7  分区表
drop view table_view;
drop view table_col_view;
drop view partition_view;
drop view subpartition_view;
create view table_view as select TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, NUM_ROWS, AVG_ROW_LEN, OBJECT_TYPE from oceanbase.dba_tab_statistics;
create view table_col_view as select TABLE_NAME, COLUMN_NAME,NUM_DISTINCT, NUM_NULLS,LOW_VALUE,AVG_COL_LEN from oceanbase.dba_tab_col_statistics;
create view partition_view as select TABLE_NAME, COLUMN_NAME, NUM_DISTINCT,LOW_VALUE,HIGH_VALUE,NUM_NULLS,AVG_COL_LEN from oceanbase.dba_part_col_statistics;
create view subpartition_view as select TABLE_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,NUM_NULLS, AVG_COL_LEN from oceanbase.dba_subpart_col_statistics;
#Online-7-1  hash分区======>非空表
DROP TABLE test2;
DROP TABLE test1;
CREATE TABLE test2(c1 bigint,c2 varchar(20),c3 date);
INSERT INTO test2 values(22222,'张三','2023-01-01');
INSERT INTO test2 values(45678,'李四','2024-01-01');
INSERT INTO test2 values(12345,'赵六','2025-01-01');
INSERT INTO test2 values(11111,'张三','2023-01-01');
INSERT INTO test2 values(33333,'李四','2024-01-01');
INSERT INTO test2 values(44444,'赵六','2025-01-01');
INSERT INTO test2 values(55555,'张三','2023-01-01');
INSERT INTO test2 values(66666,'李四','2024-01-01');
INSERT INTO test2 values(77777,'赵六','2025-01-01');
INSERT INTO test2 values(88888,'张三','2023-01-01');
INSERT INTO test2 values(99999,'李四','2024-01-01');
SELECT * FROM test2 ORDER BY c1 ASC;
CREATE TABLE test1 (c1 bigint,c2 varchar(20),c3 date) PARTITION BY hash(c1) partitions 3;
INSERT INTO test1 values(66666,'小七','2028-01-01');
EXPLAIN basic INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1 SELECT c1+200,c2,c3+2 FROM test2;
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1 SELECT c1+200,c2,c3+2 FROM test2;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM partition_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(NULL,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM partition_view WHERE table_name='TEST1';
EXPLAIN basic INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1(c1) SELECT c1-6 FROM test2;
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1(c1) SELECT c1-6 FROM test2;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM partition_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(NULL,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM partition_view WHERE table_name='TEST1';
EXPLAIN basic INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1(c2) SELECT c2 FROM test2;
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1(c2) SELECT c2 FROM test2;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM partition_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(NULL,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM partition_view WHERE table_name='TEST1';
EXPLAIN basic INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1(c3) SELECT c3 FROM test2;
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1(c3) SELECT c3 FROM test2;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM partition_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(NULL,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM partition_view WHERE table_name='TEST1';
EXPLAIN basic INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1 VALUES(20000,'李四','2024-01-01');
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1 VALUES(20000,'李四','2024-01-01');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(NULL,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
EXPLAIN basic INSERT /*+ GATHER_OPTIMIZER_STATISTICS,NO_GATHER_OPTIMIZER_STATISTICS */ INTO test1 SELECT * FROM test2;
INSERT /*+ GATHER_OPTIMIZER_STATISTICS,NO_GATHER_OPTIMIZER_STATISTICS */ INTO test1 SELECT * FROM test2;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM partition_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(NULL,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM partition_view WHERE table_name='TEST1';
EXPLAIN basic INSERT /*+ append,GATHER_OPTIMIZER_STATISTICS */ INTO test1 SELECT c1+100,c2,c3 FROM test2;
INSERT /*+ append,GATHER_OPTIMIZER_STATISTICS */ INTO test1 SELECT c1+100,c2,c3 FROM test2;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM partition_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(NULL,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM partition_view WHERE table_name='TEST1';
EXPLAIN basic INSERT /*+ append,GATHER_OPTIMIZER_STATISTICS */ INTO test1 partition(p0) SELECT c1+100,c2,c3 FROM test2;
INSERT /*+ append,GATHER_OPTIMIZER_STATISTICS */ INTO test1 partition(p0) SELECT c1+100,c2,c3 FROM test2;
INSERT /*+ append,GATHER_OPTIMIZER_STATISTICS */ INTO test1 partition(p1) SELECT c1+100,c2,c3 FROM test2;
INSERT /*+ append,GATHER_OPTIMIZER_STATISTICS */ INTO test1 partition(p2) SELECT c1+100,c2,c3 FROM test2;
DROP TABLE test1;
CREATE TABLE test1 (c1 bigint,c2 varchar(20),c3 date) PARTITION BY hash(c1) partitions 500;
EXPLAIN basic INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1 SELECT * FROM test2;
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1 SELECT * FROM test2;
SELECT * FROM test1 ORDER BY c1 ASC;
INSERT /*+ append,GATHER_OPTIMIZER_STATISTICS */ INTO test1 partition(50) SELECT c1+50.6,c2,c3 FROM test2;
INSERT /*+ append,GATHER_OPTIMIZER_STATISTICS */ INTO test1 partition(50) SELECT * FROM test2;
INSERT /*+ append,GATHER_OPTIMIZER_STATISTICS */ INTO test1 partition(1) SELECT * FROM test2;
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1 partition(p200) values(11111,'张三','2023-01-01');
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1 partition(p300) values(33333,'李四','2024-01-01');
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1 partition(p100) values(44444,'赵六','2025-01-01');
DROP TABLE test2;
DROP TABLE test1;
