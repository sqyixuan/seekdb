CREATE TABLE test1 (c1 bigint(30),c2 varchar(20),c3 date) PARTITION BY range(c1)(
partition p1 VALUES less than(44444),
partition p2 VALUES less than(55555),
partition p3 VALUES less than(66666),
partition p4 VALUES less than(77777),
partition p5 VALUES less than(88888),
partition p6 VALUES less than(99999),
partition p7 VALUES less than(100000),
partition p8 VALUES less than(111111),
partition p9 VALUES less than(222222),
partition p10 VALUES less than(333333),
partition p11 VALUES less than(444444),
partition p12 VALUES less than(555555),
partition p13 VALUES less than(666666),
partition p14 VALUES less than(777777),
partition p15 VALUES less than(888888),
partition p16 VALUES less than(999999),
partition p17 VALUES less than(1000000),
partition p18 VALUES less than(2222222),
partition p19 VALUES less than(3333333),
partition p20 VALUES less than(maxvalue));
INSERT INTO test1 values(66666,'小七','2028-01-01');
