#Environmental cleaning
drop user hjw@'%';
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
#Online-4  生成列,伪列
set _optimizer_gather_stats_on_load =true;
drop view table_view;
drop view table_col_view;
drop view partition_view;
drop view subpartition_view;
create view table_view as select TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, NUM_ROWS, AVG_ROW_LEN, OBJECT_TYPE from oceanbase.dba_tab_statistics;
create view table_col_view as select TABLE_NAME, COLUMN_NAME,NUM_DISTINCT, NUM_NULLS,LOW_VALUE,AVG_COL_LEN from oceanbase.dba_tab_col_statistics;
create view partition_view as select TABLE_NAME, COLUMN_NAME, NUM_DISTINCT,LOW_VALUE,HIGH_VALUE,NUM_NULLS,AVG_COL_LEN from oceanbase.dba_part_col_statistics;
create view subpartition_view as select TABLE_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,NUM_NULLS, AVG_COL_LEN from oceanbase.dba_subpart_col_statistics;
#Online-4-1  生成列,伪列======>生成列
#生成列======>数值
DROP TABLE test1;
DROP TABLE test2;
create table test2(c1 number,c2 float);
INSERT INTO test2 values(1,2);
INSERT INTO test2 values(6,6);
INSERT INTO test2 values(9,9);
SELECT * FROM test2 ORDER BY c1 ASC;
CREATE TABLE test1(c1 number,c2 NUMBER,c3 NUMBER generated always as(abs(c2*c1)));
EXPLAIN INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1(c1,c2) SELECT * FROM test2 ORDER BY c1 ASC;
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1(c1,c2) SELECT * FROM test2 ORDER BY c1 ASC;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(null,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM test1 ORDER BY c1 ASC;
DROP TABLE test1;
DROP TABLE test2;
#生成列======>字符串
DROP TABLE test1;
DROP TABLE test2;
create table test2(c1 char(20),c2 varchar(20));
INSERT INTO test2 values('1','a');
INSERT INTO test2 values('6','d');
INSERT INTO test2 values('9','c');
SELECT * FROM test2 ORDER BY c1 ASC;
CREATE TABLE test1(c1 char(20),c2 varchar(20),c3 NUMBER generated always as(abs(0+1)));
EXPLAIN INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1(c1,c2) SELECT * FROM test2 ORDER BY c1 ASC;
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1(c1,c2) SELECT * FROM test2 ORDER BY c1 ASC;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(null,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM test1 ORDER BY c1 ASC;
DROP TABLE test1;
DROP TABLE test2;
#生成列======>时间日期
DROP TABLE test1;
DROP TABLE test2;
create table test2(c1 date,c2 date);
INSERT INTO test2 values('2023-01-01','2026-01-01');
INSERT INTO test2 values('2024-01-01','2027-01-01');
INSERT INTO test2 values('2025-01-01','2027-01-01');
SELECT * FROM test2 ORDER BY c1 ASC;
CREATE TABLE test1(c1 date,c2 date,c3 number generated always as(abs(2*2)));
EXPLAIN INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1(c1,c2) SELECT * FROM test2 ORDER BY c1 ASC;
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1(c1,c2) SELECT * FROM test2 ORDER BY c1 ASC;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(null,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM test1 ORDER BY c1 ASC;
DROP TABLE test1;
DROP TABLE test2;
#Online-4-2  生成列,伪列======>伪列
DROP TABLE test1;
DROP TABLE test2;
create table test2(c1 number,c2 float);
INSERT INTO test2 values(1,2);
INSERT INTO test2 values(6,6);
INSERT INTO test2 values(9,9);
SELECT * FROM test2 ORDER BY c1 ASC;
CREATE TABLE test1(c1 number,c2 NUMBER,c3 NUMBER generated always as(abs(c2+1)));
EXPLAIN basic INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1(c1,c2) SELECT Rowid,rownum FROM test2 ORDER BY c1 ASC;
INSERT /*+ GATHER_OPTIMIZER_STATISTICS */ INTO test1(c1,c2) SELECT Rowid,rownum FROM test2 ORDER BY c1 ASC;
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
CALL dbms_stats.gather_table_stats(null,'TEST1');
SELECT * FROM table_view WHERE table_name='TEST1';
SELECT * FROM table_col_view WHERE table_name='TEST1';
SELECT * FROM test1 ORDER BY c1 ASC;
drop view table_view;
drop view table_col_view;
drop view partition_view;
drop view subpartition_view;
DROP TABLE test1;
DROP TABLE test2;
# Clean up users
drop user hjw@'%' ;
