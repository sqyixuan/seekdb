--echo  触发器

drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop trigger if exists ttr;
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 1;
end/
delimiter ;/
create trigger ttr
after insert on t1
for each row
insert into t2(s1) values(2*new.s1);
insert into t1(s1) values(n_1());

select * from t2;
select * from t1;



drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop trigger if exists ttr;
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 1;
end/

create trigger ttr
before insert on t1
for each row
if new.s1>1 then
signal sqlstate '45000'
set message_text = "输入过大";
end if/
delimiter ;/
--error  1644
insert into t1(s1) values(2*n_1());
select * from t2;
select * from t1;

insert into t1(s1) values(n_1());
select * from t2;
select * from t1;



--echo udf name传到message_text
drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop trigger if exists ttr;
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 1;
end/

create trigger ttr
before insert on t1
for each row
if new.s1>1 then
signal sqlstate '45000'
set message_text = n_1;
end if/
delimiter ;/
