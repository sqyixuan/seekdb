--echo  动态sql
drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
--error 1305
drop procedure agm;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 0;
end/

create procedure `agm`(in udf char(20),in order_param varchar(10),in anchor int,in size int)
begin
	set @s = concat("select " ,udf, "from t1 where ",order_param," limit ",anchor,",",size);
	prepare stmt from @s;
	execute stmt;
	deallocate prepare stmt;
end/
delimiter ;/
call agm('*','s1=n_1()',1,4);

select * from t2;



drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
drop procedure agm;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 0;
end/

create procedure `agm`(in udf char(20),in order_param varchar(10),in anchor int,in size int)
begin
	set @s = "select ? from t1 where s1=? limit ?,?";
	prepare stmt from @s;
	set @aa=udf;
	set @a=order_param;
	set @b=anchor;
	set @c=size;
	execute stmt using @aa,@a,@b,@c;
	deallocate prepare stmt;
end/

delimiter ;/
--error 1235
call agm(n_1(),n_1(),n_1(),3);

select * from t2;




--echo  pl传参
--echo  udf值传入变量
--echo #44502875 ob报错
drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
drop procedure prre;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 1;
end/

create procedure prre(in a int,in b int)
begin
declare aa int;
  set @aa=9;
  set aa=9;
    if a >= b then
      set @aa =  n_1();
      set aa=  n_1();
    else
      set @aa = 0;
    end if;
select aa;
end/
delimiter ;/
--error 1235
call prre(9,n_1());
select * from t2;

--echo  作为procedure out
drop table t1;
create table t1 (te int,tc int);
insert into t1 values(1,8),(2,9);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop procedure if exists p1;
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 1;
end/
create procedure p1(out ia int) 
begin
	select n_1() into ia from t1 where tc = 9 ;
end/
delimiter ;/
call p1(@bb);
select @bb;
select * from t2;

--echo  作为procedure in
