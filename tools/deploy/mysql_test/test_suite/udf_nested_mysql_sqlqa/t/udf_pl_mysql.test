--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by '123';
grant all privileges on *.* to 'nxa'@'%' with grant option;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$obmysql_ms0,nxa,123,test,$obmysql_port);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database if exists nxa;
--enable_warnings
###创建db，切换db测试
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='strict_all_tables,no_zero_date,no_zero_in_date,error_for_division_by_zero ';
--result_format 4

--echo  #udf_3_5 pl
--echo  udf多个定义，不兼容
--echo  多个deterministic
--echo  ob报错 9507 (hy000): at most one declaration for identifier is permitted
--error 1051
drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);
--error 1051
drop table t2;
create table t2(id int ,s1 int, s2 int);
--error 1305
drop function n_1;
delimiter /;
--error 9507
create function n_1() returns int  not  deterministic  deterministic   deterministic        
begin
	insert into t2 values(2,0,1);
  return 1;
end/

delimiter ;/



--echo  多个not deterministic
--echo  ob未报错，但udf还是deterministic
drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
--error 1305
drop function n_1;
delimiter /;
create function n_1() returns int deterministic not deterministic  not deterministic        
begin
	insert into t2 values(2,0,1);
  return 1;
end/

delimiter ;/

select * from t1 where stats=n_1();
select * from t2;


--echo  抛出错误

drop table t2;
create table t2(id int ,s1 int, s2 int);
insert into t2 values(1,1,3),(5,1,0),(3,1,0),(9,1,0),(2,7,0);
drop table t1;
create table t1 (
id int(11) not null auto_increment,
val1 varchar(20) default null,
val2 int(11) default null,
primary key (id)
) ;
drop function n_1;
delimiter /;
create function n_1() returns int  deterministic
begin
declare _var,_err int default 0;
declare continue handler for sqlexception, sqlwarning, not found set _err=1;
insert into t1(val1, val2) value(2012,'输入非int');
if _err=1 then
set _var = 2;
end if;
select case when _var = 2 then '出错了' else _var end into @aa ;

return 1;
end
/
delimiter ;/

select n_1() from t2 ; 
select * from t1;
select @aa ;

--echo  验证有错误是否实现sql
drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1(a int,b int) returns int not deterministic             
begin
    insert into t2 values(1,0,1);
    if a>b then
      signal sqlstate '45000'
    set message_text = "输入过大";
	insert into t2 values(2,0,1);
  end if;
  return 1;
end/

delimiter ;/


select * from t1 where stats=n_1(0,n_1(1,3));
select * from t2;

--echo  游标里放入udf值
drop table t1;
create table t1(id int primary key, s1 int, s2 int);
insert into t1 values(1,1,3),(5,1,0),(3,1,0),(9,1,0),(2,7,0);

drop table t2;
create table t2(id int ,s1 int, s2 int);
--error 1305
drop procedure prre;
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic
begin
  insert into t2 values(1,0,1);
  return 1;
end/

create procedure prre()
begin
 declare cur cursor for select n_1() from t1 order by n_1();
 open cur;
 close cur;
end/
delimiter ;/
call prre();
select * from t2;
--echo  udf流程控制
drop table t1;
create table t1(id int , s1 int primary key, s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,2,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1(a int,b int)
returns int
begin
if a>b then 
insert into t2 values(3,0,1);
else 
insert into t2 values(5,0,1);
end if;
return 9;
return 4;
end/
delimiter ;/
select * from t1 where n_1(id,s1)>2 ;
select * from t2;
delete from t2;
select n_1(id,s1) from t1  ;
select * from t2;
--echo  case when
drop table t1;
create table t1(id int , s1 int primary key, s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,2,0),(9,3,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1(a int,b int) 
returns int
begin
declare week int;
case a
when 0 then set week=1;
when 1 then insert into t2 values(week,0,1);
when 5 then set week=2;
when 2 then insert into t2 values(week+1,0,1);
when 3 then set week=4;
when 4 then set week=5;
else insert into t2 values(week+3,0,1);
end case;
return week;
end/
delimiter ;/
select n_1(id,1) from t1;
select * from t2 ;



--echo  while循环
drop table t1;
create table t1(stats int, s1 int, s2 int);
drop table t2;
create table t2(id int primary key auto_increment,s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop function n_1;
delimiter /;
create function n_1() returns int
begin
declare i int default 0;
while i<5 do
set i=i+1;
  insert into t2 values(null,0,i);
  end while ;
  return 0;
end/

delimiter ;/
drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int primary key auto_increment,s1 int, s2 int);
update t1 set stats=n_1() where stats=1;
select * from t2;

drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int primary key auto_increment,s1 int, s2 int);
insert into t1 values(0,(n_1()),3),(1,0,0);
select * from t2;

drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int primary key auto_increment,s1 int, s2 int);
select n_1()from t1;
select * from t2;





--echo  repeat循环
drop function n_1;
delimiter /;
create function n_1() returns int
begin
declare i int default 0;
 repeat
 insert into t2 values(null,0,1);
   set i = i +1;
until i >= 3
  end repeat;
  return i;
end/
delimiter ;/
drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int primary key auto_increment,s1 int, s2 int);
update t1 set stats=n_1() where stats=1;
select * from t2;

drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int primary key auto_increment,s1 int, s2 int);
insert into t1 values(0,(n_1()),3),(1,0,0);
select * from t2;

drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int primary key auto_increment,s1 int, s2 int);
select n_1()from t1;
select * from t2;


--echo  loop循环
drop function n_1;
delimiter /;
create function n_1() returns int
begin
declare i int default 0;
 loop_label:loop
  insert into t2 values(null,0,1);
   set i = i +1;
if i >= 4 then
   leave loop_label;
  end if;
  end loop;
  return 0;
end/


delimiter ;/
drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int primary key auto_increment,s1 int, s2 int);
update t1 set stats=n_1() where stats=1;
select * from t2;

drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int primary key auto_increment,s1 int, s2 int);
insert into t1 values(0,(n_1()),3),(1,0,0);
select * from t2;

drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
