#owner:hr351303 
#owner group: sql-sql4
#description: obmysql模式, udf数据类型传参转换
#tags:pl,dml
#author: wb-nxa01399802
--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by '123';
grant all privileges on *.* to 'nxa'@'%' with grant option;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$obmysql_ms0,nxa,123,test,$obmysql_port);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database if exists nxa;
--enable_warnings
###创建db，切换db测试
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='strict_all_tables,no_zero_date,no_zero_in_date,error_for_division_by_zero ';
--result_format 4


--echo  #udf_3_4 data_type
--echo  int转其他int
--error 1051
drop table t2;
create table t2(id int ,s1 int, s2 int);
--error 1051
drop table t1;
create table t1(id bigint);
insert into t1(id) values (3697483647);
--error 1305
drop function n_1;
delimiter /;
create function n_1(a smallint,b tinyint,c int) returns varchar(200)
begin
  insert into t2 values(1,0,1);
  return concat(a,'-',b,'-',c);
end/
delimiter ;/
--error 1264
select n_1(id,id,id) from t1 ;
select * from t2;

--echo  int转char
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table t1;
create table t1(id bigint, s1 bigint);
insert into t1(id,s1) values (3697483647,19990224232401);
drop function n_1;
delimiter /;
create function n_1(a varchar(20),b char(20),c text) returns varchar(200)
begin
  insert into t2 values(1,0,1);
  return concat(a,'-',b,'-',c);
end/
delimiter ;/
select n_1(s1,s1,s1) from t1 ;
select * from t2;

--echo  int转date(year有问题)
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table t1;
create table t1(id bigint, s1 bigint);
insert into t1(id,s1) values (3697483647,19990224232401);
drop function n_1;
delimiter /;
create function n_1(a date,b time,c year,d datetime,e timestamp) returns varchar(200)
begin
  insert into t2 values(1,0,1);
  return concat(a,'+',b,'+',c,'+',d,'+',e);
end/
delimiter ;/
--error 1264
select n_1(s1,s1,s1,s1,s1) from t1 ;
select * from t2;



--echo  int转浮点定点(decimal(5,1)m失效)
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table t1;
create table t1(id bigint, s1 bigint);
insert into t1(id,s1) values (3697483647,19990224232401);
drop function n_1;
delimiter /;
create function n_1(a float,b double,c decimal(5,1)) returns varchar(200)
begin
  insert into t2 values(1,0,1);
  return concat(a,'+',b,'+',c);
end/
delimiter ;/
--error 1264
select n_1(s1,s1,s1) from t1 ;
select * from t2;


--echo  函数中为枚举类型，ob无法传入数据
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table t1;
create table t1(id bigint, s1 char(10));
insert into t1(id,s1) values (3697483647,'111');
drop function n_1;
delimiter /;
create function n_1(c enum('111','夏')) returns varchar(200)
begin
  insert into t2 values(1,0,1);
  return c;
end/
delimiter ;/
--error 1210
select n_1(s1) from t1 ;
select * from t2;
--echo  集合类型set，ob无法传入数据
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table t1;
create table t1(id bigint, s1 char(10));
insert into t1(id,s1) values (3697483647,'1,2');
drop function n_1;
delimiter /;
create function n_1(c set('1','2')) returns varchar(200)
begin
  insert into t2 values(1,0,1);
  return c;
end/
delimiter ;/
--error 1210
select n_1(s1) from t1 ;
select * from t2;
--echo  int转binary
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table t1;
create table t1(id bigint, s1 int);
insert into t1(id,s1) values (3697483647,2);
drop function n_1;
delimiter /;
create function n_1(c binary) returns varchar(200)
begin
  insert into t2 values(1,0,1);
  return c;
end/
delimiter ;/
select n_1(s1) from t1 ;
select * from t2;

--echo  int转blob
