--echo  浮点转date,MySQL都报错1292
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table t1;
create table t1(s1 float(20),s2 double,s3 decimal(20,1));
insert into t1 values (19990224232401,19990224232401,19990224232401);

drop function n_1;
delimiter /;
create function n_1(a date,b time,c year,d datetime,e timestamp) returns varchar(200)
begin
  insert into t2 values(1,0,1);
  return concat(a,'+',b,'+',c,'+',d,'+',e);
end/
delimiter ;/
--error 1292
select n_1(s1,'','','','') from t1 ;
--error 1292
select n_1('',s1,'','','') from t1 ;
--error 1318
select n_1('','',s1,'','') from t1 ;
--error 1292
select n_1('','','',s1,'') from t1 ;
--error 1292
select n_1('','','','',s1) from t1 ;
--error 1292
select n_1(s2,'','','','') from t1 ;
--error 1292
select n_1('',s2,'','','') from t1 ;
--error 1292
select n_1('','',s2,'','') from t1 ;
--error 1292
select n_1('','','',s2,'') from t1 ;
--error 1292
select n_1('','','','',s2) from t1 ;
--error 1292
select n_1(s3,'','','','') from t1 ;
--error 1292
select n_1('',s3,'','','') from t1 ;
--error 1292
select n_1('','',s3,'','') from t1 ;
--error 1292
select n_1('','','',s3,'') from t1 ;
--error 1292
select n_1('','','','',s3) from t1 ;

select * from t2;



