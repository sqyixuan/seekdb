insert into t1(s1) values (19990224232401);
drop function n_1;
delimiter /;
create function n_1(c binary(20)) returns varchar(200)
begin
  insert into t2 values(1,0,1);
  return c;
end/
delimiter ;/
select n_1(s1) from t1 ;
select * from t2;

--echo  blob转blob
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table t1;
create table t1(s1 blob);
insert into t1(s1) values (19990224232401);
drop function n_1;
delimiter /;
create function n_1(c blob) returns varchar(200)
begin
  insert into t2 values(1,0,1);
  return c;
end/
delimiter ;/
select n_1(s1) from t1 ;
select * from t2;


