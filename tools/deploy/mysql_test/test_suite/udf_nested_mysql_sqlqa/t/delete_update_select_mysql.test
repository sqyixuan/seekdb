--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by '123';
grant all privileges on *.* to 'nxa'@'%' with grant option;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$obmysql_ms0,nxa,123,test,$obmysql_port);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database if exists nxa;
--enable_warnings
###创建db，切换db测试
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='strict_all_tables,no_zero_date,no_zero_in_date,error_for_division_by_zero ';
--result_format 4


--echo  #udf_3_5  dml
--echo udf内部为删改查
--error 1051
drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,2,3),(1,0,0),(3,5,1);
--error 1051
drop table t2;
create table t2(id int,s1 int,s2 int);
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
--error 1051
drop table t3;
create table t3(id int ,s1 int, s2 int);
insert into t3 values(0,1,3),(1,7,1);
--error 1305
drop function n_4;
delimiter /;
create function n_4() returns int deterministic 
begin
  declare a int;
  select s1 into a from t1 limit 1;
  update t2 set id=a where id =1;
  delete from t2 where id=a;
  select id into @val from t2 limit 1;
  return a;
end/
delimiter ;/
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select length((select  n_4())) from t1 order by stats;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select power((select  n_4()),0.5) from t1 order by stats;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select sum((select  n_4())) from t1 order by stats ;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select count((select  n_4())) from t1 order by stats ;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select avg((select  n_4())) from t1 order by stats ;
select @val;
select * from t2;


delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select max((select  n_4())) from t1 ;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select min((select  n_4())) from t1 order by stats ;
select @val;
select * from t2;


delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select max((select  n_4()));
select @val;
select * from t2;



--echo 一般select；
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select  n_4() from t1;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select (select  n_4()) from dual;
select @val;
select * from t2;

--echo distinct

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select distinct((select  n_4())) from t1 order by stats;
select @val;
select * from t2;

--echo 运算

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select (select  n_4())+(select  n_4()) from t1 order by stats;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select (select  n_4()) * (select  n_4()) from t1 order by stats;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select (select  n_4())+2 from t1 order by stats;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select (select  n_4())+stats from t1 order by stats;
select @val;
select * from t2;
--echo concat
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select concat((select  n_4()),(select  n_4())) from t1 order by stats;
select @val;
select * from t2;


--echo where子句

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where stats = (select  n_4());
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where stats != (select  n_4());
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where stats < (select n_4());
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where (select  n_4())=0;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where not (select  n_4())=0;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where (select  n_4())!=0;
select @val;
select * from t2;


delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select n_4() from t1 where (select  n_4())=2;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select n_4() from t1 where (select  n_4())>2;
select @val;
select * from t2;



--echo between..and
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where stats between ((select  n_4())) and (select n_4());
select @val;
select * from t2;



--echo in
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where stats in((select  n_4()));
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where stats in (((select  n_4())) ,(n_4()));
select @val;
select * from t2;

--echo and
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where stats =(select  n_4()) and stats =(select n_4());
select @val;
select * from t2;
--echo or
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where stats =(select  n_4()) or stats =(select n_4());
select @val;
select * from t2;

--echo is null
--error 1051
drop table t4;
create table t4(s1 int,s2 int);
insert into t4 values(null,3);

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t4 where (select n_4()) is null ;
select @val;
select * from t2;


--echo 包含运算

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where ((select  n_4()) div (select n_4())) is null;
select @val;
select * from t2;


delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where (select (select  n_4())+(select  n_4()) from t1 where stats=1) =4;
select @val;
select * from t2;


--echo like

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where (select  n_4()) like '%2%';
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select n_4() from t1 where (select  n_4()) like '%0%';
select @val;
select * from t2;


--echo exists

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where exists (select n_4() from t3 where t1.stats = t3.id);
select @val;
select * from t2;

--echo any
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where (select  n_4()) = any (select n_4() from t1);
select @val;
select * from t2;


--echo all

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 where (select  n_4()) = all (select n_4() from t1);
select @val;
select * from t2;


--echo limit

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select (select  n_4()) from t1 limit 0;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select (select  n_4()) from t1 limit 2;
select @val;
select * from t2;


--echo order by

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select * from t1 order by ((select  n_4()));
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select n_4() from t1 order by ((select  n_4()));
select @val;
select * from t2;


--echo group by having

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select  n_4() from t1 group by (select  n_4());
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select  n_4() from t1 group by n_4() having max((select  n_4()));
select @val;
select * from t2;

--echo case when

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select case when (select  n_4())=2 then 0.75 else 0 end from t1 order by stats;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select (case (select  n_4()) when 2 then 0.29 when 1 then 9 else 0 end) from t1;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select (case (select  n_4()) when 2 then 0.29 when 1 then 9 else 0 end) from t1 group by (case (select  n_4()) when 2 then 0.29 when 1 then 9 else 0 end) order by stats;         
select @val;
select * from t2;

--echo 多表联查

drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0),(2,0,0);
drop table t3;
create table t3(id int ,s1 int, s2 int);
insert into t3 values(0,1,3),(1,0,0);

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select (select  n_4()) from t1 q join t3 w on q.stats = w.id;
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select (select  n_4()) from t1 q right join t3 w on q.stats = w.id;
select @val;
select * from t2;


--echo 嵌套
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select  n_4()from (select n_4() from t1) qq;
select @val;
select * from t2;

--echo 操作结果集
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
(select n_4() from t1) union (select n_4() from t3);
select @val;
select * from t2;

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
(select n_4() from t1) union all (select n_4() from t3);
select @val;
select * from t2;

--echo udf内部有嵌套

drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,2,3),(1,0,0),(3,5,1);

drop table t2;
create table t2(id int,s1 int,s2 int);
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
drop table t3;
create table t3(id int ,s1 int, s2 int);
insert into t3 values(0,1,3),(1,7,1);
drop function n_4;
delimiter /;
create function n_4() returns int deterministic 
begin
  declare a int;
  select s1 into a from t3 limit 1;
  update t2 set id=(select s2 from t1 where stats=1 ) where id =2;
  delete from t2 where id=(select s2 from t3 where id=1 );
  select id into @val from t2 limit 1;
  return a;
end/
delimiter ;/
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select length((select  n_4())) from t1 order by stats;
select @val;
select * from t2;




--echo insert
drop function n_4;
delimiter /;
create function n_4() returns int deterministic 
begin
  declare a int;
  select s1 into a from t3 limit 1;
  update t2 set id=a where id =1;
  delete from t2 where id=a;
  select id into @val from t2 limit 1;
  return a;
end/
delimiter ;/
drop table t2;
create table t2(id int,s1 int,s2 int);
drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,2,3),(1,0,0),(3,5,1);


delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
insert into t1 values(0,((select  n_4())),3),(1,0,0);
select @val;
select * from t2;


delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
insert into t1 select (select  n_4()),1,2 from t3;
select @val;
select * from t2;



--echo updata

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
update t1 set stats=(select  n_4()) where stats=1;
select @val;
select * from t2;

--echo delete

delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
delete from t1 where stats=(select  n_4());
select @val;
select * from t2;

--echo  replace into

drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(2,2,2),(1,0,0),(2,0,0);
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
replace into t1 select n_4(),1,2 from t4;
select @val;
select * from t2;


drop table t1;
create table t1(stats int primary key, s1 int, s2 int);
insert into t1 values(2,2,3),(1,0,0);
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
replace into t1 values((select  n_4()),2,2);
select @val;
select * from t2;

drop table t1;
create table t1(stats int primary key, s1 int, s2 int);
insert into t1 values(2,2,3),(1,0,0);
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
replace into t1 select  n_4(),2,2 from t4;
select @val;
select * from t2;

drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,2,3),(1,0,0),(3,5,1);
drop table t2;
create table t2(id int primary key,s1 int,s2 int);
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
drop function n_4;
delimiter /;
create function n_4(a int) returns int deterministic 
begin
 replace into t2 values (9,9,9),(a,9,9);
  return a;
end/
delimiter ;/
delete from t2;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
select  n_4(1) from t1;
select * from t2;

