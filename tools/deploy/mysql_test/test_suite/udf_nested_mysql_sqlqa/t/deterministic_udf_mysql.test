--echo insert 嵌套
drop table t1;
create table t1(id int , s1 int, s2 int);
insert into t1(id,s1,s2) values (1,1,3),(5,1,0),(3,1,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
insert into t1 select n_1(),1,2 from t1;
select count( * ) from t2;


drop table t1;
create table t1(id int , s1 int, s2 int);
insert into t1(id,s1,s2) values (1,1,3),(5,1,0),(3,1,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
insert into t1(id) select s1 from t1 order by (n_1());
select count( * ) from t2;

 
drop table t1;
create table t1(id int , s1 int, s2 int);
insert into t1(id,s1,s2) values (1,1,3),(5,1,0),(3,1,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
insert into t1(id) select n_1() from t1 order by (n_1());
select count( * ) from t2;


drop table t1;
create table t1(id int , s1 int, s2 int);
insert into t1(id,s1,s2) values (1,1,3),(5,1,0),(3,1,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
insert into t1(id) select n_1() from t1 where n_1()>1;
select count( * ) from t2;

drop table t1;
create table t1(id int , s1 int, s2 int);
insert into t1(id,s1,s2) values (1,1,3),(5,1,0),(3,1,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
insert into t1(id) select n_1() from t1 group by n_1() having max(n_1());
select count( * ) from t2;


--echo  updata
--echo  #43716487 up date set字段等于子查询调用udf值，次数不一致
drop table t1;
create table t1(id int , s1 int, s2 int);
insert into t1(id,s1,s2) values (1,1,3),(5,1,0),(3,1,0),(9,1,0),(2,7,0);
drop table t2;
create table t2(id int(9) ,s1 int, s2 int);

drop function n_1;
delimiter /;
create function n_1() returns int deterministic
begin
  insert into t2 values(1,0,1);
  return 3;
end/
delimiter ;/

drop table t2;
create table t2(id int ,s1 int, s2 int);
update t1 set id=n_1() ;
select count( * ) from t2;

drop table t2;
create table t2(id int ,s1 int, s2 int);
update t1 set id=(select n_1() ) ;
select count( * ) from t2;


drop table t2;
create table t2(id int ,s1 int, s2 int);
update t1 set id=1 where id=(select n_1());
select count( * ) from t2;

--echo  update 嵌套
drop table t1;
create table t1(id int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
--error 1051
drop table t3;
create table t3(id int, s1 int, s2 int);
insert into t3 values(0,1,3),(1,0,0);

drop table t2;
create table t2(id int ,s1 int, s2 int);
update t1 set id=(select n_1() from t3 where t3.s1=1 );
select count( * ) from t2;

drop table t2;
create table t2(id int ,s1 int, s2 int);
update t1 set id=(select n_1() from t3  limit 1);
select count( * ) from t2;


drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
update t1 set stats=(select n_1() from t3 group by n_1() having max(n_1()));
select count( * ) from t2;

--echo  delete
drop table t1;
create table t1(id int , s1 int, s2 int);
insert into t1(id,s1,s2) values (1,1,3),(5,1,0),(3,1,0),(9,1,0),(3,7,0);
drop table t2;
create table t2(id int(9) ,s1 int, s2 int);

drop function n_1;
delimiter /;
create function n_1() returns int deterministic
begin
  insert into t2 values(1,0,1);
  return 3;
end/
delimiter ;/
delete from t1 where id=n_1();
select count( * ) from t2;


drop table t1;
create table t1(id int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t3;
create table t3(id int, s1 int, s2 int);
insert into t3 values(0,1,3),(1,0,0);

drop table t2;
create table t2(id int ,s1 int, s2 int);
delete from t1 where id=(select n_1() from t3 group by n_1() having max(n_1()));
select count( * ) from t2;
--echo  limit
drop table t1;
create table t1(id int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t3;
create table t3(id int, s1 int, s2 int);
insert into t3 values(0,3,3),(1,0,0),(0,3,0);

drop table t2;
create table t2(id int ,s1 int, s2 int);
delete from t1 where id =(select id from t3 where s1 = n_1() limit 1);
select count( * ) from t2;

--echo  replace into

drop table t1;
create table t1(id int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t3;
create table t3(id int, s1 int, s2 int);
insert into t3 values(0,3,3),(1,0,0),(0,3,0);
drop function n_1;
delimiter /;
create function n_1() returns int deterministic
begin
  insert into t2 values(1,0,1);
  return 3;
end/
delimiter ;/
drop table t2;
create table t2(id int ,s1 int, s2 int);
replace into t1 select n_1(),1,2 from t3;
select count( * ) from t2;

drop table t1;
create table t1(id int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
replace into t1 values(n_1(),1,2);
select count( * ) from t2;


delete from t1;
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
replace into t1(id) select n_1() from t3 group by n_1() having max(n_1());
select count( * ) from t2;

delete from t1;
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
replace into t1 select * from t3 order by (n_1());
select count( * ) from t2;


drop table t1;
create table t1(id int, s1 int, s2 int);
drop table t2;
create table t2(id int ,s1 int, s2 int);
insert into t1(id) select n_1() from t3 where n_1()>1;
select count( * ) from t2;




--echo  当replace into为改的情况，ob计算为空
drop table t1;
create table t1(stats int primary key, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop function n_1;
delimiter /;
create function n_1() returns int deterministic
begin
  insert into t2 values(1,0,1);
  return 1;
end/
delimiter ;/
drop table t2;
create table t2(id int ,s1 int, s2 int);
replace into t1 values(n_1(),1,2);
select count( * ) from t2;

drop table t1;
create table t1(stats int primary key, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
replace into t1 select n_1(),1,2 from t3;
select count( * ) from t2;

drop table t1;
create table t1(stats int primary key, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
replace into t1(stats) select n_1() from t3 order by n_1();
select count( * ) from t2;

drop table t1;
create table t1(stats int primary key, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
replace into t1(stats) select n_1() from t3 group by n_1() having sum(n_1())>0;
select count( * ) from t2;


