select count( * ) from t2;




--echo  #udf_1_7 #case when

drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,2,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1() returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return 1;
end/
delimiter ;/


drop table t2;
create table t2(id int ,s1 int, s2 int);
select case when n_1()=0 then 0.75 else 0 end from t1 order by stats;
select count( * ) from t2;

drop table t2;
create table t2(id int ,s1 int, s2 int);
select case when s1=n_1() then 0.75 else n_1() end from t1 order by stats;
select count( * ) from t2;

drop table t2;
create table t2(id int ,s1 int, s2 int);
select case when n_1()=concat(n_1(),s1) then 0.75 else n_1() end from t1 order by stats;
select count( * ) from t2;


drop table t2;
create table t2(id int ,s1 int, s2 int);
select (case n_1() when 0 then 0.29 when 1 then 9 else 0 end) from t1;
select count( * ) from t2;

drop table t2;
create table t2(id int ,s1 int, s2 int);
select (case stats when n_1() then 0.02 when 1 then 'a' else 0 end) from t1;
select count( * ) from t2;
--echo  case when concat 不兼容不一致
drop table t2;
create table t2(id int ,s1 int, s2 int);
select (case n_1() when concat(s1,n_1()) then 0.02 when 0 then 9 else 55 end) from t1;
select count( * ) from t2;


drop table t2;
create table t2(id int ,s1 int, s2 int);
select (case n_1() when 0 then 0.29 when 1 then 9 else 0 end) from t1 group by (case n_1() when 0 then 0.29 when 1 then 9 else 0 end) order by stats;         
select count( * ) from t2;


