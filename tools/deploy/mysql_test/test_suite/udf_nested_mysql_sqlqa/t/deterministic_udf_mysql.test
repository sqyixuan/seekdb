select n_1() from (select n_1() from dual) qq;
select count( * ) from t2;




--echo  #udf_1_10 操作结果集
--echo  ##45211054- 【udf】对于查询deterministic_udf的结果使用union，ob为执行两次
drop table t2;
create table t2(id int ,s1 int, s2 int);
(select n_1() from t1) union (select s1 from t1);
select count( * ) from t2;


drop table t2;
create table t2(id int ,s1 int, s2 int);
(select n_1() from t1) union (select n_1() from t1);
select count( * ) from t2;


drop table t2;
create table t2(id int ,s1 int, s2 int);
(select n_1() from t1) union all (select s1 from t1);
select count( * ) from t2;

drop table t2;
create table t2(id int ,s1 int, s2 int);
select n_1() from ((select * from t1) union all (select * from t1)) ee;
select count( * ) from t2;


