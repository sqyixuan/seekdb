drop table t2;
create table t2(id int ,s1 int, s2 int);

drop function n_1;
delimiter /;
create function n_1() returns int deterministic
begin
  insert into t2 values(1,0,1);
  return 7;
end/
delimiter ;/
select * from t1  left join t3  on t1.id = t3.bid where t1.s1=n_1()  ;
select * from t2;
delete from t2;
 select n_1() from t1  left join t3  on t1.id = t3.bid ;
select * from t2;
--echo  right join
--echo  次数不一致
delete from t2;
select * from t1  right  join t3  on t1.id = t3.bid where t3.s1=n_1()  ;
select * from t2;
delete from t2;
select n_1() from t1  left join t3  on t1.id = t3.bid ;
select * from t2;
--echo  cross join
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 q cross join t3 w on q.id = w.bid where w.s1=n_1();
select count( * ) from t2;



--echo  #udf_1_9  嵌套,不兼容

drop table t1;
create table t1(stats int , s1 int, s2 int);
insert into t1 values(1,1,3),(2,2,0),(2,3,0),(2,2,0),(2,7,0);
drop table t3;
create table t3(bid int ,s1 int, s2 int);
INSERT INTO t3 VALUES(0,1,3),(1,6,0),(2,7,0);


drop table t2;
create table t2(id int ,s1 int, s2 int);

drop function n_1;
delimiter /;
create function n_1() returns int deterministic
begin
  insert into t2 values(1,0,1);
  return 1;
end/
delimiter ;/
select * from (select n_1() from t1) qq;
select count( * ) from t2;

delete from t2;
select * from t1 where  s1 in (select n_1() from t3 );
select * from t2;

delete from t2;
select s1,s2,(select n_1() from t3 limit 1 ) as ret from t1  ;
select * from t2;

delete from t2;
with ccc as (select n_1() from t1) select * from ccc;
select * from t2;


--echo  嵌套function查询function from dual，次数不一致，待修复后验证
