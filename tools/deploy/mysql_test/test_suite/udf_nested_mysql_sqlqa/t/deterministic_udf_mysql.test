drop table t3;
create table t3(id int , s1 int, s2 int);
insert into t3 values(1,4,3);
insert into t3 values(2,7,3);

drop function n_1;
delimiter /;
create function n_1() returns int  deterministic
begin
  insert into t2 values(1,0,1);
  return 4;
end/
delimiter ;/


SELECT t1.s1 + t3.s2 FROM t1, t3 where t1.s1=n_1();
select count(*) from t2;
delete from t2;
select * from t1  join t3  on t1.id = t3.id where t1.s1=n_1();
select count(*) from t2;
delete from t2;
select n_1() from t1  join t3  on t1.id = t3.id ;
select count(*) from t2;

--echo  left join
--echo  次数不一致
drop table t1;
create table t1(id int, s1 int, s2 int);
INSERT INTO t1 VALUES(0,1,3),(1,0,0),(2,7,0);
drop table t3;
create table t3(bid int ,s1 int, s2 int);
