--echo  #udf_1_4  ##limit
drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1() returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return 0;
end/
delimiter ;/


select n_1() from t1 limit 0;
select count( * ) from t2;
drop table t2;
create table t2(id int ,s1 int, s2 int);
select n_1() from t1 limit 1;
select count( * ) from t2;
drop table t2;
create table t2(id int ,s1 int, s2 int);
select n_1() from t1 limit 2;
select count( * ) from t2;
drop table t2;
create table t2(id int ,s1 int, s2 int);
select n_1() from t1 limit 1,3;
select count( * ) from t2;
--echo  distinct+limit
drop table t2;
create table t2(id int ,s1 int, s2 int);
select distinct(n_1()) from t1 limit 2,3;
select count( * ) from t2;

--echo  where+limit 
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where s1=n_1() limit 1,3;
SELECT count( * ) FROM t2;

--echo  order by+limit 
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 order by n_1() limit 1,3;
SELECT count( * ) FROM t2;
--echo  group by+limit 
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 group by n_1() limit 1,3;
SELECT count( * ) FROM t2;




--echo  #udf_1_5  #order by
drop table t1;
create table t1(stats int , s1 int primary key , s2 int);
insert into t1 values(2,1,3),(1,2,0),(3,3,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1() returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return 1;
end/
delimiter ;/
select n_1() from t1 order by s1;
SELECT count( * ) FROM t2;
delete from t2;
select s1 from t1 order by n_1();
SELECT count( * ) FROM t2;


drop table t1;
create table t1(id int , s1 int , s2 int,primary key(id,s1));
insert into t1 values(2,1,3),(1,2,0),(3,3,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1() returns float  deterministic 
begin
  insert into t2 values(1,0,1);
  return rand();
end/
delimiter ;/
select s2 from t1 order by n_1();
SELECT * FROM t2;
delete from t2;
select id from t1 order by id,n_1() limit 1,3;
SELECT * FROM t2;
delete from t2;
select * from t1 order by id,s1,n_1();
SELECT * FROM t2;





--echo  #udf_1_6   group by 
--echo  普通group by 
--echo  次数不一致，不兼容
drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
