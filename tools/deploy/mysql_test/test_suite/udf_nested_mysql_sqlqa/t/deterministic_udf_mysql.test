delete from t2;
select s1 from t1  where id=n_1() ;
select * from t2;
delete from t2;
select n_1() from t1 group by s1 ;
select * from t2;
delete from t2;
select n_1() from t1 where (id = 1 or id = 2) and s1 > 1990  ;
select * from t2;

