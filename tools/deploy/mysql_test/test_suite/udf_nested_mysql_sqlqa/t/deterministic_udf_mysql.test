insert into t1 values(1,1,3),(2,2,0),(3,2,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);

drop function n_1;
delimiter /;
create function n_1() returns int deterministic
begin
  insert into t2 values(1,0,1);
  return 1;
end/
delimiter ;/
select sum(stats) from t1 group  by n_1();
