--echo  普通索引
drop table t3;
--error 1305
drop procedure initData;
delimiter /;
create procedure initData()
begin
declare count int default 1;
while count <= 100 DO
 insert into t1 (id,s1,s2) values (count,count,count); 
 set count = count +1;
end while;
end;
/

delimiter ;/
drop table t1;
create table t1(id int, s1 int, s2 int,index ix_id(id),index idx_id(s1));
call initData();

drop table t2;
create table t2(id int ,s1 int, s2 int);

drop function n_1;
delimiter /;
create function n_1() returns int deterministic
begin
  insert into t2 values(1,0,1);
  return 50;
end/
delimiter ;/

delete from t2;
select n_1() from t1 where id =n_1() ;
select * from t2;

delete from t2;
select n_1() from t1 where s1 <50 order by id ;
select * from t2;

delete from t2;
select n_1() from t1 where s1 <50 group by id ;
select * from t2;


delete from t2;
select * from t1 where id=n_1() ; 
select * from t2;



--echo  联合索引
drop procedure initData;
delimiter /;
create procedure initData()
begin
declare count int default 1;
while count <= 100 DO
 insert into t1 (id,s1,s2) values (count,count,count); 
 set count = count +1;
end while;
end;
/

delimiter ;/
drop table t1;
create table t1(id int primary key,s1 int, s2 int);
call initData();

drop table t2;
create table t2(id int ,s1 int, s2 int);

drop function n_1;
delimiter /;
create function n_1() returns int deterministic
begin
  insert into t2 values(1,0,1);
  return 50;
end/
delimiter ;/

create index ix_iot on t1(id,s1,s2);
delete from t2;
select id,s1,s2,n_1() from t1 where s1 =50 and s2= n_1();
select * from t2;

alter table t1 drop index ix_iot;
create index ix_iot on t1(s1,s2,id);
delete from t2;
select id,s1,s2,n_1()from t1 ;
select * from t2;

alter table t1 drop index ix_iot;
create index ix_iot on t1(id,s1,s2);
delete from t2;
select id,s1,s2,n_1()from t1 where id =50 and s1= n_1() order by s2;
select * from t2;

delete from t2;
select id,s1,s2,n_1()from t1 where id <51 and s1= n_1() order by s2;
select * from t2;



