--echo  is null
--error 1051
drop table t4;
create table t4(s1 int,s2 int);
insert into t4 values(null,3),(1,9);
--error 1305
drop function n_2;
delimiter /;
create function n_2(a int) returns int deterministic
begin
  insert into t2 values(null,1,a);
  return a;
end/
delimiter ;/
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t4 where (select n_2(s1)) is null ;
select count(*) from t2;
select * from t4 where (select n_2(s1)) is not null ;
select count(*) from t2;
select * from t4 where (n_2(s1)) is  null ;
select count(*) from t2;
select * from t4 where (n_2(s1)) is not null ;
select count(*) from t2;


--echo  包含运算
