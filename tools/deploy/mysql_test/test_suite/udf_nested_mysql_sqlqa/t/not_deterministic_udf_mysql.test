#owner:hr351303 
#owner group: sql-sql4
#description: obmysql模式,not deterministic udf对外部查询的影响以及外部查询对udf内部的影响
#tags:pl,dml
#author: wb-nxa01399802
--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by '123';
GRANT all privileges ON *.* TO 'nxa'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$OBMYSQL_MS0,nxa,123,test,$OBMYSQL_PORT);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS nxa;
--enable_warnings
###创建DB，切换DB测试
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='STRICT_ALL_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO ';
--result_format 4


--echo  #udf_3_1  not deterministic
--echo  #udf_1  select 
--echo  #udf_1_1  一般select
--echo  #前置条件
--error 1051
drop table t1;
create table t1(stats int , s1 int primary key, s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,2,0);
--error 1051
drop table t2;
create table t2(id int ,s1 int, s2 int);
--error 1305
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 0;
end/
delimiter ;/
--echo  #查询场景
--echo  #一般select
select n_1() from t1;
select count(*) from t2;

--echo  #查询udf from 空表
delete from  t2;
--error 1051
drop table kong;
create table kong(id int ,s1 int, s2 int);
select n_1() from kong;
select count( * ) from t2;

--echo  #查询udf from dual
drop table t2;
create table t2(id int ,s1 int, s2 int);
select n_1() from dual;
select count( * ) from t2;


--echo  #查询udf from 基表
--echo  ##41842047 ob和mysql结果不一致，mysql报错1442
drop table t2;
create table t2(id int ,s1 int, s2 int);
insert into t2 values(0,1,3),(1,0,0);

--error 1442
select n_1() from t2;
select count( * ) from t2;


--echo  #distinct
drop table t1;
create table t1(id int primary key, s1 int, s2 int);
insert into t1 values(1,1,3),(5,1,0),(3,1,0),(9,1,0),(2,7,0);
--error 1051
drop table t3;
create table t3(bid int ,s1 int, s2 int);
INSERT INTO t3 VALUES(0,1,3),(1,6,0),(2,7,0);

drop table t2;
create table t2(id int ,s1 int, s2 int);

drop function n_1;
delimiter /;
create function n_1() returns int not deterministic
begin
  insert into t2 values(1,0,1);
  return 1;
end/
delimiter ;/

select distinct(n_1()) from t1 where id=9  ; 
select * from t2;

--echo  #merge distinct

drop table t1;
create table t1(id int primary key, s1 int, s2 int);
insert into t1 values(1,1,3),(5,1,0),(3,1,0),(9,1,0),(2,7,0);

drop table t2;
create table t2(id int ,s1 int, s2 int);

drop function n_1;
delimiter /;
create function n_1() returns int not deterministic
begin
  insert into t2 values(1,0,1);
  return 1;
end/
delimiter ;/

select distinct(n_1()) from t1 order by n_1() ; 
select * from t2;


--echo  #hash distinct
--echo  #44574429 执行计划转变为使用hash distinct 时，对于无参udf，ob本身会多执行一次；对于有参udf，ob执行次数变为两倍
--error 1305
drop procedure initData;
delimiter /;
create procedure initData()
begin
declare count int default 1;
while count <= 240 DO
 insert into t1 (id,s1,s2) values (count,count,count); 
 set count = count +1;
end while;
end;
/
delimiter ;/

drop table t1;
create table t1(id int primary key, s1 int, s2 int);

call initData();
drop table t2;
create table t2(id int ,s1 int, s2 int);

drop function n_1;
delimiter /;
create function n_1() returns int not deterministic
begin
  insert into t2 values(1,0,1);
  return 1;
end/
delimiter ;/

select distinct(n_1()) from t1 order by n_1(); 
select count(*) from t2;


--echo #有参走hash distinct
drop table t1;
create table t1(id int primary key, s1 int, s2 int);

call initData();
drop table t2;
create table t2(id int ,s1 int, s2 int);

drop function n_1;
delimiter /;
create function n_1(a int) returns int  deterministic
begin
  insert into t2 values(1,0,1);
  return a;
end/
delimiter ;/

select  distinct(n_1(s1)) from t1 order by n_1(s1) desc limit 1 ; 
select count(*) from t2;


--echo  #运算
drop table t1;
create table t1(stats int , s1 int primary key, s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,2,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 0;
end/
delimiter ;/
drop table t2;
create table t2(id int ,s1 int, s2 int);
select n_1()+n_1() from t1 order by stats;
select count(*) from t2;
select n_1()-n_1() from t1 order by stats;
select count(*) from t2;
select n_1() * n_1() from t1 order by stats;
select count(*) from t2;
select n_1() div n_1() from t1 order by stats;
select count(*) from t2;


drop table t2;
create table t2(id int ,s1 int, s2 int);
select n_1()+2 from t1 order by stats;
select count(*) from t2;
select n_1()-3 from t1 order by stats;
select count(*) from t2;
select n_1() * 3 from t1 order by stats;
select count(*) from t2;
select n_1() div 6 from t1 order by stats;
select count(*) from t2;

drop table t2;
create table t2(id int ,s1 int, s2 int);
select n_1()+stats from t1 order by stats;
select count(*) from t2;
select n_1()-stats from t1 order by stats;
select count(*) from t2;
select n_1() * stats from t1 order by stats;
select count(*) from t2;
select n_1() div stats from t1 order by stats;
select count(*) from t2;
--echo  #concat
drop table t2;
create table t2(id int ,s1 int, s2 int);
select concat(n_1(),n_1()) from t1 ;
select count(*) from t2;

--echo  #udf_1_2  函数嵌套

--echo  #前置条件
drop table t1;
create table t1(stats int , s1 int primary key, s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,2,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 0;
end/
delimiter ;/
--echo  #字符和数字函数
select count(*) from t2;
select ascii (n_1()) from t1 order by stats;
select count(*) from t2;
select instr(n_1(),1) from t1 order by stats;
select count(*) from t2;
select length(n_1()) from t1 order by stats;
select count(*) from t2;
select abs(n_1()) from t1 order by stats;
select count(*) from t2;
select ceil(n_1())from t1 order by stats;
select count(*) from t2;
select floor(n_1()) from t1 order by stats;
select count(*) from t2;
select sin(n_1()) from t1 order by stats;
select count(*) from t2;
select cos(n_1()) from t1 order by stats;
select count(*) from t2;
select sign(n_1()) from t1 order by stats;
select count(*) from t2;
select power(n_1(),0.5) from t1 order by stats;
select count(*) from t2;
select mod(n_1(),stats) from t1 order by stats;
select count(*) from t2;
select round(n_1()) from t1 order by stats;
select count(*) from t2;
select sqrt(n_1()) from t1 order by stats;
select count(*) from t2;

--echo  #聚合函数
drop table t2;
create table t2(id int ,s1 int, s2 int);
select sum(n_1()) from t1 order by stats ;
select count(*) from t2;
select count(n_1()) from t1 order by stats ;
select count(*) from t2;
select avg(n_1()) from t1 order by stats ;
select count( * ) from t2;


--echo  ##41744381 聚合函数max和min嵌套常量udf时，ob计算一次，mysql计算3次
drop table t2;
create table t2(id int ,s1 int, s2 int);
select max(n_1()) from t1 ;
select count( * ) from t2;
select min(n_1()) from t1 order by stats ;
select count( * ) from t2;


drop table t2;
create table t2(id int ,s1 int, s2 int);
select max(n_1()) from kong ;
select count( * ) from t2;


--echo  #udf_1_3 where子句
--echo  #前置条件
drop table t1;
create table t1(stats int , s1 int primary key, s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,2,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 0;
end/
delimiter ;/

--echo  #字段与函数值比较
select * from t1 where stats = n_1();
select count(*) from t2;
select * from t1 where stats != n_1();
select count(*) from t2;
select * from t1 where stats < n_1();
select count(*) from t2;
select * from t1 where stats > n_1();
select count(*) from t2;
select * from t1 where stats <= n_1();
select count(*) from t2;
select * from t1 where stats >= n_1();
select count(*) from t2;

--echo  #函数值比较

drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where n_1()=0;
select count( * ) from t2;
select * from t1 where n_1()!=0;
select count( * ) from t2;

select * from t1 where n_1()<1;
select count( * ) from t2;


select * from t1 where n_1()>1;
select count( * ) from t2;


select * from t1 where n_1()<=1;
select count( * ) from t2;

select n_1() from t1 where n_1()>=1;
select count( * ) from t2;


select n_1() from t1 where n_1()=0;
select count( * ) from t2;

select * from t1 where n_1()=n_1();
select count( * ) from t2;


select * from kong where n_1()=0;
select count( * ) from t2;

select n_1() from dual where n_1()=0;
select count( * ) from t2;



--echo  #between..and
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where stats between (n_1()) and 9;
select count( * ) from t2;
select n_1() from t1 where stats between 0 and 9;
select count( * ) from t2;
select n_1() from t1 where stats between (n_1()) and 9;
select count( * ) from t2;

--echo  #in
--echo  #一个参数
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where stats in(n_1());
select count( * ) from t2;

select * from t1 where stats not in(n_1());
select count( * ) from t2;

--echo  #两个参数
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where stats in ((n_1()) ,4);
select count( * ) from t2;

select * from t1 where stats not in ((n_1()) ,4);
select count( * ) from t2;

--echo  #and
--echo  ##43843087 and 和 or对逻辑判断之间多个列进行筛选结果不一致,不兼容
drop table t1;
create table t1(id int , s1 int, s2 int);
insert into t1 values(1,1,3),(5,2,0),(3,3,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic
begin
  insert into t2 values(1,0,1);
  return 1;
end/
delimiter ;/
select count(*) from t1 where (id = n_1() or id = 2) and s1 < 3 ;
select * from t2;

drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where id =n_1() and id =n_1();
select count( * ) from t2;


--echo  #or
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where id =n_1() or id =n_1();
select count( * ) from t2;

--echo  #is null
--error 1051
drop table t4;
create table t4(s1 int,s2 int);
insert into t4 values(null,3);
--error 1305
drop function n_2;
delimiter /;
create function n_2(a int) returns int no sql
begin
  insert into t2 values(null,1,a);
  return a;
end/
delimiter ;/
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t4 where (select n_2(s1)) is null ;
select count(*) from t2;
select * from t4 where (select n_2(s1)) is not null ;
select count(*) from t2;
select * from t4 where (n_2(s1)) is  null ;
select count(*) from t2;
select * from t4 where (n_2(s1)) is not null ;
select count(*) from t2;

drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where n_1() is null;
select count( * ) from t2;



--echo  #包含运算

drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where (n_1() div 0) is null;
select count( * ) from t2;

select * from t1 where (n_1()+n_1())=0;
select count( * ) from t2;

select * from t1 where (select n_1()+n_1() from t1 where id=1) =2;
select count( * ) from t2;


--echo  #like

drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where n_1() like '%0%';
select count( * ) from t2;


select * from t1 where (select n_1() from t1 where id=1) like '%1%';
select count( * ) from t2;

--echo  #判定ture或false
--echo  #前置条件
drop table t3;
create table t3(id int , s1 int, s2 int);
insert into t3 values(1,1,3),(5,2,0),(3,3,0);
drop table t1;
create table t1(stats int , s1 int primary key, s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,2,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 0;
end/
delimiter ;/
--echo  #exists

drop table t2;
create table t2(id int ,s1 int, s2 int);

select * from t1 where exists (select n_1() from t3 where t1.stats = t3.id);
select count( * ) from t2;
--echo  # #43780617 ob与mysql次数不一致
delete from t2;
select * from t1 where exists (select n_1() =0);
select count( * ) from t2;
--echo  # #43779935 exists(select 1 from dual)没有消除，ob与mysql次数不一致
delete from t2;
select * from t1 where exists (select n_1() from dual);
select count( * ) from t2;

delete from t2;
select * from t1 where exists (select * from t1 where s1=n_1());
select count( * ) from t2;
--echo  ##43748653  部分查询语句在exists条件为ture时未输出结果，同时执行次数也和oracle不一致

drop table t1;
create table t1(id int , s1 int, s2 int);
insert into t1 values(1,3,5);
insert into t1 values(2,2,4);
insert into t1 values(3,3,3);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic
begin
  insert into t2 values(1,0,1);
  return 3;
end/
delimiter ;/

select * from t1 where exists (select * from t1 where s2=n_1());
select * from t2;


--echo  #any和all
--echo  #查询语句以函数值与any或all结果比较作为判定条件，ob不能根据条件ture或false输出相应结果，次数也不一致
--echo  ##43976556- NO DETERMINISTIC的udf不应该被识别成ONETIME EXPR
--echo  ##43782079- 【udf】not deterministic udf，查询where子句筛选条件为字段和any比较，any内容为select udf值，ob和mysql执行次数结果不一致
drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 1;
end/
delimiter ;/
select * from t1 where n_1() > any (select s1 from t1 );
SELECT * FROM t2;


drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(9,9,9);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 0;
end/
delimiter ;/

select * from t1 where s1 = any (select n_1() from t1 );
SELECT * FROM t2;


drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,1),(0,0,0),(9,9,9);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 0;
end/
delimiter ;/

select * from t1 where s1 = any (select s2 from t1 where stats in (n_1(),9,1));
SELECT * FROM t2;



