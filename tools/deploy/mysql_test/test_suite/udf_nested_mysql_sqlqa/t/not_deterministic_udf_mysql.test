--echo  #联合索引
drop procedure initData;
delimiter /;
create procedure initData()
begin
declare count int default 1;
while count <= 100 DO
 insert into t1 (id,s1,s2) values (count,count,count); 
 set count = count +1;
end while;
end;
/

