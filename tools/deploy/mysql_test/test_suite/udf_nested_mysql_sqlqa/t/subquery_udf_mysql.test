--echo  #udf_1_6   group by 
drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1(a int) returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return a;
end/
delimiter ;/
drop table t2;
create table t2(id int ,s1 int, s2 int);
select (select n_1(s1)) from t1 group by stats order by stats;
SELECT count( * ) FROM t2;


