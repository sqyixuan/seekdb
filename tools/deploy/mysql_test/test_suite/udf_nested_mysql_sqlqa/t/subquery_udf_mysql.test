--echo  #udf_1_4  ##limit
drop table t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1(a int) returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return a;
end/
delimiter ;/


select (select n_1(s1)) from t1 limit 0;
select count( * ) from t2;
drop table t2;
create table t2(id int ,s1 int, s2 int);
select (select n_1(s1)) from t1 limit 1;
select count( * ) from t2;
drop table t2;
create table t2(id int ,s1 int, s2 int);
select (select n_1(s1)) from t1 limit 2;
select count( * ) from t2;
drop table t2;
create table t2(id int ,s1 int, s2 int);
select (select n_1(s1)) from t1 limit 1,3;
select count( * ) from t2;
--echo  #distinct+limit
drop table t2;
create table t2(id int ,s1 int, s2 int);
select distinct((select n_1(s1))) from t1 limit 2,3;
select count( * ) from t2;

--echo  ## where+limit 
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where s1=(select n_1(s1)) limit 1,3;
SELECT count( * ) FROM t2;

--echo  #order by+limit 
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 order by (select n_1(s1)) limit 1,3;
SELECT count( * ) FROM t2;
--echo  #group by+limit 
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 group by (select n_1(s1)) limit 1,3;
SELECT count( * ) FROM t2;




