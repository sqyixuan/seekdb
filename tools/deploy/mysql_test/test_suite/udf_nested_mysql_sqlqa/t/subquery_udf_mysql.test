#owner:hr351303 
#owner group: sql-sql4
#description: obmysql模式, 子查询调用udf各嵌套场景，主要验证数据是否传入udf参数
#tags:pl,dml
#author: wb-nxa01399802
--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by '123';
grant all privileges on *.* to 'nxa'@'%' with grant option;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$obmysql_ms0,nxa,123,test,$obmysql_port);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database if exists nxa;
--enable_warnings
###创建db，切换db测试
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='strict_all_tables,no_zero_date,no_zero_in_date,error_for_division_by_zero ';
--result_format 4




--echo  #udf_3_3 subquery_udf
--echo  #udf_1  select 
--echo  #udf_1_1  一般select
--echo  #前置条件
--error 1051
drop table t1;
create table t1(stats int , s1 int primary key, s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,2,0);
--error 1051
drop table t2;
create table t2(id int ,s1 int, s2 int);
--error 1305
drop function n_1;
delimiter /;
create function n_1(a int) returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return a;
end/
delimiter ;/
--echo  #查询场景
--echo  #一般select
select (select n_1(s1)) from t1;
select count(*) from t2;



--echo  #distinct
drop table t1;
create table t1(id int primary key, s1 int, s2 int);
insert into t1 values(1,1,3),(5,1,0),(3,1,0),(9,1,0),(2,7,0);
--error 1051
drop table t3;
create table t3(bid int ,s1 int, s2 int);
INSERT INTO t3 VALUES(0,1,3),(1,6,0),(2,7,0);

drop table t2;
create table t2(id int ,s1 int, s2 int);

drop function n_1;
delimiter /;
create function n_1(a int) returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return a;
end/
delimiter ;/

select distinct((select n_1(s1))) from t1 ; 
select * from t2;



drop table t1;
create table t1(id int primary key, s1 int, s2 int);
insert into t1 values(1,1,3),(5,1,0),(3,1,0),(9,1,0),(2,7,0);

drop table t2;
create table t2(id int ,s1 int, s2 int);

drop function n_1;
delimiter /;
create function n_1(a int) returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return a;
end/
delimiter ;/

select distinct((select n_1(s1))) from t1 order by (select n_1(s1)) ; 
select * from t2;




--echo  #运算
drop table t2;
create table t2(id int ,s1 int, s2 int);
select (select n_1(s1))+(select n_1(s1)) from t1 order by id;
select count(*) from t2;
select (select n_1(s1))-(select n_1(s1)) from t1 order by id;
select count(*) from t2;
select (select n_1(s1)) * (select n_1(s1)) from t1 order by id;
select count(*) from t2;
select (select n_1(s1)) div (select n_1(s1)) from t1 order by id;
select count(*) from t2;


drop table t2;
create table t2(id int ,s1 int, s2 int);
select (select n_1(s1))+2 from t1 order by id;
select count(*) from t2;
select (select n_1(s1))-3 from t1 order by id;
select count(*) from t2;
select (select n_1(s1)) * 3 from t1 order by id;
select count(*) from t2;
select (select n_1(s1)) div 6 from t1 order by id;
select count(*) from t2;

drop table t2;
create table t2(id int ,s1 int, s2 int);
select (select n_1(s1))+id from t1 order by id;
select count(*) from t2;
select (select n_1(s1))-id from t1 order by id;
select count(*) from t2;
select (select n_1(s1)) * id from t1 order by id;
select count(*) from t2;
select (select n_1(s1)) div id from t1 order by id;
select count(*) from t2;
--echo  #concat
drop table t2;
create table t2(id int ,s1 int, s2 int);
select concat((select n_1(s1)),(select n_1(s1))) from t1 ;
select count(*) from t2;


--echo  #udf_1_2  函数嵌套

--echo  #前置条件
drop table t1;
create table t1(stats int , s1 int primary key, s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,2,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1(a int) returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return a;
end/
delimiter ;/
--echo  #字符和数字函数
select count(*) from t2;
select ascii ((select n_1(s1))) from t1 order by stats;
select count(*) from t2;
select instr((select n_1(s1)),1) from t1 order by stats;
select count(*) from t2;
select length((select n_1(s1))) from t1 order by stats;
select count(*) from t2;
select abs((select n_1(s1))) from t1 order by stats;
select count(*) from t2;
select ceil((select n_1(s1)))from t1 order by stats;
select count(*) from t2;
select floor((select n_1(s1))) from t1 order by stats;
select count(*) from t2;
select sin((select n_1(s1))) from t1 order by stats;
select count(*) from t2;
select cos((select n_1(s1))) from t1 order by stats;
select count(*) from t2;
select sign((select n_1(s1))) from t1 order by stats;
select count(*) from t2;
select power((select n_1(s1)),0.5) from t1 order by stats;
select count(*) from t2;
select mod((select n_1(s1)),stats) from t1 order by stats;
select count(*) from t2;
select round((select n_1(s1))) from t1 order by stats;
select count(*) from t2;
select sqrt((select n_1(s1))) from t1 order by stats;
select count(*) from t2;

--echo  #聚合函数
drop table t2;
create table t2(id int ,s1 int, s2 int);
select sum((select n_1(s1))) from t1 order by stats ;
select count(*) from t2;
select count((select n_1(s1))) from t1 order by stats ;
select count(*) from t2;
select avg((select n_1(s1))) from t1 order by stats ;
select count( * ) from t2;


drop table t2;
create table t2(id int ,s1 int, s2 int);
select max((select n_1(s1))) from t1 ;
select count( * ) from t2;
select min((select n_1(s1))) from t1 order by stats ;
select count( * ) from t2;






--echo  #udf_1_3 where子句
--echo  #前置条件
drop table t1;
create table t1(stats int , s1 int primary key, s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,2,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1(a int) returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return a;
end/
delimiter ;/

--echo  #字段与函数值比较
select * from t1 where stats = (select n_1(s1));
select count(*) from t2;
select * from t1 where stats != (select n_1(s1));
select count(*) from t2;
select * from t1 where stats < (select n_1(s1));
select count(*) from t2;
select * from t1 where stats > (select n_1(s1));
select count(*) from t2;
select * from t1 where stats <= (select n_1(s1));
select count(*) from t2;
select * from t1 where stats >= (select n_1(s1));
select count(*) from t2;

--echo  #函数值比较
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where (select n_1(s1))=0;
select count( * ) from t2;
select * from t1 where (select n_1(s1))!=0;
select count( * ) from t2;

select * from t1 where (select n_1(s1))<1;
select count( * ) from t2;

select * from t1 where (select n_1(s1))>1;
select count( * ) from t2;

select * from t1 where (select n_1(s1))<=1;
select count( * ) from t2;

select (select n_1(s1)) from t1 where (select n_1(s1))>=1;
select count( * ) from t2;

select (select n_1(s1)) from t1 where (select n_1(s1))=0;
select count( * ) from t2;

select * from t1 where (select n_1(s1))=(select n_1(s1));
select count( * ) from t2;





--echo  #between..and
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where stats between ((select n_1(s1))) and 9;
select count( * ) from t2;
select (select n_1(s1)) from t1 where stats between 0 and 9;
select count( * ) from t2;
select (select n_1(s1)) from t1 where stats between ((select n_1(s1))) and 9;
select count( * ) from t2;

--echo  #in
--echo  #一个参数
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where stats in((select n_1(s1)));
select count( * ) from t2;

select * from t1 where stats not in((select n_1(s1)));
select count( * ) from t2;

--echo  #两个参数
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where stats in (((select n_1(s1))) ,4);
select count( * ) from t2;

select * from t1 where stats not in (((select n_1(s1))) ,4);
select count( * ) from t2;

--echo  #and
drop table t1;
create table t1(id int , s1 int, s2 int);
insert into t1 values(1,1,3),(5,2,0),(3,3,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
delimiter /;
create function n_1(a int) returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return a;
end/
delimiter ;/
select count(*) from t1 where (id = (select n_1(s1)) or id = 2) and s1 < 3 ;
select * from t2;

drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where id =(select n_1(s1)) and id =(select n_1(s1));
select count( * ) from t2;


--echo  #or
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where id =(select n_1(s1)) or id =(select n_1(s1));
select count( * ) from t2;

--echo  #is null
--error 1051
drop table t4;
create table t4(s1 int,s2 int);
insert into t4 values(null,3);
--error 1305
drop function n_2;
delimiter /;
create function n_2(a int) returns int 
begin
  insert into t2 values(null,1,a);
  return a;
end/
delimiter ;/
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t4 where (select n_2(s1)) is null ;
select count(*) from t2;
select * from t4 where (select n_2(s1)) is not null ;
select count(*) from t2;



--echo  #where包含运算

drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where ((select n_1(s1)) div 0) is null;
select count( * ) from t2;


select * from t1 where ((select n_1(s1))+(select n_1(s1)))=0;
select count( * ) from t2;


select * from t1 where (select (select n_1(s1))+(select n_1(s1)) from t1 where id=1) =2;
select count( * ) from t2;


--echo  #like
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where (select n_1(s1)) like '%0%';
select count( * ) from t2;

select * from t1 where (select (select n_1(s1)) from t1 where id=1) like '%1%';
select count( * ) from t2;

