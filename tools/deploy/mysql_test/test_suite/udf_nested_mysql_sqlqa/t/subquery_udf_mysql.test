--echo   ##42037046 带参udf在having内无法传入字段
drop table t1;
create table t1(stats int primary key, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
replace into t1(stats) select (select n_1(s1)) from t3 group by (select n_1(s1)) having sum((select n_1(s1)))>0;
select count( * ) from t2;




