--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by '123';
grant all privileges on *.* to 'nxa'@'%' with grant option;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$obmysql_ms0,nxa,123,test,$obmysql_port);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database if exists nxa;
--enable_warnings
###创建db，切换db测试
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='strict_all_tables,no_zero_date,no_zero_in_date,error_for_division_by_zero ';
--result_format 4

--echo  #udf_3_6  append
--echo append
--echo udf嵌套函数

--error 1051
drop table t2;
create table t2(id int ,s1 int, s2 int);
--error 1051
drop table t1;
create table t1(stats int primary key, s1 int, s2 int);
insert into t1 values(1,1,3),(5,1,0),(3,1,0),(9,1,0),(2,7,0);
--error 1305
drop function n_2;
delimiter /;
create function n_2(a int) returns int
begin
  insert into t2 values(1,0,1);
  return a;
end/
delimiter ;/

SELECT n_2(ASCII(stats)) FROM t1 order by stats;
SELECT count(*) FROM t2;
SELECT n_2(INSTR(stats,3)) FROM t1 ORDER BY stats;
SELECT count(*) FROM t2;
SELECT n_2(LENGTH(stats)) FROM t1 ORDER BY stats;
SELECT count(*) FROM t2;
SELECT n_2(ABS(stats)) FROM t1 ORDER BY stats;
SELECT count(*) FROM t2;
SELECT n_2(CEIL(stats))FROM t1 ORDER BY stats;
SELECT count(*) FROM t2;
SELECT n_2(FLOOR(stats)) FROM t1 ORDER BY stats;
SELECT count(*) FROM t2;
SELECT n_2(SIN(stats)) FROM t1 ORDER BY stats;
SELECT count(*) FROM t2;
SELECT n_2(COS(stats)) FROM t1 ORDER BY stats;
SELECT count(*) FROM t2;
SELECT n_2(SIGN(stats)) FROM t1 ORDER BY stats;
SELECT count(*) FROM t2;
SELECT n_2(POWER(stats,3)) FROM t1 ORDER BY stats;
SELECT count(*) FROM t2;
SELECT n_2(MOD(3,stats)) FROM t1 ORDER BY stats;
SELECT count(*) FROM t2;
SELECT n_2(ROUND(stats)) FROM t1 ORDER BY stats;
SELECT count(*) FROM t2;
SELECT n_2(SQRT(stats)) FROM t1 ORDER BY stats;
SELECT count(*) FROM t2;
SELECT n_2(SUM(stats)) FROM t1 ORDER BY stats ;
SELECT count(*) FROM t2;
SELECT n_2(COUNT(stats)) FROM t1 ORDER BY stats ;
SELECT count(*) FROM t2;
SELECT n_2(MAX(stats)) FROM t1 ORDER BY stats ;
SELECT count(*) FROM t2;
SELECT n_2(MIN(stats)) FROM t1 ORDER BY stats ;
SELECT count(*) FROM t2;
SELECT n_2(AVG(stats)) FROM t1 ORDER BY stats ;
SELECT count(*) FROM t2;

--echo  多级函数嵌套
SELECT n_2(n_2(n_2(n_2(stats)))) FROM t1 order by stats;
SELECT count(*) FROM t2;
SELECT length(n_2(ASCII(n_2(ASCII(stats))))) FROM t1 order by stats;
SELECT count(*) FROM t2;
SELECT SUM(n_2(n_2(n_2(n_2(stats))))) FROM t1 ORDER BY stats ;
SELECT count(*) FROM t2;
SELECT MAX(n_2(n_2(n_2(stats)))) FROM t1 ORDER BY stats ;
SELECT count(*) FROM t2;


--echo 入参参数数量

drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table t1;
create table t1(id bigint, s1 char, s2 date,s3 int);
insert into t1(id,s1,s2,s3) values (3697483647,1,19981225,19981225);
--error 1305
drop function n_1;
delimiter /;
create function n_1(a int,b int,c int,d int,e date,f int,g int,h int,aa date,bb int,cc int,dd int,ee date,vv int,qq int,gg int,aaa date,bbb int,ccc int,ddd int,eee date,vvv int,qqq int,ggg int) returns varchar(200)
begin
declare a int;
  insert into t2 values(1,0,1);
  return concat(d,a);
end/
delimiter ;/


--echo 参数更新
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table t1;
create table t1(id int,s1 int);
insert into t1 values (1,5);
drop function n_1;
delimiter /;
create function n_1(a int) returns varchar(200)
begin
declare a int;
  select s1 into a from t1;
  set a:=9;
  insert into t2 values(a,0,1);
  return a;
end/
delimiter ;/
select n_1(id) from t1 ;
select * from t2 ;



--echo 修改特性
--echo 与mysql一致，deterministic无法修改
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table t1;
create table t1(id int,s1 int);
insert into t1 values (1,5);
drop function n_1;
delimiter /;
create function n_1(a char(20)) returns varchar(200)
begin
declare a int;
  select s1 into a from t1;
  set a:=9;
  insert into t2 values(a,0,1);
  return a;
end/
delimiter ;/
select n_1(id) from t1 ;
select * from t2 ;
--error 1064
alter function n_1  deterministic;
select n_1(id) from t1 ;
select * from t2 ;




--echo 单个窗口函数
--echo 窗口函数partition by udf 次数不一致，ob为空
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table if exists user;
create table  user (
  id int(0) not null auto_increment,
  name varchar(255)  default null,
  age int(0) null default null,
  primary key (id) 
);


insert into `user` values (1, 'zs', 11);
insert into `user` values (2, 'ls', 15);
insert into `user` values (3, 'zs', 22);
insert into `user` values (4, 'ww', 15);
insert into `user` values (5, 'ls', 18);
insert into `user` values (6, 'ww', 16);
insert into `user` values (7, 'zs', 11);
insert into `user` values (8, 'ls', 19);
insert into `user` values (9, 'ww', 16);


drop function n_1;
delimiter /;
create function n_1() returns varchar(200)  deterministic
begin
  insert into t2 values(1,0,1);
  return 1;
end/
delimiter ;/
drop table t2;
create table t2(id int ,s1 int, s2 int);
select 
rank() over(partition by n_1()order by name asc ) sort1
from user ;

select * from t2 ;

--echo not
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table if exists user;
create table  user (
  id int(0) not null auto_increment,
  name varchar(255)  default null,
  age int(0) null default null,
  primary key (id) 
);


insert into `user` values (1, 'zs', 11);
insert into `user` values (2, 'ls', 15);
insert into `user` values (3, 'zs', 22);
insert into `user` values (4, 'ww', 15);
insert into `user` values (5, 'ls', 18);
insert into `user` values (6, 'ww', 16);
insert into `user` values (7, 'zs', 11);
insert into `user` values (8, 'ls', 19);
insert into `user` values (9, 'ww', 16);


drop function n_1;
delimiter /;
create function n_1() returns varchar(200) not deterministic
begin
  insert into t2 values(1,0,1);
  return 1;
end/
delimiter ;/
drop table t2;
create table t2(id int ,s1 int, s2 int);
select 
rank() over(partition by n_1()order by name asc ) sort1
from user ;

select * from t2 ;




--echo 窗口函数
--echo 多个窗口函数不一致
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table if exists `user`;
create table `user`  (
  `id` int(0) not null auto_increment,
  `name` varchar(255)  default null,
  `age` int(0) null default null,
  primary key (`id`) using btree
);


insert into `user` values (1, 'zs', 11);
insert into `user` values (2, 'ls', 15);
insert into `user` values (3, 'zs', 22);
insert into `user` values (4, 'ww', 15);
insert into `user` values (5, 'ls', 18);
insert into `user` values (6, 'ww', 16);
insert into `user` values (7, 'zs', 11);
insert into `user` values (8, 'ls', 19);
insert into `user` values (9, 'ww', 16);


drop function n_1;
delimiter /;
create function n_1(c int) returns varchar(200) not deterministic
begin
  insert into t2 values(1,0,1);
  return c;
end/
delimiter ;/
drop table t2;
create table t2(id int ,s1 int, s2 int);
select 
rank() over(partition by n_1(age) order by age asc ) sort1,
dense_rank() over(partition by n_1(age) order by age asc ) sort2,
row_number() over(partition by n_1(age) order by age asc ) sort3
from `user` ;

select * from t2 ;




--echo return形式
drop table t2;
create table t2(id int unique  ,s1 int, s2 int);
insert into t2 values (1,5,2);
drop table t1;
create table t1(id int,s1 int);
insert into t1 values (1,5);
drop function n_1;
delimiter /;
create function n_1(a int) returns varchar(200)
begin
  
  insert into t2 values(a,0,1);
  replace into t2 values(a,0,1);
  return a;
end/
delimiter ;/
select n_1(s1) from t1 ;
select * from t2 ;




drop table t2;
create table t2(id int ,s1 int, s2 int);
drop table t1;
create table t1(s1 blob);
insert into t1(s1) values (19990224232401);
drop function n_1;
delimiter /;
create function n_1(c blob) returns varchar(200)
begin
declare aa int;
set @ee:=4;
set aa:=3;
set  @ee:=aa;
  insert into t2 values(@ee,0,1);
  return aa;
end/
delimiter ;/
select n_1(s1) from t1 ;
select * from t2;


drop table t2;
