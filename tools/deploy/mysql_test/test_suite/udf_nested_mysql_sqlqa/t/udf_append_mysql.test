select * from t1;


drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
drop function n_2;
delimiter /;
create function n_1() returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return 2;
end/

create function n_2(n_1 int) returns int not deterministic 
begin
  insert into t2 values(1,0,1);
  return n_1();
end/

delimiter ;/

select n_2(1) from t1;
select * from t2;



