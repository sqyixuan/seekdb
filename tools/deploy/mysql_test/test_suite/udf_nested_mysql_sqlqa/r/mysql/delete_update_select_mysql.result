drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,2,3),(1,0,0),(3,5,1);
drop table t2;
create table t2(id int,s1 int,s2 int);
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
drop table t3;
create table t3(id int ,s1 int, s2 int);
insert into t3 values(0,1,3),(1,7,1);
drop function n_4;
create function n_4() returns int deterministic 
begin
  declare a int;
  select s1 into a from t3 limit 1;
  update t2 set id=(select s2 from t1 where stats=1 ) where id =2;
  delete from t2 where id=(select s2 from t3 where id=1 );
  select id into @val from t2 limit 1;
  return a;
end/
