insert
drop function n_4;
create function n_4() returns int deterministic 
begin
  declare a int;
  select s1 into a from t3 limit 1;
  update t2 set id=a where id =1;
  delete from t2 where id=a;
  select id into @val from t2 limit 1;
  return a;
end/
