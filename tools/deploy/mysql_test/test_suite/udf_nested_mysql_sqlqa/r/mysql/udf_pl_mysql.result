loop循环
drop function n_1;
create function n_1() returns int
begin
declare i int default 0;
 loop_label:loop
  insert into t2 values(null,0,1);
   set i = i +1;
if i >= 4 then
   leave loop_label;
  end if;
  end loop;
  return 0;
end/
