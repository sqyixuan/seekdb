|    1 |    0 |    1 |
|    1 |    0 |    1 |
+------+------+------+
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where id =(select n_1(s1)) and id =(select n_1(s1));
+------+------+------+
| id   | s1   | s2   |
+------+------+------+
|    1 |    1 |    3 |
