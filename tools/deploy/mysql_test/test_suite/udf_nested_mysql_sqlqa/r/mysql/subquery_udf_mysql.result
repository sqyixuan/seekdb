#replace into
drop table t1;
create table t1(id int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t3;
create table t3(id int, s1 int, s2 int);
insert into t3 values(0,3,3),(1,0,0),(0,3,0);
drop function n_1;
create function n_1(a int) returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return a;
end/
drop table t2;
create table t2(id int ,s1 int, s2 int);
replace into t1 select (select n_1(s1)),1,2 from t3;
select count( * ) from t2;
+------------+
| count( * ) |
+------------+
|          3 |
+------------+
drop table t1;
create table t1(id int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
replace into t1 values((select n_1(s1) from t3 limit 1),1,2);
select count( * ) from t2;
+------------+
| count( * ) |
+------------+
|          1 |
