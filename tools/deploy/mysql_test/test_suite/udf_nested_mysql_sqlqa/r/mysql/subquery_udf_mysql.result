set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
drop database if exists nxa;
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='strict_all_tables,no_zero_date,no_zero_in_date,error_for_division_by_zero ';
result_format: 4
#udf_3_3 subquery_udf
#udf_1  select 
#udf_1_1  一般select
#前置条件
drop table t1;
ERROR 42S02: Unknown table 'nxa.t1'
create table t1(stats int , s1 int primary key, s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,2,0);
drop table t2;
ERROR 42S02: Unknown table 'nxa.t2'
create table t2(id int ,s1 int, s2 int);
drop function n_1;
ERROR 42000: FUNCTION nxa.n_1 does not exist
create function n_1(a int) returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return a;
end/
