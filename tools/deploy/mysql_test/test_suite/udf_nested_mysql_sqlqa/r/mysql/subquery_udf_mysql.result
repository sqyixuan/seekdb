#联合索引
drop procedure initData;
create procedure initData()
begin
declare count int default 1;
while count <= 100 DO
 insert into t1 (id,s1,s2) values (count,count,count); 
 set count = count +1;
end while;
end;
/
drop table t3;
ERROR 42S02: Unknown table 'nxa.t3'
drop table t1;
create table t1(id int primary key,s1 int, s2 int);
call initData();
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
create function n_1(a int) returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return a;
end/
#不走索引
create index ix_iot on t1(id,s1,s2);
delete from t2;
select id,s1,s2,(select n_1(s1)) from t1 where s1 =50 and s2= (select n_1(s1));
+----+------+------+------------------+
| id | s1   | s2   | (select n_1(s1)) |
+----+------+------+------------------+
| 50 |   50 |   50 |               50 |
+----+------+------+------------------+
select * from t2;
+------+------+------+
| id   | s1   | s2   |
+------+------+------+
|    1 |    0 |    1 |
|    1 |    0 |    1 |
|    1 |    0 |    1 |
|    1 |    0 |    1 |
|    1 |    0 |    1 |
|    1 |    0 |    1 |
|    1 |    0 |    1 |
+------+------+------+
#走索引
alter table t1 drop index ix_iot;
create index ix_iot on t1(s1,s2,id);
delete from t2;
select id,s1,s2,(select n_1(s1))from t1 where s1 =50 and s2= (select n_1(s1));
+----+------+------+------------------+
| id | s1   | s2   | (select n_1(s1)) |
+----+------+------+------------------+
| 50 |   50 |   50 |               50 |
+----+------+------+------------------+
select * from t2;
+------+------+------+
| id   | s1   | s2   |
+------+------+------+
|    1 |    0 |    1 |
|    1 |    0 |    1 |
|    1 |    0 |    1 |
|    1 |    0 |    1 |
|    1 |    0 |    1 |
|    1 |    0 |    1 |
+------+------+------+
#索引列排序
alter table t1 drop index ix_iot;
create index ix_iot on t1(id,s1,s2);
delete from t2;
select id,s1,s2,(select n_1(s1))from t1 where id =50 and s1= (select n_1(s1)) order by s2;
+----+------+------+------------------+
| id | s1   | s2   | (select n_1(s1)) |
+----+------+------+------------------+
| 50 |   50 |   50 |               50 |
+----+------+------+------------------+
select * from t2;
+------+------+------+
| id   | s1   | s2   |
+------+------+------+
|    1 |    0 |    1 |
|    1 |    0 |    1 |
+------+------+------+
