#udf_1_3 where子句
#前置条件
drop table t1;
create table t1(stats int , s1 int primary key, s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,2,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
create function n_1(a int) returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return a;
end/
#字段与函数值比较
select * from t1 where stats = (select n_1(s1));
+-------+----+------+
| stats | s1 | s2   |
+-------+----+------+
+-------+----+------+
select count(*) from t2;
+----------+
| count(*) |
+----------+
|        3 |
+----------+
select * from t1 where stats != (select n_1(s1));
+-------+----+------+
| stats | s1 | s2   |
+-------+----+------+
|     1 |  0 |    0 |
|     2 |  1 |    3 |
|     0 |  2 |    0 |
+-------+----+------+
select count(*) from t2;
+----------+
| count(*) |
+----------+
|        6 |
+----------+
select * from t1 where stats < (select n_1(s1));
+-------+----+------+
| stats | s1 | s2   |
+-------+----+------+
|     0 |  2 |    0 |
+-------+----+------+
select count(*) from t2;
+----------+
| count(*) |
+----------+
|        9 |
+----------+
select * from t1 where stats > (select n_1(s1));
+-------+----+------+
| stats | s1 | s2   |
+-------+----+------+
|     1 |  0 |    0 |
|     2 |  1 |    3 |
+-------+----+------+
select count(*) from t2;
+----------+
| count(*) |
+----------+
|       12 |
+----------+
select * from t1 where stats <= (select n_1(s1));
+-------+----+------+
| stats | s1 | s2   |
+-------+----+------+
|     0 |  2 |    0 |
+-------+----+------+
select count(*) from t2;
+----------+
| count(*) |
+----------+
|       15 |
+----------+
select * from t1 where stats >= (select n_1(s1));
+-------+----+------+
| stats | s1 | s2   |
+-------+----+------+
|     1 |  0 |    0 |
|     2 |  1 |    3 |
+-------+----+------+
select count(*) from t2;
+----------+
| count(*) |
+----------+
|       18 |
+----------+
