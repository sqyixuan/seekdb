| count( * ) |
+------------+
|          1 |
+------------+
drop table t1;
create table t1(stats int, s1 int, s2 int);
insert into t1 values(0,1,3),(1,0,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
update t1 set stats=(select (select n_1(s1)) from t3 group by (select n_1(s1)) having max((select n_1(s1))) limit 1);
select count( * ) from t2;
+------------+
| count( * ) |
+------------+
|          1 |
