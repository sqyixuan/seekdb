子分区
drop table t1;
CREATE TABLE t1 (id INT, s1 int,s2 int)
    PARTITION BY RANGE( id )
    SUBPARTITION BY HASH( s1 )
    SUBPARTITIONS 2 (
        PARTITION p0 VALUES LESS THAN (1990),
        PARTITION p1 VALUES LESS THAN (2000),
        PARTITION p2 VALUES LESS THAN MAXVALUE
    );
insert into t1 values (1,1990,4),(2,1991,3),(3,2009,2),(4,1,1);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
