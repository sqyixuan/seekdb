distinct+order by
drop table t1;
create table t1(id int primary key, s1 int, s2 int);
insert into t1 values(1,1,3),(5,1,0),(3,1,0),(9,1,0),(2,7,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
create function n_1() returns int deterministic
begin
  insert into t2 values(1,0,1);
  return 1;
end/
