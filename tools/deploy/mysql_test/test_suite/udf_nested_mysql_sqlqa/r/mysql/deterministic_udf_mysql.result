#聚合函数
drop table t2;
create table t2(id int ,s1 int, s2 int);
select sum(n_1()) from t1  ;
+------------+
| sum(n_1()) |
+------------+
|          0 |
+------------+
select count(*) from t2;
+----------+
| count(*) |
+----------+
|        1 |
+----------+
delete from t2;
select count(n_1()) from t1  ;
+--------------+
| count(n_1()) |
+--------------+
|            3 |
+--------------+
select count(*) from t2;
+----------+
| count(*) |
+----------+
|        1 |
+----------+
delete from t2;
select avg(n_1()) from t1  ;
+------------+
| avg(n_1()) |
+------------+
|     0.0000 |
+------------+
select count( * ) from t2;
+------------+
| count( * ) |
+------------+
|          2 |
+------------+
delete from t2;
select max(n_1()) from t1 ;
+------------+
| max(n_1()) |
+------------+
|          0 |
+------------+
select count( * ) from t2;
+------------+
| count( * ) |
+------------+
|          1 |
+------------+
delete from t2;
select min(n_1()) from t1 ;
+------------+
| min(n_1()) |
+------------+
|          0 |
+------------+
select count( * ) from t2;
+------------+
| count( * ) |
+------------+
|          1 |
+------------+
#udf_1_3 where子句
#43668126 udf定义为deterministic，udf在where后ob会执行两次，修复后统一验证
前置条件
drop table kong;
create table kong(stats int );
drop table t1;
create table t1(stats int , s1 int primary key, s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,2,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
create function n_1() returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return 0;
end/
字段与函数值比较
select * from t1 where stats = n_1();
+-------+----+------+
| stats | s1 | s2   |
+-------+----+------+
|     0 |  2 |    0 |
+-------+----+------+
select count(*) from t2;
+----------+
| count(*) |
+----------+
|        2 |
+----------+
select * from t1 where stats != n_1();
+-------+----+------+
| stats | s1 | s2   |
+-------+----+------+
|     1 |  0 |    0 |
|     2 |  1 |    3 |
+-------+----+------+
select count(*) from t2;
+----------+
| count(*) |
+----------+
|        4 |
+----------+
select * from t1 where stats < n_1();
+-------+----+------+
| stats | s1 | s2   |
+-------+----+------+
+-------+----+------+
select count(*) from t2;
+----------+
| count(*) |
+----------+
|       12 |
+----------+
select * from t1 where stats > n_1();
+-------+----+------+
| stats | s1 | s2   |
+-------+----+------+
|     1 |  0 |    0 |
|     2 |  1 |    3 |
+-------+----+------+
select count(*) from t2;
+----------+
| count(*) |
+----------+
|       20 |
+----------+
select * from t1 where stats <= n_1();
+-------+----+------+
| stats | s1 | s2   |
+-------+----+------+
|     0 |  2 |    0 |
+-------+----+------+
select count(*) from t2;
+----------+
| count(*) |
+----------+
|       28 |
+----------+
select * from t1 where stats >= n_1();
+-------+----+------+
| stats | s1 | s2   |
+-------+----+------+
|     1 |  0 |    0 |
|     2 |  1 |    3 |
|     0 |  2 |    0 |
+-------+----+------+
select count(*) from t2;
+----------+
| count(*) |
+----------+
|       36 |
+----------+
函数值比较
drop table t2;
create table t2(id int ,s1 int, s2 int);
select * from t1 where n_1()=0;
