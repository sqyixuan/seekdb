分区
rang分区
drop table t1;
create table t1(
  pid  int primary key,
  pname varchar(30)
) partition by range(pid)(
  partition p1 values less than(1000) ,
  partition p2 values less than(2000) ,
  partition p3 values less than(maxvalue)
);
insert into t1 (pid, pname) values (1, '瑶瑶');
insert into t1 (pid, pname) values (2, '西西');
insert into t1 (pid, pname) values (1500, '倩倩');
insert into t1 (pid, pname) values (1600, '菲菲');
insert into t1 (pid, pname) values (3000, '小花');
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
create function n_1() returns int deterministic
begin
  insert into t2 values(1,0,1);
  return 2;
end/
select * from t1  where pid=n_1() ;
+-----+--------+
| pid | pname  |
+-----+--------+
|   2 | 西西   |
+-----+--------+
select * from t2;
