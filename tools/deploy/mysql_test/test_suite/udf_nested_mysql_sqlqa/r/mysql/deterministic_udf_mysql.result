| stats | s1 | s2   |
+-------+----+------+
|     1 |  0 |    0 |
|     2 |  1 |    3 |
|     0 |  2 |    0 |
+-------+----+------+
select count( * ) from t2;
+------------+
| count( * ) |
+------------+
|          1 |
+------------+
select * from t1 where n_1()=n_1();
+-------+----+------+
| stats | s1 | s2   |
+-------+----+------+
|     1 |  0 |    0 |
|     2 |  1 |    3 |
|     0 |  2 |    0 |
+-------+----+------+
select count( * ) from t2;
