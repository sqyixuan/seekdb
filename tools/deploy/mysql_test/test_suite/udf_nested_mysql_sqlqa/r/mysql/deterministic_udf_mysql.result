drop table t1;
create table t1(stats int , s1 int primary key, s2 int);
insert into t1 values(2,1,3),(1,0,0),(null,2,0);
drop table t2;
create table t2(id int ,s1 int, s2 int);
drop function n_1;
create function n_1() returns int deterministic 
begin
  insert into t2 values(1,0,1);
  return null;
end/
