--result_format 4
connection default;

--echo # ◆ 准备测试用户
--disable_warnings
drop user if exists fk_testuser;
drop database if exists fk_testuser_db;
create user 'fk_testuser' identified by 'fk_testuser';
CREATE DATABASE IF NOT EXISTS  fk_testuser_db;
grant all on *.* to fk_testuser WITH GRANT OPTION;

drop user if exists fk_testuser2;
drop database if exists fk_testuser_db2;
create user 'fk_testuser2' identified by 'fk_testuser2';
CREATE DATABASE IF NOT EXISTS  fk_testuser_db2;
grant all on *.* to fk_testuser2 WITH GRANT OPTION;
--enable_warnings

--source mysql_test/include/check_schema_sync.inc
connect (conn1_sessiion1,$obmysql_ms0,fk_testuser,fk_testuser,fk_testuser_db,$obmysql_port);
connect (conn1_sessiion2,$obmysql_ms0,fk_testuser,fk_testuser,fk_testuser_db,$obmysql_port);
connect (conn2,$obmysql_ms0,fk_testuser2,fk_testuser2,fk_testuser_db2,$obmysql_port);
connection conn1_sessiion1;

--disable_warnings
drop table if exists t6;
drop table if exists t5;
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

--echo ##################################
--echo ###### 复合外键
create table t1(c1 int primary key,c2 int,c3 int,c4 int,c5 int,c6 int);
ALTER TABLE t1 ADD INDEX index1 (c1,c2);
ALTER TABLE t1 ADD INDEX index2 (c2,c1,c3);
ALTER TABLE t1 ADD INDEX index3 (c3,c2,c1,c4);
ALTER TABLE t1 ADD INDEX index4 (c2,c3,c4,c5,c6 desc);

create table t2(c1 int primary key,c2 int,c3 int,c4 int,c5 int,c6 int);

alter table t2 add CONSTRAINT fk1 foreign key (c1,c2) references t1(c1,c2) on update cascade;
alter table t2 add CONSTRAINT fk2 foreign key (c1,c2) references t1(c2,c1) on update cascade;
alter table t2 add CONSTRAINT fk3 foreign key (c1,c2,c3) references t1(c2,c1,c3) on update cascade;
alter table t2 add CONSTRAINT fk4 foreign key (c1,c2,c3) references t1(c1,c2,c3) on update cascade;
alter table t2 add CONSTRAINT fk5 foreign key (c2,c3,c4) references t1(c2,c3,c4) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk6 foreign key (c2,c3,c4) references t1(c3,c4,c5) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk7 foreign key (c2,c3,c4) references t1(c4,c5,c6) on update cascade;
alter table t2 add CONSTRAINT fk8 foreign key (c2,c3,c4,c5,c6) references t1(c6,c5,c4,c3,c2) on update cascade;
alter table t2 add CONSTRAINT fk9 foreign key (c2,c3,c4,c5,c6) references t1(c2,c3,c4,c5,c6) on update cascade;

ALTER TABLE t1 drop INDEX index1;
--error 1553
ALTER TABLE t1 drop INDEX index2;
--error 1553
ALTER TABLE t1 drop INDEX index3;
--error 1553
ALTER TABLE t1 drop INDEX index4;

drop table t2;
drop table t1;

--echo ##################################
--echo ###### 索引表达式
create table t1(c1 int primary key,c2 int,c3 int,c4 int,c5 int,c6 int);

CREATE INDEX index1 ON t1 (c2 ASC);
CREATE INDEX index2 ON t1 ((c3 + c4));

create table t2(c1 int primary key,c2 int,c3 int,c4 int,c5 int,c6 int);

alter table t2 add CONSTRAINT fk1 foreign key (c2) references t1(c2) on update cascade;
--error 1064
alter table t2 add CONSTRAINT fk2 foreign key (c3+c4) references t1(c3+c4) on update cascade;
--error 1064
alter table t2 add CONSTRAINT fk2 foreign key ((c3+c4)) references t1(c3+c4) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk2 foreign key (c3,c4) references t1(c3,c4) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk2 foreign key (c3) references t1(c3) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk2 foreign key (c4) references t1(c4) on update cascade;

drop table t2;
drop table t1;

--echo ##################################
--echo ###### 不同方式创建索引
create table t1(c1 int primary key,c2 int,c3 int,c4 int,c5 int,c6 int,
    index index1 (c2),
    key index2(c3));
CREATE INDEX index3 ON t1 (c4 asc);
CREATE unique INDEX index4 ON t1 (c5);
ALTER TABLE t1 ADD INDEX index5 (c6);
ALTER TABLE t1 ADD key index6 (c1,c2);

create table t2(c1 int primary key,c2 int,c3 int,c4 int,c5 int,c6 int);

alter table t2 add CONSTRAINT fk1 foreign key (c1) references t1(c1) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk2 foreign key (c2) references t1(c2) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk3 foreign key (c3) references t1(c3) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk4 foreign key (c4) references t1(c4) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk5 foreign key (c5) references t1(c5) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk6 foreign key (c6) references t1(c6) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk7 foreign key (c1,c2) references t1(c1,c2) on update cascade on delete cascade;

#重命名索引
ALTER TABLE t1 RENAME INDEX index1 TO new_index1;
ALTER TABLE t1 RENAME INDEX index2 TO new_index2;
ALTER TABLE t1 RENAME INDEX index3 TO new_index3;
ALTER TABLE t1 RENAME INDEX index4 TO new_index4;
ALTER TABLE t1 RENAME INDEX index5 TO new_index5;
ALTER TABLE t1 RENAME INDEX index6 TO new_index6;

insert into t1 values(1,2,3,4,5,6),(2,3,4,5,6,7);

--error 1452
insert into t2 values(1,3,4,5,6,7);
--error 1452
insert into t2 values(2,2,4,5,6,7);

insert into t2 values(1,2,4,5,6,7);
insert into t2 values(2,3,4,5,6,7);

select * from t1 order by 1,2,3;
select * from t2 order by 1,2,3;

--error 1701
truncate table t1;

delete from t1 where c1=1;
select * from t1 order by 1,2,3;
select * from t2 order by 1,2,3;

--error 3730
drop table t1;

ALTER TABLE t2 drop foreign key fk1,drop foreign key fk2;
ALTER TABLE t2 drop foreign key fk3,drop foreign key fk4,drop foreign key fk5,drop foreign key fk6,drop foreign key fk7;

drop table t1;
drop table t2;

--echo ##################################
--echo ######  重命名列
create table `t1`(`c1` int primary key,`c2` int,`c3` int,`c4` int unique,`c5` int,`c6` int,
    index index1 (`c2`),
    key index2(`c3`));

create table t2(c1 int primary key,c2 int,c3 int,c4 int,c5 int,c6 int);

alter table t2 add CONSTRAINT fk0 foreign key (c1) references t1(c1) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk1 foreign key (c2) references t1(`c2`) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk2 foreign key (`c3`) references t1(c3) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk3 foreign key (`c1`) references t1(`c1`) on update cascade on delete cascade;

#重命名列
ALTER TABLE t1 CHANGE c1 t1 int;

alter table t2 add CONSTRAINT fk4 foreign key (c4) references t1(t1) on update cascade on delete cascade;
--error 1215
alter table t2 add CONSTRAINT fk5 foreign key (c5,c6) references t1(t1,t1) on update cascade on delete cascade;

#重命名列
--error 5320
ALTER TABLE t1 CHANGE c2 t2 SMALLINT;
--error 5320
ALTER TABLE t1 CHANGE c2 t2 BIGINT;
ALTER TABLE t1 CHANGE c2 t2 INTEGER;

alter table t2 add CONSTRAINT fk6 foreign key (c2) references t1(t2) on update cascade on delete cascade;

ALTER TABLE t1 ADD INDEX index3 (t1,t2);

alter table t2 add CONSTRAINT fk7 foreign key (c1,c2) references t1(t1,t2) on update cascade on delete cascade;

#删除列
--error 5320
ALTER TABLE t1 DROP COLUMN t1;
--error 5320
ALTER TABLE t1 DROP COLUMN t2;
--error 5320
ALTER TABLE t1 DROP COLUMN c3;
ALTER TABLE t1 DROP COLUMN c4;

drop table t2;
drop table t1;

--echo ##################################
--echo ######  自引用
--error 1215
create table `t1`(`c1` int primary key,`c2` int,`c3` int,
    CONSTRAINT `fk` FOREIGN KEY (`c2`) REFERENCES `t1`(`c3`) ON UPDATE RESTRICT ON DELETE RESTRICT);

create table `t1`(`c1` int primary key,`c2` int,`c3` int,
    CONSTRAINT `fk` FOREIGN KEY (`c2`) REFERENCES `t1`(`c1`) ON UPDATE RESTRICT ON DELETE RESTRICT);

--error 0,1305
drop PROCEDURE insert_t1;

DELIMITER /;
CREATE PROCEDURE insert_t1()
BEGIN
    DECLARE i INT DEFAULT 1;
    WHILE i <= 1000 DO
        INSERT INTO t1 VALUES (i,i,i + 99);
        SET i = i + 1;
    END WHILE;
END;
/
DELIMITER ;/

CALL insert_t1();

drop table t1;

--echo ##################################
--echo ###### 跨 schema 引用
--echo ## 连接用户2
connection conn2;

create table t1(id int,c1 int not null default 1,c2 int,index index1(c1));
insert into t1 values(1,1,1),(2,2,2),(3,2,2),(4,3,3),(5,3,3),(6,3,3);

--echo ## 连接用户1
connection conn1_sessiion1;

create table t2(id int primary key,c1 int, c2 int,index index1(c1));
alter table t2 add foreign key(c1) references fk_testuser_db2.t1(c1) on update cascade on delete cascade;

insert into t2 values(1,1,1),(2,2,2),(3,3,3),(4,3,3);
select * from fk_testuser_db2.t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;

update fk_testuser_db2.t1 set c1 = 30 where c1 = 3 and id = 4;
select * from fk_testuser_db2.t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;

delete from fk_testuser_db2.t1 where c1 = 2;
select * from fk_testuser_db2.t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;

drop table t2;
drop table fk_testuser_db2.t1;

--echo ##################################
--echo ###### schema.父表 
create table t1(id int,c1 int not null default 1,c2 int,index index1(c1));
create table t2(id int primary key,c1 int, c2 int,index index1(c1));

--error 1064
alter table t2 add foreign key(c1) references t1(t1.c1) on update cascade on delete cascade;
alter table t2 add foreign key(c1) references fk_testuser_db.t1(c1) on update cascade on delete cascade;

insert into t1 values(1,1,1),(2,2,2),(3,2,2),(4,3,3),(5,3,3),(6,3,3);
insert into t2 values(1,1,1),(2,2,2),(3,3,3),(4,3,3);
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;

update t1 set c1 = 30 where c1 = 3 and id = 4;
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;

delete from t1 where c1 = 2;
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;

drop table t2;
drop table t1;

--echo ##################################
--echo ###### 父表 create table t1 like
--error 0,1051
drop table temp_t1;
create table temp_t1(id int,c1 int,c2 int,index index1(c1));

create table t1 like temp_t1;

--error 0,1051
drop table temp_t2;
create table temp_t2(id int primary key,c1 int, c2 int,index index1(c1));
alter table temp_t2 add CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade;

create table t2 like temp_t2;
alter table t2 add CONSTRAINT fk2 foreign key(c1) references temp_t2(c1) on update cascade on delete cascade;

show create table temp_t1;
show create table temp_t2;
show create table t1;
show create table t2;

insert into t1 values(1,1,1),(2,2,2),(3,2,2),(4,3,3),(5,3,3),(6,3,3);
insert into temp_t2 values(1,1,1),(2,2,2),(3,3,3),(4,3,3);
insert into t2 values(1,1,1),(2,2,2),(3,3,3),(4,3,3);
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;
select * from temp_t2 order by 1,2 for update;

update t1 set c1 = 30 where c1 = 3 and id = 4;
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;
select * from temp_t2 order by 1,2 for update;

delete from t1 where c1 = 2;
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;

drop table t2;
drop table temp_t2;
drop table t1;
drop table temp_t1;

--echo ##################################
--echo ###### 分区表
create table t1(
    id int,
    c1 int,
    c2 int,
    index index1(c1)) 
    PARTITION BY HASH(c1) PARTITIONS 6;

create table t2(
    id int,
    c1 int,
    c2 int) 
    PARTITION BY HASH(c1) PARTITIONS 4;

alter table t2 add foreign key(c1) references t1(c1) on update cascade on delete cascade;

insert into t1 values(1,1,1),(2,2,2),(3,2,2),(4,3,3),(5,3,3),(6,3,3);
insert into t2 values(1,1,1),(2,2,2),(3,3,3),(4,3,3);

SELECT * FROM t1 PARTITION(p0, p1) order by 1,2;
SELECT * FROM t1 PARTITION(p2) order by 1,2;
SELECT * FROM t1 PARTITION(p3) order by 1,2;

DELETE FROM t1 PARTITION(p0, p1);
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;

DELETE FROM t1 PARTITION(p2);
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;

drop table t2;
drop table t1;

connection default;
--disable_warnings
--error 0,600
drop user fk_testuser;
--error 0,600
drop user fk_testuser2;
--enable_warnings
purge recyclebin;
