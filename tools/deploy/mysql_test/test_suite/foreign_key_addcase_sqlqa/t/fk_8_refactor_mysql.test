--echo ## 14、子表对应多个父表 t3->t1,t2
create table t1(id int primary key,c1 int,c2 int,index index1(c1));
create table t2(id int primary key,c1 int,c2 int,index index1(c2));

create table t3(id int primary key,c1 int,c2 int);
alter table t3 add CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade;
alter table t3 add CONSTRAINT fk2 foreign key(c2) references t2(c2) on update cascade on delete cascade;

