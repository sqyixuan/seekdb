select * from t3 order by 1,2,3;

#更新 t1,t3
UPDATE t1,t3 SET t1.c1 = t1.c2,t3.c1 = 1 WHERE t1.c2 = t3.c2 and t1.c2 = 2;
select * from t1 order by 1,2,3;
select * from t2 order by 1,2,3;
select * from t3 order by 1,2,3;

#更新 t2,t3
--error 1451
UPDATE t2,t3 SET t2.c1 = 1,t3.c1 = 3 WHERE t2.c2 = t3.c2 and t2.c2 = 3;
select * from t1 where c2 = 3 order by 1,2,3;
select * from t2 where c2 = 3 order by 1,2,3;
select * from t3 where c2 = 3 order by 1,2,3;

UPDATE t2,t3 SET t2.c1 = 2,t3.c1 = 1 WHERE t2.c2 = t3.c2 and t2.c2 = 3;
select * from t1 where c2 = 3 order by 1,2,3;
select * from t2 where c2 = 3 order by 1,2,3;
select * from t3 where c2 = 3 order by 1,2,3;

UPDATE t2,t3 SET t2.c1 = 3,t3.c1 = 4 WHERE t2.c2 = t3.c2 and t2.c2 = 3;
select * from t1 where c2 = 3 order by 1,2,3;
select * from t2 where c2 = 3 order by 1,2,3;
select * from t3 where c2 = 3 order by 1,2,3;

UPDATE t2,t3 SET t2.c1 = 2,t3.c1 = null WHERE t2.c2 = t3.c2 and t2.c2 = 3;
select * from t1 where c2 = 3 order by 1,2,3;
select * from t2 where c2 = 3 order by 1,2,3;
select * from t3 where c2 = 3 order by 1,2,3;

UPDATE t2,t3 SET t2.c1 = 4,t3.c1 = 4 WHERE t2.c2 = t3.c2 and t2.c2 = 3;
select * from t1 where c2 = 3 order by 1,2,3;
select * from t2 where c2 = 3 order by 1,2,3;
select * from t3 where c2 = 3 order by 1,2,3;

drop table t3;
drop table t2;
drop table t1;

