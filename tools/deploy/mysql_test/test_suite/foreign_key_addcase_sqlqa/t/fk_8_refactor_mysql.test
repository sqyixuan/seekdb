--result_format 4
connection default;

--echo # ◆ 准备测试用户
--disable_warnings
drop user if exists fk_testuser;
drop database if exists fk_testuser_db;
create user 'fk_testuser' identified by 'fk_testuser';
CREATE DATABASE IF NOT EXISTS  fk_testuser_db;
grant all on *.* to fk_testuser WITH GRANT OPTION;
--enable_warnings

--source mysql_test/include/check_schema_sync.inc
connect (conn1_sessiion1,$obmysql_ms0,fk_testuser,fk_testuser,fk_testuser_db,$obmysql_port);
connect (conn1_sessiion2,$obmysql_ms0,fk_testuser,fk_testuser,fk_testuser_db,$obmysql_port);
connection conn1_sessiion1;

--disable_warnings
drop table if exists t6;
drop table if exists t5;
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

--echo ##################################
--echo ###### 级联操作，触发触发器
create table t1(c1 int primary key, id int);
create table t2(c1 int primary key, c2 int, id int);
create table t3(c1 int, c2 int, id int, c3 varchar(2000));
alter table t2 add foreign key(c2) references t1(c1) on update cascade on delete cascade;

insert into t1 values(1, 110),(2, 111);
insert into t2 values(1, 1, 110),(2, 1, 110),(3, 2, 111);

delimiter /;
CREATE TRIGGER tri1 BEFORE update ON t2 FOR EACH ROW
BEGIN
   insert into t3 values(old.c1,old.c2,old.id,'表t2有更新，触发触发器，记录旧值');
   update t1 set c1 = c1 * 10 where id = 110;
END;
/
delimiter ;/

select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;
select * from t3 order by 1,2 for update;

#更新子表
--error 1456
update t2 set c2 = 1 where c1 = 3;

#ob 报错，mysql 成功,已知问题
--error 1456
update t2 set c2 = 2,id=1110 where c1 = 3;
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;
select * from t3 order by 1,2 for update;

--error 1456
update t2 set c2 = 1 where c1 = 2;
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;
select * from t3 order by 1,2 for update;

--error 1456
update t2 set c2 = 2 where c1 = 2;
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;
select * from t3 order by 1,2 for update;

--error 1456
update t2 set c2 = null where c1 = 1;
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;
select * from t3 order by 1,2 for update;

#更新父表，级联操作 ob 会触发子表上定义的触发器,mysql 不会
update t1 set c1 = c1 * 10 where c1 = 1;

select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;
select * from t3 order by 1,2 for update;

drop table t3;
drop table t2;
drop table t1;

--echo ##################################
--echo ###### Prepared 语句创建表
PREPARE stmt1 FROM 'create table t1(id int primary key,c1 int,c2 int,index index1(c1,c2))';
EXECUTE stmt1;

PREPARE stmt2 FROM 'create table t2(id int primary key,c1 int,c2 int,foreign key(c1) references t1(c1) on update cascade on delete cascade)';
EXECUTE stmt2; 

PREPARE stmt3 FROM 'alter table t2 add foreign key(c1,c2) references t1(c1,c2) on update cascade on delete cascade;';
EXECUTE stmt3;

insert into t1 values(1,1,1),(2,2,2),(3,2,2),(4,3,3);
insert into t2 values(1,1,1),(2,3,3);

#mysql失败，ob成功
update t1 set c1 = 10 where id = 1;
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;

drop table t2;
drop table t1;

--echo ##################################
--echo ###### 非unique key的特性
create table t1(id int primary key,c1 int,c2 int ,index index1(c1));
create table t2(id int primary key,c1 int,c2 int);
alter table t2 add CONSTRAINT fk1  foreign key(c1) references t1(c1) on update cascade on delete cascade;

insert into t1 values(1,1,1),(2,1,1),(3,1,1),(4,1,1);
insert into t1 values(5,2,2),(6,2,2),(7,2,2),(8,2,2),(9,2,2),(10,2,2);
