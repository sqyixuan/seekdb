select * from t2 order by 1,2,3;

--echo ## 5.2、多表删除父表行数据
delete from t1;
delete from t2;
insert into t1 select * from t1_bk;
insert into t2 select * from t2_bk;

DELETE t1, t2 FROM t1, t2 WHERE t1.c1 = t2.c1 AND (t1.id = 5 or t2.id = 4);
select * from t1 order by 1,2,3;
select * from t2 order by 1,2,3;

delete from t1;
delete from t2;
insert into t1 select * from t1_bk;
insert into t2 select * from t2_bk;

--error 1066
DELETE t1, t1 FROM t1, t1 WHERE t1.c1 = t1.c1 AND (t1.id = 1 or t1.id = 10);
--error 1235
DELETE t1, t2 FROM t1, t1 as t2 WHERE t1.c1 = t2.c1 AND (t1.id = 1 or t2.id = 10);

--error 1066
DELETE FROM t1, t1 USING t1, t1 WHERE t1.c1 = t1.c1 AND (t1.id = 1 or t1.id = 10);
--error 1235
DELETE FROM t1, t2 USING t1, t1 t2 WHERE t1.c1 = t2.c1 AND (t1.id = 1 or t2.id = 10);
--error 1235
DELETE FROM t1, t2 USING t1, (select * from t1) t2 WHERE t1.c1 = t2.c1 AND (t1.id = 1 or t2.id = 10);

select * from t1 order by 1,2,3;
select * from t2 order by 1,2,3;

