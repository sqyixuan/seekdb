insert into t2 values(1,1,1);
insert into t2 values(2,2,2),(3,2,2);
insert into t2 values(4,3,3),(5,3,3),(6,3,3);

--error 0,1051
drop table t1_bk;
create table t1_bk as select * from t1;

--error 0,1051
drop table t2_bk;
create table t2_bk as select * from t2;

select * from t1 order by 1,2,3;
select * from t2 order by 1,2,3;

--echo ## 1、更新父表部分数据
update t1 set c1 = c1 * 2 where c2 = 1;
select * from t1 where c2 = 1 order by 1,2,3;
select * from t2 where c2 = 1 order by 1,2,3;

update t1 set c1 = c1 * 3 where c2 = 2 and id between 5 and 7;
select * from t1 where c2 = 2 order by 1,2,3;
select * from t2 where c2 = 2 order by 1,2,3;

update t1 set c1 = c1 * 4 where c2 = 2;
select * from t1 where c2 = 2 order by 1,2,3;
select * from t2 where c2 = 2 order by 1,2,3;

--echo ## 2、锁父表 LOCK TABLES
LOCK TABLES t1 WRITE;
--error 1452
insert into t2 values(7,1,1);

#ob 成功，mysql 报错
#官网说明(当前版本的 OceanBase 数据库对 MySQL 模式下的 LOCK TABLES 语句将被忽略，并不会对表上锁)
insert into t2 values(7,2,2);

UNLOCK TABLES;
--error 1452
insert into t2 values(8,1,1);
insert into t2 values(8,2,2);
select * from t1 order by 1,2,3;
select * from t2 where c2 = 2 order by 1,2,3;

##锁父表
LOCK TABLES t1 READ;
--error 1452
insert into t2 values(9,1,1);
insert into t2 values(9,2,2);

UNLOCK TABLES;
--error 1452
insert into t2 values(10,1,1);
insert into t2 values(10,2,2);
select * from t1 order by 1,2,3;
select * from t2 where c2 = 2 order by 1,2,3;

--echo ## 3、行锁父表 FOR UPDATE 排他锁（部分数据加了锁）
