--error 5320
alter table t4 CHANGE COLUMN c2 c2 char(100);

select * from t1  where c1 = 170 for update;

--disable_warnings
drop table if exists t6;
drop table if exists t5;
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

################################
#### 多个表的更新
create table t1(a int primary key, id int);
create table t2(b int primary key, a int unique, id int);
create table t3(c int primary key, a int unique, id int);

alter table t2 add CONSTRAINT fk1 foreign key(a) references t1(a) on update cascade on delete cascade;
alter table t3 add CONSTRAINT fk2 foreign key(a) references t2(a) on update cascade on delete cascade;
insert into t1 values(1, 110);
insert into t2 values(1, 1, 110);
insert into t3 values(1, 1, 110);

#### update
# ob 报错，oracle 成功（因为外键+update形成了环）
--error 1451
update t1, t2, t3 set t1.a = 10, t2.b = 20 where t1.id = t2.id and t2.id = t3.id;

update t1 set t1.a = 10 where t1.id = 1;
update t1 set t1.a = 11 where t1.id = 110;

select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;
select * from t3 order by 1,2 for update;

#### REPLACE
REPLACE INTO t1 VALUES (11, 1110);

select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;
select * from t3 order by 1,2 for update;

REPLACE INTO t1 VALUES (12, 111),(13, 112),(14,113);
insert into t2 values(2, 13, 112);
insert into t3 values(2, 13, 112);
--error 1452
insert into t3 values(3, 12, 111);

update t1 set t1.a = 130 where t1.id = 112;

select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;
select * from t3 order by 1,2 for update;

#### TRUNCATE 
--error 1701
TRUNCATE TABLE t1;

#### delete
delete from t1 where id = 112;

select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;
select * from t3 order by 1,2 for update;

--disable_warnings
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

################################
#### 自引用
create table t1 (c1 int primary key, c2 int, 
	foreign key (c2) references t1(c1) on update cascade on delete cascade);

set foreign_key_checks=off;
insert into t1 values (1,1),(2,2),(3,3);
insert into t1 values (4,40),(5,50),(6,60);
select * from t1 order by 1,2 for update;

set foreign_key_checks=on;
update t1 set c1 = c2 where c1 = 1;
update t1 set c1 = c2 where c1 = 4;
select * from t1 order by 1,2 for update;

--error 1451
update t1 set c1 = c2*10 where c1 = 1;

# ob 成功，mysql 报错
update t1 set c1 = c1,c2 = c2 where c1 = 1;
update t1 set c1 = c2,c2 = c1 where c1 = 1;
select * from t1 order by 1,2 for update;

# ob 成功，mysql 报错
update t1 set c1 = c1,c2 = c2 where c1 = 5;
update t1 set c1 = c2,c2 = c1 where c1 = 6;
select * from t1 order by 1,2 for update;

update t1 set c1 = 4, c2 = 4 where c1 = 1;
select * from t1 order by 1,2 for update;

drop table t1;

################################
#### 外键引用生成列
create table t1(c1 int primary key,c2 int AS (c1*c1) STORED, id int);
create index t1index1 on t1(c2); 
insert into t1(c1,id) values(1,1),(2,2),(3,3);

create table t2(c1 int primary key,c2 int, id int);
alter table t2 add foreign key(c2) references t1(c2) on update cascade on delete cascade;
insert into t2 values(1,1,1),(2,4,2),(3,9,3);

select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;

update t1 set c1 = 4 where c1 = 1;
update t2 set c2 = 9 where c1 = 2;
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;

delete from t1 where c1 = 2;
select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;

--error 1451
update t1,t2 set t1.c1 = 6,t2.id=30 where t1.id=t2.id and t1.c1 = 3;
update t1,t2 set t1.c1 = 6 where t1.id=t2.id and t1.c1 = 3;
select * from t1,t2 order by 1,2 for update;

--disable_warnings
drop table if exists t2;
drop table if exists t1;
--enable_warnings

################################
#### 级联操作，触发触发器
create table t1(c1 int primary key, id int);
create table t2(c1 int primary key, c2 int, id int);
create table t3(c1 int primary key, c2 int, id int, c3 varchar(2000));
alter table t2 add foreign key(c2) references t1(c1) on update cascade on delete cascade;

insert into t1 values(1, 110),(2, 111);
insert into t2 values(1, 1, 110),(2, 1, 110),(3, 2, 111);

delimiter /;
CREATE TRIGGER tri1 BEFORE update ON t2 FOR EACH ROW
BEGIN
   insert into t3 values(old.c1,old.c2,old.id,'表t2有更新，触发触发器，记录旧值');
END;
/
delimiter ;/

#级联操作 ob 会触发子表上定义的触发器,mysql 不会
update t1 set c1 = c1 * 10 where c1 = 1;

select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;
select * from t3 order by 1,2 for update;

drop table t3;
drop table t2;
drop table t1;

################################
#### 多条记录
create table t1(c1 int primary key, c2 int);
create index t1index1 on t1(c2); 

create table t2(c1 int, c2 int, id int);
alter table t2 add foreign key(c2) references t1(c2) on update cascade on delete cascade;

--error 0,1305
drop PROCEDURE insert_data;

DELIMITER /;
CREATE PROCEDURE insert_t1()
BEGIN
    DECLARE i INT DEFAULT 1;
    WHILE i <= 1000 DO
        INSERT INTO t1 VALUES (i, i + 99);
        SET i = i + 1;
    END WHILE;
END;
/
DELIMITER ;/

CALL insert_t1();

DELIMITER /;
CREATE PROCEDURE insert_t2()
BEGIN
    DECLARE i INT DEFAULT 1;
    WHILE i <= 1000 DO
        INSERT INTO t2 VALUES (i, i + 99,i);
        INSERT INTO t2 VALUES (i, i + 99,i);
        INSERT INTO t2 VALUES (i, i + 99,i);
        INSERT INTO t2 VALUES (i, i + 99,i);
        SET i = i + 1;
    END WHILE;
END;
/
DELIMITER ;/

CALL insert_t2();

select count(1) from t1;
select count(1) from t2;

delete from t1 where c1 = 1;
select count(1) from t1;
select count(1) from t2;

delete from t1 where c1 <10;
select count(1) from t1;
select count(1) from t2;

update t1 set c2 = c2 + 1 where c1 < 20;
select * from t1 where c1 < 20 order by 1,2 for update;
select * from t2 where c1 < 20 order by 1,2 for update;

delete from t1 where c1 = 19;
select count(1) from t1;
select count(1) from t2;

drop table t2;
drop table t1;

################################
#### 删除索引
create table t1(c1 int primary key, c2 int);
create unique index t1index1 on t1(c2); 

create table t2(c1 int, c2 int, id int);
alter table t2 add foreign key(c2) references t1(c2) on update cascade on delete cascade;

--error 4714
alter table t1 drop index t1index1;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where CONSTRAINT_SCHEMA = schema();

create unique index t1index2 on t1(c2); 

#ob 报错，mysql 成功(目前OB引用所有索引，都不允许变化)
--error 4714
alter table t1 drop index t1index1;

#ob 成功，mysql 报错
alter table t1 drop index t1index2;

select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where CONSTRAINT_SCHEMA = schema();

drop table t2;
drop table t1;

################################
#### 外键引用不同的索引
create table t1(c1 int primary key, c2 int,c3 int,c4 int);
create index t1index1 on t1(c2); 
create index t1index2 on t1(c3); 
create unique index t1index3 on t1(c4); 

insert into t1 values(11,22,33,44),(12,23,34,45),(13,24,35,46),(14,25,36,47);

create table t2(c1 int, c2 int,c3 int,c4 int, id int);
alter table t2 add foreign key(c1) references t1(c1) on update cascade on delete cascade;
alter table t2 add foreign key(c1) references t1(c2) on update cascade on delete cascade;
alter table t2 add foreign key(c1) references t1(c3) on update cascade on delete cascade;
alter table t2 add foreign key(c1) references t1(c4) on update cascade on delete cascade;

alter table t2 add foreign key(c2) references t1(c2) on update cascade on delete cascade;
alter table t2 add foreign key(c3) references t1(c3) on update cascade on delete cascade;
alter table t2 add foreign key(c4) references t1(c4) on update cascade on delete cascade;
--error 1064
alter table t2 add foreign key(c4) references t1(null) on update cascade on delete cascade;

#show create table t2;

--error 1452
insert into t2 values(11,null,null,null,null);
--error 1452
insert into t2 values(22,null,null,null,null);
--error 1452
insert into t2 values(33,null,null,null,null);
--error 1452
insert into t2 values(44,null,null,null,null);

insert into t2 values(null,22,33,44,null);
update t1 set c1 = c1,c2 = c2 * 10 where c2 = 22 ;

select * from t1 order by 1,2 for update;
select * from t2 order by 1,2 for update;

--error 1215
alter table t2 add foreign key(c1,c2) references t1(c1,c2) on update cascade on delete cascade;
--error 1215
alter table t2 add foreign key(c1,c2) references t1(c2,c3) on update cascade on delete cascade;
--error 1215
alter table t2 add foreign key(c1,c2) references t1(c3,c4) on update cascade on delete cascade;
--error 1064
alter table t2 add foreign key(c1,c2) references t1(c1,1) on update cascade on delete cascade;
--error 1215
alter table t2 add foreign key(c1,c2) references t1(c1,c1) on update cascade on delete cascade;
--error 1215
alter table t2 add foreign key(c1,c2) references t1(c2,c2) on update cascade on delete cascade;
--error 1215
alter table t2 add foreign key(c1,c2) references t1(c3,c3) on update cascade on delete cascade;
--error 1215
alter table t2 add foreign key(c1,c2) references t1(c4,c4) on update cascade on delete cascade;
--error 1064
alter table t2 add foreign key(c1,c2) references t1(null,null) on update cascade on delete cascade;

drop table t2;
drop table t1;

connection default;
--disable_warnings
--error 0,600
drop user fk_testuser;
