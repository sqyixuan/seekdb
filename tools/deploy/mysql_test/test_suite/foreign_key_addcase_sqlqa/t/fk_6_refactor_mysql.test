--result_format 4
connection default;

--echo # ◆ 准备测试用户
--disable_warnings
drop user if exists fk_testuser;
drop database if exists fk_testuser_db;
create user 'fk_testuser' identified by 'fk_testuser';
CREATE DATABASE IF NOT EXISTS  fk_testuser_db;
grant all on *.* to fk_testuser WITH GRANT OPTION;
--enable_warnings

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$obmysql_ms0,fk_testuser,fk_testuser,fk_testuser_db,$obmysql_port);
connection conn1;

--disable_warnings
drop table if exists t6;
drop table if exists t5;
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

################################
#### 相互引用
create table t1(c1 int primary key,c2 int);
create table t2(c1 int primary key,c2 int unique);

set foreign_key_checks=off;
insert into t1 values(1, 2), (2, 3), (3, 4);
insert into t2 values(10, 20), (20, 30), (30, 40);

alter table t2 add CONSTRAINT fk1 foreign key (c2) references t1(c1) on update cascade;
alter table t1 add CONSTRAINT fk2 foreign key (c1) references t2(c2) on update cascade;

set foreign_key_checks=on;
--error 1452
update t1 set c1 = c1 * 10;
--error 1452
update t1 set c1 = c1 * 10 where c1 = 1;

update t1 set c1 = c1 * 10 where c1 = 2;
update t1 set c1 = c1 * 10 where c1 = 3;
update t1 set c1 = c1;
select * from t1 order by 1,2;
select * from t2 order by 1,2;

insert into t1 values(40, 4);
--error 1452
insert into t2 values(40, 50);

alter table t1 DROP FOREIGN KEY fk2;
drop table t2;
drop table t1;


################################
#### 多表引用(表没有索引)
create table t1(c1 int primary key,c2 int);
create table t2(c1 int primary key,c2 int);
create table t3(c1 int primary key,c2 int);
create table t4(c1 int primary key,c2 int);
create table t5(c1 int primary key,c2 int);

set foreign_key_checks=off;
insert into t1 values(10, 11), (12, 13), (14, 15);
insert into t2 values(20, 21), (22, 23), (24, 25);
insert into t3 values(30, 31), (32, 33), (34, 35);
insert into t4 values(40, 41), (42, 43), (44, 45);
insert into t5 values(50, 51), (52, 53), (54, 55);

alter table t2 add CONSTRAINT fk1 foreign key (c2) references t1(c1) on update cascade;

#ob 报错，Oracle 成功（t2表的c2没有索引，oreign_key_checks=off，mysql就不止不检查数据，外键约束也不检查了）
--error 1215
alter table t3 add CONSTRAINT fk2 foreign key (c2) references t2(c2) on update cascade;
--error 1215
alter table t4 add CONSTRAINT fk3 foreign key (c2) references t3(c2) on update cascade;
--error 1215
alter table t5 add CONSTRAINT fk4 foreign key (c2) references t4(c2) on update cascade;

set foreign_key_checks=on;
--error 1452
insert into t2 values(26, 1);
insert into t2 values(26, 10);

--disable_warnings
drop table if exists t6;
drop table if exists t5;
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

################################
#### 多表引用
create table t1(c1 int primary key,c2 int);
create table t2(c1 int primary key,c2 int unique);
create table t3(c1 int primary key,c2 int unique);
create table t4(c1 int primary key,c2 int unique);
create table t5(c1 int primary key,c2 int unique);

set foreign_key_checks=off;
insert into t1 values(10, 11), (12, 13), (14, 15);
insert into t2 values(20, 21), (22, 23), (24, 25);
insert into t3 values(30, 31), (32, 33), (34, 35);
insert into t4 values(40, 41), (42, 43), (44, 45);
insert into t5 values(50, 51), (52, 53), (54, 55);

alter table t2 add CONSTRAINT fk1 foreign key (c2) references t1(c1) on update cascade on delete cascade;
alter table t3 add CONSTRAINT fk2 foreign key (c2) references t2(c2) on update cascade on delete cascade;
alter table t4 add CONSTRAINT fk3 foreign key (c2) references t3(c2) on update cascade on delete cascade;
alter table t5 add CONSTRAINT fk4 foreign key (c2) references t4(c2) on update cascade on delete cascade;

set foreign_key_checks=on;
--error 1452
insert into t2 values(26, 1);
insert into t2 values(26, 10);

--error 1452
insert into t3 values(36, 11);
insert into t3 values(36, 21);

--error 1452
insert into t4 values(46, 23);
insert into t4 values(46, 33);

--error 1452
insert into t5 values(56, 35);
insert into t5 values(56, 45);

insert into t2 values(27, 12),(28, 14);
insert into t3 values(37, 23),(38, 25);
insert into t4 values(47, 31),(48, 35);
insert into t5 values(57, 41),(58, 43);

select * from t1 order by 1,2;
select * from t2 order by 1,2;
select * from t3 order by 1,2;
select * from t4 order by 1,2;
select * from t5 order by 1,2;

update t1 set c1 = c1 + 5;
--error 1452
update t2 set c2 = c2 + 5;
--error 1452
update t3 set c2 = c2 + 5;
--error 1452
update t4 set c2 = c2 + 5;
--error 1452
update t5 set c2 = c2 + 5;

insert into t3 values(39, 15);
insert into t4 values(49, 15);
insert into t5 values(59, 15);

update t1 set c1 = c1 * 10;

select * from t1 order by 1,2;
select * from t2 order by 1,2;
select * from t3 order by 1,2;
select * from t4 order by 1,2;
select * from t5 order by 1,2;

