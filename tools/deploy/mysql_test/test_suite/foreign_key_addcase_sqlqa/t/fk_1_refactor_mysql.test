# owner: laibingzheng.lbz
#owner group: 技术部-sql-存储过程
#description: 【mysql兼容】 外键支持建立在非唯一键上
#tags: sql,pl
#author:whh01047778

--result_format 4
connection default;

--echo # ◆ 准备测试用户
--disable_warnings
drop user if exists fk_testuser;
drop database if exists fk_testuser_db;
create user 'fk_testuser' identified by 'fk_testuser';
CREATE DATABASE IF NOT EXISTS  fk_testuser_db;
grant all on *.* to fk_testuser WITH GRANT OPTION;
--enable_warnings

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$obmysql_ms0,fk_testuser,fk_testuser,fk_testuser_db,$obmysql_port);
connection conn1;

--disable_warnings
drop table if exists t6;
drop table if exists t5;
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

################################
#### 引用非唯一索引的列(1列)
create table t1(c1 int,c2 int,c3 int,c4 int); 
create index t1index on t1(c1); 

--error 1215
create table t2(c1 int,c2 int,c3 int,c4 int, foreign key(c1) references t1(c2));
--error 1215
create table t2(c1 int,c2 int,c3 int,c4 int, foreign key(c1,c2) references t1(c3,c4));
--error 1215
create table t2(c1 int,c2 int,c3 int,c4 int, foreign key(c1,c2) references t1(c1,c3));
--error 1215
create table t2(c1 int,c2 int,c3 int,c4 int, foreign key(c1,c2) references t1(c1,c1));

create table t2(c1 int,c2 int,c3 int,c4 int, foreign key(c1) references t1(c1));
create table t3(c1 int,c2 int,c3 int,c4 int, foreign key(c2) references t1(c1));

drop table t3;
drop table t2;
drop table t1;

#### 引用非唯一索引的列(2列)
