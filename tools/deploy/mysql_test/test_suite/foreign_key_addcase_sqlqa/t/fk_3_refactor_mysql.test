select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index3;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index4;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index5;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index6;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

--error 4714
alter table t1 drop index t1index7;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index8;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index9;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index10;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

--disable_warnings
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
drop table if exists new_t1;
--enable_warnings

################################
#### 多个 index（主键、index、UNIQUE index）
create table t1(c1 int,c2 int,c3 int,c4 int,CONSTRAINT pk PRIMARY KEY (c1,c2));
create index t1index1 on t1(c1); 
create index t1index2 on t1(c1,c2); 
create index t1index3 on t1(c1,c2,c3); 
create index t1index4 on t1(c1,c2,c4); 
create index t1index5 on t1(c1,c2,c3,c4); 
create UNIQUE index t1index6 on t1(c1); 
create UNIQUE index t1index7 on t1(c1,c2); 
create UNIQUE index t1index8 on t1(c1,c2,c3); 
create UNIQUE index t1index9 on t1(c1,c2,c4); 
create UNIQUE index t1index10 on t1(c1,c2,c3,c4); 

create table t2(
    c1 int not null,c2 int,c3 int,c4 int, 
    CONSTRAINT fk1 foreign key(c1,c2) references t1(c1,c2));

select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

--error 4714
alter table t1 drop PRIMARY KEY;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index1;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index2;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index3;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index4;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index5;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index6;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index7;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index8;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index9;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index10;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

--disable_warnings
drop table if exists t2;
drop table if exists t1;
--enable_warnings

################################
#### 多个 index（主键、UNIQUE index）
create table t1(c1 int,c2 int,c3 int,c4 int,CONSTRAINT pk PRIMARY KEY (c1,c2));
create UNIQUE index t1index1 on t1(c1,c2); 
create UNIQUE index t1index2 on t1(c1,c2); 
create UNIQUE index t1index3 on t1(c1,c2,c3); 

create table t2(
    c1 int not null,c2 int,c3 int,c4 int, 
    CONSTRAINT fk1 foreign key(c1,c2) references t1(c1,c2));

select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

--error 4714
alter table t1 drop PRIMARY KEY;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index1;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index2;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index3;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

connection default;
--disable_warnings
--error 0,600
drop user fk_testuser;
--enable_warnings
purge recyclebin;
