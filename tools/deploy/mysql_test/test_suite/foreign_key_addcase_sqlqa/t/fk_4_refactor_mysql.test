# owner: laibingzheng.lbz
#owner group: 技术部-sql-存储过程
#description: 【mysql兼容】 外键支持建立在非唯一键上
#tags: sql,pl
#author:whh01047778

--result_format 4
connection default;

--echo # ◆ 准备测试用户
--disable_warnings
drop user if exists fk_testuser;
drop database if exists fk_testuser_db;
create user 'fk_testuser' identified by 'fk_testuser';
CREATE DATABASE IF NOT EXISTS  fk_testuser_db;
grant all on *.* to fk_testuser WITH GRANT OPTION;
--enable_warnings

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$obmysql_ms0,fk_testuser,fk_testuser,fk_testuser_db,$obmysql_port);
connection conn1;

--disable_warnings
drop table if exists t6;
drop table if exists t5;
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

################################
#### 外键 unsigned float/double
create table t1(a float unique);
create table t2(a float unsigned unique);
create table t3(a float unique, foreign key(a) references t1(a));
create table t4(a float unique, foreign key(a) references t2(a));
create table t5(a float unsigned unique, foreign key(a) references t1(a));
create table t6(a float unsigned unique, foreign key(a) references t2(a));

insert into t1 values(-2), (-1), (1), (2);
insert into t2 values(1), (2), (3);

insert into t3 values(-2), (-1), (1), (2);

--error 1452
insert into t4 values(-1);
insert into t4 values(1), (2);

--error 1264
insert into t5 values(-2), (-1);
insert into t5 values(1), (2);

--error 1264
insert into t6 values(-2), (-1);
insert into t6 values(1), (2);

select * from t3 order by 1;
select * from t4 order by 1;
select * from t5 order by 1;
select * from t6 order by 1;

--disable_warnings
drop table if exists t6;
drop table if exists t5;
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

create table t1(a double unique);
create table t2(a double unsigned unique);
create table t3(a double unique, foreign key(a) references t1(a));
create table t4(a double unique, foreign key(a) references t2(a));
create table t5(a double unsigned unique, foreign key(a) references t1(a));
create table t6(a double unsigned unique, foreign key(a) references t2(a));

insert into t1 values(-2), (-1), (1), (2);
insert into t2 values(1), (2), (3);

insert into t3 values(-2), (-1), (1), (2);

--error 1452
insert into t4 values(-1);
insert into t4 values(1), (2);

--error 1264
insert into t5 values(-2), (-1);
insert into t5 values(1), (2);

--error 1264
insert into t6 values(-2), (-1);
insert into t6 values(1), (2);

select * from t3 order by 1;
select * from t4 order by 1;
select * from t5 order by 1;
select * from t6 order by 1;

--disable_warnings
drop table if exists t6;
drop table if exists t5;
drop table if exists t4;
drop table if exists t3, t2, t1;
--enable_warnings

################################
#### 外键 unsigned float，级联更新
create table t1(c1 double);
create index t1index on t1(c1); 
create table t5(c1 double unsigned, foreign key(c1) references t1(c1) on update cascade on delete cascade);

insert into t1 values(-2), (-1), (1), (2);
insert into t5 values(1), (2), (2);

--error 1264
update t1 set t1.c1 = -5 where t1.c1 = 2;
update t1 set t1.c1 = 3 where t1.c1 = 2;

select * from t1 order by 1;
select * from t5 order by 1;

delete from t1 where t1.c1 = -2;
delete from t1 where t1.c1 = 1;

select * from t1 order by 1;
select * from t5 order by 1;

drop table t5;
drop table t1;

################################
#### 外键 signed double，级联更新
create table t2(c1 double unsigned);
create index t1index on t2(c1); 
create table t4(c1 double, CONSTRAINT fk1 foreign key(c1) references t2(c1) on update cascade on delete cascade);

insert into t2 values(1), (2), (3);
insert into t4 values(1), (2), (2), (3);

--error 1264
update t2 set t2.c1 = -2 where t2.c1 = 1;
--error 1452
update t4 set t4.c1 = -2 where t4.c1 = 2;

select * from t2 order by 1;
select * from t4 order by 1;

delete from t2 where t2.c1 = 2;
delete from t2 where t2.c1 = 1;

select * from t2 order by 1;
select * from t4 order by 1;

drop table t4;
drop table t2;

################################
#### alter table modify signed/unsigned
create table t1(c1 double);
create index t1index on t1(c1); 
create table t2(c1 double, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);

--error 5320
alter table t1 modify column c1 double unsigned;
--error 5320
alter table t2 modify column c1 double unsigned;

drop table t2;
drop table t1;

create table t1(c1 double unsigned);
create index t1index on t1(c1); 
create table t2(c1 double unsigned, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);

--error 5320
alter table t1 modify column c1 double signed;
--error 5320
alter table t2 modify column c1 double signed;

drop table t2;
drop table t1;

################################
#### 数据类型兼容场景 数值类型
create table t1(c1 double);
create index t1index on t1(c1); 

--error 1215
create table t2(c1 float, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t2(c1 DECIMAL, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t2(c1 NUMERIC, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t2(c1 INT, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t2(c1 INTEGER, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t2(c1 SERIAL, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t2(c1 CHAR(10), CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t2(c1 VARCHAR(10), CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t2(c1 BINARY(10), CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t2(c1 VARBINARY(10), CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);

drop table t1;

################################
#### 数据类型兼容场景 字符类型
create table t1(c1 CHAR(10),c2 CHAR(20),index idx (c1,c2));

--error 1215
create table t2(c1 float, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t2(c1 DECIMAL, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t2(c1 NUMERIC, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t2(c1 INT, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t2(c1 INTEGER, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t2(c1 SERIAL, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);

create table t2(c1 CHAR(10), CONSTRAINT fk2 foreign key(c1) references t1(c1) on update cascade on delete cascade);
create table t21(c1 CHAR(100), CONSTRAINT fk21 foreign key(c1) references t1(c1) on update cascade on delete cascade);

#ob 报错，mysql 成功
--error 5319
create table t22(c1 CHAR(1), CONSTRAINT fk22 foreign key(c1) references t1(c1) on update cascade on delete cascade);

#ob 报错，mysql 成功
--error 1215
create table t3(c1 VARCHAR(10), CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);

--error 1215
create table t4(c1 BINARY(10), CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
--error 1215
create table t4(c1 VARBINARY(10), CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);

--disable_warnings
drop table if exists t3;
drop table if exists t22;
drop table if exists t21;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

################################
#### 数据类型兼容场景 日期类型
create table t1(c1 DATETIME,index idx (c1));

create table t2(c1 DATETIME, CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade);
create table t3(c1 DATETIME(4), CONSTRAINT fk2 foreign key(c1) references t1(c1) on update cascade on delete cascade);

#ob报错，mysql 成功
--error 1215
create table t4(c1 TIMESTAMP, CONSTRAINT fk3 foreign key(c1) references t1(c1) on update cascade on delete cascade);

--error 1215
create table t5(c1 DATE, CONSTRAINT fk4 foreign key(c1) references t1(c1) on update cascade on delete cascade);

#ob报错，mysql 成功
--error 1215
create table t6(c1 TIME, CONSTRAINT fk5 foreign key(c1) references t1(c1) on update cascade on delete cascade);

--error 1215
create table t7(c1 YEAR, CONSTRAINT fk6 foreign key(c1) references t1(c1) on update cascade on delete cascade);

--disable_warnings
drop table if exists t7;
drop table if exists t6;
drop table if exists t5;
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings


################################
#### 外键环状引用
create table t1(c1 int primary key,c2 int);
create table t2(c1 int primary key,c2 int unique);
create table t3(c1 int primary key,c2 int unique);

alter table t1 add CONSTRAINT fk1 foreign key(c2) references t3(c2) on update cascade;
alter table t2 add CONSTRAINT fk2 foreign key(c2) references t1(c1) on update cascade;
alter table t3 add CONSTRAINT fk3 foreign key(c2) references t2(c2) on update cascade;

insert into t1 values(1, NULL);
insert into t2 values(1, 1);
insert into t3 values(1, 1);
insert into t1 values(2, 1);

--error 1451
update t1 set t1.c1 = 10 where t1.c1 = 1;
--error 1452
update t2 set t2.c2 = 10 where t2.c2 = 1;
--error 1452
update t3 set t3.c2 = 10 where t3.c2 = 1;

--error 1451
delete from t1;
--error 1451
delete from t2;
--error 1451
delete from t3;

insert into t1 values(3, NULL);
insert into t2 values(3, 3);
insert into t3 values(3, 3);

update t1 set t1.c2 = 3 where t1.c1 = 3;
update t2 set t2.c2 = 2 where t2.c1 = 1;
update t3 set t3.c2 = 2 where t3.c1 = 1;
update t1 set t1.c2 = 2 where t1.c1 = 1;
update t1 set t1.c2 = 3 where t1.c1 = 2;

--error 1452
update t1 set t1.c2 = 6 where t1.c1 = 1;

select * from t1 order by 1,2;
select * from t2 order by 1,2;
select * from t3 order by 1,2;

alter table t1 drop foreign key fk1;
alter table t2 drop foreign key fk2;
alter table t3 drop foreign key fk3;

drop table if exists t3, t2, t1;

################################
#### 多个表的更新操作
create table t1(c1 int primary key,c2 int);
create table t2(c1 int primary key,c2 int unique);
create table t3(c1 int primary key,c2 int unique);

alter table t2 add CONSTRAINT fk2 foreign key(c2) references t1(c1) on update cascade;
alter table t3 add CONSTRAINT fk3 foreign key(c2) references t2(c2) on update cascade;

insert into t1 values(1, 1);
insert into t2 values(1, 1);
insert into t3 values(1, 1);

select * from t1 order by 1,2;
select * from t2 order by 1,2;
select * from t3 order by 1,2;

#ob报错，mysql成功
--error 1451
update t3, t2, t1 set t1.c1 = 10, t2.c1 = 20 where t1.c1 = t2.c1 and t2.c1 = t3.c1;
select * from t1 order by 1,2;
select * from t2 order by 1,2;
select * from t3 order by 1,2;

#ob成功，mysql报错
update t3, t1 set t1.c1 = 20, t3.c2 = 20 where t1.c1 = t3.c2;
select * from t1 order by 1,2;
select * from t2 order by 1,2;
select * from t3 order by 1,2;

drop table if exists t3, t2, t1;

connection default;
--disable_warnings
--error 0,600
drop user fk_testuser;
--enable_warnings
purge recyclebin;
