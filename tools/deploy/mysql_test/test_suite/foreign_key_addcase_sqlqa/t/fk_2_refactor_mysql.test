# owner: laibingzheng.lbz
#owner group: 技术部-sql-存储过程
#description: 【mysql兼容】 外键支持建立在非唯一键上
#tags: sql,pl
#author:whh01047778

--result_format 4
connection default;

--echo # ◆ 准备测试用户
--disable_warnings
drop user if exists fk_testuser;
drop database if exists fk_testuser_db;
create user 'fk_testuser' identified by 'fk_testuser';
CREATE DATABASE IF NOT EXISTS  fk_testuser_db;
grant all on *.* to fk_testuser WITH GRANT OPTION;
--enable_warnings

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$obmysql_ms0,fk_testuser,fk_testuser,fk_testuser_db,$obmysql_port);
connection conn1;

--disable_warnings
drop table if exists t6;
drop table if exists t5;
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

################################
#### index/unique index/primary key
create table t1(c1 int primary key,c2 int,c3 int,c4 int); 
create index t1index1 on t1(c2); 
create unique index t1index2 on t1(c3); 

create table t2(c1 int,c2 int,c3 int,c4 int);

alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade;
alter table t2 add CONSTRAINT fk2 foreign key(c1) references t1(c2) on update cascade;
alter table t2 add CONSTRAINT fk3 foreign key(c1) references t1(c3) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk4 foreign key(c1) references t1(c4) on update cascade;

--error 1215
alter table t2 add CONSTRAINT fk5 foreign key(c1,c2) references t1(c1,c1) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk6 foreign key(c1,c2) references t1(c1,c2) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk7 foreign key(c1,c2) references t1(c1,c3) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk8 foreign key(c1,c2) references t1(c1,c4) on update cascade;

--error 1215
alter table t2 add CONSTRAINT fk9 foreign key(c1,c2) references t1(c2,c1) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk10 foreign key(c1,c2) references t1(c2,c2) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk11 foreign key(c1,c2) references t1(c2,c3) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk12 foreign key(c1,c2) references t1(c2,c4) on update cascade;

--error 1215
alter table t2 add CONSTRAINT fk13 foreign key(c1,c2) references t1(c3,c1) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk14 foreign key(c1,c2) references t1(c3,c2) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk15 foreign key(c1,c2) references t1(c3,c3) on update cascade;
--error 1215
alter table t2 add CONSTRAINT fk16 foreign key(c1,c2) references t1(c3,c4) on update cascade;

--error 1215
alter table t2 add CONSTRAINT fk17 foreign key(c1,c2,c3) references t1(c1,c2,c3) on update cascade;

insert into t1 values(1,2,3,4),(11,21,31,41),(12,22,32,42);
select * from t1 order by 1,2,3,4;

--error 1452
insert into t2(c1) values(1);
--error 1452
insert into t2(c1) values(11);
--error 1452
insert into t2(c1) values(12);
--error 1452
insert into t2(c1) values(2);
--error 1452
insert into t2(c1) values(21);
--error 1452
insert into t2(c1) values(22);
--error 1452
insert into t2(c1) values(3);
--error 1452
insert into t2(c1) values(31);
--error 1452
insert into t2(c1) values(32);
--error 1452
insert into t2(c1) values(1),(2),(3),(11),(21),(31);
--error 1452
insert into t2(c1) values(1111111);

insert into t2(c1,c2) values(null,1);

update t1 set c1 = c1*10;
update t1 set c2 = c2*10;
update t1 set c3 = c3*10;

--error 1452
insert into t2(c1) values(10);
--error 1452
update t2 set c1 = 10;
--error 1452
update t2 set c1 = c2;

select * from t1 order by 1,2,3,4;
select * from t2 order by 1,2,3,4;

drop table t2;
drop table t1;

################################
#### 引用非唯一索引的列（索引表达式）
create table t1(c1 int,c2 int,c3 int,c4 int); 
create index t1index on t1((c1+c2+2),c3); 

create table t2(c1 int,c2 int,c3 int,c4 int);
--error 1215
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade;
--error 1215
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(c2) on update cascade on delete cascade;

alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(c3) on update cascade on delete cascade;

--error 1215
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(c4) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(c1+c2) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(c1+c2+2) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1((c1+c2)) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1((c1+c2+2)) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key((c1+c2+2)) references t1((c1+c2+2)) on update cascade on delete cascade;

drop table t2;
drop table t1;

################################
#### 引用非唯一索引的列
create table t1(c1 int,c2 int,c3 int,c4 int); 
create index t1index on t1((abs(c1+c2)),c3); 

create table t2(c1 int,c2 int,c3 int,c4 int);

--error 1215
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade;
--error 1215
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(c2) on update cascade on delete cascade;
--error 1215
alter table t2 add CONSTRAINT fk1 foreign key(c1,c2) references t1(c1,c2) on update cascade on delete cascade;
--error 1215
alter table t2 add CONSTRAINT fk1 foreign key(c1,c2) references t1(c1,c3) on update cascade on delete cascade;

alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(c3) on update cascade on delete cascade;

--error 1064
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(abs(c1)) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1((abs(c1))) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(abs(c2)) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1((abs(c2))) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(abs(c1+c2)) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1((abs(c1+c2))) on update cascade on delete cascade;

--error 1215
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(c4) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(c1+c2) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(c1+c2+2) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1((c1+c2)) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1((c1+c2+2)) on update cascade on delete cascade;
--error 1064
alter table t2 add CONSTRAINT fk1 foreign key((c1+c2+2)) references t1((c1+c2+2)) on update cascade on delete cascade;

drop table t2;
drop table t1;

################################
#### alter table
create table t1(c1 int,c2 int not null,c3 int,c4 int); 
create index t1index on t1(c1,c2,c3); 
create table t2(c1 int not null,c2 int,c3 int,c4 int, CONSTRAINT fk1 foreign key(c1,c2) references t1(c1,c2));

## 删除列
--error 5320
alter table t1 drop c1;
--error 5320
alter table t1 drop c2;
--error 5320
alter table t2 drop c1;
--error 5320
alter table t2 drop c2;

alter table t1 drop c3;
alter table t1 drop c4;
alter table t2 drop c3;
alter table t2 drop c4;

ALTER TABLE t1 ADD COLUMN c3 int;
ALTER TABLE t1 ADD COLUMN c4 int;
ALTER TABLE t2 ADD COLUMN c3 int;
ALTER TABLE t2 ADD COLUMN c4 int;

## 删除索引
#预期应该报错，issues：2025032700107815969 已修复
--error 1553
alter table t1 drop index t1index;

## 修改索引 t1index 不可见。
ALTER TABLE t1 ALTER INDEX t1index INVISIBLE;
create table t3(c1 int not null,c2 int,c3 int,c4 int, CONSTRAINT fk2 foreign key(c1,c2) references t1(c1,c2));

--error 5320
alter table t1 drop c1;
--error 5320
alter table t1 drop c2;
--error 1553
alter table t1 drop index t1index;
ALTER TABLE t1 ALTER INDEX t1index VISIBLE;

--error 5320
alter table t1 drop c1;
--error 5320
alter table t1 drop c2;
--error 1553
alter table t1 drop index t1index;

## 重命名列
ALTER TABLE t1 CHANGE c1 new_c1 int;
ALTER TABLE t1 CHANGE new_c1 c1 INTEGER;

#show create table t2;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

--error 5320
ALTER TABLE t1 CHANGE c1 c1 TINYINT;
--error 5320
ALTER TABLE t1 CHANGE c1 c1 SMALLINT;
--error 5320
ALTER TABLE t1 CHANGE c1 c1 BIGINT;
--error 5320
ALTER TABLE t1 CHANGE c1 c1 DECIMAL;
--error 5320
ALTER TABLE t1 CHANGE c1 c1 FLOAT;
--error 5320
ALTER TABLE t1 CHANGE c1 c1 BIT;

## 修改列的默认值
ALTER TABLE t1 ALTER COLUMN c1 SET DEFAULT NULL;
--error 1067
ALTER TABLE t1 ALTER COLUMN c2 SET DEFAULT NULL;
ALTER TABLE t1 ALTER COLUMN c1 SET DEFAULT 1;
ALTER TABLE t1 ALTER COLUMN c2 SET DEFAULT 1;

--error 1067
ALTER TABLE t2 ALTER COLUMN c1 SET DEFAULT NULL;
ALTER TABLE t2 ALTER COLUMN c2 SET DEFAULT NULL;
ALTER TABLE t2 ALTER COLUMN c1 SET DEFAULT 2;
ALTER TABLE t2 ALTER COLUMN c2 SET DEFAULT 2;

## 插入数据
insert into t1 values (1,1,1,1);
insert into t1 values (2,3,1,1);
insert into t1 values (3,4,1,1);

insert into t2 values (1,1,1,1);
--error 1452
insert into t2 values (1,2,1,1);
--error 1452
insert into t2 values (2,4,1,1);
--error 1452
insert into t2 values (2,2,2,2);
--error 1048
insert into t2 values (NULL,NULL,NULL,NULL);
insert into t2 values (1,NULL,NULL,NULL);
insert into t2 values (2,NULL,NULL,NULL);
insert into t2 values (3,NULL,NULL,NULL);
--error 1452
insert into t2 values (2,2,NULL,NULL);

update t1 set c1 = c2;
--error 1451
update t1 set c1 = c1 * 10;
--error 1451
update t1 set c1 = c1 * 10 where c1 = 1;
--error 1451
delete from t1 where c1 = 1;

select * from t1 order by 1;
select * from t2 order by 1;

## 删除父表数据
--error 1451
delete from t1;
--error 1701
TRUNCATE TABLE t1;
--error 3730
drop table t1;

## 重命名父表
ALTER TABLE t1 RENAME TO new_t1;
ALTER TABLE new_t1 RENAME TO t1;

show create table t2;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

--disable_warnings
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
drop table if exists new_t1;
--enable_warnings

################################
#### 多个index（index）
create table t1(c1 int,c2 int,c3 int,c4 int);
create index t1index1 on t1(c1,c2); 

create table t2(
    c1 int not null,c2 int,c3 int,c4 int, 
    CONSTRAINT fk1 foreign key(c1,c2) references t1(c1,c2));

create index t1index2 on t1(c1,c2,c3); 
create index t1index3 on t1(c1,c2,c4); 
create index t1index4 on t1(c2,c1); 
create index t1index5 on t1(c2,c1,c3); 
create index t1index6 on t1(c2,c1,c4); 

select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

--error 1553
alter table t1 drop index t1index1;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index2;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index3;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index4;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index5;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

alter table t1 drop index t1index6;
select TABLE_NAME,REFERENCED_TABLE_NAME,UNIQUE_CONSTRAINT_NAME from information_schema.referential_constraints where TABLE_NAME = 't2' and CONSTRAINT_SCHEMA = schema();

--disable_warnings
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
drop table if exists new_t1;
--enable_warnings

connection default;
--disable_warnings
--error 0,600
drop user fk_testuser;
--enable_warnings
purge recyclebin;
