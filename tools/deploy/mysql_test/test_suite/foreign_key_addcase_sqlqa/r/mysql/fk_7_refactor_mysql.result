######  重命名列
create table `t1`(`c1` int primary key,`c2` int,`c3` int,`c4` int unique,`c5` int,`c6` int,
    index index1 (`c2`),
    key index2(`c3`));

create table t2(c1 int primary key,c2 int,c3 int,c4 int,c5 int,c6 int);

alter table t2 add CONSTRAINT fk0 foreign key (c1) references t1(c1) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk1 foreign key (c2) references t1(`c2`) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk2 foreign key (`c3`) references t1(c3) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk3 foreign key (`c1`) references t1(`c1`) on update cascade on delete cascade;

ALTER TABLE t1 CHANGE c1 t1 int;

alter table t2 add CONSTRAINT fk4 foreign key (c4) references t1(t1) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk5 foreign key (c5,c6) references t1(t1,t1) on update cascade on delete cascade;
ERROR HY000: Cannot add foreign key constraint

ALTER TABLE t1 CHANGE c2 t2 SMALLINT;
ERROR HY000: 'c2': used in a foreign key constraint
ALTER TABLE t1 CHANGE c2 t2 BIGINT;
ERROR HY000: 'c2': used in a foreign key constraint
ALTER TABLE t1 CHANGE c2 t2 INTEGER;

alter table t2 add CONSTRAINT fk6 foreign key (c2) references t1(t2) on update cascade on delete cascade;

ALTER TABLE t1 ADD INDEX index3 (t1,t2);

alter table t2 add CONSTRAINT fk7 foreign key (c1,c2) references t1(t1,t2) on update cascade on delete cascade;

ALTER TABLE t1 DROP COLUMN t1;
ERROR HY000: 't1': used in a foreign key constraint
ALTER TABLE t1 DROP COLUMN t2;
ERROR HY000: 't2': used in a foreign key constraint
ALTER TABLE t1 DROP COLUMN c3;
ERROR HY000: 'c3': used in a foreign key constraint
ALTER TABLE t1 DROP COLUMN c4;

drop table t2;
drop table t1;

##################################
######  自引用
create table `t1`(`c1` int primary key,`c2` int,`c3` int,
    CONSTRAINT `fk` FOREIGN KEY (`c2`) REFERENCES `t1`(`c3`) ON UPDATE RESTRICT ON DELETE RESTRICT);
ERROR HY000: Cannot add foreign key constraint

create table `t1`(`c1` int primary key,`c2` int,`c3` int,
    CONSTRAINT `fk` FOREIGN KEY (`c2`) REFERENCES `t1`(`c1`) ON UPDATE RESTRICT ON DELETE RESTRICT);

drop PROCEDURE insert_t1;

CREATE PROCEDURE insert_t1()
BEGIN
    DECLARE i INT DEFAULT 1;
    WHILE i <= 1000 DO
        INSERT INTO t1 VALUES (i,i,i + 99);
        SET i = i + 1;
    END WHILE;
END;
/

CALL insert_t1();

drop table t1;

