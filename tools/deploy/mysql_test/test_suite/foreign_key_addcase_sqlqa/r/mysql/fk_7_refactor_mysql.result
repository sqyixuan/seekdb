##################################
###### 分区表
create table t1(
    id int,
    c1 int,
    c2 int,
    index index1(c1)) 
    PARTITION BY HASH(c1) PARTITIONS 6;

create table t2(
    id int,
    c1 int,
    c2 int) 
    PARTITION BY HASH(c1) PARTITIONS 4;

alter table t2 add foreign key(c1) references t1(c1) on update cascade on delete cascade;

insert into t1 values(1,1,1),(2,2,2),(3,2,2),(4,3,3),(5,3,3),(6,3,3);
insert into t2 values(1,1,1),(2,2,2),(3,3,3),(4,3,3);

SELECT * FROM t1 PARTITION(p0, p1) order by 1,2;
+------+------+------+
| id   | c1   | c2   |
+------+------+------+
|    1 |    1 |    1 |
+------+------+------+
SELECT * FROM t1 PARTITION(p2) order by 1,2;
+------+------+------+
| id   | c1   | c2   |
+------+------+------+
|    2 |    2 |    2 |
|    3 |    2 |    2 |
+------+------+------+
SELECT * FROM t1 PARTITION(p3) order by 1,2;
+------+------+------+
| id   | c1   | c2   |
+------+------+------+
|    4 |    3 |    3 |
|    5 |    3 |    3 |
|    6 |    3 |    3 |
+------+------+------+

DELETE FROM t1 PARTITION(p0, p1);
