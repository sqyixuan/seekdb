###### 不同方式创建索引
create table t1(c1 int primary key,c2 int,c3 int,c4 int,c5 int,c6 int,
    index index1 (c2),
    key index2(c3));
CREATE INDEX index3 ON t1 (c4 asc);
CREATE unique INDEX index4 ON t1 (c5);
ALTER TABLE t1 ADD INDEX index5 (c6);
ALTER TABLE t1 ADD key index6 (c1,c2);

create table t2(c1 int primary key,c2 int,c3 int,c4 int,c5 int,c6 int);

alter table t2 add CONSTRAINT fk1 foreign key (c1) references t1(c1) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk2 foreign key (c2) references t1(c2) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk3 foreign key (c3) references t1(c3) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk4 foreign key (c4) references t1(c4) on update cascade on delete cascade;
