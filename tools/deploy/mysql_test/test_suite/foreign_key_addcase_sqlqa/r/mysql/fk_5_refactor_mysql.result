#### 子表多列引用同一列
create table t1(c1 int primary key);
create table t2(c1 int primary key,c2 int unique,c3 int,c4 int);
set foreign_key_checks=on;
insert into t1 values(1), (2), (3), (4), (5);
insert into t2 values(1,1,2,1), (2,2,2,1), (3,3,null,2), (4,4,null,3);

alter table t2 add CONSTRAINT fk1 foreign key (c2) references t1(c1) on update cascade on delete cascade;
alter table t2 add CONSTRAINT fk2 foreign key (c3) references t1(c1) on update cascade on delete cascade;

set foreign_key_checks=on;
update t1, t2 set t1.c1 = 30, t2.c4 = 5 where t1.c1 = 1 and t2.c1 = 1;
ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails
update t1, t2 set t1.c1 = 40, t2.c4 = 6 where t1.c1 = 2 and t2.c4 = 1;
ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails
update t1, t2 set t1.c1 = 50, t2.c4 = 7 where t1.c1 = 3 and t2.c4 = 2;
ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails
update t1, t2 set t1.c1 = 60, t2.c4 = 8 where t1.c1 = 4 and t2.c4 = 3;
ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails

update t1 set t1.c1 = 70 where t1.c1 = 4;
update t1 set t1.c1 = 80 where t1.c1 = 3;
update t2 set t2.c2 = 10 where t2.c1 = 1;
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
update t2 set t2.c3 = 5 where t2.c1 = 4;

delete from t1 where c1 = 2;
delete from t1 where c1 = 4;

select * from t1 order by 1;
+----+
| c1 |
+----+
|  1 |
|  5 |
| 70 |
| 80 |
+----+
select * from t2 order by 1,2;
+----+------+------+------+
| c1 | c2   | c3   | c4   |
+----+------+------+------+
|  3 |   80 | NULL |    2 |
|  4 |   70 |    5 |    3 |
+----+------+------+------+

drop table t2;
drop table t1;

drop table if exists t2;
drop table if exists t1;
