################################
#### 自引用
create table t1(c1 int primary key, c2 int, 
    foreign key (c2) references t1(c1) on update cascade);
insert into t1 values(1, NULL), (2, 1), (3, 2);
insert into t1 values(4, 4), (5, 5), (6, 6);

update t1 set t1.c1 = 10 where t1.c1 = 1;
ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails
update t1 set t1.c1 = 10,t1.c2 = 10 where t1.c1 = 5;
update t1 set t1.c1 = 11 where t1.c2 = 6;
ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails

update t1 set t1.c2 = 4 where t1.c2 = 1;
update t1 set t1.c1 = 11 where t1.c2 = 2;

select * from t1 order by 1,2;
+----+------+
| c1 | c2   |
+----+------+
|  1 | NULL |
|  2 |    4 |
|  4 |    4 |
|  6 |    6 |
| 10 |   10 |
| 11 |    2 |
+----+------+

drop table if exists t1;

