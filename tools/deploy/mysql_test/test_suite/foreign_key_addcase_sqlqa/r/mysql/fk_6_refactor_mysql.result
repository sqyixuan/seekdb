| c1 | c2   | id   |
+----+------+------+
|  1 |    1 |    1 |
|  2 |    4 |    2 |
|  3 |    9 |    3 |
+----+------+------+

update t1 set c1 = 4 where c1 = 1;
update t2 set c2 = 9 where c1 = 2;
select * from t1 order by 1,2 for update;
+----+------+------+
| c1 | c2   | id   |
+----+------+------+
|  2 |    4 |    2 |
|  3 |    9 |    3 |
|  4 |   16 |    1 |
+----+------+------+
select * from t2 order by 1,2 for update;
+----+------+------+
| c1 | c2   | id   |
+----+------+------+
|  1 |   16 |    1 |
|  2 |    9 |    2 |
|  3 |    9 |    3 |
+----+------+------+

delete from t1 where c1 = 2;
select * from t1 order by 1,2 for update;
+----+------+------+
| c1 | c2   | id   |
+----+------+------+
|  3 |    9 |    3 |
|  4 |   16 |    1 |
+----+------+------+
select * from t2 order by 1,2 for update;
+----+------+------+
| c1 | c2   | id   |
+----+------+------+
|  1 |   16 |    1 |
|  2 |    9 |    2 |
|  3 |    9 |    3 |
+----+------+------+

update t1,t2 set t1.c1 = 6,t2.id=30 where t1.id=t2.id and t1.c1 = 3;
ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails
update t1,t2 set t1.c1 = 6 where t1.id=t2.id and t1.c1 = 3;
select * from t1,t2 order by 1,2 for update;
