| a  | id   |
+----+------+
| 11 | 1110 |
| 12 |  111 |
| 14 |  113 |
+----+------+
select * from t2 order by 1,2 for update;
+---+------+------+
| b | a    | id   |
+---+------+------+
+---+------+------+
select * from t3 order by 1,2 for update;
+---+------+------+
| c | a    | id   |
+---+------+------+
+---+------+------+

drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
################################
#### 自引用
create table t1 (c1 int primary key, c2 int, 
	foreign key (c2) references t1(c1) on update cascade on delete cascade);

set foreign_key_checks=off;
insert into t1 values (1,1),(2,2),(3,3);
insert into t1 values (4,40),(5,50),(6,60);
select * from t1 order by 1,2 for update;
+----+------+
| c1 | c2   |
+----+------+
|  1 |    1 |
|  2 |    2 |
|  3 |    3 |
|  4 |   40 |
|  5 |   50 |
|  6 |   60 |
+----+------+

set foreign_key_checks=on;
update t1 set c1 = c2 where c1 = 1;
update t1 set c1 = c2 where c1 = 4;
select * from t1 order by 1,2 for update;
+----+------+
| c1 | c2   |
+----+------+
|  1 |    1 |
|  2 |    2 |
|  3 |    3 |
|  5 |   50 |
|  6 |   60 |
| 40 |   40 |
+----+------+

update t1 set c1 = c2*10 where c1 = 1;
ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails

update t1 set c1 = c1,c2 = c2 where c1 = 1;
update t1 set c1 = c2,c2 = c1 where c1 = 1;
select * from t1 order by 1,2 for update;
+----+------+
| c1 | c2   |
+----+------+
|  1 |    1 |
|  2 |    2 |
|  3 |    3 |
|  5 |   50 |
|  6 |   60 |
| 40 |   40 |
+----+------+

update t1 set c1 = c1,c2 = c2 where c1 = 5;
update t1 set c1 = c2,c2 = c1 where c1 = 6;
select * from t1 order by 1,2 for update;
+----+------+
| c1 | c2   |
+----+------+
|  1 |    1 |
|  2 |    2 |
|  3 |    3 |
|  5 |   50 |
| 40 |   40 |
| 60 |   60 |
+----+------+

update t1 set c1 = 4, c2 = 4 where c1 = 1;
select * from t1 order by 1,2 for update;
+----+------+
| c1 | c2   |
+----+------+
|  2 |    2 |
|  3 |    3 |
|  4 |    4 |
|  5 |   50 |
| 40 |   40 |
| 60 |   60 |
+----+------+

drop table t1;

