#### 外键引用生成列
create table t1(c1 int primary key,c2 int AS (c1*c1) STORED, id int);
create index t1index1 on t1(c2);
insert into t1(c1,id) values(1,1),(2,2),(3,3);

create table t2(c1 int primary key,c2 int, id int);
alter table t2 add foreign key(c2) references t1(c2) on update cascade on delete cascade;
insert into t2 values(1,1,1),(2,4,2),(3,9,3);

select * from t1 order by 1,2 for update;
+----+------+------+
| c1 | c2   | id   |
+----+------+------+
|  1 |    1 |    1 |
|  2 |    4 |    2 |
|  3 |    9 |    3 |
+----+------+------+
select * from t2 order by 1,2 for update;
