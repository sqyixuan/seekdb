## 1、更新父表部分数据
update t1 set c1 = c1 * 2 where c2 = 1;
select * from t1 where c2 = 1 order by 1,2,3;
+----+------+------+
| id | c1   | c2   |
+----+------+------+
|  1 |    2 |    1 |
|  2 |    2 |    1 |
|  3 |    2 |    1 |
|  4 |    2 |    1 |
+----+------+------+
select * from t2 where c2 = 1 order by 1,2,3;
+----+------+------+
| id | c1   | c2   |
+----+------+------+
|  1 |    2 |    1 |
+----+------+------+

update t1 set c1 = c1 * 3 where c2 = 2 and id between 5 and 7;
select * from t1 where c2 = 2 order by 1,2,3;
+----+------+------+
| id | c1   | c2   |
+----+------+------+
|  5 |    6 |    2 |
|  6 |    6 |    2 |
|  7 |    6 |    2 |
|  8 |    2 |    2 |
|  9 |    2 |    2 |
| 10 |    2 |    2 |
+----+------+------+
select * from t2 where c2 = 2 order by 1,2,3;
+----+------+------+
| id | c1   | c2   |
+----+------+------+
|  2 |    6 |    2 |
|  3 |    6 |    2 |
+----+------+------+

update t1 set c1 = c1 * 4 where c2 = 2;
select * from t1 where c2 = 2 order by 1,2,3;
+----+------+------+
| id | c1   | c2   |
+----+------+------+
|  5 |   24 |    2 |
|  6 |   24 |    2 |
|  7 |   24 |    2 |
|  8 |    8 |    2 |
|  9 |    8 |    2 |
| 10 |    8 |    2 |
+----+------+------+
select * from t2 where c2 = 2 order by 1,2,3;
+----+------+------+
| id | c1   | c2   |
+----+------+------+
|  2 |   24 |    2 |
|  3 |   24 |    2 |
+----+------+------+

