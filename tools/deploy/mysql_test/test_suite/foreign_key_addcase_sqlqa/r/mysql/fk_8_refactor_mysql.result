## 15、多个表级联引用 t3->t2->t1
create table t1(id int primary key,c1 int,c2 int,index index1(c1));

create table t2(id int primary key,c1 int,c2 int,index index1(c1));
alter table t2 add CONSTRAINT fk1 foreign key(c1) references t1(c1) on update cascade on delete cascade;

create table t3(id int primary key,c1 int,c2 int);
alter table t3 add CONSTRAINT fk2 foreign key(c1) references t2(c1) on update cascade on delete cascade;

