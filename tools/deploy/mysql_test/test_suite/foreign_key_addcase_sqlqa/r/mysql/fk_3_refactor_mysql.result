#### 多个 index（主键、index、UNIQUE index）
create table t1(c1 int,c2 int,c3 int,c4 int,CONSTRAINT pk PRIMARY KEY (c1,c2));
create index t1index1 on t1(c1);
create index t1index2 on t1(c1,c2);
create index t1index3 on t1(c1,c2,c3);
create index t1index4 on t1(c1,c2,c4);
create index t1index5 on t1(c1,c2,c3,c4);
create UNIQUE index t1index6 on t1(c1);
create UNIQUE index t1index7 on t1(c1,c2);
