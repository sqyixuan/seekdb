| TABLE_NAME | REFERENCED_TABLE_NAME | UNIQUE_CONSTRAINT_NAME |
+------------+-----------------------+------------------------+
| t2         | t1                    | NULL                   |
+------------+-----------------------+------------------------+

alter table t1 drop index t1index4;
ERROR HY000: Cannot drop index 't1index4': needed in a foreign key constraint
