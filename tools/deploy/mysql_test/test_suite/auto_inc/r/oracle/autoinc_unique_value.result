>> Verify continuty of field with auto_increment for simple inserts
drop table if exists t1;
create table t1 (a int auto_increment primary key, b varchar(20)) auto_increment=20;
insert into t1 values (null,'vc1'),(null,'vc2'),(null,'vc3');
insert into t1 values (0,'vc4'),(0,'vc5'),(0,'vc6');
insert into t1 values (0,'vc7'),(null,'vc8'),(0,'vc9'),(null,'vc10');
insert into t1(b) values('vc11'),('vc12'),('vc13'),('vc14');
select * from t1;
a	b
20	vc1
21	vc2
22	vc3
23	vc4
24	vc5
25	vc6
26	vc7
27	vc8
28	vc9
29	vc10
30	vc11
31	vc12
32	vc13
33	vc14
>> Verify continuty of field with auto_increment for bulk inserts
drop table if exists t2;
create table t2 (b char(20));
insert into t2 values('t2_vc1'),('t2_vc2'),('t2_vc3'),('t2_vc4');
insert into t1(b) select b from t2;
select * from t1;
a	b
20	vc1
21	vc2
22	vc3
23	vc4
24	vc5
25	vc6
26	vc7
27	vc8
28	vc9
29	vc10
30	vc11
31	vc12
32	vc13
33	vc14
34	t2_vc1
35	t2_vc2
36	t2_vc3
37	t2_vc4
>> No continuty guarentee of auto_increment field for insert-like stmts
drop table t1;
create table t1 (c1 int auto_increment, c2 char(20), primary key(c1));
insert into t1 values(1,'a'),(null,'b'),(null,'c'),(8,'d'),(null,'e');
select * from t1;
c1	c2
1	a
8	d
1000002	b
1000003	c
1000004	e
insert into t1 values(null,'f');
select * from t1;
c1	c2
1	a
8	d
1000002	b
1000003	c
1000004	e
1000007	f
