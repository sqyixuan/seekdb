CREATE TABLE `t1` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '仅用于标识数据记录唯一，不用于业务',
`order_no` bigint(20) NOT NULL DEFAULT '0' COMMENT '订单编号',
`driver_no` bigint(20) NOT NULL DEFAULT '0' COMMENT '司机编号',
`total_income` bigint(11) NOT NULL DEFAULT '0' COMMENT '总流水',
PRIMARY KEY (`id`),
UNIQUE KEY `uk_order_no` (`order_no`) BLOCK_SIZE 16384 LOCAL COMMENT '订单号唯一索引',
KEY `idx_driver_no` (`driver_no`) BLOCK_SIZE 16384 LOCAL COMMENT '司机编号索引'
);
alter table t1 auto_increment = 9000000000000000000;
create sequence s1;
INSERT IGNORE INTO t1 (id,order_no,driver_no,total_income) values (s1.nextval * 10000,s1.nextval,s1.nextval,s1.nextval);
INSERT IGNORE INTO t1 (id,order_no,driver_no,total_income) values (s1.nextval * 10000,s1.nextval,s1.nextval,s1.nextval);
show create table t1;
