drop database if exists autoinc_cache_cleanup;
create database autoinc_cache_cleanup;
use autoinc_cache_cleanup;
drop table if exists t1;
create table t1 (a int auto_increment, b int) partition by hash(b) partitions 10;
insert into t1 values (NULL, 1);
insert into t1 values (NULL, 2);
select * from t1;
a	b
1	1
2	2
drop table t1;
insert into t1 values (NULL, 3);
insert into t1 values (NULL, 4);
select * from t1;
a	b
1	1
2	2
1000001	3
1000002	4
drop table t1;
