drop table seq;
create table seq (c1 int primary key auto_increment, c2 int unique, c3 int);
insert into seq (c2,c3) values (1,1);
insert into seq (c2,c3) values (2,2);
update seq set c1 = 5 where c2 = 2;
select * from seq;
