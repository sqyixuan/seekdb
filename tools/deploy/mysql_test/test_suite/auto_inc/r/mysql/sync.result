result_format: 4
drop table if exists seq;
set global auto_increment_cache_size = 1000000;

create table seq (c1 int primary key auto_increment, c2 int unique, c3 int);
insert into seq (c2,c3) values (1,2);
insert into seq (c1,c2,c3) values (9,4,3) on duplicate key update c2 = 31;
insert into seq (c2,c3) values (6,6);
select * from seq;
+----+------+------+
| c1 | c2   | c3   |
+----+------+------+
|  1 |    1 |    2 |
|  9 |    4 |    3 |
| 10 |    6 |    6 |
+----+------+------+

