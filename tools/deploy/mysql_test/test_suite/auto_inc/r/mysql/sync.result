| c1 | c2   | c3   |
+----+------+------+
|  1 |    1 |    1 |
|  4 |    3 |    3 |
|  5 |   31 |    2 |
+----+------+------+
insert into seq (c2,c3) values (5,5);
ERROR 23000: Duplicate entry '5' for key 'PRIMARY'
insert into seq (c2,c3) values (6,6);
select * from seq;
