drop table if exists t1;
create table t1 (c1 int primary key auto_increment, c2 int);
insert into t1 (c1, c2) values (null, 1);
select * from t1 where c1 is null;
c1	c2
select * from t1 where c1 is true;
c1	c2
1	1
set sql_auto_is_null = on;
select * from t1 where c1 is null;
c1	c2
1	1
select * from t1 where c1 is true;
c1	c2
1	1
set sql_auto_is_null = off;
