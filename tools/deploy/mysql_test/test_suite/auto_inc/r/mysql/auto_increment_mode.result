## test default auto increment mode configure and create table.
alter system set default_auto_increment_mode = 'ORDER';
create table t1 (a int auto_increment);
create table t2 (a int auto_increment) auto_increment_mode = 'ORDER';
create table t3 (a int auto_increment) auto_increment_mode = 'NOORDER';
show create table t1;
