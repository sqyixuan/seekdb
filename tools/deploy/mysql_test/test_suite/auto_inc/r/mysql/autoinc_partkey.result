      columns([{t1: ({t1: (t1.inv_id, t1.c1)})}]), 
      column_values([column_conv(BIGINT,PS:(20,0),NOT NULL,__values.inv_id)], [column_conv(BIGINT,PS:(20,0),NOT NULL,t1.c1.nextval(column_conv(BIGINT,PS:(20,
      0),NOT NULL,__values.c1)))])
  1 - output([__values.inv_id], [__values.c1]), filter(nil)
      values({10, NULL})
