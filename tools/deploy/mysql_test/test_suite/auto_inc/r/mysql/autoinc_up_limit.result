>> Test tinyint (-128~127)
drop table if exists t1;
create table t1 (a int, b int, c tinyint auto_increment, primary key(a), unique index(b), index(c)) auto_increment=100;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `a` int(11) NOT NULL,
  `b` int(11) DEFAULT NULL,
  `c` tinyint(4) NOT NULL AUTO_INCREMENT,
  PRIMARY KEY (`a`),
  UNIQUE KEY `b` (`b`) BLOCK_SIZE 16384 LOCAL,
  KEY `c` (`c`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX AUTO_INCREMENT = 100 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
insert into t1 values(1,1,127);
insert into t1 values(2,2,null);
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `a` int(11) NOT NULL,
  `b` int(11) DEFAULT NULL,
  `c` tinyint(4) NOT NULL AUTO_INCREMENT,
  PRIMARY KEY (`a`),
  UNIQUE KEY `b` (`b`) BLOCK_SIZE 16384 LOCAL,
  KEY `c` (`c`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX AUTO_INCREMENT = 127 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
select * from t1;
a	b	c
1	1	127
2	2	127
