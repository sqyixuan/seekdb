--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: nijia.nj
# owner group: SQL2
# description: Test altering table to be with / without auto_increment
#

# valid value [1,100000000]
--error 1231
set global auto_increment_cache_size = 0;
--error 1231
set global auto_increment_cache_size = 100000001;
--error 1231
set global auto_increment_cache_size = -10;
--error 1232
set global auto_increment_cache_size = 1.2;

set global auto_increment_cache_size = 35;
set global auto_increment_cache_size = 99999999;
set global auto_increment_cache_size = 1;
set global auto_increment_cache_size = 1000000;
