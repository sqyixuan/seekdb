--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: nijia.nj
# owner group: SQL2
# description: Test dml with auto_increment
#

--echo >>dml + null
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a int primary key auto_increment, b varchar(20));
insert into t1 values(null,'1_null'),(null,'2_null'),(null,'3_null'),(null,'4_null');
insert into t1(b) values('5_no'),('6_no'),('7_no'),('8_no');
replace into t1 values(null,'9_null'),(null,'10_null'),(null,'11_null'),(null,'12_null');
replace into t1(b) values('13_no'),('14_no'),('15_no'),('16_no');
select * from t1;

update t1 set a=a+100 where a=10;
insert into t1 values(null,'17_insert');
select * from t1 where b='17_insert';

delete from t1 where a=3; 
insert into t1 values(null,'18_insert');
select * from t1 where b='18_insert';


--echo >>dml + 0
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a int primary key auto_increment, b varchar(20));
insert into t1 values(0,'1_0'),(0,'2_0'),(0,'3_0'),(0,'4_0');
insert into t1(b) values('5_no'),('6_no'),('7_no'),('8_no');
replace into t1 values(0,'9_0'),(0,'10_0'),(0,'11_0'),(0,'12_0');
replace into t1(b) values('13_no'),('14_no'),('15_no'),('16_no');
select * from t1;

update t1 set a=a+100 where a=10;
insert into t1 values(0,'17_insert');
select * from t1 where b='17_insert';

delete from t1 where a=3; 
insert into t1 values(0,'18_insert');
select * from t1 where b='18_insert';

--echo >>update will not update auto_increment, may introduce duplicate key
--error 1062
insert into t1 values(110,'');

--echo >> There can be duplidate value in auto_increment field when this field is not in primary key or unique index
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a int auto_increment, b varchar(20));
insert into t1 values(1,1),(1,1);
select * from t1;

--echo >> The influence of sql mode and ignore.

# 目前ObExprNextval(22x)和ObExprAutoincNextval(master)的实现有问题, 暂时注掉非严格模式用例.
# 见ObExprAutoincNextval::check_and_cast接口注释。

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a int primary key auto_increment, b int) auto_increment = 1000;

delete from t1;
set sql_mode='STRICT_TRANS_TABLES';
--error 1366
insert into t1 values ('abc', 1), (null, 2), (0, 3);
select * from t1 order by b;

delete from t1;
set sql_mode='STRICT_TRANS_TABLES';
insert ignore into t1 values ('abc', 1), (null, 2), (0, 3);
select * from t1 order by b;

#set sql_mode='';
#insert into t1 values ('abc', 1), (null, 2), (0, 3);
#select * from t1 order by b;

--disable_warnings
DROP TABLE if exists `cool_deal`;
--enable_warnings
CREATE TABLE `cool_deal` (
  `deal_id` int(11) NOT NULL AUTO_INCREMENT COMMENT '交易流水ID',
  `cash_fee` decimal(10,2) NOT NULL COMMENT '实际支付',
  PRIMARY KEY (`deal_id`)
) AUTO_INCREMENT = 8178461;

delete from cool_deal;
set sql_mode='strict_all_tables';
--error 1366
INSERT INTO cool_deal (deal_id,cash_fee) values('',10);
--error 1366
INSERT INTO cool_deal (deal_id,cash_fee) values('',20),(null,30),(NULL,40),(' ',50),('\t',60),('\n',70);
select * from cool_deal order by cash_fee;

delete from cool_deal;
set sql_mode='strict_all_tables';
INSERT IGNORE INTO cool_deal (deal_id,cash_fee) values('',10);
INSERT IGNORE INTO cool_deal (deal_id,cash_fee) values('',20),(null,30),(NULL,40),(' ',50),('\t',60),('\n',70);
select * from cool_deal order by cash_fee;

#set sql_mode='';
#INSERT INTO cool_deal (deal_id,cash_fee) values('',10);
#INSERT INTO cool_deal (deal_id,cash_fee) values('',20),(null,30),(NULL,40),(' ',50),('\t',60),('\n',70);
#select * from cool_deal order by cash_fee;

--disable_warnings
drop table if exists t1;
drop table if exists cool_deal;
--enable_warnings
