--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 int);
create table t2(c1 int primary key auto_increment, c2 int default 1);

explain insert into t1 values (1);
insert into t1 values (2);
insert into t1 values (3);

select * from t1;

explain insert into t2 values ();
insert into t2 values ();
insert into t2 values ();
insert into t2 values ();

select * from t2;

explain insert into t2 values (default, default);
insert into t2 values (default, default);
insert into t2 values (default, default);

select * from t2;

explain insert into t2 values (null, default);
insert into t2 values (null, default);

select * from t2;
