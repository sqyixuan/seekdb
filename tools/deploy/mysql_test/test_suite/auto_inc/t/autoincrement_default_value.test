--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# owner group: SQL3
# description: 本case是为了测试自增列在被赋值成default/default(c1)时的反应
# tags: dml,default_value,auto_increment
--disable_warnings
drop table if exists test;
--enable_warnings

echo 'strict mode';
create table test(c1 int auto_increment primary key, c2 int);
insert into test values();
insert into test values(default, 1);
insert into test values(default(c1), 2);
insert into test set c1 = default, c2 = 3;
insert into test set c1 = default(c1), c2 = 4;
insert into test set c1 = c1, c2 = 5;
insert into test values(c1, 6);
insert into test values(c1, 7);
insert into test values(c1 + c2, 7);
insert into test values(c1 + c2, 7);
insert into test values(1 + c2, 7);
insert into test values(1 + c2, 7);
--error 1062
insert into test values(c1 + 1, 7);
select * from test;
delete from test;
insert into test values(9,10);
update test set c1 =default, c2 = 7;
select * from test;
update test set c1 = default(c1), c2 = 8;
select * from test;
delete from test;
##测试没有数据的时候是否会报错
update test set c1 =default, c2 = 7;
update test set c1 = default(c1), c2 = 8;
drop table test;

set @@sql_mode='';
echo 'not strict mode';
create table test(c1 int auto_increment primary key, c2 int);
insert into test values();
insert into test values(default, 1);
insert into test values(default(c1), 2);
insert into test set c1 = default, c2 = 3;
insert into test set c1 = default(c1), c2 = 4;
insert into test set c1 = c1, c2 = 5;
insert into test values(c1, 6);
insert into test values(c1, 7);
insert into test values(c1 + c2, 7);
insert into test values(c1 + c2, 7);
insert into test values(1 + c2, 7);
insert into test values(1 + c2, 7);
--error 1062
insert into test values(c1 + 1, 7);

select * from test;
delete from test;
insert into test values(9,10);
update test set c1 =default, c2 = 7;
select * from test;
update test set c1 = default(c1), c2 = 8;
select * from test;
delete from test;
##测试没有数据的时候是否会报错
update test set c1 =default, c2 = 7;
update test set c1 = default(c1), c2 = 8;
drop table test;

set @@sql_mode='strict_all_tables';
echo 'auto_incrememnt is unique key';
echo 'strict mode';
create table test(c1 int primary key, c2 int, c3 int auto_increment unique key);
insert into test(c1) values(10);
insert into test values(1, 1, default);
insert into test values(11, 2, default(c3));
insert into test set c1 = 12, c2 = 3,  c3 = default;
insert into test set c1 = 13, c2 = 4, c3 = default(c3);
insert into test set c1 = 14, c2 = 5, c3 = c3;
insert into test set c1 = 135, c3 = c2 + 1;
insert into test set c1 = 136, c3 = c2 + 1;
insert into test set c1 = 137, c3 = c2 + c3;
--error 1062
insert into test set c1 = 138, c2 = 5, c3 = c3 + 1;
insert into test values(15, 6, c3);
insert into test values(16, 3, c3);
insert into test values(17,3,c3);
insert into test(c1,c3) values(18, c2+c3);
insert into test(c1,c3) values(19, c2+1);
--error 1062
insert into test values(19,3, c3+1);

select * from test;
delete from test;
insert into test values(15, 6, 3);
update test set c1 =16, c2 = 7, c3=default limit 1;
select * from test;
update test set c1 = 17, c2 = 8, c3 = default(c3) limit 1;
select * from test;
delete from test;
##测试没有数据的时候是否会报错
update test set c1 =18, c2 = 7, c3 = default;
update test set c1 = 19, c2 = 8, c3 = default(c3);
drop table test;

set @@sql_mode='';
echo 'not strict mode';
create table test(c1 int primary key, c2 int, c3 int auto_increment unique key);
insert /*+USE_PLAN_CACHE(NONE)*/ into test values();
insert into test values(2, 1, default);
insert into test values(3, 2, default(c3));
insert into test set c1 = 4, c2 = 3,  c3 = default;
insert into test set c1 = 5, c2 = 4, c3 = default(c3);
insert into test set c1 = 6, c2 = 5, c3 = c3;
insert into test set c1 = 135, c3 = c2 + 1;
insert into test set c1 = 136, c3 = c2 + 1;
insert into test set c1 = 137, c3 = c2 + c3;
--error 1062
insert into test set c1 = 138, c2 = 5, c3 = c3 + 1;
insert into test values(15, 6, c3);
insert into test values(16, 3, c3);
insert into test values(17,3,c3);
insert into test(c1,c3) values(18, c2+c3);
insert into test(c1,c3) values(19, c2+1);
--error 1062
insert into test values(19,3, c3+1);


select * from test;
update test set c1 =default, c2 = 7, c3=default limit 1;
select * from test;
update test set c1 = 10, c2 = 8, c3 = default(c3) limit 1;
select * from test;
delete from test;
##测试没有数据的时候是否会报错
update test set c1 =default, c2 = 7, c3 = default;
update test set c1 = 2, c2 = 8, c3 = default(c3);
drop table test;

###################
## insert on duplicate
###################
create table test(c1 int auto_increment primary key, c2 int);
insert into test values(1,2);
insert into test values(1,2) on duplicate key update c1 = default;
select * from test;
insert into test values(0,2) on duplicate key update c1 = default(c1), c2 = 10;
insert into test values(3,2) on duplicate key update c1 = default(c1), c2 = 10;
select * from test;

drop table test;
create table test(c1 int primary key, c2 int, c3 int auto_increment unique key);
insert into test values(1, 2 , 1);
insert into test values(1,3,4) on duplicate key update c3=default;
select * from test;
insert into test values(1,3,4) on duplicate key update c3=default(c3);
select * from test;

#######
#   NULL 和0的处理
#######

drop table test;
create table test(c1 int auto_increment primary key);
insert into test set c1 = NULL;
insert into test set c1 = NULL;
insert into test set c1 = 0;
insert into test set c1 = 0;
insert into test values(NULL);
insert into test values(NULL);
insert into test values(0);
insert into test values(0);
select * from test;
