--echo ## auto-inc is pk and part key
CREATE TABLE `transfer` (
`id` bigint(20) NOT NULL AUTO_INCREMENT,
`sourceID` int(11) DEFAULT NULL,
`targetID` int(11) DEFAULT NULL,
`amount` decimal(15,2) DEFAULT NULL,
`type` varchar(100) DEFAULT NULL,
`transfer_ts` timestamp NULL DEFAULT '2023-06-20 16:33:24',
`fresh_ts` timestamp NULL DEFAULT '2023-06-20 16:33:24',
PRIMARY KEY (`id`),
KEY `idx_transfer_1` (`sourceID`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_transfer_2` (`targetID`) BLOCK_SIZE 16384 LOCAL
) partition by hash(id) partitions 128;

explain insert /*+ parallel(10) enable_parallel_dml  */into transfer select * from transfer_tmp;
insert /*+ parallel(10) enable_parallel_dml  */into transfer select * from transfer_tmp;
INSERT INTO transfer(id,sourceID,targetID,amount,type,transfer_ts) VALUES (0, 63002,17017,0.02,'red_packet','2023-10-02 19:15:59.38');
select * from transfer;
drop table transfer;

