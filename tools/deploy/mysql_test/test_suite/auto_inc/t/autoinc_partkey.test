# owner: zuojiao.hzj
#tags: optimizer
# owner group: SQL2
# description: 
# partition key with auto-inc attribute
#
--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1(
   inv_id bigint,
   c1 bigint  auto_increment ,
   primary key (inv_id)
) partition by hash(inv_id) partitions 3;

explain basic insert into t1 values (10,null);
explain basic insert into t1 values (10,null), (20,null), (30, null);
insert into t1 values (10,null), (20,null), (30, null);
explain basic insert into t1 values (null, 40);
--error 1048
insert into t1 values (null, 40);
explain basic insert into t1 values (50, 50);
insert into t1 values (50, 40);
--error 1364
explain basic insert into t1 values ();
--error 1364
insert into t1 values ();


create table t2(
   inv_id bigint not null auto_increment ,
   c1 bigint,
   primary key (inv_id)
) partition by hash(inv_id) partitions 3;

explain basic insert into t2 values (null,10), (null, 20), (null, 30);
insert into t2 values (null,10), (null, 20), (null, 30);
explain basic insert into t2 values (null, 40);
insert into t2 values (null, 40);
explain basic insert into t2 values (50, 50);
insert into t2 values (50, 40);
explain basic insert into t2 values ();
insert into t2 values ();

create table t3(
   inv_id bigint not null auto_increment ,
   c1 bigint,
   primary key (inv_id)
);

explain basic insert into t3 values (null,10);
explain basic insert into t3 values (null,10), (null, 20), (null, 30);
insert into t3 values (null,10), (null, 20), (null, 30);
explain basic insert into t3 values (null, 40);
insert into t3 values (null, 40);
explain basic insert into t3 values (50, 50);
insert into t3 values (50, 40);
explain basic insert into t3 values ();
insert into t3 values ();




--sorted_result
select * from t1;
--sorted_result
select * from t2;
--sorted_result
select * from t3;

