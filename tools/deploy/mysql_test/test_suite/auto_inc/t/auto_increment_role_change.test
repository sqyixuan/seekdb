insert into thezj2 values (null);

insert into thezj3 values (null);
insert into thezj3 values (null);
insert into thezj3 values (null);
insert into thezj3 values (null);

select * from thezj1;
select * from thezj2;
select * from thezj3;

drop table thezj1;
drop table thezj2;
drop table thezj3;
