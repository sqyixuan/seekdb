--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zuojiao.hzj
# owner group: SQL2
# description: Test auto increment for leader and follower switching
#

--echo "Test keep auto increment value continuous when role change"
connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;

let $zone1 = query_get_value(select zone from oceanbase.dba_ob_zones, zone, 1);
let $zone2 = query_get_value(select zone from oceanbase.dba_ob_zones, zone, 2);

eval alter tenant sys primary_zone = '$zone1';
--sleep 5

connection default;
--disable_warnings
drop table if exists thezj1;
drop table if exists thezj2;
drop table if exists thezj3;
--enable_warnings

create table thezj1 (c1 int auto_increment);
create table thezj2 (c1 int auto_increment);
create table thezj3 (c1 int auto_increment);

select table_name, sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name like 'thezj%' order by 1;

--echo "Test basic insert null value (for next value)"
insert into thezj1 values (null);
insert into thezj1 values (null);
insert into thezj1 values (null);
insert into thezj1 values (null);

insert into thezj2 values (null);
insert into thezj2 values (null);
insert into thezj2 values (null);
insert into thezj2 values (null);

insert into thezj3 values (null);
insert into thezj3 values (null);
insert into thezj3 values (null);
insert into thezj3 values (null);

select * from thezj1;
select * from thezj2;
select * from thezj3;

select table_name, sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name like 'thezj%' order by 1;

connection syscon;
eval alter tenant sys primary_zone = '$zone2';
--sleep 5

connection default;
insert into thezj1 values (null);
insert into thezj1 values (null);
insert into thezj1 values (null);
insert into thezj1 values (null);

insert into thezj2 values (null);
insert into thezj2 values (null);
insert into thezj2 values (null);
insert into thezj2 values (null);

insert into thezj3 values (null);
insert into thezj3 values (null);
insert into thezj3 values (null);
insert into thezj3 values (null);

select * from thezj1;
select * from thezj2;
select * from thezj3;

select table_name, sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name like 'thezj%' order by 1;

connection syscon;
eval alter tenant sys primary_zone = '$zone1';
--sleep 5

connection default;
insert into thezj1 values (null);
insert into thezj1 values (null);
insert into thezj1 values (null);
insert into thezj1 values (null);

insert into thezj2 values (null);
insert into thezj2 values (null);
insert into thezj2 values (null);
insert into thezj2 values (null);

insert into thezj3 values (null);
insert into thezj3 values (null);
insert into thezj3 values (null);
insert into thezj3 values (null);

select * from thezj1;
select * from thezj2;
select * from thezj3;

select table_name, sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name like 'thezj%' order by 1;

--echo "show create table (for current value)"
connection syscon;
eval alter tenant sys primary_zone = '$zone2';
--sleep 5

connection default;
show create table thezj1;
show create table thezj2;
show create table thezj3;

select table_name, sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name like 'thezj%' order by 1;

connection syscon;
eval alter tenant sys primary_zone = '$zone1';
--sleep 5

connection default;
show create table thezj1;
show create table thezj2;
show create table thezj3;

select table_name, sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name like 'thezj%' order by 1;

select * from thezj1;
select * from thezj2;
select * from thezj3;

--echo "insert non-null value (for sync value)"
connection syscon;
eval alter tenant sys primary_zone = '$zone2';
--sleep 5

connection default;
insert into thezj1 values (1);
insert into thezj2 values (2);
insert into thezj3 values (3);

select table_name, sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name like 'thezj%' order by 1;

connection syscon;
eval alter tenant sys primary_zone = '$zone1';
--sleep 5

connection default;
