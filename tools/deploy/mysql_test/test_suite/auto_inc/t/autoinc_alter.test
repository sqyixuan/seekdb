--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: nijia.nj
# owner group: SQL2
# description: Test altering table to be with / without auto_increment
#

--echo >> alter existing column
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a int , b varchar(20));
alter table t1 modify a int auto_increment;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

insert into t1 values(null,'');
select * from t1;

alter table t1 modify a int;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

insert into t1 values(null,'');
select * from t1;


--echo >> add new table with auto_increment
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(b varchar(20));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

insert into t1 values('');
select * from t1;

alter table t1 add a int auto_increment;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

insert into t1 values('',null);
select * from t1;


alter table t1 set auto_increment = 10240000;
delete from t1;
show create table t1;
insert into t1 values('',null);
select * from t1;
alter table t1 set auto_increment = 1024000000;
show create table t1;
alter table t1 set auto_increment = 1024;
show create table t1;

