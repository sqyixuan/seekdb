--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zuojiao.hzj
# owner group: SQL2
# description: Test last_insert_id()
#

--disable_warnings
drop table if exists t1;
--enable_warnings

--echo #
select last_insert_id(3) from dual;
select last_insert_id(-3) from dual;
select last_insert_id(2) from dual;
select last_insert_id(-2) from dual;
select last_insert_id(9223372036854775807) from dual;
select last_insert_id(-9223372036854775808) from dual;
select last_insert_id(18446744073709551615) from dual;
select last_insert_id(-18446744073709551615) from dual;
select last_insert_id(18446744073709551616) from dual;
select last_insert_id(184467440737095516164324324) from dual;
select last_insert_id(-184467440737095516164324324) from dual;

--echo #
select last_insert_id(0) from dual;
create table t1 (c1 int);
insert into t1 values (7);
select last_insert_id() from dual;
update t1 set c1 =1 where 1 in (select last_insert_id(9) from dual);
select last_insert_id() from dual;
delete from t1 where 1 in (select last_insert_id(19) from dual);
select last_insert_id() from dual;
insert into t1 (select last_insert_id(29) from dual);
select last_insert_id() from dual;
select last_insert_id(0) from dual;
drop table t1;
