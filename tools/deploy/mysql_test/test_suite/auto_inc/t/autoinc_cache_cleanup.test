--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: nijia.nj
# owner group: SQL2
# description:
# 测试点：一个表被 drop 进入回收站后，auto inc 的 cache 也会被清理。
# 当这个表 flashback 后，会生成新的 auto inc cache，并且缓存的值会比原来的大得多，原来的值范围被作废。
# 
#

# create table
--disable_warnings
drop database if exists autoinc_cache_cleanup;
create database autoinc_cache_cleanup;
use autoinc_cache_cleanup;
drop table if exists t1;
--enable_warnings
create table t1 (a int auto_increment, b int) partition by hash(b) partitions 10;
insert into t1 values (NULL, 1);
insert into t1 values (NULL, 2);
select * from t1;
drop table t1;

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'autoinc_cache_cleanup', database_id, 1);
let $tmp_obj_name = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where database_id = $db_id and original_name = 't1', object_name, 1);
connection default;
eval flashback table $tmp_obj_name to before drop;
--enable_query_log

insert into t1 values (NULL, 3);
insert into t1 values (NULL, 4);
select * from t1;
drop table t1;
