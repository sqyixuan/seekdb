--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zuojiao.hzj
# owner group: SQL2
# description: Test auto_increment_cache_size
#

--disable_warnings
drop table if exists thezj;
drop table if exists t1;
--enable_warnings

show variables like 'auto_increment_%';

--echo "basic syntax"
create table thezj (c1 int auto_increment) auto_increment_cache_size = 100;
select auto_increment_cache_size from oceanbase.__all_table where table_name = 'thezj';

alter table thezj set auto_increment_cache_size = 1000;
select auto_increment_cache_size from oceanbase.__all_table where table_name = 'thezj';

insert into thezj values (null);
select sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name = 'thezj';

drop table thezj;

--echo "order mode"
create table thezj (c1 int auto_increment);
insert into thezj values (null);
insert into thezj values (null);
insert into thezj values (null);
show create table thezj;
select sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name = 'thezj';

alter table thezj set auto_increment = 1000000;
alter table thezj set auto_increment_cache_size = 10;
insert into thezj values (null);
insert into thezj values (null);
insert into thezj values (null);
show create table thezj;
select sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name = 'thezj';
drop table thezj;

--echo "noorder mode"
create table thezj (c1 int auto_increment) auto_increment_mode = 'NOORDER', auto_increment_cache_size = 100;
insert into thezj values (null);
show create table thezj;
alter table thezj set auto_increment = 100;
alter table thezj set auto_increment_cache_size = 0;
insert into thezj values (null);
insert into thezj values (null);
insert into thezj values (null);
show create table thezj;
drop table thezj;

--echo "invalid argument"
--error 1210
create table thezj (c1 int auto_increment) auto_increment_cache_size = 100000001;
--error 1064
create table thezj (c1 int auto_increment) auto_increment_cache_size = -1;

--echo "show create table"
create table t1 (c1 int auto_increment) auto_increment_cache_size = 100;
show create table t1;

alter table t1 set auto_increment_cache_size = 1000;
show create table t1;

alter table t1 set auto_increment_cache_size = 0;
show create table t1;
drop table t1;

create table t1 (c1 int auto_increment);
show create table t1;
drop table t1;

create table t1 (c1 int) auto_increment_cache_size = 100;
show create table t1;
drop table t1;
