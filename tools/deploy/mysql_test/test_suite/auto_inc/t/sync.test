# owner: zuojiao.hzj
# owner group: SQL2
# tags: optimizer
# description: Test of auto_increment cache sync
--result_format 4

--disable_warnings
drop table if exists seq;
--enable_warnings

set global auto_increment_cache_size = 1000000;

# 观察 insert on dup 中显式指定自增列时刷 cache 的效果
create table seq (c1 int primary key auto_increment, c2 int unique, c3 int);
insert into seq (c2,c3) values (1,2);
insert into seq (c1,c2,c3) values (9,4,3) on duplicate key update c2 = 31;
insert into seq (c2,c3) values (6,6);
select * from seq;

# 观察 insert on dup 中没有显式指定自增列时刷 cache 的效果
drop table seq;
create table seq (c1 int primary key auto_increment, c2 int unique, c3 int);
insert into seq (c2,c3) values (1,2);
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 31;
insert into seq (c2,c3) values (6,6);
select * from seq;

# 观察 update 语句给自增列带货的效果
drop table seq;
create table seq (c1 int primary key auto_increment, c2 int unique, c3 int);
insert into seq (c2,c3) values (1,1);
insert into seq (c2,c3) values (2,2);
update seq set c1 = 5 where c2 = 2;
select * from seq;
insert into seq (c2,c3) values (2,2) on duplicate key update c2 = 31;
insert into seq (c2,c3) values (3,3);
select * from seq;
--error 1062
insert into seq (c2,c3) values (5,5);
insert into seq (c2,c3) values (6,6);
select * from seq;


# 观察 insert on dup 不刷 cache 的效果

drop table seq;
create table seq (c1 int primary key auto_increment, c2 int unique, c3 int);
insert into seq (c2,c3) values (1,2);
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 31;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 32;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 33;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 34;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 35;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 36;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 37;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 38;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 39;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 40;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 41;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 42;
select * from seq;
insert into seq (c2,c3) values (6,6);
insert into seq (c2,c3) values (7,7);
select * from seq;





# 观察 insert on dup 中间插入一个 insert 操作，刷新 cache 的效果
drop table seq;
create table seq (c1 int primary key auto_increment, c2 int unique, c3 int);
insert into seq (c2,c3) values (1,2);
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 31;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 32;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 33;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 34;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 35;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 36;
select * from seq;
insert into seq (c1,c2,c3) values (18, 6,6);
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 37;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 38;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 39;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 40;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 41;
select * from seq;
insert into seq (c2,c3) values (4,3) on duplicate key update c2 = 42;
select * from seq;
select * from seq;

drop table seq;
