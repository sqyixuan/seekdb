--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zuojiao.hzj
# owner group: SQL2
# description: Test auto increment for 423 enhancement
#

--disable_warnings
drop table if exists thezj;
drop table if exists t1;
--enable_warnings

show variables like 'auto_increment_%';

--echo "Test auto increment insert opt for order mode"
create table thezj (c1 int auto_increment) auto_increment_cache_size = 100;
insert into thezj values(1);
select sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name = 'thezj';

insert into thezj values(2);
select sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name = 'thezj';

insert into thezj values();
select sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name = 'thezj';

