where thezj.sequence_key = t2.table_id and t2.table_name = 'thezj';

insert into thezj values();
select sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name = 'thezj';

insert into thezj values();
select sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name = 'thezj';

insert into thezj values();
select sequence_value, sync_value
from oceanbase.__all_auto_increment thezj, oceanbase.__all_table t2 
where thezj.sequence_key = t2.table_id and t2.table_name = 'thezj';

select * from thezj;
drop table thezj;

SET auto_increment_increment=2;
CREATE TABLE `t1` (   `c1` varchar(5) DEFAULT NULL,   `c2` binary(5) DEFAULT NULL,   `c3` varbinary(5) DEFAULT NULL );
INSERT INTO t1 VALUES(1.5,1.12,10),(2.5,2.23,11),(3.5,3.34,12),(4.5,4.45,10),(5.15,5.56,13),(6.5,6.67,12),(7.5,7.78,11),(8.5,8.89,14),(9.5,9.90,14);
ALTER TABLE t1 CHANGE c1 c1 FLOAT PRIMARY KEY AUTO_INCREMENT;
SHOW CREATE TABLE t1;
INSERT INTO t1(c2,c3) VALUES(10.90,14);
select * from t1;
drop table t1;
SET auto_increment_increment=1;

--echo issue/55302234
create table t1 (c1 int) auto_increment_mode = 'noorder';
insert into t1 values (100);
alter table t1 change column c1 c1 int auto_increment;
show create table t1;
drop table t1;

create table t1(b int);
insert into t1 values (2);
alter table t1 add column a int auto_increment before b;
alter table t1 add primary key(a);
insert into t1(b) values(51);
alter table t1 set AUTO_INCREMENT_MODE = 'noorder';
alter table t1 drop primary key;
select * from t1;
