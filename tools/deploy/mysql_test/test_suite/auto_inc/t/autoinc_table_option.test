--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: nijia.nj
# owner group: SQL2
# description: Test table option auto_increment
#

--echo >> auto_increment=10
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (b varchar(20), a int) auto_increment=10;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (b varchar(20), a int auto_increment) auto_increment=10;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (b varchar(20), a int auto_increment primary key) auto_increment=10;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (b varchar(20), a int auto_increment, primary key (a)) auto_increment=10;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (b varchar(20), a int auto_increment, key (a)) auto_increment=10;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (b varchar(20), a int auto_increment, unique key (a)) auto_increment=10;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
 

