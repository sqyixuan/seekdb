--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: nijia.nj
# owner group: SQL2
# description: Test auto_increment related variables
#

set @saved_sql_mode = @@session.sql_mode;
#select @saved_sql_mode;

# sql mode改为非严格模式
set @@session.sql_mode = '';
select @@session.sql_mode;

show variables like 'auto_in%';

set session auto_increment_increment=5;
set session auto_increment_offset=2;
show variables like 'auto_in%';

--error 1232
set session auto_increment_increment='a';
set session auto_increment_offset=2;
show variables like 'auto_in%';

set session auto_increment_increment=5;
--error 1232
set session auto_increment_offset='abc';
show variables like 'auto_in%';

set session auto_increment_increment=5;
set session auto_increment_offset=6;
show variables like 'auto_in%';

set session auto_increment_increment=-1;
show variables like 'auto_in%';
set session auto_increment_offset=2;
show variables like 'auto_in%';

set session auto_increment_increment=5;
set session auto_increment_offset=-1;
show variables like 'auto_in%';

set session auto_increment_increment=-1;
set session auto_increment_offset=-1;
show variables like 'auto_in%';

set session auto_increment_increment=-1;
set session auto_increment_offset=-2;
show variables like 'auto_in%';

set session auto_increment_increment=9999;
set session auto_increment_offset=2;
show variables like 'auto_in%';

set session auto_increment_increment=5;
set session auto_increment_offset=9999;
show variables like 'auto_in%';

set session auto_increment_increment=9999;
set session auto_increment_offset=9999;
show variables like 'auto_in%';

# sql mode改回来
set @@session.sql_mode = @saved_sql_mode;
#select @@session.sql_mode;
