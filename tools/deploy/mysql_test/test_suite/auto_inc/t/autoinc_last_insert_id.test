--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: nijia.nj
# owner group: SQL2
# description: Test last_insert_id()
#

# 1. SELECT `AUTO_INCREMENT` FROM  INFORMATION_SCHEMA.TABLES
# WHERE TABLE_SCHEMA = 'test' AND   TABLE_NAME   = 't1';
#

--disable_warnings
drop table if exists t1;
--enable_warnings

#set @@ob_read_consistency='weak';

create table t1 (a int primary key auto_increment, b varchar(20));

--echo >> insert/replace should change last_insert_id()
insert into t1 values(0,''),(0,''),(null,''),(null,'');
select last_insert_id();
# It it not implemented in OB for the following query
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';

insert into t1 values(-1,'');
select last_insert_id();
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';

insert into t1 values(10,'');
select last_insert_id();
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';

replace into t1 values(0,''),(0,''),(null,''),(null,'');
select last_insert_id();
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';

--echo >> update doesn't change last_insert_id()
update t1 set a=16 where a=1;
select last_insert_id();
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
insert into t1 values(null,'');
select last_insert_id();


--echo >> delete doesn't change last_insert_id()
insert into t1 values(30,'');
select last_insert_id();
insert into t1 values(null,''),(null,'');
select last_insert_id();
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';

delete from t1 where a=32;
select last_insert_id();
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';


--echo >> last_insert_id() returns undef if the last stmt fails
--error 1062
insert into t1 values(30,'');
select last_insert_id();


--echo >> last_insert_id() returns undef after rollback
set autocommit=0;
begin;
insert into t1 values(null,'');
rollback;
select last_insert_id();


--echo >> auto_increment is reset to 1 after delete and define the new table
drop table t1;
create table t1 (a int primary key auto_increment, b varchar(20));
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
select last_insert_id();


--echo >> auto_increment should be reset to 1 after drop and add of the auto_increment field
drop table t1;
create table t1 (a int auto_increment, b int, primary key(b), unique index(a));

insert into t1 values(0,1),(0,2);
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
select last_insert_id();

# can not drop index column now
#alter table t1 drop column a;
#select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
#select last_insert_id();
#
#alter table t1 add column a int auto_increment;
#select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
#select last_insert_id();


--echo >> auto_increment should be null if auto_increment field is modified to not auto_increment
drop table t1;
create table t1 (a int auto_increment, b int, primary key(b), unique index(a));
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
select last_insert_id();

alter table t1 modify a int;
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
select last_insert_id();


--echo >> auto_increment remains not changed if remove auto_increment and then add auto_increment on the same field
drop table t1;
create table t1 (a int auto_increment, b int, primary key(b));
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
select last_insert_id();

insert into t1 values(0,1),(0,2);
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
select last_insert_id();

alter table t1 modify a int;
alter table t1 modify a int auto_increment;
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
select last_insert_id();


--echo >> add a new auto_increment field, check the old data
drop table t1;
create table t1 (a int primary key);
insert into t1 values(1),(2),(3);
select * from t1;

alter table t1 add column b int auto_increment;
insert into t1 values(4,null),(5,null);
select * from t1;


drop table t1;
create table t1 (a int primary key);
insert into t1 values(1),(2),(3);
select * from t1;

alter table t1 add column b int auto_increment;
insert into t1 values(4,null),(5,null);
select * from t1;


--echo >> test auto_increment value after manual update (not automatic)
drop table t1;
create table t1 (a int auto_increment primary key, b varchar(20));
insert into t1 values(0,''),(0,''),(0,''),(0,'');
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
select last_insert_id();

insert into t1 values(-1,'');
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
select last_insert_id();

replace into t1 values(-2,'');
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
select last_insert_id();

insert into t1 values(10,'');
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
select last_insert_id();

replace into t1 values(20,'');
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
select last_insert_id();

update t1 set a=100 where a=1;
select `auto_increment` from information_schema.tables where table_schema='test' and table_name='t1';
select last_insert_id();
