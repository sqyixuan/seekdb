--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zuojiao.hzj
# owner group: SQL2
# description: Test auto increment for alter auto_increment ddl
#

--disable_warnings
drop table if exists thezj;
drop table if exists t1;
--enable_warnings

show variables like 'auto_increment_%';

--echo "Test alter command to reduce auto_increment"
--echo "basic"
create table t1 (c1 bigint auto_increment primary key);
insert into t1 values (), (), (), ();
show create table t1;
delete from t1;
alter table t1 set auto_increment = 1;
show create table t1;
insert into t1 values (), (), (), ();
select * from t1;
drop table t1;

create table t1 (c1 bigint auto_increment);
insert into t1 values (), (), (), ();
insert into t1 values (100);
show create table t1;
alter table t1 set auto_increment = 200;
show create table t1;
insert into t1 values ();
select * from t1;

delete from t1 where c1 >= 100;
alter table t1 set auto_increment = 50;
show create table t1;
alter table t1 set auto_increment = 2;
show create table t1;
insert into t1 values ();
select * from t1;

drop table t1;

--echo "unsigned types"
create table t1 (c1 bigint unsigned auto_increment);
insert into t1 values (18446744073709551615);
show create table t1;
--error 1467
insert into t1 values ();
select * from t1;
alter table t1 set auto_increment = 2;
show create table t1;
--error 1467
insert into t1 values ();
select * from t1;
drop table t1;

--echo "signed type with negative value"
create table t1 (c1 bigint auto_increment);
insert into t1 values (-1000);
insert into t1 values (-100);
alter table t1 set auto_increment = 1;
show create table t1;
insert into t1 values ();
drop table t1;

--echo "noorder mode"
create table t1 (c1 bigint auto_increment primary key) auto_increment_mode = 'NOORDER';
insert into t1 values (), (), (), ();
show create table t1;
delete from t1;
alter table t1 set auto_increment = 1;
show create table t1;
insert into t1 values (), (), (), ();
select * from t1;
drop table t1;

