--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: auto_inc
# description:
#
use test;
--echo ================= basic auto-increment test ===================
--echo ================= variable/columns/sql_mode ===================
# on primary key(single) column
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key auto_increment, c2 int);

set auto_increment_increment=1;
set auto_increment_offset=1;

# with column ,value(0)
insert into t1(c1, c2) values(0,1),(0,2);
select * from t1;

# with column , value(NULL)
insert into t1(c1,c2) values(NULL,1),(NULL,2);
select * from t1;

# without all columns , with value(0)
insert into t1 values(0,1),(0,2);
select * from t1;

# without all columns, with value(NULL)
insert into t1 values(NULL,1),(NULL,2);
select * from t1;

#without increment_col
insert into t1(c2) values(1),(2);
select * from t1;

# set sql_mode(session)
set session sql_mode = 'NO_AUTO_VALUE_ON_ZERO';
# select sql_mode(session)
select @@sql_mode;
# without column , with value(0)
insert into t1 values(0,1);
select * from t1;

set session sql_mode = '';

# set auto_increment_increment(session)
set auto_increment_increment=2;
show variables like '%increment%';

insert into t1(c2) values(1),(2);
select * from t1;

# set auto_increment_offset(session)
set auto_increment_offset=2;
show variables like '%increment%';

insert into t1(c2) values(1),(2);
select * from t1;

# delete
delete from t1 where c1>10;
select * from t1;

insert into t1(c2) values(1),(2);
select * from t1;

# update col
update t1 set c1=25 where c1=20;
insert into t1(c2) values(1),(2);
select * from t1;

--echo ================= mixed-insert auto-increment test ===================

insert into t1 values(11,1),(14,2);
select * from t1;

insert into t1 values(50, 1), (100, 2);
select * from t1;

insert into t1 values(0, 1), (0, 2);
select * from t1;

set auto_increment_increment=1;
set auto_increment_offset=1;
delete from t1;
let $is_truncate_table = 1;
let $is_truncate_table = 0;
insert into t1 values(11, 1),(-1, 1),(NULL, 1);
select * from t1;
select last_insert_id();
insert into t1 values(null, 1);
select last_insert_id();
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings

--echo ================= alter table auto-increment test ===================
# alter table test
set auto_increment_increment=1;
set auto_increment_offset=1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key);
# add column
alter table t1 add c2 int auto_increment;
insert into t1 values(1, 0);
insert into t1 values(2, 0);
select * from t1;
# modify to non auto-increment
alter table t1 modify c2 int;
insert into t1 values(3, 0);
select * from t1;
# add column
alter table t1 add c3 int auto_increment;
insert into t1 values(4, 1, 0);
insert into t1 values(5, 1, 0);
select * from t1;
# drop column
alter table t1 drop c2;
select * from t1;
# change to auto-increment
alter table t1 change c3 c2 int auto_increment;
insert into t1 values(6, 0);
insert into t1 values(7, 0);
select * from t1;
# modify to non auto-increment
alter table t1 modify c2 int;
insert into t1 values(8, 0);
insert into t1 values(9, 0);
select * from t1;

# cleanup
--disable_warnings
drop table if exists t1;
--enable_warnings

--echo ================= auto-increment boundary test ===================
create table t1(c1 int primary key, c2 tinyint auto_increment);
insert into t1 values (1, 126);
insert into t1 values (2, 0), (3, 0);
select * from t1;
insert into t1 values (4, 0);
select * from t1;

--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2(c1 bigint unsigned primary key auto_increment);
insert into t2 values (18446744073709551614);
--error 1467
insert into t2 values (0);

--disable_warnings
drop table if exists t3;
--enable_warnings
create table t3(c1 bigint primary key auto_increment);
set auto_increment_increment = 1000;
insert into t3 values (9223372036854775807);
select * from t3;
set auto_increment_increment = 1;

drop table t1, t2, t3;

--echo ================= auto-increment prefetch test ===================
create table t1(c1 int primary key auto_increment);
insert into t1 values (0);
insert into t1 values (999998);
insert into t1 values (0);
select * from t1;
insert into t1 values (0), (0), (0);
select * from t1;
insert into t1 values (2999999);
insert into t1 values (0), (0), (0), (0), (0);
select * from t1;

drop table t1;

--echo ================= auto-increment truncate test ===================
create table t1(c1 int primary key auto_increment);
insert into t1 values (0), (NULL), (0);
select * from t1;
delete from t1;
let $is_truncate_table = 1;
let $is_truncate_table = 0;
select * from t1;

drop table t1;

--echo ================= auto-increment last_insert_id test ===================
create table t1(c1 int primary key auto_increment);
insert into t1 values (0), (NULL), (0);
select last_insert_id();
insert into t1 values (100);
select last_insert_id();
insert into t1 values (0), (1000), (0);
select last_insert_id();
insert into t1 values (null);
select last_insert_id();
#select last_insert_id(-1);
#select last_insert_id();

create table t2(c1 int primary key auto_increment);
select last_insert_id();

drop table t1, t2;

select last_insert_id();

--echo ================= auto-increment and insert...on duplicate key update  ===================
create table t1(c1 int primary key, c2 int auto_increment, c3 int default 1);
insert into t1(c1, c2) values (1, null);
select * from t1;
select last_insert_id();
# when duplicate, auto-generated value should be reused in next row
insert into t1(c1, c2)  values (1, null), (2, null) on duplicate key update c3 = c3 + 1;
select * from t1;
select last_insert_id();
insert into t1(c1, c2)  values (3, null);
select * from t1;
select last_insert_id();
# (duplicate row), (duplicate row), (normal row)
# first auto-generated value used is genreated in firt row
insert into t1(c1, c2)  values (1, null), (2, null), (4, null) on duplicate key update c3 = c3 + 1;
select * from t1;
select last_insert_id();
insert into t1(c1, c2)  values (5, null);
select * from t1;
select last_insert_id();

delete from t1;
let $is_truncate_table = 1;
let $is_truncate_table = 0;
insert into t1(c1, c2)  values (1, null), (2, null);
# last_insert_id is changed when duplicate is found in a middle row
--error 1062
insert into t1(c1, c2)  values (3, null), (2, null), (4, null);
select * from t1;
select last_insert_id();

drop table t1;

# when insert...on duplicate do not generate new row, last_insert_id should not be changed
create table t1(c1 int primary key, c2 int auto_increment, unique index(c2), c3 int, c4 int);
insert into t1(c1,c4) values(0,0);
select * from t1;
select last_insert_id();
insert into t1(c1) values(0) on duplicate key update c3=last_insert_id(), c4=c4+1;
select * from t1;
select last_insert_id();

drop table t1;

# to be compitable with MySQL
# when first value is specified by user(may duplicate or not), allocate this row's value too
CREATE TABLE t1 (c2 char(100),c1 bigint auto_increment primary key);
INSERT INTO t1 ( c1 , c2 ) VALUES ( 99 , 'aa' ) ;
INSERT INTO t1 ( c1 , c2 ) VALUES ( 99 , 'bb' ) , ( 0 , 'cc' ) ON DUPLICATE KEY UPDATE c2 = 'dd' ;
INSERT INTO t1 ( c1 , c2 ) VALUES ( NULL , 'ee' ) ON DUPLICATE KEY UPDATE c2 = 'ff' ;
SELECT * FROM t1 order by c1;

drop table t1;

# when insert is duplicated and update is duplicated too, do not sync user specified value
create table t1(c1 bigint key auto_increment);
insert into t1 values (99);
insert into t1 values (0);
insert into t1 values (0);
update t1 set c1 = 999999999 where c1 = 101;
select * from t1;
--error 1062
insert into t1 values (99) on duplicate key update c1 = 999999999;
insert into t1 values (0);
select * from t1;

drop table t1;

# insert is duplicated, but after update, auto-generated value still used
create table t1(c1 int key, c2 int auto_increment);
insert into t1 values (1, 0), (2, 0), (3, 0);
insert into t1 values (4, 0), (5, 0), (6, 0);
select * from t1;
# first row is duplicated, but now we do insert_up with batch_execute, so auto-generated value 7,8,9 will be used 
insert into t1 values (6, 0), (8, 0), (9, 0) on duplicate key update c2 = 7;
select * from t1;
insert into t1 values (10, 0);
select * from t1;

# to be compitable with MySQL
# when insert is duplicated and update value in auto-generated range, return error
drop table t1;
create table t1(c1 int key, c2 int auto_increment);
let $is_truncate_table = 1;
let $is_truncate_table = 0;
insert into t1 values (1, 0), (2, 0), (3, 0);
insert into t1 values (4, 0), (5, 0), (6, 0);
select * from t1;
# second row is duplicated
# but c2 = 7 is used in previous row
insert into t1 values (7, 0), (6, 0), (9, 0) on duplicate key update c2 = 7;
select * from t1;
insert into t1 values (10, 0);
select * from t1;

drop table t1;

create table t1(c1 int auto_increment primary key, c2 int);
insert into t1(c1) values(0);
update t1 set c1 = 99999 where c1=1;
# when row do not change, should not sync value
insert into t1(c1) values(99999) on duplicate key update c2=c2;
insert into t1(c1) values(0);
select * from t1;
# when row changed, should sync value
insert into t1(c1) values(99999) on duplicate key update c2=1;
insert into t1(c1) values(0);
select * from t1;

drop table t1;

--echo ================= auto-increment first row is duplicate  ===================
# auto-increment sequence should not be affected
create table t1(c1 int primary key auto_increment, c2 int);
insert into t1 values (null, 1), (null, 1), (null, 1);
select * from t1;
# first row is duplicate
--error 1062
insert into t1 values (3, 1), (null, 1), (null, 1);
# no gap should appear in auto-increment value
insert into t1 values (null, 1);
select * from t1;

drop table t1;

--echo ================= auto-increment conflict with row existed ===================
create table t1(c1 int primary key auto_increment, c2 int);
insert into t1 values (null, 1), (null, 1), (null, 1);
select * from t1;
update t1 set c1 = 5 where c1 = 3;
select * from t1;
# it's strange, but is compatible with MySQL
# auto-increment value reused in next row; but it is duplicate again
# the row c1 = 5, c2 = 3; two duplicate row
insert into t1 values (null, 1), (null, 1), (null, 1) on duplicate key update c2 = c2 + 1;
select * from t1;
select last_insert_id();

drop table t1;

# if insert single row and this row is duplicate, it won't change last_insert_id
create table t1(c1 int auto_increment primary key);
insert into t1 values(null);
update t1 set c1=9 where c1=1;
insert into t1 values(8);
select last_insert_id();
--error 1062
insert into t1 values(null);
select last_insert_id();

drop table t1;

--echo ================= auto-increment in select / update===================
# last_insert_id(#) called in where
SELECT LAST_INSERT_ID(20);
SELECT 1 FROM dual WHERE LAST_INSERT_ID( 10 ) = 10 ;
SELECT LAST_INSERT_ID();

create table t1(c1 bigint primary key auto_increment, c2 char(20));
insert into t1 values (1, "test");
select last_insert_id(11);
update  t1 set c1 = 9, c2 = last_insert_id(length(cast(last_insert_id() as char(100))));
select last_insert_id();
select * from t1;

drop table t1;

--echo ================= auto-increment range re-allocation ===================
create table t1(c1 int key auto_increment);
insert into t1 values (null), (10), (20), (null);
insert into t1 values (null);
select * from t1;

# sync 30 makes range allocated invalid; next allocation re-allocate 4 values
delete from t1;
let $is_truncate_table = 1;
let $is_truncate_table = 0;
insert into t1 values (10), (20), (null), (30), (40), (null), (null);
insert into t1 values (null);
select * from t1;

# sync 26 makes range allocated exhausted; next allocation re-allocate 4 values
delete from t1;
let $is_truncate_table = 1;
let $is_truncate_table = 0;
insert into t1 values (10), (20), (null), (26), (null), (null), (null);
insert into t1 values (null);
select * from t1;

drop table t1;
