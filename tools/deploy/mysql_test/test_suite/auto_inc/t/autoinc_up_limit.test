--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: nijia.nj
# owner group: SQL2
# description: Test up limit for different integer types with auto_increment
# 

--echo >> Test tinyint (-128~127)
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a int, b int, c tinyint auto_increment, primary key(a), unique index(b), index(c)) auto_increment=100;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,1,127);
insert into t1 values(2,2,null);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
select * from t1;


--echo >> Test smallint (-32768~32767)
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a int, b int, c smallint auto_increment, primary key(a), unique index(b), index(c)) auto_increment=30000;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,1,32767);
insert into t1 values(2,2,null);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
select * from t1;


--echo >> Test mediumint (-8388608~8388607)
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a int, b int, c mediumint auto_increment, primary key(a), unique index(b), index(c)) auto_increment=8000000;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,1,8388607);
insert into t1 values(2,2,null);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
select * from t1;


--echo >> Test integer (-2147483648~2147483647)
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a int, b int, c integer auto_increment, primary key(a), unique index(b), index(c)) auto_increment=2000000000;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,1,2147483647);
insert into t1 values(2,2,null);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
select * from t1;


--echo >> Test bigint (-9223372036854775808~9223372036854775807)
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a int, b int, c bigint auto_increment, primary key(a), unique index(b), index(c)) auto_increment=9000000000000000000;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,1,9223372036854775807);
insert into t1 values(2,2,null);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
select * from t1;


