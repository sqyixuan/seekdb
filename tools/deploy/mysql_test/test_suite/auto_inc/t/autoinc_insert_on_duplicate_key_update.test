--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: nijia.nj
# owner group: SQL2
# description:
#

--echo >> insert on duplicate key update with simple insert and mixed insert
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int primary key auto_increment, c2 int);

--echo >> simple insert
insert into t1 values (1, 10), (2, 10);
insert into t1 values (null, 15), (null, 15);
select * from t1;
insert into t1 values (0, 16), (0, 16);
select * from t1;

insert into t1 values (10, 18);
select * from t1;
insert into t1 values (null, 20);
select * from t1;
insert into t1 values (0, 22);
select * from t1;

insert into t1 values (null,101), (118, 100), (119, 100) on duplicate key update c2=100;
select * from t1;
insert into t1 values (null,20);
select * from t1;

insert into t1 values (114, 100), (null, 100), (111, 100) on duplicate key update c2=100;
select * from t1;
insert into t1 values (null,20);
select * from t1;

insert into t1 values (114, 100), (null, 100), (10, 100) on duplicate key update c2=200;
select * from t1;
insert into t1 values (null,20);
select * from t1;

insert into t1 values (214, 100), (null, 100), (211, 100);
select * from t1;
insert into t1 values (null,20);
select * from t1;

insert into t1 values (null, 100), (null, 100), (311, 100);
select * from t1;
insert into t1 values (null,20);
select * from t1;

insert into t1 values (null, 100), (411, 100), (null, 100);
select * from t1;
insert into t1 values (null,20);
select * from t1;

insert into t1 values (null, 10), (25, 100), (null, 100);
select * from t1;
insert into t1 values (null,20);
select * from t1;


