--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zuojiao.hzj
# owner group: SQL2
# description: Test auto increment mode.
#

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

set global auto_increment_cache_size = 1000000;
alter system set default_auto_increment_mode = 'ORDER';

--echo ## test default auto increment mode configure and create table.
alter system set default_auto_increment_mode = 'ORDER';
sleep 2;
create table t1 (a int auto_increment);
create table t2 (a int auto_increment) auto_increment_mode = 'ORDER';
create table t3 (a int auto_increment) auto_increment_mode = 'NOORDER';
show create table t1;
show create table t2;
show create table t3;
drop table t1;
drop table t2;
drop table t3;

alter system set default_auto_increment_mode = 'NOORDER';
sleep 2;
create table t1 (a int auto_increment);
create table t2 (a int auto_increment) auto_increment_mode = 'ORDER';
create table t3 (a int auto_increment) auto_increment_mode = 'NOORDER';
show create table t1;
show create table t2;
show create table t3;
drop table t1;
drop table t2;
drop table t3;

--error 4147
alter system set default_auto_increment_mode = 'INVALID';


--echo ## test alter table auto_increment_mode and clear cache
alter system set default_auto_increment_mode = 'ORDER';
sleep 2;
create table t1 (a int auto_increment) auto_increment_mode = 'ORDER';
show create table t1;
insert into t1 values();
insert into t1 values();
insert into t1 values();
select * from t1;

--echo ## alter table auto_increment_mode will clear cache.
alter table t1 auto_increment_mode = 'NOORDER';
show create table t1;
insert into t1 values();
insert into t1 values();
insert into t1 values();
select * from t1;
alter table t1 auto_increment_mode = 'ORDER';
show create table t1;
insert into t1 values();
insert into t1 values();
insert into t1 values();
select * from t1;
drop table t1;

--echo ## auto_increment_mode does not change and will not clear cache.
create table t1 (a int auto_increment) auto_increment_mode = 'ORDER';
show create table t1;
insert into t1 values();
insert into t1 values();
insert into t1 values();
select * from t1;
alter table t1 auto_increment_mode = 'ORDER';
show create table t1;
insert into t1 values();
insert into t1 values();
insert into t1 values();
select * from t1;
create table t2 (a int auto_increment) auto_increment_mode = 'NOORDER';
show create table t2;
insert into t2 values();
insert into t2 values();
insert into t2 values();
select * from t2;
alter table t2 auto_increment_mode = 'NOORDER';
show create table t2;
insert into t2 values();
insert into t2 values();
insert into t2 values();
select * from t2;

--echo ## clear cache only clears specific keys
alter table t2 auto_increment_mode = 'ORDER';
insert into t1 values();
insert into t2 values();
select * from t1;
select * from t2;
alter table t1 auto_increment_mode = 'NOORDER';
insert into t1 values();
insert into t2 values();
select * from t1;
select * from t2;
drop table t1;
drop table t2;

alter system set default_auto_increment_mode = 'ORDER';
set global auto_increment_cache_size = 1000000;
sleep 2;
