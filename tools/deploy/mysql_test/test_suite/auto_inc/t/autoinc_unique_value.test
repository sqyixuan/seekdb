--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: nijia.nj
# owner group: SQL2
# description: Test unique value of auto_increment field
#

--echo >> Verify continuty of field with auto_increment for simple inserts
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a int auto_increment primary key, b varchar(20)) auto_increment=20;

insert into t1 values (null,'vc1'),(null,'vc2'),(null,'vc3');
insert into t1 values (0,'vc4'),(0,'vc5'),(0,'vc6');
insert into t1 values (0,'vc7'),(null,'vc8'),(0,'vc9'),(null,'vc10');
insert into t1(b) values('vc11'),('vc12'),('vc13'),('vc14');
select * from t1;


--echo >> Verify continuty of field with auto_increment for bulk inserts
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2 (b char(20));
insert into t2 values('t2_vc1'),('t2_vc2'),('t2_vc3'),('t2_vc4');
insert into t1(b) select b from t2;
select * from t1;


--echo >> No continuty guarentee of auto_increment field for insert-like stmts
drop table t1;
create table t1 (c1 int auto_increment, c2 char(20), primary key(c1));
insert into t1 values(1,'a'),(null,'b'),(null,'c'),(8,'d'),(null,'e');
select * from t1;

insert into t1 values(null,'f');
select * from t1;


