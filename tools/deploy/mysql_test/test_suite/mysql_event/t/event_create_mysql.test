--echo ################## create recurring event 2001 ~ 4000
--echo ############ test on schedule 2001 ~ 3000
--echo ###### case 2001
drop event if exists e_2001;
create event e_2001 on schedule every 1 second do select 1;
select count(*) from information_schema.events where 
  EVENT_SCHEMA = 'test' and EVENT_NAME = 'e_2001' and DEFINER = 'hrh@%' and EVENT_TYPE = 'RECURRING' and
  EXECUTE_AT IS NULL and INTERVAL_VALUE = '1' and INTERVAL_FIELD = 'SECOND' and STARTS < NOW() + INTERVAL 10 SECOND  and ENDS IS NULL and
  STATUS = 'ENABLED' and ON_COMPLETION = 'NOT PRESERVE' and LAST_EXECUTED IS NULL and EVENT_COMMENT IS NULL;
drop event e_2001;

