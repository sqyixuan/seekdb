# owner: huangrenhuang.hrh
# owner group: 系统组
# description: mysql event 创建
# tags: pl
# author: huangrenhuang.hrh

connect (conn_root,$OBMYSQL_MS0,root, ,test,$OBMYSQL_PORT);
connection conn_root;

purge recyclebin;
--result_format 4
--error 0,1396
drop user hrh@'%';
--enable_warnings

create user hrh identified by 'hrh';
grant all on *.* to hrh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn_hrh,$OBMYSQL_MS0,hrh,hrh,test,$OBMYSQL_PORT);
connection conn_hrh;

SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';

SET GLOBAL event_scheduler=off;

--echo ------------------------------------------------------------------------------------
--echo ################## 环境
--error 0,1051
drop table t1;
CREATE TABLE t1 ( 
  id int
);
--echo ################## create one time event 1 ~ 2000
--echo ############ test at datetime 1 ~ 1000
--echo ###### case 1
drop event if exists e_1;
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
select count(*) from information_schema.events where 
  EVENT_SCHEMA = 'test' and EVENT_NAME = 'e_1' and DEFINER = 'hrh@%' and EVENT_TYPE ='ONE TIME' and
  EXECUTE_AT = '3000-01-01 00:00:00' and INTERVAL_VALUE IS NULL and INTERVAL_FIELD IS NULL and STARTS IS NULL and ENDS IS NULL and
  STATUS = 'ENABLED' and ON_COMPLETION = 'NOT PRESERVE' and LAST_EXECUTED IS NULL and EVENT_COMMENT IS NULL;
drop event e_1;

--echo ###### case 2
drop event if exists e_2;
