--echo ############ alter error
--echo ###### init
drop event if exists e_alter;
create event e_alter on schedule at '3000-01-01 00:00:00' do select 1;
--echo ###### case 1 alter at past time
--error ER_WRONG_VALUE
alter event e_alter on schedule at '1000-01-01 00:00:00' do select 1;

--echo ###### case 2 alter at past time
--error ER_EVENT_CANNOT_ALTER_IN_THE_PAST
alter event e_alter on schedule at '2010-01-01 00:00:00' do select 1;

--echo ###### case 3 alter every 0 interval
--error ER_EVENT_INTERVAL_NOT_POSITIVE_OR_TOO_BIG
alter event e_0_interval on schedule every 0 second do select 1;

--echo ###### case 4 alter every big interval
--error ER_EVENT_INTERVAL_NOT_POSITIVE_OR_TOO_BIG
alter event e_1000000000000_interval on schedule every 1000000000000 second do select 1;

--echo ###### case 5 alter ends > starts
--error ER_EVENT_ENDS_BEFORE_STARTS
alter event e_alter on schedule every 1 second starts '3000-01-01 00:00:00' ends '2999-01-01 00:00:00' do select 1;

--echo ###### case 6 alter same name
--error ER_EVENT_SAME_NAME
alter event e_alter rename to e_alter;

--echo ###### case 7 alter too long event body single sql
--error ER_EVENT_DATA_TOO_LONG
alter event e_alter on schedule every 10 second do 
  select "abcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghij
