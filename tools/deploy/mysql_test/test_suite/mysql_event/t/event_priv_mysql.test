# description: mysql event priv case
# tags: pl
# author: huangrenhuang.hrh

--echo # ◆ 准备测试用户
--disable_warnings
drop user if exists eve_hrhtest0;
drop database if exists eve_hrhtest0_db;
create user 'eve_hrhtest0' identified by 'eve_hrhtest0';
grant super,create,drop,alter,select,update,insert,delete on *.* to 'eve_hrhtest0'@'%' with grant option;
create database eve_hrhtest0_db character set utf8;

drop user if exists eve_hrhtest1;
drop database if exists eve_hrhtest1_db;
create user 'eve_hrhtest1' identified by 'eve_hrhtest1';
create database eve_hrhtest1_db character set utf8;
grant super,create,drop,alter,select,update,insert,delete on *.* to 'eve_hrhtest1'@'%' with grant option;
--enable_warnings

--source mysql_test/include/check_schema_sync.inc
connect (conn_sys,$obmysql_ms0,root@sys,,oceanbase,$obmysql_port);
connect (conn_session0,$obmysql_ms0,eve_hrhtest0,eve_hrhtest0,eve_hrhtest0_db,$obmysql_port);

--echo #-----------------------------------------------------------------------------
--echo # mysql支持event权限：场景测试
--echo # 测试event权限
--echo #-----------------------------------------------------------------------------

--echo #### ◆◆ case 1 用户无event权限时，预期进行事件操作失败
connection conn_session0;
SET GLOBAL sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER';

--error 1044
drop event if exists e_1;

--error 1044
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

--error 1044
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';


--echo #### ◆◆ case 2 授予用户event权限时，预期进行事件操作成功
disconnect conn_session0;
connection default;
grant event on *.* to 'eve_hrhtest0';
show grants for eve_hrhtest0;

connect (conn_session0,$obmysql_ms0,eve_hrhtest0,eve_hrhtest0,eve_hrhtest0_db,$obmysql_port);
connection conn_session0;

drop event if exists e_1;
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';

drop event e_1;

--echo #### ◆◆ case 3 撤销用户event权限后，预期进行事件操作失败
disconnect conn_session0;
connection default;
revoke event on *.* from 'eve_hrhtest0';
show grants for eve_hrhtest0;

--echo # 连接用户 eve_hrhtest0
connect (conn_session0,$obmysql_ms0,eve_hrhtest0,eve_hrhtest0,eve_hrhtest0_db,$obmysql_port);
connection conn_session0;

--error 1044
drop event if exists e_1;

--error 1044
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

--error 1044
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';

--echo #### ◆◆ case 4 授权/撤销 ALL PRIVILEGES 权限，验证事件操作
disconnect conn_session0;
connection default;
GRANT ALL PRIVILEGES ON *.* TO eve_hrhtest0;
show grants for eve_hrhtest0;

connect (conn_session0,$obmysql_ms0,eve_hrhtest0,eve_hrhtest0,eve_hrhtest0_db,$obmysql_port);
connection conn_session0;

drop event if exists e_1;

create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';

drop event e_1;

--echo # 撤销
disconnect conn_session0;
connection default;
revoke all privileges, grant option from eve_hrhtest0;
grant super,create,drop,alter,select,update,insert,delete on *.* to 'eve_hrhtest0'@'%' with grant option;
show grants for eve_hrhtest0;

--echo # 连接用户 eve_hrhtest0
connect (conn_session0,$obmysql_ms0,eve_hrhtest0,eve_hrhtest0,eve_hrhtest0_db,$obmysql_port);
connection conn_session0;

--error 1044
drop event if exists e_1;

--error 1044
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

--error 1044
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';

--echo #### ◆◆ case 5 授权/撤销event权限给不存在的用户，预期失败
disconnect conn_session0;
connection default;

--error 1045
grant event on *.* to 'nouser';
--error 1045
grant event on eve_hrhtest0.* to 'nouser';
--error 1144
grant event on eve_hrhtest0.tab1 to 'nouser';
--error 1133
revoke event on *.* from 'nouser';
--error 1133
revoke event on eve_hrhtest0.* from 'nouser';
--error 1144
revoke event on eve_hrhtest0.tab1 from 'nouser';

--echo #### ◆◆ case 6 撤销用户不存在某级别的event权限，预期失败
connection default;
grant event on *.* to 'eve_hrhtest0';
show grants for eve_hrhtest0;

--error 5133
revoke event on eve_hrhtest0_db.* from 'eve_hrhtest0';
--error 1144
revoke event on eve_hrhtest0_db.tab1 from 'eve_hrhtest0';


--echo #### ◆◆ case 7 授权/撤销event权限时与其他权限一起指定
--echo # 授权event权限
grant event,alter,alter routine,create view,delete,execute,file,index,insert,select,show view,update on *.* to 'eve_hrhtest0';
show grants for eve_hrhtest0;

--echo # 连接用户 eve_hrhtest0
connect (conn_session0,$obmysql_ms0,eve_hrhtest0,eve_hrhtest0,eve_hrhtest0_db,$obmysql_port);
connection conn_session0;

drop event if exists e_1;

create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';

drop event e_1;

--echo # 撤销event权限
disconnect conn_session0;
connection default;
revoke event,alter,alter routine,create view,delete,execute,file,index,show view,update on *.* from 'eve_hrhtest0';
show grants for eve_hrhtest0;

--echo # 连接用户 eve_hrhtest0
connect (conn_session0,$obmysql_ms0,eve_hrhtest0,eve_hrhtest0,eve_hrhtest0_db,$obmysql_port);
connection conn_session0;

--error 1044
drop event if exists e_1;

--error 1044
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

--error 1044
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';


--echo #### ◆◆ case 8 授权/撤销event权限后，检查关于event权限信息是否更新到内部表
--echo # 授权event权限（用户级别）
disconnect conn_session0;
connection default;
grant event on *.* to 'eve_hrhtest0';
show grants for eve_hrhtest0;

select user_name,priv_event from oceanbase.dba_ob_users where user_name like 'eve_hrhtest_' order by 1,2;
select grantee,privilege_type,is_grantable from information_schema.user_privileges where privilege_type ='event' and grantee like '%hrh%' order by 1,2,3;
select user,event_priv from mysql.user where user like 'eve_hrhtest%' order by 1,2;

connection conn_sys;
select user_name,priv_event from oceanbase.cdb_ob_users where user_name like 'eve_hrhtest_' order by 1,2;


--echo # 撤销event权限（用户级别）
connection default;
revoke event on *.* from 'eve_hrhtest0';
show grants for eve_hrhtest0;

select user_name,priv_event from oceanbase.dba_ob_users where user_name like 'eve_hrhtest_' order by 1,2;
select grantee,privilege_type,is_grantable from information_schema.user_privileges where privilege_type ='event' and grantee like '%hrh%' order by 1,2,3;
select user,event_priv from mysql.user where user like 'eve_hrhtest%' order by 1,2;

connection conn_sys;
select user_name,priv_event from oceanbase.cdb_ob_users where user_name like 'eve_hrhtest_' order by 1,2;


--echo # 授权event权限（数据库级别）
connection default;
grant event on eve_hrhtest0_db.* to 'eve_hrhtest0';
show grants for eve_hrhtest0;

select username,database_name,priv_event from oceanbase.dba_ob_database_privilege where username like '%hrht%' order by 1,2,3;
select grantee,table_schema,privilege_type,is_grantable from information_schema.schema_privileges where privilege_type ='event' and grantee like '%hrht%' order by 1,2,3,4;
select user,db,event_priv from mysql.db where user like 'eve_hrhtest%' order by 1,2;

connection conn_sys;
select username,database_name,priv_event from oceanbase.cdb_ob_database_privilege where username like '%hrht%' order by 1,2,3;

--echo # 撤销event权限（数据库级别）
connection default;
revoke event on eve_hrhtest0_db.* from 'eve_hrhtest0';
show grants for eve_hrhtest0;

select username,database_name,priv_event from oceanbase.dba_ob_database_privilege where username like '%hrht%' order by 1,2,3;
select grantee,table_schema,privilege_type,is_grantable from information_schema.schema_privileges where privilege_type ='event' and grantee like '%hrht%' order by 1,2,3,4;
select user,db,event_priv from mysql.db where user like 'eve_hrhtest%' order by 1,2;

connection conn_sys;
select username,database_name,priv_event from oceanbase.cdb_ob_database_privilege where username like '%hrht%' order by 1,2,3;


--echo # 授权event权限（表级别）
connection default;
--error 1144
grant event on eve_hrhtest0_db.tab1 to 'eve_hrhtest0';

--echo # 撤销event权限（表级别）
connection default;
--error 1144
revoke event on eve_hrhtest0_db.tab1 from 'eve_hrhtest0';


--echo #### ◆◆ case 9 同时授权/撤销event权限给多个用户，验证不同用户是否拥有event权限
--echo ## 同时授权event权限
connection default;
grant event on *.* to 'eve_hrhtest0','eve_hrhtest1';
show grants for eve_hrhtest0;
show grants for eve_hrhtest1;

--echo # 连接用户 eve_hrhtest0
connect (conn_session0,$obmysql_ms0,eve_hrhtest0,eve_hrhtest0,eve_hrhtest0_db,$obmysql_port);
connection conn_session0;

drop event if exists e_1;

create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';

drop event e_1;

--echo # 查看相关试图
select user_name,priv_event from oceanbase.dba_ob_users where user_name like 'eve_hrhtest_' order by 1,2;
select grantee,privilege_type,is_grantable from information_schema.user_privileges where privilege_type ='event' and grantee like '%hrh%' order by 1,2,3;
select user,event_priv from mysql.user where user like 'eve_hrhtest%' order by 1,2;

disconnect conn_session0;
connection conn_sys;
select user_name,priv_event from oceanbase.cdb_ob_users where user_name like 'eve_hrhtest_' order by 1,2;

--echo # 连接用户 eve_hrhtest1
connect (conn_session1,$obmysql_ms0,eve_hrhtest1,eve_hrhtest1,eve_hrhtest1_db,$obmysql_port);
connection conn_session1;

drop event if exists e_1;

create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';

drop event e_1;

--echo ## 同时撤销event权限
disconnect conn_session1;
connection default;
revoke event on *.* from 'eve_hrhtest0','eve_hrhtest1';
show grants for eve_hrhtest0;
show grants for eve_hrhtest1;

--echo # 连接用户 eve_hrhtest0
connect (conn_session0,$obmysql_ms0,eve_hrhtest0,eve_hrhtest0,eve_hrhtest0_db,$obmysql_port);
connection conn_session0;

--error 1044
drop event if exists e_1;

--error 1044
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

--error 1044
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';


--echo # 查看相关试图
select user_name,priv_event from oceanbase.dba_ob_users where user_name like 'eve_hrhtest_' order by 1,2;
select grantee,privilege_type,is_grantable from information_schema.user_privileges where privilege_type ='event' and grantee like '%hrh%' order by 1,2,3;
select user,event_priv from mysql.user where user like 'eve_hrhtest%' order by 1,2;

disconnect conn_session0;
connection conn_sys;
select user_name,priv_event from oceanbase.cdb_ob_users where user_name like 'eve_hrhtest_' order by 1,2;

--echo # 连接用户 eve_hrhtest1
connect (conn_session1,$obmysql_ms0,eve_hrhtest1,eve_hrhtest1,eve_hrhtest1_db,$obmysql_port);
connection conn_session1;

--error 1044
drop event if exists e_1;

--error 1044
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

--error 1044
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';

--echo #### ◆◆ case 10 授权/撤销重复的event权限，预期成功
--echo ## 授权event权限
connection default;
grant event,event,event,event,event on *.* to 'eve_hrhtest0';
show grants for eve_hrhtest0;

--echo # 连接用户 eve_hrhtest0
connect (conn_session0,$obmysql_ms0,eve_hrhtest0,eve_hrhtest0,eve_hrhtest0_db,$obmysql_port);
connection conn_session0;

drop event if exists e_1;

create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';

drop event e_1;

--echo # 查看相关试图
select user_name,priv_event from oceanbase.dba_ob_users where user_name like 'eve_hrhtest_' order by 1,2;
select GRANTEE,PRIVILEGE_TYPE,IS_GRANTABLE from INFORMATION_SCHEMA.USER_PRIVILEGES where PRIVILEGE_TYPE ='event' and GRANTEE like '%hrh%' order by 1,2,3;
select user,event_priv from mysql.user where user like '%hrh%' order by 1,2;

disconnect conn_session0;
connection conn_sys;
select user_name,priv_event from oceanbase.cdb_ob_users where user_name like 'eve_hrhtest_' order by 1,2;

--echo ## 撤销event权限
connection default;
revoke event,event,event,event,event on *.* from 'eve_hrhtest0';
show grants for eve_hrhtest0;

--echo # 连接用户 eve_hrhtest0
connect (conn_session0,$obmysql_ms0,eve_hrhtest0,eve_hrhtest0,eve_hrhtest0_db,$obmysql_port);
connection conn_session0;

--error 1044
drop event if exists e_1;

--error 1044
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

--error 1044
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;

select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';

--echo # 查看相关试图
select user_name,priv_event from oceanbase.dba_ob_users where user_name like 'eve_hrhtest_' order by 1,2;
select GRANTEE,PRIVILEGE_TYPE,IS_GRANTABLE from INFORMATION_SCHEMA.USER_PRIVILEGES where PRIVILEGE_TYPE ='event' and GRANTEE like '%hrh%' order by 1,2,3;
select user,event_priv from mysql.user where user like '%hrh%' order by 1,2;

disconnect conn_session0;
connection conn_sys;
select user_name,priv_event from oceanbase.cdb_ob_users where user_name like 'eve_hrhtest_' order by 1,2;

connection default;
--disable_warnings
--error 0,600
drop user eve_hrhtest0;
--enable_warnings
--error 0,600
drop user eve_hrhtest1;
--enable_warnings
purge recyclebin;
