purge recyclebin;
result_format: 4
drop user hrh@'%';
create user hrh identified by 'hrh';
grant all on *.* to hrh WITH GRANT OPTION;



SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';

SET GLOBAL event_scheduler=off;

------------------------------------------------------------------------------------
################## 环境
drop table t1;
CREATE TABLE t1 ( 
  id int
);
drop event if exists e_alter;
create event e_alter on schedule at "3000-01-01 00:00:00" do select 1;
select count(*) from information_schema.events where 
  EVENT_SCHEMA = 'test' and EVENT_NAME = 'e_alter' and DEFINER = 'hrh@%' and EVENT_TYPE ='ONE TIME' and
  EXECUTE_AT = '3000-01-01 00:00:00' and INTERVAL_VALUE IS NULL and INTERVAL_FIELD IS NULL and STARTS IS NULL and ENDS IS NULL and
  STATUS = 'ENABLED' and ON_COMPLETION = 'NOT PRESERVE' and LAST_EXECUTED IS NULL and EVENT_COMMENT IS NULL;
+----------+
| count(*) |
+----------+
|        1 |
+----------+

