purge recyclebin;
result_format: 4
drop user hrh@'%';
create user hrh identified by 'hrh';
grant all on *.* to hrh WITH GRANT OPTION;



SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';

SET GLOBAL event_scheduler=off;

------------------------------------------------------------------------------------
################## init
drop table t1;
CREATE TABLE t1 ( 
  id int
);

################## test
############ create error
###### case 1 create exist_name
drop event if exists e_exist_name;
create event e_exist_name on schedule at '3000-01-01 00:00:00' do select 1;
create event e_exist_name on schedule at '3000-01-01 00:00:00' do select 1;
ERROR HY000: Event already exists
drop event e_exist_name;

###### case 1 create too_long_name
create event e_too_long_name_012345678901234567890123456789012345678901234567890123456789 on schedule at '3000-01-01 00:00:00' do select 1;
ERROR 42000: Identifier name is too long

###### case 2 create every 0 interval
create event e_0_interval on schedule every 0 second do select 1;
ERROR HY000: INTERVAL is either not positive or too big

###### case 3 create every big interval
create event e_1000000000000_interval on schedule every 1000000000000 second do select 1;
ERROR HY000: INTERVAL is either not positive or too big

###### case 4 create ends > starts
create event e_0_interval on schedule every 1 second starts '2000-01-01 00:00:00' ends '1999-01-01 00:00:00' do select 1;
ERROR HY000: ENDS is either invalid or before STARTS

###### case 5 create too long event body single sql
