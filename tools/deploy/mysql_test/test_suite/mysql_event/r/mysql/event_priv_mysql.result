# ◆ 准备测试用户
drop user if exists eve_hrhtest0;
drop database if exists eve_hrhtest0_db;
create user 'eve_hrhtest0' identified by 'eve_hrhtest0';
grant super,create,drop,alter,select,update,insert,delete on *.* to 'eve_hrhtest0'@'%' with grant option;
create database eve_hrhtest0_db character set utf8;
drop user if exists eve_hrhtest1;
drop database if exists eve_hrhtest1_db;
create user 'eve_hrhtest1' identified by 'eve_hrhtest1';
create database eve_hrhtest1_db character set utf8;
grant super,create,drop,alter,select,update,insert,delete on *.* to 'eve_hrhtest1'@'%' with grant option;
#-----------------------------------------------------------------------------
# mysql支持event权限：场景测试
# 测试event权限
#-----------------------------------------------------------------------------
#### ◆◆ case 1 用户无event权限时，预期进行事件操作失败
SET GLOBAL sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER';
drop event if exists e_1;
ERROR 42000: Access denied for user 'eve_hrhtest0'@'%' to database 'eve_hrhtest0_db'
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
ERROR 42000: Access denied for user 'eve_hrhtest0'@'%' to database 'eve_hrhtest0_db'
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
ERROR 42000: Access denied for user 'eve_hrhtest0'@'%' to database 'eve_hrhtest0_db'
select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';
EVENT_SCHEMA	EVENT_NAME	DEFINER
#### ◆◆ case 2 授予用户event权限时，预期进行事件操作成功
grant event on *.* to 'eve_hrhtest0';
show grants for eve_hrhtest0;
Grants for eve_hrhtest0@%
GRANT ALTER, CREATE, DELETE, DROP, INSERT, UPDATE, SELECT, SUPER, EVENT ON *.* TO 'eve_hrhtest0' WITH GRANT OPTION
drop event if exists e_1;
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';
EVENT_SCHEMA	EVENT_NAME	DEFINER
eve_hrhtest0_db	e_1	eve_hrhtest0@%
drop event e_1;
#### ◆◆ case 3 撤销用户event权限后，预期进行事件操作失败
revoke event on *.* from 'eve_hrhtest0';
show grants for eve_hrhtest0;
Grants for eve_hrhtest0@%
GRANT ALTER, CREATE, DELETE, DROP, INSERT, UPDATE, SELECT, SUPER ON *.* TO 'eve_hrhtest0' WITH GRANT OPTION
# 连接用户 eve_hrhtest0
drop event if exists e_1;
ERROR 42000: Access denied for user 'eve_hrhtest0'@'%' to database 'eve_hrhtest0_db'
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
ERROR 42000: Access denied for user 'eve_hrhtest0'@'%' to database 'eve_hrhtest0_db'
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
ERROR 42000: Access denied for user 'eve_hrhtest0'@'%' to database 'eve_hrhtest0_db'
select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';
EVENT_SCHEMA	EVENT_NAME	DEFINER
#### ◆◆ case 4 授权/撤销 ALL PRIVILEGES 权限，验证事件操作
GRANT ALL PRIVILEGES ON *.* TO eve_hrhtest0;
show grants for eve_hrhtest0;
Grants for eve_hrhtest0@%
GRANT ALL PRIVILEGES ON *.* TO 'eve_hrhtest0' WITH GRANT OPTION
drop event if exists e_1;
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';
EVENT_SCHEMA	EVENT_NAME	DEFINER
eve_hrhtest0_db	e_1	eve_hrhtest0@%
drop event e_1;
# 撤销
revoke all privileges, grant option from eve_hrhtest0;
grant super,create,drop,alter,select,update,insert,delete on *.* to 'eve_hrhtest0'@'%' with grant option;
show grants for eve_hrhtest0;
Grants for eve_hrhtest0@%
GRANT ALTER, CREATE, DELETE, DROP, INSERT, UPDATE, SELECT, SUPER ON *.* TO 'eve_hrhtest0' WITH GRANT OPTION
# 连接用户 eve_hrhtest0
drop event if exists e_1;
ERROR 42000: Access denied for user 'eve_hrhtest0'@'%' to database 'eve_hrhtest0_db'
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
ERROR 42000: Access denied for user 'eve_hrhtest0'@'%' to database 'eve_hrhtest0_db'
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
ERROR 42000: Access denied for user 'eve_hrhtest0'@'%' to database 'eve_hrhtest0_db'
select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';
EVENT_SCHEMA	EVENT_NAME	DEFINER
#### ◆◆ case 5 授权/撤销event权限给不存在的用户，预期失败
grant event on *.* to 'nouser';
ERROR 42000: Access denied for user 'nouser'@'%' (using password: NO)
grant event on eve_hrhtest0.* to 'nouser';
ERROR 42000: Access denied for user 'nouser'@'%' (using password: NO)
grant event on eve_hrhtest0.tab1 to 'nouser';
ERROR 42000: Illegal GRANT/REVOKE command; please consult the manual to see which privileges can be used
revoke event on *.* from 'nouser';
ERROR 42000: Can not find any matching row in the user table
revoke event on eve_hrhtest0.* from 'nouser';
ERROR 42000: Can not find any matching row in the user table
revoke event on eve_hrhtest0.tab1 from 'nouser';
ERROR 42000: Illegal GRANT/REVOKE command; please consult the manual to see which privileges can be used
#### ◆◆ case 6 撤销用户不存在某级别的event权限，预期失败
grant event on *.* to 'eve_hrhtest0';
show grants for eve_hrhtest0;
Grants for eve_hrhtest0@%
GRANT ALTER, CREATE, DELETE, DROP, INSERT, UPDATE, SELECT, SUPER, EVENT ON *.* TO 'eve_hrhtest0' WITH GRANT OPTION
revoke event on eve_hrhtest0_db.* from 'eve_hrhtest0';
ERROR 42000: No such grant defined
revoke event on eve_hrhtest0_db.tab1 from 'eve_hrhtest0';
ERROR 42000: Illegal GRANT/REVOKE command; please consult the manual to see which privileges can be used
#### ◆◆ case 7 授权/撤销event权限时与其他权限一起指定
# 授权event权限
grant event,alter,alter routine,create view,delete,execute,file,index,insert,select,show view,update on *.* to 'eve_hrhtest0';
show grants for eve_hrhtest0;
Grants for eve_hrhtest0@%
GRANT ALTER, CREATE, DELETE, DROP, INSERT, UPDATE, SELECT, INDEX, CREATE VIEW, SHOW VIEW, SUPER, FILE, EXECUTE, ALTER ROUTINE, EVENT ON *.* TO 'eve_hrhtest0' WITH GRANT OPTION
# 连接用户 eve_hrhtest0
drop event if exists e_1;
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';
EVENT_SCHEMA	EVENT_NAME	DEFINER
eve_hrhtest0_db	e_1	eve_hrhtest0@%
drop event e_1;
# 撤销event权限
revoke event,alter,alter routine,create view,delete,execute,file,index,show view,update on *.* from 'eve_hrhtest0';
show grants for eve_hrhtest0;
Grants for eve_hrhtest0@%
GRANT CREATE, DROP, INSERT, SELECT, SUPER ON *.* TO 'eve_hrhtest0' WITH GRANT OPTION
# 连接用户 eve_hrhtest0
drop event if exists e_1;
ERROR 42000: Access denied for user 'eve_hrhtest0'@'%' to database 'eve_hrhtest0_db'
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
ERROR 42000: Access denied for user 'eve_hrhtest0'@'%' to database 'eve_hrhtest0_db'
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
ERROR 42000: Access denied for user 'eve_hrhtest0'@'%' to database 'eve_hrhtest0_db'
select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';
EVENT_SCHEMA	EVENT_NAME	DEFINER
#### ◆◆ case 8 授权/撤销event权限后，检查关于event权限信息是否更新到内部表
# 授权event权限（用户级别）
grant event on *.* to 'eve_hrhtest0';
show grants for eve_hrhtest0;
Grants for eve_hrhtest0@%
GRANT CREATE, DROP, INSERT, SELECT, SUPER, EVENT ON *.* TO 'eve_hrhtest0' WITH GRANT OPTION
select user_name,priv_event from oceanbase.dba_ob_users where user_name like 'eve_hrhtest_' order by 1,2;
user_name	priv_event
eve_hrhtest0	YES
eve_hrhtest1	NO
select grantee,privilege_type,is_grantable from information_schema.user_privileges where privilege_type ='event' and grantee like '%hrh%' order by 1,2,3;
grantee	privilege_type	is_grantable
'eve_hrhtest0'@'%'	EVENT	YES
select user,event_priv from mysql.user where user like 'eve_hrhtest%' order by 1,2;
user	event_priv
eve_hrhtest0	Y
eve_hrhtest1	N
select user_name,priv_event from oceanbase.cdb_ob_users where user_name like 'eve_hrhtest_' order by 1,2;
user_name	priv_event
eve_hrhtest0	YES
eve_hrhtest1	NO
# 撤销event权限（用户级别）
revoke event on *.* from 'eve_hrhtest0';
show grants for eve_hrhtest0;
Grants for eve_hrhtest0@%
GRANT CREATE, DROP, INSERT, SELECT, SUPER ON *.* TO 'eve_hrhtest0' WITH GRANT OPTION
select user_name,priv_event from oceanbase.dba_ob_users where user_name like 'eve_hrhtest_' order by 1,2;
user_name	priv_event
eve_hrhtest0	NO
eve_hrhtest1	NO
select grantee,privilege_type,is_grantable from information_schema.user_privileges where privilege_type ='event' and grantee like '%hrh%' order by 1,2,3;
grantee	privilege_type	is_grantable
select user,event_priv from mysql.user where user like 'eve_hrhtest%' order by 1,2;
user	event_priv
eve_hrhtest0	N
eve_hrhtest1	N
select user_name,priv_event from oceanbase.cdb_ob_users where user_name like 'eve_hrhtest_' order by 1,2;
user_name	priv_event
eve_hrhtest0	NO
eve_hrhtest1	NO
# 授权event权限（数据库级别）
grant event on eve_hrhtest0_db.* to 'eve_hrhtest0';
show grants for eve_hrhtest0;
Grants for eve_hrhtest0@%
GRANT CREATE, DROP, INSERT, SELECT, SUPER ON *.* TO 'eve_hrhtest0' WITH GRANT OPTION
GRANT EVENT ON `eve_hrhtest0_db`.* TO 'eve_hrhtest0'
