drop event if exists e_1;
create event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
alter event e_1 on schedule at "3000-01-01 00:00:00" do select 1;
select EVENT_SCHEMA,EVENT_NAME,DEFINER from information_schema.events where EVENT_SCHEMA=schema() and EVENT_NAME='e_1';
EVENT_SCHEMA	EVENT_NAME	DEFINER
eve_hrhtest0_db	e_1	eve_hrhtest0@%
drop event e_1;
