create table t7(a date, b date) with column group (each column);
insert into t7 select DATE(
    FROM_UNIXTIME(
        FLOOR(
            UNIX_TIMESTAMP('2023-12-31') - UNIX_TIMESTAMP('2023-01-01') + 1
        ) * RAND(20240620) + UNIX_TIMESTAMP('2023-01-01')
    )
) as a,
DATE(
    FROM_UNIXTIME(
        FLOOR(
            UNIX_TIMESTAMP('2023-12-31') - UNIX_TIMESTAMP('2023-01-01') + 1
        ) * RAND(20240620) + UNIX_TIMESTAMP('2023-01-01')
    )
) as b from table(generator(1000));

connection conn_admin;

alter system major freeze tenant=sys;
--source mysql_test/include/wait_minor_merge.inc

connection default;

set _enable_rich_vector_format = 1;
select * from t1 where a = b;
select * from t1 where a != b;
select * from t1 where a >= b;
select * from t1 where a > b;
select * from t1 where a <= b;
select * from t1 where a < b;


