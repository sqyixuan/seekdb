--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
## owner: jingfeng.jf
## owner group: SQL2
# tags: vector20
## Test implementation of hash union
connect (sysc,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sysc;
alter system set_tp tp_no = 2400, error_code = 0, frequency = 1;
connection default;
set _enable_rich_vector_format = 1;

--disable_warnings
drop table if exists t1,t2,t3,tnull;
--enable_warnings

create table t1(a int primary key, b int, c int);
create table t2 (a double primary key, b double, c double);
create table t3(a varchar(10) primary key, b varchar(10), c varchar(10));

create table tnull(a int primary key, b int, c int);
let $i=0;
--disable_query_log
while ($i < 100)
{
    eval insert into t1 values ($i, $i, $i);
    eval insert into t2 values ($i, $i, $i);
    eval insert into t3 values ('$i', '$i', '$i');
    eval insert into tnull values ($i, $i, null);
    inc $i;

    eval insert into t1 values ($i, $i, $i);
    eval insert into t2 values ($i, $i, $i);
    eval insert into t3 values ('$i', '$i', '$i');
    eval insert into tnull values ($i, null, $i);
    inc $i;
}
--enable_query_log
--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats('TEST', 'T1');
call dbms_stats.gather_table_stats('TEST', 'T2');
call dbms_stats.gather_table_stats('TEST', 'T3');
--explain_protocol 2
--result_format 4

# test hash union
select b   from t1 where a > 25 union select b   from t1 where a < 75;
select b,c from t1 where a > 25 union select b,c from t1 where a < 75;

select b   from t2 where a > 25 union select b   from t2 where a < 75;
select b,c from t2 where a > 25 union select b,c from t2 where a < 75;

select b   from t3 where a > 25 union select b   from t3 where a < 75;
select b,c from t3 where a > 25 union select b,c from t3 where a < 75;

select b   from t3 where a > 25 union select b   from t1 where a < 75;
select b,c from t3 where a > 25 union select b,c from t1 where a < 75;

# 测试 set + limit, order-by
select b,c from t1 where c > 25 union     (select b,c from t1 where c < 75) order by b;

select b,c from t1 where c > 25 union     (select b,c from t1 where c < 75) limit 10;

select b,c from t1 where c > 25 union     (select b,c from t1 where c < 75) order by b limit 10;

# 测试空值对 union的影响
select b,c from tnull where a < 10 union     (select c,b from tnull where a < 10);
select b   from tnull where a < 10 union     (select c   from tnull where a < 10);

# test hash union dump
connection sysc;
alter system set_tp tp_no = 2400, error_code = 5, frequency = 1;
connection default;
select b   from t1 where a > 25 union select b   from t1 where a < 75;
select b,c from t1 where a > 25 union select b,c from t1 where a < 75;

select b   from t2 where a > 25 union select b   from t2 where a < 75;
select b,c from t2 where a > 25 union select b,c from t2 where a < 75;

select b   from t3 where a > 25 union select b   from t3 where a < 75;
select b,c from t3 where a > 25 union select b,c from t3 where a < 75;

select b   from t3 where a > 25 union select b   from t1 where a < 75;
select b,c from t3 where a > 25 union select b,c from t1 where a < 75;

# 测试 set + limit, order-by
select b,c from t1 where c > 25 union     (select b,c from t1 where c < 75) order by b;

select b,c from t1 where c > 25 union     (select b,c from t1 where c < 75) limit 10;

select b,c from t1 where c > 25 union     (select b,c from t1 where c < 75) order by b limit 10;

# 测试空值对 union 的影响
select b,c from tnull where a < 10 union     (select c,b from tnull where a < 10);
select b   from tnull where a < 10 union     (select c   from tnull where a < 10);

connection sysc;
alter system set_tp tp_no = 2400, error_code = 0, frequency = 1;
connection default;