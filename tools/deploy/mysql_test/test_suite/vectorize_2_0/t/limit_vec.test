## do select ahead of explain so that optimizer knows table scan cost
select * from t1;

explain select SQL_CALC_FOUND_ROWS * from t1 limit 127,5;
select SQL_CALC_FOUND_ROWS * from t1 limit 127,5;

select SQL_CALC_FOUND_ROWS * from t1 limit 5;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t2(deptno decimal,dname varchar(20));
insert into t2 values(10,'AccounTing');
insert into t2 values (20,'ReSeaRch');
insert into t2 values(30,'SaLeS');
insert into t2 values(40,'OperaTions');

create table t1(EMPNO number(4),ENAME varchar(10),SAL number(7,2),DEPTNO number(2));
insert into t1(empno,ename,sal,deptno) values(7369,'SMITH',800,20);
insert into t1(empno,ename,sal,deptno) values(7499,'ALLEN',1600,30);
