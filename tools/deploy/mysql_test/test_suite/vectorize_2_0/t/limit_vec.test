select * from (select e.ename from t1 e inner join t2 p on e.deptno = p.deptno where e.sal > 1000)  limit 4;

select * from (select e.ename from t1 e inner join t2 p on e.deptno = p.deptno where e.sal > 1000)  limit 4 offset 4;

select * from (select e.ename from t1 e inner join t2 p on e.deptno = p.deptno where e.sal > 1000)  limit 8;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t0;
--enable_warnings

--echo 
CREATE TABLE t0(c0 SMALLINT(185) , c1 TINYINT(144) ) PARTITION BY KEY (c1) SUBPARTITION BY RANGE (c0) subpartition template (subpartition sp0 VALUES LESS THAN(0), subpartition sp1 VALUES LESS THAN(1000000000), subpartition sp2 VALUES LESS THAN(maxvalue)) partitions 7;
CREATE TABLE t1 LIKE t0;
REPLACE INTO t1(c0) VALUES(26);
INSERT /*+parallel(5) enable_parallel_dml */ INTO t0(c1, c0) VALUES ROW(-1, 104);
CREATE INDEX i50 USING BTREE ON t0(c1) PARTITION BY HASH(c1)  partitions 17 ;
INSERT /*+NO_GATHER_OPTIMIZER_STATISTICS */ INTO t1(c0, c1) VALUES ROW(8, 5) ON DUPLICATE KEY UPDATE c0=24;
INSERT /*+NO_GATHER_OPTIMIZER_STATISTICS */ INTO t0(c1) VALUES(-4);
explain SELECT * FROM (SELECT t1.c0 AS T1C0, t1.c1 AS T1C1, RANK() over( order by t1.c1, t1.c0 asc) AS WF FROM t0, t1) L0 WHERE (!(1 != WF));
SELECT * FROM (SELECT t1.c0 AS T1C0, t1.c1 AS T1C1, RANK() over( order by t1.c1, t1.c0 asc) AS WF FROM t0, t1) L0 WHERE (!(1 != WF));
drop table t0, t1;

connection syscon;
alter system set _rowsets_max_rows = 256 tenant=all;
--sleep 2
