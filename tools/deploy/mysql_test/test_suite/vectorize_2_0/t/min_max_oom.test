# owner: zongmei.zzm
# owner group: sql2

--result_format 4

--disable_warnings
drop table if exists tmp_serv_021720;
--enable_warnings

CREATE TABLE `tmp_serv_021720` (
  `VIDEOID` varchar(96) COLLATE utf8mb4_bin DEFAULT NULL,
  `VIDEONAME` varchar(768) COLLATE utf8mb4_bin DEFAULT NULL,
  `ONLINETIME` varchar(21) COLLATE utf8mb4_bin DEFAULT NULL,
  `OFFLINE_TIME` varchar(21) COLLATE utf8mb4_bin DEFAULT NULL,
  `CONTENT_DESC` varchar(768) COLLATE utf8mb4_bin DEFAULT NULL,
  `CONTENT_RATE` decimal(10,0) DEFAULT NULL,
  `CONTENT_TYPE` varchar(3) COLLATE utf8mb4_bin DEFAULT NULL,
  `CONTENT_PLAYDURATION` decimal(10,0) DEFAULT NULL,
  `PLAY_TYPE` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL,
  `CONTENT_FIRSTYPE` varchar(6) COLLATE utf8mb4_bin DEFAULT NULL,
  `LICENSE_PLATE` varchar(6) COLLATE utf8mb4_bin DEFAULT NULL,
  `LICENSE_PLATE_NAME` varchar(192) COLLATE utf8mb4_bin DEFAULT NULL,
  `DIRECTOR` varchar(383) COLLATE utf8mb4_bin DEFAULT NULL,
  `ACTOR` varchar(383) COLLATE utf8mb4_bin DEFAULT NULL,
  `CONTENT_PROVIDERS_NAME` varchar(383) COLLATE utf8mb4_bin DEFAULT NULL,
  `ALBUMNUM` decimal(10,0) DEFAULT NULL,
  `NEW_VIDEONUM` decimal(10,0) DEFAULT NULL,
  `QUALITY` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL,
  `CONTENT_SECTYPE` varchar(383) COLLATE utf8mb4_bin DEFAULT NULL,
  `PAY_CODE` decimal(1,0) DEFAULT NULL,
  `START_TIME` varchar(12) COLLATE utf8mb4_bin DEFAULT NULL,
  `END_TIME` varchar(12) COLLATE utf8mb4_bin DEFAULT NULL,
  `UPDATETYPE` decimal(2,0) DEFAULT NULL,
  `CPID` varchar(24) COLLATE utf8mb4_bin DEFAULT NULL,
  `CHANNELID` varchar(15) COLLATE utf8mb4_bin DEFAULT NULL,
  `ALBUMID` varchar(96) COLLATE utf8mb4_bin DEFAULT NULL,
  `ALBUMNAME` varchar(150) COLLATE utf8mb4_bin DEFAULT NULL,
  `VIDEONUM` varchar(15) COLLATE utf8mb4_bin DEFAULT NULL,
  `CONTENTTYPE` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL,
  `IS_MIGU` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL,
  `IS_PP_FIRSTTYPE` decimal(10,0) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 WITH COLUMN GROUP(each column);


insert
  /*+parallel(128) append enable_parallel_dml query_timeout(100000000000)*/
  into TMP_SERV_021720
select
  concat(repeat('a', 90), randstr(5, random(1))) VIDEOID,
  repeat('c', 768) VIDEONAME,
  '2025-06-17 12:00:00' ONLINETIME,
  '2025-06-17 12:00:00' OFFLINE_TIME,
  randstr(700, random(1)) CONTENT_DESC,
  uniform(1, 1000, random(2)) CONTENT_RATE,
  randstr(3, random(3)) CONTENT_TYPE,
  uniform(1, 1000, random(4)) CONTENT_PLAYDURATION,
  randstr(2, random(5)) PLAY_TYPE,
  randstr(6, random(6)) CONTENT_FIRSTYPE,
  randstr(6, random(7)) LICENSE_PLATE,
  randstr(180, random(8)) LICENSE_PLATE_NAME,
  randstr(350, random(9)) DIRECTOR,
  randstr(350, random(10)) ACTOR,
  randstr(250, random(11)) CONTENT_PROVIDERS_NAME,
  uniform(1, 1000, random(12)) ALBUMNUM,
  uniform(1, 1000, random(13)) NEW_VIDEONUM,
  randstr(2, random(14)) QUALITY,
  randstr(350, random(15)) CONTENT_SECTYPE,
  1 PAY_CODE,
  '2025-06-17' START_TIME,
  '2025-06-17' END_TIME,
  12 UPDATETYPE,
  '1234567890123456789' CPID,
  '1234567890' CHANNELID,
  repeat('123456789', 9) ALBUMID,
  randstr(81, random(14)) ALBUMNAME,
  '123456789012' VIDEONUM,
  '1b' CONTENTTYPE,
  '0' IS_MIGU,
  0 IS_PP_FIRSTTYPE
from
  table(generator(1000000));


set global ob_sql_work_area_percentage = 30;
disconnect default;

connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
connection default;


select /*+query_timeout(10000000000)*/ count(1) from (select /*+ no_rewrite parallel(16) */
                                        videoid,
                                        max(videoname),
                                        onlinetime,
                                        max(offline_time),
                                        max(content_desc),
                                        max(content_rate),
                                        max(content_type),
                                        max(content_playduration),
                                        max(play_type),
                                        max(content_firstype),
                                        max(license_plate),
                                        max(license_plate_name),
                                        max(director),
                                        max(actor),
                                        max(content_providers_name),
                                        max(albumnum),
                                        max(new_videonum),
                                        max(quality),
                                        group_concat(content_sectype,'|' order by videoid) content_sectype,
                                        max(pay_code),
                                        max(start_time),
                                        max(end_time),
                                        max(updatetype),
                                        cpid,
                                        max(channelid),
                                        albumid,
                                        max(albumname),
                                        max(videonum),
                                        max(contenttype),
                                        max(is_migu),
                                        max(is_pp_firsttype)
                        from tmp_serv_021720
                        group by videoid,videoname,onlinetime,cpid,albumid);

drop table tmp_serv_021720;

set global ob_sql_work_area_percentage = 5;
disconnect default;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
