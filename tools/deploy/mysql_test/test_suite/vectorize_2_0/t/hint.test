# owner: zongmei.zzm
# owner group: sql2

--result_format 4

alter system flush plan cache global;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1 (a int);
create table t2 (b int);

insert into t1 values (1), (2), (3);
insert into t2 values (1), (2), (3);

select /*+parallel(2)*/sum(a) from t1;
select /*+parallel(2)*/sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;
select outline_data, hit_count from oceanbase.gv$ob_plan_cache_plan_stat where statement = 'select /*+parallel(2)*/sum(a) from t1';

select /*+parallel(2) opt_param('enable_rich_vector_format', 'false')*/sum(a) from t1;
select /*+parallel(2) opt_param('enable_rich_vector_format', 'false')*/sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;
select outline_data, hit_count from oceanbase.gv$ob_plan_cache_plan_stat where statement = "select /*+parallel(2) opt_param('enable_rich_vector_format', 'false')*/sum(a) from t1";

set _enable_rich_vector_format = false;
select /*+parallel(2) opt_param('enable_rich_vector_format', 'true')*/sum(a) from t1;
select /*+parallel(2) opt_param('enable_rich_vector_format', 'true')*/sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;
select outline_data, hit_count from oceanbase.gv$ob_plan_cache_plan_stat where statement = "select /*+parallel(2) opt_param('enable_rich_vector_format', 'true')*/sum(a) from t1";

select /*+parallel(2)*/* from (select sum(a) as sum_v from t1 union select /*+opt_param('enable_rich_vector_format', 'true')*/sum(b) as sum_v from t2);
select /*+parallel(2)*/* from (select sum(a) as sum_v from t1 union select /*+opt_param('enable_rich_vector_format', 'true')*/sum(b) as sum_v from t2);
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;
select outline_data, hit_count from oceanbase.gv$ob_plan_cache_plan_stat where statement = "select /*+parallel(2)*/* from (select sum(a) as sum_v from t1 union select /*+opt_param('enable_rich_vector_format', 'true')*/sum(b) as sum_v from t2)";

alter system flush plan cache global;
set _enable_rich_vector_format = true;

# test outline
create or replace outline off_vec2 on select /*+parallel(2) opt_param('enable_rich_vector_format', 'false')*/sum(a) from t1 to select /*+parallel(2)*/sum(a) from t1;

select /*+parallel(2)*/sum(a) from t1;
select /*+parallel(2)*/sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;
select outline_data, hit_count from oceanbase.gv$ob_plan_cache_plan_stat where statement = "select /*+parallel(2)*/sum(a) from t1";

set _enable_rich_vector_format = false;
select /*+parallel(2)*/sum(a) from t1;
select /*+parallel(2)*/sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;
select outline_data, hit_count from oceanbase.gv$ob_plan_cache_plan_stat where statement = "select /*+parallel(2)*/sum(a) from t1";

drop outline off_vec2;
create or replace outline on_vec2 on select /*+parallel(2) opt_param('enable_rich_vector_format', 'true')*/sum(a) from t1 to select /*+parallel(2)*/sum(a) from t1;
select /*+parallel(2)*/sum(a) from t1;
select /*+parallel(2)*/sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;
select outline_data, hit_count from oceanbase.gv$ob_plan_cache_plan_stat where statement = "select /*+parallel(2)*/sum(a) from t1";

drop outline on_vec2;
set _enable_rich_vector_format = true;
drop table t1;
drop table t2;

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection default;
--disable_warnings
drop table if exists t9;
--enable_warnings

CREATE TABLE `t9` (
  `c1` double(16,14) unsigned
);

CREATE TABLE `t1` (
  `c1` double(16,14) unsigned
);

insert into t1 values(19.000),(20.123);
insert into t9 values(19.000),(20.123);

set ob_query_timeout=3600000000000;
alter system flush plan cache global;
--sleep 2
connection sys;
alter system flush kvcache;
--sleep 2
connection default;

--let $cnt = 10
while ($cnt > 0) {
alter system flush plan cache global;
select /*+log_level(trace) dynamic_sampling(1) parallel(10) px_join_filter(t9) OPT_PARAM('enable_rich_vector_format', 'False') */  * from t1 join t9 on t1.c1=t9.c1;
select /*+log_level(trace) dynamic_sampling(1) parallel(10) no_px_join_filter(t9) OPT_PARAM('enable_rich_vector_format', 'True') */  * from t1 join t9 on t1.c1=t9.c1;
dec $cnt;
}

set ob_query_timeout=10000000;

drop table t1;
drop table t9;
alter system flush plan cache global;