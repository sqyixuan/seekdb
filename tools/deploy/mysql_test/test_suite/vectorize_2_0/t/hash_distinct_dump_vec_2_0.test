--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# # owner group: SQL2
# # description: test for hash distinct dump

--disable_warnings
drop database if exists luofan_db;
drop table if exists t1;
--enable_warnings
create database luofan_db;
use luofan_db;

--disable_abort_on_error
set ob_query_timeout=10000000000;
set ob_trx_timeout=100000000000;


--echo #打开向量化2.0开关
set _enable_rich_vector_format = true;


--disable_warnings
drop table if exists t1;
drop procedure if exists pro_t1;
--enable_warnings
create table t1 (c1 int, c2 int, c3 int, c4 varchar(256));

DELIMITER //;
CREATE PROCEDURE pro_t1()
BEGIN
  DECLARE num INT;
  SET num = 0;
  WHILE
    num < 20000 DO
    insert into t1 values(num, num, num, "testtesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestset");
    insert into t1 values(num, num, num, "testtesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestset");
    SET num = num + 1;
  END WHILE;
END; //
DELIMITER ;//

CALL pro_t1();

select count(*), sum(c1) from (select distinct c1, c2, c3, c4 from t1);
select distinct c4 from t1;

--disable_warnings
drop table if exists t1;
drop procedure if exists pro_t1;
--enable_warnings
drop database luofan_db;
