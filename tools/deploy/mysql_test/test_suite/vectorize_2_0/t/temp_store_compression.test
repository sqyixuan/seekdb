#owner: zuojiao.hzj
#owner group: SQL-SQL2
#description: test temp store compression
#tags: temp_store, material
#author: zuojiao.hzj


--disable_warnings
drop database if exists temp_store;
--enable_warnings
create database temp_store;
use temp_store;

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 2210, error_code = 2097152, frequency = 1;
sleep 1;

--echo loaddata
connection default;
create table t1 (c1 int, c2 varchar(512), c3 varchar(512), c4 varchar(512), c5 varchar(512));
insert /*+query_timeout(100000000)*/ into t1
select 1, repeat('abcd', 128), repeat('efgh', 128), repeat('hgfe', 128), repeat('dcba', 128)
from table(generator(100000));

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--echo test hint
--echo none
explain outline
select /*+blocking(1) opt_param('spill_compression_codec', 'none') */
count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;
select /*+blocking(1) opt_param('spill_compression_codec', 'none') */
count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;

--echo zstd
explain outline
select /*+blocking(1) opt_param('spill_compression_codec', 'zstd') */
count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;
select /*+blocking(1) opt_param('spill_compression_codec', 'zstd') */
count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;

--echo lz4
explain outline
select /*+blocking(1) opt_param('spill_compression_codec', 'lZ4') */
count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;
select /*+blocking(1) opt_param('spill_compression_codec', 'lZ4') */
count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;

--echo snappy
explain outline
select /*+blocking(1) opt_param('spill_compression_codec', 'SNAPpy') */
count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;
select /*+blocking(1) opt_param('spill_compression_codec', 'SNAPpy') */
count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;

--echo zlib
explain outline
select /*+blocking(1) opt_param('spill_compression_codec', 'Zlib') */
count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;
select /*+blocking(1) opt_param('spill_compression_codec', 'Zlib') */
count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;

--echo invalid codec
explain outline
select /*+blocking(1) opt_param('spill_compression_codec', 'Zlid') */
count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;
select /*+blocking(1) opt_param('spill_compression_codec', 'Zlid') */
count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;

--echo test configure
alter system set spill_compression_codec = 'NoNe';
select /*+blocking(1) */ count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;

alter system set spill_compression_codec = 'ZSTD';
select /*+blocking(1) */ count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;

alter system set spill_compression_codec = 'lz4';
select /*+blocking(1) */ count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;

alter system set spill_compression_codec = 'snaPPy';
select /*+blocking(1) */ count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;

alter system set spill_compression_codec = 'Zlib';
select /*+blocking(1) */ count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;

--error 4147
alter system set spill_compression_codec = 'x';

connection conn_admin;
alter system set_tp tp_no = 2210, error_code = 0, frequency = 1;
sleep 1;
connection default;
drop database temp_store;
alter system set spill_compression_codec = 'none';
