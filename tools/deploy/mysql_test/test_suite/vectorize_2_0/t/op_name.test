# owner: zongmei.zzm
# owner group: sql2

--result_format 4
--disable_warnings
drop table if exists t1;
--enable_warnings

set _enable_rich_vector_format = true;
create table t1(a int, b int);
insert into t1 values (1, 1), (2, 2), (3, 3);

select /*+parallel(2)*/ sum(a) as sum_a, sum(b) as sum_b from t1 order by sum_a limit 2;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

set _enable_rich_vector_format = false;
select /*+parallel(2)*/ sum(a) as sum_a, sum(b) as sum_b from t1 order by sum_a limit 2;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

set _enable_rich_vector_format = true;
select /*+monitor*/distinct(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

set _enable_rich_vector_format = false;
select /*+monitor*/distinct(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

set _enable_rich_vector_format = true;
select /*+monitor blocking(1)*/distinct(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

set _enable_rich_vector_format = false;
select /*+monitor blocking(1)*/distinct(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

--disable_warnings
drop table if exists t2;
--enable_warnings

create table t2 (c int, d int);
insert into t2 values (1, 2), (3, 4);


set _enable_rich_vector_format = true;
insert into t2 select /*+monitor*/* from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

set _enable_rich_vector_format = false;
insert into t2 select /*+monitor*/* from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

set _enable_rich_vector_format = true;
drop table t1;
drop table t2;
