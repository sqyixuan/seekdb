let $cnt=28;
let $left=1;
--disable_warnings
while ($left <= $cnt)
{
  eval select distinct c$left from (select/*+ blocking('all'), USE_PX parallel(1) */ * from t1);
  let $dec= $left;
  while ($dec > 1)
  {
    dec $dec;
    eval select distinct c$left, c$dec from (select/*+ blocking('all'), USE_PX parallel(1) */ * from t1);
  }
  inc $left;
}

alter system set _enable_decimal_int_type = true;

drop table if exists t1;
drop database luofan_db;
