drop table t;

create table t(c1 int, c2 varchar(32), a0 int);

insert /*+append enable_parallel_dml parallel(16)*/into t select uniform(-100, 100, random(1)), randstr(32, random(2)), uniform(-100, 100, random(3)) from table(generator(100000));

explain basic select /*+no_use_hash_aggregation*/a0, approx_count_distinct(c1) from t group by a0 order by 1;
select /*+no_use_hash_aggregation*/a0, approx_count_distinct(c1) from t group by a0 order by 1;
explain basic select /*+no_use_hash_aggregation parallel(2)*/a0, approx_count_distinct(c1) from t group by a0 order by 1;
select /*+no_use_hash_aggregation parallel(2)*/a0, approx_count_distinct(c1) from t group by a0 order by 1;

explain basic select /*+no_use_hash_aggregation*/a0, approx_count_distinct(c2) from t group by a0 order by 1;
select /*+no_use_hash_aggregation*/a0, approx_count_distinct(c2) from t group by a0 order by 1;
explain basic select /*+no_use_hash_aggregation parallel(2)*/a0, approx_count_distinct(c2) from t group by a0 order by 1;
