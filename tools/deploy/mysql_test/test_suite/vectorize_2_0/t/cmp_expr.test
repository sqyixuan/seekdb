#insert into t1 values (ST_GeomFromText('POINT(1 1)'), ST_GeomFromText('POINT(1 2)'));
#insert into t1 values (ST_GeomFromText('POINT(2 1)'), ST_GeomFromText('POINT(1 2)'));

alter system set _enable_decimal_int_type = true;
