#### owner: yangfan.fy
#### owner group: sql2
#### description: test for between

set _enable_rich_vector_format = true;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int, b bigint, c bigint unsigned, d double, e datetime, f date, g timestamp, h year, i time);
insert into t1 values(1, 1, 1, 1, "2001-01-01 12:34:56", "2001-01-01", "2001-01-01 12:34:56", 2001, "12:34:57");
insert into t1 values(2, 2, 2, 2, "2001-01-01 13:34:56", "2001-01-02", "2002-01-01 13:34:56", 2002, "12:35:56");
insert into t1 values(3, 3, 3, 3, "2002-01-01 12:34:56", "2002-01-01", "2003-01-01 12:34:56", 2003, "12:36:56");
insert into t1 values(4, 4, 4, 4, "2003-01-01 12:34:56", "2003-01-01", "2004-01-01 12:34:56", 2004, "13:34:56");
insert into t1 values(5, 5, 5, 5, "2004-01-01 12:34:56", "2004-01-01", "2005-01-01 12:34:56", 2010, "20:34:56");

explain select 3 between 1 and t1.a from t1;
select 3 between 1 and t1.a from t1;
select -1 between 1 and t1.a from t1;
select 10 between 1 and t1.a from t1;

explain select 3 between 1 and t1.b from t1;
select 3 between 1 and t1.b from t1;
select -1 between 1 and t1.b from t1;
select 10 between 1 and t1.b from t1;

explain select 3 between 1 and t1.c from t1;
select 3 between 1 and t1.c from t1;
select -1 between 1 and t1.c from t1;
select 10 between 1 and t1.c from t1;

explain select 3 between 1 and t1.d from t1;
select 3 between 1 and t1.d from t1;
select -1 between 1 and t1.d from t1;
select 10 between 1 and t1.d from t1;

explain select "2002-12-01" between "2001-01-01 12:34:56" and t1.e from t1;
select "2002-12-01" between "2001-01-01 12:34:56" and t1.e from t1;
select "1998-12-01" between "2001-01-01 12:34:56" and t1.e from t1;
select "2020-12-01" between "2001-01-01 12:34:56" and t1.e from t1;

explain select "2002-12-01" between "2001-01-01 12:34:56" and t1.f from t1;
select "2002-12-01" between "2001-01-01 12:34:56" and t1.f from t1;
select "1998-12-01" between "2001-01-01 12:34:56" and t1.f from t1;
select "2020-12-01" between "2001-01-01 12:34:56" and t1.f from t1;

explain select "2002-12-01" between "2001-01-01 12:34:56" and t1.g from t1;
select "2002-12-01" between "2001-01-01 12:34:56" and t1.g from t1;
select "1998-12-01" between "2001-01-01 12:34:56" and t1.g from t1;
select "2020-12-01" between "2001-01-01 12:34:56" and t1.g from t1;

explain select "2002" between "2001-01-01" and t1.h from t1;
select "2002" between "2001-01-01" and t1.h from t1;
select "1998" between "2001-01-01" and t1.h from t1;
select "2020" between "2001-01-01" and t1.h from t1;

explain select "12:36:57" between "12:00:00" and t1.i from t1;
