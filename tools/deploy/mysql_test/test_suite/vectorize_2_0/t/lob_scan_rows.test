# owner: zongmei.zzm
# owner group: sql2


--result_format 4

alter system flush plan cache global;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 varchar(128));

insert into t1 select concat(randstr(10, random(1)), 'a') as c1 from table(generator(1000));

explain select c1 from t1 where regexp_replace(c1, 'a', 'b');
explain select /*+opt_param('lob_rowsets_max_rows', 128)*/c1 from t1 where regexp_replace(c1, 'a', 'b');
explain select /*+opt_param('lob_rowsets_max_rows', 64)*/c1 from t1 where regexp_replace(c1, 'a', 'b');

alter system set _lob_rowsets_max_rows = 32;

explain select c1 from t1 where regexp_replace(c1, 'a', 'b');
explain select /*+opt_param('lob_rowsets_max_rows', 128)*/c1 from t1 where regexp_replace(c1, 'a', 'b');

alter system set _lob_rowsets_max_rows = 256;

explain select c1 from t1 where regexp_replace(c1, 'a', 'b');
explain select /*+opt_param('lob_rowsets_max_rows', 128)*/c1 from t1 where regexp_replace(c1, 'a', 'b');

alter system set _lob_rowsets_max_rows = 512;
explain select c1 from t1 where regexp_replace(c1, 'a', 'b');

alter system set _rowsets_max_rows = 512;
explain select c1 from t1 where regexp_replace(c1, 'a', 'b');


alter system set _rowsets_max_rows = 256;
alter system set _lob_rowsets_max_rows = 65535;

alter system flush plan cache global;
drop table t1;

