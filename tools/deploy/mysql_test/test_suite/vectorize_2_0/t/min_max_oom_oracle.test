# owner group: sql2


--result_format 4

--error 0,942
drop table t1;

CREATE TABLE "T1" (
  "C2" BINARY_DOUBLE,
  "C3" BINARY_FLOAT,
  "C4" INTERVAL YEAR (2) TO MONTH,
  "C5" NUMBER(37,22),
  "C6" INTERVAL YEAR (2) TO MONTH,
  "C7" NUMBER(*,0),
  "C8" TIMESTAMP(3) DEFAULT TIMESTAMP '1970-01-01 08:00:01.000000000' NOT NULL ENABLE,
  "C9" INTERVAL DAY (2) TO SECOND (6),
  "C11" DATE,
  "C12" INTERVAL DAY (2) TO SECOND (6),
  "C13" NCHAR(54),
  "C14" NUMBER(37,1),
  "C15" NUMBER(37,22),
  "C16" VARCHAR2(51),
  "C17" NUMBER(37,20),
  "C18" NUMBER(37,26),
  "C19" BINARY_FLOAT,
  "C20" NCHAR(59),
  "C21" NVARCHAR2(82),
  "C22" BINARY_FLOAT,
  "C23" VARCHAR2(79),
  "C24" BINARY_DOUBLE,
  "C25" NUMBER(37,27),
  "C26" VARCHAR2(52),
  "C27" NUMBER(37),
  "C28" NUMBER(37),
  "C29" VARCHAR2(55),
  "C31" NCHAR(68),
  "C32" BINARY_FLOAT,
  "C33" TIMESTAMP(6) DEFAULT TIMESTAMP '1970-01-01 08:00:01.000000000' NOT NULL ENABLE,
  "C35" NVARCHAR2(70),
  "C36" CHAR(64),
  "C37" BINARY_DOUBLE,
  "C38" NUMBER
) COMPRESS FOR ARCHIVE REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 MERGE_ENGINE = DELETE_INSERT
 partition by hash(c38)
(partition "P0",
partition "P1",
partition "P2",
partition "P3",
partition "P4",
partition "P5",
partition "P6",
partition "P7",
partition "P8",
partition "P9",
partition "P10");

--source mysql_test/include/copy_data_for_load.inc
load data infile 'data_for_mysqltest_loaddata/min_implicit_agg_reuse_error.csv' into table t1 fields terminated by ',';

--sorted_result
SELECT
  /*+     ENABLE_PARALLEL_DML parallel(2) full(T1_0) NO_USE_HASH_AGGREGATION  opt_param('rowsets_max_rows', 2)*/
  DISTINCT (
    SELECT
      MIN(T1_0.C11)
    FROM
      T1 T1_0
  ),
  T1_0.C13,
  T1_0.C31,
  (
    SELECT
      MIN(T1_0.C26)
    FROM
      T1 T1_0
  ),
  MIN(T1_0.C31),
  T1_0.C7,
  (
    SELECT
      MIN(T1_0.C18)
    FROM
      T1 T1_0
  ),
  T1_0.C14,
  T1_0.C4,
  T1_0.C24,
  (
    SELECT
      T1_0.C11
    FROM
      T1 T1_0
    ORDER BY
      1 DESC
    FETCH FIRST
      1 ROW ONLY
  ),
  MAX(T1_0.C2) OVER (
    ORDER BY
      T1_0.C2 DESC
  ),
  T1_0.C4,
  (
    SELECT
      T1_0.C26
    FROM
      T1 T1_0
    ORDER BY
      1 ASC
    FETCH FIRST
      1 ROW ONLY
  ),
  T1_0.C2,
  COUNT(DISTINCT T1_0.C17),
  T1_0.C32,
  MIN(T1_0.C32)
FROM
  (
    SELECT
      *
    FROM
      (
        SELECT
          C26 C1,
          C2,
          C3,
          C4,
          C5,
          C6,
          C7,
          C8,
          C9,
          C26 C10,
          C11,
          C12,
          C13,
          C14,
          C15,
          C16,
          C17,
          C18,
          C19,
          C20,
          C21,
          C22,
          C23,
          C24,
          C25,
          C26,
          C27,
          C28,
          C29,
          C26 C30,
          C31,
          C32,
          C33,
          C26 C34,
          C35,
          C36,
          C37
        FROM
          T1
      ) UNPIVOT INCLUDE NULLS (
        C30 FOR C30_value IN (C30)
      )
  ) T1_0
WHERE
  EXISTS (
    SELECT
      T1_0.C16,
      T1_0.C4,
      T1_0.C35,
      T1_0.C7,
      T1_0.C7,
      T1_0.C12,
      T1_0.C25,
      T1_0.C11,
      T1_0.C13,
      T1_0.C21,
      T1_0.C1,
      T1_0.C2,
      T1_0.C37,
      T1_0.C8,
      T1_0.C33,
      T1_0.C2,
      T1_0.C32,
      T1_0.C10,
      T1_0.C16,
      T1_0.C32,
      T1_0.C27,
      T1_0.C18,
      T1_0.C18,
      T1_0.C7,
      T1_0.C29,
      T1_0.C10,
      T1_0.C22,
      T1_0.C17
    FROM
      T1 T1_0
    WHERE
      T1_0.C11 >= DATE '2033-11-7'
    ORDER BY
      12 ASC,
      13 ASC,
      14 ASC,
      15 DESC,
      16 ASC,
      17 DESC,
      utl_raw.cast_to_varchar2(T1_0.C10) DESC,
      19 DESC,
      20 DESC,
      21 DESC,
      22,
      23 ASC,
      24 ASC,
      25,
      utl_raw.cast_to_varchar2(T1_0.C10),
      27 ASC,
      28 ASC,
      1 DESC,
      2 ASC,
      3 DESC,
      4 ASC,
      5,
      6 ASC,
      7 DESC,
      8,
      9 DESC,
      10 ASC,
      utl_raw.cast_to_varchar2(T1_0.C1)
    FETCH FIRST
      1 ROW ONLY
  )
  OR T1_0.C11 >= DATE '2033-11-7'
GROUP BY
  ROLLUP (
    T1_0.C13,
    T1_0.C31,
    T1_0.C7,
    T1_0.C14,
    T1_0.C4,
    T1_0.C24,
    T1_0.C2,
    T1_0.C32
  )
ORDER BY
  14 ASC,
  15 ASC,
  16 DESC,
  17,
  18,
  1 ASC,
  2 ASC,
  3 DESC,
  4 DESC,
  5,
  6 ASC,
  7 ASC,
  8,
  9 DESC,
  10 DESC,
  11,
  12 DESC,
  13
FETCH FIRST
  2851 ROW ONLY;