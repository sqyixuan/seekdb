--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: huangweixiang.hwx
#### owner group: sql2
#### description: 向量化2.0测试regexp_replace函数
# tags: expr, datatype

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=all;
alter system set _rowsets_max_rows = 3 tenant=all;
set _enable_rich_vector_format = true;
--result_format 4

--echo ================ expression regexp_replace ================

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 varchar(100));
insert into t1 values (''),('11223311112'),('122absdsadas123'),(123123),('123123'),('12312alipay.com123sadqwe'),('123.400000'),(123.400000),('123阿里123巴巴123'),('123阿里abc巴巴123'),('2, 5, and 10 are numbers in this example'),('2019-08-07'),('a'),('a123b123'),('aaa'),('aaaa'),('aaaaa'),('abc'),('abcabc'),('abcabcABC'),('abcabd'),('abcabe'),('abcdef'),('ABCdefg'),('abc\nabc'),('abc阿123里123巴abc巴abc'),('abc阿里123巴巴abc'),('abc阿里123巴巴ABC'),('abc阿里123阿里巴巴&!@'),('abc阿里abc巴巴abc'),('baseocean'),(null),(NULL),('TechOnTheNet is a great resource'),('xy'),('蚂123蚁123'),('蚂蚁金服abc'),('阿里巴巴'),('阿里巴巴123');
select * from t1;
#normal test(optional params is default value(position = 1, nth_appearance = 0, match_parameter = 'c')
select regexp_replace(c1, 'a','d') from t1;
select regexp_replace(c1,'abc','e') from t1;
select regexp_replace(c1, '巴', '阿里') from t1;
select regexp_replace(c1, 123, 1) from t1;
select regexp_replace(c1, '123','1') from t1;
select regexp_replace(c1, 3.4, 1) from t1;
select regexp_replace(c1,'abc',null) from t1;
select regexp_replace(c1, '巴', null) from t1;
select regexp_replace(c1, 123, null) from t1;
--error 1139
select regexp_replace(c1, '','b') from t1;
select regexp_replace(c1, null, null) from t1;
select regexp_replace(c1, 'b', 'c') from t1;
select regexp_replace(c1, null,'') from t1;

select regexp_replace(c1, '.*','d') from t1;
select regexp_replace(c1, '.?','d') from t1;
select regexp_replace(c1, 'a*','d') from t1;
select regexp_replace(c1, 'ab.','ef') from t1;
select regexp_replace(c1, '阿|里|巴|巴', '123') from t1;
select regexp_replace(c1, '[a-z]', '123') from t1;
select regexp_replace(c1, '1{2,4}', 'abc') from t1;
select regexp_replace(c1, '[[:digit:]]{3}', null) from t1;
select regexp_replace(c1, '[[:alpha:]]{6}\.[[:alpha:]]{3}', '支付宝') from t1;


# with optional params(position, nth_appearance, match_parameter)
--error 1139
select regexp_replace(c1, 'abc','e', 3, 2) from t1;
select regexp_replace(c1, 'abc','e', 1, 0) from t1;
select regexp_replace(c1, 'a','d', 1, 1, 'i') from t1;
select regexp_replace(c1, 'a','d', 1, 0, 'c') from t1;
select regexp_replace(c1, '巴', '阿里', 1, 2) from t1;
--error 1139
select regexp_replace(c1, '巴', '阿里', 4, 0) from t1;
select regexp_replace(c1, 123, 1, 1, 2) from t1;
--error 1139
select regexp_replace(c1, '123', 1, 3, 0) from t1;
select regexp_replace(c1, 3.4, 1, 1, 1) from t1;
select regexp_replace(c1, 'abc', null, 2, 1) from t1;
select regexp_replace(c1, '巴', null, 4, 1) from t1;
select regexp_replace(c1, 123, null, 3, 0) from t1;
select regexp_replace(c1, 23.4, null, 1, 1, 'c') from t1;
select regexp_replace(c1, 23.4, 1, null, 1, 'c') from t1;
select regexp_replace(c1, 23.4, 1, 1, null, 'c') from t1;
select regexp_replace(c1, 23.4, 1, 1, 1, NULL)from t1;
--error 1139
select regexp_replace(c1, 'ab*','e', 3, 2) from t1;
select regexp_replace(c1, 'a..','d', 1, 0) from t1;
select regexp_replace(c1, '^abc','e', 1, 0) from t1;
select regexp_replace(c1, '[a-z]{3}','d', 1, 0, 'i') from t1;
--error 1210
select regexp_replace(c1, '[a-z]  {3}','d', 1, 0, 'ix') from t1;
select regexp_replace(c1, 'abc.\w{3}','d', 1, 1) from t1;
select regexp_replace(c1, '巴*', '阿里', 1, 2) from t1;
select regexp_replace(c1, '巴.', '阿里', 2, 0) from t1;
select regexp_replace(c1, '[1-9]{2}\.[1-9]', null, 1, 1) from t1;

# 测试中英文混合
select regexp_replace(c1, '123', '巴巴') from t1;
select regexp_replace(c1, '巴', '阿里') from t1;
select regexp_replace(c1, 'abc', null) from t1;
select regexp_replace(c1, '巴', '123', 1, 2) from t1;
select regexp_replace(c1, '巴', 'abc', 1, 0) from t1;
--error 1139
select regexp_replace(c1, 'abc', '阿里巴巴', 3) from t1;
select regexp_replace(c1, 'abc', '阿里巴巴', 1, 0, 'c') from t1;
select regexp_replace(c1, 'abc', '阿里巴巴', 1, 0, 'i') from t1;

select regexp_replace(c1, '[1-9]{3}', '#') from t1;
select regexp_replace(c1, '巴*', '阿里') from t1;
select regexp_replace(c1, '[[:alpha:]]{3}', null) from t1;
select regexp_replace(c1, '^123.', '#', 1, 2) from t1;
select regexp_replace(c1, '[a-z]$', '*', 1, 0) from t1;
--error 1139
select regexp_replace(c1, '阿|里|巴|巴', '@', 3) from t1;
select regexp_replace(c1, '[a-z]|[1-9]', '阿里巴巴', 1, 0, 'c') from t1;
select regexp_replace(c1, '[a-z]|[1-9]', '阿里巴巴', 1, 0, 'i') from t1;

# 测试非整的可选参数c1and nth_appearance)
select regexp_replace(c1, 'abc', 'd', 1.9, 1) from t1;
select regexp_replace(c1, 'abc', 'd', 1.9, 2.2) from t1;
select regexp_replace(c1, 123, null, 3.5, 0) from t1;
select regexp_replace(c1, '巴', null, 3.8, 1.9) from t1;
select regexp_replace(c1, 'abc', '阿里巴巴', 1, 0.99999999999999, 'i') from t1;

select regexp_replace(c1, 'ab.', 'd', 1.9, 1) from t1;
select regexp_replace(c1, 'ab.', 'd', 1.9, 2.2) from t1;
select regexp_replace(c1, '^123', null, 1.5, 1) from t1;
select regexp_replace(c1, '巴*', null, 3.8, 1.9) from t1;
select regexp_replace(c1, '[a-z]{3}', '阿里巴巴', 1, 0.99999999999999, 'i') from t1;

#参数边界测试
--error 1139
select regexp_replace(c1, 'a','d', 1844674407370955161518446744073709551615, 1) from t1;
select regexp_replace(c1, 123, 1, 1, 1844674407370955161518446744073709551615) from t1;
--error 1139
select regexp_replace(c1, '巴', '阿里', 1844674407370955161518446744073709551615, 1844674407370955161518446744073709551615) from t1;
--error 1139
select regexp_replace(c1, '巴', 'abc', 1844674407370955161518446744073709551615, 12312312312313123.9999999) from t1;
--error 1139
select regexp_replace(c1, 'a*','d', 1844674407370955161518446744073709551615, 1) from t1;
select regexp_replace(c1, '[[:digit:]]{3}', 1, 1, 1844674407370955161518446744073709551615) from t1;
--error 1139
select regexp_replace(c1, '.*巴$', '阿里', 1844674407370955161518446744073709551615, 1844674407370955161518446744073709551615) from t1;
--error 1139
select regexp_replace(c1, '巴.', 'abc', 1844674407370955161518446744073709551615, 12312312312313123.9999999) from t1;

#结合其他表达式测试
--error 1139
select regexp_replace(lower(c1) ,substr(c1, 1,2), '阿里巴巴', 1 ,1) from t1;
select regexp_replace(c1,'xy'), 'x', abs(-c1) from t1;
select regexp_replace(c1,'xy'), 'x*', abs(-c1) from t1;

#特殊匹配测试
select regexp_replace(c1, 'a*', '1') from t1;
select regexp_replace(c1, '\d', '#') from t1;
select regexp_replace(c1, '\d+','a') from t1;
select regexp_replace(c1, '\d+?','a') from t1;
select regexp_replace(c1, '[0-9]{2,4}','#') from t1;
select regexp_replace(c1, '\d{2,4}?','#') from t1;
select regexp_replace(c1, '^(\c1)', 'CheckYourMath') from t1;
select regexp_replace(c1, '\Aab', '1') from t1;
select regexp_replace(c1, '^ab', '1') from t1;
select regexp_replace(c1, '.*be\Z', '1') from t1;
select regexp_replace(c1, '.*be$', '1') from t1;
select regexp_replace(c1, 'b', 'c') from t1;

#无效参数测试
--error 1210
select regexp_replace(c1, 'ab', '1', -1) from t1;
--error 1210
select regexp_replace(c1, 'aab', '1', 1, -1) from t1;
--error 1210
select regexp_replace(c1, '\Aab', '1', 1, 0, 'p') from t1;
--error 5813
select regexp_replace(c1, '(', 100, 1, 10) from t1;
--error 5812
select regexp_replace(c1, '\d[', 100, 1, 10) from t1;
--error 1139
select regexp_replace(c1, '\d{3', 100, 1, 10) from t1;

#位于建表查询语句中测试及类型推导
--disable_warnings
drop table if exists t1, v1;
--enable_warnings
create table t1(c1 varchar(64), c2 varchar(64));
insert into t1 values(regexp_replace('阿123巴巴','\d{1,}','里'), regexp_replace('阿123巴巴','阿|巴','123'));
insert into t1 values(regexp_replace('阿123巴巴','\d{1,}','里'), regexp_replace('阿123巴巴','阿|巴','123'));
insert into t1 values(regexp_replace('阿123巴巴','\d{1,}','里'), regexp_replace('阿123巴巴','阿|巴','123'));
insert into t1 values(regexp_replace('阿123巴巴','\d{1,}','里'), regexp_replace('阿123巴巴','阿|巴','123'));
insert into t1 values(regexp_replace('阿123巴巴','\d{1,}','里'), regexp_replace('阿123巴巴','阿|巴','123'));
select * from t1;
select regexp_replace(c2, '123', 'abc') from t1;
drop table t1;

create view v1 as select regexp_replace('abcabd', '\Aab', '1') as c1 from dual;
desc v1;
drop view v1;

##bug:

##测试匹配分组替换
##basic test
select regexp_replace('2019-08-07', '(2019)-(08)-(07)', '\1/\2/\3') from dual;
select regexp_replace('abc阿里abc巴巴abc', '(阿)(里)', '\1-\2') from dual;
select regexp_replace('baseocean', '(base)(ocean)', '\2\1\3\4') from dual;
select regexp_replace('aaa', 'aaa', '\\\\\\\\\1') from dual;
select regexp_replace('aaaa', '(a)(a)(a)(a)','\1-\2-$3-$4') from dual;

##multi params test
select regexp_replace('a123b123', '([[:alpha:]])(\d{3})','\1', 1, 2) from dual;
select regexp_replace('蚂123蚁123', '([[:alpha:]])(\d{3})','\1', 1, 2) from dual;

##test other situation
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1 (c1 varchar(20), c2 varchar(20));
create table t2 (c1 varchar(20), c2 varchar(20));
insert into t1 values('阿里巴巴123','蚂蚁金服456');
insert into t1 values('阿里巴巴123','蚂蚁金服456');
insert into t1 values('阿里巴巴123','蚂蚁金服456');
insert into t1 values('阿里巴巴123','蚂蚁金服456');
insert into t2 values('蚂蚁金服abc','阿里巴巴DEF');
insert into t2 values('蚂蚁金服abc','阿里巴巴DEF');
insert into t2 values('蚂蚁金服abc','阿里巴巴DEF');
insert into t2 values('蚂蚁金服abc','阿里巴巴DEF');

select regexp_replace(c1, '(\w{4})(\d{3})', '\2\1') from t1;
select regexp_replace('蚂蚁金服abc', '(\w{4})([[:alpha:]]{3})', '\2\1', 1) from t2;
select regexp_replace(concat(c1, c2), '(\w{4})(\d{3})', '\2\1\3\4') from t1;
select regexp_replace(c1, '(\w{4})([[:alpha:]]{3})', '\2\1\\', 1, 1, 'i') from t2;

drop table t1;
drop table t2;

create table t1 (c1 varchar(10), c2 varchar(10) collate utf8mb4_bin);
insert into t1 values('a', 'b'),('a', 'B'),('A', 'b');
insert into t1 values('a', 'b'),('a', 'B'),('A', 'b');
insert into t1 values('a', 'b'),('a', 'B'),('A', 'b');

select regexp_replace(c1, 'a', '#') from t1;
select regexp_replace(c2, 'b', '#') from t1;
drop table t1;

connection syscon;
alter system set _rowsets_max_rows = 256 tenant=all;