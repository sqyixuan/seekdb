CREATE TABLE `tnull6ubtjw` (
  `a` int(11) NOT NULL,
  `b` int(11) DEFAULT NULL,
  `c` int(11) DEFAULT NULL,
  PRIMARY KEY (`a`)
);

select   (select max(refund_amount) from test.gp_refund_use_amount_00)  as c0 from  (select   ref_1.debit_fee_upper_limit as c0,  ref_1.credit_gt_1k_rate as c1,  ref_0.b as c2,  ref_0.b as c3 from  (test.tnull6ubtjw as ref_0 right join test.cool_agent as ref_1 on (((select vsmUUID from test.t_vsm_lock limit 1 offset 6)  is NULL)  or (ref_1.is_openplatfrom AND ref_0.b))) where ref_1.is_editdoordeviceid is NULL limit 116) as subq_0 where (select licenseID from test.t_lic_license_tmp limit 1 offset 6)  | subq_0.c2;

drop view  t1_view_view;
drop view  t1_view;
drop table t1;

