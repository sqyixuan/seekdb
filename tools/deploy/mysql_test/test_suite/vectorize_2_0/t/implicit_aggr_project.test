--disable_warnings
--disable_query_log
drop table if exists t8;
drop table if exists t38;
drop table if exists t37;

create table t8 (c1 INTEGER(127) ,c2 BINARY(51) ,c3 VARBINARY(52) ,c4 BIGINT(127) ,c5 DATE,c6 DATETIME,c7 INT(127) ,c8 INTEGER(127) ,c9 VARCHAR(86) ,c10 DATETIME,c11 YEAR(4) ,c12 VARCHAR(86) ,c13 DATETIME,c14 DECIMAL(64,27) ,c15 DECIMAL(64,6) ,c16 VARCHAR(86) ,c17 BINARY(84) ,c18 NUMERIC(64,13) ,c19 VARBINARY(77) ,c20 TIMESTAMP(1)  NOT NULL default 0,c21 DATE,c22 CHAR(152) ,c23 NUMERIC(64,22) ,c24 DECIMAL(64,17) ,c25 TIMESTAMP(5)  NOT NULL default 0,c26 VARCHAR(86) ,c27 CHAR(152) ,c28 BINARY(79) ,c29 VARCHAR(86) ,c30 DATETIME,c31 CHAR(152) ,c32 VARCHAR(86) ,c33 TIMESTAMP NOT NULL default 0,c34 INT(127) ,c35 NUMERIC(64,16) ,c36 CHAR(152) ,c37 TIME,c38 DATE, primary key(c15))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ; create unique index g_u_0_BBcRSaq on t8(c29,c26,c4,c22) global ; create unique index u_1_zmiXVdTbq on t8(c32,c26,c36,c15); create unique index u_2_x on t8(c27,c2,c4,c15); create unique index g_u_3_iZCIcF on t8(c18,c15,c23,c29) global ; create index g_i_0_azL on t8(c34,c9,c26) global ; create index g_i_1_yxuT on t8(c4,c36,c3) global ; create index g_i_3_CtTIh on t8(c36,c19) global ;
create table t37 (c1 NUMERIC(64,17) ,c2 VARCHAR(86) ,c3 TIMESTAMP NOT NULL default 0,c4 INT(127) ,c5 NUMERIC(64,5) ,c6 BINARY(54) ,c7 BIGINT(127) ,c8 DECIMAL(64,8) ,c9 DATE,c10 DATE,c11 CHAR(152) ,c12 YEAR(4) ,c13 CHAR(152) ,c14 DATETIME,c15 CHAR(152) ,c16 INTEGER(127) ,c17 DATE,c18 DECIMAL(64,21) ,c19 DATE,c20 DATETIME,c21 BIGINT(127) ,c22 VARBINARY(62) ,c23 VARCHAR(86) ,c24 YEAR(4) ,c25 VARBINARY(52) ,c26 DATETIME,c27 VARBINARY(80) ,c28 INTEGER(127)  auto_increment,c29 NUMERIC(64,13) ,c30 DATETIME,c31 VARBINARY(77) ,c32 VARBINARY(63) ,c33 NUMERIC(64,28) ,c34 DECIMAL(64,16) ,c35 VARBINARY(66) ,c36 VARBINARY(75) ,c37 YEAR(4) ,c38 TIME,c39 BIGINT(127) ,c40 BIGINT(127) ,c41 INT(127) ,c42 YEAR(4) , primary key(c36,c1,c21,c7,c29,c13))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c36) PARTITIONS 9;
create table t38 (c1 NUMERIC(64,17) ,c2 VARCHAR(86) ,c3 TIMESTAMP NOT NULL default 0,c4 INT(127) ,c5 NUMERIC(64,5) ,c6 BINARY(54) ,c7 BIGINT(127) ,c8 DECIMAL(64,8) ,c9 DATE,c10 DATE,c11 CHAR(152) ,c12 YEAR(4) ,c13 CHAR(152) ,c14 DATETIME,c15 CHAR(152) ,c16 INTEGER(127) ,c17 DATE,c18 DECIMAL(64,21) ,c19 DATE,c20 DATETIME,c21 BIGINT(127) ,c22 VARBINARY(62) ,c23 VARCHAR(86) ,c24 YEAR(4) ,c25 VARBINARY(52) ,c26 DATETIME,c27 VARBINARY(80) ,c28 INTEGER(127)  auto_increment,c29 NUMERIC(64,13) ,c30 DATETIME,c31 VARBINARY(77) ,c32 VARBINARY(63) ,c33 NUMERIC(64,28) ,c34 DECIMAL(64,16) ,c35 VARBINARY(66) ,c36 VARBINARY(75) ,c37 YEAR(4) ,c38 TIME,c39 BIGINT(127) ,c40 BIGINT(127) ,c41 INT(127) ,c42 YEAR(4) , primary key(c36,c1,c21,c7,c29,c13))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c36) PARTITIONS 9;

--enable_query_log
--enable_warnings

