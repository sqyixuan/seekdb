# owner: wenkai.cwk
# owner group: sql2

--explain_protocol 2
--result_format 4

--disable_warnings
drop table if exists obright_part;
--enable_warnings

alter system set _inlist_rewrite_threshold = 1;
ALTER TENANT sys SET PRIMARY_ZONE = 'RANDOM';

CREATE TABLE `obright_part` (
  `grp_id` bigint(20) NOT NULL,
  `row_id` bigint(20) NOT NULL,
  `row_hex` varchar(2048) NOT NULL)
 partition by key(grp_id)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`)
WITH COLUMN GROUP(each column);
insert/*+trace*/ into obright_part values (15880, 190562, '000000000000000000000000000000000000000000000000000000000002e862'), (15880, 190563, '000000000000000000000000000000000000000000000000000000000002e863'), (15880, 190569, '000000000000000000000000000000000000000000000000000000000002e869');

select grp_id,row_id from obright_part where (grp_id,row_id) in ((15880,190562),(15880,190563));

--disable_warnings
drop table if exists obright_part;
