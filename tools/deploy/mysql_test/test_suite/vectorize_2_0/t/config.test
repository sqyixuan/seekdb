# owner: xiaoyi.xy
# owner group: sql2

--result_format 4
alter system flush plan cache global;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
alter system set _global_enable_rich_vector_format = true;

--sleep 2

connection default;
create table t1 (a int);
insert into t1 values (1), (2), (3);

--echo ### case 1: config is true, sys var is true, hint is true --> enable rich format
set _enable_rich_vector_format = true;
select /*+ monitor opt_param('enable_rich_vector_format', 'true')*/sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

--echo ### case 2: config is true, sys var is true, hint is false--> disable rich format
set _enable_rich_vector_format = true;
select /*+ monitor opt_param('enable_rich_vector_format', 'false')*/sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

--echo ### case 3: config is true, sys var is false, hint is true--> enable rich format
set _enable_rich_vector_format = false;
select /*+ monitor opt_param('enable_rich_vector_format', 'true')*/sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;


--echo ### case 4: config is true, sys var is false, hint is false--> disable rich format
set _enable_rich_vector_format = false;
select /*+ monitor opt_param('enable_rich_vector_format', 'false')*/sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

--echo ### case 5: config is true, sys var is false, not hint --> disable rich format
set _enable_rich_vector_format = false;
select /*+ monitor */sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

--echo ### case 6: config is true, sys var is true, not hint --> enable rich format
set _enable_rich_vector_format = true;
select /*+ monitor */sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

connection syscon;
alter system set _global_enable_rich_vector_format = false;

--sleep 2

connection default;
--echo ### case 8: config is false, sys var is true, hint is true --> disable rich format
set _enable_rich_vector_format = true;
select /*+ monitor opt_param('enable_rich_vector_format', 'true')*/sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

--echo ### case 9: config is false, sys var is true, hint is false--> disable rich format
set _enable_rich_vector_format = true;
select /*+ monitor opt_param('enable_rich_vector_format', 'false')*/sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

--echo ### case 10: config is false, sys var is false, hint is true--> disable rich format
set _enable_rich_vector_format = false;
select /*+ monitor opt_param('enable_rich_vector_format', 'true')*/sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;


--echo ### case 11: config is false, sys var is false, hint is false--> disable rich format
set _enable_rich_vector_format = false;
select /*+ monitor opt_param('enable_rich_vector_format', 'false')*/sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

--echo ### case 12: config is false, sys var is false, not hint --> disable rich format
set _enable_rich_vector_format = false;
select /*+ monitor */sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

--echo ### case 13: config is false, sys var is true, not hint --> disable rich format
set _enable_rich_vector_format = true;
select /*+ monitor */sum(a) from t1;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;


drop table t1;

connection syscon;
alter system set _global_enable_rich_vector_format = true;
