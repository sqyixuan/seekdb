# owner: zongmei.zzm
# owner group: sql2

--result_format 4

--disable_warnings
drop table if exists t;
--enable_warnings

create table t(c1 int, c2 varchar(32), a0 int);

insert /*+append enable_parallel_dml parallel(16)*/into t select uniform(-100, 100, random(1)), randstr(32, random(2)), uniform(-100, 100, random(3)) from table(generator(100000));

explain basic select /*+no_use_hash_aggregation*/a0, approx_count_distinct(c1) from t group by a0 order by 1;
select /*+no_use_hash_aggregation*/a0, approx_count_distinct(c1) from t group by a0 order by 1;
explain basic select /*+no_use_hash_aggregation parallel(2)*/a0, approx_count_distinct(c1) from t group by a0 order by 1;
select /*+no_use_hash_aggregation parallel(2)*/a0, approx_count_distinct(c1) from t group by a0 order by 1;

explain basic select /*+no_use_hash_aggregation*/a0, approx_count_distinct(c2) from t group by a0 order by 1;
select /*+no_use_hash_aggregation*/a0, approx_count_distinct(c2) from t group by a0 order by 1;
explain basic select /*+no_use_hash_aggregation parallel(2)*/a0, approx_count_distinct(c2) from t group by a0 order by 1;
select /*+no_use_hash_aggregation parallel(2)*/a0, approx_count_distinct(c2) from t group by a0 order by 1;

drop table t;
create table t(a varchar(1024), b int);

insert into t select NULL, uniform(1, 10000, random(3)) from table(generator(100));

explain basic select /*+opt_param('rowsets_max_rows', 8) no_use_hash_aggregation*/approx_count_distinct_synopsis_merge(a) from t group by b;
select /*+opt_param('rowsets_max_rows', 8) no_use_hash_aggregation*/approx_count_distinct_synopsis_merge(a) from t group by b;

explain basic select /*+opt_param('rowsets_max_rows', 8) no_use_hash_aggregation*/approx_count_distinct_synopsis(a) from t group by b;
select /*+opt_param('rowsets_max_rows', 8) no_use_hash_aggregation*/approx_count_distinct_synopsis(a) from t group by b;

explain basic select /*+opt_param('rowsets_max_rows', 8) no_use_hash_aggregation*/approx_count_distinct(a) from t group by b;
select /*+opt_param('rowsets_max_rows', 8) no_use_hash_aggregation*/approx_count_distinct(a) from t group by b;
drop table t;