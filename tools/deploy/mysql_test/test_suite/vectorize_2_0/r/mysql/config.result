| sum(a) |
+--------+
|      6 |
+--------+
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;
+--------------+----------------------+------------------+--------+
| plan_line_id | plan_operation       | sum(output_rows) | rescan |
+--------------+----------------------+------------------+--------+
|            0 | PHY_SCALAR_AGGREGATE |                1 |      0 |
|            1 | PHY_TABLE_SCAN       |                1 |      0 |
+--------------+----------------------+------------------+--------+

