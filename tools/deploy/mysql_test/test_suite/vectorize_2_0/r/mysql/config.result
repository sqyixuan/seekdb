result_format: 4
alter system flush plan cache global;

drop table if exists t1;
drop table if exists t2;
alter system set _global_enable_rich_vector_format = true;

create table t1 (a int);
insert into t1 values (1), (2), (3);

### case 1: config is true, sys var is true, hint is true --> enable rich format
set _enable_rich_vector_format = true;
select /*+ monitor opt_param('enable_rich_vector_format', 'true')*/sum(a) from t1;
+--------+
| sum(a) |
+--------+
|      6 |
+--------+
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;
+--------------+--------------------------+------------------+--------+
| plan_line_id | plan_operation           | sum(output_rows) | rescan |
+--------------+--------------------------+------------------+--------+
|            0 | PHY_VEC_SCALAR_AGGREGATE |                1 |      0 |
|            1 | PHY_VEC_TABLE_SCAN       |                1 |      0 |
+--------------+--------------------------+------------------+--------+

### case 2: config is true, sys var is true, hint is false--> disable rich format
set _enable_rich_vector_format = true;
select /*+ monitor opt_param('enable_rich_vector_format', 'false')*/sum(a) from t1;
