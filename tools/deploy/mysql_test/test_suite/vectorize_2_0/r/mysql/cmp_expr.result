result_format: 4
set _enable_rich_vector_format = true;
alter system set _enable_decimal_int_type = false;

drop table if exists t1;
drop table if exists t2;

create table t1(a int, b varchar(128), c number(10, 2));

insert into t1 values (1, 'hello', 1.23), (2, 'world', 2.34), (3, 'test', 3.45);

select a, b, c, a = 1, b = 'world', c = 1.23 from t1;
+------+-------+------+-------+-------------+----------+
| a    | b     | c    | a = 1 | b = 'world' | c = 1.23 |
+------+-------+------+-------+-------------+----------+
|    1 | hello | 1.23 |     1 |           0 |        1 |
|    2 | world | 2.34 |     0 |           1 |        0 |
|    3 | test  | 3.45 |     0 |           0 |        0 |
+------+-------+------+-------+-------------+----------+
select a, b, c, a >=1, b != 'world', c < 2.34 from t1;
+------+-------+------+-------+--------------+----------+
| a    | b     | c    | a >=1 | b != 'world' | c < 2.34 |
+------+-------+------+-------+--------------+----------+
|    1 | hello | 1.23 |     1 |            1 |        1 |
|    2 | world | 2.34 |     1 |            0 |        0 |
|    3 | test  | 3.45 |     1 |            1 |        0 |
+------+-------+------+-------+--------------+----------+

drop table t1;

create table t1(a json, b json);
insert into t1 values ('1', '1'), ('[1, 2, 3]', '[1, 2]'), ('{"hello": "world"}', '{"hello": "json"}'), ('{"A": 1}', '{"A": 2}');

select a, b, a = b from t1;
+--------------------+-------------------+-------+
| a                  | b                 | a = b |
+--------------------+-------------------+-------+
| 1                  | 1                 |     1 |
| [1, 2, 3]          | [1, 2]            |     0 |
| {"hello": "world"} | {"hello": "json"} |     0 |
| {"A": 1}           | {"A": 2}          |     0 |
+--------------------+-------------------+-------+
select a, b, a != b from t1;
+--------------------+-------------------+--------+
| a                  | b                 | a != b |
+--------------------+-------------------+--------+
| 1                  | 1                 |      0 |
| [1, 2, 3]          | [1, 2]            |      1 |
| {"hello": "world"} | {"hello": "json"} |      1 |
| {"A": 1}           | {"A": 2}          |      1 |
+--------------------+-------------------+--------+
select a, b, a >= b from t1;
+--------------------+-------------------+--------+
| a                  | b                 | a >= b |
+--------------------+-------------------+--------+
| 1                  | 1                 |      1 |
| [1, 2, 3]          | [1, 2]            |      1 |
| {"hello": "world"} | {"hello": "json"} |      1 |
| {"A": 1}           | {"A": 2}          |      0 |
+--------------------+-------------------+--------+
select a, b, a <= b from t1;
+--------------------+-------------------+--------+
| a                  | b                 | a <= b |
+--------------------+-------------------+--------+
| 1                  | 1                 |      1 |
| [1, 2, 3]          | [1, 2]            |      0 |
| {"hello": "world"} | {"hello": "json"} |      0 |
| {"A": 1}           | {"A": 2}          |      1 |
+--------------------+-------------------+--------+
select a, b, a > b from t1;
+--------------------+-------------------+-------+
| a                  | b                 | a > b |
+--------------------+-------------------+-------+
| 1                  | 1                 |     0 |
| [1, 2, 3]          | [1, 2]            |     1 |
| {"hello": "world"} | {"hello": "json"} |     1 |
| {"A": 1}           | {"A": 2}          |     0 |
+--------------------+-------------------+-------+
select a, b, a < b from t1;
+--------------------+-------------------+-------+
| a                  | b                 | a < b |
+--------------------+-------------------+-------+
| 1                  | 1                 |     0 |
| [1, 2, 3]          | [1, 2]            |     0 |
| {"hello": "world"} | {"hello": "json"} |     0 |
| {"A": 1}           | {"A": 2}          |     1 |
+--------------------+-------------------+-------+

drop table t1;

alter system set _enable_decimal_int_type = true;
