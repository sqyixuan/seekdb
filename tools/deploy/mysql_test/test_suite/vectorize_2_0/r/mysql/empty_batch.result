CREATE TABLE `cool_agent` (
  `agent_id` int(11) NOT NULL AUTO_INCREMENT,
  `city` varchar(100) DEFAULT NULL,
  `agent_name` varchar(255) DEFAULT NULL,
  `address` varchar(255) DEFAULT NULL,
  `agent_tel` varchar(20) DEFAULT NULL,
  `agent_user` varchar(100) DEFAULT NULL,
  `agent_legal_person_id_card` varchar(30) DEFAULT NULL,
  `agent_legal_person_tel` varchar(20) DEFAULT NULL,
  `rate` varchar(10) DEFAULT '0',
  `regtime` varchar(20) DEFAULT NULL,
  `agent_type` int(11) DEFAULT NULL,
  `agent_fr` varchar(10) DEFAULT NULL,
  `agent_cost` varchar(10) DEFAULT NULL,
  `channel_id` int(11) DEFAULT NULL,
  `parent_id` varchar(100) DEFAULT '',
  `is_channelagent` varchar(11) DEFAULT NULL,
  `agent_mark` int(11) DEFAULT '0',
  `is_openplatfrom` int(10) DEFAULT '0',
  `is_editdoordeviceid` int(10) DEFAULT '0',
  `is_online` int(10) NOT NULL DEFAULT '1',
  `is_status` int(10) NOT NULL DEFAULT '1',
  `debit_gt_1k_rate` varchar(20) DEFAULT NULL,
  `credit_gt_1k_rate` varchar(20) DEFAULT NULL,
  `debit_fee_upper_limit` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`agent_id`)
);

CREATE TABLE `gp_refund_use_amount_00` (
  `use_amount_no` varchar(64) NOT NULL,
  `refund_amount` decimal(15,4) DEFAULT NULL,
  `refund_service_amount` decimal(20,4) DEFAULT NULL,
  `bill_no` varchar(64) NOT NULL,
  `gmt_create` timestamp(6) NOT NULL,
  `gmt_modified` timestamp(6) NOT NULL,
  `second_currency` varchar(3) DEFAULT NULL,
  `second_refund_amount` decimal(15,4) DEFAULT NULL,
  PRIMARY KEY (`use_amount_no`),
  UNIQUE KEY `bill_no` (`bill_no`) BLOCK_SIZE 16384 LOCAL
);

CREATE TABLE `t_lic_license_tmp` (
  `licenseID` int(11) NOT NULL AUTO_INCREMENT COMMENT 'ID',
  `licenseVsmID` char(50) NOT NULL COMMENT '许可证ID',
  `licenseVsmType` int(11) NOT NULL COMMENT '类型',
  `licenseVsmSn` char(20) DEFAULT NULL COMMENT '序列号',
  `licenseIssueDate` datetime NOT NULL COMMENT '签发时间',
  `licenseCurrentDate` datetime DEFAULT NULL COMMENT '当前时间',
  `licenseExpireDate` datetime NOT NULL COMMENT '过期时间',
  `licenseStatus` int(11) DEFAULT '0' COMMENT '当前状态： 0 可用 1 已使用',
  `licenseServiceProviderID` char(50) DEFAULT NULL COMMENT '服务商标识',
  `licenseServiceProviderNm` char(100) DEFAULT NULL COMMENT '服务商名称',
  `licenseVsmMac1` char(20) DEFAULT NULL COMMENT '对外MAC端口1',
  `licenseVsmMac2` char(20) DEFAULT NULL COMMENT '对外MAC端口2',
  `licenseVsmMac` char(20) DEFAULT NULL COMMENT '内部通讯MAC',
  `licensePkpVersion` char(10) DEFAULT NULL COMMENT 'PKP版本',
  `licensePkpPubkey` varchar(500) NOT NULL COMMENT 'PKP公钥',
  `licenseSignature` varchar(500) NOT NULL COMMENT '签名',
  PRIMARY KEY (`licenseID`)
);

CREATE TABLE `t_vsm_lock` (
  `hsmUUID` varchar(255) NOT NULL DEFAULT '',
  `vsmUUID` varchar(255) NOT NULL DEFAULT '',
  `lockType` int(11) DEFAULT NULL COMMENT '锁类型',
  PRIMARY KEY (`hsmUUID`, `vsmUUID`)
);

CREATE TABLE `tnull6ubtjw` (
  `a` int(11) NOT NULL,
  `b` int(11) DEFAULT NULL,
  `c` int(11) DEFAULT NULL,
  PRIMARY KEY (`a`)
);

EXPLAIN BASIC select   (select max(refund_amount) from test.gp_refund_use_amount_00)  as c0 from  (select   ref_1.debit_fee_upper_limit as c0,  ref_1.credit_gt_1k_rate as c1,  ref_0.b as c2,  ref_0.b as c3 from  (test.tnull6ubtjw as ref_0 right join test.cool_agent as ref_1 on (((select vsmUUID from test.t_vsm_lock limit 1 offset 6)  is NULL)  or (ref_1.is_openplatfrom AND ref_0.b))) where ref_1.is_editdoordeviceid is NULL limit 116) as subq_0 where (select licenseID from test.t_lic_license_tmp limit 1 offset 6)  | subq_0.c2;
