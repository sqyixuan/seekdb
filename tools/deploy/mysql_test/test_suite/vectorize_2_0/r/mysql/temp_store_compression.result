drop database if exists temp_store;
create database temp_store;
use temp_store;
alter system set_tp tp_no = 2210, error_code = 2097152, frequency = 1;
loaddata
create table t1 (c1 int, c2 varchar(512), c3 varchar(512), c4 varchar(512), c5 varchar(512));
insert /*+query_timeout(100000000)*/ into t1
select 1, repeat('abcd', 128), repeat('efgh', 128), repeat('hgfe', 128), repeat('dcba', 128)
from table(generator(100000));
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
test hint
none
explain outline
select /*+blocking(1) opt_param('spill_compression_codec', 'none') */
count(c1), sum(crc32(c2)), sum(crc32(c3)), sum(crc32(c4)), sum(crc32(c5)) from t1;
