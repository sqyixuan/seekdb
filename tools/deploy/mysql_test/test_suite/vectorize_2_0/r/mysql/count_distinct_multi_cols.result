result_format: 4
drop table if exists t;
create table t (a int, b int, c int) with column group(each column);

insert /*+append enable_parallel_dml parallel(32)*/into t select case when uniform(1, 10, random(1)) >= 5 then uniform(1, 1000, random(2)) else null end, 
                                                                 case when uniform(1, 10, random(3)) >= 5 then uniform(1, 1000, random(4)) else null end,
                                                                 uniform(1, 50, random(3)) from table (generator(300000));

explain basic select /*+parallel(2)*/count(distinct a, b) from t group by c;
