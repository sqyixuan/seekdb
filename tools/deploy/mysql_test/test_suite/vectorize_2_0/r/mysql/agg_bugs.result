result_format: 4
drop table if exists t0;
CREATE TABLE IF NOT EXISTS t0(c0 BIGINT, c2 TINYTEXT, c3 FLOAT(27, 0) );
INSERT INTO t0 VALUES(1,'',1);
SELECT SUM(distinct c0) as AF0, * FROM t0 where c2 = '' GROUP BY c2;
+------+------+------+------+
| AF0  | c0   | c2   | c3   |
+------+------+------+------+
|    1 |    1 |      |    1 |
+------+------+------+------+
SELECT AVG(DISTINCT t0.c0) AS AF0, * FROM t0 GROUP BY t0.c2 HAVING (! ((((t0.c2,-1) NOT IN ((t0.c2,-1))) && ((AF0,-1) IN ((-1,0), (AF0,-1), (-1,0)))) OR (('') NOT IN (("ec*<8yKM*0"), (t0.c2)))));
+--------+------+------+------+
| AF0    | c0   | c2   | c3   |
+--------+------+------+------+
| 1.0000 |    1 |      |    1 |
+--------+------+------+------+
SELECT /*+ NO_REWRITE */ AVG(DISTINCT t0.c0) AS AF0, * FROM t0 GROUP BY t0.c2 HAVING (! ((((t0.c2,-1) NOT IN ((t0.c2,-1))) && ((AF0,-1) IN ((-1,0), (AF0,-1), (-1,0)))) OR (('') NOT IN (("ec*<8yKM*0"), (t0.c2)))));
+--------+------+------+------+
| AF0    | c0   | c2   | c3   |
+--------+------+------+------+
| 1.0000 |    1 |      |    1 |
+--------+------+------+------+

drop table t0;
