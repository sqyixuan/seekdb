drop database if exists temp_store;
create database temp_store;
use temp_store;
basic
create table t0 (c1 int, c2 bigint, c3 char(100), c4 varchar(100), c5 decimal(20,2));
insert into t0 values (1, 1, '1', '1', 1.1);
insert into t0 values (2, 2, '2', '2', 2.2);
insert into t0 values (3, 3, '3', '3', 3.3);
insert into t0 values (4, 4, '4', '4', 4.4);
insert into t0 values (11, 11, '11', '11', 11.11);
insert into t0 values (22, 22, '22', '22', 22.22);
insert into t0 values (33, 33, '33', '33', 33.33);
insert into t0 values (55, 55, '55', '55', 55.55);
explain select /*+blocking('all')*/ * from t0;
