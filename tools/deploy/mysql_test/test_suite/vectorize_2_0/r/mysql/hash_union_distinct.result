alter system set_tp tp_no = 2400, error_code = 0, frequency = 1;
set _enable_rich_vector_format = 1;
drop table if exists t1,t2,t3,tnull;
create table t1(a int primary key, b int, c int);
create table t2 (a double primary key, b double, c double);
create table t3(a varchar(10) primary key, b varchar(10), c varchar(10));
create table tnull(a int primary key, b int, c int);
alter system minor freeze;
call dbms_stats.gather_table_stats('TEST', 'T1');
call dbms_stats.gather_table_stats('TEST', 'T2');
call dbms_stats.gather_table_stats('TEST', 'T3');
explain_protocol: 2
result_format: 4
