testtesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestsettesttesttesttestset
drop table if exists t1;
drop procedure if exists pro_t1;
drop database luofan_db;
