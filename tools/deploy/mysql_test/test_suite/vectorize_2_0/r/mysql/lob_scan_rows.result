result_format: 4
alter system flush plan cache global;

drop table if exists t1;
create table t1(c1 varchar(128));

insert into t1 select concat(randstr(10, random(1)), 'a') as c1 from table(generator(1000));

explain select c1 from t1 where regexp_replace(c1, 'a', 'b');
Query Plan
===============================================
|ID|OPERATOR       |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------
|0 |TABLE FULL SCAN|t1  |500     |41          |
===============================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1]), filter([cast(regexp_replace(cast(t1.c1, VARCHAR(1048576)), cast('a', VARCHAR(1048576)), cast('b', VARCHAR(1048576))), DOUBLE(-1, 
      -1))]), rowset=256
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
explain select /*+opt_param('lob_rowsets_max_rows', 128)*/c1 from t1 where regexp_replace(c1, 'a', 'b');
