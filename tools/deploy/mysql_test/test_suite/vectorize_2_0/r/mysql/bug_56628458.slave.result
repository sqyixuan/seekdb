explain_protocol: 2
result_format: 4
drop table if exists t1,t2,t3;
create table t2(c1 int);
create table t1(c1 int) ;
create table t3(c1 int) partition by hash(c1) partitions 3;
insert/*+trace*/ into t2 values(1),(2);

EXPLAIN select /*+USE_HASH_SET(@"SET$1")*/ c1, c -1 from (select /*+USE_HASH_SET*/ c1, 1+1 c   from t1 where exists (select /*+no_unnest*/ 1 from t3 where t3.c1 = t1.c1) union select c1, 1+1 as c from t2);
