result_format: 4
drop table if exists t1;
set _enable_rich_vector_format = true;
create table t1(a int, b int);
insert into t1 values (1, 1), (2, 2), (3, 3);

select /*+parallel(2)*/ sum(a) as sum_a, sum(b) as sum_b from t1 order by sum_a limit 2;
+-------+-------+
| sum_a | sum_b |
+-------+-------+
|     6 |     6 |
+-------+-------+
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;
+--------------+----------------------------+------------------+--------+
| plan_line_id | plan_operation             | sum(output_rows) | rescan |
+--------------+----------------------------+------------------+--------+
|            0 | PHY_VEC_LIMIT              |                1 |      0 |
|            1 | PHY_VEC_SCALAR_AGGREGATE   |                1 |      0 |
|            2 | PHY_VEC_PX_FIFO_COORD      |                1 |      0 |
|            3 | PHY_VEC_PX_REDUCE_TRANSMIT |                1 |      0 |
|            4 | PHY_VEC_SCALAR_AGGREGATE   |                1 |      0 |
|            5 | PHY_VEC_GRANULE_ITERATOR   |                1 |      0 |
|            6 | PHY_VEC_TABLE_SCAN         |                1 |      0 |
+--------------+----------------------------+------------------+--------+

