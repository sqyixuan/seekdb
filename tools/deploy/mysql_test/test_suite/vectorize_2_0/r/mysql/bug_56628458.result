select /*+USE_HASH_SET(@"SET$1")*/ c1, c -1 from (select /*+USE_HASH_SET*/ c1, 1+1 c   from t1 where exists (select /*+no_unnest*/ 1 from t3 where t3.c1 = t1.c1) union select c1, 1+1 as c from t2);
