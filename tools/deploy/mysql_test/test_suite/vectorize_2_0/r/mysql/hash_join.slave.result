drop table t1, t2;

drop procedure if exists insert_data;
create PROCEDURE insert_data(tab_nam varchar(100),var int)
begin
    set @i = 0;
    SET @IN_VA_SQL = CONCAT("INSERT INTO ",tab_nam," VALUES (1,1);");
    PREPARE STMT FROM @IN_VA_SQL;
    while @i < var do
    EXECUTE STMT;
    set @i = @i+1;
    end while;
    deallocate PREPARE STMT;
end;
//

create table T1 (a int , b int);
call insert_data('T1',500);

create table T2 (a CHAR , b VARCHAR(10));
call insert_data('T2',500);

set global ob_sql_work_area_percentage = 80;

EXPLAIN SELECT COUNT(*) FROM T2 WHERE A =ANY (SELECT  R.B FROM T1 L CROSS JOIN T1 R ON L.A = R.A WHERE L.B = R.A);
Query Plan
============================================================
|ID|OPERATOR                   |NAME |EST.ROWS|EST.TIME(us)|
------------------------------------------------------------
|0 |EXCHANGE IN REMOTE         |     |1       |31110       |
|1 |└─EXCHANGE OUT REMOTE      |     |1       |31109       |
|2 |  └─SCALAR GROUP BY        |     |1       |31109       |
|3 |    └─HASH SEMI JOIN       |     |495     |31100       |
|4 |      ├─TABLE FULL SCAN    |t2   |500     |4           |
|5 |      └─SUBPLAN SCAN       |VIEW1|247500  |8417        |
|6 |        └─HASH JOIN        |     |247500  |7762        |
|7 |          ├─TABLE FULL SCAN|L    |500     |54          |
|8 |          └─TABLE FULL SCAN|R    |500     |27          |
============================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT(*)]), filter(nil)
  1 - output([T_FUN_COUNT(*)]), filter(nil)
  2 - output([T_FUN_COUNT(*)]), filter(nil), rowset=3
      group(nil), agg_func([T_FUN_COUNT(*)])
  3 - output(nil), filter(nil), rowset=3
      equal_conds([cast(t2.a, DECIMAL(-1, -1)) = VIEW1.B]), other_conds(nil)
  4 - output([t2.a]), filter(nil), rowset=3
      access([t2.a]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  5 - output([VIEW1.B]), filter(nil), rowset=3
      access([VIEW1.B])
  6 - output([cast(R.b, DECIMAL(11, 0))]), filter(nil), rowset=3
      equal_conds([L.b = R.a]), other_conds(nil)
  7 - output([L.b]), filter([L.b = L.a]), rowset=3
      access([L.a], [L.b]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([L.__pk_increment]), range(MIN ; MAX)always true
  8 - output([R.a], [R.b]), filter(nil), rowset=3
      access([R.a], [R.b]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([R.__pk_increment]), range(MIN ; MAX)always true
SELECT COUNT(*) FROM T2 WHERE A =ANY (SELECT  R.B FROM T1 L CROSS JOIN T1 R ON L.A = R.A WHERE L.B = R.A);
