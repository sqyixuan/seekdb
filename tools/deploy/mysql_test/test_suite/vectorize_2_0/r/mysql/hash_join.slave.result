result_format: 4
explain_protocol: 2
alter system flush plan cache global;
alter system set _rowsets_enabled=true tenant=all;
alter system set _rowsets_max_rows = 3 tenant=all;

drop table if exists t1,t2;
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
insert/*trace*/ into t1 values(1,1),(1,2), (2,3), (2,4), (3,5), (3,6), (4,7), (5,8), (6,9), (6,10);
insert/*trace*/ into t2 values(1,1),(1,2), (2,3), (5,8), (6,9), (6,10), (7,11);

set _enable_rich_vector_format = 1;


***** test inner join
EXPLAIN select /*+leading(t1,t2)*/ * from t1, t2 where t1.c1 = t2.c1;
Query Plan
=====================================================
|ID|OPERATOR             |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------
|0 |EXCHANGE IN REMOTE   |    |10      |28          |
|1 |└─EXCHANGE OUT REMOTE|    |10      |22          |
|2 |  └─HASH JOIN        |    |10      |8           |
|3 |    ├─TABLE FULL SCAN|t1  |10      |3           |
|4 |    └─TABLE FULL SCAN|t2  |7       |3           |
=====================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t2.c1], [t2.c2]), filter(nil)
  1 - output([t1.c1], [t1.c2], [t2.c1], [t2.c2]), filter(nil)
  2 - output([t1.c1], [t1.c2], [t2.c1], [t2.c2]), filter(nil), rowset=3
      equal_conds([t1.c1 = t2.c1]), other_conds(nil)
  3 - output([t1.c1], [t1.c2]), filter(nil), rowset=3
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  4 - output([t2.c1], [t2.c2]), filter(nil), rowset=3
      access([t2.c1], [t2.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select /*+leading(t1,t2)*/ * from t1, t2 where t1.c1 = t2.c1;
+------+------+------+------+
| c1   | c2   | c1   | c2   |
+------+------+------+------+
|    1 |    2 |    1 |    1 |
|    1 |    2 |    1 |    2 |
|    2 |    4 |    2 |    3 |
|    1 |    1 |    1 |    1 |
|    1 |    1 |    1 |    2 |
|    2 |    3 |    2 |    3 |
|    5 |    8 |    5 |    8 |
|    6 |   10 |    6 |    9 |
|    6 |   10 |    6 |   10 |
|    6 |    9 |    6 |    9 |
|    6 |    9 |    6 |   10 |
+------+------+------+------+
EXPLAIN select /*+leading(t2,t1)*/ * from t1, t2 where t1.c1 = t2.c1;
