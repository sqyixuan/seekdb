explain_protocol: 2
result_format: 4
alter system set _enable_decimal_int_type = false;
set _enable_rich_vector_format = true;

drop table if exists t1;
create table t1(c1 int, c2 number(20,3));
insert/*trace*/ into t1 values(20, 20.20);
insert/*trace*/ into t1 values(10, 10.10);

EXPLAIN select /*+no_rewrite*/ partition_key(c1) from (select * from t1) t where sin(t.c1) > -1 and sin(t.c2) > -2;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |SUBPLAN SCAN     |t   |1       |3           |
|1 |└─TABLE FULL SCAN|t1  |2       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([partition_key(t.c1)]), filter([sin(cast(t.c1, DOUBLE(-1, -1))) > cast(-1, DOUBLE(-1, -1))], [sin(cast(t.c2, DOUBLE(-1, -1))) > cast(-2, DOUBLE(-1,
       -1))]), rowset=16
      access([t.c1], [t.c2])
  1 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select /*+no_rewrite*/ partition_key(c1) from (select * from t1) t where sin(t.c1) > -1 and sin(t.c2) > -2;
+---------------------+
| partition_key(c1)   |
+---------------------+
| 6958135875817990116 |
| 7188666914263997357 |
+---------------------+
EXPLAIN select /*+no_rewrite parallel(2)*/ partition_key(c1) from (select * from t1) t where sin(t.c1) > -1 and sin(t.c2) > -2;
Query Plan
===========================================================
|ID|OPERATOR               |NAME    |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------
|0 |PX COORDINATOR         |        |1       |2           |
|1 |└─EXCHANGE OUT DISTR   |:EX10000|1       |2           |
|2 |  └─SUBPLAN SCAN       |t       |1       |2           |
|3 |    └─PX BLOCK ITERATOR|        |2       |2           |
|4 |      └─TABLE FULL SCAN|t1      |2       |2           |
===========================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(partition_key(t.c1))]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(partition_key(t.c1))]), filter(nil), rowset=16
      dop=2
  2 - output([t.c1]), filter([sin(cast(t.c1, DOUBLE(-1, -1))) > cast(-1, DOUBLE(-1, -1))], [sin(cast(t.c2, DOUBLE(-1, -1))) > cast(-2, DOUBLE(-1, -1))]), rowset=16
      access([t.c1], [t.c2])
  3 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
  4 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select /*+no_rewrite parallel(2)*/ partition_key(c1) from (select * from t1) t where sin(t.c1) > -1 and sin(t.c2) > -2;
+---------------------+
| partition_key(c1)   |
+---------------------+
| 6958135875817990116 |
| 7188666914263997357 |
+---------------------+
EXPLAIN select /*+no_rewrite use_nl(t tt)*/ * from (select * from t1) t  join (select * from t1 limit 2) tt where tt.c1 =t.c1;
Query Plan
=====================================================
|ID|OPERATOR             |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------
|0 |NESTED-LOOP JOIN     |    |2       |5           |
|1 |├─SUBPLAN SCAN       |t   |2       |3           |
|2 |│ └─TABLE FULL SCAN  |t1  |2       |3           |
|3 |└─MATERIAL           |    |2       |3           |
|4 |  └─SUBPLAN SCAN     |tt  |2       |3           |
|5 |    └─TABLE FULL SCAN|t1  |2       |3           |
=====================================================
Outputs & filters:
-------------------------------------
  0 - output([t.c1], [t.c2], [tt.c1], [tt.c2]), filter(nil), rowset=16
      conds([tt.c1 = t.c1]), nl_params_(nil), use_batch=false
  1 - output([t.c1], [t.c2]), filter(nil), rowset=16
      access([t.c1], [t.c2])
  2 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  3 - output([tt.c1], [tt.c2]), filter(nil), rowset=16
  4 - output([tt.c1], [tt.c2]), filter(nil), rowset=16
      access([tt.c1], [tt.c2])
  5 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      limit(2), offset(nil), is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select /*+no_rewrite use_nl(t tt)*/ * from (select * from t1) t  join (select * from t1 limit 2) tt where tt.c1 =t.c1;
+------+--------+------+--------+
| c1   | c2     | c1   | c2     |
+------+--------+------+--------+
|   20 | 20.200 |   20 | 20.200 |
|   10 | 10.100 |   10 | 10.100 |
+------+--------+------+--------+

drop table t1;

alter system set _enable_decimal_int_type = true;
