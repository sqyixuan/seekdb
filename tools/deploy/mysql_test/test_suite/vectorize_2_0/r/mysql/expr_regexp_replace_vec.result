insert into t1 values(regexp_replace('йҳҝ123е·ҙе·ҙ','\d{1,}','йҮҢ'), regexp_replace('йҳҝ123е·ҙе·ҙ','йҳҝ|е·ҙ','123'));
insert into t1 values(regexp_replace('йҳҝ123е·ҙе·ҙ','\d{1,}','йҮҢ'), regexp_replace('йҳҝ123е·ҙе·ҙ','йҳҝ|е·ҙ','123'));
insert into t1 values(regexp_replace('йҳҝ123е·ҙе·ҙ','\d{1,}','йҮҢ'), regexp_replace('йҳҝ123е·ҙе·ҙ','йҳҝ|е·ҙ','123'));
insert into t1 values(regexp_replace('йҳҝ123е·ҙе·ҙ','\d{1,}','йҮҢ'), regexp_replace('йҳҝ123е·ҙе·ҙ','йҳҝ|е·ҙ','123'));
insert into t1 values(regexp_replace('йҳҝ123е·ҙе·ҙ','\d{1,}','йҮҢ'), regexp_replace('йҳҝ123е·ҙе·ҙ','йҳҝ|е·ҙ','123'));
