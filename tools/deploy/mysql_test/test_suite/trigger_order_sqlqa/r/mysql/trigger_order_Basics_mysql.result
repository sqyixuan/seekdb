##after+delete+follows/precedes
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int, a2 varchar(128)) default charset='utf8';
insert into t1 values(5, '爱E族');
create trigger tr1
after delete on t1
for each row 
begin
insert into t2 values(7,'www.com');
update t2 set a2 = 'a2' where a1 =7;
end
//
create trigger tr2
after delete on t1 
for each row follows tr1
begin
insert into t2 values(6,'www.com');
update t2 set a2 = 'aa' where a1 =7;
end 
//
delete from t1 where c1=5;
select * from t1;
c1	c2
select * from t2;
a1	a2
6	www.com
7	aa
SELECT ACTION_ORDER  FROM information_schema.triggers WHERE trigger_name= 'tr1' and trigger_schema ='db1';
ACTION_ORDER
1
SELECT ACTION_ORDER  FROM information_schema.triggers WHERE trigger_name= 'tr2' and trigger_schema ='db1';
ACTION_ORDER
2
