drop database IF EXISTS  db1;
create database db1;
use db1;
##设置超时时间
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';
##基本语法
##after+update+follows/precedes
drop table if exists t1;
Warnings:
Note	1051	Unknown table 'db1.t1'
drop table if exists t2;
Warnings:
Note	1051	Unknown table 'db1.t2'
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int, a2 varchar(128)) default charset='utf8';
insert into t1 values(5, '爱E族');
create trigger tr1
after update on t1
for each row 
begin
insert into t2 values(7,'www.com');
update t2 set a2 = 'a2' where a1 =7;
end
//
create trigger tr2
after update on t1 
for each row follows tr1
begin
insert into t2 values(6,'www.com');
update t2 set a2 = 'aa' where a1 =7;
end 
//
update t1 set c1=6 where c2='爱E族';
select * from t1;
c1	c2
6	爱E族
select * from t2;
a1	a2
6	www.com
7	aa
SELECT ACTION_ORDER  FROM information_schema.triggers WHERE trigger_name= 'tr1' and trigger_schema ='db1';
ACTION_ORDER
1
SELECT ACTION_ORDER  FROM information_schema.triggers WHERE trigger_name= 'tr2' and trigger_schema ='db1';
ACTION_ORDER
2
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int, a2 varchar(128)) default charset='utf8';
insert into t1 values(5, '爱E族');
create trigger tr1
after update on t1
for each row 
begin
insert into t2 values(7,'www.com');
update t2 set a2 = 'a2' where a1 =7;
end
//
create trigger tr2
after update on t1 
for each row precedes tr1
begin
insert into t2 values(6,'www.com');
update t2 set a2 = 'aa' where a1 =7;
end 
//
update t1 set c1=6 where c2='爱E族';
select * from t1;
c1	c2
6	爱E族
select * from t2;
a1	a2
6	www.com
7	a2
SELECT ACTION_ORDER  FROM information_schema.triggers WHERE trigger_name= 'tr1' and trigger_schema ='db1';
ACTION_ORDER
2
SELECT ACTION_ORDER  FROM information_schema.triggers WHERE trigger_name= 'tr2' and trigger_schema ='db1';
ACTION_ORDER
1
