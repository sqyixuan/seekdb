drop database IF EXISTS  db1;
create database db1;
use db1;
##设置超时时间
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';
##视图
##不支持触发器作用视图
drop table if exists t1;
Warnings:
Note	1051	Unknown table 'db1.t1'
drop table if exists t2;
Warnings:
Note	1051	Unknown table 'db1.t2'
drop view if exists view_t1;
Warnings:
Note	1051	Unknown table 'db1.view_t1'
drop view if exists view_t2;
Warnings:
Note	1051	Unknown table 'db1.view_t2'
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 float, a2 char(128)) default charset='utf8';
create view view_t1  as select * from t1;
create view view_t2  as select * from t2;
insert into t1 values(10,'迈巴赫');
create trigger tr1
before insert on view_t1
for each row 
begin
if new.c1>='20'and new.c1<='100' then insert into t2 values(100,'劳斯莱斯');
end if;
end
//
ERROR 0A000: simple dml trigger isn't used on user table not supported
create trigger tr2
before insert on view_t1
for each row precedes tr1
begin
if new.c1>='10'and new.c1<='20' then insert into t2 values(120,'2022-10-20 20:19:59.009');
end if;
end
//
ERROR 0A000: simple dml trigger isn't used on user table not supported
insert into t1 values(300,'ss'),(50,null),(20,null);
##before+insert+precedes/follows
drop table if exists t1;
drop table if exists t2;
drop view if exists view_t1;
drop view if exists view_t2;
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 float, a2 char(128)) default charset='utf8';
create view view_t1  as select * from t1;
create view view_t2  as select * from t2;
insert into t1 values(10,'迈巴赫');
create trigger tr1
before insert on t1
for each row 
begin
if new.c1>='20'and new.c1<='100' then insert into view_t2 values(100,'劳斯莱斯');
end if;
end
//
create trigger tr2
before insert on t1
for each row precedes tr1
begin
if new.c1>='10'and new.c1<='20' then insert into t2 values(120,'2022-10-20 20:19:59.009');
end if;
end
//
create trigger tr3
before insert on t1
for each row follows tr1
begin
delete from view_t2 where a1=120;
end
//
create trigger tr4
before insert on t1
for each row precedes tr3
begin
update t2 set a1=20 where a1=100;
if new.c1>='50'and new.c1<='80' then insert into view_t2 values(300,'迈巴赫');
end if;
end
//
insert into view_t1 values(50,'ss');
select * from view_t1;
c1	c2
10	迈巴赫
50	ss
select * from view_t2;
a1	a2
20	劳斯莱斯
300	迈巴赫
