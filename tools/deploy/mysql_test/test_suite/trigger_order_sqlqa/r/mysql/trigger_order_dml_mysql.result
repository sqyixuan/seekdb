##range分区
##before+insert+precedes/follows
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int, c2 varchar(30)) partition by range(c1) (
PARTITION p0 VALUES LESS THAN (100),
PARTITION p1 VALUES LESS THAN (200),
PARTITION p2 VALUES LESS THAN (301)
);
create table t2 (a1 int,ac2 varchar(30)) partition by range(a1) (
PARTITION p0 VALUES LESS THAN (10),
PARTITION p1 VALUES LESS THAN (100),
PARTITION p2 VALUES LESS THAN (501)
);
insert into t1 values(100,'可乐k');
create trigger tr1
before insert on t1
for each row 
begin
if new.c1>='20'and new.c1<='100' then insert into t2 values(100,'劳斯莱斯');
end if;
end
//
create trigger tr2
before insert on t1
for each row precedes tr1
begin
if new.c1>='10'and new.c1<='20' then insert into t2 values(120,'2022-10-20 20:19:59.009');
end if;
end
//
create trigger tr3
before insert on t1
for each row follows tr2
begin
if new.c1>='100'and new.c1<='500' then insert into t2 values(200,'迈巴赫');
end if;
end
//
create trigger tr4
before insert on t1
for each row precedes tr3
begin
if new.c1>='20'and new.c1<='100' then insert into t2 values(500,'迈巴赫');
end if;
end
//
create trigger tr5
before insert on t1
for each row follows tr4
begin
if new.c1>='50'and new.c1<='80' then insert into t2 values(300,'迈巴赫');
end if;
end
