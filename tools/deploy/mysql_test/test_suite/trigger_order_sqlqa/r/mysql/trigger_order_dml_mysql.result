drop database IF EXISTS  db1;
create database db1;
use db1;
##设置超时时间
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';
##单列
drop table if exists t1;
Warnings:
Note	1051	Unknown table 'db1.t1'
drop table if exists t2;
Warnings:
Note	1051	Unknown table 'db1.t2'
create table t1 (c1 double primary key, c2 varchar(128)) default charset='utf8';
create table t2 (a1 double primary key, a2 varchar(128)) default charset='utf8';
insert into t1 values(999.9,'迈巴赫');
insert into t1 values(888.8,'劳斯莱斯');
insert into t1 values(99.9,'拉法');
insert into t2 values(999.9,'奔驰');
insert into t2 values(888.8,'宝马');
insert into t2 values(99.9,'奥迪');
create trigger tr1
before update on t1
for each row 
begin
update t2 set a2='桑塔纳' where a1=888.8;
end
//
create trigger tr2
before update on t1 
for each row precedes tr1
begin
update t2 set a2='桑塔纳' where a1=888.8;
end //
update t1 set c1=1000.01 where c2='拉法';
select * from t1;
c1	c2
1000.01	拉法
888.8	劳斯莱斯
999.9	迈巴赫
select * from t2;
a1	a2
888.8	桑塔纳
99.9	奥迪
999.9	奔驰
##多列
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 double primary key, c2 varchar(128)) default charset='utf8';
create table t2 (a1 double primary key, a2 varchar(128)) default charset='utf8';
insert into t1 values(999.9,'迈巴赫');
insert into t1 values(888.8,'劳斯莱斯');
insert into t1 values(99.9,'拉法');
insert into t2 values(999.9,'奔驰');
insert into t2 values(888.8,'宝马');
insert into t2 values(99.9,'奥迪');
create trigger tr1
before update on t1
for each row 
begin
update t2 set a2='桑塔纳',a1=88.88 where a1=888.8;
end
//
create trigger tr2
before update on t1 
for each row follows tr1
begin
update t2 set a2='null',a1=99.99 where a1=999.9;
end //
update t1 set c1=1000.01,c2='法拉利' where c2='拉法';
select * from t1;
c1	c2
1000.01	法拉利
888.8	劳斯莱斯
999.9	迈巴赫
select * from t2;
a1	a2
88.88	桑塔纳
99.9	奥迪
99.99	null
##普通表测试三个以上触发器
##before+insert+precedes/follows
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 float, a2 char(128)) default charset='utf8';
insert into t1 values(10,'迈巴赫');
create trigger tr1
before insert on t1
for each row 
begin
if new.c1>='20'and new.c1<='100' then insert into t2 values(100,'劳斯莱斯');
end if;
end
//
create trigger tr2
before insert on t1
for each row precedes tr1
begin
if new.c1>='10'and new.c1<='20' then insert into t2 values(120,'2022-10-20 20:19:59.009');
end if;
end
//
create trigger tr3
before insert on t1
for each row follows tr2
begin
if new.c1>='100'and new.c1<='500' then insert into t2 values(200,'迈巴赫');
end if;
end
//
create trigger tr4
before insert on t1
for each row precedes tr3
begin
if new.c1>='20'and new.c1<='100' then insert into t2 values(600,'迈巴赫');
end if;
end
//
create trigger tr5
before insert on t1
for each row follows tr4
begin
if new.c1>='50'and new.c1<='80' then insert into t2 values(300,'迈巴赫');
end if;
end
//
insert into t1 values(300,'ss'),(50,null),(20,null);
select * from t1;
c1	c2
10	迈巴赫
20	NULL
300	ss
50	NULL
select * from t2;
a1	a2
100	劳斯莱斯
100	劳斯莱斯
120	2022-10-20 20:19:59.009
200	迈巴赫
300	迈巴赫
600	迈巴赫
600	迈巴赫
