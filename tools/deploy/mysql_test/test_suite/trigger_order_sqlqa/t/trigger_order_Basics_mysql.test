--echo ##new变量和old变量
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int, a2 varchar(128)) default charset='utf8';
DELIMITER //;
create trigger tr1
before insert on t1
for each row
insert into t2 values(new.c2,new.c1),(2,3);
//
create trigger tr2
before insert on t1
for each row follows tr1
delete from t2 where a2=new.c2;
//
create trigger tr3
before insert on t1
for each row precedes tr1
insert into t2 values(2,3),(new.c1,new.c2);
//
DELIMITER ;//
insert into t1 values(4, 5);
--sorted_result 
select * from t1;
--sorted_result 
select * from t2;


drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int, a2 varchar(128)) default charset='utf8';
insert into t1 values(4,5);
DELIMITER //;
create trigger tr1
before delete on t1
for each row
insert into t2 values(old.c1,old.c2),(2,3);
//
create trigger tr2
before delete on t1
for each row follows tr1
delete from t2 where a2=5;
//
create trigger tr3
before delete on t1
for each row precedes tr1
insert into t2 values(old.c2,old.c1);
//
DELIMITER ;//
delete from t1 where c1=4;
--sorted_result 
select * from t1;
--sorted_result 
select * from t2;

drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int, a2 varchar(128)) default charset='utf8';
insert into t1 values(4,null);
insert into t2 values(2,3);
insert into t2 values(1,4);
insert into t2 values(null,0);
DELIMITER //;
create trigger tr1
before update on t1
for each row
update t2 set a1=new.c2 where a2=old.c1;
//
create trigger tr2
before update on t1
for each row follows tr1
delete from t2 where a2=new.c2;
//
create trigger tr3
before update on t1
for each row 
insert into t2 values(new.c1,old.c2)
//
DELIMITER ;//
update t1 set c2=3 where c1=4;
--sorted_result 
select * from t1;
--sorted_result 
select * from t2;

--echo ##声明变量传值
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int, a2 varchar(128)) default charset='utf8';
insert into t2 values(3,'指令');
DELIMITER //;
create trigger tr1 after insert
on t1 for each row
begin
  declare c int;
  set c = (select a1 from t2 where a1=new.c1);
  update t2 set a1 = c + 1 where a1 = new.c1;
end //
create trigger tr2 after insert
on t1 for each row follows tr1
begin
  declare d varchar(64);
  set d ='零零';
  update t2 set a2 = d  where a1 = new.c1+1;
end 
//
DELIMITER ;//
insert into t1 values(3,'零零');
--sorted_result 
select * from t1;
--sorted_result 
select * from t2;


