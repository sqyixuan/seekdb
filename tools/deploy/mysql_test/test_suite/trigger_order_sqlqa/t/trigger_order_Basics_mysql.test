--echo ##创建两个触发器,再删除不带可选参数,创建带可选参数的触发器
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int, a2 varchar(128)) default charset='utf8';
insert into t1 values(5, '爱E族');
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	insert into t2 values(7,'www.com');
	update t2 set a2 = 'a2' where a1 =7;
end
//
create trigger tr2
before update on t1 
for each row precedes tr1
begin
	insert into t2 values(6,'www.com');
	update t2 set a2 = 'aa' where a1 =7;
end 
//
DELIMITER ;//
drop trigger tr1;
DELIMITER //;
create trigger tr1
before update on t1
for each row follows tr2
begin
	insert into t2 values(7,'www.com');
	update t2 set a2 = 'a2' where a1 =7;
end
//
create trigger tr3
before update on t1
for each row precedes tr2
begin
	insert into t2 values(7,'www.com');
	update t2 set a2 = 'a2' where a1 =7;
end
//
DELIMITER ;//
update t1 set c1=6 where c2='爱E族';
--sorted_result 
select * from t1;
--sorted_result 
select * from t2;
SELECT ACTION_ORDER  FROM information_schema.triggers WHERE trigger_name= 'tr1' and trigger_schema ='db1';
SELECT ACTION_ORDER  FROM information_schema.triggers WHERE trigger_name= 'tr2' and trigger_schema ='db1';
SELECT ACTION_ORDER  FROM information_schema.triggers WHERE trigger_name= 'tr3' and trigger_schema ='db1';

--echo ##多触发器
--echo ##单表
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int, a2 varchar(128)) default charset='utf8';
create table t3 (b1 int, b2 varchar(128)) default charset='utf8';
insert into t1 values(5, '爱E族'); 
DELIMITER //;
create trigger tr1
after update on t1
for each row 
begin
	insert into t2 values(7,'www.com');
end
//
create trigger tr2
after update on t1 
for each row follows tr1
begin
	insert into t2 values(null,'ww.com');
	delete from t2 where a1 is null;
end 
//
create trigger tr3
after update on t1 
for each row precedes tr1
begin
	insert into t2 values(6,'w.com');
end 
//
create trigger tr4
after update on t1 
for each row precedes tr1
begin
	insert into t2 values(5,'w.com');
end 
//
create trigger tr5
after update on t1 
for each row follows tr1
begin
	insert into t2 values(4,'w.com');
end 
//
create trigger tr6
after update on t1 
for each row precedes tr1
begin
	insert into t2 values(2,'w.com');
end 
//
create trigger tr7
after update on t1 
for each row precedes tr1
begin
	insert into t2 values(45,'w.com');
end 
//
DELIMITER ;//
update t1 set c1=6 where c2='爱E族';
--sorted_result 
select * from t1;
--sorted_result 
select * from t2;
--sorted_result 
select * from t3;


--echo ##多表
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int, a2 varchar(128)) default charset='utf8';
create table t3 (b1 int, b2 varchar(128)) default charset='utf8';
insert into t1 values(5, '爱E族'); 
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	insert into t2 values(7,'www.com');
end
//
create trigger tr2
before update on t1 
for each row follows tr1
begin
	insert into t2 values(null,'ww.com');
end 
//
create trigger tr3
before update on t1 
for each row precedes tr1
begin
	insert into t2 values(6,'w.com');
end 
//
create trigger tr4
before update on t2
for each row 
begin
	insert into t3 values(5,'w.com');
end
//
create trigger tr5
before update on t2 
for each row follows tr4
begin
	insert into t3 values(4,'w.com');
end 
//
create trigger tr6
before update on t2 
for each row precedes tr5
begin
	insert into t3 values(2,'w.com');
end 
//
create trigger tr7
before update on t3 
for each row 
begin
	insert into t1 values(45,'w.com');
end 
//
create trigger tr8
before update on t3 
for each row precedes tr7
begin
	insert into t1 values(55,'w.com');
end 
//
DELIMITER ;//
update t1 set c1=6 where c2='爱E族';
update t2 set a1=1 where a1 is null;
update t3 set b1=11 where b1=5;
--sorted_result 
select * from t1;
--sorted_result 
select * from t2;
--sorted_result 
select * from t3;

drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int, a2 varchar(128)) default charset='utf8';
create table t3 (b1 int, b2 varchar(128)) default charset='utf8';
insert into t1 values(5, '爱E族'); 
DELIMITER //;
create trigger tr1
after update on t1
for each row 
begin
	insert into t2 values(7,'www.com');
end
//
create trigger tr2
after update on t1 
for each row follows tr1
begin
	insert into t2 values(null,'ww.com');
	delete from t2 where a1 is null;
end 
//
create trigger tr3
after update on t1 
for each row precedes tr1
begin
	insert into t2 values(6,'w.com');
end 
//
create trigger tr4
after update on t1 
for each row precedes tr1
begin
	insert into t2 values(5,'w.com');
end 
//
create trigger tr5
after update on t1 
for each row follows tr1
begin
	insert into t2 values(4,'w.com');
end 
//
create trigger tr6
after update on t1 
for each row precedes tr1
begin
	insert into t2 values(2,'w.com');
end 
//
create trigger tr7
after update on t1 
for each row precedes tr1
begin
	insert into t2 values(45,'w.com');
end 
//
DELIMITER ;//
update t1 set c1=6 where c2='爱E族';
--sorted_result 
select * from t1;
--sorted_result 
select * from t2;
--sorted_result 
select * from t3;


--echo ##删除不含可选参数的基础触发器
