drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int, a2 varchar(128)) default charset='utf8';
insert into t1 values(5, '爱E族'); 
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	insert into t2 values(7,'www.com');
end
//
create trigger tr2
before update on t1 
for each row follows tr1
begin
	insert into t2 values(null,'ww.com');
end 
//
create trigger tr3
before update on t1 
for each row precedes tr1
begin
	insert into t2 values(8,'ww.com');
end 
//
DELIMITER ;//
drop trigger tr1;
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	insert into t2 values(7,'www.com');
end
//
DELIMITER ;//
update t1 set c1=7 where c2='爱E族';
--sorted_result 
select * from t1;
--sorted_result 
select * from t2;

