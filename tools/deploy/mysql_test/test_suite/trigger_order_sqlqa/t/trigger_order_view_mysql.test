//
DELIMITER ;//
update view_t1 set c1=50 where c1=10;
--sorted_result 
select * from view_t1;
--sorted_result 
select * from view_t2;

--echo ##before+delete+precedes/follows
drop table if exists t1;
drop table if exists t2;
drop view if exists view_t1;
drop view if exists view_t2;
create table t1 (c1 int, c2 varchar(128)) default charset='utf8';
create table t2 (a1 float, a2 char(128)) default charset='utf8';
create view view_t1  as select * from t1;
create view view_t2  as select * from t2;
insert into t1 values(50,'迈巴赫');
DELIMITER //;
create trigger tr1
before delete on t1
for each row 
begin
	if old.c1>='20'and old.c1<='100' then insert into view_t2 values(100,'劳斯莱斯');
end if;
end
//
create trigger tr2
before delete on t1
for each row precedes tr1
begin
	if old.c1>='10'and old.c1<='20' then insert into t2 values(120,'2022-10-20 20:19:59.009');
end if;
end
//
create trigger tr3
before delete on t1
for each row follows tr1
begin
	delete from view_t2 where a1=120;
end
//
create trigger tr4
before delete on t1
for each row precedes tr3
begin
	update t2 set a1=20 where a1=100;
	if old.c1>='50'and old.c1<='80' then insert into view_t2 values(300,'迈巴赫');
end if;
end
//
DELIMITER ;//
delete from t1 where c1=50;
--sorted_result 
select * from view_t1;
--sorted_result 
select * from view_t2;

