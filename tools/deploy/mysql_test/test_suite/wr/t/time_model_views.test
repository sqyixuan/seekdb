#owner:roland.qk
#owner group: imf

--disable_query_log
--enable_query_log

--result_format 4
--enable_info

connect (conn_root,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);
connection conn_root;

desc oceanbase.GV$OB_SYS_TIME_MODEL;
desc oceanbase.V$OB_SYS_TIME_MODEL;
desc oceanbase.GV$OB_SESS_TIME_MODEL;
desc oceanbase.V$OB_SESS_TIME_MODEL;
desc oceanbase.DBA_WR_SYS_TIME_MODEL;
desc oceanbase.CDB_WR_SYS_TIME_MODEL;

connection default;

desc oceanbase.GV$OB_SYS_TIME_MODEL;
desc oceanbase.V$OB_SYS_TIME_MODEL;
desc oceanbase.GV$OB_SESS_TIME_MODEL;
desc oceanbase.V$OB_SESS_TIME_MODEL;
desc oceanbase.DBA_WR_SYS_TIME_MODEL;
#--error 1146
#desc oceanbase.CDB_WR_SYS_TIME_MODEL;
