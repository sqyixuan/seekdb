#owner:roland.qk
#owner group: imf

--disable_query_log
--enable_query_log

--result_format 4
--enable_info

connect (conn_root,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);
connection conn_root;

show tenant;
desc __all_virtual_sqlstat;
desc v$ob_sqlstat;
desc gv$ob_sqlstat;
desc __wr_sqlstat;
desc __wr_sqltext;
desc DBA_WR_SQLSTAT;
desc CDB_WR_SQLSTAT;
desc DBA_WR_SQLTEXT;
desc CDB_WR_SQLTEXT;

show tenant;
desc v$ob_sqlstat;
desc gv$ob_sqlstat;
#--error 1146
#desc __wr_sqlstat;
#--error 1146
#desc __wr_sqltext;

desc DBA_WR_SQLSTAT;
#--error 1146
#desc CDB_WR_SQLSTAT;
desc DBA_WR_SQLTEXT;
#--error 1146
#desc CDB_WR_SQLTEXT;
