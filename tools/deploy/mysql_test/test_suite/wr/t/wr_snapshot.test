#owner:roland.qk
#owner group: imf

--disable_query_log
--enable_query_log

--result_format 4
--enable_info

connect (conn_root,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);
connection conn_root;
alter system set_tp tp_name = ERRSIM_WR_SNAPSHOT_COLLECTOR_FAILURE, error_code = 0, frequency = 0;

# set ob_query_timeout = 1200000000;

# success create wr snapshot
--disable_warnings
call dbms_workload_repository.create_snapshot();
--let $current_snap_id=query_get_value(select snap_id from CDB_WR_SNAPSHOT order by snap_id desc limit 1, snap_id, 1)
--disable_query_log
eval select cluster_id, tenant_id, snap_flag from CDB_WR_SNAPSHOT where snap_id=$current_snap_id;
eval select cluster_id, tenant_id, snap_flag,status from __all_virtual_wr_snapshot where snap_id=$current_snap_id;
--enable_query_log

--let $current_snap_id=$current_snap_id+1
# ERR INJECTION
alter system set_tp tp_name = ERRSIM_WR_SNAPSHOT_COLLECTOR_FAILURE, error_code = 4016, frequency = 1;
--error 4000
call dbms_workload_repository.create_snapshot();
--enable_warnings
alter system set_tp tp_name = ERRSIM_WR_SNAPSHOT_COLLECTOR_FAILURE, error_code = 0, frequency = 0;
# should have no record because create snapshot failed
--disable_query_log
eval select cluster_id, tenant_id, snap_flag from CDB_WR_SNAPSHOT where snap_id=$current_snap_id;
eval select cluster_id, tenant_id, snap_flag,status from __all_virtual_wr_snapshot where snap_id=$current_snap_id;
--enable_query_log

--let $current_snap_id=$current_snap_id+1
call dbms_workload_repository.create_snapshot();
--disable_query_log
eval select cluster_id, tenant_id, snap_flag from CDB_WR_SNAPSHOT where snap_id=$current_snap_id;
eval select cluster_id, tenant_id, snap_flag,status from __all_virtual_wr_snapshot where snap_id=$current_snap_id;
--enable_query_log

# test for dropping a snapshot
--disable_query_log
eval call dbms_workload_repository.drop_snapshot_range($current_snap_id-1, $current_snap_id);
--sleep 5
eval select cluster_id, tenant_id, snap_flag from CDB_WR_SNAPSHOT where snap_id=$current_snap_id;
eval select cluster_id, tenant_id, snap_flag,status from __all_virtual_wr_snapshot where snap_id=$current_snap_id;
--enable_query_log

# test for modify snapshot setting
call dbms_workload_repository.modify_snapshot_settings(0);
eval select retention, retention_num, tenant_id from __wr_control;
eval select retention, tenant_id from CDB_WR_CONTROL;
--error 1210
call dbms_workload_repository.modify_snapshot_settings(5);
eval select retention, retention_num, tenant_id from __wr_control;
eval select retention, tenant_id from CDB_WR_CONTROL;
call dbms_workload_repository.modify_snapshot_settings(24*60);
eval select retention, retention_num, tenant_id from __wr_control;
eval select retention, tenant_id from CDB_WR_CONTROL;
call dbms_workload_repository.modify_snapshot_settings(50 * 365 * 24 * 60);
eval select retention, retention_num, tenant_id from __wr_control;
eval select retention, tenant_id from CDB_WR_CONTROL;
call dbms_workload_repository.modify_snapshot_settings(100 * 365 * 24 * 60);
eval select retention, retention_num, tenant_id from __wr_control;
eval select retention, tenant_id from CDB_WR_CONTROL;
--error 1210
call dbms_workload_repository.modify_snapshot_settings(100 * 365 * 24 * 60+1);
eval select retention, retention_num, tenant_id from __wr_control;
eval select retention, tenant_id from CDB_WR_CONTROL;
call dbms_workload_repository.modify_snapshot_settings(NULL);
eval select retention, retention_num, tenant_id from __wr_control;
eval select retention, tenant_id from CDB_WR_CONTROL;

call dbms_workload_repository.modify_snapshot_settings(NULL, 0);
eval select snap_interval, snapint_num, tenant_id from __wr_control;
eval select snap_interval, tenant_id from CDB_WR_CONTROL;
--error 1210
call dbms_workload_repository.modify_snapshot_settings(NULL, 5);
eval select snap_interval, snapint_num, tenant_id from __wr_control;
eval select snap_interval, tenant_id from CDB_WR_CONTROL;
call dbms_workload_repository.modify_snapshot_settings(NULL, 10);
eval select snap_interval, snapint_num, tenant_id from __wr_control;
eval select snap_interval, tenant_id from CDB_WR_CONTROL;
call dbms_workload_repository.modify_snapshot_settings(NULL, 20);
eval select snap_interval, snapint_num, tenant_id from __wr_control;
eval select snap_interval, tenant_id from CDB_WR_CONTROL;
call dbms_workload_repository.modify_snapshot_settings(NULL, 365 * 24 * 60);
eval select snap_interval, snapint_num, tenant_id from __wr_control;
eval select snap_interval, tenant_id from CDB_WR_CONTROL;
--error 1210
call dbms_workload_repository.modify_snapshot_settings(NULL, 365 * 24 * 60+1);
eval select snap_interval, snapint_num, tenant_id from __wr_control;
eval select snap_interval, tenant_id from CDB_WR_CONTROL;
call dbms_workload_repository.modify_snapshot_settings(NULL, NULL);
eval select snap_interval, snapint_num, tenant_id from __wr_control;
eval select snap_interval, tenant_id from CDB_WR_CONTROL;

call dbms_workload_repository.modify_snapshot_settings(NULL, NULL);
eval select retention, retention_num,snap_interval, snapint_num, tenant_id from __wr_control;
eval select retention,snap_interval, tenant_id from CDB_WR_CONTROL;
call dbms_workload_repository.modify_snapshot_settings(0, 0);
eval select retention, retention_num,snap_interval, snapint_num, tenant_id from __wr_control;
eval select retention,snap_interval, tenant_id from CDB_WR_CONTROL;
call dbms_workload_repository.modify_snapshot_settings(10*24*60, 20);
eval select retention, retention_num,snap_interval, snapint_num, tenant_id from __wr_control;
eval select retention,snap_interval, tenant_id from CDB_WR_CONTROL;

# test wr sql retry
--disable_warnings
call dbms_workload_repository.create_snapshot();

## err that will be retried
alter system set_tp tp_name =EN_WR_SNAPSHOT_ERRSIM, error_code=5627,frequency = 1;
--error 4012
call dbms_workload_repository.create_snapshot();
alter system set_tp tp_name =EN_WR_SNAPSHOT_ERRSIM, error_code=5627,frequency = 10;
call dbms_workload_repository.create_snapshot();

## err that will be retried
alter system set_tp tp_name =EN_WR_SNAPSHOT_ERRSIM, error_code=4279,frequency = 1;
--error 4279
call dbms_workload_repository.create_snapshot();
alter system set_tp tp_name =EN_WR_SNAPSHOT_ERRSIM, error_code=4279,frequency = 0;
--enable_warnings

connection default;
# non-sys tenant failed to create a snapshot
#--error 1227
#call dbms_workload_repository.create_snapshot();
# non-sys tenant failed to drop snapshots
#--error 1227
#call dbms_workload_repository.drop_snapshot_range(0,9999);
# non-sys tenant failed to modify some wr settings
#--error 1227
#call dbms_workload_repository.modify_snapshot_settings(0,0);
--enable_warnings

# test for tablet wr_res_mgr_sysstat
--disable_query_log
eval desc oceanbase.DBA_WR_RES_MGR_SYSSTAT;
eval desc oceanbase.DBA_WR_ACTIVE_SESSION_HISTORY;
eval desc oceanbase.DBA_WR_SNAPSHOT;
eval desc oceanbase.DBA_WR_STATNAME;
eval desc oceanbase.DBA_WR_SYSSTAT;
eval desc oceanbase.DBA_WR_CONTROL;
eval desc oceanbase.DBA_WR_SYSTEM_EVENT;
eval desc oceanbase.DBA_WR_EVENT_NAME;
eval desc oceanbase.DBA_WR_SQLSTAT;
eval desc oceanbase.DBA_WR_SYS_TIME_MODEL;
eval desc oceanbase.DBA_WR_SQLTEXT;
eval desc oceanbase.DBA_WR_SQL_PLAN;
--enable_query_log
