# bug: 
--disable_warnings
drop table if exists t1;
drop view if exists v2;
--enable_warnings

create table t2(a varchar(20), b varchar(20));

set sql_quote_show_create=OFF;
set sql_mode='ANSI_QUOTES';
CREATE VIEW `v2` AS 
select `t2`.`a` AS `a`,.`t2`.`b` AS `b` from `t2` where (`t2`.`a` like 'a%' escape '\\') WITH CHECK OPTION;

show create view v2;

drop table t2;
drop view v2;