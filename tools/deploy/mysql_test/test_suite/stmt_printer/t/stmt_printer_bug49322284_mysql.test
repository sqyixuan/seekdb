# owner group: SQL1

# bug: 
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(a int, b int);
insert into t1 values (10,20);

create or replace view v as select bin(a), bin(b) from t1; 
show create view v;
select * from v;

create or replace view v as select oct(a), oct(b) from t1; 
show create view v;
select * from v;

create or replace view v as select conv(a, 10, 4), conv(b, 10, 8) from t1; 
show create view v;
select * from v;

create or replace view v as select conv(a, 8, 10), conv(b, 8, 10) from t1; 
show create view v;
select * from v;

create or replace view v as select ntile(1) over (partition by bin(a) order by a) from t1; 
show create view v;
select * from v;

set @a = 1+(select bin(200) from dual);
select @a from dual;

# bug: 
create or replace view v as select a+b as c from t1 having c < 5 order by c+1,c; 
show create view v;
select * from v;
drop view v;

drop table t1;