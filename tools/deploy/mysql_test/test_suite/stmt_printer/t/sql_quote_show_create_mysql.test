# owner: dingjincheng.djc
# owner group: SQL1
# tags : optimizer,printer
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop view if exists v1;
drop table if exists `t```;
drop view if exists v2;
--enable_warnings
create table t1 (
  `c1` int(11) primary key,
  `c2` int(11) NOT NULL,
  `a b` char(20) NOT NULL,
  `b``c` varchar(20) NOT NULL,
  `c'b` date not null,
  `d"b` timestamp not null,
  `中文` char(20) not null,
  UNIQUE KEY (`c2`)
);

create table t2 (
  `c1` int(11) primary key,
  `c2` int(11) NOT NULL,
  `a b` char(20) NOT NULL,
  `b``c` varchar(20) NOT NULL,
  `c'b` date not null,
  `d"b` timestamp not null,
  `中文` char(20) not null,
  KEY (`c2`, `b``c`) 
);

create table `t``` (
  `c1` int(11) primary key,
  `c2` int(11) NOT NULL,
  `a b` varchar(20) NOT NULL,
  `b``c` varchar(20) NOT NULL,
  `c'b` varchar(20) not null,
  `d"b` varchar(20) not null,
  `中文` varchar(20) not null,
  KEY (`c2`, `b``c`) 
);

create view v1 as select /*+ leading(A B) */ 'n`b', 'm\'c', "p\"d", 'ANY中文\'"', A.* from t1 A, t2 B;
create view v2 as select * from `t``` as `m``t``m` where `a b` = 'a b' and `b``c` = 'b`c' and `c'b` = 'c\'b' and `d"b` = 'd"b' and `中文` = '中文';
--result_format 4
set sql_quote_show_create = on;
set sql_mode = '';
show create table t1;
show create table t2;
show create view v1;
show create view v2;
show create database test;
select * from v2;

set sql_mode = 'ANSI_QUOTES';
show create table t1;
show create table t2;
show create view v1;
show create view v2;
show create database test;
select * from v2;

set sql_quote_show_create = off;
set sql_mode = '';
show create table t1;
show create table t2;
show create view v1;
show create view v2;
show create database test;
select * from v2;

drop table if exists t1;
drop table if exists t2;
drop view if exists v1;
drop table if exists `t```;
drop view if exists v2;
