SOURCE_LANG VARCHAR(4),
LAST_UPDATE_DATE DATE,
CREATION_DATE DATE,
CREATED_BY NUMBER(15),
LAST_UPDATED_BY NUMBER(15),
LAST_UPDATE_LOGIN NUMBER(15)
);

