# verify stmt printer

# bug: 
--disable_warnings
drop view if exists v0;
--enable_warnings

# bugfix in 
# order by INT are not allowed in mysql
--error 3592
CREATE OR REPLACE VIEW v0 AS SELECT 57 > ( SELECT 8 ) , 'x' ORDER BY NULL ASC , STDDEV ( ( 0 , 0 ) >= ( 0 , 'x' ) ) OVER ( ORDER BY 9 RANGE 61 PRECEDING ) DESC;
--error 1146
SELECT * FROM V0;

# ORDER BY 2 指向第二个投影项，第二个投影项是常量表达式 3， 要避免返拼成：
# SELECT '0', 3 FROM DUAL ORDER BY 3;
CREATE OR REPLACE VIEW v0 AS SELECT '0', 3 FROM DUAL ORDER BY 2 DESC;
SHOW CREATE VIEW V0;

SELECT * FROM V0;

DROP VIEW v0;

# bug: 
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_info
--disable_metadata
--disable_abort_on_error

--disable_warnings
drop database if exists stmt_db;
create database stmt_db;
use stmt_db;

alter system flush plan cache global;
alter system set plan_cache_evict_interval = 1;
drop table if exists t1;
create table t1(c1 int, c2 int);
--result_format 4
set @a=(SELECT INTERVAL(23, 1, 15, 17, 30, 44, 200));
select ret_code, query_sql from oceanbase.v$ob_sql_audit where query_sql like "%SELECT INTERVAL%" and is_inner_sql = true order by request_time desc limit 1;
select @a;
set @a=(SELECT APPROX_COUNT_DISTINCT(c1) OVER (ORDER BY c2) FROM t1 ORDER BY c1, c2);
select ret_code, query_sql from oceanbase.v$ob_sql_audit where query_sql like "%SELECT APPROX_COUNT_DISTINCT%" and is_inner_sql = true order by request_time desc limit 1;
select @a;
set @a=(select "123" as json);
select ret_code, query_sql from oceanbase.v$ob_sql_audit where query_sql like "%select '123'%" and is_inner_sql = true order by request_time desc limit 1;
select @a from dual;
set names gbk;
set @a = (select '测试' from dual);
select ret_code, query_sql from oceanbase.v$ob_sql_audit where query_sql like "%select '测试'%" and is_inner_sql = true order by request_time desc limit 1;

--error 1253
set @a=(SELECT _utf8mb4'abc' COLLATE utf8mb4_unicode_ci);
select ret_code, query_sql from oceanbase.v$ob_sql_audit where query_sql like "%select _utf8mb4'abc' COLLATE%" and is_inner_sql = true order by request_time desc limit 1;
drop table if exists t1;
drop database if exists stmt_db;

##bug:

use test;

--disable_warnings
drop table if exists t0;
drop view if exists v1;
--enable_warnings

CREATE TABLE t0(c1 varchar(20));

create view v1 as select 1 from t0 where (! ((! ((GREATEST(CAST((concat(t0.c1,'')) >= ((! (1953638379))) AS SIGNED), NULL)) IS TRUE)))) = 1;
select * from v1;

drop table t0;
drop view v1;

##bug:

--disable_warnings
drop table if exists t0;
drop view if exists v1;
--enable_warnings

CREATE TABLE t0(c0 varchar(20), c1 varchar(20));

create view v1 as SELECT * FROM t0 WHERE CAST((((concat(t0.c1,'')) IS TRUE) && ((+ ((CAST(t0.c0 AS SIGNED)) IS NOT TRUE)))) > ((NOT (t0.c0))) AS SIGNED);
select * from v1;

drop table t0;
drop view v1;
