drop table if exists t1;
drop view if exists v2;
create table t2(a varchar(20), b varchar(20));
set sql_quote_show_create=OFF;
set sql_mode='ANSI_QUOTES';
CREATE VIEW `v2` AS 
select `t2`.`a` AS `a`,.`t2`.`b` AS `b` from `t2` where (`t2`.`a` like 'a%' escape '\\') WITH CHECK OPTION;
show create view v2;
View	Create View	character_set_client	collation_connection
v2	CREATE VIEW v2 AS select test.t2.a AS a,test.t2.b AS b from test.t2 where (test.t2.a like 'a%' escape '\\') WITH CHECK OPTION	utf8mb4	utf8mb4_general_ci
drop table t2;
drop view v2;
