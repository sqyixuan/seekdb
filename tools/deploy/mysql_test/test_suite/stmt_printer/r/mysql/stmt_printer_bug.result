drop database if exists stmt_db;
create database stmt_db;
use stmt_db;
alter system flush plan cache global;
alter system set plan_cache_evict_interval = 1;
drop table if exists t1;
create table t1(c1 int, c2 int);
result_format: 4
set @a=(SELECT INTERVAL(23, 1, 15, 17, 30, 44, 200));
select ret_code, query_sql from oceanbase.v$ob_sql_audit where query_sql like "%SELECT INTERVAL%" and is_inner_sql = true order by request_time desc limit 1;
+----------+----------------------------------------------------------+
| ret_code | query_sql                                                |
+----------+----------------------------------------------------------+
|        0 | select (select interval(23,1,15,17,30,44,200)) from dual |
+----------+----------------------------------------------------------+
select @a;
+------+
| @a   |
+------+
|    3 |
+------+
set @a=(SELECT APPROX_COUNT_DISTINCT(c1) OVER (ORDER BY c2) FROM t1 ORDER BY c1, c2);
select ret_code, query_sql from oceanbase.v$ob_sql_audit where query_sql like "%SELECT APPROX_COUNT_DISTINCT%" and is_inner_sql = true order by request_time desc limit 1;
+----------+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| ret_code | query_sql                                                                                                                                                                                                                                  |
+----------+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
|        0 | select (select approx_count_distinct(`stmt_db`.`t1`.`c1`) over( ORDER BY `stmt_db`.`t1`.`c2` ASC  RANGE BETWEEN  UNBOUNDED  PRECEDING  AND  CURRENT ROW ) from `stmt_db`.`t1` order by `stmt_db`.`t1`.`c1`, `stmt_db`.`t1`.`c2`) from dual |
+----------+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
select @a;
+------+
| @a   |
+------+
| NULL |
+------+
set @a=(select "123" as json);
select ret_code, query_sql from oceanbase.v$ob_sql_audit where query_sql like "%select '123'%" and is_inner_sql = true order by request_time desc limit 1;
+----------+-------------------------------------------+
| ret_code | query_sql                                 |
+----------+-------------------------------------------+
|        0 | select (select '123' AS `json`) from dual |
+----------+-------------------------------------------+
select @a from dual;
+------+
| @a   |
+------+
| 123  |
+------+
set names gbk;
set @a = (select '测试' from dual);
select ret_code, query_sql from oceanbase.v$ob_sql_audit where query_sql like "%select '测试'%" and is_inner_sql = true order by request_time desc limit 1;
+----------+------------------------------------+
| ret_code | query_sql                          |
+----------+------------------------------------+
|        0 | select (select '测试') from dual   |
+----------+------------------------------------+

set @a=(SELECT _utf8mb4'abc' COLLATE utf8mb4_unicode_ci);
