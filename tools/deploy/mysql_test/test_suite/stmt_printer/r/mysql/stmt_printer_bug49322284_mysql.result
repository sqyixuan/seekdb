drop table if exists t1;
create table t1(a int, b int);
insert into t1 values (10,20);
create or replace view v as select bin(a), bin(b) from t1;
show create view v;
View	Create View	character_set_client	collation_connection
v	CREATE VIEW `v` AS select bin(`test`.`t1`.`a`) AS `bin(a)`,bin(`test`.`t1`.`b`) AS `bin(b)` from `test`.`t1`	utf8mb4	utf8mb4_general_ci
select * from v;
bin(a)	bin(b)
1010	10100
create or replace view v as select oct(a), oct(b) from t1;
show create view v;
View	Create View	character_set_client	collation_connection
v	CREATE VIEW `v` AS select oct(`test`.`t1`.`a`) AS `oct(a)`,oct(`test`.`t1`.`b`) AS `oct(b)` from `test`.`t1`	utf8mb4	utf8mb4_general_ci
select * from v;
oct(a)	oct(b)
12	24
create or replace view v as select conv(a, 10, 4), conv(b, 10, 8) from t1;
show create view v;
View	Create View	character_set_client	collation_connection
v	CREATE VIEW `v` AS select conv(`test`.`t1`.`a`,10,4) AS `conv(a, 10, 4)`,conv(`test`.`t1`.`b`,10,8) AS `conv(b, 10, 8)` from `test`.`t1`	utf8mb4	utf8mb4_general_ci
select * from v;
conv(a, 10, 4)	conv(b, 10, 8)
22	24
create or replace view v as select conv(a, 8, 10), conv(b, 8, 10) from t1;
show create view v;
View	Create View	character_set_client	collation_connection
v	CREATE VIEW `v` AS select conv(`test`.`t1`.`a`,8,10) AS `conv(a, 8, 10)`,conv(`test`.`t1`.`b`,8,10) AS `conv(b, 8, 10)` from `test`.`t1`	utf8mb4	utf8mb4_general_ci
select * from v;
conv(a, 8, 10)	conv(b, 8, 10)
8	16
create or replace view v as select ntile(1) over (partition by bin(a) order by a) from t1;
show create view v;
View	Create View	character_set_client	collation_connection
v	CREATE VIEW `v` AS select ntile(1) over( PARTITION BY bin(`test`.`t1`.`a`) ORDER BY `test`.`t1`.`a` ASC ) AS `ntile(1) over (partition by bin(a) order by a)` from `test`.`t1`	utf8mb4	utf8mb4_general_ci
select * from v;
ntile(1) over (partition by bin(a) order by a)
1
set @a = 1+(select bin(200) from dual);
select @a from dual;
@a
11001001
create or replace view v as select a+b as c from t1 having c < 5 order by c+1,c;
show create view v;
View	Create View	character_set_client	collation_connection
v	CREATE VIEW `v` AS select (`test`.`t1`.`a` + `test`.`t1`.`b`) AS `c` from `test`.`t1` having (`c` < 5) order by ((`test`.`t1`.`a` + `test`.`t1`.`b`) + 1), 1	utf8mb4	utf8mb4_general_ci
select * from v;
c
drop view v;
drop table t1;
