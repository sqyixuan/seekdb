create table t1 (
`c1` int(11) primary key,
`c2` int(11) NOT NULL,
`a b` char(20) NOT NULL,
`b``c` varchar(20) NOT NULL,
`c'b` date not null,
`d"b` timestamp not null,
`дёӯж–Ү` char(20) not null,
UNIQUE KEY (`c2`)
);
create table t2 (
`c1` int(11) primary key,
`c2` int(11) NOT NULL,
`a b` char(20) NOT NULL,
`b``c` varchar(20) NOT NULL,
`c'b` date not null,
`d"b` timestamp not null,
`дёӯж–Ү` char(20) not null,
KEY (`c2`, `b``c`) 
);
create table `t``` (
`c1` int(11) primary key,
`c2` int(11) NOT NULL,
`a b` varchar(20) NOT NULL,
`b``c` varchar(20) NOT NULL,
`c'b` varchar(20) not null,
`d"b` varchar(20) not null,
`дёӯж–Ү` varchar(20) not null,
KEY (`c2`, `b``c`) 
);
create view v1 as select /*+ leading(A B) */ 'n`b', 'm\'c', "p\"d", 'ANYдёӯж–Ү\'"', A.* from t1 A, t2 B;
create view v2 as select * from `t``` as `m``t``m` where `a b` = 'a b' and `b``c` = 'b`c' and `c'b` = 'c\'b' and `d"b` = 'd"b' and `дёӯж–Ү` = 'дёӯж–Ү';
