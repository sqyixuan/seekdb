#### owner: qiaolinjun.qlj
#### owner group: IMF
#### description: foreign key

--disable_warnings
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
drop table if exists t0;
--enable_warnings

--result_format 4
--enable_sorted_result
--enable_info
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 302, error_code = 200, frequency = 1;
connection default;

## 非分区表，查询主表，batch优化查询
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, foreign key (c2) references t1(c1));
insert into t1 values (1,1),(2,2),(3,3);

insert into t2 values (1,1),(2,1),(3,1),(4,2),(5,1),(6,1),(7,1),(8,1),(9,2),(10,1);
select * from t2;
update t2 set c2 = c2 + 1;
select * from t2;

update t2 set c2 = c2 - 1;
select * from t2;

--error 1452
update t2 set c2 = c2 + 2;
delete from t2;

--error 1452
insert into t2 values (1,1),(2,1),(3,6),(4,1),(5,1);
select * from t2;

drop table t2;
drop table t1;

## 分区表场景下，查询主表，batch优化查询
create table t1 (c1 int primary key, c2 int) partition by hash(c1) partitions 4;
create table t2 (c1 int primary key, c2 int, foreign key (c2) references t1(c1));
insert into t1 values (1,1),(2,2),(3,3);

insert into t2 values (1,1),(2,1),(3,1),(4,2),(5,1),(6,1),(7,1),(8,1),(9,2),(10,1);
select * from t2;
update t2 set c2 = c2 + 1;
select * from t2;

update t2 set c2 = c2 - 1;
select * from t2;

--error 1452
update t2 set c2 = c2 + 2;
delete from t2;

--error 1452
insert into t2 values (1,1),(2,1),(3,6),(4,1),(5,1);
select * from t2;

drop table t2;
drop table t1;

## 非分区表，查询索引表，batch优化查询
create table t1 (c1 int unique, c2 int);
create table t2 (c1 int primary key, c2 int, foreign key (c2) references t1(c1));
insert into t1 values (1,1),(2,2),(3,3);

insert into t2 values (1,1),(2,1),(3,1),(4,2),(5,1),(6,1),(7,1),(8,1),(9,2),(10,1);
select * from t2;
update t2 set c2 = c2 + 1;
select * from t2;

update t2 set c2 = c2 - 1;
select * from t2;

--error 1452
update t2 set c2 = c2 + 2;
delete from t2;

--error 1452
insert into t2 values (1,1),(2,1),(3,6),(4,1),(5,1);
select * from t2;

drop table t2;
drop table t1;

## 分区表，查询索引表，batch优化查询
create table t1 (c1 int unique, c2 int) partition by hash(c1) partitions 4;
create table t2 (c1 int primary key, c2 int, foreign key (c2) references t1(c1));
insert into t1 values (1,1),(2,2),(3,3);

insert into t2 values (1,1),(2,1),(3,1),(4,2),(5,1),(6,1),(7,1),(8,1),(9,2),(10,1);
select * from t2;
update t2 set c2 = c2 + 1;
select * from t2;

update t2 set c2 = c2 - 1;
select * from t2;

--error 1452
update t2 set c2 = c2 + 2;
delete from t2;

--error 1452
insert into t2 values (1,1),(2,1),(3,6),(4,1),(5,1);
select * from t2;

drop table t2;
drop table t1;

## 子表上有多个外键参数，batch优化查询
create table t0 (c1 int primary key, c2 int);
create table t1 (c1 int unique, c2 int) partition by hash(c1) partitions 4;
create table t2 (c0 int, c1 int, c2 int, foreign key(c1) references t0(c1), foreign key(c2) references t1(c1));
insert into t0 values (1,1),(2,2),(3,3);
insert into t1 values (1,1),(2,2),(3,3);

select * from t0;
select * from t1;

insert into t2 values (1,1,1),(2,1,1),(3,1,1),(4,2,2),(5,1,1),(6,1,1),(7,1,1),(8,1,1),(9,2,2),(10,1,1);
select * from t2;
update t2 set c1 = c1 +1 ,c2 = c2 + 1;
select * from t2;

update t2 set c1 = c1 - 1, c2 = c2 - 1;
select * from t2;

--error 1452
update t2 set c1 = c1 + 2, c2 = c2 + 2;
delete from t2;

--error 1452
insert into t2 values (1,1,1),(2,1,1),(3,6,6),(4,1,1),(5,1,1);
select * from t2;

drop table t2;
drop table t1;
drop table t0;

## 外键自引用，batch优化查询
create table t1 (c1 int primary key, c2 int, foreign key(c2) references t1(c1));

insert into t1 values (1,1),(2,1),(3,1),(4,1),(5,2),(6,1),(7,2),(8,1),(9,2),(10,2),(11,2);
select * from t1;

update t1 set c2 = c2 + 1;
select * from t1;
--error 1452
update t1 set c2 = c2 + 10;
update t1 set c1 = c1 + 20 where c1 = 1;
select * from t1;
--error 1451
update t1 set c1 = c1 + 20 where c1 = 2;

drop table t1;

connection conn_admin;
alter system set_tp tp_no = 302, error_code = 0, frequency = 1;
connection default;
