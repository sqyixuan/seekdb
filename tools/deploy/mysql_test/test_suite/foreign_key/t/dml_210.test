#### owner: yuchen.wyc
#### owner group: sql2
#### description: foreign key

--disable_warnings

--source mysql_test/include/load_zone_name.inc

# 以下为非分区表测试用例

set foreign_key_checks=on;
drop table if exists t1113, t1112, t1111, t111, t12, t11, t1;
--disable_query_log
eval create table t1(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b));
eval create table t11(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b),
                      constraint foreign key (a, b) references t1 (a, b) on update CASCADE on delete CASCADE);
eval create table t12(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b),
                      constraint foreign key (a, b) references t1 (a, b) on update CASCADE on delete CASCADE);
eval create table t111(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b),
                       constraint foreign key (a, b) references t11 (a, b) on update CASCADE on delete CASCADE);
eval create table t1111(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b),
                        constraint foreign key (a, b) references t111 (a, b) on update CASCADE on delete CASCADE);
eval create table t1112(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b),
                        constraint foreign key (a, b) references t111 (a, b) on update CASCADE on delete CASCADE);
eval create table t1113(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b),
                        constraint foreign key (a, b) references t111 (a, b) on update CASCADE on delete CASCADE);
--enable_query_log

sleep 3;

