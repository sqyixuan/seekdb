# 回归主表和索引表数据不一致问题

## 外键自引用表

### 外键自引用表（1个外键约束、2行数据，第2行引用第1行）
### 级联更新：报错
### 级联报错：成功
drop table if exists t1;
create table t1 (
  a int not null,
  b int,
  primary key (a),
  foreign key fk1 (b) references t1 (a) on update cascade on delete cascade
);
insert into t1 values (1, null);
insert into t1 values (11, 1);
select * from t1;

### 成功（第2行被级联删除1次）
delete from t1 where a = 1;
select * from t1;


### 外键自引用表（2个外键约束、4行数据，第3行引用第1、2行，第4行自引用）
### 级联更新：报错
### 级联报错：成功
drop table if exists t1;
create table t1 (
  a int not null,
  b int,
  c int,
  primary key (a),
  foreign key fk1 (b) references t1 (a) on update cascade on delete cascade,
  foreign key fk2 (c) references t1 (a) on update cascade on delete cascade
);
insert into t1 values (1, null, null);
insert into t1 values (2, null, null);
insert into t1 values (3, 1, 2);
insert into t1 values (4, 4, 4);
select * from t1;

--error ER_ROW_IS_REFERENCED_2
update t1 set a = a + 100 where a < 3;
--error ER_ROW_IS_REFERENCED_2
update t1 set a = a + 100 where a = 4;
### 成功（第3行被级联删除2次）
delete from t1 where a < 3;

delete from t1 where a = 4;
select * from t1;

## 两张表+全局索引

drop table if exists t2;
drop table if exists t1;
create table t1 (
  a int not null,
  b int,
  c int,
  primary key (a)
);
create table t2 (
  a int not null,
  b int,
  c int,
  primary key (a),
  foreign key fk1 (b) references t1 (a) on update cascade,
  foreign key fk2 (c) references t1 (a) on update cascade
);
create index t2_b_c on t2 (b, c) global;

insert into t1 values (1, null, null);
insert into t1 values (2, null, null);
insert into t2 values (3, 1, 2);
update t1 set a = a + 100 where a < 3;
select * from t1;
select * from t2;
select * from t2 where a = 1;
select * from t2 where b = 1;
select * from t2 where a = 101;
select * from t2 where b = 101;

## 两张表+本地索引

drop table if exists t2;
drop table if exists t1;
create table t1 (
  a int not null,
  b int,
  c int,
  primary key (a)
);
create table t2 (
  a int not null,
  b int,
  c int,
  primary key (a),
  foreign key fk1 (b) references t1 (a) on update cascade,
  foreign key fk2 (c) references t1 (a) on update cascade
);
create index t2_b_c on t2 (b, c) local;

insert into t1 values (1, null, null);
insert into t1 values (2, null, null);
insert into t2 values (3, 1, 2);
update t1 set a = a + 100 where a < 3;
select * from t1;
select * from t2;
select * from t2 where a = 1;
select * from t2 where b = 1;
select * from t2 where a = 101;
select * from t2 where b = 101;

## 清理

drop table if exists t2;
drop table if exists t1;

