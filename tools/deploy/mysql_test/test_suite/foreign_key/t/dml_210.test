# 以下测试自引用行(非分区+全局索引、分区+全局索引、分区+局部索引)
# 顺便测binlog_row_image的问题：
# 在这个问题修复前，下面的dml操作有很多都报4016。

set foreign_key_checks=on;
drop table if exists t2, t3, t4;
create table t2(pk int, a int, b int, c int, d int, primary key (a), unique key uk_a_b (a, b),
                constraint foreign key (c, d) references t2 (a, b) on update CASCADE on delete CASCADE);
create table t3(pk int, a int, b int, c int, d int, primary key (a), unique key uk_a_b (a, b),
                constraint foreign key (c, d) references t3 (a, b) on update CASCADE on delete CASCADE)
               partition by hash(a) partitions 7;
create table t4(pk int, a int, b int, c int, d int, primary key (a), unique key uk_a_b (a, b) local,
                constraint foreign key (c, d) references t4 (a, b) on update CASCADE on delete CASCADE)
               partition by hash(a) partitions 7;

sleep 3;

--echo # binlog_row_image是不常用的测试点，这里不保存原始设置，后面直接恢复为默认值FULL。

SET session binlog_row_image = 'MINIMAL';

insert into t2 values (10, 11, 12, 11, 12), (20, 21, 22, 21, 22);
insert into t2 values (30, 31, 32, 11, 12), (40, 41, 42, 21, 22);
select * from t2 order by pk;
--error ER_ROW_IS_REFERENCED_2
update t2 set a = a * 10, b = b * 10 where pk < 30;
select * from t2 order by pk;

delete from t2 where pk < 20;
select * from t2 order by pk;

insert into t3 values (10, 11, 12, 11, 12), (20, 21, 22, 21, 22);
insert into t3 values (30, 31, 32, 11, 12), (40, 41, 42, 21, 22);
select * from t3 order by pk;
--error ER_ROW_IS_REFERENCED_2
update t3 set a = a * 10, b = b * 10 where pk < 30;
select * from t3 order by pk;

delete from t3 where pk < 20;
select * from t3 order by pk;

insert into t4 values (10, 11, 12, 11, 12), (20, 21, 22, 21, 22);
insert into t4 values (30, 31, 32, 11, 12), (40, 41, 42, 21, 22);
select * from t4 order by pk;
--error ER_ROW_IS_REFERENCED_2
update t4 set a = a * 10, b = b * 10 where pk < 30;
select * from t4 order by pk;

delete from t4 where pk < 20;
select * from t4 order by pk;

SET session binlog_row_image = 'FULL';

drop table if exists t2, t3, t4;

# 测试RESTRICT / NO ACTION选项.

set foreign_key_checks=on;
drop table if exists t2;
create table t2(pk int, a int, b int, c int, d int, primary key (a), unique key uk_a_b (a, b),
                constraint foreign key (c, d) references t2 (a, b) on update NO ACTION on delete RESTRICT)
               partition by hash(a) partitions 7;

sleep 3;

insert into t2 values (10, 11, 12, 11, 12), (20, 21, 22, 21, 22);
insert into t2 values (30, 31, 32, 11, 12), (40, 41, 42, 21, 22);
select * from t2 order by pk;
--error ER_ROW_IS_REFERENCED_2
update t2 set a = a * 10, b = b * 10 where pk < 30;
select * from t2 order by pk;
--error ER_ROW_IS_REFERENCED_2
delete from t2 where pk < 20;
select * from t2 order by pk;

drop table if exists t2;

