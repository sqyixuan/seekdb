#### owner: qiaolinjun.qlj
#### owner group: IMF
#### description: foreign key
# tags: dml,das


--disable_warnings
drop table if exists t17,tf17;
--enable_warnings

create table t17(a int, b int, c int, d int, primary key (a)) partition by hash(a) partitions 3;
create table tf17(a int, b int, c int, d int, primary key (a), foreign key (a) references t17 (a)) partition by hash(a) partitions 3;


insert into t17 values ( 9, 9, 9, 9), (10,10,10,10), (11,11,11,11), (12,12,12,12),
                       (13,13,13,13), (14,14,14,14), (15,15,15,15), (16,16,16,16),
                       (17,17,17,17), (18,18,18,18), (19,19,19,19), (20,20,20,20),
                       (21,21,21,21), (22,22,22,22), (23,23,23,23), (24,24,24,24),
                       (25,25,25,25), (26,26,26,26), (27,27,27,27), (28,28,28,28);
insert into tf17 values ( 9, 9, 9, 9), (10,10,10,10), (11,11,11,11), (12,NULL,12,12),
                        (13,13,13,13), (14,14,14,14), (15,15,15,15), (16,NULL,16,16),
                        (17,17,17,17), (18,18,18,18), (19,19,19,19), (20,NULL,20,20),
                        (21,21,21,21), (22,22,22,22), (23,23,23,23), (24,NULL,24,24),
                        (25,25,25,25), (26,26,26,26), (27,27,27,27), (28,NULL,28,28);


update tf17 partition(p0) as C, tf17 as P set C.d = C.d + 100 where C.a = P.a;
select * from tf17;
rollback;
update /*+NO_REWRITE*/tf17 partition(p0) as C, tf17 as P set C.d = C.d + 100 where C.a = P.a;
select * from tf17;
rollback;

update tf17 partition(p0) as C1, t17 as P1 set C1.d = C1.d + 1000 where C1.a = P1.a;
select * from tf17;
rollback;
update /*+NO_REWRITE*/tf17 partition(p1,p2) as C1, tf17 partition(p1,p2) as P1 set C1.d = C1.d + 1000 where C1.a = P1.a;
select * from tf17;
rollback;


update tf17 partition(p0) as C1, t17 as P1 set C1.d = C1.d + 1000 where C1.a = P1.a;
select * from tf17;
rollback;
update /*+NO_REWRITE*/tf17 partition(p0) as C1, t17 as P1 set C1.d = C1.d + 1000 where C1.a = P1.a;
select * from tf17;
rollback;

update tf17 partition(p0) A set A.b = A.b + 10 where exists (select 1 from tf17 B where A.a = B.a and (B.b = A.b OR B.c = B.d OR B.d > 15)) and A.d < 25;
select * from t17;

drop table tf17;
drop table t17;