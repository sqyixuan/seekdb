#### owner: qiaolinjun.qlj
#### owner group: IMF
#### description: foreign key

--disable_warnings
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings


##外键正交join算子，底下有表达式复用
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 302, error_code = 20, frequency = 1;
connection default;
alter system set _rowsets_enabled = false;

create table t1 (c1 varchar(20) primary key, c2 varchar(20), c3 int unique);
create table t2 (c1 varchar(20), c2 varchar(20), c3 int unique);

create table t3 (c1 int, foreign key(c1) references t1(c3));
create table t4 (c1 int, foreign key(c1) references t2(c3));

insert into t1 values ('1', '1', '1'),('2', '2', '2'),('3', '3', '3'),('4', '4', '4'),('5', '5', '5');
insert into t2 values ('1', '1', '1'),('1', '1', '6'),('1', '1', '7'),('1', '1', '8'),('1', '1', '9'),('1', '1', '10'),('1', '1', '11'),('1', '1', '12'), ('2', '2', '2'),('3', '3', '3'),('4', '4', '4'),('5', '5', '5');

insert into t2 values ('1', '1', 13),('1', '1', 14),('1', '1', 15),('1', '1', 16),('1', '1', 17),('1', '1', 18),('1', '1', 19),('1', '1', 20);
insert into t2 values ('2', '1', 21),('2', '2', 22),('2', '2', 23),('2', '2', 24),('2', '2', 25),('2', '1', 26),('2', '1', 27),('2', '1', 28);
insert into t2 values ('2', '1', 29),('2', '2', 30),('2', '2', 31),('2', '2', 32),('2', '2', 33),('2', '1', 34),('2', '1', 35),('2', '1', 36);

##explain DELETE /*+use_merge(t1, t2) */ t1,t2 FROM t1,t2 WHERE t1.c1=t2.c2;
DELETE /*+use_merge(t1, t2) */ t1,t2 FROM t1,t2 WHERE t2.c1=t2.c1;

##explain DELETE /*+use_merge(t1, t2) */ t1,t2 FROM t1,t2 WHERE t1.c1=t2.c2;
DELETE /*+use_nl(t1, t2) */ t1,t2 FROM t1,t2 WHERE t2.c1=t2.c1;

connection conn_admin;
alter system set_tp tp_no = 302, error_code = 20, frequency = 0;
connection default;
alter system set _rowsets_enabled = true;

drop table t4;
drop table t3;
drop table t2;
drop table t1;