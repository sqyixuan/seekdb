#### owner: yuanfangzhou.yfz
#### owner group: IMF
#### description: allow for a float column to reference a unsigned float column, or vice versa

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

# case 1: parent signed, child unsigned
create table t1(c1 float primary key);
create table t2(c1 float unsigned, foreign key(c1) references t1(c1));
insert into t1 values(2), (-2), (3);
insert into t2 values(2), (2), (3);
--error ER_WARN_DATA_OUT_OF_RANGE
insert into t2 values(-1);
select * from t1;
select * from t2;
drop table t1, t2;

create table t1(c1 double primary key);
create table t2(c1 double unsigned, foreign key(c1) references t1(c1));
insert into t1 values(2), (-2), (3);
insert into t2 values(2), (2), (3);
--error ER_WARN_DATA_OUT_OF_RANGE
insert into t2 values(-1);
select * from t1;
select * from t2;
drop table t1, t2;

# case 2: parent unsigned, child signed
create table t1(c1 float unsigned primary key);
create table t2(c1 float, foreign key(c1) references t1(c1));
--error ER_WARN_DATA_OUT_OF_RANGE
insert into t1 values(-1);
insert into t1 values(2), (3);
insert into t2 values(2), (2), (3);
--error ER_NO_REFERENCED_ROW_2
insert into t2 values(-2);
select * from t1;
select * from t2;
drop table t1, t2;

create table t1(c1 double unsigned primary key);
create table t2(c1 double, foreign key(c1) references t1(c1));
--error ER_WARN_DATA_OUT_OF_RANGE
insert into t1 values(-1);
insert into t1 values(2), (3);
insert into t2 values(2), (2), (3);
--error ER_NO_REFERENCED_ROW_2
insert into t2 values(-1);
select * from t1;
select * from t2;
drop table t1, t2;

# case 3: parent signed, child unsigned, update cascade&delete cascade
create table t1(c1 float primary key);
create table t2(c1 float unsigned, foreign key(c1) references t1(c1) on update cascade on delete cascade);
insert into t1 values(2), (-2), (3);
insert into t2 values(2), (2), (3);
--error ER_WARN_DATA_OUT_OF_RANGE
update t1 set t1.c1 = -5 where t1.c1 = 2;
update t1 set t1.c1 = 1 where t1.c1 = 2;
select * from t1;
select * from t2;
delete from t1 where t1.c1 = -2;
delete from t1 where t1.c1 = 1;
select * from t1;
select * from t2;
drop table t1, t2;


create table t1(c1 double primary key);
create table t2(c1 double unsigned, foreign key(c1) references t1(c1) on update cascade on delete cascade);
insert into t1 values(2), (-2), (3);
insert into t2 values(2), (2), (3);
--error ER_WARN_DATA_OUT_OF_RANGE
update t1 set t1.c1 = -5 where t1.c1 = 2;
update t1 set t1.c1 = 1 where t1.c1 = 2;
select * from t1;
select * from t2;
delete from t1 where t1.c1 = -2;
delete from t1 where t1.c1 = 1;
select * from t1;
select * from t2;
drop table t1, t2;

# case 4: parent&child signed, cannot alter table modify parent signed -> unsigned
create table t1(c1 float primary key);
create table t2(c1 float, foreign key(c1) references t1(c1));
--error 5320
alter table t1 modify column c1 float unsigned;
drop table t1, t2;

create table t1(c1 double primary key);
create table t2(c1 double, foreign key(c1) references t1(c1));
--error 5320
alter table t1 modify column c1 double unsigned;
drop table t1, t2;

# case 5: float-double is incompatible;
create table t1(c1 float primary key);
--error ER_CANNOT_ADD_FOREIGN
create table t2(c1 double, foreign key(c1) references t1(c1));
--error ER_CANNOT_ADD_FOREIGN
create table t2(c1 double unsigned, foreign key(c1) references t1(c1));
drop table t1;

create table t1(c1 double primary key);
--error ER_CANNOT_ADD_FOREIGN
create table t2(c1 float, foreign key(c1) references t1(c1));
--error ER_CANNOT_ADD_FOREIGN
create table t2(c1 float unsigned, foreign key(c1) references t1(c1));
drop table t1;