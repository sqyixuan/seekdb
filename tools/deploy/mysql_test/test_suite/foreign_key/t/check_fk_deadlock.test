# owner: yangyifei.yyf
# owner group: transaction
# description: this case is used to test whether foreign key constraint check can handle deadlock during checking

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
set GLOBAL ob_query_timeout = 1000000000000;
--enable_query_log

connect (conn0, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, oceanbase, $OBMYSQL_PORT);
connect (conn1, $OBMYSQL_MS0, $OBMYSQL_USR, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
connect (conn2, $OBMYSQL_MS0, $OBMYSQL_USR, $OBMYSQL_PWD, test, $OBMYSQL_PORT);

connection conn1;
--disable_warnings
drop table if exists child;
drop table if exists parent;
--enable_warnings

### 1. check foreign key constratint which has index in the child table
# create parent table and child table with index
create table parent(c1 int primary key, c2 int);
create table child(c1 int primary key, c2 int, foreign key(c2) references parent(c1));
insert into parent values(1, 1);
insert into child values(1, 1);

## 1.1 common deadlock when check row in memtable
# start transaction and lock the rows in parent table
begin;
select * from parent for update;

# start transaction and lock the rows in child table
connection conn2;
begin;
select * from child for update;

# try to delete the row in parent table
connection conn1;
send delete from parent where c1 = 1;

# try to insert a row in child table, which referneces the row will be deleted in parent table
connection conn2;
send insert into child values(2, 1);
--error 1213
reap;
rollback;

connection conn1;
--error 1451
reap;
rollback;

# check result
select * from parent;
select * from child;

## 1.2 common deadlock when check row in sstable
# start transaction and lock the rows in parent table
begin;
select * from parent for update;

# start transaction and lock the rows in child table
connection conn2;
begin;
select * from child for update;

# dump uncommiitted transaction to sstable
connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

# try to delete the row in parent table
connection conn1;
send delete from parent where c1 = 1;

# dump uncommiitted transaction to sstable
connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

# try to insert a row in child table,
# which referneces the row will be deleted in parent table
connection conn2;
send insert into child values(2, 1);
--error 1213
reap;
rollback;

connection conn1;
--error 1451
reap;
rollback;

# check result
select * from parent;
select * from child;

### 2. check foreign key constratint which has no index in the child table
# create child table without index
drop table child;
create table child(c1 int, c2 int, foreign key(c2) references parent(c1));
insert into child values(1, 1);

## 2.1 common deadlock when check row in memtable
# start transaction and lock the rows in parent table
begin;
select * from parent where c1 = 1 for update;

# start transaction and lock the rows in child table
connection conn2;
begin;
select * from child where c2 = 1 for update;

# try to delete the row in parent table
connection conn1;
send delete from parent where c1 = 1;

# try to insert a row in child table, which referneces the row will be deleted in parent table
connection conn2;
send insert into child values(2, 1);
--error 1213
reap;
rollback;

connection conn1;
--error 1451
reap;
rollback;

# check result
select * from parent;
select * from child;

## 2.2 common deadlock when check row in sstable
# start transaction and lock the rows in parent table
begin;
select * from parent for update;

# start transaction and lock the rows in child table
connection conn2;
begin;
select * from child for update;

# dump uncommiitted transaction to sstable
connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

# try to delete the row in parent table
connection conn1;
send delete from parent where c1 = 1;

# dump uncommiitted transaction to sstable
connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

# try to insert a row in child table,
# which referneces the row will be deleted in parent table
connection conn2;
send insert into child values(2, 1);
--error 1213
reap;
rollback;

connection conn1;
--error 1451
reap;
rollback;

# check result
select * from parent;
select * from child;

# test done, drop tables
drop table child;
drop table parent;
