--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: dachuan.sdc
#### owner group: sql2
#### description: foreign key ddl
#### tags: ddl

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
connection default;
--disable_warnings
drop database if exists xiaofeng_db;
create database xiaofeng_db;
use xiaofeng_db;
--enable_warnings
set @@recyclebin = on;

create table t1(c1 int primary key);
create table tr2(c1 int, constraint cons_name foreign key(c1) references t1(c1));
let $connection_id = query_get_value(select connection_id(), connection_id(), 1);


connection obsys;
let $tenant_id = query_get_value(select effective_tenant_id() as tenant_id, tenant_id, 1);
let $database_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'xiaofeng_db', database_id, 1);
let $tr2_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'tr2' and database_id = $database_id, table_id, 1);

connection default;
drop table tr2;
connection obsys;

let $tr2_objname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where table_id = $tr2_id, object_name, 1);

connection default;
--disable_query_log
eval flashback table $tr2_objname to before drop;
--enable_query_log

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table tr2;
drop database xiaofeng_db;
