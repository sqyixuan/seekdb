--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: dachuan.sdc
#### owner group: sql2
#### description: foreign key ddl
#### tags: ddl

--disable_warnings
drop database if exists xiaofeng_db;
create database xiaofeng_db;
use xiaofeng_db;
--enable_warnings

--disable_warnings
drop database if exists xiaofeng_db2;
create database xiaofeng_db2;
--enable_warnings

set recyclebin = on;

# 测试建表时建外键的几种语法
create table t1(c1 int primary key);
# 创建外键时，不显式指定外键约束名 cons_name
create table t2(c1 int, foreign key(c1) references t1(c1));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
create table t2(c1 int, foreign key ind_name(c1) references t1(c1));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
create table t2(c1 int, constraint foreign key(c1) references t1(c1));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
# 创建外键时，显式指定外键约束名 cons_name
create table t2(c1 int, constraint cons_name foreign key(c1) references t1(c1));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
create table t2(c1 int, constraint cons_name foreign key ind_name(c1) references t1(c1));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
drop table t1;

# 测试建表时创建外键约束，加入 match 子句
# MySQL 5.6 目前尚未实现该功能，仅支持语法，相当于缺省
create table t1(c1 int, c2 int, c3 int, primary key(c1), unique key(c1, c2));
create table t2(c1 int, c2 int, foreign key(c1, c2) references t1(c1, c2) match simple);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
create table t2(c1 int, c2 int, foreign key(c1, c2) references t1(c1, c2) match full);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
create table t2(c1 int, foreign key(c1) references t1(c1));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;

# 测试建表时创建外键约束，加入 on delete 子句
create table t2(c1 int, foreign key(c1) references t1(c1));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
create table t2(c1 int, constraint cons_name foreign key(c1) references t1(c1) on delete restrict);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
create table t2(c1 int, constraint cons_name foreign key(c1) references t1(c1) on delete cascade);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
create table t2(c1 int, constraint cons_name foreign key(c1) references t1(c1) on delete set null);
drop table t2;
create table t2(c1 int, constraint cons_name foreign key(c1) references t1(c1) on delete no action);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;

# 测试建表时创建外键约束，加入 on update 子句
create table t2(c1 int, constraint cons_name foreign key(c1) references t1(c1));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
create table t2(c1 int, constraint cons_name foreign key(c1) references t1(c1) on update restrict);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
create table t2(c1 int, constraint cons_name foreign key(c1) references t1(c1) on update cascade);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
create table t2(c1 int, constraint cons_name foreign key(c1) references t1(c1) on update set null);
drop table t2;
create table t2(c1 int, constraint cons_name foreign key(c1) references t1(c1) on update no action);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;

# 测试建表时创建外键约束，同时加入 on update 子句和 on delete 子句
create table t2(c1 int, constraint cons_name foreign key(c1) references t1(c1) on update set null on delete cascade);
drop table t2;
drop table t1;

# 测试 create table like 的行为，应该不复制外键信息
create table t1(c1 int primary key);
create table t2(c1 int, constraint cons_name foreign key(c1) references t1(c1));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
create table t3 like t1;
create table t4 like t2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t4;
--error 3730
drop table t1;
drop table t3;
drop table t4;
drop table t2, t1;

# 建外键时应该执行失败的几种情况
# 测试建表时创建外键约束，约束名是保留关键字的情况，应该失败
create table t1(c1 int, c2 int, c3 char, primary key(c1), index c2_ind(c2));
--error 1064
create table t2(c1 int, t1_c1 int, constraint table foreign key(t1_c1) references t1(c1));
# 测试建表时创建外键约束，约束名与已有约束名相同的情况，应该失败
create table t2(c1 int, t1_c1 int, constraint fk_1 foreign key(t1_c1) references t1(c1));
--error 1022
create table t3(c1 int, t1_c1 int, constraint fk_1 foreign key(t1_c1) references t1(c1));
# 测试建表时创建外键约束，被引用索引不满足主键或者唯一约束，应该失败
--error 1215
create table t3(c1 char, foreign key(c1) references t1(c3));
# 测试在生成列上加索引，应该失败
create table t3(first_name VARCHAR(50) NOT NULL, last_name VARCHAR(50) NOT NULL, fullname varchar(101) GENERATED ALWAYS AS (CONCAT(first_name,' ',last_name)));
create unique index ind on t3(fullname);
create table t4(first_name VARCHAR(50) NOT NULL, last_name VARCHAR(50) NOT NULL, fullname varchar(101) GENERATED ALWAYS AS (CONCAT(first_name,' ',last_name)), constraint cons_name foreign key(fullname) references t3(fullname));
drop table t4;
create table t4(fullname varchar(101), constraint cons_name foreign key(fullname) references t3(fullname));
drop table t4;
drop table t3;

# 测试 drop table 时，有外键约束的情形
# drop 子表，会同时删除外键约束
drop table t2;
# drop 受外键约束的父表，应该失败
create table t2(c1 int, t1_c1 int, constraint fk_1 foreign key(t1_c1) references t1(c1));
--error 3730
drop table t1;

# 用一个 drop 语句连续先后删除有外键约束关系的父表和子表
# mysql 5.7 会失败，有报错信息，父表无法被删除，但子表被删除
show tables;
# mysql 8.0 开始不是这个奇怪的行为了，ob 与 mysql 8.0 行为兼容
#--error 3730
#drop table t1, t2;
drop table t2;
show tables;
# 用一个 drop 语句连续先后删除有外键约束关系的子表和父表
create table t2(c1 int, t1_c1 int, constraint fk_1 foreign key(t1_c1) references t1(c1));
drop table t1, t2;
show tables;

# 测试 truncate table 时，有外键约束的情形
create table t1(c1 int, c2 int, unique key(c1, c2));
create table t2(c1 int, c2 int, index ind(c1, c2), constraint cons_name foreign key(c1, c2) references t1(c1, c2));
# truncate 有外键约束关系的子表，会保留外键约束
truncate table t2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
# truncate 有外键约束关系的父表，会失败
--error 1701
truncate table t1;
drop table t2, t1;

# 测试 alter table drop column 时，有外键约束的情形
create table t1(c1 int primary key, c2 int);
create table t2(c1 int, c2 int, constraint cons_name foreign key(c1) references t1(c1));
# 注意：这里的显示给用户的错误信息和 mysql 不兼容
# 原因是 mysql 的报错信息是 “建外键同时创建的索引无法被删除”，但 OB 当前版本在创建外键时不会默认为外键列创建索引，因此报错信息调整为与索引无关而仅与外键相关的内容
--error 5320
alter table t2 drop column c1;

# 测试 alter table change column 时，有外键约束的情形
# 修改受外键约束的列的列名，可以执行成功
alter table t2 change column c1 c11 int;
# 修改受外键约束的列的类型，会失败
# 注意：这里的显示给用户的错误信息和 mysql 不兼容
--error 5320
alter table t2 change column c11 c11 char;

# 测试 alter table modify column 时，有外键约束的情形
# 什么都不修改，可以执行成功
alter table t2 modify c11 int;
# 修改受外键约束的类型，会失败
# 注意：这里的显示给用户的错误信息和 mysql 不兼容
--error 5320
alter table t2 modify c11 char;

# 测试 alter table alter column 时，有外键约束的情形
alter table t2 alter c11 drop default;
alter table t2 alter c11 set default 0;

# 测试 alter table drop foreign key 的行为
alter table t2 drop foreign key cons_name;
drop table t2, t1;

# 测试 drop index ind_name on tbl_name 时，有外键约束的情形
# 可以在外键列上加索引，也可以删除，但是删除的限制是要在外键列上剩至少一个索引
create table t1(c1 int primary key, c2 int unique key);
create table t2(c1 int, c2 int, constraint cons_name foreign key(c1) references t1(c1), unique index ind1(c1), unique index ind2(c1));
drop index ind1 on t2;
# 注意：这里的显示给用户的错误信息和 mysql 不兼容
--error 5320
drop index ind2 on t2;
alter table t2 rename index ind2 to new_ind2;
create index ind3 on t2(c1);
# mysql 没有 alter index idx VISIBLE 这种语法（ob 自己的语法）
--error 5320
alter table t2 alter index ind3 VISIBLE;
drop index new_ind2 on t2;
drop table t2, t1;

# 测试 alter table tbl_name drop index ind_name 时，有外键约束的情形
create table t1(c1 int primary key, c2 int unique key);
create table t2(c1 int, c2 int, constraint cons_name foreign key(c1) references t1(c1), unique index ind1(c1), unique index ind2(c1));
alter table t2 drop index ind1;
# 注意：这里的显示给用户的错误信息和 mysql 不兼容
--error 5320
alter table t2 drop index ind2;
alter table t2 add index ind3(c1);
alter table t2 drop index ind2;
drop table t2, t1;

# 测试 drop index 时，index 包含多列，且同时有外键约束的情形
create table t1(c1 int, c2 int, unique key(c1, c2));
create table t2(c1 int, c2 int, index ind1(c1, c2), index ind2(c1, c2), constraint cons_name foreign key(c1, c2) references t1(c1, c2));
drop index ind1 on t2;
# 注意：这里的显示给用户的错误信息和 mysql 不兼容
--error 5320
drop index ind2 on t2;
drop table t2, t1;

# 测试 rename table 的行为，应该不受外键约束
create table t1(c1 int primary key);
create table t2(c1 int, foreign key(c1) references t1(c1));
rename table t1 to t3;
rename table t2 to t4;
drop table t4, t3;

# 测试自引用（父子表为同一张表）
create table t1(c1 int, c2 int, unique key(c1), foreign key(c2) references t1(c1));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

# 补充测试
# 建表时创建外键约束，约束名与已有约束名相同的情况，应该失败
create table t1(c1 int, c2 int, c3 char, primary key(c1), index c2_ind(c2));
create table t2(c1 int, t1_c1 int, constraint fk_1 foreign key(t1_c1) references t1(c1));
--error 1022
create table t3(c1 int, t1_c1 int, constraint fk_1 foreign key(t1_c1) references t1(c1));
drop table t2;
create table t3(c1 int, t1_c1 int, constraint fk_1 foreign key(t1_c1) references t1(c1));
drop table t3, t1;
# 建表时创建外键约束，约束名与已有约束名相同的情况，在 alter table drop foreign key 之后，应该可以成功
create table t1(c1 int, c2 int, c3 char, primary key(c1), index c2_ind(c2));
create table t2(c1 int, t1_c1 int, constraint fk_1 foreign key(t1_c1) references t1(c1));
alter table t2 drop foreign key fk_1;
create table t3(c1 int, t1_c1 int, constraint fk_1 foreign key(t1_c1) references t1(c1));
drop table t3, t2, t1;
# 建表时创建外键约束，约束名与已有约束名相同的情况，测试用一句 alter table 同时 drop 多个 foreign key，应该可以成功
create table t1(c1 int primary key);
create table t2(c1 int, constraint cons_name foreign key fk_1(c1) references t1(c1), constraint cons_name2 foreign key fk_1(c1) references t1(c1));
--error 1022
create table t3(c1 int, t1_c1 int, constraint cons_name foreign key(t1_c1) references t1(c1));
--error 1022
create table t3(c1 int, t1_c1 int, constraint cons_name2 foreign key(t1_c1) references t1(c1));
alter table t2 drop foreign key cons_name, drop foreign key cons_name2;
create table t3(c1 int, t1_c1 int, constraint cons_name foreign key(t1_c1) references t1(c1));
drop table t3;
create table t3(c1 int, t1_c1 int, constraint cons_name2 foreign key(t1_c1) references t1(c1));
drop table t3, t2, t1;
# 跨 db 建同名外键名测试，不同库间允许出现同名外键约束名，应该可以成功
create table t1(c1 int primary key);
create table t2(c1 int, constraint cons_name foreign key fk_1(c1) references t1(c1), constraint cons_name2 foreign key fk_1(c1) references t1(c1));
use xiaofeng_db2;
create table t1(c1 int primary key);
create table t2(c1 int, constraint cons_name foreign key fk_1(c1) references t1(c1), constraint cons_name2 foreign key fk_1(c1) references t1(c1));
drop table t2,t1;
use xiaofeng_db;
drop table t2,t1;

# 测试一条 create table 语句同时创建两个同名外键，应该失败
create table t1(c1 int, c2 int, primary key(c1), unique key uk_ind(c2));
--error 1215
create table t2(c1 int, c2 int, constraint fk_1 foreign key(c1) references t1(c1), constraint fk_1 foreign key(c1) references t1(c1));
--error 1215
create table t2(c1 int, c2 int, constraint fk_1 foreign key(c1) references t1(c1), constraint fk_1 foreign key(c2) references t1(c2));
create table t2(c1 int, c2 int, constraint fk_1 foreign key(c1) references t1(c1), constraint fk_2 foreign key(c1) references t1(c1));
create table t3(c1 int, c2 int, constraint fk_3 foreign key(c1) references t1(c1), constraint fk_4 foreign key(c2) references t1(c2));
drop table t3,t2,t1;


# fix bug#18316526，测试 truncate table t2 之后，t2 上的外键没有被删除，而且不能建和 t2 表上的外键 cons_name 同名的外键
create table t1(c1 int, c2 int, unique key(c1, c2));
create table t2(c1 int, c2 int, constraint cons_name foreign key(c1, c2) references t1(c1, c2));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
truncate table t2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
--error 1022
create table t3(c1 int, c2 int, constraint cons_name foreign key(c1, c2) references t1(c1, c2));
drop table t2;
create table t3(c1 int, c2 int, constraint cons_name foreign key(c1, c2) references t1(c1, c2));
drop table t3,t1;


# 测试关闭回收站之后，alter table drop fk、drop table 和 truncate table 的行为
set recyclebin = off;
create table t1(c1 int, c2 int, c3 char, primary key(c1), index c2_ind(c2));
create table t2(c1 int, t1_c1 int, constraint fk_1 foreign key(t1_c1) references t1(c1));
# 测试 alter table drop foreign key 的行为
alter table t2 drop foreign key fk_1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
create table t2(c1 int, t1_c1 int, constraint fk_1 foreign key(t1_c1) references t1(c1));
# drop 受外键约束的父表，应该失败
--error 3730
drop table t1;
# 测试 drop table 时，有外键约束的情形
drop table t2;
create table t2(c1 int, t1_c1 int, constraint fk_1 foreign key(t1_c1) references t1(c1));
# 测试truncate 有外键约束关系的父表，会失败
--error 1701
truncate table t1;
# truncate 有外键约束关系的子表，会保留外键约束
truncate table t2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
# 测试 truncate table t2 之后，t2 上的外键没有被删除，而且不能建和 t2 表上的外键 fk_1 同名的外键
--error 1022
create table t3(c1 int, t1_c1 int, constraint fk_1 foreign key(t1_c1) references t1(c1));
set recyclebin = on;

--error 1064
create table t3(c1 int, t1_c1 int, constraint fk_1 foreign key(c2.c1.c3) references t1(c1));
--error 1064
create table t3(c1 int, t1_c1 int, constraint fk_1 foreign key(c1.c3) references t1(c1));
--error 1064
create table t3(c1 int, t1_c1 int, constraint fk_1 foreign key(c1) references t1(c2.c1.c3));
--error 1064
create table t3(c1 int, t1_c1 int, constraint fk_1 foreign key(c1) references t1(c1.c3));


# clean up
drop table t2,t1;
drop database xiaofeng_db;
drop database xiaofeng_db2;
