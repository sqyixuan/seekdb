--disable_warnings
drop database if exists xf_foreign_key_checks_test_db_2;
--enable_warnings
create database xf_foreign_key_checks_test_db_2;
use xf_foreign_key_checks_test_db_2;
set foreign_key_checks = off;
CREATE TABLE Bug_60196 ( FK1_Key INT NOT NULL, FK2_Key INT NOT NULL, PRIMARY KEY (FK2_Key, FK1_Key), KEY FK1_Key (FK1_Key), KEY FK2_Key (FK2_Key), CONSTRAINT FK_FK1 FOREIGN KEY (FK1_Key) REFERENCES Bug_60196_FK1 (Primary_Key) ON DELETE CASCADE ON UPDATE CASCADE, CONSTRAINT FK_FK2 FOREIGN KEY (FK2_Key) REFERENCES Bug_60196_FK2 (Primary_Key) ON DELETE CASCADE ON UPDATE CASCADE );

use xf_foreign_key_checks_test_db;
set foreign_key_checks = off;
--disable_warnings
DROP TABLES IF EXISTS t1,t2,t3,t4;
--enable_warnings
CREATE TABLE IF NOT EXISTS `t2` ( `ID` int(11) NOT NULL auto_increment, `ParId` int(11) default NULL, `tst` text, `tst1` text, PRIMARY KEY (`ID`), KEY `IX_ParId_t2` (`ParId`), FOREIGN KEY (`ParId`) REFERENCES `t1` (`id`) );
create TABLE t1 (id int primary key, Word varchar(40) not null, Index(Word));
DROP TABLE t1;


set foreign_key_checks=off;
create table t44269106_2 (a int auto_increment primary key, b int, index(b), foreign key (b) references t44269106_1(id), unique(b));
CREATE TABLE t44269106_1 (id INT PRIMARY KEY, t1_id INT, INDEX par_ind (t1_id), FOREIGN KEY (t1_id) REFERENCES t44269106_1(id));
ALTER TABLE t44269106_1 ADD COLUMN b INT DEFAULT 0;
alter TABLE t44269106_1 add index (b);
DROP TABLE `t44269106_1`;
--error 1051
DROP TABLE `t44269106_1`;


--disable_warnings
DROP TABLES IF EXISTS t4,t3,t2,t1,t0;
--enable_warnings
set foreign_key_checks=0;
create table t1(t1_c1 int, primary key(t1_c1), foreign key (t1_c1) references t0(t0_c1));
create table t2(t2_c1 int, primary key(t2_c1), foreign key(t2_c1) references t1(t1_c1));
create table t3(t3_c1 int, constraint t3_t2_fk foreign key(t3_c1) references t2(t2_c1), constraint t3_t1_fk foreign key(t3_c1) references t1(t1_c1));
create table t4(t4_c1 int, constraint t4_t2_fk foreign key(t4_c1) references t2(t2_c1));
drop table t2;
--error 1146
show create table t2;


--disable_warnings
DROP TABLES IF EXISTS t4;
DROP TABLES IF EXISTS t3;
DROP TABLES IF EXISTS t2;
DROP TABLES IF EXISTS t1;
DROP TABLES IF EXISTS t0;
--enable_warnings
create table t1(c1 int, primary key(c1));
create table t2(c1 int, constraint fk foreign key(c1) references t1(c1));
set session foreign_key_checks=0;
insert into t1 values(1);
truncate table t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
