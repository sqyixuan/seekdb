#### owner: qiaolinjun.qlj
#### owner group: IMF
#### description: foreign key

--disable_warnings
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings


create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, foreign key(c2) references t1(c1) on delete set null on update set null);

insert into t1 values (1,1),(2,2);
insert into t2 values (1,1),(2,2);

delete from t1 where c1 = 1;
select * from t1;
select * from t2;

update t1 set c1 = 3 where c1 = 2;
select * from t1;
select * from t2;

drop table t2;
drop table t1;

create table t1 (c1 int, c2 int, c3 int, primary key(c1, c2));
create table t2 (c1 int, c2 int, c3 int, foreign key(c1, c2) references t1(c1, c2) on delete set null on update set null);

insert into t1 values (1,1,1),(2,2,2),(3,3,3);
insert into t2 values (1,1,1),(2,2,2),(3,3,3);

delete from t1 where c1 = 1;
select * from t1;
select * from t2;

update t1 set c1 = c1 + 2;
select * from t1;
select * from t2;

drop table t2;
drop table t1;


create table t1 (c1 int, c2 int, c3 int, unique key(c1, c2));
create table t2 (c1 int, c2 int, c3 int, foreign key(c1, c2) references t1(c1,c2) on delete set null on update set null);

insert into t1 values (1,null,1),(2,2,2),(3,3,3);
insert into t2 values (1,null,1),(2,null,2),(3,3,3);

delete from t1 where c1 = 1;
select * from t1;
select * from t2;

update t1 set c1 = c1 + 2;
select * from t1;
select * from t2;

drop table t2;
drop table t1;

create table t1 (c1 varchar(20) primary key, c2 varchar(20));
create table t2 (c1 varchar(20) primary key, c2 varchar(20), foreign key(c2) references t1(c1) on delete set null on update set null);

insert into t1 values ('leo', 'leo'), ('rony', 'rony'), ('benzema', 'benzema');
insert into t2 values ('leo', 'leo'), ('rony', 'rony'), ('benzema', 'benzema');

delete from t1 where c1 = 'leo';
select * from t1;
select * from t2;

update t1 set c1 = 'ronaldo' where c1 = 'rony';
select * from t1;
select * from t2;

drop table t2;
drop table t1;

create table t1 (c1 varchar(20) unique key, c2 varchar(20));
create table t2 (c1 varchar(20), c2 varchar(20), foreign key(c2) references t1(c1) on delete set null on update set null);

insert into t1 values (null, 'leo'), ('rony', 'rony'), ('benzema', 'benzema');
insert into t2 values ('leo', null), ('rony', 'rony'), ('benzema', 'benzema');

delete from t1 where c2 = 'leo';
select * from t1;
select * from t2;

update t1 set c1 = 'ronaldo' where c1 = 'rony';
select * from t1;
select * from t2;

drop table t2;
drop table t1;

create table t1 (c1 int primary key, c2 int);
## 测试外键列定义为not null
--source mysql_test/include/replace_object_name_created_by_sys.inc
--error 1830
create table t2 (c1 int primary key, c2 int not null, foreign key(c2) references t1(c1) on delete set null on update set null);

##测试外键列是stored 生成列
--error 3104
create table t2 (c1 int primary key, c2 int generated always as (c1 + 1) stored, foreign key(c2) references t1(c1) on delete set null on update set null);

##测试外键列是virtual生成列
--error 3104
create table t2 (c1 int primary key, c2 int generated always as (c1 + 1) virtual, foreign key(c2) references t1(c1) on delete set null on update set null);
##测试外键是stored生成列的基列
--error 1215
create table t2 (c1 int primary key, c2 int, c3 int generated always as (c2 + 1) stored, foreign key(c2) references t1(c1) on delete set null on update set null);

##测试外键是virtual生成列的基列
create table t2 (c1 int primary key, c2 int, c3 int generated always as (c2 + 1) virtual, foreign key(c2) references t1(c1) on delete set null on update set null);

insert into t1 values (1,1),(2,2),(3,3);
insert into t2(c1,c2) values (1,1),(2,2),(3,3);

delete from t1 where c1 = 1;
select * from t1;
select * from t2;

update t1 set c1 = c1 + 2;
select * from t1;
select * from t2;

drop table t2;
drop table t1;

## 多级外键嵌套下的set null
create table t1(c1 int primary key, c2 int);
create table t2 (c1 int unique key, c2 int, foreign key(c1) references t1(c1) on delete set null on update set null);
create table t3 (c1 int unique key, c2 int, foreign key(c1) references t2(c1) on delete set null on update set null);

insert into t1 values (1,1),(2,2),(3,3);
insert into t2 values (1,1),(2,2),(3,3);
insert into t3 values (1,1),(2,2),(3,3);

delete from t1 where c1 = 1;
select * from t1;
select * from t2;
select * from t3;

update t1 set c1 = c1 + 2;
select * from t1;
select * from t2;
select * from t3;

delete from t1;
select * from t1;
select * from t2;
select * from t3;

drop table t3;
drop table t2;
drop table t1;

## alter table 进行ddl检查
create table t1 (c1 int primary key, c2 int);
##先有not null, 再增加外键 set null
create table t2 (c1 int primary key, c2 int not null);
--source mysql_test/include/replace_object_name_created_by_sys.inc
--error 1830
alter table t2 add constraint fk_cst foreign key(c2) references t1(c1) on delete set null on update set null;

drop table t2;
## 先有外键set null,再修改列的属性为 not null
create table t2 (c1 int primary key, c2 int, foreign key(c2) references t1(c1) on delete set null on update set null);
## MySQL 会报错， OB不会
alter table t2 modify c2 int not null;

## 先定义外键列是生成列，再增加外键约束
drop table t2;
create table t2 (c1 int primary key, c2 int generated always as (c1 + 1) stored);
--error 3104
alter table t2 add constraint fk_cst foreign key(c2) references t1(c1) on delete set null on update set null;

drop table t2;
create table t2 (c1 int primary key, c2 int generated always as (c1 + 1) virtual);
--error 3104
alter table t2 add constraint fk_cst foreign key(c2) references t1(c1) on delete set null on update set null;

## 先定义外键，再修改列为生成列
drop table t2;
create table t2(c1 int primary key, c2 int, foreign key(c2) references t1(c1) on delete set null on update set null);
--error 3106
alter table t2 modify column c2 int generated always as (c1 + 1) stored;

drop table t2;
create table t2(c1 int primary key, c2 int, foreign key(c2) references t1(c1) on delete set null on update set null);
--error 3106
alter table t2 modify column c2 int generated always as (c1 + 1) virtual;

## 先定义外键列是生成列基础列，再增加外键约束
drop table t2;
create table t2 (c1 int primary key, c2 int, c3 int generated always as (c2 + 1) stored);
--error 1215
alter table t2 add constraint fk_cst foreign key(c2) references t1(c1) on delete set null on update set null;

## 先增加外键约束，再增加一个为stored生成列，其基础列为外键列
drop table t2;
create table t2(c1 int primary key, c2 int, foreign key(c2) references t1(c1) on delete set null on update set null);
## MySQL会报错，OB目前不会
alter table t2 add column c3 int generated always as (c2 + 1) stored;