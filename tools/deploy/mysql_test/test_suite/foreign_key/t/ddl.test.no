connection obsys;
let $zone_name=query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 2, zone, 2);
let $zone_name2=query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 2, zone, 1);
