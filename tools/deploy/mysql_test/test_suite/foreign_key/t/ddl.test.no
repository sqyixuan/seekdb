## alter table
create table alter_t0(c1 int primary key, c2 int unique key, c3 int);
alter table alter_t0 add unique key uk_1(c3);
create table alter_t1(c1 int, c2 int unique key);
--error ER_PARSE_ERROR
alter table alter_t1 add foreign key(c2) references alter_t0(c2);

create table alter_t2(c1 int, c2 int unique key, c3 int, foreign key(c2) references alter_t0(c2), foreign key(c3) references alter_t0(c3));
--error 5320
alter table alter_t2 drop column c2;
--error 5320
alter table alter_t0 drop column c2;

alter table alter_t2 change column c2 c22 int unique key;
alter table alter_t0 change column c2 c22 int unique key;

--error 5320
alter table alter_t2 modify column c22 bigint unique key;
--error 5320
alter table alter_t0 modify column c22 bigint unique key;
alter table alter_t0 change column c22 c2 int unique key;

#索引列不是外键列，可以被drop
alter table alter_t0 add key nk_1(c3, c2);
drop index nk_1 on alter_t0;
alter table alter_t0 add key nk_1(c3, c2);
alter table alter_t0 alter index nk_1 VISIBLE;
show index from alter_t0;
alter table alter_t0 alter index nk_1 INVISIBLE;
show index from alter_t0;

alter table alter_t2 add key nk_2(c3);
--error 5320
drop index nk_2 on alter_t2;

alter table alter_t0 alter index uk_1 VISIBLE;
alter table alter_t0 alter index uk_1 INVISIBLE;
--error 5320
alter table alter_t2 alter index nk_2 VISIBLE;
--error 5320
alter table alter_t2 alter index nk_2 INVISIBLE;

#alter table列id不同
create table jx_t1(a int primary key, b int, c varchar(50), d int, unique key uk_1(b));
create table jx_t2(a int primary key, b int, c varchar(50), d int, foreign key(a) references jx_t1(b));
--error 5320
alter table jx_t1 change column b b bigint;
--error 5320
alter table jx_t2 change column a a bigint;
drop table jx_t2, jx_t1;

create table jx_t3(c1 int, c2 int primary key, foreign key(c1) references jx_t3(c2));
--error 5320
alter table jx_t3 change c1 c1 bigint;
drop table jx_t3;

## show create table with fk
