# drop foreign key.
--disable_warnings
drop database if exists jiuren;
--enable_warnings

create database jiuren;
use jiuren;

drop table if exists t2, t1;
create table t1(pk int, a int, b int, primary key (pk), unique key uk_a_b (b, a));
create table t2(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b), constraint cst_name foreign key fk_name (a, b) references t1 (b, a) on update CASCADE on delete NO ACTION);
show create table t2;
--error ER_CANT_DROP_FIELD_OR_KEY
alter table t2 drop foreign key fk_name;
alter table t2 drop foreign key cst_name;

drop table if exists t2, t1;
create table t1(pk int, a int, b int, primary key (pk), unique key uk_a_b (b, a));
create table t2(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b), constraint cst_name foreign key (a, b) references t1 (b, a) on update RESTRICT on delete SET NULL);
show create table t2;
alter table t2 drop foreign key cst_name;

drop table if exists t2, t1;
create table t1(pk int, a int, b int, primary key (pk), unique key uk_a_b (b, a));
create table t2(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b), constraint foreign key fk_name (a, b) references t1 (b, a) on update CASCADE);
show create table t2;
--error ER_CANT_DROP_FIELD_OR_KEY
alter table t2 drop foreign key fk_name;

drop table if exists t2, t1;
create table t1(pk int, a int, b int, primary key (pk), unique key uk_a_b (b, a));
create table t2(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b), constraint foreign key (a, b) references t1 (b, a) on delete SET DEFAULT);
show create table t2;

drop table if exists t2, t1;
create table t1(pk int, a int, b int, primary key (pk), unique key uk_a_b (b, a));
create table t2(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b), foreign key fk_name (a, b) references t1 (b, a) on update CASCADE on delete CASCADE);
show create table t2;
alter table t2 drop foreign key fk_name;

drop table if exists t2, t1;
create table t1(pk int, a int, b int, primary key (pk), unique key uk_a_b (b, a));
create table t2(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b), foreign key (a, b) references t1 (b, a) on update CASCADE on delete CASCADE);
show create table t2;

drop table if exists t2, t1;
drop database jiuren;
set foreign_key_checks=off;
