--disable_query_log
create table info (
  l_user_id bigint not null,
  l_item_type bigint not null,
  l_item_id bigint not null,
  l_collect_time bigint not null,
  l_info_from varchar(20) default null,
  l_info_note varchar(20) default null,
  primary key (l_user_id, l_item_type, l_item_id)
);
create table item (
  r_item_id bigint not null,
  r_item_type bigint not null,
  r_item_title varchar(20) not null,
  r_item_price bigint not null,
  primary key (r_item_id, r_item_type)
) locality='F,R{all_server}@zone1';

--enable_query_log
create materialized view mv_info_item as select info.l_item_id, info.l_info_from, item.r_item_id, item.r_item_type, item.r_item_title from info, item where info.l_item_type = item.r_item_type and info.l_item_id = item.r_item_id order by info.l_user_id, info.l_item_type;
--error ER_CANNOT_ADD_FOREIGN
create table non_user_f1(
  l_user_id bigint not null,
  l_item_type bigint not null,
  l_item_id bigint not null,
  l_collect_time bigint not null,
  l_info_from varchar(20) default null,
  l_info_note varchar(20) default null,
  primary key (l_user_id, l_item_type, l_item_id),
  foreign key(l_user_id, l_item_type, l_item_id) references mv_info_item(l_user_id, l_item_type, l_item_id)
);

