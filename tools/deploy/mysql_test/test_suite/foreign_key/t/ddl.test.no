show create table show_p3;

## cross pk and uk
create table mult_p1(c1 int primary key, c2 int unique key);
#不同参考覆盖两个uk，Mysql也不支持
--error ER_CANNOT_ADD_FOREIGN
create table mult_f1(c1 int primary key, c2 int, foreign key(c1, c2) references mult_p1(c1, c2));

#################### drop index
###索引在父表上
create table jx_t1(a int primary key, b int, unique key `i_b` (b));
create table jx_t2(a int, b int, foreign key (b) references jx_t1(a));
alter table jx_t1 drop index i_b;
create index i_b on jx_t1(b);
drop index i_b on jx_t1;

create index idx_2 on jx_t1(a);
drop index idx_2 on jx_t1;
create index idx_3 on jx_t1(a, b);
drop index idx_3 on jx_t1;
alter table jx_t1 add index idx_3(b, a);
alter table jx_t1 drop index idx_3;
drop table jx_t2, jx_t1;

###索引在子表上
create table jx_t1(a int primary key, b int, unique key `i_b` (b));
create table jx_t2(a int primary key, b int, unique key `i_b` (b), foreign key (a) references jx_t1(a));
alter table jx_t2 drop index i_b;
create index i_b on jx_t2(b);
drop index i_b on jx_t2;

create index idx_2 on jx_t2(a);
--error 5320
drop index idx_2 on jx_t2;
--error 5320
alter table jx_t2 drop index idx_2;
create index idx_3 on jx_t2(a, b);
drop index idx_3 on jx_t2;
alter table jx_t2 add index idx_3(b, a);
alter table jx_t2 drop index idx_3;
drop table jx_t2, jx_t1;

###索引在子表和父表上
create table jx_t1(a int primary key, b int, c varchar(50), d int, unique key uk_1(b), unique key uk_2(b, c));
create table jx_t2(a int primary key, b int, c varchar(50), d int, unique key uk_1(b), 
    foreign key (d) references jx_t2(b), #自引用外键
    foreign key (a) references jx_t1(a),
    foreign key (a, c) references jx_t1(b, c));
create table jx_t3(a int primary key, b int , c varchar(50), d int, foreign key (a) references jx_t2(a));
alter table jx_t2 drop index uk_1;
create table jx_t4(c1 int, c2 int primary key, index idx(c2), foreign key(c1) references jx_t4(c2));
drop index idx on jx_t4;

#索引列大于外键列
create index idx_2 on jx_t2(a, b);
drop index idx_2 on jx_t2;
create index idx_2 on jx_t2(a, b);
alter table jx_t2 drop index idx_2; 

#自引用外键列
create index idx_3 on jx_t2(a);
--error 5320
drop index idx_3 on jx_t2;
--error 5320
alter table jx_t2 drop index idx_3;

#索引列小于外键列
create index idx_4 on jx_t2(c);
drop index idx_4 on jx_t2;
drop table jx_t3, jx_t2, jx_t1;

#索引在子表和父表上, 含有多个外键

## 不能建line foreign key
create table inline_p1(c1 int , c2 int, primary key(c1), unique key (c2));
--error ER_PARSE_ERROR
create table inline_f1(c1 int , c2 int foreign key reference inline_p1(c1), primary key(c1), unique key (c2));

# truncate table fri_tab2;
create table pri_tab2(c1 int primary key, c2 int);
insert into pri_tab2 values(1,1);
insert into pri_tab2 values(2,2);
create table fri_tab2(c1 int not null, c2 int not null, primary key(c1), foreign key(c2) references pri_tab2(c1));

truncate table fri_tab2;
insert into pri_tab2 values(3,3);
connection obsys;
select count(*) from oceanbase.__all_virtual_foreign_key_history where is_deleted = 0 and child_table_id in(select table_id from oceanbase.__all_virtual_table where table_name='fri_tab2' order by schema_version desc limit 1);
select count(*) from oceanbase.__all_virtual_foreign_key_history where is_deleted = 0 and parent_table_id in(select table_id from oceanbase.__all_virtual_table where table_name='pri_tab2' order by schema_version desc limit 1);
connection default;

--error ER_NO_REFERENCED_ROW_2
insert into fri_tab2 values(4,4);

delete from pri_tab2 where c1=1;
delete from pri_tab2 where c1=3;
update pri_tab2 set c1 = 3 where c2 = 2;

--error ER_ROW_IS_REFERENCED
drop table pri_tab2;

drop table fri_tab2;
drop table pri_tab2;

# truncate table pri_tab3;
create table pri_tab3(c1 int primary key, c2 int);
insert into pri_tab3 values(1,1);
insert into pri_tab3 values(2,2);
create table fri_tab3(c1 int not null, c2 int not null, primary key(c1), foreign key(c2) references pri_tab3(c1));
insert into fri_tab3 values(1,1);
insert into fri_tab3 values(2,2);

--error ER_TRUNCATE_ILLEGAL_FK
truncate table pri_tab3;
insert into pri_tab3 values(3,3);
connection obsys;
select count(*) from oceanbase.__all_virtual_foreign_key_history where is_deleted = 0 and child_table_id in(select table_id from oceanbase.__all_virtual_table where table_name='fri_tab3' order by schema_version desc limit 1);
select count(*) from oceanbase.__all_virtual_foreign_key_history where is_deleted = 0 and parent_table_id in(select table_id from oceanbase.__all_virtual_table where table_name='pri_tab3' order by schema_version desc limit 1);
connection default;
--error ER_NO_REFERENCED_ROW_2
insert into fri_tab3 values(4,4);

--error ER_ROW_IS_REFERENCED_2
delete from pri_tab3 where c1=1;
--error ER_ROW_IS_REFERENCED_2
update pri_tab3 set c1 = 3 where c2 = 2;

--error ER_ROW_IS_REFERENCED
drop table pri_tab3;

drop table fri_tab3;
drop table pri_tab3;

###drop table
create table p1(c1 int primary key, c2 int);
create table f1(c1 int not null, c2 int not null, primary key(c1), foreign key(c2) references p1(c1));
create table f2(c1 int not null, c2 int not null, primary key(c1), foreign key(c2) references f1(c1));
create table f3(c1 int not null, c2 int not null, primary key(c1), foreign key(c2) references f2(c1));

--error ER_ROW_IS_REFERENCED
drop table p1,f1,f2;
show tables;

# 如果一个表既是其他表的主表又是子表
create table drop_t1(c1 int primary key, c2 int);
create table drop_t2(c1 int primary key, foreign key(c1) references drop_t1(c1));
create table drop_t3(c1 int primary key, foreign key(c1) references drop_t2(c1));
--error ER_ROW_IS_REFERENCED
drop table drop_t2;
--error ER_TRUNCATE_ILLEGAL_FK
truncate table drop_t2;

#目前和MySql不一致，MySql是会删除掉f3和f2
#OB所有都无法删除
--error ER_ROW_IS_REFERENCED
drop table p1,f1,f3,f2;
show tables;

### lower_case_table_names, 系统租户是2， 普通租户默认是1
# OB_ORIGIN_AND_SENSITIVE = 0,//stored using lettercase, and name comparisons are case sensitive
# OB_LOWERCASE_AND_INSENSITIVE = 1,//stored using lowercase, and name comparisons are case insensitive
# OB_ORIGIN_AND_INSENSITIVE = 2,//stored using lettercase, and name comparisons are case insensitive
SELECT @@global.lower_case_table_names;
use jx_db;
create table p_tt1(col1 tinyint(10) not null primary key, `cOl2` varchar(10) unique key, COL3 time(6), unique key(`cOl2`, COL3));
create table f_tt1_0(Col1 tinyint(10) not null primary key, `COL2` varchar(10), CoL3 time(6), foreign key(col2) references p_tt1(col2));
connection obsys;
select count(*) from oceanbase.__all_virtual_foreign_key_history where is_deleted = 0 and child_table_id in(select table_id from oceanbase.__all_virtual_table where table_name='f_tt1_0' order by schema_version desc limit 1);
connection default;
create table f_tt1_1(Col1 tinyint(10) not null primary key, `COL2` varchar(10), CoL3 time(6), foreign key(`COL2`) references p_tt1(col2));
connection obsys;
select count(*) from oceanbase.__all_virtual_foreign_key_history where is_deleted = 0 and child_table_id in(select table_id from oceanbase.__all_virtual_table where table_name='f_tt1_1' order by schema_version desc limit 1);
connection default;
create table f_tt1_2(Col1 tinyint(10) not null primary key, `COL2` varchar(10), CoL3 time(6), foreign key(col2) references p_tt1(`cOl2`));
connection obsys;
select count(*) from oceanbase.__all_virtual_foreign_key_history where is_deleted = 0 and child_table_id in(select table_id from oceanbase.__all_virtual_table where table_name='f_tt1_2' order by schema_version desc limit 1);
connection default;
create table f_tt1_3(Col1 tinyint(10) not null primary key, `COL2` varchar(10), CoL3 time(6), foreign key(`COL2`) references p_tt1(`cOl2`));
connection obsys;
select count(*) from oceanbase.__all_virtual_foreign_key_history where is_deleted = 0 and child_table_id in(select table_id from oceanbase.__all_virtual_table where table_name='f_tt1_3' order by schema_version desc limit 1);

