--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: dachuan.sdc
#### owner group: sql2
#### description: foreign key

# basic ddl test

--disable_warnings
drop database if exists xf_db;
drop database if exists xf_db2;
--enable_warnings

create database xf_db;
create database xf_db2;
use xf_db;


# 当外键列和索引列不重合时，允许删除索引列
create table t1(c1 int, c2 int, c3 int, unique key(c1, c2));
create table t2(c1 int, c2 int, c3 int, index ind(c3, c2), constraint cons_name foreign key(c1, c2) references t1(c1, c2));
drop index ind on t2;
drop table t2, t1;


# 当外键列和索引列重合时，14x 中不允许删除索引列
create table t1(c1 int, c2 int, unique key(c1, c2));
create table t2(c1 int, c2 int, index ind(c1, c2), constraint cons_name foreign key(c1, c2) references t1(c1, c2));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
--error 5320
drop index ind on t2;

use xf_db2;
create table t3(c1 int, c2 int, index ind(c1, c2), constraint cons_name foreign key(c1, c2) references xf_db.t1(c1, c2));
drop table t3;

create table t4(c1 int, c2 int, index ind(c1, c2), constraint cons_name foreign key(c1, c2) references xf_db.t1(c1, c2));

set @@recyclebin = off;
create table jx_t1(c1 int primary key);
create table jx_t11(c1 int, constraint fk1 foreign key(c1) references jx_t1(c1));
drop table jx_t11;
drop table jx_t1;

drop database xf_db;
drop database xf_db2;


