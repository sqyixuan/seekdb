#### owner: fangzhou.yfz
#### owner group: IMF
#### description: foreign key references non-unique index (in parallel/not in parallel)

# set parallel ddl to true
connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
set @@session.foreign_key_checks = on;
set @@session.recyclebin = off;
let $orig_value = `select value from __all_virtual_tenant_parameter_stat where name = '_enable_parallel_table_creation' limit 1`;
alter system set _enable_parallel_table_creation = true;
sleep 5;
select value from __all_virtual_tenant_parameter_stat where name = '_enable_parallel_table_creation' limit 1;
use test;

--source mysql_test/test_suite/foreign_key/t/fk_non_unique_index.inc

# set parallel ddl to false
use oceanbase;
alter system set _enable_parallel_table_creation = false;
sleep 5;
select value from __all_virtual_tenant_parameter_stat where name = '_enable_parallel_table_creation' limit 1;
use test;

--source mysql_test/test_suite/foreign_key/t/fk_non_unique_index.inc

# clean
set @@session.recyclebin = off;
eval alter system set _enable_parallel_table_creation = '$orig_value';