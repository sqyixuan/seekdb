## 外键自身依赖
create table p_f1(c1 int not null primary key, c2 int not null unique key, c3 int unique key, unique key(c2, c3),
    foreign key(c2) references p_f1(c1) on update RESTRICT on delete NO ACTION,
    foreign key(c3) references p_f1(c2) on update RESTRICT on delete NO ACTION);

connection obsys;
select count(*) from oceanbase.__all_virtual_foreign_key_history where is_deleted = 0 and child_table_id
    in(select table_id from oceanbase.__all_virtual_table where table_name='p_f1' order by schema_version desc limit 1);
connection default;

--error ER_CANNOT_ADD_FOREIGN
create table p_f1(c1 int not null primary key, c2 int not null unique key, c3 int unique key, unique key(c2, c3),
    foreign key(c2) references p_f1(c1) on update RESTRICT on delete NO ACTION,
    foreign key(c3) references p_f1(c2) on update RESTRICT on delete NO ACTION,
    foreign key(c2, c3) references p_f1(c1, c3) on update RESTRICT on delete NO ACTION);
# 特殊case：自身依赖中两个外键，完全是互相依赖 MySQL5.7是支持创建表带这样的外键的, 只不过没法insert data
create table p_f2(c1 int not null primary key, c2 int not null unique key,
    foreign key(c2) references p_f2(c1) on update RESTRICT on delete NO ACTION,
    foreign key(c1) references p_f2(c2) on update RESTRICT on delete NO ACTION);
    
connection obsys;
select count(*) from oceanbase.__all_virtual_foreign_key_history where is_deleted = 0 and child_table_id
    in(select table_id from oceanbase.__all_virtual_table where table_name='p_f2' order by schema_version desc limit 1);
connection default;

# bug: 15610076
#被删除表上的外键有引用自身，也有引用其他表
CREATE TABLE `act_re_procdef` (`ID_` varchar(64) COLLATE utf8mb4_bin NOT NULL,
`REV_` int(11) DEFAULT NULL,
`CATEGORY_` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL,
`NAME_` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL,
`KEY_` varchar(255) COLLATE utf8mb4_bin NOT NULL,
`VERSION_` int(11) NOT NULL,
`DEPLOYMENT_ID_` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL,
`RESOURCE_NAME_` varchar(4000) COLLATE utf8mb4_bin DEFAULT NULL,
`DGRM_RESOURCE_NAME_` varchar(4000) COLLATE utf8mb4_bin DEFAULT NULL,
`DESCRIPTION_` varchar(4000) COLLATE utf8mb4_bin DEFAULT NULL,
`HAS_START_FORM_KEY_` tinyint(4) DEFAULT NULL,
`HAS_GRAPHICAL_NOTATION_` tinyint(4) DEFAULT NULL,
`SUSPENSION_STATE_` int(11) DEFAULT NULL,
`TENANT_ID_` varchar(255) COLLATE utf8mb4_bin DEFAULT '',
PRIMARY KEY (`ID_`),
UNIQUE KEY `ACT_UNIQ_PROCDEF` (`KEY_`, `VERSION_`, `TENANT_ID_`));

CREATE TABLE `act_ru_execution`( `ID_` varchar(64) COLLATE utf8mb4_bin NOT NULL DEFAULT '', 
`REV_` int(11) DEFAULT NULL, 
`PROC_INST_ID_` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL, 
`BUSINESS_KEY_` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL, 
`PARENT_ID_` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL, 
`PROC_DEF_ID_` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL, 
`SUPER_EXEC_` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL, 
`ACT_ID_` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL, 
`IS_ACTIVE_` tinyint(4) DEFAULT NULL, 
`IS_CONCURRENT_` tinyint(4) DEFAULT NULL, 
`IS_SCOPE_` tinyint(4) DEFAULT NULL, 
`IS_EVENT_SCOPE_` tinyint(4) DEFAULT NULL, 
`SUSPENSION_STATE_` int(11) DEFAULT NULL, 
`CACHED_ENT_STATE_` int(11) DEFAULT NULL, 
`TENANT_ID_` varchar(255) COLLATE utf8mb4_bin DEFAULT '', 
`NAME_` varchar(255) COLLATE utf8mb4_bin DEFAULT NULL, 
`LOCK_TIME_` timestamp(3) NULL DEFAULT NULL, 
PRIMARY KEY (`ID_`), 
constraint cons_name_act_ru_execution_1 FOREIGN KEY (`SUPER_EXEC_`) REFERENCES `act_ru_execution`(`ID_`) , 
constraint cons_name_act_ru_execution_2 FOREIGN KEY (`PROC_INST_ID_`) REFERENCES `act_ru_execution`(`ID_`) ,
constraint cons_name_act_ru_execution_3 FOREIGN KEY (`PROC_DEF_ID_`) REFERENCES `act_re_procdef`(`ID_`), 
constraint cons_name_act_ru_execution_4 FOREIGN KEY (`PARENT_ID_`) REFERENCES `act_ru_execution`(`ID_`) , 
KEY `ACT_FK_EXE_PROCINST` (`PROC_INST_ID_`) BLOCK_SIZE 16384, 
KEY `ACT_FK_EXE_PARENT` (`PARENT_ID_`) BLOCK_SIZE 16384, 
KEY `ACT_FK_EXE_SUPER` (`SUPER_EXEC_`) BLOCK_SIZE 16384, 
KEY `ACT_FK_EXE_PROCDEF` (`PROC_DEF_ID_`) BLOCK_SIZE 16384);
--source mysql_test/include/replace_object_name_created_by_sys.inc
--error 3730
drop table act_re_procdef;
--error 1701
truncate table act_re_procdef;
drop table act_ru_execution;
--disable_query_log
connection obsys;
eval select count(*) from oceanbase.__all_virtual_foreign_key where child_table_id in(select table_id from oceanbase.__all_virtual_table where table_name='act_ru_execution' and database_id = $database_id limit 1);
connection default;
--enable_query_log
drop table act_re_procdef;
--disable_query_log
connection obsys;
eval select count(*) from oceanbase.__all_virtual_foreign_key where child_table_id in(select table_id from oceanbase.__all_virtual_table where table_name='act_re_procdef' and database_id = $database_id limit 1);
connection default;
--enable_query_log

