--disable_warnings
drop database if exists jx_db;
--enable_warnings

create database jx_db;
use jx_db;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $database_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name ='jx_db', database_id, 1);
connection default;

create table pri_tab1(c1 int primary key, c2 int);
insert into pri_tab1 values(1,1);
insert into pri_tab1 values(2,2);
create table fri_tab1(c1 int not null, c2 int not null, primary key(c1), foreign key(c2) references pri_tab1(c1));
insert into fri_tab1 values(1,1);
insert into fri_tab1 values(2,2);

connection obsys;
select count(*) from oceanbase.__all_virtual_foreign_key_history where is_deleted = 0 and child_table_id in(select table_id from oceanbase.__all_virtual_table where table_name='fri_tab1' order by schema_version desc limit 1);
select count(*) from oceanbase.__all_virtual_foreign_key_history where is_deleted = 0 and parent_table_id in(select table_id from oceanbase.__all_virtual_table where table_name='pri_tab1' order by schema_version desc limit 1);
connection default;


--source mysql_test/include/replace_object_name_created_by_sys.inc
--error 3730
drop table pri_tab1;
drop table fri_tab1;
update pri_tab1 set c2 = c2 * 10 where c1 = 2;
drop table pri_tab1;

create table p_tab1(c1 int primary key, c2 smallint unsigned unique key, c3 tinyint(16) unique key,
    ca_val char(30) unique key, vc_val varchar(40) unique key, 
    flt_val float(8, 6) unique key, dbl_val double(9, 7) unique key, dec_val decimal(10, 8) unique key, num_val number(11,9) unique key,
    dt_val datetime(6) unique key, t_val time(6) unique key,
    index(ca_val, flt_val),
    unique key(dbl_val, t_val));

# 列类型不同
