create table f_tab1(c1 smallint not null, c2 int not null, foreign key(c1) references p_tab1(c1));
# 无符号和有符号
--error ER_CANNOT_ADD_FOREIGN
create table f_tab1(c1 int unsigned, c2 int not null, foreign key(c1) references p_tab1(c1));
--error ER_CANNOT_ADD_FOREIGN
create table f_tab1(c2 smallint, c1 int not null, foreign key(c2) references p_tab1(c2));
drop table if exists f_tab1;
create table f_tab1(ca_val char(30), flt_val float(8, 6), foreign key(ca_val, flt_val) references p_tab1(ca_val, flt_val));
drop table if exists f_tab1;
--error ER_CANNOT_ADD_FOREIGN
create table f_tab1(c2 smallint signed, c1 int not null, foreign key(c2) references p_tab1(c2));
create table f_tab_sgn(c3 tinyint signed, c2 int not null, foreign key(c3) references p_tab1(c3));
connection obsys;
select count(*) from oceanbase.__all_virtual_foreign_key_history where is_deleted = 0 and parent_table_id in(select table_id from oceanbase.__all_virtual_table where table_name='f_tab_sgn' order by schema_version desc limit 1);
connection default;
