## show create table with fk
create table show_p1(c1 int primary key, c2 int unique key, c3 int, c4 int, unique key(c3, c4));
create table show_p2(c1 int primary key, c2 int, 
    constraint cons_name_show_p2_1 foreign key(c2) references show_p1(c1),
    constraint cons_name_show_p2_2 foreign key(c2) references show_p1(c1),
    constraint cons_name_show_p2_3 foreign key(c2) references show_p1(c1));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table show_p1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table show_p2;
create table show_p3(c1 int primary key, c2 int, constraint cons_name_show_p3 foreign key(c2) references show_p2(c1));
--source mysql_test/include/show_create_table_old_version_replica2.inc
