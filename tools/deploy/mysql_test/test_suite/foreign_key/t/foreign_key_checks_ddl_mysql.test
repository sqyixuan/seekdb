##### 2-2-5 flashback table to before drop
set recyclebin = on;
set foreign_key_checks = off;
create table tp_flashback_rename_1_tmp_1(c1 varchar(10), c2 int, c3 varchar(10), c4 int, primary key(c1, c2), unique key(c3, c4));
create table tp_flashback_rename_1_tmp_2(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2));
