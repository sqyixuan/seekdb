create table tp_flashback_rename_1_tmp_4(c1 int, c2 int, c3 int, c4 int, primary key(c1, c3), unique key(c2, c4));
create table tp_flashback_rename_1(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2), unique key(c3, c4));
create table tc_flashback_rename_1(c1 int, c2 int, constraint fk_tp_flashback_rename_1_tc_flashback_rename_1 foreign key(c1, c2) references tp_flashback_rename_1(c1, c2));
create table tc_flashback_rename_2(c1 int, c2 int, constraint fk_tp_flashback_rename_1_tc_flashback_rename_2 foreign key(c1, c2) references tp_flashback_rename_1(c3, c4));
drop table tp_flashback_rename_1_tmp_1;
drop table tp_flashback_rename_1_tmp_2;
drop table tp_flashback_rename_1_tmp_3;
drop table tp_flashback_rename_1_tmp_4;
drop table tp_flashback_rename_1;
