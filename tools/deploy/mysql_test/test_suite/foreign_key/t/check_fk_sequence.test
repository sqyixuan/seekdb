# owner: yangyifei.yyf
# owner group: transaction
# description: this case is used to test foreign key constraint check sequence,
#              i.e. execute delete / update / insert operations in own table
#              before check foreign key constraint in child / parent table

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

connect (conn1, $OBMYSQL_MS0, root@sys, , test, $OBMYSQL_PORT);
connect (conn2, $OBMYSQL_MS0, root@sys, , test, $OBMYSQL_PORT);

connection conn1;
--disable_warnings
drop table if exists child;
drop table if exists parent;
--enable_warnings
# enable debug_sync
alter system set debug_sync_timeout = '100000s';
sleep 5;

### 1. check foreign key constratint which has index in the child table
# create parent table and child table with index
create table parent(c1 int primary key, c2 int);
create table child(c1 int primary key, c2 int, foreign key(c2) references parent(c1));
insert into parent values(1, 1);
insert into child values(1, 1);

## 1.1 check row in parent table has been locked before check
# start transaction in parent table
# and hold the process before foreign key constraint check
begin;
set session ob_query_timeout = 100000000;
set debug_sync = 'before_foreign_key_constraint_check wait_for select_time_out execute 10000';
send delete from parent where c1 = 1;

# start transaction and try to lock the same row in parent table
connection conn2;
begin;
set session ob_query_timeout = 2000000; # the timeout config here should be less than 100s, to make tiemout error
--error 1205
select * from parent where c1 = 1 for update;
set debug_sync = 'now signal select_time_out';

connection conn1;
--error 1451
reap;
set debug_sync = 'before_foreign_key_constraint_check clear';
rollback;

# check result
select * from parent;
select * from child;

## 1.2 check row in child table has been locked before check
# start transaction in child table
# and hold the process before foreign key constraint check
begin;
set session ob_query_timeout = 100000000;
set debug_sync = 'before_foreign_key_constraint_check wait_for select_time_out execute 10000';
send update child set c2 = 2 where c2 = 1;

# start transaction and try to lock the same row in child table
connection conn2;
begin;
set session ob_query_timeout = 2000000; # the timeout config here should be less than 100s, to make tiemout error
--error 1205
select * from child where c2 = 1 for update;
set debug_sync = 'now signal select_time_out';

connection conn1;
--error 1452
reap;
set debug_sync = 'before_foreign_key_constraint_check clear';
rollback;

# check result
select * from parent;
select * from child;

### 2. check foreign key constratint which has index no in the child table
# create child table without index
drop table child;
create table child(c1 int, c2 int, foreign key(c2) references parent(c1));
insert into child values(1, 1);

## 2.1 check row in parent table has been locked before check
# start transaction in parent table
# and hold the process before foreign key constraint check
begin;
set session ob_query_timeout = 100000000;
set debug_sync = 'before_foreign_key_constraint_check wait_for select_time_out execute 10000';
send delete from parent where c1 = 1;

# start transaction and try to lock the same row in parent table
connection conn2;
begin;
set session ob_query_timeout = 2000000; # the timeout config here should be less than 100s, to make tiemout error
--error 1205
select * from parent where c1 = 1 for update;
set debug_sync = 'now signal select_time_out';

connection conn1;
--error 1451
reap;
set debug_sync = 'before_foreign_key_constraint_check clear';
rollback;

# check result
select * from parent;
select * from child;

## 2.2 check row in child table has been locked before check
# start transaction in child table
# and hold the process before foreign key constraint check
begin;
set session ob_query_timeout = 100000000;
set debug_sync = 'before_foreign_key_constraint_check wait_for select_time_out execute 10000';
send update child set c2 = 2 where c2 = 1;

# start transaction and try to lock the same row in child table
connection conn2;
begin;
set session ob_query_timeout = 2000000; # the timeout config here should be less than 100s, to make tiemout error
--error 1205
select * from child where c2 = 1 for update;
set debug_sync = 'now signal select_time_out';

connection conn1;
--error 1452
reap;
set debug_sync = 'before_foreign_key_constraint_check clear';
rollback;

# check result
select * from parent;
select * from child;

# test done, drop tables
drop table child;
drop table parent;
