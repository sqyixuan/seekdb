# owner: dachuan.sdc
# owner group: SQL1
# description: 测试 mysql 模式下 alter table add fk 的行为
# tags: foreign_key

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
create user if not exists __oceanbase_inner_drc_user;
--enable_warnings
grant all privileges on *.* to __oceanbase_inner_drc_user;
--source mysql_test/include/check_schema_sync.inc
connect (conn_drc,$OBMYSQL_MS0,__oceanbase_inner_drc_user,,*NO-ONE*,$OBMYSQL_PORT);

# 测试非备份恢复用户 alter table add foreign key 时进行数据合法性检查
connection default;
use test;
create table t1(c1 int, c2 int, c3 int, c4 int, constraint t1_pk1 primary key(c1, c2), constraint t1_uk1 unique(c3, c4));
create table t2(c1 int, c2 int, c3 int, c4 int);
insert into t2 values(1, 2, 3, 4);
--error 5785
alter table t2 add constraint fk1 foreign key(c1, c2) references t1(c1, c2);
--error 5785
alter table t2 add constraint fk2 foreign key(c3, c4) references t1(c3, c4);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
delete from t2;
alter table t2 add constraint fk1 foreign key(c1, c2) references t1(c1, c2);
alter table t2 add constraint fk2 foreign key(c3, c4) references t1(c3, c4);
drop table t2;
drop table t1;

# clean up
drop user __oceanbase_inner_drc_user;

