# owner: qiaolinjun.qlj
# owner group: IMF
# tag: self-ref-foreign_key, cascade delete 
# description: Verify correctness of self-ref foreign key with cascade delete

--disable_warnings
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 302, error_code = 20, frequency = 1;
connection default;
## 单表，只存在外键自引用
create table t1 (c1 int primary key, c2 int, foreign key(c2) references t1(c1) on delete cascade);

insert into t1 values (1,1),(2,2);
insert into t1 values (3,2);
insert into t1 values (4,3);
insert into t1 values (5,3);
insert into t1 values (6,4);

select * from t1;

delete from t1 where c1 = 1;
select * from t1;

delete from t1 where c1 >= 2;
select * from t1;

## 多个外键依赖，都允许级联删除
drop table t1;
create table t1 (c1 int primary key, c2 int, foreign key(c2) references t1(c1) on delete cascade);  
create table t2 (c1 int primary key, c2 int, foreign key(c2) references t2(c1) on delete cascade, foreign key(c2) references t1(c1) on delete cascade);

insert into t1 values (1,1);
insert into t1 values (2,1);

insert into t2 values (1,1);
insert into t2 values (2,1);

delete from t1 where c1 = 1;
select * from t1;
select * from t2;

## 外键依赖结合多表连接删除
drop table t2;
drop table t1;

create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, foreign key(c2) references t1(c1) on delete cascade);

insert into t1 values (1,1);
insert into t1 values (2,1);

insert into t2 values (1,1);
insert into t2 values (2,1);

delete from t1,t2 using t1,t2 where t1.c1 = t2.c2 and t1.c1 = 1;

select * from t1;
select * from t2;


## 多层外键嵌套结合多表join
drop table t2;
drop table t1;

create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, foreign key(c2) references t1(c1) on delete cascade);
create table t3 (c1 int primary key, c2 int, foreign key(c2) references t2(c1) on delete cascade);

insert into t1 values (1,1);
insert into t1 values (2,1);

insert into t2 values (1,1);
insert into t2 values (2,1);

insert into t3 values (1,1);
insert into t3 values (2,1);

delete from t1,t2,t3 using t1,t2, t3 where t1.c1 = t2.c2 and t3.c2 = t2.c1 and t1.c1 = 1;

select * from t1;
select * from t2;
select * from t3;

## 多层外键级联删除，join删除t1,t3， 级联删除t2,t3
drop table t3;
drop table t2;
drop table t1;

create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, foreign key(c2) references t1(c1) on delete cascade);
create table t3 (c1 int primary key, c2 int, foreign key(c2) references t2(c1) on delete cascade);

insert into t1 values (1,1);
insert into t1 values (2,1);

insert into t2 values (1,1);
insert into t2 values (2,1);

insert into t3 values (1,1);
insert into t3 values (2,1);

delete from t1,t3 using t1,t3 where t1.c1 = t3.c2 and t1.c1 = 1;

select * from t1;
select * from t2;
select * from t3;

## 外键依赖正交trig删除
drop table t3;
drop table t2;
drop table t1;

create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, foreign key(c2) references t1(c1) on delete cascade);

create trigger del_check before delete on t1 for each row delete from t2 where t2.c2 = 1;

insert into t1 values (1,1);
insert into t1 values (2,1);

insert into t2 values (1,1);
insert into t2 values (2,1);

delete from t1 where t1.c1 = 1;

select * from t1;
select * from t2;

## replace算子导致的外键自级联删除
drop table t2;
drop table t1;
create table t1 (c1 int primary key, c2 int, foreign key(c2) references t1(c1) on delete cascade);

insert into t1 values (1,1),(2,2);
insert into t1 values (3,2);
insert into t1 values (4,3);
insert into t1 values (5,3);
insert into t1 values (6,4);
select * from t1;

replace into t1 values (1,2);
select * from t1;

replace into t1 values (7,7);
replace into t1 values (2,7);
select * from t1;

## pdml结合外键级联删除
drop table t1;
create table t1 (c1 int primary key, c2 int, foreign key(c2) references t1(c1) on delete cascade) PARTITION BY HASH(c1);

insert into t1 values (1,1),(2,2);
insert into t1 values (3,2);
insert into t1 values (4,3);
insert into t1 values (5,3);
insert into t1 values (6,4);

select * from t1;

delete /*+parallel(2),enable_parallel_dml*/ from t1 where c1 = 1;
select * from t1;

delete /*+parallel(2),enable_parallel_dml*/ from t1 where c1 >= 2;
select * from t1;

## 多层嵌套叠加环状依赖的case
drop table t1;
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int, foreign key (c2) references t1 (c1) on delete cascade);
create table t3 (c1 int primary key, c2 int, foreign key (c2) references t2 (c1) on delete cascade);
create table t4 (c1 int primary key, c2 int, foreign key (c2) references t3 (c1) on delete cascade);

insert into t1 values (1,1),(2,2),(3,3);
insert into t2 values (1,1),(2,1),(3,2);
insert into t3 values (1,1),(2,2),(3,1);
insert into t4 values (1,1),(2,1),(3,1);

alter table t2 add constraint fk_1 foreign key (c2) references t4(c1) on delete cascade;
delete from t1 where c1 < 3;
select * from t1;
select * from t2;
select * from t3;
select * from t4;
alter table t2 drop constraint fk_1;

## 清除环境
drop table if exists t4;
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;

connection conn_admin;
alter system set_tp tp_no = 302, error_code = 20, frequency = 0;
connection default;