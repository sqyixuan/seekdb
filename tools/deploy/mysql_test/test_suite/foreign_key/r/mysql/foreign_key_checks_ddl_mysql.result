  CONSTRAINT `fk_tp1_tc4` FOREIGN KEY (`c1`, `c2`) REFERENCES `xf_foreign_key_checks_test_db`.`tp1`(`c1`, `c3`) ON UPDATE RESTRICT ON DELETE RESTRICT 
