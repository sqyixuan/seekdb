  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` int(11) DEFAULT NULL,
  CONSTRAINT `fk_tp1_tc3` FOREIGN KEY (`c1`, `c2`) REFERENCES `xf_foreign_key_checks_test_db`.`tp1`(`c1`, `c3`) ON UPDATE RESTRICT ON DELETE RESTRICT 
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
###### 引用一张已经存在的 mock 父表 tp1，此时仅推高 mock 父表 tp1 的 schema version 版本
create table tc4(c1 int, c2 int, c3 int, c4 int, constraint fk_tp1_tc4 foreign key(c1, c2) references tp1(c1, c3));
show create table tc4;
