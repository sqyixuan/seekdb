result_format: 4
drop database if exists xf_foreign_key_checks_test_db;
drop database if exists xf_foreign_key_checks_test_db_2;
create database xf_foreign_key_checks_test_db;
create database xf_foreign_key_checks_test_db_2;
use xf_foreign_key_checks_test_db;

## 测试当 foreign_key_checks 被设置成 off 时，MySQL 模式下外键的行为
set foreign_key_checks = off;

### 1. mock 父表生命周期的起始点
#### 1-1 在删子表之前先删父表，此时会创建这张 mock 父表 tp1
create table tp1(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2), unique key(c3, c4));
create table tc0(c1 int, c2 int, constraint fk_tp1_tc0 foreign key(c1, c2) references tp1(c1, c2));
create table tc1(c1 int, c2 int, constraint fk_tp1_tc1 foreign key(c1, c2) references tp1(c3, c4));
create table tc1_5(c1 int, c2 int, constraint fk_tp1_tc1_5 foreign key(c1, c2) references tp1(c3, c4));
drop table tp1;
##### 如果父表被删除之后把 foreign_key_checks 设置成 on，子表会因为外键而不能进行 insert 和 update
set foreign_key_checks = on;
insert into tc0 values(1, 2);
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
update tc0 set c1 = 123 where c2 = 2;
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
delete from tc0;
##### 如果父表被删除之后把 foreign_key_checks 设置成 off，子表不受外键影响可以执行 dml
set foreign_key_checks = off;
insert into tc0 values(1, 2);
update tc0 set c1 = 123 where c2 = 2;
delete from tc0;
show create table tc0;
Table	Create Table
tc0	CREATE TABLE `tc0` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  CONSTRAINT `fk_tp1_tc0` FOREIGN KEY (`c1`, `c2`) REFERENCES `xf_foreign_key_checks_test_db`.`tp1`(`c1`, `c2`) ON UPDATE RESTRICT ON DELETE RESTRICT 
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
show create table tc1;
Table	Create Table
tc1	CREATE TABLE `tc1` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  CONSTRAINT `fk_tp1_tc1` FOREIGN KEY (`c1`, `c2`) REFERENCES `xf_foreign_key_checks_test_db`.`tp1`(`c3`, `c4`) ON UPDATE RESTRICT ON DELETE RESTRICT 
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10

#### 1-2 在创建外键时引用了一张不存在的父表
##### 1-2-1 通过 create table 创建这种特殊外键
###### 引用一张不存在的 mock 父表 tp2，此时会创建这张 mock 父表 tp2
create table tc2(c1 int, c2 int, constraint fk_tp2_tc2 foreign key(c1, c2) references tp2(c1, c2));
show create table tc2;
Table	Create Table
tc2	CREATE TABLE `tc2` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  CONSTRAINT `fk_tp2_tc2` FOREIGN KEY (`c1`, `c2`) REFERENCES `xf_foreign_key_checks_test_db`.`tp2`(`c1`, `c2`) ON UPDATE RESTRICT ON DELETE RESTRICT 
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
###### 引用一张已经存在的 mock 父表 tp1，此时会在这张 mock 父表 tp1 上加新列 c3
create table tc3(c1 int, c2 int, c3 int, c4 int, constraint fk_tp1_tc3 foreign key(c1, c2) references tp1(c1, c3));
show create table tc3;
Table	Create Table
