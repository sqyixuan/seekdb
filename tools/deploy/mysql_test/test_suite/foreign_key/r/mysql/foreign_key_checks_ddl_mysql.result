###### 异常情况：mock 父表的列在 real 父表上不存在
create table tp11(c1 int, c2 int, c5 int, c6 int);
ERROR HY000: Cannot add foreign key constraint
###### 异常情况：mock 父表和 real 父表列类型不匹配
create table tp11(c1 varchar(10), c2 int, c3 varchar(10), c4 int, primary key(c1, c2), unique key(c3, c4));
ERROR HY000: Cannot add foreign key constraint
###### 异常情况：mock 父表上外键的外键列在 real 父表里不在主键或唯一索引上
create table tp11(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2));
ERROR HY000: Cannot add foreign key constraint
create table tp11(c1 int, c2 int, c3 int, c4 int, unique key(c3, c4));
ERROR HY000: Cannot add foreign key constraint
create table tp11(c1 int, c2 int, c3 int, c4 int, primary key(c1, c3), unique key(c2, c4));
ERROR HY000: Cannot add foreign key constraint
###### 正常情况
create table tp11(c4 int, c3 int, c2 int, c1 int, c5 int, primary key(c1, c2), unique key(c3, c4));
