drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
create table t1 (c1 int primary key, c2 int) partition by hash(c1) partitions 4;
create table t2 (c1 int ,c2 int, foreign key(c1) references t1(c1), foreign key(c2) references t1(c1));
insert into t1 values (1,1),(2,2),(3,3);
insert into t2 values (1,1),(2,2),(3,3);
select * from t2;
c1	c2
1	1
2	2
3	3
update t2 set c2 = c2 + 1;
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
update t2 set c1 = 1, c2 = 1 where c2 = 2;
select * from t2;
c1	c2
1	1
1	1
3	3
delete from t1;
ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails
delete from t2;
delete from t1;
drop table t2;
drop table t1;
