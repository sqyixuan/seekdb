drop database if exists xiaofeng_db;
create database xiaofeng_db;
use xiaofeng_db;
set @@recyclebin = on;
create table t1(c1 int primary key);
create table tr2(c1 int, constraint cons_name foreign key(c1) references t1(c1));
drop table tr2;
show create table tr2;
Table	Create Table
tr2	CREATE TABLE `tr2` (
  `c1` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
drop database xiaofeng_db;
