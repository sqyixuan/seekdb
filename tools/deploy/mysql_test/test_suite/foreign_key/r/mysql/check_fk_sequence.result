drop table if exists child;
drop table if exists parent;
alter system set debug_sync_timeout = '100000s';
create table parent(c1 int primary key, c2 int);
create table child(c1 int primary key, c2 int, foreign key(c2) references parent(c1));
insert into parent values(1, 1);
insert into child values(1, 1);
begin;
set session ob_query_timeout = 100000000;
set debug_sync = 'before_foreign_key_constraint_check wait_for select_time_out execute 10000';
delete from parent where c1 = 1;
begin;
set session ob_query_timeout = 2000000;
select * from parent where c1 = 1 for update;
ERROR HY000: Lock wait timeout exceeded; try restarting transaction
set debug_sync = 'now signal select_time_out';
ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails
set debug_sync = 'before_foreign_key_constraint_check clear';
rollback;
select * from parent;
c1	c2
1	1
select * from child;
c1	c2
1	1
begin;
set session ob_query_timeout = 100000000;
set debug_sync = 'before_foreign_key_constraint_check wait_for select_time_out execute 10000';
update child set c2 = 2 where c2 = 1;
begin;
set session ob_query_timeout = 2000000;
select * from child where c2 = 1 for update;
