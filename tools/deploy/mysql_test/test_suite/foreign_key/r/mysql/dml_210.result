set foreign_key_checks=on;
drop table if exists t1113, t1112, t1111, t111, t12, t11, t1;
create table t1(pk int, a int, b int, primary key (a), unique key uk_a_b (a, b) local)
partition by hash(a) partitions 3;
create table t11(pk int, a int, b int, primary key (a), unique key uk_a_b (a, b) local,
constraint foreign key (a, b) references t1 (a, b) on update CASCADE on delete CASCADE)
partition by hash(a) partitions 3;
create table t12(pk int, a int, b int, primary key (a), unique key uk_a_b (a, b) local,
constraint foreign key (a, b) references t1 (a, b) on update CASCADE on delete CASCADE)
partition by hash(a) partitions 3;
create table t111(pk int, a int, b int, primary key (a), unique key uk_a_b (a, b) local,
constraint foreign key (a, b) references t11 (a, b) on update CASCADE on delete CASCADE)
partition by hash(a) partitions 3;
create table t1111(pk int, a int, b int, primary key (a), unique key uk_a_b (a, b) local,
constraint foreign key (a, b) references t111 (a, b) on update CASCADE on delete CASCADE)
partition by hash(a) partitions 3;
create table t1112(pk int, a int, b int, primary key (a), unique key uk_a_b (a, b) local,
constraint foreign key (a, b) references t111 (a, b) on update CASCADE on delete CASCADE)
partition by hash(a) partitions 3;
create table t1113(pk int, a int, b int, primary key (a), unique key uk_a_b (a, b) local,
constraint foreign key (a, b) references t111 (a, b) on update CASCADE on delete CASCADE)
partition by hash(a) partitions 3;
