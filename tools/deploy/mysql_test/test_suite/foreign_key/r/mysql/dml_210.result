drop table if exists t2, t3, t4;
create table t2(pk int, a int, b int, c int, d int, primary key (a), unique key uk_a_b (a, b),
constraint foreign key (c, d) references t2 (a, b) on update CASCADE on delete CASCADE);
create table t3(pk int, a int, b int, c int, d int, primary key (a), unique key uk_a_b (a, b),
constraint foreign key (c, d) references t3 (a, b) on update CASCADE on delete CASCADE)
partition by hash(a) partitions 7;
create table t4(pk int, a int, b int, c int, d int, primary key (a), unique key uk_a_b (a, b) local,
constraint foreign key (c, d) references t4 (a, b) on update CASCADE on delete CASCADE)
partition by hash(a) partitions 7;
