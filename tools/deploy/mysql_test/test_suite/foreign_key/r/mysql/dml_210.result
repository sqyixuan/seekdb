create table t10 (`d1` date primary key);
create table t20 (dt2 datetime(2) primary key);
create table t30 (ts3 timestamp(3) primary key);
create table t11 (pk int primary key, d1 date, foreign key (d1) references t10 (`d1`));
create table t21 (pk int primary key, `dt2` datetime(2), foreign key (`dt2`) references t20 (dt2) on update cascade);
create table t31 (pk int primary key, ts3 timestamp(3), foreign key (ts3) references t30 (ts3) on delete cascade);
