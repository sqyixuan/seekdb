set foreign_key_checks=on;
drop table if exists t3, t2, t1;
drop table if exists t5, t4;
create table t1(a int primary key, b int, key t1_b(b), constraint foreign key (b) references t1 (a) on update CASCADE on delete CASCADE);
create table t2(a int primary key, b int, unique key t2_b(b), constraint foreign key (b) references t1 (a) on update CASCADE on delete CASCADE);
create table t3(a int primary key, b int, constraint foreign key (b) references t2 (b) on update CASCADE on delete CASCADE);
create table t4(a int primary key, b int, unique key t4_b(b), constraint foreign key (b) references t4 (a) on update CASCADE on delete CASCADE);
create table t5(a int primary key, b int, constraint foreign key (b) references t4 (b) on update CASCADE on delete CASCADE);
insert into t1 values (1, 1);
insert into t1 values (2, 1);
insert into t1 values (3, 1);
insert into t2 values (1, 1);
insert into t2 values (2, 2);
insert into t2 values (3, 3);
insert into t3 values (1, 1);
insert into t3 values (2, 2);
insert into t3 values (3, 3);

update t1 set a = 9 where a = 1;
