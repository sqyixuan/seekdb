create user if not exists __oceanbase_inner_drc_user;
grant all privileges on *.* to __oceanbase_inner_drc_user;
use test;
create table t1(c1 int, c2 int, c3 int, c4 int, constraint t1_pk1 primary key(c1, c2), constraint t1_uk1 unique(c3, c4));
create table t2(c1 int, c2 int, c3 int, c4 int);
insert into t2 values(1, 2, 3, 4);
alter table t2 add constraint fk1 foreign key(c1, c2) references t1(c1, c2);
ERROR HY000: cannot validate (test.fk1) - parent keys not found
alter table t2 add constraint fk2 foreign key(c3, c4) references t1(c3, c4);
ERROR HY000: cannot validate (test.fk2) - parent keys not found
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` int(11) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
delete from t2;
alter table t2 add constraint fk1 foreign key(c1, c2) references t1(c1, c2);
alter table t2 add constraint fk2 foreign key(c3, c4) references t1(c3, c4);
drop table t2;
drop table t1;
drop user __oceanbase_inner_drc_user;
