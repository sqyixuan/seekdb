--echo  ##################update##################
--disable_warnings
--error 0,942
DROP TABLE blob_test1;
--enable_warnings

create table blob_test1(s1 number primary key, s2 blob not null, s3 blob, s4 blob, s5 blob, s6 blob,check(length(s5) > 2)) compress;
#comment on table blob_test1 is 'blob类型测试表';
#comment on column blob_test1.s1 is '作为primary key使用';
#comment on column blob_test1.s6 is '作为分组建来使用';

insert into blob_test1(s1, s2, s3, s4, s5, s6) values(11, nvl('20191001', null), '20091001', '1999', 'abcdef', '2');
insert into blob_test1(s1, s2, s3, s4, s5, s6) values(12, '20191001', decode('', null, '20091001', '', '20001010'), '1999', 'abcdef', '2');
insert into blob_test1(s1, s2, s3, s4, s5, s6) values(13, '20191001', '20091001', substr('19991001',1,20), 'abcdef', '2');
insert into blob_test1(s1, s2, s3, s4, s5, s6) values(14, '20191001', '20091001', '1999', cast('19790321' as varchar2(10)), '2');
insert into blob_test1(s1, s2, s3, s4, s5, s6) values(15, 'aaaaaaa', 'BBBBBB', '1999', cast('19790321' as varchar2(10)), '2');
#select * from blob_test1;

