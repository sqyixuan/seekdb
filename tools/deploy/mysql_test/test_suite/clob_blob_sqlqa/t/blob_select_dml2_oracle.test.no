select nvl(s2, null) s2 from blob_test1;
--error 600
select substr(s3, 1, 4) s3 from blob_test1;
--error 00932
select s4+654321 s4 from blob_test1;
--error 00932
select s5*0 s5 from blob_test1;
#--error 600
#select upper(s2) s2 from blob_test1;
