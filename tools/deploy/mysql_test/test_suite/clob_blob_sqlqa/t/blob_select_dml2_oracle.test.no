#12      20191001        2009-10-01      1999/10/01 12:10:01     19891001 10:00:01       2
#13      20191001        2009-10-01      1999/10/01 06:00:00     19891001 10:00:01       2
#14      20191001        2009-10-01      1999/10/01 12:10:01     19790321        2
#15      aaaaaaa BBBBBB  1999/10/01 12:10:01     19790321        2

