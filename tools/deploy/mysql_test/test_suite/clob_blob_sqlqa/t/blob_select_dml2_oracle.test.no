select nvl(s5,'abcdef') s5 from blob_test1;
--error 00932,00600
select upper(nvl(s5,'abcdef')) s4 from blob_test1;
--error 00932,00600
select decode(s4, '', '空', '1999', s4) s4 from blob_test1;
select * from blob_test1 where s1< 15 and length(s2)>=2 ;
--error 00932,00600
select * from blob_test1 where to_number(s6)< 12 and length(s3)>=4;

