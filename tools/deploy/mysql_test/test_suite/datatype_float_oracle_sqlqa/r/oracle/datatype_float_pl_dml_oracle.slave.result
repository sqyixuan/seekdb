##创建测试用户
drop user zc_float_oracle_pl cascade;
create user zc_float_oracle_pl IDENTIFIED BY zc_float_oracle_pl;
grant all on *.* to zc_float_oracle_pl WITH GRANT OPTION;
grant dba to zc_float_oracle_pl;
result_format: 4
alter session set nls_date_format = 'yyyy-mm-dd';
alter session set nls_timestamp_format = 'yyyy-mm-dd hh24:mi:ss.ff';
###########dml############
##INSERT##
DROP TABLE ff01;//
CREATE TABLE ff01 (a float,b FLOAT(1),c float(10),d float(126));//
DECLARE
	aa float :=1.23456789;
	bb float(10) :=1.23456789;
	cc float(1) :=1.23456789;
	dd float(126) :=1.23456789;
BEGIN
	INSERT INTO ff01 VALUES (aa,aa,aa,aa);
	INSERT INTO ff01 VALUES (bb,bb,bb,bb);
	INSERT INTO ff01 VALUES (cc,cc,cc,cc);
	INSERT INTO ff01 VALUES (dd,dd,dd,dd);
END;
//
SELECT * FROM ff01;//
+------------+------+-------+------------+
| A          | B    | C     | D          |
+------------+------+-------+------------+
| 1.23456789 |    1 | 1.235 | 1.23456789 |
|      1.235 |    1 | 1.235 |      1.235 |
|          1 |    1 |     1 |          1 |
| 1.23456789 |    1 | 1.235 | 1.23456789 |
+------------+------+-------+------------+
CREATE VIEW vv01 AS SELECT * FROM ff01;//
DECLARE
	aa float :=1.23456789;
	bb float(10) :=1.23456789;
	cc float(1) :=1.23456789;
	dd float(126) :=1.23456789;
BEGIN
	INSERT INTO vv01 VALUES (aa,aa,aa,aa);
	INSERT INTO vv01 VALUES (bb,bb,bb,bb);
	INSERT INTO vv01 VALUES (cc,cc,cc,cc);
	INSERT INTO vv01 VALUES (dd,dd,dd,dd);
END;
//
SELECT * FROM vv01;//
