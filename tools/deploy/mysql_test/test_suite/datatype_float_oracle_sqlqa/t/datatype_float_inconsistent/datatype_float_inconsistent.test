#owner: zuojiao.hzj
#owner group: sql2
#description: datatype_float_pl_oracle_inconsistent
#tags: pl,datatype
#author: wb-zc01084078


##创建测试用户
--disable_warnings
--error 0,600
drop user zc_float_oracle_pl cascade;
--enable_warnings
create user zc_float_oracle_pl IDENTIFIED BY zc_float_oracle_pl;
grant all on *.* to zc_float_oracle_pl WITH GRANT OPTION;
grant dba to zc_float_oracle_pl;
--disable_query_log
--disable_result_log
--source mysql_test/include/check_schema_sync.inc
--enable_query_log
--enable_result_log
connect (conn,$OBMYSQL_MS0,zc_float_oracle_pl@oracle,zc_float_oracle_pl,zc_float_oracle_pl,$OBMYSQL_PORT);
connection conn;
--source output_print_enable.inc

alter session set nls_date_format = 'yyyy-mm-dd';
alter session set nls_timestamp_format = 'yyyy-mm-dd hh24:mi:ss.ff';

delimiter //;

##ob报错,oracle正常
DECLARE
	a float(5+5);
BEGIN
	a:=1.123456789;
	dbms_output.put_line(a);
END;
//

##ob报错，oracle正常
DECLARE
	a float(TRUNC(5.555));
BEGIN
	a:=1.123456789;
	dbms_output.put_line(a);
END;
//

##ob报错,oracle正常,bug:
DECLARE
	a float(1.23);
BEGIN
	a:=1.123456789;
	dbms_output.put_line(a);
END;
//

##ob保留37位。oracle保留38位
DECLARE
	a float;
BEGIN
	a:=1.234567898765432123456789876543212345678;
	dbms_output.put_line(a);
END;
//

DECLARE
	a float;
BEGIN
	a:=1.23456789876543212345678987654321234567;
	dbms_output.put_line(a);
END;
//

##ob结果为1,0,oracle报错
DECLARE
	a float;
BEGIN
	a:=TRUE;
	dbms_output.put_line(a);
END;
//

DECLARE
	a float;
BEGIN
	a:=FALSE;
	dbms_output.put_line(a);
END;
//

##结果不一致，obbug##
CREATE TABLE ff01 (a float(10));//
insert into ff01 values (1.23);//
DECLARE
	ddl_1 varchar(200);
BEGIN
	ddl_1 := 'alter table ff01 add b float(10) default 1.23456789';
	EXECUTE IMMEDIATE ddl_1;
END;
//
select * from ff01;//

##插入时间类型为null值时,oracle报错，ob可以插入##
DECLARE
	aa date := null;
BEGIN
	INSERT INTO ff01 VALUES (aa,aa,aa,aa);
END;
//
SELECT * FROM ff01;//

##ob与oracle结果不一致##
CREATE OR REPLACE PROCEDURE pro01(a IN int) AS
aa float := a ;
bb float(1) := a;
cc float(10) := a;
dd float(126) := a;
BEGIN
	dbms_output.put_line(aa);
	dbms_output.put_line(bb);
	dbms_output.put_line(cc);
	dbms_output.put_line(dd);
END;
//

CALL pro01('123.45678987654');//
SELECT print() FROM DUAL;//

##ob与oracle结果不一致##
DROP TABLE ff01;//
CREATE TABLE ff01 (a float , b float(1));//
CREATE OR REPLACE PROCEDURE pro01(aa IN ff01.b%type,bb OUT ff01.a%TYPE)AS
BEGIN
	bb:=aa;
END;
//
DECLARE
	aa float;
BEGIN
	pro01(123.456,aa);
	dbms_output.put_line(aa);
END;
//
SELECT print() FROM DUAL;//
##IN%TYPE问题##
CREATE OR REPLACE PROCEDURE pro01(aa in ff01.a%type,bb IN ff01.b%type)AS
BEGIN
	INSERT INTO ff01 VALUES (aa,aa);
	INSERT INTO ff01 VALUES (bb,bb);
END;
//
DECLARE
	aa float;
	bb char(10);
BEGIN
	pro01(TRUNC(123.456),NULL);
	pro01('123.456',123.456-654.321);
END;
//
SELECT * FROM ff01;//


delimiter ;//

--source output_print_disable.inc

connection default;
--disable_warnings
--error 0,600
drop user zc_float_oracle_pl cascade;
--enable_warnings
