# owner: jim.wjh
# owner group: 技术部-SQL-优化器
# tags: external_table
# description: test create external table

--result_format 4
--enable_sorted_result
--source mysql_test/test_suite/external_table3_sqlqa/include/copy_data_for_external_table.inc

connection default;
--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;
--enable_query_log

####不同hive表属性场景
####create as SELECT
create external table ex_t1(
a1 TINYINT as (get_path(external$filerow, 'c1')),
b2 SMALLINT as (get_path(external$filerow, 'c2')),
c3 INT as (get_path(external$filerow, 'c3')),
d4 BIGINT as (get_path(external$filerow, 'c4')),
e9 VARCHAR(50) as (get_path(external$filerow, 'c9')),
f10 VARCHAR(50) as (get_path(external$filerow, 'c10')),
g11 VARCHAR(50) as (get_path(external$filerow, 'c11')),
h12 VARBINARY(50) as (get_path(external$filerow, 'c12')),
i14 DATE as (get_path(external$filerow, 'c14')),
j7 DECIMAL(10,2) as (get_path(external$filerow, 'c7'))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data4/'
PATTERN = "000000_0$";

SELECT * from ex_t1;


####PARTITIONED BY
create external table ex_t2(
b VARCHAR(50) as (get_path(external$filerow, 'c2')),
c DATE as (get_path(external$filerow, 'c3'))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data5/'
PATTERN = "000000_0$";

SELECT * from ex_t2;


