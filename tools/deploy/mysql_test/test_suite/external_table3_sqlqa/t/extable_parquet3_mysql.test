a1 TINYINT as (get_path(external\$filerow, 'c1')),
b2 SMALLINT as (get_path(external\$filerow, 'c2')),
c3 INT as (get_path(external\$filerow, 'c3')),
d4 BIGINT as (get_path(external\$filerow, 'c4')),
e7 DECIMAL(10,2) as (get_path(external\$filerow, 'c7')),
f9 VARCHAR(50) as (get_path(external\$filerow, 'c9')),
g10 VARCHAR(50) as (get_path(external\$filerow, 'c10')),
h11 VARCHAR(50) as (get_path(external\$filerow, 'c11')),
i12 VARBINARY(50) as (get_path(external\$filerow, 'c12')),
