--error 0,1051
drop table ex_t2;
create external table ex_t2(
a1 VARCHAR(50) as (metadata$filecol9)
)
format (
    type = 'csv'
    FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true) location 'mysqltest_data_for_external_table3/data/external_data2/'
PATTERN = "000000_0$";

SELECT * from ex_t2;

--error 0,1051
drop table ex_t2;
create external table ex_t2(
a1 VARCHAR(50) as (get_path(external$filerow, 'c9'))
)
format (
    type = 'parquet'
    FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'BINARY'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true) location 'mysqltest_data_for_external_table3/data/external_data3/'
PATTERN = "^(?!.*\.crc$).*$";

SELECT * from ex_t2;


