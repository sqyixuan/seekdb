--result_format 4
--enable_sorted_result
--source mysql_test/test_suite/external_table3_sqlqa/include/copy_data_for_external_table.inc
--source mysql_test/include/oss_config_for_import.inc

connection default;
--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;
--enable_query_log


####жөӢиҜ•create external TABLE е…¶д»–зҡ„иЎЁеұһжҖ§(parquet)####

create external table ex_t1(
a1 TINYINT as (get_path(external$filerow, 'c1')),
b2 SMALLINT as (get_path(external$filerow, 'c2')),
c3 INT as (get_path(external$filerow, 'c3')),
d4 BIGINT as (get_path(external$filerow, 'c4')),
e7 DECIMAL(10,2) as (get_path(external$filerow, 'c7')),
f9 VARCHAR(50) as (get_path(external$filerow, 'c9')),
g10 VARCHAR(50) as (get_path(external$filerow, 'c10')),
h11 VARCHAR(50) as (get_path(external$filerow, 'c11')),
i12 VARBINARY(50) as (get_path(external$filerow, 'c12')),
j13 TIMESTAMP as (get_path(external$filerow, 'c13')),
k14 DATE as (get_path(external$filerow, 'c14'))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data2/'
PATTERN = "000000_0$";

SELECT * from ex_t1;

