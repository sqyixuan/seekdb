##special DATA
--error 0,1051
drop table ex_t15;

create external table ex_t15(
c1 TINYINT as (get_path(external$filerow, 'c1')),
c2 SMALLINT as (get_path(external$filerow, 'c2')),
c3 INT as (get_path(external$filerow, 'c3')),
c4 BIGINT as (get_path(external$filerow, 'c4')),
c9 VARCHAR(21) as (get_path(external$filerow, 'c9')),
c10 VARCHAR(20) as (get_path(external$filerow, 'c10')),
c11 VARCHAR(20) as (get_path(external$filerow, 'c11')),
c12 VARBINARY(21) as (get_path(external$filerow, 'c12')),
c14 DATE as (get_path(external$filerow, 'c14'))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data3/'
PATTERN = "^(?!.*\.crc$).*$";

SELECT * from ex_t15;

--error 0,1051
drop table ex_t15;

