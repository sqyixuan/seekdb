# owner: jim.wjh
# owner group: 技术部-SQL-优化器
# tags: external_table
# description: test create external table

--result_format 4
--enable_sorted_result
--source mysql_test/test_suite/external_table3_sqlqa/include/copy_data_for_external_table.inc

connection default;
--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;
--enable_query_log

##手动测试后修改文件路径


####basic test####
create external table ex_t1(
c1 int  as (get_path(external$filerow, 'c1')),
c2 int  as (get_path(external$filerow, 'c2')),
c3 varchar(50) as (get_path(external$filerow, 'c3')),
c4 DATE as (get_path(external$filerow, 'c4'))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data1/'
PATTERN = "000000_0$";

SELECT * from ex_t1;

create external table ex_t2(
c1 bigint as (get_path(external$filerow, 'int')),
c2 varchar(1000) as (get_path(external$filerow, 'string')),
c3 decimal(6,3) as (get_path(external$filerow, 'decimal32')),
c4 decimal as (get_path(external$filerow, 'decimal64')),
#c5 decimal(20,3) as (get_path(external$filerow, 'decimalbytearr')),
c6 date as (get_path(external$filerow, 'date')),
c7 timestamp as (get_path(external$filerow, 'timestamp'))
)  format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/'
PATTERN = 'parquet_cpp_example.parquet';

select * from ex_t2 limit 10;


####datatype####
##无符号整型对负数的处理有问题，已修复，目前不允许UNSIGNED类型
##INT32(INTEGER(8,true)
