###个别日期数据不一致（属于已知问题）
drop table ex_t16;
create external table ex_t16(
c1 INT as (get_path(external$filerow, 'c1')),
c2 varchar(10) as (get_path(external$filerow, 'c2')),
c3 date as (get_path(external$filerow, 'c3')),
c4 TIMESTAMP as (get_path(external$filerow, 'c4'))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data9/'
PATTERN = '^(?!.*\.crc$).*$';
SELECT * from ex_t16;
+------+------+------------+---------------------+
| c1   | c2   | c3         | c4                  |
+------+------+------------+---------------------+
|    1 | a    | 1501-01-09 | 1501-01-09 12:06:29 |
|    2 | B    | 1500-01-10 | 1500-01-09 23:54:17 |
|    3 | 中   | NULL       | NULL                |
|    4 |      | NULL       | NULL                |
|    5 | NULL | NULL       | NULL                |
|    6 | NULL | 2024-06-30 | 2024-06-30 00:00:00 |
|    7 | NULL | NULL       | NULL                |
|    8 | NULL | 2024-02-29 | 2024-02-29 00:00:00 |
|    9 | NULL | 2024-02-29 | 0001-01-01 23:59:17 |
