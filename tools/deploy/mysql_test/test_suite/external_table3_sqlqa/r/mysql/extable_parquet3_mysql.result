####OTHERS
drop table ex_t3;
create external table ex_t3(
c1 int as (get_path(external$filerow, 'c1')),
c2 int 
)
format (
    type = 'parquet'
	) location 'mysqltest_data_for_external_table3/data/external_data8/'
;
SELECT * from ex_t3;
