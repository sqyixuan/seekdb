result_format: 4
####测试create external TABLE 其他的表属性(parquet)####
create external table ex_t1(
a1 TINYINT as (get_path(external$filerow, 'c1')),
b2 SMALLINT as (get_path(external$filerow, 'c2')),
c3 INT as (get_path(external$filerow, 'c3')),
d4 BIGINT as (get_path(external$filerow, 'c4')),
e7 DECIMAL(10,2) as (get_path(external$filerow, 'c7')),
f9 VARCHAR(50) as (get_path(external$filerow, 'c9')),
g10 VARCHAR(50) as (get_path(external$filerow, 'c10')),
h11 VARCHAR(50) as (get_path(external$filerow, 'c11')),
i12 VARBINARY(50) as (get_path(external$filerow, 'c12')),
j13 TIMESTAMP as (get_path(external$filerow, 'c13')),
k14 DATE as (get_path(external$filerow, 'c14'))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data2/'
PATTERN = "000000_0$";
SELECT * from ex_t1;
+------+------+-------+--------+---------+---------+----------+-------+---------+---------------------+------------+
| a1   | b2   | c3    | d4     | e7      | f9      | g10      | h11   | i12     | j13                 | k14        |
+------+------+-------+--------+---------+---------+----------+-------+---------+---------------------+------------+
|    1 |  101 |  1001 |  10001 |  123.46 | string1 | varchar1 | char1 | binary1 | 2021-01-01 00:00:01 | 2021-01-01 |
|    3 |  103 |  1003 |  10003 |  789.01 | string3 | varchar3 | char3 | binary3 | 2021-01-03 00:00:03 | 2021-01-03 |
|    5 |  105 |  1005 |  10005 |  345.68 | string5 | varchar5 | char5 | binary5 | 2021-01-05 00:00:05 | 2021-01-05 |
|   -2 | -102 | -1002 | -10002 | -456.79 | string2 | varchar2 | char2 | binary2 | 2021-01-02 00:00:02 | 2021-01-02 |
|   -4 | -104 | -1004 | -10004 |  -12.35 | string4 | varchar4 | char4 | binary4 | 2021-01-04 00:00:04 | 2021-01-04 |
| NULL | NULL |  NULL |   NULL |    NULL | NULL    | NULL     | NULL  | NULL    | NULL                | NULL       |
+------+------+-------+--------+---------+---------+----------+-------+---------+---------------------+------------+
####函数嵌套外表的伪列
####not support
create external table ex_t2(
a1 TINYINT as (LOWER(get_path(external$filerow, 'c1')))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data2/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
ERROR HY000: not supported for generated columns
drop table ex_t2;
create external table ex_t2(
a1 TINYINT as (ABS(get_path(external$filerow, 'c1')))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data2/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
ERROR HY000: not supported for generated columns
####colname
drop table ex_t2;
create external table ex_t2(
a1 TINYINT as (get_path(external$filerow, NULL))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data2/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
ERROR 0A000: Not supported feature or function
drop table ex_t2;
create external table ex_t2(
a1 TINYINT as (get_path(external$filerow, ''))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data2/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
ERROR HY000: Invalid path: 
drop table ex_t2;
create external table ex_t2(
a1 TINYINT as (get_path(external$filerow, 'cc1'))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data2/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
ERROR HY000: Invalid path: cc1
####format
drop table ex_t2;
create external table ex_t2(
a1 VARCHAR(50) as (get_path(external$filerow, 'c9'))
)
format (type = 'csv') location 'mysqltest_data_for_external_table3/data/external_data2/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
ERROR HY000: Invalid argument
drop table ex_t2;
create external table ex_t2(
a1 VARCHAR(50) as (metadata$filecol1)
)
format (type = 'csv') location 'mysqltest_data_for_external_table3/data/external_data2/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
ERROR 22001: Data too long for column
drop table ex_t2;
create external table ex_t2(
a1 VARCHAR(50) as (metadata$filecol9)
)
format (type = 'csv') location 'mysqltest_data_for_external_table3/data/external_data2/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
+------+
| a1   |
+------+
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
+------+
drop table ex_t2;
create external table ex_t2(
a1 VARCHAR(50) as (metadata$filecol9)
)
format (
    type = 'csv'
    FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true) location 'mysqltest_data_for_external_table3/data/external_data2/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
+------+
| a1   |
+------+
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
+------+
drop table ex_t2;
create external table ex_t2(
a1 VARCHAR(50) as (get_path(external$filerow, 'c9'))
)
format (
    type = 'parquet'
    FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'BINARY'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true) location 'mysqltest_data_for_external_table3/data/external_data3/'
PATTERN = "^(?!.*\.crc$).*$";
SELECT * from ex_t2;
+------------------+
| a1               |
+------------------+
|                  |
| 1234567891       |
| 1234567891       |
| 12345678912      |
| _+{|:"<?,.       |
| ~!@#$%^&*)       |
| 中すāд￥         |
| 中すāд￥壹       |
+------------------+
