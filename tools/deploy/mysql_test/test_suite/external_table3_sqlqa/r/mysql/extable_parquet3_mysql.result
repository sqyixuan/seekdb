c1 TINYINT as (get_path(external$filerow, 'c1')),
c2 SMALLINT as (get_path(external$filerow, 'c2')),
c3 INT as (get_path(external$filerow, 'c3')),
c4 BIGINT as (get_path(external$filerow, 'c4')),
c7 DECIMAL(10,2) as (get_path(external$filerow, 'c7')),
c9 VARCHAR(50) as (get_path(external$filerow, 'c9')),
c10 VARCHAR(50) as (get_path(external$filerow, 'c10')),
c11 VARCHAR(50) as (get_path(external$filerow, 'c11')),
c12 VARBINARY(50) as (get_path(external$filerow, 'c12')),
