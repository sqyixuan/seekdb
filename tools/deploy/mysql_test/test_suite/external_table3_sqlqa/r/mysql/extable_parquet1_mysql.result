result_format: 4
##手动测试后修改文件路径
####basic test####
create external table ex_t1(
c1 int  as (get_path(external$filerow, 'c1')),
c2 int  as (get_path(external$filerow, 'c2')),
c3 varchar(50) as (get_path(external$filerow, 'c3')),
c4 DATE as (get_path(external$filerow, 'c4'))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data1/'
PATTERN = "000000_0$";
SELECT * from ex_t1;
+------+------+------+------+
| c1   | c2   | c3   | c4   |
+------+------+------+------+
|    1 |    1 | a    | NULL |
+------+------+------+------+
create external table ex_t2(
c1 bigint as (get_path(external$filerow, 'int')),
c2 varchar(1000) as (get_path(external$filerow, 'string')),
c3 decimal(6,3) as (get_path(external$filerow, 'decimal32')),
c4 decimal as (get_path(external$filerow, 'decimal64')),
#c5 decimal(20,3) as (get_path(external$filerow, 'decimalbytearr')),
c6 date as (get_path(external$filerow, 'date')),
c7 timestamp as (get_path(external$filerow, 'timestamp'))
)  format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/'
PATTERN = 'parquet_cpp_example.parquet';
select * from ex_t2 limit 10;
+---------------+------------+-------+-------+------------+---------------------+
| c1            | c2         | c3    | c4    | c6         | c7                  |
+---------------+------------+-------+-------+------------+---------------------+
|          NULL | parquet000 |  NULL |     0 | NULL       | 2024-05-28 17:12:45 |
|          NULL | parquet002 | 0.002 | 20000 | 2024-05-16 | 2024-05-28 19:12:45 |
|          NULL | parquet004 | 0.004 |  NULL | 2024-05-18 | NULL                |
|          NULL | parquet006 |  NULL | 60000 | NULL       | 2024-05-28 23:12:45 |
|          NULL | parquet008 | 0.008 | 80000 | 2024-05-22 | 2024-05-29 01:12:45 |
| 1000000000000 | NULL       | 0.001 |  NULL | 2024-05-15 | NULL                |
| 3000000000000 | NULL       |  NULL | 30000 | 2024-05-17 | 2024-05-28 20:12:45 |
| 5000000000000 | NULL       | 0.005 | 50000 | 2024-05-19 | 2024-05-28 22:12:45 |
| 7000000000000 | NULL       | 0.007 |  NULL | 2024-05-21 | NULL                |
| 9000000000000 | NULL       |  NULL | 90000 | 2024-05-23 | 2024-05-29 02:12:45 |
+---------------+------------+-------+-------+------------+---------------------+
####datatype####
##无符号整型对负数的处理有问题，已修复，目前不允许UNSIGNED类型
##INT32(INTEGER(8,true)
drop table ex_t1;
create external table ex_t1(
c1 TINYINT  as (get_path(external$filerow, 'c1')),
c2 TINYINT as (get_path(external$filerow, 'c1'))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data2/'
PATTERN = "000000_0$";
SELECT * from ex_t1;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    1 |
|    3 |    3 |
|    5 |    5 |
|   -2 |   -2 |
|   -4 |   -4 |
| NULL | NULL |
+------+------+
