create view v1 as select * from ta;
create materialized view mv3 refresh complete on demand as select * from v1;
drop materialized view mv3;
drop view v1;
drop materialized view mv2;
drop materialized view log on mv1;
drop materialized view mv1;
drop materialized view log on ta;
drop materialized view log on tb;
drop table ta;
drop table tb;
drop materialized view log on t2;
drop table t1;
drop table t2;
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create materialized view log on t2 with rowid (c1, c2) including new values;
insert into t1 values (1, 10), (2, 20), (3, 30), (4, 40), (5, 50), (6, 60), (7, 70), (8, 80), (9, 90);
insert /*+ append enable_parallel_dml parallel(2) */ into t2 select * from t1;
drop table t1;
drop materialized view log on t2;
drop table t2;
