select * from mv1;
ID_A	ID_B	NAME	AGE
1	1	jack	21
2	2	rose	19
3	3	mary	25
select * from mlog$_mv1;
ID_A	ID_B	NAME	AGE	SEQUENCE$$	DMLTYPE$$	OLD_NEW$$
call dbms_mview.refresh('mv2', 'f');
