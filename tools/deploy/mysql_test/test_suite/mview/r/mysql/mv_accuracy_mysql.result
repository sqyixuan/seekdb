result_format: 4

## issue: 
drop materialized view mv1;
drop materialized view log on t1;
drop table if exists t1;
create table t1 (c1 number(20) primary key, c2 number(20),c3 number(20));
insert into t1 values(-10,99,44);

create materialized view mv1 refresh complete on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3) * sum(c3)/c2 calc1, c2+sum(c3) calc2 from t1 group by c2;
desc mv1;
+--------+---------------+------+-----+---------+-------+
| Field  | Type          | Null | Key | Default | Extra |
+--------+---------------+------+-----+---------+-------+
| c2     | decimal(20,0) | YES  |     | NULL    |       |
| cnt    | bigint(20)    | YES  |     | NULL    |       |
| cnt_c3 | bigint(20)    | YES  |     | NULL    |       |
| sum_c3 | decimal(42,0) | YES  |     | NULL    |       |
| avg_c3 | decimal(24,4) | YES  |     | NULL    |       |
| calc1  | decimal(65,8) | YES  |     | NULL    |       |
| calc2  | decimal(43,0) | YES  |     | NULL    |       |
+--------+---------------+------+-----+---------+-------+

select * from mv1;
+------+------+--------+--------+---------+-------------+-------+
| c2   | cnt  | cnt_c3 | sum_c3 | avg_c3  | calc1       | calc2 |
+------+------+--------+--------+---------+-------------+-------+
|   99 |    1 |      1 |     44 | 44.0000 | 19.55555556 |   143 |
+------+------+--------+--------+---------+-------------+-------+

drop materialized view mv1;
drop table t1;
