set @@recyclebin = OFF;
drop database if exists test_mv_parallel;
create database test_mv_parallel;
use test_mv_parallel;
set ob_query_timeout = 10000000000;
set mview_refresh_dop = 0;
create table t1(c1 int, c2 int primary key);
create materialized view log on t1 with primary key (c1) including new values;
insert into t1 values(1,1);
insert into t1 values(2,2);
create materialized view mv1 parallel 2 refresh complete on demand as select * from t1;
# expect parallel = 2
select regexp_substr(query_sql, 'parallel\\((\\d+)\\)', 1, 1, 'i', 1) as p from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'INSERT /*+ append%' and hints_info like '%ENABLE_PARALLEL_DML%' order by LAST_ACTIVE_TIME desc limit 1;
p
2
set mview_refresh_dop = 3;
create materialized view mv2 refresh complete on demand as select * from t1;
# expect parallel = 3
select regexp_substr(query_sql, 'parallel\\((\\d+)\\)', 1, 1, 'i', 1) as p from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'INSERT /*+ append%' and hints_info like '%ENABLE_PARALLEL_DML%' order by LAST_ACTIVE_TIME desc limit 1;
p
3
set mview_refresh_dop = 0;
create materialized view mv3 refresh complete on demand as select * from t1;
# expect parallel = 2
select regexp_substr(query_sql, 'parallel\\((\\d+)\\)', 1, 1, 'i', 1) as p from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'INSERT /*+ append%' and hints_info like '%ENABLE_PARALLEL_DML%' order by LAST_ACTIVE_TIME desc limit 1;
p
2
call dbms_mview.refresh('mv1', 'c', refresh_parallel => 4);
# expect parallel = 4
select parallelism from oceanbase.__all_mview_refresh_run_stats where mviews = 'mv1' order by gmt_create desc limit 1;
parallelism
4
select regexp_substr(query_sql, 'parallel\\((\\d+)\\)', 1, 1, 'i', 1) as p from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'INSERT /*+ append%' and hints_info like '%ENABLE_PARALLEL_DML%' order by LAST_ACTIVE_TIME desc limit 1;
p
4
set mview_refresh_dop = 5;
call dbms_mview.refresh('mv2', 'c');
# expect parallel = 5
select parallelism from oceanbase.__all_mview_refresh_run_stats where mviews = 'mv2' order by gmt_create desc limit 1;
parallelism
5
select regexp_substr(query_sql, 'parallel\\((\\d+)\\)', 1, 1, 'i', 1) as p from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'INSERT /*+ append%' and hints_info like '%ENABLE_PARALLEL_DML%' order by LAST_ACTIVE_TIME desc limit 1;
p
5
set mview_refresh_dop = 0;
call dbms_mview.refresh('mv2', 'c');
# expect parallel = 1
select parallelism from oceanbase.__all_mview_refresh_run_stats where mviews = 'mv2' order by gmt_create desc limit 1;
parallelism
1
# expect parallel = 2
select regexp_substr(query_sql, 'parallel\\((\\d+)\\)', 1, 1, 'i', 1) as p from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'INSERT /*+ append%' and hints_info like '%ENABLE_PARALLEL_DML%' order by LAST_ACTIVE_TIME desc limit 1;
p
2
set global mview_refresh_dop = 6;
create materialized view mv4 parallel 7 refresh complete on demand start with sysdate() next sysdate() + interval 5 second as select * from t1;
# expect parallel = 7
select parallelism from oceanbase.__all_mview_refresh_run_stats where mviews = 'test_mv_parallel.mv4' order by gmt_create desc limit 1;
parallelism
7
create materialized view mv5 refresh complete on demand start with sysdate() next sysdate() + interval 5 second as select * from t1;
# expect parallel = 6
select parallelism from oceanbase.__all_mview_refresh_run_stats where mviews = 'test_mv_parallel.mv5' order by gmt_create desc limit 1;
parallelism
6
create materialized view mv6 refresh fast on demand as select count(*) cnt, c1 from t1 group by c1;
call dbms_mview.refresh('mv6', 'f', refresh_parallel => 8);
# expect parallel = 8
select parallelism from oceanbase.__all_mview_refresh_run_stats where mviews = 'mv6' order by gmt_create desc limit 1;
parallelism
8
set mview_refresh_dop = 9;
call dbms_mview.refresh('mv6', 'f');
# expect parallel = 9
select parallelism from oceanbase.__all_mview_refresh_run_stats where mviews = 'mv6' order by gmt_create desc limit 1;
parallelism
9
set mview_refresh_dop = 0;
call dbms_mview.refresh('mv6', 'f');
# expect parallel = 1
select parallelism from oceanbase.__all_mview_refresh_run_stats where mviews = 'mv6' order by gmt_create desc limit 1;
parallelism
1
set global mview_refresh_dop = 10;
create materialized view mv7 parallel 11 refresh fast on demand start with sysdate() next sysdate() + interval 5 second as select count(*) cnt, c1 from t1 group by c1;
# expect parallel = 11
select parallelism from oceanbase.__all_mview_refresh_run_stats where mviews = 'test_mv_parallel.mv7' order by gmt_create desc limit 1;
parallelism
11
create materialized view mv8 refresh fast on demand start with sysdate() next sysdate() + interval 5 second as select count(*) cnt, c1 from t1 group by c1;
# expect parallel = 10
select parallelism from oceanbase.__all_mview_refresh_run_stats where mviews = 'test_mv_parallel.mv8' order by gmt_create desc limit 1;
parallelism
10
set mview_refresh_dop = -1;
ERROR 42000: Variable 'mview_refresh_dop' can't be set to the value of '-1'
drop materialized view mv1;
drop materialized view mv2;
drop materialized view mv3;
drop materialized view mv4;
drop materialized view mv5;
drop materialized view mv6;
drop materialized view mv7;
drop materialized view mv8;
drop materialized view log on t1;
drop table t1;
drop database test_mv_parallel;
