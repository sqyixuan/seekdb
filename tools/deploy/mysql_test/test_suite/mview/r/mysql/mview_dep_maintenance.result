alter system set debug_sync_timeout = '100000s';
set ob_global_debug_sync = 'reset';
set recyclebin = OFF;
set ob_query_timeout = 10000000000;
drop database if exists test_mv_dep_main;
create database test_mv_dep_main;
use test_mv_dep_main;
create table t1(c1 int primary key, c2 int);
insert into t1 values(1, 1);
insert into t1 values(2, 2);
set ob_global_debug_sync = 'TABLE_REDEFINITION_REPLICA_BUILD wait_for signalxxx execute 10000';
create materialized view mv1 as select * from t1;
alter table t1 set parallel = 8;
set ob_global_debug_sync = 'now signal signalxxx';
set ob_global_debug_sync = 'reset';
ERROR HY000: Base tables are altered during the creation or complete refresh of materialized views, please try again when base tables have no ongoing DDL operations
drop database test_mv_dep_main;
