drop materialized view log on t1;
DROP TABLE IF EXISTS t1;
DROP MATERIALIZED VIEW IF EXISTS mv1;
CREATE TABLE t1 (
id int primary key,
name varchar(10),
age int
);
create materialized view mv1 refresh complete on demand as select * from t1;
desc mv1;
Field	Type	Null	Key	Default	Extra
id	int(11)	YES		NULL	
name	varchar(10)	YES		NULL	
age	int(11)	YES		NULL	
insert into mv1 values (1, 'Tom', 10);
ERROR 0A000: DML operation on materialized view (log) is not supported
update mv1 set age = age + 1;
ERROR 0A000: DML operation on materialized view (log) is not supported
delete from mv1;
ERROR 0A000: DML operation on materialized view (log) is not supported
drop materialized view mv1;
drop table t1;
