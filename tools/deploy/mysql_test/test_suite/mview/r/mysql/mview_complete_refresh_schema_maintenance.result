alter system set debug_sync_timeout = '100000s';
set ob_global_debug_sync = 'reset';
set recyclebin = OFF;
set ob_query_timeout = 10000000000;
drop database if exists test_mv_refresh_schema;
create database test_mv_refresh_schema;
use test_mv_refresh_schema;
create table t1(c1 int);
expect 1
select count(*) from oceanbase.__all_table_history a, oceanbase.__all_database b where a.database_id = b.database_id and b.database_name = 'test_mv_refresh_schema' and a.table_name = 't1';
count(*)
1
expect 0
select (table_mode >> 26) & 1 as referenced_by_mv from oceanbase.__all_table a, oceanbase.__all_database b where a.database_id = b.database_id and b.database_name = 'test_mv_refresh_schema' and table_name = 't1';
referenced_by_mv
0
create materialized view mv1 as select * from t1;
expect 2
select count(*) from oceanbase.__all_table_history a, oceanbase.__all_database b where a.database_id = b.database_id and b.database_name = 'test_mv_refresh_schema' and a.table_name = 't1';
count(*)
2
expect 1
select (table_mode >> 26) & 1 as referenced_by_mv from oceanbase.__all_table a, oceanbase.__all_database b where a.database_id = b.database_id and b.database_name = 'test_mv_refresh_schema' and table_name = 't1';
referenced_by_mv
1
call dbms_mview.refresh('mv1', 'c');
expect 2
select count(*) from oceanbase.__all_table_history a, oceanbase.__all_database b where a.database_id = b.database_id and b.database_name = 'test_mv_refresh_schema' and a.table_name = 't1';
count(*)
2
expect 1
select (table_mode >> 26) & 1 as referenced_by_mv from oceanbase.__all_table a, oceanbase.__all_database b where a.database_id = b.database_id and b.database_name = 'test_mv_refresh_schema' and table_name = 't1';
referenced_by_mv
1
create materialized view mv2 as select * from t1;
expect 2
select count(*) from oceanbase.__all_table_history a, oceanbase.__all_database b where a.database_id = b.database_id and b.database_name = 'test_mv_refresh_schema' and a.table_name = 't1';
count(*)
2
expect 1
select (table_mode >> 26) & 1 as referenced_by_mv from oceanbase.__all_table a, oceanbase.__all_database b where a.database_id = b.database_id and b.database_name = 'test_mv_refresh_schema' and table_name = 't1';
referenced_by_mv
1
drop materialized view mv1;
expect 2
select count(*) from oceanbase.__all_table_history a, oceanbase.__all_database b where a.database_id = b.database_id and b.database_name = 'test_mv_refresh_schema' and a.table_name = 't1';
count(*)
2
expect 1
select (table_mode >> 26) & 1 as referenced_by_mv from oceanbase.__all_table a, oceanbase.__all_database b where a.database_id = b.database_id and b.database_name = 'test_mv_refresh_schema' and table_name = 't1';
referenced_by_mv
1
drop materialized view mv2;
expect 3
select count(*) from oceanbase.__all_table_history a, oceanbase.__all_database b where a.database_id = b.database_id and b.database_name = 'test_mv_refresh_schema' and a.table_name = 't1';
count(*)
3
expect 0
select (table_mode >> 26) & 1 as referenced_by_mv from oceanbase.__all_table a, oceanbase.__all_database b where a.database_id = b.database_id and b.database_name = 'test_mv_refresh_schema' and table_name = 't1';
referenced_by_mv
0
drop database test_mv_refresh_schema;
