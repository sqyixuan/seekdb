alter system set debug_sync_timeout = '100000s';
set ob_global_debug_sync = 'reset';
set recyclebin = OFF;
set ob_query_timeout = 10000000000;
drop database if exists test_mv_diagnose;
create database test_mv_diagnose;
use test_mv_diagnose;
create table t1(c1 int primary key, c2 int);
create table t2(c1 int primary key, c2 int);
create table t3(c1 int primary key, c2 int);
create table t4(c1 int primary key, c2 int);
create materialized view log on t1 with primary key (c2);
create materialized view log on t2 with primary key (c2);
create materialized view log on t3 with primary key (c2);
create materialized view log on t4 with primary key (c2);
insert into t1 values(1, 1);
insert into t2 values(1, 1);
insert into t3 values(1, 1);
insert into t4 values(1, 1);
create materialized view mv1(c1, c2, primary key(c1)) refresh fast as select c1, count(*) c2 from t1 group by c1;
create materialized view log on mv1 with primary key (c2);
create materialized view mv2(c1, c2, primary key(c1)) refresh fast as select mv1.c1 c1, t2.c1 c2 from mv1, t2 where mv1.c1 = t2.c1;
create materialized view log on mv2 with primary key (c2);
create materialized view mv3(c1, c2, primary key(c1)) refresh fast as select t3.c1 c1, t4.c1 c2 from t3, t4 where t3.c1 = t4.c1;
create materialized view log on mv3 with primary key (c2);
create materialized view mv4(c1, c2, primary key(c1)) refresh fast as select mv2.c1 c1, mv3.c1 c2 from mv2, mv3 where mv2.c1 = mv3.c1;
call dbms_mview.refresh('mv1', 'f');
call dbms_mview.refresh('mv2', 'f');
call dbms_mview.refresh('mv3', 'f');
call dbms_mview.refresh('mv4', 'f');
res
1
res
