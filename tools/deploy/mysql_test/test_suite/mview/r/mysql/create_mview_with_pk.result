result_format: 4
drop table if exists t1;
drop table if exists t2;
drop materialized view t1_mv1;
drop materialized view t2_mv2;
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
insert into t1 values(1, 1, 10, 1), (2, 1, 11, 1), (4, 1, 12, 1), (3, 1, 13, 1);

create materialized view t1_mv1 ( primary key (c1) ) as
select * from t1;
desc t1_mv1;
