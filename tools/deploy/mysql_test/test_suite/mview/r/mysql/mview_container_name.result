alter system set debug_sync_timeout = '100000s';
set ob_global_debug_sync = 'reset';
set recyclebin = OFF;
set ob_query_timeout = 10000000000;
drop database if exists test_mv_container_name;
create database test_mv_container_name;
use test_mv_container_name;
create table t1(c1 int, c2 int);
create materialized view mv1 as select * from t1;
select count(*) from oceanbase.DBA_MVIEWS where OWNER = 'test_mv_container_name' and MVIEW_NAME = 'mv1' and CONTAINER_NAME like '__mv_container%';
count(*)
1
select count(*) from oceanbase.CDB_MVIEWS where OWNER = 'test_mv_container_name' and MVIEW_NAME = 'mv1' and CONTAINER_NAME like '__mv_container%';
count(*)
1
drop database test_mv_container_name;
