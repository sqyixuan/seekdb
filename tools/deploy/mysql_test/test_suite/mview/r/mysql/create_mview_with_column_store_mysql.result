result_format: 4
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
DROP MATERIALIZED VIEW IF EXISTS mv1;
DROP MATERIALIZED VIEW IF EXISTS mv2;
DROP MATERIALIZED VIEW IF EXISTS mv3;
DROP MATERIALIZED VIEW IF EXISTS mv4;
DROP MATERIALIZED VIEW IF EXISTS mv5;
CREATE TABLE t1 (arg1 int, arg2 int);
CREATE TABLE t2 (arg1 int, arg2 int);
CREATE MATERIALIZED VIEW mv1 AS SELECT t1.arg1 arg1, t2.arg1 arg2 FROM t1 JOIN t2;
CREATE MATERIALIZED VIEW mv2 WITH COLUMN GROUP (all columns) AS SELECT t1.arg1 arg1, t2.arg1 arg2 FROM t1 JOIN t2;
CREATE MATERIALIZED VIEW mv3 WITH COLUMN GROUP (each column) AS SELECT t1.arg1 arg1, t2.arg1 arg2 FROM t1 JOIN t2;
CREATE MATERIALIZED VIEW mv4 WITH COLUMN GROUP (all columns, each column) AS SELECT t1.arg1 arg1, t2.arg1 arg2 FROM t1 JOIN t2;
CREATE MATERIALIZED VIEW mv5 WITH COLUMN GROUP (each column, all columns) AS SELECT t1.arg1 arg1, t2.arg1 arg2 FROM t1 JOIN t2;

explain basic SELECT * FROM mv1;
