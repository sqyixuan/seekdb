# owner group: data
# tags:
# descriotion: 
# 创建嵌套mv的测试 
#

--disable_warnings
--source mysql_test/include/ignore_drop_mlog_err_oracle.inc
drop materialized view log on ta;
--source mysql_test/include/ignore_drop_mlog_err_oracle.inc
drop materialized view log on tb;
--source mysql_test/include/ignore_drop_mlog_err_oracle.inc
drop materialized view log on mv1;
--source mysql_test/include/ignore_drop_mview_err_oracle.inc
drop materialized view mv1;
--source mysql_test/include/ignore_drop_mview_err_oracle.inc
drop materialized view mv2;
--source mysql_test/include/ignore_drop_table_err.inc
drop table ta;
--source mysql_test/include/ignore_drop_table_err.inc
drop table tb;
--enable_warnings

create table ta(id int primary key, name varchar(30));
create table tb(id int primary key, age int);
insert into ta values (1, 'jack');
insert into tb values (1, 21);
create materialized view log on ta with primary key (name) including new values;
create materialized view log on tb with primary key (age) including new values;
create materialized view mv1 (primary key (id_a, id_b)) refresh fast on demand as select ta.id id_a, tb.id id_b, ta.name, tb.age from ta, tb where ta.id = tb.id;

create materialized view log on mv1 with primary key (name, age) including new values;
create materialized view mv2 refresh fast as select count(*) cnt, count(age) age_cnt, sum(age) age_sum  from mv1;
select * from mv1;
select * from mv2;
insert into ta values (2, 'rose');
insert into tb values (2, 19);

# fast refresh
call dbms_mview.refresh('mv1', 'f');
select * from mv1;
select * from mlog$_mv1;
call dbms_mview.refresh('mv2', 'f');
select * from mv2;
select * from mlog$_mv1;

# complete refresh to mview with mlog
insert into ta values (3, 'mary');
insert into tb values (3, 25);
call dbms_mview.refresh('mv1', 'f');
select * from mv1;
select * from mlog$_mv1;
call dbms_mview.refresh('mv1', 'c');
select * from mv1;
select * from mlog$_mv1;

# fast refresh changed to complete refresh
call dbms_mview.refresh('mv2', 'f');
select * from mv2;
# comple refresh gets correct result
call dbms_mview.refresh('mv2', 'c');
select * from mv2;

# mlog of mv1 is still available
insert into ta values (4, 'tom');
insert into tb values (4, 30);
call dbms_mview.refresh('mv1', 'f');
select * from mv1;
select * from mlog$_mv1;
call dbms_mview.refresh('mv2', 'f');
select * from mv2;
select * from mlog$_mv1;

# create materialized view on a normal view
create view v1 as select * from ta;
create materialized view mv3 refresh complete on demand as select * from v1;
drop materialized view mv3;
drop view v1;

drop materialized view mv2;
drop materialized view log on mv1;
drop materialized view mv1;
drop materialized view log on ta;
drop materialized view log on tb;
drop table ta;
drop table tb;

# direct load to a user table with mlog is not allowed
--disable_warnings
--source mysql_test/include/ignore_drop_mlog_err_oracle.inc
drop materialized view log on t2;
--source mysql_test/include/ignore_drop_table_err.inc
drop table t1;
--source mysql_test/include/ignore_drop_table_err.inc
drop table t2;
--enable_warnings
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create materialized view log on t2 with rowid (c1, c2) including new values;
insert into t1 values (1, 10), (2, 20), (3, 30), (4, 40), (5, 50), (6, 60), (7, 70), (8, 80), (9, 90);
insert /*+ append enable_parallel_dml parallel(2) */ into t2 select * from t1;
drop table t1;
drop materialized view log on t2;
drop table t2;