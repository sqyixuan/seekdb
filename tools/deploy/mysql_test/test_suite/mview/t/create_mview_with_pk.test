--enable_sorted_result
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test for create view with primary key
#tags: mview

--result_format 4
--enable_sorted_result

--disable_warnings
--error 0, 1146
drop table if exists t1;
--error 0, 1146
drop table if exists t2;
--error 0, 9757
drop materialized view t1_mv1;
--error 0, 9757
drop materialized view t2_mv2;
--enable_warnings

create table t1(c1 int primary key, c2 int, c3 int, c4 int);
insert into t1 values(1, 1, 10, 1), (2, 1, 11, 1), (4, 1, 12, 1), (3, 1, 13, 1);

create materialized view t1_mv1 ( primary key (c1) ) as
select * from t1;
desc t1_mv1;
show index from t1_mv1;
select * from t1_mv1;
drop materialized view t1_mv1;

create materialized view t1_mv1 (c1, c2, c3, c4, primary key (c1) ) as
select * from t1;
select * from t1_mv1;
drop materialized view t1_mv1;

--error 1062
create materialized view t1_mv1 ( primary key (c2) ) as
select * from t1;

--error 1072
create materialized view t1_mv1 (primary key (c5) ) as
select * from t1;

--error 1072
create materialized view t1_mv1 (c1, c2, c3, c4, primary key (c5) ) as
select * from t1;

create materialized view t1_mv1 ( primary key (c1, c2) ) as
select * from t1;
select * from t1_mv1;
drop materialized view t1_mv1;

create materialized view t1_mv1 ( primary key (c3, c2) ) as
select * from t1;
select * from t1_mv1;
drop materialized view t1_mv1;

create materialized view t1_mv1 ( primary key (c1) ) partition by hash(c1) partitions 2 as
select * from t1;
select * from t1_mv1 partition (p0);
drop materialized view t1_mv1;

create materialized view t1_mv1 partition by hash(c1) partitions 2 as
select * from t1;
select * from t1_mv1 partition (p0);
drop materialized view t1_mv1;

--error 1503
create materialized view t1_mv1 ( primary key (c1) ) partition by hash(c2) partitions 2 as
select * from t1;

create materialized view t1_mv1 ( primary key (c1) using btree ) as
select * from t1;
drop materialized view t1_mv1;

create materialized view t1_mv1 ( primary key (c1) using hash ) as
select * from t1;
drop materialized view t1_mv1;

create materialized view t1_mv1 ( primary key (c1) using btree comment 'mv-primary-key' ) as
select * from t1;
drop materialized view t1_mv1;

create materialized view t1_mv1 ( primary key (c1) using hash comment 'mv-primary-key' ) as
select * from t1;
drop materialized view t1_mv1;

create materialized view t1_mv1 ( primary key (c1) comment 'mv-primary-key' ) as
select * from t1;
drop materialized view t1_mv1;

# user table is heap table
create table t2 (c1 int, c2 int);
insert into t2 values (null, 10);
--error 1048
create materialized view t2_mv2 ( primary key (c1) ) as select * from t2;

drop table if exists t1;
drop table if exists t2;
