--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: lana.lgx

connect (oracle,$OBMYSQL_MS0,SYS@oracle,,SYS,$OBMYSQL_PORT);
connection oracle;

--disable_warnings
--error 0,12003
drop materialized view mv;
--error 0,23413,942
drop materialized view log on t1;
--error 0,23413,942
drop materialized view log on t2;
--error 0,942
drop table t1;
--error 0,942
drop table t2;

create table t1(a int primary key, b int) partition by hash(a) partitions 4;
create table t2(c int primary key, d int) partition by hash(c) partitions 4;
create materialized view log on t1 parallel 7 with primary key, rowid, sequence (b) including new values;
create materialized view log on t2 parallel 7 with primary key, rowid, sequence (d) including new values;

CREATE MATERIALIZED VIEW mv(a,b,c,d)  parallel 10 partition by hash(a) subpartition by hash(b) (   partition hp0   (     subpartition hp0sp0, subpartition hp0sp1  ),   partition hp1   (     subpartition hp1sp0,  subpartition hp1sp1 )) as  select t1.a, t1.b, t2.c, t2.d from t1 join t2 on t1.a = t2.c;

create index idx on mv(b) local;

select * from ALL_PART_TABLES where table_name='MV' order by 1,2,3,4,5,6,7;
select * from USER_PART_TABLES where table_name='MV' order by 1,2,3,4,5,6,7;
select * from DBA_PART_TABLES where table_name='MV' order by 1,2,3,4,5,6,7;
select * from DBA_TAB_SUBPARTITIONS where table_name='MV' order by 1,2,3,4,5,6,7;
select * from DBA_TAB_PARTITIONS where table_name='MV' order by 1,2,3,4,5,6,7;
--replace_column 3 "table_id" 9 "tablet_id" 10 "ls_id" 12 "ip" 13 "port" 18 "object_id"
select * from DBA_OB_TABLE_LOCATIONS where table_name='MV' and role='LEADER' order by 1,2,3,4,5,6,7;
select * from DBA_PART_INDEXES where table_name='MV' order by 1,2,3,4,5,6,7;
select * from ALL_INDEXES where table_name='MV' order by 1,2,3,4,5,6,7;
select * from USER_INDEXES where table_name='MV' order by 1,2,3,4,5,6,7;
select * from DBA_INDEXES where table_name='MV' order by 1,2,3,4,5,6,7;
select * from USER_IND_COLUMNS where table_name='MV' order by 1,2,3,4,5,6,7;
select * from ALL_IND_COLUMNS where table_name='MV' order by 1,2,3,4,5,6,7;
select * from DBA_IND_COLUMNS where table_name='MV' order by 1,2,3,4,5,6,7;

--error 0,23413
drop materialized view log on t1;
--error 0,23413,942
drop materialized view log on t2;
--error 0,12003,942
drop materialized view mv;
--error 0,942
drop table t1;
--error 0,942
drop table t2;
