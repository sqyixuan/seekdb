) ORGANIZATION INDEX
partition by hash ( col_1350 ) partitions 5;

create materialized view log on tbl_400 with primary key, rowid, sequence (col_1348, col_1351) including new values;

desc mlog$_tbl_400;

insert into tbl_400 values(1,1,1,1);
insert into tbl_400 values(2,2,2,2);
