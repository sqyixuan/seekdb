# owner: guohanyun.ghy
# owner group: SQL1
# tags: mview
# descriotion: test the build mlog for each type of basic table

--disable_warnings
drop database if exists test_build_mlog;
--enable_warnings
create database test_build_mlog;
use test_build_mlog;

--result_format 4

create table tbl_100 (
  col_1348 int ( 20 ) ,
  col_1349 char ( 132 ) not null default 'OH9T' ,
  col_1350 tinyint ,
  col_1351 blob ( 286 ) not null ,
  key idx_189 ( col_1349 , col_1348 , col_1350 ) local
) ORGANIZATION INDEX
partition by hash ( col_1350 ) partitions 5;

create materialized view log on tbl_100 with primary key, rowid, sequence (col_1348, col_1349, col_1350, col_1351) including new values;

desc mlog$_tbl_100;

insert into tbl_100 values(1,1,1,1);
insert into tbl_100 values(2,2,2,2);
insert into tbl_100 values(3,3,3,3);
insert into tbl_100 values(NULL,1,NULL,1);
insert into tbl_100 values(NULL,2,NULL,2);

select * from mlog$_tbl_100;

delete from tbl_100 where col_1348 = 1;
update tbl_100 set col_1350 = NULL where col_1348 = 3;
update tbl_100 set col_1348 = 9 where col_1349 like '1';

select * from mlog$_tbl_100;



create table tbl_200 (
  col_1348 int ( 20 ) ,
  col_1349 char ( 132 ) not null default 'OH9T' ,
  col_1350 tinyint ,
  col_1351 blob ( 286 ) not null ,
  primary key (col_1350, col_1349)
) ORGANIZATION INDEX
partition by hash ( col_1350 ) partitions 5;

create materialized view log on tbl_200 with primary key, rowid, sequence (col_1348, col_1351) including new values;

desc mlog$_tbl_200;

insert into tbl_200 values(1,1,1,1);
insert into tbl_200 values(2,2,2,2);
insert into tbl_200 values(3,3,3,3);
insert into tbl_200 values(NULL,4,1,4);
insert into tbl_200 values(NULL,5,2,5);

select * from mlog$_tbl_200;

delete from tbl_200 where col_1348 = 1;
update tbl_200 set col_1350 = 5 where col_1348 = 3;
update tbl_200 set col_1348 = 9 where col_1349 like '1';

select * from mlog$_tbl_200;



create table tbl_300 (
  col_1348 int ( 20 ) ,
  col_1349 char ( 132 ) not null default 'OH9T' ,
  col_1350 tinyint ,
  col_1351 blob ( 286 ) not null ,
  key idx_189 ( col_1349 , col_1348 , col_1350 ) local
) ORGANIZATION HEAP
partition by hash ( col_1350 ) partitions 5;

create materialized view log on tbl_300 with primary key, rowid, sequence (col_1348, col_1349, col_1350, col_1351) including new values;

desc mlog$_tbl_300;

insert into tbl_300 values(1,1,1,1);
insert into tbl_300 values(2,2,2,2);
insert into tbl_300 values(3,3,3,3);
insert into tbl_300 values(NULL,1,NULL,1);
insert into tbl_300 values(NULL,2,NULL,2);

select * from mlog$_tbl_300;

delete from tbl_300 where col_1348 = 1;
update tbl_300 set col_1350 = NULL where col_1348 = 3;
update tbl_300 set col_1348 = 9 where col_1349 like '1';

select * from mlog$_tbl_300;



create table tbl_400 (
  col_1348 int ( 20 ) ,
