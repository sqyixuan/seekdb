#owner: lana.lgx
#owner group: data
#description: xxx_MVIEWS views
#tags: mview
#author: suzhi.yt

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--disable_query_log
let $current_tenant_id = query_get_value(select effective_tenant_id() x, x, 1);
set ob_query_timeout = 1000 * 1000 * 1000;
use test;
--source mysql_test/include/ignore_drop_mlog_err_mysql.inc
drop materialized view log on t1;
--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
drop materialized view if exists mv2;
drop sequence if exists s1;
--enable_warnings
--enable_query_log

create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create materialized view log on t1 with primary key, sequence (c2, c3) including new values;
create materialized view mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
create materialized view mv2 as select * from t1;
create sequence s1 cache 1000000 noorder;
call dbms_mview_stats.set_mvref_stats_params('mv1', 'NONE', 31);
call dbms_mview_stats.set_mvref_stats_params('mv2', 'NONE', 31);

select OWNER,MVIEW_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL from oceanbase.DBA_MVIEWS where OWNER = 'test' AND MVIEW_NAME IN ('mv1', 'mv2') ORDER BY MVIEW_NAME;
connection sys;
--echo select OWNER,MVIEW_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL from oceanbase.CDB_MVIEWS where OWNER = 'test' AND MVIEW_NAME IN ('mv1', 'mv2') ORDER BY MVIEW_NAME;
--disable_query_log
eval select OWNER,MVIEW_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL from oceanbase.CDB_MVIEWS where OWNER = 'test' AND MVIEW_NAME IN ('mv1', 'mv2') ORDER BY MVIEW_NAME;
--enable_query_log
connection default;

# issue/54620448
insert into t1 select s1.nextval, s1.nextval, s1.nextval, s1.nextval from table(generator(100000));
call dbms_mview.refresh('mv1');
call dbms_mview.refresh('mv2');

select OWNER,MVIEW_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL,TIMESTAMPDIFF(SECOND, LAST_REFRESH_DATE, LAST_REFRESH_END_TIME) < 10 from oceanbase.DBA_MVIEWS where OWNER = 'test' AND MVIEW_NAME IN ('mv1', 'mv2') ORDER BY MVIEW_NAME;
connection sys;
--echo select OWNER,MVIEW_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL,TIMESTAMPDIFF(SECOND, LAST_REFRESH_DATE, LAST_REFRESH_END_TIME) < 10 from oceanbase.CDB_MVIEWS where OWNER = 'test' AND MVIEW_NAME IN ('mv1', 'mv2') ORDER BY MVIEW_NAME;
--disable_query_log
eval select OWNER,MVIEW_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL,TIMESTAMPDIFF(SECOND, LAST_REFRESH_DATE, LAST_REFRESH_END_TIME) < 10 from oceanbase.CDB_MVIEWS where OWNER = 'test' AND MVIEW_NAME IN ('mv1', 'mv2') ORDER BY MVIEW_NAME;
--enable_query_log
connection default;

drop materialized view log on t1;
drop table t1;
drop materialized view mv1;
drop materialized view mv2;
drop sequence s1;
