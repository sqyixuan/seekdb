# owner: zg410411
# owner group: mv
# tags: 
# descriotion: purge the mlog of a materialized view
#

# 0. prepare
set recyclebin = OFF;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database if exists test_mv_purge_mlog;
--enable_warnings
create database test_mv_purge_mlog;
use test_mv_purge_mlog;

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test_mv_purge_mlog,$OBMYSQL_PORT);

# 1. test the mlog of a materialized view can be purged successfully
create table t1(c1 int);
create materialized view log on t1 with (c1);
create materialized view mv1 refresh fast as select count(*) cnt, c1 from t1 group by c1;
create materialized view log on mv1 with (c1);
insert into t1 values(1),(2),(3);
call dbms_mview.refresh('mv1', 'f');
select * from mlog$_mv1 order by c1;
call dbms_mview.purge_log('mv1');
select * from mlog$_mv1;

# 2. clean up
drop database test_mv_purge_mlog;
