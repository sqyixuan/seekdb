--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: guohanyun.ghy
#owner group: SQL1
#description: test for create view with null values
#tags: mview

--result_format 4

--disable_warnings
--error 0, 1146
drop table if exists t0;
--error 0, 1146
drop table if exists t1;
--error 0, 1146
drop table if exists t2;
--error 0, 1146, 9755
drop materialized view log on ZC_T1;
--error 0, 1146
drop table if exists ZC_T1;
--error 0, 9757
drop materialized view mv1;
--error 0, 9757
drop materialized view mv2;
--error 0, 9757
drop materialized view mv3;
--error 0, 9757
drop materialized view ZC_MV1;


--enable_warnings

create table t0 (c1 int primary key, c2 int);
insert into t0 values (1,2);

create table t1 (c1 int primary key, c2 int);
insert into t1 values (1,2);
insert into t1 values (2,3);

create table t2 (c1 int primary key, c2 int);
insert into t2 values (1,2);
insert into t2 values (3,4);

create materialized view mv1 as select t1.c2, t2.c1 from t1 left join t2 on t1.c1 = t2.c1;
select * from mv1 order by c2;
desc mv1;


create materialized view mv2 (primary key (c1)) as select t0.c2, t2.c1 from t0 left join t2 on t0.c1 = t2.c1;
desc mv2;
insert into t0 values (2,3);
--error 1048
call dbms_mview.refresh('mv2');


--error 1048
create materialized view mv3 (primary key (c1)) as select t1.c2, t2.c1 from t1 left join t2 on t1.c1 = t2.c1;

create materialized view mv3 (primary key (c2)) as select t1.c2, t2.c1 from t1 left join t2 on t1.c1 = t2.c1;
desc mv3;



CREATE TABLE ZC_T1(pk int primary key, c1 int, c2 int, c3 int);
CREATE MATERIALIZED VIEW LOG ON ZC_T1 parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c1,c2,c3) INCLUDING NEW VALUES;
INSERT INTO ZC_T1 VALUES(1,1,1,1);

create materialized view ZC_MV1 REFRESH FAST ON DEMAND enable on query computation AS select SUM(pk) AS su,COUNT(pk) as cnt from ZC_T1 ZT1 WHERE zt1.pk = 0;
desc ZC_MV1;


drop table t0;
drop table t1;
drop table t2;
drop materialized view log on ZC_T1;
drop table ZC_T1;
drop materialized view mv1;
drop materialized view mv2;
drop materialized view mv3;
drop materialized view ZC_MV1;