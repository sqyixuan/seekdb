# owner: lana.lgx
# owner group: data

--disable_warnings
--source mysql_test/include/ignore_drop_mlog_err_mysql.inc
drop materialized view log on t1;
DROP TABLE IF EXISTS t1;
DROP MATERIALIZED VIEW IF EXISTS mv1;
--enable_warnings
CREATE TABLE t1 (
  id int primary key,
  name varchar(10),
  age int
);

# create mview on table
create materialized view mv1 refresh complete on demand as select * from t1;
desc mv1;

# insert data to mview directly is not supported
--error 1235
insert into mv1 values (1, 'Tom', 10);

# update data of mview is not supported
--error 1235
update mv1 set age = age + 1;

# delete data from mview directly is not supported
--error 1235
delete from mv1;

--disable_query_log
--disable_result_log
explain basic insert into mv1 values (1, 'Tom', 10);
explain basic update mv1 set age = age + 1;
explain basic delete from mv1;
--enable_query_log
--enable_result_log

#cleanup
drop materialized view mv1;
drop table t1;