#owner: lana.lgx
#owner group: data

--disable_warnings
--source mysql_test/include/ignore_drop_mlog_err_mysql.inc
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t3;
DROP MATERIALIZED VIEW IF EXISTS mv1;
DROP MATERIALIZED VIEW IF EXISTS mv2;
--enable_warnings
CREATE TABLE t1 (
  id int primary key,
  name varchar(10),
  age int
);
insert into t1 values (1, 'Tom', 10), (2, 'Lucy', 20);
# table mode flag is unset
select table_name, table_mode from oceanbase.__all_table where table_name='t1';

# 1. create mview on table
create materialized view mv1 refresh complete on demand as select * from t1;
create materialized view mv2 refresh complete on demand as select * from t1;
--sorted_result
select * from mv1;
--sorted_result
select * from mv2;
# table_mode flag will be set
select table_name, table_mode from oceanbase.__all_table where table_name='t1';
# dependency info of mv1-t1, mv2-t1 will be created
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name='t1');
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv1');
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv2');

# 2. refresh mview
insert into t1 values (3, 'Mary', 30), (4, 'Jack', 40);
call dbms_mview.refresh('mv1');
call dbms_mview.refresh('mv2');
--sorted_result
select * from mv1;
--sorted_result
select * from mv2;
# nothing will be changed
select table_name, table_mode from oceanbase.__all_table where table_name='t1';
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name='t1');
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv1');
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv2');

# 3. do offline ddl to t1
drop table t1;
CREATE TABLE t1 (
  id int primary key,
  name varchar(10),
  age int
);
insert into t1 values (5, 'Grace', 50), (6, 'Rose', 60);
# table id has been changed, table_mode flag will be reset
select table_name, table_mode from oceanbase.__all_table where table_name='t1';
# the dependency info of the new t1 does not exist, while the old dependency info of mviews still exists
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name='t1');
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv1');
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv2');

# 4. refresh mv1
call dbms_mview.refresh('mv1');
--sorted_result
select * from mv1;
# table_mode flag will be set again
select table_name, table_mode from oceanbase.__all_table where table_name='t1';
# the dependency info of mv1-t1 will be updated, while the dependency info of mv2-t1 will not be updated
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name='t1');
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv1');
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv2');

# 5. refresh mv2
call dbms_mview.refresh('mv2');
--sorted_result
select * from mv2;
# table_mode flag has already been set
select table_name, table_mode from oceanbase.__all_table where table_name='t1';
# the dependency info of mv1-t1 has already been updated, the dependency info of mv2-t1 will be updated
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name='t1');
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv1');
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv2');

# 6. drop mv1
drop materialized view mv1;
# table_mode flag will not be reset because t1 is still referenced by mv2
select table_name, table_mode from oceanbase.__all_table where table_name='t1';
# the dependency info of mv1-t1 will be deleted
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name='t1');
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv1');
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv2');

# 7. drop mv2
drop materialized view mv2;
# table_mode flag will be reset
select table_name, table_mode from oceanbase.__all_table where table_name='t1';
# the dependency info of mv2-t1 will be deleted
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name='t1');
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv2');

# multiple base tables
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t3;
CREATE TABLE t1 (
  id int primary key,
  name varchar(10),
  age int
);
CREATE TABLE t2 (
  id int primary key,
  name varchar(10),
  age int
);
CREATE TABLE t3 (
  id int primary key,
  name varchar(10),
  age int
);
insert into t1 values (1, 'Tom1', 10), (2, 'Lucy1', 20);
insert into t2 values (1, 'Tom2', 10), (2, 'Lucy2', 20);
insert into t3 values (1, 'Tom3', 10), (2, 'Lucy3', 20);
# table mode flag is unset
select table_name, table_mode from oceanbase.__all_table where table_name in ('t1', 't2', 't3');
# mview dependency info is empty
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t1', 't2', 't3'));

create materialized view mv1 refresh complete on demand as select t1.id id1, t1.name name1, t1.age age1, t2.id id2, t2.name name2, t2.age age2 from t1, t2;
create materialized view mv2 refresh complete on demand as select t2.id id2, t2.name name2, t2.age age2, t3.id id3, t3.name name3, t3.age age3 from t2, t3;
--sorted_result
select * from mv1;
--sorted_result
select * from mv2;
# table_mode flag will be set
select table_name, table_mode from oceanbase.__all_table where table_name in ('t1', 't2', 't3');
# dependency info of mv1 and mv2 will be created
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t1'));
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t2'));
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t3'));
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv1');
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv2');

# rename base table
rename table t1 to t11;
# t11's table_mode flag still exists, original t1's dependency info still exists
select table_name, table_mode from oceanbase.__all_table where table_name in ('t11');
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t11'));
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv1');

# rename back
rename table t11 to t1;
# t11's table_mode flag still exists, original t1's dependency info still exists
select table_name, table_mode from oceanbase.__all_table where table_name in ('t1');
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t1'));
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv1');

# switch table t1 and t2's name
rename table t1 to t4;
rename table t2 to t1;
rename table t4 to t2;
# t1 and t2's table_mode, dependency info still exists
select table_name, table_mode from oceanbase.__all_table where table_name in ('t1');
select table_name, table_mode from oceanbase.__all_table where table_name in ('t2');

select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t1'));
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t2'));
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv1');

# complete refresh for mv1
call dbms_mview.refresh('mv1');
# mv1's content has been changed from original t1 + original t2 to original t2 + original t1
--sorted_result
select * from mv1;
# the p_order of dependency info has been changed for t1 and t2
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t1'));
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t2'));
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t3'));
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv1');

# complete refresh for mv2
call dbms_mview.refresh('mv2');
# mv2's content has been changed from original t2 + original t3 to original t1 + original t3
--sorted_result
select * from mv2;
# the p_order of dependency info has been changed for t1 and t2
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t1'));
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t2'));
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t3'));
select p_order, p_type from oceanbase.__all_mview_dep where mview_id in (select table_id from oceanbase.__all_table where table_name='mv2');

# drop mv1
drop materialized view mv1;
# the table_mode flag and dependency info of t1 will be cleared
select table_name, table_mode from oceanbase.__all_table where table_name in ('t1');
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t1'));
# the table_mode flag of t2 will not be cleared, the dependency info between mv1-t2 will be removed
select table_name, table_mode from oceanbase.__all_table where table_name in ('t2');
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t2'));

# drop mv2
drop materialized view mv2;
# the table_mode flag and dependency info of t2 will be cleared
select table_name, table_mode from oceanbase.__all_table where table_name in ('t2');
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t2'));
# the table_mode flag and dependency info of t3 will be cleared
select table_name, table_mode from oceanbase.__all_table where table_name in ('t3');
select p_order, p_type from oceanbase.__all_mview_dep where p_obj in (select table_id from oceanbase.__all_table where table_name in ('t3'));

#cleanup
drop table t1;
drop table t2;
drop table t3;
