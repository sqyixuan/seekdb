--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: zhanyue.zzy
# owner group: sql1
# tags: 
# descriotion: materialized view accuracy test
#

--result_format 4


## issue: 

--disable_warnings
--source mysql_test/include/ignore_drop_mview_err_mysql.inc
drop materialized view mv1;
--source mysql_test/include/ignore_drop_mlog_err_mysql.inc
drop materialized view log on t1;
drop table if exists t1;
--enable_warnings

create table t1 (c1 number(20) primary key, c2 number(20),c3 number(20));
insert into t1 values(-10,99,44);

create materialized view mv1 refresh complete on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3) * sum(c3)/c2 calc1, c2+sum(c3) calc2 from t1 group by c2;
desc mv1;

--sorted_result
select * from mv1;

drop materialized view mv1;
drop table t1;
