#owner: wyh329796 
#owner group: data
#description: 
#tags: mview

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--disable_query_log
let $current_tenant_id = query_get_value(SELECT effective_tenant_id() x, x, 1);
use test;
--source mysql_test/include/ignore_drop_mlog_err_mysql.inc
drop materialized view log on t1;
--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
drop materialized view if exists mv2;
drop materialized view if exists mv3;
--enable_warnings
--enable_query_log

create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create materialized view log on t1 with primary key, sequence (c2, c3) including new values;
create materialized view mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;


connection sys;
alter system set_tp tp_name = ERRSIM_MVIEW_REFRESH, error_code = 4023, frequency = 1;

connection default;
send call dbms_mview.refresh('mv1');

sleep 10;

connection sys;
alter system set_tp tp_name = ERRSIM_MVIEW_REFRESH, error_code = 4023, frequency = 0;

sleep 5;
connection default;
reap;
let $mview_id = query_get_value(select table_id from oceanbase.__all_table where table_name ='mv1', table_id, 1);
--disable_query_log
eval select count(*) >= 1 from oceanbase.__all_mview_refresh_stats where mview_id = $mview_id and result = -4023;
eval select count(*) = 1 from oceanbase.__all_mview_refresh_stats where mview_id = $mview_id and result = 0;
select count(*)  = 1 from oceanbase.DBA_MVREF_STATS where MV_NAME = 'mv1';
select count(*)  = 1 from oceanbase.DBA_MVREF_RUN_STATS where MVIEWS = 'mv1';
--enable_query_log

connection sys;
--disable_query_log
eval select count(*)  = 1 from oceanbase.CDB_MVREF_STATS where MV_NAME = 'mv1' and tenant_id = $current_tenant_id;
eval select count(*)  = 1 from oceanbase.CDB_MVREF_RUN_STATS where MVIEWS = 'mv1' and tenant_id = $current_tenant_id;
--enable_query_log

connection default;

#drop materialized view log on t1;
#drop table t1;
#drop materialized view mv1;
