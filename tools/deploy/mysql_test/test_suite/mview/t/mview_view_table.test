# owner: zg410411
# owner group: mv
# tags: 
# descriotion: create materialized view with user views
#

# 0. prepare
set recyclebin = OFF;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database if exists test_mv_view_table;
--enable_warnings
create database test_mv_view_table;
use test_mv_view_table;

# 1. create materialized view with user views
create table t1(c1 int primary key, c2 int);
insert into t1 values(1,1),(2,2),(3,3);
create view v1 as select * from t1;

--error 1235
create materialized view log on v1 with (c1, c2);
create materialized view mv1 as select * from v1;
--error 9760
create materialized view mv2 refresh fast as select * from v1;

select DEP_TYPE from oceanbase.DBA_MVIEW_DEPS WHERE DEP_OWNER = 'test_mv_view_table' and DEP_NAME = 'v1';

# clean up
drop database test_mv_view_table;
