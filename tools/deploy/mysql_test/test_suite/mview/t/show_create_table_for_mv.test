#owner: lana.lgx
#owner group: data
#description: show create table mview
#tags: mview
#author: cyh438514

--result_format 4

--disable_warnings
--source mysql_test/include/ignore_drop_mview_err_mysql.inc
drop materialized view mv1;
--source mysql_test/include/ignore_drop_mview_err_mysql.inc
drop materialized view mv2;
--source mysql_test/include/ignore_drop_mview_err_mysql.inc
drop materialized view mv3;
--source mysql_test/include/ignore_drop_mview_err_mysql.inc
drop materialized view mv4;
--source mysql_test/include/ignore_drop_mview_err_mysql.inc
drop materialized view mv5;
--source mysql_test/include/ignore_drop_mlog_err_mysql.inc
drop materialized view log on t1;
drop table if exists t1;
--enable_warnings

# create table
CREATE TABLE t1 (c1 int, c2 int, c3 int);

# show common mview
CREATE MATERIALIZED VIEW mv1 AS SELECT t1.c1 from t1;
SHOW CREATE TABLE mv1;
SHOW CREATE VIEW mv1;
SET _show_ddl_in_compat_mode = 1;
SHOW CREATE TABLE mv1;
SHOW CREATE VIEW mv1;
SET _show_ddl_in_compat_mode = 0;

# show mview with refresh method and enable query rewrite
CREATE MATERIALIZED VIEW mv2 refresh force enable query rewrite AS SELECT t1.c1 from t1;
SHOW CREATE TABLE mv2;
SHOW CREATE VIEW mv2;
SET _show_ddl_in_compat_mode = 1;
SHOW CREATE TABLE mv2;
SHOW CREATE VIEW mv2;
SET _show_ddl_in_compat_mode = 0;

# show mview with refresh task
CREATE MATERIALIZED VIEW mv3 refresh force start with sysdate() next sysdate() + interval 1 day AS SELECT t1.c1 from t1;
SHOW CREATE TABLE mv3;
SHOW CREATE VIEW mv3;
SET _show_ddl_in_compat_mode = 1;
SHOW CREATE TABLE mv3;
SHOW CREATE VIEW mv3;
SET _show_ddl_in_compat_mode = 0;

# show mview enable on query computation
CREATE MATERIALIZED VIEW LOG ON t1 WITH PRIMARY KEY, ROWID, SEQUENCE (c1, c2, c3) INCLUDING NEW VALUES;
CREATE MATERIALIZED VIEW mv4
  REFRESH COMPLETE ON DEMAND
  ENABLE ON QUERY COMPUTATION
  AS SELECT c1, count(*) AS cnt
      FROM t1
      GROUP BY c1;
SHOW CREATE TABLE mv4;
SHOW CREATE VIEW mv4;
SET _show_ddl_in_compat_mode = 1;
SHOW CREATE TABLE mv4;
SHOW CREATE VIEW mv4;
SET _show_ddl_in_compat_mode = 0;

# show mview with pk
CREATE MATERIALIZED VIEW mv5 (PRIMARY KEY (c1)) AS SELECT t1.c1 from t1;
SHOW CREATE TABLE mv5;
SHOW CREATE VIEW mv5;
SET _show_ddl_in_compat_mode = 1;
SHOW CREATE TABLE mv5;
SHOW CREATE VIEW mv5;
SET _show_ddl_in_compat_mode = 0;
CREATE MATERIALIZED VIEW mv6 (PRIMARY KEY (c1, c2, c3)) AS SELECT t1.c1, t1.c2, t1.c3 from t1;
SHOW CREATE TABLE mv6;
SHOW CREATE VIEW mv6;
SET _show_ddl_in_compat_mode = 1;
SHOW CREATE TABLE mv6;
SHOW CREATE VIEW mv6;
SET _show_ddl_in_compat_mode = 0;

#show mview enable query rewrite and refresh task
CREATE MATERIALIZED VIEW mv7 refresh force start with sysdate() next sysdate() + interval 1 day enable query rewrite AS SELECT t1.c1 from t1;
SHOW CREATE TABLE mv7;
SHOW CREATE VIEW mv7;
SET _show_ddl_in_compat_mode = 1;
SHOW CREATE TABLE mv7;
SHOW CREATE VIEW mv7;
SET _show_ddl_in_compat_mode = 0;

#show mview enable query computation and refresh task
CREATE MATERIALIZED VIEW mv8
  REFRESH COMPLETE ON DEMAND
  start with sysdate() next sysdate() + interval 1 day
  ENABLE ON QUERY COMPUTATION
  AS SELECT c1, count(*) AS cnt
      FROM t1
      GROUP BY c1;
SHOW CREATE TABLE mv8;
SHOW CREATE VIEW mv8;
SET _show_ddl_in_compat_mode = 1;
SHOW CREATE TABLE mv8;
SHOW CREATE VIEW mv8;
SET _show_ddl_in_compat_mode = 0;

#show mview with column group
CREATE MATERIALIZED VIEW mv9 partition by hash (c1) with column group (each column) refresh force AS SELECT t1.c1 from t1;
SHOW CREATE TABLE mv9;
SHOW CREATE VIEW mv9;
SET _show_ddl_in_compat_mode = 1;
SHOW CREATE TABLE mv9;
SHOW CREATE VIEW mv9;
SET _show_ddl_in_compat_mode = 0;
CREATE MATERIALIZED VIEW mv10 partition by hash (c1) with column group (all columns) refresh force AS SELECT t1.c1 from t1;
SHOW CREATE TABLE mv10;
SHOW CREATE VIEW mv10;
SET _show_ddl_in_compat_mode = 1;
SHOW CREATE TABLE mv10;
SHOW CREATE VIEW mv10;
SET _show_ddl_in_compat_mode = 0;
CREATE MATERIALIZED VIEW mv11 partition by hash (c1) with column group (all columns, each column) refresh force AS SELECT t1.c1 from t1;
SHOW CREATE TABLE mv11;
SHOW CREATE VIEW mv11;
SET _show_ddl_in_compat_mode = 1;
SHOW CREATE TABLE mv11;
SHOW CREATE VIEW mv11;
SET _show_ddl_in_compat_mode = 0;
CREATE MATERIALIZED VIEW mv12 partition by hash (c1) with column group (each column, all columns) refresh force AS SELECT t1.c1 from t1;
SHOW CREATE TABLE mv12;
SHOW CREATE VIEW mv12;
SET _show_ddl_in_compat_mode = 1;
SHOW CREATE TABLE mv12;
SHOW CREATE VIEW mv12;
SET _show_ddl_in_compat_mode = 0;

# drop materialized views and tables
DROP MATERIALIZED VIEW mv1, mv2, mv3, mv4, mv5, mv6, mv7, mv8, mv9, mv10, mv11, mv12;
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;