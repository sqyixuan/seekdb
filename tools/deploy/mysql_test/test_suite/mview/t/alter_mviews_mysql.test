#owner: lana.lgx
#owner group: data

--disable_warnings
--source mysql_test/include/ignore_drop_mlog_err_mysql.inc
drop materialized view log on t1;
DROP TABLE IF EXISTS t1;
--source mysql_test/include/ignore_drop_mlog_err_mysql.inc
drop materialized view log on t2;
DROP TABLE IF EXISTS t2;
--enable_warnings
CREATE TABLE t1 (
  id int primary key,
  name varchar(10),
  age int
);

--disable_warnings
drop materialized view IF EXISTS mv1;
--disable_warnings
drop materialized view IF EXISTS mv2;
--enable_warnings
create materialized view mv1 refresh complete on demand as select * from t1;

#1: unsupported operations
#rename mview(supported in 435bp3)
rename table mv1 to mv2;
rename table mv2 to mv1;

--error 1235
alter table mv1 rename to mv2;

#add column to mview
--error 1235
alter table mv1 add column new_col varchar(20);

#drop column of mview
--error 1235
alter table mv1 drop column name;

#add virtual generated column to mview
--error 1235
alter table mv1 add (vcol int generated always as (age + 1) virtual);

#truncate mview
--error 1235
truncate mv1;

#add primary key to mview
--error 1068
alter table mv1 add primary key(id);

#rename mview column
--error 1235
alter table mv1 rename column age to age2;

#modify mview column datatype
--error 1235
alter table mv1 modify name varchar(20);

#add not null constraint
--error 1235
alter table mv1 modify name varchar(20) not null;

#alter default column value
--error 1235
alter table mv1 alter column age set default 1;

#alter partition is not supported
--disable_warnings
drop materialized view IF EXISTS mv2;
--enable_warnings
create materialized view mv2 partition by range(age)
(
partition p1 values less than(10),
partition p2 values less than(20),
partition p3 values less than(30),
partition p4 values less than(40),
partition p5 values less than(50)
)
refresh complete on demand as select * from t1;

#add partition
--error 1235
alter table mv2 add partition (partition p6 values less than(60));

#drop partition
--error 1235
alter table mv2 drop partition p3;

#rename partition is not supported
#--error 1235
#alter table mv2 rename partition p2 to new_p2;

#truncate partition
--error 1235
alter table mv2 truncate partition p2;

#alter partition
--error 1235
alter table mv2 partition by range(age)
(
partition p1 values less than(15),
partition p2 values less than(25),
partition p3 values less than(35),
partition p4 values less than(45),
partition p5 values less than(55)
);
drop materialized view mv2;

#2: supported operations
#rename base table
rename table t1 to t2;
rename table t2 to t1;

#truncate base table
truncate t1;

#drop primary key of base table
alter table t1 drop primary key;

#add primary key to base table
alter table t1 add primary key(id);

#add column to base table
alter table t1 add column new_col varchar(20);

#drop column of base table
alter table t1 drop column new_col;

#add virtual generated column to base table
alter table t1 add (vcol int generated always as (age + 1) virtual);
alter table t1 drop column vcol;

#rename base table column
alter table t1 rename column age to age2;
alter table t1 rename column age2 to age;

#modify base table column datatype
alter table t1 modify name varchar(20);

#add not null constraint
alter table t1 modify name varchar(20) not null;

#alter default column value
alter table t1 alter column age set default 1;

#add/drop index to mview
create index k1 on mv1(age) local;
show index from mv1;
drop index k1 on mv1;
show index from mv1;
create index k2 on mv1(age) global;
show index from mv1;
drop index k2 on mv1;
show index from mv1;

alter table mv1 add index k1(age);
show index from mv1;
alter table mv1 rename index k1 to k2;
show index from mv1;
alter table mv1 drop index k2;
show index from mv1;

#add/drop index to base table
create index k1 on t1(age) local;
drop index k1 on t1;
create index k2 on t1(age) global;
drop index k2 on t1;

alter table t1 add index k1(age) local;
alter table t1 drop index k1;
alter table t1 add index k2(age) global;
alter table t1 drop index k2;

#add unique index
alter table t1 add unique(age);

#drop unique key
alter table t1 drop index age;

#add foreign key constraint
CREATE TABLE fk_t1 (
  age int primary key
);
alter table t1 add constraint fk_constraint foreign key(age) references fk_t1(age);

#drop foreign key constraint
alter table t1 drop foreign key fk_constraint;
drop table fk_t1;

#alter table options
alter table t1 row_format = DYNAMIC;
alter table t1 character set = utf8;
alter table t1 compression = 'zstd_1.0';
alter table t1 block_size = 1024;

#cleanup
drop materialized view mv1;
drop table t1;