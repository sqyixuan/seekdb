# owner: zg410411
# owner group: mv
# tags: 
# descriotion: create materialized view with external tables
#

# 0. prepare
set recyclebin = OFF;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database if exists test_mv_external_table;
--enable_warnings
create database test_mv_external_table;
use test_mv_external_table;

# 1. create materialized view with external table
--source mysql_test/include/external_table/delete_data_for_external_table.inc
call dbms_external_table.auto_refresh_external_table(-1);
create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
)
AUTO_REFRESH = OFF;
--source mysql_test/include/external_table/copy_data_for_external_table.inc
select * from ex_t1;

--error 1235
create materialized view log on ex_t1 with primary key (c1);
create materialized view mv1 as select * from ex_t1;
--error 9760
create materialized view mv2 refresh fast as select c1, count(*) cnt from ex_t1 group by c1;

call dbms_external_table.auto_refresh_external_table(1);
sleep 5;
alter external table ex_t1 refresh;
select * from ex_t1;

select * from mv1 order by c1;
call dbms_mview.refresh('mv1', 'c');
select * from mv1 order by c1;

select DEP_TYPE from oceanbase.DBA_MVIEW_DEPS WHERE DEP_OWNER = 'test_mv_external_table' and DEP_NAME = 'ex_t1';

# clean up
drop database test_mv_external_table;
