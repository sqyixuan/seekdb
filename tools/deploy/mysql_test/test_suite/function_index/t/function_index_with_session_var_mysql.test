--echo #test rename and change column
create table t1(c1 date, c2 date as (cast(c1 as date)));
insert into t1(c1) values('2023-05-30 01:02:03');
insert into t1(c1) values('2023-05-30 00:02:03');
select * from t1;

set @@session.time_zone = '+00:00';
##offline ddl, use '+00:00' for c2
alter table t1 change c1 c1 timestamp;
select * from t1;

set @@session.time_zone = '-2:00';
select * from t1;

##online ddl, still use '+00:00' for c2
alter table t1 change column c1 c3 timestamp;
select * from t1;

drop table t1;

