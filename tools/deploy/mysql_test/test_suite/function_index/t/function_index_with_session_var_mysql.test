#tags: ddl

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--result_format 4
--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings
--echo #Create table
--echo ##Generated Column

--disable_warnings
set @@session.time_zone = '+08:00';
create table t1(c1 timestamp, c2 datetime as (cast(c1 as datetime)), index i1(c2));
insert into t1(c1) values('2023-05-30 01:02:03');
insert into t1(c1) values('2023-05-30 00:02:03');
select * from t1;
explain select * from t1 where c2 = '2023-05-30 00:02:03';
select * from t1 where c2 = '2023-05-30 00:02:03';
explain select * from t1 where cast (c1 as datetime) = '2023-05-30 01:02:03';
select * from t1 where cast (c1 as datetime) = '2023-05-30 01:02:03';

set @@session.time_zone = '+00:00';
insert into t1(c1) values('2023-05-30 22:02:03');
insert into t1(c1) values('2023-05-30 22:04:03');
select * from t1;
explain select * from t1 where c2 = '2023-05-30 00:02:03';
select * from t1 where c2 = '2023-05-30 00:02:03';
explain select * from t1 where cast (c1 as datetime) = '2023-05-30 01:02:03';
select * from t1 where cast (c1 as datetime) = '2023-05-30 01:02:03';

set @@session.time_zone = '+08:00';
explain select * from t1 where cast (c1 as datetime) = '2023-05-30 01:02:03';
select * from t1 where cast (c1 as datetime) = '2023-05-30 01:02:03';

drop table t1;

create table t1(c1 timestamp, c2 datetime as (cast(c1 as datetime)));
insert into t1(c1) values('2023-05-30 01:02:03');
insert into t1(c1) values('2023-05-30 00:02:03');
select * from t1;
create index i1 on t1(c2);
explain select * from t1 where c2 = '2023-05-30 00:02:03';
select * from t1 where c2 = '2023-05-30 00:02:03';
set @@session.time_zone = '+00:00';
insert into t1(c1) values('2023-05-30 22:02:03');
insert into t1(c1) values('2023-05-30 22:04:03');
select * from t1;
explain select * from t1 where c2 = '2023-05-30 00:02:03';
select * from t1 where c2 = '2023-05-30 00:02:03';
drop table t1;

--echo ##Functional Index
set @@session.time_zone = '+08:00';
create table t1(c1 timestamp, index i1((cast (c1 as date))));
insert into t1(c1) values('2023-05-30 01:02:03');
insert into t1(c1) values('2023-05-30 00:02:03');
select c1,cast (c1 as date) from t1;
explain select c1,cast(c1 as date) from t1 where cast(c1 as date) = '2023-05-30';
select c1,cast(c1 as date) from t1 where cast(c1 as date) = '2023-05-30';

set @@session.time_zone = '+0:00';
insert into t1(c1) values('2023-05-30 22:02:03');
insert into t1(c1) values('2023-05-30 22:04:03');
select c1,cast (c1 as date) from t1;

explain select c1,cast(c1 as date) from t1 where cast(c1 as date) = '2023-05-30';
select c1,cast(c1 as date) from t1 where cast(c1 as date) = '2023-05-30';

set @@session.time_zone = '+08:00';
explain select c1,cast(c1 as date) from t1 where cast(c1 as date) = '2023-05-30';
select c1,cast(c1 as date) from t1 where cast(c1 as date) = '2023-05-30';
select c1,cast(c1 as date) from t1 where cast(c1 as date) = '2023-05-31';
drop table t1;

