#bugfix: 
drop table if exists stu1;
set @@collation_connection = 'LATIN1_SWEDISH_CI';
CREATE TABLE stu1 (
  s1 char(2) NOT NULL,
  s2 char(4) DEFAULT NULL,
  s3 char(20) GENERATED ALWAYS AS ((`s2` * 0.001)) VIRTUAL,
  PRIMARY KEY (s1),
  UNIQUE KEY s2 (s2) BLOCK_SIZE 16384 LOCAL,
  CONSTRAINT stu1_OBCHECK_1701839301153991 CHECK (((`s2` > 0) and (`s1` > 0)))
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

set @@collation_connection = 'utf8mb4_general_ci';

select s3 from stu1;
explain select s3 from stu1;
create index stu1_s2 on stu1(s2) local;

drop table stu1;