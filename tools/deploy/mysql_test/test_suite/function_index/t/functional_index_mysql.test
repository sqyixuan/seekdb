#owner : sean.yyj
#owner group : sql1
#tags: ddl, generated_column

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

--echo #basic test
create table t1(c1 int, c2 varchar(10), c3 float, c4 json as (cast(c1 as json)), c5 point, c6 text, index i1 ((c1+1)), unique key ui1 ((c1+2)));
alter table t1 add key i2(c1, (c3+1));
alter table t1 add unique key ui2(c1, (c3+1));
alter table t1 add unique key gi1(c1, (c3+1)) global;
create index i3 on t1(c2(5), (c1+2));
create unique index ui3 on t1(c2(5), (c1+2));
create unique index gi3 on t1(c2(5), (c1+2)) global;
show create table t1;
show index from t1;
show indexes from t1;

--echo #build on field
--error 3762
create index i5 on t1((c1));
--error 3762
create index i5 on t1((c1)) global;

--error 3762
alter table t1 add index i5((c1));
--error 3762
alter table t1 add index i5((c1)) global;

--error 3762
create table t2(c1 int, c2 int, index i5 ((c1)));
--error 3762
create table t2(c1 int, c2 int, index i5 ((c1)) global);

--echo #disallowed function
--error 3758
create index i5 on t1((now()));
--error 3758
alter table t1 add index i5 ((now()));
--error 3758
create table t2(c1 int, index i1 ((now())));

--echo #spatial key
--error 3762
create index i5 on t1((c5));
--error 3760
create index i5 on t1((point(c1,1)));
--error 3760
create index i5 on t1((point(c1,1))) global;
--error 3760
create spatial index i5 on t1((c1+1));
--error 3760
create spatial index i5 on t1((c1+1)) global;

--error 3762
alter table t1 add index i5 ((c5));
--error 3760
alter table t1 add index i5 ((point(c1,1)));
--error 3760
alter table t1 add index i5 ((point(c1,1))) global;
--error 3760
alter table t1 add spatial index i5 ((c1+1));
--error 3760
alter table t1 add spatial index i5 ((c1+1)) global;

--error 3762
create table t2(c1 int, c2 point, index i1((c2)));
--error 3760
create table t2(c1 int, c2 point, index i1((point(c1,1))));
--error 3760
create table t2(c1 int, c2 point, index i1((point(c1,1))) global);
--error 3760
create table t2(c1 int, c2 point, spatial index i1((c1+1)));
--error 3760
create table t2(c1 int, c2 point, spatial index i1((c1+1)) global);

--echo #build on json/text expr
--error 3753
create index i5 on t1((cast(c1 as json)));
--error 3753
create index i5 on t1((cast(c1 as json))) global;
--error 3753
alter table t1 add index i5 ((cast(c1 as json)));
--error 3753
alter table t1 add index i5 ((cast(c1 as json))) global;
--error 3753
create table t2(c1 int, c2 text, index i5((cast(c1 as json))));
--error 3753
create table t2(c1 int, c2 text, index i5((cast(c1 as json))) global);
--error 3760
create spatial index i5 on t1((cast(c1 as json)));

--error 3757
create index i5 on t1((ifnull(1,c6)));
--error 3757
create index i5 on t1((ifnull(1,c6))) global;
--error 3757
alter table t1 add index i5 ((ifnull(1,c6)));
--error 3757
alter table t1 add index i5 ((ifnull(1,c6))) global;
--error 3757
create table t1(c1 int, c2 text, index i5((ifnull(null,c2))));
--error 3757
create table t1(c1 int, c2 text, index i5((ifnull(null,c2))) global);

--echo #drop/rename dependant Column
drop table t1;
create table t1(c1 int, c2 int, c3 int, c4 int as (c3+1), index i1 (c1, (c2+1)));
show create table t1;
--error 3837
alter table t1 drop column c2;
--error 3108
alter table t1 drop column c3;

#mysql can't rename columns which are used in generated columns and function indexes. But ob can.
alter table t1 change c2 c5 int;
alter table t1 change c3 c6 int;
show create table t1;

#Bugfix:
drop table t1;
create table t1(c1 int, c2 int);
--error 1054
alter table t1 add index ((c1 + 1)) partition by hash(c1) partitions 2;
--error 1054
alter table t1 add index ((c1 + 1)) partition by hash(c1+1) partitions 2;
alter table t1 add index ((c1 + 1),c1) partition by hash(c1+1) partitions 2;
show create table t1;
drop table t1;

#Bugfix:
create table t1 (id int, c21 datetime, c22 timestamp);
create index i1 on t1((cast(c22 as decimal(38,0))));
alter table t1 drop index i1;
create index i1 on t1((cast(c22 as date)));
alter table t1 drop index i1;
create index i1 on t1((CONVERT_TZ(c22, '+00:00', '+08:00')));
alter table t1 drop index i1;
create index i1 on t1((TO_DAYS(c22)));
alter table t1 drop index i1;
create index i1 on t1((DATE_FORMAT(c22,'%Y-%m-%d %H:%i:%s')));
alter table t1 drop index i1;
create index i1 on t1 ((DATE(c22)));
alter table t1 drop index i1;
create index i1 on t1 ((STR_TO_DATE(c22, '%Y-%m-%d')));
alter table t1 drop index i1;
drop table t1;

#Bugfix:
##functional index
--error 3758
CREATE TABLE t1 (col1 char(30), INDEX idx1 ((name_const('CamelCase', 'CAMELCASE'))));
CREATE TABLE t1 (col1 char(30));
--error 3758
alter table t1 add index ((name_const('CamelCase', 'CAMELCASE')));
drop table t1;
##generated column
--error 3102
CREATE TABLE t1 (col1 char(30), col2 char(50) as ((name_const('CamelCase', 'CAMELCASE'))));
CREATE TABLE t1 (col1 char(30));
--error 3102
alter table t1 add column col2 char(50) as ((name_const('CamelCase', 'CAMELCASE')));
drop table t1;

#Bugfix:
CREATE TABLE t1(x INT, KEY((1+1)));
--error 4028
ALTER TABLE t1 DROP COLUMN x;
drop table t1;

#Bugfix:
CREATE TABLE t1 (col1 INT, col2 INT);
insert into t1 values(1,1),(2,2),(3,3);
alter table t1 add column col3 int default 0,
               add index i1 ((col1 - col3)),
               add column col4 int,
               add index i2 ((col4 + col3));

show create table t1;

select * from t1;
explain select * from t1 where col1 - col3 = 1;
select * from t1 where col1 - col3 = 1;
explain select * from t1 where col4 + col3 is null;
select * from t1 where col4 + col3 is null;

##add index before depend column
alter table t1 add column col5 int default 0,
               add index i3 ((col6 - col5)),
               add column col6 int;

##add index before drop column
--error 1235
alter table t1 add index i4 ((col1+1)),
               drop column col1;

##add index before change column
alter table t1 add column col7 int;
--error 1072
alter table t1 add index i5 ((col7 + 1)),
               change column col7 col8 int;

alter table t1 add index i5 ((col8 + 1)),
               change column col7 col8 int;

drop table t1;