# con1
set session ob_trx_timeout=5000000;
set session ob_query_timeout=5000000;
# con2
set session ob_trx_timeout=5000000;
set session ob_query_timeout=5000000;
# con1
drop table if exists trans_minor_freeze;
create table if not exists trans_minor_freeze (id integer, x integer);
# case 1
insert into trans_minor_freeze values(0, 0);
# default
alter system minor freeze tenant sys;
# con2
select * from trans_minor_freeze;
id	x
0	0
# case 2
# con1
set autocommit=0;
select * from trans_minor_freeze where id=0 for update;
id	x
0	0
update trans_minor_freeze set x=x+1 where id = 0;
# default
alter system minor freeze tenant sys;
# con1
select * from trans_minor_freeze;
id	x
0	1
commit;
# con2
update trans_minor_freeze set x=x+1 where id = 0;
select * from trans_minor_freeze;
id	x
0	2
# case 3
# con1
set autocommit=0;
select * from trans_minor_freeze where id=0 for update;
id	x
0	2
# default
alter system minor freeze tenant sys;
# con1
commit;
# case 4
# con1
set autocommit=0;
select * from trans_minor_freeze where id=0 for update;
id	x
0	2
# default
alter system minor freeze tenant sys;
# con2
update trans_minor_freeze set x=x+1 where id = 0;
# con1
commit;
# con2
select * from trans_minor_freeze;
id	x
0	3
# Switch to connection default + disconnect con1 and con2
# con1
drop table trans_minor_freeze;
# default
