set global ob_sql_audit_percentage = 30;
use test;
drop table if exists t1;
"---------- 1 - basic seq_num test ----------"
"CASE 1.1"
create table t1 (c1 int primary key);
set autocommit=0;
begin;
select * from t1 order by c1 desc;
c1
insert into t1 values(1);
select * from t1 where c1=1;
c1
1
update t1 set c1=3 where c1=1;
select * from t1 where c1=3;
c1
3
insert into t1 values(2);
select * from t1 where c1=2;
c1
2
commit;
"CASE 1.2"
begin;
insert into t1 values(4);
select * from t1 where c1=4;
c1
4
savepoint sp1;
insert into t1 values(5);
select * from t1 where c1=5;
c1
5
rollback to sp1;
insert into t1 values(6);
select * from t1 where c1=6;
c1
6
commit;
"---------- 2 - distributed trx and no free route seq num test ----------"
change mysql tenant primary_zone to RANDOM
alter tenant sys set primary_zone = 'RANDOM';
drop table if exists t2;
create table t2(id int primary key) partition by range(id)
(partition p0 values less than (10000), partition p1 values less than (3000000000));
alter system set _enable_transaction_internal_routing = false;
drop view if exists check__enable_transaction_internal_routing;
create view check__enable_transaction_internal_routing as select Value from oceanbase.gv$ob_parameters where name = '_enable_transaction_internal_routing';
"CASE 2.1"
set autocommit=0;
begin;
select * from t2 order by id desc;
id
insert into t2 values(1);
select * from t2 where id=1;
id
1
update t2 set id=10001 where id=1;
select * from t2 where id=10001;
id
10001
insert into t2 values(10002);
select * from t2 where id=10002;
id
10002
commit;
"CASE 2.2"
set autocommit=0;
begin;
insert into t2 values(4);
select * from t2 where id=4;
id
4
savepoint sp1;
insert into t2 values(10005);
select * from t2 where id=10005;
id
10005
rollback to sp1;
insert into t2 values(10006);
select * from t2 where id=10006;
id
10006
commit;
"---------- 3 - distributed trx and free route seq num test ----------"
alter system set _enable_transaction_internal_routing = true;
"CASE 3.1"
set autocommit=0;
begin;
select * from t2 order by id desc;
id
10006
10002
10001
4
insert into t2 values(10);
select * from t2 where id=10;
id
10
update t2 set id=100010 where id=10;
select * from t2 where id=100010;
id
100010
insert into t2 values(100020);
select * from t2 where id=100020;
id
100020
commit;
"CASE 3.2"
set autocommit=0;
begin;
insert into t2 values(40);
select * from t2 where id=40;
id
40
savepoint sp1;
insert into t2 values(100050);
select * from t2 where id=100050;
id
100050
rollback to sp1;
insert into t2 values(100060);
select * from t2 where id=100060;
id
100060
commit;
"CLEANUP"
drop table t1;
drop table t2;
set global ob_sql_audit_percentage = 3;
recovery primary_zone settings for mysql tenant
