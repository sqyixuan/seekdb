DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
`pk` BIGINT AUTO_INCREMENT NOT NULL,
`id` BIGINT NOT NULL,
`int1` BIGINT,
`int1_key` BIGINT,
`int1_unique` BIGINT,
`int2` BIGINT,
`int2_key` BIGINT,
`int2_unique` BIGINT,
`for_update` BOOLEAN DEFAULT 0,
`timestamp` TIMESTAMP,
`connection_id` BIGINT,
`thread_id` BIGINT DEFAULT 0,
`is_uncommitted` BOOLEAN DEFAULT 0,
`is_consistent` BOOLEAN DEFAULT 0,
KEY (`id`),
KEY (`int1_key`),
KEY (`int2_key`),
UNIQUE (`int1_unique`),
UNIQUE (`int2_unique`),
PRIMARY KEY (`pk`)
);
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `pk` bigint(20) NOT NULL AUTO_INCREMENT,
  `id` bigint(20) NOT NULL,
  `int1` bigint(20) DEFAULT NULL,
  `int1_key` bigint(20) DEFAULT NULL,
  `int1_unique` bigint(20) DEFAULT NULL,
  `int2` bigint(20) DEFAULT NULL,
  `int2_key` bigint(20) DEFAULT NULL,
  `int2_unique` bigint(20) DEFAULT NULL,
  `for_update` tinyint(1) DEFAULT '0',
  `timestamp` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  `connection_id` bigint(20) DEFAULT NULL,
  `thread_id` bigint(20) DEFAULT '0',
  `is_uncommitted` tinyint(1) DEFAULT '0',
  `is_consistent` tinyint(1) DEFAULT '0',
  PRIMARY KEY (`pk`),
  UNIQUE KEY `int1_unique` (`int1_unique`) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY `int2_unique` (`int2_unique`) BLOCK_SIZE 16384 LOCAL,
  KEY `id` (`id`) BLOCK_SIZE 16384 LOCAL,
  KEY `int1_key` (`int1_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `int2_key` (`int2_key`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX AUTO_INCREMENT = 1 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
SELECT SUM(`int1` + `int1_key` + `int1_unique`
         + `int2` + `int2_key` + `int2_unique`)
AS TotalSum
FROM t1;
TotalSum
