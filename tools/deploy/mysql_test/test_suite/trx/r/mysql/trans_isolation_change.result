set autocommit=1;
use test;
drop table if exists t;
create table t(id int);
when txn not active, change session isolation_level will take effect
insert into t values(1);
set autocommit=0;
set session transaction isolation level read committed;
select * from t;
id
1
insert into t values(2);
select * from t;
id
1
2
set session transaction isolation level repeatable read;
select * from t;
id
1
2
insert into t values(3);
should read 1,2 but 3
select * from t;
id
1
2
set session transaction isolation level read committed;
should read 1,2,3
select * from t;
id
1
2
3
when txn active, change session isolation_level will NOT take effect
insert into t values(4);
select * from t;
id
1
2
3
4
set session transaction isolation level repeatable read;
select * from t;
id
1
2
3
4
insert into t values(5);
should read 1,2,3,4,5
select * from t;
id
1
2
3
4
5
