prepare table for test
set autocommit=on;
set autocommit=on;
drop table if exists ac_6005_test;
create table ac_6005_test(id int primary key, v int);
insert into ac_6005_test values(1,1);
test1: isolation level is RC, transaction id will not changed
set session transaction isolation level read committed;
begin;
update ac_6005_test set v = v + 1;
set ob_query_timeout = 300000000;
set session transaction isolation level read committed;
update ac_6005_test set v = v + 2;
rollback;
select * from ac_6005_test;
id	v
1	3
select ob_transaction_id();
ob_transaction_id()
0
test2: isolation level is SERIALIZABLE, snapshot should re-acquired for each retry
begin;
update ac_6005_test set v = v + 1;
set ob_query_timeout = 300000000;
set session transaction isolation level SERIALIZABLE;
update ac_6005_test set v = v + 2;
begin;
insert into ac_6005_test values(2,2);
commit;
rollback;
select * from ac_6005_test;
id	v
1	5
2	4
select ob_transaction_id();
ob_transaction_id()
0
test3: other error will rollback transaction, here use primary key duplicate error (-1062)
insert into ac_6005_test values(1,1);
ERROR 23000: Duplicate entry '1' for key 'PRIMARY'
select ob_transaction_id();
ob_transaction_id()
0
test4: finally, retry timeout should rollback transaction
begin;
update ac_6005_test set v = v + 1;
set ob_query_timeout = 5000000;
update ac_6005_test set v = v + 2;
ERROR HY000: Lock wait timeout exceeded; try restarting transaction
select ob_transaction_id();
ob_transaction_id()
0
select * from ac_6005_test;
id	v
1	5
2	4
rollback;
test5: 6005 retry 2 times and then reroute, the transaction should rollbacked
inject EN_LOCK_CONFLICT_RETRY_THEN_REROUTE, 2 times retry
begin;
update ac_6005_test set v = v + 1;
set ob_query_timeout = 5000000;
update ac_6005_test set v = v + 2;
ERROR HY000: SQL request should be rerouted
select ob_transaction_id();
ob_transaction_id()
0
select * from ac_6005_test;
id	v
1	5
2	4
rollback;
cleanup
drop table ac_6005_test;
