insert into t0 values(2);
ERROR 25000: transaction needs rollback
commit;
ERROR 40000: Transaction rollbacked
select * from t0;
a
0
begin;
insert into t1 value(1);
insert into t1 value(2);
select NOW(), * from t1;
ERROR 25000: transaction needs rollback
insert into t1 values(3);
ERROR 25000: transaction needs rollback
commit;
