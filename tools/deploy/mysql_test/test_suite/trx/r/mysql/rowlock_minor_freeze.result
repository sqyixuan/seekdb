drop table if exists t1;
create table t1(a int primary key, b int, unique key u_idx(b));
insert into t1 (a, b) values (1, 1), (2, 2), (3, 3);
begin;
select * from t1 where a = 1 for update;
a	b
1	1
update t1 set b = b * 10 where a = 1;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
update /*+log_level(debug) */ t1 set b = 3 where a = 1;
ERROR 23000: Duplicate entry '3' for key 'u_idx'
begin;
select /*+log_level(debug) */ * from t1 where a = 1 for update nowait;
ERROR HY000: Lock wait timeout exceeded; try restarting transaction
commit;
commit;
drop table t1;
