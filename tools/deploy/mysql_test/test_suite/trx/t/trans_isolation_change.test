#owner : yunxing.cyx
#owner group : transaction
#description : transaction isolation level change 
#              when txn active or not
#  NOTE: there is difference with MySQL when set autocommit=0:
#  on MySQL, set autocommit implicitly start a transaction, the set
#  session isolation level can not affect current transaction
#  until it committed or rollbacked.
#  while on OceanBase, set autocommit won't start transaction
#  so, change session isolation level will affect following stmt
#  read snapshot
#  this is for performance reason currently, it may change in the future
#  if we solve the performance via other method
#-----------------------------------------------------------------------
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
set autocommit=1;
use test;
--disable_warnings
drop table if exists t;
--enable_warnings
create table t(id int);

--echo when txn not active, change session isolation_level will take effect
connection conn1;
insert into t values(1);
connection conn2;
set autocommit=0;
set session transaction isolation level read committed;
select * from t;
connection conn1;
insert into t values(2);
connection conn2;
select * from t;
set session transaction isolation level repeatable read;
select * from t;
connection conn1;
insert into t values(3);
connection conn2;
--echo should read 1,2 but 3
select * from t;
set session transaction isolation level read committed;
--echo should read 1,2,3
select * from t;

--echo when txn active, change session isolation_level will NOT take effect
connection conn2;
insert into t values(4);
select * from t;
set session transaction isolation level repeatable read;
select * from t;
connection conn1;
insert into t values(5);
connection conn2;
--echo should read 1,2,3,4,5
select * from t;

#--disable_warnings
#drop table t;
