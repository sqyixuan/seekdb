--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: OUR GOAL: Make all this simple and effective!
####test:two trx on one rows,one trx rollback
connect (conn0,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn0;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk int primary key, c1 int);
create index idx on t1(c1);
insert into t1 values(6,6),(7,7),(8,8);
--source mysql_test/include/check_all_idx_ok.inc

connection conn1;
set autocommit=0;

connection conn2;
set autocommit=0;

####insert +insert
connection conn1;
send update t1 set pk=9 where pk=6;

connection conn2;
sleep 2;
send update t1 set pk=10 where pk=6;

connection conn1;
reap;
rollback;

connection conn2;
reap;
commit;
select * from t1;

