--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# tags: optimizer
# description: foobar
#--disable_abort_on_error
--disable_warnings
drop database if exists tmp;
create database tmp;
use tmp;
--disable_warnings
drop table if exists test;
--enable_warnings
--disable_warnings
drop table if exists tt;
--enable_warnings
create table test(c1 int);

set @@session.tx_read_only = 1;
set transaction read write;

##read write
start transaction;
insert into test values(1);
commit;

##read only
start transaction;
--error 1792
insert into test values(2);
##update/delete empty set also failed
--error 1792
update test set c1 = c1 + 1 where c1 = 1001;
--error 1792
delete from test where c1 = 1001;
commit;

##read write
set session transaction read write;

start transaction;
insert into test values(2);
commit;

start transaction;
insert into test values(3);
commit;

set session transaction read only;
start transaction;
--error 1568
set transaction read write;
set session transaction read write;
--error 1792
insert into test values(4);
--error 1792
delete from test where c1 = 9191;
commit;

##read write
start transaction;
insert into test values(5);
commit;

set session transaction read only;
set transaction read write;
start transaction;
insert into test values(6);
--error 1792
create table tt(c1 int primary key);
##create table 隐式开启新事务，
##read only
--error 1792
insert into tt values(2);
##update/delete empty set also failed
--error 1792
update tt set c1 = c1 + 1 where c1 = 1001;
--error 1792
delete from tt where c1 = 1001;
commit;
--error 1792
drop table if exists test;
--error 1792
drop table if exists tt;

--error 1792
drop table if exists t1;
--error 1792
create table t1(id int primary key auto_increment);
set session transaction read write;
create table t1(id int primary key auto_increment);
set session transaction read only;
set transaction read only;
--error 1792
insert into t1 values ();
select * from t1;
##update/delete empty set also failed
--error 1792
update tt set c1 = c1 + 1 where c1 = 1001;
--error 1792
delete from tt where c1 = 1001;

###select 1不会开启隐式事务
set session transaction read only;
set @@session.autocommit = 1;
set transaction read write;
select 1;
insert into t1 values(3);
--error 1792
insert into t1 values(3);
##在执行阶段之前就发生错误的语句不会开启事务
set session transaction read write;
set transaction read only;
--error 1792
insert into t1 values(3);
--error 1792
insert into t1 values(3);
select 1;
--error 1792
insert into t1 values(3);
# select , ac = 1, auto start and commit a transaction
select * from t1;
# key duplicate
--error 1062
insert into t1 values(3);
drop table t1;

####远程执行时，远程开启事务；
set session transaction read only;
set @@session.autocommit = 1;
set transaction read write;
##失败，create table引起隐式提交，不管是否在事务中，都会导致重置tx_read_Only
--error 1792
create table ff(c1 int);
##失败
--error 1792
insert into ff values(1);
set session transaction read write;
--disable_warnings
drop table if exists ff;
--enable_warnings
create table ff(c1 int);
set session transaction read only;
set transaction read write;
insert into ff values(1);
--error 1792
insert into ff values(1);
set transaction read write;
--error 1792
drop table ff;
set transaction read write;
--error 1146
explain insert into tt values(1);
--error 1146
explain insert into tt values(1);
select * from ff;

set session transaction read write;
set @@autocommit=1;
set transaction read only;
--error 1792
insert into ff values(1);
commit;
insert into ff values(1);
set transaction read only;
create table tt(c1 int primary key);
set session transaction read only;
set transaction read write;
insert into tt values(1);
--error 1792
insert into tt values(1);
set transaction read write;
--error 1062
insert into tt values(1);
--error 1792
insert into tt values(1);

set session transaction read only;
set transaction read write;
start transaction;
insert into tt values(5);
insert into tt values(6);
start transaction;
insert into tt values(8);
commit;
--error 1792
insert into tt values(9);
set session transaction read write;
drop table tt;
drop table ff;


--echo SQL caused implicit commit, will commit current transaction event a READ_ONLY error is reported
create table tt(id int);
set session transaction read only;
set transaction read write;
start transaction;
insert into tt values(1);
--error 1792
create table ff(id int);
rollback;
--echo trans commited, query it to confirm
select * from tt;

--echo Set autocommit to cause implicit commit transaction will not reset transaction characteristics
set autocommit=0;
set session transaction read only;
set transaction read write;
start transaction;
insert into tt values(2);
set autocommit=1;
start transaction;
insert into tt values(3);
commit;

--echo clean up
set session transaction read write;
drop table tt;
drop database tmp;
