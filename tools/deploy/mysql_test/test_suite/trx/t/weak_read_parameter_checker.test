--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: shanyan.g
#owner group : transaction
#description: 测试弱读配置项依赖关系的相关case
### 1. max_stale_time_for_weak_consistency 大于等于默认值(5s)
### 2. max_stale_time_for_weak_consistency 大于等于weak_read_version_refresh_interval


connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

#测试max_stale_time_for_weak_consistency设置大于等于默认值
--error 4147
alter system set max_stale_time_for_weak_consistency = '10us';
--error 4147
alter system set max_stale_time_for_weak_consistency = '10ms';
--error 4147
alter system set max_stale_time_for_weak_consistency = '1s';
alter system set max_stale_time_for_weak_consistency = '5000000us';
alter system set max_stale_time_for_weak_consistency = '5000ms';
alter system set max_stale_time_for_weak_consistency = '5s';
alter system set max_stale_time_for_weak_consistency = '1m';
alter system set max_stale_time_for_weak_consistency = '1h';
alter system set max_stale_time_for_weak_consistency = '1d';

#测试max_stale_time_for_weak_consistency设置大于等于weak_read_version_refresh_interval
alter system set weak_read_version_refresh_interval = '20s';
sleep 5;
--error 4147
alter system set max_stale_time_for_weak_consistency = '10s' tenant=sys;
--error 4147
alter system set max_stale_time_for_weak_consistency = '10s' tenant=all_user;
--error 4147
alter system set max_stale_time_for_weak_consistency = '10s' tenant=all_meta;
alter system set max_stale_time_for_weak_consistency = '20s' tenant=sys;
alter system set max_stale_time_for_weak_consistency = '20s' tenant=all_user;
alter system set max_stale_time_for_weak_consistency = '20s' tenant=all_meta;
alter system set max_stale_time_for_weak_consistency = '1m' tenant=sys;
alter system set max_stale_time_for_weak_consistency = '1m' tenant=all_user;
alter system set max_stale_time_for_weak_consistency = '1m' tenant=all_meta;

##alter system set weak_read_version_refresh_interval = '50ms';


#测试普通租户
connection conn1;
--error 4147
alter system set max_stale_time_for_weak_consistency = '10s';
alter system set max_stale_time_for_weak_consistency = '20s';

#恢复环境
connection obsys;
alter system set weak_read_version_refresh_interval = '50ms';
alter system set max_stale_time_for_weak_consistency = '5s';
