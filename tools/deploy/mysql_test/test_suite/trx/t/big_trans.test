--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# owner group: SQL3
# description: OUR GOAL: Make all this simple and effective!
--disable_warnings
drop table if exists t1;
--enable_warnings

# farm环境不好，很容易超时，调大该时间，默认事务超时是100s，这里改成600s
set ob_trx_timeout = 600000000;

create table t1(i int primary key, c1 char(30), c256 char(255), dt datetime(6), d  datetime(6));

#--disable_query_log
#--disable_result_log

#insert
begin;
let $i=0;
while($i < 3000) 
{
    eval insert into t1(i,c1,c256,dt,d) values($i,'1','$i','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
commit;

#replace
begin;
let $i=3000;
while($i < 6000)
{
    eval replace into t1(i,c1,c256,dt,d) values($i,'1','$i+3000','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
commit;

#update
begin;
let $i=0;
while($i < 3000)
{
    eval update t1 set c1='update_$i' where i=$i;
    inc $i;
}
commit;

#select for update
begin;
let $i=0;
while($i < 3000)
{
    eval select * from t1 where i=$i for update;
    inc $i;
}
commit;

#delete
begin;
let $i=0;
while($i < 3000)
{
    eval delete from t1 where i=$i;
    inc $i;
}
commit;

drop table t1;
