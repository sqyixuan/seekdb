# owner: yunxing.cyx
# owner group: transaction
# description: trans internal rollbacked when session
#              idle time greate than ob_trx_idle_timeout
#              and need user rollback transaction explicitly

let $cpu = 2;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870712;
let $iops = 100000;
let $session = 64;

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--disable_warnings
connection sys;
alter system set enable_auto_leader_switch = false;
--enable_warnings

connection conn1;
--disable_abort_on_error
set global ob_query_timeout = 100000000000;
set global ob_trx_timeout = 100000000000;
set global ob_trx_idle_timeout = 2000000;
use test;

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn2;
--disable_warnings
drop table if exists t0;
drop table if exists t1;
--enable_warnings
create table t0(a int primary key);
create table t1(a int) partition by hash(a) partitions 4;
insert into t0 values(0);
insert into t1 values(0),(1),(2),(3);

# case 1: read only trans will success
connection conn2;
begin;
select * from t0;
sleep 7;
select * from t0;
commit;
select * from t0;

# case 2: single part trans
connection conn2;
begin;
insert into t0 values(1);
sleep 7;
select NOW(), * from t0;
insert into t0 values(2);
commit;
select * from t0;


# case 3: multi part trans
connection conn2;
begin;
insert into t1 value(1);
insert into t1 value(2);
sleep 7;
select NOW(), * from t1;
insert into t1 values(3);
commit;

# case 4: implicit commit
connection conn2;
begin;
insert into t0 values(10);
sleep 7;
begin;
select * from t0;

# case 5: rollback will not disconnect
connection conn2;
begin;
insert into t0 values(10);
sleep 7;
select NOW(), * from t0;
rollback;
select * from t0;

--disable_warnings
drop table if exists t0;
drop table if exists t1;
--enable_warnings
