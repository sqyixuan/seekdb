WITH T2 AS (SELECT /*+ READ_CONSISTENCY(STRONG) */  SUBSTRING( A.COL_MEDIUMINT_KEY, A.COL_MEDIUMINT ) AS COL_NUMBER_ALIAS FROM table30_key_pk_parts_2 A WHERE COL_TINYINT_KEY = (SELECT /*+ DISABLE_PARALLEL_DML*/ MIN(COL_INT_KEY) FROM table10 B)) SELECT /*+ READ_CONSISTENCY(WEAK) */ COUNT(*) FROM table30_key_pk_parts_2 T1, T2,table10_key_pk_parts_2_bigint T3 WHERE T1.PK=T3.PK AND T2.COL_NUMBER_ALIAS=T1.PK;

WITH T2 AS (SELECT /*+ READ_CONSISTENCY(STRONG) */  SUBSTRING( A.COL_MEDIUMINT_KEY, A.COL_MEDIUMINT ) AS COL_NUMBER_ALIAS FROM table30_key_pk_parts_2 A WHERE COL_TINYINT_KEY = (SELECT /*+ DISABLE_PARALLEL_DML*/ MIN(COL_INT_KEY) FROM table10 B)) SELECT /*+ READ_CONSISTENCY(WEAK) */ COUNT(*) FROM table30_key_pk_parts_2 T1, T2,table10_key_pk_parts_2_bigint T3 WHERE T1.PK=T3.PK AND T2.COL_NUMBER_ALIAS=T1.PK;

