--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: 并发事务同时insert up操作，查询索引表、数据表、回表 返回结果的顺序会跟是否需要回表相关。
# 为了避免因为执行计划带来的问题，去除case里面结果对索引的依赖。
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk int primary key, a int, b int, c varchar(1024));
create index i1 on t1(b) storing(c);

--source mysql_test/include/check_all_idx_ok.inc

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

####CASE:并发事务insert，无锁冲突，commit
connection conn1;
set autocommit=0;
insert into t1 values(1,1,1,'a');
commit;
insert into t1 values(1, 3, 5,7) on duplicate key update b = pk + b;

connection conn2;
set autocommit=0;
insert into t1 values(2,1,1,'a');
commit;
insert into t1 values(2,1,1,'a') on duplicate key update b = pk + b;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;

connection conn1;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10  order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;

connection conn2;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;

####CASE:并发事务insert，有锁冲突，commit
connection conn1;
set autocommit=0;
insert into t1 values(3,1,1,'a');
commit;
insert into t1 values(3,1,1,'a') on duplicate key update b = pk + b;
connection conn2;
set autocommit=0;
insert into t1 values(4,1,1,'a');
commit;
insert into t1 values(4,1,1,'a') on duplicate key update b = pk + b;
--error 1205,4012
delete from t1 where pk=3;
--error 1205,4012
update t1 set b=4 where pk=3;
--error 1205,4012
insert into t1 values(3,1,1,'a') on duplicate key update b = b-pk;
--error 1205,4012
insert into t1 values(3,1,1,'c') on duplicate key update b = pk + b;
insert into t1 values(5,1,1,'a');
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;

connection conn1;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;

connection conn2;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;

####CASE:并发事务，事务1 insert on duplicate，事务2 做其他dml，无锁冲突
connection conn1;
set autocommit=0;
insert into t1 values(6,1,1,'a'),(7,1,1,'a'),(8,1,1,'a');
commit;
insert into t1 values(6,1,1,'a') on duplicate key update b = b-pk;

connection conn2;
set autocommit=0;
insert into t1 values(7,2,2,'b') on duplicate key update b = b-pk;
insert into t1 values(8,2,2,'b') on duplicate key update b = b-pk;
delete from t1 where pk = 8;
update t1 set b = b-pk where pk=7;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;

connection conn1;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;

connection conn2;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;

####CASE: 多个事务insert,事务1 commit，事物2 rollback
connection conn1;
set autocommit=0;
insert into t1 values(10,1,1,'a');
commit;
insert into t1 values(10,1,1,'a') on duplicate key update b = b-pk;

connection conn2;
set autocommit=0;
insert into t1 values(11,1,1,'a');
commit;
insert into t1 values(11,1,1,'a') on duplicate key update b = b-pk;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<20 order by pk;
select * from t1 where b>0 and b<10 order by pk;

connection conn1;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<10 order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<20 order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;

connection conn2;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<20 order by pk;
select * from t1 where b>0 and b<10 order by pk;
rollback;
select pk, b, c from t1 where b>0 and b<10 order by pk;
select pk, a, b from t1 where pk>0 and pk<20 order by pk;
select * from t1 where b>0 and b<10 order by pk;
commit;

drop table t1;
