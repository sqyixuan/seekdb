# owner:xiongjun.qxj
# owner group: transaction
# description: 测试gv$lock视图

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

connection conn1;
set SESSION ob_query_timeout = 100000000;
set SESSION ob_trx_timeout = 100000000;
set SESSION ob_trx_idle_timeout = 100000000;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 int);
insert into t1 values(100, 100);
insert into t1 values(200, 200);
commit;

connection conn2;
set SESSION ob_query_timeout = 100000000;
set SESSION ob_trx_timeout = 100000000;
set SESSION ob_trx_idle_timeout = 100000000;
begin;
update t1 set c2 = 101 where c1 = 100;
update t1 set c2 = 201 where c1 = 200;

connection conn1;
begin;
send update t1 set c2 = 102 where c1 = 100;

connection conn3;
set SESSION ob_query_timeout = 100000000;
set SESSION ob_trx_timeout = 100000000;
set SESSION ob_trx_idle_timeout = 100000000;
begin;
send update t1 set c2 = 202 where c1 = 200;

sleep 1;

connection conn4;
select count(*) from gv$lock;
commit;

connection conn2;
commit;

connection conn1;
reap;
commit;

connection conn3;
reap;
commit;

sleep 1;

connection conn4;
select * from gv$lock;
select count(*) from gv$lock;
commit;

connection conn3;
select * from t1;
drop table if exists t1;