#owner : jingyan.kfy
#owner group : transaction
#description : 测试savepoint相关的case

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--disable_warnings
connection sys;
--enable_warnings

connection conn1;
--disable_abort_on_error
set session autocommit = 0;
set session ob_trx_timeout = 500000000;
use test;

## 测试savapoint不存在的异常判断
--disable_warnings
drop table if exists sp_test1;
--enable_warnings
create table sp_test1(a int, b int);
begin;
rollback to sp1;
insert into sp_test1 values(1, 1);
rollback to sp2;
commit;

## 测试不显式begin
--disable_warnings
drop table if exists sp_test1;
--enable_warnings
create table sp_test1(a int, b int);
savepoint sp1;
insert into sp_test1 values(1, 1);
insert into sp_test1 values(2, 2);
rollback to sp1;
select * from sp_test1;
commit;

## 测试release savepoint的行为
--disable_warnings
drop table if exists sp_test1;
--enable_warnings
create table sp_test1(a int, b int);
begin;
savepoint s1;
savepoint s2;
savepoint s3;
insert into sp_test1 values (1, 1);
select * from sp_test1;
release savepoint s2;
rollback to s3;
rollback to s2;
select * from sp_test1;
commit;
--echo test autocommit=0 with savepoint release
set autocommit=0;
savepoint s1;
release savepoint s1;
--error 1305
rollback to s1;
commit;
--error 1305
release savepoint s1;

## 测试未执行语句，开始执行savepoint流程的情况,
## 
begin;
select 1;
savepoint sp1;
rollback to sp1;
commit;

## 测试分布式语句回滚完整性
## 
--disable_warnings
drop table if exists sp_test1;
drop table if exists sp_test2;
--enable_warnings
create table sp_test1(a int, b int);
create table sp_test2(a int);
begin;
savepoint sp1;
insert into sp_test1 values(1,1);
savepoint sp2;
insert into sp_test2 values(1);
savepoint sp3;
insert into sp_test1 values (2,2);
insert into sp_test2 values (2);
select * from sp_test1;
select * from sp_test2;
rollback to sp3;
select * from sp_test1;
select * from sp_test2;
commit;

## 测试savepoint id长度
## 
begin;
savepoint ;
rollback to ;
commit;

## 测试事务开启时执行savepoint
--disable_warnings
drop table if exists sp_test1;
--enable_warnings
create table sp_test1(a int, b int);

begin;
savepoint sp1;
insert into sp_test1 values(1, 1);
insert into sp_test1 values(2, 2);
rollback to sp1;
select * from sp_test1;
commit;

## 测试savapoint覆盖
--disable_warnings
drop table if exists sp_test1;
--enable_warnings
create table sp_test1(a int, b int);
begin;
insert into sp_test1 values(1, 1);
savepoint sp1;
insert into sp_test1 values(2, 2);
savepoint sp1;
insert into sp_test1 values(3, 3);
rollback to sp1;
select * from sp_test1;
commit;

## 测试savapoint回滚
--disable_warnings
drop table if exists sp_test1;
--enable_warnings
create table sp_test1(a int, b int);
begin;
insert into sp_test1 values(1, 1);
savepoint sp1;
insert into sp_test1 values(2, 2);
savepoint sp2;
insert into sp_test1 values(3, 3);
savepoint sp3;
insert into sp_test1 values(4, 4);
rollback to sp2;
select * from sp_test1;
rollback to sp3;
select * from sp_test1;
commit;

## 测试savepoint删除1
--disable_warnings
drop table if exists sp_test1;
--enable_warnings
create table sp_test1(a int, b int);

begin;
release savepoint sp1;
insert into sp_test1 values(1, 1);
release savepoint sp2;
select * from sp_test1;
commit;

## 测试savepoint删除2
--disable_warnings
drop table if exists sp_test1;
--enable_warnings
create table sp_test1(a int, b int);

begin;
insert into sp_test1 values(1, 1);
savepoint sp1;
insert into sp_test1 values(2, 2);
rollback to sp1;
insert into sp_test1 values(3, 3);
rollback to sp1;
select * from sp_test1;
release savepoint sp1;
insert into sp_test1 values(4, 4);
rollback to sp1;
select * from sp_test1;
commit;

## 1. 测试单分区事务的savepoint功能
--disable_warnings
drop table if exists sp_test1;
--enable_warnings
create table sp_test1(a int, b int);

--disable_warnings
drop table if exists sp_test2;
--enable_warnings
create table sp_test2(a int, b int);

begin;
insert into sp_test1 values(1, 1);
update sp_test1 set b = 2 where a = 1;
savepoint sp1;
insert into sp_test1 values(2, 2);
select * from sp_test1;
rollback to sp1;
select * from sp_test1;
commit;

begin;
insert into sp_test2 values(1, 1);
savepoint sp2;
insert into sp_test2 values(2, 2);
release savepoint sp2;
rollback to sp2;
savepoint sp3;
update sp_test2 set b = 2 where a = 1;
select * from sp_test2;
rollback to sp3;
select * from sp_test2;
commit;

begin;
select * from sp_test1;
select * from sp_test2;
commit;

## 2. 测试分布式事务的savepoint功能
--disable_warnings
drop table if exists sp_test1;
--enable_warnings
create table sp_test1(a int, b int);

--disable_warnings
drop table if exists sp_test2;
--enable_warnings
create table sp_test2(a int, b int);

begin;
insert into sp_test1 values(1, 1);
insert into sp_test2 values(1, 1);
savepoint sp4;
update sp_test1 set b = 2 where a = 1;
update sp_test2 set b = 2 where a = 1;
select * from sp_test1;
select * from sp_test2;
rollback to sp4;
select * from sp_test1;
select * from sp_test2;
commit;

begin;
insert into sp_test1 values(1, 1);
insert into sp_test2 values(1, 1);
savepoint sp5;
savepoint sp6;
update sp_test1 set b = 2 where a = 1;
update sp_test2 set b = 2 where a = 1;
select * from sp_test1;
select * from sp_test2;
release savepoint sp5;
rollback to sp5;
rollback to sp6;
select * from sp_test1;
select * from sp_test2;
commit;

begin;
select * from sp_test1;
select * from sp_test2;
commit;

## 3. 测试语句回滚和savepoint回滚同时出现的情况
--disable_warnings
drop table if exists sp_test1;
--enable_warnings
create table sp_test1(a int, b int);

--disable_warnings
drop table if exists sp_test2;
--enable_warnings
create table sp_test2(a int, b int, primary key(a));

begin;
insert into sp_test1 values(1, 1);
insert into sp_test2 values(1, 1);
savepoint sp7;
update sp_test1 set b = 2 where a = 1;
update sp_test2 set b = 2 where a = 1;
select * from sp_test1;
select * from sp_test2;
rollback to sp7;
select * from sp_test1;
select * from sp_test2;
insert into sp_test2 values(1, 1);
select * from sp_test1;
select * from sp_test2;
commit;


## 4. 测试事务第一句为create savepoint、事务结束后访问savepoint的情况
--disable_warnings
drop table if exists sp_test1;
--enable_warnings
create table sp_test1(a int, b int);
set autocommit=0;
rollback;

savepoint sp7;
insert into sp_test1 values(1, 1);
savepoint sp8;
insert into sp_test1 values(2, 2);
select * from sp_test1;
rollback to sp8;
select * from sp_test1;
rollback to sp7;
select * from sp_test1;
commit;
--error 1305
rollback to sp7;
--error 1305
release savepoint sp8;
--error 1305
release savepoint sp7;
set autocommit=1;
--disable_warnings
drop table if exists sp_test1, sp_test2;
--enable_warnings

