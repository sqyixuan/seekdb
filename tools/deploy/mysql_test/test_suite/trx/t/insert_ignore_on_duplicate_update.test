#owner: handora.qc
#owner group: transaction
# tags: transaction, insert ignore, on duplicate update

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
drop table if exists test;
create table test (c1 int primary key, c2 time, c3 char(3));
insert ignore into test values(4,5,6),(5,6,7), (6,7,3),(7,8, 0),(4,10,5), (5,9,0) on duplicate key update c2 = c2 + 1;
insert ignore into test values(4,5,6),(5,6,7), (6,7,3),(7,8, 0),(4,10,5), (5,9,0) on duplicate key update c2 = c2 + 1;

connection conn1;
drop table if exists test;


