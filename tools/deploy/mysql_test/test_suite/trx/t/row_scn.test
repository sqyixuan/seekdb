# owner: handora.qc
# owner group: transaction 2
# description: this case is used to test row scn under uncommitted row

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

connection conn1;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(a int primary key);

connection conn0;
let $__table_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ table_id from oceanbase.__all_virtual_table where table_name= 't1', table_id, 1);

connection conn1;
# 测试普通标记脏事务
set SESSION ob_trx_timeout=10000000000;
set SESSION ob_trx_idle_timeout=10000000000;
insert into t1 value(1);
begin;
insert into t1 value(2);

connection conn2;
set ob_query_timeout=10000000000;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn1;
insert into t1 value(3);
commit;

select *, ORA_ROWSCN != 9223372036854775807 from t1;

connection conn2;
--disable_warnings
drop table if exists t1, t2;
--enable_warnings

set sql_mode = '';
create table t1(c1 double,c2 double not null);
ALTER TABLE t1 ADD   UNIQUE KEY i1 (c1);
insert into t1 values (3,' \n\tTest String');
select ora_rowscn/ora_rowscn from t1 where c1 = 3;
alter system minor freeze;
sleep 5;
select ora_rowscn/ora_rowscn from t1 where c1 = 3;
drop table t1;

create table t1(a int primary key, b int);
create table t2 like t1;
--error 1052
select * from t1, t2 where ora_rowscn=1;
--error 1054
select * from (select * from t1) t where t.ora_rowscn=1;
select * from t1 join t2 where t1.ora_rowscn=1;
select * from t1 join t2 where t2.ora_rowscn=1;
select * from (select * from t1) t join t2 where ora_rowscn=1;
--error 1054
select * from (select * from t1) t join (select * from t2) tt where ora_rowscn=1;
select * from t1 join (select * from t2) t where ora_rowscn=1;
select * from (select ora_rowscn from t1) t where ora_rowscn=1;
select * from (select ora_rowscn from t1) t join (select ora_rowscn from t2) tt where t.ora_rowscn=1;
--error 1052
select * from t1 left join t2 on 1=1 where ora_rowscn=1;
--error 1052
select * from t1 right join t2 on 1=1 where ora_rowscn=1;
select * from (select t1.*, ora_rowscn from t1) t where ora_rowscn=1;
drop table t1;
drop table t2;
