#owner : handora.qc
#owner group : transaction
#description : 测试系统变量ob_trx_lock_timeout的相关的case

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--disable_warnings
connection sys;
--enable_warnings

connection conn1;
--disable_abort_on_error
set session autocommit = 0;
set session ob_trx_timeout = 500000000;
set session ob_query_timeout = 10000000;
use test;

connection conn2;
--disable_abort_on_error
set session autocommit = 0;
set session ob_trx_timeout = 10000000;
set session ob_query_timeout = 15000000;
use test;

connection conn1;
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1(x int, y int);
create table t2(x int, y int);
insert into t1 values(1, 1);
insert into t2 values(1, 1);

## case 1
## 测试ob_trx_lock_timeout = -1 的场景
## 预期等锁超时时间等于ob_query_timeout
begin;
select * from t1 where x = 1 for update;

connection conn2;
set session ob_trx_lock_timeout = -1;
begin;
select * from t1 where x = 1 for update;
commit;

begin;
insert into t2 values (2, 2);
select * from t1 where x = 1 for update;
commit;

sleep 1;

select * from t1;
select * from t2;

## case 2
## 测试ob_trx_lock_timeout = 3 的场景
## 预期等锁超时时间等于ob_trx_lock_timeout
set session ob_trx_lock_timeout = 3;
begin;
select * from t1 where x = 1 for update;
commit;

begin;
insert into t2 values (2, 2);
select * from t1 where x = 1 for update;
commit;

sleep 1;

select * from t1;
select * from t2;

## case 3
## 测试ob_trx_lock_timeout = 0 的场景
## 预期立刻报set session ob_trx_lock_timeout = 0;
set session ob_trx_lock_timeout = 0;
begin;
select * from t1 where x = 1 for update;
commit;

begin;
insert into t2 values (2, 2);
select * from t1 where x = 1 for update;
commit;

sleep 1;

select * from t1;
select * from t2;
