#owner : wx372254
#owner group : transaction
#description : 测试事务内语句sql_audit seq_num记录正确性

connect (sys,$OBMYSQL_MS0,root,"",oceanbase,$OBMYSQL_PORT);
connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

connection conn0;
set global ob_sql_audit_percentage = 30;
use test;
--disable_warnings
drop table if exists t1;
--enable_warnings

# 场景1： local/remote 场景
--echo "---------- 1 - basic seq_num test ----------"

# dml与select语句定序
--echo "CASE 1.1"
create table t1 (c1 int primary key);
set autocommit=0;
begin;
let $tx_id=`select ob_transaction_id()`;
let $seq_num_0=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='begin' order by request_time desc, seq_num, 1);
select * from t1 order by c1 desc;
let $seq_num_1=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='select * from t1 order by c1 desc' order by request_time desc, seq_num, 1);
insert into t1 values(1);
let $seq_num_2=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='insert into t1 values(1)' order by request_time desc, seq_num, 1);
select * from t1 where c1=1;
let $seq_num_3=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='select * from t1 where c1=1' order by request_time desc, seq_num, 1);
update t1 set c1=3 where c1=1;
let $seq_num_4=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='update t1 set c1=3 where c1=1' order by request_time desc, seq_num, 1);
select * from t1 where c1=3;
let $seq_num_5=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='select * from t1 where c1=3' order by request_time desc, seq_num, 1);
insert into t1 values(2);
let $seq_num_6=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='insert into t1 values(2)' order by request_time desc, seq_num, 1);
select * from t1 where c1=2;
let $seq_num_7=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='select * from t1 where c1=2' order by request_time desc, seq_num, 1);
commit;
let $seq_num_8=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='commit' order by request_time desc, seq_num, 1);

if ($seq_num_0 >= $seq_num_1){ --echo "seq num incorrect !!!"
--echo $seq_num_0
--echo $seq_num_1
}
if ($seq_num_1 >= $seq_num_2){ --echo "seq num incorrect !!!"
--echo $seq_num_1
--echo $seq_num_2
}
if ($seq_num_2 >= $seq_num_3){ --echo "seq num incorrect !!!"
--echo $seq_num_2
--echo $seq_num_3
}
if ($seq_num_3 >= $seq_num_4){ --echo "seq num incorrect !!!"
--echo $seq_num_3
--echo $seq_num_4
}
if ($seq_num_4 >= $seq_num_5){ --echo "seq num incorrect !!!"
--echo $seq_num_4
--echo $seq_num_5
}
if ($seq_num_5 >= $seq_num_6){ --echo "seq num incorrect !!!"
--echo $seq_num_5
--echo $seq_num_6
}
if ($seq_num_6 >= $seq_num_7){ --echo "seq num incorrect !!!"
--echo $seq_num_6
--echo $seq_num_7
}
if ($seq_num_7 >= $seq_num_8){ --echo "seq num incorrect !!!"
--echo $seq_num_7
--echo $seq_num_8
}

# savepoint相关语句定序
--echo "CASE 1.2"
begin;
let $tx_id=`select ob_transaction_id()`;
let $seq_num_0=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='begin' order by request_time desc, seq_num, 1);
insert into t1 values(4);
let $seq_num_1=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='insert into t1 values(4)' order by request_time desc, seq_num, 1);
select * from t1 where c1=4;
let $seq_num_2=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='select * from t1 where c1=4' order by request_time desc, seq_num, 1);
savepoint sp1;
let $seq_num_3=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where query_sql='savepoint sp1' order by request_time desc, seq_num, 1);
insert into t1 values(5);
let $seq_num_4=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='insert into t1 values(5)' order by request_time desc, seq_num, 1);
select * from t1 where c1=5;
let $seq_num_5=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='select * from t1 where c1=5' order by request_time desc, seq_num, 1);
rollback to sp1;
let $seq_num_6=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where query_sql='rollback to sp1' order by request_time desc, seq_num, 1);
insert into t1 values(6);
let $seq_num_7=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='insert into t1 values(6)' order by request_time desc, seq_num, 1);
select * from t1 where c1=6;
let $seq_num_8=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='select * from t1 where c1=6' order by request_time desc, seq_num, 1);
commit;
let $seq_num_9=query_get_value(select seq_num from oceanbase.__all_virtual_sql_audit where transaction_id=$tx_id and query_sql='commit' order by request_time desc, seq_num, 1);

if ($seq_num_0 >= $seq_num_1){ --echo "seq num incorrect !!!"
--echo $seq_num_0
--echo $seq_num_1
}
if ($seq_num_1 >= $seq_num_2){ --echo "seq num incorrect !!!"
--echo $seq_num_1
--echo $seq_num_2
}
if ($seq_num_2 >= $seq_num_3){ --echo "seq num incorrect !!!"
--echo $seq_num_2
--echo $seq_num_3
}
if ($seq_num_3 >= $seq_num_4){ --echo "seq num incorrect !!!"
--echo $seq_num_3
--echo $seq_num_4
}
if ($seq_num_4 >= $seq_num_5){ --echo "seq num incorrect !!!"
--echo $seq_num_4
--echo $seq_num_5
}
if ($seq_num_5 >= $seq_num_6){ --echo "seq num incorrect !!!"
--echo $seq_num_5
--echo $seq_num_6
}
if ($seq_num_6 == 'No such row'){
  --echo $seq_num_6
}
if ($seq_num_7 == 'No such row'){
  --echo $seq_num_7
}
if ($seq_num_6 >= $seq_num_7){ --echo "seq num incorrect !!!"
--echo $seq_num_6
--echo $seq_num_7
}
if ($seq_num_7 >= $seq_num_8){ --echo "seq num incorrect !!!"
--echo $seq_num_7
--echo $seq_num_8
}
if ($seq_num_8 >= $seq_num_9){ --echo "seq num incorrect !!!"
--echo $seq_num_8
--echo $seq_num_9
}

# 场景2： 非分布式路由分布式事务场景 seq_num test
--echo "---------- 2 - distributed trx and no free route seq num test ----------"

# 设置primary zone为random
connection sys;
let $saved_primary_zone=`select primary_zone from oceanbase.__all_tenant where tenant_name = 'sys'`;
--echo change mysql tenant primary_zone to RANDOM
alter tenant sys set primary_zone = 'RANDOM';
let $tenant_id=`select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys'`;
let $break_loop=0;
let $i=0;
while ($break_loop == 0)
{
 --inc $i
 let $ls_cnt=`select count(ls_id) from oceanbase.__all_virtual_ls where tenant_id = $tenant_id and ls_id != 1 and status = "NORMAL" and flag not like "%DUPLICATE%"`;
 if ($ls_cnt > 1) {
    --inc $break_loop
 }
 if ($i >= 300) {
    --inc $break_loop
 }
 --sleep 0.2
}

# 创建分区表，位于多个ls上
connection conn1;
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2(id int primary key) partition by range(id)
 (partition p0 values less than (10000), partition p1 values less than (3000000000));
let $table_id=`select table_id from oceanbase.__all_virtual_table where table_name = 't2' and tenant_id = $tenant_id`;
let $ls_count=`select count(distinct ls_id) from oceanbase.__all_tablet_to_ls where table_id = $table_id`;
if ($ls_count <= 1) {
--echo "error, table should distributed to all ls"
eval select * from oceanbase.__all_tablet_to_ls where table_id = $table_id;
eval select svr_ip, ls_id, role from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id;
select * from oceanbase.__all_ls;
}
if ($ls_count > 1) {
let $check_ts=`select now()`;
let $svr_cnt=`select count(distinct svr_ip,svr_port) from oceanbase.__all_virtual_ls_meta_table where role = 1 and ls_id in (select distinct ls_id from oceanbase.__all_tablet_to_ls where table_id = $table_id)`;
if ($svr_cnt <= 1) {
--echo "ls leader not distributed to all server, check_ts=$check_ts, table_id=$table_id, ls_count=$ls_count"
eval select * from oceanbase.__all_tablet_to_ls where table_id = $table_id;
select * from oceanbase.__all_virtual_ls_meta_table where role = 1 order by ls_id;
eval select svr_ip, ls_id, role from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id;
select * from oceanbase.__all_ls;
}
}

# 关闭事务路由
alter system set _enable_transaction_internal_routing = false;
connection conn0;
--disable_warnings
drop view if exists check__enable_transaction_internal_routing;
--enable_warnings
create view check__enable_transaction_internal_routing as select Value from oceanbase.gv$ob_parameters where name = '_enable_transaction_internal_routing';
let $i = 0;
while ($i < 100)
{
   let $c=`select count(1) from check__enable_transaction_internal_routing WHERE Value != 'False'`;
   if ($c == 0)
   {
     let $i = 110;
   }
   if ($c != 0)
   {
     --sleep 1
     --inc $i
   }
}
if ($i != 110)
{
--echo "wait _enable_transaction_internal_routing to False failed : $i"
select * from oceanbase.gv$ob_parameters where name = '_enable_transaction_internal_routing';
}

