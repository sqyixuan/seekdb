--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: foobar
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(pk int primary key, c1 int);

#--disable_query_log
#--disable_result_log

sleep 1;
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
insert into t1 values(1,1), (2, 1);

begin;
update t1 set c1=pk ;

connection conn2;
begin;
send update t1 set c1=2 where c1=1;

connection conn1;
sleep 1;
select * from t1;
commit;

connection conn2;
reap;
select * from t1;
commit;

select * from t1;

#drop table t1;
