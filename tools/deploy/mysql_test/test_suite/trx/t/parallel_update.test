--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: OUR GOAL: Make all this simple and effective!
####test:two trx on one rows,one trx rollback
connect (conn0,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn0;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk int primary key, c1 int);
create index idx on t1(c1);
insert into t1 values(6,6),(7,7),(8,8);
--source mysql_test/include/check_all_idx_ok.inc

connection conn1;
set autocommit=0;

connection conn2;
set autocommit=0;

####update +update
connection conn1;
update t1 set pk=9 where pk=6;
connection conn2;
--error 1205,4012
update t1 set pk=10 where pk=6;

connection conn1;
commit;

connection conn2;
commit;
select * from t1;

####update +update,更新带索引的列,加隐式类型转换
connection conn1;
update t1 set c1='9' where pk='9';
connection conn2;
--error 1205,4012
update t1 set c1='10' where pk='9';

connection conn1;
commit;

connection conn2;
commit;
select * from t1;

####update +update,更新带索引的列,加隐式类型转换
connection conn1;
update t1 set c1='9' where c1='7';
connection conn2;
send update t1 set c1='10' where c1='7';

connection conn1;
commit;

connection conn2;
reap;
commit;
select * from t1;

####update +update,索引为条件，更新主键列,加隐式类型转换
connection conn1;
update t1 set pk='19' where c1='8';
connection conn2;
--error 1205,4012
update t1 set pk='10' where pk='8';
send update t1 set pk='10' where pk='8';

connection conn1;
commit;

connection conn2;
reap;
commit;
select * from t1;
