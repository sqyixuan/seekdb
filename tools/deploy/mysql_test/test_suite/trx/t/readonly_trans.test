--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : shanyan.g
#owner group : transaction
#description : 测试只读事务的相关case

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

##修改配置
--disable_abort_on_error
##准备数据
#create resource unit if not exists readonly_test max_cpu=1, memory_size='2G';
#create resource pool if not exists readonly_test unit='readonly_test', unit_num=1;
#create tenant if not exists readonly_test RESOURCE_POOL_LIST=('readonly_test') set ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc

## case:检查表结构
connection conn1;
use test;
--disable_warnings
drop table if exists readonly_trans_test;
--enable_warnings

create table readonly_trans_test(id1 int, id2 int);
desc readonly_trans_test;
insert into readonly_trans_test values(1, 1);
insert into readonly_trans_test values(1, 2);
insert into readonly_trans_test values(1, 3);

##数据插入之后，立即查询,验证数据；
select count(1)=3 from readonly_trans_test;

#只读事务中，执行非select的语句
set autocommit=0;
set @@session.tx_read_only=1;
begin;
select * from readonly_trans_test;
select * from readonly_trans_test;
select * from readonly_trans_test;
#预期update语句会失败
update readonly_trans_test set id1=0 where id2=2;
#最后commit事务，事务提交走只读事务的流程
commit;

set autocommit=1;
set @@session.tx_read_only=0;
select * from readonly_trans_test;

##删除table
drop table if exists readonly_trans_test;

connection obsys;
##清理租户资源
#drop tenant readonly_test force;
#drop resource pool readonly_test;
#drop resource unit readonly_test;

##还原配置
--enable_abort_on_error
