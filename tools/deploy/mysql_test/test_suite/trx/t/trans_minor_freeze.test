#
# owner: xiaoshi.xjl
# owner group: transaction
#

connect (conn1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

--disable_warnings
--disable_query_log
#eval create resource unit if not exists test_unit max_cpu 1, memory_size '2G';
#eval create resource pool if not exists test_pool unit = 'test_unit', unit_num = 1;
#eval create tenant if not exists test_tenant resource_pool_list('test_pool') set ob_tcp_invited_nodes='%';
--enable_query_log
--source mysql_test/include/check_tenant_sync.inc
--enable_warnings
connect (con1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (con2,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection con1;

--echo # con1
connection con1;
set session ob_trx_timeout=5000000;
set session ob_query_timeout=5000000;
--echo # con2
connection con2;
set session ob_trx_timeout=5000000;
set session ob_query_timeout=5000000;

--echo # con1
connection con1;
--disable_warnings
drop table if exists trans_minor_freeze;
--enable_warnings

eval create table if not exists trans_minor_freeze (id integer, x integer);

--echo # case 1
insert into trans_minor_freeze values(0, 0);
--echo # default
connection sys;
alter system minor freeze tenant sys;
--sleep 3
--echo # con2
connection con2;
select * from trans_minor_freeze;

--echo # case 2
--echo # con1
connection con1;
set autocommit=0;
select * from trans_minor_freeze where id=0 for update;
update trans_minor_freeze set x=x+1 where id = 0;
--echo # default
connection sys;
alter system minor freeze tenant sys;
--sleep 3
--echo # con1
connection con1;
select * from trans_minor_freeze;
commit;
--echo # con2
connection con2;
update trans_minor_freeze set x=x+1 where id = 0;
select * from trans_minor_freeze;

--echo # case 3
--echo # con1
connection con1;
set autocommit=0;
select * from trans_minor_freeze where id=0 for update;
--echo # default
connection sys;
alter system minor freeze tenant sys;
--sleep 3
--echo # con1
connection con1;
commit;

--echo # case 4
--echo # con1
connection con1;
set autocommit=0;
select * from trans_minor_freeze where id=0 for update;
--echo # default
connection sys;
alter system minor freeze tenant sys;
--sleep 3
--echo # con2
connection con2;
--send
update trans_minor_freeze set x=x+1 where id = 0;
--echo # con1
connection con1;
commit;
--echo # con2
connection con2;
reap;
select * from trans_minor_freeze;

# Cleanup
--echo # Switch to connection default + disconnect con1 and con2
--echo # con1
connection con1;
drop table trans_minor_freeze;
disconnect con1;
disconnect con2;
--echo # default
connection sys;
--disable_query_log
#drop tenant test_tenant force;
#drop resource pool test_pool;
#drop resource unit test_unit;
--enable_query_log
