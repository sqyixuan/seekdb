--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: SQL1
#description:本case原052是为了测试consisitent_mode，现在1.0已经不支持consistent_mode,所以先暂时把所有的consistent_mode删除掉了。

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

# speed up major freeze
#
#alter system set minor_num_limit=10 server_type=updateserver;
#alter system set min_drop_cache_wait_time='10s' server_type=chunkserver;

sleep 1;

# case 1 : frozen level
#
--disable_warnings
--disable_query_log
--disable_result_log
drop table if exists t1;
--source mysql_test/include/index_quick_major.inc
--enable_warnings
--enable_query_log
--enable_result_log
create table t1 (c1 int primary key, c2 int);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,1);
select * from t1;
select * from t1 where c1 in (1);
select * from t1 where c1 = 1;


insert into t1 values(2,2);
select * from t1;
select * from t1 where c1 in (1,2);
select * from t1 where c1 = 1;
select * from t1 where c1 = 2;

sleep 3;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

insert into t1 values(3,3);
select * from t1;
select * from t1 where c1 in (1,2,3);
select * from t1 where c1 = 1;
select * from t1 where c1 = 2;
select * from t1 where c1 = 3;

# case 3: weak level
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int primary key, c2 int);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,1);
select * from t1;
select * from t1 where c1 in (1);
select * from t1 where c1 = 1;
sleep 3;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

#select table_status from __updateserver_memtable_info order by table_id desc limit 1;
insert into t1 values(2,2);
select * from t1;
select * from t1 where c1 in (1,2);
select * from t1 where c1 = 1;
select * from t1 where c1 = 2;

# case 4： strong level
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int primary key, c2 int);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,1);
select * from t1;
select * from t1 where c1 in (1);
select * from t1 where c1 = 1;
sleep 3;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

#select table_status from __updateserver_memtable_info order by table_id desc limit 1;
insert into t1 values(2,2);
select * from t1;
select * from t1 where c1 in (1,2);
select * from t1 where c1 = 1;
select * from t1 where c1 = 2;

# case 6: default consistent mode
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int primary key, c2 int);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

# case 7: table is frozen, hint is strong/weak/static
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int primary key, c2 int);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,1);
sleep 1;
select /*+ read_consistency(weak)*/ * from t1;
select /*+ read_consistency(weak)*/ * from t1 where c1=1;
select /*+ read_consistency(weak)*/ * from t1 where c1 in (1);
select /*+ read_consistency(strong)*/ * from t1;
select /*+ read_consistency(strong)*/ * from t1 where c1=1;
select /*+ read_consistency(strong)*/ * from t1 where c1 in (1);


#select table_status from __updateserver_memtable_info order by table_id desc limit 1;
insert into t1 values(2,2);
sleep 1;
select /*+ read_consistency(weak)*/ * from t1;
select /*+ read_consistency(weak)*/ * from t1 where c1=1;
select /*+ read_consistency(weak)*/ * from t1 where c1=2;
select /*+ read_consistency(weak)*/ * from t1 where c1 in (1,2);
select /*+ read_consistency(strong)*/ * from t1;
select /*+ read_consistency(strong)*/ * from t1 where c1=1;
select /*+ read_consistency(strong)*/ * from t1 where c1=2;
select /*+ read_consistency(strong)*/ * from t1 where c1 in (1);
select /*+ read_consistency(strong)*/ * from t1 where c1 in (1,2);

sleep 3;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

#select table_status from __updateserver_memtable_info order by table_id desc limit 1;
sleep 1;
select /*+ read_consistency(weak)*/ * from t1;
select /*+ read_consistency(weak)*/ * from t1 where c1=1;
select /*+ read_consistency(weak)*/ * from t1 where c1=2;
select /*+ read_consistency(weak)*/ * from t1 where c1 in (1,2);
select /*+ read_consistency(strong)*/ * from t1;
select /*+ read_consistency(strong)*/ * from t1 where c1=1;
select /*+ read_consistency(strong)*/ * from t1 where c1=2;
select /*+ read_consistency(strong)*/ * from t1 where c1 in (1);
select /*+ read_consistency(strong)*/ * from t1 where c1 in (1,2);

sleep 3;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

#select table_status from __updateserver_memtable_info order by table_id desc limit 1;
sleep 1;
select /*+ read_consistency(weak)*/ * from t1;
select /*+ read_consistency(weak)*/ * from t1 where c1=1;
select /*+ read_consistency(weak)*/ * from t1 where c1=2;
select /*+ read_consistency(weak)*/ * from t1 where c1 in (1,2);
select /*+ read_consistency(strong)*/ * from t1;
select /*+ read_consistency(strong)*/ * from t1 where c1=1;
select /*+ read_consistency(strong)*/ * from t1 where c1=2;
select /*+ read_consistency(strong)*/ * from t1 where c1 in (1);
select /*+ read_consistency(strong)*/ * from t1 where c1 in (1,2);
select /*+ read_consistency(frozen)*/ * from t1;
select /*+ read_consistency(frozen)*/ * from t1 where c1=1;
select /*+ read_consistency(frozen)*/ * from t1 where c1=2;
select /*+ read_consistency(frozen)*/ * from t1 where c1 in (1,2);

# case 9:  table is strong, hint is fronze/static
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int primary key, c2 int);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,1);
sleep 1;
select /*+ read_consistency(weak)*/ * from t1;
select /*+ read_consistency(weak)*/ * from t1 where c1=1;
select /*+ read_consistency(weak)*/ * from t1 where c1 in (1);
select /*+ read_consistency(frozen)*/ * from t1;
select /*+ read_consistency(frozen)*/ * from t1 where c1=1;
select /*+ read_consistency(frozen)*/ * from t1 where c1 in (1);


#select table_status from __updateserver_memtable_info order by table_id desc limit 1;
insert into t1 values(2,2);
sleep 1;
select /*+ read_consistency(weak)*/ * from t1;
select /*+ read_consistency(weak)*/ * from t1 where c1=1;
select /*+ read_consistency(weak)*/ * from t1 where c1=2;
select /*+ read_consistency(weak)*/ * from t1 where c1 in (1,2);
select /*+ read_consistency(frozen)*/ * from t1;
select /*+ read_consistency(frozen)*/ * from t1 where c1=1;
select /*+ read_consistency(frozen)*/ * from t1 where c1=2;
select /*+ read_consistency(frozen)*/ * from t1 where c1 in (1,2);

sleep 3;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

#select table_status from __updateserver_memtable_info order by table_id desc limit 1;
sleep 1;
select /*+ read_consistency(weak)*/ * from t1;
select /*+ read_consistency(weak)*/ * from t1 where c1=1;
select /*+ read_consistency(weak)*/ * from t1 where c1=2;
select /*+ read_consistency(weak)*/ * from t1 where c1 in (1,2);
select /*+ read_consistency(frozen)*/ * from t1;
select /*+ read_consistency(frozen)*/ * from t1 where c1=1;
select /*+ read_consistency(frozen)*/ * from t1 where c1=2;
select /*+ read_consistency(frozen)*/ * from t1 where c1 in (1,2);


