--echo   instr-4-2-1     内连接
SELECT   instr(e.ename, 'S')  from emp e  join dept d  on e.deptno = d.deptno;

--echo   instr-4-2-2
###左连接  左外连接
select     instr(e.ename, 'S')   eee  from emp e left  join  dept d on e.deptno = d.deptno   ORDER BY  eee; 
select    instr(e.ename, 'S')    eee  from emp e left outer join  dept d on e.deptno = d.deptno   ORDER BY  eee; 


--echo  instr-4-2-3
###右连接  右外连接
select      instr(e.ename, 'S')    eee   from emp e right join dept d on e.deptno = d.deptno  ORDER BY  eee; 
select      instr(e.ename, 'S')    eee  from emp e right outer join  dept d on e.deptno = d.deptno  ORDER BY  eee; 


#mysql不支持ob支持
--echo   instr-4-2-4    全连接full join
select    instr(e.ename, 'S')  eee  from emp e full join dept d on e.DEPTNO=d.DEPTNO    ORDER BY  eee;  




--echo     instr-4-3-1  
SELECT empno,ename,job    FROM emp     WHERE deptno  in(SELECT instr(ename, 'S') FROM  emp);

--echo    instr-4-3-2
SELECT empno,ename,job    FROM emp  e    WHERE deptno  NOT  in(SELECT instr(ename, 'S') FROM  emp)   ORDER BY  e.empno;


--echo   instr-5-1-1                    
select  substr(e.ename,2, instr(e.ename, 'S')) eee from emp e  ORDER BY  eee;                           
                        
 
--echo   instr-5-1-2
SELECT   replace(e.ename,'SMITH',substr(e.ename,2, instr(e.ename, 'S')))   eee  FROM   emp e  ORDER BY  eee;                
                                    

--echo   instr-5-1-3
SELECT   ABS(instr(ename, 'S'))   eee  FROM   emp e  ORDER BY  eee;                   
                        
                        
 
--echo   instr-5-1-4
SELECT   CEIL(instr(ename, 'S'))   eee  FROM   emp e  ORDER BY  eee;                                  
                        
                                    
                        

--echo   instr-5-1-5
SELECT   FLOOR(instr(ename, 'S'))  eee   FROM   emp e   ORDER BY  eee;                           
                        
                        
 
--echo   instr-5-1-6
SELECT   MOD(instr(ename, 'S'),100)   eee  FROM   emp e   ORDER BY  eee;      

                      
--echo   instr-5-1-7
SELECT   hex(CHAR(instr(ename, 'S')))   eee  FROM   emp e  ORDER BY  eee;                       


--echo   instr-5-1-8
SELECT   LENGTH(MOD(instr(e.ename, 'S'),100))   FROM   emp e;   

--echo   instr-5-1-9
SELECT  MOD(LENGTH(INSTR('Hello world','or')),instr(e.ename, 'S'))   eee FROM  emp e    ORDER BY  eee;       
                                      
                        

--echo   instr-5-1-10

SELECT   LOG(12,instr(e.ename, 'S')/1000)   eee  FROM   emp e   ORDER BY  eee;                               
     

--echo   instr-5-1-11
SELECT   POWER(1,instr(e.ename, 'S'))   eee  FROM   emp e   ORDER BY  eee;               
                        
                

--echo   instr-5-1-12
SELECT   SQRT(MOD(e.empno,e.sal))   eee  FROM   emp e   ORDER BY  eee;  

                        
                        
--echo   instr-5-1-13
--error   1305
SELECT   TRUNC(MOD(e.empno,e.sal),2)   eee  FROM   emp e   ORDER BY  eee;   
                        

--echo   instr-5-1-14
SELECT ENAME,JOB,SAL,NVL(COMM,MOD(e.empno,e.sal)) FROM EMP e WHERE SAL<2000   ORDER  BY   sal;            

--echo   instr-5-1-15
SELECT   COALESCE (instr(e.ename, 'S'),instr(e.ename, 'S'))  eee    FROM   emp e   ORDER BY  eee;                       

  
                        
--echo   instr-5-1-16
--error   1582
SELECT   decode(MOD(e.empno,e.sal),instr(e.ename, 'S'),100,99)   FROM   emp e;    

--echo   instr-5-1-17
--error   1064
select cast(instr(e.ename, 'S') as varchar(10)) as eee    from emp e   ORDER  BY   eee;  
                        
                                             
--echo     instr-5-2
SELECT     hex(CONCAT(CHAR(instr(e.ename, 'S')),CHAR(e.empno)))  eee    from emp e   ORDER  BY   eee;              


--echo   instr-6-1-1
SELECT   MOD(e.empno,e.sal)+instr(e.ename, 'S') eee    from emp e   ORDER  BY   eee;   


--echo   instr-6-1-2
SELECT   MOD(e.empno,e.sal)-instr(e.ename, 'S')    eee    from emp e   ORDER  BY   eee;   

--echo   instr-6-1-3
SELECT   MOD(e.empno,e.sal)*instr(e.ename, 'S')    eee    from emp e   ORDER  BY   eee;  

--echo   instr-6-1-4
SELECT   MOD(e.empno,e.sal)/instr(e.ename, 'S')    eee    from emp e   ORDER  BY   eee; 

--echo   instr-6-2-1
SELECT   *    FROM   emp e  WHERE  MOD(e.empno,e.sal) NOT IN(SELECT instr(e.ename, 'S')    FROM emp)   ORDER BY empno;       

--echo   instr-6-2-2
SELECT   *    FROM   emp e  WHERE  MOD(e.empno,e.sal)<sal  AND  instr(e.ename, 'S') >tno  ORDER BY empno;            

--echo   instr-6-2-3    
SELECT   *    FROM   emp e  WHERE  MOD(e.empno,e.sal)<sal  or  instr(e.ename, 'S') >tno  ORDER BY empno;            


--echo   instr-6-3-1
SELECT   *   FROM   emp e   WHERE   e.sal =instr(e.ename, 'S')    ORDER BY e.EMPNO,e.sal;              


--echo   instr-6-3-2
SELECT   *   FROM   emp e   WHERE   e.sal >= instr(e.ename, 'S')   ORDER BY e.EMPNO,e.sal;          


--echo   instr-6-3-3
SELECT   *   FROM   emp e   WHERE   e.sal < instr(e.ename, 'S')     ORDER BY e.EMPNO,e.sal;          


--echo   instr-6-3-4
SELECT   *   FROM   emp e   WHERE   e.sal <= instr(e.ename, 'S')    ORDER BY e.EMPNO,e.sal;          


--echo   instr-6-3-5
SELECT   *   FROM   emp e   WHERE   e.sal != instr(e.ename, 'S')    ORDER BY e.EMPNO,e.sal;          


--echo   instr-6-3-6
SELECT   *   FROM   emp e   WHERE   e.sal <> instr(e.ename, 'S')    ORDER BY e.EMPNO,e.sal;          



drop   table  if  exists   emp;
create   TABLE   EMP (empno int,ename VARCHAR(10),job VARCHAR(9),mgr int,hiredate DATE,
sal FLOAT(7,0),comm FLOAT(7,0),deptno int,tno int);


--echo  instr-7-1-1  无参数的存储过程
drop procedure if exists myproc1;
delimiter //;
create procedure myproc1()
begin
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7369, 'SMITH001', 'CLERK001', 7902, '7980-12-07',  800, null, instr('helloworld','l'),1);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7370, 'SMITH002', 'CLERK002', 7902, '7980-12-07',  900, 15, instr('helloworld','o'),2);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7371, 'SMITH003', 'CLERK003', 7902, '7980-12-07',  250, 25, instr('helloworld','w'),3);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7372, 'SMITH004', 'CLERK004', 7902, '7980-12-07',  100, 35, instr('helloworld','d'),4);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7373, 'SMITH005', 'CLERK005', 7902, '7980-12-07',  200, 45, instr('helloworld','e'),5);
end 
//
DELIMITER ;//
call myproc1();
select  *  from   emp e order by  e.empno;




--echo  instr-7-1-2    只有一个 in 参数的存储过程 
drop procedure if exists myproc2;
delimiter //;
create procedure myproc2(in userId int)
begin
    SELECT    substr(e.ename,userId/10, instr(e.ename, 'S'))      FROM emp  e;
end
//
DELIMITER ;//
set @dum =10;
call myproc2(@dum);
SELECT    substr(e.ename,@dum/10, instr(e.ename, 'S'))      FROM emp  e;


--echo  instr-7-1-3    :包含 in 参数和 out 参数的存储过程,只能将一行的查询到的用户名赋值给username 
drop procedure if exists myproc3;
delimiter //;
create procedure myproc3(in userId int, out username varchar(20))
begin
set username= userId;	
SELECT *  FROM emp d where  d.DEPTNO> username;		
end
//
DELIMITER ;//
-- echo --  调用时，传入查询的userid 和 全局变量 @username
call myproc3(instr('helloworld','l'),@username);
select  *  from   emp e order by  e.empno;



--echo  instr-7-1-4     包含 inout 参数的存储过程
drop procedure if exists myproc4;
delimiter //;
create procedure myproc4(inout a char(10))
begin
SELECT     instr(a,'l')     FROM emp  e;	
end//

DELIMITER ;//
-- echo --  用户变量 （全局的变量）作用域： 用户变量: 在当前连接（即当前会话）中都有效
set @num ='helloworld';
call  myproc4(@num);
SELECT     instr(@num,'l')     FROM emp  e;	


--echo   instr-7-2-1 无参数的自定义函数
drop function  IF EXISTS salemp001;
DELIMITER //;
CREATE FUNCTION salemp001(saller001 int) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;#定义局部变量并初始化
SELECT  sum(instr('helloworld','l'))  INTO ag #为局部变量赋值
FROM emp e INNER JOIN dept d ON e.DEPTNO=d.DEPTNO where  e.sal >saller001 GROUP BY d.DEPTNO having d.DEPTNO>1;
RETURN ag;
end//
DELIMITER ;//
SELECT salemp001(100);


--echo   instr-7-2-2  自定义函数  有参数

drop function  IF EXISTS salemp001;
DELIMITER //;
CREATE FUNCTION salemp001(saller001 int) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;#定义局部变量并初始化
SELECT   sum(instr('helloworld','l')) INTO ag #为局部变量赋值
FROM emp e INNER JOIN dept d ON e.DEPTNO=d.DEPTNO where  e.sal >saller001 GROUP BY d.DEPTNO having d.DEPTNO>10;
RETURN ag;
end//
DELIMITER ;//
SELECT salemp001(100);



--echo   instr-7-2-3   自定义函数使用循环 

drop function  IF EXISTS salemp001;
DELIMITER //;
CREATE FUNCTION salemp001(saller001 int) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;
DECLARE i INT DEFAULT 1;
WHILE i<=1000 DO
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (saller001+i*10, 'SMITH001', 'CLERK001', 7902, '7980-12-07',  800, null, instr('helloworld','l'),1);
SET i = i+1;
END WHILE;
SELECT  count(*)  into  ag   from   EMP;
RETURN ag;
end
//
DELIMITER ;//
SELECT salemp001(100);

drop database  IF EXISTS  ob100x;

