#description: mod函数
#tags: pl, sql,数据类型,常用函数，存储过程
#author: wb-mcl707228

drop database  IF EXISTS  ob100x;
create database ob100x  character set utf8;
use ob100x;
select database();



--echo     instr-1-1  0个参数
--error    1582                   
SELECT instr() FROM dual;

--echo     instr-2-1  1个参数
--error    1582               
SELECT instr(500) FROM dual;


--echo    instr-1-3-1    第一个参数包含第二个参数
select instr('helloworld','l') from dual;


--echo     instr-1-3-2   第一个参数不包含第二个参数
select instr('helloworld','7') from dual;


--echo     instr-1-3-3     第一个参数等于第二个参数
select instr('helloworld','helloworld') from dual;

--echo     instr-1-3-4     第二个参数为空
select instr('helloworld','') from dual;

--echo     instr-1-3-5     第一个参数为空
select instr('','helloworld') from dual;

--echo     instr-1-3-6     第二个参数为null
select instr('helloworld',null) from dual;

--echo     instr-1-3-7     第一个参数为null
select instr(null,'helloworld') from dual;


--echo     instr-1-3-8    第二个参数包含第一个参数
select instr('hellow','helloworld') from dual;


--echo     instr-1-4-1     起始位置和匹配序号能匹配到值
--error   1582
select instr('helloworld','l',2,2) from dual;


--echo      instr-1-4-2    起始位置和匹配序号不能匹配到值 
--error   1582
select instr('helloworld','l',5,2) from dual;

--echo     instr-1-4-3    起始位置大于字符串长度 
--error   1582
select instr('helloworld','l',15,2) from dual;

--echo     instr-1-4-4    匹配序号过大
--error   1582
select instr('helloworld','l',2,4) from dual;

--echo     instr-1-4-5   匹配序号为0
--error   1582
select instr('helloworld','l',2,4) from dual;

--echo     instr-1-4-6   匹配序号为负数
--error   1582
select instr('helloworld','l',2,-4) from dual;

--echo     instr-1-4-7  起始位置为0
--error   1582
select instr('helloworld','l',0,1) from dual;

--echo     instr-1-4-8  起始位置为负数
--error   1582
select instr('helloworld','l',-10,4) from dual;


--echo    instr-2-1-1    char               
drop   table  if  exists   emp;
create table EMP(a char(20));
insert into EMP values('helloworld');
select instr(a,'l') from EMP;


--echo    instr-2-1-2   varchar2    
drop   table  if  exists   emp;
create table EMP(a VARCHAR(20));
insert into EMP values('helloworld');
select instr(a,'l') from EMP;


--echo  instr-2-1-3   TEXT               
drop   table  if  exists   emp;
create table EMP(a  TEXT);
insert into EMP values('helloworld');
select instr(a,'l') from EMP;

--echo  instr-2-1-4   BLOB
drop   table  if  exists   emp;
create table EMP(a BLOB(20));
insert into EMP values('helloworld');
select instr(a,'l') from EMP;


--echo    instr-2-2-1    int    
drop   table  if  exists   emp;
create table EMP(a  INT); 
insert into EMP values('10000');
select instr(a,'l') from EMP;

--echo    instr-2-2-2    float        

drop   table  if  exists   emp;
create table EMP(a FLOAT);
insert into EMP values('10000');
select instr(a,'l') from EMP;


--echo    instr-2-2-3    DOUBLE
drop   table  if  exists   emp;
create table EMP(a  DOUBLE); 
insert into EMP values('10000');
select instr(a,'0') from EMP;

--echo    instr-2-2-4    BOOL
drop   table  if  exists   emp;
create table EMP(a BOOL);
insert into EMP values('100');
select instr(a,'0') from EMP;

  
--echo    instr-2-2-5    DECIMAL
drop   table  if  exists   emp;
create table EMP(a DECIMAL);
insert into EMP values('10000');
select instr(a,'0') from EMP;


--echo    instr-2-3-1   LONGTEXT             
drop   table  if  exists   emp;
create table EMP(a LONGTEXT);
insert into EMP values('10000');
select instr(a,'0') from EMP;

--echo    instr-2-3-2  BINARY
drop   table  if  exists   emp;
create table EMP(a BINARY);
insert into EMP values('0');
select instr(a,'0') from EMP;


--echo    instr-2-3-3   blob        
drop   table  if  exists   emp;
create table EMP(a BLOB);
insert into EMP values('10000');
select instr(a,'0') from EMP;


drop   table  if  exists   emp;
create   TABLE   EMP (empno int,ename VARCHAR(10),job VARCHAR(9),mgr int,hiredate DATE,
sal FLOAT(7,0),comm FLOAT(7,0),deptno int,tno int);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7369, 'SMITH001', 'CLERK001', 7902, '7980-12-07',  800, null, 20,1);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7370, 'SMITH002', 'CLERK002', 7902, '7980-12-07',  900, 15, 10,2);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7371, 'SMITH003', 'CLERK003', 7902, '7980-12-07',  250, 25, 50,3);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7372, 'SMITH004', 'CLERK004', 7902, '7980-12-07',  100, 35, 30,4);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7373, 'SMITH005', 'CLERK005', 7902, '7980-12-07',  200, 45, 80,5);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7374, 'SMITH006', 'CLERK002', 7902, '7980-12-07',  300, 55, 10,6);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7375, 'SMITH007', 'CLERK003', 7902, '7980-12-07',  400, 65, 20,7);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7376, 'SMITH008', 'CLERK006', 7902, '7980-12-07',  500, null, 20,8);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7377, 'SMITH009', 'CLERK008', 7902, '7980-12-07',  600, 75, 30,9);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7378, 'SMITH010', 'CLERK009', 7902, '7980-12-07',  800, 95, 20,10);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7379, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, 20,11);


--echo   instr-3-1-1-1  select   
SELECT instr(e.ename, 'M')   eee FROM EMP e   ORDER  BY   eee  desc;


--echo   instr-3-1-1-2  select嵌套 
--error   1582
SELECT instr(e.ename,'S',instr(e.ename, 'M'),1)   eee FROM EMP e   ORDER  BY   eee  desc;

--echo   instr-3-1-1-3    some,any,all
SELECT sum(instr(e.ename, 'M'))   eee FROM EMP e   ORDER  BY   eee  desc;
SELECT min(instr(e.ename, 'M'))   eee FROM EMP e   ORDER  BY   eee  desc;
SELECT max(instr(e.ename, 'M'))   eee FROM EMP e   ORDER  BY   eee  desc;
SELECT avg(instr(e.ename, 'M'))   eee FROM EMP e   ORDER  BY   eee  desc;


--echo   instr-3-1-1-4    create as        
drop   table  if  exists   EMP001;
DROP VIEW  if  exists   EMP001;
create TABLE    EMP001   as  SELECT instr(e.ename, 'M')   eee FROM EMP e   ORDER  BY   eee  desc;
select  *    FROM    EMP001   ORDER BY  eee;


--echo   instr-3-1-2   where  语句    
select        instr(e.ename, 'S')   eee   from    emp e  WHERE  e.sal > 2000    ORDER  BY   eee;


--echo   instr-3-1-3     order by 子句
select        instr(e.ename, 'S')   eee   from    emp e  WHERE  e.sal > 2000  OR   e.sal <1000     ORDER  BY   eee;




--echo   instr-3-1-4     group by   子句
select        instr(e.ename, 'S')    eee    from    emp e    GROUP  BY   e.ename   ORDER BY eee;



--echo   instr-3-1-5     group by  having   子句
select        instr(e.ename, 'S')    eee    from    emp e    GROUP  BY   e.ename   HAVING   instr(e.ename, 'S')>0   ORDER BY eee;




--echo     instr-3-2-1   根据字段插入
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (9000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, instr('helloworld','l'),11);
select  *    FROM    EMP    e   WHERE   e.EMPNO=9000;



--echo     instr-3-2-2    根据表插入
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (8000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, instr('helloworld','l'),11);
select  *    FROM    EMP    e   WHERE   e.EMPNO=8000;


--echo     instr-3-2-3    插入语句中使用嵌套
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, instr('helloworld','l'),11);
select  *    FROM    EMP    e   WHERE   e.EMPNO=7000;


--echo     instr-3-3-1   单列              
UPDATE    EMP  e  SET    e.DEPTNO = instr('helloworld','l')   WHERE   e.EMPNO = 7369;
select  *    FROM    EMP    e   WHERE   e.EMPNO=7369;


--echo     instr-3-3-2  多列      
UPDATE    EMP  e  SET    e.DEPTNO = instr('helloworld','l');
select  *    FROM    EMP    e   ORDER  BY e.EMPNO,e.TNO;


--echo     instr-3-4-1   单列              
DELETE  FROM     EMP      WHERE   EMPNO = 7369  and  DEPTNO = instr('helloworld','l');
select  *    FROM    EMP       WHERE   EMPNO=7369;


--echo     instr-3-4-2  多列      
DELETE  FROM     EMP      WHERE    DEPTNO = instr('helloworld','l');
select      count(*)     FROM    EMP;

--echo    instr-3-5    多列
with e as (SELECT   instr('helloworld','l')  from    emp e)  select * from e;


insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (8000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, instr('helloworld','l'),11);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (8000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, instr('helloworld','l'),11);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (8000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, instr('helloworld','l'),11);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (8000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, instr('helloworld','l'),11);


--echo    instr-3-6     CASE WHEN语句
SELECT   sum(empno),  COUNT (CASE WHEN  instr('helloworld','l') = 1 THEN 1 
                         ELSE       NULL      END) 数据A,         
                         COUNT (CASE WHEN instr('helloworld','l') = 2 THEN 1                      
                         ELSE       NULL       END) 数据B   
                         FROM EMP e   ORDER  BY MOD(e.empno,e.sal);
                        
                                          

drop   table  if  exists   emp;
create   TABLE   EMP (empno int,ename VARCHAR(10),job VARCHAR(9),mgr int,hiredate DATE,
sal FLOAT(7,0),comm FLOAT(7,0),deptno int,tno int);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7369, 'SMITH001', 'CLERK001', 7902, '7980-12-07',  800, null, 20,1);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7370, 'SMITH002', 'CLERK002', 7902, '7980-12-07',  900, 15, 10,2);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7371, 'SMITH003', 'CLERK003', 7902, '7980-12-07',  250, 25, 50,3);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7372, 'SMITH004', 'CLERK004', 7902, '7980-12-07',  100, 35, 30,4);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7373, 'SMITH005', 'CLERK005', 7902, '7980-12-07',  200, 45, 80,5);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7374, 'SMITH006', 'CLERK002', 7902, '7980-12-07',  300, 55, 10,6);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7375, 'SMITH007', 'CLERK003', 7902, '7980-12-07',  400, 65, 20,7);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7376, 'SMITH008', 'CLERK006', 7902, '7980-12-07',  500, null, 20,8);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7377, 'SMITH009', 'CLERK008', 7902, '7980-12-07',  600, 75, 30,9);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7378, 'SMITH010', 'CLERK009', 7902, '7980-12-07',  800, 95, 20,10);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7379, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, 20,11);


drop   table  if  exists   EMP001;                     
CREATE OR  REPLACE  VIEW EMP001 AS   SELECT  *    FROM   emp;

--echo   instr-4-1-1-1-1  select   
SELECT instr(e.ename, 'M')   eee   FROM EMP001 e   ORDER BY  eee;


--echo   instr-4-1-1-1-2  select嵌套 
--error  1582
select       instr(e.ename, 'M', instr(e.ename, 'M'),  instr(e.ename, 'M'))  eee   from    EMP001 e   ORDER BY  eee;


--echo   instr-4-1-1-1-3    聚合函数
SELECT sum(instr(e.ename, 'M'))   eee FROM EMP001 e   ORDER  BY   eee  desc;
SELECT min(instr(e.ename, 'M'))   eee FROM EMP001 e   ORDER  BY   eee  desc;
SELECT max(instr(e.ename, 'M'))   eee FROM EMP001 e   ORDER  BY   eee  desc;
SELECT avg(instr(e.ename, 'M'))   eee FROM EMP001 e   ORDER  BY   eee  desc;


--echo   instr-4-1-1-1-4    create as        
drop   table  if  exists   EMP002;
create TABLE    EMP002   as   SELECT   instr(e.ename,'M')  eee   from    EMP001 e;
select  *    FROM    EMP002;


--echo   instr-4-1-1-2   where  语句    
select      instr(e.ename, 'S')    eee  from    EMP001 e  WHERE  e.sal > 200  ORDER BY  eee;


--echo   instr-4-1-1-3     order by 子句
select       instr(e.ename, 'L') eee   from    EMP001 e        ORDER BY  eee;  




--echo   instr-4-1-1-4     group by   子句
select      instr(e.ename, 's')  eee    from    EMP001 e    GROUP  BY   e.ename    ORDER BY  eee;


--echo   instr-4-1-1-5     group by  having   子句
select      instr(e.ename, 'S')  eee    from    EMP001 e    GROUP  BY   e.ename    HAVING   LENGTH(e.ename)>0   ORDER BY  eee;


--echo     instr-4-1-2-1   根据字段插入
insert into EMP001 (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (9000, 'SMITH', 'CLERK', 7902,  '1980-12-17', 800, null, instr('helloworld','l'),1);
select  *    FROM    EMP001    e   WHERE   e.EMPNO=9000;



--echo     instr-4-1-2-2    根据表插入
insert into EMP001 values (8000, 'SMITH', 'CLERK', 7902,  '1980-12-17', 800, null, instr('helloworld','l'),1);
select  *    FROM    EMP001    e   WHERE   e.EMPNO=8000;


--echo     instr-4-1-2-3    插入语句中使用嵌套
insert into EMP001 values (7000, 'SMITH', 'CLERK', 7902,  '1980-12-17', 800, null, instr('helloworld', CAST(instr('helloworld','l') AS CHAR)),1);
select  *    FROM    EMP001    e   WHERE   e.EMPNO=7000;


--echo     instr-4-1-3-1   单列              
UPDATE    EMP001  e  SET    e.DEPTNO =instr('helloworld','l')   WHERE   e.EMPNO = 7369;
select  *    FROM    EMP001    e   WHERE   e.EMPNO=7369;


--echo     instr-4-1-3-2  多列      
UPDATE    EMP001  e  SET    e.DEPTNO = instr('helloworld','l');
select  *    FROM    EMP001    e   ORDER  BY e.EMPNO,e.TNO;


--echo     instr-4-1-4-1   单列              
DELETE  FROM     EMP001       WHERE   EMPNO = 7369   and   DEPTNO = instr('helloworld','l');
select  *    FROM    EMP001        WHERE   EMPNO=7369;


--echo     instr-4-1-4-2  多列      
DELETE          FROM     EMP001  WHERE     DEPTNO = instr('helloworld','l');
select      count(*)     FROM    EMP001;

--echo    instr-4-1-5    多列
with e as (SELECT    instr(e.ename, 'S')  from    EMP001 e)  select * from e;

--echo    instr-4-1-6     CASE WHEN语句
SELECT   sum(empno),  COUNT (CASE WHEN  instr(e.ename, 'S') = 1 THEN 1 
                         ELSE       NULL      END) 数据A,         
                         COUNT (CASE WHEN instr(e.ename, 'S')= 2 THEN 1                      
                         ELSE       NULL       END) 数据B   
                         FROM EMP001 e   ORDER  BY MOD(e.empno,e.sal);



                        
