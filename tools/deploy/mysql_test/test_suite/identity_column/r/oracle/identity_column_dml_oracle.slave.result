result_format: 4
drop table t1;
drop table t2;
drop table t3;
drop table t4;
purge recyclebin;

create table t1(i int, j int generated always as identity);
create table t2(i int, j int);
create table t3(i int, j int);

insert into t2 values(20,21);
insert into t3 values(30,null);

