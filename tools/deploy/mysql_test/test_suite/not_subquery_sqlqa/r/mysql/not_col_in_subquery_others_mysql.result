| c1 | c2         | c3      |
+----+------------+---------+
|  0 | cat        | 8001.11 |
|  1 | NULL       | 8001.01 |
|  2 | yellow cat |  100.00 |
|  3 |            | 8888.88 |
|  5 | yellow cat |    NULL |
|  6 |            |    NULL |
|  7 | white cat  |    NULL |
+----+------------+---------+
