WITH 
temp AS (SELECT e.cat_id,e.name FROM t_category e WHERE  not e.cat_id IN (1,2) ORDER BY e.cat_id),
test1 AS (SELECT p.cat_id,p.name FROM t_category p WHERE not p.name  IN ('Kitchenware','Household Electric Appliances') ORDER BY p.cat_id)
SELECT e.cat_id,e.name  FROM temp e,test1 p WHERE e.cat_id = p.cat_id and  e.cat_id  in (SELECT p.cat_id from test1 p where not p.cat_id = any (SELECT c1 from t1)) ORDER BY 1,2;
