# not in subquery 在外层查询位置
WITH 
temp AS (SELECT e.cat_id,e.name,e.parent_cid FROM t_category e WHERE  not e.cat_id IN (1,2) ORDER BY e.cat_id),
test1 AS (SELECT p.cat_id,p.name,p.parent_cid  FROM t_category p WHERE not p.name  IN ('Kitchenware','Household Electric Appliances') ORDER BY p.cat_id)
SELECT e.cat_id,e.name  FROM temp e,test1 p WHERE p.parent_cid = e.cat_id and not e.cat_id in (SELECT e.cat_id from temp e where e.cat_id =7) ORDER BY 1,2;
