#删除用户、释放空间
#Environmental cleaning
drop user zhe123@'%';
drop database zhe123;
create database zhe123;
create user zhe123 identified by 'zhe123';
grant all on *.* to zhe123 WITH GRANT OPTION;
# 测试数据，c1为主键
drop table t1;
create table t1 (c1 int primary key, c2 varchar(50),c3 DECIMAL(8,2),c4 date)
partition by range (c1) (partition p0 values less than (3),partition p1 values less than (6));
insert into t1 values(0,'cat',1.11,str_to_date('20210202','%Y%m%d'));
insert into t1 values(1,null,0.01,str_to_date('20210101','%Y%m%d'));
insert into t1 values(2,'yellow cat',100,str_to_date('20211212','%Y%m%d'));
insert into t1 values(3,'',8888.88,str_to_date('20210323','%Y%m%d'));
drop table t2;
create table t2 (c1 int primary key, c2 varchar(50),c3 DECIMAL(8,2),c4 date);
insert into t2 values(1,null,4444.44,str_to_date('20211212','%Y%m%d'));
insert into t2 values(2,'yellow cat',1.11,str_to_date('20210202','%Y%m%d'));
insert into t2 values(3,'',2.22,str_to_date('20210303','%Y%m%d'));
insert into t2 values(4,'white cat',100,str_to_date('20210101','%Y%m%d'));
drop table t3;
create table t3 (c1 int primary key, c2 varchar(50),c3 DECIMAL(8,2),c4 date);
insert into t3 values(1,null,4444.44,str_to_date('20211212','%Y%m%d'));
insert into t3 values(5,'yellow cat',1.11,str_to_date('20210202','%Y%m%d'));
insert into t3 values(6,'',2.22,str_to_date('20210303','%Y%m%d'));
insert into t3 values(7,'white cat',100,str_to_date('20210101','%Y%m%d'));
# not col 比较运算符 (subquery)
result_format: 4
explain_protocol: 2
EXPLAIN SELECT a.c1 FROM t1 a INNER JOIN t2 b on a.c1=b.c1 WHERE  NOT a.c1 != (SELECT MAX(a.c1) FROM t2 a ) ORDER BY a.c1;
Query Plan
=======================================================================
|ID|OPERATOR                         |NAME      |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------------
|0 |PX COORDINATOR MERGE SORT        |          |1       |11          |
|1 |└─EXCHANGE OUT DISTR             |:EX10001  |1       |11          |
|2 |  └─HASH JOIN                    |          |1       |11          |
|3 |    ├─EXCHANGE IN DISTR          |          |1       |6           |
|4 |    │ └─EXCHANGE OUT DISTR (PKEY)|:EX10000  |1       |6           |
|5 |    │   └─MERGE JOIN             |          |1       |5           |
|6 |    │     ├─SUBPLAN SCAN         |VIEW1     |1       |3           |
|7 |    │     │ └─SCALAR GROUP BY    |          |1       |3           |
|8 |    │     │   └─SUBPLAN SCAN     |VIEW2     |1       |3           |
|9 |    │     │     └─TABLE FULL SCAN|a(Reverse)|1       |3           |
|10|    │     └─TABLE FULL SCAN      |b         |4       |3           |
|11|    └─PX PARTITION ITERATOR      |          |4       |5           |
|12|      └─TABLE FULL SCAN          |a         |4       |5           |
=======================================================================
