WITH RECURSIVE temp AS
(
SELECT count(t.cat_id),t.name,t.parent_cid,t.product_count FROM t_category t where not t.cat_id in (SELECT c1 from t1 where not c1 = (SELECT max(c1) from t2 where c2 is not null)) GROUP BY cat_level HAVING (sum(product_count)<500)
UNION ALL
SELECT c.cat_id,c.name,c.parent_cid,c.product_count FROM t_category c,temp r WHERE c.cat_id=r.parent_cid and not r.parent_cid in (SELECT c1 from t3 where not c3 in (SELECT c3 from t1 where c2 is null ) )
) SELECT * FROM temp where not name in (SELECT t.name from t_category t where t.cat_id in (SELECT c1 from t1 )) ;
