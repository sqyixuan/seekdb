test1 AS (SELECT p.cat_id,p.name FROM t_category p WHERE not p.name  IN ('Kitchenware','Household Electric Appliances') and  not p.product_count > any (SELECT sum (product_count ) from t_category e group by parent_cid having sum (product_count )>100) ORDER BY p.cat_id)
SELECT e.cat_id,e.name  FROM temp e,test1 p WHERE e.cat_id = p.cat_id and  not e.cat_id  in (SELECT e.cat_id from temp e where not e.cat_id = some (SELECT e.cat_id from temp e)) ORDER BY 1,2;
