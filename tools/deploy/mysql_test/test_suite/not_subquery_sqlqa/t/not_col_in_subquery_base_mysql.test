--echo #删除用户、释放空间
--echo #Environmental cleaning
--disable_warnings
--error 0,1396
drop user zhe123@'%';
--enable_warnings
--error 0,1008
drop database zhe123;
create database zhe123;
create user zhe123 identified by 'zhe123';
grant all on *.* to zhe123 WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zhe123,zhe123,test,$OBMYSQL_PORT);
connection conn;


--echo # 测试数据，c1为主键
--error 0,1051
drop table t1;
create table t1 (c1 int primary key, c2 varchar(50),c3 DECIMAL(8,2),c4 date)
partition by range (c1) (partition p0 values less than (3),partition p1 values less than (6));

insert into t1 values(0,'cat',1.11,str_to_date('20210202','%Y%m%d'));
insert into t1 values(1,null,0.01,str_to_date('20210101','%Y%m%d'));
insert into t1 values(2,'yellow cat',100,str_to_date('20211212','%Y%m%d'));
insert into t1 values(3,'',8888.88,str_to_date('20210323','%Y%m%d'));

--error 0,1051
drop table t2;

create table t2 (c1 int primary key, c2 varchar(50),c3 DECIMAL(8,2),c4 date);

insert into t2 values(1,null,4444.44,str_to_date('20211212','%Y%m%d'));
insert into t2 values(2,'yellow cat',1.11,str_to_date('20210202','%Y%m%d'));
insert into t2 values(3,'',2.22,str_to_date('20210303','%Y%m%d'));
insert into t2 values(4,'white cat',100,str_to_date('20210101','%Y%m%d'));

--error 0,1051
drop table t3;

create table t3 (c1 int primary key, c2 varchar(50),c3 DECIMAL(8,2),c4 date);

insert into t3 values(1,null,4444.44,str_to_date('20211212','%Y%m%d'));
insert into t3 values(5,'yellow cat',1.11,str_to_date('20210202','%Y%m%d'));
insert into t3 values(6,'',2.22,str_to_date('20210303','%Y%m%d'));
insert into t3 values(7,'white cat',100,str_to_date('20210101','%Y%m%d'));


--echo # not col 比较运算符 (subquery)
--result_format 4
--explain_protocol 2
SELECT a.c1 FROM t1 a INNER JOIN t2 b on a.c1=b.c1 WHERE  NOT a.c1 != (SELECT MAX(a.c1) FROM t2 a ) ORDER BY a.c1;
SELECT /*+ NO_REWRITE */ a.c1 FROM t1 a INNER JOIN t2 b on a.c1=b.c1 WHERE  NOT a.c1 != (SELECT MAX(a.c1) FROM t2 a ) ORDER BY a.c1;
SELECT a.c1 FROM t1 a INNER JOIN t2 b on a.c1=b.c1 WHERE  NOT a.c1 > (SELECT MAX(a.c1) FROM t2 a ) ORDER BY a.c1;
SELECT /*+ NO_REWRITE */ a.c1 FROM t1 a INNER JOIN t2 b on a.c1=b.c1 WHERE  NOT a.c1 > (SELECT MAX(a.c1) FROM t2 a ) ORDER BY a.c1;

SELECT a.c1 FROM t1 a INNER JOIN t2 b on a.c1=b.c1 WHERE  NOT a.c1 = (SELECT MAX(a.c1) FROM t2 a ) ORDER BY a.c1;
SELECT /*+ NO_REWRITE */ a.c1 FROM t1 a INNER JOIN t2 b on a.c1=b.c1 WHERE  NOT a.c1 = (SELECT MAX(a.c1) FROM t2 a ) ORDER BY a.c1;
SELECT a.c3 FROM t1 a INNER JOIN t2 b on a.c1=b.c1 WHERE NOT a.c3 = (SELECT MAX(a.c3) FROM t2 a INNER JOIN t2 b on a.c1=b.c1 where exists (SELECT c1 from t1 where not c3 =any(SELECT c3 from t2))) ORDER BY a.c1;
SELECT /*+ NO_REWRITE */ a.c3 FROM t1 a INNER JOIN t2 b on a.c1=b.c1 WHERE NOT a.c3 = (SELECT MAX(a.c3) FROM t2 a INNER JOIN t2 b on a.c1=b.c1 where exists (SELECT c1 from t1 where not c3 =any(SELECT c3 from t2))) ORDER BY a.c1;

SELECT a.c4 FROM t1 a WHERE not c4 = any(SELECT c4 from t2);
SELECT /*+ NO_REWRITE */ a.c4 FROM t1 a WHERE not c4 = any(SELECT c4 from t2);
SELECT a.c4 FROM t1 a WHERE not c4 = (SELECT max(c4) from t2);
SELECT /*+ NO_REWRITE */ a.c4 FROM t1 a WHERE not c4 = (SELECT max(c4) from t2);
SELECT a.c4 FROM t1 a WHERE not c4 > (SELECT max(c4) from t2);
SELECT /*+ NO_REWRITE */ a.c4 FROM t1 a WHERE not c4 > (SELECT max(c4) from t2);

SELECT a.c3 FROM t1 a WHERE not c2 = (SELECT min(c2) from t2 where not c3 =(SELECT min(c3) from t1));
SELECT /*+ NO_REWRITE */ a.c3 FROM t1 a WHERE not c2 = (SELECT min(c2) from t2 where not c3 =(SELECT min(c3) from t1));
SELECT a.c3 FROM t1 a WHERE not (SELECT min(c2) from t1 where c2 is null) = (SELECT min(c2) from t2 where not c3 =(SELECT min(c3) from t1));
SELECT /*+ NO_REWRITE */ a.c3 FROM t1 a WHERE not (SELECT min(c2) from t1 where c2 is null) = (SELECT min(c2) from t2 where not c3 =(SELECT min(c3) from t1));
SELECT a.c2 FROM t1 a WHERE not (SELECT min(c2) from t1 where c2 is not null) = (SELECT min(c2) from t2 where not c3 =(SELECT min(c3) from t1));
SELECT /*+ NO_REWRITE */ a.c2 FROM t1 a WHERE not (SELECT min(c2) from t1 where c2 is not null) = (SELECT min(c2) from t2 where not c3 =(SELECT min(c3) from t1));
SELECT a.c2 FROM t1 a WHERE not c3*2+1 = (SELECT min(c3) from t2 where not c3 =(SELECT min(c3) from t1));
SELECT /*+ NO_REWRITE */ a.c2 FROM t1 a WHERE not c3*2+1 = (SELECT min(c3) from t2 where not c3 =(SELECT min(c3) from t1));
SELECT a.c2 from t1 a where not a.c4 <> all (SELECT a.c4 from t1 a where a.c2 is not null) and a.c1 != any (SELECT a.c1 from t1 a where a.c2 is not null) order by a.c1;
SELECT /*+ NO_REWRITE */ a.c2 from t1 a where not a.c4 <> all (SELECT a.c4 from t1 a where a.c2 is not null) and a.c1 != any (SELECT a.c1 from t1 a where a.c2 is not null) order by a.c1;
SELECT a.c2 from t1 a where not a.c4 <> some (SELECT a.c4 from t1 a where a.c1 is null) and a.c1 != all (SELECT a.c3 from t1 where a.c1 is null) order by a.c1;
SELECT /*+ NO_REWRITE */ a.c2 from t1 a where not a.c4 <> some (SELECT a.c4 from t1 a where a.c1 is null) and a.c1 != all (SELECT a.c3 from t1 where a.c1 is null) order by a.c1;


