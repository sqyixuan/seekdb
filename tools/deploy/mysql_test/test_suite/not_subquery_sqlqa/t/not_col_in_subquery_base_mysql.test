--echo # mysql 递归查询分区表关联查询， not in subquery 在各个位置
WITH RECURSIVE temp AS
(
SELECT count(t.cat_id),t.name,t.parent_cid,t.product_count FROM t_category PARTITION(p0) t where not t.cat_id in (SELECT c1 from t1 where not c1 = (SELECT max(c1) from t2 where c2 is not null)) GROUP BY cat_level HAVING (sum(product_count)<500)
UNION ALL
