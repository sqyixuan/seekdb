SELECT c4 from t1 where not c4+1 = any (SELECT min(c4) from t2 group by c4 having (min(c1)>1)) and not (c1,c2) not in (SELECT max(t1.c1),min(t1.c2) from t2 inner join t1 on t2.c1=t1.c1 where t1.c1>0 and not (t1.c1,t1.c2) not in (SELECT c1,c2 from t2 where c2 is not null)group by t1.c1);
SELECT /*+ NO_REWRITE*/ c4 from t1 where not c4+1 = any (SELECT min(c4) from t2 group by c4 having (min(c1)>1)) and not (c1,c2) not in (SELECT max(t1.c1),min(t1.c2) from t2 inner join t1 on t2.c1=t1.c1 where t1.c1>0 and not (t1.c1,t1.c2) not in (SELECT c1,c2 from t2 where c2 is not null)group by t1.c1);
SELECT c4 from t1 where not c4+1 != any (SELECT min(c4) from t2 group by c4 having (min(c1)>1));
SELECT /*+ NO_REWRITE*/ c4 from t1 where not c4+1 != any (SELECT min(c4) from t2 group by c4 having (min(c1)>1));

