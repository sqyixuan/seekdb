--error 0,1051
drop table t1;
create table t1 (c1 int primary key, c2 varchar(50),c3 DECIMAL(8,2),c4 date)
partition by range (c1) (partition p0 values less than (3),partition p1 values less than (maxvalue));

insert into t1 values(0,'cat',1.11,str_to_date('20210202','%Y%m%d'));
insert into t1 values(1,null,0.01,str_to_date('20210101','%Y%m%d'));
insert into t1 values(2,'yellow cat',100,str_to_date('20211212','%Y%m%d'));
