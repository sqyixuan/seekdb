CREATE TABLE if not exists app_image_task (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`app_id` int(11) NOT NULL COMMENT 'app id', 
`status` varchar(12) NOT NULL COMMENT 'INQUEUE(队列中), SUCC(成功) 和FAILED(失败)', 
`session_id` varchar(32) NOT NULL COMMENT '提供app查询使用的Session_id', 
`result` varchar(1024) NOT NULL COMMENT '执行结果', 
`parameter` varchar(1024) NOT NULL COMMENT '执行参数', 
`group_id` int(11) NULL COMMENT '图片集合id11', 
`task_type` int(11) NOT NULL COMMENT '任务的类型', 
`service_id` int(11) NOT NULL COMMENT '服务id', 
`search_id` int(11) NOT NULL COMMENT '搜索id', 
PRIMARY KEY (`id`), 
KEY `status` (`status`), 
KEY `app_id` (`app_id`)
)  AUTO_INCREMENT = 99 CHARSET = utf8 COMMENT = '图片训练异步任务表';
CREATE TABLE if not exists app_info (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`app_name` varchar(32) NOT NULL COMMENT 'app 名字', 
`app_secret` varchar(32) NOT NULL COMMENT 'app 的密匙', 
`app_url` varchar(128) NULL COMMENT '图片服务平台api的请求url', 
`app_memo` varchar(1024) NOT NULL COMMENT '应用描述', 
`terminal_type` varchar(128) NULL COMMENT '应用运行环境（手机端，pc端等）', 
`service_type` varchar(128) NULL COMMENT '应用对外提供的服务类型（相册，人脸识别，封面识别等）', 
`app_max_time` int(11) NULL COMMENT '用户最大请求量', 
`app_owner` bigint(20) NOT NULL COMMENT 'app拥有者', 
`app_key` varchar(32) NOT NULL COMMENT 'app的key', 
`status` int(11) DEFAULT '0' COMMENT 'app的状态（删除：-1，测试中：0，待发布：1 ，已发布）', 
`app_member` varchar(256) NULL COMMENT 'app成员列表', 
`app_group` int(11) NULL COMMENT '应用所属分组，1-合作伙伴应用，2-淘宝官方应用，3-淘宝内部应用', 
PRIMARY KEY (`id`), 
UNIQUE `app_key` (`app_key`, `app_secret`)
)  AUTO_INCREMENT = 89 CHARSET = utf8 COMMENT = 'App应用配置表';
CREATE TABLE if not exists app_monitor (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`app_id` int(11) NULL COMMENT '应用id', 
`request_info` varchar(2048) NOT NULL COMMENT '监控记录（json）', 
`owner_id` int(11) NOT NULL COMMENT '拥有者id', 
`monitor_key` varchar(64) NOT NULL COMMENT '监控主键（比如接口id）', 
`count` int(11) DEFAULT '0' NOT NULL COMMENT '请求次数统计', 
PRIMARY KEY (`id`), 
KEY `app_id` (`app_id`)
)  AUTO_INCREMENT = 7773 CHARSET = utf8 COMMENT = '应用监控数据表';
CREATE TABLE if not exists app_permission (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`name` varchar(32) NOT NULL COMMENT '权限名', 
`name_key` varchar(32) NOT NULL COMMENT '权限字符串', 
PRIMARY KEY (`id`), 
UNIQUE `name_key` (`name_key`)
)  CHARSET = utf8 COMMENT = '用户权限表';
CREATE TABLE if not exists app_role (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`role_name` varchar(32) NOT NULL COMMENT '角色名', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '用户角色表';
CREATE TABLE if not exists app_role_permission (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`role_id` int(11) NOT NULL COMMENT '角色id', 
`permission_id` int(11) NOT NULL COMMENT '权限id', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '用户和权限关联表';
CREATE TABLE if not exists app_search (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`app_id` int(11) NULL COMMENT '应用表主键id', 
`service_id` int(11) NULL COMMENT '服务类型', 
`name` varchar(50) NULL COMMENT '图片搜索名', 
`status` int(11) NOT NULL COMMENT '状态', 
`max_size` int(11) DEFAULT '0' NOT NULL COMMENT '图片书籍集最大搜索数量', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 34 CHARSET = utf8 COMMENT = 'app搜索关联表';
CREATE TABLE if not exists app_source_image (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`app_id` int(11) NOT NULL COMMENT 'app id', 
`tfs_path` varchar(128) NOT NULL COMMENT 'app的tfs地址', 
`group_id` int(11) NULL COMMENT '数据分组11', 
`service_id` int(11) NOT NULL COMMENT '服务id', 
`search_id` int(11) NOT NULL COMMENT '搜索id', 
`info` varchar(5000) NULL COMMENT '图片信息', 
PRIMARY KEY (`id`), 
KEY `index1` (`app_id`, `group_id`)
)  AUTO_INCREMENT = 248626 CHARSET = utf8 COMMENT = 'App图片搜索源数据表';
CREATE TABLE if not exists app_user (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`name` varchar(32) NOT NULL COMMENT '名字', 
`password` varchar(32) NOT NULL COMMENT '密码', 
`role_id` int(11) NOT NULL COMMENT '角色id', 
`email` varchar(128) NOT NULL COMMENT 'email', 
`phone` varchar(32) NULL COMMENT '联系方式', 
PRIMARY KEY (`id`), 
UNIQUE `name` (`name`, `password`)
)  AUTO_INCREMENT = 1095274161683 CHARSET = utf8 COMMENT = 'app用户表';
CREATE TABLE if not exists app_user_image (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`app_id` int(11) NOT NULL COMMENT 'app_id', 
`tfs_path` varchar(64) NOT NULL COMMENT 'app的tfs_path', 
`memo` varchar(1024) NULL COMMENT '图片匹配结果', 
`match_result` varchar(1024) NULL COMMENT '用户提交的备注', 
`group_id` int(11) NULL COMMENT '数据分组', 
`service_id` int(11) NOT NULL COMMENT '服务di', 
`search_id` int(11) NOT NULL COMMENT '搜索id', 
PRIMARY KEY (`id`), 
KEY `app_id` (`app_id`, `group_id`)
)  AUTO_INCREMENT = 8955174 CHARSET = utf8 COMMENT = 'App用户提交图片数据表';
CREATE TABLE if not exists auction_tfs_mapper (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NULL COMMENT '创建时间', 
`gmt_modified` datetime NULL COMMENT '修改时间', 
`auction_id` bigint(20) NOT NULL COMMENT '商品ID', 
`tfs_path` varchar(256) NOT NULL COMMENT 'tfs path', 
`sid` bigint(20) UNSIGNED NOT NULL COMMENT '图像唯一标识', 
PRIMARY KEY (`id`), 
KEY `auction_id` (`auction_id`), 
KEY `sid` (`sid`)
)  AUTO_INCREMENT = 2962688 CHARSET = utf8 COMMENT = '维护商品ID与TFSPath映射关系';
CREATE TABLE if not exists chaoxing_item_image (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`item_id` bigint(20) NULL COMMENT '商品id', 
`image_url` varchar(200) NULL COMMENT '图片地址', 
`pt` date NULL COMMENT '数据所属日期', 
PRIMARY KEY (`id`), 
KEY `idx_pt` (`pt`)
)  AUTO_INCREMENT = 316623 CHARSET = utf8 COMMENT = '吵信商品图片表，用于datax数据回流';
CREATE TABLE if not exists clawer_movie_image (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`movie_id` int(11) NOT NULL COMMENT '关联id', 
`imageurl` varchar(128) NULL COMMENT '图片地址', 
`tfs_path` varchar(128) NULL COMMENT '图片tfs地址', 
`image_type` int(11) NOT NULL COMMENT '图片类型（0，剧照，1，海报）', 
`image_source` varchar(32) NOT NULL COMMENT '图片来源（taobao ，douban）', 
`status` int(11) NOT NULL COMMENT '1:正常 -1 删除', 
PRIMARY KEY (`id`), 
UNIQUE `tfs` (`tfs_path`), 
UNIQUE `imageurl` (`imageurl`)
)  AUTO_INCREMENT = 224231 CHARSET = utf8 COMMENT = '影片图片数据汇总';
CREATE TABLE if not exists clawer_movie_relative (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`tb_id` int(11) NULL COMMENT '淘宝movieId', 
`db_id` int(11) NULL COMMENT '豆瓣movieId', 
`info`varchar(100)COMMENT '信息', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 2911 CHARSET = utf8 COMMENT = '电影关联表';
CREATE TABLE if not exists clawer_result (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`info_key` varchar(20) NOT NULL COMMENT '唯一建', 
`site_domain` varchar(20) NOT NULL COMMENT '站点名', 
`result_json`varchar(100)COMMENT '爬取内容', 
PRIMARY KEY (`id`), 
UNIQUE `info_key` (`info_key`, `site_domain`)
)  AUTO_INCREMENT = 72620 CHARSET = utf8 COMMENT = '爬取结果表';
CREATE TABLE if not exists clawer_script (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`domain` varchar(64) NOT NULL COMMENT '解析网站域名', 
`status` tinyint(4) NULL COMMENT '状态', 
`version` int(11) NULL COMMENT '版本', 
`scriptcode`varchar(100)COMMENT '脚本代码', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '爬虫脚本';
CREATE TABLE if not exists clawer_tb_movie (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`movie_id` int(11) NOT NULL COMMENT '淘宝电影id', 
`open_day` date NULL COMMENT '上映时间', 
`remark` varchar(64) NULL COMMENT '评分', 
`director` varchar(64) NULL COMMENT '导演', 
`leading_role` varchar(64) NULL COMMENT '主演', 
`type` varchar(32) NULL COMMENT '类型', 
`description` bigint(20) UNSIGNED NULL COMMENT '描述', 
`show_name` bigint(20) UNSIGNED NOT NULL COMMENT '电影名', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '淘宝电影表';
CREATE TABLE if not exists data_reflow_for_create_task (
`attr1` varchar(100) NULL COMMENT '扩展字段1', 
`attr2` varchar(100) NULL COMMENT '扩展字段2', 
`attr3` varchar(100) NULL COMMENT '扩展字段3', 
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`pt` date NULL COMMENT '回流天数', 
`type` varchar(118) NULL COMMENT '创建任务类型', 
`tfs_name` varchar(256) NULL COMMENT '图片tfsname', 
`attr4` varchar(100) NULL COMMENT '扩展字段4', 
`attr5` varchar(100) NULL COMMENT '扩展字段5', 
PRIMARY KEY (`id`), 
KEY `idx_type_pt` (`type`, `pt`)
)  AUTO_INCREMENT = 2224692 CHARSET = utf8 COMMENT = '用于数据回流的先上表';
CREATE TABLE if not exists face_data_rec (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`tfs_path` varchar(256) NULL COMMENT '图像TFS Path', 
`feature`varchar(100)COMMENT '图像特征', 
`match_result` varchar(10) COMMENT '匹配结果', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '记录头像比对信息';
CREATE TABLE if not exists face_data_reg (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_nick` varchar(50) NULL COMMENT '用户Nick', 
`image_tfs_path` varchar(256) NOT NULL COMMENT '图片TFS Path', 
`feature`varchar(100)COMMENT '图片特征值', 
`email` varchar(50) NOT NULL COMMENT '邮箱, 用户的唯一标识', 
PRIMARY KEY (`id`), 
KEY `user_id` (`user_nick`), 
KEY `user_identify` (`email`, `user_nick`)
)  CHARSET = utf8 COMMENT = '存储人脸识别的相关源数据';
CREATE TABLE if not exists gpu_ids (
`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`type` varchar(64) NOT NULL COMMENT 'sequence类型', 
PRIMARY KEY (`type`)
)  CHARSET = utf8 COMMENT = 'gpu sequence';
CREATE TABLE if not exists image_library (
`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
`name` varchar(64) NOT NULL COMMENT '图片集名称', 
`source` int(11) NULL COMMENT '来源', 
`label` varchar(256) NULL COMMENT '标注', 
`tfs_path` varchar(256) NULL COMMENT 'tfs路径', 
`type` int(11) NULL COMMENT '训练还是校验', 
`attribute` varchar(2048) NULL COMMENT '附加属性', 
`status` int(11) NULL COMMENT '图片集状态', 
`parent_id` bigint(20) UNSIGNED NULL COMMENT '衍生源图集id', 
`template_id` bigint(20) UNSIGNED NULL COMMENT '图集的标注类型', 
`info` varchar(256) NULL COMMENT '描述标签，后面便于分类', 
`privacy` tinyint(4) DEFAULT '1' COMMENT '隐私,0公有,1私有', 
`level` tinyint(4) DEFAULT '3' COMMENT '权限等级', 
`app_key` varchar(256) NULL COMMENT '使用方申请的key', 
`app_id` bigint(20) UNSIGNED NULL COMMENT '使用方申请的id', 
`team_id` bigint(20) NULL COMMENT '绑定的团队id', 
PRIMARY KEY (`id`), 
KEY `idx_user_mod` (`user_id`, `gmt_modified`), 
KEY `idx_privacy_template` (`template_id`, `privacy`), 
KEY `idx_appkey` (`app_key`), 
KEY `idx_user_privacy` (`user_id`, `privacy`), 
KEY `idx_privacy_type` (`privacy`, `type`)
)  CHARSET = utf8 COMMENT = '图片集';
CREATE TABLE if not exists image_quality_barcode_detection (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`tfs` varchar(256) NOT NULL COMMENT '图片文件tfs地址', 
`image_score` varchar(64) NULL COMMENT '条码结果', 
PRIMARY KEY (`id`), 
KEY `gmt_create` (`gmt_create`)
)  CHARSET = utf8 COMMENT = '图像条码检测结果';
CREATE TABLE if not exists image_quality_facedetectopt (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`tfs` varchar(256) NULL COMMENT '图片tfs地址', 
`image_score` varchar(2048) NULL COMMENT '人脸检测结果', 
PRIMARY KEY (`id`), 
KEY `gmt_create` (`gmt_create`)
)  CHARSET = utf8 COMMENT = '人脸检测结果';
CREATE TABLE if not exists image_quality_full_text (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`tfs` varchar(256) NULL COMMENT '图片tfs地址', 
`image_result` varchar(2048) NULL COMMENT 'OCR识别结果', 
PRIMARY KEY (`id`), 
KEY `gmt_create` (`gmt_create`)
)  CHARSET = utf8 COMMENT = '图像OCR识别结果表';
CREATE TABLE if not exists image_quality_predict_category (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_type` varchar(64) NOT NULL COMMENT '用户类型', 
`category_level2` varchar(128) NULL COMMENT '二级类目ID', 
`pict_url` varchar(256) NULL COMMENT '图片地址', 
`predict_category` varchar(2048) NULL COMMENT '预测结果', 
PRIMARY KEY (`id`), 
KEY `gmt_create` (`gmt_create`)
)  CHARSET = utf8 COMMENT = '图片类目检测表';
CREATE TABLE if not exists image_quality_quanqiugou_fvdsift_t (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`tfs` varchar(256) NULL COMMENT '图片地址', 
`features` varchar(2048) NULL COMMENT '检测结果', 
PRIMARY KEY (`id`), 
KEY `gmt_create` (`gmt_create`)
)  CHARSET = utf8 COMMENT = '全球购检测结果表';
CREATE TABLE if not exists image_quality_textdetect (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`tfs` varchar(256) NULL COMMENT '图片地址', 
`image_score` varchar(64) NULL COMMENT '检测结果', 
PRIMARY KEY (`id`), 
KEY `gmt_create` (`gmt_create`)
)  CHARSET = utf8 COMMENT = '图片文本检测表';
CREATE TABLE if not exists image_quality_textsaliency (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`tfs` varchar(256) NULL COMMENT '图片地址', 
`image_score` varchar(64) NULL COMMENT '检测结果', 
PRIMARY KEY (`id`), 
KEY `gmt_create` (`gmt_create`)
)  CHARSET = utf8 COMMENT = 'image_quality_textsaliency';
CREATE TABLE if not exists image_quality_wbdetect (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`tfs` varchar(256) NULL COMMENT '图片地址', 
`image_result` varchar(2048) NULL COMMENT '图片检测结果', 
PRIMARY KEY (`id`), 
KEY `gmt_create` (`gmt_create`)
)  CHARSET = utf8 COMMENT = 'image_quality_wbdetect';
CREATE TABLE if not exists image_submit_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`width` int(11) NOT NULL COMMENT '图片的宽', 
`hight` int(11) NOT NULL COMMENT '图片的长', 
`tfspath` varchar(256) NOT NULL COMMENT '图片的tfs存放路径', 
`parser_result` varchar(5000) NULL COMMENT '解析的结果', 
`image_type` tinyint(4) NOT NULL COMMENT '图片类型', 
PRIMARY KEY (`id`), 
KEY `image_type_index` (`image_type`)
)  AUTO_INCREMENT = 39563 CHARSET = utf8 COMMENT = '用户上传的图片信息';
CREATE TABLE if not exists is_app (
`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`name` varchar(512) NULL COMMENT '应用名称', 
`description` varchar(1024) NULL COMMENT '应用描述', 
`tps` int(11) NULL COMMENT '数据访问tps', 
`data` int(11) NULL COMMENT '数据访问大小', 
`model_info` varchar(2048) NULL COMMENT '数据模型信息-json格式', 
`owen_odsp` bigint(20) UNSIGNED NULL COMMENT '是否自己拥有odps', 
`status` int(11) NULL COMMENT '应用状态', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '搜索服务应用信息';
CREATE TABLE if not exists is_application (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`name` varchar(64) NOT NULL COMMENT '名称', 
`app_id` int(11) NOT NULL COMMENT '应用ID', 
`app_key` varchar(32) NOT NULL COMMENT '应用Key', 
`service_info_id` int(11) NOT NULL COMMENT '服务ID', 
`applicant` int(11) NOT NULL COMMENT '申请人ID', 
`applicant_nick` varchar(64) NOT NULL COMMENT '申请人昵称', 
`type` tinyint(4) NOT NULL COMMENT '申请类型', 
`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '状态,-1-已删除，0-待审批，1-审批中，2-已通过，3-已拒绝', 
`param` varchar(10) COMMENT '申请提交的参数', 
`memo` varchar(1024) NULL COMMENT '备注或描述', 
`handle` int(11) NULL COMMENT '当前处理人ID', 
`handle_nick` varchar(64) NULL COMMENT '当前处理人昵称', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '最近修改时间', 
`extra` varchar(2046) NULL COMMENT '扩展字段', 
PRIMARY KEY (`id`), 
KEY `idx_aid_auid_s` (`app_id`, `applicant`, `status`)
)  AUTO_INCREMENT = 19 CHARSET = utf8 COMMENT = '图像服务接入申请表';
CREATE TABLE if not exists is_application_log (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`flow_id` int(11) NOT NULL COMMENT '申请流程id', 
`status` tinyint(4) NOT NULL COMMENT '审批状态', 
`handle` int(11) NOT NULL COMMENT '审批人id', 
`handle_nick` varchar(64) NOT NULL COMMENT '审批人昵称', 
`memo` varchar(1024) NULL COMMENT '备注', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '最近修改时间', 
PRIMARY KEY (`id`), 
KEY `idx_fid` (`flow_id`)
)  AUTO_INCREMENT = 45 CHARSET = utf8 COMMENT = '申请审批记录表';
CREATE TABLE if not exists is_common_feature_model (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`model_alias` varchar(200) NULL COMMENT '模型简称', 
`last_model` varchar(4000) NULL COMMENT '上次使用的模型文件，用于回滚', 
`cur_model` varchar(4000) NULL COMMENT '当前使用的模型文件   JSON-list=[{name=,tfspath=},{name=,tfspath=}] 字符串格式', 
`model_desc` varchar(4000) NULL COMMENT '模型详细描述信息，描述该模型适用在什么场景搜索，如女装、男装等', 
`train_time` datetime NULL COMMENT '上次训练的时间', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '图像搜索平台公共特征算法模型库管理';
CREATE TABLE if not exists is_engine (
`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`type` int(11) NULL COMMENT '引擎类型', 
`name` varchar(1024) NULL COMMENT '引擎名称', 
`jvm_heap` int(11) NULL COMMENT 'jvm heap内存大小', 
`version` int(11) NULL COMMENT '版本号', 
`description` varchar(1024) NULL COMMENT '引擎描述', 
`config` varchar(2048) NULL COMMENT '引擎配置信息', 
`search_app_id` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '引擎所属应用', 
PRIMARY KEY (`id`), 
KEY `idx_search_app_id` (`search_app_id`)
)  CHARSET = utf8 COMMENT = '图像搜索引擎信息表';
CREATE TABLE if not exists is_image_classify_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`image_url` varchar(1024) NULL COMMENT '图片地址', 
`classify_result` int(11) NULL COMMENT '2 商品，1旺旺截图 0 无法识别', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 71957 CHARSET = utf8 COMMENT = '图片类型的审核';
