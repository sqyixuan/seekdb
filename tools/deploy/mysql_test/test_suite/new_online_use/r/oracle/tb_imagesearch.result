)  AUTO_INCREMENT = 791583 CHARSET = utf8 COMMENT = '搜索应用数据节点监控历史数据';
CREATE TABLE if not exists platform (
`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`auto_train` int(11) NOT NULL COMMENT '0-人工训练1-自动训练', 
`argument` varchar(1024) NULL COMMENT '平台默认参数', 
`owner` varchar(1024) NULL COMMENT '负责人', 
`attribute` varchar(1024) NULL COMMENT '附加字段', 
`module_name` varchar(1024) NULL COMMENT '模型文件名称', 
`creator` bigint(20) UNSIGNED NOT NULL COMMENT '平台创建者', 
`task_dir_id` int(11) NULL COMMENT '默认任务存放位置', 
`description` varchar(2048) NULL COMMENT '平台描述', 
`param` varchar(512) NULL COMMENT '平台参数', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '平台表';
CREATE TABLE if not exists review_sample_single (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`ds` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`hh` bigint(20) UNSIGNED NOT NULL COMMENT '产生的小时数', 
`hostname` varchar(64) NOT NULL COMMENT '被调用主机名', 
`unique_key` varchar(40) NOT NULL COMMENT '唯一主键', 
`method_name` varchar(256) NOT NULL COMMENT '算法的方法名', 
`app_key` varchar(64) NOT NULL COMMENT '应用的Key', 
`input_params` varchar(512) NOT NULL COMMENT '算法的入参', 
`ret_value` varchar(2048) NOT NULL COMMENT '算法的返回结果', 
`can_review` varchar(8) NOT NULL COMMENT '是否要以被标注系统标注', 
`review_resources` varchar(2048) NOT NULL COMMENT '标注时需要的资源', 
`label_task_id` bigint(20) UNSIGNED NULL COMMENT '标注任务Id', 
`is_accepted` int(11) NULL COMMENT '结果是否被接受', 
`is_by_user_label` int(11) NULL COMMENT '是否是由标注系统标注', 
`review_result` int(11) NULL COMMENT '标注结果，正确或错误', 
`call_time` datetime NOT NULL COMMENT '调用产生的时间', 
PRIMARY KEY (`id`), 
KEY `query_index_app` (`app_key`, `method_name`, `is_accepted`, `call_time`), 
KEY `query_index_unique` (`app_key`, `unique_key`)
)  AUTO_INCREMENT = 3004142 CHARSET = utf8 COMMENT = '算法的采样数据，通过odps回流生成';
CREATE TABLE if not exists review_task_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键，任务Id', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NULL COMMENT '任务发起人Id', 
`label_out_id` bigint(20) UNSIGNED NULL COMMENT '标注系统Id', 
`template_id` bigint(20) UNSIGNED NULL COMMENT '模板Id，用于显示标注资源', 
`label_info` varchar(64) NOT NULL COMMENT '标注系统相关注释信息', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '任务信息表';
CREATE TABLE if not exists review_template (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`template_info` varchar(2048) NOT NULL COMMENT '模板的内容', 
`template_type` int(11) NULL COMMENT '模板类型，如：json型，velocity型', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '模板信息';
CREATE TABLE if not exists task (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '1', 
`app_id` int(11) NOT NULL COMMENT '1', 
`incr` int(11) NULL COMMENT '1', 
`library_id` bigint(20) UNSIGNED NULL COMMENT '1', 
`again` int(11) NULL COMMENT '1', 
`parent_id` bigint(20) UNSIGNED NULL COMMENT '1', 
`train_file` varchar(256) NULL COMMENT '1', 
`check_file` varchar(256) NULL COMMENT '1', 
`code_file` varchar(256) NULL COMMENT '1', 
`train_rule_file` varchar(256) NULL COMMENT '1', 
`check_rule_file` varchar(256) NULL COMMENT '1', 
`slover_rule_file` varchar(256) NULL COMMENT '1', 
`submit_time` datetime NULL COMMENT '1', 
`status` int(11) NOT NULL COMMENT '1', 
`end_time` datetime NULL COMMENT '1', 
`result_temp_file` varchar(256) NULL COMMENT '1', 
`result_temp_key` varchar(64) NULL COMMENT '1', 
`cfg_attr` varchar(2048) NULL COMMENT '1', 
`ret_attr` varchar(2048) NULL COMMENT '1', 
`task_name` varchar(64) NOT NULL COMMENT '1', 
`train_library_id` bigint(20) UNSIGNED NULL COMMENT '1', 
`check_library_id` bigint(20) UNSIGNED NULL COMMENT '1', 
`priority` int(11) DEFAULT '10' NOT NULL COMMENT '优先级', 
`platform` int(10) UNSIGNED NULL COMMENT '任务所属模型', 
`task_id` varchar(64) NULL COMMENT '平台返回的任务id', 
`task_desc` varchar(256) NULL COMMENT '任务描述', 
`parameter` varchar(4096) NULL COMMENT '任务参数', 
`run_time` datetime NULL COMMENT '运行时间', 
`result` varchar(2048) NULL COMMENT '运行结果', 
`train_id` bigint(20) UNSIGNED NULL COMMENT '训练ID', 
PRIMARY KEY (`id`), 
KEY `idx_user_app` (`user_id`, `app_id`, `gmt_create`), 
KEY `idx_train_app` (`train_id`, `app_id`, `gmt_create`)
)  AUTO_INCREMENT = 30006 CHARSET = utf8 COMMENT = '任务表';
CREATE TABLE if not exists train (
`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`platform` int(11) NOT NULL COMMENT '训练平台', 
`name` varchar(256) NOT NULL COMMENT '训练名称', 
`data_source` varchar(1024) NULL COMMENT '训练数据源', 
`parameter` varchar(1024) NULL COMMENT '训练附加参数', 
`auto_train` int(11) DEFAULT '0' NOT NULL COMMENT '自动训练0-否，1-是', 
`status` int(11) NOT NULL COMMENT '训练状态0-新训练，1-训练中，2-训练成功 3-训练失败', 
`start_time` datetime NULL COMMENT '训练开始时间', 
`end_time` datetime NULL COMMENT '训练结束时间', 
`model` varchar(2048) NULL COMMENT '模型文件', 
`error_msg` varchar(1024) NULL COMMENT '错误信息', 
`attribute` varchar(1024) NULL COMMENT '附加字段', 
`app_id` int(11) NOT NULL COMMENT '业务ID', 
`user_id` bigint(20) UNSIGNED NULL COMMENT '训练创建者', 
PRIMARY KEY (`id`), 
KEY `idx_plat_app` (`platform`, `app_id`, `gmt_create`), 
KEY `idx_user_app` (`user_id`, `app_id`, `gmt_create`)
)  CHARSET = utf8 COMMENT = '训练管理';
drop table if exists user;
CREATE TABLE if not exists user (
`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
`role` int(10) UNSIGNED NOT NULL COMMENT '用户角色1-管理员，2-普通用户', 
`level_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户等级', 
`email` varchar(64) NULL COMMENT '电子邮箱', 
`phone_num` varchar(32) NULL COMMENT '电话号码', 
`attribute` varchar(2048) NULL COMMENT '附加字段', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '用户表';
CREATE TABLE if not exists image (
`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`image_library_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`pic_url` varchar(256) NOT NULL COMMENT '图片地址', 
`source` int(11) NULL COMMENT '数据来源', 
`out_id` varchar(50) NULL COMMENT '数据来源的外键', 
`owner_id` bigint(20) NULL COMMENT '图片所有者', 
`info` varchar(512) NULL COMMENT '其它信息', 
`md5` varchar(32) NULL COMMENT 'md5值', 
PRIMARY KEY (`id`), 
KEY `idx_lib_cr` (`image_library_id`, `gmt_create`), 
KEY `udx_lib_md5` (`image_library_id`, `md5`)
)  CHARSET = utf8 COMMENT = '图片表';
CREATE TABLE if not exists image_label_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`image_library_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`pic_url` varchar(256) NULL COMMENT '图片tfs地址', 
`source` int(11) NULL COMMENT '数据来源，image''表的冗余', 
`out_id` varchar(50) NULL COMMENT '数据来源', 
`label_result`varchar(100)COMMENT '标注结果', 
`privacy` tinyint(4) NULL COMMENT '隐私，0公有，1私有', 
`owner_id` bigint(20) NULL COMMENT '图片所有者，image表的冗余', 
`label_template_id` bigint(20) NULL COMMENT '标注类型，模板id，label_template的外键', 
`image_id` bigint(20) NULL COMMENT 'image表外键', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '数据中心图片标注的结果数据';
CREATE TABLE if not exists label_speech (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`pack_id` bigint(20) NOT NULL COMMENT '分表字段', 
`tfs_path` varchar(200) NULL COMMENT '语音存放地', 
`label_result`varchar(100)COMMENT '标注信息', 
`info` varchar(4000) NULL COMMENT '其它信息', 
`label_template_id` bigint(20) NULL COMMENT '标注模版id', 
`source` int(11) NULL COMMENT '数据来源', 
`out_id` varchar(50) NULL COMMENT '数据来源外键', 
PRIMARY KEY (`id`), 
KEY `uk_packid` (`pack_id`)
)  AUTO_INCREMENT = 69899 CHARSET = utf8 COMMENT = '语音标注导入数据的存放表';
CREATE TABLE if not exists label_team_permission (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`team_id` bigint(20) NOT NULL COMMENT '团队id', 
`user_id` bigint(20) NOT NULL COMMENT '成员id', 
`role` int(11) NOT NULL COMMENT '角色', 
PRIMARY KEY (`id`), 
KEY `uk_userid_teamid` (`user_id`, `team_id`)
)  AUTO_INCREMENT = 27002 CHARSET = utf8 COMMENT = '团队权限表';
CREATE TABLE if not exists label_team_user (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`team_id` bigint(20) UNSIGNED NOT NULL COMMENT '团队id', 
`user_id` bigint(20) NOT NULL COMMENT '成员userId', 
`nick` varchar(118) NOT NULL COMMENT '成员nick', 
`role` int(11) NOT NULL COMMENT '成员角色：0：成员1：管理员2：团主', 
`status` int(11) NOT NULL COMMENT '加入状态：0：申请加入中1：加入成功2：被拒绝3：被拉黑', 
`join_time` datetime NULL COMMENT '加入成功时间', 
`join_reason` varchar(118) NULL COMMENT '加入理由', 
PRIMARY KEY (`id`), 
UNIQUE `uk_teamid_userid` (`team_id`, `user_id`), 
KEY `pk_teamid_status_role` (`team_id`, `status`, `role`)
)  CHARSET = utf8 COMMENT = '团队成员表';
