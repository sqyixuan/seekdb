PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 12673 CHARSET = utf8 COMMENT = '任务信息';
CREATE TABLE if not exists mgr_job_slice (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`jobsliceid` varchar(200) NOT NULL COMMENT '任务分片id', 
