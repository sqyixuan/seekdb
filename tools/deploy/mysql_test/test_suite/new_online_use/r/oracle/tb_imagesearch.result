SELECT run.id AS id, run.gmt_create AS gmt_create, run.gmt_modified AS gmt_modified, run.run_start_time AS run_start_time, run.run_end_time AS run_end_time , run.thread_num AS thread_num, run.interval_time AS interval_time, run.image_cate_id AS image_cate_id, run.notify_users AS notify_users, run.fetch_image_num AS fetch_image_num , run.script_path AS script_path, run.algorithm_id AS algorithm_id, run.script_config_id AS script_config_id, run.max_execute_time AS max_execute_time, run.status AS status , run.so_id AS so_id, run.type AS type, run.comment AS comment, run.work_machine AS work_machine, run.result_id AS result_id , vs.id AS v_id, vs.comment AS v_comment, vs.so_name AS v_so_name, vs.ref_head AS v_ref_head, sc.id AS p_id , sc.script_name AS p_script_name, sc.script_comment AS p_script_comment, sc.param_config AS p_param_config, sc.log_config AS p_log_config, sc.script_content AS p_script_content , ct.id AS c_id, ct.cate_name AS c_cate_name, ct.comment AS c_comment, dc.id AS d_id, dc.dict_name AS d_dict_name , dc.dict_path AS d_dict_path, dc.comment AS d_comment FROM `is_test_runtime_config` run LEFT JOIN `is_test_algorithm_so` vs ON run.so_id = vs.id LEFT JOIN `is_test_dictionary` dc ON vs.dict_id = dc.id LEFT JOIN `is_test_script_config` sc ON run.script_config_id = sc.id LEFT JOIN `is_test_sample_cate` ct ON run.image_cate_id = ct.id WHERE run.status = 1 ORDER BY run.gmt_modified DESC;
