`label_text`varchar(100)COMMENT '标注后文本内容', 
`label_result`varchar(100)COMMENT '标注结果', 
`info` varchar(4000) NULL COMMENT '其它信息', 
`label_template_id` bigint(20) NULL COMMENT '标注模版id', 
`source` bigint(20) NULL COMMENT '数据来源', 
`out_id` varchar(50) NULL COMMENT '数据来源外键', 
PRIMARY KEY (`id`), 
KEY `idx_packid_labelstatus` (`pack_id`, `label_status`)
)  AUTO_INCREMENT = 1528764 CHARSET = utf8 COMMENT = '文本标注';
CREATE TABLE if not exists label_user_statistics (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NULL COMMENT '用户id', 
`total_score` bigint(20) UNSIGNED NULL COMMENT '总积分', 
`used_score` bigint(20) UNSIGNED NULL COMMENT '已使用积分', 
`accept_task` bigint(20) UNSIGNED NULL COMMENT '已认领总任务数', 
`finish_label_task` bigint(20) UNSIGNED NULL COMMENT '已完成标注任务', 
`finish_check_task` bigint(20) UNSIGNED NULL COMMENT '已通过校验任务数', 
`create_task` bigint(20) UNSIGNED NULL COMMENT '新建的任务数', 
`publish_task` bigint(20) UNSIGNED NULL COMMENT '已发布的任务数', 
`info` varchar(200) NULL COMMENT '描述', 
PRIMARY KEY (`id`), 
UNIQUE `idx_user` (`user_id`)
)  AUTO_INCREMENT = 4939461 CHARSET = utf8 COMMENT = '这是用户积分、标注任务等统计表';
CREATE TABLE if not exists level (
`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`level_name` varchar(64) NOT NULL COMMENT '等级名称', 
