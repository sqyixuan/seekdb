PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 11 CHARSET = utf8 COMMENT = 'worker的表';
CREATE TABLE if not exists model_training_schedule (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`search_id` bigint(20) UNSIGNED NOT NULL COMMENT '搜索业务id', 
`training_type` char(1) NOT NULL COMMENT '训练类型1、训练加速模型2、训练特征模型', 
`stage` char(2) NOT NULL COMMENT '1.新建模型训练2.提交ODPS准备数据失败3.ODPS数据准备中4.数据源准备失败5.数据源准备成功6.提交训练任务失败7.模型训练中8.模型训练成功9.模型训练失败10.手工上传模型文件11.重新训练模型', 
`task_id` varchar(64) NULL COMMENT 'stage为2-5时具有训练任务id', 
`engine_id` bigint(20) UNSIGNED NULL COMMENT '训练类型为1时表示引擎id', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '更新时间', 
`error_log` varchar(2048) NULL COMMENT '每步的异常日志记录', 
PRIMARY KEY (`id`), 
KEY `index_srerch_id_training_type` (`search_id`, `training_type`, `engine_id`, `stage`, `gmt_modified`), 
KEY `index_gmt_create` (`gmt_create`, `search_id`)
)  AUTO_INCREMENT = 4 CHARSET = utf8 COMMENT = '模型训练进度表';
CREATE TABLE if not exists monitor_app_current (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`cluster_id` varchar(20) NOT NULL COMMENT '集群id', 
`search_id` int(11) NOT NULL COMMENT '业务id', 
`search_app_name` varchar(20) NULL COMMENT '搜索业务名称', 
`engine_id` int(11) NULL COMMENT '引擎id', 
`engine_name` varchar(32) NULL COMMENT '引擎名字', 
`data` int(11) NULL COMMENT '数据量', 
`tps` int(11) NULL COMMENT '访问量', 
`memory` bigint(20) NULL COMMENT '机器内存总量', 
`data_node_num` int(11) NULL COMMENT 'datanode节点数量', 
`healthy_node_num` int(11) NULL COMMENT '健康节点数量', 
`abnormal_node` varchar(1024) NULL COMMENT '异常节点IP', 
`avil_memory` bigint(20) NULL COMMENT '可用内存量', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`total_tps` int(11) NULL COMMENT '访问总量', 
PRIMARY KEY (`id`), 
KEY `index_search_id_tps` (`search_app_name`, `data_node_num`, `total_tps`, `data`), 
KEY `index_gmt_create` (`gmt_create`), 
KEY `index_cluster_id` (`cluster_id`, `search_id`, `total_tps`)
)  AUTO_INCREMENT = 21834631 CHARSET = utf8 COMMENT = '搜索应用业务监控实时数据表';
