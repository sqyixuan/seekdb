`info`varchar(100)COMMENT '其它信息', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 56 CHARSET = utf8 COMMENT = '用来保存集群组的信息';
CREATE TABLE if not exists mgr_datasource_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`appid` varchar(200) NOT NULL COMMENT '应用id', 
`appname` varchar(200) DEFAULT '"2015-09-30 12:00:00"' NOT NULL COMMENT '应用名', 
`categorytype` int(11) NOT NULL COMMENT '应用分类号', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 35 CHARSET = utf8 COMMENT = '特征提取管理模块数据源信息';
CREATE TABLE if not exists mgr_job_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`appid` varchar(200) NOT NULL COMMENT '应用id', 
`categorytype` int(11) NOT NULL COMMENT '应用分类', 
`jobtype` int(11) NOT NULL COMMENT '任务类型', 
`finishpercent` double NOT NULL COMMENT '完成情况', 
`otherinfo` varchar(100) DEFAULT '"2015-09-30 12:00:00"' COMMENT '其它信息', 
