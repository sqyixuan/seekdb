CREATE TABLE if not exists is_offline_job (
`out_odps_table` varchar(1024) NULL COMMENT '输出的任务信息', 
`out_tfs_data` varchar(512) NULL COMMENT '输出文件的信息', 
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`data_type` int(11) NOT NULL COMMENT '输入数据类型 1 为tfs 2为odps', 
`in_data` varchar(512) NOT NULL COMMENT '输入数据', 
`algorithm` bigint(20) UNSIGNED NOT NULL COMMENT '算法id', 
`odps_user_name` varchar(512) NULL COMMENT 'odps的用户名称', 
`status` int(11) NOT NULL COMMENT '任务的状态', 
`params` varchar(1024) NULL COMMENT '参数信息', 
`run_time` varchar(64) NULL COMMENT '运行时间', 
`create_id` bigint(20) UNSIGNED NULL COMMENT '提交任务者id', 
`algorithm_name` varchar(64) NULL COMMENT '算法名称', 
`exception_msg` varchar(1024) NULL COMMENT '异常信息', 
`instance_id` varchar(215) NULL COMMENT '运行任务的实例', 
`in_odps_table` varchar(512) NULL COMMENT '输入参数ODPS表', 
PRIMARY KEY (`id`), 
KEY `job_query_index` (`run_time`, `status`)
)  AUTO_INCREMENT = 11 CHARSET = utf8 COMMENT = '离线任务表';
CREATE TABLE if not exists is_offline_method (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`name` varchar(512) NOT NULL COMMENT '算法的名称', 
`udf` varchar(512) NULL COMMENT '离线算法的udf的名称', 
`env_odps` varchar(1024) NULL COMMENT 'ODPS的运行环境参数', 
`env_yarm` varchar(1024) NULL COMMENT 'YARM集群的运行环境参数', 
`env_led` varchar(1024) NULL COMMENT '离线小集群的环境参数', 
`service_id` int(11) NOT NULL COMMENT 'is_offline_service_table 表主键id', 
`method_name` varchar(32) NOT NULL COMMENT '算法名', 
PRIMARY KEY (`id`), 
KEY `gmt_create` (`gmt_create`)
)  AUTO_INCREMENT = 6 CHARSET = utf8 COMMENT = '离线算法管理表';
CREATE TABLE if not exists is_offline_method_param (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`method_id` bigint(20) UNSIGNED NOT NULL COMMENT '离线算法方法id', 
`name` varchar(512) NOT NULL COMMENT '参数的名称', 
`env_type` int(11) NOT NULL COMMENT '离线算法的平台类型 1odps 2 yarm 3离线计算', 
`type` varchar(60) NOT NULL COMMENT '参数的类型 描述', 
`value` varchar(128) NULL COMMENT '参数的默认值', 
`index_order` int(11) NOT NULL COMMENT '参数的顺序', 
PRIMARY KEY (`id`), 
KEY `method_param` (`method_id`, `env_type`)
)  AUTO_INCREMENT = 8 CHARSET = utf8 COMMENT = '离线算法的参数信息';
CREATE TABLE if not exists is_offline_pt_method (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`service_table` varchar(256) NULL COMMENT '表名称', 
`pt` varchar(256) NULL COMMENT '分区的信息', 
`total` int(11) NULL COMMENT '数量', 
`method` varchar(256) NULL COMMENT '方法名称', 
`status` tinyint(4) NOT NULL COMMENT '状态0-未生成任务，1-已生成任务', 
`attribute` varchar(1024) NULL COMMENT '扩展字段', 
`env` tinyint(4) NULL COMMENT '环境', 
PRIMARY KEY (`id`), 
UNIQUE `pt_method_index` (`env`, `pt`, `service_table`, `method`), 
KEY `idx_status_pt` (`env`, `status`, `pt`)
)  AUTO_INCREMENT = 5680 CHARSET = utf8 COMMENT = '数据分区的数据量统计';
CREATE TABLE if not exists is_offline_service_table (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`service_name` varchar(128) NOT NULL COMMENT '服务名称', 
`table_name` varchar(64) NOT NULL COMMENT '表名称', 
`status` int(11) DEFAULT '1' NOT NULL COMMENT '服务状态1 表示可用 0 下线', 
PRIMARY KEY (`id`), 
UNIQUE `service_table_index` (`service_name`, `table_name`), 
KEY `status_index` (`status`)
)  AUTO_INCREMENT = 3 CHARSET = utf8 COMMENT = '离线服务对应的请求存储ODPS表信息';
CREATE TABLE if not exists is_offline_service_table_pt (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`service_name` varchar(512) NOT NULL COMMENT '服务名称', 
`table_name` varchar(64) NOT NULL COMMENT 'ODPS表名称', 
`pt` varchar(32) NULL COMMENT '分区信息', 
`status` int(11) NULL COMMENT '分区状态 0 表示创建 1表示开始执行服务 2 表示执行成功 3表示执行失败', 
PRIMARY KEY (`id`), 
UNIQUE `table_pt_index` (`table_name`, `pt`)
)  AUTO_INCREMENT = 56540 CHARSET = utf8 COMMENT = '离线服务请求分区信息表';
CREATE TABLE if not exists is_offline_sub_task (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`sub_task_id` varchar(512) NOT NULL COMMENT '子任务id', 
`parent_task_id` varchar(512) NOT NULL COMMENT '总任务id 对应is_offline_task 表中task_id', 
`record_count` bigint(20) UNSIGNED NULL COMMENT '子任务的记录数', 
`task_status` int(11) NOT NULL COMMENT '任务状态0 未运行1 运行中2 成功4 失败5 取消6 重新运行中', 
`input_odps_table_name` varchar(512) NULL COMMENT '子任务输入的表名称', 
`output_odps_table_name` varchar(512) NULL COMMENT '子任务输出的表名称', 
`pre_task_id` bigint(20) UNSIGNED NULL COMMENT '前一个任务的id', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '图像离线计算子任务表';
CREATE TABLE if not exists is_offline_task (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`task_id` varchar(64) NULL COMMENT '执行任务id', 
`record_count` bigint(20) UNSIGNED NULL COMMENT '执行任务的数量', 
`is_template_task` int(11) NULL COMMENT '是不是模板任务 0 不是 1 是', 
`function_id` int(11) NULL COMMENT '模板id或算法Id', 
`has_sub_task` int(11) NULL COMMENT '是否拆分成了子任务。1、	未处理2、	不需要拆分3、	已拆分', 
`task_platform` int(11) NULL COMMENT '任务执行平台1、	odps  2、yarn 3、	内部集群', 
`task_outer_key` varchar(512) NULL COMMENT '关联一次作用的字段，可以是一个PT，也可以是一次任务提交', 
`status` int(11) NOT NULL COMMENT '任务状态0 未运行1 运行中2 成功3 部分成功4 失败5 取消6 重新运行中', 
`type` int(11) NULL COMMENT '任务类型：1 离线接口2 tfs文件3 odps表', 
`service_table` varchar(256) NULL COMMENT '表名', 
`pt` varchar(256) NULL COMMENT '分区信息', 
`method` varchar(256) NULL COMMENT '方法名', 
`attribute` varchar(1024) NULL COMMENT '附加字段', 
`service` varchar(256) NULL COMMENT '服务', 
`env` tinyint(4) NULL COMMENT '环境0日常1预发2线上', 
`clean` tinyint(4) NULL COMMENT '清理标志0未清理1已清理', 
`result_preview` varchar(2048) NULL COMMENT '结果预览', 
`exec_context` varchar(1024) NULL COMMENT '执行上下文,json', 
`exec_platform` varchar(256) NULL COMMENT '执行平台，按平台ID逗号分隔', 
`send_count` bigint(20) UNSIGNED NULL COMMENT '消息发送量', 
PRIMARY KEY (`id`), 
KEY `idx_status` (`env`, `status`), 
KEY `idx_clean` (`env`, `clean`), 
KEY `idx_condition` (`env`, `task_id`, `service`, `status`)
)  AUTO_INCREMENT = 22126 CHARSET = utf8 COMMENT = '图像离线计算的任务表';
CREATE TABLE if not exists is_open_service_api (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`api_desc` varchar(10) COMMENT 'API 描述，功能描述', 
`sdk_desc` varchar(10) COMMENT 'SDK 描述', 
`hsf_desc` varchar(10) COMMENT 'HSF 描述', 
`effect_desc` varchar(10) COMMENT '效果说明', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '最近修改时间', 
`offline_desc` varchar(10) COMMENT '离线描述', 
`extra` varchar(10) COMMENT '扩展信息', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 22 CHARSET = utf8 COMMENT = '开放接入的服务API信息表';
CREATE TABLE if not exists is_open_service_authorization (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`app_id` int(11) NOT NULL COMMENT '应用ID', 
`app_key` varchar(32) NOT NULL COMMENT '应用Key', 
`service_info_id` int(11) NOT NULL COMMENT '申请的服务ID', 
`category_id` int(11) NOT NULL COMMENT '申请的服务类型', 
`service_id` varchar(128) NOT NULL COMMENT '分配的的服务ID', 
`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '状态: -1-已删除，0-测试中，1-已上线', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '最近修改时间', 
PRIMARY KEY (`id`), 
KEY `idx_aid_s` (`app_id`, `status`)
)  AUTO_INCREMENT = 11 CHARSET = utf8 COMMENT = '应用服务授权表';
CREATE TABLE if not exists is_open_service_category (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`parent_id` int(11) DEFAULT '0' NOT NULL COMMENT '父类型', 
`name` varchar(128) NOT NULL COMMENT '类型名称', 
`description` varchar(1024) NULL COMMENT '类型描述', 
`status` tinyint(4) DEFAULT '0' COMMENT '状态: -1-已删除，0-有效', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '最近修改时间', 
PRIMARY KEY (`id`), 
KEY `idx_pid_s` (`parent_id`, `status`)
)  AUTO_INCREMENT = 7 CHARSET = utf8 COMMENT = '开放接入的服务类型表';
CREATE TABLE if not exists is_open_service_information (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`name` varchar(128) NOT NULL COMMENT '服务名称', 
`category_id` int(10) UNSIGNED NOT NULL COMMENT '服务类型', 
`api_id` int(11) NOT NULL COMMENT '关联的API', 
`open_service_id` varchar(128) NULL COMMENT '关联的服务ID', 
`owner` varchar(64) NOT NULL COMMENT '服务接口人', 
`status` tinyint(4) DEFAULT '0' COMMENT '状态，-1-已删除，0-待发布，1-已上线', 
`description` varchar(10) COMMENT '服务说明', 
`pic_url` varchar(256) NULL COMMENT '图片logo', 
`param_velocity_template` varchar(10) COMMENT '参数模板', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '最近修改时间', 
`demo_url` varchar(256) NULL COMMENT '示例url', 
`extra` varchar(2046) NULL COMMENT '扩展字段', 
PRIMARY KEY (`id`), 
KEY `idx_cid_s` (`category_id`, `status`)
)  AUTO_INCREMENT = 20 CHARSET = utf8 COMMENT = '开放接入的服务表';
CREATE TABLE if not exists is_provider_algorithm (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`test_aid` bigint(20) UNSIGNED NULL COMMENT '评测系统中的算法ID', 
`algorithm_name` varchar(64) NOT NULL COMMENT '算法名称', 
`exec_conf` varchar(1024) NULL COMMENT '运行配置，包括CPU、Memo等', 
`comment` varchar(256) NULL COMMENT '算法说明', 
`client_api` varchar(128) NULL COMMENT '算法调用API名称', 
`client_path` varchar(128) NULL COMMENT '算法调用API存储路径', 
`thrift_api` varchar(128) NULL COMMENT '算法包thrift API', 
`thrift_path` varchar(128) NULL COMMENT 'thrift API 存储路径', 
`model_need` int(11) DEFAULT '0' COMMENT '是否需要模型文件', 
`stakeholder` varchar(1024) NULL COMMENT '算法开发者和关注该算法的人员', 
PRIMARY KEY (`id`), 
KEY `id_testid_idx` (`id`, `test_aid`), 
KEY `name_idx` (`algorithm_name`)
)  AUTO_INCREMENT = 11 CHARSET = utf8 COMMENT = '算法信息表';
CREATE TABLE if not exists is_provider_event (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`event_code` varchar(32) NULL COMMENT '接入事件code，也即MetaQ中相关的topic', 
`script_name` varchar(128) NULL COMMENT '事件处理脚本名称', 
`script_content` varchar(10) COMMENT '事件处理脚本内容', 
`comment` varchar(256) NULL COMMENT '事件备注', 
`processor_clazz` varchar(256) NULL COMMENT '事件处理器class类型', 
`event_tag` varchar(32) NULL COMMENT '接入事件tag，即MetaQ中相关的tag', 
`status` int(11) DEFAULT '0' COMMENT '事件状态, -1：停止，0：等待集群同步；n(>0)：已同步', 
PRIMARY KEY (`id`), 
UNIQUE `event_unique` (`event_code`, `event_tag`)
)  AUTO_INCREMENT = 3 CHARSET = utf8 COMMENT = '对外服务接口的事件表';
CREATE TABLE if not exists is_provider_event_counter (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`time_span` bigint(20) UNSIGNED NULL COMMENT '记录事件戳', 
`comment` varchar(256) NULL COMMENT '统计备注', 
`counter_key` varchar(256) NULL COMMENT '统计标识', 
`all_counter` bigint(20) UNSIGNED NULL COMMENT '接收到的总量', 
`done` bigint(20) UNSIGNED NULL COMMENT '处理的数量', 
`result` bigint(20) UNSIGNED NULL COMMENT '正常处理的数量', 
`error` bigint(20) UNSIGNED NULL COMMENT '异常的数量', 
`cost` bigint(20) UNSIGNED NULL COMMENT '处理时间总和', 
`delay` bigint(20) UNSIGNED NULL COMMENT '处理延迟总和', 
`max_single_cost` bigint(20) UNSIGNED NULL COMMENT '单次最大开销', 
`min_single_cost` bigint(20) UNSIGNED NULL COMMENT '单次最小开销', 
PRIMARY KEY (`id`), 
UNIQUE `counter_unique` (`time_span`, `counter_key`)
)  AUTO_INCREMENT = 6400189 CHARSET = utf8 COMMENT = '事件处理计数器';
CREATE TABLE if not exists is_provider_lib (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`algorithm_id` bigint(20) UNSIGNED NOT NULL COMMENT 'FK, algorithm#id', 
`lib_name` varchar(64) NULL COMMENT '算法包名称', 
`lib_path` varchar(128) NULL COMMENT '算法包存储地址', 
`model_file` varchar(128) NULL COMMENT '模型文件', 
`model_path` varchar(128) NULL COMMENT '模型存储地址', 
`exec_conf` varchar(512) NULL COMMENT '执行配置', 
`test_lib_id` bigint(20) UNSIGNED NULL COMMENT '算法包在测试平台的id', 
PRIMARY KEY (`id`), 
KEY `algorithm_lib_idx` (`algorithm_id`, `test_lib_id`), 
KEY `name_idx` (`lib_name`)
)  AUTO_INCREMENT = 29 CHARSET = utf8 COMMENT = '算法包信息表';
CREATE TABLE if not exists is_provider_memento (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`tfspath` varchar(512) NULL COMMENT '图片tfspath', 
`request_content`varchar(100)COMMENT '请求信息,JSON格式', 
`parse_result`varchar(100)COMMENT '算法解析结果', 
`event_id` int(11) NULL COMMENT '关联事件', 
PRIMARY KEY (`id`), 
KEY `idx_event_id_gmt_create` (`event_id`, `gmt_create`), 
KEY `event_id` (`event_id`)
)  AUTO_INCREMENT = 20 CHARSET = utf8 COMMENT = '服务处理备忘，记录请求数据和处理结果';
CREATE TABLE if not exists is_provider_model (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`algorithm_id` bigint(20) UNSIGNED NULL COMMENT '关联算法模型', 
`model_nick` varchar(32) NULL COMMENT '模型别名', 
`tfs_path` varchar(64) NULL COMMENT '模型tfsPath', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 13 CHARSET = utf8 COMMENT = '算法模型信息表';
CREATE TABLE if not exists is_provider_processor (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`algorithm_id` bigint(20) UNSIGNED NOT NULL COMMENT '算法ID', 
`algorithm_name` varchar(128) NOT NULL COMMENT '算法名称', 
`algorithmtag_id` bigint(20) UNSIGNED NULL COMMENT '算法版本ID', 
`algorithmtag_name` varchar(128) NULL COMMENT '算法版本名称', 
`algorithmlib_name` varchar(256) NULL COMMENT '算法动态库 文件名称，具体使用的', 
`algorithmlib_path` varchar(1024) NULL COMMENT '所在路径', 
`process_mode` smallint(6) NULL COMMENT '处理模式 1java 2 python', 
`default_process` smallint(6) NULL COMMENT '是否 是默认执行器 1 是 0否', 
`script_name` varchar(128) NULL COMMENT '脚本名称', 
`script_content`varchar(100)COMMENT '脚本内容', 
`processor_clazz` varchar(1024) NULL COMMENT '处理类', 
`comment` varchar(1024) NULL COMMENT '描述', 
`status` smallint(6) NULL COMMENT '处理器状态 ，待配置  （0  这个是测试平台过来的初始状态），正常（>=0），删除（-1）', 
`dict_dir_name` varchar(512) NULL COMMENT '字典全路径名', 
`dict_files` varchar(1024) NULL COMMENT '字典包含的文件，以,分隔', 
PRIMARY KEY (`id`), 
UNIQUE `idx_alg_tag_name` (`algorithm_name`, `algorithmtag_name`), 
KEY `idx_related_id` (`algorithm_id`, `algorithmtag_id`)
)  AUTO_INCREMENT = 103 CHARSET = utf8 COMMENT = '动态库处理器';
CREATE TABLE if not exists is_provider_release (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`type` int(11) NULL COMMENT '发布类型', 
`status` int(11) NULL COMMENT '状态', 
`service_id` bigint(20) UNSIGNED NULL COMMENT '服务ID', 
`creator` varchar(20) NULL COMMENT '创建人', 
`opt_count` int(11) NULL COMMENT '主机总数', 
`finished_count` int(11) NULL COMMENT '完成主机数', 
`rls_config` varchar(512) NULL COMMENT '发布配置', 
PRIMARY KEY (`id`), 
KEY `service_rlt_idx` (`service_id`), 
KEY `append_idx` (`type`, `status`, `creator`)
)  AUTO_INCREMENT = 362 CHARSET = utf8 COMMENT = '算法发布信息表';
CREATE TABLE if not exists is_provider_release_detail (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`release_id` bigint(20) UNSIGNED NULL COMMENT '发布ID', 
`server_id` bigint(20) UNSIGNED NULL COMMENT '主机ID', 
`release_detail` varchar(256) NULL COMMENT '发布细节', 
`status` int(11) NULL COMMENT '发布状态', 
`service_id` bigint(20) UNSIGNED NULL COMMENT '服务ID', 
`pt_num` int(11) NULL COMMENT '进程数', 
PRIMARY KEY (`id`), 
KEY `rlt_idx` (`service_id`, `server_id`, `release_id`)
)  AUTO_INCREMENT = 1073 CHARSET = utf8 COMMENT = '发布详情表';
CREATE TABLE if not exists is_provider_server (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`ip` varchar(20) NOT NULL COMMENT 'IP地址', 
`conf` varchar(512) NULL COMMENT '主机配置，json格式', 
`server_name` varchar(64) NULL COMMENT '主机名', 
`type` int(11) DEFAULT '0' COMMENT '机器类型，0:CPU, 1:GPU', 
`env` int(11) DEFAULT '2' COMMENT '机器所处环境，0：daily,1:pre,2:online', 
PRIMARY KEY (`id`), 
UNIQUE `ip_idx` (`ip`), 
KEY `query_idx` (`server_name`, `ip`)
)  AUTO_INCREMENT = 218 CHARSET = utf8 COMMENT = '主机信息表';
CREATE TABLE if not exists is_provider_server_group (
`comment` varchar(256) NULL COMMENT '备注', 
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`group_name` varchar(64) NULL COMMENT '分组名', 
PRIMARY KEY (`id`), 
UNIQUE `name_idx` (`group_name`)
)  CHARSET = utf8 COMMENT = '机器分组表';
CREATE TABLE if not exists is_provider_server_group_rlt (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`server_id` bigint(20) UNSIGNED NULL COMMENT '主机ID', 
`group_id` bigint(20) UNSIGNED NULL COMMENT '分组ID', 
PRIMARY KEY (`id`), 
UNIQUE `server_group_idx` (`server_id`, `group_id`)
)  CHARSET = utf8 COMMENT = '机器分组关联表';
CREATE TABLE if not exists is_provider_service (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`service_name` varchar(64) NULL COMMENT '服务名称', 
`comment` varchar(128) NULL COMMENT '注释', 
`algorithm_id` bigint(20) UNSIGNED NULL COMMENT '算法ID', 
`lib_id` bigint(20) UNSIGNED NULL COMMENT '关联Lib', 
`opt_type` int(11) NULL COMMENT '操作类型', 
`exec_conf` varchar(256) NULL COMMENT '执行配置', 
`service_id` bigint(20) UNSIGNED NULL COMMENT '关联服务ID', 
PRIMARY KEY (`id`), 
UNIQUE `name_idx` (`service_name`, `service_id`), 
KEY `service_algorithm_lib_idx` (`algorithm_id`, `lib_id`)
)  AUTO_INCREMENT = 28 CHARSET = utf8 COMMENT = '对外提供的服务';
CREATE TABLE if not exists is_provider_service_apply (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`appkey` varchar(32) NULL COMMENT '申请方appkey', 
`service_id` bigint(20) UNSIGNED NULL COMMENT '要申请的服务ID', 
`allot_service_key` varchar(32) NULL COMMENT '分配的服务实例标识', 
`status` int(11) DEFAULT '0' COMMENT '申请状态，0：新申请', 
`param_config` varchar(512) NULL COMMENT '参数配置, JSON 串', 
`apply_id` bigint(20) UNSIGNED NULL COMMENT '服务开放平台的申请ID', 
`comment` varchar(256) NULL COMMENT '备注', 
PRIMARY KEY (`id`), 
UNIQUE `app_service_idx` (`appkey`, `service_id`)
)  AUTO_INCREMENT = 8 CHARSET = utf8 COMMENT = '服务申请表';
CREATE TABLE if not exists is_provider_service_detail (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`service_id` bigint(20) UNSIGNED NULL COMMENT '服务ID', 
`server_id` bigint(20) UNSIGNED NULL COMMENT '主机ID', 
`client_port` int(11) NULL COMMENT 'client端口', 
`thrift_port` int(11) NULL COMMENT 'thrift端口', 
`client_pid` int(11) NULL COMMENT 'client PID', 
`status` int(11) NULL COMMENT '运行状况', 
`thrift_pid` int(11) DEFAULT '0' COMMENT 'thrift PID', 
PRIMARY KEY (`id`), 
UNIQUE `service_process_idx` (`service_id`, `server_id`, `client_port`)
)  AUTO_INCREMENT = 555 CHARSET = utf8 COMMENT = '服务明细表';
CREATE TABLE if not exists is_provider_service_external (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`algorithm_id` bigint(20) UNSIGNED NULL COMMENT '关联算法ID', 
`service_name` varchar(32) NULL COMMENT '算法名称', 
`comment`varchar(100)COMMENT '备注', 
`model_id` bigint(20) UNSIGNED DEFAULT '0' COMMENT '关联模型ID,默认为0，表示无需模型', 
`adt_config` varchar(2048) NULL COMMENT '附加配置', 
`client_name` varchar(64) NULL COMMENT 'client文件名', 
`client_path` varchar(64) NULL COMMENT 'client存储路径', 
`lib_id` bigint(20) UNSIGNED NULL COMMENT '关联Lib ID', 
PRIMARY KEY (`id`), 
KEY `algorithm_model_idx` (`algorithm_id`, `model_id`), 
KEY `servicename_idx` (`service_name`)
)  AUTO_INCREMENT = 12 CHARSET = utf8 COMMENT = '对外提供的算法服务';
CREATE TABLE if not exists is_provider_service_server_rlt (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`service_id` bigint(20) UNSIGNED NULL COMMENT '算法ID', 
`server_id` bigint(20) UNSIGNED NULL COMMENT '机器ID', 
`pt_num` int(11) NULL COMMENT '分配进程数', 
PRIMARY KEY (`id`), 
UNIQUE `rlt_idx` (`service_id`, `server_id`)
)  AUTO_INCREMENT = 193 CHARSET = utf8 COMMENT = '算法服务器关联表';
CREATE TABLE if not exists is_provider_statistics (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`app_key` varchar(64) NULL COMMENT '调用方标识', 
`instance_key` varchar(32) NULL COMMENT '服务实例标识', 
`stc_type` int(11) NULL COMMENT '统计维度标识, 1: hour 2:day', 
`method_name` varchar(256) NULL COMMENT '调用方法名', 
`invoke_total` bigint(20) UNSIGNED NULL COMMENT '总调用量', 
`invoke_succeed` bigint(20) UNSIGNED NULL COMMENT '调用成功量', 
`invoke_failed` bigint(20) UNSIGNED NULL COMMENT '调用失败量', 
`cost_avg` double NULL COMMENT '平均处理耗时', 
`cost_max` double NULL COMMENT '最大处理耗时', 
`cost_min` double NULL COMMENT '最小处理耗时', 
`algorithm_id` bigint(20) UNSIGNED NULL COMMENT '算法ID', 
`service_id` bigint(20) UNSIGNED NULL COMMENT '服务ID', 
`instance_id` bigint(20) UNSIGNED NULL COMMENT '实例ID', 
`date_zone` datetime NULL COMMENT '时间（按天）分区', 
`hour_zone` int(10) UNSIGNED NULL COMMENT '时间（按小时）分区', 
PRIMARY KEY (`id`), 
UNIQUE `uniq_idx` (`app_key`, `instance_key`, `method_name`, `stc_type`, `date_zone`, `hour_zone`), 
KEY `app_instance_method_idx` (`app_key`, `instance_key`, `method_name`), 
KEY `type_idx` (`stc_type`), 
KEY `ids_idx` (`algorithm_id`, `service_id`, `instance_id`), 
KEY `time_idx` (`date_zone`, `hour_zone`), 
KEY `method_idx` (`method_name`)
)  AUTO_INCREMENT = 2801 CHARSET = utf8 COMMENT = '调用统计表';
CREATE TABLE if not exists is_search_appmapnode (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`search_id` bigint(20) UNSIGNED NOT NULL COMMENT '应用ID', 
`search_name` varchar(64) NOT NULL COMMENT '应用名称', 
`datanode_ip` varchar(256) NOT NULL COMMENT '搜索节点ip', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 60 CHARSET = utf8 COMMENT = '应用与搜索节点之间的映射关系';
CREATE TABLE if not exists is_search_dump_business_table (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`search_id` bigint(20) NOT NULL COMMENT '搜索searchId', 
`hive_project` varchar(128) NOT NULL COMMENT '数据表所在项目', 
`hive_data_table` varchar(256) NOT NULL COMMENT '存放数据的表', 
`hive_complete_table` varchar(256) NOT NULL COMMENT '用来判断 数据表是否准备好的表', 
`table_schema` varchar(4000) NOT NULL COMMENT '使用json来记录 这个表的结构', 
`belongs_to` int(11) DEFAULT '0' NOT NULL COMMENT '1 表示是 这个表是创建在自己项目里面2 表示是使用业务方自己的表，', 
`permissions_to_obtain` int(11) DEFAULT '0' NOT NULL COMMENT '0 表示 未获取1 表示权限已经获取这个由于表的归属不同 需要有不同的逻辑判断', 
`authorization_account` varchar(256) NULL COMMENT 'belongs_to 为1的时候 需要对方提供 账户名称，这个是在 表创建在我方 odps 上，需要对方给账户 帮对方将表授权', 
PRIMARY KEY (`id`), 
UNIQUE `uniq_search_id` (`search_id`)
)  AUTO_INCREMENT = 6 CHARSET = utf8 COMMENT = '这张表记录业务需要做索引的表信息';
CREATE TABLE if not exists is_search_feature_model_set (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`search_id` int(11) NOT NULL COMMENT '搜索ID', 
`model_file` varchar(4000) NULL COMMENT '模型文件地址 使用json 存储。一个特征 一般会用到多个模型，因此需要多个模型文件', 
`interface_service` varchar(4000) NULL COMMENT '算法接口服务信息 使用json 保存', 
`feature_model_type` varchar(32) NOT NULL COMMENT '使用什么特征模型', 
PRIMARY KEY (`id`), 
KEY `idx_sid` (`search_id`)
)  AUTO_INCREMENT = 5 CHARSET = utf8 COMMENT = '搜索的特征模型配置表';
CREATE TABLE if not exists is_search_model_training_set (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`search_id` bigint(20) UNSIGNED NOT NULL COMMENT '搜索ID', 
`model_scope` int(11) NOT NULL COMMENT '1.引擎加速2.特征模型', 
`model_key` varchar(56) NOT NULL COMMENT '这个key 和model_scope 在一个搜索中可以确定唯一。model_scope 1下表示参数名称model_scope 2 特征', 
`cycle_time` int(11) NOT NULL COMMENT '单位是分钟。根据展示 进行折算', 
`target_data_meta` varchar(4000) NOT NULL COMMENT '这个用json 来存储目标数据信息', 
`task_id` varchar(64) NULL COMMENT '训练任务Id', 
`stage` char(2) NULL COMMENT '1.新建模型训练2.提交ODPS准备数据失败3.ODPS数据准备中4.数据源准备失败5.数据源准备成功6.提交训练任务失败7.模型训练中8.模型训练成功9.模型训练失败10.手工上传模型文件11.重新训练模型', 
`model_file` varchar(4000) NULL COMMENT '模型训练文件json格式1、pq加速文件唯一2、提取特征的模型文件存在多个', 
PRIMARY KEY (`id`), 
UNIQUE `uniq_search_key_scope` (`search_id`, `model_scope`, `model_key`), 
KEY `index_gmt_create` (`gmt_create`), 
KEY `index_model_scope` (`model_scope`, `stage`)
)  AUTO_INCREMENT = 6 CHARSET = utf8 COMMENT = '设置 模型训练的时间周期表';
CREATE TABLE if not exists is_search_resource_info (
`search_id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`engine_id` bigint(20) UNSIGNED NULL COMMENT '引擎id', 
`alloced_str` varchar(4000) NULL COMMENT '已经分配的节点', 
`groups_str` varchar(2000) NULL COMMENT '分片组信息', 
`shardtogroup_str` varchar(2000) NULL COMMENT '分片对应组关系', 
PRIMARY KEY (`search_id`)
)  CHARSET = utf8 COMMENT = '搜索业务资源节点分配信息';
CREATE TABLE if not exists is_test_algorithm (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`algorithm_name` varchar(32) NOT NULL COMMENT '算法名称', 
`so_name` varchar(64) NULL COMMENT 'so包名', 
`git_repo` varchar(256) NULL COMMENT '算法的GitLab地址', 
`makefile_name` varchar(50) NULL COMMENT 'makefile文件名', 
`makefile_path` varchar(50) NULL COMMENT 'makefile 相对路径', 
`algorithm_note` varchar(256) NULL COMMENT '算法说明', 
`algorithm_nick` varchar(256) NULL COMMENT '算法昵称', 
`algorithm_type` int(11) NULL COMMENT '算法类型', 
`project_name` varchar(32) NULL COMMENT '项目名称', 
`test_case` varchar(64) NULL COMMENT '测试用例名称', 
`notifier` varchar(64) NULL COMMENT '消息通知人', 
`model_need` int(11) NULL COMMENT '是否需要模板文件', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 33 CHARSET = utf8 COMMENT = '算法配置表';
CREATE TABLE if not exists is_test_algorithm_so (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`algorithm_id` bigint(20) UNSIGNED NULL COMMENT '算法ID', 
`comment` varchar(118) NULL COMMENT '打包注释', 
`ref_head` varchar(50) NULL COMMENT '算法本地Git库的HEAD ref, 若有tag,存tag,无则存9位commit_id', 
`so_name` varchar(118) NULL COMMENT '该版本的算法包名称', 
`branch` varchar(64) NULL COMMENT '代码分支', 
`status` smallint(6) NULL COMMENT '算法包状态，0:等待测试，1:测试通过，2: 已发布', 
`dict_id` int(11) DEFAULT '0' COMMENT '关联的字典ID', 
PRIMARY KEY (`id`), 
KEY `idx_algorithmid_dictid` (`algorithm_id`, `dict_id`)
)  AUTO_INCREMENT = 208 CHARSET = utf8 COMMENT = '算法包信息';
CREATE TABLE if not exists is_test_algorithm_type (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`type_name` varchar(32) NOT NULL COMMENT '算法类型名称', 
`comment` varchar(512) NULL COMMENT '备注', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 7 CHARSET = utf8 COMMENT = '算法类型';
CREATE TABLE if not exists is_test_codecheck (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`algorithm_id` int(11) NOT NULL COMMENT '算法ID', 
`version` varchar(32) NULL COMMENT '代码版本号', 
`type` int(11) NULL COMMENT '测试类型,1:memcheck', 
`status` int(11) NULL COMMENT '测试状态, 1:准备测试,2:测试中,3:测试完成,-1:异常', 
`check_info` varchar(10) COMMENT '检测信息', 
`branch` varchar(32) NULL COMMENT '代码分支', 
PRIMARY KEY (`id`), 
KEY `algorithmid_idx` (`algorithm_id`, `gmt_modified`)
)  AUTO_INCREMENT = 42 CHARSET = utf8 COMMENT = '代码检测表,记录检测相关信息';
CREATE TABLE if not exists is_test_dictionary (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`dict_name` varchar(64) NULL COMMENT '字典名称', 
`dict_path` varchar(256) NULL COMMENT '字典路径', 
`comment` varchar(256) NULL COMMENT '备注', 
`algorithm_id` int(10) UNSIGNED NULL COMMENT '所属算法ID', 
`dict_files` varchar(1024) NULL COMMENT '字典所包含的文件，以,分隔', 
PRIMARY KEY (`id`), 
KEY `idx_algorithmid` (`algorithm_id`)
)  AUTO_INCREMENT = 47 CHARSET = utf8 COMMENT = '算法字典表';
CREATE TABLE if not exists is_test_result (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`runtime_id` int(11) NULL COMMENT '运行id', 
`script_id` int(11) NULL COMMENT '脚本id', 
`so_id` int(11) NULL COMMENT 'so版本id', 
`result` varchar(5000) NULL COMMENT '结果，json形式', 
PRIMARY KEY (`id`), 
KEY `idx_related_id` (`runtime_id`, `script_id`, `so_id`)
)  AUTO_INCREMENT = 192 CHARSET = utf8 COMMENT = '图像测试结果表';
CREATE TABLE if not exists is_test_runtime_config (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`run_start_time` datetime NULL COMMENT '开始时间', 
`run_end_time` datetime NULL COMMENT '结束时间', 
`thread_num` int(11) DEFAULT '0' COMMENT '并行运行线程数', 
`interval_time` int(11) DEFAULT '0' COMMENT '执行间隔时间', 
`image_cate_id` int(11) NULL COMMENT '目标测试图片类型', 
`notify_users` varchar(1024) NULL COMMENT '通知关注的人', 
`fetch_image_num` int(11) NULL COMMENT '随机取的图片数量', 
`script_path` varchar(1024) NULL COMMENT '执行脚本路径', 
`algorithm_id` int(11) NULL COMMENT 'so_config表主键id', 
`script_config_id` int(11) NULL COMMENT 'id_config表主键id', 
`max_execute_time` int(11) DEFAULT '0' COMMENT '图片测试最大执行次数', 
`status` int(11) NULL COMMENT '1：等待 2：运行中 3：停止 4：异常 5：执行完毕', 
`so_id` int(11) NULL COMMENT '算法包版本ID', 
`type` int(11) NULL COMMENT '测试类型, 1: 功能测试, 2: 性能测试', 
`comment` varchar(118) NULL COMMENT '测试备注', 
`work_machine` varchar(32) NULL COMMENT '运行机器', 
`result_id` int(11) NULL COMMENT '测试结果id', 
PRIMARY KEY (`id`), 
KEY `idx_status_type` (`status`, `type`), 
KEY `idx_related_id` (`algorithm_id`, `script_config_id`, `so_id`)
)  AUTO_INCREMENT = 144 CHARSET = utf8 COMMENT = '图片测试运行配置表';
CREATE TABLE if not exists is_test_sample (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`image_path` varchar(256) NULL COMMENT '图片地址', 
`image_cate_id` int(11) NULL COMMENT '图片类型ID', 
`image_height` int(11) NULL COMMENT '图片高', 
`image_width` int(11) NULL COMMENT '图片宽', 
`image_size` bigint(20) UNSIGNED NULL COMMENT '图片大小', 
`image_info` varchar(1024) NULL COMMENT '图片描述', 
PRIMARY KEY (`id`), 
KEY `image_cate_id` (`image_cate_id`)
)  AUTO_INCREMENT = 42111 CHARSET = utf8 COMMENT = '图片测试素材库';
CREATE TABLE if not exists is_test_sample_cate (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`cate_name` varchar(256) NULL COMMENT '图片样本类型名', 
`comment` varchar(1024) NULL COMMENT '样本类型备注', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 18 CHARSET = utf8 COMMENT = '图片样本类型表';
CREATE TABLE if not exists is_test_script_config (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`script_name` varchar(256) NULL COMMENT '脚本名称', 
`param_config` varchar(1024) NULL COMMENT '参数配置', 
`script_content` varchar(10) COMMENT '脚本内容', 
`script_comment` varchar(1024) NULL COMMENT '脚本说明', 
`algorithm_id` bigint(20) UNSIGNED NOT NULL COMMENT '关联的算法ID', 
`log_config` varchar(1024) NULL COMMENT '日志配置', 
PRIMARY KEY (`id`), 
KEY `idx_algorithm_id` (`algorithm_id`)
)  AUTO_INCREMENT = 39 CHARSET = utf8 COMMENT = '测试py脚本配置表';
CREATE TABLE if not exists is_work_order (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`work_order_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户工单号', 
`app_key` varchar(200) NULL COMMENT '应用在开放平台的appKey', 
`search_id` bigint(20) UNSIGNED NULL COMMENT '搜索服务ID', 
`type` int(10) UNSIGNED NOT NULL COMMENT '工单类型（1: 申请搜索服务  2：配置变更  3：服务下线）', 
`content` varchar(4000) NULL COMMENT '工单基本内容', 
`extinfo` varchar(4000) NULL COMMENT '工单其他信息，如schema配置xml内容', 
`status` tinyint(3) UNSIGNED NOT NULL COMMENT '处理状态（true：已处理，false：待处理）', 
PRIMARY KEY (`id`), 
UNIQUE `work_order_id` (`work_order_id`)
)  CHARSET = utf8 COMMENT = '用户工单信息';
CREATE TABLE if not exists label_image (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`pack_id` bigint(20) NOT NULL COMMENT '分表字段', 
`tfs_path` varchar(200) NULL COMMENT '图片的tfs地址', 
`label_status` varchar(50) NULL COMMENT '标注状态', 
`check_status` varchar(50) NULL COMMENT '校验状态', 
`label_result`varchar(100)COMMENT '标注信息', 
`info` varchar(4000) NULL COMMENT '其它信息', 
`label_template_id` bigint(20) NULL COMMENT '标注模版id', 
`source` int(11) NULL COMMENT '数据来源', 
`out_id` varchar(50) NULL COMMENT '数据来源外键', 
PRIMARY KEY (`id`), 
KEY `idx_packid_labelstatus` (`pack_id`, `label_status`)
)  AUTO_INCREMENT = 3918084 CHARSET = utf8 COMMENT = '图片标注';
CREATE TABLE if not exists label_imageset (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`name` varchar(128) NOT NULL COMMENT '图集名', 
`label_status` varchar(50) DEFAULT '未标注' NOT NULL COMMENT '标注状态', 
`check_status` varchar(50) DEFAULT '未校验' NOT NULL COMMENT '校验状态', 
`marker` varchar(118) NULL COMMENT '标注者', 
`reviewer` varchar(118) NULL COMMENT '校验者', 
`label_progress` float NULL COMMENT '标注进度', 
`check_progress` float NULL COMMENT '校验进度', 
`info`varchar(100)COMMENT '其它信息', 
`type` varchar(118) NULL COMMENT '图集类型', 
`parent` bigint(20) DEFAULT '0' NOT NULL COMMENT '父文件夹', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 14 CHARSET = utf8 COMMENT = '数据标注系统中图集的表';
CREATE TABLE if not exists label_mall_exchange (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户Id', 
`user_nick` varchar(118) NULL COMMENT '用户昵称', 
`gmt_exchange` datetime NULL COMMENT '兑换时间', 
`status` int(11) DEFAULT '0' NOT NULL COMMENT '交易状态  0:兑换申请 1:审核通过,2:审核不通过. 3兑换完成', 
`gift_id` bigint(20) UNSIGNED NOT NULL COMMENT '奖品id', 
`info` varchar(256) NULL COMMENT '其它信息', 
`score` bigint(20) UNSIGNED NULL COMMENT '礼品兑换分数', 
`gift_name` varchar(128) NULL COMMENT '奖品名', 
PRIMARY KEY (`id`), 
KEY `idx_userid` (`user_id`)
)  CHARSET = utf8 COMMENT = '商城兑换记录表';
CREATE TABLE if not exists label_pack_user (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`pack_id` bigint(20) NOT NULL COMMENT '任务包id', 
`user_id` bigint(20) NULL COMMENT '认领者id', 
`label_status` varchar(50) NULL COMMENT '标注状态', 
`check_status` varchar(50) NULL COMMENT '验证状态', 
`label_count` int(11) NULL COMMENT '标注数量', 
`check_count` int(11) NULL COMMENT '验证数量', 
`pay_status` varchar(50) NULL COMMENT '积分发放状态', 
`team_id` bigint(20) NULL COMMENT '在哪个团队认领的', 
`check_success_count` int(11) DEFAULT '0' COMMENT '验证通过个数', 
`check_fail_count` int(11) DEFAULT '0' COMMENT '校验驳回个数', 
`check_redo_count` int(11) DEFAULT '0' COMMENT '重新校验个数', 
PRIMARY KEY (`id`), 
UNIQUE `uk_pack_id_user_id` (`user_id`, `pack_id`), 
KEY `idx_pack_id_user_id` (`pack_id`, `user_id`), 
KEY `idx_user_id_gmtcreate` (`user_id`, `gmt_create`)
)  AUTO_INCREMENT = 144004 CHARSET = utf8 COMMENT = '任务包认领人关系表';
CREATE TABLE if not exists label_project (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`name` varchar(50) NULL COMMENT '项目名', 
`pack_count` int(11) NULL COMMENT '任务包数量', 
`pack_label_count` int(11) NULL COMMENT '标记过的数据', 
`pack_check_count` int(11) NULL COMMENT '验证过的数量', 
`requester` bigint(20) NULL COMMENT '老板id', 
`parent_id` bigint(20) NULL COMMENT '父项目id', 
`root_id` bigint(20) NULL COMMENT '根项目id', 
`free_pack_count` int(11) NULL COMMENT '未被认领的包数量', 
`privacy` int(11) NULL COMMENT '隐私：0为一般隐私，1为发布到集市可见', 
`info`varchar(100)COMMENT '描述', 
`publish_time` datetime NULL COMMENT '发布时间', 
`template_id` bigint(20) UNSIGNED NULL COMMENT '规则模版类型', 
`pay` bigint(20) UNSIGNED NULL COMMENT '每个任务所能获得的积分', 
`status` int(11) DEFAULT '1' NOT NULL COMMENT '状态位，0为未审核，1为审核通过', 
`type` int(11) DEFAULT '0' NOT NULL COMMENT '0个人任务，1团队任务', 
PRIMARY KEY (`id`), 
KEY `idx_name_parent_id` (`parent_id`, `name`), 
KEY `idx_requester_parent_id` (`requester`, `parent_id`), 
KEY `idx_parentid_privacy_type` (`parent_id`, `privacy`, `type`)
)  AUTO_INCREMENT = 160080 CHARSET = utf8 COMMENT = '标注项目';
CREATE TABLE if not exists label_task (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`pack_id` bigint(20) NOT NULL COMMENT '分表字段', 
`task_id` bigint(20) UNSIGNED NOT NULL COMMENT '任务id，label_image或者label_text的外键', 
`task_type` tinyint(4) NOT NULL COMMENT '标注类型，0为image，1为text', 
`marker` bigint(20) NULL COMMENT '标注者', 
`checker` bigint(20) NULL COMMENT '验证者', 
`mark_time` datetime NULL COMMENT '标注时间', 
`check_time` datetime NULL COMMENT '验证时间', 
`project_id` bigint(20) NOT NULL COMMENT 'label_project外键，所属项目', 
`label_result`varchar(100)COMMENT '标注结果', 
`label_template_id` bigint(20) NULL COMMENT '标注模版类型', 
`label_text`varchar(100)COMMENT '数据来源', 
`label_status` varchar(50) NULL COMMENT '标注状态', 
`check_status` varchar(50) NULL COMMENT '校验状态', 
PRIMARY KEY (`id`), 
UNIQUE `uk_taskid_tasktype_marker` (`task_id`, `task_type`, `marker`), 
KEY `idx_packid_taskid_tasktype` (`pack_id`, `task_type`, `task_id`), 
KEY `idx_packid_marker_labelstatus` (`pack_id`, `marker`, `label_status`)
)  AUTO_INCREMENT = 4939329 CHARSET = utf8 COMMENT = '标注任务状态';
CREATE TABLE if not exists label_task_pack (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`name` varchar(128) NULL COMMENT '任务集名', 
`label_status` varchar(50) NULL COMMENT '标注状态', 
`check_status` varchar(50) NULL COMMENT '校验状态', 
`marker` bigint(20) NULL COMMENT '标注者，冗余字段', 
`reviewer` bigint(20) NULL COMMENT '校验者，冗余字段', 
`info`varchar(100)COMMENT '其它信息', 
`label_template_id` bigint(20) NULL COMMENT '图集类型', 
`project_id` bigint(20) NULL COMMENT 'label_project外键，所属项目', 
`description`varchar(100)COMMENT '描述', 
`pay` bigint(20) NULL COMMENT '报酬（单位分)', 
`invalid_time` datetime NULL COMMENT '失效时间', 
`review_type` tinyint(4) NULL COMMENT '验证方式', 
`label_count` int(11) NULL COMMENT '标记过的数据', 
`check_count` int(11) NULL COMMENT '验证过的数量', 
`task_count` int(11) NULL COMMENT '包下的任务数', 
`pay_status` tinyint(4) NULL COMMENT '是否已经支付积分的标记位', 
`marker_count` int(11) NULL COMMENT '标注者人数', 
PRIMARY KEY (`id`), 
KEY `idx_project_id` (`project_id`)
)  AUTO_INCREMENT = 161545 CHARSET = utf8 COMMENT = '任务集';
CREATE TABLE if not exists label_team (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`name` varchar(50) NOT NULL COMMENT '团队名字', 
`member_num` int(11) DEFAULT '0' NOT NULL COMMENT '团队成员数', 
`task_num` int(11) NOT NULL COMMENT '团队任务数', 
`description` varchar(500) NOT NULL COMMENT '简介', 
`signature` varchar(200) NULL COMMENT '签名', 
`owner_id` bigint(20) NOT NULL COMMENT '团主', 
`creator` bigint(20) NOT NULL COMMENT '团队创建者', 
`owner_nick` varchar(118) NOT NULL COMMENT '团主nick', 
`status` int(11) DEFAULT '0' NOT NULL COMMENT '状态位，0为未审核，1为审核通过，2为审核拒绝', 
`join_type` int(11) DEFAULT '0' NOT NULL COMMENT '加入类型，0需要需要审核、1需要密码', 
`join_md5` varchar(118) NULL COMMENT '加入时的密码', 
PRIMARY KEY (`id`), 
KEY `pk_ownerid_status` (`owner_id`, `status`), 
KEY `pk_status` (`status`)
)  AUTO_INCREMENT = 8002 CHARSET = utf8 COMMENT = '团队表';
CREATE TABLE if not exists label_team_project (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`team_id` bigint(20) NOT NULL COMMENT '团队id', 
`project_id` bigint(20) NOT NULL COMMENT '项目id', 
`assign_user_id` bigint(20) NOT NULL COMMENT '领取任务的管理员id', 
`assign_time` datetime NOT NULL COMMENT '领取任务的时间', 
PRIMARY KEY (`id`), 
UNIQUE `uk_teamid_projectid` (`team_id`, `project_id`), 
KEY `pd_projectid` (`project_id`)
)  AUTO_INCREMENT = 112 CHARSET = utf8 COMMENT = '团队领取的项目表';
CREATE TABLE if not exists label_template (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`label_rule`varchar(100)COMMENT '标注规则', 
`info`varchar(100)COMMENT '其它信息', 
`name` varchar(118) NULL COMMENT '模版名', 
`label_result`varchar(100)COMMENT '标注结果', 
`type` varchar(118) NOT NULL COMMENT '模版类型', 
`owner` bigint(20) NULL COMMENT '拥有者的id', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 69003 CHARSET = utf8 COMMENT = '标注模版';
CREATE TABLE if not exists label_text (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`pack_id` bigint(20) NOT NULL COMMENT '分表字段', 
`label_status` varchar(50) NULL COMMENT '标注状态', 
`check_status` varchar(50) NULL COMMENT '校验状态', 
