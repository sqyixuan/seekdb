`banner_url` varchar(256) NULL COMMENT 'banner图片url', 
`sort` int(11) DEFAULT '0' NOT NULL COMMENT '场馆排序', 
`flag_url` varchar(256) NULL COMMENT '国家标识图片url', 
`info` varchar(1024) NULL COMMENT '国家介绍', 
`admin_id` bigint(20) NOT NULL COMMENT '操作小二id', 
