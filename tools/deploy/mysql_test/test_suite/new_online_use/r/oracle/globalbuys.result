`seller_id` bigint(20) NOT NULL COMMENT '卖家Id', 
`seller_nick` varchar(1024) NOT NULL COMMENT '卖家昵称', 
`is_self_quit` tinyint(4) NULL COMMENT '参见record', 
`is_prepay` tinyint(4) NULL COMMENT '参见record', 
`seller_star_name` tinyint(4) NULL COMMENT '参见record', 
`open_shop_long` tinyint(4) NULL COMMENT '参见record', 
`dsr_service` tinyint(4) NULL COMMENT 'dsr_service', 
`dsr_merchandise` tinyint(4) NULL COMMENT 'dsr_merchandise', 
`year_b_point` tinyint(4) NULL COMMENT 'year_b_point', 
`year_a_point` tinyint(4) NULL COMMENT 'year_a_point', 
`fee30_per_uv` tinyint(4) NULL COMMENT 'fee30_per_uv', 
`auc_n` tinyint(4) NULL COMMENT 'auc_n', 
`virtual_rate` tinyint(4) NULL COMMENT 'virtual_rate', 
`avg30_issue_refund_ratio` tinyint(4) NULL COMMENT 'avg30_issue_refund_ratio', 
`ali30_uv` tinyint(4) NULL COMMENT 'ali30_uv', 
`combine3` tinyint(4) NULL COMMENT 'combine3', 
`is_high_danger` tinyint(4) NULL COMMENT 'is_high_danger', 
`data_source` tinyint(4) NULL COMMENT 'data_source', 
`quit_reason` varchar(200) NULL COMMENT 'quit_reason', 
`approve_status` tinyint(4) NULL COMMENT '店铺状态', 
`dsr_consignment` tinyint(4) NULL COMMENT 'dsr_consignment', 
`dsr_service_value` double NULL COMMENT 'dsr_service值', 
`dsr_consignment_value` double NULL COMMENT 'dsr_consignment值', 
`dsr_merchandise_value` double NULL COMMENT 'dsr_merchandise值', 
`year_a_point_value` double NULL COMMENT 'year_a_point值', 
`year_b_point_value` double NULL COMMENT 'year_b_point值', 
`open_shop_long_value` bigint(20) NULL COMMENT 'open_shop_long值', 
`virtual_rate_value` double NULL COMMENT 'virtual_rate值', 
`ali30_uv_value` bigint(20) NULL COMMENT 'ali30_uv值', 
`seller_star_id_value` int(11) NULL COMMENT 'seller_star_id值', 
`seller_star_name_value` varchar(20) NULL COMMENT 'seller_star_name值', 
`fee30_per_uv_value` double NULL COMMENT 'fee30_per_uv值', 
`auc_n_value` bigint(20) NULL COMMENT 'auc_n值', 
`avg30_issue_refund_ratio_value` double NULL COMMENT 'avg30_issue_refund_ratio值', 
`c_cnt_old` int(11) DEFAULT '0' COMMENT '历史C类违规次数', 
`auc_ovs_r_p` double DEFAULT '0' COMMENT '海外商品数占比', 
`overseas_r_p` double DEFAULT '0' COMMENT '海外商品成交占比', 
PRIMARY KEY (`id`), 
KEY `sellerid` (`seller_id`, `data_source`, `gmt_create`)
)  AUTO_INCREMENT = 133681 CHARSET = utf8 COMMENT = '卖家清退结果';
drop table if exists sequence;
CREATE TABLE if not exists sequence (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT 'id', 
`name` varchar(255) NULL COMMENT 'name', 
`value` bigint(20) NULL COMMENT 'value', 
`gmt_modified` datetime NULL COMMENT 'modified', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 2 CHARSET = utf8 COMMENT = 'tddl_sequence';
CREATE TABLE if not exists service_output_filter_config (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`app_name` varchar(118) NOT NULL COMMENT '应用名称', 
`service_name` varchar(200) NOT NULL COMMENT '服务名称', 
`function_name` varchar(200) NOT NULL COMMENT '调用函数名称', 
`content`varchar(100)COMMENT '配置内容', 
`version` int(11) DEFAULT '1' NOT NULL COMMENT '版本号', 
`attributes` varchar(2000) NULL COMMENT '扩展字段', 
`config_code` varchar(512) NOT NULL COMMENT '每个应用下config_code唯一', 
`description` varchar(2000) NULL COMMENT '描述', 
`env` varchar(10) NULL COMMENT '环境: 日常-daily 预发-pre  线上-online', 
`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '0:正常 -1:删除', 
PRIMARY KEY (`id`), 
KEY `normal_select_env_app_status` (`env`, `status`, `app_name`)
)  CHARSET = utf8 COMMENT = '全球购服务输出过滤配置详情';
CREATE TABLE if not exists global_high_risk_seller (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`seller_nick` varchar(1024) NOT NULL COMMENT '卖家NICK', 
`credit_score` double NOT NULL COMMENT '诚信分', 
`is_high_risk` varchar(128) NOT NULL COMMENT '是否高危卖家', 
`total_ability_score` double NOT NULL COMMENT '能力模型综合分数', 
`customer_ability_score` double NOT NULL COMMENT '能力模型客户关系分数', 
`service_ability_score` double NOT NULL COMMENT '能力模型服务分数', 
`marketing_ability_score` double NOT NULL COMMENT '能力模型引流分数', 
`design_ability_score` double NOT NULL COMMENT '能力模型装修分数', 
`goods_ability_score` double NOT NULL COMMENT '能力模型选品分数', 
`seller_group` double NOT NULL COMMENT '能力模型卖家所在群体', 
`mark` varchar(512) NOT NULL COMMENT '网安假货模型-名单标识', 
PRIMARY KEY (`id`), 
KEY `idx_seller_id_is_high_risk` (`seller_id`, `is_high_risk`)
)  CHARSET = utf8 COMMENT = '全球购高危卖家 从云梯2通过datax回流';
CREATE TABLE if not exists global_lbs_history (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`seller_nick` varchar(200) NULL COMMENT '卖家昵称', 
`longitude` varchar(200) NOT NULL COMMENT '经度', 
`dimension` varchar(200) NOT NULL COMMENT '维度', 
`location` varchar(1024) NOT NULL COMMENT '地址信息', 
`browse_time` date NOT NULL COMMENT '浏览时间', 
`country` varchar(200) NULL COMMENT '国家', 
`browser_day_count` int(11) DEFAULT '1' COMMENT '当天浏览次数', 
`attributes` varchar(1024) NOT NULL COMMENT '预留字段', 
PRIMARY KEY (`id`), 
KEY `seller_search` (`seller_id`, `gmt_create`)
)  AUTO_INCREMENT = 4408062 CHARSET = utf8 COMMENT = 'lbs_history';
