CREATE TABLE if not exists bak_global_item_extra_20140414_2052_00_1_es (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`item_id` bigint(20) NOT NULL COMMENT '商品数字id', 
`user_id` bigint(20) NOT NULL COMMENT '卖家数字id', 
`nick` varchar(64) NULL COMMENT '用户昵称', 
`title` varchar(256) NOT NULL COMMENT '宝贝标题', 
`price` bigint(20) DEFAULT '0' NOT NULL COMMENT '商品价格', 
`category_id` bigint(20) NOT NULL COMMENT '类目id', 
`pict_url` varchar(256) NOT NULL COMMENT '主图路径', 
`country` varchar(256) NULL COMMENT '国家', 
`state` varchar(256) NULL COMMENT '州', 
`city` varchar(256) NULL COMMENT '市', 
`area` varchar(256) NULL COMMENT '区', 
`lbs` varchar(512) NULL COMMENT '详细地址', 
`division_code` bigint(20) NULL COMMENT '区域码', 
`coordinate` varchar(256) NULL COMMENT '经纬度', 
`fare` bigint(20) DEFAULT '0' NOT NULL COMMENT '运费', 
`desc_path` varchar(256) NOT NULL COMMENT '描述路径', 
`auction_type` varchar(1) NOT NULL COMMENT '宝贝类型', 
`sold_quantity` bigint(20) DEFAULT '0' NOT NULL COMMENT '销售量', 
`item_from` varchar(118) NULL COMMENT '来源', 
`device` int(11) NULL COMMENT '设备', 
`video_url` varchar(256) NULL COMMENT '视频地址', 
`attributes` varchar(100) NULL COMMENT '业务自定义属性', 
`status` tinyint(4) NOT NULL COMMENT '宝贝状态', 
`quantity` bigint(20) DEFAULT '1' NOT NULL COMMENT '库存', 
`sort_time` datetime NULL COMMENT '排序时间', 
`pict_desc_path` varchar(2000) NULL COMMENT '描述图片路径', 
`head_pict_path` varchar(512) NULL COMMENT '头像路径', 
PRIMARY KEY (`id`), 
UNIQUE `itemid` (`item_id`), 
KEY `userid` (`user_id`), 
KEY `gmtcreate` (`gmt_create`), 
KEY `status` (`status`), 
KEY `attributes` (`attributes`)
)  AUTO_INCREMENT = 13346 CHARSET = utf8 COMMENT = '全球代购DB';
CREATE TABLE if not exists bwt_protect_config (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`status` int(11) NOT NULL COMMENT '状态，0：生效 -1: 删除', 
`name` varchar(200) NOT NULL COMMENT '配置名称（默认展示活动名称）', 
`source_type` int(11) NOT NULL COMMENT '来源类型，来源作为enum写到程序中； 1-招商活动 2-聚划算', 
`source_main_id` varchar(128) NULL COMMENT '来源活动主要id标示；譬如招商活动的活动id', 
`source_sub_id` varchar(128) NULL COMMENT '来源活动的次要id标示，譬如招商活动的子活动id', 
`protect_time` int(11) DEFAULT '-1' NOT NULL COMMENT '保护时间，大于0为保护天数；-1 直接到活动结束', 
`ext_memo` varchar(256) NULL COMMENT '外部备注', 
`inner_memo` varchar(256) NULL COMMENT '内部注释', 
`attributes` varchar(2000) NULL COMMENT '冗余字段，json格式', 
`primary_buffer1` varchar(128) NULL COMMENT '冗余索引字段1', 
`primary_buffer2` varchar(128) NULL COMMENT '冗余索引字段1', 
`protect_start_type` int(11) DEFAULT '0' NOT NULL COMMENT '保护开始类型 0审核通过 1活动开始', 
`operator` varchar(64) NULL COMMENT '创建者', 
`source_start` datetime NULL COMMENT '来源开始时间 - 如招商活动开始时间', 
`source_end` datetime NULL COMMENT '来源结束时间 - 如招商活动结束时间', 
PRIMARY KEY (`id`), 
KEY `idx_source` (`source_type`, `source_sub_id`, `status`)
)  AUTO_INCREMENT = 23 CHARSET = utf8 COMMENT = '白名单保护配置(blackwhite_proected_config)';
CREATE TABLE if not exists bwt_result (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '会员id', 
`status` int(11) NULL COMMENT '0-生效  -1: 小二删除 -2:系统删除  1:完结', 
`gmt_start` datetime NULL COMMENT '开始时间，保护/拉黑开始时间', 
`gmt_end` datetime NULL COMMENT '结束时间, 保护/拉黑时间。如果是2999-01-01 00:00:00表示永久', 
`biz_type` int(11) NOT NULL COMMENT '业务类型 1-招商黑名单', 
`biz_id` bigint(20) UNSIGNED NULL COMMENT '业务id；如果没有则空置', 
`operator` varchar(64) NULL COMMENT '操作人；如果system_type为小二，则记录小二昵称', 
`system_type` int(11) DEFAULT '0' NOT NULL COMMENT '系统类型 0-系统 1-小二手工增加', 
`sub_biz_type` int(11) NULL COMMENT '子业务类型,业务方自己定义', 
`primary_buffer1` bigint(20) UNSIGNED NULL COMMENT '主要业务字段1', 
`primary_buffer2` bigint(20) UNSIGNED NULL COMMENT '主要 业务字段2', 
`inner_memo` varchar(1024) NULL COMMENT '内部备注', 
`extra_memo` varchar(1024) NULL COMMENT '外部备注，用于旺旺等信息纰漏', 
`attributes` varchar(2000) NULL COMMENT '附加属性', 
`user_nick` varchar(200) NULL COMMENT '会员昵称', 
PRIMARY KEY (`id`), 
KEY `idx_timetask_change_status` (`status`, `gmt_end`), 
KEY `idx_query_type` (`biz_type`, `status`, `gmt_start`), 
KEY `idx_search_userid` (`user_id`, `biz_type`, `gmt_start`)
)  AUTO_INCREMENT = 81500 CHARSET = utf8 COMMENT = '黑白名单记录（拉黑、保护记录）';
CREATE TABLE if not exists channel_buyer (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`deleted` bigint(20) UNSIGNED DEFAULT '1' NOT NULL COMMENT '1：未删除，2：已删除', 
`user_nick` varchar(512) NOT NULL COMMENT '用户昵称', 
`show_name` varchar(512) NOT NULL COMMENT '用户显示名称，若为空，则默认为用户昵称', 
`shop_url` varchar(1024) NOT NULL COMMENT '买手店铺链接', 
`post_num` int(11) DEFAULT '0' NOT NULL COMMENT '每日限制发帖数', 
`country` varchar(118) NOT NULL COMMENT '买手所在国家', 
`city` varchar(118) NOT NULL COMMENT '买手所在城市', 
`avatar` varchar(1024) NOT NULL COMMENT '买手头像', 
PRIMARY KEY (`id`), 
KEY `idx_gmt_create` (`gmt_create`)
)  AUTO_INCREMENT = 84 CHARSET = utf8 COMMENT = '买手频道买手表';
CREATE TABLE if not exists channel_goods (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`deleted` tinyint(4) DEFAULT '1' NOT NULL COMMENT '1：未删除，2：已删除', 
`info` varchar(1024) NOT NULL COMMENT '页卡描述', 
`rank` smallint(6) DEFAULT '0' NOT NULL COMMENT '置顶顺序，0不置顶', 
`status` tinyint(4) DEFAULT '1' NOT NULL COMMENT '上线状态，1上线，2不上线', 
`buyer_id` bigint(20) UNSIGNED NOT NULL COMMENT '买手id', 
`item1_id` bigint(20) UNSIGNED NOT NULL COMMENT '大图对应的淘宝商品id', 
`item1_img` varchar(1024) NOT NULL COMMENT '大图地址', 
`item2_id` bigint(20) UNSIGNED NOT NULL COMMENT '小图1对应的淘宝商品id', 
`item2_img` varchar(1024) NOT NULL COMMENT '小图1地址', 
`item3_id` bigint(20) UNSIGNED NOT NULL COMMENT '小图2对应的淘宝商品id', 
`item3_img` varchar(1024) NOT NULL COMMENT '小图2地址', 
PRIMARY KEY (`id`), 
KEY `idx_rank` (`rank`), 
KEY `idx_buyer_id` (`buyer_id`), 
KEY `idx_gmt_create` (`gmt_create`)
)  AUTO_INCREMENT = 119 CHARSET = utf8 COMMENT = '买手频道商品表';
CREATE TABLE if not exists direct_post_item (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '卖家ID', 
`category_id` bigint(20) NOT NULL COMMENT '叶子类目', 
`title` varchar(256) NOT NULL COMMENT '商品标题', 
`pic_url` varchar(256) NULL COMMENT '商品主图', 
`fare` bigint(20) NULL COMMENT '运费', 
`attributes` varchar(3000) NULL COMMENT '冗余属性', 
`auction_status` int(11) NULL COMMENT '宝贝状态', 
`sold_quantity` bigint(20) NULL COMMENT '销量', 
`sku_id` tinyint(4) NULL COMMENT 'sku_id', 
`spu_id` tinyint(4) NULL COMMENT 'spu_id', 
`options` varchar(2000) NULL COMMENT 'options', 
`property` varchar(2000) NULL COMMENT '商品属性', 
`inventory_id` bigint(20) NULL COMMENT '库存', 
`quantity` bigint(20) NULL COMMENT '当前数量', 
`item_id` bigint(20) NOT NULL COMMENT '商品Id', 
`seller_nick` varchar(200) NULL COMMENT '卖家昵称', 
`reserve_price` bigint(20) NOT NULL COMMENT '商品价格', 
`postage_id` bigint(20) NULL COMMENT '所属运费', 
`buy_country` varchar(256) NOT NULL COMMENT '采购地', 
`gmt_quit_direct_post` datetime NOT NULL COMMENT '最后一次退出直邮的时间', 
`post_country` varchar(256) NOT NULL COMMENT '发货地', 
`direct_post_status` int(11) NOT NULL COMMENT '直邮状态 0-直邮 1-非直邮', 
`gmt_add_direct_post` datetime NOT NULL COMMENT '最后一次加入直邮的时间', 
PRIMARY KEY (`id`), 
UNIQUE `item_id` (`item_id`), 
KEY `selleritem` (`seller_id`, `item_id`), 
KEY `gmt_create` (`gmt_create`)
)  AUTO_INCREMENT = 4859275 CHARSET = utf8 COMMENT = '直邮商品表';
CREATE TABLE if not exists direct_post_seller (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家Id', 
`seller_nick` varchar(200) NOT NULL COMMENT '卖家昵称', 
`seller_pic` varchar(200) NULL COMMENT '卖家头像', 
`country` varchar(200) NULL COMMENT '直邮所在国家', 
`attributes` varchar(2000) NULL COMMENT '冗余字段', 
`status` tinyint(4) NULL COMMENT '卖家状态', 
`items_count` bigint(20) NULL COMMENT '直邮商品数', 
`latest_pub_time` datetime NULL COMMENT '最近一次发布时间', 
`latest_pub_item` bigint(20) NULL COMMENT '最近一次发布宝贝', 
`first_pub_time` datetime NULL COMMENT '第一次发布时间', 
`first_pub_item` bigint(20) NULL COMMENT '第一次发布宝贝', 
`collect_count` bigint(20) NULL COMMENT '被收藏次数', 
`main_category` tinyint(4) NULL COMMENT '主营类目', 
`main_brand` varchar(200) NULL COMMENT '主营品牌', 
PRIMARY KEY (`id`), 
KEY `seller_id` (`seller_id`)
)  CHARSET = utf8 COMMENT = '直邮卖家表';
CREATE TABLE if not exists global_act_notice (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`act_id` bigint(20) NOT NULL COMMENT '活动Id', 
`subscriber_id` bigint(20) NOT NULL COMMENT '活动订阅者Id', 
`status` int(11) DEFAULT '0' NOT NULL COMMENT '0-有效 -1-无效', 
`notice_type` int(11) DEFAULT '0' NOT NULL COMMENT '通知类型', 
`attributes` varchar(2048) NULL COMMENT 'key:value', 
PRIMARY KEY (`id`), 
UNIQUE `userandact` (`act_id`, `subscriber_id`), 
KEY `index_status` (`status`), 
KEY `index_subscriber` (`subscriber_id`)
)  AUTO_INCREMENT = 130942 CHARSET = utf8 COMMENT = '全球购活动预告通知表';
CREATE TABLE if not exists global_activity_extend_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`unit_id` bigint(20) NULL COMMENT '如果活动类型是惊喜，这个字段是商品ID。。如果是首页，这里是卖家ID', 
`feature` varchar(2048) NOT NULL COMMENT '标签字段，k：v存储。与页面无关，只存储活动中商品的销量等统计类信息', 
`contents`varchar(100)NOT NULL COMMENT '存放每个活动报名的商品或卖家信息,json形式存储', 
`seller_id` bigint(20) NULL COMMENT '卖家ID', 
`seller_nick` varchar(1024) NULL COMMENT '卖家NICK', 
`unit_type` tinyint(4) NULL COMMENT '活动维度 1：卖家维度  2：商品维度', 
`activity_type` tinyint(4) NULL COMMENT '活动类型 1：惊喜  2：首页', 
`sorted` int(11) NULL COMMENT '排序字段', 
`edit_status` tinyint(4) NOT NULL COMMENT '扩展信息编辑状态  0：生效  1：编辑中', 
`activity_id` bigint(20) NULL COMMENT '活动ID，活动表的主键', 
`start_time` datetime NULL COMMENT '活动开始时间', 
`end_time` datetime NULL COMMENT '活动结束时间', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 12619 CHARSET = utf8 COMMENT = '全球购活动产品扩展表';
CREATE TABLE if not exists global_activity_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`title` varchar(1024) NULL COMMENT '标题', 
`status` tinyint(4) NULL COMMENT '活动状态 0：生效  1: 编辑中', 
`admin_id` bigint(20) NULL COMMENT '小二ID', 
`admin_nick` varchar(512) NULL COMMENT '小二nick', 
`start_time` datetime NULL COMMENT '活动开始时间', 
`end_time` datetime NULL COMMENT '活动结束时间', 
`activity_type` tinyint(4) NOT NULL COMMENT '活动类型  1：洋桃惊喜  2：洋桃首页', 
`unit_type` tinyint(4) NULL COMMENT '活动维度 1：卖家维度  2：商品维度', 
`schema_info` varchar(2048) NULL COMMENT '存放数据格式定义', 
`attributes` varchar(2048) NULL COMMENT '备注', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 2361 CHARSET = utf8 COMMENT = '全球购活动记录表';
CREATE TABLE if not exists global_brand_category (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`brand_id` bigint(20) UNSIGNED NOT NULL COMMENT '品牌id', 
`brand_name_cn` varchar(64) NULL COMMENT '品牌中文名', 
`brand_name_en` varchar(64) NULL COMMENT '品牌英文名', 
`category1_id` bigint(20) UNSIGNED NULL COMMENT '淘宝一级类目id', 
`category1_info`varchar(100)COMMENT '淘宝一级类目文案描述', 
`category2_id` bigint(20) UNSIGNED NULL COMMENT '淘宝二级类目id', 
`category2_info`varchar(100)COMMENT '淘宝二级类目文案描述', 
`custom_category1_id` bigint(20) UNSIGNED NULL COMMENT '自定义一级类目id', 
`custom_category1_info`varchar(100)COMMENT '自定义一级类目文案描述', 
`initial` varchar(1) NULL COMMENT '首字母', 
`score` bigint(20) UNSIGNED NULL COMMENT '分值', 
`online_items_count` bigint(20) UNSIGNED NULL COMMENT '在线商品数', 
`online_seller_count` bigint(20) UNSIGNED NULL COMMENT '在线商家数', 
PRIMARY KEY (`id`), 
KEY `custom_category1_id_index` (`custom_category1_id`), 
KEY `gmt_create_index` (`gmt_create`)
)  AUTO_INCREMENT = 4119270 CHARSET = utf8 COMMENT = '品牌与类目关系';
CREATE TABLE if not exists global_brand_extra (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`brand_name_cn` varchar(64) NULL COMMENT '品牌名中文', 
`brand_name_en` varchar(64) NULL COMMENT '品牌名英文', 
`logo` varchar(512) NULL COMMENT '品牌logo地址', 
`aliases`varchar(100)COMMENT '品牌别名集合，多个别名用逗号分隔', 
`brand_id` bigint(20) UNSIGNED NOT NULL COMMENT '品牌id', 
`logo_source` int(11) DEFAULT '0' COMMENT '图片来源：1.品牌中心2.英文名称生成3.中文名称生成', 
PRIMARY KEY (`id`), 
KEY `brand_id_index` (`brand_id`), 
KEY `idx_gmt_create` (`gmt_create`)
)  AUTO_INCREMENT = 1134320 CHARSET = utf8 COMMENT = '品牌扩展信息表';
CREATE TABLE if not exists global_bwt_protect_seller_result_list (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` timestamp DEFAULT CURRENT_TIMESTAMP NOT NULL COMMENT '时间创建', 
`gmt_modified` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家id', 
PRIMARY KEY (`id`), 
UNIQUE `uniq_idx_seller` (`seller_id`), 
KEY `idx_create_time` (`gmt_create`)
)  AUTO_INCREMENT = 35688 CHARSET = utf8 COMMENT = '白名单odps回流';
CREATE TABLE if not exists global_dartlike (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) NOT NULL COMMENT '代购者用户id', 
`user_nick` varchar(256) NOT NULL COMMENT '代购者用户nick', 
`dartlike_content` varchar(4000) NOT NULL COMMENT '代购内容', 
`pict_urls` varchar(100) NULL COMMENT '代购用户上传图片的tfs地址，多个图片用英文逗号分隔', 
`tags` varchar(2000) NULL COMMENT '代购用户填写的代购内容标签，多个标签用英文逗号分隔', 
`attributes` varchar(4000) NULL COMMENT '扩展key:value，多个用英文分号分隔', 
`dartlike_seller_count` int(11) DEFAULT '0' COMMENT '接镖卖家数', 
`dartlike_status` int(11) DEFAULT '0' NOT NULL COMMENT '该求购状态，0表示正常，1表示已经关闭，2表示有违规', 
`last_comment_id` bigint(20) DEFAULT '0' COMMENT '最后一条留言id', 
`last_comment_time` datetime NULL COMMENT '最后一条留言时间', 
`last_comment_userid` bigint(20) NULL COMMENT '最后一条留言用户id', 
`last_comment_usernick` varchar(256) NULL COMMENT '最后一条留言的用户nick', 
`cat_id` bigint(20) NULL COMMENT '保留字段：该求购对应的类目id', 
`is_test` int(11) DEFAULT '0' COMMENT '是否是测试求购（测试求购不要展示到正式环境）。0表示否，1表示是。', 
`brand_info` varchar(256) NULL COMMENT '品牌信息（中文/英文）', 
`close_time` datetime NULL COMMENT '如果代购关闭，则记录关闭时间', 
`close_operator` varchar(300) NULL COMMENT '关闭的操作者，记录 id和用户名（有可能小二操作或系统自动操作）', 
`browse_count` int(11) DEFAULT '0' COMMENT '被浏览次数', 
`dialog_count` int(11) DEFAULT '0' COMMENT '买卖家之间针对该求购的对话次数', 
PRIMARY KEY (`id`), 
KEY `userid_pk` (`user_id`), 
KEY `dartlikestatus_pk` (`dartlike_status`)
)  AUTO_INCREMENT = 63965 CHARSET = utf8 COMMENT = '淘宝用户发起的求代购';
CREATE TABLE if not exists global_datax_item_model (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`item_id` bigint(20) NOT NULL COMMENT '商品id', 
`title` varchar(256) NOT NULL COMMENT '商品标题', 
`score` double DEFAULT '0' COMMENT '评分', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`tzk_rate` double DEFAULT '0' COMMENT '折扣率', 
`pict_url` varchar(256) NULL COMMENT '图片地址', 
`quantity` bigint(20) NOT NULL COMMENT '库存', 
`ordercost` bigint(20) DEFAULT '0' COMMENT '收藏人气', 
`auc_haopinglv` double DEFAULT '0' COMMENT '好评率', 
`sel_rate_cnt` bigint(20) DEFAULT '0' COMMENT '评价数', 
`sel_hp_cnt` bigint(20) DEFAULT '0' COMMENT '好评数', 
`category_level1` bigint(20) NULL COMMENT '一级类目', 
`category_level1_name` varchar(128) NULL COMMENT '一级类目名称', 
`category_level2` bigint(20) NULL COMMENT '二级类目', 
`category_level2_name` varchar(128) NULL COMMENT '二级类目名称', 
`category` bigint(20) DEFAULT '0' NOT NULL COMMENT '叶子类目', 
`category_name` varchar(128) NULL COMMENT '叶子类目名称', 
`reserve_price` bigint(20) DEFAULT '0' COMMENT '一口价：价格相关单位全部为分', 
`avg_price` bigint(20) DEFAULT '0' COMMENT '一月内均价', 
`sell_price` bigint(20) DEFAULT '0' COMMENT '现售价', 
`attributes` varchar(2000) NULL COMMENT '特征值信息', 
`nick` varchar(64) NULL COMMENT '用户昵称', 
`sold_quantity` bigint(20) DEFAULT '0' COMMENT '30天销量', 
PRIMARY KEY (`id`), 
UNIQUE `unique_itemid` (`item_id`)
)  AUTO_INCREMENT = 399418546 CHARSET = utf8 COMMENT = '全球购商品选品模型回流信息表';
CREATE TABLE if not exists global_high_risk_order (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家id', 
`seller_nick` varchar(1024) NOT NULL COMMENT '卖家nick', 
`shop_id` bigint(20) NOT NULL COMMENT '店铺id', 
`shop_name` varchar(2048) NOT NULL COMMENT '店铺名', 
`auction_id` bigint(20) NOT NULL COMMENT '宝贝id', 
`auction_title` varchar(2048) NOT NULL COMMENT '宝贝名称', 
`xiaoer_confirmed` tinyint(4) NOT NULL COMMENT '小二是否处理过  1 处理过   0 未处理', 
`apass_tag` tinyint(4) NULL COMMENT '1:apass会员', 
`order_id` bigint(20) NOT NULL COMMENT '订单ID', 
`risk_source` int(11) NULL COMMENT '高危订单来源（网安 1 、CRM模型 0）', 
`level` int(11) NULL COMMENT '订单高危级别 数字由低到高，代表高危程度   0 非高危订单   1 低级 2中级 3 高危', 
PRIMARY KEY (`id`), 
UNIQUE `idx_orderid` (`order_id`)
)  AUTO_INCREMENT = 119 CHARSET = utf8 COMMENT = '全球购高危订单表';
CREATE TABLE if not exists global_high_risk_seller_datax (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家ID', 
`seller_nick` varchar(1024) NOT NULL COMMENT '卖家NICK', 
`is_high_risk` tinyint(4) NOT NULL COMMENT '是否高危', 
`mark` varchar(1024) NOT NULL COMMENT '网安假货模型的名单标识', 
`credit_score` double NOT NULL COMMENT '诚信分', 
`total_ability_score` double NOT NULL COMMENT '能力模型综合分数', 
`customer_ability_score` double NOT NULL COMMENT '能力模型客户关系分数', 
`service_ability_score` double NOT NULL COMMENT '能力模型服务分数', 
`marketing_ability_score` double NOT NULL COMMENT '能力模型引流分数', 
`design_ability_score` double NOT NULL COMMENT '能力模型装修分数', 
`goods_ability_score` double NOT NULL COMMENT '能力模型选品分数', 
`seller_group` varchar(1024) NOT NULL COMMENT '分群模型卖家所在群体', 
`odps_import_time` varchar(1024) NOT NULL COMMENT '数据从odps导过来的日期 没有时分秒', 
`black_reason` varchar(1024) NULL COMMENT 'odps导入', 
`level` bigint(20) NULL COMMENT '诚信模型分层', 
`level_attr` bigint(20) NULL COMMENT '诚信模型分层属性', 
PRIMARY KEY (`id`), 
KEY `idx_sellerid` (`seller_id`), 
KEY `idx_ishighrisk` (`is_high_risk`), 
KEY `idx_odpsimporttime` (`odps_import_time`)
)  AUTO_INCREMENT = 19509239 CHARSET = utf8 COMMENT = '全球购招商卖家准入表，odps数据通过datax回流的';
CREATE TABLE if not exists global_item_extra (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`item_id` bigint(20) NOT NULL COMMENT '商品数字id', 
`user_id` bigint(20) NOT NULL COMMENT '卖家数字id', 
`nick` varchar(64) NULL COMMENT '用户昵称', 
`title` varchar(256) NOT NULL COMMENT '宝贝标题', 
`price` bigint(20) DEFAULT '0' NOT NULL COMMENT '商品价格', 
`category_id` bigint(20) NOT NULL COMMENT '类目id', 
`pict_url` varchar(256) NOT NULL COMMENT '主图路径', 
`country` varchar(256) NULL COMMENT '国家', 
`state` varchar(256) NULL COMMENT '州', 
`city` varchar(256) NULL COMMENT '市', 
`area` varchar(256) NULL COMMENT '区', 
`lbs` varchar(512) NULL COMMENT '详细地址', 
`division_code` bigint(20) NULL COMMENT '区域码', 
`coordinate` varchar(256) NULL COMMENT '经纬度', 
`fare` bigint(20) DEFAULT '0' NOT NULL COMMENT '运费', 
`desc_path` varchar(256) NOT NULL COMMENT '描述路径', 
`auction_type` varchar(1) NOT NULL COMMENT '宝贝类型', 
`sold_quantity` bigint(20) DEFAULT '0' NOT NULL COMMENT '销售量', 
`item_from` varchar(118) NULL COMMENT '来源', 
`device` int(11) NULL COMMENT '设备', 
`video_url` varchar(256) NULL COMMENT '视频地址', 
`attributes` varchar(3000) NULL COMMENT '业务自定义属性', 
`status` tinyint(4) NOT NULL COMMENT '宝贝状态', 
`quantity` bigint(20) DEFAULT '1' NOT NULL COMMENT '库存', 
`sort_time` datetime NULL COMMENT '排序时间', 
`pict_desc_path` varchar(2000) NULL COMMENT '描述图片路径', 
`head_pict_path` varchar(512) NULL COMMENT '头像路径', 
`publish_type` tinyint(4) DEFAULT '0' COMMENT '发布类型：0-单品（兼容以前数据） 1-直播活动商品', 
`business_id` bigint(20) DEFAULT '0' COMMENT '业务id 当publish_type = 1时，表示直播活动id', 
`post_type` tinyint(4) DEFAULT '0' COMMENT '包邮类型 1-包邮 0orNull 未填写', 
`duty_type` tinyint(4) DEFAULT '0' COMMENT '包税类型 1包税 0orNull-未选择', 
`tranport_type` tinyint(4) DEFAULT '0' COMMENT '货品类型  1-直邮 2-中转 3-国内现货', 
`init_pict_urls` varchar(2000) NULL COMMENT '初始图片', 
`is_live_hot` tinyint(4) DEFAULT '0' COMMENT '是否是直播置顶宝贝', 
PRIMARY KEY (`id`), 
UNIQUE `itemid` (`item_id`), 
KEY `userid` (`user_id`), 
KEY `gmtcreate` (`gmt_create`), 
KEY `status` (`status`), 
KEY `attributes` (`attributes`), 
KEY `business` (`business_id`, `publish_type`)
)  AUTO_INCREMENT = 1116230 CHARSET = utf8 COMMENT = '全球代购DB';
CREATE TABLE if not exists global_item_hisperf_datax (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '商品id', 
`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '卖家id', 
`seller_nick` varchar(120) NOT NULL COMMENT '卖家昵称', 
`item_create` datetime NULL COMMENT '商品创建时间', 
`alipay_fee_month` double NULL COMMENT '商品近一个月支付金额', 
`alipay_count_month` int(11) NULL COMMENT '商品近一个月支付订单数', 
`alipay_uv_month` int(11) NULL COMMENT '近一个月支付uv', 
`like_count` bigint(20) UNSIGNED NULL COMMENT '喜欢数', 
`comment_count` bigint(20) UNSIGNED NULL COMMENT '评论数', 
`gmt_odps` datetime NULL COMMENT 'odps的调度日期', 
`sort_value` bigint(20) NULL COMMENT '综合排序值', 
PRIMARY KEY (`id`), 
UNIQUE `unique_item_id` (`item_id`), 
KEY `search_seller_id` (`seller_id`)
)  AUTO_INCREMENT = 240123054 CHARSET = utf8 COMMENT = '商品历史表现';
CREATE TABLE if not exists global_ka_seller_basic_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_nick` varchar(200) NULL COMMENT '商家昵称', 
`seller_id` bigint(20) NOT NULL COMMENT '商家ID', 
`main_cate_id` bigint(20) NULL COMMENT '主营类目id', 
`main_cate_name` varchar(118) NULL COMMENT '主营类目名称', 
`brand` varchar(118) NULL COMMENT '品牌名称', 
`status` tinyint(4) NULL COMMENT 'KA状态，0已签约,1降级,2 删除', 
`last_upd_status_time` datetime NULL COMMENT '最后一次status变更时间', 
PRIMARY KEY (`id`), 
UNIQUE `uniq_idx_seller_id` (`seller_id`), 
KEY `idx_seller_nick` (`seller_nick`), 
KEY `idx_create_time` (`gmt_create`), 
KEY `idx_cate_id` (`main_cate_id`)
)  AUTO_INCREMENT = 3263 CHARSET = utf8 COMMENT = '全球购KA活动签约商家信息表';
CREATE TABLE if not exists global_ka_seller_brand_upload (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`brand_id` bigint(20) NULL COMMENT '品牌id', 
`brand_name` varchar(118) NULL COMMENT '品牌名', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 205 CHARSET = utf8 COMMENT = '用于在odps上同步ka品牌信息';
CREATE TABLE if not exists global_ka_seller_cate_brand (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`stat_date` datetime NULL COMMENT '统计日期', 
`cate_level1_id` bigint(20) NULL COMMENT '主营一级类目', 
`cate_level1_name` varchar(300) NULL COMMENT '一级类目名称', 
`brand_id` bigint(20) NULL COMMENT '品牌ID', 
`brand_name` varchar(300) NULL COMMENT '品牌名称', 
`is_ka_brand` char(10) NULL COMMENT '是否KA品牌 Y/N', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家id', 
`seller_nick` varchar(300) NOT NULL COMMENT '卖家名称', 
`pay_ord_amt_3m_001` double NOT NULL COMMENT '最近3个月支付金额', 
`pay_ord_amt_rank_3m_001` bigint(20) NOT NULL COMMENT '最近3个月支付金额在一级类目下排名', 
`seller_star_id` bigint(20) NULL COMMENT '卖家星级ID', 
`seller_star_name` varchar(300) NULL COMMENT '卖家星级名称', 
`ovs_itm_cnt_std_001` bigint(20) NULL COMMENT '历史截至当日海外商品数', 
PRIMARY KEY (`id`), 
KEY `idx_stat_cate` (`stat_date`, `cate_level1_id`, `pay_ord_amt_rank_3m_001`), 
KEY `idx_stat_date_brand` (`stat_date`, `brand_id`, `pay_ord_amt_rank_3m_001`), 
KEY `idx_item_cnt` (`stat_date`, `ovs_itm_cnt_std_001`), 
KEY `idx_sellerid` (`seller_id`), 
KEY `idx_is_ka_brand` (`is_ka_brand`), 
KEY `idx_brand_gmt_create` (`brand_id`, `gmt_create`)
)  AUTO_INCREMENT = 1561781 CHARSET = utf8 COMMENT = '全球购KA卖家类目，品牌成交表';
CREATE TABLE if not exists global_ka_seller_history (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) NOT NULL COMMENT '商家ID', 
`seller_nick` varchar(200) NOT NULL COMMENT '商家昵称', 
`operate_type` tinyint(4) NOT NULL COMMENT '操作类型：0发送邀约；1确认签约；2发送降级；3删除签约', 
`reason`varchar(100)COMMENT '操作理由', 
`operator` varchar(200) NULL COMMENT '操作人，小二名称或者系统', 
PRIMARY KEY (`id`), 
KEY `idx_sellerid` (`seller_id`), 
KEY `idx_gmtcreate` (`gmt_create`), 
KEY `idx_operatetype` (`operate_type`)
)  AUTO_INCREMENT = 8810 CHARSET = utf8 COMMENT = 'KA商家历史信息表';
CREATE TABLE if not exists global_ka_seller_stat (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`qinfo` varchar(10) NOT NULL COMMENT '季度', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家id', 
`seller_nick` varchar(300) NOT NULL COMMENT '卖家名', 
`main_cate_id` bigint(20) NULL COMMENT '主类目id', 
`main_cate_name` varchar(300) NULL COMMENT '主类目名', 
`main_brand_id` bigint(20) NULL COMMENT '品牌id', 
`main_brand_name` varchar(300) NULL COMMENT '品牌名', 
`last_pay_ord_amt` double NULL COMMENT '上季度销量', 
`this_pay_ord_amt` double NULL COMMENT '本季度销量', 
`this_pay_ord_amt_all_shop` double NULL COMMENT '本季度全点销量', 
`gmt_accept_thisq` datetime NULL COMMENT '签约时间', 
`gmt_clear_thisq` datetime NULL COMMENT '清退时间', 
`last_pay_ord_amt_all_shop` double NULL COMMENT '上季度全店销量', 
PRIMARY KEY (`id`), 
KEY `gmt_create` (`gmt_create`), 
KEY `idx_qinfo` (`qinfo`), 
KEY `idx_sid` (`seller_id`), 
KEY `idx_snick` (`seller_nick`)
)  AUTO_INCREMENT = 368 CHARSET = utf8 COMMENT = '全球购ka季度统计';
CREATE TABLE if not exists global_limit_result (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '会员id', 
`gmt_forbid` datetime NOT NULL COMMENT '限制开始时间', 
`gmt_relieve` datetime NOT NULL COMMENT '限制结束时间,如果永久,直接写入一个非常大的值（譬如2999-01-01 00:00:00）', 
`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '0:生效 -1:删除', 
`operate_type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '操作类型 0-系统 1-小二执行', 
`operator` varchar(50) NULL COMMENT '操作人名称，如果是小二操作，记录最近一次操作的小二名称', 
`module_code` varchar(118) NOT NULL COMMENT '模型code, 抓取规则的code, 每个规则需唯一定义', 
`reason_memo` varchar(500) NULL COMMENT '原因备注(外部备注)', 
`biz_type` tinyint(4) NULL COMMENT '业务类型 1-直播活动业务', 
`biz_id` bigint(20) UNSIGNED NULL COMMENT '业务id ,  如果是直播活动引起的限制，则为直播活动id', 
`attributes` varchar(2000) NULL COMMENT '扩展字段key-value格式', 
`xiaoer_memo` varchar(500) NULL COMMENT '小二后台备注(内部备注)', 
`xiaoer_release_time` datetime NULL COMMENT '小二解禁时间', 
`user_nick` varchar(118) NULL COMMENT '会员昵称', 
`sub_type` tinyint(4) NULL COMMENT 'bizType对应的子类型', 
`rule_id` int(11) NULL COMMENT '规则Id', 
`show_reason` varchar(1024) NULL COMMENT '展示给卖家看的关小黑屋原因', 
`release_operator` varchar(118) NULL COMMENT '释放小黑屋的小二名称', 
PRIMARY KEY (`id`), 
KEY `idx_gmt` (`gmt_create`), 
KEY `biztype` (`user_id`, `biz_type`, `status`), 
KEY `bizscan` (`biz_type`, `rule_id`)
)  AUTO_INCREMENT = 192721 CHARSET = utf8 COMMENT = '全球购会员权限控制表';
CREATE TABLE if not exists global_live_event (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`malls_pict` varchar(500) NOT NULL COMMENT '商场图片', 
`gmt_effective` datetime NOT NULL COMMENT '活动生效时间', 
`gmt_deadline` datetime NOT NULL COMMENT '活动截止日期', 
`title` varchar(200) NOT NULL COMMENT '标题', 
`description` varchar(500) NOT NULL COMMENT '扫货说明', 
`malls_name` varchar(118) NOT NULL COMMENT '商场名称', 
`malls_lbs` varchar(200) NULL COMMENT '商场lbs定位', 
`audio` varchar(300) NULL COMMENT '音频', 
`vedio` varchar(300) NULL COMMENT '视频', 
`attributes` varchar(2000) NULL COMMENT '附加字段', 
`main_cat_id` bigint(20) UNSIGNED NULL COMMENT '主营类目id', 
`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '直播状态 0:初始化(已发布)  -1：已删除 -2:系统清退', 
`order_count` bigint(20) UNSIGNED NULL COMMENT '订单数', 
`view_count` bigint(20) UNSIGNED NULL COMMENT '浏览数', 
`item_count` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '商品数', 
`trade_money` bigint(20) UNSIGNED NULL COMMENT '交易金额（单位是分）', 
`theme` varchar(118) NULL COMMENT '特色字段（冗余）', 
`country` varchar(256) NULL COMMENT '国家', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '发布直播活动的卖家id', 
`brands` varchar(200) NULL COMMENT '品牌列表', 
`tranport_type` tinyint(4) DEFAULT '1' NOT NULL COMMENT '货品类型  1-直邮 2-中转 3-国内现货', 
`post_type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '包邮类型 1-包邮 0-无', 
`duty_type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '包税类型 1-包税 0-无', 
`sort_value` int(11) NULL COMMENT '直播综合排序值', 
PRIMARY KEY (`id`), 
KEY `idx_playing_query` (`gmt_effective`, `gmt_deadline`, `status`, `item_count`), 
KEY `idx_upcoming_query` (`status`, `gmt_effective`)
)  AUTO_INCREMENT = 24707 CHARSET = utf8 COMMENT = '全球购直播活动';
CREATE TABLE if not exists global_logo_illegal_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家ID', 
`seller_nick` varchar(1024) NULL COMMENT '卖家NICK', 
`item_id` bigint(20) NULL COMMENT '宝贝ID', 
`pict_url` varchar(512) NULL COMMENT '宝贝图片', 
`det_type` smallint(6) NULL COMMENT '类型 1表示 全球购+LOGO2 表示 全球购+金牌卖家 3 表示 全球购+认证商家', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 8192 CHARSET = utf8 COMMENT = '违规使用全球购logo信息表,主要是从odps回流数据';
CREATE TABLE if not exists global_logs (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`url` varchar(2000) NULL COMMENT '访问URL', 
`category` varchar(200) NULL COMMENT '类别', 
`info`varchar(100)COMMENT '描述', 
`os` varchar(400) NULL COMMENT '操作系统', 
`nickname` varchar(400) NULL COMMENT '用户名', 
`app_from` varchar(200) NULL COMMENT '来自于哪个应用', 
`ip` varchar(40) NULL COMMENT '调用ip', 
`attributes` varchar(4000) NULL COMMENT '扩展属性', 
`excutor` varchar(200) NULL COMMENT '执行者(比如小二nick)', 
`terminal_type` varchar(200) NULL COMMENT '具体的终端型号（如手机型号、PC浏览器等）', 
`feedback_type` varchar(32) NULL COMMENT '反馈类型', 
PRIMARY KEY (`id`), 
KEY `category` (`category`), 
KEY `appfromandcategory` (`app_from`, `category`)
)  AUTO_INCREMENT = 2593264 CHARSET = utf8 COMMENT = '用于保存用户反馈等信息';
CREATE TABLE if not exists global_msg_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`type` int(11) DEFAULT '0' COMMENT '0-订单消息', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`role_a_msg` int(11) DEFAULT '0' COMMENT '默认：买家消息数', 
`role_b_msg` int(11) DEFAULT '0' COMMENT '默认：卖家消息数', 
PRIMARY KEY (`id`), 
UNIQUE `useridindex` (`user_id`)
)  AUTO_INCREMENT = 335688 CHARSET = utf8 COMMENT = '全球购消息记录表';
CREATE TABLE if not exists global_nation_feed (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`nation_id` int(11) NOT NULL COMMENT '所属国家id', 
`nation_name` varchar(32) NULL COMMENT '所属国家名称', 
`banner_url` varchar(256) NULL COMMENT 'banner图片链接', 
`online_start` datetime NULL COMMENT '在线开始时间', 
`online_end` datetime NULL COMMENT '在线结束时间', 
`read_count` int(11) NOT NULL COMMENT '阅读人数', 
`article`varchar(100)COMMENT '富文本形式的内容', 
`title` varchar(256) NULL COMMENT '文章标题', 
`feed_type` varchar(32) NULL COMMENT 'Feed类型', 
`author_name` varchar(256) NULL COMMENT '买手名称', 
`author_avatar` varchar(256) NULL COMMENT '买手头像', 
`author_link` varchar(256) NULL COMMENT '买手跳转链接', 
`author_nation` varchar(32) NULL COMMENT '买手所在国家', 
`author_locate_name` varchar(32) NULL COMMENT '买手所在地区', 
`author_info` varchar(32) NULL COMMENT '买手认证信息', 
`author_from` varchar(32) NULL COMMENT '买手来源，例如“weibo”', 
`items` varchar(1024) NULL COMMENT '富文本中存在的商品id，JSONArray形式存储', 
`attribute` varchar(1024) NULL COMMENT '备注', 
`description` varchar(1024) NULL COMMENT '文章描述', 
`status` int(11) NULL COMMENT '上线状态', 
`admin_id` bigint(20) UNSIGNED NOT NULL COMMENT '操作小二id', 
`admin_nick` varchar(16) NOT NULL COMMENT '操作小二昵称', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 617 CHARSET = utf8 COMMENT = '国家馆Feed表';
CREATE TABLE if not exists global_nation_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
