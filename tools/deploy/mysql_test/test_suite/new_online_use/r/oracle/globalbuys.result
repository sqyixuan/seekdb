CREATE TABLE if not exists global_ovs_buyer_quit_record (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '表自增主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家ID', 
`seller_nick` varchar(200) NOT NULL COMMENT '卖家昵称', 
`is_prepay` tinyint(4) DEFAULT '0' COMMENT '是否参与消保', 
`seller_star_flag` tinyint(4) DEFAULT '0' COMMENT '是否满足卖家星级', 
`seller_star_name` varchar(20) NULL COMMENT '卖家星级名称', 
`seller_star_id` int(11) DEFAULT '0' COMMENT '卖家星级ID', 
`open_shop_long_flag` tinyint(4) DEFAULT '0' COMMENT '是否满足开店时长', 
`open_shop_long` bigint(20) DEFAULT '0' COMMENT '开店时长，天数', 
`dsr_service_flag` tinyint(4) DEFAULT '0' COMMENT '是否符合DSR服务评分', 
`dsr_service` double DEFAULT '0' COMMENT 'DSR服务评分', 
`dsr_merchandise_flag` tinyint(4) DEFAULT '0' COMMENT '是否符合DSR货物质量评分', 
`dsr_merchandise` double DEFAULT '0' COMMENT 'DSR货物质量评分', 
`dsr_consignment_flag` tinyint(4) DEFAULT '0' COMMENT '是否符合DSR卖家发货评分', 
`dsr_consignment` double DEFAULT '0' COMMENT 'DSR卖家发货评分', 
`year_b_point_flag` tinyint(4) DEFAULT '0' COMMENT '是否符合B类扣分要求', 
`year_b_point` double DEFAULT '0' COMMENT 'B类扣分', 
`year_a_point_flag` tinyint(4) DEFAULT '0' COMMENT '是否符合A类扣分要求', 
`year_a_point` double DEFAULT '0' COMMENT 'A类扣分', 
`year_c_point_flag` tinyint(4) DEFAULT '0' COMMENT '是否符合C扣分要求', 
`year_c_point` double DEFAULT '0' COMMENT 'C类扣分', 
`fee30_per_uv_flag` tinyint(4) DEFAULT '0' COMMENT '是否符合近30天支付客单价', 
`fee30_per_uv` double DEFAULT '0' COMMENT '近30天支付客单价', 
`auc_n_flag` tinyint(4) DEFAULT '0' COMMENT '是否符合在店铺商品数', 
`auc_n` bigint(20) DEFAULT '0' COMMENT '在线店铺商品数', 
`virtual_rate_flag` tinyint(4) DEFAULT '0' COMMENT '是否符合虚拟信用比例', 
`virtual_rate` double DEFAULT '0' COMMENT '虚拟信用比例', 
`avg30_issue_refund_ratio_flag` tinyint(4) DEFAULT '0' COMMENT '是否符合近30天售中售后纠纷退款率', 
`avg30_issue_refund_ratio` double DEFAULT '0' COMMENT '近30天售中售后纠纷退款率', 
`ali30_uv_flag` tinyint(4) DEFAULT '0' COMMENT '是否符合近30天支付人数', 
`ali30_uv` bigint(20) DEFAULT '0' COMMENT '近30天支付人数', 
`combine3_flag` tinyint(4) DEFAULT '0' COMMENT '是否符合买家喜好度', 
`c_cnt_old` int(11) DEFAULT '0' COMMENT '历年(近两年)c0类违规次数', 
`auc_ovs_r_p` double DEFAULT '0' COMMENT '海外商品数占比', 
`overseas_r_p` double DEFAULT '0' COMMENT '海外商品成交占比', 
`is_high_danger` tinyint(4) DEFAULT '0' COMMENT '是否高危卖家', 
`data_source` tinyint(4) NOT NULL COMMENT '数据来源', 
`quit_reason` varchar(2048) NULL COMMENT '清退理由', 
`is_ovs_buyer` tinyint(4) DEFAULT '0' COMMENT '是否人在海外', 
`approve_status` tinyint(4) DEFAULT '0' COMMENT '店铺状态', 
PRIMARY KEY (`id`), 
KEY `gmt_create` (`gmt_create`, `data_source`), 
KEY `data_source` (`data_source`, `gmt_create`), 
KEY `data_source_2` (`data_source`, `gmt_create`)
)  CHARSET = utf8 COMMENT = '海外买手基础资质日志回流';
