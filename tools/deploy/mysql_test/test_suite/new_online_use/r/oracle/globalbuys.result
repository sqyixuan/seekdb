CREATE TABLE if not exists global_seller_basic (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '卖家id', 
`user_nick` varchar(200) NULL COMMENT '卖家昵称', 
`shop_id` bigint(20) UNSIGNED NULL COMMENT '店铺id', 
`shop_name` varchar(200) NULL COMMENT '店铺名称', 
`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '状态 0:正常 -1:清退', 
`gmt_settle` datetime NULL COMMENT '入住时间', 
`shop_type` tinyint(4) NULL COMMENT '卖家类型 1-集市 2-天猫', 
`seller_type` bigint(20) UNSIGNED NULL COMMENT '全球购卖家类型 1-商户 2-买手', 
`attributes` varchar(2000) NULL COMMENT 'json格式附加字段', 
`is_risk` tinyint(4) NULL COMMENT '是否是高危卖家0-否 1-是', 
`gmt_clear` datetime NULL COMMENT '最后一次清退时间', 
PRIMARY KEY (`id`), 
KEY `index_userid` (`user_id`), 
KEY `idx_us` (`user_id`)
)  AUTO_INCREMENT = 120624 CHARSET = utf8 COMMENT = '全球购卖家基础表';
CREATE TABLE if not exists global_seller_enterorreject (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家id', 
`seller_nick` varchar(200) NOT NULL COMMENT '卖家nick', 
`shop_name` varchar(400) NULL COMMENT '店铺名', 
`shop_rate` int(11) NULL COMMENT '卖家当天星级', 
`type` int(11) NOT NULL COMMENT '0表示入驻，1表示清退', 
`reason`varchar(100)COMMENT '操作原因，如清退理由', 
`mark`varchar(100)COMMENT '备注', 
`odps_import_time` varchar(40) NULL COMMENT 'odps导入的时间，只有日期YYYY-MM-DD', 
`attributes` varchar(2000) NULL COMMENT '扩展信息', 
`app_type` int(11) DEFAULT '1' NOT NULL COMMENT '业务类型：1代表全球购；2代表洋桃', 
PRIMARY KEY (`id`), 
KEY `pkdateandtype` (`odps_import_time`, `app_type`, `type`)
)  AUTO_INCREMENT = 20141026204001 CHARSET = utf8 COMMENT = '全球购招商准入和清退对应的卖家表';
CREATE TABLE if not exists global_seller_frm_libra (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) NULL COMMENT '卖家ID', 
`seller_nick` varchar(1024) NULL COMMENT '卖家昵称', 
`is_prepay` tinyint(4) NULL COMMENT '是否消保', 
`seller_star_name` varchar(20) NULL COMMENT '星级名称', 
`seller_star_name_flag` tinyint(4) NULL COMMENT '是否满足星级', 
`open_shop_long` bigint(20) NULL COMMENT '开店时长', 
`open_shop_long_flag` tinyint(4) NULL COMMENT '是否满足开店时长', 
`dsr_service` double NULL COMMENT 'DSR服务', 
`dsr_service_flag` tinyint(4) NULL COMMENT '是否满足DSR服务', 
`dsr_merchandise` double NULL COMMENT '商品描述', 
`dsr_merchandise_flag` tinyint(4) NULL COMMENT '是否符合商品描述', 
`year_b_point` double NULL COMMENT 'B类扣分', 
`year_b_point_flag` tinyint(4) NULL COMMENT '是否符合B类违规', 
`year_a_point` double NULL COMMENT 'A类扣分', 
`year_a_point_flag` tinyint(4) NULL COMMENT '是否符合A类违规', 
`fee30_per_uv` double NULL COMMENT '近30天平均客单价', 
`fee30_per_uv_flag` tinyint(4) NULL COMMENT '是否满足近30天平均客单价', 
`auc_n` bigint(20) NULL COMMENT '在线商品数', 
`auc_n_flag` tinyint(4) NULL COMMENT '是否满足在线商品数', 
`virtual_rate` double NULL COMMENT '虚拟信用占比', 
`virtual_rate_flag` tinyint(4) NULL COMMENT '是否满足虚拟信用占比', 
`avg30_issue_refund_ratio` double NULL COMMENT '近30天退款纠纷率', 
`avg30_issue_refund_ratio_flag` tinyint(4) NULL COMMENT '是否满足近30天退款纠纷率', 
`ali30_uv` bigint(20) NULL COMMENT '近30天购买人数', 
`ali30_uv_flag` tinyint(4) NULL COMMENT '是否符合近30天购买人数', 
`combine3` tinyint(4) NULL COMMENT '是否符合卖家喜好度', 
`is_high_danger` tinyint(4) NULL COMMENT '是否高危', 
`approve_status` bigint(20) UNSIGNED NULL COMMENT '店铺状态', 
PRIMARY KEY (`id`), 
KEY `sellerid` (`seller_id`, `gmt_create`)
)  CHARSET = utf8 COMMENT = '从全球购打标回流的卖家';
CREATE TABLE if not exists global_seller_hisperf_datax (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家id', 
`seller_nick` varchar(128) NOT NULL COMMENT '卖家昵称', 
`rate_sum` int(11) NULL COMMENT '平均分值', 
`seller_star_id` int(11) NULL COMMENT '卖家星级id', 
`shop_starts_time` datetime NULL COMMENT '开店时间', 
`gmt_settled_time` datetime NULL COMMENT '洋桃入住时间', 
`follows_num` int(11) NULL COMMENT '粉丝数', 
`item_count_total` int(11) NULL COMMENT '商品总数', 
`item_count_online` int(11) NULL COMMENT '在线商品数', 
`alipay_fee_sevenday` double NULL COMMENT '7天支付金额', 
`alipay_count_sevenday` int(11) NULL COMMENT '7天支付订单数', 
`alipay_uv_sevenday` int(11) NULL COMMENT '7天支付uv', 
`live_total` int(11) NULL COMMENT '总直播数(所有历史直播)', 
`live_effect_count` int(11) NULL COMMENT '有效直播数(所有历史直播)', 
`live_effect_rate` double NULL COMMENT '有效直播率', 
`live_total_month` int(11) NULL COMMENT '近一个月直播总数', 
`live_effect_count_month` int(11) NULL COMMENT '近一个月有效直播数', 
`live_effect_rate_month` double NULL COMMENT '近一个月直播有效率', 
`live_uv_month` int(11) NULL COMMENT '月直播uv总和', 
`avg_live_uv_month` int(11) NULL COMMENT '月平均直播uv', 
`live_fee_month` double NULL COMMENT '月直播支付金额总和', 
`avg_live_fee_month` double NULL COMMENT '月平均直播支付金额', 
`live_alicount_month` int(11) NULL COMMENT '月直播支付订单总数', 
`avg_live_alicount_month` int(11) NULL COMMENT '月平均直播支付订单数', 
`live_aliuv_month` int(11) NULL COMMENT '月直播总支付uv', 
`avg_live_aliuv_month` int(11) NULL COMMENT '月平均直播支付uv', 
`live_comment_month` int(11) NULL COMMENT '月直播留言总数', 
`avg_live_comment_month` int(11) NULL COMMENT '月直播平均留言数', 
`live_itemlike_month` int(11) NULL COMMENT '月直播商品喜欢数', 
`avg_live_itemlike_month` int(11) NULL COMMENT '月直播平均商品喜欢数', 
`gmt_odps` datetime NULL COMMENT '云梯2任务运行时间', 
`allnet_funs` int(11) NULL COMMENT '全网粉丝数', 
`main_category_id` bigint(20) NULL COMMENT '主营类目id', 
`main_cat_items_count` int(11) NULL COMMENT '主营类目下的商品数目(非历史库-在线or下架)', 
`last_pub_item_id` bigint(20) NULL COMMENT '最近发布商品的商品id', 
`last_item_pub_time` datetime NULL COMMENT '商品最近发布时间', 
`first_pub_item_id` bigint(20) NULL COMMENT '首次发布商品id', 
`first_item_pub_time` datetime NULL COMMENT '首次商品发布时间', 
PRIMARY KEY (`id`), 
UNIQUE `unq_seller_id` (`seller_id`)
)  AUTO_INCREMENT = 16384 CHARSET = utf8 COMMENT = '洋桃卖家历史表现datax数据回流表';
CREATE TABLE if not exists global_seller_protect_rule (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`qualify_key` varchar(118) NOT NULL COMMENT '资质索引，程序所用', 
`qualify_value` varchar(118) NOT NULL COMMENT '资质的值', 
`qualify_memo` varchar(250) NULL COMMENT '资质说明', 
`global_seller_type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '全球购卖家类型：高级卖家1，优质卖家2，海外买手3', 
`operator` varchar(250) NULL COMMENT '操作人', 
`deleted` tinyint(4) NULL COMMENT '是否删除', 
`protect_day` int(11) NULL COMMENT '保护天数', 
PRIMARY KEY (`id`), 
UNIQUE `seller_qualify_uniq` (`qualify_key`, `global_seller_type`)
)  AUTO_INCREMENT = 47 CHARSET = utf8 COMMENT = '全球购卖家白名单保护配置';
CREATE TABLE if not exists global_seller_tag_operator (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家ID', 
`seller_nick` varchar(200) NULL COMMENT '卖家昵称', 
`biz_type` tinyint(4) DEFAULT '1' NOT NULL COMMENT '业务类型，1表示打标，2表示去标', 
`operator` varchar(200) NULL COMMENT '操作人', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 9125 CHARSET = utf8 COMMENT = '全球购卖家标人工运营表';
CREATE TABLE if not exists global_special (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增id', 
`brand_id` bigint(20) NULL COMMENT '品牌id', 
`brand_name_cn` varchar(64) NULL COMMENT '品牌中文名', 
`brand_name_en` varchar(64) NULL COMMENT '品牌英文名', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`operator_id` int(11) NULL COMMENT '运营工号', 
`operator_nick` varchar(32) NULL COMMENT '操作者旺旺昵称', 
`title` varchar(256) NULL COMMENT '标题', 
`picture_url` varchar(256) NULL COMMENT '图片链接', 
`introduce`varchar(100)COMMENT '专题介绍', 
`url` varchar(256) NULL COMMENT '专题链接', 
`remark` varchar(256) NULL COMMENT '备注', 
`feature` varchar(1024) NULL COMMENT '扩展字段，JSON格式', 
`status` int(11) NULL COMMENT '是否删除0：未删除 1：已删除', 
PRIMARY KEY (`id`), 
KEY `idx_brand_id` (`brand_id`), 
KEY `idx_id_bid_del` (`id`, `brand_id`, `status`)
)  AUTO_INCREMENT = 3 CHARSET = utf8 COMMENT = '全球购专题表';
CREATE TABLE if not exists global_sys_log (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`business_type` int(11) NOT NULL COMMENT '业务类型。例如：商品发布、直播发布分别为一业务类型， 1,2,4,6,7,8,11,56,68,89,435,4523-200预留商品发布枚举，逐步叠加，小于1,2,4,6,7,8,11,56,68,89,435,4523预留系统业务', 
`action` int(11) NOT NULL COMMENT '操作。例如：商品传图、获取LBS等各种动作', 
`result` int(11) NOT NULL COMMENT '操作结果。3个枚举： 0成功、1失败、2取消操作', 
`sub_result`varchar(100)COMMENT '操作结果子集。如：失败可能性的文本，由调用方自定义枚举描述写入', 
`act_start_time` bigint(20) NULL COMMENT '操作开始时间。时间戳', 
`act_end_time` bigint(20) NULL COMMENT '操作结束时间。时间戳', 
`action_from` int(11) NOT NULL COMMENT '调用来源。如：1,taobao-h5-android、2,app-android、3,app-ios、4,pc、5,taobao-h5-ios', 
`terminal_type` varchar(100) NULL COMMENT '终端类型。如：具体的终端型号（如手机型号、PC浏览器等）', 
`os` varchar(50) NULL COMMENT '操作系统。如：IOS 7.X 等', 
`ip` varchar(50) NULL COMMENT 'ip', 
`curr_user_id` bigint(20) NULL COMMENT '当前操作用户id', 
`curr_user_nick` varchar(30) NULL COMMENT '当前操作用户nick', 
`attributes` varchar(2000) NULL COMMENT '扩展信息。Key:Value英文逗号分隔', 
`refer_url` varchar(500) NULL COMMENT 'refer', 
`device_id` varchar(50) NULL COMMENT '设备id', 
`cost_time` bigint(20) NULL COMMENT '耗时', 
`network_type` int(11) NULL COMMENT '网络类型。1,wifi、2.3g、3.其它', 
`version` varchar(118) NULL COMMENT '版本号。H5时为手淘版本号，APP时为APP版本号。', 
PRIMARY KEY (`id`), 
KEY `businesstype_action_prk` (`business_type`, `action`, `action_from`), 
KEY `gmtcreate_pk` (`gmt_create`)
)  AUTO_INCREMENT = 7379185 CHARSET = utf8 COMMENT = '全球购系统日志信息';
CREATE TABLE if not exists global_user_extra (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) NOT NULL COMMENT '用户ID', 
`country` varchar(256) NOT NULL COMMENT '用户所在国家', 
`story` varchar(100) NULL COMMENT '用户故事', 
`item_total` bigint(20) NOT NULL COMMENT '在线商品数', 
`sold_total` bigint(20) NOT NULL COMMENT '售出总数', 
`user_img_url` varchar(256) NULL COMMENT '用户图片', 
`attribute` varchar(100) NULL COMMENT '属性', 
`gmt_settled_time` datetime NULL COMMENT '入驻时间', 
`nick` varchar(64) NULL COMMENT '用户昵称', 
`status` tinyint(4) DEFAULT '0' COMMENT '用户状态：0 正常 -1 清退', 
`coordinate` varchar(256) NULL COMMENT '用户经纬度坐标', 
`lbs` varchar(256) NULL COMMENT '用户定位位置', 
`ip` varchar(64) NULL COMMENT '用户最近一次IP', 
`ip_country` varchar(64) NULL COMMENT '通过IP定位的国家名', 
`lbs_country` varchar(64) NULL COMMENT '通过手淘定位的国家名', 
PRIMARY KEY (`id`), 
UNIQUE `userid` (`user_id`), 
KEY `status` (`status`)
)  AUTO_INCREMENT = 9979 CHARSET = utf8 COMMENT = '商品代购用户表';
CREATE TABLE if not exists import_brand (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NULL COMMENT '写入时间', 
`brand_info` varchar(2000) NULL COMMENT '品牌信息', 
`country` varchar(45) NULL COMMENT '国家', 
`gmt_update` datetime NULL COMMENT '更新时间', 
`crawl_status` tinyint(4) NULL COMMENT '抓取状态', 
`gmt_effective` datetime NULL COMMENT '生效时间', 
PRIMARY KEY (`id`), 
KEY `gmt_create_index_ib` (`gmt_create`), 
KEY `effective_idx_ib` (`gmt_effective`)
)  AUTO_INCREMENT = 405 CHARSET = utf8 COMMENT = '全球购精品库-品牌库';
CREATE TABLE if not exists import_item (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT 'id', 
`item_id` varchar(118) NULL COMMENT '商品id', 
`title` varchar(500) NULL COMMENT '商品标题', 
`brand_id` varchar(118) NULL COMMENT '品牌id', 
`brand_name` varchar(118) NULL COMMENT '品牌名', 
`cate_level1_name` varchar(118) NULL COMMENT '1级类目名', 
`cate_level1_id` bigint(20) NULL COMMENT '1级类目id', 
`cate_level2_name` varchar(118) NULL COMMENT '2级类目名', 
`cate_level2_id` bigint(20) NULL COMMENT '2级类目id', 
`gmt_create` datetime NULL COMMENT '创建时间', 
`gmt_modified` datetime NULL COMMENT '修改时间', 
`sales_30` bigint(20) NULL COMMENT '30天销量', 
`country` varchar(50) NULL COMMENT '国家', 
`item_type` varchar(50) NULL COMMENT '类型', 
`check_status` tinyint(4) NULL COMMENT '确认状态', 
`online_status` tinyint(4) NULL COMMENT '在线状态', 
`ops_status` tinyint(4) NULL COMMENT '操作状态', 
`img_url` varchar(500) NULL COMMENT '图片地址', 
`crawl_keyword` varchar(118) NULL COMMENT '抓取关键字', 
`img_upload_cdn_url` varchar(500) NULL COMMENT '上传图片地址', 
`crawl_status` tinyint(4) NULL COMMENT '抓取状态', 
`gmt_effective` datetime NULL COMMENT '生效时间', 
PRIMARY KEY (`id`), 
KEY `item_id_idx_ii` (`item_id`), 
KEY `brand_id_idx_ii` (`brand_id`), 
KEY `cat2_idx_ii` (`cate_level2_id`), 
KEY `crt_time_idx_ii` (`gmt_create`), 
KEY `brand_name_idx_ii` (`brand_name`), 
KEY `country_idx_ii` (`country`), 
KEY `cate1_cate2_idx_ii` (`cate_level1_id`, `cate_level2_id`, `cate_level2_name`), 
KEY `effective_idx_ii` (`gmt_effective`)
)  AUTO_INCREMENT = 2028 CHARSET = utf8 COMMENT = '全球购精品库-商品库';
CREATE TABLE if not exists nav (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`deleted` tinyint(4) DEFAULT '1' NOT NULL COMMENT '1：未删除，2：已删除', 
`name` varchar(118) NOT NULL COMMENT '导航名', 
`link` varchar(500) NULL COMMENT '导航链接', 
`icon` varchar(500) NULL COMMENT '导航图标', 
`sup_id` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '0：顶层导航', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 496 CHARSET = utf8 COMMENT = '全球购PC页导航数据';
CREATE TABLE if not exists odps_general_report_data (
`attributes` varchar(2000) NULL COMMENT '冗余字段', 
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`ds` varchar(32) NOT NULL COMMENT '业务分区时间', 
`table_name` varchar(118) NOT NULL COMMENT '表名', 
`data` varchar(3000) NULL COMMENT 'json格式数据', 
`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '状态', 
PRIMARY KEY (`id`), 
KEY `unq_ds_table_name` (`table_name`, `ds`)
)  CHARSET = utf8 COMMENT = 'odps普通报表数据';
CREATE TABLE if not exists odps_genneral_report_config (
`project_name` varchar(40) NOT NULL COMMENT 'odps工程name', 
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`table_name` varchar(118) NULL COMMENT '表名', 
`fetch_time` varchar(128) NULL COMMENT 'cron表达式，如果没有，则默认每天16点更新', 
`ds_pattern` bigint(20) UNSIGNED NULL COMMENT '分区格式，譬如 pt=yyyyMMddHHmmss', 
`report_name` varchar(256) NULL COMMENT '报表中文名', 
`fields_reflect` varchar(3000) NULL COMMENT '字段映射 json格式', 
`attributes` varchar(2000) NULL COMMENT '附属字段', 
`status` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '0:生效 -1:清楚', 
PRIMARY KEY (`id`), 
KEY `idx_project_table` (`project_name`, `table_name`)
)  CHARSET = utf8 COMMENT = 'odps普通报表配置';
CREATE TABLE if not exists operate_flow (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`operate_time` datetime NOT NULL COMMENT '执行时间', 
`app_type` int(11) DEFAULT '0' NOT NULL COMMENT '业务类型数字标示（如：洋桃买手入驻或清退，全球购买手入驻，全球购买手清退，小二执行某某动作，请自行遵循约定的数字对应规范）', 
`app_type_desc` varchar(200) NOT NULL COMMENT '业务类型文案描述', 
`app_operate_type` int(11) DEFAULT '0' NOT NULL COMMENT '操作动作标示（如入驻或清退，请自行遵循约定的数字对应规范）', 
`app_operate_type_desc` varchar(200) NOT NULL COMMENT '操作动作文案描述', 
`source_type` int(11) DEFAULT '0' NOT NULL COMMENT '操作主体类型标示', 
`source_type_desc` varchar(200) NOT NULL COMMENT '操作主体类型文案描述', 
`source_id` bigint(20) NOT NULL COMMENT '操作者用户id(小二工号 或 淘宝账号id 或其它)', 
`source_desc` varchar(200) NOT NULL COMMENT '操作者用户nick(小二花名 或 淘宝账号nick 或其它)', 
`target_type` int(11) DEFAULT '0' NOT NULL COMMENT '被操作主体类型标示', 
`target_type_desc` varchar(200) NOT NULL COMMENT '被操作主体类型文案描述', 
`target_id` bigint(20) NOT NULL COMMENT '被操作者id(小二工号 或 淘宝账号id 或其它)', 
`target_desc` varchar(200) NOT NULL COMMENT '被操作者描述(小二花名 或 淘宝账号nick 或其它)', 
`operate_reason`varchar(100)COMMENT '操作触发原因（标准原因，如：不符合某某资质）', 
`operate_mark`varchar(100)COMMENT '备注（存储信息诸如人工记录：该卖家反复违规等）', 
`attributes` varchar(2000) NULL COMMENT '扩展属性', 
PRIMARY KEY (`id`), 
KEY `apptypeandtargetid` (`app_type`, `target_id`), 
KEY `apptypeandoperatetime` (`app_type`, `operate_time`)
)  AUTO_INCREMENT = 3375579 CHARSET = utf8 COMMENT = '全球购通用流水记录表';
CREATE TABLE if not exists seller_quit_record (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家Id', 
`seller_nick` varchar(200) NOT NULL COMMENT '卖家昵称', 
`target_detail` varchar(2048) NULL COMMENT '打标详情json格式', 
`is_self_quit` tinyint(4) NULL COMMENT '是否是自主清退', 
`is_prepay` tinyint(4) NULL COMMENT '是否参加消保', 
`seller_star_name` tinyint(4) NULL COMMENT '是否符合卖家星级', 
`open_shop_long` tinyint(4) NULL COMMENT '是否符合开店时长', 
`dsr_service` tinyint(4) NULL COMMENT 'dsr_service', 
`dsr_merchandise` tinyint(4) NULL COMMENT '是否符合DSR货物质量评分', 
`dsr_consignment` tinyint(4) NULL COMMENT '是否符合DSR卖家发货评分', 
`year_b_point` tinyint(4) NULL COMMENT '是否符合B类扣分', 
`year_a_point` tinyint(4) NULL COMMENT '是否符合A类扣分', 
`fee30_per_uv` tinyint(4) NULL COMMENT '是否符合近30天支付客单价', 
`auc_n` tinyint(4) NULL COMMENT '是否符合店铺商品数', 
`virtual_rate` tinyint(4) NULL COMMENT '是否符合虚拟信用比例', 
`avg30_issue_refund_ratio` tinyint(4) NULL COMMENT '是否符合近30天售中售后纠纷退款率', 
`ali30_uv` tinyint(4) NULL COMMENT '是否符合近30天支付人数', 
`combine3` tinyint(4) NULL COMMENT '是否满足三合一字段', 
`is_high_danger` tinyint(4) NULL COMMENT '是否是高危卖家', 
`data_source` int(11) NOT NULL COMMENT '数据来源', 
`quit_reason` varchar(2048) NULL COMMENT '数据源清退原因', 
`is_quit` tinyint(4) NULL COMMENT '是否被执行清退', 
`quit_target` varchar(200) NULL COMMENT '执行清退原因', 
`approve_status` tinyint(4) NULL COMMENT '店铺状态', 
`year_c_point` tinyint(4) NULL COMMENT '自然年是否有C0违规，0表示没有，1表示有', 
`dsr_service_value` double NULL COMMENT 'dsr_service值', 
`dsr_consignment_value` double NULL COMMENT 'dsr_consignment 值', 
`dsr_merchandise_value` double NULL COMMENT 'dsr_merchandise 值', 
`year_b_point_value` double NULL COMMENT 'year_b_point值', 
`open_shop_long_value` bigint(20) NULL COMMENT 'open_shop_long值', 
`virtual_rate_value` double NULL COMMENT 'virtual_rate值', 
`ali30_uv_value` bigint(20) NULL COMMENT 'ali30_uv值', 
`seller_star_id_value` int(11) NULL COMMENT 'seller_star_id值', 
`seller_star_name_value` varchar(20) NULL COMMENT 'seller_star_name值', 
`fee30_per_uv_value` double NULL COMMENT 'fee30_per_uv值', 
`auc_n_value` bigint(20) NULL COMMENT 'auc_n值', 
`avg30_issue_refund_ratio_value` double NULL COMMENT 'avg30_issue_refund_ratio值', 
`year_a_point_value` double NULL COMMENT 'year_a_point值', 
`c_cnt_old` int(11) DEFAULT '0' COMMENT '历史C类违规次数', 
`auc_ovs_r_p` double DEFAULT '0' COMMENT '海外商品数占比', 
`overseas_r_p` double NULL COMMENT '海外商品成交占比', 
PRIMARY KEY (`id`), 
KEY `seller_id` (`seller_id`, `data_source`, `gmt_create`)
)  AUTO_INCREMENT = 3333616 CHARSET = utf8 COMMENT = '卖家清退记录';
CREATE TABLE if not exists seller_quit_result (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`is_quit` tinyint(4) NOT NULL COMMENT '是否已清退', 
