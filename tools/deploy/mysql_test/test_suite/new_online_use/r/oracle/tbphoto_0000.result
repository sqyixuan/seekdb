drop table if exists sequence;
CREATE TABLE if not exists accounts (
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '主键字段 ', 
`login_id` varchar(45) NOT NULL, 
`last_login_time` bigint(20) UNSIGNED NULL, 
`last_modified_time` bigint(20) UNSIGNED NULL, 
`create_time` bigint(20) UNSIGNED NULL, 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`user_id`), 
KEY `idx_loginid` (`login_id`), 
KEY `idx_gmt_create` (`gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists album_ids (
`id` binary(16) NULL, 
`aid` bigint(20) NULL, 
`pt` tinyint(4) NULL, 
KEY `album_id_index_id` (`id`), 
KEY `album_id_index_aid` (`aid`)
)  CHARSET = utf8;
CREATE TABLE if not exists album_photo (
`aid` bigint(20) UNSIGNED NOT NULL COMMENT '主键字段', 
`pid` bigint(20) UNSIGNED NOT NULL COMMENT '主键字段', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`sid` bigint(20) UNSIGNED NOT NULL COMMENT 'sequence id', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`aid`, `pid`), 
KEY `idx_album_photo_user_id` (`user_id`), 
KEY `idx_gmt_create` (`gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists album_transfer (
`tb_album_id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
`source_album_id` bigint(20) UNSIGNED NOT NULL COMMENT '来源处的相册id', 
`source_type` int(11) DEFAULT '0' COMMENT '相册来源。0则表示来源于sns相册 ', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
PRIMARY KEY (`tb_album_id`), 
KEY `idx_user_id` (`user_id`), 
KEY `idx_gmt_create` (`gmt_create`), 
KEY `idx_source_type` (`source_type`), 
KEY `idx_source_album_id` (`source_album_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists albums (
`aid` bigint(20) UNSIGNED NOT NULL COMMENT '主键字段', 
`id` binary(16) NULL, 
`name` varchar(255) NULL, 
`photo_count` int(10) UNSIGNED DEFAULT '0', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`preface_photo` binary(16) NULL, 
`preface_photo_id` bigint(20) UNSIGNED DEFAULT '0', 
`source_type` int(11) DEFAULT '0', 
`album_size` bigint(20) UNSIGNED DEFAULT '0', 
`safety_level` tinyint(4) DEFAULT '0', 
`description` varchar(255) NULL, 
`viewtype` tinyint(4) DEFAULT '1' NOT NULL COMMENT '之前类型为bit(1)，值为b''1', 
`tag` varchar(500) NULL, 
`hit_count` int(10) UNSIGNED DEFAULT '1', 
`photo_comment_count` int(10) UNSIGNED DEFAULT '0', 
`fav_count` int(10) UNSIGNED DEFAULT '0', 
`last_modified_time` bigint(20) UNSIGNED NOT NULL, 
`create_time` bigint(20) UNSIGNED NULL, 
`attributes` varchar(500) NULL COMMENT '备用字段', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录修改时间', 
PRIMARY KEY (`aid`), 
KEY `idx_albums_owner_lmt_ind` (`user_id`, `last_modified_time`), 
KEY `idx_album_id` (`id`), 
KEY `idx_album_preface_photo_id` (`preface_photo_id`), 
KEY `idx_gmt_create` (`gmt_create`), 
KEY `idx_user_id` (`user_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists channel_catalog (
`channel_name` varchar(45) NOT NULL COMMENT '主键字段', 
`catalog_name` varchar(45) NOT NULL COMMENT '主键字段', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`id` bigint(20) UNSIGNED NULL COMMENT '以后设置为自增id', 
PRIMARY KEY (`channel_name`, `catalog_name`), 
KEY `idx_gmt_create` (`gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists channel_catalog_album (
`aid` bigint(20) UNSIGNED NOT NULL COMMENT '联合主键', 
`channel_name` varchar(45) NOT NULL COMMENT '联合主键', 
`catalog_name` varchar(45) NOT NULL COMMENT '联合主键', 
`last_modified` bigint(20) UNSIGNED DEFAULT '0' NOT NULL, 
`status` tinyint(3) UNSIGNED DEFAULT '0' NOT NULL, 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`sid` bigint(20) UNSIGNED NOT NULL COMMENT 'sequence id', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`channel_name`, `aid`, `catalog_name`), 
KEY `idx_channel_album_user_id` (`user_id`), 
KEY `idx_gmt_create` (`gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists channel_catalog_tag (
`channel_name` varchar(45) NOT NULL COMMENT '主键字段', 
`catalog_name` varchar(45) NOT NULL COMMENT '主键字段', 
`name` varchar(45) NOT NULL COMMENT '主键字段', 
`create_time` bigint(20) UNSIGNED NOT NULL, 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
`id` bigint(20) UNSIGNED NULL COMMENT '以后设置为自增id', 
PRIMARY KEY (`channel_name`, `catalog_name`, `name`), 
KEY `idx_gmt_create` (`gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists m_topics (
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`pid` bigint(20) UNSIGNED NOT NULL COMMENT '照片ID', 
`aid` bigint(20) UNSIGNED NOT NULL COMMENT '相册ID', 
`audio_id` bigint(20) UNSIGNED NULL COMMENT '音频ID', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
`description` varchar(500) NULL COMMENT '照片附加描述', 
`original_path` varchar(255) NOT NULL COMMENT '图片路径', 
`audio_path` varchar(255) NULL COMMENT '音频路径', 
`longitude` double NULL COMMENT '经度', 
`latitude` double NULL COMMENT '纬度', 
`geohash` varchar(45) NULL COMMENT 'geohash', 
`status` int(10) UNSIGNED NOT NULL COMMENT '状态', 
`attributes` varchar(100) NULL COMMENT 'attributes', 
`source_type` int(11) NOT NULL COMMENT 'source_type', 
PRIMARY KEY (`pid`), 
KEY `idx_mtopics_position` (`longitude`, `latitude`), 
KEY `idx_mtopics_user` (`user_id`), 
KEY `idx_mtopics_create` (`gmt_create`)
)  CHARSET = utf8 COMMENT = '图友广场';
CREATE TABLE if not exists maudios (
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`audio_id` bigint(20) UNSIGNED NOT NULL COMMENT '音频ID', 
`audio_path` varchar(255) NOT NULL COMMENT '音频路径', 
`attributes` varchar(100) NULL COMMENT '备用', 
`status` int(10) UNSIGNED DEFAULT '0' NOT NULL COMMENT 'status', 
`source_type` int(10) UNSIGNED NOT NULL COMMENT 'source type', 
PRIMARY KEY (`audio_id`), 
KEY `idx_maudios_user` (`user_id`, `source_type`, `status`, `gmt_create`), 
KEY `idx_maudios_create` (`gmt_create`)
)  CHARSET = utf8 COMMENT = '图友音频表';
CREATE TABLE if not exists mmessage (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`message_id` bigint(20) UNSIGNED NOT NULL COMMENT '消息ID', 
`type` smallint(5) UNSIGNED NOT NULL COMMENT '消息类型', 
`source_user_id` bigint(20) UNSIGNED NOT NULL COMMENT '源用户ID', 
`message` varchar(100) NULL COMMENT '消息内容', 
`attributes` varchar(100) NULL COMMENT '备用', 
`status` int(10) UNSIGNED NOT NULL COMMENT '状态', 
`source_type` int(10) UNSIGNED NOT NULL COMMENT 'sourceType', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '图友消息表';
CREATE TABLE if not exists photo_ids (
`id` binary(16) NULL, 
`pid` bigint(20) NULL, 
`pt` tinyint(4) NULL, 
KEY `photo_id_index_id` (`id`), 
KEY `photo_id_index_pid` (`pid`)
)  CHARSET = utf8;
CREATE TABLE if not exists photo_transfer (
`tb_photo_id` bigint(20) UNSIGNED NOT NULL COMMENT '淘相册照片id ', 
`source_photo_id` bigint(20) UNSIGNED NOT NULL COMMENT '来源处的照片id ', 
`source_type` int(11) DEFAULT '0' COMMENT '照片来源类型。0表示来源于淘江湖', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
PRIMARY KEY (`tb_photo_id`), 
KEY `idx_gmt_create` (`gmt_create`), 
KEY `idx_user_id` (`user_id`), 
KEY `idx_source_type` (`source_type`), 
KEY `idx_source_photo_id` (`source_photo_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists photos (
`pid` bigint(20) UNSIGNED NOT NULL COMMENT '主键字段', 
`id` binary(16) NULL, 
`name` varchar(255) NULL, 
`last_modified_time` bigint(20) UNSIGNED NOT NULL, 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`comments` varchar(4000) NULL, 
`tag` varchar(4000) NULL, 
`picture_type` varchar(45) NULL, 
`display_path` varchar(255) NULL, 
`original_path` varchar(255) NULL, 
`uploaded_time` bigint(20) UNSIGNED NULL, 
`thumbnail_path` varchar(255) NULL, 
`safety_level` tinyint(4) DEFAULT '0', 
`big_thumbnail_path` varchar(255) NULL, 
`poster_path` varchar(255) NULL, 
`fav_count` int(10) UNSIGNED DEFAULT '0', 
`comment_count` int(10) UNSIGNED DEFAULT '0', 
`hit_count` int(10) UNSIGNED DEFAULT '0', 
`attributes` varchar(100) NULL COMMENT '备用字段', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
`original_length` int(10) UNSIGNED NOT NULL, 
`biz_type` int(11) DEFAULT '0' COMMENT '0：淘相册照片、1：评价照片、2：淘单照片', 
PRIMARY KEY (`pid`), 
KEY `idx_user_id_last_modify` (`user_id`, `last_modified_time`), 
KEY `idx_id` (`id`), 
KEY `idx_gmt_create` (`gmt_create`), 
KEY `idx_user_id` (`user_id`)
)  CHARSET = utf8 COMMENT = 'photos';
CREATE TABLE if not exists sequence (
`name` varchar(118) NOT NULL COMMENT '主键', 
`idvalue` bigint(20) UNSIGNED NOT NULL, 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`name`)
)  CHARSET = utf8;
CREATE TABLE if not exists share_out_albums (
`aid` bigint(20) UNSIGNED NOT NULL COMMENT '联合主键', 
`to_owner` bigint(20) UNSIGNED NOT NULL COMMENT '联合主键', 
`from_owner` bigint(20) UNSIGNED NOT NULL COMMENT '联合主键，分表字段', 
`shared_date` bigint(20) UNSIGNED NULL, 
`sid` bigint(20) UNSIGNED NOT NULL COMMENT 'sequence id', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`from_owner`, `to_owner`, `aid`), 
KEY `idx_gmt_create` (`gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists shared_in_albums (
`from_owner` bigint(20) UNSIGNED NOT NULL COMMENT '联合主键', 
`to_owner` bigint(20) UNSIGNED NOT NULL COMMENT '联合主键，分表字段', 
`aid` bigint(20) UNSIGNED NOT NULL COMMENT '联合主键', 
`shared_date` bigint(20) UNSIGNED NOT NULL, 
`sid` bigint(20) UNSIGNED NOT NULL COMMENT 'sequence id', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`aid`, `from_owner`, `to_owner`), 
KEY `idx_gmt_create` (`gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists spaces_info (
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '主键，分表字段', 
`basesize` bigint(20) UNSIGNED DEFAULT '2048', 
`album_usedsize` bigint(20) UNSIGNED DEFAULT '0', 
`event_usedsize` bigint(20) UNSIGNED DEFAULT '0', 
`totalsize` bigint(20) UNSIGNED DEFAULT '2048', 
`lastmodified_time` bigint(20) UNSIGNED NULL, 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`user_id`), 
KEY `idx_gmt_create` (`gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists tag_album (
`aid` bigint(20) UNSIGNED NOT NULL COMMENT '联合主键', 
`channel_name` varchar(45) NOT NULL COMMENT '联合主键', 
`catalog_name` varchar(45) NOT NULL COMMENT '联合主键', 
`tag` varchar(45) NOT NULL COMMENT '联合主键', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`sid` bigint(20) UNSIGNED NOT NULL COMMENT 'sequence id', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`aid`, `channel_name`, `catalog_name`, `tag`), 
KEY `idx_gmt_create` (`gmt_create`), 
KEY `idx_user_id` (`user_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists taobao_6uu (
`owner_id` varchar(50) NOT NULL COMMENT '主键字段', 
`taobao_id` bigint(20) UNSIGNED NOT NULL, 
`taobao_nick` varchar(50) NOT NULL, 
`owner_nick` varchar(50) NOT NULL, 
`state` int(10) UNSIGNED DEFAULT '0' NOT NULL COMMENT '是否迁移（0：未迁移，1：已迁移）', 
`id` bigint(20) NULL, 
PRIMARY KEY (`owner_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists variable_space_info (
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '临时联合主键，分表字段', 
`start_time` bigint(20) UNSIGNED NOT NULL, 
`end_time` bigint(20) UNSIGNED NOT NULL, 
`channel` varchar(45) NOT NULL COMMENT '临时联合主键', 
`increase_size` bigint(20) UNSIGNED NOT NULL, 
`create_time` bigint(20) UNSIGNED NULL, 
`type` int(10) UNSIGNED NULL, 
`reason` varchar(255) NULL, 
`sid` bigint(20) UNSIGNED NOT NULL COMMENT 'sequence id', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
PRIMARY KEY (`user_id`, `channel`), 
KEY `idx_gmt_create` (`gmt_create`), 
KEY `idx_user_id` (`user_id`)
)  CHARSET = utf8;
