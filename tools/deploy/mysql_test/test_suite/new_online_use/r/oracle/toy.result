CREATE TABLE if not exists auth (
`id` varchar(255) NOT NULL, 
`mute` int(1) DEFAULT '0' NOT NULL, 
`deleted` int(1) DEFAULT '0', 
`gmtCreate` timestamp NULL, 
`gmtModified` timestamp NULL, 
PRIMARY KEY (`id`)
)  CHARSET = utf8;
CREATE TABLE if not exists designers (
`id` varchar(255) NOT NULL, 
`vip` int(1) NULL, 
`nickName` varchar(255) NULL, 
`avatar` varchar(255) NULL, 
`homeAddress` varchar(255) NULL, 
`gender` int(1) NULL, 
`occupation` varchar(255) NULL, 
`constellation` varchar(255) NULL, 
`introduction` varchar(255) NULL, 
`idNo` varchar(255) NULL, 
`cellPhone` varchar(255) NULL, 
`receiveAddress` varchar(255) NULL, 
`domain` varchar(255) NULL, 
`website` varchar(255) NULL, 
`weibo` varchar(255) NULL, 
`zhanku` varchar(255) NULL, 
`meikong` varchar(255) NULL, 
`shijueCn` varchar(255) NULL, 
`mail` varchar(255) NULL, 
`activeTime` timestamp DEFAULT CURRENT_TIMESTAMP NOT NULL, 
`hotOrder` int(8) DEFAULT '-1' NOT NULL, 
`deleted` int(1) DEFAULT '0', 
`gmtCreate` timestamp NULL, 
`gmtModified` timestamp NULL, 
`realName` varchar(50) NULL, 
`state` int(1) NULL, 
`sid` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '新的主键', 
PRIMARY KEY (`sid`), 
KEY `deleted_gmtcreate` (`deleted`, `gmtCreate`)
)  AUTO_INCREMENT = 62004 CHARSET = utf8 COMMENT = '新增主键sid，原来主键不再关联id';
CREATE TABLE if not exists followrelations (
`designerId` varchar(255) NOT NULL, 
`followingId` varchar(255) NOT NULL, 
`deleted` int(1) DEFAULT '0', 
`gmtCreate` timestamp NULL, 
`gmtModified` timestamp NULL, 
PRIMARY KEY (`designerId`, `followingId`)
)  CHARSET = utf8;
CREATE TABLE if not exists gift_list (
`giftId` bigint(10) NOT NULL, 
`giftType` int(1) NULL, 
`user` char(100) NULL, 
`userInfo` varchar(255) NULL, 
`dateline` bigint(10) NULL, 
PRIMARY KEY (`giftId`), 
KEY `XMAS` (`giftId`, `giftType`, `user`, `dateline`)
)  CHARSET = utf8;
CREATE TABLE if not exists gifts (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '脳脭脭枚脰梅录眉', 
`uid` varchar(35) NULL COMMENT '脤员娄脫没搂ID', 
`nick` varchar(118) NULL COMMENT '脤员娄脫没搂nick', 
`realname` varchar(118) NULL COMMENT '脮忙实脨脮脙没', 
`tel` varchar(30) NULL COMMENT 'j系碌缁', 
`address` varchar(254) NULL COMMENT '脢栈帽碌脴址', 
`prizeinfo` varchar(254) NULL COMMENT '陆卤品脨脜息', 
`state` varchar(2) NULL COMMENT '状态拢篓0拢潞未路垄       1拢潞脪逊垄       -1拢潞麓媒露篓       2:路脧脝煤拢漏', 
`gmt_create` datetime NULL COMMENT '录脟录麓麓陆篓时录盲', 
`gmt_modified` datetime NULL COMMENT '录脟录脳卯潞贸脨薷脛时录盲', 
`type` varchar(2) NULL COMMENT '脌脿脨停篓0拢潞投票鲁榻1,2,4,6,7,8,11,56,68,89,435,4523      1拢潞脝盲脣没拢漏', 
`matchid` int(11) NULL COMMENT '禄疃疘D', 
`prizeid` int(11) NULL COMMENT '陆卤品脨脜息ID', 
`leve` int(11) NULL COMMENT '陆卤品脰脴要碌燃露拢篓1-10录露拢卢碌燃露越赂撸卢潞卢陆迷铰多）', 
`ip` varchar(64) NULL COMMENT '禄帽陆卤脫没搂ip碌脴址', 
PRIMARY KEY (`id`), 
KEY `idx_gmt_create` (`gmt_create`), 
KEY `idx_type` (`type`)
)  AUTO_INCREMENT = 970 CHARSET = utf8 COMMENT = '投票鲁榻甭幻甭铰泵撁宦1,2,4,6,7,8,11,56,68,89,435,4523惷呄';
CREATE TABLE if not exists joinwork (
`matchId` int(11) NOT NULL, 
`designerId` varchar(255) NOT NULL, 
`matchName` varchar(255) NULL, 
`matchLogo` varchar(255) NULL, 
`deleted` int(1) DEFAULT '0' NOT NULL, 
`gmtCreate` timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP NOT NULL, 
`gmtModified` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL, 
`state` int(11) NULL COMMENT '状态拢篓0拢潞未脧脗脭脴模掳澹1,2,4,6,7,8,11,56,68,89,435,4523拢潞脧脗脭脴模掳澹', 
PRIMARY KEY (`matchId`, `designerId`)
)  CHARSET = utf8;
CREATE TABLE if not exists m_bee_fraction (
`user_id` int(32) UNSIGNED NULL, 
`logon_id` varchar(118) NULL, 
`biz_no` varchar(32) NULL, 
`bill_time` timestamp NULL, 
`out_biz_no` varchar(32) NULL, 
`out_biz_time` timestamp NULL, 
`fraction` int(11) NULL, 
`state` varchar(4) NULL, 
`client_ip` varchar(50) NULL, 
`gmt_create` timestamp DEFAULT CURRENT_TIMESTAMP
)  CHARSET = utf8;
CREATE TABLE if not exists m_bee_integral (
`user_id` int(32) UNSIGNED NULL, 
`user_nick` varchar(118) NULL, 
`integral` int(11) NULL, 
`fire` int(5) NULL, 
`time` int(11) NULL, 
`hot` int(5) NULL, 
`client_ip` varchar(50) NULL, 
`gmt_create` timestamp DEFAULT CURRENT_TIMESTAMP
)  CHARSET = utf8;
CREATE TABLE if not exists m_bee_user_fraction_map (
`user_id` int(32) UNSIGNED NULL, 
`fraction` int(11) NULL, 
`state` varchar(4) NULL, 
`dateline` bigint(20) NULL, 
`gmt_create` timestamp DEFAULT CURRENT_TIMESTAMP
)  CHARSET = utf8;
CREATE TABLE if not exists m_postcard_info (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`uid` bigint(20) NULL COMMENT '用户id', 
`pic` varchar(254) NULL COMMENT '图片地址', 
`memo` varchar(500) NULL COMMENT '用户寄语', 
`tag` varchar(500) NULL COMMENT '标签信息', 
`time_info` varchar(500) NULL COMMENT '时光机信息', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`app_id` int(11) DEFAULT '0' COMMENT '对应活动标识', 
`deleted` smallint(6) DEFAULT '0' COMMENT '是否删除', 
PRIMARY KEY (`id`), 
KEY `idx_m_postcard_info_uid` (`uid`), 
KEY `idx_appid_uid` (`app_id`, `uid`)
)  AUTO_INCREMENT = 1114934 CHARSET = utf8 COMMENT = '明信片活动';
CREATE TABLE if not exists match_tag (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`deleted` int(11) DEFAULT '0' NOT NULL COMMENT '是否被逻辑删除', 
`name` varchar(50) NOT NULL COMMENT '标签', 
`icon` varchar(255) NULL COMMENT '图片地址', 
`type` int(11) DEFAULT '0' NOT NULL COMMENT '标签类型', 
`tag_desc` varchar(255) NULL COMMENT '描述', 
`match_id` int(11) NULL COMMENT '活动id', 
PRIMARY KEY (`id`), 
KEY `idx_match_id` (`match_id`)
)  AUTO_INCREMENT = 58 CHARSET = utf8 COMMENT = '存储活动的风格标签';
CREATE TABLE if not exists matchs (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '脰梅录眉', 
`name` varchar(255) NOT NULL COMMENT '禄疃1,2,4,6,7,8,11,56,68,89,435,4523兠宦趁', 
`rule`varchar(100)COMMENT '禄疃1,2,4,6,7,8,11,56,68,89,435,4523姑γ斆', 
`intro`varchar(100)COMMENT '禄疃1,2,4,6,7,8,11,56,68,89,435,4523柮访屆', 
`logo` varchar(255) NOT NULL COMMENT '禄疃痩ogo', 
`banner` varchar(255) NULL COMMENT '禄疃疊anner', 
`poster` varchar(255) NULL COMMENT '禄疃1,2,4,6,7,8,11,56,68,89,435,4523郝Ｂ甭', 
`flatuploadstarttime` timestamp NULL COMMENT '平脙忙脳梅品脡洗芦驴陋始时录盲', 
`flatauditstarttime` timestamp NULL COMMENT '平脙忙脳梅品脡贸潞丝陋始时录盲', 
`sendtemplatestarttime` timestamp NULL COMMENT '路垄脣桶脳模驴陋始时录盲', 
`entityuploadstarttime` timestamp NULL COMMENT '实脦茂脳梅品脡洗芦驴陋始时录盲', 
`voteLimitNumber` int(6) NOT NULL, 
`type` int(11) NOT NULL COMMENT '禄疃1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523犆愅Ｂ1,2,4,6,7,8,11,56,68,89,435,4523=平脙忙禄疃1,2,4,6,7,8,11,56,68,89,435,4523Ｂ1,2,4,6,7,8,11,56,68,89,435,4523=实脦茂禄疃1,2,4,6,7,8,11,56,68,89,435,4523Ｂ', 
`state` int(11) NOT NULL COMMENT '禄疃1,2,4,6,7,8,11,56,68,89,435,4523刺1,2,4,6,7,8,11,56,68,89,435,4523Ｂ1,2,4,6,7,8,11,56,68,89,435,45230=未驴陋始拢卢1=脡洗芦平脙忙脳梅品脰脨,2=脡洗芦平脙忙脳梅品陆谩脢酶, 3=平脙忙脳梅品脡贸潞脣脰脨,4=平脙忙脳梅品脡贸潞私谩脢酶, 5=路垄脣脥脳梅品掳脳模脰脨,6=路垄脣脥脳梅品掳脳模陆谩脢酶, 7=脡猫录脝师麓麓脳梅脰脨,8=脡洗芦实脦茂脳梅品脰脨, 9=脡洗芦实脦茂脳梅品陆谩脢酶,10=实脦茂脳梅品脡贸潞脣脰脨, 11=实脦茂脳梅品脡贸潞私谩脢酶,12=投票脰脨, 13=投票陆谩脢酶,14=专录脪脝脌脡贸脰脨, 15=专录脪脝脌脡贸陆谩脢酶,16=路垄脣徒卤品脰脨, 17=路', 
`endtime` timestamp NULL COMMENT '禄疃1,2,4,6,7,8,11,56,68,89,435,4523矫∶娒甘甭济', 
`prizeimg` varchar(500) NULL COMMENT '陆卤品图片', 
`deleted` int(1) DEFAULT '0' NOT NULL, 
`gmtcreate` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL, 
`gmtmodified` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL, 
`entityauditstarttime` timestamp NULL COMMENT '实脦茂脳梅品脡贸潞脣时录盲', 
`votestarttime` timestamp NULL COMMENT '投票驴陋始时录盲', 
`finalauditstarttime` timestamp NULL COMMENT '专录脪脝脌脡贸驴陋始时录盲', 
`copyright`varchar(100)COMMENT '掳忙权脡锚脙梅', 
`timeline`varchar(100)COMMENT '禄疃1,2,4,6,7,8,11,56,68,89,435,4523甭间安脜脜', 
`judges`varchar(100)COMMENT '麓贸脠眉脝脌委', 
`templateurl` varchar(254) NULL COMMENT '卤戮禄疃1,2,4,6,7,8,11,56,68,89,435,4523Ｂ懊ッ幠济久徝偯斆樎仿韭', 
`officialannouncement` varchar(254) NULL COMMENT '卤戮禄疃1,2,4,6,7,8,11,56,68,89,435,4523栃官仿矫椕1,2,4,6,7,8,11,56,68,89,435,4523好陈孤1,2,4,6,7,8,11,56,68,89,435,4523该', 
`guest_designer_entry`varchar(100)COMMENT '邀约设计师入口', 
`vote_gift_optios` int(11) DEFAULT '1' COMMENT '是否启用投票抽奖（1：启用，0：不启用）', 
`guest_designer_entry_collapse`varchar(100)COMMENT '邀约设计师入口（小）', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 30 CHARSET = utf8;
CREATE TABLE if not exists messages (
`id` int(11) AUTO_INCREMENT NOT NULL, 
`workId` int(11) NOT NULL, 
`user` varchar(255) NULL, 
`content` varchar(100), 
`timestamp` timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP NOT NULL, 
`denounce` int(1) DEFAULT '0' NOT NULL, 
`deleted` int(1) DEFAULT '0', 
`gmtcreate` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL, 
`gmtmodified` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL, 
`user_id` bigint(20) DEFAULT '0' NOT NULL COMMENT '淘宝用户id', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 115936 CHARSET = utf8;
CREATE TABLE if not exists pics (
`id` int(11) AUTO_INCREMENT NOT NULL, 
`workId` int(11) NOT NULL, 
`cover` int(1) NOT NULL, 
`description` varchar(100), 
`url` varchar(255) NULL, 
`size` int(20) DEFAULT '0', 
`name` varchar(255) NULL, 
`hotOrder` int(8) DEFAULT '-1', 
`deleted` int(1) DEFAULT '0', 
`gmtCreate` timestamp NULL, 
`gmtModified` timestamp NULL, 
`width` int(11) DEFAULT '0', 
`height` int(11) DEFAULT '0', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 168328 CHARSET = utf8;
CREATE TABLE if not exists prizes (
`id` int(11) AUTO_INCREMENT NOT NULL, 
`matchId` int(11) NOT NULL, 
`prizeleve` int(11) NOT NULL, 
`prizeImg` varchar(255) NULL, 
`prizeIntro` varchar(100), 
`prizeNum` int(5) NULL, 
`deleted` int(1) DEFAULT '0' NOT NULL, 
`gmtCreate` timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP NOT NULL, 
`gmtModified` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL, 
`prizeName` varchar(50) NULL, 
`type` int(11) NULL COMMENT '陆卤品脌脿脨停篓0拢潞禄疃1,2,4,6,7,8,11,56,68,89,435,4523铰逼仿Ｂ1,2,4,6,7,8,11,56,68,89,435,4523拢潞鲁榻甭铰逼仿Ｂ', 
`send_num` int(11) DEFAULT '0' COMMENT '已发送奖品数', 
PRIMARY KEY (`id`), 
KEY `idx_matchId` (`matchId`)
)  AUTO_INCREMENT = 194 CHARSET = utf8;
CREATE TABLE if not exists sysparam (
`id` int(11) AUTO_INCREMENT NOT NULL, 
`name` varchar(255) NOT NULL, 
`value` varchar(255) NOT NULL, 
`attr1` varchar(255) NULL, 
`attr2` varchar(255) NULL, 
`type` int(3) DEFAULT '0' NOT NULL, 
`state` smallint(1) DEFAULT '0' NOT NULL, 
`deleted` int(1) DEFAULT '0' NOT NULL, 
`gmtCreate` timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP NOT NULL, 
`gmtModified` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL, 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 3 CHARSET = utf8;
CREATE TABLE if not exists user_gift_log (
`user` char(100) NULL, 
`giftType` int(1) NULL, 
`dateline` bigint(10) NULL, 
KEY `USERLOG` (`user`, `dateline`)
)  CHARSET = utf8;
CREATE TABLE if not exists votelog (
`matchId` int(11) NOT NULL, 
`workId` int(11) NOT NULL, 
`designerId` varchar(255) NOT NULL, 
`voteDesignerId` varchar(255) NOT NULL, 
`ip` varchar(30) NULL, 
`deleted` int(1) DEFAULT '0' NOT NULL, 
`gmtCreate` timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP NOT NULL, 
`gmtModified` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL, 
KEY `idx_gmtCreate` (`gmtCreate`), 
KEY `idx_mid_wid_vid_did` (`matchId`, `workId`, `designerId`, `voteDesignerId`), 
KEY `idx_mid_vid_gmt` (`matchId`, `voteDesignerId`, `gmtCreate`)
)  CHARSET = utf8;
CREATE TABLE if not exists works (
`id` int(11) AUTO_INCREMENT NOT NULL, 
`title` varchar(255) NULL, 
`description` varchar(100), 
`taobaoLink` varchar(255) NULL, 
`designerId` varchar(255) NOT NULL, 
`cover` int(1) DEFAULT '0' NOT NULL, 
`pic` varchar(255) NULL, 
`addtime` datetime NULL, 
`hotOrder` int(255) DEFAULT '-1' NOT NULL, 
`voteCount` int(6) DEFAULT '0', 
`matchId` int(11) NULL, 
`matchRoundNo` int(1) DEFAULT '0', 
`state` int(3) DEFAULT '0', 
`remark` varchar(255) NULL, 
`isWin` int(1) DEFAULT '0', 
`prizeId` int(11) DEFAULT '-1', 
`prizeLeve` varchar(255) NULL, 
`deleted` int(1) DEFAULT '0', 
`gmtcreate` datetime NULL, 
`gmtmodified` datetime NULL, 
`tag_id` int(11) NULL COMMENT '作品风格标签id', 
`tag_name` varchar(50) NULL COMMENT '作品风格标签name', 
PRIMARY KEY (`id`), 
KEY `idx_matchId_matchroundno_state_isWin` (`matchId`, `matchRoundNo`, `state`, `isWin`), 
KEY `idx_del_designid` (`deleted`, `designerId`)
)  AUTO_INCREMENT = 36908 CHARSET = utf8;
SELECT * FROM works w LEFT JOIN prizes p ON p.id = w.prizeid WHERE w.matchid = 1 AND w.iswin = 1 AND w.deleted = 1 ORDER BY p.prizeleve ASC;
id	title	description	taobaoLink	designerId	cover	pic	addtime	hotOrder	voteCount	matchId	matchRoundNo	state	remark	isWin	prizeId	prizeLeve	deleted	gmtcreate	gmtmodified	tag_id	tag_name	id	matchId	prizeleve	prizeImg	prizeIntro	prizeNum	deleted	gmtCreate	gmtModified	prizeName	type	send_num
SELECT COUNT(id) FROM works WHERE matchid = 1 AND matchroundno = 1 AND state = 1 AND deleted = 1;
