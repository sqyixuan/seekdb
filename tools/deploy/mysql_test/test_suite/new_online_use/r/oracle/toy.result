SELECT id, title, designerid, description, taobaolink , cover, pic, addtime, hotorder, votecount , matchid, matchroundno, state, iswin, remark , prizeid, prizeleve, tag_id AS tagid, tag_name AS tagname, deleted , gmtcreate, gmtmodified FROM works WHERE matchid = 1 AND matchroundno = 1 AND state IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND deleted = 1 ORDER BY votecount DESC LIMIT 1, 1;
