CREATE TABLE if not exists ads_tb_hi_cat_uv_30d (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`category_id` bigint(20) UNSIGNED NULL COMMENT '类目ID', 
`user_id` bigint(20) UNSIGNED NULL COMMENT '用户ID', 
PRIMARY KEY (`id`), 
KEY `index_category_id` (`category_id`)
)  CHARSET = utf8 COMMENT = '30天内浏览过众筹类目的人群表';
CREATE TABLE if not exists dream_homepage (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '标识区块类型：', 
`project_id` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '项目ID', 
`order_id` int(11) NULL COMMENT '排序ID', 
`remark` varchar(2048) NULL COMMENT '备注', 
`op_imgs` varchar(512) NULL COMMENT '运营图片', 
`project_desc` varchar(2048) NULL COMMENT '项目描述', 
PRIMARY KEY (`id`), 
KEY `index_type` (`type`), 
KEY `index_projectid` (`project_id`)
)  AUTO_INCREMENT = 11 CHARSET = utf8 COMMENT = '首页表';
CREATE TABLE if not exists dream_project (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NULL COMMENT '创建时间', 
`gmt_modified` datetime NULL COMMENT '修改时间', 
`user_id` bigint(20) NULL COMMENT '用户ID，来自于UIC系统', 
`nick` varchar(128) NULL COMMENT '用户昵称，来自UIC用户系统', 
`title` varchar(256) NULL COMMENT '项目名称', 
`sub_title` varchar(256) NULL COMMENT '副标题', 
`country` varchar(128) NULL COMMENT '国家', 
`prov` varchar(128) NULL COMMENT '省份', 
`city` varchar(128) NULL COMMENT '城市', 
`project_desc` varchar(2048) NULL COMMENT '项目简介', 
`video` varchar(256) NULL COMMENT '介绍视频', 
`content` varchar(256) NULL COMMENT '项目详细介绍', 
`imgs` varchar(512) NULL COMMENT '项目图片，英文逗号分隔', 
`main_img` varchar(256) NULL COMMENT '背景图片', 
`plan_date` datetime NULL COMMENT '项目预计上线时间', 
`begin_date` datetime NULL COMMENT '筹款开始时间', 
`need_days` int(11) NULL COMMENT '筹款天数', 
`make_days` int(11) NULL COMMENT '制作天数', 
`target_money` bigint(20) DEFAULT '0' COMMENT '目标筹款额，单位：分', 
`current_money` bigint(20) DEFAULT '0' COMMENT '当前筹款额，单位：分', 
`feature` varchar(5120) NULL COMMENT '扩展字段', 
`category_id` bigint(20) NULL COMMENT '类目', 
`item_ids` varchar(512) NULL COMMENT '商品ID，英文逗号分隔', 
`status` int(11) DEFAULT '0' COMMENT '状态，0计划中,1审核中,2审核不通过,3审核通过,4筹款中,5筹款失败,6制作中,7项目失败,8项目延期,9项目成功,10筹款违规,11制作违规,12筹款失败退款成功,20预热中,23预热违规，-1软删除且无法查询(不可恢复)', 
`comment` varchar(2048) NULL COMMENT '备注', 
`pay_order_count` int(11) DEFAULT '0' COMMENT '已付款的订单数量', 
`update_status` int(11) DEFAULT '0' COMMENT '更新状态，是否有更新，0无更新，1资料已保存,2待审核,3审核不通过,4审核通过,11预热变更已保存,12预热变更待审核,13预热变更审核不通过,14预热变更审核通过', 
`seek_days` int(11) DEFAULT '0' COMMENT '项目预热天数，0天不预热，小于等于7.', 
`focus_count` int(11) DEFAULT '0' COMMENT '该项目的喜欢人数,定时从Tair写回。', 
`project_tag` varchar(512) NULL COMMENT '项目tag，英文逗号分隔', 
PRIMARY KEY (`id`), 
KEY `index_dream_project_status` (`status`), 
KEY `index_dream_project_user_id` (`user_id`)
)  AUTO_INCREMENT = 452343386 CHARSET = utf8 COMMENT = '众筹项目';
CREATE TABLE if not exists dream_project_analyze (
`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) NULL COMMENT 'UIC id', 
`nick` varchar(128) NULL COMMENT 'nick', 
`title` varchar(256) NULL COMMENT '项目title', 
`sub_title` varchar(256) NULL COMMENT '副标题', 
`country` varchar(128) NULL COMMENT '国家', 
`prov` varchar(128) NULL COMMENT '省份', 
`city` varchar(128) NULL COMMENT '城市', 
`project_desc` varchar(2048) NULL COMMENT '项目简介', 
`video` varchar(256) NULL COMMENT '介绍视频', 
`content` varchar(256) NULL COMMENT '项目详细介绍', 
`imgs` varchar(512) NULL COMMENT '项目图片，英文逗号分隔', 
`main_img` varchar(256) NULL COMMENT '背景图片', 
`plan_date` datetime NULL COMMENT '项目预计上线时间', 
`begin_date` datetime NULL COMMENT '筹款开始时间', 
`need_days` int(11) NULL COMMENT '筹款天数', 
`make_days` int(11) NULL COMMENT '制作天数', 
`target_money` bigint(20) NULL COMMENT '目标筹款额，单位：分', 
`current_money` bigint(20) NULL COMMENT '当前筹款额，单位：分', 
`feature` varchar(5120) NULL COMMENT '扩展字段', 
`category_id` bigint(20) NULL COMMENT '类目', 
`item_ids` varchar(512) NULL COMMENT '商品ID，英文逗号分隔', 
`status` int(11) NULL COMMENT '状态，0计划中,1审核中,2审核不通过,3审核通过,4筹款中,5筹款失败,6制作中,7项目失败,8项目延期,9项目成功,10筹款违规,11制作违规,12筹款失败退款成功,20预热中,23预热违规，-1软删除且无法查询(不可恢复)', 
`comment` varchar(2048) NULL COMMENT '备注', 
`pay_order_count` int(11) NULL COMMENT '已付款的订单数量', 
`update_status` int(11) NULL COMMENT '更新状态，是否有更新，0无更新，1资料已保存,2待审核,3审核不通过,4审核通过,11预热变更已保存,12预热变更待审核,13预热变更审核不通过,14预热变更审核通过', 
`seek_days` int(11) NULL COMMENT '项目预热天数，0天不预热，小于等于7.', 
`money_oneday` bigint(20) DEFAULT '0' COMMENT '前一天的筹款数', 
`money_sevenday` bigint(20) DEFAULT '0' COMMENT '前七天的筹款数', 
`order_sevenday` bigint(20) UNSIGNED DEFAULT '0' COMMENT '前七天的支持人数', 
`project_tag` varchar(512) NULL COMMENT '项目分类tag', 
PRIMARY KEY (`id`), 
KEY `one_day_money` (`money_oneday`, `status`), 
KEY `seven_day_money` (`money_sevenday`, `status`), 
KEY `seven_day_order` (`order_sevenday`, `status`), 
KEY `category` (`category_id`)
)  CHARSET = utf8 COMMENT = '7天统计回流表';
CREATE TABLE if not exists dream_project_faq (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`project_id` bigint(20) UNSIGNED NOT NULL COMMENT '项目id', 
`order_num` int(10) UNSIGNED NULL COMMENT 'faq列表排序序号', 
`question` varchar(512) NULL COMMENT 'faq问题', 
`answer` varchar(1024) NULL COMMENT 'faq问题回复', 
`status` tinyint(4) NULL COMMENT '状态（-1删除,0正常）', 
`attribute` varchar(1024) NULL COMMENT '扩展属性', 
PRIMARY KEY (`id`), 
KEY `index_faq_project_id` (`project_id`, `status`)
)  AUTO_INCREMENT = 4742 CHARSET = utf8 COMMENT = '众筹项目faq表';
CREATE TABLE if not exists dream_project_feed (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`project_id` bigint(20) UNSIGNED NOT NULL COMMENT '项目id', 
`provider_id` bigint(20) UNSIGNED NOT NULL COMMENT '项目创建者id', 
`content` varchar(1024) NULL COMMENT '动态内容', 
`medias` varchar(1024) NULL COMMENT '动态的多媒体信息集合如图片/视频/商品等', 
`status` tinyint(4) NOT NULL COMMENT '状态（-1:删除，0:正常）', 
`attribute` varchar(1024) NULL COMMENT '扩展属性', 
PRIMARY KEY (`id`), 
KEY `index_project_id` (`project_id`, `status`, `id`, `gmt_create`), 
KEY `index_provider_id` (`provider_id`, `status`, `id`)
)  AUTO_INCREMENT = 4084 CHARSET = utf8 COMMENT = '项目动态表';
CREATE TABLE if not exists dream_project_item (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`project_id` bigint(20) DEFAULT '0' NOT NULL COMMENT '项目ID', 
`item_id` bigint(20) DEFAULT '0' NOT NULL COMMENT '商品ID', 
`status` tinyint(4) DEFAULT '0' COMMENT '状态，0待发货,1发货中,2已发货,3确认发货,4发货完成,5补发货', 
`buy_count` int(11) DEFAULT '0' COMMENT '购买数量', 
`refound_count` int(11) DEFAULT '0' COMMENT '退款数量', 
PRIMARY KEY (`id`), 
UNIQUE `index_item_id` (`item_id`), 
KEY `index_status` (`status`), 
KEY `index_project_id` (`project_id`)
)  AUTO_INCREMENT = 136409 CHARSET = utf8 COMMENT = '项目商品';
CREATE TABLE if not exists dream_project_item_repay (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`item_id` bigint(20) DEFAULT '0' COMMENT '项目商品ID', 
`status` int(11) DEFAULT '0' COMMENT '状态，0发货中,1已发货,2已删除', 
`type` int(11) DEFAULT '0' COMMENT '类型,0音乐,1电子书,2其它', 
`title` varchar(1024) NOT NULL COMMENT '标题', 
`url` varchar(1024) NOT NULL COMMENT '链接', 
`outer_id` varchar(512) NULL COMMENT '业务方ID', 
`feature_string` varchar(1024) NULL COMMENT '扩展信息', 
PRIMARY KEY (`id`), 
KEY `index_item_id` (`item_id`), 
KEY `index_status` (`status`)
)  AUTO_INCREMENT = 369 CHARSET = utf8 COMMENT = '项目商品回报';
CREATE TABLE if not exists dream_user (
`user_id` bigint(20) NOT NULL COMMENT '卖家ID(筹款发起人),来自UIC', 
`gmt_create` datetime NULL COMMENT '创建时间', 
`gmt_modified` datetime NULL COMMENT '修改时间', 
`nick` varchar(128) NULL COMMENT '昵称(来自UIC用户系统)', 
`other_name1` varchar(64) NULL COMMENT '艺名', 
`other_name2` varchar(64) NULL COMMENT '昵称', 
`birthday` date NULL COMMENT '生日', 
`area` varchar(128) NULL COMMENT '地区', 
`tag` bigint(20) DEFAULT '0' COMMENT '是否显示生日 年份/月/日', 
`website` varchar(256) NULL COMMENT '个人主页', 
`user_desc` varchar(2048) NULL COMMENT '个人简介', 
`head_img` varchar(256) NULL COMMENT '个人头像', 
`background_img` varchar(256) NULL COMMENT '个人页面背景图', 
`other_desc` varchar(256) NULL COMMENT '个人详细介绍', 
`status` int(11) DEFAULT '0' COMMENT '状态，0已保存,1审核中,2审核不通过,3审核通过', 
`type` int(11) DEFAULT '0' COMMENT '用户类型', 
`comment` varchar(2048) NULL COMMENT '备注', 
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`update_status` int(11) DEFAULT '0' COMMENT '更新状态，是否有更新，0为无更新，1为有更新，需要小二进一步审查。', 
PRIMARY KEY (`id`), 
KEY `idx_dream_user_user_id` (`user_id`), 
KEY `idx_dream_user_nick` (`nick`), 
KEY `idx_dream_user_update_status` (`update_status`), 
KEY `idx_dream_user_other_name2` (`other_name2`), 
KEY `idx_dream_user_status` (`status`), 
KEY `idx_dream_user_other_name1` (`other_name1`)
)  AUTO_INCREMENT = 13380 CHARSET = utf8 COMMENT = '个人资料(筹款发起人/卖家)';
CREATE TABLE if not exists dream_user_project (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '类型：0-关注，1-购买', 
`project_id` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '项目ID', 
`user_id` bigint(20) UNSIGNED NULL COMMENT '用户ID', 
`nick` varchar(128) NULL COMMENT '用户昵称', 
`status` tinyint(4) NULL COMMENT '-1-删除，0-正常', 
`subscribe` tinyint(4) DEFAULT '0' NOT NULL COMMENT '0未订阅，1订阅', 
PRIMARY KEY (`id`), 
KEY `index_nick` (`nick`), 
KEY `index_type` (`type`), 
KEY `index_userid` (`user_id`), 
KEY `index_status` (`status`), 
KEY `index_projectid` (`project_id`), 
KEY `idx_pid_statyp` (`project_id`, `type`, `status`), 
KEY `idx_statyp_gmt` (`type`, `status`, `gmt_create`)
)  AUTO_INCREMENT = 5883877 CHARSET = utf8 COMMENT = '用户项目表';
CREATE TABLE if not exists ques_answer (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) DEFAULT '0' NOT NULL COMMENT '用户ID', 
`ques_id` bigint(20) DEFAULT '0' NOT NULL COMMENT '问卷ID', 
`answer` varchar(1024) NOT NULL COMMENT '用户答案', 
`status` int(11) DEFAULT '0' NOT NULL COMMENT '状态，0正常，-1删除', 
`nick` varchar(256) NOT NULL COMMENT '用户昵称', 
PRIMARY KEY (`id`), 
KEY `user_id` (`user_id`), 
KEY `ques_id` (`ques_id`)
)  AUTO_INCREMENT = 1235 CHARSET = utf8 COMMENT = '问卷答卷';
CREATE TABLE if not exists ques_promo (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) DEFAULT '0' NOT NULL COMMENT '用户ID', 
`title` varchar(256) NOT NULL COMMENT '标题', 
`need_login` int(11) DEFAULT '0' NOT NULL COMMENT '是否需要登录才能填写，1需要,0无需', 
`keep_one` int(11) DEFAULT '0' NOT NULL COMMENT '不允许填写多份,0允许，1不允许。', 
`status` int(11) DEFAULT '0' NOT NULL COMMENT '状态，0正常，-1删除', 
PRIMARY KEY (`id`), 
KEY `user_id` (`user_id`)
)  AUTO_INCREMENT = 11 CHARSET = utf8 COMMENT = '问卷发起人';
CREATE TABLE if not exists ques_question (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`key_title` varchar(256) NOT NULL COMMENT '标题', 
`key_values` varchar(1024) NOT NULL COMMENT '值列表，特殊符号分隔，还没想好用哪个。', 
`type` int(11) DEFAULT '0' NOT NULL COMMENT '输入类型，0文本,1多行文本,2数字,3邮箱,4电话,5单选,6多选', 
`status` int(11) DEFAULT '0' NOT NULL COMMENT '状态,0正常，-1删除', 
`max_length` int(11) DEFAULT '150' NOT NULL COMMENT '字段长度,默认150', 
`promo_id` int(11) DEFAULT '0' NOT NULL COMMENT '发起问卷ID', 
PRIMARY KEY (`id`), 
KEY `promo_id` (`promo_id`)
)  AUTO_INCREMENT = 31 CHARSET = utf8 COMMENT = '问卷问题';
CREATE TABLE if not exists t_1212_coin_user (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
PRIMARY KEY (`id`), 
KEY `user_id_index` (`user_id`)
)  AUTO_INCREMENT = 42 CHARSET = utf8 COMMENT = '双12淘金币领取表';
CREATE TABLE if not exists t_1212_vote (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`project_id` bigint(20) UNSIGNED NOT NULL COMMENT '项目ID', 
`vote_num` bigint(20) UNSIGNED DEFAULT '0' COMMENT '投票数', 
`status` bigint(20) UNSIGNED NOT NULL COMMENT '删除标志', 
PRIMARY KEY (`id`), 
KEY `project_index` (`project_id`)
)  AUTO_INCREMENT = 25 CHARSET = utf8 COMMENT = '众筹双12投票表';
CREATE TABLE if not exists t_1212_vote_user (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
`project_id` bigint(20) UNSIGNED NOT NULL COMMENT '被投票的项目ID', 
`status` bigint(20) UNSIGNED NOT NULL COMMENT '删除标志', 
PRIMARY KEY (`id`), 
KEY `user_project_index` (`user_id`, `project_id`, `gmt_create`)
)  AUTO_INCREMENT = 58 CHARSET = utf8 COMMENT = '众筹双12投票记录表';
CREATE TABLE if not exists t_black_list (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
`end_date` datetime NOT NULL COMMENT '小黑屋结束时间', 
`operator` varchar(256) NOT NULL COMMENT '操作人工号', 
PRIMARY KEY (`id`), 
KEY `endtime_user` (`user_id`, `end_date`)
)  AUTO_INCREMENT = 2 CHARSET = utf8 COMMENT = '众筹黑名单表';
CREATE TABLE if not exists t_correction_project (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`initiator` varchar(255) NOT NULL COMMENT '发起订正人ID', 
`project_id` bigint(20) UNSIGNED NOT NULL COMMENT '项目ID', 
`status` int(11) NOT NULL COMMENT '状态：0为未提交；1待审核；2执行成功；-1被拒绝；-2执行失败', 
`feature`varchar(100)NOT NULL COMMENT '具体订正内容，json结构', 
`user_name` varchar(256) NOT NULL COMMENT '发起人花名', 
`type` int(11) DEFAULT '0' NOT NULL COMMENT '订正类型，0为普通订正，1为设计师图片订正', 
PRIMARY KEY (`id`), 
KEY `userid` (`initiator`), 
KEY `type` (`type`)
)  AUTO_INCREMENT = 74 CHARSET = utf8 COMMENT = '数据订正线索表';
CREATE TABLE if not exists t_operator_log (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`project_id` bigint(20) UNSIGNED NOT NULL COMMENT '项目ID', 
`user_id` varchar(512) NOT NULL COMMENT '小二ID', 
`content` varchar(2000) NOT NULL COMMENT '操作明细', 
`user_name` varchar(256) NOT NULL COMMENT '小二花名', 
PRIMARY KEY (`id`), 
KEY `project_id` (`project_id`)
)  AUTO_INCREMENT = 6138 CHARSET = utf8 COMMENT = 'CRM小二操作日志';
CREATE TABLE if not exists t_white_list (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_nick` varchar(255) NOT NULL COMMENT '用户nick', 
`operator` bigint(20) UNSIGNED NOT NULL COMMENT '小二ID', 
PRIMARY KEY (`id`), 
KEY `user_id_time` (`gmt_create`, `user_nick`)
)  AUTO_INCREMENT = 7 CHARSET = utf8 COMMENT = '众筹发项目白名单';
CREATE TABLE if not exists t_tag (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`tag` varchar(255) NOT NULL COMMENT 'tag名称', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 63 CHARSET = utf8 COMMENT = '众筹分类tag表';
SELECT id, gmt_create, gmt_modified, user_id, nick , title, sub_title, country, prov, city , project_desc, video, content, imgs, main_img , plan_date, begin_date, need_days, make_days, target_money , current_money, pay_order_count, category_id, item_ids, status , comment, feature, update_status, seek_days, focus_count FROM dream_project WHERE status > 1 AND nick = "3" AND status IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND category_id IN (1,2,4,6,7,8,11,56,68,89,435,4523) ORDER BY gmt_modified ASC LIMIT 1, 1;
id	gmt_create	gmt_modified	user_id	nick	title	sub_title	country	prov	city	project_desc	video	content	imgs	main_img	plan_date	begin_date	need_days	make_days	target_money	current_money	pay_order_count	category_id	item_ids	status	comment	feature	update_status	seek_days	focus_count
SELECT user_id, gmt_create, gmt_modified, nick, other_name1 , other_name2, birthday, area, tag, user_desc , head_img, website, other_desc, status, type , comment, update_status FROM dream_user WHERE user_id = 1 LIMIT 1;
