CREATE TABLE if not exists autosave_gov_bid_extra (
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`item_id` bigint(20) NULL COMMENT '宝贝ID', 
`auction_starts` datetime NULL COMMENT '开始时间', 
`auction_ends` datetime NULL COMMENT '结束时间', 
`auction_type` tinyint(4) NULL COMMENT '宝贝类型', 
`features` varchar(512) NULL COMMENT '附加字段', 
`options` bigint(20) NULL COMMENT '标示字段', 
`current_price` bigint(20) NULL COMMENT '当前价', 
`reserve_price` varchar(128) NULL COMMENT '保留价', 
`next_bid` bigint(20) NULL COMMENT '下次出价价格', 
`consult_price` bigint(20) NULL COMMENT '评估价', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`link_man` varchar(64) NULL COMMENT '联系人', 
`mobile_phone` varchar(20) NULL COMMENT '联系手机', 
`phone` varchar(30) NULL COMMENT '手机', 
`has_attach` tinyint(4) NULL COMMENT '是否包含附件', 
`project_id` bigint(20) NULL COMMENT '项目id', 
`custom_pic_url` varchar(2048) NULL COMMENT '自定义图片', 
`movie_url` varchar(256) NULL COMMENT '视频在ftf的链接', 
`cat_id` bigint(20) NULL COMMENT '类目ID', 
`notice_tfsname` varchar(256) NULL COMMENT '须知tfs', 
`priority_users` varchar(1024) NULL COMMENT '优先购买权人', 
`coordinate` varchar(64) NULL COMMENT '坐标', 
`location` varchar(256) NULL COMMENT '所在地', 
`item_desc` varchar(64) NULL COMMENT '宝贝描述临时保存', 
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`is_deleted` tinyint(4) DEFAULT '0' NOT NULL COMMENT '是否被删除', 
`title` varchar(256) NULL COMMENT '宝贝标题', 
`black_users` varchar(1024) NULL COMMENT '黑名单用户字段', 
`type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '入驻类型:0=司法,11=资产政府类,12=资产商业类,13=拍卖行', 
`buyer_qualification` varchar(2048) NULL COMMENT '资产竞买人资格', 
`comp` int(11) DEFAULT '0' COMMENT '佣金比例，DB存储是实际比例(小数点后最多5位)的1,2,4,6,7,8,11,56,68,89,435,4523000倍。', 
`postage` bigint(20) UNSIGNED NULL COMMENT '资产类的邮费', 
`loan_tfs_name` varchar(256) NULL COMMENT '司法贷款服务', 
PRIMARY KEY (`id`), 
KEY `user_id_pk` (`user_id`)
)  AUTO_INCREMENT = 91111 CHARSET = utf8 COMMENT = '自动保存司法宝贝';
CREATE TABLE if not exists bid_album_statistics (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`title` varchar(200) NULL COMMENT '专场名称', 
`start_time` date NULL COMMENT '专场开始时间', 
`end_time` date NULL COMMENT '专场结束时间', 
`creator_id` bigint(20) NULL COMMENT '专场创建人id', 
`nick` varchar(118) NULL COMMENT '创建人nick', 
`album_id` bigint(20) NULL COMMENT '专场id', 
`front_cat_name` varchar(100) NULL COMMENT '前台类目名称', 
`cat_item_count` int(11) NULL COMMENT '类目下商品数目', 
`bid_count` int(11) NULL COMMENT '类目下商品的出价次数', 
`bid_buyer_count` int(11) NULL COMMENT '类目下商品的出价人数', 
`paixia_item_count` int(11) NULL COMMENT '类目下拍下商品数', 
`suc_item_count` int(11) NULL COMMENT '类目下成交商品数', 
`ing_item_count` int(11) NULL COMMENT '类目下正在走交易流程的商品数', 
`ing_gmv` double NULL COMMENT '类目下正在走交易流程的gmv', 
`suc_item_amount` int(11) NULL COMMENT '交易成功的商品数量', 
`paixia_gmv` double NULL COMMENT '拍下gmv', 
`suc_gmv` double NULL COMMENT '成交gmv', 
`refund_item_count` int(11) NULL COMMENT '退款商品数', 
`refund_item_gmv` bigint(20) UNSIGNED NULL COMMENT '退款gmv', 
`ipv` bigint(20) NULL COMMENT 'ipv', 
`iuv` bigint(20) NULL COMMENT 'iuv', 
`biz_date` date NULL COMMENT '数据的截止日期（包括biz_date)，数据是计算的一月内的专场的数据', 
`pv` bigint(20) NULL COMMENT '专场pv数据', 
`uv` bigint(20) NULL COMMENT '专场uv数据', 
PRIMARY KEY (`id`), 
KEY `biz_date` (`biz_date`), 
KEY `ttile` (`title`), 
KEY `album_id` (`album_id`), 
KEY `start_end_time` (`start_time`, `end_time`), 
KEY `cat_id` (`front_cat_name`)
)  AUTO_INCREMENT = 4219102 CHARSET = utf8 COMMENT = '拍卖专场统计数据';
CREATE TABLE if not exists gov_assets_cooperater (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`cooperater_name` varchar(60) NOT NULL COMMENT '合作机构名', 
`contact_book` varchar(1024) NOT NULL COMMENT '合作机构联系方式', 
`cooperater_picurl` varchar(1024) NULL COMMENT '合作机构的相关证件', 
`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '资产拍卖用户id', 
PRIMARY KEY (`id`), 
KEY `index_seller_id` (`seller_id`)
)  AUTO_INCREMENT = 16 CHARSET = utf8 COMMENT = '资产处置合作机构';
CREATE TABLE if not exists gov_attach_file (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`source_id` bigint(20) UNSIGNED NOT NULL COMMENT '所属源id（标的物或公告id），外键', 
`title` varchar(256) NULL COMMENT '附件标题', 
`url` varchar(256) NULL COMMENT '附件链接', 
`file_type` tinyint(4) NULL COMMENT '附件文件类型，如doc、txt', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
PRIMARY KEY (`id`), 
KEY `idx_gov_attach_file_sid` (`source_id`, `file_type`)
)  AUTO_INCREMENT = 20587 CHARSET = utf8 COMMENT = '司法拍卖附件表';
CREATE TABLE if not exists gov_bid_auction (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '宝贝id', 
`buyer_id` bigint(20) UNSIGNED NOT NULL COMMENT '出价者id', 
`bid_time` datetime NOT NULL COMMENT '出价时间', 
`bid_price` bigint(20) UNSIGNED NOT NULL COMMENT '出价金额，单位分', 
`quantity` int(10) UNSIGNED NOT NULL COMMENT '出价数量', 
`bid_ip` varchar(32) NULL COMMENT '出价ip', 
`status` tinyint(4) NOT NULL COMMENT '出价记录状态', 
`options` bigint(20) UNSIGNED NULL COMMENT '位与字段', 
`biz_order_id` bigint(20) UNSIGNED NULL COMMENT '订单id', 
`alias_name` varchar(32) NULL COMMENT '出价者别名', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
`pause_flag` tinyint(4) NULL COMMENT '中止标记', 
PRIMARY KEY (`id`), 
KEY `idx_gov_bid_auction_itemid_buyerid` (`item_id`, `buyer_id`), 
KEY `idx_gov_bid_auction_itemid_bidtime` (`item_id`, `bid_time`), 
KEY `idx_gid_id_bidp` (`item_id`, `status`, `bid_price`, `gmt_create`)
)  AUTO_INCREMENT = 1066257 CHARSET = utf8 COMMENT = '司法拍卖出价表';
CREATE TABLE if not exists gov_bid_extra (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '宝贝id', 
`auction_starts` datetime NULL COMMENT '拍卖开始时间', 
`auction_ends` datetime NULL COMMENT '拍卖结束时间', 
`auction_type` tinyint(4) NOT NULL COMMENT '拍卖类型，1单件拍', 
`bid_status` tinyint(4) NOT NULL COMMENT '拍卖状态（0未出价，1出价中，2已生成订单，3失败，4失效）', 
`features` varchar(100) NULL COMMENT '规则信息等', 
`options` bigint(20) UNSIGNED NULL COMMENT '扩展预留位*', 
`attribute_cc` bigint(20) UNSIGNED NOT NULL COMMENT '系统标示版本号', 
`current_price` bigint(20) UNSIGNED NULL COMMENT '当前价格，单位分', 
`reserve_price` varchar(128) NULL COMMENT '保留价，加密字段', 
`next_bid` bigint(20) UNSIGNED NULL COMMENT '下次最小出价，单位分', 
`consult_price` bigint(20) NULL COMMENT '市场估价，单位分', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户id', 
`link_man` varchar(64) NULL COMMENT '标的物联系人', 
`mobile_phone` varchar(20) NULL COMMENT '手机号', 
`phone` varchar(30) NULL COMMENT '电话号码', 
`has_attach` tinyint(4) NULL COMMENT '是否有附件，0没有，1有', 
`project_id` bigint(20) UNSIGNED NULL COMMENT '项目id，外键', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
`end_url` varchar(256) NULL COMMENT '终结理由链接', 
`custom_pic_url` varchar(256) NULL COMMENT '自定义的图片', 
`movie_url` varchar(256) NULL COMMENT '视频在tft的链接', 
`export_info` varchar(256) NULL COMMENT '文件导出信息', 
`cat_id` bigint(20) UNSIGNED DEFAULT '0' COMMENT '类目id', 
`notice_tfsname` varchar(256) NULL COMMENT '商品须知的tfsName', 
`priority_users` varchar(2048) NULL COMMENT '优先竞买权人用户id', 
`coordinate` varchar(64) NULL COMMENT '坐标', 
`location` varchar(256) NULL COMMENT '所在地', 
`pub_time` datetime NULL COMMENT '标的物发布时间', 
`type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '入驻类型:0=司法,11=资产政府类,12=资产商业类,13=拍卖行', 
`buyer_qualification` varchar(2048) NULL COMMENT '资产竞买人资格', 
`comp` int(11) NULL COMMENT '佣金比例，DB存储是实际比例(小数点后最多5位)的1,2,4,6,7,8,11,56,68,89,435,4523000倍。', 
`postage` bigint(20) UNSIGNED NULL COMMENT '资产类的邮费', 
`root_item_id` bigint(20) UNSIGNED NULL COMMENT '第一次拍卖时的记录下的宝贝id，后续通过转拍产生的新标的物商品也会冗余这个宝贝id。', 
`loan_tfs_name` varchar(256) NULL COMMENT '司法贷款服务TFS', 
PRIMARY KEY (`id`), 
KEY `idx_gov_bid_extra_itemid` (`item_id`), 
KEY `idx_gov_bid_extra_projectid` (`project_id`, `bid_status`), 
KEY `idx_gov_bid_extra_bidstu_auctionend` (`bid_status`, `auction_ends`), 
KEY `idx_gov_bid_extra_userid_pubtime_bidstatus` (`user_id`, `pub_time`, `bid_status`), 
KEY `ind_cu` (`current_price`), 
KEY `inx_root_item_id` (`root_item_id`, `gmt_create`), 
KEY `idx_uid_auctst_bstat` (`user_id`, `auction_starts`, `bid_status`), 
KEY `idx_report_detail` (`type`, `bid_status`, `gmt_modified`)
)  AUTO_INCREMENT = 158695 CHARSET = utf8 COMMENT = '司法拍卖子表';
CREATE TABLE if not exists gov_bid_foregift (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '宝贝id', 
`buyer_id` bigint(20) UNSIGNED NOT NULL COMMENT '买家用户id', 
`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '卖家id', 
`alipay_id` varchar(32) NOT NULL COMMENT '转出支付宝账号', 
`amount` bigint(20) UNSIGNED NOT NULL COMMENT '冻结金额', 
`type` tinyint(4) NOT NULL COMMENT '押金类型1-冻结 2-解冻 3-转移', 
`status` tinyint(4) NOT NULL COMMENT '押金状态：0-初始化 1-成功 2-失败', 
`operator` varchar(64) NULL COMMENT '操作者', 
`error_code` varchar(64) NULL COMMENT '错误码', 
`alias_name` varchar(32) NULL COMMENT '用户别名', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
`contact` varchar(256) NULL COMMENT '联系地址|联系电话', 
`pause_flag` tinyint(4) NULL COMMENT '中止标记', 
`features` varchar(2000) NULL COMMENT '扩展字段', 
`is_deleted` tinyint(4) NULL COMMENT '删除标记', 
`event_history` varchar(2048) NULL COMMENT '变更事件历史', 
`pre_auth_id` bigint(20) NULL COMMENT '资金预授权资金单id', 
`idcard_type` tinyint(4) NULL COMMENT '证件类型', 
`idcard_id` varchar(64) NULL COMMENT '用户证件id，需要加密', 
`idcard_name` varchar(128) NULL COMMENT '用户真名', 
PRIMARY KEY (`id`), 
UNIQUE `uk_gov_bid_foregift_itemid_aliasname` (`item_id`, `alias_name`), 
KEY `idx_gov_bid_foregift_buyerid` (`buyer_id`), 
KEY `idx_bidstype` (`buyer_id`, `status`, `type`)
)  AUTO_INCREMENT = 487983 CHARSET = utf8 COMMENT = '司法拍卖押金表';
CREATE TABLE if not exists gov_bid_spc_user (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`bid_auction_id` bigint(20) UNSIGNED NOT NULL COMMENT '拍品id', 
`name` varchar(512) NOT NULL COMMENT '用户姓名', 
`id_card_num` varchar(512) NOT NULL COMMENT '身份证号', 
`deleted` tinyint(4) NOT NULL COMMENT '是否被删除，1表示被删除，0表示正常', 
`type` bigint(20) UNSIGNED NOT NULL COMMENT '特殊用户的类型，目前只有黑名单，0表示黑名单类型', 
`id_card_type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '证件类型(1表示企业营业执照 ，2身份证，3台胞证，4港澳，5护照等)', 
PRIMARY KEY (`id`), 
KEY `bid_auction_id_type` (`bid_auction_id`, `type`)
)  AUTO_INCREMENT = 9622 CHARSET = utf8 COMMENT = '拍卖特殊用户（黑名单）';
CREATE TABLE if not exists gov_call4foregift (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`type_id` int(11) NOT NULL COMMENT '0司法，11/12/13资产', 
`buyer_id` bigint(20) UNSIGNED NOT NULL COMMENT '买家id', 
`buyer_nick` varchar(64) NOT NULL COMMENT '买家nick', 
`buyer_mobile` varchar(32) NULL COMMENT '买家手机号', 
`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '宝贝Id', 
`item_title` varchar(256) NULL COMMENT '宝贝标题', 
`item_url` varchar(128) NULL COMMENT '宝贝链接', 
`foregift_create_time` datetime NOT NULL COMMENT '交保时间', 
`foregift_amount` bigint(20) UNSIGNED NOT NULL COMMENT '交保金额，单位分', 
`foregitf_from` varchar(10) NULL COMMENT '来源，pc 或 wap，需要解析gov_bid_foregift表中的features字段，获取属性f_from的值', 
`start_time` datetime NULL COMMENT '开拍时间', 
`end_time` datetime NULL COMMENT '结束时间', 
`cat_id` int(11) NULL COMMENT '类目Id', 
`cat_name` varchar(16) NULL COMMENT '类目名称', 
`foregift_id` bigint(20) UNSIGNED NULL COMMENT '保证金记录的唯一Id', 
`version` int(11) NOT NULL COMMENT '记录是哪次任务产生的', 
`score` int(11) NULL COMMENT '此条交保记录外呼的分数', 
`op_type` int(11) NULL COMMENT '相对上次扫描本记录是新增、修改还是删除', 
`append_info` varchar(512) NULL COMMENT '附加信息', 
PRIMARY KEY (`id`), 
UNIQUE `idx_biv` (`buyer_id`, `item_id`, `version`), 
KEY `idx_v` (`version`)
)  AUTO_INCREMENT = 6453 CHARSET = utf8 COMMENT = '400大客户外呼记录表';
CREATE TABLE if not exists gov_court_address (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`province` varchar(256) NULL COMMENT '省', 
`city` varchar(256) NULL COMMENT '市', 
`area` varchar(256) NULL COMMENT '区（县）', 
`user_id` bigint(20) UNSIGNED NULL COMMENT '法院用户ID', 
`user_nick` varchar(32) NULL COMMENT '法院名称 - uic一致冗余', 
`parent_user_id` bigint(20) UNSIGNED NULL COMMENT '父级法院(user_id)', 
`char_1` varchar(512) NULL COMMENT 'backup', 
`number_1` bigint(20) UNSIGNED NULL COMMENT 'backup', 
`province_id` bigint(20) UNSIGNED DEFAULT '0' COMMENT '省division_id(行政层级2)', 
`city_id` bigint(20) UNSIGNED DEFAULT '0' COMMENT '市division_id((行政层级3)', 
`area_id` bigint(20) UNSIGNED DEFAULT '0' COMMENT '区/县divsion_id(行政层级4)', 
`gov_settled_id` bigint(20) UNSIGNED NULL COMMENT '关联gov_judicial_settled表的外键id', 
PRIMARY KEY (`id`), 
KEY `idx_gsid` (`gov_settled_id`), 
KEY `idx_user_id` (`user_id`)
)  AUTO_INCREMENT = 1079 CHARSET = utf8 COMMENT = '司法拍卖法院地域层级关系';
CREATE TABLE if not exists gov_court_paimai_summary (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`court_id` bigint(20) UNSIGNED NOT NULL COMMENT '法院id', 
`court_nick` varchar(118) NOT NULL COMMENT '法院名称', 
`month` int(10) UNSIGNED NOT NULL COMMENT '统计的月份', 
`paimai_num` int(10) UNSIGNED NULL COMMENT '开拍次数（除了待发布的）', 
`paimai_extra_num` int(10) UNSIGNED NULL COMMENT '开拍标的数', 
`deal_extra_num` int(10) UNSIGNED NULL COMMENT '成交标的数', 
`notify_user_num` bigint(20) UNSIGNED NULL COMMENT '提醒人数', 
`pay_foregift_num` bigint(20) UNSIGNED NULL COMMENT '缴纳保证金人数', 
`paimai_user_num` bigint(20) UNSIGNED NULL COMMENT '参拍人数', 
`foregift_total` bigint(20) UNSIGNED NULL COMMENT '保证金额度', 
`deal_money_total` bigint(20) UNSIGNED NULL COMMENT '成交金额', 
`deal_percent` varchar(10) NULL COMMENT '成交率（小数点二位的格式）', 
`premium_rate` varchar(10) NULL COMMENT '溢价率（小数点二位的格式）', 
`extinfo` varchar(4000) NULL COMMENT '扩展信息', 
`version` bigint(20) UNSIGNED NULL COMMENT '版本号', 
`last_scan_time` datetime NULL COMMENT '上次统计标物的时间', 
`look_user_num` bigint(20) UNSIGNED NULL COMMENT '围观人数', 
`complete` int(11) DEFAULT '0' COMMENT '数据是否完整，0-不完整，1-完整', 
PRIMARY KEY (`id`), 
UNIQUE `idx_id_month` (`court_id`, `month`), 
KEY `idx_month` (`month`), 
KEY `idx_last_scan_time` (`last_scan_time`), 
KEY `idx_c_complete` (`court_id`, `complete`)
)  AUTO_INCREMENT = 15852 CHARSET = utf8 COMMENT = '法院拍卖数据摘要';
CREATE TABLE if not exists gov_court_shorturl (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) NULL COMMENT '淘宝用户id', 
`court_name` varchar(118) NULL COMMENT '法院的名称（旺旺名）', 
`short_url` varchar(118) NULL COMMENT '短链地址', 
`operator` varchar(118) NULL COMMENT '短链接最近一次修改人', 
`status` tinyint(4) NULL COMMENT '状态（0,：初始化，1,：生效，-1：失效）', 
PRIMARY KEY (`id`), 
KEY `pri_short_url` (`short_url`), 
KEY `pri_user_id` (`user_id`)
)  AUTO_INCREMENT =200 CHARSET = utf8 COMMENT = '法院短链的存储表';
CREATE TABLE if not exists gov_extra_data_detail (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`court_id` bigint(20) UNSIGNED NOT NULL COMMENT '发布法院id', 
`extra_id` bigint(20) UNSIGNED NOT NULL COMMENT '拍品id', 
`pub_court_nick` varchar(118) NULL COMMENT '发布法院名称', 
`pub_court_location` varchar(30) NULL COMMENT '发布法院所在地区', 
`case_no` varchar(118) NULL COMMENT '案号', 
`auction_starts` datetime NULL COMMENT '拍卖开始时间', 
`auction_ends` datetime NULL COMMENT '拍卖结束时间', 
`circ` varchar(10) NULL COMMENT '拍卖阶段', 
`extra_title` varchar(118) NULL COMMENT '拍卖名称', 
`extra_type` varchar(10) NULL COMMENT '拍品类型（如，房产）', 
`extra_location` char(30) NULL COMMENT '拍品所在地', 
`look_user_num` int(10) UNSIGNED NULL COMMENT '围观人次', 
`sub_notify_user_num` int(10) UNSIGNED NULL COMMENT '订阅提醒人数', 
`apply_user_num` int(10) UNSIGNED NULL COMMENT '报名人数', 
`bid_user_num` int(10) UNSIGNED NULL COMMENT '出价人数', 
`bid_num` int(10) UNSIGNED NULL COMMENT '出价次数', 
`start_price` bigint(20) UNSIGNED NULL COMMENT '起拍价	(cent)', 
`consult_price` bigint(20) NULL COMMENT '评估价	(cent)', 
`deal_price` bigint(20) UNSIGNED NULL COMMENT '成交价	(cent)', 
`pai_mai_result` varchar(10) NULL COMMENT '拍卖结果', 
`premium_rate` varchar(10) NULL COMMENT '溢价率(两位小数点格式)', 
`parent_extra_id` bigint(20) UNSIGNED NULL COMMENT '上一拍的拍品id', 
`root_extra_id` bigint(20) UNSIGNED NULL COMMENT '第一次拍卖的id', 
`extinfo` varchar(2000) NULL COMMENT '扩展信息', 
`version` bigint(20) UNSIGNED NULL COMMENT '版本号', 
`foregift` bigint(20) UNSIGNED NULL COMMENT '保证金	(cent)', 
`cat_id` bigint(20) UNSIGNED NULL COMMENT '类目ID', 
PRIMARY KEY (`id`), 
UNIQUE `idx_extra_id` (`extra_id`), 
KEY `idx_auction_starts` (`auction_starts`), 
KEY `idx_court_id` (`court_id`), 
KEY `idx_ends` (`court_id`, `auction_ends`), 
KEY `idx_start` (`court_id`, `auction_starts`)
)  AUTO_INCREMENT = 244202 CHARSET = utf8 COMMENT = '司法标物拍卖的数据明细';
CREATE TABLE if not exists gov_high_court (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`court_nick` varchar(200) NOT NULL COMMENT '法院名称', 
`court_account` varchar(200) NOT NULL COMMENT '法院账号', 
`prov` varchar(128) NULL COMMENT '所在省', 
`city` varchar(128) NULL COMMENT '所在市', 
`sub_courts_id` varchar(4000) NULL COMMENT '下属法院（id,id,id）', 
`extinfo` varchar(2000) NULL COMMENT '扩展信息', 
`version` bigint(20) UNSIGNED NOT NULL COMMENT '版本号', 
`court_id` bigint(20) UNSIGNED NOT NULL COMMENT '法院用户id', 
PRIMARY KEY (`id`), 
KEY `idx_court_nick` (`court_nick`), 
KEY `idx_court_account` (`court_account`), 
KEY `idx_court_id` (`court_id`), 
KEY `idx_gmt_create` (`gmt_create`)
)  AUTO_INCREMENT = 59 CHARSET = utf8 COMMENT = '高院用户表';
CREATE TABLE if not exists gov_judicial_settled (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`name` varchar(32) NOT NULL COMMENT '法院名称，即淘宝账号，跟uic一样32的长度', 
`email` varchar(64) NULL COMMENT '法院邮箱', 
`organization_code` varchar(64) NOT NULL COMMENT '法院组织机构代码', 
`organization_address` varchar(512) NOT NULL COMMENT '组织机构代码证详细地址', 
`legal_name` varchar(32) NOT NULL COMMENT '法人代表姓名', 
`legal_identity` varchar(64) NOT NULL COMMENT '法人代表身份证，需加密', 
`address` varchar(512) NOT NULL COMMENT '法院联系地址', 
`phone` varchar(32) NOT NULL COMMENT '法院联系电话', 
`contact_name` varchar(32) NULL COMMENT '法院联系接口人', 
`contact_phone` varchar(32) NULL COMMENT '法院联系人手机', 
`fax` varchar(32) NOT NULL COMMENT '传真', 
`organization_picurl` varchar(256) NOT NULL COMMENT '组织机构代码证扫描件', 
`parent_bodies` varchar(256) NULL COMMENT '法院上级机构', 
`bank_account_name` varchar(64) NOT NULL COMMENT '开户名称', 
`bank_province` varchar(64) NULL COMMENT '开户银行所在省份', 
`bank_city` varchar(64) NULL COMMENT '开户银行所在城市', 
`bank_name` varchar(64) NOT NULL COMMENT '开户银行名称', 
`bank_branch_name` varchar(64) NOT NULL COMMENT '开户支行名称', 
`bank_account_num` varchar(64) NOT NULL COMMENT '法院银行帐号', 
`status` tinyint(4) NOT NULL COMMENT '帐号状态', 
`valid_date` date NULL COMMENT '帐号有效期', 
`export_info` varchar(256) NULL COMMENT '文件导出信息', 
`is_deleted` tinyint(4) NOT NULL COMMENT '逻辑删除位', 
`user_id` bigint(20) NULL COMMENT '淘宝用户id', 
`organization_valid_time` datetime NULL COMMENT '法院组织机构代码证有效期', 
`type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '入驻类型:0=司法,1=资产政府类,2=资产商业类,3=拍卖行', 
`data` varchar(2048) NULL COMMENT '入驻信息记录', 
`amount` bigint(20) UNSIGNED NULL COMMENT '入驻需要缴纳的保证金', 
`attribute` varchar(2048) NULL COMMENT '扩展字段，json格式', 
PRIMARY KEY (`id`), 
KEY `k_name` (`name`), 
KEY `idx_name` (`name`), 
KEY `idx_email` (`email`), 
KEY `idx_uid` (`user_id`), 
KEY `idx_bac` (`bank_account_num`), 
KEY `idx_lid` (`legal_identity`), 
KEY `idx_status_gctime` (`status`, `gmt_create`)
)  AUTO_INCREMENT = 1191 CHARSET = utf8 COMMENT = '司法拍卖法院入驻信息表';
CREATE TABLE if not exists gov_priority_bid (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '商品id', 
`round_index` int(11) NOT NULL COMMENT '第几轮竞价', 
`first_winner` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '首轮竞价优胜者', 
`final_winner` bigint(20) UNSIGNED DEFAULT '0' COMMENT '最终优胜者', 
`apply_priority` varchar(2048) NULL COMMENT '报名的优先购买人', 
`valid_users` varchar(2048) NULL COMMENT '本轮有效的优先人，不包括首轮出价者', 
`accept_users` varchar(2048) NULL COMMENT '本轮应价的用户', 
`give_up_users` varchar(2048) NULL COMMENT '本轮放弃的用户', 
`stage` tinyint(4) NOT NULL COMMENT '优先竞买阶段状态：0:优先人要价阶段,1:首轮胜出者出价阶段,2:优先人抽签阶段,3:结束', 
`version` int(11) DEFAULT '0' COMMENT '更新时使用的版本号', 
`gmt_round_end` datetime NOT NULL COMMENT '本轮应该结束的时间，不一定是实际结束时间', 
`is_deleted` tinyint(4) DEFAULT '0' NOT NULL COMMENT '逻辑删除，0:未删除，1:已删除', 
`first_alias_name` varchar(32) NULL COMMENT '首轮优胜者的竞拍号', 
`draw_lots_user` varchar(2048) NULL COMMENT '抽签的用户名单，只在抽奖阶段才有值', 
`time_out_users` varchar(2048) NULL COMMENT '超时放弃的用户名单', 
PRIMARY KEY (`id`), 
UNIQUE `item_round` (`item_id`, `round_index`)
)  AUTO_INCREMENT = 32274 CHARSET = utf8 COMMENT = '优先人阶段的应价记录';
CREATE TABLE if not exists gov_project_notice (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户id', 
`title` varchar(256) NOT NULL COMMENT '项目公告标题', 
`status` tinyint(4) NULL COMMENT '公告状态（初始化：0，发布：1，撤下：2）', 
`content_url` varchar(256) NULL COMMENT '公告内容tfs地址', 
`last_modified` datetime NOT NULL COMMENT '最后编辑时间', 
`has_attach` tinyint(4) NULL COMMENT '是否有附件，0没有，1有', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
`publish_time` datetime NULL, 
`case_no` varchar(256) NULL COMMENT '案号', 
`type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '入驻类型:0=司法,1=资产政府类,2=资产商业类,3=拍卖行', 
`is_deleted` tinyint(4) DEFAULT '0' NOT NULL COMMENT '逻辑删除，0:未删除，1:已删除', 
PRIMARY KEY (`id`), 
KEY `idx_userid_status` (`user_id`, `status`), 
KEY `idx_status_id` (`status`, `id`)
)  AUTO_INCREMENT = 153436 CHARSET = utf8 COMMENT = '司法拍卖项目公告表';
CREATE TABLE if not exists gov_sub_to_high_court (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`sub_court_nick` varchar(200) NOT NULL COMMENT '下属法院名称', 
`high_court` varchar(300) NULL COMMENT '所属高院（id:nick,id:nick）,一个高院可以对应多个执行法院', 
`extinfo` varchar(2000) NULL COMMENT '扩展信息', 
`sub_court_accout` varchar(118) NOT NULL COMMENT '下属法院账号', 
`version` bigint(20) UNSIGNED NOT NULL COMMENT '版本号', 
`sub_court_id` bigint(20) UNSIGNED NOT NULL COMMENT '下属法院用户id', 
PRIMARY KEY (`id`), 
KEY `idx_sub_court_nick` (`sub_court_nick`), 
KEY `idx_sub_court_account` (`sub_court_accout`), 
KEY `idx_sub_court_id` (`sub_court_id`)
)  AUTO_INCREMENT = 603 CHARSET = utf8 COMMENT = '用于根据下属法院模糊搜索高院';
CREATE TABLE if not exists gov_user_verification (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '淘宝用户id', 
`alipay_id` varchar(32) NOT NULL COMMENT '支付宝id', 
`idcard_name` varchar(128) NULL COMMENT '用户真名', 
`idcard_id` varchar(64) NULL COMMENT '用户证件id，需加密', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`idcard_type` tinyint(4) NULL COMMENT '证件类型', 
PRIMARY KEY (`id`), 
KEY `idx_gov_user_verif_userid` (`user_id`)
)  AUTO_INCREMENT = 226629 CHARSET = utf8 COMMENT = '司法拍卖用户信息表';
CREATE TABLE if not exists merchant_notice (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) NOT NULL COMMENT '处置主体用户ID', 
`name` varchar(32) NOT NULL COMMENT '处置主体名称', 
`title` varchar(128) NOT NULL COMMENT '公告标题', 
`type` bigint(20) NOT NULL COMMENT '资产类型', 
`subtype` varchar(512) NULL COMMENT '子类型，逗号分隔', 
`location` varchar(32) NOT NULL COMMENT '所在地，区域码', 
`contacts` varchar(2048) NULL COMMENT '联系人，json格式', 
`pics` varchar(2048) NULL COMMENT '图片，逗号分隔', 
`video_url` varchar(512) NULL COMMENT '视频地址', 
`summary` varchar(2048) NULL COMMENT '摘要，搜索结果展示', 
`detail_url` varchar(256) NOT NULL COMMENT '详情地址', 
`attachments` varchar(2048) NULL COMMENT '附件,json格式，需要存储原文件名', 
`lower_price` bigint(20) NOT NULL COMMENT '参考价值下限(单位：元)', 
`upper_price` bigint(20) NOT NULL COMMENT '参考价值上限(单位：元)', 
`start_time` datetime NOT NULL COMMENT '公告开始时间（当前时间）', 
`end_time` datetime NOT NULL COMMENT '公告结果时间', 
`interval_day` int(11) NOT NULL COMMENT '公告间隔天数', 
`status` int(11) NOT NULL COMMENT '状态1-	编辑中2-	招商中3-	已转竞价4-	线下已处置5-	已结束6-	已撤回 -1已删除', 
`withdraw_reason` varchar(2048) NULL COMMENT '撤回理由', 
`intention_person` varchar(2048) NULL COMMENT '意向人，json格式', 
`attribute` varchar(2048) NULL COMMENT '扩展字段', 
`pic_count` int(11) NOT NULL COMMENT '图片数', 
`has_video` tinyint(4) NOT NULL COMMENT '是否有视频0-无，1-有', 
`intention_person_count` int(11) NOT NULL COMMENT '意向人数', 
`prov` varchar(64) NOT NULL COMMENT '省', 
`city` varchar(64) NOT NULL COMMENT '市', 
PRIMARY KEY (`id`), 
KEY `user_status_idx` (`user_id`, `status`), 
KEY `status_end_idx` (`status`, `end_time`)
)  AUTO_INCREMENT = 592 CHARSET = utf8 COMMENT = '招商公告';
CREATE TABLE if not exists sub_account (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`sub_account_id` bigint(20) UNSIGNED NOT NULL COMMENT '子账号ID', 
`parent_account_id` bigint(20) UNSIGNED NOT NULL COMMENT '父账号ID', 
`master_account_id` bigint(20) UNSIGNED NOT NULL COMMENT '根账号ID（入驻账号）', 
`status` int(11) NOT NULL COMMENT '状态：1（正常），-1（删除）', 
`app` int(10) UNSIGNED NOT NULL COMMENT '所属应用', 
`description` varchar(512) NULL COMMENT '账号描述', 
`char_1` varchar(1024) NULL COMMENT '扩展备用字段', 
`sub_account_nick` varchar(64) NOT NULL COMMENT '子账号NICK冗余', 
PRIMARY KEY (`id`), 
KEY `sai_app_index` (`sub_account_id`, `app`), 
KEY `sai_status_app_index` (`sub_account_id`, `status`, `app`), 
KEY `mai_status_app_index` (`master_account_id`, `status`, `app`), 
KEY `pai_status_app_index` (`parent_account_id`, `status`, `app`)
)  AUTO_INCREMENT = 29 CHARSET = utf8 COMMENT = '主子账号信息';
CREATE TABLE if not exists sub_account_auth (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`sub_account_id` bigint(20) UNSIGNED NOT NULL COMMENT '子账号ID', 
`auth_type` int(10) UNSIGNED NOT NULL COMMENT '权限的类型：数据（1），操作（2）', 
`auth_code` int(10) UNSIGNED NOT NULL COMMENT '权限code', 
`status` int(11) NOT NULL COMMENT '该条权限的状态：正常（1），删除（-1）', 
`app` int(10) UNSIGNED NOT NULL COMMENT '所属应用', 
`char_1` varchar(1024) NULL COMMENT '扩展备用字段', 
PRIMARY KEY (`id`), 
KEY `sai_status_app_index` (`sub_account_id`, `status`, `app`), 
KEY `sai_type_code_app_index` (`sub_account_id`, `auth_type`, `auth_code`, `app`), 
KEY `sai_status_type_code_app_index` (`sub_account_id`, `status`, `auth_type`, `auth_code`, `app`), 
KEY `sai_status_type_app_index` (`sub_account_id`, `status`, `auth_type`, `app`)
)  AUTO_INCREMENT = 202 CHARSET = utf8 COMMENT = '账号分权权限信息表';
CREATE TABLE if not exists sub_account_resource (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`sub_account_id` bigint(20) UNSIGNED NOT NULL COMMENT '子账号ID', 
`master_account_id` bigint(20) UNSIGNED NOT NULL COMMENT '入驻账号ID', 
`app` int(10) UNSIGNED NOT NULL COMMENT '所属应用', 
`resource_id` bigint(20) UNSIGNED NOT NULL COMMENT '资源ID', 
`resource_type` int(10) UNSIGNED NOT NULL COMMENT '资源类型', 
`resource_title` varchar(512) NULL COMMENT '资源标题', 
`char_1` varchar(1024) NULL COMMENT '扩展备用字段', 
PRIMARY KEY (`id`), 
UNIQUE `ri_type_app_index` (`resource_id`, `resource_type`, `app`), 
KEY `sai_rt_type_app_index` (`sub_account_id`, `resource_title`, `resource_type`, `app`), 
KEY `sai_type_app` (`sub_account_id`, `resource_type`, `app`)
)  AUTO_INCREMENT = 398 CHARSET = utf8 COMMENT = '子账号资源表';
