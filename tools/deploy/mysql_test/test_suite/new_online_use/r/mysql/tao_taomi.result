CREATE TABLE if not exists taomi_job_trigger_init (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`server_num` int(10) UNSIGNED NOT NULL COMMENT '初始化job的机器数，任务运行后递减1.为0时不运行job', 
`job_name` varchar(32) NOT NULL COMMENT '任务名称', 
PRIMARY KEY (`id`), 
KEY `job_name` (`job_name`)
)  AUTO_INCREMENT = 2 CHARSET = utf8 COMMENT = '淘米任务调度表';
CREATE TABLE if not exists taomi_source_shop_dump (
`shop_id` bigint(20) UNSIGNED NOT NULL COMMENT '主键、店铺ID', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
`title` varchar(255) NOT NULL COMMENT '店铺名称', 
`tfs_path` varchar(255) NOT NULL COMMENT '店铺介绍和店铺公告的TFS路径', 
`process` tinyint(4) DEFAULT '0' NOT NULL COMMENT '处理进度：0初始化，1被锁定，2发送完成', 
PRIMARY KEY (`shop_id`), 
KEY `user_id` (`user_id`), 
KEY `process` (`process`)
)  CHARSET = utf8 COMMENT = '店铺信息回流表，不建议前台应用直接读取';
CREATE TABLE if not exists taomi_task_analyze (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`task_id` bigint(20) UNSIGNED NOT NULL COMMENT '任务表ID', 
`analyze_status` tinyint(4) DEFAULT '1' COMMENT '分析状态：1、开始分析；2、不需要处理；3、需要处理；4、处理完成', 
`old_context`varchar(100)COMMENT '分析前的样本', 
`new_context`varchar(100)COMMENT '分析后的结果', 
PRIMARY KEY (`id`), 
KEY `k_tid` (`task_id`)
)  AUTO_INCREMENT = 45237 CHARSET = utf8 COMMENT = '任务分析处理表';
CREATE TABLE if not exists taomi_task_trigger_sender (
`task_id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键、全局标识一个任务', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`task_type` varchar(12) NOT NULL COMMENT '任务类型：shop - 店铺', 
`task_status` tinyint(4) DEFAULT '1' NOT NULL COMMENT '任务进度：1、已经发送至分析队列；2、任务挂起；3、任务完成', 
`task_detail` varchar(255) NULL COMMENT '任务详情，如果任务挂起，可用于保存挂起原因。', 
`task_context`varchar(100)COMMENT '任务上下文详情', 
`task_context_pk` bigint(20) UNSIGNED NULL COMMENT '任务上下文用于检索的标识：用户维度则为user_id、shop维度可为shop_id', 
PRIMARY KEY (`task_id`), 
KEY `task_context_pk` (`task_context_pk`)
)  AUTO_INCREMENT = 76273131 CHARSET = utf8 COMMENT = '任务触发队列';
