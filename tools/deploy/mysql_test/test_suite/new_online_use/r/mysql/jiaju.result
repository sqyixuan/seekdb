SELECT a.index_name AS index_name, a.column_name AS column_name, b.column_type AS column_type, b.ordinal_position AS column_index FROM (SELECT table_schema, table_name, index_name, column_name, seq_in_index FROM information_schema.statistics WHERE index_name = "3" AND non_unique = 1 AND table_schema = "3" AND table_name = "3" ) a LEFT JOIN (SELECT table_schema, table_name, column_name, column_type, ordinal_position FROM information_schema.columns WHERE table_schema = "3" AND table_name = "3" ) b ON a.table_schema = b.table_schema AND a.table_name = b.table_name AND a.column_name = b.column_name ORDER BY index_name ASC, seq_in_index ASC;
index_name	column_name	column_type	column_index
