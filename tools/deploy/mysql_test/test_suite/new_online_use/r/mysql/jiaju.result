create database jiaju;
use jiaju;
CREATE TABLE if not exists jiaju_delivery_distribution_fee (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`template_id` bigint(20) NOT NULL COMMENT '模板ID', 
`province_id` bigint(20) NULL COMMENT '省ID', 
`city_id` bigint(20) NULL COMMENT '城市ID', 
`district_id` bigint(20) NOT NULL COMMENT '地区ID', 
`start_standard` int(11) NULL COMMENT '首费标准', 
`start_fee` int(11) NULL COMMENT '首费', 
`add_standard` int(11) NULL COMMENT '增费标准', 
`add_fee` int(11) NULL COMMENT '增费', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
PRIMARY KEY (`id`), 
KEY `ind_jiaju_delivery_distribution_fee_tid` (`template_id`, `district_id`)
)  AUTO_INCREMENT = 55449730 CHARSET = utf8 COMMENT = '配送模板，数据量kw级别';
CREATE TABLE if not exists jiaju_delivery_setup_fee (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`template_id` bigint(20) NOT NULL COMMENT '模板ID', 
`category_id` bigint(20) NOT NULL COMMENT '类目ID', 
`province_id` bigint(20) NULL COMMENT '省ID', 
`city_id` bigint(20) NOT NULL COMMENT '城市ID', 
`start_standard` int(11) NULL COMMENT '首费标准', 
`start_fee` int(11) NULL COMMENT '首费', 
`add_standard` int(11) NULL COMMENT '增费标准', 
`add_fee` int(11) NULL COMMENT '增费', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
`property_id` bigint(20) DEFAULT '0' COMMENT '类目属性ID', 
`value_id` bigint(20) DEFAULT '0' COMMENT '类目属性值ID', 
PRIMARY KEY (`id`), 
KEY `ind_jiaju_delivery_setup_fee_tid` (`template_id`, `category_id`, `city_id`)
)  AUTO_INCREMENT = 18600477 CHARSET = utf8 COMMENT = '安装费模板，数据量百万级别';
CREATE TABLE if not exists jiaju_delivery_template (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键，模板id', 
`user_id` bigint(20) NOT NULL COMMENT '用户ID', 
`service_type` tinyint(4) NOT NULL COMMENT '模板类型，1、配送模板，2、搬楼模板，3、安装模板', 
`valuation` tinyint(4) NOT NULL COMMENT '计费类型，1、按体积计费；2、按重量计费', 
`status` tinyint(4) NOT NULL COMMENT '0表示正常，1表示停用', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
PRIMARY KEY (`id`), 
KEY `ind_jiaju_delivery_template_uid` (`user_id`, `service_type`, `valuation`)
)  AUTO_INCREMENT = 89028 CHARSET = utf8 COMMENT = '模板，数据量50w级别';
CREATE TABLE if not exists jiaju_delivery_upstairs_fee (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`template_id` bigint(20) NOT NULL COMMENT '模板ID', 
`province_id` bigint(20) NULL COMMENT '省ID', 
`city_id` bigint(20) NULL COMMENT '城市ID', 
`start_standard` int(11) NULL COMMENT '首费标准', 
`start_fee` int(11) NULL COMMENT '首费', 
`add_standard` int(11) NULL COMMENT '增费标准', 
`add_fee` int(11) NULL COMMENT '增费', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
PRIMARY KEY (`id`), 
KEY `ind_jiaju_delivery_upstairs_fee_tid` (`template_id`, `city_id`)
)  AUTO_INCREMENT = 3632266 CHARSET = utf8 COMMENT = '搬楼模板，数据量10w级别';
CREATE TABLE if not exists jiaju_delivery_user (
`user_id` bigint(20) NOT NULL COMMENT '用户ID', 
`nick` varchar(45) NULL COMMENT '昵称', 
`type` tinyint(4) NULL COMMENT '用户类型，家居用户1', 
`status` tinyint(4) NULL COMMENT '状态，0正常，1禁用', 
`gmt_create` datetime NULL, 
`gmt_modified` datetime NULL, 
PRIMARY KEY (`user_id`)
)  CHARSET = utf8 COMMENT = '用户表，数据量10w级别';
CREATE TABLE if not exists seller_city (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家ID', 
`city_id` bigint(20) NOT NULL COMMENT '城市ID', 
`billing_type` varchar(7) NOT NULL COMMENT '计费方式', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
UNIQUE `uk_seller_city_scid` (`seller_id`, `city_id`)
)  AUTO_INCREMENT = 17190 CHARSET = utf8 COMMENT = '卖家与城市关联.及计费方式.';
CREATE TABLE if not exists seller_district_billing_by_count (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家ID', 
`city_id` bigint(20) NOT NULL COMMENT '城市ID', 
`district_id` bigint(20) NOT NULL COMMENT '城市区域ID', 
`tb_category_id` bigint(20) NOT NULL COMMENT '淘宝类目的叶子ID', 
`valve_1` int(11) NOT NULL COMMENT '阀值', 
`lower_valve_1` int(11) NOT NULL COMMENT '小于阀值', 
`upper_valve_1` int(11) NOT NULL COMMENT '大于阀值', 
`create_user` varchar(118) NOT NULL, 
`update_user` varchar(118) NOT NULL, 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
UNIQUE `uk_seller_district_billing_by_count_scdtid` (`seller_id`, `city_id`, `district_id`, `tb_category_id`)
)  AUTO_INCREMENT = 58116791 CHARSET = utf8 COMMENT = '卖家所涵盖的配送区域及收费(按件数)';
CREATE TABLE if not exists seller_district_billing_by_price (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家ID', 
`city_id` bigint(20) NOT NULL COMMENT '城市ID', 
`district_id` bigint(20) NOT NULL COMMENT '城市区域ID', 
`base_price_0` int(11) NOT NULL COMMENT '起步价', 
`valve_0` int(11) NOT NULL COMMENT '阀值', 
`lower_valve_0` int(11) NOT NULL COMMENT '小于阀值', 
`upper_valve_0` int(11) NOT NULL COMMENT '大于阀值', 
`create_user` varchar(118) NOT NULL, 
`update_user` varchar(118) NOT NULL, 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
UNIQUE `uk_seller_district_billing_by_price_scdid` (`seller_id`, `city_id`, `district_id`)
)  AUTO_INCREMENT = 86253 CHARSET = utf8 COMMENT = '卖家所涵盖的配送区域及收费(按计价)';
CREATE TABLE if not exists seller_setup_billing (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家ID', 
`city_id` bigint(20) NOT NULL COMMENT '城市ID', 
`tb_category_id` bigint(20) NOT NULL COMMENT '淘宝类目的叶子ID', 
`prop_value_id` bigint(20) NULL COMMENT '淘宝类目的属性ID. 例: 123654', 
`base_price` int(11) NOT NULL COMMENT '起价费用(分)', 
`privilege` tinyint(4) NOT NULL COMMENT '是否取消起价费用', 
`additional_price_per_good` float NOT NULL COMMENT '每件商品的安装费用', 
`create_user` varchar(118) NOT NULL, 
`update_user` varchar(118) NOT NULL, 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
UNIQUE `uk_seller_setup_billing_sctpid` (`seller_id`, `city_id`, `tb_category_id`, `prop_value_id`)
)  AUTO_INCREMENT = 13208359 CHARSET = utf8 COMMENT = '卖家所涵盖的安装区域及收费';
CREATE TABLE if not exists seller_upstairs (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家ID', 
`city_id` bigint(20) NOT NULL COMMENT '城市ID', 
`left_price` int(11) NOT NULL COMMENT '电梯费用', 
`floor_1` int(11) NOT NULL COMMENT '1楼', 
`floor_2` int(11) NOT NULL COMMENT '2楼', 
`floor_3` int(11) NOT NULL COMMENT '3楼', 
`floor_4` int(11) NOT NULL COMMENT '4楼', 
`floor_5` int(11) NOT NULL COMMENT '5楼', 
`floor_6` int(11) NOT NULL COMMENT '6楼', 
`floor_7` int(11) NOT NULL COMMENT '7楼', 
`floor_8` int(11) NOT NULL COMMENT '8楼', 
`floor_9` int(11) NOT NULL COMMENT '9楼', 
`floor_10` int(11) NOT NULL COMMENT '10楼', 
`create_user` varchar(118) NOT NULL, 
`update_user` varchar(118) NOT NULL, 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
UNIQUE `uk_seller_upstairs_scid` (`seller_id`, `city_id`)
)  AUTO_INCREMENT = 34816 CHARSET = utf8 COMMENT = '搬楼费用表';
SELECT a.id AS id, a.template_id AS templateid, a.province_id AS provinceid, a.city_id AS cityid, a.district_id AS districtid , a.start_standard AS startstandard, a.start_fee AS startfee, a.add_standard AS addstandard, a.add_fee AS addfee, a.gmt_create AS gmtcreate , a.gmt_modified AS gmtmodified FROM jiaju_delivery_distribution_fee a, jiaju_delivery_template b WHERE a.template_id = b.id AND b.user_id = 1 AND b.service_type = 1 AND b.valuation = 1 AND district_id = 1;
id	templateid	provinceid	cityid	districtid	startstandard	startfee	addstandard	addfee	gmtcreate	gmtmodified
SELECT a.id AS id, a.template_id AS templateid, a.province_id AS provinceid, a.city_id AS cityid, a.category_id AS categoryid , a.property_id AS propertyid, a.value_id AS valueid, a.start_standard AS startstandard, a.start_fee AS startfee, a.add_standard AS addstandard , a.add_fee AS addfee, a.gmt_create AS gmtcreate, a.gmt_modified AS gmtmodified FROM jiaju_delivery_setup_fee a, jiaju_delivery_template b WHERE a.template_id = b.id AND b.user_id = 1 AND b.service_type = 1 AND b.valuation = 1 AND city_id = 1 AND category_id = 1;
id	templateid	provinceid	cityid	categoryid	propertyid	valueid	startstandard	startfee	addstandard	addfee	gmtcreate	gmtmodified
SELECT id FROM jiaju_delivery_template WHERE user_id = 1 AND service_type = 1 AND valuation = 1 LIMIT 1;
id
