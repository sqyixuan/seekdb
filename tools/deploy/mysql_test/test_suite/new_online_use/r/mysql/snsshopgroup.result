CREATE TABLE if not exists apply_join (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`group_id` bigint(20) NOT NULL COMMENT '分表字段', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`status` int(11) NOT NULL COMMENT '状态', 
`content` varchar(1024) NULL COMMENT '申请理由', 
PRIMARY KEY (`id`), 
KEY `idx_gid_uid_stat` (`group_id`, `user_id`, `status`), 
KEY `idx_gid_gmtc` (`group_id`, `gmt_create`)
)  AUTO_INCREMENT = 1645713 CHARSET = utf8 COMMENT = '申请表';
CREATE TABLE if not exists check_in (
`id` bigint(20) NOT NULL COMMENT '自增主键', 
`group_id` bigint(20) NOT NULL COMMENT '圈子id', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`status` int(11) NOT NULL COMMENT '是否删除', 
PRIMARY KEY (`id`), 
KEY `idx_gmt_create` (`gmt_create`), 
KEY `idx_uid_gmt_create` (`gmt_create`, `group_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists daily_top_group (
`id` bigint(20) AUTO_INCREMENT NOT NULL, 
`tag` varchar(256) NOT NULL COMMENT '鍦堝瓙鏍囩1,2,4,6,7,8,11,56,68,89,435,4523', 
`group_id` bigint(20) NOT NULL COMMENT '鍦堝瓙id', 
`score` int(11) NOT NULL COMMENT '杩囩1,2,4,6,7,8,11,56,68,89,435,4523绾胯1,2,4,6,7,8,11,56,68,89,435,4523绠楀緱鍒扮殑鍦堝瓙寰楀垎', 
`follower_count` bigint(20) NOT NULL COMMENT '鍦堝瓙鐨勭矇涓濇暟', 
`item_count` int(11) NOT NULL COMMENT '鍦堝瓙涓1,2,4,6,7,8,11,56,68,89,435,4523殑瀹濊礉鏁', 
`item_shared_count` int(11) NOT NULL COMMENT '鍦堝瓙涓1,2,4,6,7,8,11,56,68,89,435,4523殑鍟嗗搧琚1,2,4,6,7,8,11,56,68,89,435,4523垎浜1,2,4,6,7,8,11,56,68,89,435,4523殑鎬绘1,2,4,6,7,8,11,56,68,89,435,4523鏁', 
`item_json` varchar(2048) NULL COMMENT '涓庡湀瀛愭爣绛剧浉鍚岀殑鍒嗕韩娆℃暟闈犲墠鐨勪竴浜涘晢鍝', 
`gmt_create` datetime NOT NULL COMMENT '璁板綍鍒涘缓鏃堕棿', 
`gmt_modified` datetime NOT NULL COMMENT '璁板綍鏈1,2,4,6,7,8,11,56,68,89,435,4523悗淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿', 
PRIMARY KEY (`id`), 
KEY `idx_daily_top_group_tag` (`tag`), 
KEY `idx_group_id` (`group_id`), 
KEY `idx_count_group_id_tag` (`item_shared_count`, `group_id`, `tag`)
)  AUTO_INCREMENT = 76898 CHARSET = utf8;
CREATE TABLE if not exists group_activity_group (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`group_id` bigint(20) NOT NULL COMMENT '小分队id', 
`support_num` bigint(20) DEFAULT '0' NOT NULL COMMENT '小分队获得的支持数量', 
`user_id` bigint(20) NOT NULL COMMENT '小分队队长user_id', 
`data_type` tinyint(4) NOT NULL COMMENT '数据类型；1-系统自动生成的，2-手工推荐的；', 
`status` tinyint(4) NOT NULL COMMENT '记录状态；1-正常，0-删除；', 
`faction_id` int(11) NOT NULL COMMENT '小分队所属的派系id', 
PRIMARY KEY (`id`), 
KEY `idx_status_gid` (`status`, `group_id`), 
KEY `idx_status_gmtc` (`status`, `gmt_create`), 
KEY `idx_gmtc` (`gmt_create`), 
KEY `idx_s_sn` (`status`, `support_num`), 
KEY `idx_status_uid` (`user_id`, `status`)
)  AUTO_INCREMENT = 286 CHARSET = utf8 COMMENT = '小分队参加活动数据表';
CREATE TABLE if not exists group_activity_item (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`item_id` bigint(20) NOT NULL COMMENT '宝贝id', 
`user_id` bigint(20) NOT NULL COMMENT '宝贝的添加者user_id', 
`item_type` smallint(6) NOT NULL COMMENT '宝贝的类型；个人报名-1，小分队报名-2', 
`support_num` bigint(20) DEFAULT '0' NOT NULL COMMENT '宝贝的支持人数', 
`status` tinyint(4) NOT NULL COMMENT '记录的状态；1-正常，2-删除；', 
`group_id` bigint(20) NULL COMMENT '宝贝所属的小分队id', 
`data_type` tinyint(4) NOT NULL COMMENT '数据类型；自动推荐-1，人工推荐-2；', 
`reason` varchar(1023) NULL COMMENT '宝贝的推荐理由', 
PRIMARY KEY (`id`), 
KEY `idx_group_id_status` (`group_id`, `status`), 
KEY `idx_status_gmt` (`status`, `gmt_create`), 
KEY `idx_s_i_type_uid` (`status`, `item_id`, `item_type`, `user_id`), 
KEY `idx_u_s` (`user_id`, `status`), 
KEY `idx_s_sn` (`status`, `support_num`)
)  AUTO_INCREMENT = 11264 CHARSET = utf8 COMMENT = '参加活动的商品详细报名数据';
drop table if exists group_ids;
CREATE TABLE if not exists group_ids (
`id` bigint(20) NOT NULL COMMENT '鍞1,2,4,6,7,8,11,56,68,89,435,4523竴涓婚敭瀛楁1,2,4,6,7,8,11,56,68,89,435,4523锛岀敱tddl璐熻矗鏇存柊', 
`name` varchar(32) NOT NULL COMMENT '涓婚敭鍚', 
`gmt_modified` datetime NOT NULL COMMENT '璁板綍鏈1,2,4,6,7,8,11,56,68,89,435,4523悗淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿', 
PRIMARY KEY (`name`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_index (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`group_id` bigint(20) NOT NULL COMMENT '圈子ID 分表字段', 
`ref_id` bigint(20) NOT NULL COMMENT '关联ID', 
`type` int(11) NOT NULL COMMENT '类型', 
`status` int(11) NOT NULL COMMENT '状态', 
PRIMARY KEY (`id`), 
KEY `idx_group_user_status_gmt` (`group_id`, `user_id`, `status`, `gmt_create`), 
KEY `k_gid_stat_gmtc` (`group_id`, `status`, `gmt_create`, `type`)
)  AUTO_INCREMENT = 21916766 CHARSET = utf8 COMMENT = '圈子索引表';
CREATE TABLE if not exists group_message_counter (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`type` tinyint(4) NULL COMMENT '类型', 
`group_id` bigint(20) NULL COMMENT '圈子id', 
`unread_num` int(11) NULL COMMENT '未读数', 
PRIMARY KEY (`id`), 
KEY `idx_3cols` (`user_id`, `type`, `group_id`)
)  AUTO_INCREMENT = 2600341 CHARSET = utf8 COMMENT = '小分队消息表';
CREATE TABLE if not exists group_recommend (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`group_id` bigint(20) NOT NULL COMMENT '小分队id', 
`type` int(11) NOT NULL COMMENT '推荐类型；类型id由业务控制', 
`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '记录状态；1为正常，0为删除', 
`rank` int(11) NOT NULL COMMENT '排序字段；', 
`extra` varchar(1024) NULL COMMENT '附加属性数据；亦可作为扩展字段使用', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录修改时间', 
PRIMARY KEY (`id`), 
KEY `idx_type_status` (`type`, `status`)
)  AUTO_INCREMENT = 1635 CHARSET = utf8 COMMENT = '存储经过推荐规则过滤出来的小分队数据';
CREATE TABLE if not exists group_task (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`group_id` bigint(20) NOT NULL COMMENT '分表字段', 
`number` varchar(10) NOT NULL COMMENT '编号', 
`status` int(11) NOT NULL COMMENT '状态', 
`prouser_id` bigint(20) NOT NULL COMMENT '任务发出者ID', 
`recuser_id` bigint(20) NOT NULL COMMENT '任务收到者ID', 
`count` int(11) NOT NULL COMMENT '任务次数', 
PRIMARY KEY (`id`), 
KEY `k_gid_rid_numb` (`group_id`, `recuser_id`, `number`), 
KEY `k_gid_rid_gmtc` (`group_id`, `recuser_id`, `gmt_create`)
)  AUTO_INCREMENT = 452350 CHARSET = utf8 COMMENT = '小分队任务表';
CREATE TABLE if not exists group_top_tags (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`group_id` bigint(20) UNSIGNED NOT NULL COMMENT '小分队id', 
`tag` varchar(32) NULL COMMENT '小分队标签', 
`cat_id` bigint(20) UNSIGNED NULL COMMENT '标签所属类目id', 
`rank` tinyint(3) UNSIGNED NULL COMMENT '标签在小分队中的排行', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
PRIMARY KEY (`id`), 
KEY `idx_gid_rank` (`group_id`, `rank`)
)  AUTO_INCREMENT = 4074784 CHARSET = utf8 COMMENT = '存放小分队的后台推荐标签信息；每天定期更新';
CREATE TABLE if not exists group_topic (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`content` varchar(1024) NOT NULL COMMENT '话题内容', 
`status` bigint(20) NULL COMMENT '状态', 
`group_id` bigint(20) NOT NULL COMMENT '圈子ID 分表字段', 
`item_count` int(11) DEFAULT '0' NOT NULL COMMENT '已推荐数', 
PRIMARY KEY (`id`), 
KEY `idx_group_user_status_gmt` (`group_id`, `user_id`, `status`, `gmt_create`), 
KEY `idx_group_status_gmt` (`group_id`, `status`, `gmt_create`)
)  AUTO_INCREMENT = 3254671 CHARSET = utf8 COMMENT = '话题';
CREATE TABLE if not exists invite_black (
`id` bigint(20) NOT NULL COMMENT '自增主键', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`group_id` bigint(20) NOT NULL COMMENT '圈子id', 
`type` tinyint(4) NOT NULL COMMENT '类型', 
`invite_user_id` bigint(20) NOT NULL COMMENT '邀请者的id', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
KEY `k_gid_iuid` (`group_id`, `invite_user_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists recent_visit (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`fgroup_id` bigint(20) NOT NULL COMMENT '分表字段', 
`tgroup_id` bigint(20) NOT NULL COMMENT '目标小分队', 
`num` bigint(20) NOT NULL COMMENT '访问数', 
`status` int(11) NOT NULL COMMENT '状态', 
PRIMARY KEY (`id`), 
KEY `fgroupid_tgroupid` (`fgroup_id`, `tgroup_id`), 
KEY `idx_fgid_num` (`fgroup_id`, `num`)
)  AUTO_INCREMENT = 1905122 CHARSET = utf8 COMMENT = '最近浏览小分队';
CREATE TABLE if not exists recommend_top_group (
`id` bigint(20) NOT NULL COMMENT '鑷1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523涓婚敭', 
`group_id` bigint(20) NOT NULL COMMENT '鎺ㄨ崘鐨勫湀瀛恑d', 
`gmt_create` datetime NOT NULL COMMENT '璁板綍鍒涘缓鏃堕棿', 
`gmt_modified` datetime NOT NULL COMMENT '璁板綍鏈1,2,4,6,7,8,11,56,68,89,435,4523悗淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿', 
`is_deleted` char(2) DEFAULT '0' NOT NULL COMMENT '0 鏈1,2,4,6,7,8,11,56,68,89,435,4523垹闄1,2,4,6,7,8,11,56,68,89,435,45231 宸插垹闄', 
`creator` varchar(200) NOT NULL COMMENT '鍒涘缓鑰', 
`item_json` varchar(2048) NULL, 
PRIMARY KEY (`id`), 
KEY `idx_gmt_create` (`gmt_create`), 
KEY `idx_gmt_modified` (`gmt_modified`), 
KEY `idx_is_deleted_group_id` (`is_deleted`, `group_id`), 
KEY `idx_is_delete_gmt_modified` (`is_deleted`, `gmt_modified`)
)  CHARSET = utf8;
CREATE TABLE if not exists shop_group (
`id` bigint(20) NOT NULL COMMENT '自增主键', 
`name` varchar(32) NOT NULL COMMENT '圈子的名字，不可重名', 
`tags` varchar(512) NULL COMMENT '圈子的标签', 
`privacy` tinyint(4) NOT NULL COMMENT '是否为公开圈子：0-私密, 1-公开,2-可申请加入', 
`creator` bigint(20) NOT NULL COMMENT '圈子的创建者', 
`status` tinyint(4) NOT NULL COMMENT '圈子的状态：0-未使用, 1-正在使用', 
`invite_link` varchar(256) NULL COMMENT '每个圈子对应的邀请链接', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`intro` varchar(512) NULL COMMENT '小分队介绍', 
`image` varchar(118) NULL COMMENT '小分队头像', 
PRIMARY KEY (`id`), 
KEY `idx_status` (`status`)
)  CHARSET = utf8;
CREATE TABLE if not exists shop_group_counter (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`group_id` bigint(20) DEFAULT '0' NOT NULL COMMENT '圈子id', 
`follower_count` bigint(20) DEFAULT '0' NOT NULL COMMENT '圈子粉丝数', 
`item_count` bigint(20) DEFAULT '0' NOT NULL COMMENT '宝贝数', 
`latest_item_updated` bigint(20) NULL COMMENT '最后一次有内容产生的时间', 
`latest_msg_updated` bigint(20) NULL COMMENT '最近一次留言时间', 
`collect_count` bigint(20) DEFAULT '0' NOT NULL COMMENT '宝贝被采集的总数', 
`member_count` int(11) DEFAULT '0' NOT NULL COMMENT '圈子的成员数', 
`topic_count` bigint(20) DEFAULT '0' NOT NULL COMMENT '话题数', 
`share_shop_count` bigint(20) DEFAULT '0' NOT NULL COMMENT '店铺分享数', 
PRIMARY KEY (`id`), 
UNIQUE `uk_group_counter_00_group_id` (`group_id`), 
KEY `idx_group_id_member_count` (`group_id`, `member_count`), 
KEY `idx_group_id_item_count` (`group_id`, `item_count`), 
KEY `idx_group_id_topic_count` (`group_id`, `topic_count`)
)  AUTO_INCREMENT = 7488151 CHARSET = utf8;
CREATE TABLE if not exists shop_group_item (
`id` bigint(20) NOT NULL COMMENT '自增主键', 
`group_id` bigint(20) NOT NULL COMMENT '圈子id', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`item_id` bigint(20) NOT NULL COMMENT '商品id', 
`item_title` varchar(120) NOT NULL COMMENT '商品标题', 
`item_pic` varchar(120) NOT NULL COMMENT '商品图片', 
`item_pic_width` int(11) NULL COMMENT '商品图片x', 
`item_pic_height` int(11) NULL COMMENT '商品图片y', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`item_price` bigint(20) NOT NULL COMMENT '商品价格', 
`content` varchar(1024) NULL COMMENT '评论内容', 
`extra_props` varchar(1024) NULL COMMENT '扩展属性', 
`status` int(11) NOT NULL COMMENT '记录状态', 
PRIMARY KEY (`id`), 
KEY `idx_group_id_item_id` (`group_id`, `item_id`, `status`), 
KEY `idx_group_id_uid_status` (`group_id`, `user_id`, `status`, `gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists shop_group_name (
`id` bigint(20) NOT NULL COMMENT '自增主键', 
`name_hash` int(11) NOT NULL COMMENT '圈名的hash code', 
`group_id` bigint(20) NOT NULL COMMENT '圈子的id', 
`status` tinyint(4) NOT NULL COMMENT '圈子的状态：1-未使用, 0-正在使用', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`name` varchar(32) NOT NULL COMMENT '圈名', 
PRIMARY KEY (`id`), 
UNIQUE `uk_group_name_00_name_hash` (`name_hash`, `group_id`), 
KEY `idx_group_name_hash_status_name` (`name_hash`, `status`, `name`)
)  CHARSET = utf8;
CREATE TABLE if not exists shop_group_shopshare (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`group_id` bigint(20) NOT NULL COMMENT '分表字段,小分队ID', 
`user_id` bigint(20) NOT NULL COMMENT '分享者用户ID', 
`shop_id` bigint(20) NOT NULL COMMENT '店铺ID', 
`content` varchar(1024) NULL COMMENT '分享内容', 
`extra_props` varchar(1024) NULL COMMENT '额外属性', 
`status` int(11) NOT NULL COMMENT '0正常,1删除', 
`seller_id` bigint(20) NOT NULL COMMENT '店铺卖家id', 
PRIMARY KEY (`id`), 
KEY `idx_gid_sid_stat` (`group_id`, `shop_id`, `status`), 
KEY `idx_gid_uid_stat` (`group_id`, `user_id`, `status`, `gmt_create`)
)  AUTO_INCREMENT = 1184145 CHARSET = utf8 COMMENT = '小分队店铺分享表';
CREATE TABLE if not exists shop_group_user (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`group_id` bigint(20) NOT NULL COMMENT '圈子id', 
`user_id` bigint(20) NOT NULL COMMENT '创建、加入或者关注圈子的用户id', 
`type` int(11) NOT NULL COMMENT '用来标记用户与圈子的关系，0-创建 1-加入 2-关注', 
`is_deleted` tinyint(4) NOT NULL COMMENT '是否已删除，0-未删除 1-已删除', 
`item_count` bigint(20) DEFAULT '0' NOT NULL COMMENT '圈子中某个用户贡献的宝贝数量', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`topic_count` bigint(20) DEFAULT '0' NOT NULL COMMENT '圈子中某个用户贡献的话题数量', 
`share_shop_count` bigint(20) DEFAULT '0' NOT NULL COMMENT '分享的店铺数量', 
PRIMARY KEY (`id`), 
UNIQUE `uk_group_user_00_group_id` (`group_id`, `user_id`), 
KEY `idx_groupid_type_isdeleted` (`group_id`, `type`, `is_deleted`), 
KEY `idx_gid_isdel_gmtc` (`group_id`, `is_deleted`, `gmt_create`)
)  AUTO_INCREMENT = 11046362 CHARSET = utf8;
CREATE TABLE if not exists top_group (
`id` bigint(20) NOT NULL COMMENT '鑷1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523涓婚敭', 
`tag` varchar(256) NOT NULL COMMENT '鏍囩1,2,4,6,7,8,11,56,68,89,435,4523', 
