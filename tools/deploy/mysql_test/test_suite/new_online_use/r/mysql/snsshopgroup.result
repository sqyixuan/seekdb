`follower_count` int(11) NOT NULL COMMENT '鍦堝瓙鐨勭矇涓濇暟', 
`item_count` int(11) NOT NULL COMMENT '鍦堝瓙涓1,2,4,6,7,8,11,56,68,89,435,4523殑瀹濊礉鏁', 
`gmt_create` datetime NOT NULL COMMENT '璁板綍鍒涘缓鏃堕棿', 
`gmt_modified` datetime NOT NULL COMMENT '璁板綍鏈1,2,4,6,7,8,11,56,68,89,435,4523悗淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿', 
`item_shared_count` int(11) NOT NULL COMMENT '鍦堝瓙涓1,2,4,6,7,8,11,56,68,89,435,4523殑鍟嗗搧琚1,2,4,6,7,8,11,56,68,89,435,4523垎浜1,2,4,6,7,8,11,56,68,89,435,4523殑鎬绘1,2,4,6,7,8,11,56,68,89,435,4523鏁', 
`item_json` varchar(2048) NOT NULL COMMENT '涓庡湀瀛愭爣绛剧浉鍚岀殑鍒嗕韩娆℃暟闈犲墠鐨勪竴浜涘晢鍝', 
PRIMARY KEY (`id`), 
UNIQUE `udx_gid` (`group_id`, `tag`), 
KEY `idx_top_group` (`tag`, `score`), 
KEY `idx_item_shared_count_group_id` (`item_shared_count`, `group_id`), 
KEY `k_score_gid` (`score`, `group_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists top_item (
`id` bigint(20) NOT NULL COMMENT '鑷1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523涓婚敭', 
`item_id` bigint(20) NOT NULL COMMENT '鍟嗗搧id', 
`item_link` varchar(512) NOT NULL COMMENT '鍟嗗搧閾炬帴', 
`shared_count` int(11) NOT NULL COMMENT '鍟嗗搧瀛樺湪浜庡1,2,4,6,7,8,11,56,68,89,435,4523灏戜釜涓嶅悓鐨勫湀瀛愪腑', 
`is_recommend` tinyint(4) DEFAULT '0' NOT NULL COMMENT '鏄1,2,4,6,7,8,11,56,68,89,435,4523惁琚1,2,4,6,7,8,11,56,68,89,435,4523帹鑽愪负绮惧搧 0-鍚1,2,4,6,7,8,11,56,68,89,435,45231-鏄', 
`gmt_create` datetime NOT NULL COMMENT '璁板綍鍒涘缓鏃堕棿', 
`gmt_modified` datetime NOT NULL COMMENT '璁板綍鏈1,2,4,6,7,8,11,56,68,89,435,4523悗淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿', 
PRIMARY KEY (`id`), 
UNIQUE `uk_top_item` (`item_id`), 
KEY `idx_top_item` (`is_recommend`, `shared_count`)
)  CHARSET = utf8;
CREATE TABLE if not exists topic_item (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`group_id` bigint(20) NOT NULL COMMENT '圈子id 分表字段', 
`item_id` bigint(20) NOT NULL COMMENT '商品id', 
`item_title` varchar(120) NOT NULL COMMENT '商品标题', 
`item_pic` varchar(120) NOT NULL COMMENT '商品图片', 
`item_pic_width` int(11) NULL COMMENT '商品图片x', 
`item_pic_height` int(11) NULL COMMENT '商品图片y', 
`item_price` bigint(20) NOT NULL COMMENT '商品价格', 
`content` varchar(1024) NULL COMMENT '推荐理由', 
`extra_props` varchar(1024) NULL COMMENT '扩展属性', 
`status` int(11) NOT NULL COMMENT '记录状态', 
`topic_id` bigint(20) NOT NULL COMMENT '话题ID', 
PRIMARY KEY (`id`), 
KEY `idx_gid_tid_gmtc` (`group_id`, `topic_id`, `gmt_create`, `status`)
)  AUTO_INCREMENT = 3425512 CHARSET = utf8 COMMENT = '推荐宝贝数据';
CREATE TABLE if not exists user_shop_group (
`id` bigint(20) NOT NULL COMMENT '自增主键', 
`user_id` bigint(20) NOT NULL COMMENT '用户的id', 
`group_id` bigint(20) NOT NULL COMMENT '用户创建、加入或者关注的圈子id', 
`type` int(11) NOT NULL COMMENT '用来标记用户与圈子的关系，0-创建 1-加入 2-关注', 
`is_deleted` tinyint(4) NOT NULL COMMENT '是否已删除 0-未删除 1-已删除', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
UNIQUE `uk_user_group_00_user_id` (`user_id`, `group_id`), 
KEY `idx_user_group_userid_type_isdeleted` (`user_id`, `type`, `is_deleted`)
)  CHARSET = utf8;
CREATE TABLE if not exists user_shop_group_counter (
`id` bigint(20) NOT NULL COMMENT '自增主键', 
`followed_count` int(11) DEFAULT '0' NOT NULL COMMENT '关注的圈子数', 
`joined_count` int(11) DEFAULT '0' NOT NULL COMMENT '加入的圈子数', 
`user_id` bigint(20) NOT NULL COMMENT '用户的id', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
UNIQUE `uk_use_id` (`user_id`), 
KEY `idx_user_id` (`user_id`, `followed_count`), 
KEY `idx_user_id_jc` (`user_id`, `joined_count`)
)  CHARSET = utf8;
CREATE TABLE if not exists win_record (
`id` bigint(20) AUTO_INCREMENT NOT NULL, 
`user_id` bigint(20) NOT NULL COMMENT '涓1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523鐢ㄦ埛', 
`nick` varchar(32) NOT NULL COMMENT '涓1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523鐢ㄦ埛nick', 
`prize_type` int(11) NOT NULL COMMENT '濂栧搧椤圭洰锛1,2,4,6,7,8,11,56,68,89,435,4523鍏冦1,2,4,6,7,8,11,56,68,89,435,452310鍏1,2,4,6,7,8,11,56,68,89,435,4523..5000鍏', 
`gmt_create` datetime NOT NULL COMMENT '璁板綍鍒涘缓鏃堕棿', 
`gmt_modified` datetime NOT NULL COMMENT '璁板綍鏈1,2,4,6,7,8,11,56,68,89,435,4523悗淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿', 
`group_id` bigint(20) DEFAULT '0' COMMENT '圈子id ', 
`type` tinyint(4) DEFAULT '0' COMMENT '抽奖类型', 
`item_id` bigint(20) DEFAULT '0' COMMENT '商品id', 
PRIMARY KEY (`id`), 
KEY `idx_uid_gmt` (`user_id`, `gmt_create`), 
KEY `idx_type_gmt_create` (`prize_type`, `gmt_create`), 
KEY `idx_type_group_id` (`type`, `group_id`)
)  AUTO_INCREMENT = 296183 CHARSET = utf8;
CREATE TABLE if not exists win_summary (
`id` bigint(20) NOT NULL COMMENT '鑷1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523涓婚敭', 
`win_count` int(11) NOT NULL COMMENT '涓1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523鎬绘暟', 
`gmt_create` datetime NOT NULL COMMENT '璁板綍鍒涘缓鏃堕棿', 
`gmt_modified` datetime NOT NULL COMMENT '璁板綍鏈1,2,4,6,7,8,11,56,68,89,435,4523悗淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿', 
PRIMARY KEY (`id`), 
KEY `idx_gmt_create` (`gmt_create`), 
KEY `idx_gmt_modified` (`gmt_modified`)
)  CHARSET = utf8;
SELECT id, group_id, follower_count, item_count, topic_count , member_count, share_shop_count FROM shop_group_counter WHERE group_id = 1;
id	group_id	follower_count	item_count	topic_count	member_count	share_shop_count
SELECT id, group_id, user_id, type, gmt_create , gmt_modified FROM user_shop_group WHERE user_id = 1 AND is_deleted = 1 ORDER BY gmt_create DESC;
id	group_id	user_id	type	gmt_create	gmt_modified
SELECT id, name, creator, privacy, invite_link , tags, gmt_create, gmt_modified, status, intro , image FROM shop_group WHERE status = 1 AND id IN (1,2,4,6,7,8,11,56,68,89,435,4523) LIMIT 1;
id	name	creator	privacy	invite_link	tags	gmt_create	gmt_modified	status	intro	image
SELECT s.item_id FROM (SELECT id FROM shop_group_item WHERE group_id = 1 AND status != 1 ORDER BY gmt_create DESC LIMIT 1, 1 ) a, shop_group_item s WHERE a.id = s.id;
item_id
SELECT id, name, creator, privacy, invite_link , tags, gmt_create, gmt_modified, status, intro , image FROM shop_group WHERE id = 1 AND status = 1;
id	name	creator	privacy	invite_link	tags	gmt_create	gmt_modified	status	intro	image
SELECT id, user_id, group_id, type, item_count , topic_count, share_shop_count, gmt_create, gmt_modified FROM shop_group_user WHERE group_id = 1 AND is_deleted = 1 AND type = 1 ORDER BY gmt_create DESC;
id	user_id	group_id	type	item_count	topic_count	share_shop_count	gmt_create	gmt_modified
SELECT COUNT(*) FROM apply_join WHERE group_id = 1 AND status = 1;
COUNT(*)
