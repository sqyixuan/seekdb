CREATE TABLE if not exists bbc_spu_seller (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`spu_id` bigint(20) UNSIGNED NOT NULL COMMENT 'SPU_ID', 
`seller_content` varchar(2000) NOT NULL COMMENT '店铺信息：包含店铺ID、分销SPU销量', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 23209198 CHARSET = utf8 COMMENT = '分销SPU对应的卖家';
CREATE TABLE if not exists black_list (
`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL, 
`right_name` varchar(30) NOT NULL COMMENT '权限名称', 
`user_id` bigint(20) NOT NULL, 
`gmt_create` datetime NOT NULL, 
`gmt_modify` datetime NOT NULL, 
PRIMARY KEY (`id`), 
UNIQUE `uk_up_uid` (`right_name`, `user_id`)
)  AUTO_INCREMENT = 315 CHARSET = utf8 COMMENT = '用户黑名单.用于禁止滥发广告等的恶意用户过滤. 由运营添加. 因此数量很少. 千级别.';
CREATE TABLE if not exists brand_activity (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`begin_time` datetime NOT NULL COMMENT '活动开始时间', 
`end_time` datetime NOT NULL COMMENT '活动结束时间', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`title` varchar(50) NOT NULL COMMENT '标题', 
`content` varchar(10240) NOT NULL COMMENT '内容', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`material` varchar(1024) NULL COMMENT '素材', 
`status` int(11) DEFAULT '0' NOT NULL COMMENT '状态', 
`is_deleted` smallint(6) DEFAULT '0' NOT NULL COMMENT '是否删除', 
`feed_id` bigint(20) DEFAULT '0' COMMENT '微博id', 
`picture` varchar(1024) NULL COMMENT '海报', 
PRIMARY KEY (`id`), 
KEY `ind_brand_activity_uid` (`user_id`, `is_deleted`)
)  AUTO_INCREMENT = 181 CHARSET = utf8 COMMENT = '品牌站活动表，数据量万级别';
CREATE TABLE if not exists brand_audit_remark (
`id` bigint(20) AUTO_INCREMENT NOT NULL, 
`user_id` varchar(44) NOT NULL COMMENT '用户ID', 
`remark` varchar(500) NOT NULL COMMENT '备注', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 18 CHARSET = utf8 COMMENT = '品牌站审核备注，数据量1w以内';
CREATE TABLE if not exists brand_bbc_seller (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`brand_site_id` bigint(20) UNSIGNED NOT NULL COMMENT '品牌站点ID', 
`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT 'seller_id', 
`item_list` varchar(4000) NOT NULL COMMENT '商品列表', 
`rate` double DEFAULT '0' NOT NULL COMMENT '卖家等级', 
`sold_out` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '销量', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 42940699 CHARSET = utf8 COMMENT = 'datax 同步表纪录brand站点分销卖家';
CREATE TABLE if not exists brand_compute_main_cats (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`cat_id` bigint(20) UNSIGNED NOT NULL COMMENT '后台类目id', 
`cat_name` varchar(200) NOT NULL COMMENT '后台类目名称', 
`is_deleted` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '是否删除', 
`source` varchar(118) DEFAULT 'sync' NOT NULL COMMENT '来源', 
`brand_id` bigint(20) NOT NULL COMMENT '品牌id', 
`brand_name` varchar(118) NOT NULL COMMENT '品牌名称', 
PRIMARY KEY (`id`), 
UNIQUE `brand_cat_unique` (`brand_id`, `cat_id`)
)  AUTO_INCREMENT = 18283 CHARSET = utf8 COMMENT = '基于离线计算的主营类目';
CREATE TABLE if not exists brand_lottery_rule (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`site_owner` bigint(20) UNSIGNED NOT NULL COMMENT '站长', 
`rule_id` bigint(20) UNSIGNED NOT NULL COMMENT '营销抽奖活动id', 
`rule_key` varchar(500) NOT NULL COMMENT '密钥', 
`rule` varchar(2000) NOT NULL COMMENT '活动规则 JSON', 
`begin_time` datetime NOT NULL COMMENT '活动开始时间', 
`end_time` datetime NOT NULL COMMENT '活动结束时间', 
`key_id` varchar(500) NOT NULL COMMENT '营销活动加密id', 
PRIMARY KEY (`id`), 
UNIQUE `unique_rule` (`rule_id`)
)  AUTO_INCREMENT = 260 CHARSET = utf8 COMMENT = '抽奖活动规则';
CREATE TABLE if not exists brand_main_cats (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`brand_site_id` bigint(20) NOT NULL COMMENT '品牌站点ID', 
`category_id` bigint(20) NOT NULL COMMENT '类目ID', 
`category_path` varchar(255) NOT NULL COMMENT '类目路径', 
`is_deleted` smallint(6) NOT NULL COMMENT '是否删除', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
KEY `ind_brand_main_cats_bid` (`brand_site_id`, `is_deleted`), 
KEY `ind_brand_main_cats_cid` (`category_id`, `is_deleted`)
)  AUTO_INCREMENT = 7112 CHARSET = utf8 COMMENT = '品牌主营类目,数据量10w';
CREATE TABLE if not exists brand_map_category (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`category_id` varchar(20) NOT NULL COMMENT 'SPU挂靠的类目Id', 
`content` varchar(2000) NOT NULL COMMENT '类目下销量Top10的SPU，格式为JSON', 
PRIMARY KEY (`id`), 
KEY `ind_brand_map_category_cid` (`category_id`)
)  AUTO_INCREMENT = 2507 CHARSET = utf8 COMMENT = '同类目下热销的SPU Top10';
CREATE TABLE if not exists brand_map_data (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`brand_id` varchar(20) NOT NULL COMMENT '品牌ID', 
`biz` varchar(100) NOT NULL COMMENT '品牌一级类目下30天内销量,JSON格式', 
`shop` varchar(100) NOT NULL COMMENT '品牌一级类目下店铺,JSON格式', 
`categories` varchar(2000) NOT NULL COMMENT '品牌的二级主营类目，JSON格式数据', 
`click` varchar(100) NOT NULL COMMENT '品牌map页分1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523显示点击数量，JSON格式', 
PRIMARY KEY (`id`), 
KEY `ind_brand_map_data_bid` (`brand_id`)
)  AUTO_INCREMENT = 341407 CHARSET = utf8 COMMENT = '品牌导购品牌销量、店铺、主营类目等基本信息';
CREATE TABLE if not exists brand_org_auth_info (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`telephone` varchar(45) NULL COMMENT '固定电话', 
`mobile` varchar(20) NULL COMMENT '移动电话', 
`org_structure_code` varchar(255) NULL COMMENT '组织结构代码（扫描件）路径', 
`area` varchar(255) NULL COMMENT '地区', 
`tax_reg_cert` varchar(255) NULL COMMENT '税务登记证路径', 
`brand_auth` varchar(255) NULL COMMENT '品牌授权书', 
`email` varchar(255) NULL COMMENT ' 电子邮件', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`linkman` varchar(50) NULL COMMENT '联系人', 
`name` varchar(255) NULL COMMENT '公司 组织名称', 
`org_desc`varchar(100)COMMENT '描述', 
`is_deleted` tinyint(4) NOT NULL COMMENT '是否删除', 
`biz_license` varchar(255) NOT NULL COMMENT '企业营业执照', 
PRIMARY KEY (`id`), 
KEY `ind_brand_org_auth_info_em` (`email`, `is_deleted`)
)  AUTO_INCREMENT = 3437 CHARSET = utf8 COMMENT = '组织经营授权信息,数据量1w';
CREATE TABLE if not exists brand_page_puv (
`id` bigint(20) AUTO_INCREMENT NOT NULL, 
`brand_owner_id` bigint(20) NOT NULL COMMENT '品牌站ID ', 
`page_id` bigint(20) NOT NULL COMMENT '页面ID', 
`pv` bigint(20) DEFAULT '0' NOT NULL COMMENT '页面PV', 
`mem_pv` bigint(20) DEFAULT '0' NOT NULL COMMENT '会员PV', 
`visitor_pv` bigint(20) DEFAULT '0' NOT NULL COMMENT '游客PV', 
`uv` bigint(20) DEFAULT '0' NOT NULL COMMENT '页面UV', 
`mem_uv` bigint(20) DEFAULT '0' NOT NULL COMMENT '会员UV', 
`visitor_uv` bigint(20) DEFAULT '0' NOT NULL COMMENT '游客UV', 
`jump_ipv` bigint(20) DEFAULT '0' NOT NULL COMMENT '引导IPV', 
`jump_ipvuv` bigint(20) DEFAULT '0' NOT NULL COMMENT '引导IPVUV', 
`page_url` varchar(255) NOT NULL COMMENT '页面相对路径的URL', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
PRIMARY KEY (`id`), 
KEY `ind_brand_page_puv_bid` (`brand_owner_id`, `page_url`, `gmt_create`)
)  AUTO_INCREMENT = 158651 CHARSET = utf8 COMMENT = '品牌站页面PV和UV监控表';
CREATE TABLE if not exists brand_promotion_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`price_guess` varchar(2000) NULL COMMENT '低价大猜想', 
`tae_site_id` bigint(20) NOT NULL COMMENT '站点id', 
`brand_goods` varchar(3000) NULL COMMENT '品牌会员专享', 
`new_goods` varchar(2000) NULL COMMENT '预售商品', 
`brand_story` varchar(100) NULL COMMENT '商品故事', 
`logo` varchar(5000) NULL COMMENT '各种logo', 
`item_list` varchar(100) NULL COMMENT '商品集合', 
`site_type` int(10) UNSIGNED NOT NULL COMMENT '1表示海景房 2表示重点品牌 3 表示海景房', 
`cat_type` int(10) UNSIGNED NOT NULL COMMENT '所属分会场', 
`tab` int(10) UNSIGNED NOT NULL COMMENT '品牌分会场所属tab', 
`lotty_rule` varchar(100) NOT NULL COMMENT '抽奖规则', 
`start_goods` varchar(100) NULL COMMENT '明星产品， 子站活动当天展示', 
PRIMARY KEY (`id`), 
KEY `tae_site_id` (`tae_site_id`), 
KEY `site_type` (`site_type`), 
KEY `tab` (`tab`), 
KEY `cat_type` (`cat_type`)
)  AUTO_INCREMENT = 1738 CHARSET = utf8 COMMENT = '品牌分会场促销信息收集';
CREATE TABLE if not exists brand_recommend (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家id', 
`seller_name` varchar(32) NULL COMMENT '卖家nick', 
`brand_id` bigint(20) NOT NULL COMMENT '品牌id', 
`owner_id` bigint(20) NULL COMMENT '品牌商id', 
`seller_category` varchar(400) NULL COMMENT '卖家主营类目', 
`seller_level` int(11) NULL COMMENT '卖家星级', 
`seller_open_time` datetime NULL COMMENT '开店时间', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`is_bbc` int(11) NULL COMMENT '是否分销', 
`seller_shop_url` varchar(400) NULL COMMENT '卖家店铺url', 
`seller_info` varchar(400) NULL COMMENT '卖家信息（json）', 
`is_delete` int(11) NOT NULL COMMENT '是否已删除', 
PRIMARY KEY (`id`), 
KEY `ind_brand_recommend_oid` (`owner_id`, `is_delete`, `is_bbc`, `seller_open_time`, `seller_level`)
)  CHARSET = utf8 COMMENT = '推荐卖家表';
CREATE TABLE if not exists brand_recruit (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`owner_id` bigint(20) NOT NULL COMMENT '品牌商id', 
`brand_id` bigint(20) NOT NULL COMMENT '品牌id', 
`status` int(11) NOT NULL COMMENT '状态（1-开启；0-关闭）', 
`recruit_content` varchar(2000) NULL COMMENT '规则内容（json）', 
`is_deleted` int(11) NOT NULL COMMENT '是否已删除', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
KEY `ind_brand_recruit_oid` (`owner_id`, `status`, `is_deleted`, `brand_id`)
)  AUTO_INCREMENT = 528 CHARSET = utf8 COMMENT = '品牌商招募规则表';
CREATE TABLE if not exists brand_sellers (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家淘宝id', 
`seller_name` varchar(32) NULL COMMENT '卖家淘宝nick', 
`brand_id` bigint(20) NOT NULL COMMENT '入驻品牌id', 
`brand_name` varchar(255) NULL COMMENT '入驻品牌名称', 
`owner_id` bigint(20) NULL COMMENT '品牌商id', 
`seller_category` varchar(400) NULL COMMENT '卖家主营类目（json）', 
`seller_level` int(11) NULL COMMENT '卖家星级', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`seller_open_time` datetime NULL COMMENT '开店时间', 
`is_bbc` int(11) NULL COMMENT '是否分销', 
`seller_shop_url` varchar(400) NOT NULL COMMENT '店铺url', 
`status` int(11) NOT NULL COMMENT '状态(1-申请中；2-成功；3-已打标；4-退回；5-撤消；6-过期)', 
`seller_info` varchar(400) NULL COMMENT '卖家信息（json）', 
`is_deleted` int(11) NOT NULL COMMENT '是否已删除', 
`audit_at` datetime NULL COMMENT '入驻时间', 
`tagged_at` datetime NULL COMMENT '商品打标时间', 
PRIMARY KEY (`id`), 
KEY `ind_brand_sellers_bid` (`brand_id`, `seller_id`, `is_deleted`, `status`), 
KEY `ind_brand_sellers_is` (`is_deleted`, `owner_id`, `seller_id`, `status`)
)  AUTO_INCREMENT = 25347 CHARSET = utf8 COMMENT = '卖家申请表';
CREATE TABLE if not exists brand_site_index_pic (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`brand_site_id` bigint(20) UNSIGNED NOT NULL COMMENT '品牌站站点id', 
`pic_json` varchar(100) NOT NULL COMMENT '首页图片，key是尺寸， value是图片地址', 
`url_json` varchar(100) NULL COMMENT '链接地址， 和图片对应', 
`activity_json` varchar(100) NULL COMMENT '活动描述', 
PRIMARY KEY (`id`), 
UNIQUE `brand_site_unique` (`brand_site_id`)
)  AUTO_INCREMENT = 273 CHARSET = utf8 COMMENT = '首页品牌商上传图片';
CREATE TABLE if not exists brand_sites (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`tae_site_id` bigint(20) NOT NULL COMMENT 'TAE站点对应id', 
`brand_org_auth_info_id` bigint(20) NULL COMMENT '品牌验证信息', 
`tp_org_auth_info_id` bigint(20) NULL COMMENT '第三方验证信息', 
`brand_id` bigint(20) NOT NULL COMMENT '品牌id(品牌站横向扩展，表示所有属性标识值id)', 
`tags` varchar(100) NULL COMMENT '标签， 半角逗号分隔', 
`big_logo` varchar(255) NULL COMMENT '大logo', 
`small_logo` varchar(255) NULL COMMENT '小logo', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`status` tinyint(4) NOT NULL COMMENT '状态 WAITING_AUDIT(0, "等待审核"),AUDIT_SUCCESS(2, "审核成功"),  AUDIT_FAILURE(-2, "审核失败"), DELETED(-1, "删除"), ', 
`apply_taobao_id` bigint(20) NULL COMMENT '申请人淘宝帐号', 
`brand_auth_taobao_id` bigint(20) NULL COMMENT '品牌站淘宝账号', 
`site_domain` varchar(255) NULL COMMENT '域名', 
`brand_name` varchar(255) NULL COMMENT '品牌名称(品牌站横向扩展， 表示站点名称)', 
`site_type` int(11) DEFAULT '0' COMMENT '站点类型', 
`feature` varchar(100) NULL COMMENT '站点特殊业务数据', 
`brand_ids` varchar(255) NULL COMMENT '支持多品牌', 
`brandsite_type` int(11) DEFAULT '0' COMMENT '不同类型品牌站', 
`telephone` varchar(15) NULL COMMENT '联系电话', 
`email` varchar(50) NULL COMMENT 'e-mail', 
PRIMARY KEY (`id`), 
KEY `ind_brand_sites_tid` (`tae_site_id`), 
KEY `ind_brand_sites_bid` (`brand_id`), 
KEY `ind_brand_sites_btid` (`brand_auth_taobao_id`), 
KEY `ind_brand_sites_st` (`site_domain`), 
KEY `ind_brand_sites_atid` (`apply_taobao_id`), 
KEY `ind_brand_sites_stat` (`status`, `site_type`, `gmt_create`)
)  AUTO_INCREMENT = 6671 CHARSET = utf8 COMMENT = '品牌站站点信息,数据量10w';
CREATE TABLE if not exists brand_spu_avg_price (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`spu_id` varchar(20) NOT NULL COMMENT 'Spu ID', 
`content` varchar(2000) NOT NULL COMMENT '同类目，同价位的10个SPu', 
PRIMARY KEY (`id`), 
KEY `ind_brand_spu_avg_price_sid` (`spu_id`), 
KEY `idx_spuid_content` (`spu_id`, `content`)
)  AUTO_INCREMENT = 608544 CHARSET = utf8 COMMENT = '同价位SPU推荐';
CREATE TABLE if not exists brand_top_spu (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`brand_id` varchar(20) NOT NULL COMMENT '品牌ID', 
`content` varchar(2000) NOT NULL COMMENT '热销的TOP 10 SPU集合，JSON数组格式', 
PRIMARY KEY (`id`), 
KEY `ind_brand_top_spu_bid` (`brand_id`)
)  AUTO_INCREMENT = 14570 CHARSET = utf8 COMMENT = '品牌下热销的TOP 10 SPU';
CREATE TABLE if not exists brand_user_order (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`order_id` bigint(20) NOT NULL COMMENT '订单id', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`fee` bigint(20) NOT NULL COMMENT '费用', 
`site_owner` bigint(20) NOT NULL COMMENT '站长，', 
PRIMARY KEY (`id`), 
UNIQUE `order_index` (`order_id`)
)  AUTO_INCREMENT = 153359 CHARSET = utf8 COMMENT = '品牌站双12订单成交明细';
CREATE TABLE if not exists brand_work (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`activity_id` bigint(20) NOT NULL COMMENT '活动id', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`feed_id` bigint(20) DEFAULT '0' COMMENT '微博id', 
`picture` varchar(1024) NOT NULL COMMENT '作品地址', 
`vote_count` int(11) NOT NULL COMMENT '投票数', 
`is_deleted` smallint(6) NOT NULL COMMENT '是否删除', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
KEY `ind_brand_work_aid` (`activity_id`, `is_deleted`, `vote_count`), 
KEY `ind_brand_work_uid` (`user_id`, `activity_id`, `is_deleted`)
)  AUTO_INCREMENT = 121 CHARSET = utf8 COMMENT = '品牌站作品，数据量百万级别';
CREATE TABLE if not exists `brandsite_qrcode` (  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',  `gmt_create` datetime NOT NULL COMMENT '创建时间',  `gmt_modified` datetime NOT NULL COMMENT '修改时间',  `site_id` bigint(20) unsigned NOT NULL COMMENT '站点id',  `url` varchar(1024) NOT NULL COMMENT 'url',  `content` varchar(10) DEFAULT NULL COMMENT '内容',  `qrcode_url` varchar(1024) NOT NULL COMMENT '二维码地址',  `is_deleted` tinyint(4) NOT NULL COMMENT '是否删除',  `size` int(11) DEFAULT NULL COMMENT '图片大小',  `img_url` varchar(1024) DEFAULT NULL COMMENT '图片logo',  PRIMARY KEY (`id`),  KEY `ind_brandsite_qrcode_sid` (`site_id`,`gmt_modified`)) AUTO_INCREMENT=650 DEFAULT CHARSET=utf8 COMMENT='站点二维码记录 10w';
CREATE TABLE if not exists brandsite_show_base (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`brand_site_id` bigint(20) UNSIGNED NOT NULL COMMENT '品牌站站点id', 
`tae_site_id` bigint(20) UNSIGNED NOT NULL COMMENT '建站装修站点id', 
`site_domain` varchar(255) NOT NULL COMMENT '域名', 
`category_id` varchar(255) NOT NULL COMMENT '类目id， 多个使用逗号分隔', 
`pv` bigint(20) UNSIGNED NOT NULL COMMENT '当天pv', 
`week_avg_pv` bigint(20) UNSIGNED NOT NULL COMMENT '周平均pv', 
`uv` bigint(20) UNSIGNED NOT NULL COMMENT '当天uv', 
`week_avg_uv` bigint(20) UNSIGNED NOT NULL COMMENT '周日均uv', 
`fans_count` bigint(20) UNSIGNED NOT NULL COMMENT '粉丝数', 
`fans_week_inc` bigint(20) UNSIGNED NOT NULL COMMENT '粉丝周增量', 
`first_letter` varchar(32) NULL COMMENT '首字母', 
`index_pic_update` date NULL COMMENT '活动图片更新时间', 
`brand_id` bigint(20) UNSIGNED NOT NULL COMMENT '品牌id', 
`brand_name` varchar(255) NOT NULL COMMENT '品牌名称', 
`brand_main_cat` varchar(255) NOT NULL COMMENT '品牌主营类目id', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 104164 CHARSET = utf8 COMMENT = '品牌站首页展示基础表每日回流';
CREATE TABLE if not exists car_type_profile (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`pid` bigint(20) UNSIGNED NULL COMMENT 'forest的pid', 
`vid` bigint(20) UNSIGNED NULL COMMENT 'forest的vid', 
`image_url` varchar(500) NULL COMMENT '对应车型的图片', 
`gmt_create_user` varchar(50) NULL COMMENT '创建小二', 
`gmt_modify_user` varchar(50) NULL COMMENT '最后修改小二', 
PRIMARY KEY (`id`), 
UNIQUE `pid_vid` (`pid`, `vid`)
)  AUTO_INCREMENT = 1152 CHARSET = utf8 COMMENT = '用于小二维护汽车市场的车型档案. 共1,2,4,6,7,8,11,56,68,89,435,45230多条数据. 以pid vid为条件 , 搜索出该车型的展示图片';
CREATE TABLE if not exists dgd_blackpages (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键id', 
`page_Id` bigint(20) NULL COMMENT '页面id', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
PRIMARY KEY (`id`), 
UNIQUE `uk_dgd_blackpages_pid` (`page_Id`)
)  CHARSET = utf8 COMMENT = '活动中心之组件-黑名单,调用量在每日万次级别,数据量小于1k';
CREATE TABLE if not exists dgd_promotion (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键id', 
`site_Id` bigint(20) UNSIGNED NULL COMMENT '站点id', 
`page_Id` bigint(20) UNSIGNED NULL COMMENT '页面id', 
`module_id` bigint(20) UNSIGNED NULL COMMENT '模块id', 
`position_id` bigint(20) UNSIGNED NULL COMMENT '位置id', 
`pic_url` varchar(1024) NOT NULL COMMENT '图片url', 
`url` varchar(1024) NOT NULL COMMENT '商品或者list的url', 
`ipv` bigint(20) UNSIGNED NOT NULL COMMENT '该链接的pv', 
`state` tinyint(4) NOT NULL COMMENT '是否处于删除状态', 
`title` varchar(256) NOT NULL COMMENT '宝贝标题', 
`price` bigint(20) UNSIGNED NULL COMMENT '宝贝价格', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
PRIMARY KEY (`id`), 
UNIQUE `uk_dgd_promotion_pmpid` (`page_Id`, `module_id`, `position_id`), 
KEY `ind_dgd_promotion_pstat` (`page_Id`, `state`)
)  AUTO_INCREMENT = 7473 CHARSET = utf8 COMMENT = '活动中心之组件';
CREATE TABLE if not exists express (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '表白发布者，淘宝用户id', 
`sender` varchar(32) NOT NULL COMMENT '表白者的名称，在表白的内容中展示', 
`receiver` varchar(32) NOT NULL COMMENT '被表白的人的名称', 
`template` varchar(64) NOT NULL COMMENT '模板的id，前期里面主要是一些id，后续根据需要可以修改成为tfs路径等相关信息', 
`content` varchar(256) NOT NULL COMMENT '表白的内容', 
`token` varchar(16) NOT NULL COMMENT 'token，用来防止用户随意扒表白的内容', 
`status` tinyint(4) NOT NULL COMMENT '状态:0->有效 -1->删除 -2->屏蔽', 
PRIMARY KEY (`id`), 
KEY `query_user_status` (`user_id`, `status`)
)  AUTO_INCREMENT = 9392 CHARSET = utf8 COMMENT = '情侣等表白的内容表. 表日增记录数最高可能有10W的（在前期推广的时候,最高可能达到10W）';
CREATE TABLE if not exists fashion_forfeit_history (
`user_id` bigint(20) NOT NULL COMMENT '卖家ID', 
`cat_id` int(11) NOT NULL COMMENT '一级类目', 
`reason` varchar(2047) NOT NULL COMMENT '处罚内容', 
`gmt_create` datetime NOT NULL COMMENT '创建日期', 
`gmt_modified` datetime NOT NULL COMMENT '最近修改日期', 
PRIMARY KEY (`user_id`, `cat_id`)
)  CHARSET = utf8 COMMENT = '女装新品卖家去标原因表，数据量300w';
CREATE TABLE if not exists feed_base (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '鑷1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523涓婚敭', 
`feed_id` bigint(20) NOT NULL, 
`title` varchar(255) NOT NULL, 
`content` varchar(500) NOT NULL, 
`sub_feed_count` bigint(20) NOT NULL, 
`pic_url` varchar(500) NOT NULL, 
`user_id` bigint(20) NOT NULL, 
`status` int(11) NOT NULL, 
`gmt_create` datetime NOT NULL COMMENT '璁板綍鍒涘缓鏃堕棿', 
`gmt_modified` datetime NOT NULL COMMENT '璁板綍鏈1,2,4,6,7,8,11,56,68,89,435,4523悗淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿', 
`key_words` varchar(255) NOT NULL, 
PRIMARY KEY (`id`), 
KEY `idx_fb_uid` (`user_id`, `status`, `gmt_create`, `sub_feed_count`), 
KEY `idx_fb_fid` (`feed_id`, `status`)
)  AUTO_INCREMENT = 334 CHARSET = utf8 COMMENT = '鐢ㄦ潵瀛樺彇鐖秄eed鐨勪汉姘1,2,4,6,7,8,11,56,68,89,435,4523鍏抽敭璇嶄互鍙婂叾浠栫浉鍏充俊鎭';
CREATE TABLE if not exists guess_price_record (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`auction_id` bigint(20) NOT NULL COMMENT '活动商品id', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`price` int(11) NOT NULL COMMENT '价格(分)', 
PRIMARY KEY (`id`), 
UNIQUE `item_user_index` (`auction_id`, `user_id`)
)  AUTO_INCREMENT = 7701 CHARSET = utf8 COMMENT = '猜底价记录';
CREATE TABLE if not exists info (
`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL, 
`type` tinyint(3) UNSIGNED DEFAULT '0' NOT NULL COMMENT '0：总结，10：指南，20：任务，21：建议，30：食谱名称，31：食材，32：做法，40：游戏', 
`title` varchar(128) NULL, 
`content` varchar(4096) NULL, 
`pic` varchar(128) NULL, 
`stage` smallint(5) UNSIGNED NOT NULL COMMENT '资讯所属阶段', 
`stage_title` varchar(20) NOT NULL COMMENT '资讯所属阶段名称', 
`url` varchar(128) NULL COMMENT '对应母婴资讯的url', 
PRIMARY KEY (`id`), 
KEY `ind_info_type` (`type`)
)  AUTO_INCREMENT = 436 CHARSET = utf8 COMMENT = '母婴资讯表,1,2,4,6,7,8,11,56,68,89,435,45230';
CREATE TABLE if not exists item_service (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`name` varchar(255) NOT NULL COMMENT '服务名,ex:新品', 
`service_value` varchar(255) NOT NULL COMMENT '服务URL参数,ex:Viewindex=11', 
`service_status` int(11) NOT NULL COMMENT '0表示正常，1表示删除，2表示停用', 
`gmt_create` date NOT NULL COMMENT '标签创建日期', 
`gmt_modified` date NOT NULL COMMENT '标签最近编辑日期', 
`service_type` int(10) UNSIGNED DEFAULT '0' COMMENT '标识标签属于的类别', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 66 CHARSET = utf8 COMMENT = '商品服务信息表，通过数据订正初始化数据，数据量：1,2,4,6,7,8,11,56,68,89,435,452300以内';
CREATE TABLE if not exists love_post_card (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`status` bigint(20) UNSIGNED NOT NULL COMMENT '状态 0 有效 1删除', 
`features` varchar(118) NULL COMMENT '扩展信息', 
`pic_url` varchar(118) NOT NULL COMMENT '生成的图片路径', 
`user_id` bigint(20) NOT NULL COMMENT '生成明信片的用户ID', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 283204 CHARSET = utf8 COMMENT = '情人节明信片活动';
CREATE TABLE if not exists market_group_info (
`id` bigint(20) AUTO_INCREMENT NOT NULL, 
`group_name` varchar(255) NOT NULL COMMENT '市场分组的名称', 
`pic_url` varchar(32) NULL COMMENT '分组图片的url', 
`is_high_light` int(11) DEFAULT '0' COMMENT '是否高亮，1为高亮，0为不高亮', 
`status` int(11) NOT NULL COMMENT '状态: 1 正常，1 删除', 
`sort_order` int(11) NULL COMMENT '排序值:排序值越小越靠前，用于定义在hesper前端的显示顺序', 
`env` varchar(8) NOT NULL COMMENT '环境： 日常环境:daily   预发环境：prepub   线上环境:online', 
`operator` varchar(64) NOT NULL COMMENT '最后一次的修改人', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '导购市场的分组信息 没有做sqlreview直接要求上线';
CREATE TABLE if not exists market_info (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`market_id` varchar(64) NOT NULL COMMENT '市场id', 
`market_name` varchar(118) NOT NULL COMMENT '市场名称', 
`market_code` varchar(118) NOT NULL COMMENT '市场code', 
`market_url` varchar(255) NOT NULL COMMENT '市场首页的url', 
`status` int(11) NOT NULL COMMENT '状态：0为正常，1为删除', 
`all_cat` int(11) NOT NULL COMMENT '是否为横切市场，1为横切市场，0为非横切市场', 
`auction_tags` varchar(512) NULL COMMENT '横切市场对应的特殊参数', 
`cats` varchar(400) NULL COMMENT '市场对应的一级类目', 
`skin_name` varchar(118) NULL COMMENT '市场对应的皮肤文件的名称', 
`sort_order` int(11) NULL COMMENT '排序值:排序值越小越靠前，用于定义在hesper前端的显示顺序', 
`group_id` bigint(20) NULL COMMENT '该市场属于的分组id', 
`env` varchar(8) DEFAULT 'daily' NOT NULL COMMENT '环境： 日常环境:daily   预发环境：prepub   线上环境:online', 
`operartor` varchar(64) NOT NULL COMMENT '最后一次的修改人', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '导购市场的配置信息表 没有做sqlreview直接要求上线';
CREATE TABLE if not exists member_alipay_fail_issue (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`order_id` varchar(64) NOT NULL COMMENT '订单id', 
`site_owner_id` bigint(20) UNSIGNED NOT NULL COMMENT '站长id', 
`buyer_user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户id', 
`type` int(11) NOT NULL COMMENT '类型', 
`sub_type` int(11) NOT NULL COMMENT '子类型', 
`amount` bigint(20) UNSIGNED NULL COMMENT '数量', 
`issue_memo` varchar(32) NULL COMMENT '备注', 
`error_code` varchar(32) NULL COMMENT '出错代码', 
`error_msg` varchar(1024) NULL COMMENT '出错信息', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '会员积分发放失败记录';
CREATE TABLE if not exists member_alipay_point_issue (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`order_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`site_owner_id` bigint(20) UNSIGNED NOT NULL COMMENT '站点用户id', 
`buyer_user_id` bigint(20) UNSIGNED NOT NULL COMMENT '买家用户id', 
`opt_type` tinyint(4) NOT NULL COMMENT '预留字段， 发放类型', 
`ump_detail_id` bigint(20) UNSIGNED NOT NULL COMMENT 'ump详情id', 
`amount` bigint(20) UNSIGNED NOT NULL COMMENT '发放数量', 
`issue_memo` varchar(255) NULL COMMENT '备注', 
`status` tinyint(4) NULL COMMENT '状态', 
PRIMARY KEY (`id`), 
KEY `idx_oid` (`order_id`), 
KEY `idx_soid` (`site_owner_id`)
)  CHARSET = utf8 COMMENT = '会员权益积分宝发放流水记录';
CREATE TABLE if not exists member_card (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`card_name` varchar(200) NOT NULL COMMENT '会员卡名称', 
`template_id` bigint(20) NULL COMMENT '会员卡模板id', 
`creator` bigint(20) NOT NULL COMMENT '创建人id', 
`logo_url` varchar(500) NULL COMMENT 'logo地址', 
`pic_url` varchar(500) NOT NULL COMMENT '会员卡图片地址', 
`description` varchar(500) NULL COMMENT '会员卡描述', 
`card_num` int(10) UNSIGNED DEFAULT '0' NOT NULL COMMENT '会员数量', 
`next_card_no` varchar(30) NULL COMMENT '下一会员卡号', 
`type` tinyint(4) NOT NULL COMMENT '1  品牌站 、2 U站', 
PRIMARY KEY (`id`), 
UNIQUE `creator_index` (`creator`)
)  AUTO_INCREMENT = 67112 CHARSET = utf8 COMMENT = '品牌会员站会员卡';
CREATE TABLE if not exists member_card_record (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) NOT NULL COMMENT '会员id', 
`offer_id` bigint(20) NOT NULL COMMENT '发送人id', 
`score` bigint(20) DEFAULT '0' NOT NULL COMMENT '积分', 
`experience` bigint(20) DEFAULT '0' NOT NULL COMMENT '经验值', 
`level` tinyint(3) UNSIGNED DEFAULT '1' NOT NULL COMMENT '等级', 
`type` tinyint(4) NOT NULL COMMENT '1：品牌站、2：U站', 
`status` tinyint(4) DEFAULT '1' NOT NULL COMMENT '1：开通、2：注销', 
`valid_date` date NULL COMMENT '有效期(预留)', 
`card_id` bigint(20) NULL COMMENT '会员卡id', 
`card_no` varchar(30) NULL COMMENT '会员卡编号', 
PRIMARY KEY (`id`), 
UNIQUE `user_offer_unique` (`user_id`, `offer_id`)
)  AUTO_INCREMENT = 1848333 CHARSET = utf8 COMMENT = '会员卡记录';
CREATE TABLE if not exists member_card_template (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`template_name` varchar(200) NOT NULL COMMENT '模板名称', 
`type` tinyint(4) NOT NULL COMMENT '模板类型（0 通用，1 品牌站，2 U站）', 
`pic_url` varchar(500) NOT NULL COMMENT '图片地址', 
`description` varchar(500) NULL COMMENT '模板描述', 
`is_deleted` tinyint(4) DEFAULT '0' NOT NULL COMMENT '是否删除（0正常，1删除）', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 12 CHARSET = utf8 COMMENT = '品牌会员站会员卡模板';
CREATE TABLE if not exists member_marketing (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`name` varchar(200) NOT NULL COMMENT '营销任务名称', 
`start_time` datetime NOT NULL COMMENT '任务生效时间,同步给UMP', 
`end_time` datetime NOT NULL COMMENT '任务结束时间,同步给UMP', 
`marketing_type` tinyint(4) NOT NULL COMMENT '营销方式，1-定向打折 2-定向换购', 
`promotion_type` tinyint(4) NOT NULL COMMENT '优惠方式，1-直接打折 2-集分宝 3- 一口价折扣率 4- 一口价折扣率+集分宝', 
`status` tinyint(4) NOT NULL COMMENT '状态  1未发布、2已发布、3已结束、4已停用、9 已删除', 
`creator` varchar(118) NOT NULL COMMENT '创建人', 
`owner_id` bigint(20) NOT NULL COMMENT '创建人id', 
PRIMARY KEY (`id`), 
KEY `idx_oid` (`owner_id`)
)  AUTO_INCREMENT = 947 CHARSET = utf8 COMMENT = '品牌站营销任务';
CREATE TABLE if not exists member_promotion_item (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`marketing_id` bigint(20) NOT NULL COMMENT '营销任务ID', 
`rule_id` bigint(20) UNSIGNED NOT NULL COMMENT '规则ID', 
`item_id` bigint(20) NOT NULL COMMENT '商品ID', 
`ump_activity_id` bigint(20) NULL COMMENT 'ump活动ID', 
`ump_detail_id` bigint(20) NULL COMMENT 'ump优惠详情', 
`status` tinyint(4) NOT NULL COMMENT '同步状态 1-打标成功 2-打标失败3去标成功4去标失败 9废弃', 
`fail_reason` varchar(2000) NULL COMMENT '失败原因', 
`user_id` bigint(20) NOT NULL COMMENT '卖家id', 
PRIMARY KEY (`id`), 
KEY `idx_mid_stat` (`marketing_id`, `status`), 
KEY `idx_mid_rid` (`marketing_id`, `rule_id`)
)  AUTO_INCREMENT = 11 CHARSET = utf8 COMMENT = '关联打标的商品记录';
CREATE TABLE if not exists member_promotion_rule (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`marketing_id` bigint(20) NOT NULL COMMENT '营销任务ID', 
`user_group_ids` varchar(1024) NOT NULL COMMENT '人群标签ID', 
`item_set_id` bigint(20) NOT NULL COMMENT '对应营销活动分组ID', 
`promotion_info` varchar(1024) NULL COMMENT '定向打折时的优惠规则，kv存储', 
`fee_pay_side` tinyint(4) NULL COMMENT '营销费用承担者,0-买家承担  1-组织者承担，父表的promotion_type 为2或者4 时，字段有效', 
`last_sync_time` datetime NULL COMMENT '上次同步打标时间', 
`ump_title` varchar(200) NULL COMMENT 'detail优惠展现文字', 
`ump_activity_id` bigint(20) NULL COMMENT 'ump活动ID', 
`activety_start_time` datetime NULL COMMENT '对应营销活动开始时间', 
`activety_end_time` datetime NULL COMMENT '对应营销活动结束时间', 
`user_group_name` varchar(200) NULL COMMENT '人群名称', 
`item_set_name` varchar(200) NULL COMMENT '营销活动分组名称', 
`content_id` bigint(20) NULL COMMENT '淘营销活动id', 
`content_name` varchar(200) NULL COMMENT '淘营销活动名称', 
PRIMARY KEY (`id`), 
KEY `idx_mid` (`marketing_id`)
)  AUTO_INCREMENT = 1388 CHARSET = utf8 COMMENT = '优惠规则';
CREATE TABLE if not exists museum_info (
`id` bigint(20) AUTO_INCREMENT NOT NULL, 
`museum_name` varchar(255) NOT NULL COMMENT '馆名,ex:新品馆', 
`museum_url` varchar(2047) NOT NULL COMMENT '服务URL参数   ex:默认标签，不限制个数', 
`logo_url` varchar(255) NOT NULL COMMENT 'Logo地址', 
`museum_status` tinyint(4) NOT NULL COMMENT '馆状态', 
`normal_service` varchar(2047) NULL COMMENT '一般服务  ex:剩下的服务', 
`market_service` varchar(255) NULL COMMENT '推广服务  ex:行业特色   最多3个', 
`lstyle` varchar(255) DEFAULT 'pinterst' NOT NULL COMMENT '排列方式', 
`tms` varchar(2047) NULL COMMENT 'tms模块', 
`nav_style` varchar(255) DEFAULT 'categroy' NOT NULL COMMENT '按照标签导航，类目导航:category、tag', 
`itemsns` varchar(1023) NULL COMMENT '商品信息', 
`bp_url` varchar(1023) NULL COMMENT '报表地址', 
`group1_info` varchar(2047) NULL COMMENT '组信息1', 
`group2_info` varchar(2047) NULL COMMENT '组信息2', 
`group3_info` varchar(2047) NULL COMMENT '组信息3', 
`group4_info` varchar(2047) NULL COMMENT '组信息4', 
`group5_info` varchar(2047) NULL COMMENT '组信息5', 
`gmt_create` datetime NOT NULL COMMENT '馆创建日期', 
`gmt_modified` datetime NOT NULL COMMENT '馆最近编辑日期', 
`creator` varchar(255) NULL COMMENT '创建人', 
`last_op` varchar(255) NULL COMMENT '最后修改人', 
`group6_info` varchar(2047) NULL COMMENT '组信息6', 
`group7_info` varchar(2047) NULL COMMENT '组信息7', 
`group8_info` varchar(2047) NULL COMMENT '组信息8', 
`check_style` varchar(31) DEFAULT 'N' COMMENT '是否显示风格测试', 
`temp_style` varchar(31) DEFAULT 'newArrival' COMMENT '页面模板类型', 
`ind_style` varchar(31) DEFAULT 'tag' COMMENT '个性市场左侧导航方式', 
`custom1_info`varchar(100)COMMENT '专辑信息1', 
`custom2_info`varchar(100)COMMENT '专辑信息2', 
`custom3_info`varchar(100)COMMENT '专辑信息3', 
`custom4_info`varchar(100)COMMENT '专辑信息4', 
`custom5_info`varchar(100)COMMENT '专辑信息5', 
`custom6_info`varchar(100)COMMENT '专辑信息6', 
`customids`varchar(100)COMMENT '类目商品id', 
`custom_format` int(11) DEFAULT '0' COMMENT 'custom_info格式标识，默认1为json格式，0为custom_info1到custom_info6的原先格式', 
`version` bigint(20) UNSIGNED DEFAULT '0' COMMENT '用来控制新旧版本的数据，新版本为1', 
PRIMARY KEY (`id`), 
KEY `ind_MUSEUM_INFO_mstat` (`museum_status`)
)  AUTO_INCREMENT = 286 CHARSET = utf8 COMMENT = '新品馆 信息管理表，每天通过catserver将museum_status为0（启用）的信息推送到hesper，数据量：';
CREATE TABLE if not exists phb_bl_auctions (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`auction_id` bigint(20) NOT NULL COMMENT '商品主键', 
`state` tinyint(4) DEFAULT '0' NOT NULL COMMENT '0:有效，1：无效', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
UNIQUE `uk_phb_bl_auctions_aid` (`auction_id`), 
KEY `ind_phb_bl_auctions_state` (`state`)
)  AUTO_INCREMENT = 1207 CHARSET = utf8 COMMENT = '排行榜商品黑名单';
CREATE TABLE if not exists phb_bl_brand (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`brand_id` bigint(20) NOT NULL COMMENT '品牌主键', 
`state` tinyint(4) DEFAULT '0' NOT NULL COMMENT '0:有效，1：无效', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
UNIQUE `uk_phb_bl_brand_bid` (`brand_id`), 
KEY `ind_phb_bl_brand_state` (`state`)
)  AUTO_INCREMENT = 28 CHARSET = utf8 COMMENT = '排行榜品牌黑名单';
CREATE TABLE if not exists phb_bl_poster (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`poster_id` bigint(20) NOT NULL COMMENT '画报主键', 
`state` tinyint(4) DEFAULT '0' NOT NULL COMMENT '0:有效，1：无效', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
UNIQUE `uk_phb_bl_poster_pid` (`poster_id`), 
KEY `ind_phb_bl_poster_state` (`state`)
)  AUTO_INCREMENT = 2 CHARSET = utf8 COMMENT = '排行榜画报黑名单';
CREATE TABLE if not exists phb_bl_shop (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`shop_id` bigint(20) NOT NULL COMMENT '店铺主键', 
`state` tinyint(4) DEFAULT '0' NOT NULL COMMENT '0:有效，1：无效', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
UNIQUE `uk_phb_bl_shop_sid` (`shop_id`), 
KEY `ind_phb_bl_shop_state` (`state`)
)  AUTO_INCREMENT = 3 CHARSET = utf8 COMMENT = '排行榜店铺黑名单';
CREATE TABLE if not exists phb_bl_spu (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`spu_id` bigint(20) NOT NULL COMMENT 'SPU主键', 
`state` tinyint(4) DEFAULT '0' NOT NULL COMMENT '0:有效，1：无效', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
UNIQUE `uk_phb_bl_spu_sid` (`spu_id`), 
KEY `ind_phb_bl_spu_state` (`state`)
)  AUTO_INCREMENT = 2 CHARSET = utf8 COMMENT = '排行榜SPU黑名单';
CREATE TABLE if not exists pk_topic (
`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL, 
`topic_id` int(10) UNSIGNED NOT NULL COMMENT '被选为PK话题的话题ID', 
`topic_case` varchar(30) NULL COMMENT '案例在论坛中的帖子ID', 
`thread_url` varchar(30) NULL COMMENT 'PK话题在论坛中对应的帖子ID', 
`aff_comment_id` varchar(50) NULL COMMENT '正方精彩评论的ID. 以分号分隔', 
`opp_comment_id` varchar(50) NULL COMMENT '反方精彩评论的ID. 以分号分隔', 
`aff_num` int(10) UNSIGNED DEFAULT '0' NOT NULL COMMENT '正方支持数', 
`opp_num` int(10) UNSIGNED DEFAULT '0' NOT NULL COMMENT '正方支持数', 
`status` tinyint(3) UNSIGNED DEFAULT '1' NOT NULL COMMENT '常规状态字段', 
`last_reply` datetime NOT NULL COMMENT '最新回复时间', 
`gmt_create` datetime NOT NULL, 
`gmt_modify` datetime NOT NULL, 
`aff_view` varchar(255) NOT NULL COMMENT '正方观点', 
`opp_view` varchar(255) NOT NULL COMMENT '反方观点', 
PRIMARY KEY (`id`), 
UNIQUE `uk_topic_id` (`topic_id`)
)  AUTO_INCREMENT = 37 CHARSET = utf8 COMMENT = 'PK话题,由话题引出. 运营维护, 15天一期, 所以数量最多在百级别.';
CREATE TABLE if not exists pk_topic_comment (
`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL, 
`pk_topic_id` int(10) UNSIGNED NOT NULL, 
`user_id` bigint(20) UNSIGNED NOT NULL, 
`side` tinyint(3) UNSIGNED NOT NULL COMMENT '0代表正方,1代表反方', 
`content` varchar(255) NOT NULL COMMENT '评论内容', 
`aff_num` smallint(5) UNSIGNED DEFAULT '0' NOT NULL COMMENT '赞该条评论的人数', 
`opp_num` smallint(5) UNSIGNED DEFAULT '0' NOT NULL COMMENT '反驳该条评论的人数', 
`response_id` int(10) UNSIGNED DEFAULT '0' NOT NULL COMMENT '为0时代表这是观点,不为0则为被回复的评论ID', 
`status` tinyint(3) UNSIGNED DEFAULT '1' NOT NULL COMMENT '0删除,1正常', 
`type` tinyint(3) UNSIGNED DEFAULT '0' NOT NULL COMMENT '0为观点,1为回复,2为精彩评论', 
`gmt_create` datetime NOT NULL, 
`gmt_modify` datetime NOT NULL, 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 58629 CHARSET = utf8 COMMENT = '针对PK话题的评论. 乐观估计如果人数较多每期在千级别.';
CREATE TABLE if not exists pk_topic_comment_vote (
`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL, 
`comment_id` int(11) NOT NULL COMMENT '被赞的观点ID', 
`user_id` bigint(20) NOT NULL, 
`gmt_create` datetime NOT NULL, 
`gmt_modify` datetime NOT NULL, 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 6180 CHARSET = utf8 COMMENT = '针对他人评论的投票. 数量级同其他表.';
CREATE TABLE if not exists pk_topic_vote (
`id` bigint(11) UNSIGNED AUTO_INCREMENT NOT NULL, 
`pk_topic_id` int(11) NOT NULL COMMENT 'PK话题ID', 
`user_id` bigint(20) NOT NULL, 
`side` tinyint(4) NOT NULL COMMENT '0代表正方,1代表反方', 
`user_ip` varchar(20) NULL COMMENT '用户IP,用于统计', 
`gmt_create` datetime NOT NULL, 
`gmt_modify` datetime NOT NULL, 
PRIMARY KEY (`id`), 
UNIQUE `uk_up_uid` (`pk_topic_id`, `user_id`)
)  AUTO_INCREMENT = 157985 CHARSET = utf8 COMMENT = '话题投票.每期增加千级别,预估最多到万级别.';
CREATE TABLE if not exists promotion_goods_pool (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`item_id` bigint(20) DEFAULT '0' NOT NULL COMMENT '宝贝ID', 
`activity_id` bigint(20) DEFAULT '0' NOT NULL COMMENT '优惠活动ID', 
`activity_title` varchar(118) DEFAULT '0' NOT NULL COMMENT '优惠活动名称', 
`discount` decimal(15, 2) DEFAULT '0.00' NOT NULL COMMENT '当promotion_type==1, 代表折扣率(0~1); 当promotion_type==2, 代表减现金的数量', 
`promotion_tag` bigint(20) DEFAULT '0' NOT NULL COMMENT 'TCIF标签或者勋章', 
`cat_id` bigint(20) DEFAULT '0' NOT NULL COMMENT '商品叶子类目', 
`parent_cat_id` bigint(20) DEFAULT '0' NOT NULL COMMENT '商品父类目', 
`grandpa_cat_id` bigint(20) DEFAULT '0' NOT NULL COMMENT '商品爷爷类目', 
`original_price` bigint(20) NULL COMMENT '商品原价', 
`seller_nick` varchar(118) DEFAULT '0' NOT NULL COMMENT '卖家昵称', 
`promotion_type` bigint(20) DEFAULT '0' NOT NULL COMMENT '优惠规则.(沿用优惠系统: 0代表包邮、1代表打折、2代表减现金)', 
`status` int(11) DEFAULT '0' NOT NULL COMMENT '记录状态. 0为已删除; 1为有效.', 
`activity_start_time` datetime NOT NULL COMMENT '活动开始时间', 
`activity_end_time` datetime NOT NULL COMMENT '活动结束时间', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后一次被修改时间', 
`feature` varchar(1024) DEFAULT '0' NOT NULL COMMENT '扩展字段', 
`feature_1` varchar(20) DEFAULT '0' NOT NULL COMMENT '扩展字段1', 
`feature_2` varchar(20) DEFAULT '0' NOT NULL COMMENT '扩展字段2', 
`shop_id` bigint(20) NULL COMMENT '店铺ID', 
`global_buy` bigint(20) NULL COMMENT '1 代表是全球购商品, null则不是 (用bigint是想简单一点. 怕有自动转换带的来麻烦). ', 
`pay_for_thrice` bigint(20) NULL COMMENT '1代表是假一赔三商品. null则不是', 
PRIMARY KEY (`id`), 
KEY `ind_promotion_goods_pool_aetime` (`activity_end_time`), 
KEY `ind_promotion_goods_pool_aiid` (`activity_id`, `item_id`), 
KEY `ind_promotion_goods_pool_snick` (`seller_nick`, `promotion_tag`, `activity_start_time`, `activity_end_time`), 
KEY `ind_promotion_goods_pool_sid` (`shop_id`)
)  CHARSET = utf8 COMMENT = '优惠商品池(用于保存ump部门的举行活动时的相关商品数据)';
CREATE TABLE if not exists reward_detail (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '奖励id', 
`task_id` bigint(20) UNSIGNED NOT NULL COMMENT '任务id', 
`name` varchar(256) NOT NULL COMMENT '奖励描述', 
`repeat_times` int(11) NOT NULL COMMENT '中奖机会次数;-1表示无限大', 
`type` int(11) NOT NULL COMMENT '奖品类型：1：杯子；2、淘金币；3、空间；4、店铺优惠券5、店铺VIP', 
`reward_num` int(11) NOT NULL COMMENT '奖励数量', 
`probability` decimal(3, 3) NULL COMMENT '中奖概率', 
`feature` varchar(32) NULL, 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
`reward_img` varchar(64) NULL COMMENT '奖励照片url', 
`weight` int(11) NULL COMMENT '奖励权重', 
PRIMARY KEY (`id`), 
KEY `ind_reward_detail_tid` (`task_id`)
)  AUTO_INCREMENT = 26 CHARSET = utf8 COMMENT = '奖励详情表，数据量几百';
CREATE TABLE if not exists schedule_tagging (
`id` int(11) AUTO_INCREMENT NOT NULL, 
`name` varchar(255) NOT NULL COMMENT '任务名称', 
`tp_behavior` int(11) NOT NULL COMMENT '打标，去标', 
`tp_classify` int(11) NOT NULL COMMENT '标类型,-1扩展属性，1卖家标，2商品标，4卖家类目标', 
`tp_status` int(11) NOT NULL COMMENT '0表示正常，1表示删除，2表示停用', 
`tp_info` varchar(2047) NULL COMMENT '标签的信息： 扩展属性StructStr,ChildStr,卖家类目标：catId', 
`ds_path` varchar(511) NOT NULL COMMENT '数据源路径', 
`tag_id` int(11) NOT NULL COMMENT '标签ID', 
`tag_desp` varchar(255) NULL COMMENT '标签描述', 
`creator` varchar(31) NOT NULL COMMENT '创建人', 
`last_op` varchar(31) NOT NULL COMMENT '最后操作人', 
`gmt_create` datetime NOT NULL COMMENT '标签创建日期', 
`gmt_modified` datetime NOT NULL COMMENT '标签最近编辑日期', 
`tp_run` int(11) DEFAULT '0' NOT NULL COMMENT '运行状态', 
`work_hour` int(11) DEFAULT '1' NOT NULL COMMENT '运行时间', 
`run_slot` bigint(20) DEFAULT '0' NOT NULL COMMENT '任务处理中机器的比特位', 
`done_slot` bigint(20) DEFAULT '0' NOT NULL COMMENT '任务完成机器的比特位', 
`blacklist_on` tinyint(4) DEFAULT '0' NOT NULL COMMENT '是否启用黑名单。 0停用，1启用', 
PRIMARY KEY (`id`), 
KEY `ind_schedule_tagging_stat` (`tp_status`, `gmt_modified`), 
KEY `ind_schedule_tagging_creator` (`creator`, `tp_status`, `gmt_modified`)
)  AUTO_INCREMENT = 46 CHARSET = utf8 COMMENT = '记录定时打标的配置信息，数据量1w以内';
CREATE TABLE if not exists schedule_tagging_static (
`id` int(11) AUTO_INCREMENT NOT NULL, 
`template_id` int(11) NOT NULL COMMENT 'schedule_tagging表的主键', 
`success` int(11) NOT NULL COMMENT '成功数', 
`fail` int(11) NOT NULL COMMENT '失败数', 
`invalid` int(11) NOT NULL COMMENT '不合法宝贝数', 
`start_time` datetime NOT NULL COMMENT '任务开始时间', 
`gmt_create` datetime NOT NULL COMMENT '记录创建日期', 
PRIMARY KEY (`id`), 
KEY `ind_schedule_tagging_static_tid` (`template_id`, `start_time`)
)  AUTO_INCREMENT = 22488 CHARSET = utf8 COMMENT = '打标系统的每日打标信息汇总， 数据量10w左右';
CREATE TABLE if not exists sequence (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`name` varchar(500) NOT NULL COMMENT '表名', 
`value` bigint(20) UNSIGNED DEFAULT '1' NOT NULL COMMENT 'sequence 值', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 2 CHARSET = utf8 COMMENT = 'tddl sequence';
CREATE TABLE if not exists site_op_log (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户id', 
`user_nick` varchar(255) NOT NULL COMMENT '用户nick', 
`operation` varchar(100) NOT NULL COMMENT '用户操作', 
`op_type` varchar(32) NULL COMMENT '操作类型', 
`op_ip` varchar(255) NOT NULL COMMENT '操作ip', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '站点操作日志';
CREATE TABLE if not exists spu_extend (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键id', 
`spu_id` bigint(20) NOT NULL COMMENT 'spu_id', 
`title` varchar(118) NULL COMMENT '产品标题', 
`designer` varchar(6400) NULL COMMENT '关联设计师', 
`video_url` varchar(100) NULL COMMENT '关联视频', 
`area` bigint(20) NULL COMMENT '产品产地vid', 
`market_time` date NULL COMMENT '上市时间', 
`brander_status` int(11) NULL COMMENT 'spu品牌商授权状态（1-品牌商确认，-1-品牌商未确认）', 
`gmt_create` datetime NULL COMMENT '创建时间', 
`gmt_modified` datetime NULL COMMENT '最后更改时间', 
`colour` varchar(6400) NULL COMMENT '颜色分类', 
`product_package` varchar(400) NULL COMMENT '产品包装', 
`original_price` double NULL COMMENT '产品吊牌价', 
`price_region` varchar(50) NULL COMMENT '价格监控区间', 
`product_feature` varchar(400) NULL COMMENT '产品特点', 
`intro` varchar(2000) NULL COMMENT '产品简介', 
`picture_url` varchar(2000) NULL COMMENT '产品图片', 
`relation_spu` varchar(200) NULL COMMENT '关联spu', 
`weibo` varchar(2000) NULL COMMENT '关联资讯', 
`status` int(11) NULL COMMENT 'Spu状态(0--品牌商授权，null or -1--品牌商未授权)', 
`last_modified_userid` bigint(20) NULL COMMENT '最后修改者用户id', 
`brand_id` bigint(20) NULL COMMENT '品牌vid', 
`product_id` bigint(20) NULL COMMENT '货号vid', 
`designer_info` varchar(100) NULL, 
`video` varchar(255) NULL, 
`extend_info` varchar(255) NULL, 
`extend_info2` varchar(255) NULL, 
`is_deleted` tinyint(4) NULL, 
PRIMARY KEY (`id`), 
UNIQUE `uk_spu_extend_sid` (`spu_id`)
)  AUTO_INCREMENT = 46660 CHARSET = utf8 COMMENT = 'spu扩展信息，数据量百万级别';
CREATE TABLE if not exists starbaby_activity (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
`activity_num` bigint(20) NOT NULL COMMENT '活动编号', 
`user_id` bigint(20) NOT NULL COMMENT '创建者id', 
`activity_starttime` date NOT NULL COMMENT '活动开始时间', 
`activity_endtime` date NOT NULL COMMENT '活动结束时间', 
`activity_status` tinyint(4) NOT NULL COMMENT '活动状态（1表示正常，0表示删除）', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录修改时间', 
`b_int` bigint(20) NULL COMMENT '预留字段', 
`b_varchar` varchar(512) NULL COMMENT '预留字段', 
`activity_theme` varchar(256) NULL COMMENT '活动主题', 
`is_impress` tinyint(4) NULL COMMENT '是否开启宝宝印象', 
`upload_starttime` date NULL COMMENT '上传截止时间', 
`upload_endtime` date NULL COMMENT '上传截止时间', 
`vote_starttime` date NULL COMMENT '投票开始时间', 
`vote_endtime` date NULL COMMENT '投票结束时间', 
`impress_starttime` date NULL COMMENT '印象点评开始时间', 
`impress_endtime` date NULL COMMENT '印象点评结束时间', 
`activity_abstract` varchar(512) NULL COMMENT '活动简介', 
`activity_banner` varchar(140) NULL COMMENT '活动banner', 
`allow_user_impress` tinyint(4) NULL COMMENT '是否允许用户添加印象', 
`islottery` tinyint(4) NULL COMMENT '是否开启抽奖功能', 
`type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '活动类型', 
`user_num` int(11) NULL COMMENT '参赛人数', 
`photo_num` int(11) NULL COMMENT '相片数', 
`age_low_limit` date NULL COMMENT '最小参赛年龄', 
`age_up_limit` date NULL COMMENT '最大参赛年龄', 
`sex_limit` tinyint(4) NOT NULL COMMENT '性别限制。0不限制，1限男，2限女', 
PRIMARY KEY (`id`), 
KEY `ind_starbaby_activity_astime` (`activity_starttime`), 
KEY `ind_starbaby_activity_aat` (`activity_num`, `activity_status`, `type`), 
KEY `ind_starbaby_activity_at` (`activity_status`, `type`, `activity_starttime`, `activity_endtime`)
)  AUTO_INCREMENT = 62 CHARSET = utf8 COMMENT = '明星宝宝活动表';
CREATE TABLE if not exists starbaby_comment (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
`user_id` bigint(20) NOT NULL COMMENT '评论者的id', 
`activity_num` bigint(20) NOT NULL COMMENT '活动期数', 
`competitor_num` bigint(20) NOT NULL COMMENT '参赛编号', 
`comment_content` varchar(256) NULL COMMENT '评论内容', 
`comment_status` tinyint(4) NOT NULL COMMENT '评论的状态(0表示未审核，1表示已审核，2表示已删除）', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录修改时间', 
`b_int` bigint(20) NULL COMMENT '预留字段', 
`b_varchar` varchar(512) NULL COMMENT '预留字段', 
`user_nick` varchar(40) NULL COMMENT '优化查询速度，对用户昵称冗余存储', 
PRIMARY KEY (`id`), 
KEY `ind_starbaby_comment_cstat` (`comment_status`, `activity_num`, `competitor_num`), 
KEY `ind_starbaby_comment_uid` (`user_id`, `comment_status`)
)  AUTO_INCREMENT = 6802674 CHARSET = utf8 COMMENT = '活动评论表';
CREATE TABLE if not exists starbaby_competitor (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
`competitor_num` bigint(20) NOT NULL COMMENT '参赛编号', 
`activity_num` bigint(20) NOT NULL COMMENT '活动编号', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`competitor_declaration` varchar(256) NOT NULL COMMENT '参赛宣言', 
`competitor_content` varchar(512) NULL COMMENT '参赛信息（默认存放图片地址）', 
`competitor_status` tinyint(4) NOT NULL COMMENT '宝宝信息状态(1表示正常，2表示删除,0待审核的）', 
`votecount` bigint(20) NOT NULL COMMENT '总得票数', 
`commentcount` bigint(20) NOT NULL COMMENT '总评论数', 
`comment_id` bigint(20) NOT NULL COMMENT '最新评论编号', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`b_int` bigint(20) NULL COMMENT '预留int字段', 
`b_varchar` varchar(512) NULL COMMENT '预留字符串字段', 
`user_nick` varchar(40) NULL COMMENT '提高查询速度考虑对参赛者的昵称冗余存储', 
PRIMARY KEY (`id`), 
KEY `ind_starbaby_competitor_cstat` (`competitor_status`, `activity_num`, `votecount`), 
KEY `ind_starbaby_competitor_uid` (`user_id`, `activity_num`), 
KEY `ind_starbaby_competitor_cn` (`competitor_num`, `activity_num`, `competitor_status`)
)  AUTO_INCREMENT = 789206 CHARSET = utf8 COMMENT = '参赛宝宝表';
CREATE TABLE if not exists starbaby_entry_number (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
`activity_num` bigint(20) NOT NULL COMMENT '活动期数', 
`competitor_num` bigint(20) NOT NULL COMMENT '参赛编号', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录修改时间', 
PRIMARY KEY (`id`), 
KEY `ind_starbaby_entry_number_anum` (`activity_num`)
)  AUTO_INCREMENT = 30 CHARSET = utf8 COMMENT = '活动期数自增';
CREATE TABLE if not exists starbaby_impress_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
`impress_word_id` bigint(20) UNSIGNED NULL COMMENT '印象词条的id', 
`activity_num` bigint(20) UNSIGNED NULL COMMENT '活动编号', 
`competitor_num` bigint(20) UNSIGNED NULL COMMENT '参赛编号', 
`impress_count` int(10) UNSIGNED NULL COMMENT '印象得分', 
`impress_status` tinyint(3) UNSIGNED NULL COMMENT '所得印象状态 1正常 2删除', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录修改时间', 
`b_int` int(10) UNSIGNED NULL COMMENT '备用整形字段', 
`b_varchar` varchar(512) NULL COMMENT '备用字符串字段', 
PRIMARY KEY (`id`), 
UNIQUE `uk_starbaby_impress_info_iid` (`impress_word_id`, `competitor_num`, `activity_num`, `impress_status`), 
KEY `ind_starbaby_impress_info_cnum` (`competitor_num`, `activity_num`, `impress_count`)
)  AUTO_INCREMENT = 123601 CHARSET = utf8 COMMENT = '宝宝的印象信息表';
CREATE TABLE if not exists starbaby_impress_trace (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
`impress_word_id` bigint(20) UNSIGNED NULL COMMENT '词条id', 
`activity_num` bigint(20) UNSIGNED NULL COMMENT '活动编号', 
`competitor_num` bigint(20) UNSIGNED NULL COMMENT '参赛编号', 
`user_id` bigint(20) UNSIGNED NULL COMMENT '评论印象的会员id', 
`impress_ip` varchar(32) NULL COMMENT 'ip地址', 
`impress_num` int(10) UNSIGNED NULL COMMENT '评论印象次数', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录修改时间', 
`b_int` int(10) UNSIGNED NULL COMMENT '备用字段', 
`b_varchar` varchar(512) NULL COMMENT '备用字段', 
`impress_reason` tinyint(3) UNSIGNED NULL COMMENT '印象记录创建原因(1,添加印象，2其他）', 
PRIMARY KEY (`id`), 
KEY `ind_starbaby_impress_trace_uid` (`user_id`, `activity_num`, `competitor_num`)
)  AUTO_INCREMENT = 485815 CHARSET = utf8 COMMENT = '宝宝印象的操作记录';
CREATE TABLE if not exists starbaby_impress_word (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
`impress_word` varchar(140) NULL COMMENT '印象词条', 
`baby_sex` tinyint(3) UNSIGNED NULL COMMENT '性别 1男 2女 3不区分', 
`word_status` tinyint(3) UNSIGNED NULL COMMENT '词条状态 1正常 2删除', 
`impress_type` bigint(20) UNSIGNED NULL COMMENT '词条类型 1不推荐 否则推荐', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`b_int` int(10) UNSIGNED NULL COMMENT '预备字段', 
`b_varchar` varchar(512) NULL COMMENT '备用字段', 
PRIMARY KEY (`id`), 
KEY `ind_starbaby_impress_word_tw` (`impress_word`, `word_status`, `impress_type`, `baby_sex`), 
KEY `ind_starbaby_impress_word_wi` (`word_status`, `impress_type`, `baby_sex`)
)  AUTO_INCREMENT = 41 CHARSET = utf8 COMMENT = '宝宝印象的词库';
CREATE TABLE if not exists starbaby_lottery_rule (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`activity_num` bigint(20) NOT NULL COMMENT '活动id', 
`lottery_start_date` date NOT NULL COMMENT '活动中开启抽奖的日期', 
`lottery_end_date` date NOT NULL COMMENT '活动中关闭的抽奖的日期', 
`lottery_start_time` datetime NOT NULL COMMENT '每天抽奖的开始时间', 
`lottery_end_time` datetime NOT NULL COMMENT '每天抽奖的结束时间', 
`lottery_info` varchar(200) NULL COMMENT '抽奖的奖项设置相关信息', 
`lottery_status` tinyint(4) NOT NULL COMMENT '抽奖活动的状态', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`b_int` int(11) NULL COMMENT '备用字段', 
`b_varchar` varchar(512) NULL COMMENT '备用字段', 
`lottery_seed` int(11) NULL COMMENT '抽奖计算种子', 
PRIMARY KEY (`id`), 
KEY `ind_starbaby_lottery_rule_stat` (`activity_num`, `lottery_status`)
)  AUTO_INCREMENT = 13 CHARSET = utf8 COMMENT = '明星宝宝抽奖活动规则';
CREATE TABLE if not exists starbaby_voteinfo (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
`activity_num` bigint(20) NOT NULL COMMENT '活动编号', 
`competitor_num` bigint(20) NOT NULL COMMENT '参赛者编号', 
`vote_ip` varchar(32) NULL COMMENT '投票者ip', 
`user_id` bigint(20) NULL COMMENT '投票的用户id', 
`track_id` varchar(32) NOT NULL COMMENT '浏览器自带id', 
`vote_count` int(11) NOT NULL COMMENT '投票数 默认为1', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录修改时间', 
`b_int` bigint(20) NULL COMMENT '预留整型字段', 
`b_varchar` varchar(512) NULL COMMENT '预留字符串字段', 
`vote_type` tinyint(4) NULL COMMENT '投票类型', 
PRIMARY KEY (`id`), 
KEY `ind_starbaby_voteinfo_tid` (`track_id`, `activity_num`, `competitor_num`), 
KEY `ind_starbaby_voteinfo_uid` (`user_id`, `activity_num`, `competitor_num`), 
KEY `ind_starbaby_voteinfo_vip` (`vote_ip`, `activity_num`), 
KEY `ind_starbaby_voteinfo_anum` (`activity_num`, `vote_type`, `gmt_create`, `competitor_num`, `vote_count`)
)  AUTO_INCREMENT = 10190401 CHARSET = utf8 COMMENT = '投票记录表';
CREATE TABLE if not exists tag_black_item (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`template_id` int(11) NOT NULL COMMENT '模板ID，schedule_tagging主键', 
`black_id` bigint(20) NOT NULL COMMENT '黑名单ID，可能会卖家ID或者商品iD', 
`item_status` int(11) DEFAULT '0' NOT NULL COMMENT '0启用，-1删除。r增加、逻辑删除数据。逻辑删除后，再次新增则增加一条记录', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 4 CHARSET = utf8 COMMENT = '打标黑名单表';
CREATE TABLE if not exists tag_thread (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '鑷1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523涓婚敭', 
`seller_id` bigint(20) NOT NULL COMMENT '鍗栧1,2,4,6,7,8,11,56,68,89,435,4523id', 
`brand_id` bigint(20) NOT NULL COMMENT '鍝佺墝id', 
`op` int(11) NOT NULL COMMENT '鎿嶄綔锛1,2,4,6,7,8,11,56,68,89,435,4523锛氭墦鏍囷紝1:鍘绘爣锛', 
`succ` int(11) NOT NULL COMMENT '鏄1,2,4,6,7,8,11,56,68,89,435,4523惁鎴愬姛', 
`gmt_create` datetime NOT NULL COMMENT '璁板綍鍒涘缓鏃堕棿', 
`gmt_modified` datetime NOT NULL COMMENT '璁板綍鏈1,2,4,6,7,8,11,56,68,89,435,4523悗淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿', 
`fail_time` int(11) NULL COMMENT '鎵ц1,2,4,6,7,8,11,56,68,89,435,4523澶辫触鐨勬1,2,4,6,7,8,11,56,68,89,435,4523鏁', 
PRIMARY KEY (`id`), 
KEY `idx_tt_sid` (`seller_id`, `brand_id`, `op`, `succ`), 
KEY `idx_tt_succ` (`succ`)
)  AUTO_INCREMENT = 3349 CHARSET = utf8 COMMENT = '淇濆瓨鍙戠敓寮傚父鐨勬壒閲忔爣绛惧1,2,4,6,7,8,11,56,68,89,435,4523鐞嗙嚎绋嬩俊鎭';
CREATE TABLE if not exists tagging_fail_item (
`id` int(11) AUTO_INCREMENT NOT NULL, 
`proc_id` bigint(20) NOT NULL COMMENT '商品ID、卖家ID', 
`behavior` int(11) NOT NULL COMMENT '打标，去标', 
`classify` int(11) NOT NULL COMMENT '标类型,-1扩展属性，1卖家标，2商品标，4卖家类目标', 
`status` int(11) NOT NULL COMMENT '0,成功,1,宝贝不合法,2,失败,3,待处理', 
`info` varchar(2047) NULL COMMENT '标签的信息： 扩展属性StructStr,ChildStr,卖家类目标：catId', 
`gmt_create` datetime NOT NULL COMMENT '标签创建日期', 
`gmt_modified` datetime NOT NULL COMMENT '标签最近编辑日期', 
`tag_id` int(11) NOT NULL COMMENT '标签ID', 
PRIMARY KEY (`id`), 
KEY `ind_tagging_fail_item_stat` (`status`, `gmt_create`)
)  AUTO_INCREMENT = 343085 CHARSET = utf8 COMMENT = '记录打标失败的宝贝，数据量500w左右';
CREATE TABLE if not exists tmp_st_spu_extend (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '鑷1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523涓婚敭id', 
`spu_id` bigint(20) UNSIGNED NOT NULL COMMENT 'spu_id', 
`brand_id` bigint(20) UNSIGNED NOT NULL COMMENT '鍝佺墝id', 
`designer_info` varchar(100) NOT NULL COMMENT '璁捐1,2,4,6,7,8,11,56,68,89,435,4523甯', 
`video` varchar(255) NOT NULL COMMENT '瑙嗛1,2,4,6,7,8,11,56,68,89,435,4523', 
`extend_info` varchar(255) NOT NULL COMMENT '鎵╁睍淇℃伅', 
`extend_info2` varchar(255) NOT NULL COMMENT '鎵╁睍淇℃伅', 
`is_deleted` tinyint(4) NOT NULL COMMENT '鏄1,2,4,6,7,8,11,56,68,89,435,4523惁鍒犻櫎', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
PRIMARY KEY (`id`), 
KEY `idx_se_sid` (`spu_id`, `is_deleted`), 
KEY `idx_se_bid` (`brand_id`, `is_deleted`)
)  AUTO_INCREMENT = 4 CHARSET = utf8 COMMENT = 'spu鎵╁睍淇℃伅';
CREATE TABLE if not exists topic (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`name` varchar(40) NOT NULL COMMENT '话题名称', 
`create_time` datetime NOT NULL COMMENT '话题创建时间', 
`banner_url` varchar(255) NULL COMMENT '该话题横幅的超链接地址', 
`description` varchar(255) NULL COMMENT '关于该话题的描述', 
`rank` varchar(4) DEFAULT '0011' NOT NULL COMMENT '排行. 0001新话题排行,0010热门排行.0011全部', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
`type` varchar(15) NULL COMMENT '格式为id1,id2,id3 因为一个话题可能属于多种类别', 
PRIMARY KEY (`id`), 
UNIQUE `uk_t_name` (`name`), 
KEY `ind_topic_ctime` (`create_time`)
)  AUTO_INCREMENT = 126 CHARSET = utf8;
CREATE TABLE if not exists user_profile (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
`user_id` bigint(20) UNSIGNED NOT NULL, 
`track_id` varchar(32) NOT NULL COMMENT '没有清cookie之前,用户访问TAOBAO的trackId保持不变', 
`content` varchar(2048) NULL COMMENT '属性值字段,由应用各自维护', 
`app_id` int(11) NOT NULL COMMENT '区分应用', 
`condition_01` varchar(32) NULL COMMENT '查询条件_01:字符串', 
`condition_02` varchar(32) NULL COMMENT '查询条件_02:字符串', 
`condition_03` bigint(20) NULL COMMENT '查询条件_03:数字', 
`status` tinyint(3) UNSIGNED NOT NULL COMMENT '当前profile信息的状态,0表示正常，1表示被取消，2表示删除', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '改修时间', 
`finish_task` varchar(32) NULL COMMENT '任务完成占位符', 
PRIMARY KEY (`id`), 
UNIQUE `uk_up_uid` (`user_id`, `app_id`, `track_id`), 
KEY `idx_up_tid` (`track_id`, `app_id`, `status`)
)  AUTO_INCREMENT = 20551754 CHARSET = utf8;
CREATE TABLE if not exists user_task (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '任务id', 
`name` varchar(32) NOT NULL COMMENT '任务名', 
`summary` varchar(256) NULL COMMENT '任务详细描述', 
`status` tinyint(3) UNSIGNED NOT NULL COMMENT '任务是否正常，1不正常，0正常', 
`tag` int(11) NOT NULL COMMENT '任务规则标签， 1：相册数；2：照片数;4 :喜欢数;8：评论数;16：分享购物记录;32、签到', 
`threshold` varchar(32) NULL COMMENT '任务完成判断阈值', 
`lottery_amount` int(11) NOT NULL COMMENT '抽奖机会次数;为0表示不抽奖;-1表示不限次数', 
`vmarket` int(11) NOT NULL COMMENT '垂直市场,1母婴；2：旅游', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
PRIMARY KEY (`id`), 
KEY `ind_user_task_vstat` (`vmarket`, `status`)
)  AUTO_INCREMENT = 5 CHARSET = utf8 COMMENT = '任务表，数据量几百';
CREATE TABLE if not exists user_task_action (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '任务事件id', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户数字id', 
`nick` varchar(32) NULL COMMENT '用户nick', 
`task_id` bigint(20) UNSIGNED NOT NULL COMMENT '任务id', 
`reward_id` bigint(20) UNSIGNED NULL COMMENT '奖励id', 
`feature` varchar(32) NULL, 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
PRIMARY KEY (`id`), 
KEY `ind_user_task_action_utid` (`user_id`, `task_id`), 
KEY `ind_user_task_action_urid` (`user_id`, `reward_id`), 
KEY `ind_user_task_action_trid` (`task_id`, `reward_id`, `gmt_modified`)
)  AUTO_INCREMENT = 76563 CHARSET = utf8 COMMENT = '母婴用户行为表，数据量几百万';
CREATE TABLE if not exists vmarket_jiaju_museum (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`museum_id` int(11) NOT NULL COMMENT '馆id，唯一', 
`museum_name` varchar(128) NOT NULL COMMENT '馆名称', 
`category_id` varchar(128) NOT NULL COMMENT '类目id串，以英文的逗号分隔', 
`remark` varchar(500) NULL COMMENT '备注', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`tag_id` int(11) NOT NULL COMMENT '标签id', 
PRIMARY KEY (`id`), 
KEY `idx_vjm_mid` (`museum_id`)
)  AUTO_INCREMENT = 6 CHARSET = utf8 COMMENT = '存储家居打标后台的馆信息';
CREATE TABLE if not exists vmarket_jiaju_tag (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家id', 
`seller_name` varchar(63) NOT NULL COMMENT '卖家昵称', 
`tag_id` int(11) NOT NULL COMMENT '标签id', 
`category_id` varchar(128) NOT NULL COMMENT '类目id串，以逗号分隔', 
`status` int(11) DEFAULT '0' NOT NULL COMMENT '状态，0：正常，-1删除', 
`creator` varchar(31) NOT NULL COMMENT '创建人', 
`modifier` varchar(31) NOT NULL COMMENT '最后修改人', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`remark` varchar(500) NULL COMMENT '备注', 
`museum_id` int(11) NOT NULL COMMENT '馆id', 
PRIMARY KEY (`id`), 
KEY `idx_vjt_mid` (`museum_id`, `status`), 
KEY `idx_vjt_sid` (`seller_id`, `tag_id`, `museum_id`)
)  AUTO_INCREMENT = 946 CHARSET = utf8 COMMENT = '存储家居打标卖家信息';
CREATE TABLE if not exists vmarket_museum (
`id` int(11) NOT NULL COMMENT '馆ID:parent_id不为0时，是tagId，根据当前parent_id为0的记录的id最大值+1生成', 
`name` varchar(63) NOT NULL COMMENT '馆名称', 
`status` tinyint(4) NOT NULL COMMENT '状态:0 正常,-1 删除,-2 屏蔽', 
`parent_id` int(11) NOT NULL COMMENT '父馆id，如果为0，代表此为分类，不是一个实际的馆，不能挂商品', 
`description` varchar(255) NOT NULL COMMENT '对此馆的介绍', 
`creator` varchar(31) NOT NULL COMMENT '创建者', 
`modifier` varchar(31) NOT NULL COMMENT '最后修改者', 
`features` varchar(4095) NULL COMMENT '扩展字段,暂无用途', 
`sort_order` int(11) NOT NULL COMMENT '排序值', 
`market_optioins` int(11) NULL COMMENT '扩展字段,暂无用途', 
`gmt_created` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
`navigate_name` varchar(63) NOT NULL COMMENT '前台馆名，分类时，馆名称与前台管名称相同', 
PRIMARY KEY (`id`), 
KEY `ind_vmarket_museum_pid` (`parent_id`, `sort_order`, `status`), 
KEY `ind_VMARKET_MUSEUM_name` (`name`)
)  CHARSET = utf8 COMMENT = '垂直市场女装风格管,数据量5k以内';
CREATE TABLE if not exists vmarket_museum_auth (
`id` int(11) AUTO_INCREMENT NOT NULL COMMENT '主键，自增id', 
`museum_id` int(11) NOT NULL COMMENT '馆id', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家的数字id', 
`seller_name` varchar(63) NOT NULL COMMENT '卖家的nick', 
`status` tinyint(4) NOT NULL COMMENT '状态：1.授权；2.没收权限', 
`creator` varchar(31) NOT NULL COMMENT '创建者', 
`modifier` varchar(31) NOT NULL COMMENT '最后修改者', 
`gmt_created` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
`crime_cnt` int(11) DEFAULT '0' COMMENT '风格馆卖家宝贝清退计数', 
PRIMARY KEY (`id`), 
UNIQUE `uk_vmarket_museum_auth_msid` (`museum_id`, `seller_id`), 
KEY `ind_VMARKET_MUSEUM_AUTH_stat` (`status`, `seller_id`)
)  AUTO_INCREMENT = 1105 CHARSET = utf8 COMMENT = '存储授权、清退的卖家信息,数据量50w以内';
CREATE TABLE if not exists zlist_filter_form_info (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`crm_display_name` varchar(128) NOT NULL COMMENT 'crm系统里面的显示名称.例如：正品保障', 
`crm_name` varchar(32) NOT NULL COMMENT 'crm里面的参数名称：例如fcQuality', 
`display_name` varchar(32) NOT NULL COMMENT '在hesper里面页面上面显示的名称', 
`param_name` varchar(32) NOT NULL COMMENT 'hesper页面上的变量名称。例如:user_type', 
`param_value` varchar(64) NOT NULL COMMENT 'hesper页面上的变量数值。例如:1', 
`title` varchar(512) NULL COMMENT 'hesper页面上面显示的title信息', 
`disabled_parameter_name` varchar(32) NULL COMMENT '参数名。hesper里面的业务规则，当某个参数参数值对出现的时候默认disabled掉。例如:viewIndex', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`disabled_parameter_value` varchar(64) NULL COMMENT '参数值。hesper里面的业务规则，当某个参数参数值对出现的时候默认disabled掉。例如:10', 
`status` int(11) NOT NULL COMMENT '状态: 0 无效，1 有效: 2: 已删除', 
`describe_info` varchar(512) NULL COMMENT '该filterfom选项的备注信息', 
`sort_order` int(11) NOT NULL COMMENT '排序值:排序值越小越靠前，用于定义在hesper前端的显示顺序', 
`env` varchar(8) DEFAULT 'daily' NOT NULL COMMENT '环境： 日常环境:daily   预发环境：prepub   线上环境:online', 
`operator` varchar(64) NOT NULL COMMENT '最后一次的操作人', 
PRIMARY KEY (`id`), 
KEY `idx_xlist_filter_form_info_crm_name` (`crm_name`, `env`)
)  AUTO_INCREMENT = 85 CHARSET = utf8 COMMENT = '用来存放hesper应用里面的filterform信息, 记录不会超过2000';
CREATE TABLE if not exists zlist_page_template (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`content` varchar(2048) NOT NULL COMMENT '页面模板配置的xml数据', 
`operator` varchar(64) NOT NULL COMMENT '最近一次的操作人', 
`env` varchar(32) NOT NULL COMMENT '环境标记', 
`status` int(11) NOT NULL COMMENT '模板配置的状态（生效，删除）', 
`name` varchar(512) NOT NULL COMMENT '页面模板的描述，用来方便的区分不同的模板', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 7 CHARSET = utf8 COMMENT = 'hesper页面模板配置信息';
CREATE TABLE if not exists zlist_parameter_info (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`name` varchar(64) NOT NULL COMMENT 'url参数名称。例如:q', 
`validator_rules` varchar(512) NULL COMMENT '参数验证规则,数据格式: 验证规则1^规则参数#验证规则2^验证规则2参数,验证规则: number:代表是整数,enum:代表是允许设置的字符,multinumber:代表多数值,规则参数：number没有参数, multinumber有参数,参数为分割符号，比如半角逗号[,],enum有参数,参数值为多个允许的数值，数值之间使用半角逗号[,]分割,里面的数值使用urlEncode处理过', 
`describe_info` varchar(512) NULL COMMENT '备注信息', 
`status` int(11) NOT NULL COMMENT '状态: 0 无效，1 有效, 2: 已删除', 
`disable_values` varchar(512) NULL COMMENT '禁止的参数数值,参数值使用urlEncode(GBK)处理过,多个数值之间使用逗号分隔', 
`need_render_url` int(11) NOT NULL COMMENT '是否需要render到url里面, 0不需要，1需要', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`env` varchar(8) DEFAULT 'daily' NOT NULL COMMENT '环境： 日常环境:daily 预发环境：prepub 线上环境:online', 
`operator` varchar(64) NOT NULL COMMENT '最近一次的操作人', 
PRIMARY KEY (`id`), 
KEY `idx_parameter_info_name` (`name`, `env`)
)  AUTO_INCREMENT = 393 CHARSET = utf8 COMMENT = '存放HESPER应用参数定义信息, 记录不会超过2000条';
CREATE TABLE if not exists zlist_search_mapping_info (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`param_name` varchar(32) NOT NULL COMMENT 'url参数名称', 
`search_engine_type` int(11) NOT NULL COMMENT '搜索引擎类型：主搜索：1，商城搜索：2，VSearch: 3，spuSearch: 4，DgSearch: 5', 
`mapping_type` int(11) NOT NULL COMMENT '参数映射规则,1 代表:参数名映射  例如:url参数的数值和搜索时推送给搜索端的数值是一样的,2 代表:参数值映射 例如：url参数+url参数值能和搜索参数名称+参数值进行简单的映射，url的参数数值也只有3个左右。', 
`mapping_detail` varchar(512) NOT NULL COMMENT '参数映射规则详细信息. 如果mapping_type为1，则存放搜索参数名称，如果mapping_type为2，则存放具体的映射规则。', 
`status` int(11) NOT NULL COMMENT '参数状态  0:无效   1: 有效  2：已删除', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`describe_info` varchar(512) NULL COMMENT '备注信息', 
`env` varchar(8) DEFAULT 'daily' NOT NULL COMMENT '环境： 日常环境:daily 预发环境：prepub 线上环境:online', 
`operator` varchar(64) NOT NULL COMMENT '最近一次的操作人', 
PRIMARY KEY (`id`), 
KEY `idx_zlist_search_mapping_info_param_name` (`param_name`, `search_engine_type`, `env`)
)  AUTO_INCREMENT = 291 CHARSET = utf8 COMMENT = '用来存放hesper里面前端url参数和后端搜索引擎参数之间的映射关系, 记录不会超过2000';
CREATE TABLE if not exists zlist_url_rule (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`content` varchar(512) NOT NULL COMMENT 'url规则描述', 
`operator` varchar(64) NOT NULL COMMENT '最近一次的操作人', 
`priority` int(11) NOT NULL COMMENT '规则优先级，数字越大优先级越高', 
`env` varchar(32) NOT NULL COMMENT '环境的标记（日常，预发，线上等）', 
`status` int(11) NOT NULL COMMENT 'url规则的状态(生效，删除)', 
`type` varchar(16) NOT NULL COMMENT 'url规则的类型（market，cat，param）', 
`template_id` bigint(20) NOT NULL COMMENT '页面模板的主键ID', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 7 CHARSET = utf8 COMMENT = 'hesper的url规则表';
