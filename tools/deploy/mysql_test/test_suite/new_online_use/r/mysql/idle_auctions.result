SELECT category_id, value_id, AVG(CASE WHEN day_pay_uv > 1 THEN success_uv / day_pay_uv END) AS avg_pay_success_rate, AVG(CASE WHEN `all_user` > 1 THEN day_pay_uv / `all_user` END) AS avg_pay_rate, AVG(CASE WHEN day_pay_uv > 1 THEN adjust_pay_user / day_pay_uv END) AS avg_adjust_rate , AVG(CASE WHEN user_count > 1 THEN success_uv / user_count END) AS avg_all_success_rate, AVG(CASE WHEN user_count > 1 THEN `all_user` / user_count END) AS avg_all_order_rate, AVG(CASE WHEN good_rate + mid_rate + bad_rate > 1 THEN good_rate / (good_rate + mid_rate + bad_rate) END) AS avg_good_rate, AVG(CASE WHEN day_pay_uv > 1 THEN b_refund_uv / day_pay_uv END) AS avg_pay_adjust_rate, AVG(CASE WHEN day_pay_uv > 1 THEN q_refund_uv / day_pay_uv END) AS avg_refund_rate , AVG(CASE WHEN `all_user` > 1 THEN success_uv / `all_user` END) AS avg_success_rate, MAX(CASE WHEN day_pay_uv > 1 THEN success_uv / day_pay_uv END) AS max_pay_success_rate, MAX(CASE WHEN `all_user` > 1 THEN day_pay_uv / `all_user` END) AS max_pay_rate, MAX(CASE WHEN day_pay_uv > 1 THEN adjust_pay_user / day_pay_uv END) AS max_adjust_rate, MAX(CASE WHEN user_count > 1 THEN success_uv / user_count END) AS max_all_success_rate , MAX(CASE WHEN user_count > 1 THEN `all_user` / user_count END) AS max_all_order_rate, MAX(CASE WHEN good_rate + mid_rate + bad_rate > 1 THEN good_rate / (good_rate + mid_rate + bad_rate) END) AS max_good_rate, MAX(CASE WHEN day_pay_uv > 1 THEN b_refund_uv / day_pay_uv END) AS max_pay_adjust_rate, MAX(CASE WHEN day_pay_uv > 1 THEN q_refund_uv / day_pay_uv END) AS max_refund_rate, MAX(CASE WHEN `all_user` > 1 THEN success_uv / `all_user` END) AS max_success_rate , MIN(CASE WHEN day_pay_uv > 1 THEN success_uv / day_pay_uv END) AS min_pay_success_rate, MIN(CASE WHEN `all_user` > 1 THEN day_pay_uv / `all_user` END) AS min_pay_rate, MIN(CASE WHEN day_pay_uv > 1 THEN adjust_pay_user / day_pay_uv END) AS min_adjust_rate, MIN(CASE WHEN user_count > 1 THEN success_uv / user_count END) AS min_all_success_rate, MIN(CASE WHEN user_count > 1 THEN `all_user` / user_count END) AS min_all_order_rate , MIN(CASE WHEN good_rate + mid_rate + bad_rate > 1 THEN good_rate / (good_rate + mid_rate + bad_rate) END) AS min_good_rate, MIN(CASE WHEN day_pay_uv > 1 THEN b_refund_uv / day_pay_uv END) AS min_pay_adjust_rate, MIN(CASE WHEN day_pay_uv > 1 THEN q_refund_uv / day_pay_uv END) AS min_refund_rate, MIN(CASE WHEN `all_user` > 1 THEN success_uv / `all_user` END) AS min_success_rate FROM recycler_recommended_index GROUP BY category_id, value_id;
category_id	value_id	avg_pay_success_rate	avg_pay_rate	avg_adjust_rate	avg_all_success_rate	avg_all_order_rate	avg_good_rate	avg_pay_adjust_rate	avg_refund_rate	avg_success_rate	max_pay_success_rate	max_pay_rate	max_adjust_rate	max_all_success_rate	max_all_order_rate	max_good_rate	max_pay_adjust_rate	max_refund_rate	max_success_rate	min_pay_success_rate	min_pay_rate	min_adjust_rate	min_all_success_rate	min_all_order_rate	min_good_rate	min_pay_adjust_rate	min_refund_rate	min_success_rate
