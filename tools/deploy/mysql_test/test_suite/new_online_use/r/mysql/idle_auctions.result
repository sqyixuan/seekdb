)  AUTO_INCREMENT = 1278 CHARSET = utf8 COMMENT = '搜索定制化-规则配置信息表';
CREATE TABLE if not exists sc_schema_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
