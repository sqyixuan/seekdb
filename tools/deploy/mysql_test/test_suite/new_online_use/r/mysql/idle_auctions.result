`banner_order` tinyint(4) NOT NULL COMMENT 'banner 序列', 
PRIMARY KEY (`id`), 
KEY `index_order` (`banner_order`)
)  AUTO_INCREMENT = 25 CHARSET = utf8 COMMENT = 'idle_home_banner';
CREATE TABLE if not exists idle_home_theme (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '1,2,4,6,7,8,11,56,68,89,435,4523÷1,2,4,6,7,8,11,56,68,89,435,4523ü', 
`gmt_create` datetime NOT NULL COMMENT '′′1,2,4,6,7,8,11,56,68,89,435,4523¨ê±1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523', 
`gmt_modified` datetime NOT NULL COMMENT 'DT1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523ê±1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523', 
`theme_name` varchar(128) NOT NULL COMMENT '1,2,4,6,7,8,11,56,68,89,435,4523÷ìa±ê1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231ê1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,452331,2,4,6,7,8,11,56,68,89,435,4523', 
`theme_rule` varchar(400) NULL COMMENT '主题报名规则', 
`status` tinyint(4) DEFAULT '0' COMMENT '状态(空或0:正常，1:非正常)', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 45 CHARSET = utf8 COMMENT = '首页主题标签';
CREATE TABLE if not exists idle_home_theme_item (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '1,2,4,6,7,8,11,56,68,89,435,4523÷1,2,4,6,7,8,11,56,68,89,435,4523ü', 
`gmt_create` datetime NOT NULL COMMENT '′′1,2,4,6,7,8,11,56,68,89,435,4523¨ê±1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523', 
`gmt_modified` datetime NOT NULL COMMENT 'DT1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523ê±1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523', 
`item_id` bigint(20) UNSIGNED NOT NULL COMMENT 'éì1,2,4,6,7,8,11,56,68,89,435,4523·id', 
`main_title` varchar(128) NULL COMMENT '主标题', 
`sub_title` varchar(128) NULL COMMENT '副标题', 
`theme_id` bigint(20) UNSIGNED NOT NULL COMMENT '1,2,4,6,7,8,11,56,68,89,435,4523ùê1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523÷ìa±ê1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523', 
`online_date` datetime NULL COMMENT '宝贝生效时间', 
`join_frontpage` tinyint(4) DEFAULT '0' COMMENT '是否加入首页混排.0:不加入,1加入', 
`status` tinyint(4) DEFAULT '0' COMMENT '审核状态（空或0:小二直接导入,1:提交,2:审核通过,3:驳回，9:不在线）', 
`auditor` bigint(20) NULL COMMENT '处理人（空:历史数据小二上传或直接添加）', 
`auditor_nick` varchar(32) NULL COMMENT '操作人', 
`user_id` bigint(20) UNSIGNED NULL COMMENT '用户id', 
PRIMARY KEY (`id`), 
