CREATE TABLE if not exists act_earth_notice (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`notice_cat` int(11) NOT NULL COMMENT '宣言类别', 
`notice_cat_name` varchar(20) NOT NULL COMMENT '宣言名称', 
`notice` varchar(118) NOT NULL COMMENT '宣言', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`nick` varchar(32) NULL COMMENT '昵称', 
`status` int(11) DEFAULT '0' NOT NULL COMMENT '留言状态  0：正常 1：可以用户', 
PRIMARY KEY (`id`), 
UNIQUE `idx_act_earth_notice_user_id` (`user_id`), 
KEY `idx_act_earth_notice_status` (`status`), 
KEY `idx_act_earth_notice_nick` (`nick`), 
KEY `idx_act_earth_notice_cat` (`notice_cat`), 
KEY `idx_act_earth_notice_statcat` (`notice_cat`, `status`)
)  AUTO_INCREMENT = 78838 CHARSET = utf8 COMMENT = '地球日活动宣言表';
CREATE TABLE if not exists act_earth_user_support (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`share_uid` bigint(20) NOT NULL COMMENT '宣言用户id', 
`share_cat` bigint(20) NOT NULL COMMENT '宣言类别', 
`share_nick` varchar(32) NOT NULL COMMENT '宣言用户昵称', 
`user_id` bigint(20) NULL COMMENT '支持者id', 
`ip` varchar(30) NULL COMMENT '支持者ip', 
`cookie` varchar(50) NULL COMMENT '支持者cookie', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
KEY `idx_Act_earth_user_support_user_id` (`user_id`), 
KEY `idx_user_support_share_uid` (`share_uid`), 
KEY `idx_user_support_gmt` (`gmt_create`), 
KEY `idx_user_support_uidid` (`share_uid`, `user_id`), 
KEY `idx_user_support_uidipcoo` (`share_uid`, `ip`, `cookie`)
)  AUTO_INCREMENT = 369773 CHARSET = utf8 COMMENT = '地球日活动用户支持表';
CREATE TABLE if not exists erhuo_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NULL COMMENT '用户ID', 
`nick` varchar(118) NULL COMMENT '用户昵称', 
`title` varchar(200) NULL COMMENT '标题', 
`desc_text` varchar(100) NULL COMMENT '描述', 
`image_url` varchar(200) NULL COMMENT '图片地址', 
`mix_image_url` varchar(200) NULL COMMENT '合成图片地址', 
`type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '活动类型  1- 贩2', 
`feature` varchar(100) NULL COMMENT '冗余信息', 
`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '-1 无效状态', 
`act_id` bigint(20) UNSIGNED DEFAULT '0' COMMENT '冗余活动ID', 
`pop_num` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '人气指数', 
PRIMARY KEY (`id`), 
KEY `orderbykey` (`gmt_create`, `status`), 
KEY `userkey` (`user_id`, `status`)
)  AUTO_INCREMENT = 2744 CHARSET = utf8 COMMENT = '二货信息';
CREATE TABLE if not exists idle_act_award (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`award_type_id` int(11) NOT NULL COMMENT '奖励类型', 
`award_detail` varchar(500) NULL COMMENT '奖励参数明细，json串', 
`task_id` bigint(20) UNSIGNED NOT NULL COMMENT '所属任务id', 
`status` int(11) NULL COMMENT '奖励状态，1为正常，2为删除', 
`award_user_type` int(11) NOT NULL COMMENT '奖励对象，1为卖家，2为买家', 
PRIMARY KEY (`id`), 
KEY `idx_taskid` (`task_id`)
)  AUTO_INCREMENT = 4 CHARSET = utf8 COMMENT = '活动奖励信息';
CREATE TABLE if not exists idle_act_data (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NULL COMMENT '用户id', 
`activity_id` bigint(20) UNSIGNED NULL COMMENT '活动id', 
`task_id` bigint(20) UNSIGNED NULL COMMENT '任务id', 
`award_id` bigint(20) UNSIGNED NULL COMMENT '奖励id', 
PRIMARY KEY (`id`), 
KEY `ind_us_ac_ta` (`user_id`, `activity_id`, `task_id`), 
KEY `idx_all` (`activity_id`, `task_id`, `award_id`, `user_id`, `gmt_create`, `id`)
)  AUTO_INCREMENT = 559403 CHARSET = utf8 COMMENT = '活动获奖记录';
CREATE TABLE if not exists idle_act_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`name` varchar(25) NOT NULL COMMENT '活动名称', 
`activity_start` datetime NULL COMMENT '开始时间', 
`activity_end` datetime NULL COMMENT '结束时间', 
`type` smallint(6) NULL COMMENT '活动类型', 
`owner` varchar(10) NULL COMMENT '创建者', 
`attribute` varchar(100) NULL COMMENT '活动其他信息', 
`aid` bigint(20) NULL COMMENT '定向回收活动的id', 
PRIMARY KEY (`id`), 
KEY `ind_ow` (`owner`), 
KEY `idx_start_end_owner_name_id` (`activity_start`, `activity_end`, `owner`, `name`, `id`)
)  AUTO_INCREMENT = 3 CHARSET = utf8 COMMENT = '活动列表';
CREATE TABLE if not exists idle_act_machine_data (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`user_nick` varchar(50) NULL COMMENT '用户昵称', 
`utdid` varchar(50) NULL COMMENT 'ios设备号', 
`imei` varchar(50) NULL COMMENT 'android设备号', 
`app_id` bigint(20) UNSIGNED NOT NULL COMMENT 'appId:21407387 android ,12431167  ios', 
`last_login_time` datetime NULL COMMENT '最后一次登录时间', 
`user_id` bigint(20) UNSIGNED NULL COMMENT '用户userId', 
PRIMARY KEY (`id`), 
KEY `index_utdid` (`utdid`), 
KEY `index_user_nick` (`user_nick`), 
KEY `index_imei` (`imei`), 
KEY `idx_last_login_time_user_id` (`last_login_time`, `user_id`)
)  AUTO_INCREMENT = 52205229 CHARSET = utf8 COMMENT = '二手客户端用户机器历史数据';
CREATE TABLE if not exists idle_act_maimeng_detail (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户Id', 
`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '商品Id', 
`status` tinyint(4) NOT NULL COMMENT '状态：1:支持，-1:反对', 
`type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '0:卖萌,1:旅游卫视', 
PRIMARY KEY (`id`), 
KEY `index_item_id` (`item_id`), 
KEY `index_user_id` (`user_id`), 
KEY `index_item_id_type` (`item_id`, `type`)
)  AUTO_INCREMENT = 82090 CHARSET = utf8 COMMENT = '二手活动投票详情';
CREATE TABLE if not exists idle_act_maimeng_sum (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '宝贝ID', 
`support_num` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '支持数', 
`unsupport_num` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '反对数', 
`total_num` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '总数', 
`type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '0:卖萌 ,1:旅游卫视', 
PRIMARY KEY (`id`), 
KEY `index_unsupport_num` (`unsupport_num`), 
KEY `index_support_num` (`support_num`), 
KEY `index_item_id` (`item_id`), 
KEY `index_total_num` (`total_num`), 
KEY `index_item_id_type` (`item_id`, `type`)
)  AUTO_INCREMENT = 1450 CHARSET = utf8 COMMENT = '二手活动投票数据汇总表';
CREATE TABLE if not exists idle_act_task (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`activity_id` bigint(20) UNSIGNED NOT NULL COMMENT '所属活动ID', 
`task_type_id` int(11) NOT NULL COMMENT '任务类型ID，如发布、估价', 
`task_constraint` varchar(100) NULL COMMENT '任务约束', 
`activity_start` datetime NOT NULL COMMENT '开始时间', 
`activity_end` datetime NOT NULL COMMENT '结束时间', 
`status` tinyint(4) NOT NULL COMMENT '任务状态，1为正常，2为删除', 
`remark` varchar(200) NULL COMMENT '任务备注', 
PRIMARY KEY (`id`), 
KEY `ind_sta` (`status`), 
KEY `ind_ac` (`activity_id`)
)  AUTO_INCREMENT = 4 CHARSET = utf8 COMMENT = '活动任务信息';
CREATE TABLE if not exists idle_auction_tag_num (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`tagname` varchar(20) NOT NULL COMMENT '标签名', 
`matchnum` bigint(20) NOT NULL COMMENT '匹配数', 
`qualinum` bigint(20) NOT NULL COMMENT '合格数（比如：bqTag>=500）', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '宝贝标签数量对应表';
CREATE TABLE if not exists idle_auctions_credit (
`item_id` bigint(20) NOT NULL COMMENT '宝贝ID', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`ref_score` double NULL COMMENT '用户买家信用得分', 
`score` double NULL COMMENT '商品信用得分', 
`gmt_date` datetime NULL COMMENT '入库时间', 
`gmt_create` datetime NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NULL COMMENT '记录最后修改时间', 
`grade` double NULL COMMENT '商品基本信息分数', 
`buyer_star_id` bigint(20) NULL COMMENT '买家星级id', 
`buyer_star_name` varchar(111) NULL COMMENT '买家星级名称', 
`seller_star_id` bigint(20) NULL COMMENT '卖家星级id', 
`seller_star_name` varchar(111) NULL COMMENT '卖家星级名称', 
`vip_level` int(11) NULL COMMENT '用户星级', 
`attributes` varchar(100) NULL COMMENT '冗余字段', 
`online_item_count` int(11) NULL COMMENT '当前在线商品数', 
`user_type` int(11) NULL COMMENT '用户标记：与运算', 
`bq_tag` int(11) DEFAULT '0' COMMENT '商品等级', 
`item_tag` varchar(200) NULL COMMENT '商品标签', 
PRIMARY KEY (`item_id`), 
KEY `idx_user_id_type` (`user_id`, `user_type`)
)  CHARSET = utf8 COMMENT = '用户、商品等级信息';
CREATE TABLE if not exists idle_auctions_extra (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`item_id` bigint(20) NOT NULL COMMENT '宝贝数字id', 
`user_id` bigint(20) NOT NULL COMMENT '卖家数字id（索引）', 
`area` varchar(50) NOT NULL COMMENT '宝贝所在的区', 
`stuff_status` tinyint(4) NOT NULL COMMENT '宝贝新旧程度（10-全新 9-九成新 8-八成新  7-七成新及以下）', 
`tag` varchar(118) NULL COMMENT '宝贝标签', 
`offlined` tinyint(4) NOT NULL COMMENT '交易方式 （0-线上 1-线下 2-线上线下均可）', 
`status` tinyint(4) NOT NULL COMMENT '宝贝状态 （0-在线 1-售出 -1 用户删除 -2 用户下架 -3 小二下架 -4 小二删除 -5 从未上架 -9 cc -98 历史库宝贝）', 
`contacter` varchar(40) NULL COMMENT '联系人', 
`phone` varchar(20) NULL COMMENT '联系电话', 
`other_con` varchar(50) NULL COMMENT '其他联系方式', 
`first_modified` datetime NULL COMMENT '宝贝当天的第一次编辑时间', 
`gmt_create` datetime NOT NULL COMMENT '宝贝创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '宝贝修改时间', 
`nick` varchar(32) NULL COMMENT '用户昵称', 
`title` varchar(256) NULL COMMENT '宝贝标题', 
`pict_url` varchar(256) NULL COMMENT '主图路径', 
`reserve_price` decimal(14, 2) DEFAULT '0.00' COMMENT '商品价格', 
`category` bigint(20) NULL, 
`prov` varchar(20) NULL COMMENT '宝贝所在省', 
`city` varchar(30) NULL COMMENT '宝贝所在市', 
`desc_path` varchar(128) NULL COMMENT '描述路径', 
`auction_type` varchar(1) NULL COMMENT '宝贝类型 （a-拍卖 b-一口价）', 
`sold_quantity` int(11) DEFAULT '0' COMMENT '销售量', 
`item_from` varchar(118) NULL COMMENT '发布来源', 
`gps` varchar(40) NULL COMMENT '地图定位：纬度，经度', 
`pose_price` decimal(14, 2) NULL COMMENT '运费', 
`original_price` decimal(14, 2) DEFAULT '0.00' COMMENT '商品原价', 
`order_trade_id` bigint(20) NULL COMMENT '交易id', 
`chop_pic` varchar(256) NULL COMMENT '宝贝主图：正方形主图', 
`attributes` varchar(100) NULL COMMENT '业务系统自定义的属性，（key:value格式）', 
`property` varchar(2048) NULL, 
`grade` double NULL COMMENT '宝贝信息完善度的评分', 
`spu_id` bigint(20) NULL COMMENT '商品spu_id', 
`image_texts` varchar(128) NULL COMMENT '图文描述地址', 
`video_url` varchar(256) NULL COMMENT '视频地址', 
`user_modified` datetime NULL COMMENT '用户擦亮时间戳', 
PRIMARY KEY (`id`), 
UNIQUE `UK_IDLE_AUCTIONS_EXTRA_IID` (`item_id`), 
KEY `IDX_AUCTIONS_EXTRA_CATEGORY` (`category`, `gmt_create`, `status`), 
KEY `IDX_AUCTIONS_EXTRA_GMTCREATE` (`gmt_create`, `status`), 
KEY `IND_AUCTIONS_EXTRA_STATUS` (`status`, `gmt_modified`), 
KEY `IND_AUCTIONS_EXTRA_USERID` (`user_id`, `gmt_create`), 
KEY `IND_IDLE_AUCTIONS_EXTRA_OTID` (`order_trade_id`, `status`), 
KEY `idx_auctions_extra_usg` (`user_id`, `status`, `gmt_create`), 
KEY `IND_GMT_STATUS` (`gmt_modified`, `status`, `item_id`), 
KEY `idx_st_gc` (`status`, `gmt_create`), 
KEY `ind_userid_itemfrom` (`user_id`, `item_from`), 
KEY `ind_user_modified` (`user_modified`)
)  AUTO_INCREMENT = 232359142 CHARSET = utf8 COMMENT = '闲置宝贝信息表';
CREATE TABLE if not exists idle_auctions_extra_foractivity (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '宝贝数字id', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '卖家数字id（索引）', 
PRIMARY KEY (`id`), 
KEY `idx_itemid_userid` (`item_id`, `user_id`)
)  AUTO_INCREMENT = 2006284 CHARSET = utf8 COMMENT = '闲鱼商品表活动数据抽取表（从idle_auctions_extra表中抽取商品，odps回流进来）';
CREATE TABLE if not exists idle_auctions_extra_partner (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`taobao_user_id` bigint(20) NOT NULL COMMENT '淘宝卖家id', 
`partner_type_id` bigint(20) NOT NULL COMMENT '合作伙伴类型，按位运算，新浪微博为2的0次方=1', 
`partner_user_id` bigint(20) NULL COMMENT '合作伙伴的用户id', 
`partner_user_nick` varchar(32) NULL COMMENT '合作伙伴的用户昵称', 
`partner_user_sex` bigint(20) NULL COMMENT '合作伙伴的用户性别，1为男，2为女，3为未知', 
`partner_user_auth` bigint(20) NULL COMMENT '合作伙伴的认证信息，1为新浪微博加v，2为新浪微博达人', 
`partner_user_auth_detail` varchar(118) NULL COMMENT '合作伙伴的认证详细描述信息', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`partner_status` bigint(20) NOT NULL COMMENT '该记录状态，1为正常，0为不正常', 
PRIMARY KEY (`id`), 
KEY `idx_extra_partner_tui` (`taobao_user_id`)
)  AUTO_INCREMENT = 10358 CHARSET = utf8 COMMENT = '发布宝贝的合作伙伴用户信息';
CREATE TABLE if not exists idle_auctions_for_dump (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '商品Id', 
`title` varchar(118) NULL COMMENT '商品标题', 
`price` bigint(20) NULL COMMENT '转让价', 
`original_price` bigint(20) NULL COMMENT '原价', 
`discount` int(11) NULL COMMENT '折扣，75表示7.5折', 
`stuff_status` int(11) NULL COMMENT '10 全新 9 非全新', 
`pict_url` varchar(118) NULL COMMENT '主图链接', 
`chop_url` varchar(118) NULL COMMENT '方图链接', 
`pic_measure` varchar(20) NULL COMMENT '图片尺寸', 
`has_picurl` int(11) NULL COMMENT '是否有图 0 无 1 有', 
`cat_id` bigint(20) UNSIGNED NULL COMMENT '后台类目', 
`front_cat_id` varchar(118) NULL COMMENT '前台类目', 
`prov` varchar(10) NULL COMMENT '宝贝所在地 省份', 
`city` varchar(20) NULL COMMENT '城市', 
`area` varchar(30) NULL COMMENT '区县', 
`user_id` bigint(20) UNSIGNED NULL COMMENT '卖家id', 
`user_nick` varchar(30) NULL COMMENT '卖家nick', 
`has_phone` int(11) NULL COMMENT '是否有联系电话', 
`offline` int(11) NULL COMMENT '0:仅见面交易；1:在线交易；2:二者均可', 
`first_modified` bigint(20) UNSIGNED NULL COMMENT '当天第一次编辑时间', 
`scan` int(11) NULL COMMENT '流览量', 
`collect` int(11) NULL COMMENT '收藏数', 
`comment` int(11) NULL COMMENT '留言数', 
`heat` int(11) NULL COMMENT '宝贝热度', 
`item_desc` varchar(150) NULL COMMENT '宝贝描述', 
`has_desc` int(11) NULL COMMENT '是否有描述', 
`auction_type` varchar(1) NULL COMMENT '商品类型，拍卖:a 一口价:b', 
`auction_from` varchar(10) NULL COMMENT '发布来源', 
`auction_tag` varchar(118) NULL COMMENT '商品标签', 
`bq_tag` int(11) NULL COMMENT '商品排序分值', 
`position` varchar(40) NULL COMMENT 'gps', 
`total_cnt` int(11) NULL COMMENT '拍卖宝贝的出价数', 
`ends` bigint(20) UNSIGNED NULL COMMENT '结束时间', 
`properties` varchar(1024) NULL COMMENT '属性', 
`seller_types` varchar(118) NULL COMMENT '卖家类型', 
`user_score` int(11) NULL COMMENT '另一排序值', 
`has_video` int(11) NULL COMMENT '是否有语音', 
`video_url` varchar(118) NULL COMMENT '语音地址', 
`vlen` int(11) NULL COMMENT '语音长度', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '最后修改时间', 
`sell_status` int(11) NULL COMMENT '0 在线 1 已售出 2 下架', 
`fishpool_id` bigint(20) UNSIGNED NULL COMMENT '鱼塘id', 
`fishpool_topitem` tinyint(4) NULL COMMENT '鱼塘中是否置顶商品1否，99是', 
`theme_tab_id` bigint(20) UNSIGNED NULL COMMENT '主题id', 
`theme_tab_date` bigint(20) UNSIGNED NULL COMMENT '在主题中上线日期', 
`theme_tab_top` tinyint(4) NULL COMMENT '是否主题中顶置', 
PRIMARY KEY (`id`), 
KEY `index_item_id` (`item_id`), 
KEY `index_sell_status` (`sell_status`, `gmt_modified`)
)  AUTO_INCREMENT = 63120927 CHARSET = utf8 COMMENT = '二手商品宽表，仅用于搜索dump';
CREATE TABLE if not exists idle_auctions_grade (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`grade` double NOT NULL, 
`cnt` varchar(10) NOT NULL, 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '宝贝评分分布表';
CREATE TABLE if not exists idle_best_offer (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键id', 
`buyer_id` bigint(20) NOT NULL COMMENT '用户id', 
`buyer_nick` varchar(50) NOT NULL COMMENT '用户nick', 
`price` bigint(20) NOT NULL COMMENT '心愿价', 
`phone` varchar(50) NOT NULL COMMENT '联系电话', 
`prov` varchar(50) NULL COMMENT '省份', 
`city` varchar(50) NULL COMMENT '城市', 
`rank` int(11) NULL COMMENT '买家信用', 
`auth_status` tinyint(4) NOT NULL COMMENT '是否实名认证：1为已认证；0为未认证', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录修改时间', 
`item_id` bigint(20) NOT NULL COMMENT '商品id', 
`seller_id` bigint(20) NOT NULL COMMENT '商品对应的卖家Id', 
`biz_order_id` bigint(20) NULL COMMENT '该商品成交的订单号', 
`status` tinyint(4) NOT NULL COMMENT '璁1,2,4,6,7,8,11,56,68,89,435,4523环鐘舵1,2,4,6,7,8,11,56,68,89,435,4523锛1,2,4,6,7,8,11,56,68,89,435,4523绛夊緟鍗栧1,2,4,6,7,8,11,56,68,89,435,4523鍚屾剰锛1,2,4,6,7,8,11,56,68,89,435,4523鍥炴敹鍟嗚秴鏃朵粯娆句骇鐢熺殑鐘舵1,2,4,6,7,8,11,56,68,89,435,4523锛屼腑闂寸姸鎬侊紝3鍗栧1,2,4,6,7,8,11,56,68,89,435,4523宸茬粡鍚屾剰锛岀瓑寰呬拱瀹朵粯娆撅紝4宸叉彁浜ゆ柊璁1,2,4,6,7,8,11,56,68,89,435,4523环,璇ヨ1,2,4,6,7,8,11,56,68,89,435,4523浠蜂綔搴燂紝5鍗栧1,2,4,6,7,8,11,56,68,89,435,4523閫変腑鐨勫洖鏀跺晢锛岃繖涓1,2,4,6,7,8,11,56,68,89,435,4523笉鍋氬睍绀虹敤锛1,2,4,6,7,8,11,56,68,89,435,4523鍗栧1,2,4,6,7,8,11,56,68,89,435,4523涓嶅悓鎰忚1,2,4,6,7,8,11,56,68,89,435,4523浠蜂俊鎭', 
`item_detail` varchar(5000) NULL COMMENT '冗余一份回收平台提交过来的议价信息', 
`buyer_message` varchar(140) NULL COMMENT '涔板1,2,4,6,7,8,11,56,68,89,435,4523鐣欒█', 
`view_status` tinyint(4) NULL COMMENT '闃呰1,2,4,6,7,8,11,56,68,89,435,4523鐘舵1,2,4,6,7,8,11,56,68,89,435,4523锛1,2,4,6,7,8,11,56,68,89,435,4523涓烘湭闃咃紝1涓1,2,4,6,7,8,11,56,68,89,435,4523闃', 
`offer_from` bigint(20) NULL COMMENT '鏉ユ簮锛1,2,4,6,7,8,11,56,68,89,435,4523涓篜C', 
PRIMARY KEY (`id`), 
KEY `idx_iit_st` (`item_id`, `status`), 
KEY `idx_bid_gc` (`buyer_id`, `gmt_create`), 
KEY `idx_gc` (`gmt_create`), 
KEY `idx_gm` (`gmt_modified`), 
KEY `index_gmt` (`gmt_create`), 
KEY `index_bid_status_gmt` (`buyer_id`, `status`, `gmt_create`), 
KEY `idx_item_id_status_gmt_create` (`item_id`, `status`, `gmt_create`), 
KEY `index_sellerid_gmt` (`seller_id`, `gmt_create`)
)  AUTO_INCREMENT = 10119535 CHARSET = utf8 COMMENT = '闲置议价表信息';
CREATE TABLE if not exists idle_care_item (
`care_id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键，订阅id', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`item_id` bigint(20) NOT NULL COMMENT '商品id', 
`title` varchar(256) NOT NULL COMMENT '商品标题', 
`price` decimal(14, 2) NOT NULL COMMENT '商品价格', 
`pic_url` varchar(256) NOT NULL COMMENT '商品主图路径', 
`item_from` varchar(50) NOT NULL COMMENT '商品来源', 
`chop_pic` varchar(256) NULL COMMENT '商品正方形主图', 
`item_tag` varchar(118) NULL COMMENT '商品关键字', 
`category` bigint(20) NOT NULL COMMENT '叶子类目id', 
`property` varchar(2048) NULL COMMENT '类目属性', 
`stuff_status` tinyint(4) NULL COMMENT '商品新旧程度（10-全新 9-九成新 8-八成新 7-七成新及以下）', 
`status` tinyint(4) NOT NULL COMMENT '订阅状态:1表示订阅，2表示取消订阅', 
`spu_id` bigint(20) NULL COMMENT '商品的spu_id', 
`spu_property` varchar(2048) NULL COMMENT '标类商品对应的spu属性，含系统属性与非关键属性', 
`offlined` tinyint(4) NULL COMMENT '交易方式 （0-线上 1-线下 2-线上线下均可）', 
`gps` varchar(40) NULL COMMENT '地图定位：纬度,经度', 
`prov` varchar(20) NULL COMMENT '商品所在省份', 
`city` varchar(30) NULL COMMENT '商品所在城市', 
`area` varchar(50) NULL COMMENT '商品所在地区，同闲置子表', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
PRIMARY KEY (`care_id`), 
UNIQUE `uk_uid_itemid` (`user_id`, `item_id`), 
KEY `idx_uid_st_gm` (`user_id`, `status`, `gmt_modified`), 
KEY `idx_gm` (`gmt_modified`), 
KEY `idx_gc` (`gmt_create`)
)  AUTO_INCREMENT = 33968689 CHARSET = utf8 COMMENT = '闲置订阅列表';
