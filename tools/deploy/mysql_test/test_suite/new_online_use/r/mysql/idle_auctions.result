`order_onday_end_count` bigint(20) DEFAULT '0' NOT NULL COMMENT '30天内同一天完成的交易量', 
`refund_order_count` bigint(20) DEFAULT '0' NOT NULL COMMENT '30天内退款订单数', 
`refund_user_count` bigint(20) DEFAULT '0' NOT NULL COMMENT '30天内退款涉及买家数', 
