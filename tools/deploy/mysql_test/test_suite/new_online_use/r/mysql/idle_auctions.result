`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
PRIMARY KEY (`id`), 
KEY `idx_transfershop_unset_shop_id` (`shop_id`), 
KEY `idx_transfershop_unset_buyer_id` (`buyer_id`)
)  AUTO_INCREMENT = 70473 CHARSET = utf8 COMMENT = '记录购买记录多而未开通同店转让的店铺';
CREATE TABLE if not exists idle_user_count (
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
