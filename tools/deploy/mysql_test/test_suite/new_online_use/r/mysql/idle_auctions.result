KEY `ind_it` (`item_id`), 
KEY `themeid` (`theme_id`), 
KEY `ind_jo` (`join_frontpage`), 
KEY `ind_themeid_userid_gmtcreate` (`theme_id`, `user_id`, `gmt_create`), 
KEY `ind_itemid_onlinedate` (`item_id`, `online_date`), 
KEY `ind_joinfrontpage_onlinedate` (`join_frontpage`, `online_date`)
)  AUTO_INCREMENT = 1055363 CHARSET = utf8 COMMENT = '主页主题标签商品';
CREATE TABLE if not exists idle_honey_data (
`id` bigint(20) AUTO_INCREMENT NOT NULL, 
`log_date` datetime NOT NULL COMMENT '数据在honey中的创建日期', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`key_code` varchar(500) NOT NULL, 
`comm_value` double NOT NULL COMMENT '统计结果', 
PRIMARY KEY (`id`), 
KEY `idx_kc` (`key_code`, `log_date`), 
KEY `idx_gm` (`gmt_modified`)
)  AUTO_INCREMENT = 21 CHARSET = utf8 COMMENT = '同步honey的相关数据';
CREATE TABLE if not exists idle_itb_namelist (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户userid', 
`nick` varchar(64) NULL COMMENT '用户昵称', 
`site` varchar(64) NULL COMMENT '站点名称,例如:TAOBAO', 
`category` varchar(32) NULL COMMENT '类目信息，对应规则中：手机=B,平板电脑=C,笔记本电脑=D,相机=F,镜头=G,台式机/一体机=H', 
`level` int(11) NULL COMMENT '优先级,1-5', 
`order_id` varchar(256) NULL COMMENT '子订单编号', 
`status` int(11) DEFAULT '0' NOT NULL COMMENT '状态，0未处理，1处理完成。', 
PRIMARY KEY (`id`), 
KEY `idx_userid` (`user_id`)
)  AUTO_INCREMENT = 322261 CHARSET = utf8 COMMENT = '发送淘宝日历消息的用户名单回流表，数据从云梯回流此表。此表不保留历史信息，只保留当天推送名单。';
CREATE TABLE if not exists idle_item_search_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`item_id` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '宝贝id', 
`modified_count` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '30天内宝贝修改次数', 
`price_modified_count` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '30天内金额修改次数', 
`collector_count` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '收藏人气数', 
`collect_count` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '收藏量', 
`comment_count` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '评论量', 
`comment_user_count` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '评论用户量', 
`share_count` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '分享量', 
`share_user_count` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '分享用户量', 
PRIMARY KEY (`id`), 
KEY `index_item_id` (`item_id`)
)  AUTO_INCREMENT = 5570476 CHARSET = utf8 COMMENT = '二手搜索规则，宝贝历史数据';
CREATE TABLE if not exists idle_key_value (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`key_field` varchar(30) NOT NULL COMMENT 'key，有业务属性能够，一般需要通过namespace+key进行单条查询', 
`namespace` tinyint(3) UNSIGNED NOT NULL COMMENT '不同业务的一个区分', 
`value_field` varchar(100) NULL COMMENT '存储的value数据，一般使用json格式', 
`index_value` bigint(20) UNSIGNED NOT NULL COMMENT '业务索引字段，一般用于排序', 
`index_text` varchar(50) NULL COMMENT '索引字段，可用于定位记录', 
PRIMARY KEY (`id`), 
KEY `idx_key` (`namespace`, `key_field`, `index_value`), 
KEY `idx_index_value` (`namespace`, `index_text`, `index_value`), 
KEY `idx_key_index_value` (`namespace`, `key_field`, `index_text`)
)  AUTO_INCREMENT = 6170159 CHARSET = utf8 COMMENT = '闲鱼KV通用表，一般用于活动等临时数据存储';
CREATE TABLE if not exists idle_message_checkcode (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`user_id` bigint(20) NOT NULL COMMENT '用户数字id', 
`user_nick` varchar(32) NOT NULL COMMENT '用户昵称', 
`cellphone` varchar(20) NOT NULL COMMENT '手机号码', 
`check_code` varchar(10) NOT NULL COMMENT '验证码', 
`retry_count` bigint(20) NOT NULL COMMENT '该手机请求验证失败尝试次数', 
`active` bigint(20) NOT NULL COMMENT '该手机认证状态，1为已认证，0为未认证', 
`send_time` datetime NOT NULL COMMENT '记录验证码发送时间', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
KEY `idx_message_checkcode_uid` (`user_id`), 
KEY `idx_message_checkcode_cu` (`cellphone`, `user_id`), 
KEY `idx_message_checkcode_ug` (`user_id`, `gmt_create`), 
KEY `idx_message_checkcode_sg` (`cellphone`, `gmt_create`)
)  AUTO_INCREMENT = 9982729 CHARSET = utf8 COMMENT = '用户手机号码验证';
CREATE TABLE if not exists idle_message_count (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`buyer_id` bigint(20) NOT NULL COMMENT '买家id', 
`buyer_phone` varchar(20) NOT NULL COMMENT '买家手机号', 
`seller_id` bigint(20) NOT NULL COMMENT '卖家id', 
`seller_phone` varchar(20) NOT NULL COMMENT '卖家手机号', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
KEY `idx_message_count_bg` (`buyer_id`, `gmt_create`), 
KEY `idx_message_count_sg` (`seller_id`, `gmt_create`)
)  AUTO_INCREMENT = 6186631 CHARSET = utf8 COMMENT = '用于实时短信计数统计，如某个买家（卖家） 一天发了（接收了）多少条短信';
CREATE TABLE if not exists idle_recycler_activity (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键，活动id', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`name` varchar(50) NOT NULL COMMENT '活动名称', 
`operator` varchar(50) NOT NULL COMMENT '操作者', 
`recycler_ids` varchar(500) NOT NULL COMMENT '回收商列表，即该活动只有这些回收商可以出价', 
`status` int(11) NOT NULL COMMENT '1为正常，2为删除', 
PRIMARY KEY (`id`), 
KEY `ind_st` (`status`)
)  AUTO_INCREMENT = 32 CHARSET = utf8 COMMENT = '定向回收活动';
CREATE TABLE if not exists idle_recycler_brand_sort (
`category_id` bigint(20) NOT NULL COMMENT '类目id', 
`brand_id` bigint(20) NOT NULL COMMENT '品牌id', 
`brand_count` bigint(20) NOT NULL COMMENT '该品牌30天内被估价的次数', 
PRIMARY KEY (`category_id`, `brand_id`)
)  CHARSET = utf8 COMMENT = '热门回收品牌排序';
CREATE TABLE if not exists idle_recycler_formula (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键，算法id', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`formula_detail` varchar(3000) NULL COMMENT '算法明细', 
`user_id` bigint(20) NULL COMMENT '回收商用户id', 
`formula_name` varchar(50) NULL COMMENT '算法名称', 
`status` tinyint(4) NULL COMMENT '算法状态，1为系统默认算法，2为自定义算法,null为改造前原始数据状态', 
PRIMARY KEY (`id`), 
KEY `index_userid` (`user_id`)
)  AUTO_INCREMENT = 2892 CHARSET = utf8 COMMENT = '编辑模式下价格的计算公式';
CREATE TABLE if not exists idle_recycler_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`user_id` bigint(20) NOT NULL COMMENT '回收商淘宝用户id', 
`user_nick` varchar(50) NOT NULL COMMENT '回收商淘宝nick', 
`mode` tinyint(4) NOT NULL COMMENT '接入模式，开发模式为2，编辑模式为1，默认编辑模式。', 
`dev_mode_detail` varchar(300) NULL COMMENT '开发模式下的接入地址+token', 
`service_nicks` varchar(200) NULL COMMENT '客服旺旺，多个以,分割', 
`company_name` varchar(50) NULL COMMENT '回收商称呼，如：xxx回收公司', 
`options` bigint(20) NULL COMMENT '回收商的一些标记，预留，按位与运算', 
`status` int(11) NOT NULL COMMENT '回收商状态，1：签署法务协议；2：店小二审核中；3：审核未通过；4：审核通过，未接客；5：正常接口服务中；6：小二删除', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录编辑时间', 
`sos_mobile` varchar(20) NULL COMMENT '紧急联系电话', 
`sos_phone` varchar(20) NULL COMMENT '客服电话', 
`attributes` varchar(2000) NULL COMMENT '资质证明tfs地址，attribute的形式，分号分割', 
`remarks` varchar(140) NULL COMMENT '备注，记录审核通过or审核未通过原因等', 
`contacter` varchar(20) NULL COMMENT '紧急联系人', 
`serve_city` varchar(118) NULL COMMENT '支持上门服务的城市', 
PRIMARY KEY (`id`), 
KEY `ind_us` (`user_id`)
)  AUTO_INCREMENT = 933 CHARSET = utf8 COMMENT = '回收商信息表';
CREATE TABLE if not exists idle_recycler_mapping (
`category_id` bigint(20) NOT NULL COMMENT '叶子类目id', 
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`status` tinyint(4) NULL COMMENT '状态，1表示正常，0表示不正常', 
PRIMARY KEY (`category_id`, `user_id`), 
KEY `ind_us` (`user_id`), 
KEY `index_category_status_gmtcreate` (`category_id`, `status`, `gmt_create`)
)  CHARSET = utf8 COMMENT = '回收商回收类目映射';
CREATE TABLE if not exists idle_recycler_options (
`spu_id` bigint(20) NOT NULL COMMENT 'spuId', 
`property_id` bigint(20) NOT NULL COMMENT '选项id', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键id', 
PRIMARY KEY (`id`), 
KEY `ind_sp` (`spu_id`), 
KEY `ind_pr_sp` (`spu_id`, `property_id`)
)  AUTO_INCREMENT = 360605 CHARSET = utf8 COMMENT = '回收选项与spu的关系';
CREATE TABLE if not exists idle_recycler_options_group (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`category_id` bigint(20) NULL COMMENT '类目id', 
`p_v_price` varchar(3000) NULL COMMENT 'p:选项id， v：选项值id ，price：该选项的选项值对应的回收折扣，含+-*/（加减乘除），分号分隔，其中格式如：11_2_*0.3,12_1_-10，表示选项id为11选项值为2的在基准价上乘0.3，选项为12选项值为1的在基准价上减10元，这里的价格以元为单位', 
`user_id` bigint(20) NULL COMMENT '用户id', 
`group_name` varchar(50) NULL COMMENT '选项组命名', 
`excel_upload` varchar(118) NULL COMMENT '上一次的映射关系设置文件', 
`formula_id` bigint(20) UNSIGNED NULL COMMENT '算法公式id', 
`status` tinyint(4) NULL COMMENT '选项组状态，1表示启用，2表示未启用,null为改造前原始数据状态', 
PRIMARY KEY (`id`), 
KEY `index_userid_category` (`user_id`, `category_id`)
)  AUTO_INCREMENT = 3347 CHARSET = utf8 COMMENT = '价格计算逻辑的选项分组';
CREATE TABLE if not exists idle_recycler_options_value (
`spu_id` bigint(20) NOT NULL COMMENT '主键', 
`property_id` bigint(20) NULL COMMENT '选项id', 
`value_id` bigint(20) NOT NULL COMMENT '选项值id', 
`operator` varchar(50) NULL COMMENT '操作者，admin为系统操作', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
PRIMARY KEY (`spu_id`, `value_id`)
)  CHARSET = utf8 COMMENT = '单个spu对应选项下选项值的映射关系';
CREATE TABLE if not exists idle_recycler_price (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
`user_id` bigint(20) NOT NULL COMMENT '当前用户id，卖家id', 
`recycler_user_id` bigint(20) NOT NULL COMMENT '回收商id，即该回收商的淘宝user_id', 
`recycler_user_nick` varchar(50) NOT NULL COMMENT '回收商nick', 
`recycler_company_name` varchar(50) NULL COMMENT '回收商的名称，如：xxx公司', 
`recycler_service_nicks` varchar(200) NULL COMMENT '回收商客服nick', 
`mode` int(11) NOT NULL COMMENT '回收商接入类型', 
`option_id` varchar(32) NOT NULL COMMENT '唯一，选项值对应的id', 
`option_detail` varchar(5000) NOT NULL COMMENT 'user_id对应用户选择的选项明细', 
`price` bigint(20) NOT NULL COMMENT '出价，必须大于0', 
`status` int(11) NOT NULL COMMENT '出价状态', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录修改时间', 
PRIMARY KEY (`id`), 
KEY `idx_option_id_gmt_create` (`option_id`, `gmt_create`), 
KEY `idx_gmt_modified` (`gmt_modified`)
)  AUTO_INCREMENT = 642295141 CHARSET = utf8 COMMENT = '所有回收商出价记录';
CREATE TABLE if not exists idle_recycler_price_edit (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键id', 
`user_id` bigint(20) NOT NULL COMMENT '回收商id，即淘宝的user_id', 
`spu_id` bigint(20) NOT NULL COMMENT 'spu id', 
`property_id` bigint(20) NOT NULL COMMENT '选项id', 
`value_id` bigint(20) NOT NULL COMMENT '选项值id', 
`base_price` bigint(20) NOT NULL COMMENT '该SPU下的基准价，分为单位', 
`option_price` bigint(20) NOT NULL COMMENT '出价，可为负数、0、正数分为单位', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '编辑模式下的回收商出价';
CREATE TABLE if not exists idle_recycler_property (
`property_id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键，属性id', 
`property_name` varchar(50) NOT NULL COMMENT '属性名称', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录修改时间', 
`status` int(11) NOT NULL COMMENT '记录该选项状态，1表示正常，2表示小二删除', 
`operator` varchar(50) NULL COMMENT '操作者，admin为系统操作', 
`forest_propery_id` varchar(50) NOT NULL COMMENT '绑定的forest中的propertyId', 
`sort_index` int(11) NULL COMMENT '显示顺序', 
`category_id` bigint(20) NULL COMMENT '类目', 
PRIMARY KEY (`property_id`)
)  AUTO_INCREMENT = 75 CHARSET = utf8 COMMENT = '回收选项名称';
CREATE TABLE if not exists idle_recycler_property_value (
`value_id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键,选项值id', 
`value_name` varchar(50) NOT NULL COMMENT '选项值名称', 
`property_id` bigint(20) NOT NULL COMMENT '选项id', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '编辑时间', 
`sort_index` int(11) NULL COMMENT '显示顺序', 
PRIMARY KEY (`value_id`), 
KEY `ind_pr` (`property_id`)
)  AUTO_INCREMENT = 253 CHARSET = utf8 COMMENT = '回收选项名称对应值';
CREATE TABLE if not exists idle_recycler_reports (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) NULL COMMENT '用户名', 
`code` bigint(20) NULL COMMENT 'value标识', 
`value` varchar(200) NOT NULL COMMENT 'value值', 
PRIMARY KEY (`id`), 
KEY `index_userid` (`user_id`), 
KEY `index_userid_code` (`user_id`, `code`)
)  AUTO_INCREMENT = 167876 CHARSET = utf8 COMMENT = '回收商的一些数据统计';
CREATE TABLE if not exists idle_recycler_sbof_mapping (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键ID', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`spu_id` bigint(20) NOT NULL COMMENT 'spuid', 
`base_price` bigint(20) NULL COMMENT '基准价', 
`options_group_id` bigint(20) NULL COMMENT '选项组id', 
`formula_id` bigint(20) NULL COMMENT '公式id', 
`user_id` bigint(20) NOT NULL COMMENT '回收商用户id', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`category_id` bigint(20) NULL COMMENT '类目id', 
`brand_id` bigint(20) NULL COMMENT '品牌id', 
`status` tinyint(4) NULL COMMENT '状态，1：启用，2未启用，null为改造前原始数据状态', 
PRIMARY KEY (`id`), 
UNIQUE `unique_userid_spuid_status` (`spu_id`, `user_id`, `status`), 
KEY `idx_userid_spuid` (`user_id`, `spu_id`), 
KEY `idx_spuid` (`spu_id`), 
KEY `idx_uid_op_status` (`user_id`, `options_group_id`, `status`), 
KEY `ind_op` (`options_group_id`)
)  AUTO_INCREMENT = 1922085 CHARSET = utf8 COMMENT = 'spu、基准价、选项组、算法公式的映射关系';
CREATE TABLE if not exists idle_recycler_service_log (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '回收商的淘宝userid', 
`gmt_online_time` datetime NULL COMMENT '上线开始时间。回收商纬度记录点：没有任何选项组在线->有任何一条选项组上线；选项组纬度记录点：当前选项组上线时间', 
`gmt_offline_time` datetime NULL COMMENT '上线结束时间。回收商纬度记录点：有任何选项组在线->没有任何一条选项组上线；选项组纬度记录点：当前选项组下线时间', 
`parent_id` bigint(20) UNSIGNED NOT NULL COMMENT '父记录ID，回收商纬度：父ID固定为0；选项组纬度，父ID为当前活跃状态回收商在线记录ID', 
`status` int(11) DEFAULT '0' NOT NULL COMMENT '0不在线，1在线', 
`option_group_id` bigint(20) UNSIGNED NULL COMMENT '选项组id，回收商纬度为空', 
PRIMARY KEY (`id`), 
KEY `idx_userid_parentid_status` (`status`, `parent_id`, `user_id`), 
KEY `idx_ogid_parentid_status` (`option_group_id`, `status`, `parent_id`), 
KEY `idx_us_st` (`user_id`, `status`)
)  AUTO_INCREMENT = 25206 CHARSET = utf8 COMMENT = '回收商报价服务在线时间日志，包括以回收商纬度和以报价组为纬度记录，两者父子关系组织';
CREATE TABLE if not exists idle_recycler_wireless_client (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) NULL COMMENT '用户id', 
`device_model` varchar(50) NOT NULL COMMENT '设备型号', 
PRIMARY KEY (`id`), 
KEY `ind_userid` (`user_id`)
)  AUTO_INCREMENT = 102270918 CHARSET = utf8 COMMENT = '云梯dm_wireless_client_user中的device_model信息';
CREATE TABLE if not exists idle_search_conf_effect (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`rule_id` bigint(20) NOT NULL COMMENT '规则Id', 
`version` int(11) NOT NULL COMMENT '本版号', 
`effect_date` datetime NOT NULL COMMENT '生效日期', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`rule_name` varchar(50) NOT NULL COMMENT '规则名', 
PRIMARY KEY (`id`), 
KEY `idx_conf_effect_rule_id` (`rule_id`)
)  AUTO_INCREMENT = 5379 CHARSET = utf8 COMMENT = '搜索规则生效日期记录表';
CREATE TABLE if not exists idle_search_conf_page (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`page_name` varchar(118) NOT NULL COMMENT '页面名称', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 22 CHARSET = utf8 COMMENT = '搜索页面，用以给搜索规则分组，一个页面对应n个规则';
CREATE TABLE if not exists idle_search_conf_param (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`rule_id` bigint(20) NOT NULL COMMENT '规则Id', 
`param_name` varchar(50) NOT NULL COMMENT '参数名', 
`param_value` varchar(5000) NOT NULL COMMENT '参数值', 
`type` int(11) NOT NULL COMMENT '参数类型', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
KEY `idx_conf_param_rule_id` (`rule_id`)
)  AUTO_INCREMENT = 25481 CHARSET = utf8 COMMENT = '搜索规则参数表';
CREATE TABLE if not exists idle_search_conf_rule (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`page_id` bigint(20) NOT NULL COMMENT '页面Id', 
`rule_name` varchar(50) NOT NULL COMMENT '规则名称', 
`remark` varchar(500) NULL COMMENT '备注', 
`version` int(11) NOT NULL COMMENT '规则版本号', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`status` int(11) NOT NULL COMMENT '启用状态；0：停用 1：启用', 
PRIMARY KEY (`id`), 
KEY `idx_conf_rule_page_id` (`page_id`), 
KEY `idx_conf_rule_rs` (`rule_name`, `status`)
)  AUTO_INCREMENT = 360 CHARSET = utf8 COMMENT = '搜索规则表';
CREATE TABLE if not exists idle_shop_info (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`shop_id` bigint(20) NOT NULL COMMENT '店铺id', 
`title` varchar(110) NULL COMMENT '店铺名称', 
`approve_status` bigint(20) NULL COMMENT '店铺状态', 
`user_id` bigint(20) NOT NULL COMMENT '店家id', 
`nick` varchar(32) NULL COMMENT '店家昵称', 
`siteid` bigint(20) NULL COMMENT '店铺类型', 
`status` int(11) DEFAULT '0' COMMENT '开通状态', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`module_id` bigint(20) NULL COMMENT '模块id', 
PRIMARY KEY (`id`), 
KEY `IND_USERID_SHOPID` (`user_id`, `shop_id`)
)  AUTO_INCREMENT = 19261716 CHARSET = utf8 COMMENT = '闲置一键转卖商品相关信息';
CREATE TABLE if not exists idle_shop_info_extra (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`shop_id` bigint(20) NOT NULL COMMENT '店铺id', 
`seller_id` bigint(20) NOT NULL COMMENT '店铺卖家id', 
`seller_nick` varchar(32) NOT NULL COMMENT '店铺卖家nick', 
`bannar_url` varchar(256) NOT NULL COMMENT '店铺bannar的url地址', 
`gmt_create` datetime NOT NULL, 
`gmt_modified` datetime NOT NULL, 
PRIMARY KEY (`id`), 
KEY `idx_shop_info_extra_shop_id` (`shop_id`)
)  AUTO_INCREMENT = 7763 CHARSET = utf8 COMMENT = '“同店转让”店铺用于存店铺bannar';
CREATE TABLE if not exists idle_theme_list (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`name` varchar(50) NOT NULL COMMENT '主题名称', 
`pict_url` varchar(200) NOT NULL COMMENT '主题氛围图', 
`icon_url` varchar(200) NOT NULL COMMENT '主题图标图', 
`link` varchar(50) NOT NULL COMMENT '主题链接', 
`introduce` varchar(500) NOT NULL COMMENT '主题介绍', 
`market` varchar(50) NOT NULL COMMENT '所属市场', 
`rule_id` varchar(50) NOT NULL COMMENT '关联规则', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`query` int(11) DEFAULT '0' NOT NULL COMMENT '是否支持搜索 0:不支持 1:支持', 
`sort` varchar(20) NULL COMMENT '默认排序(帮你淘、发布时间、价格)', 
`modules` varchar(118) NULL COMMENT '专题模块(区域筛选、卖家筛选、刚刚转让、专题讨论)', 
`ralate` varchar(118) NULL COMMENT '关联主题', 
`icon_url2` varchar(200) NOT NULL COMMENT '主题图标，客户端用', 
`bg_color` varchar(50) NOT NULL COMMENT '背景色', 
`style` varchar(50) NOT NULL COMMENT '配色风格', 
`client_order` int(11) NULL COMMENT '客户端排序字段', 
`pc_order` int(11) NULL COMMENT 'PC端排序字段', 
`type` tinyint(4) DEFAULT '0' COMMENT '0 主题, 1 专题,', 
`tfs_path` varchar(60) NULL COMMENT '专题描述tfs路径', 
`guide_url` varchar(300) NULL COMMENT '专题引导链接', 
`mix_rule` int(11) DEFAULT '0' COMMENT '搜索机选和人工选择的打散规则,0机选，1人选', 
`theme_tab_id` bigint(20) UNSIGNED NULL COMMENT '人选规则ID', 
`theme_order` int(11) DEFAULT '0' COMMENT '客户端首页排序 0不在首页显示', 
PRIMARY KEY (`id`), 
KEY `idx_market_gc` (`market`, `gmt_create`), 
KEY `idx_gm` (`gmt_modified`), 
KEY `idx_gc` (`gmt_create`), 
KEY `index_market` (`market`), 
KEY `index_type` (`type`), 
KEY `index_order` (`theme_order`)
)  AUTO_INCREMENT = 225 CHARSET = utf8 COMMENT = '主题列表基础信息表';
CREATE TABLE if not exists idle_theme_tag (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`tag_name` varchar(50) NOT NULL COMMENT '标签名', 
`tag_link` varchar(200) NOT NULL COMMENT '标签链接', 
`group_name` varchar(50) NOT NULL COMMENT '标签组', 
`tm_id` int(11) NOT NULL COMMENT '所属主题', 
`tag_order` int(11) NULL COMMENT '标签顺序', 
`group_order` int(11) NULL COMMENT '标签组顺序', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
PRIMARY KEY (`id`), 
KEY `idx_gm` (`gmt_modified`), 
KEY `idx_gc` (`gmt_create`), 
KEY `idx_tm_id_group_tag_order` (`tm_id`, `group_order`, `tag_order`), 
KEY `ind_tm` (`tm_id`), 
KEY `idx_tmid` (`tm_id`)
)  AUTO_INCREMENT = 765 CHARSET = utf8 COMMENT = '主题列表导航标签';
CREATE TABLE if not exists idle_top_tag (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`tag` varchar(30) NOT NULL COMMENT '热门标签', 
`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
`ranking` int(11) NOT NULL COMMENT '排名', 
PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 177 CHARSET = utf8 COMMENT = '热门标签表';
CREATE TABLE if not exists idle_transfershop_data (
`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
`buyer_id` bigint(20) NULL COMMENT '买家id', 
`buyer_nick` varchar(32) NULL COMMENT '买家nick', 
`seller_id` bigint(20) NULL COMMENT '卖家id', 
`seller_nick` varchar(32) NULL COMMENT '卖家nick', 
`shop_id` bigint(20) NULL COMMENT '卖家对应店铺id', 
