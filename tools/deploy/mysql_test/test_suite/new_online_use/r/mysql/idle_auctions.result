`buyer_star_name` varchar(111) NULL COMMENT '买家星级', 
`seller_star_name` varchar(111) NULL COMMENT '卖家星级', 
`vip_level` int(11) NULL COMMENT 'vip等级', 
`attributes` varchar(100) NULL, 
`gmt_create` datetime NULL COMMENT '记录创建时间', 
`gmt_modified` datetime NULL COMMENT '记录最后修改时间', 
`nick` varchar(50) NULL COMMENT '昵称', 
PRIMARY KEY (`id`), 
UNIQUE `idx_credit_info_user_id` (`user_id`), 
KEY `idx_credit_info_uid` (`user_id`)
)  AUTO_INCREMENT = 5152360 CHARSET = utf8 COMMENT = '闲置卖家信息评分信息';
CREATE TABLE if not exists idle_user_earn_fee (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户id', 
`nick` varchar(32) NOT NULL COMMENT '用户nick', 
`fee` decimal(14, 0) NOT NULL COMMENT '在闲置市场卖出多少价值商品(分)', 
PRIMARY KEY (`id`), 
UNIQUE `unique_user_id` (`user_id`)
)  AUTO_INCREMENT = 876139793 CHARSET = utf8 COMMENT = '闲置交易额汇总表';
CREATE TABLE if not exists idle_user_feed_detail (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`feed_id` bigint(20) UNSIGNED NOT NULL COMMENT '评论ID', 
`rated_uid` bigint(20) UNSIGNED NOT NULL COMMENT '被评论者数字ID，如果rater_type=0，则表示卖家数字id', 
`rated_user_nick` varchar(32) NOT NULL COMMENT '被评论者昵称', 
`rater_uid` bigint(20) UNSIGNED NOT NULL COMMENT '评论者数字ID，如果rater_type=0，则表示买家数字id', 
`rater_user_nick` varchar(32) NOT NULL COMMENT '评论者昵称', 
`rater_type` tinyint(4) NOT NULL COMMENT '评论者交易角色 1：评论者是卖家 0：评论者是买家', 
`status` tinyint(4) NULL COMMENT '业务数据状态：0正常 1删除 2单向挂起或未生效 3 48小时挂起 4删除后恢复  5炒一罚二只删不罚 6炒一罚二删除并罚两分 7广告评价(fengxiao.xb)', 
`validscore` bigint(20) UNSIGNED NULL COMMENT '评价的计分状态：1：计分；0：不计分，平衡一个月内不超过4分', 
`rate` bigint(20) UNSIGNED NULL COMMENT '评价结果：1好评 0默认', 
`trade_id` bigint(20) UNSIGNED NULL COMMENT '交易子订单id，-1表示无订单', 
`parent_trade_id` bigint(20) UNSIGNED NULL COMMENT '交易父订单ID，-1表示无订单', 
`item_id` bigint(20) UNSIGNED NULL COMMENT '商品数字ID', 
`attributes` varchar(2000) NULL COMMENT 'key-value的形式存放记录的信息', 
PRIMARY KEY (`id`), 
UNIQUE `unique_feedid` (`feed_id`), 
KEY `index_rateinfo` (`rated_uid`, `rater_uid`, `validscore`, `parent_trade_id`, `gmt_create`)
)  AUTO_INCREMENT = 13493452 CHARSET = utf8 COMMENT = '评价闲置子表';
