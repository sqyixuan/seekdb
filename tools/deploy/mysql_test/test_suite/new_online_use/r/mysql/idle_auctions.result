)  AUTO_INCREMENT = 17744 CHARSET = utf8 COMMENT = '搜索定制化-参数配置表';
CREATE TABLE if not exists sc_rule_info (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
