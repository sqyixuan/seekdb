`module_id` bigint(20) NULL COMMENT '妯″潡id'
)  CHARSET = utf8;
CREATE TABLE if not exists uic_need_move_data (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户Id', 
`fullname` varchar(118) NOT NULL COMMENT '用户名或公司名', 
`id_card_number` varchar(118) NOT NULL COMMENT '身份证号或企业注册号', 
`type` int(11) NOT NULL COMMENT '类型：1，个人 2，企业', 
PRIMARY KEY (`id`), 
KEY `index_user_id` (`user_id`), 
KEY `index_type` (`type`)
)  CHARSET = utf8 COMMENT = '需要迁移的认证数据';
CREATE TABLE if not exists vote_record (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`vote_id` bigint(20) UNSIGNED NOT NULL COMMENT '投票者ID', 
`voted_id` bigint(20) UNSIGNED NOT NULL COMMENT '被投票者ID', 
`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '支持or反对  1-支持 -1 反对', 
`vote_type` int(11) DEFAULT '0' NOT NULL COMMENT '根据当前活动而设定 1- 贩二', 
PRIMARY KEY (`id`), 
KEY `uniquekey` (`vote_id`, `voted_id`, `vote_type`)
)  AUTO_INCREMENT = 5735 CHARSET = utf8 COMMENT = '投票记录';
CREATE TABLE if not exists vote_result (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`voted_user_id` bigint(20) UNSIGNED DEFAULT '0' COMMENT '被投票所属用户', 
`voted_id` bigint(20) UNSIGNED NOT NULL COMMENT '被投票ID', 
`vote_type` int(11) DEFAULT '0' NOT NULL COMMENT '投票类型 1 - 贩二', 
`support_num` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '支持数', 
`unsupport_num` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '反对数', 
`feature` varchar(520) NULL COMMENT '冗余字段', 
`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '状态  -1 无效', 
PRIMARY KEY (`id`), 
KEY `orderbyid` (`gmt_create`, `voted_user_id`), 
KEY `uniquekey` (`voted_id`, `vote_type`)
)  CHARSET = utf8 COMMENT = '投票结果';
CREATE TABLE if not exists idle_2013_orders (
`buyer_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段，主键', 
`buyer_nick` varchar(64) NULL COMMENT '用户nick', 
`top_category` varchar(10) NULL COMMENT '购买金额最多的类目', 
`top_money` varchar(20) NULL COMMENT '购买金额最多的类目，其对应的购买金额', 
`attributes` varchar(5000) NULL COMMENT 'biz_order_id:订单号auction_id:宝贝idpict_url:宝贝图片price:宝贝价格	itle：宝贝标题逗号分割，分号分组', 
PRIMARY KEY (`buyer_id`)
)  CHARSET = utf8 COMMENT = '云梯2013年购买最多的类目和其对应金额，以及前8个商品';
CREATE TABLE if not exists idle_user (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
`user_nick` varchar(118) NULL COMMENT '淘宝nick', 
`idle_nick` varchar(118) NULL COMMENT '二手用户别名', 
`idle_level` int(11) NULL COMMENT '二手用户等级', 
`idle_credit_score` int(11) DEFAULT '1' COMMENT '二手信用分，默认1,2,4,6,7,8,11,56,68,89,435,452300分', 
`idle_icon` varchar(200) NULL COMMENT '二手用户头像', 
`idle_mobile` varchar(118) NULL COMMENT '二手用户联系方式', 
`idle_email` varchar(118) NULL COMMENT '二手用户邮箱', 
`idle_status` tinyint(4) NULL COMMENT '用户状态，1正常2屏蔽3CC', 
`idle_last_long_date` datetime NULL COMMENT '用户上次登录时间', 
`idle_login_imei` varchar(40) NULL COMMENT '用户登录设备imei号', 
`attributes` varchar(500) NULL COMMENT '属性，扩展用', 
`options` bigint(20) UNSIGNED NULL COMMENT '用户权限', 
`f_seller_feed_num` bigint(20) UNSIGNED DEFAULT '0' COMMENT '来自卖家的评价数', 
`f_buyer_feed_num` bigint(20) UNSIGNED DEFAULT '0' COMMENT '来自买家的评价数', 
`f_seller_good_num` bigint(20) UNSIGNED DEFAULT '0' COMMENT '来自卖家的“好”评数', 
`f_buyer_good_num` bigint(20) UNSIGNED DEFAULT '0' COMMENT '来自买家的“好”评数', 
PRIMARY KEY (`id`), 
UNIQUE `idx_uniq_userid` (`user_id`), 
KEY `idx_userid_status` (`user_id`, `idle_status`), 
KEY `idx_usernick_status` (`idle_nick`, `idle_status`)
)  AUTO_INCREMENT = 74376 CHARSET = utf8 COMMENT = '二手用户表';
CREATE TABLE if not exists idle_wireless_client_user (
`user_id` bigint(20) NOT NULL COMMENT '用户id', 
`brand` varchar(50) NULL COMMENT '品牌', 
`divice_model` varchar(255) NOT NULL COMMENT '设备型号', 
`first_start_time` datetime NULL COMMENT '第一次使用时间', 
`last_start_time` datetime NULL COMMENT '最后一次使用时间', 
PRIMARY KEY (`user_id`, `divice_model`)
)  CHARSET = utf8 COMMENT = '云梯dm_wireless_client_user表的一些设备信息，不是全部阿里系客户端的信息，具体看hivesql决定';
CREATE TABLE if not exists act_913_awards (
`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
`gmt_create` datetime NOT NULL COMMENT '创建时间', 
`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户uid', 
`user_nick` varchar(32) NULL COMMENT '用户nick', 
`device_id` varchar(256) NULL COMMENT '设备唯一id', 
`award_type` int(11) NOT NULL COMMENT '奖品类型.1千人宝箱2万人宝箱3十万人宝箱4百万人宝箱', 
`award_id` bigint(20) UNSIGNED NOT NULL COMMENT '奖品编码', 
`award_aount` bigint(20) UNSIGNED NOT NULL COMMENT '奖品金额，单位分', 
`status` int(11) DEFAULT '1' NOT NULL COMMENT '1中奖未发钱2已经发钱', 
PRIMARY KEY (`id`), 
UNIQUE `idx_uid` (`user_id`), 
KEY `idx_type_amount_gmtcreate` (`award_type`, `award_aount`, `gmt_create`), 
KEY `idx_type_gmtcreate` (`award_type`, `gmt_create`)
)  AUTO_INCREMENT = 27012 CHARSET = utf8 COMMENT = '2015.9.13宝箱活动获奖名单';
