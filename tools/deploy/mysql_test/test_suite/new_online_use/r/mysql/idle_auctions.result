`create_order_count` bigint(20) DEFAULT '0' NOT NULL COMMENT '30天内创建的订单数', 
`pay_order_count` bigint(20) DEFAULT '0' NOT NULL COMMENT '30天内付款订单数', 
`pay_buyer_count` bigint(20) DEFAULT '0' NOT NULL COMMENT '30天内支付涉及的买家数', 
