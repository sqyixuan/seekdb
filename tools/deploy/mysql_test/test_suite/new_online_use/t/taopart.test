INSERT INTO tb_user_plugin_rel (gmt_create, gmt_modified, plugin_id, user_id, status , source, last_visitor_time) VALUES (now(), now(), 1, 1, 1 , 1, now());

UPDATE tb_user_client SET gmt_modified = now(), last_active_time = now(), device_token = "3", client_version = 1 WHERE user_id = 1 AND client_type = 1;
UPDATE tb_user_logistics SET gmt_modified = now(), gmt_last_read_time = now(), last_read_step_count = now_step_count WHERE user_id = 1 AND trade_id = 1;
UPDATE tb_user_client SET gmt_modified = now(), last_active_time = now(), client_version = 1 WHERE user_id = 1 AND client_type = 1;
UPDATE tb_shop_info SET subcribe_count = subcribe_count + 1, gmt_modified = now() WHERE seller_id = 1;
UPDATE tb_user_logistics SET gmt_modified = now(), status = 1 WHERE user_id = 1 AND trade_id IN (1);
UPDATE tb_user SET gmt_modified = now(), last_active_time = "2016-09-30 00:00:01", accept_push_type = 1, push_start_time = 1, push_end_time = 1, status = 1 WHERE user_id = 1;
UPDATE tb_user_logistics SET gmt_modified = now(), now_step_count = 1, transit_step_list = "3", status = 1, gmt_update_time = now(), gmt_last_logistics_time = "2016-09-30 00:00:01" WHERE user_id = 1 AND trade_id = 1;
UPDATE tb_user_plugin_rel SET status = 1 WHERE user_id = 1 AND plugin_id = 1;

DELETE FROM tb_user_shop_rel WHERE user_id = 1 AND seller_id = 1;
DELETE FROM tb_shop_user_rel WHERE seller_id = 1 AND user_id = 1;
DELETE FROM tb_user_logistics WHERE status = 1 AND datediff(now(), gmt_create) >= 1;
