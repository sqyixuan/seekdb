--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: jim.wjh
#owner group:sql2
#tags new_online_use 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists buyershow (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NULL COMMENT '创建时间', 
	`gmt_modified` datetime NULL COMMENT '修改时间', 
	`like_count` int(11) DEFAULT '0' COMMENT '喜欢数', 
	`dislike_count` int(11) DEFAULT '0' COMMENT '不喜欢数', 
	`show_count` int(11) DEFAULT '0' COMMENT '展示数', 
	`path` varchar(1024) NULL COMMENT '图片地址', 
	`feed_id` varchar(64) NULL COMMENT 's_feed_item_receive.feed_id 评论主键Id', 
	`rated_uid` varchar(64) NULL COMMENT '卖家数字id（被评论者数字ID）', 
	`rated_user_nick` varchar(64) NULL COMMENT '卖家昵称（被评论者昵称）', 
	`rater_uid` varchar(64) NULL COMMENT '买家id（评论者数字ID', 
	`rater_user_nick` varchar(64) NULL COMMENT '买家昵称（评论者昵称）', 
	`trade_id` varchar(64) NULL COMMENT '交易子订单id，-1表示无订单', 
	`parent_trade_id` varchar(64) NULL COMMENT '交易父订单ID，-1表示无订单', 
	`gmt_trade_create` varchar(64) NULL COMMENT '交易创建时间', 
	`gmt_trade_finished` varchar(64) NULL COMMENT '交易完成时间', 
	`auc_num_id` varchar(64) NULL COMMENT '商品数字ID （IC的id）', 
	`auction_title` varchar(1024) NULL COMMENT '商品标题', 
	`auction_pic_url` varchar(512) NULL COMMENT '商品主图地址', 
	`auction_price` varchar(64) NULL COMMENT '商品价格', 
	`leaf_cat_id` varchar(64) NULL COMMENT '商品叶子类目id', 
	`root_cat_id` varchar(64) NULL COMMENT '商品一级类目id（女装=16）', 
	`spu_id` varchar(64) NULL COMMENT '商品对应spuId', 
	`feedback` varchar(2048) NULL COMMENT '评论内容. 140610近45天线上最长757', 
	`feedback_length` varchar(16) NULL COMMENT '评论内容长度', 
	`source` varchar(16) NULL COMMENT '如果是biz_type=评价，以位标记形式标明来源，第1位-集市；第2位-天猫；第3位-外部；', 
	`properties` varchar(1024) NULL COMMENT '评论中的个性化的垂直属性，以key:value保存，分号分隔，默认为Null. 线上最长138', 
	`anony` varchar(4) NULL COMMENT '是否匿名评价', 
	`vote_useful` varchar(4) NULL COMMENT '有用、赞、顶的通用计数', 
	`rater_star` varchar(16) NULL COMMENT '评论者星级', 
	`attributes` varchar(1024) NULL COMMENT '评论的备用字段。超好用的字段。很多杂七杂八的信息这里都有。', 
	`feedback_ip` varchar(32) NULL COMMENT '评论者ip', 
	`category_level1_name` varchar(512) NULL COMMENT '一级类目名字', 
	`category_level2_name` varchar(512) NULL COMMENT '二级类目名字', 
	`category_leaf_name` varchar(512) NULL COMMENT '叶子类目名字', 
	`auction_status` varchar(16) NULL COMMENT '宝贝状态 0=正常，1=删除后正常，<0 下架状态', 
	`shop_url` varchar(512) NULL COMMENT '店铺URL', 
	`is_prepay` varchar(16) NULL COMMENT '是否加入消保', 
	`seller_good_rate` varchar(128) NULL COMMENT '店铺好评率 不知道为什么String类型', 
	`dsr_merchandise` double NULL COMMENT 'dsr商品描述', 
	`dsr_service` double NULL COMMENT 'dsr服务', 
	`dsr_consignment` double NULL COMMENT 'dsr发货速度', 
	`dsr_logistics_service` double NULL COMMENT 'dsr物流服务（不常用）', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 40057232 CHARSET = utf8 COMMENT = '买家秀主表（只有最近n天的数据）';
CREATE TABLE if not exists buyershow_daily_sync (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NULL COMMENT '创建时间', 
	`gmt_modified` datetime NULL COMMENT '修改时间', 
	`like_count` int(11) DEFAULT '0' COMMENT '喜欢数', 
	`dislike_count` int(11) DEFAULT '0' COMMENT '不喜欢数', 
	`show_count` int(11) DEFAULT '0' COMMENT '展示数', 
	`path` varchar(1024) NULL COMMENT '图片地址', 
	`feed_id` varchar(64) NULL COMMENT 's_feed_item_receive.feed_id 评论主键Id', 
	`rated_uid` varchar(64) NULL COMMENT '卖家数字id（被评论者数字ID）', 
	`rated_user_nick` varchar(64) NULL COMMENT '卖家昵称（被评论者昵称）', 
	`rater_uid` varchar(64) NULL COMMENT '买家id（评论者数字ID', 
	`rater_user_nick` varchar(64) NULL COMMENT '买家昵称（评论者昵称）', 
	`trade_id` varchar(64) NULL COMMENT '交易子订单id，-1表示无订单', 
	`parent_trade_id` varchar(64) NULL COMMENT '交易父订单ID，-1表示无订单', 
	`gmt_trade_create` varchar(64) NULL COMMENT '交易创建时间', 
	`gmt_trade_finished` varchar(64) NULL COMMENT '交易完成时间', 
	`auc_num_id` varchar(64) NULL COMMENT '商品数字ID （IC的id）', 
	`auction_title` varchar(1024) NULL COMMENT '商品标题', 
	`auction_pic_url` varchar(512) NULL COMMENT '商品主图地址', 
	`auction_price` varchar(64) NULL COMMENT '商品价格', 
	`leaf_cat_id` varchar(64) NULL COMMENT '商品叶子类目id', 
	`root_cat_id` varchar(64) NULL COMMENT '商品一级类目id（女装=16）', 
	`spu_id` varchar(64) NULL COMMENT '商品对应spuId', 
	`feedback` varchar(2048) NULL COMMENT '评论内容. 140610近45天线上最长757', 
	`feedback_length` varchar(16) NULL COMMENT '评论内容长度', 
	`source` varchar(16) NULL COMMENT '如果是biz_type=评价，以位标记形式标明来源，第1位-集市；第2位-天猫；第3位-外部；', 
	`properties` varchar(1024) NULL COMMENT '评论中的个性化的垂直属性，以key:value保存，分号分隔，默认为Null. 线上最长138', 
	`anony` varchar(4) NULL COMMENT '是否匿名评价', 
	`vote_useful` varchar(4) NULL COMMENT '有用、赞、顶的通用计数', 
	`rater_star` varchar(16) NULL COMMENT '评论者星级', 
	`attributes` varchar(1024) NULL COMMENT '评论的备用字段。超好用的字段。很多杂七杂八的信息这里都有。', 
	`feedback_ip` varchar(32) NULL COMMENT '评论者ip', 
	`category_level1_name` varchar(512) NULL COMMENT '一级类目名字', 
	`category_level2_name` varchar(512) NULL COMMENT '二级类目名字', 
	`category_leaf_name` varchar(512) NULL COMMENT '叶子类目名字', 
	`auction_status` varchar(16) NULL COMMENT '宝贝状态 0=正常，1=删除后正常，<0 下架状态', 
	`shop_url` varchar(512) NULL COMMENT '店铺URL', 
	`is_prepay` varchar(16) NULL COMMENT '是否加入消保', 
	`seller_good_rate` varchar(128) NULL COMMENT '店铺好评率 不知道为什么String类型', 
	`dsr_merchandise` double NULL COMMENT 'dsr商品描述', 
	`dsr_service` double NULL COMMENT 'dsr服务', 
	`dsr_consignment` double NULL COMMENT 'dsr发货速度', 
	`dsr_logistics_service` double NULL COMMENT 'dsr物流服务（不常用）', 
	`isprocessed` varchar(4) DEFAULT 'n' COMMENT 'sync任务是否处理过', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 40057238 CHARSET = utf8 COMMENT = '每日同步表。每天会truncate。每天上午10点，通过datax把云梯上hive跑的带图评论结果拉回来暂存这里。';
CREATE TABLE if not exists buyershow_task_log (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NULL COMMENT '创建时间', 
	`type` varchar(128) NULL COMMENT '日志消息类型', 
	`status` varchar(16) NULL COMMENT '状态。start 、 finish', 
	`msg` varchar(1024) NULL COMMENT '文本消息', 
	`has_exception` varchar(16) NULL COMMENT '是否出现异常', 
	`exception_detail` varchar(2048) NULL COMMENT '异常明细', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 1632 CHARSET = utf8 COMMENT = '买家秀任务日志表';
CREATE TABLE if not exists dedicate (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`target_id` bigint(20) UNSIGNED NOT NULL COMMENT 'id', 
	`type` varchar(118) NOT NULL COMMENT '类型', 
	`count` int(11) NOT NULL COMMENT '献花次数', 
	`sum` bigint(20) UNSIGNED NOT NULL COMMENT '被献花总数', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户id', 
	PRIMARY KEY (`id`), 
	KEY `typeandid` (`target_id`, `type`), 
	KEY `modify` (`gmt_modified`)
)  CHARSET = utf8 COMMENT = '献花统计表';
CREATE TABLE if not exists taobeauty (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`like_count` int(11) DEFAULT '0' COMMENT '喜欢数', 
	`dislike_count` int(11) DEFAULT '0' COMMENT '不喜欢数', 
	`show_count` int(11) DEFAULT '0' COMMENT '展示数', 
	`pic_id` bigint(20) UNSIGNED NULL COMMENT '淘女郎图片ID', 
	`user_id` bigint(20) UNSIGNED NULL COMMENT '淘女郎的userId', 
	`path` varchar(256) NULL COMMENT '图片tfs地址', 
	`is_deleted` varchar(4) DEFAULT 'n' COMMENT '是否已经被删除', 
	PRIMARY KEY (`id`), 
	KEY `pic_id_index` (`pic_id`)
)  AUTO_INCREMENT = 4390380 CHARSET = utf8 COMMENT = '淘女郎';
CREATE TABLE if not exists taobeauty_sync (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`pic_id` bigint(20) UNSIGNED NULL COMMENT '淘女郎图片ID', 
	`user_id` bigint(20) UNSIGNED NULL COMMENT '淘女郎的userId', 
	`path` varchar(256) NULL COMMENT '图片tfs地址', 
	PRIMARY KEY (`id`), 
	KEY `pic_id_index` (`pic_id`)
)  CHARSET = utf8 COMMENT = '淘女郎同步表';
CREATE TABLE if not exists tb_client_version (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`client_type` tinyint(3) UNSIGNED NOT NULL COMMENT '客户端类型，1=iOS，2=Android', 
	`client_version` tinyint(4) NOT NULL COMMENT '客户端内部版本号', 
	`client_version_show` varchar(32) NOT NULL COMMENT '客户端显示版本，比如“2.1.0”', 
	`is_max_version` tinyint(4) DEFAULT '0' NOT NULL COMMENT '是否配置为最新版本，0=否，1=是。默认否，需要手动配置为最新版本。用户检查更新时，根据这个字段来取。如果一个新版本的该字段为0，则用户不会收到版本更新通知。', 
	`is_force_version` tinyint(4) DEFAULT '0' NOT NULL COMMENT '是否为强制更新版本，0=否，1=是。默认否。', 
	`update_msg` varchar(1024) NOT NULL COMMENT '更新时，通知用户的文案', 
	PRIMARY KEY (`id`), 
	UNIQUE `type_version_show_index` (`client_type`, `client_version_show`), 
	UNIQUE `type_version_index` (`client_type`, `client_version`)
)  AUTO_INCREMENT = 62 CHARSET = utf8 COMMENT = '记录客户端的版本';
CREATE TABLE if not exists tb_error_insert_shop_user (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '卖家id', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '订阅店铺的用户的id', 
	`error_desc` varchar(4096) NULL COMMENT '发生错误的描述', 
	`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '该错误的处理状态。0=尚未处理，1=已经处理了。', 
	PRIMARY KEY (`id`), 
	KEY `index_seller_id` (`seller_id`), 
	KEY `index_user_id` (`user_id`)
)  AUTO_INCREMENT = 64704 CHARSET = utf8 COMMENT = '记录从tb_user_shop_rel导数据到tb_shop_user_rel时，发生错误的记录';
CREATE TABLE if not exists tb_plugin (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`plugin_id` smallint(5) UNSIGNED NOT NULL COMMENT '主模块id，唯一', 
	`name` varchar(256) NOT NULL COMMENT '模块的名字，例如“聚划算,女装”。对于物流，写“物流”即可。', 
	`is_fixed` tinyint(3) UNSIGNED NOT NULL COMMENT '是否固定订阅。0=不是固定订阅，可取消；1=固定订阅，不允许取消', 
	`status` tinyint(3) UNSIGNED NOT NULL COMMENT '状态码,-1=禁止订阅；0=即将开放订阅；1=可以订阅', 
	`weight` tinyint(4) NULL COMMENT '插件权重', 
	`subscribe_count` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '订阅该模块的人数', 
	`icon` varchar(256) NULL COMMENT '插件对应icon', 
	`has_sub_plugin` tinyint(3) UNSIGNED NOT NULL COMMENT '是否有子插件', 
	`description` varchar(1024) NULL COMMENT '描述', 
	`h5_page_url` varchar(256) NULL COMMENT 'h5页面的url', 
	`ext_pro` varchar(1024) NULL COMMENT '扩展属性', 
	`dis_img_andriod` varchar(256) NULL COMMENT '安卓下的组件宣传图片', 
	`dis_img_ios` varchar(256) NULL COMMENT 'IOS下的组件宣传图片', 
	`banner_img` varchar(256) NULL COMMENT '自定义组件的banner图片', 
	PRIMARY KEY (`id`), 
	UNIQUE `id_index` (`plugin_id`), 
	KEY `ind_is_fixed` (`is_fixed`), 
	KEY `ind_status` (`status`)
)  AUTO_INCREMENT = 26 CHARSET = utf8 COMMENT = '模块表，模块已插件形式，支持用户订阅';
CREATE TABLE if not exists tb_plugin_rel (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`plugin_id` smallint(5) UNSIGNED NOT NULL COMMENT '主模块id，标识这是‘上新优惠’、‘物流’、‘聚划算’......', 
	`sub_plugin_id` smallint(5) UNSIGNED NOT NULL COMMENT '子模块id', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_main_plugin` (`plugin_id`, `sub_plugin_id`)
)  CHARSET = utf8 COMMENT = '主订阅插件表结构';
CREATE TABLE if not exists tb_shop_info (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`shop_id` bigint(20) UNSIGNED NULL COMMENT '店铺id', 
	`shop_name` bigint(20) UNSIGNED NULL COMMENT '店铺名称', 
	`subcribe_count` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '订阅数', 
	`icon` varchar(200) NULL COMMENT '店铺图标Url', 
	`msxf` varchar(10) NULL COMMENT '描述相符', 
	`fwtd` varchar(10) NULL COMMENT '服务态度', 
	`fhsd` varchar(10) NULL COMMENT '发货速度', 
	PRIMARY KEY (`id`), 
	UNIQUE `unique_seller_id_index` (`seller_id`)
)  AUTO_INCREMENT = 41 CHARSET = utf8 COMMENT = '淘伴店铺概要信息表';
CREATE TABLE if not exists tb_shop_user_rel (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段，卖家id', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '订阅店铺的用户的id', 
	`shop_id` bigint(20) UNSIGNED NOT NULL COMMENT '店铺id', 
	`source` tinyint(4) NOT NULL COMMENT '关注来源。0=默认推荐；1=从淘伴关注；2=从pc端关注', 
	`status` tinyint(4) DEFAULT '1' NOT NULL COMMENT '状态码，0=用户取消订阅；1=正常订阅', 
	`props` varchar(1024) NULL COMMENT '扩展属性（Json串', 
	`last_visitor_time` datetime NULL COMMENT '用户最近访问时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `index_sellerid_userid` (`seller_id`, `user_id`), 
	KEY `index_sellerid_status` (`status`, `seller_id`)
)  AUTO_INCREMENT = 2504514 CHARSET = utf8 COMMENT = '这是tb_user_shop_rel的反向查询表，可以根据seller_id查询订阅了该店铺的用户';
CREATE TABLE if not exists tb_user (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`user_nick` varchar(128) NOT NULL COMMENT '淘宝登陆nick', 
	`last_active_time` datetime NOT NULL COMMENT '最近活跃时间', 
	`accept_push_type` bigint(20) DEFAULT '7' NOT NULL COMMENT '用户接收的push类型，从低位到高位，每一位表示一种，0=拒绝，1=接收。第一位是淘金币，第二位是上新促销，第三位是物流', 
	`push_start_time` int(10) UNSIGNED DEFAULT '28800' NOT NULL COMMENT '接收push的开始时间，秒，默认8*60*60', 
	`push_end_time` int(10) UNSIGNED DEFAULT '79200' NOT NULL COMMENT '接收push的结束时间，秒，默认22*60*60', 
	`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '用户状态，0=正常，-1=失效', 
	PRIMARY KEY (`id`), 
	UNIQUE `user_nick_index` (`user_nick`), 
	UNIQUE `user_id_index` (`user_id`)
)  AUTO_INCREMENT = 214585 CHARSET = utf8 COMMENT = '淘伴用户表';
CREATE TABLE if not exists tb_user_client (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`client_type` tinyint(3) UNSIGNED NOT NULL COMMENT '客户端类型，1=iOS，2=Android', 
	`client_version` tinyint(4) NOT NULL COMMENT '客户端版本', 
	`device_token` varchar(128) NULL COMMENT '设备token', 
	`last_active_time` datetime NOT NULL COMMENT '用户最近使用该客户端的时间', 
	`last_push_time` datetime NULL COMMENT '最近一次发送push的时间，用户初始化时，这个字段是null', 
	`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '客户端状态，0=正常，-1=失效', 
	PRIMARY KEY (`id`), 
	UNIQUE `user_client_index` (`user_id`, `client_type`)
)  AUTO_INCREMENT = 18287 CHARSET = utf8 COMMENT = '用户的客户端表，如果用户既使用iOS，又使用Android，就会有两条记录';
CREATE TABLE if not exists tb_user_logistics (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '卖家ID，用于查物流', 
	`trade_id` bigint(20) UNSIGNED NOT NULL COMMENT '交易ID，用于查物流', 
	`mail_no` varchar(32) NOT NULL COMMENT '运单号，用于显示', 
	`company_name` varchar(64) NOT NULL COMMENT '物流公司名', 
	`item_img` varchar(256) NOT NULL COMMENT '宝贝图片，只取一个宝贝的主图。tfs相对路径。', 
	`item_name` varchar(256) NOT NULL COMMENT '宝贝名，只取一个宝贝', 
	`gmt_last_read_time` datetime NOT NULL COMMENT '用户上一次读取该记录的时间。初始值是记录的创建时间。', 
	`last_read_step_count` tinyint(4) DEFAULT '0' NOT NULL COMMENT '用户上次读取该记录时，读到的物流流转数', 
	`now_step_count` tinyint(4) NOT NULL COMMENT '该订单的物流流转总数。该字段减去last_read_step_count就是未读流转数。', 
	`transit_step_list` varchar(4096) NOT NULL COMMENT '详细物流流转数据，json格式', 
	`status` tinyint(4) NOT NULL COMMENT '1=已发货；2=运输中；3=派件中；4=已收货', 
	`gmt_update_time` datetime NOT NULL COMMENT '物流信息被更新的时间，是我们的服务端更新这条记录的时间。用户读取时不要更新。', 
	`gmt_last_logistics_time` datetime NOT NULL COMMENT '最近一次流转发生的时间。解析transitStepList可以获取这个字段。但因为要排序，所以单独拿出来当做一个字段。', 
	PRIMARY KEY (`id`), 
	UNIQUE `trade_id_index` (`trade_id`), 
	KEY `idx_userid_status` (`user_id`, `status`)
)  AUTO_INCREMENT = 2034883 CHARSET = utf8 COMMENT = '记录用户的物流信息';
CREATE TABLE if not exists tb_user_logistics_status (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`trade_id` bigint(20) UNSIGNED NOT NULL COMMENT '交易订单id', 
	`gmt_last_read_time` datetime NULL COMMENT '用户上一次读取该记录的时间', 
	`gmt_last_event_time` datetime NOT NULL COMMENT '最新一条快递流转事件的时间', 
	`last_read_step_count` int(11) NOT NULL COMMENT '用户上次读取该记录时，读到的物流流转数', 
	`now_step_count` int(11) NOT NULL COMMENT '该订单目前的物流流转总数', 
	`status` tinyint(4) NOT NULL COMMENT '1=已发货；2=运输中；3=派件中；4=已收货；5=已完成', 
	`gmt_update_time` datetime NOT NULL COMMENT '后台任务更新本记录的时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_tid` (`trade_id`), 
	KEY `k_tid` (`user_id`)
)  AUTO_INCREMENT = 18995 CHARSET = utf8 COMMENT = '淘伴用户的物流状态表';
CREATE TABLE if not exists tb_user_plugin_rel (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`plugin_id` smallint(5) UNSIGNED NOT NULL COMMENT '主模块插件id', 
	`source` tinyint(3) UNSIGNED NOT NULL COMMENT '订阅来源。0=默认订阅；1=从淘伴关注；2=从pc端关注 ...', 
	`status` tinyint(3) UNSIGNED NOT NULL COMMENT '状态码，0=用户取消订阅；1=正常订阅', 
	`last_visitor_time` datetime NULL COMMENT '用户最近访问时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `user_plugin_index` (`user_id`, `plugin_id`), 
	KEY `user_status_index` (`user_id`, `status`)
)  AUTO_INCREMENT = 685647 CHARSET = utf8 COMMENT = '用户与模块插件关系表';
CREATE TABLE if not exists tb_user_shop_rel (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '卖家id', 
	`shop_id` bigint(20) UNSIGNED NULL COMMENT '店铺id', 
	`source` tinyint(3) UNSIGNED NOT NULL COMMENT '关注来源。0=默认推荐；1=从淘伴关注；2=从pc端关注', 
	`status` tinyint(3) UNSIGNED NULL COMMENT '状态码，0=用户取消订阅；1=正常订阅', 
	`props` varchar(1024) NULL COMMENT '扩展属性（Json串）', 
	`last_visitor_time` datetime NULL COMMENT '用户最近访问时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `index_userid_sellerid` (`user_id`, `seller_id`), 
	KEY `index_userid_status` (`user_id`, `status`)
)  AUTO_INCREMENT = 2201417 CHARSET = utf8 COMMENT = '买家与卖家店铺的关系';

SELECT id, gmt_create, gmt_modified, plugin_id, user_id , status, source, last_visitor_time FROM tb_user_plugin_rel WHERE user_id = 1;
SELECT id, gmt_create, gmt_modified, user_id, client_type , client_version, device_token, last_active_time, last_push_time, status FROM tb_user_client WHERE user_id = 1;
SELECT id, gmt_create, gmt_modified, user_id, seller_id , trade_id, mail_no, company_name, item_img, item_name , gmt_last_read_time, last_read_step_count, now_step_count, transit_step_list, status , gmt_update_time, gmt_last_logistics_time FROM tb_user_logistics WHERE user_id = 1 AND trade_id = 1;
SELECT id, gmt_create, gmt_modified, client_type, client_version , client_version_show, is_max_version, is_force_version, update_msg FROM tb_client_version WHERE client_type = 1 AND client_version_show = "3";
SELECT id, gmt_create, gmt_modified, plugin_id, name , is_fixed, status, weight, subscribe_count, icon , has_sub_plugin, description, h5_page_url, ext_pro, dis_img_andriod , dis_img_ios, banner_img FROM tb_plugin;
SELECT COUNT(*) FROM tb_user_logistics WHERE user_id = 1 AND status < 1;
SELECT id, gmt_create, gmt_modified, user_id, seller_id , trade_id, mail_no, company_name, item_img, item_name , gmt_last_read_time, last_read_step_count, now_step_count, transit_step_list, status , gmt_update_time, gmt_last_logistics_time FROM tb_user_logistics WHERE user_id = 1 AND trade_id IN (1,2,4,6,7,8,11,56,68,89,435,4523) ORDER BY gmt_last_logistics_time DESC;
SELECT id, gmt_create, gmt_modified, user_id, seller_id , trade_id, mail_no, company_name, item_img, item_name , gmt_last_read_time, last_read_step_count, now_step_count, transit_step_list, status , gmt_update_time, gmt_last_logistics_time FROM tb_user_logistics WHERE user_id = 1 AND status < 1 ORDER BY gmt_last_logistics_time DESC LIMIT 1, 1;
SELECT id, gmt_create, gmt_modified, client_type, client_version , client_version_show, is_max_version, is_force_version, update_msg FROM tb_client_version WHERE client_type = 1 AND client_version = ( SELECT MAX(client_version) FROM tb_client_version WHERE client_type = 1 AND is_max_version = 1 );
SELECT user_id, user_nick, accept_push_type, push_start_time, push_end_time FROM tb_user WHERE status  and 1=1 ORDER BY id LIMIT 1, 1;
SELECT COUNT(1) FROM buyershow WHERE 1 = 1 AND gmt_create >= "3" AND gmt_create <= "3" AND show_count > 1;
SELECT user_id, client_type, client_version, device_token, last_active_time FROM tb_user_client WHERE user_id IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT id AS id, gmt_create AS gmtcreate, gmt_modified AS gmtmodified, like_count AS likecount, dislike_count AS dislikecount , show_count AS showcount, path AS path, feed_id AS feedid, rated_uid AS rateduid, rated_user_nick AS ratedusernick , rater_uid AS rateruid, rater_user_nick AS raterusernick, trade_id AS tradeid, parent_trade_id AS parenttradeid, gmt_trade_create AS gmttradecreate , gmt_trade_finished AS gmttradefinished, auc_num_id AS aucnumid, auction_title AS auctiontitle, auction_pic_url AS auctionpicurl, auction_price AS auctionprice , leaf_cat_id AS leafcatid, root_cat_id AS rootcatid, spu_id AS spuid, feedback AS feedback, feedback_length AS feedbacklength , source AS source, properties AS properties, anony AS anony, vote_useful AS voteuseful, rater_star AS raterstar , attributes AS attributes, feedback_ip AS feedbackip, category_level1_name AS categorylevel1name, category_level2_name AS categorylevel2name, category_leaf_name AS categoryleafname , auction_status AS auctionstatus, shop_url AS shopurl, is_prepay AS isprepay, seller_good_rate AS sellergoodrate, dsr_merchandise AS dsrmerchandise , dsr_service AS dsrservice, dsr_consignment AS dsrconsignment, dsr_logistics_service AS dsrlogisticsservice, isprocessed AS isprocessed FROM buyershow_daily_sync ORDER BY id ASC LIMIT 1, 1;
SELECT id, gmt_create, gmt_modified, user_id, seller_id , trade_id, mail_no, company_name, item_img, item_name , gmt_last_read_time, last_read_step_count, now_step_count, transit_step_list, status , gmt_update_time, gmt_last_logistics_time FROM tb_user_logistics WHERE user_id = 1 AND status < 1;
SELECT plugin_id FROM tb_user_plugin_rel WHERE user_id = 1 AND status = 1;
SELECT id AS id FROM buyershow WHERE 1 = 1 AND gmt_create >= "3" AND gmt_create <= "3";
SELECT id, gmt_create, gmt_modified, user_id, user_nick , last_active_time, accept_push_type, push_start_time, push_end_time, status FROM tb_user WHERE user_id = 1;
SELECT subcribe_count FROM tb_shop_info WHERE seller_id = 1;
SELECT COUNT(*) FROM tb_user_logistics WHERE user_id = 1 AND last_read_step_count != now_step_count AND status < 1;
SELECT COUNT(1) FROM buyershow_daily_sync;

