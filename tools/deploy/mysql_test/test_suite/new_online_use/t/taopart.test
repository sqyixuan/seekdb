INSERT INTO tb_user_logistics (id, gmt_create, gmt_modified, user_id, seller_id , trade_id, mail_no, company_name, item_img, item_name , gmt_last_read_time, last_read_step_count, now_step_count, transit_step_list, status , gmt_update_time, gmt_last_logistics_time) VALUES (1, "2015-09-30 12:00:00", "2015-09-30 12:00:00", 1, 1 , 1, "30", "30", "30", "30" , "2016-09-30 00:00:01", 1, 1, "30", 1 , "2015-09-30 12:00:00", "2015-09-30 12:00:00");
