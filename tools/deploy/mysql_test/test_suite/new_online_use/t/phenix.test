--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: jim.wjh
#owner group:sql2
#tags new_online_use 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists album (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`title` varchar(32) NOT NULL COMMENT '专辑名称', 
	`cat_id` int(11) NOT NULL COMMENT '类目ID', 
	`user_nick` varchar(32) NULL COMMENT '用户昵称', 
	`origin_id` bigint(20) UNSIGNED NOT NULL COMMENT '原数据ID', 
	`origin_type` tinyint(4) NOT NULL COMMENT '来源类别', 
	`description` varchar(256) NULL COMMENT '专辑描述', 
	`tags` varchar(118) NULL COMMENT '专辑标签', 
	`fav_count` int(11) DEFAULT '0' NOT NULL COMMENT '喜欢数', 
	`comment_count` int(11) DEFAULT '0' NOT NULL COMMENT '评论数', 
	`status` tinyint(4) DEFAULT '1' NOT NULL COMMENT '状态(1-正常 0-逻辑删除)', 
	`visited_count` int(11) NOT NULL COMMENT '访问的次数', 
	`upload_time` datetime NULL COMMENT '专辑内容发生修改的时间', 
	PRIMARY KEY (`id`), 
	KEY `idx_user_origin_id` (`user_id`, `origin_id`)
)  AUTO_INCREMENT = 4538760007 CHARSET = utf8 COMMENT = '专辑表';
CREATE TABLE if not exists data_album (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`data_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`user_nick` varchar(256) NOT NULL COMMENT '用户nick', 
	`album_id` bigint(20) UNSIGNED NOT NULL COMMENT '专辑ID', 
	`type` tinyint(4) DEFAULT '1' NOT NULL COMMENT '物种类型：1 宝贝 2 图片 3 文章 5 店铺 6 U 站', 
	`status` tinyint(4) DEFAULT '1' NOT NULL COMMENT '状态 0 禁用, 1 启用', 
	`gmt_modified` datetime NOT NULL COMMENT '变更时间', 
	`src_id` bigint(20) UNSIGNED NOT NULL COMMENT '对应的资源ID', 
	`primitive_id` bigint(20) UNSIGNED NOT NULL COMMENT '对应资源的原始ID', 
	PRIMARY KEY (`id`), 
	KEY `idx_did_uid_type` (`data_id`, `user_id`, `type`)
)  CHARSET = utf8 COMMENT = '单p+人和专辑的关系。';
CREATE TABLE if not exists data_follow (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`data_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`data_user_id` bigint(20) UNSIGNED NOT NULL COMMENT '关注的信息所属的用户ID', 
	`status` tinyint(4) NOT NULL COMMENT '状态(0-删除，1-正常)', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '关注者的Id', 
	`type` tinyint(4) NOT NULL COMMENT '关注的信息类型(1、专辑,2、店铺)', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_data_user_type` (`data_id`, `user_id`, `type`)
)  AUTO_INCREMENT = 3011454378 CHARSET = utf8 COMMENT = '信息被关注表';
CREATE TABLE if not exists follow_data (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`type` tinyint(4) NOT NULL COMMENT '关注的信息类型(1、专辑,2、店铺)', 
	`data_id` bigint(20) UNSIGNED NOT NULL COMMENT '关注的信息主键ID', 
	`data_user_id` bigint(20) UNSIGNED NOT NULL COMMENT '关注的信息所属的用户ID', 
	`status` tinyint(4) NOT NULL COMMENT '状态(0-删除，1-正常)', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_data_user_type` (`data_id`, `user_id`, `type`), 
	KEY `idx_user_id_gmt_c` (`user_id`, `gmt_create`)
)  AUTO_INCREMENT = 3006506633 CHARSET = utf8 COMMENT = '用户关注的信息表';
CREATE TABLE if not exists niupixuan_record (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主1,2,4,6,7,8,11,56,68,89,435,4523', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '表1,2,4,6,7,8,11,56,68,89,435,4523段', 
	`source_id` bigint(20) UNSIGNED NOT NULL COMMENT '1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523ID', 
	`npx` int(11) DEFAULT '0' COMMENT '1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523', 
	`operation` int(11) NULL COMMENT '1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523', 
	`operation_desc` varchar(118) NULL COMMENT '1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523述', 
	`gmt_create` datetime NOT NULL COMMENT '建1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523', 
	`gmt_modified` datetime NOT NULL COMMENT '修1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 10875005 CHARSET = utf8 COMMENT = '1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523滤表';
CREATE TABLE if not exists phenix_recom_user (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`gender` smallint(6) NULL COMMENT '性别', 
	`age` smallint(6) NULL COMMENT '年龄', 
	`category` varchar(2000) NULL COMMENT '类目集合', 
	`tag` varchar(2000) NULL COMMENT '标签集合', 
	`promoted_type` smallint(6) NULL COMMENT '用户身份标识', 
	PRIMARY KEY (`id`), 
	KEY `index_user_id` (`user_id`)
)  CHARSET = utf8 COMMENT = '回流推荐用户表';
CREATE TABLE if not exists phenix_recommend_album_feature (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`album_id` bigint(20) UNSIGNED NOT NULL COMMENT '专辑id', 
	`album_title` varchar(100) NOT NULL COMMENT '专辑名称', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '专辑归属用户id', 
	`category` varchar(2000) NULL COMMENT '专辑类目集合', 
	`tag` varchar(2000) NULL COMMENT '专辑标签集合', 
	`category_id` varchar(2000) NULL COMMENT '专辑类目id集合', 
	`category_name` varchar(2000) NULL COMMENT '专辑类目名称集合', 
	PRIMARY KEY (`id`), 
	KEY `index_gmt_modified` (`gmt_modified`)
)  AUTO_INCREMENT = 660999 CHARSET = utf8 COMMENT = 'datax回流表';
CREATE TABLE if not exists phenix_recommend_hot_follow_album (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`album_id` bigint(20) UNSIGNED NOT NULL COMMENT '专辑资源id', 
	`album_title` varchar(100) NOT NULL COMMENT '专辑标题', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '归属用户id', 
	`category` varchar(100) NULL COMMENT '叶子类目集合', 
	`tag` varchar(100) NULL COMMENT '标签集合', 
	`follow_cnt` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '收藏数', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 31 CHARSET = utf8 COMMENT = '最热收藏专辑回流表';
CREATE TABLE if not exists source (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段 用户ID', 
	`user_nick` varchar(32) NOT NULL COMMENT '用户昵称', 
	`origin_id` bigint(20) UNSIGNED NOT NULL COMMENT '源数据ID(如果来自数据迁移则为之前各应用的数据ID，若为新增则与id保持一致)', 
	`origin_type` tinyint(4) NOT NULL COMMENT '来源类别(1-顽兔；2-爱逛街；3-乐活+)', 
	`type` tinyint(4) NOT NULL COMMENT '资源类型（1-宝贝；2-图片；3-文章）', 
	`album_id` bigint(20) UNSIGNED NOT NULL COMMENT '专辑ID', 
	`primitive_id` bigint(20) UNSIGNED NOT NULL COMMENT '原始资源ID', 
	`status` tinyint(4) NOT NULL COMMENT '状态(0-删除，1-正常，2-不进入广场页)', 
	`fav_count` int(11) NOT NULL COMMENT '喜欢数', 
	`comment_count` int(11) NOT NULL COMMENT '评论数', 
	`carrot_count` int(11) NOT NULL COMMENT '萝卜数', 
	`shit_count` int(11) NOT NULL COMMENT '粪球数', 
	`cat_id` int(11) NOT NULL COMMENT '类别ID', 
	`privacy` tinyint(4) NOT NULL COMMENT '隐私状态（0-可见，1-隐私)', 
	`action_type` int(11) NOT NULL COMMENT '动作的类别(1-发布,2-喜欢,3-加入专辑，4-分享 ）', 
	`first_owner_nick` varchar(32) NOT NULL COMMENT '最初的采集人Nick', 
	`from_owner_nick` varchar(32) NOT NULL COMMENT '--被我转采人Nick', 
	`first_owner_id` bigint(20) UNSIGNED NOT NULL COMMENT '最初发表者Id', 
	`from_owner_id` bigint(20) UNSIGNED NOT NULL COMMENT '被转采的人Id', 
	`from_id` bigint(20) UNSIGNED NOT NULL COMMENT '被转采的资源Id', 
	PRIMARY KEY (`id`), 
	KEY `idx_user_album_id` (`user_id`, `album_id`), 
	KEY `idx_from_user` (`from_id`, `user_id`), 
	KEY `idx_pua` (`primitive_id`, `user_id`, `action_type`), 
	KEY `idx_uid_oid_stat` (`user_id`, `origin_id`, `status`), 
	KEY `idx_userid_type_privacy` (`user_id`, `type`, `privacy`)
)  AUTO_INCREMENT = 10304998912 CHARSET = utf8 COMMENT = '资源索引表';
CREATE TABLE if not exists source_album (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`primitive_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段 第一次被加入专辑的原始资源ID', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`album_id` bigint(20) UNSIGNED NOT NULL COMMENT '专辑ID', 
	`data_id` bigint(20) UNSIGNED NULL COMMENT 'phenix外全网单P ID', 
	`status` bigint(20) UNSIGNED NOT NULL COMMENT '0-删除，1-正常', 
	`gmt_modified` datetime NULL COMMENT '修改时间', 
	`src_id` bigint(20) UNSIGNED NOT NULL COMMENT '对应的资源ID', 
	`user_nick` varchar(256) NOT NULL COMMENT '所属用户的nick', 
	PRIMARY KEY (`id`), 
	KEY `idx_pid_uid` (`primitive_id`, `user_id`)
)  AUTO_INCREMENT = 114534016 CHARSET = utf8 COMMENT = 'p-专辑关系表';
CREATE TABLE if not exists source_from (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`from_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`src_id` bigint(20) UNSIGNED NOT NULL COMMENT '资源ID', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`user_nick` varchar(32) NOT NULL COMMENT '用户昵称', 
	`action_type` int(11) NOT NULL COMMENT '动作类型', 
	PRIMARY KEY (`id`), 
	KEY `idx_from_id` (`from_id`), 
	KEY `idx_action_from_id` (`action_type`, `from_id`)
)  AUTO_INCREMENT = 10445994080 CHARSET = utf8 COMMENT = '资源反向表,以fromId分表';
CREATE TABLE if not exists source_love (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`data_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`res_id` bigint(20) UNSIGNED NOT NULL COMMENT '资源主键', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`user_nick` varchar(32) NOT NULL COMMENT '用户昵称', 
	`type` tinyint(4) NOT NULL COMMENT '资源类型（1-宝贝；2-图片；3-文章）', 
	`status` tinyint(4) NOT NULL COMMENT '状态(0-删除，1-正常, 2-不进入广场页)', 
	`action_type` int(11) NOT NULL COMMENT '动作类型', 
	`album_id` bigint(20) NOT NULL COMMENT '专辑ID', 
	`from_id` bigint(20) UNSIGNED NOT NULL COMMENT '资源的来源ID', 
	PRIMARY KEY (`id`), 
	KEY `idx_data_id` (`data_id`), 
	KEY `idx_user_data_id` (`user_id`, `data_id`), 
	KEY `idx_res_data_id` (`res_id`, `data_id`)
)  AUTO_INCREMENT = 4502960594 CHARSET = utf8 COMMENT = '资源反向表,以dataId分表';
CREATE TABLE if not exists src_article (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`src_id` bigint(20) UNSIGNED NOT NULL COMMENT '主表ID', 
	`title` varchar(32) NOT NULL COMMENT '攻略标题', 
	`content_key` varchar(128) NULL COMMENT '内容tfs存储key', 
	`cover_picpath` varchar(128) NULL COMMENT '封面图片', 
	`item_id` varchar(1300) NULL COMMENT '商品ID', 
	`tags` varchar(118) NULL COMMENT '标签', 
	`count_num` int(11) NULL COMMENT '阅读数', 
	`summary` varchar(256) NULL COMMENT '摘要', 
	`source_url` varchar(256) NULL COMMENT '来源url', 
	`original` tinyint(4) NULL COMMENT '是否原创，0不是，1是', 
	`feature` varchar(1024) NULL COMMENT '属性字段', 
	PRIMARY KEY (`id`), 
	KEY `idx_src_user_id` (`src_id`, `user_id`)
)  AUTO_INCREMENT = 7156474079 CHARSET = utf8 COMMENT = '攻略表';
CREATE TABLE if not exists src_item (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`src_id` bigint(20) UNSIGNED NOT NULL COMMENT '主表ID', 
	`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '商品ID', 
	`description` varchar(1024) NOT NULL COMMENT '商品描述', 
	`is_buyed` tinyint(4) NOT NULL COMMENT '是否已购买 (0-未购 1-已购)', 
	`tags` varchar(118) NOT NULL COMMENT '商品标签', 
	`src_url` varchar(1024) NOT NULL COMMENT '来源url', 
	`features` varchar(1024) NOT NULL COMMENT '扩展信息(淘客链接等)', 
	`action_type` int(11) DEFAULT '0' NOT NULL COMMENT '动作的类别(1-发布,2-喜欢,3-加入专辑，4-分享 ）', 
	`title` varchar(256) NULL COMMENT '宝贝名称', 
	`price` bigint(20) UNSIGNED NULL COMMENT '宝贝价格', 
	`img_url` varchar(256) NULL COMMENT '宝贝图片', 
	PRIMARY KEY (`id`), 
	KEY `idx_src_user_id` (`src_id`, `user_id`), 
	KEY `idx_user_buy` (`user_id`, `is_buyed`)
)  AUTO_INCREMENT = 7591264601 CHARSET = utf8 COMMENT = '宝贝表';
CREATE TABLE if not exists src_item_snapshot (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`price` bigint(20) UNSIGNED NULL COMMENT '价格', 
	`title` varchar(256) NULL COMMENT '名称', 
	`img_url` varchar(256) NULL COMMENT '主图地址', 
	PRIMARY KEY (`id`), 
	KEY `idx_iid` (`item_id`)
)  AUTO_INCREMENT = 26940272784 CHARSET = utf8 COMMENT = '宝贝历史快照存档';
CREATE TABLE if not exists src_picture (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`src_id` bigint(20) UNSIGNED NOT NULL COMMENT '主表ID', 
	`pic_path` varchar(200) NOT NULL COMMENT '图片地址', 
	`width` int(11) NOT NULL COMMENT '图片宽度', 
	`height` int(11) NOT NULL COMMENT '图片高度', 
	`tags` varchar(118) NULL COMMENT '标签', 
	`description` varchar(1024) NULL COMMENT '描述', 
	`img_type` tinyint(4) NOT NULL COMMENT '图片类型(jpeg/bmp/gif)', 
	`img_file_id` bigint(20) UNSIGNED NOT NULL COMMENT 'img文件在图片空间的唯一编号', 
	`src_url` varchar(1024) NULL COMMENT '图片来源URL', 
	`cutted_pic_path` varchar(200) NULL COMMENT '裁剪图片地址', 
	`has_auction` tinyint(4) NOT NULL COMMENT '是否导购', 
	`item_id` varchar(60) NULL COMMENT '导购商品ID', 
	`features` varchar(1024) NULL COMMENT '扩展信息：淘客链接', 
	`indexed` int(11) NOT NULL COMMENT '排列顺序', 
	PRIMARY KEY (`id`), 
	KEY `idx_src_user_id` (`src_id`, `user_id`), 
	KEY `idx_img_file_id` (`img_file_id`), 
	KEY `idx_user_id` (`user_id`)
)  CHARSET = utf8 COMMENT = '资源表-图片信息';
CREATE TABLE if not exists user (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`user_nick` varchar(32) NOT NULL COMMENT '用户昵称', 
	`user_role` bigint(20) NOT NULL COMMENT '用户角色(管理员/达人/淘客)', 
	`status` tinyint(4) DEFAULT '1' NOT NULL COMMENT '用户状态(停用/正常)', 
	`visited_count` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '访问次数', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_user_id` (`user_id`)
)  CHARSET = utf8 COMMENT = '用户信息表';
CREATE TABLE if not exists user_medal (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户Id', 
	`medal_id` int(11) NOT NULL COMMENT '勋章Id', 
	`granted_time` datetime NOT NULL COMMENT '授予时间', 
	`granted_no` bigint(20) UNSIGNED NULL COMMENT '授予的名次', 
	`status` tinyint(4) NOT NULL COMMENT '0正常，1取消', 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	`cate_id` int(11) NOT NULL COMMENT '勋章种类ID', 
	PRIMARY KEY (`id`), 
	KEY `idx_user_id` (`user_id`)
)  AUTO_INCREMENT = 34216811 CHARSET = utf8 COMMENT = '用户勋章表';
CREATE TABLE if not exists user_stat (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`type` tinyint(4) NOT NULL COMMENT '物种类别', 
	`stat_info` varchar(2048) NULL COMMENT '统计信息', 
	PRIMARY KEY (`id`), 
	UNIQUE `u_t_udx` (`user_id`, `type`)
)  AUTO_INCREMENT = 1331771067714 CHARSET = utf8 COMMENT = '用户数据统计表';

SELECT id, user_id, src_id, pic_path, width , height, tags, description, img_type, img_file_id , src_url, cutted_pic_path, has_auction, item_id, features , indexed, gmt_create, gmt_modified FROM src_picture WHERE user_id = 1 AND src_id = 1;
SELECT id, user_id, title, cat_id, comment_count , fav_count, gmt_create, gmt_modified, description FROM album WHERE status IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND user_id = 1 ORDER BY gmt_create DESC LIMIT 1, 1;
SELECT COUNT(*) FROM source WHERE user_id = 1 AND status IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND action_type = 1;
SELECT id, item_id, title, price, img_url FROM src_item_snapshot WHERE item_id IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT id, user_id, type, stat_info, gmt_create , gmt_modified FROM user_stat WHERE user_id = 1 AND type = 1;
