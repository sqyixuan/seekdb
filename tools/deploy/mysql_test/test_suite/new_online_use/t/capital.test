--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt 
#owner group:sql1 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists capital_sequence (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`name` varchar(64) NOT NULL COMMENT '序列名', 
	`value` bigint(20) NOT NULL COMMENT '序列值', 
	`gmt_create` timestamp DEFAULT CURRENT_TIMESTAMP COMMENT '记录创建日期', 
	`gmt_modified` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL COMMENT '记录更新时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `unique_name` (`name`)
)  AUTO_INCREMENT = 5 CHARSET = utf8 COMMENT = '赔付序列表';
CREATE TABLE if not exists compen_auto_unique (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`out_id` varchar(200) NOT NULL COMMENT '外部唯一编号', 
	PRIMARY KEY (`id`), 
	UNIQUE `idx_compen_auto_unique_out_id` (`out_id`)
)  AUTO_INCREMENT = 37114082 CHARSET = utf8 COMMENT = '赔付唯一主键表';
CREATE TABLE if not exists compen_type_config (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`compen_type_name` varchar(30) NOT NULL COMMENT '赔付类型名称', 
	`money_types` varchar(20) NOT NULL COMMENT '资金类型，COMPEN_TOTAL_FEE(0,"赔付总金额"), COMPEN_FEE(1,"赔付金额"), ADVANCE_FEE(2,"垫付金额"), EXTRA_ADVANCE_FEE(3,"额外垫付金额"), TMALL_POINTS(4,"商城积分"), POST_FEE(5, "退货运费"), FAKEFIVE_FEE(6, "假一赔五"),', 
	`payer_actors` varchar(20) NOT NULL COMMENT '赔付角色，TAOBAO(1,"淘宝"),     BUYER(2,"买家"),     SELLER(3,"卖家"),    CHOUJIAN(4,"抽检方"),    WLBTP(5,"物流宝TP"),    SPECIAL(6,"特殊赔付对象"),    SUPPLIER(7,"供应商"),    TMALL(8,"天猫"),    LOGISTICSTP(9,"物流TP"),    ROOKIE(10,"菜鸟")', 
	`payee_actors` varchar(20) NOT NULL COMMENT '同payer_actors', 
	`reminder_actos` varchar(20) NULL COMMENT '同payer_actors', 
	`freeze_types` varchar(20) NULL COMMENT '资金冻结类型，ADVANCE_FREEZE(0, "是否冻结垫付金额", "advanceFreeze"), TRANSFER_FREEZE(1, "是否冻结保证金", "transferFreeze")', 
	`other_inputs` varchar(20) NULL COMMENT '其他输入，BEREMINDER_INPUT(0, "催缴金额", "bereminderInput"), MOVE_FREEZE_MONEY(1, "转移冻结金额", "monveFreezeMoney")', 
	`common_validators` varchar(200) NULL COMMENT '通用校验器', 
	`create_validators` varchar(118) NULL COMMENT '创建校验器', 
	`edit_vliadators` varchar(118) NULL COMMENT '编辑校验器', 
	`processname` varchar(50) NOT NULL COMMENT '流程名称', 
	`payagent` varchar(30) NULL COMMENT '出账接口', 
	`case_types` varchar(20) NULL COMMENT 'case类型，REFUND_CASE(1,"退款"), SUIT_CASE(2,"投诉"), LOGISTICS_CASE(3,"物流工单"), FORM_CASE(4,"表单"), TMALL_SUIT(5,"天猫投诉"),    RIGHT_CASE(6,"淘宝售后")', 
	`order_types` varchar(20) NULL COMMENT '订单类型，TC(1,"交易订单"), WLB(2,"物流宝订单"), ZHIJIAN(3,"质检订单"), ALIPAY(4,"支付宝订单"), SPECIAL(5,"特殊编号"), LOGISTICS(6,"物流订单"), AIRTRAVEL(7,"机票订单"), LOTTERY(8,"彩票订单"),', 
	`gmt_create` datetime NULL COMMENT '创建时间', 
	`gmt_modified` datetime NULL COMMENT '更新时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `idx_unique_primary` (`compen_type_name`)
)  CHARSET = utf8 COMMENT = '赔付类型配置表';
CREATE TABLE if not exists compensate_bill_alive (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`order_id` varchar(64) NULL COMMENT '订单编号', 
	`order_type` int(10) UNSIGNED NULL COMMENT '订单类型，淘宝订单、彩票订单、物流宝订单等', 
	`case_id` bigint(20) UNSIGNED NULL COMMENT 'case编号', 
	`case_type` int(10) UNSIGNED NULL COMMENT 'case类型，退款、投诉、表单等', 
	`alipay_order_id` varchar(64) NULL COMMENT '赔付记录关联的订单的支付宝交易号', 
	`compen_type` varchar(32) NOT NULL COMMENT '赔付类型', 
	`payer_id` bigint(20) UNSIGNED NOT NULL COMMENT '付款方UIC-ID', 
	`payer_actor` int(10) UNSIGNED NOT NULL COMMENT '付款方角色', 
	`payee_id` bigint(20) UNSIGNED NOT NULL COMMENT '收款方UIC-ID', 
	`payee_actor` int(10) UNSIGNED NOT NULL COMMENT '收款方角色', 
	`total_amout` bigint(20) UNSIGNED NOT NULL COMMENT '赔付金额，单位分', 
	`amounts` varchar(100) NULL COMMENT '赔付金额，积分明细', 
	`creator_id` bigint(20) UNSIGNED NULL COMMENT '赔付单创建人', 
	`previous_id` bigint(20) UNSIGNED NULL COMMENT '赔付单之前审批人', 
	`dealer_id` bigint(20) UNSIGNED NULL COMMENT '赔付单当前审批人', 
	`status` int(11) NOT NULL COMMENT '赔付状态', 
	`reminder_status` int(11) NULL COMMENT '催缴状态', 
	`compen_memo` varchar(100) NULL COMMENT '赔付单备注', 
	`gmt_pay_date` datetime NULL COMMENT '出账时间', 
	`pay_alipay_order_id` varchar(64) NULL COMMENT '出账的支付宝交易号', 
	`move_freeze_fee` bigint(20) UNSIGNED NULL COMMENT '冻结金额', 
	`sync_version` int(11) NULL COMMENT '版本信息，暂时未用', 
	`main_order_id` varchar(64) NULL COMMENT '赔付记录关联的主订单编号', 
	`out_id` varchar(118) NULL COMMENT '赔付唯一外部编号', 
	`attributes` varchar(100) NULL COMMENT '赔付属性及扩充字段', 
	PRIMARY KEY (`id`), 
	KEY `idx_compensate_bill_outid` (`out_id`), 
	KEY `ind_compensate_bill_case` (`case_id`, `case_type`), 
	KEY `ind_compensate_bill_creator` (`creator_id`, `status`, `gmt_create`), 
	KEY `ind_compensate_bill_dealer` (`dealer_id`, `status`, `gmt_create`), 
	KEY `ind_compensate_bill_moid` (`main_order_id`), 
	KEY `ind_compensate_bill_order` (`order_id`), 
	KEY `ind_compensate_bill_payee` (`payee_id`, `gmt_create`), 
	KEY `ind_compensate_bill_payer` (`payer_id`, `gmt_create`)
)  CHARSET = utf8 COMMENT = '赔付记录活跃表';
CREATE TABLE if not exists compensate_remind_cfg (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`compen_type` varchar(32) NOT NULL COMMENT '赔付类型', 
	`max_retry_times` int(11) NOT NULL COMMENT '最多重试次数', 
	`interval_days` int(11) NOT NULL COMMENT '催缴间隔时间', 
	`env_type` varchar(40) NULL COMMENT '环境标记，预发还是线上', 
	`status` int(11) NULL COMMENT '配置状态', 
	PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '赔付催缴配置表';
CREATE TABLE if not exists compensate_reminder (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`compen_id` bigint(20) UNSIGNED NOT NULL COMMENT '赔付编号', 
	`compen_type` varchar(32) NOT NULL COMMENT '冗余赔付类型', 
	`reminder_user_id` bigint(20) UNSIGNED NOT NULL COMMENT '被催缴人id', 
	`amount` bigint(20) UNSIGNED NOT NULL COMMENT '催缴金额', 
	`alipay_order_id` varchar(64) NULL COMMENT '催缴的支付宝交易号', 
	`return_payment_date` datetime NULL COMMENT '催缴还款时间', 
	`retry_times` int(11) NULL COMMENT '催缴重试次数', 
	`status` int(11) NOT NULL COMMENT '催缴状态', 
	`reminder_memo` varchar(100) NULL COMMENT '备注', 
	`reminder_user_nick` varchar(118) NOT NULL COMMENT '被催缴人nick', 
	`env_type` varchar(20) NULL COMMENT '当期提醒的执行环境', 
	`remind_pay_url` varchar(400) NULL COMMENT '催缴还款链接', 
	`cancel_reason` int(11) NULL COMMENT '撤销原因', 
	`islocked` int(11) NULL COMMENT '数据是否锁住', 
	PRIMARY KEY (`id`), 
	KEY `ind_compensate_reminder_compen` (`compen_id`), 
	KEY `ind_compensate_reminder_user` (`reminder_user_id`, `status`)
)  CHARSET = utf8 COMMENT = '赔付催缴表';
CREATE TABLE if not exists compensate_sequence (
	`name` varchar(50) NOT NULL COMMENT '主键', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`seq_value` bigint(20) NOT NULL COMMENT '当前序列值', 
	PRIMARY KEY (`name`)
)  CHARSET = utf8 COMMENT = '赔付编号序列表';
CREATE TABLE if not exists compensate_type (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`code` varchar(118) NOT NULL COMMENT '赔付code', 
	`parent_code` varchar(118) NOT NULL COMMENT '父节点code', 
	`alias` varchar(118) NOT NULL COMMENT '赔付类型全称', 
	`name` varchar(118) NOT NULL COMMENT '赔付类型简称', 
	`type_level` int(11) NULL COMMENT '暂时未使用', 
	PRIMARY KEY (`id`), 
	KEY `ind_compensate_type` (`code`)
)  CHARSET = utf8 COMMENT = '赔付类型表';
CREATE TABLE if not exists crm_advance_timeout (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_created` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`refund_id` bigint(20) UNSIGNED NULL COMMENT '退款id', 
	`timeout_type` int(10) UNSIGNED NULL COMMENT '超时类型 1.	等待买家退货 2.	等待卖家确认收货 3. 未收到货等待卖家确认', 
	`gmt_finished` datetime NULL COMMENT '完结时间', 
	`gmt_timeout` datetime NULL COMMENT '超时时间', 
	`fail_count` int(10) UNSIGNED NULL COMMENT '失败次数(默认超过10次,置为异常,不再处理)', 
	`fail_info` varchar(500) NULL COMMENT '失败信息', 
	`status` int(10) UNSIGNED NULL COMMENT '状态0.未处理 1.处理中2.完成，4异常', 
	PRIMARY KEY (`id`), 
	KEY `idx_adv_timeout_rid` (`refund_id`, `timeout_type`, `gmt_created`), 
	KEY `idx_adv_timeout_st_gmttimeout` (`status`, `gmt_timeout`), 
	KEY `idx_adv_timeout_status` (`status`, `gmt_modified`, `timeout_type`, `gmt_timeout`)
)  CHARSET = utf8 COMMENT = '垫付超时表，应该可以废弃';
CREATE TABLE if not exists crm_compensate_info (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`scheme_id` bigint(20) NULL COMMENT '任务ID（CRM_SCHEME_DETAIL.ID）', 
	`compen_fee` bigint(20) UNSIGNED NULL COMMENT '赔付金额', 
	`trade_id` bigint(20) NULL COMMENT '淘宝交易号', 
	`alipay_trade_no` varchar(118) NULL COMMENT '支付宝交易号', 
	`memo` varchar(2000) NULL COMMENT '备注', 
	`source_info_id` bigint(20) NULL COMMENT '投诉退款编号 投诉举报（包括物流）：CRM_PUNISH_INFO.PUNISH_ID 退款编号：CRM_REFUND_INFO.REFUND_ID', 
	`biz_source` int(11) NULL COMMENT '业务类型 801-投诉举报任务 803-物流投诉任务 999-退款任务', 
	`compen_status` int(11) NULL COMMENT '0-	待提交1-	待初审2-	待复审3-	待财务审批4-	已完成5-	已取消', 
	`payee_user_id` bigint(20) NULL COMMENT '收款人数字ID', 
	`payer_user_id` bigint(20) NULL COMMENT '付款人数字ID', 
	`is_backward` int(11) NULL COMMENT '是否被退回 0-否 1-是', 
	`compen_type` varchar(118) NULL COMMENT '赔付类型', 
	`creator_id` bigint(20) UNSIGNED NULL COMMENT '创建人id', 
	`deal_id` bigint(20) UNSIGNED NULL COMMENT '处理人id', 
	`move_freeze_fee` bigint(20) UNSIGNED NULL COMMENT '冻结金额', 
	`previou_user_id` bigint(20) NULL COMMENT '上一个用户ID', 
	`payment_remind_status` int(11) NULL COMMENT '赔付催缴状态（1：催缴中，2：催缴完成）', 
	`payment_remind_money` bigint(20) UNSIGNED NULL COMMENT '赔付催缴金额', 
	`payment_be_reminders` varchar(50) NULL COMMENT '被催缴人nick', 
	`payment_remind_date` datetime NULL COMMENT '催缴还款时间', 
	`payment_remind_tradeno` varchar(800) NULL COMMENT '催缴还款对应的支付宝交易号', 
	`auto_punish_date` datetime NULL COMMENT '自动处罚时间', 
	`compen_paymoeny_date` datetime NULL COMMENT '财务出账时间', 
	`advance_type` int(11) NULL COMMENT '=CRM_ADVANCE_INFO.ADVANCE_TYPE', 
	`sync_version` bigint(20) NULL COMMENT '无用字段', 
	PRIMARY KEY (`id`), 
	KEY `index_scheme_id` (`scheme_id`), 
	KEY `index_payee` (`payee_user_id`), 
	KEY `index_payer` (`payer_user_id`), 
	KEY `index_tradeid` (`trade_id`), 
	KEY `index_businessid` (`source_info_id`), 
	KEY `index_alipay_no` (`alipay_trade_no`), 
	KEY `index_compen_paymoeny_date` (`compen_paymoeny_date`)
)  AUTO_INCREMENT = 6500061 CHARSET = utf8 COMMENT = '老的赔付表，迁移自CRM库';
CREATE TABLE if not exists crm_compensate_type (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`compen_key` varchar(118) NULL COMMENT '赔付类型key值', 
	`compen_code` varchar(200) NULL COMMENT '编码', 
	`compen_name` varchar(200) NULL COMMENT '赔付类型名称', 
	`compen_parents` bigint(20) NULL COMMENT '父亲类型id', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 195 CHARSET = utf8 COMMENT = '老的赔付类型';
CREATE TABLE if not exists crm_mall_apply (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modify` datetime NOT NULL COMMENT '修改时间', 
	`punish_id` bigint(20) UNSIGNED NOT NULL COMMENT '投诉任务id', 
	`sub_order_id` bigint(20) UNSIGNED NOT NULL COMMENT '淘宝交易号', 
	`main_order_id` bigint(20) UNSIGNED NOT NULL COMMENT '父淘宝交易号', 
	`alipay_id` varchar(40) NOT NULL COMMENT '支付宝交易号', 
	`refund_cash_to_buyer` bigint(20) NULL COMMENT '退给买家的现金', 
	`refund_point_to_buyer` bigint(20) NULL COMMENT '退的买家消费积分', 
	`refund_commission_to_seller` bigint(20) NULL COMMENT '退给卖家的佣金', 
	`refund_other_to_buyer` bigint(20) NULL COMMENT '退给卖家的其他金额包括返点积分', 
	`refund_buyer` varchar(32) NOT NULL COMMENT '买家昵称', 
	`refund_buyer_id` bigint(20) UNSIGNED NOT NULL COMMENT '买家数字id', 
	`refund_seller` varchar(32) NOT NULL COMMENT '卖家昵称', 
	`refund_seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '卖家数字id', 
	`order_status` int(11) NULL COMMENT '申请单状态 1- 复审被退回 2- 待复审 3- 已完成', 
	`create_dealer_id` bigint(20) UNSIGNED NOT NULL COMMENT '创建人', 
	`process_status` bigint(20) UNSIGNED NULL COMMENT '申请单处理状态', 
	`xiaoer_quantity` bigint(20) UNSIGNED NULL COMMENT '小二填写的退货数量', 
	`auction_title` varchar(256) NULL COMMENT '宝贝title', 
	`peifu_to_buyer` bigint(20) NULL COMMENT '多余赔付买家的金额', 
	`compen_funds_source` int(11) NULL COMMENT '商城保证金来源, 0-商城基础保证金  1-聚划算商城保证金', 
	PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '旧赔付记录表';
CREATE TABLE if not exists crm_payment_reminder (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`from_type` bigint(20) UNSIGNED NULL COMMENT '催缴来源类型', 
	`from_source_id` bigint(20) UNSIGNED NULL COMMENT '催缴来源业务编号id', 
	`reminder_status` bigint(20) UNSIGNED NULL COMMENT '催缴状态', 
	`reminder_money` bigint(20) UNSIGNED NULL COMMENT '催缴金额', 
	`bereminder` varchar(50) NULL COMMENT '被催缴人', 
	`remind_tradeurl` varchar(500) NULL COMMENT '催缴后用来支付的url', 
	`memo` varchar(500) NULL COMMENT '备注', 
	`auto_punish` date NULL COMMENT '处罚时间，赔付的催缴到时间了需要进行处罚的，每次自动处罚后会更新这个时间。', 
	`returnmoeny_date` date NULL COMMENT '*', 
	PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '老的赔付催缴表';
CREATE TABLE if not exists compen_freeze_compare_result (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`compen_freeze_fee` bigint(20) UNSIGNED NOT NULL COMMENT '赔付冻结资金', 
	`bail_freeze_fee` bigint(20) UNSIGNED NOT NULL COMMENT '保证金冻结资金', 
	`seller_id` bigint(20) UNSIGNED NULL COMMENT '卖家uic-id', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 108455 CHARSET = utf8 COMMENT = '用于赔付中心与消保的资金对账，每天的量在5w左右，每天从云梯导入新数据并删除之前的数据';
CREATE TABLE if not exists compensate_bill_id (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`order_id` varchar(64) NULL COMMENT '订单编号', 
	`order_type` int(10) UNSIGNED NULL COMMENT '订单类型，淘宝订单、彩票订单、物流宝订单等', 
	`case_id` bigint(20) UNSIGNED NULL COMMENT 'case编号', 
	`case_type` int(10) UNSIGNED NULL COMMENT 'case类型，退款、投诉、表单等', 
	`alipay_order_id` varchar(64) NULL COMMENT '赔付记录关联的订单的支付宝交易号', 
	`compen_type` varchar(32) NOT NULL COMMENT '赔付类型', 
	`payer_id` bigint(20) UNSIGNED NOT NULL COMMENT '付款方UIC-ID', 
	`payer_actor` int(10) UNSIGNED NULL COMMENT '付款方角色', 
	`payee_id` bigint(20) UNSIGNED NOT NULL COMMENT '收款方UIC-ID', 
	`payee_actor` int(10) UNSIGNED NULL COMMENT '收款方角色', 
	`total_amout` bigint(20) UNSIGNED NOT NULL COMMENT '赔付金额，单位分', 
	`amounts` varchar(100) NULL COMMENT '赔付金额，积分明细', 
	`creator_id` bigint(20) UNSIGNED NULL COMMENT '赔付单创建人', 
	`previous_id` bigint(20) UNSIGNED NULL COMMENT '赔付单之前审批人', 
	`dealer_id` bigint(20) UNSIGNED NULL COMMENT '赔付单当前审批人', 
	`status` int(11) NOT NULL COMMENT '赔付状态', 
	`reminder_status` int(11) NULL COMMENT '催缴状态', 
	`compen_memo` varchar(100) NULL COMMENT '赔付单备注', 
	`gmt_pay_date` datetime NULL COMMENT '出账时间', 
	`pay_alipay_order_id` varchar(64) NULL COMMENT '出账的支付宝交易号', 
	`move_freeze_fee` bigint(20) UNSIGNED NULL COMMENT '冻结金额', 
	`sync_version` int(11) NULL COMMENT '版本信息，暂时未用', 
	`main_order_id` varchar(64) NULL COMMENT '赔付记录关联的主订单编号', 
	`out_id` varchar(118) NULL COMMENT '赔付唯一外部编号', 
	`attributes` varchar(100) NULL COMMENT '赔付属性及扩充字段', 
	PRIMARY KEY (`id`), 
	KEY `idx_compensate_bill_outid` (`out_id`), 
	KEY `ind_compensate_bill_case` (`case_id`), 
	KEY `ind_compensate_bill_creator` (`creator_id`, `gmt_create`), 
	KEY `ind_compensate_bill_dealer` (`dealer_id`, `gmt_create`), 
	KEY `ind_compensate_bill_moid` (`main_order_id`), 
	KEY `ind_compensate_bill_order` (`order_id`), 
	KEY `ind_compensate_bill_payee` (`payee_id`, `gmt_create`), 
	KEY `ind_compensate_bill_payer` (`payer_id`, `gmt_create`)
)  CHARSET = utf8 COMMENT = '赔付主表,陪付主维度表';
CREATE TABLE if not exists compensate_bill_order (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`order_id` varchar(64) NULL COMMENT '订单编号', 
	`order_type` int(10) UNSIGNED NULL COMMENT '订单类型，淘宝订单、彩票订单、物流宝订单等', 
	`case_id` bigint(20) UNSIGNED NULL COMMENT 'case编号', 
	`case_type` int(10) UNSIGNED NULL COMMENT 'case类型，退款、投诉、表单等', 
	`alipay_order_id` varchar(64) NULL COMMENT '赔付记录关联的订单的支付宝交易号', 
	`compen_type` varchar(32) NOT NULL COMMENT '赔付类型', 
	`payer_id` bigint(20) UNSIGNED NOT NULL COMMENT '付款方UIC-ID', 
	`payer_actor` int(10) UNSIGNED NULL COMMENT '付款方角色', 
	`payee_id` bigint(20) UNSIGNED NOT NULL COMMENT '收款方UIC-ID', 
	`payee_actor` int(10) UNSIGNED NULL COMMENT '收款方角色', 
	`total_amout` bigint(20) UNSIGNED NOT NULL COMMENT '赔付金额，单位分', 
	`amounts` varchar(100) NULL COMMENT '赔付金额，积分明细', 
	`creator_id` bigint(20) UNSIGNED NULL COMMENT '赔付单创建人', 
	`previous_id` bigint(20) UNSIGNED NULL COMMENT '赔付单之前审批人', 
	`dealer_id` bigint(20) UNSIGNED NULL COMMENT '赔付单当前审批人', 
	`status` int(11) NOT NULL COMMENT '赔付状态', 
	`reminder_status` int(11) NULL COMMENT '催缴状态', 
	`compen_memo` varchar(100) NULL COMMENT '赔付单备注', 
	`gmt_pay_date` datetime NULL COMMENT '出账时间', 
	`pay_alipay_order_id` varchar(64) NULL COMMENT '出账的支付宝交易号', 
	`move_freeze_fee` bigint(20) UNSIGNED NULL COMMENT '冻结金额', 
	`sync_version` int(11) NULL COMMENT '版本信息，暂时未用', 
	`main_order_id` varchar(64) NULL COMMENT '赔付记录关联的主订单编号', 
	`out_id` varchar(118) NULL COMMENT '赔付唯一外部编号', 
	`attributes` varchar(100) NULL COMMENT '赔付属性及扩充字段', 
	PRIMARY KEY (`id`), 
	KEY `idx_compensate_bill_outid` (`out_id`), 
	KEY `ind_compensate_bill_case` (`case_id`), 
	KEY `ind_compensate_bill_creator` (`creator_id`, `gmt_create`), 
	KEY `ind_compensate_bill_dealer` (`dealer_id`, `gmt_create`), 
	KEY `ind_compensate_bill_moid` (`main_order_id`), 
	KEY `ind_compensate_bill_order` (`order_id`), 
	KEY `ind_compensate_bill_payee` (`payee_id`, `gmt_create`), 
	KEY `ind_compensate_bill_payer` (`payer_id`, `gmt_create`)
)  CHARSET = utf8 COMMENT = '赔付主表,订单维度表';
CREATE TABLE if not exists compensate_bill_payee (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`order_id` varchar(64) NULL COMMENT '订单编号', 
	`order_type` int(10) UNSIGNED NULL COMMENT '订单类型，淘宝订单、彩票订单、物流宝订单等', 
	`case_id` bigint(20) UNSIGNED NULL COMMENT 'case编号', 
	`case_type` int(10) UNSIGNED NULL COMMENT 'case类型，退款、投诉、表单等', 
	`alipay_order_id` varchar(64) NULL COMMENT '赔付记录关联的订单的支付宝交易号', 
	`compen_type` varchar(32) NOT NULL COMMENT '赔付类型', 
	`payer_id` bigint(20) UNSIGNED NOT NULL COMMENT '付款方UIC-ID', 
	`payer_actor` int(10) UNSIGNED NULL COMMENT '付款方角色', 
	`payee_id` bigint(20) UNSIGNED NOT NULL COMMENT '收款方UIC-ID', 
	`payee_actor` int(10) UNSIGNED NULL COMMENT '收款方角色', 
	`total_amout` bigint(20) UNSIGNED NOT NULL COMMENT '赔付金额，单位分', 
	`amounts` varchar(100) NULL COMMENT '赔付金额，积分明细', 
	`creator_id` bigint(20) UNSIGNED NULL COMMENT '赔付单创建人', 
	`previous_id` bigint(20) UNSIGNED NULL COMMENT '赔付单之前审批人', 
	`dealer_id` bigint(20) UNSIGNED NULL COMMENT '赔付单当前审批人', 
	`status` int(11) NOT NULL COMMENT '赔付状态', 
	`reminder_status` int(11) NULL COMMENT '催缴状态', 
	`compen_memo` varchar(100) NULL COMMENT '赔付单备注', 
	`gmt_pay_date` datetime NULL COMMENT '出账时间', 
	`pay_alipay_order_id` varchar(64) NULL COMMENT '出账的支付宝交易号', 
	`move_freeze_fee` bigint(20) UNSIGNED NULL COMMENT '冻结金额', 
	`sync_version` int(11) NULL COMMENT '版本信息，暂时未用', 
	`main_order_id` varchar(64) NULL COMMENT '赔付记录关联的主订单编号', 
	`out_id` varchar(118) NULL COMMENT '赔付唯一外部编号', 
	`attributes` varchar(100) NULL COMMENT '赔付属性及扩充字段', 
	PRIMARY KEY (`id`), 
	KEY `idx_compensate_bill_outid` (`out_id`), 
	KEY `ind_compensate_bill_case` (`case_id`), 
	KEY `ind_compensate_bill_moid` (`main_order_id`), 
	KEY `ind_compensate_bill_payee` (`payee_id`, `gmt_create`), 
	KEY `ind_compensate_bill_creator` (`creator_id`, `gmt_create`), 
	KEY `ind_compensate_bill_dealer` (`dealer_id`, `gmt_create`), 
	KEY `ind_compensate_bill_payer` (`payer_id`, `gmt_create`)
)  CHARSET = utf8 COMMENT = '赔付主表,收款方维度表';
CREATE TABLE if not exists compensate_bill_payer (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`order_id` varchar(64) NULL COMMENT '订单编号', 
	`order_type` int(10) UNSIGNED NULL COMMENT '订单类型，淘宝订单、彩票订单、物流宝订单等', 
	`case_id` bigint(20) UNSIGNED NULL COMMENT 'case编号', 
	`case_type` int(10) UNSIGNED NULL COMMENT 'case类型，退款、投诉、表单等', 
	`alipay_order_id` varchar(64) NULL COMMENT '赔付记录关联的订单的支付宝交易号', 
	`compen_type` varchar(32) NOT NULL COMMENT '赔付类型', 
	`payer_id` bigint(20) UNSIGNED NOT NULL COMMENT '付款方UIC-ID', 
	`payer_actor` int(10) UNSIGNED NULL COMMENT '付款方角色', 
	`payee_id` bigint(20) UNSIGNED NOT NULL COMMENT '收款方UIC-ID', 
	`payee_actor` int(10) UNSIGNED NULL COMMENT '收款方角色', 
	`total_amout` bigint(20) UNSIGNED NOT NULL COMMENT '赔付金额，单位分', 
	`amounts` varchar(100) NULL COMMENT '赔付金额，积分明细', 
	`creator_id` bigint(20) UNSIGNED NULL COMMENT '赔付单创建人', 
	`previous_id` bigint(20) UNSIGNED NULL COMMENT '赔付单之前审批人', 
	`dealer_id` bigint(20) UNSIGNED NULL COMMENT '赔付单当前审批人', 
	`status` int(11) NOT NULL COMMENT '赔付状态', 
	`reminder_status` int(11) NULL COMMENT '催缴状态', 
	`compen_memo` varchar(100) NULL COMMENT '赔付单备注', 
	`gmt_pay_date` datetime NULL COMMENT '出账时间', 
	`pay_alipay_order_id` varchar(64) NULL COMMENT '出账的支付宝交易号', 
	`move_freeze_fee` bigint(20) UNSIGNED NULL COMMENT '冻结金额', 
	`sync_version` int(11) NULL COMMENT '版本信息，暂时未用', 
	`main_order_id` varchar(64) NULL COMMENT '赔付记录关联的主订单编号', 
	`out_id` varchar(118) NULL COMMENT '赔付唯一外部编号', 
	`attributes` varchar(100) NULL COMMENT '赔付属性及扩充字段', 
	PRIMARY KEY (`id`), 
	KEY `idx_compensate_bill_outid` (`out_id`), 
	KEY `ind_compensate_bill_case` (`case_id`), 
	KEY `ind_compensate_bill_moid` (`main_order_id`), 
	KEY `ind_compensate_bill_order` (`order_id`), 
	KEY `ind_compensate_bill_create` (`gmt_create`), 
	KEY `ind_compensate_bill_creator` (`creator_id`, `gmt_create`), 
	KEY `ind_compensate_bill_payee` (`payee_id`, `gmt_create`), 
	KEY `ind_compensate_bill_payer` (`payer_id`, `status`)
)  CHARSET = utf8 COMMENT = '赔付主表，收款方维度表';
CREATE TABLE if not exists compensate_process_log (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`compen_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`dealer_id` bigint(20) UNSIGNED NOT NULL COMMENT '动作处理人', 
	`deal_type` int(10) UNSIGNED NOT NULL COMMENT '动作类型', 
	`content` varchar(100) NULL COMMENT '动作备注', 
	`process_level` int(11) NULL COMMENT '动作等级，暂时未用', 
	PRIMARY KEY (`id`), 
	KEY `ind_compensate_process_log_com` (`compen_id`, `process_level`)
)  CHARSET = utf8 COMMENT = '赔付动作记录表';

SELECT b.id, b.order_id, b.order_type, b.case_id, b.alipay_order_id , b.compen_type, b.payer_id, b.payee_id, b.total_amout, b.creator_id , b.dealer_id, b.compen_memo, b.gmt_create, b.gmt_modified, b.status , b.case_type, b.payer_actor, b.payee_actor, b.previous_id, b.gmt_pay_date , b.move_freeze_fee, r.reminder_user_id, r.reminder_user_nick, r.status AS remind_status, r.amount AS remind_amount , r.return_payment_date, r.retry_times, r.id AS remind_id, r.compen_id, r.alipay_order_id AS remind_alipay_order_id , r.reminder_memo, r.compen_type, r.gmt_create, r.gmt_modified, r.remind_pay_url FROM compensate_bill_alive b, compensate_reminder r WHERE b.id = r.compen_id AND r.compen_type LIKE concat("30", "30") AND r.reminder_user_id = 1 AND b.case_id = 1;
SELECT COUNT(*) AS gross, SUM(b.total_amout) AS compensummenoy FROM compensate_bill_order b WHERE b.case_id = 1 AND b.order_id = "3";
SELECT id, order_id, order_type, case_id, case_type , alipay_order_id, compen_type, payer_id, payer_actor, payee_id , payee_actor, total_amout, amounts, creator_id, previous_id , dealer_id, status, reminder_status, compen_memo, gmt_create , gmt_modified, gmt_pay_date, pay_alipay_order_id, move_freeze_fee, main_order_id , out_id, attributes FROM compensate_bill_payee WHERE payee_id = 1 AND order_type = 1 AND main_order_id = "3" AND compen_type LIKE concat("30", "30");
SELECT id, order_id, order_type, case_id, alipay_order_id , compen_type, payer_id, payee_id, total_amout, creator_id , dealer_id, compen_memo, gmt_create, gmt_modified, status , reminder_status, case_type, payer_actor, payee_actor, previous_id , gmt_pay_date, move_freeze_fee, attributes, out_id FROM compensate_bill_order b WHERE case_id = 1 AND order_id = "3" LIMIT 1, 1;
SELECT id, order_id, order_type, case_id, case_type , alipay_order_id, compen_type, payer_id, payer_actor, payee_id , payee_actor, total_amout, amounts, creator_id, previous_id , dealer_id, status, reminder_status, compen_memo, gmt_create , gmt_modified, gmt_pay_date, pay_alipay_order_id, move_freeze_fee, main_order_id , out_id, attributes FROM compensate_bill_payer WHERE payer_id = 1 AND status IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND (compen_type LIKE "30" OR compen_type LIKE "30");
SELECT id, order_id, order_type, case_id, alipay_order_id , compen_type, payer_id, payee_id, total_amout, creator_id , dealer_id, compen_memo, gmt_create, gmt_modified, status , reminder_status, case_type, payer_actor, payee_actor, previous_id , gmt_pay_date, move_freeze_fee, attributes, out_id FROM compensate_bill_alive b WHERE dealer_id = 1 AND gmt_create >= "3" AND gmt_create <= "3" AND status = 1 ORDER BY gmt_create ASC LIMIT 1, 1;
SELECT seq_value FROM compensate_sequence WHERE name = "3";
SELECT value FROM capital_sequence WHERE name = "3";
SELECT r.reminder_user_id, r.reminder_user_nick, r.status AS remind_status, r.amount AS remind_amount, r.return_payment_date , r.retry_times, r.id AS remind_id, r.compen_id, r.alipay_order_id AS remind_alipay_order_id, r.reminder_memo , r.compen_type, r.gmt_create, r.gmt_modified, r.remind_pay_url FROM compensate_reminder r WHERE r.compen_id = 1;
SELECT id, code, parent_code, alias, name , type_level, gmt_create, gmt_modified FROM compensate_type WHERE code = "3";
SELECT COUNT(*) AS gross, SUM(b.total_amout) AS compensummenoy FROM compensate_bill_payee b WHERE b.payee_id = 1 AND b.order_id = "3" AND b.order_type = 1;
SELECT id, compen_id, dealer_id, deal_type, content , process_level, gmt_create, gmt_modified FROM compensate_process_log WHERE compen_id = 1 ORDER BY id DESC;
SELECT r.islocked FROM compensate_reminder r WHERE r.id = 1;
SELECT b.id, b.order_id, b.order_type, b.case_id, b.alipay_order_id , b.compen_type, b.payer_id, b.payee_id, b.total_amout, b.creator_id , b.dealer_id, b.compen_memo, b.gmt_create, b.gmt_modified, b.status , b.case_type, b.payer_actor, b.payee_actor, b.previous_id, b.gmt_pay_date , b.move_freeze_fee, r.reminder_user_id, r.reminder_user_nick, r.status AS remind_status, r.amount AS remind_amount , r.return_payment_date, r.retry_times, r.id AS remind_id, r.compen_id, r.alipay_order_id AS remind_alipay_order_id , r.reminder_memo, r.compen_type, r.gmt_create, r.gmt_modified, r.remind_pay_url FROM compensate_bill_alive b, compensate_reminder r WHERE b.id = r.compen_id AND b.case_id = 1 AND b.case_type = 1;
SELECT a.id, a.scheme_id, a.compen_fee, a.trade_id, a.alipay_trade_no , a.payee_user_id, a.payer_user_id, a.source_info_id, a.biz_source, a.is_backward , a.compen_status, a.compen_type, a.memo, a.gmt_create, a.creator_id , a.deal_id FROM crm_compensate_info a WHERE a.payee_user_id = 1 ORDER BY a.gmt_create LIMIT 1;
SELECT id, order_id, order_type, case_id, alipay_order_id , compen_type, payer_id, payee_id, total_amout, creator_id , dealer_id, compen_memo, gmt_create, gmt_modified, status , reminder_status, case_type, payer_actor, payee_actor, previous_id , gmt_pay_date, move_freeze_fee, attributes, out_id FROM compensate_bill_payee b WHERE payee_id = 1 AND order_id = "3" AND order_type = 1 LIMIT 1, 1;
SELECT id, order_id, order_type, case_id, case_type , alipay_order_id, compen_type, payer_id, payer_actor, payee_id , payee_actor, total_amout, amounts, creator_id, previous_id , dealer_id, status, reminder_status, compen_memo, gmt_create , gmt_modified, gmt_pay_date, pay_alipay_order_id, move_freeze_fee, main_order_id , out_id, attributes FROM compensate_bill_order WHERE order_id = "3" AND order_type = 1;
SELECT COUNT(*) AS gross, SUM(b.total_amout) AS compensummenoy FROM compensate_bill_payee b WHERE b.payee_id = 1 AND b.gmt_create >= "3" AND b.gmt_create <= "3" AND b.compen_type LIKE concat("30", "30");
SELECT id, order_id, order_type, case_id, case_type , alipay_order_id, compen_type, payer_id, payer_actor, payee_id , payee_actor, total_amout, amounts, creator_id, previous_id , dealer_id, status, reminder_status, compen_memo, gmt_create , gmt_modified, gmt_pay_date, pay_alipay_order_id, move_freeze_fee, main_order_id , out_id, attributes FROM compensate_bill_payer WHERE payer_id = 1 AND compen_type LIKE concat("30", "30");
SELECT COUNT(*) FROM compensate_bill_alive b WHERE b.status = 1 AND b.dealer_id = 1 AND b.gmt_create >= "3" AND b.gmt_create <= "3";
SELECT r.reminder_user_id, r.reminder_user_nick, r.status AS remind_status, r.amount AS remind_amount, r.return_payment_date , r.retry_times, r.id AS remind_id, r.compen_id, r.alipay_order_id AS remind_alipay_order_id, r.reminder_memo , r.compen_type, r.gmt_create, r.gmt_modified, r.remind_pay_url FROM compensate_reminder r, compensate_remind_cfg c WHERE r.compen_type LIKE concat(c.compen_type, "30") AND r.status = 1 AND c.env_type = "3" AND r.env_type = "3" AND c.status = 1 AND mod(r.id, 1) IN (1,2,4,6,7,8,11,56,68,89,435,4523) LIMIT 1, 1;
SELECT SUM(r.amount) FROM compensate_reminder r WHERE r.reminder_user_id = 1 AND r.status IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT id, punish_id, sub_order_id, main_order_id, refund_cash_to_buyer , refund_point_to_buyer, refund_commission_to_seller, refund_other_to_buyer, peifu_to_buyer, order_status , compen_funds_source, gmt_create, gmt_modify FROM crm_mall_apply WHERE main_order_id = 1;
SELECT COUNT(*) AS gross, SUM(b.total_amout) AS compensummenoy FROM compensate_bill_payee b WHERE b.payer_id = 1 AND b.payee_id = 1 AND b.compen_type = "3" AND b.order_id = "3";
SELECT COUNT(*) AS gross, SUM(b.total_amout) AS compensummenoy FROM compensate_bill_payee b WHERE b.payee_id = 1 AND b.order_id = "3" AND b.compen_type LIKE concat("30", "30") AND b.order_type = 1;
SELECT id, order_id, order_type, case_id, alipay_order_id , compen_type, payer_id, payee_id, total_amout, creator_id , dealer_id, compen_memo, gmt_create, gmt_modified, status , reminder_status, case_type, payer_actor, payee_actor, previous_id , gmt_pay_date, move_freeze_fee, attributes, out_id FROM compensate_bill_alive b WHERE dealer_id = 1 AND gmt_create >= "3" AND gmt_create <= "3" AND compen_type LIKE concat("30", "30") AND status = 1 ORDER BY gmt_create ASC LIMIT 1, 1;
SELECT COUNT(*) AS gross, SUM(b.total_amout) AS compensummenoy FROM compensate_bill_alive b WHERE b.dealer_id = 1 AND b.gmt_create >= "3" AND b.gmt_create <= "3" AND b.status = 1;
SELECT COUNT(*) AS gross, SUM(b.total_amout) AS compensummenoy FROM compensate_bill_payee b WHERE b.payee_id = 1 AND b.gmt_create >= "3" AND b.gmt_create <= "3";
SELECT id, order_id, order_type, case_id, alipay_order_id , compen_type, payer_id, payee_id, total_amout, creator_id , dealer_id, compen_memo, gmt_create, gmt_modified, status , reminder_status, case_type, payer_actor, payee_actor, previous_id , gmt_pay_date, move_freeze_fee, attributes, out_id FROM compensate_bill_payee b WHERE payer_id = 1 AND payee_id = 1 AND compen_type = "3" AND order_id = "3" LIMIT 1, 1;
SELECT id, order_id, order_type, case_id, alipay_order_id , compen_type, payer_id, payee_id, total_amout, creator_id , dealer_id, compen_memo, gmt_create, gmt_modified, status , reminder_status, case_type, payer_actor, payee_actor, previous_id , gmt_pay_date, move_freeze_fee, attributes, out_id FROM compensate_bill_payee b WHERE payee_id = 1 AND gmt_create >= "3" AND gmt_create <= "3" AND compen_type LIKE concat("30", "30") LIMIT 1, 1;
SELECT b.id, b.order_id, b.order_type, b.case_id, b.alipay_order_id , b.compen_type, b.payer_id, b.payee_id, b.total_amout, b.creator_id , b.dealer_id, b.compen_memo, b.gmt_create, b.gmt_modified, b.status , b.case_type, b.payer_actor, b.payee_actor, b.previous_id, b.gmt_pay_date , b.move_freeze_fee, r.reminder_user_id, r.reminder_user_nick, r.status AS remind_status, r.amount AS remind_amount , r.return_payment_date, r.retry_times, r.id AS remind_id, r.compen_id, r.alipay_order_id AS remind_alipay_order_id , r.reminder_memo, r.compen_type, r.gmt_create, r.gmt_modified, r.remind_pay_url FROM compensate_bill_alive b, compensate_reminder r WHERE b.id = r.compen_id AND r.compen_type LIKE concat("30", "30") AND r.reminder_user_id = 1;
SELECT id, order_id, order_type, case_id, case_type , alipay_order_id, compen_type, payer_id, payer_actor, payee_id , payee_actor, total_amout, amounts, creator_id, previous_id , dealer_id, status, reminder_status, compen_memo, gmt_create , gmt_modified, gmt_pay_date, pay_alipay_order_id, move_freeze_fee, main_order_id , out_id, attributes FROM compensate_bill_order WHERE case_id = 1 AND case_type = 1 AND order_id = "3" AND order_type = 1;
SELECT id, order_id, order_type, case_id, alipay_order_id , compen_type, payer_id, payee_id, total_amout, creator_id , dealer_id, compen_memo, gmt_create, gmt_modified, status , reminder_status, case_type, payer_actor, payee_actor, previous_id , gmt_pay_date, move_freeze_fee, attributes, out_id FROM compensate_bill_payee b WHERE payee_id = 1 AND compen_type = "3" AND gmt_create >= "3" AND gmt_create <= "3" ORDER BY gmt_create LIMIT 1, 1;
SELECT id, order_id, order_type, case_id, case_type , alipay_order_id, compen_type, payer_id, payer_actor, payee_id , payee_actor, total_amout, amounts, creator_id, previous_id , dealer_id, status, reminder_status, compen_memo, gmt_create , gmt_modified, gmt_pay_date, pay_alipay_order_id, move_freeze_fee, main_order_id , out_id, attributes FROM compensate_bill_payee WHERE payee_id = 1 AND out_id = "3";
SELECT id, order_id, order_type, case_id, case_type , alipay_order_id, compen_type, payer_id, payer_actor, payee_id , payee_actor, total_amout, amounts, creator_id, previous_id , dealer_id, status, reminder_status, compen_memo, gmt_create , gmt_modified, gmt_pay_date, pay_alipay_order_id, move_freeze_fee, main_order_id , out_id, attributes FROM compensate_bill_payee WHERE payee_id = 1 AND order_type = 1 AND main_order_id = "3";
SELECT COUNT(*) AS gross, SUM(b.total_amout) AS compensummenoy FROM compensate_bill_payee b WHERE b.payee_id = 1 AND b.compen_type = "3" AND b.gmt_create >= "3" AND b.gmt_create <= "3";
SELECT id, order_id, order_type, case_id, alipay_order_id , compen_type, payer_id, payee_id, total_amout, creator_id , dealer_id, compen_memo, gmt_create, gmt_modified, status , reminder_status, case_type, payer_actor, payee_actor, previous_id , gmt_pay_date, move_freeze_fee, attributes, out_id FROM compensate_bill_payee b WHERE payee_id = 1 AND gmt_create >= "3" AND gmt_create <= "3" ORDER BY gmt_create ASC LIMIT 1, 1;
SELECT COUNT(*) AS gross, SUM(b.total_amout) AS compensummenoy FROM compensate_bill_alive b WHERE b.dealer_id = 1 AND b.gmt_create >= "3" AND b.gmt_create <= "3" AND b.compen_type LIKE concat("30", "30") AND b.status = 1;
SELECT r.reminder_user_id, r.reminder_user_nick, r.status AS remind_status, r.amount AS remind_amount, r.return_payment_date , r.retry_times, r.id AS remind_id, r.compen_id, r.alipay_order_id AS remind_alipay_order_id, r.reminder_memo , r.compen_type, r.gmt_create, r.gmt_modified, r.remind_pay_url FROM compensate_reminder r, compensate_remind_cfg c WHERE r.compen_type LIKE concat(c.compen_type, "30") AND r.status = 1 AND c.env_type = "3" AND r.env_type = "3" AND c.status = 1 AND mod(r.id, 1) IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND r.gmt_modified <= date_add(now(), INTERVAL -c.interval_days DAY) LIMIT 1, 1;
