--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt 
#owner group:sql1 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists sns_base_info (
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户数字id', 
	`key_id` smallint(6) NOT NULL, 
	`value` varchar(300) NOT NULL COMMENT '值', 
	`open_status` tinyint(4) NOT NULL COMMENT '是否公布资料', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`char_1` varchar(256) NULL COMMENT '保留字段', 
	`number_1` bigint(20) NULL COMMENT '保留字段', 
	PRIMARY KEY (`user_id`, `key_id`), 
	KEY `IDX_baseinfo_modified` (`gmt_modified`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_micro_shop (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`user_id` bigint(20) NOT NULL COMMENT '微店店主的id', 
	`shop_type` tinyint(4) NOT NULL COMMENT '微店的类型1|商城,2|集市,3|品牌机构,4|线下店铺', 
	`shop_name` varchar(128) NOT NULL COMMENT '微店的店铺名称', 
	`logo_picurl` varchar(500) NULL COMMENT '微店的店标logo', 
	`shop_id` bigint(20) NULL COMMENT '线上店铺的shopid', 
	`status` tinyint(4) NOT NULL COMMENT '1|关闭 0|正常', 
	`char_1` varchar(256) NULL, 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`number_1` int(11) NULL, 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_sms_uid` (`user_id`), 
	KEY `idx_sms_stype` (`shop_type`), 
	KEY `idx_sms_sname` (`shop_name`, `shop_id`)
)  AUTO_INCREMENT = 23346011 CHARSET = utf8 COMMENT = '微店基本信息表';
CREATE TABLE if not exists sns_micro_shop_profile (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`user_id` bigint(20) NOT NULL COMMENT '微店店主的id', 
	`add_province` varchar(20) NULL COMMENT '微店所在地 (省代码)', 
	`add_city` varchar(20) NULL COMMENT '微店所在地 (市代码)', 
	`add_area` varchar(20) NULL COMMENT '微店所在地 (区代码)', 
	`add_other` varchar(128) NULL COMMENT '微店所在地 (街道门牌号等)', 
	`business_scope` varchar(128) NOT NULL COMMENT '店铺的主营范围', 
	`tag` varchar(128) NULL COMMENT '店铺标签', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`service_phone` varchar(128) NULL COMMENT '微店的服务电话', 
	`description` varchar(512) NULL COMMENT '店铺介绍', 
	`char_1` varchar(256) NULL, 
	`char_2` varchar(256) NULL, 
	`number_1` int(11) NULL, 
	`number_2` int(11) NULL, 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_smsp_uid` (`user_id`)
)  AUTO_INCREMENT = 22974011 CHARSET = utf8 COMMENT = '微店的扩展信息表';
CREATE TABLE if not exists sns_micro_shop_user (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`shop_id` bigint(20) NOT NULL COMMENT '店铺id，分表键', 
	`user_id` bigint(20) NOT NULL COMMENT '店铺对应的卖家id', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	PRIMARY KEY (`id`), 
	KEY `idx_smsu_sid` (`shop_id`, `user_id`)
)  AUTO_INCREMENT = 22996012 CHARSET = utf8 COMMENT = '根据店铺id反查用户id表表';
CREATE TABLE if not exists sns_outer_account_auth (
	`id` bigint(20) UNSIGNED NOT NULL, 
	`user_id` bigint(20) NOT NULL COMMENT '用户ID', 
	`partner_id` int(11) NOT NULL COMMENT '合作伙伴ID', 
	`auth_token` varchar(256) NULL COMMENT 'auth token', 
	`access_token` varchar(256) NULL COMMENT 'access token', 
	`auth_secret` varchar(256) NULL COMMENT 'auth secret', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`status` tinyint(4) DEFAULT '0' NOT NULL, 
	`outer_id` varchar(128) NULL COMMENT '站外关系绑定的唯一字段', 
	`login_name` varchar(128) NULL COMMENT '站外用户的nick，跟sns_outer_relation表里的login_name对应', 
	`real_name` varchar(32) NULL COMMENT '增加站外用户真实姓名', 
	`invalid_time` datetime NULL COMMENT 'accessToken失效时间', 
	`display_face` varchar(512) NULL COMMENT '头像地址', 
	`remark` varchar(512) NULL COMMENT '描述', 
	`birthday` varchar(32) NULL COMMENT '生日，存储格式yyyy-MM-dd', 
	`location` varchar(128) NULL COMMENT '所在地', 
	`gender` char(1) NULL COMMENT '性别', 
	`tags` varchar(512) NULL COMMENT '用户身上的标签', 
	`profile_info` varchar(2048) NULL COMMENT '其他一些profile信息', 
	PRIMARY KEY (`id`), 
	KEY `idx_accauth_userid` (`user_id`, `partner_id`)
)  CHARSET = utf8 COMMENT = '站外关系绑定';
CREATE TABLE if not exists sns_outer_account_extend (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`outer_id` varchar(128) NOT NULL COMMENT '分表字段,用户的外站的id', 
	`partner_id` int(11) NOT NULL COMMENT '外站的编号,比如新浪是4', 
	`login_name` varchar(128) NULL COMMENT '登陆名,在外站上是唯一的', 
	`display_face` varchar(512) NULL COMMENT '用户在外站上的头像地址,取的是原图', 
	`remark` varchar(512) NULL COMMENT '用户自己的说明,备注', 
	`birthday` varchar(32) NULL COMMENT '生日,会尽量保证yyyy-MM-dd的格式', 
	`location` varchar(128) NULL COMMENT '地址,各个站点的略有不同,新浪的格式如北京 朝阳区', 
	`gender` char(1) NULL COMMENT '性别', 
	`profile_info` varchar(4096) NULL COMMENT '一些额外的信息', 
	`is_delete` bigint(20) UNSIGNED NULL COMMENT '是否被删除', 
	`real_name` varchar(32) NULL COMMENT '真实姓名,可能会有重名', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_oid_pid` (`outer_id`, `partner_id`)
)  AUTO_INCREMENT = 9273802 CHARSET = utf8 COMMENT = '用来记录从外站来的用户信息,可做分析或者其他用途,profile_info里面会保留外站的几乎全部原始信息. 256张表';
CREATE TABLE if not exists sns_outer_account_reverse (
	`id` bigint(20) NOT NULL, 
	`outer_id_hash` bigint(20) NOT NULL COMMENT '分库分表字段', 
	`outer_id` varchar(128) NOT NULL, 
	`partner_id` int(11) NOT NULL COMMENT '合作伙伴ID 0：淘宝 2：开心网 3：人人网 4：新浪微博 5：搜狐 6：腾讯微博 7：QZONE', 
	`user_id` bigint(20) NOT NULL, 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	`status` tinyint(4) NOT NULL COMMENT '1：用户解绑 0：正常', 
	PRIMARY KEY (`id`), 
	KEY `pk_sns_outer_account_unit` (`outer_id`, `partner_id`), 
	KEY `pk_sns_outer_account_gmt` (`gmt_modified`), 
	KEY `index_gmt_create` (`gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_personal_info (
	`user_id` bigint(20) UNSIGNED NOT NULL, 
	`key_id` tinyint(3) NOT NULL, 
	`value` varchar(300) NOT NULL, 
	`open_status` tinyint(4) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`char_1` varchar(256) NULL, 
	`number_1` bigint(20) NULL, 
	PRIMARY KEY (`user_id`, `key_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_privacy_setting (
	`user_id` bigint(20) UNSIGNED NOT NULL, 
	`apply_setting` tinyint(4) NOT NULL, 
	`blog_setting` tinyint(4) NOT NULL, 
	`photo_setting` tinyint(4) NOT NULL, 
	`favorite_setting` tinyint(4) NOT NULL, 
	`comment_setting` tinyint(4) NOT NULL, 
	`transaction_setting` tinyint(4) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`key1_setting` tinyint(4) NULL, 
	`key2_setting` tinyint(4) NULL, 
	`key3_setting` tinyint(4) NULL, 
	`char_1` varchar(256) NULL, 
	`number_1` bigint(20) NULL, 
	PRIMARY KEY (`user_id`), 
	KEY `IDX_user_setting_modified` (`gmt_modified`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_profiler (
	`user_id` bigint(20) UNSIGNED NOT NULL, 
	`key_id` tinyint(4) NOT NULL, 
	`value` varchar(300) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`char_1` varchar(256) NULL, 
	`number_1` bigint(20) NULL, 
	PRIMARY KEY (`user_id`, `key_id`), 
	KEY `idx_profiler_gmtmodified` (`gmt_modified`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_star (
	`id` bigint(20) NOT NULL, 
	`user_id` bigint(20) NOT NULL, 
	`nick` varchar(32) NOT NULL, 
	`star_types` varchar(256) NOT NULL, 
	`star_desc` varchar(512) NULL, 
	`domain_name` varchar(256) NULL, 
	`template_id` bigint(20) NOT NULL, 
	`status` tinyint(4) NOT NULL, 
	`reason` varchar(256) NULL, 
	`is_domain_check` tinyint(4) NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`is_deleted` char(1) NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_star_userid` (`user_id`), 
	KEY `idx_star_status` (`status`, `is_deleted`, `gmt_create`), 
	KEY `idx_star_idcheck` (`is_domain_check`), 
	KEY `idx_star_dname` (`domain_name`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_star_feature_value (
	`id` bigint(20) NOT NULL, 
	`star_id` bigint(20) NOT NULL, 
	`star_feature_field_id` bigint(20) NOT NULL, 
	`field_value` varchar(200) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`is_deleted` char(1) NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_sfvalue_starid` (`star_id`, `star_feature_field_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_user_personalize_info (
	`user_id` bigint(20) NOT NULL, 
	`intrest` varchar(300) NULL, 
	`brands` varchar(300) NULL, 
	`films` varchar(300) NULL, 
	`musics` varchar(300) NULL, 
	`books` varchar(300) NULL, 
	`sports` varchar(300) NULL, 
	`games` varchar(300) NULL, 
	`catoon` varchar(300) NULL, 
	`favoritestar` varchar(300) NULL, 
	`favoritesongs` varchar(300) NULL, 
	`favoritefood` varchar(300) NULL, 
	`recentlywant` varchar(300) NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`user_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_user_profile_privacy (
	`user_id` bigint(20) NOT NULL, 
	`field` int(11) NOT NULL, 
	`visibility` tinyint(4) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`user_id`, `field`), 
	KEY `idx_supp_gmodified` (`gmt_modified`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_user_property (
	`user_id` bigint(20) NOT NULL, 
	`home_prov` varchar(20) NULL, 
	`home_city` varchar(20) NULL, 
	`home_area` varchar(20) NULL, 
	`weight` varchar(20) NULL, 
	`height` varchar(20) NULL, 
	`blood` varchar(20) NULL, 
	`skin` varchar(20) NULL, 
	`hair` varchar(20) NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`user_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_user_uniquename (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`namehash` bigint(20) NOT NULL COMMENT '分表字段,用户名字的hash值', 
	`unique_name` varchar(32) NOT NULL COMMENT '用户的唯一姓名', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户id', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `idx_namehash_uniquename` (`namehash`, `unique_name`)
)  AUTO_INCREMENT = 1247433 CHARSET = utf8 COMMENT = '用户记录用户的唯一昵称';
CREATE TABLE if not exists sns_users (
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户数字id', 
	`nick` varchar(32) NOT NULL COMMENT '用户nick', 
	`real_name` varchar(256) NULL COMMENT '真是姓名', 
	`pic_url` varchar(500) NULL COMMENT '图片url', 
	`heart_desc` varchar(512) NULL COMMENT '一句话心情', 
	`space_title` varchar(118) NULL COMMENT '空间标题', 
	`space_pic` varchar(500) NULL COMMENT '空间图片', 
	`finished_Status` tinyint(6) NULL COMMENT '资料完成度', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`char_1` varchar(256) NULL COMMENT '保留字段', 
	`number_1` bigint(20) NULL, 
	`space_title_style` varchar(1024) NULL, 
	`space_pic_style` tinyint(4) NULL, 
	`status` tinyint(4) NULL, 
	`gmt_head_opt` datetime NULL, 
	`head_status` char(1) NULL, 
	`birthday` datetime NULL, 
	`gender` char(1) NULL, 
	`prov` varchar(20) NULL, 
	`city` varchar(20) NULL, 
	`area` varchar(20) NULL, 
	`level` int(11) NULL, 
	`type` varchar(1024) NULL, 
	`unique_name` varchar(32) NULL COMMENT '用户的唯一昵称', 
	PRIMARY KEY (`user_id`), 
	KEY `IDX_user_users_modified` (`gmt_modified`), 
	KEY `IDX_user_headstatus` (`head_status`, `pic_url`), 
	KEY `IDX_user_level` (`level`)
)  CHARSET = utf8 COMMENT = '用户的个人信息表';
CREATE TABLE if not exists sns_users_education (
	`user_id` bigint(20) UNSIGNED NOT NULL, 
	`school_id` int(11) NOT NULL, 
	`enter_day` datetime NULL, 
	`career` tinyint(4) NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`char_1` varchar(256) NULL, 
	`number_1` bigint(20) NULL, 
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`school_department` varchar(64) NULL, 
	`school_class` varchar(64) NULL, 
	PRIMARY KEY (`id`), 
	KEY `user_id` (`user_id`, `school_id`, `enter_day`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_users_job (
	`id` bigint(20) NOT NULL, 
	`USER_ID` bigint(20) NOT NULL, 
	`COMPANY_NAME` varchar(128) NOT NULL, 
	`COMPANY_DESC` varchar(1024) NULL, 
	`BUSINESS_1` varchar(64) NULL, 
	`BUSINESS_2` varchar(64) NULL, 
	`POSITION_1` varchar(64) NULL, 
	`POSITION_2` varchar(64) NULL, 
	`GMT_START` datetime NULL, 
	`GMT_END` datetime NULL, 
	`gmt_create` datetime NOT NULL, 
	`GMT_MODIFIED` datetime NOT NULL, 
	`number_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	`date_1` datetime NULL, 
	PRIMARY KEY (`id`), 
	KEY `USER_ID` (`USER_ID`, `GMT_START`)
)  CHARSET = utf8;
CREATE TABLE if not exists user_authority_set (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`user_id` bigint(20) NOT NULL COMMENT '用户id', 
	`authority_key` varchar(256) NOT NULL COMMENT '权限设置key', 
	`authority_value` varchar(256) NULL COMMENT '权限设置的值', 
	`is_deleted` char(1) NOT NULL COMMENT '是否已删除', 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录修改时间', 
	`char_1` varchar(256) NULL, 
	`num_1` bigint(20) NULL, 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_uas_uid` (`user_id`, `authority_key`)
)  AUTO_INCREMENT = 5872980 CHARSET = utf8;
CREATE TABLE if not exists user_privacy (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`user_id` bigint(20) NOT NULL, 
	`field` int(11) NOT NULL, 
	`visible_value` varchar(256) NOT NULL, 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	PRIMARY KEY (`id`), 
	KEY `idx_user_id_field` (`user_id`, `field`)
)  AUTO_INCREMENT = 104688 CHARSET = utf8 COMMENT = '用户隐私表，表512张表';
CREATE TABLE if not exists weibo_unconfirmed_bind (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段,淘宝的用户id', 
	`weibo_uid` varchar(32) NOT NULL COMMENT '新浪微博的用户id', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_uid_wid` (`user_id`, `weibo_uid`)
)  AUTO_INCREMENT = 8714057 CHARSET = utf8 COMMENT = '记录了暗绑定的数据';

SELECT id, user_id, company_name, company_desc, business_1 , business_2, position_1, position_2, gmt_start, gmt_end FROM sns_users_job WHERE user_id = 1 ORDER BY gmt_start DESC, id ASC;
SELECT user_id, key_id, value, gmt_modified, gmt_create FROM sns_profiler WHERE user_id = 1 AND key_id = 1;
SELECT user_id, field, visible_value, gmt_create, gmt_modified FROM user_privacy WHERE user_id = 1 AND field = 1;
SELECT COUNT(1) FROM sns_micro_shop WHERE shop_name = "3" AND shop_id = 1;
SELECT user_id, unique_name, namehash FROM sns_user_uniquename WHERE namehash = 1 AND unique_name = "3";
SELECT user_id, home_prov, home_city, home_area, weight , height, blood, skin, hair FROM sns_user_property WHERE user_id = 1 LIMIT 1;
SELECT user_id, field, visibility FROM sns_user_profile_privacy WHERE user_id = 1 AND field = 1 LIMIT 1;
SELECT user_id, intrest, brands, films, musics , books, sports, games, catoon, favoritestar , favoritefood, favoritesongs, recentlywant FROM sns_user_personalize_info WHERE user_id = 1 LIMIT 1;
SELECT user_id, space_title, space_pic, space_title_style, space_pic_style FROM sns_users WHERE user_id = 1;
SELECT id, user_id, nick, star_types, star_desc , domain_name, template_id, status, reason, is_domain_check , gmt_modified, gmt_create, is_deleted FROM sns_star WHERE user_id = 1 AND is_deleted = "3" ORDER BY gmt_modified DESC LIMIT 1, 1;
SELECT user_id, nick, real_name, unique_name, pic_url , heart_desc, birthday, gender, prov, city , area, level, type, status, head_status , gmt_head_opt FROM sns_users WHERE user_id = 1;
SELECT id, user_id, partner_id, outer_id, outer_id_hash , status, gmt_create, gmt_modified FROM sns_outer_account_reverse WHERE outer_id = "3" AND partner_id = 1 AND outer_id_hash = 1 LIMIT 1;
SELECT id, user_id, partner_id, outer_id, login_name , real_name, auth_token, access_token, auth_secret, status , gmt_create, gmt_modified, invalid_time, display_face, remark , birthday, location, gender, tags, profile_info FROM sns_outer_account_auth WHERE user_id = 1 AND partner_id = 1;
SELECT user_id AS uid FROM weibo_unconfirmed_bind WHERE user_id = 1 AND weibo_uid = "3";
SELECT id, user_id, school_id, career, school_department , school_class, enter_day FROM sns_users_education WHERE user_id = 1 ORDER BY enter_day DESC;
SELECT id, user_id, shop_type, shop_name, logo_picurl , shop_id, status, gmt_create, gmt_modified FROM sns_micro_shop WHERE user_id = 1 LIMIT 1;
SELECT login_name, real_name, is_delete, display_face, remark , birthday, location, gender, profile_info, gmt_modified FROM sns_outer_account_extend WHERE outer_id = "3" AND partner_id = 1;
SELECT user_id, apply_setting, blog_setting, photo_setting, favorite_setting , comment_setting, transaction_setting, key1_setting, key2_setting, key3_setting , number_1 FROM sns_privacy_setting WHERE user_id = 1;
SELECT id, user_id, add_province, add_city, add_area , add_other, business_scope, tag, gmt_create, gmt_modified , service_phone, description FROM sns_micro_shop_profile WHERE user_id = 1;

