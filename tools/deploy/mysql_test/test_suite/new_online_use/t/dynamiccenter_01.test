SELECT seller_id AS sellerid, item_id AS itemid, new_time AS newtime, start_time AS starttime, price , pic, title, category_id AS categoryid, item_type AS itemtype, state , deleted, first_start_time AS firststarttime, gmt_create AS gmtcreate, gmt_modify AS gmtmodify FROM uac_new_arrival_item WHERE seller_id = 1 AND first_start_time > "2015-09-29 12:00:00" AND (first_start_time < "2015-09-29 12:00:00" OR first_start_time = "2015-09-29 12:00:00" AND item_id > 1) AND start_time = first_start_time AND deleted = 1 ORDER BY first_start_time DESC, item_id ASC LIMIT 1;
