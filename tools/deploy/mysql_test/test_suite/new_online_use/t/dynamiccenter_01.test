#tags new_online_use 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists uac_dynamic_shop_infor (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '卖家编号', 
	`shop_id` bigint(20) UNSIGNED NOT NULL COMMENT '店铺编号', 
	`shop_type` int(11) NULL COMMENT '店铺类型', 
	`state` int(11) NULL COMMENT '状态', 
	`promotion_start_time` datetime NULL COMMENT '优惠开始时间', 
	`promotion_end_time` datetime NULL COMMENT '优惠结束时间', 
	`today_new_count` int(11) DEFAULT '0' NOT NULL COMMENT '当天的上新', 
	`seven_ago_new_count` int(11) DEFAULT '0' NOT NULL COMMENT '7天的上新', 
	`fifteen_ago_new_count` int(11) DEFAULT '0' NOT NULL COMMENT '15天的上新', 
	`thirty_ago_new_count` int(11) DEFAULT '0' NOT NULL COMMENT '30天的上新', 
	`promotion_count` int(11) DEFAULT '0' NOT NULL COMMENT '优惠的计数', 
	`pre_new_count` int(11) DEFAULT '0' NOT NULL COMMENT '预上新的计数', 
	`pre_new_time` datetime NULL COMMENT '预上新的时间', 
	`features` varchar(1024) NULL COMMENT '备注', 
	`new_time` datetime NULL COMMENT '上新时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `seller_id` (`seller_id`)
)  AUTO_INCREMENT = 196206 CHARSET = utf8 COMMENT = '卖家信息表，用于记录卖家的count数和上新时间等';
CREATE TABLE if not exists uac_new_arrival_item (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`seller_id` bigint(20) UNSIGNED NULL COMMENT '卖家id', 
	`item_id` bigint(20) UNSIGNED NULL COMMENT 'itemId', 
	`start_time` datetime NULL COMMENT '商品首次上架时间，预上架的不算。没有上架之前该时间可以更改，一旦上架，不再改变', 
	`new_time` datetime NULL COMMENT '上架或发布时间', 
	`price` bigint(20) NULL COMMENT '发布价格', 
	`pic` varchar(254) NULL COMMENT '发布时主图', 
	`title` varchar(254) NULL COMMENT '发布时title', 
	`category_id` bigint(20) UNSIGNED NULL COMMENT '发布时淘宝类目', 
	`state` smallint(6) NULL COMMENT '状态， 可已为null,', 
	`item_type` int(11) DEFAULT '1' COMMENT 'item类型，b,c商品', 
	`deleted` int(11) DEFAULT '0' COMMENT '是否逻辑删除', 
	`gmt_create` datetime NULL COMMENT '创建时间', 
	`gmt_modify` datetime NULL COMMENT '最后修改时间', 
	`first_start_time` datetime NULL COMMENT '商品首次上架时间，预上架的不算。没有上架之前该时间可以更改，一旦上架，不再改变', 
	PRIMARY KEY (`id`), 
	KEY `idx_seller_id_new_time_start_time` (`seller_id`, `new_time`, `start_time`), 
	KEY `idx_seller_id_item_id` (`seller_id`, `item_id`), 
	KEY `idx_seller_id_category_id_new_time` (`seller_id`, `category_id`, `new_time`), 
	KEY `idx_seller_id_first_start_time` (`seller_id`, `deleted`, `first_start_time`), 
	KEY `idx_seller_id_category_id_first_start_time` (`seller_id`, `deleted`, `category_id`, `first_start_time`), 
	KEY `idx_seller_id_start_time_item_id` (`seller_id`, `start_time`, `item_id`)
)  AUTO_INCREMENT = 4596001 CHARSET = utf8 COMMENT = '上新优惠详情表';
CREATE TABLE if not exists uac_promotion_item (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`seller_id` bigint(20) NOT NULL COMMENT '卖家seller_id,分表字段', 
	`item_id` bigint(20) NOT NULL COMMENT '商品id', 
	`activity_id` bigint(20) NOT NULL COMMENT '优惠活动id', 
	`purchase_price` bigint(20) NULL COMMENT '优惠后的价格，精确到分', 
	`discount` int(11) NULL COMMENT '折扣率，精确到分，如8折为800', 
	`decrease_price` bigint(20) NULL COMMENT '减钱，精确到分', 
	`promotion_name` varchar(1024) NOT NULL COMMENT '优惠名称', 
	`start_time` datetime NOT NULL COMMENT '优惠开始时间，建立索引', 
	`end_time` datetime NOT NULL COMMENT '优惠结束时间，建立索引', 
	`shop_id` bigint(20) DEFAULT '0' COMMENT '店铺id', 
	`feature` varchar(1024) NULL COMMENT '额外的一些特性（json格式）', 
	`promotion_id` bigint(20) NULL COMMENT '自定义优惠id（兼容宝贝动态）', 
	`ex_1` bigint(20) NULL COMMENT '预留的扩展字段', 
	PRIMARY KEY (`id`), 
	UNIQUE `idx_uq_item_promotion_activity` (`item_id`, `promotion_id`, `activity_id`), 
	KEY `end_time` (`end_time`), 
	KEY `start_time` (`start_time`), 
	KEY `idx_seller_id_activity` (`seller_id`, `activity_id`)
)  AUTO_INCREMENT = 30658146 CHARSET = utf8 COMMENT = '优惠总表按seller_id进行分表';
CREATE TABLE if not exists uac_seller_category_count (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`category_id` int(11) DEFAULT '0' NOT NULL COMMENT '类目id', 
	`count` int(11) DEFAULT '0' NOT NULL COMMENT '计数', 
	`days` int(11) NOT NULL COMMENT '天数，目前支持一周和一个月的店铺上新类目统计', 
	`count_type` tinyint(4) NOT NULL COMMENT '1=上新，2=促销', 
	PRIMARY KEY (`id`), 
	UNIQUE `seller_type_days_cate_uidx` (`seller_id`, `count_type`, `days`, `category_id`)
)  AUTO_INCREMENT = 298901 CHARSET = utf8 COMMENT = 'uac 店铺类目上新数统计表';
CREATE TABLE if not exists uac_shop_item_promotion (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`seller_id` bigint(20) NOT NULL COMMENT '卖家id主键,分表字段', 
	`promotion_id` bigint(20) NOT NULL COMMENT '自定义优惠id（兼容宝贝动态）', 
	`start_time` datetime NOT NULL COMMENT '优惠开始时间，建立索引', 
	`end_time` datetime NOT NULL COMMENT '优惠结束时间，建立索引', 
	`item_id` bigint(20) NOT NULL COMMENT '宝贝id', 
	`activity_id` bigint(20) NOT NULL COMMENT '优惠活动id', 
	`promotion_price` bigint(20) NULL COMMENT '优惠价格', 
	PRIMARY KEY (`id`), 
	UNIQUE `idx_uq_item` (`item_id`), 
	KEY `item_id` (`item_id`), 
	KEY `idx_deller_id_end_time` (`seller_id`, `end_time`), 
	KEY `idx_deller_id_start_time` (`seller_id`, `start_time`), 
	KEY `idx_seller_item_start` (`seller_id`, `start_time`, `item_id`)
)  AUTO_INCREMENT = 45555540 CHARSET = utf8 COMMENT = '店铺索引表';

SELECT id, seller_id, item_id, activity_id, purchase_price , discount, decrease_price, promotion_name, shop_id, feature , promotion_id, start_time, end_time, gmt_create, gmt_modified , ex_1 FROM uac_promotion_item WHERE seller_id = 1 AND activity_id = 1 AND id > 1 ORDER BY id LIMIT 1;
SELECT COUNT(1) FROM uac_dynamic_shop_infor;
SELECT uac_shop_item_promotion.end_time FROM uac_shop_item_promotion uac_shop_item_promotion WHERE uac_shop_item_promotion.seller_id = 1 ORDER BY uac_shop_item_promotion.end_time ASC LIMIT 1, 1;
SELECT uac_shop_item_promotion.start_time FROM uac_shop_item_promotion uac_shop_item_promotion WHERE uac_shop_item_promotion.seller_id = 1 ORDER BY uac_shop_item_promotion.start_time DESC LIMIT 1, 1;
SELECT seller_id AS sellerid, item_id AS itemid, new_time AS newtime, start_time AS starttime, price , pic, title, category_id AS categoryid, item_type AS itemtype, state , deleted, first_start_time AS firststarttime, gmt_create AS gmtcreate, gmt_modify AS gmtmodify FROM uac_new_arrival_item WHERE seller_id = 1 AND start_time < "2015-09-29 12:00:00" AND first_start_time > "2015-09-29 12:00:00" AND (first_start_time < "2015-09-29 12:00:00" OR first_start_time = "2015-09-29 12:00:00" AND item_id > 1) AND deleted = 1 ORDER BY first_start_time DESC, item_id ASC LIMIT 1;
SELECT seller_id, item_id, activity_id, purchase_price, discount , decrease_price, promotion_name, shop_id, feature, promotion_id , start_time, end_time, gmt_create, gmt_modified, ex_1 FROM uac_promotion_item WHERE seller_id = 1 AND activity_id = 1;
SELECT end_time FROM uac_shop_item_promotion WHERE seller_id = 1 ORDER BY end_time LIMIT 1;
SELECT seller_id AS sellerid, item_id AS itemid, new_time AS newtime, start_time AS starttime, price , pic, title, category_id AS categoryid, item_type AS itemtype, state , deleted, first_start_time AS firststarttime, gmt_create AS gmtcreate, gmt_modify AS gmtmodify FROM uac_new_arrival_item WHERE seller_id = 1 AND deleted = 1 AND start_time > "2015-09-29 12:00:00" AND start_time < "2015-09-29 12:00:00" ORDER BY start_time ASC LIMIT 1, 1;
SELECT start_time FROM uac_shop_item_promotion WHERE seller_id = 1 ORDER BY start_time DESC LIMIT 1;
SELECT COUNT(1) FROM uac_shop_item_promotion WHERE seller_id = 1 AND end_time > now();
SELECT seller_id AS sellerid, item_id AS itemid, new_time AS newtime, start_time AS starttime, price , pic, title, category_id AS categoryid, item_type AS itemtype, state , deleted, first_start_time AS firststarttime, gmt_create AS gmtcreate, gmt_modify AS gmtmodify FROM uac_new_arrival_item WHERE seller_id = 1 AND start_time <= now() AND first_start_time > "2015-09-29 12:00:00" AND first_start_time < "2015-09-29 12:00:00" AND deleted = 1 ORDER BY first_start_time DESC LIMIT 1, 1;
SELECT seller_id, item_id, activity_id, purchase_price, discount , decrease_price, promotion_name, shop_id, feature, promotion_id , start_time, end_time, gmt_create, gmt_modified, ex_1 FROM uac_promotion_item WHERE seller_id = 1 AND item_id = 1;
SELECT seller_id AS sellerid, item_id AS itemid, new_time AS newtime, start_time AS starttime, price , pic, title, category_id AS categoryid, item_type AS itemtype, state , deleted, first_start_time AS firststarttime, gmt_create AS gmtcreate, gmt_modify AS gmtmodify FROM uac_new_arrival_item WHERE seller_id = 1 AND first_start_time > "2015-09-29 12:00:00" AND (first_start_time < "2015-09-29 12:00:00" OR first_start_time = "2015-09-29 12:00:00" AND item_id > 1) AND deleted = 1 ORDER BY first_start_time DESC, item_id ASC LIMIT 1;
