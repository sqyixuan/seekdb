SELECT uac_new_arrival_item.seller_id AS sellerid, uac_new_arrival_item.item_id AS itemid, uac_new_arrival_item.new_time AS newtime, uac_new_arrival_item.start_time AS starttime, uac_new_arrival_item.price , uac_new_arrival_item.pic, uac_new_arrival_item.title, uac_new_arrival_item.category_id AS categoryid, uac_new_arrival_item.item_type AS itemtype, uac_new_arrival_item.state , uac_new_arrival_item.deleted, uac_new_arrival_item.first_start_time AS firststarttime, uac_new_arrival_item.gmt_create AS gmtcreate, uac_new_arrival_item.gmt_modify AS gmtmodify FROM uac_new_arrival_item uac_new_arrival_item WHERE uac_new_arrival_item.seller_id = 1 AND uac_new_arrival_item.deleted = 1 AND uac_new_arrival_item.first_start_time > "2015-09-29 12:00:00" AND uac_new_arrival_item.first_start_time < "2015-09-29 12:00:00" AND uac_new_arrival_item.start_time <= now() LIMIT 1, 1;
