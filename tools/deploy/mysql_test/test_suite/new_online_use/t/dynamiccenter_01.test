SELECT id, seller_id AS sellerid, shop_id AS shopid, shop_type AS shoptype, state , promotion_start_time AS promotionstarttime, promotion_end_time AS promotionendtime, new_time AS newtime, pre_new_time AS prenewtime, today_new_count AS todaynewcount , seven_ago_new_count AS sevenagonewcount, fifteen_ago_new_count AS fifteenagonewcount, thirty_ago_new_count AS thirtyagonewcount, promotion_count AS promotioncount, pre_new_count AS prenewcount , features, gmt_create AS gmtcreate, gmt_modified AS gmtmodify FROM uac_dynamic_shop_infor WHERE id > 1 ORDER BY id ASC LIMIT 1;
SELECT seller_id, item_id, activity_id, purchase_price, discount , decrease_price, promotion_name, shop_id, feature, promotion_id , start_time, end_time, gmt_create, gmt_modified, ex_1 FROM uac_promotion_item WHERE start_time > "2015-09-29 12:00:00" AND start_time <= "2015-09-29 12:00:00" OR end_time > "2015-09-29 12:00:00" AND end_time <= "2015-09-29 12:00:00" LIMIT 1, 1;
SELECT seller_id AS sellerid, item_id AS itemid, new_time AS newtime, start_time AS starttime, price , pic, title, category_id AS categoryid, item_type AS itemtype, state , deleted, first_start_time AS firststarttime, gmt_create AS gmtcreate, gmt_modify AS gmtmodify FROM uac_new_arrival_item WHERE seller_id = 1 AND start_time <= now() AND first_start_time > "2015-09-29 12:00:00" AND first_start_time < "2015-09-29 12:00:00" AND deleted = 1 AND start_time = first_start_time ORDER BY first_start_time DESC LIMIT 1, 1;
SELECT id, seller_id AS sellerid, shop_id AS shopid, shop_type AS shoptype, state , promotion_start_time AS promotionstarttime, promotion_end_time AS promotionendtime, new_time AS newtime, pre_new_time AS prenewtime, today_new_count AS todaynewcount , seven_ago_new_count AS sevenagonewcount, fifteen_ago_new_count AS fifteenagonewcount, thirty_ago_new_count AS thirtyagonewcount, promotion_count AS promotioncount, pre_new_count AS prenewcount , features, gmt_create AS gmtcreate, gmt_modified AS gmtmodify FROM uac_dynamic_shop_infor WHERE seller_id = 1;
SELECT seller_id, item_id, activity_id, promotion_id, promotion_price , start_time, end_time FROM uac_shop_item_promotion WHERE seller_id = 1 AND start_time < now() AND end_time > now() ORDER BY start_time DESC LIMIT 1, 1;
SELECT seller_id, item_id, activity_id, purchase_price, discount , decrease_price, promotion_name, shop_id, feature, promotion_id , start_time, end_time, gmt_create, gmt_modified, ex_1 FROM uac_promotion_item WHERE seller_id = 1 AND item_id = 1 AND activity_id = 1 AND promotion_id = 1;
SELECT seller_id AS sellerid, item_id AS itemid, new_time AS newtime, start_time AS starttime, price , pic, title, category_id AS categoryid, item_type AS itemtype, state , deleted, first_start_time AS firststarttime, gmt_create AS gmtcreate, gmt_modify AS gmtmodify FROM uac_new_arrival_item WHERE seller_id = 1 AND start_time < "2015-09-29 12:00:00" AND first_start_time > "2015-09-29 12:00:00" AND (first_start_time < "2015-09-29 12:00:00" OR first_start_time = "2015-09-29 12:00:00" AND item_id > 1) AND deleted = 1 AND start_time = first_start_time ORDER BY first_start_time DESC, item_id ASC LIMIT 1;

