--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt 
#owner group:sql1 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists appfprstatistics (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT 'app的id', 
	`ydfans` bigint(20) UNSIGNED NOT NULL COMMENT '昨天的粉丝数', 
	`ydpost` bigint(20) UNSIGNED NOT NULL COMMENT '昨天的帖子数', 
	`ydreply` bigint(20) UNSIGNED NOT NULL COMMENT '昨天的回复数', 
	`bydfans` bigint(20) UNSIGNED NOT NULL COMMENT '前天的粉丝数', 
	`bydpost` bigint(20) UNSIGNED NOT NULL COMMENT '前天的帖子数', 
	`bydreply` bigint(20) UNSIGNED NOT NULL COMMENT '前天的回复数', 
	`tbydfans` bigint(20) UNSIGNED NOT NULL COMMENT '大前天的粉丝数', 
	`tbydpost` bigint(20) UNSIGNED NOT NULL COMMENT '大前天的帖子数', 
	`tbydreply` bigint(20) UNSIGNED NOT NULL COMMENT '大前天的回复数', 
	`wfans` bigint(20) UNSIGNED NOT NULL COMMENT '上周的粉丝数', 
	`wpost` bigint(20) UNSIGNED NOT NULL COMMENT '上周的帖子数', 
	`wreply` bigint(20) UNSIGNED NOT NULL COMMENT '上周的回复数', 
	`lmfans` bigint(20) UNSIGNED NOT NULL COMMENT '上月的粉丝数', 
	`lmpost` bigint(20) UNSIGNED NOT NULL COMMENT '上月的帖子数', 
	`lmreply` bigint(20) UNSIGNED NOT NULL COMMENT '上月的回复数', 
	`blmfans` bigint(20) UNSIGNED NOT NULL COMMENT '上上月的粉丝数', 
	`blmpost` bigint(20) UNSIGNED NOT NULL COMMENT '上上月的帖子数', 
	`blmreply` bigint(20) UNSIGNED NOT NULL COMMENT '上上月的回复数', 
	PRIMARY KEY (`id`), 
	KEY `kappid` (`appid`)
)  AUTO_INCREMENT = 142 CHARSET = utf8 COMMENT = 'app的粉丝帖子回复统计表';
CREATE TABLE if not exists apptag (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`name` varchar(255) NOT NULL COMMENT '标签名字', 
	`creatorid` bigint(20) UNSIGNED NOT NULL COMMENT '创建者', 
	`status` tinyint(4) DEFAULT '0' COMMENT '状态', 
	`operatorid` bigint(20) UNSIGNED NOT NULL COMMENT '修改者', 
	`weight` bigint(20) UNSIGNED DEFAULT '0' COMMENT '权重', 
	`weighttime` datetime NOT NULL COMMENT '权重计算时间', 
	`tagid` bigint(20) UNSIGNED NOT NULL COMMENT '标签id', 
	PRIMARY KEY (`id`), 
	KEY `idxappidnamestatusgmtcreate` (`appid`, `name`, `status`, `gmtcreate`), 
	KEY `idxappidtagidstatusgmtcreate` (`appid`, `tagid`, `status`, `gmtcreate`)
)  CHARSET = utf8 COMMENT = '应用标签表';
CREATE TABLE if not exists bbspermission (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`permissioncode` varchar(128) NOT NULL COMMENT '权限点编码', 
	`permissionname` varchar(256) NOT NULL COMMENT '权限名称', 
	`permissioncondition` varchar(256) NOT NULL COMMENT '权限表达式', 
	`permissionconditiondesc` varchar(128) NOT NULL COMMENT '权限描述', 
	`appid` bigint(20) NOT NULL COMMENT '站点的appId', 
	`topicid` bigint(20) NULL COMMENT '版块或者主题id', 
	`parentid` bigint(20) NOT NULL COMMENT '权限的父id，也是当前表的主键id', 
	`operatorid` bigint(20) NOT NULL COMMENT '操作者的userId，可能是小二也可能是卖家', 
	PRIMARY KEY (`id`), 
	KEY `kapptopiccode` (`appid`, `topicid`, `permissioncode`)
)  AUTO_INCREMENT = 31 CHARSET = utf8 COMMENT = '权限单表';
CREATE TABLE if not exists bizspecialchina (
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`cityid` bigint(20) UNSIGNED NOT NULL COMMENT '城市主键', 
	PRIMARY KEY (`appid`), 
	KEY `idxappidcityid` (`appid`, `cityid`)
)  CHARSET = utf8 COMMENT = '特设中国使用的关系映射表，用于查找城市ID对应的社区ID';
CREATE TABLE if not exists bpapppermissionconfig (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`topicid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '版块id', 
	`bprolepermissionid` bigint(20) UNSIGNED NOT NULL COMMENT '关联bprolepermission的主键', 
	`filter` varchar(512) NULL COMMENT '拦截的url', 
	`type` int(11) NOT NULL COMMENT '对url类型的区分', 
	`createid` bigint(20) UNSIGNED NOT NULL COMMENT '创建过滤规则的userid', 
	`status` int(11) NOT NULL COMMENT '规则状态', 
	`feature` varchar(256) NULL COMMENT '一些扩展的feature', 
	`operatetype` varchar(64) NOT NULL COMMENT '操作的类型，比如posts：发帖，reply：回复，comment：评论，browse：浏览', 
	PRIMARY KEY (`id`), 
	KEY `kapptopicstatus` (`appid`, `topicid`, `status`)
)  CHARSET = utf8 COMMENT = '角色权限拦截控制表，一般来讲就是一条规则';
CREATE TABLE if not exists bpappusers (
	`userid` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`appid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '应用ID', 
	`userflags` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '用户标记', 
	`userstatus` tinyint(4) DEFAULT '0' NOT NULL COMMENT '用户状态:-1逻辑删除,0正常', 
	`pictures` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器1--图片数量', 
	`posts` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器2--帖子数量', 
	`replies` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器3--回复数量', 
	`comments` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器5--评论数量', 
	`baseexp` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器6--用户基础经验值', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '最后修改时间', 
	PRIMARY KEY (`userid`, `appid`)
)  CHARSET = utf8 COMMENT = '用户表';
CREATE TABLE if not exists bpapps (
	`appid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '应用ID', 
	`appname` varchar(255) DEFAULT '' NOT NULL COMMENT '应用名称', 
	`appintroduction` varchar(255) DEFAULT '' NOT NULL COMMENT '应用描述', 
	`appmanagers` varchar(255) DEFAULT '' NOT NULL COMMENT '版主userId', 
	`appstatus` tinyint(4) DEFAULT '0' NOT NULL COMMENT '应用状态:-1逻辑删除,0正常', 
	`applogo` varchar(255) DEFAULT '' NOT NULL COMMENT '应用logo的url地址', 
	`appbanner` varchar(4096) DEFAULT '' NOT NULL COMMENT '应用banner的url地址', 
	`appextend` varchar(4096) DEFAULT '' NOT NULL COMMENT '应用扩展数据', 
	`appflags` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '应用标记', 
	`pictures` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器1--图片数量', 
	`posts` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器2--帖子数量', 
	`replies` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器3--回复数量', 
	`views` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器4--浏览数量', 
	`comments` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器5--评论数量', 
	`users` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器6--关注应用的用户数量', 
	`createdtime` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '创建时间', 
	`createduid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '创建用户', 
	`createdip` varchar(16) DEFAULT '' NOT NULL COMMENT '创建时IP地址', 
	`lastmodifytime` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后修改时间', 
	`lastmodifyuid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后修改用户', 
	`lastmodifyip` varchar(16) DEFAULT '' NOT NULL COMMENT '最后修改IP', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '最后修改时间', 
	`tmsheader` varchar(4096) DEFAULT '' COMMENT 'tmsheader地址', 
	`indexpageid` bigint(20) UNSIGNED NULL COMMENT '首页模板地址', 
	`listpageid` bigint(20) UNSIGNED NULL COMMENT 'list page的模板地址', 
	`detailpageid` bigint(20) UNSIGNED NULL COMMENT 'detai page的模板地址', 
	`templateid` bigint(20) UNSIGNED NULL COMMENT '模板id', 
	`templateextend` varchar(255) NULL COMMENT '模板extend', 
	`functiontype` tinyint(4) DEFAULT '0' COMMENT '功能类型', 
	`functionextend` varchar(1024) NULL COMMENT '功能扩展字段', 
	PRIMARY KEY (`appid`), 
	KEY `idxbpappscreateduid` (`createduid`, `appstatus`), 
	KEY `idxbpstatus` (`appid`, `appstatus`), 
	KEY `idxbpappname` (`appname`, `appstatus`)
)  CHARSET = utf8 COMMENT = '应用登记表';
CREATE TABLE if not exists bpcomments (
	`appid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '应用ID,分库分表', 
	`postid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '评论对应帖子ID', 
	`replyid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '评论对应回复ID', 
	`commentid` bigint(20) UNSIGNED NOT NULL COMMENT '评论ID,主键', 
	`commenttype` tinyint(3) UNSIGNED DEFAULT '0' NOT NULL COMMENT '评论类型:0回复评论,1帖子评论', 
	`commentcontent` varchar(255) DEFAULT '' NOT NULL COMMENT '评论内容（由于长度业务限制,不需要压缩）', 
	`commenttfs` varchar(127) DEFAULT '' NOT NULL COMMENT '回复内容tfs文件名', 
	`commentmd5` varchar(32) DEFAULT '' NOT NULL COMMENT '回复内容md5', 
	`commentstatus` tinyint(4) DEFAULT '0' NOT NULL COMMENT '回复状态:-1逻辑删除,0正常,1草稿箱,2回收站', 
	`version` smallint(5) UNSIGNED DEFAULT '0' NOT NULL COMMENT '版本号', 
	`commentflags` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '回复业务标签', 
	`createdtime` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '发布时间', 
	`createduid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '发布者ID', 
	`createdip` varchar(40) DEFAULT '' NOT NULL COMMENT '发布IP', 
	`lastmodifytime` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后修改时间', 
	`lastmodifyuid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后修改用户', 
	`lastmodifyip` varchar(16) DEFAULT '' NOT NULL COMMENT '最后修改IP', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '最后修改时间', 
	PRIMARY KEY (`commentid`), 
	KEY `idxbpcommentsappid` (`appid`, `postid`, `createduid`), 
	KEY `idxappidpostidreplyid` (`appid`, `postid`, `replyid`)
)  CHARSET = utf8 COMMENT = '评论表';
CREATE TABLE if not exists bpdomain (
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '应用id', 
	`appdomain` varchar(32) NOT NULL COMMENT '应用域名', 
	`appstatus` tinyint(4) DEFAULT '0' NOT NULL COMMENT '应用状态:-1逻辑删除,0正常', 
	`spm` varchar(128) NULL COMMENT 'spm的value', 
	`prespm` varchar(128) NULL COMMENT '预发spm的value', 
	`bbsadmin` int(11) DEFAULT '0' COMMENT 'bbsadmin权限是否创建', 
	PRIMARY KEY (`appid`), 
	UNIQUE `domain` (`appdomain`), 
	KEY `statusappid` (`appstatus`, `appid`)
)  CHARSET = utf8 COMMENT = '每个app对用的域名表';
CREATE TABLE if not exists bplikes (
	`appid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '社区id，分表字段', 
	`postid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '赞对应帖子ID', 
	`replyid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '赞对应回复ID', 
	`likeid` bigint(20) UNSIGNED NOT NULL COMMENT '赞id，主键', 
	`liketype` tinyint(3) UNSIGNED DEFAULT '0' NOT NULL COMMENT '赞类型:0赞帖子，1赞回复', 
	`likestatus` tinyint(4) DEFAULT '0' NOT NULL COMMENT '赞状态:-1逻辑删除,0正常', 
	`likeflags` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '业务标签', 
	`createduid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '发布者ID', 
	`createdip` varchar(20) NOT NULL COMMENT '发布IP', 
	`lastmodifyuid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后修改用户', 
	`lastmodifyip` varchar(20) NOT NULL COMMENT '最后修改IP', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '最后修改时间', 
	PRIMARY KEY (`likeid`), 
	KEY `idxpostreply` (`appid`, `postid`, `replyid`, `createduid`)
)  CHARSET = utf8 COMMENT = '用户点赞记录表';
CREATE TABLE if not exists bpmanager (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '社区id，分表字段', 
	`userid` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`userflags` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '用户标记', 
	`userstatus` tinyint(4) DEFAULT '0' NOT NULL COMMENT '用户状态:-1逻辑删除,0正常', 
	`roleid` tinyint(3) UNSIGNED DEFAULT '0' NOT NULL COMMENT '角色id', 
	`features` varchar(512) NULL COMMENT '特征', 
	`createduid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '创建者ID', 
	`createdip` varchar(20) DEFAULT '' NOT NULL COMMENT '创建者IP', 
	`lastmodifyuid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后修改者ID', 
	`lastmodifyip` varchar(20) DEFAULT '' NOT NULL COMMENT '最后者修改IP', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '最后修改时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `appuser` (`appid`, `userid`), 
	KEY `appstatus` (`appid`, `userstatus`)
)  AUTO_INCREMENT = 2 CHARSET = utf8 COMMENT = 'bbs社区管理员表';
CREATE TABLE if not exists bppatterns (
	`patternid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '模式id', 
	`patternname` varchar(128) NOT NULL COMMENT '模式名称', 
	`patternstatus` tinyint(4) DEFAULT '0' NOT NULL COMMENT '状态:-1逻辑删除,0正常', 
	`version` smallint(5) UNSIGNED DEFAULT '0' NOT NULL COMMENT '版本号', 
	`patternflags` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '业务标签', 
	`patterntype` smallint(5) UNSIGNED DEFAULT '0' NOT NULL COMMENT 'pattern类型', 
	`patterngroup` smallint(5) UNSIGNED DEFAULT '0' NOT NULL COMMENT 'pattern分组', 
	`createduid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '发布者ID', 
	`createdip` varchar(16) NOT NULL COMMENT '最后回复IP', 
	`lastmodifyuid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后修改用户', 
	`lastmodifyip` varchar(16) NOT NULL COMMENT '最后修改IP', 
	`objectification` tinyint(4) DEFAULT '0' NOT NULL COMMENT '是否对象化', 
	`config` varchar(10) COMMENT '配置', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '最后修改时间', 
	PRIMARY KEY (`patternid`), 
	KEY `status` (`patternstatus`), 
	KEY `name` (`patternname`)
)  CHARSET = utf8 COMMENT = 'bbs资源展示的模式';
CREATE TABLE if not exists bppermissionuserlist (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`topicid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '版块id', 
	`bprolepermissionid` bigint(20) UNSIGNED NOT NULL COMMENT '关联bppermission的主键', 
	`userid` bigint(20) UNSIGNED NOT NULL COMMENT '被添加的名单id', 
	`nick` varchar(128) NOT NULL COMMENT '被添加的名单昵称', 
	`status` int(11) NOT NULL COMMENT '被添加的名单的状态', 
	PRIMARY KEY (`id`), 
	KEY `kapptopicuserstatuspermission` (`appid`, `topicid`, `userid`, `status`, `bprolepermissionid`)
)  CHARSET = utf8 COMMENT = '权限名单表';
CREATE TABLE if not exists bpposts (
	`appid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '应用ID,分库分表', 
	`postid` bigint(20) UNSIGNED NOT NULL COMMENT '帖子ID,主键', 
	`topicid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '主题ID', 
	`posttitle` varchar(255) DEFAULT '' NOT NULL COMMENT '帖子标题', 
	`postgzip` varchar(10) NOT NULL COMMENT '帖子内容gzip压缩存档:[c]为压缩标签[n]为非压缩', 
	`posttfs` varchar(127) DEFAULT '' NOT NULL COMMENT '帖子内容tfs文件名', 
	`postmd5` varchar(32) DEFAULT '' NOT NULL COMMENT '帖子标题和内容md5', 
	`poststatus` tinyint(4) DEFAULT '0' NOT NULL COMMENT '帖子状态:-1逻辑删除,0正常,1草稿箱,2回收站', 
	`version` smallint(5) UNSIGNED DEFAULT '0' NOT NULL COMMENT '版本号', 
	`posttags` varchar(255) DEFAULT '' NOT NULL COMMENT '搜索属性：标签', 
	`postflags` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '标签--业务标签', 
	`pictures` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器1--图片数量', 
	`replies` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器2--回复数量', 
	`views` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器3--浏览数量', 
	`comments` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器4--评论数量', 
	`createdtime` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '发布时间', 
	`createduid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '发布者ID', 
	`createdip` varchar(16) DEFAULT '' NOT NULL COMMENT '发布IP', 
	`lastreplytime` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后回复时间', 
	`lastreplyuid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后回复者ID', 
	`lastreplyip` varchar(16) DEFAULT '' NOT NULL COMMENT '最后回复IP', 
	`lastmodifytime` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后修改时间', 
	`lastmodifyuid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后修改用户', 
	`lastmodifyip` varchar(16) DEFAULT '' NOT NULL COMMENT '最后修改IP', 
	`managercomment` varchar(1024) DEFAULT '' NOT NULL COMMENT '组合属性--管理员回复', 
	`cachecomments` varchar(4096) DEFAULT '' NOT NULL COMMENT '组合属性--前3条评论缓存', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '最后修改时间', 
	`likes` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器5-点赞数量', 
	`pattern` int(11) DEFAULT '0' NOT NULL COMMENT '对应的展示模式id', 
	`tags` varchar(4096) NULL COMMENT '标签', 
	`pageid` bigint(20) UNSIGNED NULL COMMENT '页面id', 
	`cachelikes` varchar(1024) DEFAULT '' NOT NULL COMMENT '组合属性--赞缓存', 
	`preview` varchar(255) NULL COMMENT '预览图片', 
	`templateextend` varchar(255) NULL COMMENT '模板中心扩展字段', 
	PRIMARY KEY (`postid`), 
	KEY `idxbppostsappid` (`appid`, `createduid`), 
	KEY `idxappidpostid` (`appid`, `postid`)
)  CHARSET = utf8 COMMENT = '帖子表';
CREATE TABLE if not exists bppostsvote (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`userid` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`postid` bigint(20) UNSIGNED NOT NULL COMMENT '帖子ID', 
	`voteid` bigint(20) UNSIGNED NOT NULL COMMENT '选票ID', 
	`extend` varchar(4000) NULL COMMENT '扩展字段', 
	`status` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '状态', 
	PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '投票表';
CREATE TABLE if not exists bpreplies (
	`appid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '应用ID,分库分表', 
	`postid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '帖子ID,分库分表', 
	`replyid` bigint(20) UNSIGNED NOT NULL COMMENT '回复ID,主键', 
	`replytitle` varchar(255) DEFAULT '' NOT NULL COMMENT '帖子标题', 
	`replygzip` varchar(10) NOT NULL COMMENT '回复内容gzip压缩存档', 
	`replytfs` varchar(127) DEFAULT '' NOT NULL COMMENT '回复内容tfs文件名', 
	`replymd5` varchar(32) DEFAULT '' NOT NULL COMMENT '回复内容md5', 
	`replystatus` tinyint(4) DEFAULT '0' NOT NULL COMMENT '回复状态:-1逻辑删除,0正常,1草稿箱,2回收站', 
	`version` smallint(5) UNSIGNED DEFAULT '0' NOT NULL COMMENT '版本号', 
	`replyflags` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '回复业务标签', 
	`createdtime` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '发布时间', 
	`createduid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '发布者ID', 
	`createdip` varchar(40) DEFAULT '' NOT NULL COMMENT '发布IP', 
	`lastmodifytime` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后修改时间', 
	`lastmodifyuid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后修改用户', 
	`lastmodifyip` varchar(16) DEFAULT '' NOT NULL COMMENT '最后修改IP', 
	`pictures` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器1--图片数量', 
	`comments` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器2--评论数量', 
	`views` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器3--浏览数量', 
	`managercomment` varchar(1024) DEFAULT '' NOT NULL COMMENT '组合属性--管理员回复', 
	`cachecomments` varchar(4096) DEFAULT '' NOT NULL COMMENT '组合属性--前3条评论缓存', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '最后修改时间', 
	`likes` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器4-点赞数量', 
	`cachelikes` varchar(1024) DEFAULT '' NOT NULL COMMENT '组合属性--赞缓存', 
	PRIMARY KEY (`replyid`), 
	KEY `idxbprepliesappid` (`appid`, `postid`, `createduid`), 
	KEY `idxbpappidpostidreplyid` (`appid`, `postid`, `replyid`)
)  CHARSET = utf8 COMMENT = '回复表';
CREATE TABLE if not exists bprolepermission (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`topicid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '版块id', 
	`rolename` varchar(32) NULL COMMENT '角色的名字', 
	`createid` bigint(20) UNSIGNED NOT NULL COMMENT '创建者的userId', 
	`feature` varchar(128) NULL COMMENT 'KV的集合', 
	`status` int(11) NOT NULL COMMENT '当前角色的状态', 
	`conditionset` varchar(256) NOT NULL COMMENT '计算表达式的合集', 
	`codeset` varchar(256) NOT NULL COMMENT '权限点的集合', 
	PRIMARY KEY (`id`), 
	KEY `kapptopic` (`appid`, `topicid`, `id`)
)  CHARSET = utf8 COMMENT = '角色权限表';
CREATE TABLE if not exists bptopics (
	`appid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '应用ID,分库分表', 
	`topicid` bigint(20) UNSIGNED NOT NULL COMMENT '主题ID', 
	`topicname` varchar(255) DEFAULT '' NOT NULL COMMENT '主题名称', 
	`topicstatus` tinyint(4) DEFAULT '0' NOT NULL COMMENT '主题状态:-1逻辑删除,0正常', 
	`topicflags` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '主题标记', 
	`pictures` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器1--图片数量', 
	`posts` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器2--帖子数量', 
	`replies` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器2--回复数量', 
	`views` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器3--浏览数量', 
	`comments` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器4--评论数量', 
	`createdtime` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '发布时间', 
	`createduid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '发布者ID', 
	`createdip` varchar(40) DEFAULT '' NOT NULL COMMENT '发布IP', 
	`lastmodifytime` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后修改时间', 
	`lastmodifyuid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '最后修改用户', 
	`lastmodifyip` varchar(16) DEFAULT '' NOT NULL COMMENT '最后修改IP', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '最后修改时间', 
	`weight` bigint(20) UNSIGNED DEFAULT '0' COMMENT '权重', 
	`listpageid` bigint(20) UNSIGNED NULL COMMENT '列表模板', 
	`detailpageid` bigint(20) UNSIGNED NULL COMMENT '详情模板', 
	`templateid` bigint(20) UNSIGNED NULL COMMENT '模板id', 
	`templateextend` varchar(255) NULL COMMENT '模板扩展字段', 
	`topictype` tinyint(4) DEFAULT '0' COMMENT '主题类型', 
	PRIMARY KEY (`topicid`), 
	UNIQUE `uappidtopicname` (`appid`, `topicname`), 
	KEY `appidtopicstatuscreatedtime` (`appid`, `topicstatus`, `createdtime`), 
	KEY `appiptopicid` (`appid`, `topicid`)
)  CHARSET = utf8 COMMENT = '帖子主题';
CREATE TABLE if not exists bpusers (
	`userid` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`userstatus` tinyint(4) DEFAULT '0' NOT NULL COMMENT '用户状态:-1逻辑删除,0正常', 
	`userflags` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '用户标记', 
	`pictures` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器1--图片数量', 
	`posts` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器2--帖子数量', 
	`replies` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器3--回复数量', 
	`comments` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器5--评论数量', 
	`apps` bigint(20) DEFAULT '0' NOT NULL COMMENT '计数器6--关注应用数量', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '最后修改时间', 
	PRIMARY KEY (`userid`)
)  CHARSET = utf8 COMMENT = '用户表';
CREATE TABLE if not exists bpusersinapp (
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '应用ID', 
	`userid` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '用户ID', 
	`attributes` varchar(256) NULL COMMENT '用户属性', 
	`userflags` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '用户标记', 
	`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '用户状态', 
	PRIMARY KEY (`appid`, `userid`), 
	KEY `appflagstatus` (`appid`, `userflags`, `status`)
)  CHARSET = utf8 COMMENT = 'app特殊状态用户表';
CREATE TABLE if not exists customuser (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`userid` bigint(20) UNSIGNED NOT NULL COMMENT '用户id', 
	`bizdate` varchar(255) NOT NULL COMMENT '云梯回流时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '社区Id', 
	`type` int(11) DEFAULT '0' COMMENT '业务类型', 
	`extend` varchar(255) NOT NULL COMMENT '扩展字段', 
	`status` tinyint(4) DEFAULT '0' COMMENT '状态', 
	PRIMARY KEY (`id`), 
	KEY `idxappiduseridtypestatus` (`appid`, `userid`, `type`, `status`)
)  AUTO_INCREMENT = 4938 CHARSET = utf8 COMMENT = '自定义的用户。私密社区或者有特殊需求的社区使用';
CREATE TABLE if not exists lpblock (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`title` varchar(255) NOT NULL COMMENT '名字', 
	`code` varchar(10) NOT NULL COMMENT 'html代码', 
	`description` varchar(10) NOT NULL COMMENT '描述：json字段', 
	`status` tinyint(4) DEFAULT '0' COMMENT '状态', 
	`creatorid` bigint(20) UNSIGNED NOT NULL COMMENT '创建者', 
	`operatorid` bigint(20) UNSIGNED NOT NULL COMMENT '修改者', 
	`templateid` bigint(20) UNSIGNED NOT NULL COMMENT '模板id', 
	`templatename` varchar(255) NULL COMMENT '模板name', 
	`type` tinyint(4) DEFAULT '0' COMMENT '区块类型', 
	`name` varchar(255) NULL COMMENT '名称，和title含义不同。反了。', 
	PRIMARY KEY (`id`), 
	KEY `idxtemlpateidstatusgmtcreate` (`templateid`, `status`, `gmtcreate`), 
	KEY `idxtemplateidstatustypegmtcreate` (`templateid`, `status`, `type`, `gmtcreate`), 
	KEY `idxnamestatus` (`name`, `status`), 
	KEY `idxtemplateidnamestatus` (`templateid`, `name`, `status`), 
	KEY `idxtemplatenamenamestatus` (`templatename`, `name`, `status`)
)  AUTO_INCREMENT = 86 CHARSET = utf8 COMMENT = '基于可变描述对象的内容发布工具';
CREATE TABLE if not exists lpdata (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`blockid` bigint(20) UNSIGNED NOT NULL COMMENT '区块id', 
	`data` varchar(10) COMMENT '数据', 
	`result` varchar(10) COMMENT '结果', 
	`status` tinyint(4) DEFAULT '0' COMMENT '状态', 
	`creatorid` bigint(20) UNSIGNED NOT NULL COMMENT '创建者', 
	`operatorid` bigint(20) UNSIGNED NOT NULL COMMENT '操作者', 
	PRIMARY KEY (`id`), 
	KEY `idxappidblockidstatusgmtcreate` (`appid`, `blockid`, `status`, `gmtcreate`)
)  CHARSET = utf8 COMMENT = '基于可变描述对象的内容发布工具的数据';
CREATE TABLE if not exists lppagedata (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`postid` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`creatorid` bigint(20) UNSIGNED NOT NULL COMMENT '创建者', 
	`operatorid` bigint(20) UNSIGNED NOT NULL COMMENT '操作者', 
	`pageid` bigint(20) UNSIGNED NULL COMMENT '页面原型id', 
	`status` tinyint(4) DEFAULT '0' COMMENT '状态', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '冗余字段', 
	`data` varchar(10) COMMENT '数据', 
	`result` varchar(10) COMMENT '结果', 
	PRIMARY KEY (`id`), 
	KEY `idxappidpostidstatusgmtcreate` (`appid`, `postid`, `status`, `gmtcreate`)
)  CHARSET = utf8 COMMENT = '页面原型数据表';
CREATE TABLE if not exists lpprototypepage (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`title` varchar(255) NOT NULL COMMENT '名称', 
	`creatorid` bigint(20) UNSIGNED NOT NULL COMMENT '创建者', 
	`operatorid` bigint(20) UNSIGNED NOT NULL COMMENT '操作者', 
	`content` varchar(10) NOT NULL COMMENT '内容', 
	`status` tinyint(4) DEFAULT '0' COMMENT '状态', 
	`result` varchar(10) COMMENT '结果', 
	`templateid` bigint(20) UNSIGNED NULL COMMENT '模板id', 
	`templatename` varchar(255) NULL COMMENT '模板名称', 
	PRIMARY KEY (`id`), 
	KEY `idxstatuscreator` (`status`, `creatorid`), 
	KEY `idxstatusgmtcreate` (`status`, `gmtcreate`), 
	KEY `idxtemplatenamenamestatus` (`templatename`, `title`, `status`), 
	KEY `idxtemplateidstatusgmtcreate` (`templateid`, `result`, `gmtcreate`)
)  AUTO_INCREMENT = 15 CHARSET = utf8 COMMENT = '页面原型';
CREATE TABLE if not exists lpprototypepagedata (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`pageid` bigint(20) UNSIGNED NOT NULL COMMENT '页面id', 
	`creatorid` bigint(20) UNSIGNED NOT NULL COMMENT '创建者', 
	`operatorid` bigint(20) UNSIGNED NOT NULL COMMENT '操作者', 
	`status` tinyint(4) DEFAULT '0' COMMENT '状态', 
	`data` varchar(10) COMMENT '数据', 
	`result` varchar(10) COMMENT '结果', 
	PRIMARY KEY (`id`), 
	KEY `idxappidpageidstatusgmtcreate` (`appid`, `pageid`, `status`, `gmtcreate`)
)  CHARSET = utf8 COMMENT = '原型页面的数据。主要用于首页等，不需要帖子id的页面';
CREATE TABLE if not exists lpwhiteusers (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`userid` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`nick` varchar(128) NOT NULL COMMENT '用户昵称', 
	`status` int(11) NOT NULL COMMENT '用户状态,0无效，1有效', 
	PRIMARY KEY (`id`), 
	UNIQUE `appidpriamry` (`appid`, `userid`)
)  CHARSET = utf8 COMMENT = '拉普达白名单';
CREATE TABLE if not exists migrationapp (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`groupid` bigint(20) UNSIGNED NOT NULL COMMENT '帮派or论坛id', 
	`sourceid` int(11) NOT NULL COMMENT '帮派or论坛', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '淘社区id', 
	`version` bigint(20) UNSIGNED DEFAULT '0' COMMENT '版本号', 
	`status` tinyint(4) DEFAULT '0' COMMENT '0:准备迁移，1:迁移主题,2:迁移置顶帖子及评论，3：普通帖子及回复,4,迁移用户，5：迁移完毕', 
	`extend` bigint(20) UNSIGNED NULL COMMENT '扩展字段：迁移中，用于标注当前哪几页已经迁移完毕', 
	`step` varchar(255) NULL COMMENT '用户选择的迁移步骤。', 
	`extend2` varchar(255) NULL COMMENT '扩展字段', 
	PRIMARY KEY (`id`), 
	UNIQUE `idxsourceidgroupid` (`sourceid`, `groupid`), 
	KEY `idxsourceidstatus` (`sourceid`, `status`)
)  AUTO_INCREMENT = 58 CHARSET = utf8 COMMENT = '帮派or论坛数据迁移表';
CREATE TABLE if not exists migrationpost (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`threadid` bigint(20) UNSIGNED NOT NULL COMMENT '帮派or论坛帖子id', 
	`sourceid` int(11) NOT NULL COMMENT '帮派为1，论坛为2', 
	`postid` bigint(20) UNSIGNED NOT NULL COMMENT '淘社区帖子id', 
	`version` bigint(20) UNSIGNED DEFAULT '0' COMMENT '版本号', 
	`status` tinyint(4) DEFAULT '0' COMMENT '1:准备迁移，2:正在迁移，3:迁移完毕', 
	`groupid` bigint(20) UNSIGNED NOT NULL COMMENT '论坛or帮派id', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '淘社区Id', 
	`extend` varchar(255) NULL COMMENT '扩展字段', 
	`extend2` varchar(255) NULL COMMENT '扩展字段', 
	PRIMARY KEY (`id`), 
	UNIQUE `idxsourceidgroupidthreadid` (`sourceid`, `groupid`, `threadid`)
)  CHARSET = utf8 COMMENT = '帮派or论坛帖子迁移表';
CREATE TABLE if not exists migrationreply (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`groupid` bigint(20) UNSIGNED NOT NULL COMMENT '帮派or论坛Id', 
	`sourceid` int(11) DEFAULT '0' COMMENT '帮派or论坛', 
	`threadid` bigint(20) UNSIGNED NOT NULL COMMENT '帖子id', 
	`originreplyid` bigint(20) UNSIGNED NOT NULL COMMENT '帮派or论坛回复id', 
	`replyid` bigint(20) UNSIGNED NOT NULL COMMENT '淘社区回复id', 
	`version` bigint(20) UNSIGNED DEFAULT '0' COMMENT '版本号', 
	`status` tinyint(4) DEFAULT '1' COMMENT '1:准备迁移，2：开始迁移，3：迁移完毕', 
	`postid` bigint(20) UNSIGNED NOT NULL COMMENT '淘社区帖子id', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT 'appId', 
	PRIMARY KEY (`id`), 
	UNIQUE `idxsigidtiori` (`sourceid`, `groupid`, `threadid`, `originreplyid`)
)  CHARSET = utf8 COMMENT = '帮派or论坛回复迁移表';
CREATE TABLE if not exists migrationtop (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`groupid` bigint(20) UNSIGNED NOT NULL COMMENT '帮派or论坛id', 
	`boardid` bigint(20) UNSIGNED NOT NULL COMMENT '帮派or论坛主题id', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '淘社区id', 
	`topid` bigint(20) UNSIGNED NOT NULL COMMENT '淘社区主题id', 
	`sourceid` int(11) DEFAULT '1' COMMENT '来源', 
	`version` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '版本号', 
	`status` tinyint(4) DEFAULT '0' COMMENT '状态', 
	PRIMARY KEY (`id`), 
	UNIQUE `idxgroupsourceboard` (`groupid`, `status`, `boardid`)
)  AUTO_INCREMENT = 477 CHARSET = utf8 COMMENT = '帮派or论坛迁移的主题';
CREATE TABLE if not exists oldboard (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`groupid` bigint(20) UNSIGNED NOT NULL COMMENT '分组id', 
	`name` varchar(10) NOT NULL COMMENT '子主题名字', 
	`boardgmtcreate` datetime NOT NULL COMMENT 'board创建时间', 
	`boardgmtmodified` datetime NOT NULL COMMENT 'board修改时间', 
	`boardid` bigint(20) UNSIGNED NOT NULL COMMENT 'board分表的主键', 
	PRIMARY KEY (`id`), 
	KEY `kgroupboard` (`groupid`, `boardid`)
)  AUTO_INCREMENT = 251266 CHARSET = utf8 COMMENT = '从云梯回流的子主题表';
CREATE TABLE if not exists oldchannelcatalog (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`channelid` bigint(20) UNSIGNED NOT NULL COMMENT '渠道的id', 
	`groupid` bigint(20) UNSIGNED NOT NULL COMMENT '分组id', 
	`channelname` varchar(50) NOT NULL COMMENT '渠道名称', 
	`groupname` varchar(118) NOT NULL COMMENT '分组名称', 
	`official` tinyint(4) NOT NULL COMMENT '是否官方', 
	`cataloggmtcreate` datetime NOT NULL COMMENT 'catalog创建时间', 
	`cataloggmtmodified` datetime NOT NULL COMMENT 'catalog修改时间', 
	`channelgmtcreate` datetime NOT NULL COMMENT 'channel穿件时间', 
	`channelgmtmodified` datetime NOT NULL COMMENT 'channel修改时间', 
	`parentid` bigint(20) UNSIGNED NULL COMMENT '父节点id', 
	`hasmigrate` tinyint(4) DEFAULT '0' NOT NULL COMMENT '0:未迁移，1:已迁移', 
	PRIMARY KEY (`id`), 
	KEY `kchannelgroup` (`groupid`, `channelid`)
)  AUTO_INCREMENT = 232 CHARSET = utf8 COMMENT = '从云梯回流的表，渠道主题表';
CREATE TABLE if not exists oldpost (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`threadid` bigint(20) UNSIGNED NOT NULL COMMENT '帖子的id', 
	`groupid` bigint(20) UNSIGNED NOT NULL COMMENT '帖子所属组id', 
	`subject` varchar(50) NOT NULL COMMENT '帖子的标题', 
	`type` tinyint(4) NOT NULL COMMENT '类型', 
	`status` tinyint(4) NOT NULL COMMENT '状态', 
	`digest` tinyint(4) NOT NULL COMMENT '是否精华', 
	`viewcount` int(11) NOT NULL COMMENT '浏览次数', 
	`replycount` int(11) NOT NULL COMMENT '回复次数', 
	`authorid` bigint(20) UNSIGNED NOT NULL COMMENT '发帖人的userId', 
	`authorip` varchar(16) NOT NULL COMMENT '发帖人的ip', 
	`lastreplyauthorid` bigint(20) UNSIGNED DEFAULT '0' COMMENT '最后回复者的userId', 
	`lastreplytime` datetime NULL COMMENT '最后回复时间', 
	`postgmtcreate` datetime NOT NULL COMMENT '帖子创建时间', 
	`postgmtmodified` datetime NOT NULL COMMENT '帖子回复时间', 
	`content`varchar(100)NOT NULL COMMENT '帖子的内容', 
	`boardid` bigint(20) UNSIGNED NULL COMMENT '子主题', 
	`extrauserid` bigint(20) UNSIGNED NULL COMMENT '外部第三方名称', 
	`synctotp` tinyint(4) NULL COMMENT '是否同步给第三方', 
	`char` varchar(256) NULL COMMENT '标签', 
	PRIMARY KEY (`id`), 
	KEY `kgroupthreadboard` (`groupid`, `threadid`, `boardid`)
)  AUTO_INCREMENT = 13451012 CHARSET = utf8 COMMENT = '用来从云梯回流老bbs的帖子数据';
CREATE TABLE if not exists oldreply (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`threadid` bigint(20) UNSIGNED NOT NULL COMMENT '帖子id', 
	`groupid` bigint(20) UNSIGNED NOT NULL COMMENT '分组id', 
	`authorid` bigint(20) UNSIGNED NOT NULL COMMENT '回复者id', 
	`authorip` varchar(16) NOT NULL COMMENT '作者ip', 
	`content`varchar(100)NOT NULL COMMENT '回复内容', 
	`replygmtcreate` datetime NOT NULL COMMENT '回复的创建时间', 
	`replygmtmodified` datetime NOT NULL COMMENT '回复的修改时间', 
	`lastmodified` datetime NULL COMMENT '最后修改时间', 
	PRIMARY KEY (`id`), 
	KEY `kgroupthread` (`groupid`, `threadid`)
)  AUTO_INCREMENT = 324055 CHARSET = utf8 COMMENT = '云梯回流表，帖子回复表';
--disable_warnings
drop table if exists sequence;
--enable_warnings
CREATE TABLE if not exists sequence (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`name` varchar(255) NULL COMMENT '主键key', 
	`value` bigint(20) NULL COMMENT '当前值', 
	`gmtmodified` datetime NULL COMMENT '最后修改时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `uniquename` (`name`)
)  AUTO_INCREMENT = 12 CHARSET = utf8 COMMENT = '分布式主键';
CREATE TABLE if not exists tccode (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`type` tinyint(4) NOT NULL COMMENT '状态', 
	`content` varchar(10) NOT NULL COMMENT '代码片段', 
	`status` tinyint(4) DEFAULT '0' COMMENT '状态', 
	`creator` bigint(20) UNSIGNED NOT NULL COMMENT '创建者Id', 
	`name` varchar(255) NOT NULL COMMENT '名称', 
	`description` varchar(255) NOT NULL COMMENT '描述', 
	PRIMARY KEY (`id`), 
	KEY `idxstatustypegmtcreate` (`status`, `type`, `gmtcreate`), 
	KEY `idxstatusgmtcreate` (`status`, `gmtcreate`)
)  AUTO_INCREMENT = 41 CHARSET = utf8 COMMENT = '模板中心代码片段';
CREATE TABLE if not exists tcpage (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`name` varchar(255) NOT NULL COMMENT '页面名称', 
	`content` varchar(10) NOT NULL COMMENT 'vm内容', 
	`creator` bigint(20) UNSIGNED NOT NULL COMMENT '创建者id', 
	`templateid` bigint(20) UNSIGNED NOT NULL COMMENT '模板id', 
	`status` tinyint(4) DEFAULT '0' COMMENT '状态', 
	`pagetype` int(11) DEFAULT '0' COMMENT '页面类型', 
	`versiontype` tinyint(4) DEFAULT '0' COMMENT '版本类型', 
	`defaulttype` tinyint(4) DEFAULT '0' COMMENT '是否是默认', 
	`prototypeid` bigint(20) UNSIGNED NULL COMMENT '页面原型id', 
	`templatename` varchar(255) NULL COMMENT '模板名称', 
	`env` tinyint(4) DEFAULT '0' NOT NULL COMMENT '模板使用环境，0表示开发中，1表示正式使用', 
	PRIMARY KEY (`id`), 
	KEY `idxtidstatuspagetypegmtcreate` (`templateid`, `status`, `pagetype`, `gmtcreate`), 
	KEY `idxtidpagetypedefaulttype` (`templateid`, `pagetype`, `defaulttype`), 
	KEY `idxtidstatusgmtcreate` (`templateid`, `status`, `gmtcreate`), 
	KEY `idxtemplateidnamestatus` (`templateid`, `name`, `status`), 
	KEY `idxtemplatenamenamestatus` (`templatename`, `name`, `status`, `env`)
)  AUTO_INCREMENT = 417 CHARSET = utf8 COMMENT = '模板页面vm信息表';
CREATE TABLE if not exists tctemplate (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`creator` bigint(20) UNSIGNED NOT NULL COMMENT '创建者Id', 
	`status` int(11) DEFAULT '0' COMMENT '状态', 
	`count` bigint(20) UNSIGNED DEFAULT '0' COMMENT '使用数', 
	`type` tinyint(4) DEFAULT '0' COMMENT '类型', 
	`description` varchar(255) NOT NULL COMMENT '描述', 
	`name` varchar(255) NOT NULL COMMENT '模板名称', 
	`title` varchar(255) NULL COMMENT '模板title', 
	PRIMARY KEY (`id`), 
	KEY `idxstg` (`status`, `type`, `gmtcreate`), 
	KEY `idxcs` (`creator`, `status`), 
	KEY `idxsg` (`status`, `gmtcreate`), 
	KEY `idxnamestatusgmtcreate` (`name`, `status`, `gmtcreate`)
)  AUTO_INCREMENT = 29 CHARSET = utf8 COMMENT = '模板中心';
CREATE TABLE if not exists bpcollect (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`postid` bigint(20) UNSIGNED NOT NULL COMMENT '帖子ID', 
	`userid` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`extend` varchar(7000) NULL COMMENT '扩展字段', 
	`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '0:正常 1： 删除', 
	PRIMARY KEY (`id`), 
	UNIQUE `idxunique` (`appid`, `postid`, `userid`)
)  CHARSET = utf8 COMMENT = '收藏表';
CREATE TABLE if not exists bpmessage (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`userid` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`postid` bigint(20) UNSIGNED NOT NULL COMMENT '帖子ID', 
	`replyid` bigint(20) UNSIGNED NULL COMMENT '评论ID', 
	`type` tinyint(3) UNSIGNED DEFAULT '0' NOT NULL COMMENT '0：帖子评论消息；1：帖子收藏消息；2：帖子回复消息；3：评论回复消息', 
	`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '0：未读 ； 1：已读；-1：删除', 
	`fromuserid` bigint(20) UNSIGNED NULL COMMENT '操作用户', 
	PRIMARY KEY (`id`), 
	KEY `idxuserid` (`appid`, `userid`)
)  CHARSET = utf8 COMMENT = '消息表';
CREATE TABLE if not exists bppostreplyrelation (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`userid` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`postid` bigint(20) UNSIGNED NOT NULL COMMENT '帖子ID', 
	`replyid` bigint(20) UNSIGNED NOT NULL COMMENT '对应回复ID', 
	`status` int(11) NOT NULL COMMENT '回复状态', 
	PRIMARY KEY (`id`), 
	KEY `idxuser` (`userid`)
)  CHARSET = utf8 COMMENT = '回复关联关系表';
CREATE TABLE if not exists bppoststatistics (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`postid` bigint(20) UNSIGNED NOT NULL COMMENT '帖子ID', 
	`collectamount` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '收藏数量', 
	`relpyamount` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '评论数量', 
	`extend` varchar(7000) NULL COMMENT '扩展字段', 
	PRIMARY KEY (`id`), 
	UNIQUE `postid` (`appid`, `postid`)
)  CHARSET = utf8 COMMENT = '帖子信息统计表';
CREATE TABLE if not exists bpuserstatistics (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreate` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodified` datetime NOT NULL COMMENT '修改时间', 
	`appid` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`userid` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`relpyamount` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '评论数量', 
	`collectamount` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '收藏数量', 
	`publishamount` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '发帖数量', 
	PRIMARY KEY (`id`), 
	UNIQUE `idxuserid` (`appid`, `userid`)
)  CHARSET = utf8 COMMENT = '用户统计数据';

