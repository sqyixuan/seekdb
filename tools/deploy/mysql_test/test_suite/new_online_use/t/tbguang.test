--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: jim.wjh
#owner group:sql2
#tags new_online_use 
#description:this case is use for test online use of ob1.0 
--disable_warnings
drop table if exists sequence;
--enable_warnings
CREATE TABLE if not exists agj_dapei_contents (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NULL COMMENT '创建时间', 
	`gmt_modified` datetime NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NULL COMMENT 'uid', 
	`user_nick` varchar(128) NULL COMMENT 'unick', 
	`descript` varchar(512) NULL COMMENT '描述', 
	`tags` varchar(512) NULL COMMENT '标签集', 
	`multi_pic_path` varchar(512) NULL COMMENT '多图路径', 
	`multi_item_id` varchar(512) NULL COMMENT '多宝贝id', 
	PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '搭配数据';
CREATE TABLE if not exists agj_dapei_tag_dict (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NULL COMMENT '创建时间', 
	`gmt_modified` datetime NULL COMMENT '修改时间', 
	`name` varchar(128) NOT NULL COMMENT '标签名称', 
	PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '搭配标签字典';
CREATE TABLE if not exists agj_dict (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`dict_key` varchar(80) NOT NULL COMMENT '键', 
	`dict_value` varchar(500) NOT NULL COMMENT '值', 
	`status` int(11) DEFAULT '1' NOT NULL COMMENT '状态 0：可删除，1：正常', 
	`type` int(11) NOT NULL COMMENT '类型 1：手淘消息合并', 
	`dict_subkey` varchar(80) NOT NULL COMMENT '子键', 
	PRIMARY KEY (`id`), 
	KEY `idx_stauts` (`status`), 
	KEY `idx_key_type_subkey` (`dict_key`, `type`, `dict_subkey`)
)  AUTO_INCREMENT = 7708422 CHARSET = utf8 COMMENT = '爱逛街字典表';
CREATE TABLE if not exists agj_recall_source (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NULL COMMENT '创建时间', 
	`gmt_modified` datetime NULL COMMENT '修改时间', 
	`source_id` bigint(20) UNSIGNED NOT NULL COMMENT '泛Pid', 
	`pic_id` bigint(20) UNSIGNED NOT NULL COMMENT '图片主键id', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户id', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 5961589 CHARSET = utf8 COMMENT = '数据订正临时表';
CREATE TABLE if not exists agj_user_tag (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`user_nick` varchar(64) NOT NULL COMMENT '用户昵称', 
	`user_tag` varchar(128) NOT NULL COMMENT '用户标签', 
	`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '用户状态', 
	PRIMARY KEY (`id`), 
	KEY `idx_userid` (`user_id`)
)  CHARSET = utf8 COMMENT = '用户标签表';
CREATE TABLE if not exists agj_albums (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '专辑id/主键，全局序列产生', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`user_nick` varchar(64) NULL COMMENT '用户昵称，snsnick或uicnick', 
	`title` varchar(128) NULL COMMENT '专辑标题', 
	`cat_id` int(11) NULL COMMENT '前台分类id', 
	`album_from` tinyint(4) NULL COMMENT '来源标志', 
	`tags` varchar(128) NULL COMMENT '专辑标签', 
	`status` tinyint(4) NULL COMMENT '状态', 
	`attributes` varchar(512) NULL COMMENT '属性扩展字段kv结构', 
	`recent_used_time` datetime NULL COMMENT '业务使用时间', 
	`seq_no` int(11) NULL COMMENT '分表、预留字段', 
	`description` varchar(512) NULL COMMENT '描述', 
	PRIMARY KEY (`id`), 
	KEY `idx_uid_status_time` (`user_id`, `status`, `recent_used_time`)
)  CHARSET = utf8 COMMENT = '专辑表0';
CREATE TABLE if not exists agj_group (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`group_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段，需要全局唯一', 
	`type` tinyint(4) NULL COMMENT '群类型，0，正常 1，达人导入', 
	`background` varchar(256) NULL COMMENT '群背景图片url，相对地址', 
	`status` tinyint(4) NULL COMMENT '状态，0：待审核，1：审核通过，2：审核不通过 ，3：删除', 
	`attributes` varchar(1024) NULL COMMENT '扩展属性', 
	`creator_id` bigint(20) UNSIGNED NULL COMMENT '创建者用户id', 
	`style` tinyint(4) NULL COMMENT '风格', 
	`group_name` varchar(128) NULL COMMENT '群名称', 
	PRIMARY KEY (`id`), 
	KEY `idx_group` (`group_id`)
)  AUTO_INCREMENT = 5 CHARSET = utf8 COMMENT = '群表信息';
CREATE TABLE if not exists agj_image_anchor (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`image_id` bigint(20) UNSIGNED NOT NULL COMMENT '图片ID', 
	`x_axis` varchar(20) NOT NULL COMMENT 'x轴', 
	`y_axis` varchar(20) NOT NULL COMMENT 'y轴', 
	`title` varchar(118) NULL COMMENT '锚点标题', 
	`direction` tinyint(4) NULL COMMENT '标题方向', 
	`attributes` varchar(1024) NULL COMMENT '扩展字段', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 4557824160 CHARSET = utf8 COMMENT = '图片锚点元数据';
CREATE TABLE if not exists agj_relation_album (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`album_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`target_id` bigint(20) UNSIGNED NOT NULL COMMENT '关系对象id，泛p/用户id', 
	`target_type` tinyint(4) NOT NULL COMMENT '1:泛p，3，用户', 
	`target_user_id` bigint(20) UNSIGNED NULL COMMENT '如果是泛p则表示拥有者id，如果是用户，则=target_id', 
	`action` tinyint(4) NULL COMMENT '关系的动作，3：被关注，4：资源被转采到', 
	`status` tinyint(4) DEFAULT '1' COMMENT '状态，0-删除 ，1-正常', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_aid_target_action` (`album_id`, `target_id`, `action`, `target_type`), 
	KEY `idx_aid_combo` (`album_id`, `status`, `action`, `target_type`)
)  AUTO_INCREMENT = 293862 CHARSET = utf8 COMMENT = '专辑维度出发的关系表';
CREATE TABLE if not exists agj_relation_group (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`group_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段，agj_group主键', 
	`type` tinyint(4) NULL COMMENT '关系对象类型，2:专辑，3：用户', 
	`target_id` bigint(20) UNSIGNED NULL COMMENT '产生关系端id,和type对应；专辑id或用户id', 
	`action` tinyint(4) NULL COMMENT '动作类型，1：创建，2：加入，3：关注', 
	`attributes` varchar(256) NULL COMMENT '扩展属性，非特殊情况不要写入', 
	`status` tinyint(4) NULL COMMENT '状态，1正常，0删除', 
	`target_user_id` bigint(20) UNSIGNED NULL COMMENT 'target_id的拥有者，如果是用户则为空', 
	PRIMARY KEY (`id`), 
	KEY `idx_group_action_type` (`group_id`, `type`, `action`, `gmt_modified`), 
	KEY `idx_group_target` (`target_id`, `type`, `group_id`, `action`)
)  AUTO_INCREMENT = 176 CHARSET = utf8 COMMENT = '群关系维度表.';
CREATE TABLE if not exists agj_relation_source (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`source_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`user_id` bigint(20) UNSIGNED NULL COMMENT '动作发出者用户id', 
	`album_id` bigint(20) UNSIGNED NULL COMMENT '专辑id', 
	`action` tinyint(4) NULL COMMENT '动作。2-被喜欢，4-被加入专辑，5-发布加专辑', 
	`status` tinyint(4) NULL COMMENT '状态 0删除 1正常', 
	`target_user_id` bigint(20) UNSIGNED NULL COMMENT '资源的拥有者id', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_sid_uid_action` (`user_id`, `source_id`, `album_id`, `action`), 
	KEY `idx_sid_status` (`source_id`, `status`, `gmt_modified`)
)  AUTO_INCREMENT = 636731 CHARSET = utf8 COMMENT = '泛p维度的关系表0';
CREATE TABLE if not exists agj_relation_users (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`action` tinyint(4) NULL COMMENT '动作', 
	`target_id` bigint(20) UNSIGNED NULL COMMENT '目标id', 
	`target_type` tinyint(4) NULL COMMENT '目标类型', 
	`status` tinyint(4) NULL COMMENT '状态', 
	`target_user_id` bigint(20) UNSIGNED NULL COMMENT '目标的拥有者', 
	`from_id` bigint(20) UNSIGNED NULL COMMENT '关系链上游id，未使用', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_uid_target_action` (`user_id`, `target_id`, `target_type`, `action`), 
	KEY `idx_uid_type` (`user_id`, `target_type`)
)  AUTO_INCREMENT = 623008 CHARSET = utf8 COMMENT = '用户维度关系表';
CREATE TABLE if not exists agj_source_goods (
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`image` varchar(200) NOT NULL COMMENT '图片', 
	`title` varchar(200) NOT NULL COMMENT '标题', 
	`attributes` varchar(1024) NULL COMMENT '扩展字段', 
	`category_id` bigint(20) UNSIGNED NOT NULL COMMENT '类目ID', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '卖家ID', 
	`price` varchar(20) NULL COMMENT '价格', 
	PRIMARY KEY (`item_id`)
)  CHARSET = utf8 COMMENT = '商品元数据表';
CREATE TABLE if not exists agj_source_image (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`url` varchar(200) NOT NULL COMMENT '图片地址', 
	`attributes` varchar(1024) NULL COMMENT '扩展属性', 
	`width` int(10) UNSIGNED NOT NULL COMMENT '宽', 
	`height` int(10) UNSIGNED NOT NULL COMMENT '高', 
	PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '泛P图片元数据表';
CREATE TABLE if not exists agj_source_items (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`source_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户id', 
	`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '商品id', 
	`description` varchar(512) NULL COMMENT '描述', 
	`tags` varchar(128) NULL COMMENT '标签', 
	`src_url` varchar(512) NULL COMMENT '来源url', 
	`attributes` varchar(512) NULL COMMENT '扩展属性字段', 
	`img_url` varchar(200) NULL COMMENT '图片url', 
	`title` varchar(128) NULL COMMENT '商品标题', 
	PRIMARY KEY (`id`), 
	KEY `ind_sourceid` (`source_id`)
)  AUTO_INCREMENT = 6839387 CHARSET = utf8 COMMENT = '泛p商品信息0';
CREATE TABLE if not exists agj_source_media (
	`id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`type` tinyint(4) NOT NULL COMMENT '多媒体类型', 
	`title` varchar(118) NULL COMMENT '多媒体标题', 
	`url` varchar(200) NOT NULL COMMENT '多媒体地址', 
	`attributes` varchar(1024) NULL COMMENT '扩展属性', 
	PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '多媒体元数据表';
CREATE TABLE if not exists agj_source_pictures (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`source_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`user_id` bigint(20) UNSIGNED NULL COMMENT '用户id', 
	`pic_path` varchar(200) NULL COMMENT '图片url', 
	`tags` varchar(128) NULL COMMENT '图片标签', 
	`description` varchar(256) NULL COMMENT '图片描述', 
	`width` int(11) NULL COMMENT '高度', 
	`height` int(11) NULL COMMENT '宽度', 
	`img_type` tinyint(4) NULL COMMENT '图片类型', 
	`src_url` varchar(200) NULL COMMENT '来源', 
	`cutted_pic_path` varchar(200) NULL COMMENT '裁剪后图片地址', 
	`item_id` bigint(20) UNSIGNED NULL COMMENT '导购商品id', 
	`attributes` varchar(512) NULL COMMENT '扩展字段kv结构', 
	`indexed` int(11) NULL COMMENT '排序字段', 
	`multi_pic_path` varchar(1024) NULL COMMENT '多图url集合', 
	`multi_item_id` varchar(200) NULL COMMENT '多宝贝集合', 
	`pic_type` tinyint(4) NULL COMMENT '类型，2(攻略)，3(搭配)', 
	PRIMARY KEY (`id`), 
	KEY `ind_sourceid` (`source_id`, `user_id`)
)  AUTO_INCREMENT = 2274686 CHARSET = utf8 COMMENT = '泛p图片信息0';
CREATE TABLE if not exists agj_sources (
	`source_id` bigint(20) UNSIGNED NOT NULL COMMENT '主键,全局序列', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`type` tinyint(4) NULL COMMENT '泛p类型：图片、商品', 
	`source_from` tinyint(4) NULL COMMENT '泛p来源', 
	`user_nick` varchar(64) NULL COMMENT 'snsnick或uicnick', 
	`status` tinyint(4) NULL COMMENT '状态', 
	`cat_id` int(11) NULL COMMENT '所属前台类目id', 
	`privacy` tinyint(4) NULL COMMENT '隐私字段', 
	`descript` varchar(512) NULL COMMENT '描述', 
	`tags` varchar(128) NULL COMMENT '标签', 
	`attributes` varchar(512) NULL COMMENT '属性扩展kv', 
	`seq_no` int(11) NULL COMMENT '分表序列 预留', 
	`structure` varchar(1024) NULL COMMENT '元数据结构体', 
	PRIMARY KEY (`source_id`), 
	KEY `idx_uid_stat_from` (`user_id`, `status`, `source_from`), 
	KEY `idx_uid_sid` (`user_id`, `source_id`, `gmt_create`)
)  CHARSET = utf8 COMMENT = '泛p主表-';
CREATE TABLE if not exists ifashion_content (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) NOT NULL COMMENT '用户（卖家）ID。只能为主账号ID，表示内容的所属者。', 
	`title` varchar(128) NULL COMMENT '标题', 
	`about` varchar(512) NULL COMMENT '描述', 
	`tag_names` varchar(512) NULL COMMENT '所有标签名字，逗号分隔', 
	`tag_ids` varchar(512) NULL COMMENT '所有标签ID，逗号分隔', 
	`content_scene` tinyint(4) NOT NULL COMMENT '内容场景，1-看图购，2-潮流志，3-人物动态，4-人物故事', 
	`category_names` varchar(128) NULL COMMENT '一级类目名称，逗号分隔', 
	`gender` tinyint(4) NULL COMMENT '性别，1-男，2-女，3-中性', 
	`status` tinyint(4) NOT NULL COMMENT '0：保存，1：待审核，1,2,4,6,7,8,11,56,68,89,435,4523：一审通过，101：二审通过，102：免审通过，-1,2,4,6,7,8,11,56,68,89,435,4523：一审拒绝，-101：二审拒绝，-1：小二删除，-4：卖家删除', 
	`reject_reason` varchar(64) NULL COMMENT '拒绝理由', 
	`delete_reason` varchar(64) NULL COMMENT '删除理由', 
	`operate_id` bigint(20) NULL COMMENT '最后一次操作者ID', 
	`operate_nick` varchar(64) NULL COMMENT '最后一次操作者NICK', 
	`attributes` varchar(512) NULL COMMENT '属性', 
	`content` varchar(1024) NULL COMMENT '富文本存储地址', 
	`main_category_id` bigint(20) NOT NULL COMMENT '卖家的主营类目ID，没有为0', 
	`store_type` tinyint(4) NULL COMMENT '存储方式 0：db，1 oss', 
	`category_ids` varchar(256) NULL COMMENT '内容相关商品所属 一级类目id，逗号分隔', 
	`leaf_categories` varchar(256) NULL COMMENT '叶子类目，类目id:类目名称，分号分隔', 
	`gmt_publish` datetime NULL COMMENT '发布者提交审核时间', 
	`gmt_verify` datetime NULL COMMENT '审核时间', 
	`shop_id` bigint(20) NULL COMMENT '店铺id', 
	`back_string` varchar(512) NULL COMMENT '备注', 
	`back_long` bigint(20) NULL COMMENT '备注', 
	`back_int` int(11) NULL COMMENT '备注', 
	`user_nick` varchar(64) NULL COMMENT '用户（卖家）NICK', 
	`check_xiaoer_id` bigint(20) NOT NULL COMMENT '内容所属的小二ID，与表ifashion_user_info中的卖家归属小二保持一致', 
	`pc_cover` varchar(256) NULL COMMENT '潮流志PC封面图', 
	`mobile_cover` varchar(256) NULL COMMENT '潮流志手淘封面图', 
	`publish_user_id` bigint(20) NULL COMMENT '内容实际发布者ID，可以为子账号ID或主账号ID。区别于字段user_id。', 
	PRIMARY KEY (`id`), 
	KEY `user_id_status_key` (`user_id`, `status`), 
	KEY `check_xiaoer_id_status_key` (`check_xiaoer_id`, `status`), 
	KEY `content_scene_status_key` (`content_scene`, `status`), 
	KEY `search_key` (`check_xiaoer_id`, `content_scene`, `status`, `gmt_publish`, `gmt_verify`)
)  AUTO_INCREMENT = 11947 CHARSET = utf8 COMMENT = 'ifashion发布内容表';
CREATE TABLE if not exists ifashion_privilege (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`title` varchar(32) NOT NULL COMMENT '权限名称', 
	`privilege` varchar(32) NOT NULL COMMENT '权限标识名', 
	`target_id` bigint(20) UNSIGNED NULL COMMENT '所属权限控制对象id', 
	`target` varchar(32) NOT NULL COMMENT '所属权限控制对象标识名', 
	`futures` varchar(1024) DEFAULT '{}' COMMENT '权限参数定义', 
	`status` tinyint(4) DEFAULT '0' COMMENT '状态', 
	`operator` varchar(256) NULL COMMENT '操作者', 
	PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = 'ifashion权限定义表';
CREATE TABLE if not exists ifashion_role (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`name` varchar(32) NOT NULL COMMENT '角色名称', 
	`type` varchar(32) NULL COMMENT '角色类型：管理员 发布者', 
	`status` tinyint(4) DEFAULT '0' COMMENT '状态：0待启用，1已启用，-1已停用', 
	`operator` varchar(32) NULL COMMENT '操作者', 
	PRIMARY KEY (`id`), 
	UNIQUE `rolename` (`name`)
)  AUTO_INCREMENT = 70 CHARSET = utf8 COMMENT = 'ifashion爱锋尚 角色表';
CREATE TABLE if not exists ifashion_role_privilege (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`role_id` bigint(20) UNSIGNED NOT NULL COMMENT '角色ID', 
	`privilege_id` bigint(20) UNSIGNED NULL COMMENT '权限ID', 
	`target_id` bigint(20) UNSIGNED NULL COMMENT '权限对象ID', 
	`target` varchar(32) NOT NULL COMMENT '权限对象标识名', 
	`privilege` varchar(32) NOT NULL COMMENT '权限标识名', 
	`futures` varchar(1024) NULL COMMENT '权限参数值', 
	`operator` varchar(32) NULL COMMENT '操作者', 
	`status` tinyint(4) DEFAULT '1' COMMENT '状态值，1有效', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 279 CHARSET = utf8 COMMENT = 'ifashion爱锋尚角色授权表';
CREATE TABLE if not exists ifashion_s_favor (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`targetkey` varchar(512) NOT NULL COMMENT '目标key', 
	`number` bigint(20) UNSIGNED NULL COMMENT '数量', 
	`usernum` bigint(20) UNSIGNED NULL COMMENT '用户数', 
	PRIMARY KEY (`id`), 
	KEY `targetkey` (`targetkey`)
)  AUTO_INCREMENT = 1055 CHARSET = utf8 COMMENT = 'ifashion用于导odps记录的表';
CREATE TABLE if not exists ifashion_scene (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`operator` varchar(32) NOT NULL COMMENT '操作者', 
	`store_type` tinyint(4) NOT NULL COMMENT '存储方式，0： db 1：oss', 
	`status` tinyint(4) NOT NULL COMMENT '状态', 
	`content_rule` varchar(1024) NOT NULL COMMENT '内容规则定义', 
	`name` varchar(128) NULL COMMENT '场景名称', 
	`about` varchar(256) NOT NULL COMMENT '介绍', 
	`privilege_key` varchar(32) NULL COMMENT '权限实体key', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 5 CHARSET = utf8 COMMENT = 'ifashion 内容场景';
CREATE TABLE if not exists ifashion_tag_type (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`name` varchar(64) NOT NULL COMMENT '名称', 
	`categories` varchar(256) NULL COMMENT '一级类目ID，用逗号分隔', 
	`is_user_defined` tinyint(4) NOT NULL COMMENT '发布者是否可以加入自定义标签，0-不支持，1-支持', 
	`content_scenes` varchar(256) NULL COMMENT '内容类型ID，用逗号分隔。1-看图购，2-潮流志，3-人物动态，4-人物故事', 
	`sort` int(11) NOT NULL COMMENT '排序', 
	`type` tinyint(4) NOT NULL COMMENT '类型。0-普通标签，小二管理。1-性别标签。2-一级类目标签。3-叶子类目标签。', 
	`select_min` int(11) NOT NULL COMMENT '可选数量下限，包含关系。例如取值1，表示最少要选取1个标签值。', 
	`select_max` int(11) NOT NULL COMMENT '可选数量上限，包含关系。例如取值3，表示最多可以选择3个标签值。', 
	`status` tinyint(4) NOT NULL COMMENT '状态，0-已停用，1-已启用', 
	`ref_count` varchar(256) NULL COMMENT '被内容使用的次数。格式：内容类型ID，使用次数；内容类型ID，使用次数；', 
	`attributes` varchar(1024) NULL COMMENT '属性', 
	`back_string` varchar(512) NULL COMMENT '备注', 
	`back_long` bigint(20) NULL COMMENT '备注', 
	`back_int` int(11) NULL COMMENT '备注', 
	`operate_id` bigint(20) NULL COMMENT '操作者ID，如果是系统则为0', 
	`operate_nick` varchar(128) NULL COMMENT '操作者NICK', 
	PRIMARY KEY (`id`), 
	KEY `id_stattus_key` (`id`, `status`), 
	KEY `name_status_key` (`name`, `status`), 
	KEY `status_key` (`status`)
)  AUTO_INCREMENT = 46 CHARSET = utf8 COMMENT = 'ifashion标签类型表';
CREATE TABLE if not exists ifashion_tag_value (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`name` varchar(64) NOT NULL COMMENT '名称', 
	`tag_type_id` bigint(20) NOT NULL COMMENT '标签类型ID，ifashion_tag_type中的主键', 
	`status` tinyint(4) NOT NULL COMMENT '状态。0-已停用，1-已启用。', 
	`categories` varchar(256) NULL COMMENT '一级类目ID，逗号分隔。', 
	`content_scenes` varchar(256) NULL COMMENT '内容类型ID，用逗号分隔。1-看图购，2-潮流志，3-人物动态，4-人物故事', 
	`ref_count` varchar(256) NULL COMMENT '被内容使用的次数。格式：内容类型ID，使用次数；内容类型ID，使用次数；', 
	`attributes` varchar(1024) NULL COMMENT '属性', 
	`back_string` varchar(512) NULL COMMENT '备注', 
	`back_long` bigint(20) NULL COMMENT '备注', 
	`back_int` int(11) NULL COMMENT '备注', 
	`operate_id` bigint(20) NULL COMMENT '操作者ID，如果是系统操作则为0', 
	`operate_nick` varchar(128) NULL COMMENT '操作者NICK', 
	`tag_type_name` varchar(64) NOT NULL COMMENT '标签类型name', 
	PRIMARY KEY (`id`), 
	KEY `id_status_key` (`id`, `status`), 
	KEY `tag_type_id_status_key` (`tag_type_id`, `status`), 
	KEY `tag_type_name_status_key` (`tag_type_name`, `status`), 
	KEY `status_key` (`status`)
)  AUTO_INCREMENT = 361 CHARSET = utf8 COMMENT = 'ifashion标签值标';
CREATE TABLE if not exists ifashion_user_info (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) NOT NULL COMMENT '登录时的user_id', 
	`user_nick` varchar(128) NOT NULL COMMENT '登录时的user_nick', 
	`my_nick` varchar(128) NULL COMMENT '个人主页设置的nick', 
	`my_head_pic` varchar(1024) NULL COMMENT '个人主页设置的头像', 
	`about` varchar(1024) NULL COMMENT '个人说明', 
	`is_xiaoer` tinyint(4) NOT NULL COMMENT '0-用户是小二，1-用户不是小二', 
	`role_id` bigint(20) NOT NULL COMMENT '角色ID，ifashion_role表的主键', 
	`role_name` varchar(128) NOT NULL COMMENT '角色名称', 
	`role_type` tinyint(4) NOT NULL COMMENT '角色类型，0-管理员，1-发布者', 
	`kantugou_num` bigint(20) NULL COMMENT '有效的看图购数目', 
	`chaoliuzhi_num` bigint(20) NULL COMMENT '有效的潮流志数目', 
	`renwudongtai_num` bigint(20) NULL COMMENT '有效的人物动态数目', 
	`renwugushi_num` bigint(20) NULL COMMENT '有效的人物故事数目', 
	`attributes` varchar(1024) NULL COMMENT '属性', 
	`back_string` varchar(512) NULL COMMENT '备注', 
	`back_long` bigint(20) NULL COMMENT '备注', 
	`back_int` int(11) NULL COMMENT '备注', 
	`status` tinyint(4) NOT NULL COMMENT '状态。0-已停用，1-已启用。', 
	`operate_id` bigint(20) NULL COMMENT '操作者ID，如果是系统操作则为0', 
	`operate_nick` varchar(128) NULL COMMENT '操作者NICK', 
	`kantugou_day_num` bigint(20) NULL COMMENT '当天发布的看图购数目（所有）', 
	`chaoliuzhi_day_num` bigint(20) NULL COMMENT '当天发布的潮流志数目（所有）', 
	`renwudongtai_day_num` bigint(20) NULL COMMENT '当天发布的所有人物动态数目', 
	`renwugushi_day_num` bigint(20) NULL COMMENT '当天发布的所有人物故事数目', 
	`renwugushi_id` bigint(20) NULL COMMENT '人物故事ID，ifashion_content表的主键', 
	PRIMARY KEY (`id`), 
	KEY `id_status_key` (`id`, `status`), 
	KEY `user_id_status_key` (`user_id`, `status`), 
	KEY `role_type_status_key` (`role_type`, `status`), 
	KEY `role_id_status_key` (`role_id`, `status`), 
	KEY `status_key` (`status`)
)  AUTO_INCREMENT = 2954 CHARSET = utf8 COMMENT = 'ifashion用户信息表';
CREATE TABLE if not exists sequence (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT 'id', 
	`name` varchar(255) NULL COMMENT 'name', 
	`value` bigint(20) NULL COMMENT 'value', 
	`gmt_modified` datetime NULL COMMENT 'modified', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 4 CHARSET = utf8 COMMENT = '唯一序列生成器';
CREATE TABLE if not exists push_message_record (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`push_content` varchar(200) NOT NULL COMMENT '内容', 
	`push_title` varchar(80) NOT NULL COMMENT '标题', 
	`push_desc` varchar(200) NOT NULL COMMENT '简介', 
	`operator` varchar(50) NOT NULL COMMENT '操作者', 
	`status` int(11) NOT NULL COMMENT '状态，1 未发送， 2 发送中，3：发送完成，0 删除', 
	`push_time` varchar(50) NULL COMMENT '发送时间，一次性：yyyyMMdd HH:mm', 
	`type` int(11) NOT NULL COMMENT '类型，1 一次性，2 周期性', 
	`send_start_time` datetime NULL COMMENT '发送开始时间', 
	`send_end_time` datetime NULL COMMENT '发送结束时间', 
	`action_url` varchar(118) NULL COMMENT '跳转url', 
	PRIMARY KEY (`id`), 
	KEY `idx_time_operator_sts` (`status`, `gmt_create`, `operator`)
)  AUTO_INCREMENT = 9 CHARSET = utf8 COMMENT = 'push 消息记录';

SELECT DISTINCT target_id, target_user_id FROM agj_relation_group a WHERE status = 1 AND group_id = 1 AND type = 1 AND action = 1 ORDER BY a.id DESC LIMIT 1, 1;
SELECT id, album_id, target_id, target_type, action , status, target_user_id, gmt_create, gmt_modified FROM agj_relation_album WHERE album_id = 1 AND target_id = 1 AND target_type = 1 AND action = 1;
SELECT COUNT(1) FROM agj_relation_group WHERE group_id = 1 AND type = 1 AND target_id = 1 AND action = 1 AND status = 1;
SELECT id, group_id, action, target_id, type , status, target_user_id, attributes, gmt_create, gmt_modified FROM agj_relation_group WHERE group_id = 1 AND type = 1 AND status = 1 AND action = 1 ORDER BY gmt_modified DESC;
SELECT id, dict_key, dict_subkey, dict_value, type , status, gmt_create, gmt_modified FROM agj_dict WHERE status = 1 AND dict_key = "3" AND type = 1 LIMIT 1, 1;
SELECT a.id, user_id, action, target_id, target_type , status, target_user_id, from_id, gmt_create, gmt_modified FROM agj_relation_users a, (SELECT id FROM agj_relation_users WHERE user_id = 1 AND target_type = 1 AND target_id = 1 AND action = 1 ORDER BY id DESC LIMIT 1, 1 ) b WHERE a.id = b.id;
SELECT source_id FROM agj_sources WHERE user_id = 1 AND status = 1 AND type = 1 AND gmt_modified >= date_sub(now(), INTERVAL 1 MONTH) AND gmt_modified <= now() ORDER BY source_id DESC;
SELECT id, user_id, user_nick, title, cat_id , album_from, description, tags, status, attributes , gmt_create, gmt_modified, recent_used_time FROM agj_albums WHERE status IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND user_id = 1 ORDER BY recent_used_time DESC LIMIT 1;
SELECT DISTINCT target_id FROM agj_relation_group WHERE group_id = 1 AND type = 1 AND status = 1 AND action = 1 ORDER BY gmt_modified DESC;
SELECT a.id, user_id, action, target_id, target_type , status, target_user_id, from_id, gmt_create, gmt_modified FROM agj_relation_users a, (SELECT id FROM agj_relation_users WHERE user_id = 1 AND target_type = 1 AND status = 1 AND target_id = 1 AND action = 1 ORDER BY id DESC LIMIT 1, 1 ) b WHERE a.id = b.id;
