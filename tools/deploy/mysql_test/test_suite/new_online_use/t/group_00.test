--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt 
#owner group:sql1 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists `group_activity` (  `id` bigint(20) NOT NULL AUTO_INCREMENT,  `thread_id` bigint(20) NOT NULL,  `group_id` bigint(20) NOT NULL,  `start_time` datetime NOT NULL COMMENT '活动开始时间',  `end_time` datetime NOT NULL COMMENT '活动截止时间',  `toplimit` int(11) NOT NULL COMMENT '活动人数上限',  `tag` varchar(118) DEFAULT NULL COMMENT '活动的标签',  `options` bigint(20) unsigned NOT NULL COMMENT '第1位：仅本帮成员可以参加第2位：仅实名认证用户可以参加第3位：参加报名需要提供电话',  `logo_url` varchar(200) DEFAULT NULL COMMENT '活动logo url',  `gmt_create` datetime NOT NULL,  `gmt_modified` datetime NOT NULL,  `activity_type` smallint(6) NOT NULL COMMENT '3 促销打折 4 店铺买家秀5 商品团购 6 免费试用 7线下聚会 8 同城交友 9 团队建设',  `expense` int(10) unsigned DEFAULT NULL COMMENT '每人花费的费用。转换成分存储',  `joined_user_count` int(11) NOT NULL COMMENT '已经加入活动人数',  `number_1` bigint(20) DEFAULT NULL,  `char_1` varchar(256) DEFAULT NULL,  PRIMARY KEY (`id`),  KEY `idx_group_act_tid` (`thread_id`,`joined_user_count`,`toplimit`) USING BTREE,  KEY `idx_gmt_create` (`gmt_create`)) AUTO_INCREMENT=19316 DEFAULT CHARSET=utf8;
CREATE TABLE if not exists group_activity_user (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`thread_id` bigint(20) NOT NULL, 
	`user_id` bigint(20) NOT NULL, 
	`group_id` bigint(20) NULL, 
	`user_nick` varchar(32) NULL, 
	`phone_num` varchar(20) NULL COMMENT '电话号码', 
	`status` tinyint(4) UNSIGNED NOT NULL COMMENT '1.已参加（直接参加或者审核已通过）n2.拒绝(审核没通过)n3.退出（用户主动退出活动，或者取消报名）n', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`number_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	PRIMARY KEY (`id`), 
	UNIQUE `idx_group_act_utid` USING BTREE (`user_id`, `thread_id`), 
	KEY `idx_group_act_tgsid` USING BTREE (`thread_id`, `gmt_modified`, `status`)
)  AUTO_INCREMENT = 210984 CHARSET = utf8;
CREATE TABLE if not exists group_catalog (
	`id` bigint(20) UNSIGNED NOT NULL, 
	`channel_id` bigint(20) NOT NULL, 
	`name` varchar(50) NOT NULL, 
	`official` tinyint(4) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`options` bigint(20) NULL COMMENT '标记位。第一位如果是：0：在聚合页面显示，１在聚合页面不显示', 
	`char_1` varchar(256) NULL, 
	`group_id` bigint(20) NULL, 
	`weight` int(11) NULL COMMENT '类目的权限', 
	`catalog_type` tinyint(4) NULL, 
	`group_count` int(11) NULL, 
	`deleted` tinyint(4) NULL COMMENT '删除标识位；0：正常，1：已删除', 
	PRIMARY KEY (`id`), 
	KEY `name` (`name`), 
	KEY `channel_id` (`channel_id`), 
	KEY `group_id` (`group_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_channel (
	`id` bigint(20) UNSIGNED NOT NULL, 
	`name` varchar(50) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`number_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	`channel_type` tinyint(4) NULL, 
	`weight` int(11) NULL, 
	`bg_img` varchar(1024) NULL COMMENT '类目背景图片地址', 
	`skin` varchar(50) NULL COMMENT '肤色样式', 
	PRIMARY KEY (`id`), 
	KEY `name` (`name`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_cheer_entry (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`group_id` bigint(20) UNSIGNED NOT NULL, 
	`thread_id` bigint(20) UNSIGNED NOT NULL COMMENT '帖子帮派', 
	`f_user_id` bigint(20) UNSIGNED NOT NULL COMMENT '帖子', 
	`f_user_nick` varchar(32) NOT NULL COMMENT '助威者 ', 
	`respect` int(11) NOT NULL COMMENT '威望点 ', 
	`comment` varchar(118) NOT NULL COMMENT '评论', 
	`thread_source` tinyint(3) UNSIGNED NOT NULL COMMENT '帖子来源', 
	`cheer_type` tinyint(3) UNSIGNED NOT NULL COMMENT '助威类型', 
	`t_user_id` bigint(20) UNSIGNED NOT NULL COMMENT '被助威者', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`char_1` varchar(256) NULL, 
	`num_1` bigint(20) UNSIGNED NULL, 
	PRIMARY KEY (`id`), 
	KEY `thread_id_gmt_create` USING BTREE (`thread_id`, `gmt_create`, `cheer_type`)
)  AUTO_INCREMENT = 124124693 CHARSET = utf8;
CREATE TABLE if not exists group_claw_name_value (
	`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`name` varchar(255) NOT NULL COMMENT '标识符 ', 
	`value` varchar(2048) NOT NULL COMMENT '值对象', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 347 CHARSET = utf8 COMMENT = '迁移表断点续传表';
CREATE TABLE if not exists group_group (
	`id` bigint(20) UNSIGNED NOT NULL, 
	`catalog_id` bigint(20) NOT NULL COMMENT '类目id', 
	`type` tinyint(4) NOT NULL COMMENT '帮派公开性设置,-1 类目的聚合圈子 0 公开 1 半公开 2 私密', 
	`status` tinyint(4) NOT NULL COMMENT '帮派状态：0 正常 1解散', 
	`name` varchar(50) NOT NULL COMMENT '帮派名字', 
	`logo_url` varchar(200) NULL COMMENT 'Logo链接地址', 
	`head_url` varchar(200) NULL COMMENT 'head链接地址', 
	`bulletin` varchar(100) NULL, 
	`tag` varchar(50) NULL COMMENT '标签', 
	`description` varchar(200) NULL COMMENT '描述', 
	`point` int(11) NOT NULL COMMENT '积分', 
	`member_count` int(11) NOT NULL COMMENT '成员数', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`number_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	`lz_stat_id` bigint(20) NULL, 
	`options` bigint(20) DEFAULT '0', 
	`ww_group_id` varchar(118) NULL COMMENT '旺旺群号', 
	`statistics_date` datetime NULL, 
	`recommendable` tinyint(4) NULL COMMENT ' 能否被推荐 0:可以被推荐 1：不能被推荐', 
	`hot` int(11) NULL COMMENT '类目下帮派的数量', 
	`verify` smallint(6) NULL COMMENT '审核状态(Null 无审核、0C级别待审核、1D级别待审核、2通过、3删除)', 
	`operator_id` bigint(20) NULL COMMENT '审核人的id', 
	`operator_time` datetime NULL COMMENT '操作时间', 
	PRIMARY KEY (`id`), 
	KEY `name` (`name`), 
	KEY `gmt_modified` (`gmt_modified`), 
	KEY `catalog_id1` (`catalog_id`, `status`, `hot`, `type`, `id`), 
	KEY `statistics_date` (`statistics_date`, `status`, `type`), 
	KEY `idx_status` (`status`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_group_authentication (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '申请id', 
	`group_id` bigint(20) UNSIGNED NOT NULL COMMENT '申请帮派id', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '申请人id', 
	`user_nick` varchar(32) NOT NULL COMMENT '申请人昵称', 
	`custom_url` varchar(512) NULL COMMENT '业务线链接', 
	`custom_name` varchar(60) NOT NULL COMMENT '自定义名称', 
	`reason` varchar(512) NULL COMMENT '拒绝原因', 
	`description` varchar(512) NOT NULL COMMENT '自定义说明', 
	`status` tinyint(4) UNSIGNED NOT NULL COMMENT '申请状态', 
	`auth_type` tinyint(4) UNSIGNED NOT NULL COMMENT '申请类型', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`deleted` tinyint(4) UNSIGNED NOT NULL COMMENT '是否删除', 
	`number_1` bigint(20) UNSIGNED NULL, 
	`char_1` varchar(256) NULL, 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_group_group_auth_gid` (`group_id`, `auth_type`), 
	KEY `idx_group_group_authentication_sta` (`status`, `auth_type`, `deleted`, `gmt_create`), 
	KEY `idx_group_group_authentication_unick` (`user_nick`, `gmt_create`)
)  AUTO_INCREMENT = 3187012 CHARSET = utf8;
CREATE TABLE if not exists group_group_blacklist (
	`id` bigint(20) NOT NULL, 
	`group_id` bigint(20) NOT NULL, 
	`user_id` bigint(20) NOT NULL, 
	`user_nick` varchar(32) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`number_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	PRIMARY KEY (`id`), 
	KEY `group_id` (`group_id`, `user_id`, `gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_group_board (
	`id` bigint(20) NOT NULL, 
	`group_id` bigint(20) NOT NULL, 
	`name` varchar(10) NOT NULL, 
	`sorts` bigint(20) NOT NULL, 
	`deleted` tinyint(4) NOT NULL, 
	`options` bigint(20) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`number_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	PRIMARY KEY (`id`), 
	KEY `group_id` (`group_id`, `deleted`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_group_collection (
	`user_id` bigint(20) NOT NULL COMMENT '用户id ', 
	`group_id` bigint(20) NOT NULL COMMENT '帮派id', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`num_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	`type` smallint(6) NULL, 
	PRIMARY KEY (`user_id`, `group_id`), 
	KEY `ind_uid_gmt` (`user_id`, `gmt_create`)
)  CHARSET = utf8 COMMENT = '帮派收藏';
CREATE TABLE if not exists group_group_hot_statistics (
	`group_id` bigint(20) NOT NULL COMMENT '帮派Id', 
	`statistics_date` datetime NOT NULL COMMENT '统计日期', 
	`group_hot` int(11) NOT NULL COMMENT '帮派热度', 
	`num_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	PRIMARY KEY (`group_id`, `statistics_date`), 
	KEY `statistics_date` (`statistics_date`, `group_hot`, `group_id`)
)  CHARSET = utf8 COMMENT = '帮派热度统计表';
CREATE TABLE if not exists group_group_show (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '展示id', 
	`group_id` bigint(20) UNSIGNED NOT NULL COMMENT '帮派id', 
	`content_type` tinyint(3) UNSIGNED NOT NULL COMMENT '展示类型（文本、Flash、视频等）', 
	`module_id` bigint(20) UNSIGNED NOT NULL COMMENT '展示模块（页头、公告等）', 
	`adboard_id` bigint(20) UNSIGNED NULL COMMENT 'Flash对应ID', 
	`show_url` varchar(1024) NOT NULL COMMENT '展示地址', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '更新时间', 
	`char_1` varchar(1024) NULL, 
	`num_1` bigint(20) UNSIGNED NULL, 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户id ', 
	`user_nick` varchar(32) NOT NULL COMMENT '用户昵称', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_group_group_show` (`group_id`, `content_type`, `module_id`)
)  AUTO_INCREMENT = 474 CHARSET = utf8 COMMENT = '帮派展示表';
CREATE TABLE if not exists group_group_thread (
	`id` bigint(20) NOT NULL, 
	`group_id` bigint(20) NOT NULL COMMENT '帮派id', 
	`board_id` bigint(20) DEFAULT '0' NOT NULL COMMENT '版面id', 
	`subject` varchar(50) NOT NULL COMMENT '帖子标题', 
	`type` tinyint(4) NOT NULL COMMENT '0 普通 1 置顶', 
	`status` tinyint(4) NOT NULL COMMENT '0 普通  1 主贴锁定  2 主题锁定', 
	`digest` tinyint(4) NOT NULL COMMENT '0 普通 1 精华', 
	`options` bigint(20) NOT NULL, 
	`deleted` tinyint(4) NOT NULL COMMENT '0 正常  1 删除', 
	`view_count` int(11) NOT NULL COMMENT '浏览数', 
	`reply_count` int(11) NOT NULL COMMENT '回答数', 
	`author_id` bigint(20) NOT NULL COMMENT '作者id', 
	`author_nick` varchar(32) NOT NULL COMMENT '作者nick', 
	`author_ip` varchar(16) NOT NULL COMMENT '作者ip', 
	`last_reply_author_id` bigint(20) NULL COMMENT '最后回复者id', 
	`last_reply_author_nick` varchar(32) NULL COMMENT '最后回复者nick', 
	`last_reply_id` bigint(20) NULL COMMENT '最后回复id', 
	`last_reply_time` datetime NULL COMMENT '最后回复时间', 
	`last_modified` datetime NULL COMMENT '帖子（标题、内容）最后修改时间', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`number_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	`category` tinyint(4) NULL, 
	`verify` smallint(6) NULL COMMENT '审核状态(Null 无审核、0C级别待审核、1D级别待审核、2通过、3删除)', 
	`operator_id` bigint(20) NULL COMMENT '审核人的id', 
	`operator_time` datetime NULL COMMENT '操作时间', 
	`rated_respect` int(11) NULL COMMENT '被评价的分数', 
	PRIMARY KEY (`id`), 
	KEY `author_nick` (`author_nick`), 
	KEY `gmt_modified` (`gmt_modified`), 
	KEY `group_id_reply_time` (`group_id`, `type`, `last_reply_time`, `deleted`, `digest`, `board_id`, `category`, `verify`), 
	KEY `group_id_gmt_create` (`group_id`, `type`, `gmt_create`, `deleted`, `digest`, `board_id`, `verify`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_group_user (
	`group_id` bigint(20) NOT NULL COMMENT '帮派id', 
	`user_id` bigint(20) NOT NULL COMMENT '申请人id', 
	`user_nick` varchar(32) NOT NULL COMMENT '申请人nick', 
	`role_id` tinyint(4) NOT NULL COMMENT '角色', 
	`status` tinyint(4) NOT NULL, 
	`message` varchar(50) NULL COMMENT '留言信息', 
	`join_time` datetime NULL COMMENT '加入帮派的时间', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`number_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	`deleted` int(10) UNSIGNED DEFAULT '0' NOT NULL COMMENT '0是正常，1是被删除', 
	`inviter_id` bigint(20) UNSIGNED NULL COMMENT '记录下邀请人id', 
	`last_visit_time` datetime NULL COMMENT '用户最后访问某个帮派的时间', 
	PRIMARY KEY (`user_id`, `group_id`), 
	KEY `user_nick` (`user_nick`), 
	KEY `group_id` (`group_id`, `status`, `join_time`, `role_id`, `deleted`), 
	KEY `idx_ggu_gid` (`group_id`, `status`, `last_visit_time`, `role_id`, `deleted`), 
	KEY `idx_status` (`status`), 
	KEY `idx_group_id_role_id` (`group_id`, `role_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_group_white_name (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户数字ID', 
	`deleted` tinyint(3) UNSIGNED DEFAULT '0' NOT NULL COMMENT '0 正常  1 删除', 
	PRIMARY KEY (`id`), 
	UNIQUE `user_id` (`user_id`), 
	KEY `idx_deleted_gmt_modified` (`deleted`, `gmt_modified`)
)  AUTO_INCREMENT = 10 CHARSET = utf8 COMMENT = '特殊用户白名单，允许表中用户创建帮派、发帖、回帖';
CREATE TABLE if not exists group_ids (
	`id` bigint(20) NULL COMMENT 'id', 
	`type` varchar(118) NOT NULL COMMENT '某类型', 
	`gmt_modified` datetime NULL, 
	PRIMARY KEY (`type`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_invitation (
	`id` bigint(20) NOT NULL, 
	`group_id` bigint(20) NOT NULL, 
	`invitee_id` bigint(20) NOT NULL, 
	`invitee_nick` varchar(32) NOT NULL, 
	`status` tinyint(4) NOT NULL, 
	`inviter_id` bigint(20) NOT NULL, 
	`inviter_nick` varchar(32) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`number_1` bigint(20) NULL, 
	`number_2` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	`char_2` varchar(256) NULL, 
	PRIMARY KEY (`id`), 
	KEY `group_id` (`group_id`, `gmt_modified`, `inviter_id`, `status`), 
	KEY `invitee_id` (`invitee_id`, `group_id`, `gmt_create`, `status`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_invitation_link_extend (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`group_id` bigint(20) UNSIGNED NOT NULL COMMENT '帮派id', 
	`invite_id` bigint(20) UNSIGNED NOT NULL COMMENT '链接邀请id', 
	`day_user_count` int(10) UNSIGNED NULL COMMENT '一天接受邀请的人数', 
	`last_accept_time` datetime NULL COMMENT '最后接受邀请的时间', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`number_1` bigint(20) UNSIGNED NULL, 
	`char_1` varchar(256) NULL, 
	PRIMARY KEY (`id`), 
	KEY `invite_id` (`invite_id`)
)  AUTO_INCREMENT = 17507 CHARSET = utf8 COMMENT = '链接邀请扩展表';
CREATE TABLE if not exists group_invitation_record (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`group_id` bigint(20) UNSIGNED NOT NULL COMMENT '帮派id', 
	`invite_id` bigint(20) UNSIGNED NOT NULL COMMENT '邀请id ', 
	`inviter_id` bigint(20) UNSIGNED NOT NULL COMMENT '邀请人id', 
	`inviter_nick` varchar(32) NOT NULL COMMENT '邀请人nick', 
	`invitee_id` bigint(20) UNSIGNED NULL COMMENT '被邀请人id，如果非淘宝用户则留空', 
	`invitee` varchar(118) NULL COMMENT '被邀请人 链接邀请：空 旺旺邀请：nick ', 
	`invite_type` tinyint(3) UNSIGNED NOT NULL COMMENT '邀请类型：1. 链接邀请 2. 旺旺邀请 ', 
	`invite_user_count` int(10) UNSIGNED NOT NULL COMMENT '成功邀请人数', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`number_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_group_invitation_record_invite_id` (`invite_id`), 
	KEY `ivterid_gid_type_gmtcreate` (`inviter_id`, `group_id`, `invite_type`, `gmt_create`)
)  AUTO_INCREMENT = 262402 CHARSET = utf8 COMMENT = '邀请记录表';
CREATE TABLE if not exists group_operation_log (
	`id` bigint(20) NOT NULL, 
	`group_id` bigint(20) NOT NULL COMMENT '帮派id，0表示后台小二', 
	`user_id` bigint(20) NOT NULL COMMENT '操作人id', 
	`user_nick` varchar(32) NOT NULL COMMENT '操作人nick', 
	`target_id` bigint(20) NULL, 
	`target_name` varchar(32) NULL, 
	`target_user_id` bigint(20) NULL, 
	`target_user_nick` varchar(32) NULL, 
	`op_type` smallint(6) NOT NULL COMMENT '操作类型', 
	`op_comment` varchar(118) NULL COMMENT '操作注释', 
	`gmt_create` datetime NOT NULL, 
	`number_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	PRIMARY KEY (`id`), 
	KEY `group_id` (`group_id`, `gmt_create`, `target_user_id`, `user_id`, `op_type`), 
	KEY `target_user_id` (`target_user_id`, `group_id`, `gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_shop_binding (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`group_id` bigint(20) UNSIGNED NOT NULL COMMENT '帮派ID', 
	`shop_id` bigint(20) UNSIGNED NOT NULL COMMENT '店铺ID', 
	`thread_count` tinyint(4) UNSIGNED NOT NULL COMMENT '显示帖子数', 
	`activity_count` tinyint(4) UNSIGNED NOT NULL COMMENT '显示活动数量', 
	`digest_prior` tinyint(4) UNSIGNED DEFAULT '0' NOT NULL COMMENT '精华优先', 
	`top_prior` tinyint(4) UNSIGNED DEFAULT '0' NOT NULL COMMENT '置顶优先', 
	`number_1` bigint(20) UNSIGNED NULL COMMENT '备用字段', 
	`char_1` varchar(256) NULL COMMENT '备用字段', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_group_shop_binding_gid` (`group_id`), 
	UNIQUE `uk_group_shop_binding_sid` (`shop_id`), 
	KEY `idx_group_shop_binding_gmod` (`gmt_modified`)
)  AUTO_INCREMENT = 2377526 CHARSET = utf8 COMMENT = '帮派和店铺绑定表';
CREATE TABLE if not exists group_thread_body (
	`thread_id` bigint(20) NOT NULL, 
	`group_id` bigint(20) NOT NULL, 
	`content`varchar(100)NOT NULL, 
	`number_1` bigint(20) NULL, 
	`reply` varchar(100) NULL COMMENT '小二回复', 
	`reply_time` datetime NULL COMMENT '小二回复时间', 
	`content_flag` tinyint(3) UNSIGNED NULL COMMENT '区分是content_ext存放的是帖子内容还是帖子内容对应的TFS的KEY', 
	`content_ext` varchar(100) NULL, 
	PRIMARY KEY (`thread_id`), 
	KEY `idx_body_replytime` (`reply_time`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_thread_collection (
	`user_id` bigint(20) NOT NULL COMMENT '用户id ', 
	`thread_id` bigint(20) NOT NULL COMMENT '帖子id', 
	`group_id` bigint(20) NOT NULL COMMENT '帮派id', 
	`type` smallint(6) NOT NULL COMMENT '帖子标示，类型信息', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`num_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	PRIMARY KEY (`user_id`, `thread_id`), 
	KEY `ind_uid_gmt_type` USING BTREE (`user_id`, `gmt_create`, `type`)
)  CHARSET = utf8 COMMENT = '帖子收藏';
CREATE TABLE if not exists group_thread_hot_statistics (
	`thread_id` bigint(20) NOT NULL, 
	`statistics_date` datetime NOT NULL, 
	`thread_hot` int(11) NOT NULL, 
	`group_id` bigint(20) NULL, 
	PRIMARY KEY (`thread_id`, `statistics_date`), 
	KEY `statistics_date` (`statistics_date`, `thread_hot`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_thread_pic (
	`pic_id` bigint(20) NOT NULL COMMENT '从相册传递过来的图片id，PK', 
	`uuid` varchar(32) NOT NULL COMMENT '唯一标识，长度32个字符(数字和字母组成)', 
	`thread_id` bigint(20) NULL COMMENT '帖子id ', 
	`group_id` bigint(20) NOT NULL COMMENT '帮派id', 
	`reply_id` bigint(20) NULL COMMENT '帮派id', 
	`floor` bigint(20) NULL COMMENT '楼层 ', 
	`status` tinyint(4) NOT NULL COMMENT '是否在帖子中 0不在，1在 ', 
	`prohibited` tinyint(4) NOT NULL COMMENT '是否违禁       0正常，1 违禁', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`number_1` bigint(20) NULL COMMENT '备用字段，数字型 ', 
	`char_1` varchar(256) NULL COMMENT '备用字段，字符串 ', 
	PRIMARY KEY (`pic_id`), 
	KEY `uuid` (`uuid`, `group_id`), 
	KEY `thread_id` (`thread_id`)
)  CHARSET = utf8 COMMENT = '帖子内容与图片对应关系表';
CREATE TABLE if not exists group_thread_reply (
	`id` bigint(20) UNSIGNED NOT NULL, 
	`thread_id` bigint(20) NOT NULL COMMENT '所属帖子id', 
	`group_id` bigint(20) NOT NULL COMMENT '帮派id', 
	`deleted` tinyint(4) NOT NULL COMMENT '0 正常  1 删除', 
	`author_id` bigint(20) NOT NULL COMMENT '作者id', 
	`author_nick` varchar(32) NOT NULL COMMENT '作者nick', 
	`author_ip` varchar(16) NOT NULL COMMENT '作者ip', 
	`content`varchar(100)NOT NULL COMMENT '恢复内容', 
	`last_modified` datetime NULL COMMENT '帖子最后修改', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`number_1` bigint(20) NULL, 
	`reply` varchar(256) NULL COMMENT '小二回复', 
	`floor` int(11) DEFAULT '0' NOT NULL, 
	`reply_time` datetime NULL COMMENT '小二回复时间', 
	`verify` smallint(6) NULL COMMENT '审核状态(Null 无审核、0C级别待审核、1D级别待审核、2通过、3删除)', 
	`operator_id` bigint(20) NULL COMMENT '审核人的id', 
	`operator_time` datetime NULL COMMENT '操作时间', 
	`rated_respect` int(11) NULL COMMENT '被评价的分数', 
	`options` bigint(20) NULL, 
	`content_flag` tinyint(3) UNSIGNED NULL COMMENT '区分是content_ext存放的是帖子内容还是帖子内容对应的TFS的KEY', 
	`content_ext` varchar(100) NULL, 
	`char_1` varchar(256) NULL, 
	`number_2` bigint(20) NULL, 
	`number_3` bigint(20) NULL, 
	`sticky` tinyint(4) DEFAULT '0' COMMENT '0 普通 1 置顶(默认值是0)', 
	`sticky_author_id` bigint(20) NULL COMMENT '回复顶置者ID', 
	`sticky_author_nick` varchar(32) NULL COMMENT '回复顶置者nick', 
	`sticky_time` datetime NULL COMMENT '回复顶置时间', 
	PRIMARY KEY (`id`), 
	KEY `IDX_group_reply_modified` (`gmt_modified`), 
	KEY `thread_id` (`thread_id`, `gmt_create`, `floor`, `author_id`, `deleted`), 
	KEY `author_id` (`author_id`, `thread_id`, `deleted`, `gmt_create`), 
	KEY `idx_tid_sticky_delete_time` (`thread_id`, `sticky`, `deleted`, `sticky_time`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_user (
	`user_id` bigint(20) NOT NULL, 
	`user_nick` varchar(32) NOT NULL, 
	`point` int(11) NOT NULL COMMENT '积分', 
	`point_day` datetime NULL COMMENT '记分时间戳', 
	`point_thread` int(11) DEFAULT '0' NOT NULL COMMENT '当天的已发帖数', 
	`point_reply` int(11) DEFAULT '0' NOT NULL COMMENT '当天的已回帖数', 
	`thread_count` int(11) DEFAULT '0' NOT NULL COMMENT '发贴总数', 
	`digest_thread_count` int(11) DEFAULT '0' NOT NULL COMMENT '精华贴总数', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`number_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	`respect` int(11) NULL COMMENT '威望', 
	`coin` int(11) NULL COMMENT '社区币', 
	`contribution` int(11) NULL COMMENT '贡献值', 
	`applied_count_day` smallint(6) NULL COMMENT '每天申请的活动数量', 
	PRIMARY KEY (`user_id`), 
	KEY `IDX_group_user_modified` (`gmt_modified`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_user_role (
	`user_id` bigint(20) NOT NULL COMMENT '用户id', 
	`user_nick` varchar(32) NOT NULL COMMENT '用户nick', 
	`group_id` bigint(20) NOT NULL COMMENT '帮派id', 
	`role_id` int(11) NOT NULL COMMENT '角色id，无对应表', 
	`number_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	`deleted` int(10) UNSIGNED DEFAULT '0' NOT NULL COMMENT '0是正常，1是被删除', 
	PRIMARY KEY (`user_id`, `group_id`), 
	KEY `idx_delete` (`deleted`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_vote (
	`thread_id` bigint(20) NOT NULL, 
	`group_id` bigint(20) NOT NULL COMMENT '所属帖子的ID', 
	`options` bigint(20) NOT NULL COMMENT '第一位：0投票前可见　1投票前不可见　第二位：0普通投票1图片投票第一位：0投票前可见　1投票前不可见　第二位：0普通投票1图片投票', 
	`max_answer` int(11) NOT NULL COMMENT '最大可选项', 
	`vote_user_count` int(11) NOT NULL COMMENT '投票人数', 
	`start_date` datetime NOT NULL COMMENT '投票开始时间', 
	`end_date` datetime NOT NULL COMMENT '投票结束时间', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`char_1` varchar(256) NULL, 
	`num_1` bigint(20) NULL, 
	PRIMARY KEY (`thread_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_vote_choice (
	`id` bigint(20) NOT NULL, 
	`thread_id` bigint(20) NOT NULL COMMENT '帖子Id', 
	`description` varchar(60) NULL COMMENT '选项文字说明', 
	`link_url` varchar(1024) NULL COMMENT '选项的链接地址', 
	`image_url` varchar(200) NULL COMMENT '图片链接中图片的地址 ', 
	`vote_count` int(11) NOT NULL COMMENT '票数', 
	`status` tinyint(4) NOT NULL COMMENT '０正常　１删除', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`num_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	PRIMARY KEY (`id`), 
	KEY `thread_id` (`thread_id`, `status`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_vote_choice_extend (
	`user_id` bigint(20) NOT NULL COMMENT ' 用户Id', 
	`thread_id` bigint(20) NOT NULL COMMENT '帖子Id', 
	`choice` varchar(2000) NOT NULL COMMENT '用户选则的选项ID列表', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`num_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	`voter_ip` varchar(16) NULL, 
	PRIMARY KEY (`user_id`, `thread_id`), 
	KEY `thread_id` (`thread_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists group_web_image_whitelist (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键ID，自增长', 
	`domain` varchar(256) NOT NULL COMMENT '主域名', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`num_1` bigint(20) NULL COMMENT '预留字段', 
	`char_1` varchar(256) NULL COMMENT '预留字段', 
	PRIMARY KEY (`id`), 
	KEY `ind_gwi_whitelist_gmt_create` (`gmt_create`), 
	KEY `ind_gwi_whitelist_domain` (`domain`)
)  AUTO_INCREMENT = 83 CHARSET = utf8 COMMENT = '帮派应用中，网络图片白名单';

SELECT t.id, t.group_id, t.user_id, t.user_nick, t.gmt_create , t.gmt_modified FROM group_group_blacklist t WHERE t.user_id = 1 AND t.group_id = 1;
SELECT COUNT(*) FROM group_group_user t WHERE t.group_id = 1 AND t.deleted = 1 AND t.status IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT t.id, t.name, t.channel_type, t.weight, t.bg_img , t.skin, t.gmt_create, t.gmt_modified FROM group_channel t WHERE t.id = 1;
SELECT t.id, t.group_id, t.board_id, t.subject, t.type , t.status, t.digest, t.options, t.deleted, t.view_count , t.reply_count, t.author_id, t.author_nick, t.author_ip, t.last_reply_author_id , t.last_reply_author_nick, t.last_reply_id, t.last_reply_time, t.category, t.last_modified , t.gmt_create, t.gmt_modified, t.verify, t.operator_id, t.operator_time , t.rated_respect FROM group_group_thread t FORCE INDEX (group_id_gmt_create) WHERE t.group_id = 1 AND t.deleted = 1 AND (t.verify != 1 OR t.verify IS NULL) AND t.category = 1 AND t.type = 1 ORDER BY gmt_create DESC;
SELECT COUNT(*) FROM group_group_collection WHERE user_id = 1;
SELECT t.group_id, t.user_id, t.status, t.role_id, t.user_nick , t.message, t.join_time, t.gmt_create, t.gmt_modified, t.deleted , t.inviter_id, t.last_visit_time FROM group_group_user t WHERE t.group_id = 1 AND t.status = 1 AND t.deleted = 1 AND t.user_nick = "3" ORDER BY t.join_time DESC LIMIT 1, 1;
SELECT t.id, t.group_id, t.board_id, t.subject, t.type , t.status, t.digest, t.options, t.deleted, t.view_count , t.reply_count, t.author_id, t.author_nick, t.author_ip, t.last_reply_author_id , t.last_reply_author_nick, t.last_reply_id, t.last_reply_time, t.category, t.last_modified , t.gmt_create, t.gmt_modified, t.verify, t.operator_id, t.operator_time , t.rated_respect FROM group_group_thread t FORCE INDEX (group_id_reply_time) WHERE t.group_id = 1 AND t.deleted = 1 AND (t.verify != 1 OR t.verify IS NULL) AND t.board_id = 1 AND t.category = 1 AND t.type = 1 ORDER BY last_reply_time DESC;
SELECT t.group_id, t.user_id, t.status, t.role_id, t.user_nick , t.message, t.join_time, t.gmt_create, t.gmt_modified, t.deleted , t.inviter_id, t.last_visit_time FROM group_group_user t WHERE t.group_id = 1 AND t.deleted = 1 AND t.status IN (1,2,4,6,7,8,11,56,68,89,435,4523) ORDER BY t.gmt_create ASC LIMIT 1, 1;
SELECT t.id, t.group_id, t.board_id, t.subject, t.type , t.status, t.digest, t.options, t.deleted, t.view_count , t.reply_count, t.author_id, t.author_nick, t.author_ip, t.last_reply_author_id , t.last_reply_author_nick, t.last_reply_id, t.last_reply_time, t.category, t.last_modified , t.gmt_create, t.gmt_modified, t.verify, t.operator_id, t.operator_time , t.rated_respect FROM (SELECT id FROM group_group_thread g FORCE INDEX (group_id_gmt_create) WHERE g.group_id = 1 AND g.deleted = 1 AND (g.verify != 1 OR g.verify IS NULL) AND digest = 1 AND g.board_id = 1 AND g.type = 1 ORDER BY gmt_create DESC LIMIT 1, 1 ) g, group_group_thread t WHERE t.id = g.id;
SELECT COUNT(*) FROM group_group_thread t WHERE t.group_id = 1 AND t.type = 1 AND t.deleted = 1;
SELECT t.id, t.group_id, t.board_id, t.subject, t.type , t.status, t.digest, t.options, t.deleted, t.view_count , t.reply_count, t.author_id, t.author_nick, t.author_ip, t.last_reply_author_id , t.last_reply_author_nick, t.last_reply_id, t.last_reply_time, t.category, t.last_modified , t.gmt_create, t.gmt_modified, t.verify, t.operator_id, t.operator_time , t.rated_respect FROM group_group_thread t FORCE INDEX (group_id_reply_time) WHERE t.group_id = 1 AND t.deleted = 1 AND (t.verify != 1 OR t.verify IS NULL) AND t.board_id = 1 AND t.type = 1 ORDER BY last_reply_time DESC;
SELECT t.id, t.catalog_id, t.type, t.status, t.name , t.logo_url, t.head_url, t.bulletin, t.tag, t.description , t.point, t.member_count, t.gmt_create, t.gmt_modified, t.lz_stat_id , t.options, t.ww_group_id, t.recommendable, t.hot, t.statistics_date , t.verify, t.operator_id, t.operator_time FROM group_group t WHERE t.id = 1;
SELECT t.id, t.group_id, t.user_id, t.user_nick, t.gmt_create , t.gmt_modified FROM group_group_blacklist t WHERE t.group_id = 1 ORDER BY t.gmt_create DESC LIMIT 1, 1;
SELECT t.id, t.group_id, t.board_id, t.subject, t.type , t.status, t.digest, t.options, t.deleted, t.view_count , t.reply_count, t.author_id, t.author_nick, t.author_ip, t.last_reply_author_id , t.last_reply_author_nick, t.last_reply_id, t.last_reply_time, t.category, t.last_modified , t.gmt_create, t.gmt_modified, t.verify, t.operator_id, t.operator_time , t.rated_respect FROM group_group_thread t FORCE INDEX (group_id_gmt_create) WHERE t.group_id = 1 AND t.deleted = 1 AND (t.verify != 1 OR t.verify IS NULL) AND t.digest = 1 AND t.board_id = 1 AND t.type = 1 ORDER BY gmt_create DESC;
SELECT t.group_id, t.user_id, t.user_nick, t.content_type, t.module_id , t.adboard_id, t.show_url, t.gmt_create, t.gmt_modified FROM group_group_show t WHERE t.group_id = 1 AND t.content_type = 1 AND t.module_id = 1;
SELECT t.id, t.group_id, t.board_id, t.subject, t.type , t.status, t.digest, t.options, t.deleted, t.view_count , t.reply_count, t.author_id, t.author_nick, t.author_ip, t.last_reply_author_id , t.last_reply_author_nick, t.last_reply_id, t.last_reply_time, t.category, t.last_modified , t.gmt_create, t.gmt_modified, t.verify, t.operator_id, t.operator_time , t.rated_respect FROM group_group_thread t FORCE INDEX (group_id_reply_time) WHERE t.group_id = 1 AND t.deleted = 1 AND t.type = 1 AND t.last_reply_time < "30" ORDER BY last_reply_time DESC LIMIT 1;
SELECT t.id, t.group_id, t.thread_id, t.f_user_id, t.f_user_nick , t.thread_source, t.cheer_type, t.t_user_id, t.respect, t.comment , t.gmt_create, t.gmt_modified FROM group_cheer_entry t WHERE t.thread_id = 1 AND cheer_type = 1 ORDER BY t.gmt_create DESC LIMIT 1, 1;
SELECT catalog_id AS catalogid, COUNT(*) AS groupcount FROM group_group t WHERE status = 1 AND type IN (1,2,4,6,7,8,11,56,68,89,435,4523) GROUP BY catalog_id;
SELECT t.id, t.group_id, t.board_id, t.subject, t.type , t.status, t.digest, t.options, t.deleted, t.view_count , t.reply_count, t.author_id, t.author_nick, t.author_ip, t.last_reply_author_id , t.last_reply_author_nick, t.last_reply_id, t.last_reply_time, t.category, t.last_modified , t.gmt_create, t.gmt_modified, t.verify, t.operator_id, t.operator_time , t.rated_respect FROM (SELECT id FROM group_group_thread g FORCE INDEX (group_id_gmt_create) WHERE g.group_id = 1 AND g.deleted = 1 AND (g.verify != 1 OR g.verify IS NULL) AND g.board_id = 1 AND g.category = 1 AND g.type = 1 ORDER BY gmt_create DESC LIMIT 1, 1 ) g, group_group_thread t WHERE t.id = g.id;
SELECT t.id, t.group_id, t.board_id, t.subject, t.type , t.status, t.digest, t.options, t.deleted, t.view_count , t.reply_count, t.author_id, t.author_nick, t.author_ip, t.last_reply_author_id , t.last_reply_author_nick, t.last_reply_id, t.last_reply_time, t.category, t.last_modified , t.gmt_create, t.gmt_modified, t.verify, t.operator_id, t.operator_time , t.rated_respect FROM (SELECT id FROM group_group_thread g FORCE INDEX (group_id_reply_time) WHERE g.group_id = 1 AND g.deleted = 1 AND (g.verify != 1 OR g.verify IS NULL) AND digest = 1 AND g.board_id = 1 AND g.type = 1 ORDER BY last_reply_time DESC LIMIT 1, 1 ) g, group_group_thread t WHERE t.id = g.id;
SELECT COUNT(*) FROM (SELECT 1 FROM group_group_thread t WHERE t.group_id = 1 AND t.deleted = 1 AND (t.verify != 1 OR t.verify IS NULL) AND digest = 1 AND board_id = 1 AND t.type = 1 LIMIT 1 ) t;
SELECT COUNT(*) FROM group_thread_reply t WHERE t.thread_id = 1 AND t.sticky = 1 AND t.deleted = 1 ORDER BY t.sticky_time DESC LIMIT 1;
