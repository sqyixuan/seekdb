SELECT t.id, t.thread_id, t.group_id, t.deleted, t.author_id , t.author_nick, t.author_ip, t.content, t.last_modified, t.gmt_create , t.gmt_modified, t.floor, t.reply, t.reply_time, t.verify , t.operator_time, t.operator_id, t.rated_respect, t.options, t.sticky , t.sticky_author_id, t.sticky_author_nick, t.sticky_time FROM group_thread_reply t WHERE t.thread_id = 1 AND t.sticky = 1 AND t.deleted = 1 ORDER BY t.sticky_time DESC;
