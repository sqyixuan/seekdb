SELECT COUNT(*) FROM group_activity_user t WHERE t.thread_id = 1 AND t.status = 1;
SELECT t.id, t.group_id, t.board_id, t.subject, t.type , t.status, t.digest, t.options, t.deleted, t.view_count , t.reply_count, t.author_id, t.author_nick, t.author_ip, t.last_reply_author_id , t.last_reply_author_nick, t.last_reply_id, t.last_reply_time, t.category, t.last_modified , t.gmt_create, t.gmt_modified, t.verify, t.operator_id, t.operator_time , t.rated_respect FROM (SELECT id FROM group_group_thread g FORCE INDEX (group_id_gmt_create) WHERE g.group_id = 1 AND g.deleted = 1 AND (g.verify != 1 OR g.verify IS NULL) AND g.board_id = 1 AND g.type = 1 ORDER BY gmt_create DESC LIMIT 1, 1 ) g, group_group_thread t WHERE t.id = g.id;
