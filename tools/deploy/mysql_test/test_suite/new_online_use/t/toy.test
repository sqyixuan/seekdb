	`user_nick` varchar(118) NULL, 
	`integral` int(11) NULL, 
	`fire` int(5) NULL, 
	`time` int(11) NULL, 
	`hot` int(5) NULL, 
	`client_ip` varchar(50) NULL, 
	`gmt_create` timestamp DEFAULT CURRENT_TIMESTAMP
)  CHARSET = utf8;
CREATE TABLE if not exists m_bee_user_fraction_map (
	`user_id` int(32) UNSIGNED NULL, 
	`fraction` int(11) NULL, 
	`state` varchar(4) NULL, 
	`dateline` bigint(20) NULL, 
	`gmt_create` timestamp DEFAULT CURRENT_TIMESTAMP
)  CHARSET = utf8;
CREATE TABLE if not exists m_postcard_info (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT 'иҮӘеўһдё»й”®', 
	`uid` bigint(20) NULL COMMENT 'з”ЁжҲ·id', 
	`pic` varchar(254) NULL COMMENT 'еӣҫзүҮең°еқҖ', 
	`memo` varchar(500) NULL COMMENT 'з”ЁжҲ·еҜ„иҜӯ', 
	`tag` varchar(500) NULL COMMENT 'ж ҮзӯҫдҝЎжҒҜ', 
	`time_info` varchar(500) NULL COMMENT 'ж—¶е…үжңәдҝЎжҒҜ', 
	`gmt_create` datetime NOT NULL COMMENT 'и®°еҪ•еҲӣе»әж—¶й—ҙ', 
	`gmt_modified` datetime NOT NULL COMMENT 'и®°еҪ•жңҖеҗҺдҝ®ж”№ж—¶й—ҙ', 
	`app_id` int(11) DEFAULT '0' COMMENT 'еҜ№еә”жҙ»еҠЁж ҮиҜҶ', 
