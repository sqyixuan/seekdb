	PRIMARY KEY (`id`), 
	KEY `idx_m_postcard_info_uid` (`uid`), 
	KEY `idx_appid_uid` (`app_id`, `uid`)
)  AUTO_INCREMENT = 1114934 CHARSET = utf8 COMMENT = 'жҳҺдҝЎзүҮжҙ»еҠЁ';
CREATE TABLE if not exists match_tag (
	`id` int(11) AUTO_INCREMENT NOT NULL COMMENT 'дё»й”®', 
	`gmt_create` datetime NOT NULL COMMENT 'еҲӣе»әж—¶й—ҙ', 
	`gmt_modified` datetime NOT NULL COMMENT 'дҝ®ж”№ж—¶й—ҙ', 
	`deleted` int(11) DEFAULT '0' NOT NULL COMMENT 'жҳҜеҗҰиў«йҖ»иҫ‘еҲ йҷӨ', 
	`name` varchar(50) NOT NULL COMMENT 'ж Үзӯҫ', 
	`icon` varchar(255) NULL COMMENT 'еӣҫзүҮең°еқҖ', 
	`type` int(11) DEFAULT '0' NOT NULL COMMENT 'ж Үзӯҫзұ»еһӢ', 
	`tag_desc` varchar(255) NULL COMMENT 'жҸҸиҝ°', 
	`match_id` int(11) NULL COMMENT 'жҙ»еҠЁid', 
	PRIMARY KEY (`id`), 
	KEY `idx_match_id` (`match_id`)
)  AUTO_INCREMENT = 58 CHARSET = utf8 COMMENT = 'еӯҳеӮЁжҙ»еҠЁзҡ„йЈҺж јж Үзӯҫ';
CREATE TABLE if not exists matchs (
	`id` int(11) AUTO_INCREMENT NOT NULL COMMENT 'и„°жў…еҪ•зңү', 
	`name` varchar(255) NOT NULL COMMENT 'зҰ„з–ғ1,2,4,6,7,8,11,56,68,89,435,4523е… е®Ұи¶Ғ', 
	`rule`varchar(100)COMMENT 'зҰ„з–ғ1,2,4,6,7,8,11,56,68,89,435,4523е§‘Оіж–Ҷ', 
	`intro`varchar(100)COMMENT 'зҰ„з–ғ1,2,4,6,7,8,11,56,68,89,435,4523жҹ®и®ҝеұҶ', 
	`logo` varchar(255) NOT NULL COMMENT 'зҰ„з–ғз—©ogo', 
	`banner` varchar(255) NULL COMMENT 'зҰ„з–ғз–Ҡanner', 
	`poster` varchar(255) NULL COMMENT 'зҰ„з–ғ1,2,4,6,7,8,11,56,68,89,435,4523йғқпјўз”ӯ', 
	`flatuploadstarttime` timestamp NULL COMMENT 'е№іи„ҷеҝҷи„іжў…е“Ғи„Ўжҙ—иҠҰй©ҙйҷӢе§Ӣж—¶еҪ•зӣІ', 
	`flatauditstarttime` timestamp NULL COMMENT 'е№іи„ҷеҝҷи„іжў…е“Ғи„ЎиҙёжҪһдёқйҷӢе§Ӣж—¶еҪ•зӣІ', 
	`sendtemplatestarttime` timestamp NULL COMMENT 'и·Ҝеһ„и„ЈжЎ¶и„іжЁЎй©ҙйҷӢе§Ӣж—¶еҪ•зӣІ', 
	`entityuploadstarttime` timestamp NULL COMMENT 'е®һи„ҰиҢӮи„іжў…е“Ғи„Ўжҙ—иҠҰй©ҙйҷӢе§Ӣж—¶еҪ•зӣІ', 
	`voteLimitNumber` int(6) NOT NULL, 
	`type` int(11) NOT NULL COMMENT 'зҰ„з–ғ1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523зҠҶж„…пјў1,2,4,6,7,8,11,56,68,89,435,4523=е№іи„ҷеҝҷзҰ„з–ғ1,2,4,6,7,8,11,56,68,89,435,4523пјў1,2,4,6,7,8,11,56,68,89,435,4523=е®һи„ҰиҢӮзҰ„з–ғ1,2,4,6,7,8,11,56,68,89,435,4523пјў', 
	`state` int(11) NOT NULL COMMENT 'зҰ„з–ғ1,2,4,6,7,8,11,56,68,89,435,4523еҲә1,2,4,6,7,8,11,56,68,89,435,4523пјў1,2,4,6,7,8,11,56,68,89,435,45230=жңӘй©ҙйҷӢе§ӢжӢўеҚў1=и„Ўжҙ—иҠҰе№іи„ҷеҝҷи„іжў…е“Ғи„°и„Ё,2=и„Ўжҙ—иҠҰе№іи„ҷеҝҷи„іжў…е“ҒйҷҶи°©и„ўй…¶, 3=е№іи„ҷеҝҷи„іжў…е“Ғи„ЎиҙёжҪһи„Ји„°и„Ё,4=е№іи„ҷеҝҷи„іжў…е“Ғи„ЎиҙёжҪһз§Ғи°©и„ўй…¶, 5=и·Ҝеһ„и„Ји„Ҙи„іжў…е“ҒжҺіи„іжЁЎи„°и„Ё,6=и·Ҝеһ„и„Ји„Ҙи„іжў…е“ҒжҺіи„іжЁЎйҷҶи°©и„ўй…¶, 7=и„ЎзҢ«еҪ•и„қеёҲйә“йә“и„іжў…и„°и„Ё,8=и„Ўжҙ—иҠҰе®һи„ҰиҢӮи„іжў…е“Ғи„°и„Ё, 9=и„Ўжҙ—иҠҰе®һи„ҰиҢӮи„іжў…е“ҒйҷҶи°©и„ўй…¶,10=е®һи„ҰиҢӮи„іжў…е“Ғи„ЎиҙёжҪһи„Ји„°и„Ё, 11=е®һи„ҰиҢӮи„іжў…е“Ғи„ЎиҙёжҪһз§Ғи°©и„ўй…¶,12=жҠ•зҘЁи„°и„Ё, 13=жҠ•зҘЁйҷҶи°©и„ўй…¶,14=дё“еҪ•и„Әи„қи„Ңи„Ўиҙёи„°и„Ё, 15=дё“еҪ•и„Әи„қи„Ңи„ЎиҙёйҷҶи°©и„ўй…¶,16=и·Ҝеһ„и„Јеҫ’еҚӨе“Ғи„°и„Ё, 17=и·Ҝ', 
	`endtime` timestamp NULL COMMENT 'зҰ„з–ғ1,2,4,6,7,8,11,56,68,89,435,4523зҹ«вҲ¶еЁ’з”ҳз”ӯжөҺ', 
	`prizeimg` varchar(500) NULL COMMENT 'йҷҶеҚӨе“ҒеӣҫзүҮ', 
	`deleted` int(1) DEFAULT '0' NOT NULL, 
	`gmtcreate` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL, 
	`gmtmodified` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL, 
	`entityauditstarttime` timestamp NULL COMMENT 'е®һи„ҰиҢӮи„іжў…е“Ғи„ЎиҙёжҪһи„Јж—¶еҪ•зӣІ', 
	`votestarttime` timestamp NULL COMMENT 'жҠ•зҘЁй©ҙйҷӢе§Ӣж—¶еҪ•зӣІ', 
	`finalauditstarttime` timestamp NULL COMMENT 'дё“еҪ•и„Әи„қи„Ңи„Ўиҙёй©ҙйҷӢе§Ӣж—¶еҪ•зӣІ', 
	`copyright`varchar(100)COMMENT 'жҺіеҝҷжқғи„Ўй”ҡи„ҷжў…', 
	`timeline`varchar(100)COMMENT 'зҰ„з–ғ1,2,4,6,7,8,11,56,68,89,435,4523з”ӯй—ҙе®үи„ңи„ң', 
	`judges`varchar(100)COMMENT 'йә“иҙёи„ зңүи„қи„Ңе§”', 
	`templateurl` varchar(254) NULL COMMENT 'еҚӨжҲ®зҰ„з–ғ1,2,4,6,7,8,11,56,68,89,435,4523пјўжҮҠгғғе№ жөҺд№…еҫқеҒҜж–ҶжЁҺд»ҝйҹӯ', 
	`officialannouncement` varchar(254) NULL COMMENT 'еҚӨжҲ®зҰ„з–ғ1,2,4,6,7,8,11,56,68,89,435,4523ж ғе®ҳд»ҝзҹ«жӨ•1,2,4,6,7,8,11,56,68,89,435,4523еҘҪйҷҲеӯӨ1,2,4,6,7,8,11,56,68,89,435,4523иҜҘ', 
	`guest_designer_entry`varchar(100)COMMENT 'йӮҖзәҰи®ҫи®ЎеёҲе…ҘеҸЈ', 
	`vote_gift_optios` int(11) DEFAULT '1' COMMENT 'жҳҜеҗҰеҗҜз”ЁжҠ•зҘЁжҠҪеҘ–пјҲ1пјҡеҗҜз”ЁпјҢ0пјҡдёҚеҗҜз”Ёпјү', 
	`guest_designer_entry_collapse`varchar(100)COMMENT 'йӮҖзәҰи®ҫи®ЎеёҲе…ҘеҸЈпјҲе°Ҹпјү', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 30 CHARSET = utf8;
CREATE TABLE if not exists messages (
	`id` int(11) AUTO_INCREMENT NOT NULL, 
	`workId` int(11) NOT NULL, 
	`user` varchar(255) NULL, 
	`content` varchar(100), 
	`timestamp` timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP NOT NULL, 
	`denounce` int(1) DEFAULT '0' NOT NULL, 
	`deleted` int(1) DEFAULT '0', 
	`gmtcreate` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL, 
	`gmtmodified` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL, 
	`user_id` bigint(20) DEFAULT '0' NOT NULL COMMENT 'ж·ҳе®қз”ЁжҲ·id', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 115936 CHARSET = utf8;
CREATE TABLE if not exists pics (
