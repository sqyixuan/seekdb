CREATE TABLE if not exists auth (
	`id` varchar(255) NOT NULL, 
	`mute` int(1) DEFAULT '0' NOT NULL, 
	`deleted` int(1) DEFAULT '0', 
	`gmtCreate` timestamp NULL, 
	`gmtModified` timestamp NULL, 
	PRIMARY KEY (`id`)
)  CHARSET = utf8;
CREATE TABLE if not exists designers (
	`id` varchar(255) NOT NULL, 
	`vip` int(1) NULL, 
	`nickName` varchar(255) NULL, 
	`avatar` varchar(255) NULL, 
	`homeAddress` varchar(255) NULL, 
	`gender` int(1) NULL, 
	`occupation` varchar(255) NULL, 
	`constellation` varchar(255) NULL, 
	`introduction` varchar(255) NULL, 
	`idNo` varchar(255) NULL, 
	`cellPhone` varchar(255) NULL, 
	`receiveAddress` varchar(255) NULL, 
	`domain` varchar(255) NULL, 
	`website` varchar(255) NULL, 
	`weibo` varchar(255) NULL, 
	`zhanku` varchar(255) NULL, 
	`meikong` varchar(255) NULL, 
	`shijueCn` varchar(255) NULL, 
	`mail` varchar(255) NULL, 
	`activeTime` timestamp DEFAULT CURRENT_TIMESTAMP NOT NULL, 
	`hotOrder` int(8) DEFAULT '-1' NOT NULL, 
	`deleted` int(1) DEFAULT '0', 
	`gmtCreate` timestamp NULL, 
	`gmtModified` timestamp NULL, 
	`realName` varchar(50) NULL, 
	`state` int(1) NULL, 
	`sid` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT 'ж–°зҡ„дё»й”®', 
	PRIMARY KEY (`sid`), 
	KEY `deleted_gmtcreate` (`deleted`, `gmtCreate`)
)  AUTO_INCREMENT = 62004 CHARSET = utf8 COMMENT = 'ж–°еўһдё»й”®sidпјҢеҺҹжқҘдё»й”®дёҚеҶҚе…іиҒ”id';
CREATE TABLE if not exists followrelations (
	`designerId` varchar(255) NOT NULL, 
	`followingId` varchar(255) NOT NULL, 
	`deleted` int(1) DEFAULT '0', 
	`gmtCreate` timestamp NULL, 
	`gmtModified` timestamp NULL, 
	PRIMARY KEY (`designerId`, `followingId`)
)  CHARSET = utf8;
CREATE TABLE if not exists gift_list (
	`giftId` bigint(10) NOT NULL, 
	`giftType` int(1) NULL, 
	`user` char(100) NULL, 
	`userInfo` varchar(255) NULL, 
	`dateline` bigint(10) NULL, 
	PRIMARY KEY (`giftId`), 
	KEY `XMAS` (`giftId`, `giftType`, `user`, `dateline`)
)  CHARSET = utf8;
CREATE TABLE if not exists gifts (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT 'и„іи„ӯи„ӯжһҡи„°жў…еҪ•зңү', 
	`uid` varchar(35) NULL COMMENT 'и„Өе‘ҳеЁ„и„«жІЎжҗӮID', 
	`nick` varchar(118) NULL COMMENT 'и„Өе‘ҳеЁ„и„«жІЎжҗӮnick', 
	`realname` varchar(118) NULL COMMENT 'и„®еҝҷе®һи„Ёи„®и„ҷжІЎ', 
	`tel` varchar(30) NULL COMMENT 'jзі»зўҢзјҒ', 
	`address` varchar(254) NULL COMMENT 'и„ўж ҲеёҪзўҢи„ҙеқҖ', 
	`prizeinfo` varchar(254) NULL COMMENT 'йҷҶеҚӨе“Ғи„Ёи„ңжҒҜ', 
	`state` varchar(2) NULL COMMENT 'зҠ¶жҖҒжӢўзҜ“0жӢўжҪһжңӘи·Ҝеһ„       1жӢўжҪһи„ӘйҖҠеһ„       -1жӢўжҪһйә“еӘ’йңІзҜ“       2:и·Ҝи„§и„қз…ӨжӢўжјҸ', 
	`gmt_create` datetime NULL COMMENT 'еҪ•и„ҹеҪ•йә“йә“йҷҶзҜ“ж—¶еҪ•зӣІ', 
	`gmt_modified` datetime NULL COMMENT 'еҪ•и„ҹеҪ•и„іеҚҜжҪһиҙёи„Ёи–·и„ӣж—¶еҪ•зӣІ', 
	`type` varchar(2) NULL COMMENT 'и„Ңи„ҝи„ЁеҒңзҜ“0жӢўжҪһжҠ•зҘЁйІҒжҰ»1,2,4,6,7,8,11,56,68,89,435,4523      1жӢўжҪһи„қзӣІи„ЈжІЎжӢўжјҸ', 
	`matchid` int(11) NULL COMMENT 'зҰ„з–ғз–ҳD', 
	`prizeid` int(11) NULL COMMENT 'йҷҶеҚӨе“Ғи„Ёи„ңжҒҜID', 
	`leve` int(11) NULL COMMENT 'йҷҶеҚӨе“Ғи„°и„ҙиҰҒзўҢзҮғйңІжӢўзҜ“1-10еҪ•йңІжӢўеҚўзўҢзҮғйңІи¶ҠиөӮж’ёеҚўжҪһеҚўйҷҶиҝ·й“°еӨҡпјү', 
	`ip` varchar(64) NULL COMMENT 'зҰ„еёҪйҷҶеҚӨи„«жІЎжҗӮipзўҢи„ҙеқҖ', 
	PRIMARY KEY (`id`), 
	KEY `idx_gmt_create` (`gmt_create`), 
	KEY `idx_type` (`type`)
)  AUTO_INCREMENT = 970 CHARSET = utf8 COMMENT = 'жҠ•зҘЁйІҒжҰ»з”ӯе№»з”ӯй“°жіөж’Ғе®Ұ1,2,4,6,7,8,11,56,68,89,435,4523жғ·е‘„';
CREATE TABLE if not exists joinwork (
	`matchId` int(11) NOT NULL, 
	`designerId` varchar(255) NOT NULL, 
	`matchName` varchar(255) NULL, 
	`matchLogo` varchar(255) NULL, 
	`deleted` int(1) DEFAULT '0' NOT NULL, 
	`gmtCreate` timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP NOT NULL, 
	`gmtModified` timestamp DEFAULT '0000-00-00 00:00:00' NOT NULL, 
	`state` int(11) NULL COMMENT 'зҠ¶жҖҒжӢўзҜ“0жӢўжҪһжңӘи„§и„—и„ӯи„ҙжЁЎжҺіжҫ№1,2,4,6,7,8,11,56,68,89,435,4523жӢўжҪһи„§и„—и„ӯи„ҙжЁЎжҺіжҫ№', 
	PRIMARY KEY (`matchId`, `designerId`)
)  CHARSET = utf8;
CREATE TABLE if not exists m_bee_fraction (
