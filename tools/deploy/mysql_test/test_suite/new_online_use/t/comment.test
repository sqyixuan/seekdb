--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: jim.wjh
#owner group:sql2
#tags new_online_use 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists activity_award (
	`id` bigint(20) NOT NULL, 
	`sort_id` bigint(20) NOT NULL, 
	`award_name` varchar(256) NOT NULL, 
	`question_flag` tinyint(4) NOT NULL, 
	`award_num` int(11) NOT NULL, 
	`max_win` int(11) NOT NULL, 
	`probability` int(11) NOT NULL, 
	`question_ids` varchar(1024) NULL, 
	`deleted` tinyint(4) NOT NULL, 
	`award_type` int(11) NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `IDX_actaward_sortid` (`sort_id`, `deleted`, `gmt_create`), 
	KEY `IDX_actaward_deleted` (`deleted`, `gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists activity_award_count (
	`award_id` bigint(20) NOT NULL, 
	`award_win_num` int(11) NOT NULL, 
	`deleted` tinyint(4) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	UNIQUE `award_id` (`award_id`, `gmt_create`), 
	KEY `IDX_actcount_awardnum` (`award_win_num`, `gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists activity_question (
	`id` bigint(20) NOT NULL, 
	`question` varchar(2000) NOT NULL, 
	`answer` varchar(2000) NOT NULL, 
	`deleted` tinyint(4) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `IDX_question_deleted` (`deleted`, `gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists activity_rule (
	`id` bigint(20) NOT NULL, 
	`sort_id` bigint(20) NOT NULL, 
	`rule_name` varchar(256) NOT NULL, 
	`rule` varchar(1024) NOT NULL, 
	`award_ids` varchar(1024) NOT NULL, 
	`start_date` datetime NOT NULL, 
	`end_date` datetime NOT NULL, 
	`activity_control` tinyint(4) NOT NULL, 
	`deleted` tinyint(4) NOT NULL, 
	`question_ids` varchar(1024) NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `IDX_actrule_sortid` (`sort_id`, `deleted`, `gmt_create`), 
	KEY `IDX_actrule_deleted` (`deleted`, `gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists activity_sort (
	`id` bigint(20) NOT NULL, 
	`activity_name` varchar(256) NOT NULL, 
	`deleted` tinyint(4) NOT NULL, 
	`start_date` datetime NOT NULL, 
	`end_date` datetime NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `IDX_actsort_deleted` (`deleted`, `gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists activity_user_chance (
	`id` bigint(20) NOT NULL, 
	`auth_key` varchar(64) NOT NULL, 
	`deleted` tinyint(4) NOT NULL, 
	`award_id` bigint(20) NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `IDX_actchance_deleted` (`deleted`, `gmt_create`), 
	KEY `IDX_actchance_authkey` (`auth_key`)
)  CHARSET = utf8;
CREATE TABLE if not exists activity_user_win (
	`id` bigint(20) NOT NULL, 
	`user_id` bigint(20) NOT NULL, 
	`user_nick` varchar(1024) NOT NULL, 
	`award_id` int(11) NOT NULL, 
	`award_name` varchar(256) NULL, 
	`win_num` int(11) NOT NULL, 
	`deleted` tinyint(4) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `IDX_actwin_deleted` (`deleted`, `gmt_create`), 
	KEY `IDX_actwin_userid` (`user_id`), 
	KEY `IDX_actwin_awardid` (`award_id`, `gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists certification (
	`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`uuid` varchar(20) NOT NULL, 
	`name` varchar(10) NOT NULL, 
	`gender` tinyint(4) NOT NULL, 
	`identity` varchar(20) NOT NULL, 
	`quali_name` varchar(32) NOT NULL, 
	`level` tinyint(4) NOT NULL, 
	`mark1` tinyint(3) UNSIGNED NOT NULL, 
	`mark2` tinyint(3) UNSIGNED NOT NULL, 
	`mark3` smallint(5) UNSIGNED NOT NULL, 
	`pubdate` varchar(15) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_certifi_uuid` (`uuid`, `name`, `gmt_modified`)
)  AUTO_INCREMENT = 897 CHARSET = utf8;
CREATE TABLE if not exists comment (
	`id` bigint(64) NOT NULL COMMENT '点评类型ID', 
	`typeId` int(11) NOT NULL COMMENT '点评类型ID', 
	`objectTypeId` int(11) NOT NULL COMMENT '点评对象类型ID', 
	`objectId` bigint(20) NOT NULL COMMENT '点评对象ID', 
	`templetId` int(11) NULL COMMENT '点评模板ID', 
	`templetType` int(2) NULL COMMENT '点评模板类型', 
	`commentName` varchar(256) NULL COMMENT '点评名称', 
	`personCount` int(11) DEFAULT '0' COMMENT '参与总人数', 
	`scoreCount` int(11) DEFAULT '0' COMMENT '参与有效人数', 
	`createdate` datetime NULL COMMENT '创建日期', 
	`status` int(2) NULL COMMENT '状态', 
	`psnValidCount` int(11) DEFAULT '0', 
	`ObjectUrl` varchar(512) NULL, 
	`objownerid` bigint(20) NULL, 
	`gmt_modified` datetime NULL, 
	`menuid` varchar(64) NULL, 
	`parenttypeid` bigint(20) NULL, 
	`parentobjectid` bigint(20) NULL, 
	`parentobjecttypeid` bigint(20) NULL, 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_c_typeId` (`typeId`, `objectTypeId`, `objectId`), 
	KEY `objectId` (`objectId`, `createdate`, `typeId`), 
	KEY `objectTypeId` (`objectTypeId`, `personCount`), 
	KEY `ind_comment_gmt` (`gmt_modified`)
)  CHARSET = utf8;
CREATE TABLE if not exists comment_content (
	`id` int(11) NOT NULL COMMENT '主键id', 
	`infoId` int(11) NULL COMMENT '用户点评id', 
	`commentId` int(11) NULL, 
	`objectTypeId` int(11) NULL COMMENT '点评对象类型ID', 
	`optionId` int(11) NULL COMMENT '点评项ID', 
	`valueId` varchar(250) NULL COMMENT '点评项值ID', 
	`commenterId` bigint(20) NULL COMMENT '评论者ID', 
	`commenterNickname` varchar(32) NULL, 
	`content` varchar(4000) NULL COMMENT '评论内容', 
	`status` int(11) NULL COMMENT '内容状态字段', 
	`createDate` datetime NULL COMMENT '创建日期', 
	`score` int(11) DEFAULT '0' COMMENT '点评分数', 
	`contenttype` int(11) NULL, 
	`modifydate` datetime NULL, 
	`impeach` tinyint(4) NULL, 
	`menuid` varchar(64) NULL, 
	PRIMARY KEY (`id`), 
	KEY `objectTypeId` (`objectTypeId`, `createDate`, `status`), 
	KEY `idx_cc_infoId` (`infoId`, `objectTypeId`), 
	KEY `idx_cc_commenterId` (`commenterId`, `status`)
)  CHARSET = utf8 COMMENT = '点评内容信息表';
CREATE TABLE if not exists comment_content_log (
	`id` bigint(11) NOT NULL COMMENT '日志ID', 
	`infoId` int(11) NULL COMMENT '用户点评ID', 
	`contentId` int(11) NULL COMMENT '点评内容id', 
	`userId` int(11) NULL COMMENT '点评用户ID', 
	`userNickName` varchar(32) NULL, 
	`objectId` bigint(20) NULL, 
	`objectName` varchar(118) NULL COMMENT '点评对象名称', 
	`remarks` varchar(2000) NULL, 
	`logRegDate` datetime NULL COMMENT '记录日期', 
	`ip` varchar(60) NULL COMMENT '评论者IP', 
	`objectTypeId` int(11) NULL COMMENT '分库id', 
	PRIMARY KEY (`id`), 
	KEY `logRegDate` (`logRegDate`, `objectTypeId`), 
	KEY `userNickName` (`userNickName`)
)  CHARSET = utf8;
CREATE TABLE if not exists comment_content_stat (
	`id` bigint(11) NOT NULL, 
	`objectTypeId` int(11) NULL COMMENT '点评对象类型ID', 
	`commentId` bigint(11) NULL COMMENT '点评ID', 
	`optionId` bigint(11) NULL COMMENT '点评项ID', 
	`valueId` bigint(11) NULL COMMENT '点评项值ID', 
	`personCount` int(11) DEFAULT '0' COMMENT '总人数', 
	`scoreCount` int(11) DEFAULT '0' COMMENT '分数', 
	`statisticsDate` datetime NULL COMMENT '统计日期', 
	PRIMARY KEY (`id`), 
	UNIQUE `commentId_2` (`commentId`, `valueId`), 
	KEY `commentId` (`commentId`, `objectTypeId`), 
	KEY `ind_comment_content_stat_gmt` (`statisticsDate`), 
	KEY `ind_comment_content_stat_type` (`objectTypeId`)
)  CHARSET = utf8;
CREATE TABLE if not exists comment_content_stat_bak (
	`id` bigint(11) NOT NULL, 
	`objectTypeId` int(11) NULL COMMENT '点评对象类型ID', 
	`commentId` bigint(11) NULL COMMENT '点评ID', 
	`optionId` bigint(11) NULL COMMENT '点评项ID', 
	`valueId` bigint(11) NULL COMMENT '点评项值ID', 
	`personCount` int(11) DEFAULT '0' COMMENT '总人数', 
	`scoreCount` int(11) DEFAULT '0' COMMENT '分数', 
	`statisticsDate` datetime NULL COMMENT '统计日期'
)  CHARSET = utf8;
CREATE TABLE if not exists comment_ids (
	`name` varchar(255) NULL, 
	`value` bigint(20) NULL, 
	`gmt_modified` datetime NULL, 
	KEY `IDX_ids_value` (`value`)
)  CHARSET = utf8;
CREATE TABLE if not exists comment_info (
	`id` bigint(11) NOT NULL, 
	`commentId` bigint(11) NULL, 
	`objectTypeId` int(11) NULL, 
	`commenterid` bigint(20) NULL, 
	`commenterNickname` varchar(32) NULL, 
	`content` varchar(20), 
	`support` int(11) DEFAULT '0' COMMENT '支持数', 
	`oppose` int(11) DEFAULT '0' COMMENT '反对数', 
	`commentDate` datetime NULL COMMENT '点评日期', 
	`anonymity` int(2) NULL COMMENT '是否匿名 1匿名 0非匿名', 
	`status` int(11) NULL COMMENT '点评状态', 
	`supportrate` int(11) DEFAULT '0' COMMENT '支持热度', 
	`ip` varchar(60) NULL COMMENT '点评者ip', 
	`excerpt_count` int(11) NULL, 
	`revert_count` int(11) NULL, 
	`parent_commentid` bigint(20) NULL, 
	`menuid` varchar(64) NULL, 
	`info_type` tinyint(4) DEFAULT '0', 
	`description` varchar(256) NULL, 
	`impeach` tinyint(4) DEFAULT '0', 
	`impeach_count` int(11) NULL, 
	`comment_pithtype` tinyint(4) DEFAULT '0', 
	`gmt_modified` datetime NULL, 
	`vouch` tinyint(4) DEFAULT '0', 
	`vouchernickname` varchar(32) NULL, 
	`voucherid` int(11) NULL, 
	PRIMARY KEY (`id`), 
	KEY `commentId` (`commentId`, `supportrate`, `objectTypeId`, `status`), 
	KEY `idx_ci_commentId` (`commentId`, `objectTypeId`, `status`, `comment_pithtype`, `supportrate`, `commentDate`), 
	KEY `idx_ci_objectTypeId` (`objectTypeId`, `gmt_modified`, `vouch`, `comment_pithtype`, `status`), 
	KEY `idx_ci_commenterId` (`commenterid`), 
	KEY `idx_objecttypeid_status_comment_pithtype_supportrate_commentdate` (`objectTypeId`, `status`, `comment_pithtype`, `supportrate`, `commentDate`)
)  CHARSET = utf8;
CREATE TABLE if not exists comment_object_type (
	`id` bigint(11) NOT NULL, 
	`objectTypeName` varchar(118) NULL COMMENT '点评对象类型名称', 
	`creatorId` bigint(20) NULL, 
	`creator` varchar(32) NULL, 
	`editorId` bigint(20) NULL, 
	`editor` varchar(32) NULL, 
	`creatDate` datetime NULL, 
	`editeDate` datetime NULL, 
	`config` varchar(512) NULL, 
	`status` int(11) NULL, 
	PRIMARY KEY (`id`)
)  CHARSET = utf8;
CREATE TABLE if not exists comment_oper_log (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`object_name` varchar(64) NULL, 
	`operator_nick` varchar(64) NULL, 
	`target_nick` varchar(64) NULL, 
	`operation` tinyint(4) NOT NULL, 
	`content` varchar(64) NULL, 
	`object_type_id` bigint(20) NOT NULL, 
	`ip` varchar(64) NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`content_id` bigint(20) NULL, 
	`info_id` bigint(20) NULL, 
	`object_url` varchar(256) NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_operlog` (`object_type_id`, `gmt_create`)
)  AUTO_INCREMENT = 590596 CHARSET = utf8;
CREATE TABLE if not exists comment_option_value (
	`id` bigint(11) NOT NULL, 
	`objectTypeId` int(11) NULL COMMENT '点评对象类型ID', 
	`optionId` bigint(11) NULL COMMENT '点评项ID', 
	`optionValue` varchar(256) NULL COMMENT '点评项值', 
	`valueSequence` int(11) NULL COMMENT '点评项顺序', 
	`numValue` bigint(20) NULL, 
	`title` varchar(256) NULL COMMENT '点评项值标题', 
	`creatorId` int(11) NULL COMMENT '创建者ID', 
	`creator` varchar(32) NULL, 
	`editorId` int(11) NULL COMMENT 'editorId', 
	`editor` varchar(32) NULL, 
	`createDate` datetime NULL COMMENT '创建日期', 
	`editeDate` datetime NULL COMMENT '修改日期', 
	PRIMARY KEY (`id`), 
	KEY `optionId` (`optionId`, `objectTypeId`, `valueSequence`)
)  CHARSET = utf8;
CREATE TABLE if not exists comment_options (
	`id` bigint(11) NOT NULL, 
	`commentType` bigint(11) NULL COMMENT '点评项类型', 
	`typeId` bigint(11) NULL COMMENT '点评类型Id', 
	`objectTypeId` int(11) NULL COMMENT '点评对象类型', 
	`optionName` varchar(118) NULL COMMENT '点评项名称', 
	`optionLimit` varchar(256) NULL COMMENT '选项限制,包括字数，项数等限制', 
	`optionSequence` int(11) NULL COMMENT '选项顺序', 
	`creatorId` int(11) NULL COMMENT '创建者ID', 
	`creator` varchar(32) NULL, 
	`editorId` int(11) NULL COMMENT '修改者id', 
	`editor` varchar(32) NULL, 
	`createDate` date NULL COMMENT '创建日期', 
	`editeDate` date NULL COMMENT '修改日期', 
	PRIMARY KEY (`id`), 
	KEY `objectTypeId` (`objectTypeId`, `typeId`, `optionSequence`)
)  CHARSET = utf8;
CREATE TABLE if not exists comment_stat (
	`id` bigint(11) NOT NULL, 
	`objectTypeId` int(11) NULL COMMENT '点评对象类型Id', 
	`commentType` bigint(11) NULL COMMENT '点评类型', 
	`commentCount` int(11) DEFAULT '0' COMMENT '点评总数', 
	`scoreCount` int(11) DEFAULT '0' COMMENT '有效数量', 
	`validCount` bigint(20) DEFAULT '0', 
	`psnVoteCount` bigint(20) DEFAULT '0', 
	`psnScoreCount` bigint(20) DEFAULT '0', 
	`statisticsDate` datetime NULL COMMENT '统计日期', 
	PRIMARY KEY (`id`), 
	KEY `objectTypeId` (`objectTypeId`, `statisticsDate`)
)  CHARSET = utf8;
CREATE TABLE if not exists comment_syslog (
	`id` bigint(11) NOT NULL, 
	`objectTypeId` int(11) NULL COMMENT '评论内容信息id', 
	`typeId` bigint(11) NULL COMMENT '点评类型ID', 
	`optionId` bigint(11) NULL COMMENT '点评项id', 
	`valueId` bigint(11) NULL COMMENT ' 点评项值id', 
	`operationuserid` bigint(20) NULL COMMENT '操作者id', 
	`operationUserName` varchar(50) NULL COMMENT '操作者昵称', 
	`operation` int(11) NULL COMMENT '操作名称1增加，2删除，3修改', 
	`ip` varchar(60) NULL COMMENT '操作者ip', 
	`operationDate` datetime NULL, 
	`remark` varchar(100) NULL, 
	PRIMARY KEY (`id`), 
	KEY `objectTypeId` (`objectTypeId`, `operationDate`)
)  CHARSET = utf8;
CREATE TABLE if not exists comment_type (
	`id` bigint(11) NOT NULL, 
	`objectTypeId` int(11) NULL COMMENT '点评对象类型ID', 
	`typeName` varchar(118) NULL COMMENT '点评类型名称', 
	`typeLimit` varchar(500) NULL, 
	`creatorId` int(11) NULL COMMENT '创建者ID', 
	`creator` varchar(32) NULL, 
	`editorId` int(11) NULL COMMENT '修改者id', 
	`editor` varchar(32) NULL, 
	`createDate` datetime NULL COMMENT '创建日期', 
	`editeDate` datetime NULL COMMENT '修改日期', 
	PRIMARY KEY (`id`), 
	KEY `objectTypeId` (`objectTypeId`, `editeDate`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_article_recommend (
	`article_id` bigint(20) NOT NULL, 
	`recommend_num` int(11) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`deleted` tinyint(4) NOT NULL, 
	`vote_num` int(11) NOT NULL, 
	`hot` int(11) NOT NULL, 
	`article_title` varchar(128) NULL, 
	`article_url` varchar(256) NULL, 
	PRIMARY KEY (`article_id`), 
	KEY `IDX_arecommend_deleted` (`deleted`, `gmt_modified`, `hot`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_tag (
	`id` bigint(20) NOT NULL, 
	`tag_name` varchar(256) NOT NULL, 
	`hot_flag` int(11) NOT NULL, 
	`subscribe_num` int(11) NOT NULL, 
	`deleted` tinyint(4) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `IDX_tag_deleted` (`deleted`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_user_action (
	`id` bigint(20) NOT NULL, 
	`user_id` bigint(20) NOT NULL, 
	`user_nick` varchar(32) NOT NULL, 
	`action_type` tinyint(4) NOT NULL, 
	`vote_content` varchar(2000) NULL, 
	`action_url` varchar(2000) NOT NULL, 
	`article_id` bigint(20) NOT NULL, 
	`article_content` varchar(2000) NOT NULL, 
	`article_img` varchar(1024) NULL, 
	`article_title` varchar(128) NULL, 
	`article_url` varchar(256) NULL, 
	`feed_id` bigint(20) NOT NULL, 
	`action_object_id` bigint(20) NOT NULL, 
	`deleted` tinyint(4) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`tag_name` varchar(256) NULL, 
	PRIMARY KEY (`id`), 
	UNIQUE `IDX_uaction_userid` (`user_id`, `article_id`, `action_type`, `action_object_id`), 
	KEY `IDX_uaction_articleid` (`article_id`, `deleted`, `gmt_create`), 
	KEY `IDX_uaction_userid2` (`user_id`, `deleted`, `gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_user_hot (
	`user_id` bigint(20) NOT NULL, 
	`article_id` bigint(20) NULL, 
	`article_name` varchar(512) NULL, 
	`article_url` varchar(256) NULL, 
	`hot` int(11) NOT NULL, 
	`vote_num` int(11) NOT NULL, 
	`recommend_num` int(11) NOT NULL, 
	`deleted` tinyint(4) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`user_id`), 
	KEY `IDX_userhot_deleted` (`deleted`, `hot`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_user_recommend (
	`id` bigint(20) NOT NULL, 
	`tag_id` int(11) NOT NULL, 
	`tag_name` varchar(256) NOT NULL, 
	`user_id` bigint(20) NOT NULL, 
	`deleted` tinyint(4) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	UNIQUE `IDX_urecommend` (`user_id`, `tag_id`), 
	KEY `IDX_urecommend_tagid` (`tag_id`, `gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists tbf_contribution (
	`contribution_id` bigint(20) NOT NULL, 
	`channel` varchar(16) NOT NULL, 
	`channel_id` varchar(128) NOT NULL, 
	`node` varchar(64) NOT NULL, 
	`node_id` varchar(128) NOT NULL, 
	`subject` varchar(256) NOT NULL, 
	`path` varchar(256) NOT NULL, 
	`tags` varchar(256) NULL, 
	`status` tinyint(4) NOT NULL, 
	`cms_url` varchar(256) NULL, 
	`gmt_create` datetime NULL, 
	`gmt_modified` datetime NULL, 
	`adopt_date` datetime NULL, 
	`author_id` varchar(32) NULL, 
	`author_nickname` varchar(32) NULL, 
	`priority` int(11) NULL, 
	`forum_url` varchar(256) NULL, 
	`articletype` int(11) NULL, 
	`refause` tinyint(4) NULL, 
	`savedate` datetime NULL, 
	`article_from` varchar(256) NULL, 
	UNIQUE `contribution_id` (`contribution_id`), 
	KEY `channel_id` (`channel_id`, `status`, `savedate`), 
	KEY `savedate` (`savedate`, `channel_id`, `status`), 
	KEY `subject` (`subject`, `status`), 
	KEY `author_nickname` (`author_nickname`, `status`, `channel_id`, `gmt_modified`)
)  CHARSET = utf8;
CREATE TABLE if not exists tbf_group (
	`id` bigint(20) NOT NULL, 
	`group_name` varchar(256) NULL, 
	`description` varchar(1024) NULL, 
	`status` tinyint(4) NULL, 
	`level` int(11) NULL, 
	`gmt_create` date NULL, 
	`gmt_modified` date NULL, 
	`num_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	`creator` varchar(32) NULL, 
	`editor` varchar(32) NULL, 
	UNIQUE `id` (`id`), 
	KEY `group_name` (`group_name`), 
	KEY `idx_tbfgroup_status` (`status`, `gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists tbf_group_user (
	`id` bigint(20) NOT NULL, 
	`group_id` int(11) NULL, 
	`user_id` bigint(20) NULL, 
	`usernickname` varchar(32) NULL, 
	`gmt_create` date NULL, 
	`gmt_modified` date NULL, 
	`status` tinyint(4) NULL, 
	`num_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	`creator` varchar(32) NULL, 
	`editor` varchar(32) NULL, 
	UNIQUE `id` (`id`), 
	KEY `idx_tbfguser_groupid` (`group_id`, `gmt_create`), 
	KEY `idx_tbfguser_userid` (`user_id`, `gmt_create`)
)  CHARSET = utf8;
CREATE TABLE if not exists tmp_lx (
	`id` bigint(11) NULL
)  CHARSET = utf8;
CREATE TABLE if not exists tmp_lx_comment (
	`id` bigint(11) NOT NULL, 
	`objectTypeId` int(11) NULL COMMENT '点评对象类型ID', 
	`commentId` bigint(11) NULL COMMENT '点评ID', 
	`optionId` bigint(11) NULL COMMENT '点评项ID', 
	`valueId` bigint(11) NULL COMMENT '点评项值ID', 
	`personCount` int(11) DEFAULT '0' COMMENT '总人数', 
	`scoreCount` int(11) DEFAULT '0' COMMENT '分数', 
	`statisticsDate` datetime NULL COMMENT '统计日期'
)  CHARSET = utf8;
