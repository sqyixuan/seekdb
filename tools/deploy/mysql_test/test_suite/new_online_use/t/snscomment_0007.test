--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt 
#owner group:sql1 
# tags: optimizer
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists comm_del_his_oper (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`owner_user_id` bigint(20) NOT NULL, 
	`owner_nick` varchar(32) NOT NULL, 
	`content` varchar(2000) NOT NULL, 
	`del_count` int(11) NOT NULL, 
	`oper_reason` varchar(512) NOT NULL, 
	`operator_id` bigint(20) NOT NULL, 
	`operator_nick` varchar(32) NOT NULL, 
	`oper_type` tinyint(4) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_oper_operid` (`operator_id`, `gmt_create`, `owner_user_id`)
)  AUTO_INCREMENT = 32102086 CHARSET = utf8;
CREATE TABLE if not exists comm_del_his_owner (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`owner_user_id` bigint(20) NOT NULL, 
	`owner_nick` varchar(32) NOT NULL, 
	`content` varchar(2000) NOT NULL, 
	`del_count` int(11) NOT NULL, 
	`oper_reason` varchar(512) NOT NULL, 
	`operator_id` bigint(20) NOT NULL, 
	`operator_nick` varchar(32) NOT NULL, 
	`oper_type` tinyint(4) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_owner_owneruid` (`owner_user_id`, `gmt_create`, `operator_id`)
)  AUTO_INCREMENT = 32170086 CHARSET = utf8;
--disable_warnings
drop table if exists comment;
--enable_warnings
CREATE TABLE if not exists comment (
	`id` bigint(20) NOT NULL, 
	`target_id` bigint(20) NOT NULL, 
	`target_key` varchar(60) NOT NULL, 
	`pro_user_id` bigint(20) NOT NULL, 
	`pro_user_nick` varchar(32) NULL, 
	`status` tinyint(4) NULL, 
	`whisper` tinyint(4) NULL, 
	`content` varchar(2000) NULL, 
	`rec_user_id` bigint(20) NOT NULL, 
	`rec_user_nick` varchar(32) NULL, 
	`type_id` int(11) NOT NULL, 
	`parent_id` bigint(20) NULL, 
	`quote_id` bigint(20) NULL, 
	`rec_user_pic` varchar(500) NULL, 
	`pro_user_pic` varchar(500) NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`char_1` varchar(1200) NULL, 
	`number_1` bigint(20) NULL, 
	`date_1` datetime NULL, 
	`is_deleted` tinyint(4) DEFAULT '0' NOT NULL, 
	`comment_index` int(11) NULL COMMENT '楼层序号', 
	`tag` varchar(32) NULL, 
	`sub_type` tinyint(4) NULL, 
	`froms` tinyint(4) NULL, 
	`modifier` bigint(20) NULL, 
	`image_urls` varchar(512) NULL, 
	`client_id` bigint(20) DEFAULT '0' NOT NULL COMMENT '客户端id', 
	`app_id` bigint(20) NULL COMMENT '应用id', 
	`ip` varchar(32) NULL COMMENT '记录用户IP', 
	PRIMARY KEY (`id`), 
	KEY `idx_comment_gmtmodified` (`gmt_modified`), 
	KEY `idx_comment_targetid` (`target_id`, `target_key`, `is_deleted`, `gmt_create`, `pro_user_id`), 
	KEY `idx_comment_typeid` (`type_id`, `is_deleted`, `target_key`)
)  CHARSET = utf8;
CREATE TABLE if not exists comment_count (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`target_id` bigint(20) NOT NULL, 
	`target_key` varchar(60) NOT NULL, 
	`type_id` int(11) NOT NULL, 
	`count` int(11) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`client_id` bigint(20) DEFAULT '0' NOT NULL COMMENT 'client id', 
	PRIMARY KEY (`id`), 
	KEY `idx_count_targetid` (`target_id`, `target_key`, `client_id`)
)  AUTO_INCREMENT = 1058323014 CHARSET = utf8;
CREATE TABLE if not exists comment_index (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`target_id` bigint(20) NOT NULL COMMENT '分表字段', 
	`target_key` varchar(60) NOT NULL COMMENT '业务id', 
	`type_id` int(11) NOT NULL, 
	`last_index` int(11) NOT NULL COMMENT '最大楼层序号', 
	`comment_state` tinyint(4) NOT NULL COMMENT '评论状态:1、所有楼层已重置;0、有未置楼层', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`client_id` bigint(20) DEFAULT '0' NOT NULL COMMENT 'client id', 
	PRIMARY KEY (`id`), 
	KEY `idx_ci_cstate` (`comment_state`, `gmt_modified`), 
	KEY `idx_tid_tkey_cid` (`target_id`, `target_key`, `client_id`)
)  AUTO_INCREMENT = 655454165 CHARSET = utf8;
CREATE TABLE if not exists comment_of_mine (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`receiver_id` bigint(20) NOT NULL COMMENT '评论的接受者id', 
	`sender_id` bigint(20) NOT NULL COMMENT '评论的发出者id', 
	`target_key` varchar(60) NOT NULL COMMENT '评论的业务key', 
	`type_id` int(11) NOT NULL, 
	`target_id` bigint(20) NOT NULL COMMENT 'Type_id: Target_key的hashcode值', 
	`comment_id` bigint(20) NOT NULL COMMENT 'Comment的id，与comment表的id关联', 
	`comment_target_info` varchar(2048) NULL COMMENT '评论目标信息', 
	`comment_type` tinyint(4) NOT NULL COMMENT '评论类型，1|评论，2|回复', 
	`is_deleted` char(1) NOT NULL COMMENT '是否已删除', 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录修改时间', 
	`char_1` varchar(256) NULL, 
	`char_2` varchar(256) NULL, 
	`num_1` bigint(20) NULL, 
	`num_2` bigint(20) NULL, 
	`client_id` bigint(20) DEFAULT '0' NOT NULL COMMENT 'client id', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_com_sid` (`sender_id`, `comment_id`)
)  AUTO_INCREMENT = 458963035 CHARSET = utf8;
CREATE TABLE if not exists comment_to_me (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`receiver_id` bigint(20) NOT NULL COMMENT '评论的接受者id', 
	`sender_id` bigint(20) NOT NULL COMMENT '评论的发出者id', 
	`target_key` varchar(60) NOT NULL COMMENT '评论的业务key', 
	`type_id` int(11) NOT NULL, 
	`target_id` bigint(20) NOT NULL COMMENT 'Type_id: Target_key的hashcode值', 
	`comment_id` bigint(20) NOT NULL COMMENT 'Comment的id，与comment表的id关联', 
	`comment_target_info` varchar(2048) NULL COMMENT '评论目标信息', 
	`comment_type` tinyint(4) NOT NULL COMMENT '评论类型，1|评论，2|回复', 
	`is_deleted` char(1) NOT NULL COMMENT '是否已删除', 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录修改时间', 
	`char_1` varchar(256) NULL, 
	`char_2` varchar(256) NULL, 
	`num_1` bigint(20) NULL, 
	`num_2` bigint(20) NULL, 
	`client_id` bigint(20) DEFAULT '0' NOT NULL COMMENT 'client id', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_ctm_rid` (`receiver_id`, `comment_id`), 
	KEY `idx_ctm_rid` (`receiver_id`, `is_deleted`, `gmt_create`, `type_id`)
)  AUTO_INCREMENT = 457435224 CHARSET = utf8;
CREATE TABLE if not exists evaluate (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '鑷1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523涓婚敭', 
	`evaluate_id` bigint(20) NOT NULL COMMENT '璇勪环id', 
	`explain_content` varchar(100) NULL COMMENT '瑙ｉ噴鍐呭1,2,4,6,7,8,11,56,68,89,435,4523', 
	`user_id` bigint(20) NOT NULL COMMENT '解释发表者', 
	`user_nick` varchar(32) NULL COMMENT '解释发表者昵称', 
	`recevied_user_id` bigint(20) NOT NULL COMMENT '被解释者id', 
	`recevied_user_nick` varchar(32) NULL COMMENT '被解释者昵称', 
	`is_deleted` tinyint(4) DEFAULT '0' NOT NULL COMMENT '閫昏緫鍒犻櫎瀛楁1,2,4,6,7,8,11,56,68,89,435,4523', 
	`gmt_create` datetime NOT NULL COMMENT '璁板綍鍒涘缓鏃堕棿', 
	`gmt_modified` datetime NOT NULL COMMENT '璁板綍鏈1,2,4,6,7,8,11,56,68,89,435,4523悗淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿', 
	`modifier_id` bigint(20) NULL COMMENT '鍒犻櫎浜', 
	`comment_id` bigint(20) NOT NULL COMMENT '璇勮1,2,4,6,7,8,11,56,68,89,435,4523id', 
	`item_id` bigint(20) NULL COMMENT '商品id', 
	`creator_id` bigint(20) NULL COMMENT '创建者id，子账号的时候用', 
	PRIMARY KEY (`id`), 
	KEY `idx_eid_sid_id` (`evaluate_id`, `user_id`, `is_deleted`), 
	KEY `idx_iid` (`item_id`, `user_id`, `is_deleted`)
)  AUTO_INCREMENT = 464102047 CHARSET = utf8;
CREATE TABLE if not exists favor (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '鑷1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523涓婚敭', 
	`target_id` int(11) NOT NULL COMMENT '鍒嗚〃渚濇嵁锛宼ypeid:target_key鐨刪ash鍊', 
	`target_key` varchar(60) NOT NULL COMMENT '鐩稿叧涓氬姟鐨勪富閿', 
	`type_id` bigint(20) NOT NULL COMMENT '绫诲瀷', 
	`app_id` bigint(20) NULL COMMENT 'appid', 
	`user_id` bigint(20) NOT NULL COMMENT '鍒涘缓鑰卛d', 
	`rec_user_id` bigint(20) NULL COMMENT '鎺ユ敹璧炵殑鐢ㄦ埛id(鐩稿叧涓氬姟鐨勬嫢鏈夎1,2,4,6,7,8,11,56,68,89,435,4523)', 
	`gmt_create` datetime NOT NULL COMMENT '璁板綍鍒涘缓鏃堕棿', 
	`gmt_modified` datetime NOT NULL COMMENT '璁板綍鏈1,2,4,6,7,8,11,56,68,89,435,4523悗淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿', 
	`sub_type` tinyint(4) NULL COMMENT '瀛愮被鍨1,2,4,6,7,8,11,56,68,89,435,4523椤躲1,2,4,6,7,8,11,56,68,89,435,4523韪╃瓑', 
	`client_id` bigint(20) DEFAULT '0' NOT NULL COMMENT 'clientId', 
	PRIMARY KEY (`id`), 
	KEY `idx_tid_tkey_uid_cid` (`target_id`, `target_key`, `user_id`, `client_id`)
)  AUTO_INCREMENT = 982660149 CHARSET = utf8 COMMENT = '璧';
CREATE TABLE if not exists history_del_comment (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '鑷1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523涓婚敭', 
	`target_id` bigint(20) NOT NULL COMMENT '鍒嗚〃涓1,2,4,6,7,8,11,56,68,89,435,4523仛', 
	`target_key` varchar(60) NOT NULL COMMENT '涓氬姟涓婚敭', 
	`pro_user_id` bigint(20) NOT NULL COMMENT '璇勮1,2,4,6,7,8,11,56,68,89,435,4523鍙戣〃鑰', 
	`pro_user_nick` varchar(32) NULL COMMENT '璇勮1,2,4,6,7,8,11,56,68,89,435,4523鍙戣〃鑰呮樀绉', 
	`status` tinyint(4) NULL, 
	`whisper` tinyint(4) NULL, 
	`content` varchar(2000) NULL COMMENT '璇勮1,2,4,6,7,8,11,56,68,89,435,4523鍐呭1,2,4,6,7,8,11,56,68,89,435,4523', 
	`gmt_create` datetime NOT NULL COMMENT '璁板綍鍒涘缓鏃堕棿', 
	`gmt_modified` datetime NOT NULL COMMENT '璁板綍鏈1,2,4,6,7,8,11,56,68,89,435,4523悗淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿', 
	`rec_user_id` bigint(20) NOT NULL, 
	`rec_user_nick` varchar(32) NULL, 
	`app_id` bigint(20) NULL, 
	`parent_id` bigint(20) NULL, 
	`quote_id` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	`number_1` bigint(20) NULL, 
	`date_1` datetime NULL, 
	`comment_index` int(11) NULL, 
	`tag` varchar(32) NULL, 
	`sub_type` tinyint(4) NULL, 
	`froms` tinyint(4) NULL, 
	`modifier` bigint(20) NULL, 
	`commentid` bigint(20) NULL, 
	`image_urls` varchar(512) NULL, 
	`client_id` bigint(20) DEFAULT '0' NOT NULL COMMENT 'client id', 
	PRIMARY KEY (`id`), 
	KEY `idx_gmt_create` (`gmt_create`), 
	KEY `idx_target_id_commentid` (`target_id`, `commentid`)
)  AUTO_INCREMENT = 143007 CHARSET = utf8 COMMENT = '璇勮1,2,4,6,7,8,11,56,68,89,435,4523鍒犻櫎鍘嗗彶璁板綍琛';
CREATE TABLE if not exists my_comment_count (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`user_id` bigint(20) NOT NULL, 
	`receive_comment_count` bigint(20) NOT NULL, 
	`send_comment_count` bigint(20) NOT NULL, 
	`is_deleted` char(1) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`char_1` varchar(256) NULL, 
	`char_2` varchar(256) NULL, 
	`num_1` bigint(20) NULL, 
	`num_2` bigint(20) NULL, 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_mcc_uid` (`user_id`)
)  AUTO_INCREMENT = 50365017 CHARSET = utf8;
CREATE TABLE if not exists my_favor (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '鑷1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523涓婚敭', 
	`target_id` bigint(20) NOT NULL COMMENT 'typeid:target_key鐨刪ash鍊', 
	`target_key` varchar(60) NOT NULL COMMENT '鐩稿叧涓氬姟鐨勪富閿', 
	`user_id` bigint(20) NOT NULL COMMENT '鍒嗚〃渚濇嵁锛屽垱寤鸿1,2,4,6,7,8,11,56,68,89,435,4523id', 
	`type_id` bigint(20) NOT NULL COMMENT '绫诲瀷', 
	`app_id` bigint(20) NULL COMMENT 'appid', 
	`rec_user_id` bigint(20) NULL COMMENT '鎺ユ敹璧炵殑鐢ㄦ埛id(鐩稿叧涓氬姟鐨勬嫢鏈夎1,2,4,6,7,8,11,56,68,89,435,4523)', 
	`properties` varchar(1024) NULL COMMENT '鎵╁睍灞炴1,2,4,6,7,8,11,56,68,89,435,4523锛屽彲浠ュ寘鎷1,2,4,6,7,8,11,56,68,89,435,4523紙绯荤粺娑堟伅id锛岃浆鍙戠殑feedid绛夛級', 
	`gmt_create` datetime NOT NULL COMMENT '鍒涘缓鏃堕棿', 
	`gmt_modified` datetime NOT NULL COMMENT '淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿', 
	`sub_type` tinyint(4) NULL COMMENT '瀛愮被鍨1,2,4,6,7,8,11,56,68,89,435,4523椤躲1,2,4,6,7,8,11,56,68,89,435,4523韪╃瓑', 
	`client_id` bigint(20) DEFAULT '0' NOT NULL COMMENT 'clientId', 
	PRIMARY KEY (`id`), 
	KEY `idx_uid_tid_cid_st` (`user_id`, `type_id`, `client_id`, `sub_type`, `gmt_create`), 
	KEY `idx_uid_tid_tkey_cid` (`user_id`, `target_id`, `target_key`, `client_id`, `sub_type`)
)  AUTO_INCREMENT = 980979027 CHARSET = utf8 COMMENT = '鎴戣禐杩囩殑琛';

SELECT id, user_id, receive_comment_count, send_comment_count, is_deleted , gmt_create, gmt_modified FROM my_comment_count WHERE user_id = 1 LIMIT 1;
SELECT b.id, b.receiver_id, b.sender_id, b.target_key, b.type_id , b.target_id, b.comment_id, b.comment_target_info, b.comment_type, b.is_deleted , b.gmt_create, b.gmt_modified, b.client_id FROM (SELECT id FROM comment_to_me WHERE receiver_id = 1 AND is_deleted = "3" ORDER BY gmt_create DESC LIMIT 1, 1 ) a, comment_to_me b WHERE a.id = b.id;
SELECT COUNT(id) FROM my_favor WHERE user_id = 1 AND type_id = 1;
SELECT t2.id, t2.target_id, t2.target_key, t2.type_id, t2.app_id , t2.client_id, t2.user_id, t2.rec_user_id, t2.gmt_create, t2.gmt_modified , t2.sub_type FROM (SELECT id FROM favor WHERE target_id = 1 AND sub_type = 1 AND target_key = "3" AND client_id = 1 ORDER BY id DESC LIMIT 1, 1 ) t1, favor t2 FORCE INDEX (PRIMARY) WHERE t1.id = t2.id;
SELECT COUNT(1) FROM comment WHERE target_id = 1 AND target_key = "3" AND client_id = 1 AND is_deleted = 1;
SELECT t2.id, t2.target_id, t2.target_key, t2.user_id, t2.type_id , t2.app_id, t2.client_id, t2.rec_user_id, t2.properties, t2.gmt_create , t2.gmt_modified, t2.sub_type FROM (SELECT id FROM my_favor WHERE user_id = 1 AND type_id = 1 AND client_id = 1 ORDER BY gmt_create DESC LIMIT 1, 1 ) t1, my_favor t2 FORCE INDEX (PRIMARY) WHERE t1.id = t2.id;
SELECT id AS id, target_id AS subjectid, pro_user_id AS ownerid, pro_user_nick AS ownernick, content AS content , gmt_create AS gmtcreate, is_deleted AS isdeleted, 1 AS fromtype, type_id AS typeid FROM comment WHERE pro_user_nick IS NOT NULL AND type_id != 1 AND gmt_modified > "30";
SELECT COUNT(id) FROM comment_to_me WHERE receiver_id = 1 AND is_deleted = "3" AND type_id IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND client_id = 1;
SELECT b.id, b.receiver_id, b.sender_id, b.target_key, b.type_id , b.target_id, b.comment_id, b.comment_target_info, b.comment_type, b.is_deleted , b.gmt_create, b.gmt_modified, b.client_id FROM (SELECT id FROM comment_to_me WHERE receiver_id = 1 AND is_deleted = "3" AND type_id IN (1,2,4,6,7,8,11,56,68,89,435,4523) ORDER BY gmt_create DESC LIMIT 1, 1 ) a, comment_to_me b WHERE a.id = b.id;
SELECT t2.user_id, t2.target_key, t2.type_id, t2.client_id, t2.sub_type FROM (SELECT id FROM my_favor WHERE user_id = 1 ORDER BY gmt_create DESC LIMIT 1, 1 ) t1, my_favor t2 FORCE INDEX (PRIMARY) WHERE t1.id = t2.id;
SELECT COUNT(id) FROM comm_del_his_owner WHERE owner_user_id = 1;
SELECT b.id, b.receiver_id, b.sender_id, b.target_key, b.type_id , b.target_id, b.comment_id, b.comment_target_info, b.comment_type, b.is_deleted , b.gmt_create, b.gmt_modified, b.client_id FROM (SELECT id FROM comment_to_me WHERE receiver_id = 1 AND is_deleted = "3" AND type_id IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND client_id = 1 ORDER BY gmt_create DESC LIMIT 1, 1 ) a, comment_to_me b WHERE a.id = b.id;
SELECT id, target_id, target_key, type_id, last_index , comment_state, gmt_create, gmt_modified, client_id FROM comment_index WHERE target_id = 1 AND target_key = "3" AND client_id = 1 LIMIT 1;
SELECT t2.id, t2.target_id, t2.target_key, t2.type_id, t2.app_id , t2.client_id, t2.user_id, t2.rec_user_id, t2.gmt_create, t2.gmt_modified , t2.sub_type FROM (SELECT id FROM favor WHERE target_id = 1 AND target_key = "3" AND client_id = 1 ORDER BY id DESC LIMIT 1, 1 ) t1, favor t2 FORCE INDEX (PRIMARY) WHERE t1.id = t2.id;
SELECT b.id, b.target_key, b.pro_user_id, b.pro_user_nick, b.pro_user_pic , b.status, b.rec_user_id, b.rec_user_nick, b.rec_user_pic, b.parent_id , b.is_deleted, b.app_id, b.type_id, b.content, b.gmt_create , b.gmt_modified, b.comment_index, b.char_1, b.sub_type, b.modifier , b.froms, b.image_urls, b.client_id FROM (SELECT id FROM comment WHERE target_id = 1 AND target_key = "3" AND client_id = 1 AND is_deleted = 1 ORDER BY gmt_create DESC LIMIT 1, 1 ) a, comment b WHERE a.id = b.id;
SELECT COUNT(id) FROM my_favor WHERE user_id = 1 AND type_id = 1 AND sub_type = 1;
SELECT b.id, b.receiver_id, b.sender_id, b.target_key, b.type_id , b.target_id, b.comment_id, b.comment_target_info, b.comment_type, b.is_deleted , b.gmt_create, b.gmt_modified, b.client_id FROM (SELECT id FROM comment_to_me WHERE receiver_id = 1 AND is_deleted = "3" AND client_id = 1 ORDER BY gmt_create DESC LIMIT 1, 1 ) a, comment_to_me b WHERE a.id = b.id;
SELECT target_key FROM my_favor WHERE user_id = 1 AND type_id = 1 AND client_id = 1 AND target_key IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT COUNT(id) FROM my_favor WHERE user_id = 1 AND type_id = 1 AND client_id = 1;
SELECT t2.id, t2.target_id, t2.target_key, t2.user_id, t2.type_id , t2.app_id, t2.client_id, t2.rec_user_id, t2.properties, t2.gmt_create , t2.gmt_modified, t2.sub_type FROM (SELECT id FROM my_favor WHERE user_id = 1 AND type_id = 1 ORDER BY gmt_create DESC LIMIT 1, 1 ) t1, my_favor t2 FORCE INDEX (PRIMARY) WHERE t1.id = t2.id;
SELECT count FROM comment_count WHERE target_id = 1 AND target_key = "3" AND client_id = 1 LIMIT 1;
SELECT b.id, b.receiver_id, b.sender_id, b.target_key, b.type_id , b.target_id, b.comment_id, b.comment_target_info, b.comment_type, b.is_deleted , b.gmt_create, b.gmt_modified, b.client_id FROM (SELECT id FROM comment_of_mine WHERE sender_id = 1 AND is_deleted = "3" AND type_id IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND client_id = 1 ORDER BY gmt_create DESC LIMIT 1, 1 ) a, comment_of_mine b WHERE a.id = b.id;
SELECT t2.id, t2.target_id, t2.target_key, t2.user_id, t2.type_id , t2.app_id, t2.client_id, t2.rec_user_id, t2.properties, t2.gmt_create , t2.gmt_modified, t2.sub_type FROM (SELECT id FROM my_favor WHERE user_id = 1 AND type_id = 1 AND sub_type = 1 ORDER BY gmt_create DESC LIMIT 1, 1 ) t1, my_favor t2 FORCE INDEX (PRIMARY) WHERE t1.id = t2.id;
SELECT COUNT(id) FROM comment_to_me WHERE receiver_id = 1 AND is_deleted = "3" AND type_id IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT tab.id, tab.owner_user_id, tab.owner_nick, tab.content, tab.del_count , tab.oper_reason, tab.operator_id, tab.operator_nick, tab.oper_type, tab.gmt_create , tab.gmt_modified FROM comm_del_his_owner tab, (SELECT id FROM comm_del_his_owner WHERE owner_user_id = 1 ORDER BY gmt_create DESC LIMIT 1, 1 ) a WHERE a.id = tab.id;
SELECT COUNT(id) FROM comment_of_mine WHERE sender_id = 1 AND is_deleted = "3" AND type_id IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND client_id = 1;
SELECT id AS id, target_id AS subjectid, pro_user_id AS ownerid, pro_user_nick AS ownernick, content AS content , gmt_create AS gmtcreate, is_deleted AS isdeleted, 1 AS fromtype, type_id AS typeid FROM comment WHERE pro_user_nick IS NOT NULL AND type_id != 1 AND gmt_modified <= "3" AND gmt_modified >= "3";
SELECT id, target_id, target_key, user_id, type_id , app_id, client_id, rec_user_id, properties, gmt_create , gmt_modified, sub_type FROM my_favor WHERE user_id = 1 AND target_id = 1 AND target_key = "3" AND client_id = 1 LIMIT 1;
SELECT id, target_key, pro_user_id, pro_user_nick, pro_user_pic , is_deleted, status, rec_user_id, rec_user_nick, rec_user_pic , parent_id, app_id, type_id, content, gmt_create , gmt_modified, comment_index, char_1, sub_type, modifier , froms, image_urls, client_id FROM comment WHERE id = 1 AND target_id = 1;
SELECT target_key, type_id, client_id, count FROM comment_count WHERE target_id IN (1,2,4,6,7,8,11,56,68,89,435,4523);

