UPDATE comment_count SET count = count + 1, gmt_modified = now() WHERE target_id = 1 AND target_key = "3" AND client_id = 1;
UPDATE comment SET is_deleted = 1, gmt_modified = now(), modifier = 1 WHERE id = 1 AND target_id = 1;
UPDATE my_comment_count SET receive_comment_count = receive_comment_count + 1, gmt_modified = now() WHERE user_id = 1;
UPDATE my_comment_count SET receive_comment_count = receive_comment_count - 1, gmt_modified = now() WHERE user_id = 1 AND receive_comment_count > 1;
UPDATE my_comment_count SET send_comment_count = send_comment_count - 1, gmt_modified = now() WHERE user_id = 1 AND send_comment_count > 1;
UPDATE comment_index SET last_index = 1, gmt_modified = now() WHERE target_id = 1 AND target_key = "3" AND client_id = 1 AND last_index = 1;
UPDATE comment_to_me SET is_deleted = "3", gmt_modified = now() WHERE receiver_id = 1 AND comment_id = 1 AND is_deleted = "3";
UPDATE comment_of_mine SET is_deleted = "3", gmt_modified = now() WHERE sender_id = 1 AND comment_id = 1 AND is_deleted = "3";
UPDATE my_comment_count SET send_comment_count = send_comment_count + 1, gmt_modified = now() WHERE user_id = 1;
UPDATE comment_count SET count = 1, gmt_modified = now() WHERE target_id = 1 AND target_key = "3" AND client_id = 1;

