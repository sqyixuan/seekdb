--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: jim.wjh
#owner group:sql2
#tags new_online_use 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists like_ids (
	`id` bigint(20) NOT NULL COMMENT '主键', 
	`type` varchar(300) NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = 'like序列表';
CREATE TABLE if not exists sina_comment (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`fid` bigint(20) NOT NULL COMMENT '分表字段', 
	`app_id` bigint(20) NOT NULL COMMENT '应用id', 
	`target_key` varchar(60) NOT NULL COMMENT '业务标识', 
	`type` int(11) DEFAULT '0' NOT NULL COMMENT '分享类型', 
	`out_id` varchar(1024) NULL COMMENT '商品或店铺id', 
	`total_count` int(11) DEFAULT '0' NOT NULL COMMENT '评论总数', 
	PRIMARY KEY (`id`), 
	KEY `idx_fid` (`fid`)
)  AUTO_INCREMENT = 449 CHARSET = utf8 COMMENT = '新浪评论数据同步到淘宝';
CREATE TABLE if not exists sina_like (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`original_id` bigint(20) NOT NULL COMMENT '分表字段', 
	`sina_id` bigint(20) NOT NULL COMMENT '新浪喜欢id', 
	`uid` bigint(20) NOT NULL COMMENT '用户id', 
	`create_at` datetime NULL COMMENT '创建时间', 
	`operation` int(11) NULL COMMENT '操作', 
	`object_type` varchar(60) NULL COMMENT '对象类型', 
	PRIMARY KEY (`id`), 
	KEY `idx_oid_sid` (`original_id`, `sina_id`)
)  AUTO_INCREMENT = 3626 CHARSET = utf8 COMMENT = '新浪喜欢数据同步';
CREATE TABLE if not exists sns_like (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`target_key` bigint(20) NOT NULL COMMENT '分表字段，主体业务id(如：商品id/店铺id)', 
	`user_id` bigint(20) NOT NULL COMMENT '喜欢操作的用户id', 
	`like_type` tinyint(4) NOT NULL COMMENT '喜欢类型，1：商品，2：店铺；3：其他', 
	`app_id` bigint(20) NULL COMMENT '应用标记', 
	`rec_user_id` bigint(20) NULL COMMENT '喜欢主体的用户id', 
	`properties` varchar(1024) NULL COMMENT '记录其他属性', 
	`is_deleted` tinyint(4) DEFAULT '0' NOT NULL COMMENT '是否删除，0:未删除；1:已删除', 
	`client_id` bigint(20) NULL COMMENT '业务方id', 
	`row_key` varchar(64) NULL COMMENT '关联收藏夹row_key', 
	PRIMARY KEY (`id`), 
	KEY `idx_tkey_uid_ltype` (`target_key`, `user_id`, `like_type`)
)  AUTO_INCREMENT = 35301 CHARSET = utf8 COMMENT = '新喜欢组件喜欢记录表';

SELECT id, gmt_create, gmt_modified, target_key, user_id , like_type, app_id, rec_user_id, properties, is_deleted , client_id, row_key FROM sns_like;
