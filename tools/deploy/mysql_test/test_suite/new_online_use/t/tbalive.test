SELECT * FROM wireless_code WHERE codeid = "3";
SELECT a.class_id, a.item_id, MAX(a.gmt_create) AS importtime FROM content_item a LEFT JOIN app_content b ON a.app_content_id = b.id WHERE b.status = 1 AND a.status = 1 AND a.item_id != 1 AND a.class_id != 1 AND b.biz_type = 1 GROUP BY a.class_id, a.item_id;
SELECT * FROM content_item WHERE app_content_id = "3" AND status = 1;
SELECT * FROM content_item WHERE item_id != 1 AND status = 1 AND biz_type = 1 AND class_id = 1 AND gmt_create >= date_sub(now(), INTERVAL 1 DAY);
