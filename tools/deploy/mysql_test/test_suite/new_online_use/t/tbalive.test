SELECT id, group_id, user_id, class_id, biz_type , gmt_create, gmt_modified FROM app_content WHERE user_id = "3" AND class_id = "3" AND biz_type = 1 AND status = 1 ORDER BY gmt_create DESC LIMIT 1;
SELECT id, user_id, owner_id, class_id, action_type , biz_type, content_id, group_id, status, gmt_create , gmt_modified FROM user_record WHERE status != 1 AND class_id = 1 AND biz_type = 1 AND action_type = 1 AND content_id = 1 LIMIT 1, 1;
SELECT b.title, b.id, c.buy_url, b.summary, c.pic_url , c.item_price, c.item_id, c.item_quantity FROM user_record a LEFT JOIN app_content b ON a.content_id = b.id LEFT JOIN content_item c ON b.id = c.app_content_id WHERE a.class_id = 1 AND a.biz_type = 1 AND a.status = 1 AND b.status = 1 AND c.status != 1 AND a.group_id = 1 AND a.action_type = 1 AND a.user_id = 1 ORDER BY a.order_id, a.gmt_modified LIMIT 1, 1;
SELECT COUNT(*) FROM user_record a LEFT JOIN app_content b ON a.content_id = b.id WHERE a.class_id = 1 AND a.biz_type = 1 AND a.status = 1 AND b.status = "3" AND a.group_id = "3" AND a.action_type = 1 AND a.user_id = "3";
SELECT id, user_id, nick, class_id, biz_type , cover_image_url, properties, input_properties, title, features , status, tags, gmt_create, gmt_modified, user_modified FROM content_group WHERE status != 1 AND class_id = 1 AND biz_type = 1 AND user_id = 1 AND title = "3";
