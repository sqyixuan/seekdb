SELECT COUNT(1) FROM content_group WHERE status != 1 AND class_id = 1 AND id IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT id AS id, gmt_create AS gmtcreate, gmt_modified AS gmtmodified, parentpid AS parentpid, name AS name , alias AS alias, description AS description, image AS image, feature AS feature, class_id AS classid , biz_type AS biztype, sort_order AS sortorder, pid AS pid, flaguse AS flaguse FROM listproperty WHERE (flaguse != 1 OR flaguse IS NULL) AND class_id = 1 ORDER BY sortorder;
SELECT COUNT(*) FROM content_pic WHERE app_content_id = 1 AND status = 1;
SELECT COUNT(1) FROM user_record WHERE status != 1 AND class_id = 1 AND biz_type = 1 AND action_type = 1 AND content_id = 1;
SELECT id, gmt_create, gmt_modified, user_id, class_id , group_id, biz_type, cover_image_url, properties, input_properties , content_id, nick, title, summary, features , status, user_modified, tfs_path, tags, content_items , extend_info, extend_imginfo FROM app_content WHERE app_content.status = 1 OR app_content.class_id = 1 ORDER BY app_content.group_id ASC, CASE WHEN tags  and 1=1 THEN 1 ELSE 1 END, app_content.gmt_create DESC;
