SELECT COUNT(1) FROM app_content WHERE status != 1 AND class_id = 1 AND group_id = 1;
SELECT id, user_id, class_id, group_id, biz_type , cover_image_url, properties, input_properties, content_id, nick , title, summary, features, content_items, status , tfs_path, tags, gmt_create, gmt_modified, user_modified FROM app_content WHERE status != 1 AND class_id = 1 AND biz_type = 1 AND user_id = 1 ORDER BY gmt_modified DESC LIMIT 1, 1;
