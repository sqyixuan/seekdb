SELECT id, user_id, nick, class_id, biz_type , cover_image_url, properties, input_properties, title, features , status, tags, gmt_create, gmt_modified, user_modified FROM content_group WHERE status = 1 AND EXISTS (SELECT 1 FROM user_role WHERE user_id = content_group.user_id AND class_id = content_group.class_id AND role_id = 1 AND status = 1) AND class_id = 1 AND biz_type = 1 ORDER BY user_modified DESC LIMIT 1, 1;
