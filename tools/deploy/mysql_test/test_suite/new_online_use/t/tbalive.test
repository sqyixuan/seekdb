SELECT id, user_id, nick, class_id, biz_type , cover_image_url, properties, input_properties, title, features , status, tags, gmt_create, gmt_modified, user_modified FROM content_group WHERE status != 1 AND class_id = 1 AND biz_type = 1 AND id IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT id, user_id, class_id, biz_type, group_id , app_content_id, order_id, item_name, item_type, buy_url , item_id, item_price, item_quantity, pic_url, category_id , seller_id, online, category_level2, status, feature , gmt_create, gmt_modified FROM content_item WHERE 1 = 1 AND status = 1 AND app_content_id = 1 ORDER BY gmt_create ASC LIMIT 1, 1;
