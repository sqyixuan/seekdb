SELECT id, user_id, role_id, class_id, field_values , status, features, gmt_create, gmt_modified, user_modified , role_type, nick FROM user_role WHERE 1 = 1 AND status = 1 AND class_id = 1 ORDER BY gmt_create DESC LIMIT 1, 1;
