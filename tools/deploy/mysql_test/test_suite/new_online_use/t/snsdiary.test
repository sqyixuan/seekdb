--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt 
#owner group:sql1 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists diary_ids (
	`id` bigint(20) NULL COMMENT 'id', 
	`type` varchar(118) NOT NULL COMMENT '1,2,4,6,7,8,11,56,68,89,435,45233¨¤¨¤D¨a', 
	`gmt_modified` datetime NULL, 
	PRIMARY KEY (`type`)
)  CHARSET = utf8;
CREATE TABLE if not exists from_data (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`start_date` datetime NOT NULL, 
	`end_date` datetime NOT NULL, 
	`from_name` varchar(20) NOT NULL, 
	`from_url` varchar(200) NULL, 
	`create_user_id` bigint(20) NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_fd_sdate` (`start_date`, `end_date`)
)  AUTO_INCREMENT = 3491 CHARSET = utf8;
CREATE TABLE if not exists topic_widget (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`topic` varchar(50) NOT NULL COMMENT 'widget绑定的话题', 
	`from_id` bigint(20) NULL COMMENT 'widget的来源信息', 
	`creator` bigint(20) NOT NULL COMMENT '创建改widget的用户id', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	PRIMARY KEY (`id`), 
	KEY `idx_tw_fid` (`from_id`, `topic`), 
	KEY `idx_tw_tic` (`topic`)
)  AUTO_INCREMENT = 60783 CHARSET = utf8 COMMENT = '话题widget注册信息';
CREATE TABLE if not exists fa_diary (
	`id` bigint(20) NOT NULL, 
	`feeds_id` bigint(20) NOT NULL, 
	`user_id` bigint(20) NOT NULL, 
	`user_nick` varchar(32) NOT NULL, 
	`status` tinyint(4) NOT NULL, 
	`pic_url` varchar(200) NULL, 
	`type` tinyint(4) NULL, 
	`content` varchar(4000) NULL, 
	`audit_status` tinyint(4) NULL, 
	`opt_id` bigint(20) NULL, 
	`opt_nick` varchar(32) NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`number_1` bigint(20) NULL, 
	`char_1` varchar(256) NULL, 
	`date_1` datetime NULL, 
	`publish_type` tinyint(4) DEFAULT '0' NOT NULL, 
	`property` varchar(2000) NULL, 
	`forward_count` int(11) DEFAULT '0' NOT NULL, 
	`origin_id` bigint(20) NULL, 
	`origin_user_id` bigint(20) NULL, 
	`origin_user_nick` varchar(32) NULL, 
	`origin_content` varchar(4000) NULL, 
	`forward_id` bigint(20) NULL, 
	`forward_user_id` bigint(20) NULL, 
	`is_deleted` char(1) DEFAULT 'n' NOT NULL, 
	`origin_type` bigint(20) DEFAULT '12005723' NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `user_id` (`user_id`, `gmt_create`, `type`), 
	KEY `idx_diary_isdeleted` (`is_deleted`, `gmt_create`, `user_id`), 
	KEY `idx_diary_gmtmodified` (`gmt_modified`)
)  CHARSET = utf8;
CREATE TABLE if not exists follow_topic (
	`id` int(10) UNSIGNED NOT NULL, 
	`user_id` int(11) NOT NULL COMMENT '用户id', 
	`topics` varchar(500) NOT NULL COMMENT '话题关注列表', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_ft_uid` (`user_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists weibo_outer (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`weibo_id` bigint(20) NOT NULL, 
	`outer_id` bigint(20) NOT NULL, 
	`user_id` bigint(20) NOT NULL, 
	`outer_user_id` bigint(20) NOT NULL, 
	`outer_type` bigint(20) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_outer_weiboid` (`weibo_id`, `outer_user_id`, `outer_id`), 
	KEY `idx_outder_outerid` (`outer_id`, `outer_user_id`, `outer_type`)
)  AUTO_INCREMENT = 4796821 CHARSET = utf8;
CREATE TABLE if not exists weibo_rollcall (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`user_id` bigint(20) NOT NULL, 
	`weibo_id` bigint(20) NOT NULL, 
	`owner_id` bigint(20) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_weibo_weiboid` (`weibo_id`, `user_id`)
)  AUTO_INCREMENT = 7590009 CHARSET = utf8;
