--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt 
#owner group:sql1 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists tad_compute (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '卖家id', 
	`task_id` bigint(20) UNSIGNED NOT NULL COMMENT '任务主键', 
	`status` tinyint(4) DEFAULT '1' NOT NULL COMMENT '1 可以计算 0不能被计算', 
	PRIMARY KEY (`id`), 
	KEY `k_sellerid_taskid_status` (`seller_id`, `task_id`, `status`)
)  CHARSET = utf8 COMMENT = '用于实时计算的任务';
CREATE TABLE if not exists tadx_sequence (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`type` varchar(64) NOT NULL COMMENT '序列名字', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 20001 CHARSET = utf8 COMMENT = '生成sequence的表';
CREATE TABLE if not exists tad_content (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`name` varchar(128) NOT NULL COMMENT '内容名称', 
	`content`varchar(100)NOT NULL COMMENT '内容的json串', 
	`status` tinyint(4) DEFAULT '1' NOT NULL COMMENT '内容状态', 
	PRIMARY KEY (`id`), 
	KEY `k_sellerid` (`seller_id`)
)  AUTO_INCREMENT = 1794241 CHARSET = utf8 COMMENT = '内容存储表';
CREATE TABLE if not exists tad_content_item (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`content_id` bigint(20) UNSIGNED NOT NULL COMMENT '内容id', 
	`item_id` bigint(20) UNSIGNED NOT NULL COMMENT '商品id', 
	`status` tinyint(4) DEFAULT '1' NOT NULL COMMENT '1 正常', 
	PRIMARY KEY (`id`), 
	KEY `k_sellerid_contentid` (`seller_id`, `content_id`), 
	KEY `k_selleid_itemid` (`seller_id`, `item_id`)
)  AUTO_INCREMENT = 16254 CHARSET = utf8 COMMENT = '内容和商品的item映射关系';
CREATE TABLE if not exists tad_name_list (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`type` int(11) NOT NULL COMMENT '名单类型：1，同店推荐；2，看了又看', 
	`status` int(11) NOT NULL COMMENT '名单状态 1：有效；2：无效', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '卖家的userId', 
	PRIMARY KEY (`id`), 
	KEY `k_seller` (`seller_id`, `type`, `status`)
)  CHARSET = utf8 COMMENT = '卖家的白名单';
CREATE TABLE if not exists tad_plan (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`plan_type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '计划类型的数据来源和tad_task表的activity_type一致', 
	`terminal_type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '终端的类型', 
	`name` varchar(256) NOT NULL COMMENT '计划的名称', 
	`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '计划的状态', 
	PRIMARY KEY (`id`), 
	KEY `k_selelrid_status` (`seller_id`, `status`)
)  AUTO_INCREMENT = 840768 CHARSET = utf8 COMMENT = '卖家计划表';
CREATE TABLE if not exists tad_task (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`plan_id` bigint(20) NOT NULL COMMENT 'tad_plan表的主键', 
	`resource_id` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '资源id，目前是渠道商品的itemid', 
	`resource_code` varchar(128) DEFAULT '0' NOT NULL COMMENT '资源的resource_code，目前主要有detail一区和二区', 
	`content_id` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '内容的id', 
	`user_tag_id` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '人群id', 
	`activity_type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '活动类型和tad_plan表中的plan_type一样,冗余', 
	`status` tinyint(4) DEFAULT '0' NOT NULL COMMENT '任务的状态：-1取消,0初始,1已开始；3运行成功结束；4异常结束', 
	`compute_mode` tinyint(4) DEFAULT '0' NOT NULL COMMENT '计算模式：有js、hsf、tair、http', 
	`priority` tinyint(4) DEFAULT '0' NOT NULL COMMENT '优先级，对于同一个资源位，该值越大，优先级越高', 
	`terminal_type` tinyint(4) DEFAULT '0' NOT NULL COMMENT '冗余tad_plan中的terminal_type', 
	`env` tinyint(4) DEFAULT '0' NOT NULL COMMENT '环境变量', 
	PRIMARY KEY (`id`), 
	KEY `k_sellerid_itemid` (`seller_id`, `resource_id`), 
	KEY `k_sellerid_planid` (`seller_id`, `plan_id`), 
	KEY `k_sellerid_contentid` (`seller_id`, `content_id`), 
	KEY `k_sellerid_status` (`seller_id`, `status`)
)  AUTO_INCREMENT = 27369 CHARSET = utf8 COMMENT = '任务表';

SELECT id FROM tadx_sequence WHERE type = "3";
SELECT id, plan_id, seller_id, resource_id, resource_code , content_id, user_tag_id, activity_type, status, compute_mode , priority, terminal_type, env, gmt_create, gmt_modified FROM tad_task WHERE seller_id = 1 AND status = 1;
SELECT id, gmt_create, gmt_modified, seller_id, name , status, plan_type, terminal_type FROM tad_plan WHERE seller_id = 1 AND id = 1 AND status = 1;
SELECT id, gmt_create, gmt_modified, seller_id, name , status, plan_type, terminal_type FROM tad_plan WHERE seller_id = 1 AND status IN (1,2,4,6,7,8,11,56,68,89,435,4523) ORDER BY gmt_create DESC LIMIT 1, 1;
SELECT id, gmt_create, gmt_modified, seller_id, name , status, plan_type, terminal_type FROM tad_plan WHERE seller_id = 1 AND id = 1;
SELECT id, plan_id, seller_id, resource_id, resource_code , content_id, user_tag_id, activity_type, status, compute_mode , priority, terminal_type, env, gmt_create, gmt_modified FROM tad_task WHERE seller_id = 1 AND plan_id = 1 AND status = 1;
SELECT id, plan_id, seller_id, resource_id, resource_code , content_id, user_tag_id, activity_type, status, compute_mode , priority, terminal_type, env, gmt_create, gmt_modified FROM tad_task WHERE seller_id = 1 AND resource_id IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND status = 1;
SELECT COUNT(*) FROM tad_plan WHERE seller_id = 1 AND terminal_type = 1 AND status IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT id, plan_id, seller_id, resource_id, resource_code , content_id, user_tag_id, activity_type, status, compute_mode , priority, terminal_type, env, gmt_create, gmt_modified FROM tad_task WHERE seller_id = 1 AND plan_id = 1 AND status IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT id, gmt_create, gmt_modified, seller_id, name , content, status FROM tad_content WHERE seller_id = 1 AND id = 1;

INSERT INTO tad_task (id, plan_id, seller_id, resource_id, resource_code , content_id, user_tag_id, activity_type, status, compute_mode , priority, terminal_type, env, gmt_create, gmt_modified) VALUES (1, 1, 1, 1, "2015-09-30 12:00:00" , 1, 1, 1, 1, 1 , 1, 1, 1, now(), now());
INSERT INTO tad_content (id, gmt_create, gmt_modified, seller_id, name , content, status) VALUES (1, now(), now(), 1, "2015-09-30 12:00:00" , "2015-09-30 12:00:00", 1);
INSERT INTO tad_plan (id, gmt_create, gmt_modified, seller_id, name , status, plan_type, terminal_type) VALUES (1, now(), now(), 1, "2015-09-30 12:00:00" , 1, 1, 1);
INSERT INTO tad_content_item (id, gmt_create, gmt_modified, seller_id, item_id , status, content_id) VALUES (1, now(), now(), 1, 1 , 1, 1);

UPDATE tad_content_item SET gmt_modified = now(), status = 1 WHERE seller_id = 1 AND content_id = 1;
UPDATE tadx_sequence SET id = 1, gmt_modified = "2016-09-30 12:00:00" WHERE type = "3" AND id = 1;
UPDATE tad_plan SET gmt_modified = now(), status = 1 WHERE seller_id = 1 AND id = 1;
UPDATE tad_task SET gmt_modified = now(), content_id = 1 WHERE seller_id = 1 AND id = 1;
UPDATE tad_task SET gmt_modified = now(), status = 1 WHERE seller_id = 1 AND id = 1;
UPDATE tad_content SET status = 1, gmt_modified = now() WHERE seller_id = 1 AND id = 1;
UPDATE tad_plan SET gmt_modified = now(), name = "3" WHERE seller_id = 1 AND id = 1;
