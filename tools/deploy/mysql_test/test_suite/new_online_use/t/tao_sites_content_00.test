--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: jim.wjh
#owner group:sql2
#tags new_online_use 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists sp_content (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '分表字段 主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '内容所属用户', 
	`site_id` bigint(20) UNSIGNED DEFAULT '0' COMMENT '内容所属站点', 
	`site_category_id` int(10) UNSIGNED NOT NULL COMMENT '内容所属物种', 
	`schema_name` varchar(32) NOT NULL COMMENT '内容对应的schema', 
	`type` int(11) NOT NULL COMMENT '内容来源。 1：拖拽版， 2：编码版', 
	`title` varchar(256) NOT NULL COMMENT '内容标题', 
	`status` int(11) NOT NULL COMMENT '内容状态。 1：正常 -1：删除', 
	`modify_time` datetime NULL COMMENT '内容最后修改时间', 
	`content_class_id` int(11) NULL COMMENT '内容所属分类', 
	`tags` varchar(512) NULL COMMENT '内容的标签信息，逗号分割', 
	`refer_id` bigint(20) NULL COMMENT '内容相关的外部关联ID,如sns的内容id等', 
	`target_type` int(11) NULL COMMENT '内容附着的目标的类型 1：其他内容；2：ITEM, 3：SPU', 
	`target_id` bigint(20) NULL COMMENT '附着目标的目标id', 
	`refer_items` varchar(2048) NULL COMMENT '该内容关联到的商品id。如果有多个商品，用逗号分割', 
	`content_class_name` varchar(256) NULL COMMENT '内容分类名称（冗余字段）', 
	`like_num` int(11) DEFAULT '0' NOT NULL COMMENT '喜欢数', 
	`share_num` int(11) DEFAULT '0' NOT NULL COMMENT '分享数', 
	`comment_num` int(11) DEFAULT '0' NOT NULL COMMENT '评论数', 
	`view_num` int(11) DEFAULT '0' NOT NULL COMMENT '浏览数', 
	`top_enable` bigint(20) UNSIGNED NOT NULL COMMENT '是否置顶', 
	`keyword` varchar(256) NULL COMMENT '关键词', 
	`out_id` bigint(20) NULL COMMENT '如果该内容是从外部抓取的，则表示的是外部来源ID', 
	`out_refer_url` varchar(512) NULL COMMENT '如果该内容是从外部抓取的，则表示的是外部来源的URL', 
	`main_pic` varchar(512) NULL COMMENT '内容主图', 
	`target_url` varchar(512) NULL COMMENT '目标URL，展现内容详情的URL', 
	`market_ids` varchar(80) NULL COMMENT '关联的行业市场ID，逗号分割', 
	`cat_ids` varchar(150) NULL COMMENT '内容关联的类目ID', 
	`tae_site_id` bigint(20) UNSIGNED NOT NULL COMMENT 'tae的站点id', 
	`mark` int(11) DEFAULT '0' COMMENT '内容扩展属性，用于内容打标', 
	`intervention_score` double DEFAULT '0' COMMENT '小二干预质量分', 
	PRIMARY KEY (`id`), 
	KEY `idx_schemaname` (`schema_name`)
)  AUTO_INCREMENT = 226390528 CHARSET = utf8 COMMENT = '建站平台 内容表';
CREATE TABLE if not exists sp_content_extends (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`content_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段 内容id', 
	`field_key` varchar(256) NOT NULL COMMENT '内容字段key', 
	`field_value` varchar(4096) NULL COMMENT '内容字段value', 
	`custom` int(11) DEFAULT '0' NOT NULL COMMENT '当前key是否为用户自定义', 
	`tae_site_id` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '站点ID', 
	PRIMARY KEY (`id`), 
	KEY `idx_content_id` (`content_id`)
)  AUTO_INCREMENT = 1873050140 CHARSET = utf8 COMMENT = '建站平台 内容扩展表';
CREATE TABLE if not exists sp_content_tag (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`site_id` bigint(20) UNSIGNED DEFAULT '0' COMMENT '所属站点', 
	`name` varchar(16) NOT NULL COMMENT 'tag 名称', 
	`site_category_id` int(11) NOT NULL COMMENT '物种', 
	`tae_site_id` bigint(20) UNSIGNED NOT NULL COMMENT 'tae站点ID', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_sp_content_tag_tae_site_id` (`tae_site_id`, `name`)
)  AUTO_INCREMENT = 16979267 CHARSET = utf8 COMMENT = '建站平台 内容标签表';
CREATE TABLE if not exists sp_content_tag_mapping (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`content_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段 内容ID', 
	`tag_id` bigint(20) UNSIGNED NOT NULL COMMENT '标签ID', 
	`tag_name` varchar(20) NULL COMMENT '标签名称，冗余字段', 
	`class_id` bigint(20) UNSIGNED NOT NULL COMMENT '内容类目ID', 
	`site_category_id` int(11) NOT NULL COMMENT '物种ID', 
	`site_id` bigint(20) UNSIGNED DEFAULT '0' COMMENT 'sp_site 主键ID', 
	`tae_site_id` bigint(20) UNSIGNED NOT NULL COMMENT 'tae的站点ID', 
	PRIMARY KEY (`id`), 
	KEY `idx_content_id` (`content_id`), 
	KEY `idx_contentid_tagid` (`content_id`, `tag_id`)
)  AUTO_INCREMENT = 896380434 CHARSET = utf8 COMMENT = '内容标签映射表';

SELECT id, site_id, name, user_id, tae_site_id FROM sp_content_tag WHERE tae_site_id = 1 AND user_id = 1;
SELECT content_id, tag_id, tag_name FROM sp_content_tag_mapping WHERE content_id = 1;

INSERT INTO sp_content (id, user_id, site_id, tae_site_id, site_category_id , schema_name, type, title, status, modify_time , content_class_id, target_type, target_id, main_pic, refer_items , refer_id, keyword, market_ids, target_url, cat_ids , gmt_create, gmt_modified, top_enable, mark) VALUES (1, 1, 1, 1, 1 , "2015-09-30 12:00:00", 1, "2015-09-30 12:00:00", 1, now() , 1, 1, 1, "2015-09-30 12:00:00", "2015-09-30 12:00:00" , 1, 1, 1, 1, 1 , now(), now(), 1, 1);
INSERT INTO sp_content_tag (id, site_id, name, user_id, gmt_create , gmt_modified, site_category_id, tae_site_id) VALUES (1, 1, "2015", 1, now() , now(), 1, 1);

UPDATE sp_content SET gmt_modified = now(), top_enable = 1 WHERE id = 1;
UPDATE sp_content SET gmt_modified = now(), status = 1 WHERE id = 1;
UPDATE sp_content SET gmt_modified = now(), modify_time = now(), refer_items = "3", title = "3", content_class_id = 1, main_pic = "3", target_url = "3" WHERE id = 1;
UPDATE sp_content_extends SET field_value = "3", gmt_modified = now() WHERE content_id = 1 AND field_key = "3";
UPDATE sp_content SET gmt_modified = now(), modify_time = now(), refer_items = "3", title = "3", content_class_id = 1, main_pic = "3", mark = 1, target_url = "3" WHERE id = 1;

DELETE FROM sp_content_tag_mapping WHERE content_id = 1;
