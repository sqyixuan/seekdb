SELECT COUNT(*) FROM gp_card WHERE 1 = 1 AND service_area = 1 AND biz_id = 1;
SELECT id, sn_number, stauts, gmt_create, gmt_modified FROM game_cat_permis_key WHERE sn_number = 1 ORDER BY stauts DESC;
SELECT * FROM bail_batch WHERE status = 1 AND unfreezy_time < "30";
SELECT id, card_id, status, gmt_create, gmt_modified , file_error, file_url, file_name, user_id, amount , amount_error FROM gp_card_file WHERE card_id = 1;
SELECT id, gmt_create, status, coop_id, game_forest_id , equipment_type, business_mode, complaints_rate, success_rate, delivery_speed , pay_sum FROM game_cooperation_service_zhibiao WHERE coop_id = "3" AND game_forest_id = 1 AND equipment_type = "3" AND business_mode = 1 AND status = 1 LIMIT 1;
SELECT bail.seller_id, bail.freezy_time, bail.type, bail.source, bail.out_order_id , bail.amount FROM bail_log bail WHERE status = 1 AND type = 1 AND gmt_create < "2016-09-30 00:00:01" AND gmt_create >= "3";
