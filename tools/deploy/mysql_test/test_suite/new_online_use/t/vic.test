CREATE TABLE if not exists game_cooperation_service_zhibiao (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`status` int(11) DEFAULT '1' NOT NULL COMMENT '方便运营控制，默认填写1-正常', 
	`coop_id` varchar(16) NOT NULL COMMENT '服务商ID，因为汇总得不到ID，改为服务商nike', 
	`game_forest_id` bigint(20) UNSIGNED NOT NULL COMMENT '游戏类目ID', 
	`equipment_type` varchar(32) NOT NULL COMMENT '交易类型：游戏币：44791 点卡：28136 装备：27533 账号：3249948 代练：58338 道具：44789 点券：3240975 装备代打：131277252 其他剩余：other', 
	`business_mode` int(11) NOT NULL COMMENT '交易方式（1-担保交易， 2-寄售交易）', 
	`complaints_rate` int(11) NOT NULL COMMENT '投诉率（精度到百分位，元数据为扩大1,2,4,6,7,8,11,56,68,89,435,452300倍，既：23.33% 存储为 2333）投诉率：投诉次数/总交易笔数×1,2,4,6,7,8,11,56,68,89,435,4523%', 
	`success_rate` int(11) NOT NULL COMMENT '成功率（精度到百分位，元数据为扩大1,2,4,6,7,8,11,56,68,89,435,452300倍，既：23.33% 存储为 2333）成功率：成功笔数/总交易笔数×1,2,4,6,7,8,11,56,68,89,435,4523%', 
	`delivery_speed` int(11) NOT NULL COMMENT '平均发货速度（整数，如195,小数部分省略）', 
	`pay_sum` bigint(20) UNSIGNED NOT NULL COMMENT '总成交笔数（服务商服务笔数）最近30天，支付宝付款笔数', 
	PRIMARY KEY (`id`), 
	KEY `coop_cat_type_mode_status` (`coop_id`, `game_forest_id`, `equipment_type`, `business_mode`, `status`)
)  AUTO_INCREMENT = 20845311 CHARSET = utf8 COMMENT = '4维度服务商指标回流表(30day)';
