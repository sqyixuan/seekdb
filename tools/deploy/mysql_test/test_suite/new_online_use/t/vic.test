--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: jim.wjh
#owner group:sql2
#tags new_online_use 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists auction_game (
	`id` bigint(20) NOT NULL, 
	`auction_id` bigint(20) NOT NULL, 
	`trade_time` varchar(118) NULL COMMENT '方便交易时间，以 - 分隔', 
	`freeze_id` bigint(20) NULL COMMENT '诚信赔付押金表id号', 
	`status` tinyint(4) NOT NULL, 
	`game_name` bigint(20) NULL COMMENT '游戏名', 
	`game_area` bigint(20) NULL COMMENT '游戏区域', 
	`game_server` bigint(20) NULL COMMENT '游戏服务器', 
	`game_camp` bigint(20) NULL COMMENT '游戏阵营', 
	`game_type` bigint(20) NULL COMMENT '物品类型(3249948表示账号; 44791表示游戏币)', 
	`post` int(11) NOT NULL COMMENT '是否支持邮寄', 
	`user_id` bigint(20) NOT NULL, 
	`features` varchar(4000) NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`security_grade` smallint(6) NULL COMMENT '安全等级', 
	`freezeid_account` bigint(20) NULL COMMENT '增值服务freezeId', 
	`msg_for_check` varchar(2000) NULL COMMENT '猎宝审核结果', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_game_auctionid` USING BTREE (`auction_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists auction_refresh (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键自增id', 
	`game_name` bigint(20) NOT NULL COMMENT '游戏名称id', 
	`game_name_str` varchar(50) NOT NULL COMMENT '游戏名称', 
	`game_area` bigint(20) NOT NULL COMMENT '游戏区id', 
	`game_area_str` varchar(50) NOT NULL COMMENT '游戏区名称', 
	`game_server` bigint(20) NULL COMMENT '游戏服务器id', 
	`game_server_str` varchar(50) NULL COMMENT '游戏服务器名称', 
	`operator_usre_id` bigint(20) NOT NULL COMMENT '操作人id', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NULL COMMENT '修改时间', 
	`new_game_area` bigint(20) NOT NULL COMMENT '修改后游戏区id', 
	`new_game_area_str` varchar(50) NOT NULL COMMENT '修改后游戏区名称', 
	`new_game_server` bigint(20) NULL COMMENT '修改后游戏服务器id', 
	`new_game_server_str` varchar(50) NULL COMMENT '修改后游戏服务器名称', 
	`flag` varchar(1) NOT NULL COMMENT '处理标示0-未处理，1-已处理，2-正在处理，3-失败，4-撤销', 
	`features` varchar(255) NULL COMMENT '备注', 
	PRIMARY KEY (`id`), 
	KEY `ind_auction_refresh_fg` (`flag`, `gmt_create`), 
	KEY `ind_auction_refresh_gmtc` (`gmt_create`)
)  AUTO_INCREMENT = 866 CHARSET = utf8 COMMENT = '注释区服商品刷新';
CREATE TABLE if not exists auction_vertical_property (
	`id` bigint(20) NOT NULL, 
	`auction_var_id` varchar(32) NULL, 
	`vertical_type` int(11) NOT NULL, 
	`properties` varchar(4000) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`auction_id` bigint(20) NULL, 
	PRIMARY KEY (`id`), 
	UNIQUE `idx_auc_ver_pro_aucid` (`auction_id`, `vertical_type`)
)  CHARSET = utf8;
CREATE TABLE if not exists bail_batch (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`out_order_id` varchar(32) NOT NULL COMMENT '外部id,这个是根据一定的规则生成的', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '商家id', 
	`amount` bigint(20) UNSIGNED DEFAULT '0' COMMENT '冻结金额', 
	`unfreezy_time` datetime NULL COMMENT '解冻到期时间', 
	`type` int(11) NOT NULL COMMENT '冻结类型', 
	`source` int(11) NOT NULL COMMENT '来源', 
	`status` int(11) NOT NULL COMMENT '冻结状态（0 – 待冻结 1 – 已冻结 2 – 已解冻）', 
	PRIMARY KEY (`id`), 
	UNIQUE `idx_bail_batch_ord` (`out_order_id`), 
	KEY `idx_bail_batch_sgmc` (`status`, `gmt_create`), 
	KEY `idx_bail_batch_unfreezys` (`unfreezy_time`, `status`)
)  AUTO_INCREMENT = 581193 CHARSET = utf8 COMMENT = '真正请求保证金的记录';
CREATE TABLE if not exists bail_log (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`out_order_id` varchar(32) NOT NULL COMMENT '外部id,保持唯一性。', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '商家用户id', 
	`amount` bigint(20) DEFAULT '0' NOT NULL COMMENT '冻结金额', 
	`freezy_time` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '冻结时间长度，转换为小时', 
	`type` int(11) DEFAULT '0' NOT NULL COMMENT '冻结状态:冻结时间确定的，冻结时间不确定的', 
	`source` int(11) DEFAULT '0' NOT NULL COMMENT '来源：页游，服务市场，gt2', 
	`status` int(11) DEFAULT '0' NOT NULL COMMENT '状态：0 待处理，1处理过', 
	PRIMARY KEY (`id`), 
	UNIQUE `idx_bail_log_ord` (`out_order_id`), 
	KEY `idx_bail_log_sgct` (`status`, `gmt_create`, `type`)
)  AUTO_INCREMENT = 1147358 CHARSET = utf8 COMMENT = '保证金请求流水记录表，最终处理过的请求会清理';
CREATE TABLE if not exists cooptest_chongzhi_log (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`test_order_id` bigint(20) UNSIGNED NOT NULL COMMENT '测试订单ID', 
	`type` varchar(16) NOT NULL COMMENT '调用接口类型(query,charge,notify)', 
	`parameter` varchar(1024) NOT NULL COMMENT '调用接口完整url', 
	`result` varchar(2048) NOT NULL COMMENT '返回结果', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 4 CHARSET = utf8 COMMENT = '联调平台充值日志表';
CREATE TABLE if not exists cooptest_system_user (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`tb_nick` varchar(64) NOT NULL COMMENT '淘宝用户名', 
	`coop_name` varchar(64) NOT NULL COMMENT '商家名称', 
	`user_type` tinyint(4) NOT NULL COMMENT '用户类型（admin=1，user=0）', 
	`user_stop` tinyint(4) NOT NULL COMMENT '是否停用(1=停用，0=正常)', 
	`service_list` varchar(256) NULL COMMENT '支持的业务（直充业务=1,网游业务=2，用户权益=3）,多业务用逗号分隔', 
	`email` varchar(64) NULL COMMENT '联系人邮件地址', 
	`coop_id` bigint(20) UNSIGNED NULL COMMENT '商家ID', 
	`sign_key` varchar(32) NULL COMMENT '商家密钥', 
	PRIMARY KEY (`id`), 
	KEY `cooptest_csu_tbnick` (`tb_nick`)
)  AUTO_INCREMENT = 45 CHARSET = utf8 COMMENT = '联调平台系统用户表';
CREATE TABLE if not exists cooptest_test_order (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`query_url` varchar(128) NOT NULL COMMENT '商家订单查询接口', 
	`charge_url` varchar(128) NOT NULL COMMENT '商家订单充值接口', 
	`coop_id` bigint(20) UNSIGNED NOT NULL COMMENT '商家ID', 
	`tb_order_no` varchar(16) NOT NULL COMMENT '淘宝订单号', 
	`card_id` varchar(32) NOT NULL COMMENT '商家宝贝ID', 
	`card_num` int(10) UNSIGNED NOT NULL COMMENT '宝贝数量', 
	`sum` varchar(32) NOT NULL COMMENT '宝贝总价', 
	`customer` varchar(64) NOT NULL COMMENT '商家游戏账号', 
	`game_id` bigint(20) UNSIGNED NULL COMMENT '游戏ID', 
	`region` bigint(20) UNSIGNED NULL COMMENT '区ID', 
	`section` bigint(20) UNSIGNED NULL COMMENT '服ID', 
	`role` varchar(64) NULL COMMENT '角色名', 
	`status` tinyint(4) NOT NULL COMMENT '订单状态(0=创建订单，1=订单处理中，2=订单处理成功，3=订单处理失败)', 
	`sign_key` varchar(32) NOT NULL COMMENT '密钥', 
	PRIMARY KEY (`id`), 
	KEY `cooptest_order_coopid` (`coop_id`, `gmt_create`)
)  AUTO_INCREMENT = 1407289604024 CHARSET = utf8 COMMENT = '联调平台直充测试订单表';
CREATE TABLE if not exists game (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`name` varchar(1024) NOT NULL COMMENT '游戏名称', 
	`word` char(1) NOT NULL COMMENT '游戏首字母', 
	`sort` bigint(20) UNSIGNED NOT NULL COMMENT '排序字段', 
	`status` int(10) UNSIGNED NOT NULL COMMENT '0：被屏蔽；1：可见', 
	`description` varchar(5000) NULL COMMENT '描述信息', 
	`publisher` varchar(1024) NULL COMMENT '游戏发行商', 
	`options` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '当前游戏关联的业务种类，通过位与字段判断', 
	PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '游戏库主表(包含目前业务支撑的所有游戏）';
CREATE TABLE if not exists game_area (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`name` varchar(1024) NOT NULL COMMENT '区服名称', 
	`parent_id` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '父节点id', 
	`status` int(10) UNSIGNED NOT NULL COMMENT '区服状态1：可见；0：不可见', 
	`game_id` bigint(20) UNSIGNED NOT NULL COMMENT '游戏id', 
	`game_name` varchar(1024) NOT NULL COMMENT '游戏名称', 
	`options` varchar(20000) NULL COMMENT '区服的附加信息，如直充传递给厂商的参数等。', 
	PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '游戏区服表，和厂商保持同步';
CREATE TABLE if not exists game_card_infos (
	`id` bigint(20) AUTO_INCREMENT NOT NULL, 
	`cards_id` bigint(20) NOT NULL COMMENT '发卡ID标识卡的批次', 
	`card_number` varchar(300) NOT NULL COMMENT '卡号', 
	`card_flag` bigint(20) NOT NULL COMMENT '领取标识 默认值-1未领取', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `ind_game_card_infos_cflag` (`card_flag`, `cards_id`)
)  AUTO_INCREMENT = 816647 CHARSET = utf8 COMMENT = '卡片信息表';
CREATE TABLE if not exists game_card_receive_infos (
	`id` bigint(20) AUTO_INCREMENT NOT NULL, 
	`cards_id` bigint(20) NOT NULL COMMENT '发卡ID标识卡的批次', 
	`card_number` varchar(300) NOT NULL COMMENT '卡号', 
	`user_id` bigint(20) NOT NULL COMMENT '用户ID', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `ind_game_card_receive_infos_ucid` (`user_id`, `cards_id`)
)  AUTO_INCREMENT = 1341 CHARSET = utf8 COMMENT = '卡片领用信息表';
CREATE TABLE if not exists game_cat_permis (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`user_id` bigint(20) NOT NULL COMMENT '用户id', 
	`user_nike` varchar(32) NOT NULL COMMENT '用户名称', 
	`item_type` bigint(20) NOT NULL COMMENT '类目属性id', 
	`category_id` bigint(20) NOT NULL COMMENT '类目id', 
	`sn_number` bigint(20) NOT NULL COMMENT '验证码', 
	`stauts` bigint(20) NOT NULL COMMENT '状态 0 正常 ；1被删除', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_cat_perm_nick` (`stauts`), 
	KEY `idx_cat_perm_userid` (`user_id`, `stauts`)
)  AUTO_INCREMENT = 1867 CHARSET = utf8 COMMENT = '用户拥有准入类目权限';
CREATE TABLE if not exists game_cat_permis_key (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`sn_number` bigint(20) NOT NULL COMMENT '验证码', 
	`stauts` bigint(20) NOT NULL COMMENT '是否被使用 0未使用；1已使用', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_cat_per_key_sn` (`sn_number`, `stauts`)
)  AUTO_INCREMENT = 1894 CHARSET = utf8 COMMENT = '类目权限验证码';
CREATE TABLE if not exists game_coop_select (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`coop1` varchar(128) NOT NULL COMMENT '主选服务商', 
	`coop2` varchar(128) NOT NULL COMMENT '备选服务商', 
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '卖家id', 
	`seller_nick` varchar(64) NULL COMMENT '卖家昵称', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_game_coop_select_seller_id` (`seller_id`)
)  AUTO_INCREMENT = 33953 CHARSET = utf8 COMMENT = '主备服务商选择（2013.12.23专用）';
