	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`partner_id` bigint(20) NOT NULL COMMENT '合作方id', 
	`partner_name` varchar(50) NOT NULL COMMENT '合作方名称', 
	`partner_wangwang` varchar(50) NOT NULL COMMENT '合作方旺旺', 
	`partner_url` varchar(500) NOT NULL COMMENT '合作方url', 
	`partner_phone` varchar(50) NOT NULL COMMENT '合作方电话', 
	`account_verify_url` varchar(500) NOT NULL COMMENT '下单时帐号验证接口地址', 
	`transaction_url` varchar(500) NOT NULL COMMENT '付款后交易接口地址', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`offline_notify_url` varchar(500) NOT NULL COMMENT '宝贝下架通知地址', 
	`app_key` varchar(512) NOT NULL COMMENT 'top appkey', 
	`game_id` bigint(20) NOT NULL COMMENT '游戏id', 
	`status` bigint(20) NOT NULL COMMENT '状态,0正常,1中止', 
	`validthru` datetime NOT NULL COMMENT '合同到期时间,只显示不做控制', 
	`sign_key` varchar(32) NOT NULL COMMENT '对称密钥（用于签名时使用）', 
	PRIMARY KEY (`id`), 
	KEY `idx_game_partner_partid` (`partner_id`, `game_id`), 
	KEY `idx_game_partner_appkey` (`app_key`), 
	KEY `idx_game_partner_gameid` (`game_id`)
)  AUTO_INCREMENT = 6 CHARSET = utf8 COMMENT = '网游平台官方合作信息';
CREATE TABLE if not exists game_partner_log (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`partner_id` bigint(20) NOT NULL, 
	`operator` varchar(32) NOT NULL, 
	`operator_ip` varchar(15) NOT NULL, 
	`content` varchar(4000) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_game_partner_partid` USING BTREE (`partner_id`, `id`), 
	KEY `idx_game_partner_oper` USING BTREE (`operator`, `id`), 
	KEY `idx_game_partner_ip` USING BTREE (`operator_ip`, `id`)
)  AUTO_INCREMENT = 22 CHARSET = utf8 COMMENT = 'partner修改的日志表';
CREATE TABLE if not exists game_sell_zhibiao (
	`seller_id` bigint(20) UNSIGNED NOT NULL COMMENT '主键', 
	`pay_sum` bigint(20) UNSIGNED NOT NULL COMMENT '总成交笔数，最近30天，支付宝付款笔数', 
	`success_rate` int(11) NOT NULL COMMENT '成功率（精度到百分位，元数据为扩大1,2,4,6,7,8,11,56,68,89,435,452300倍，既：23.33% 存储为 2333）成功笔数/总成交笔数×1,2,4,6,7,8,11,56,68,89,435,4523%', 
	`success_sum` bigint(20) UNSIGNED NOT NULL COMMENT '成功笔数，最近30天，订单成功笔数', 
	`game_max_sum` varchar(128) NULL COMMENT '最大成交笔数，两笔，按交易量顺序，维度为游戏厂商+游戏。格式为(游戏名称:交易笔数,游戏名称:交易笔数)', 
	`game_other_sum` bigint(20) UNSIGNED DEFAULT '0' COMMENT '其他成交笔数，除了上面最大的两笔，剩下的总数。只给出一个汇总值就可以', 
	PRIMARY KEY (`seller_id`)
)  CHARSET = utf8 COMMENT = '卖家维度数据指标表(30day)';
CREATE TABLE if not exists game_tio (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`category_id` bigint(20) UNSIGNED NOT NULL COMMENT '类目id', 
	`game_id` bigint(20) UNSIGNED NOT NULL COMMENT '游戏id', 
	`game_name` varchar(1024) NOT NULL COMMENT '游戏名称', 
	PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '游戏装备账号金币交易关联表，即以前的GT2类目，升级之后新名称叫TIO（two in one)二合一，简单好记。';
CREATE TABLE if not exists game_tjb_order (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`user_name` varchar(64) NOT NULL COMMENT '用户名称', 
	`tjb` int(11) NOT NULL COMMENT '兑换使用的淘金币数量', 
	`game_money` int(11) NOT NULL COMMENT '可以兑换成的游戏币数目', 
	`game_id` bigint(20) UNSIGNED NOT NULL COMMENT '游戏id ，这里是游戏品牌id', 
	`game_name` varchar(64) NULL COMMENT '游戏名称', 
	`rate` int(10) UNSIGNED NOT NULL COMMENT '兑换汇率，淘金币：游戏币', 
	`status` int(11) NOT NULL COMMENT '兑换状态', 
	`reason` varchar(32) NULL COMMENT '失败原因', 
	`out_order_id` bigint(20) UNSIGNED NOT NULL COMMENT '生成订单id', 
	`section1` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '游戏区服id', 
	`section2` bigint(20) UNSIGNED NULL COMMENT '游戏二级区服', 
	PRIMARY KEY (`id`), 
	UNIQUE `idx_out_order_id_uid` (`out_order_id`, `user_id`), 
	KEY `k_stat_uid` (`status`, `user_id`), 
	KEY `k_stat_gmtc` (`status`, `gmt_create`)
)  AUTO_INCREMENT = 186574 CHARSET = utf8 COMMENT = '网游双十二淘金币兑换信息存放';
CREATE TABLE if not exists gp_card (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`name` varchar(64) NOT NULL COMMENT '卡片名（最多30个字符）', 
	`service_area` bigint(20) NOT NULL COMMENT '卡关联区服（单选）（淘宝一区、淘宝二区…）', 
	`content` varchar(512) NOT NULL COMMENT '卡包内容（最多200个字符）', 
	`card_usage` varchar(512) NOT NULL COMMENT '卡使用方法（最多200个字符）', 
	`picture` varchar(128) NOT NULL COMMENT '卡图片', 
	`valid_begin` datetime NOT NULL COMMENT '卡使用有效期（起）', 
	`valid_end` datetime NOT NULL COMMENT '卡使用有效期（止）', 
	`begin_time` datetime NOT NULL COMMENT '卡发放时间（起）', 
	`end_time` datetime NOT NULL COMMENT '卡发放时间（止）', 
	`biz_type` tinyint(4) NOT NULL COMMENT '关联业务方（小二后台、页游、礼包卡…）', 
	`rec_mode` tinyint(4) NOT NULL COMMENT '领取方式（多张、一张）', 
	`card_use` tinyint(4) NOT NULL COMMENT '卡用途', 
	`amount` bigint(20) NOT NULL COMMENT '卡数量（总数）', 
	`amount_already` bigint(20) NOT NULL COMMENT '已领取数量（已经被领取的数量）', 
	`status` tinyint(4) NOT NULL COMMENT '卡状态（审核中、审核通过、未开始、领取中、已领光、已结束，正在创建卡密）', 
	`card_code` varchar(32) NOT NULL COMMENT '卡号', 
	`biz_id` bigint(20) NOT NULL COMMENT '关联业务方定义的标识', 
	PRIMARY KEY (`id`), 
	KEY `query_list_idx` (`begin_time`, `end_time`, `biz_type`, `biz_id`, `service_area`), 
	KEY `status_createtime_idx` (`status`, `gmt_create`), 
	KEY `biztype_idx` (`biz_type`)
)  AUTO_INCREMENT = 2022 CHARSET = utf8 COMMENT = '卡信息主表';
CREATE TABLE if not exists gp_card_file (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`card_id` bigint(20) NOT NULL COMMENT '卡表主键', 
	`file_error` varchar(128) NOT NULL COMMENT '文件路径', 
	`file_url` varchar(128) NOT NULL COMMENT '文件链接', 
	`user_id` bigint(20) NOT NULL COMMENT '上传文件人', 
	`status` tinyint(4) NOT NULL COMMENT '1-待处理  2-正在处理 3-已处理', 
	`amount` bigint(20) NOT NULL COMMENT '总数量', 
	`amount_error` bigint(20) NOT NULL COMMENT '失败数量', 
	`file_name` varchar(64) NOT NULL COMMENT '文件名（和card_id的组合必须唯一否则会创建失败）', 
	PRIMARY KEY (`id`), 
	KEY `status_idx` (`status`), 
	KEY `cardid_idx` (`card_id`)
)  AUTO_INCREMENT = 2133 CHARSET = utf8 COMMENT = '卡密文件列表';
CREATE TABLE if not exists gp_card_secret (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`card_id` bigint(20) NOT NULL COMMENT '分表字段(卡标识)', 
	`biz_type` tinyint(4) NOT NULL COMMENT '参考卡表的相同字段', 
	`service_area` bigint(20) NOT NULL COMMENT '参考卡表的相同字段', 
	`secret_key` varchar(128) NOT NULL COMMENT '卡密码', 
	`card_code` varchar(64) NOT NULL COMMENT '卡号', 
	`apply_user` bigint(20) NOT NULL COMMENT '领取人', 
	`status` tinyint(4) NOT NULL COMMENT '状态（待领取、已领取）', 
	PRIMARY KEY (`id`), 
	UNIQUE `secret_cardid_idx` (`card_id`, `secret_key`), 
	KEY `status_cardid_idx` (`status`, `card_id`), 
	KEY `applyuser_card_id_idx` (`apply_user`, `card_id`)
)  AUTO_INCREMENT = 300490 CHARSET = utf8 COMMENT = '冗余了卡表的几个字段，只要考虑到未来可能根据限制某个业务限制是否可以被某些人使用（使用次数以及是否有权利使用）；';
--disable_warnings
drop table if exists sequence;
--enable_warnings
CREATE TABLE if not exists sequence (
	`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`name` varchar(118) NOT NULL, 
	`value` bigint(20) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_seq_name` (`name`)
)  AUTO_INCREMENT = 3 CHARSET = utf8;

SELECT MIN(id) AS minid, MAX(id) AS maxid FROM auction_game WHERE status != 1 AND status != 1;
SELECT id, user_id, user_name, tjb, game_money , rate, game_id, game_name, status, reason , out_order_id, section1, section2, gmt_create, gmt_modified FROM game_tjb_order WHERE user_id = 1 AND out_order_id = 1;
SELECT COUNT(*) FROM gp_card WHERE 1 = 1 AND biz_type = 1 AND biz_id = 1;
SELECT id, status, gmt_create, gmt_modified, biz_type , service_area, card_code, name, content, card_usage , picture, valid_begin, valid_end, begin_time, end_time , rec_mode, card_use, amount, amount_already, biz_id FROM gp_card WHERE 1 = 1 AND biz_id = 1 ORDER BY status DESC, gmt_create DESC LIMIT 1, 1;
