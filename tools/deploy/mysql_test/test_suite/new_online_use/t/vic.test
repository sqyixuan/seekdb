SELECT COUNT(*) FROM gp_card WHERE status IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT id, card_id, biz_type, service_area, secret_key , card_code, apply_user, status, gmt_create, gmt_modified FROM gp_card_secret WHERE apply_user = 1 AND card_id IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT id, vertical_type, properties, gmt_create, gmt_modified , auction_id FROM auction_vertical_property WHERE auction_id = 1 AND vertical_type = 1;
SELECT id, gmt_create, gmt_modified, coin_url, server_status_url , server_user_url, rate, game_id, private_key, user_id , unit, item_id, tjb_num, game_num FROM game_exchange_info WHERE 1 = 1 AND game_id = 1;
SELECT id, out_order_id, seller_id, amount, freezy_time , type, source, status, gmt_create, gmt_modified FROM bail_log WHERE out_order_id = "3";
SELECT seller_id, pay_sum, success_rate, success_sum, game_max_sum , game_other_sum FROM game_sell_zhibiao WHERE seller_id = 1 LIMIT 1;
SELECT id, partner_id, partner_name, partner_wangwang, partner_url , partner_phone, account_verify_url, transaction_url, gmt_create, gmt_modified , offline_notify_url, app_key, game_id, status, validthru , sign_key FROM game_partner WHERE partner_id = 1 AND game_id = 1;
SELECT id, gmt_create, gmt_modified, coin_url, server_status_url , server_user_url, rate, game_id, private_key, user_id , unit, item_id, tjb_num, game_num FROM game_exchange_info WHERE 1 = 1;
SELECT id, card_id, biz_type, service_area, secret_key , card_code, apply_user, status, gmt_create, gmt_modified FROM gp_card_secret WHERE status = 1 AND card_id = 1 LIMIT 1;
SELECT id, status, gmt_create, gmt_modified, biz_type , service_area, card_code, name, content, card_usage , picture, valid_begin, valid_end, begin_time, end_time , rec_mode, card_use, amount, amount_already, biz_id FROM gp_card WHERE status IN (1,2,4,6,7,8,11,56,68,89,435,4523) ORDER BY gmt_create DESC LIMIT 1, 1;
SELECT id, category_id, user_id, user_nike, item_type , sn_number, stauts, gmt_create, gmt_modified FROM game_cat_permis WHERE user_id = 1 ORDER BY stauts DESC;
SELECT id, status, gmt_create, gmt_modified, biz_type , service_area, card_code, name, content, card_usage , picture, valid_begin, valid_end, begin_time, end_time , rec_mode, card_use, amount, amount_already, biz_id FROM gp_card WHERE id = 1;
SELECT id, status, gmt_create, gmt_modified, coop , type, ali_cnt, succ_cnt, complaint_cnt, delivery_speed , seller_id, seller_nick FROM game_cooperation_service_info WHERE gmt_create BETWEEN "30" AND "30" AND type = 1 AND coop = "3";
SELECT * FROM bail_batch WHERE status = 1 AND gmt_create < "2016-09-30 00:00:01";
SELECT COUNT(*) FROM gp_card WHERE 1 = 1 AND biz_id = 1;
SELECT auction_id, features, trade_time, freeze_id, status , game_name, game_area, game_server, game_camp, game_type , user_id, gmt_create, gmt_modified, security_grade, freezeid_account , msg_for_check FROM auction_game WHERE status != 1 AND status != 1 AND id BETWEEN 1 AND 1;
SELECT id, card_id, status, gmt_create, gmt_modified , file_error, file_url, file_name, user_id, amount , amount_error FROM gp_card_file WHERE status = 1 ORDER BY gmt_create DESC LIMIT 1;
SELECT id, status, gmt_create, gmt_modified, biz_type , service_area, card_code, name, content, card_usage , picture, valid_begin, valid_end, begin_time, end_time , rec_mode, card_use, amount, amount_already, biz_id FROM gp_card WHERE 1 = 1 AND service_area = 1 AND biz_id = 1 ORDER BY status DESC, gmt_create DESC LIMIT 1, 1;
SELECT id, status, gmt_create, gmt_modified, coop , type, ali_cnt, succ_cnt, complaint_cnt, delivery_speed , seller_id, seller_nick FROM game_cooperation_service_info WHERE type = 1 AND coop = "3" ORDER BY gmt_create DESC LIMIT 1;
