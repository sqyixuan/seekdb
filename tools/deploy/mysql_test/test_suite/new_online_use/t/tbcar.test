SELECT u.id, u.gmt_create, u.gmt_modified, u.seller_id, u.seller_name , u.seller_nick, u.seller_phone, u.system_envaluation_id, u.status, u.buyer_id , u.buyer_name, u.buyer_nick, u.gmt_commit, u.gmt_contact, u.gmt_deal , u.gmt_cancel, u.price, u.seller_comment, u.buyer_comment, u.gmt_envaluate , u.division_id, u.order_id, u.province, u.city, u.town , u.bstatus FROM user_inquiry u WHERE u.system_envaluation_id = 1 AND u.status IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT COUNT(*) FROM user_inquiry WHERE buyer_id = 1 AND status IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND gmt_create BETWEEN "30" AND "30";
SELECT COUNT(*) FROM user_inquiry u WHERE u.seller_id = 1 AND u.status IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT id, gmt_create, gmt_modified, bvid, svid , yvid, mvid, bpid, spid, ypid , mpid, province_city, buy_date, user_id, mileage , archives FROM user_car WHERE id = 1;
SELECT id, gmt_create, gmt_modified, car_id, price , status, source FROM system_evaluation WHERE id = 1;
SELECT id, gmt_create, gmt_modified, bvid, svid , yvid, mvid, bpid, spid, ypid , mpid, province_city, buy_date, user_id, mileage , archives FROM user_car WHERE bvid = 1 AND svid = 1 AND yvid = 1 AND mvid = 1 AND province_city = "3" AND buy_date = "2016-09-30 00:00:01" AND user_id = 1 AND mileage = 1 LIMIT 1;
SELECT id, gmt_create, gmt_modified, car_id, price , status, source FROM system_evaluation WHERE car_id = 1 AND price= 1  LIMIT 1;
SELECT u.id, u.gmt_create, u.gmt_modified, u.seller_id, u.seller_name , u.seller_nick, u.seller_phone, u.system_envaluation_id, u.status, u.buyer_id , u.buyer_name, u.buyer_nick, u.gmt_commit, u.gmt_contact, u.gmt_deal , u.gmt_cancel, u.price, u.seller_comment, u.buyer_comment, u.gmt_envaluate , u.division_id, u.order_id, u.province, u.city, u.town , u.bstatus FROM user_inquiry u WHERE u.seller_id = 1 AND u.buyer_id = 1 AND u.system_envaluation_id = 1 AND u.status IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT u.id, u.gmt_create, u.gmt_modified, u.seller_id, u.seller_name , u.seller_nick, u.seller_phone, u.system_envaluation_id, u.status, u.buyer_id , u.buyer_name, u.buyer_nick, u.gmt_commit, u.gmt_contact, u.gmt_deal , u.gmt_cancel, u.price, u.seller_comment, u.buyer_comment, u.gmt_envaluate , u.division_id, u.order_id, u.province, u.city, u.town , u.bstatus FROM user_inquiry u WHERE u.seller_id = 1 AND u.status IN (1,2,4,6,7,8,11,56,68,89,435,4523) ORDER BY u.id DESC LIMIT 1;
SELECT u.id, u.gmt_create, u.gmt_modified, u.seller_id, u.seller_name , u.seller_nick, u.seller_phone, u.system_envaluation_id, u.status, u.buyer_id , u.buyer_name, u.buyer_nick, u.gmt_commit, u.gmt_contact, u.gmt_deal , u.gmt_cancel, u.price, u.seller_comment, u.buyer_comment, u.gmt_envaluate , u.division_id, u.order_id, u.province, u.city, u.town , u.bstatus FROM user_inquiry u WHERE u.id = 1;
SELECT u.id, u.gmt_create, u.gmt_modified, u.seller_id, u.seller_name , u.seller_nick, u.seller_phone, u.system_envaluation_id, u.status, u.buyer_id , u.buyer_name, u.buyer_nick, u.gmt_commit, u.gmt_contact, u.gmt_deal , u.gmt_cancel, u.price, u.seller_comment, u.buyer_comment, u.gmt_envaluate , u.division_id, u.order_id, u.province, u.city, u.town , u.bstatus FROM user_inquiry u WHERE u.buyer_id = 1 AND u.status IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND u.gmt_create BETWEEN "30" AND "30" ORDER BY u.id DESC LIMIT 1, 1;
SELECT COUNT(*) FROM user_inquiry WHERE buyer_id = 1 AND status IN (1,2,4,6,7,8,11,56,68,89,435,4523);
SELECT * FROM couponlimit WHERE couponid = 1 AND date_format(getdate, "30") = date_format(now(), "30");
SELECT COUNT(*) FROM user_inquiry WHERE buyer_id = 1 AND status IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND order_id IS NOT NULL;
SELECT u.id, u.gmt_create, u.gmt_modified, u.seller_id, u.seller_name , u.seller_nick, u.seller_phone, u.system_envaluation_id, u.status, u.buyer_id , u.buyer_name, u.buyer_nick, u.gmt_commit, u.gmt_contact, u.gmt_deal , u.gmt_cancel, u.price, u.seller_comment, u.buyer_comment, u.gmt_envaluate , u.division_id, u.order_id, u.province, u.city, u.town , u.bstatus FROM user_inquiry u WHERE u.buyer_id = 1 AND u.status IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND u.bstatus = 1 ORDER BY u.id DESC LIMIT 1, 1;
SELECT u.id, u.gmt_create, u.gmt_modified, u.seller_id, u.seller_name , u.seller_nick, u.seller_phone, u.system_envaluation_id, u.status, u.buyer_id , u.buyer_name, u.buyer_nick, u.gmt_commit, u.gmt_contact, u.gmt_deal , u.gmt_cancel, u.price, u.seller_comment, u.buyer_comment, u.gmt_envaluate , u.division_id, u.order_id, u.province, u.city, u.town , u.bstatus FROM user_inquiry u WHERE u.buyer_id = 1 AND u.status IN (1,2,4,6,7,8,11,56,68,89,435,4523) ORDER BY u.id DESC LIMIT 1, 1;
SELECT COUNT(*) FROM user_inquiry WHERE buyer_id = 1 AND status IN (1,2,4,6,7,8,11,56,68,89,435,4523) AND bstatus = 1;
SELECT id, gmt_create, gmt_modified, name, gmt_start , gmt_end, location, number, promoter_id, promoter_nick , sub_type, info_config, status FROM meeting WHERE id = 1;
SELECT COUNT(*) FROM system_evaluation a, user_car b WHERE a.car_id = b.id AND price > 1 AND a.gmt_modified BETWEEN "30" AND "30";
SELECT b.id, b.gmt_create, b.gmt_modified, b.bvid, b.svid , b.yvid, b.mvid, b.bpid, b.spid, b.ypid , b.mpid, b.province_city, b.buy_date, b.user_id, b.mileage , b.archives, a.price FROM system_evaluation a, user_car b WHERE a.car_id = b.id AND a.gmt_modified BETWEEN "30" AND "30" LIMIT 1, 1;
SELECT COUNT(*) FROM system_evaluation a, user_car b WHERE a.car_id = b.id AND a.gmt_modified BETWEEN "30" AND "30";
SELECT b.id, b.gmt_create, b.gmt_modified, b.bvid, b.svid , b.yvid, b.mvid, b.bpid, b.spid, b.ypid , b.mpid, b.province_city, b.buy_date, b.user_id, b.mileage , b.archives, a.price FROM system_evaluation a, user_car b WHERE a.price = 1 AND a.car_id = b.id AND a.gmt_modified BETWEEN "30" AND "30" LIMIT 1, 1;

