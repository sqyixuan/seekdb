UPDATE `user_inquiry` SET status = 1, bstatus = 1, gmt_modified = now(), gmt_contact = now() WHERE id = 1;
UPDATE system_evaluation SET gmt_modified = now() WHERE id = 1;
UPDATE `user_inquiry` SET buyer_comment = "3", gmt_modified = now() WHERE id = 1;
UPDATE `user_inquiry` SET status = 1, seller_phone = 1, seller_comment = "3", division_id = 1, gmt_modified = now(), gmt_commit = now(), province = "3", city = "3", town = "3" WHERE id = 1;
UPDATE `user_inquiry` SET status = 1, seller_phone = 1, seller_comment = 1, division_id = 1, gmt_modified = now(), gmt_commit = now(), province = "3", city = "3", town = "3" WHERE id = 1;
UPDATE user_car SET province_city = "3" WHERE id = 1;
UPDATE `user_inquiry` SET status = 1, gmt_modified = now(), gmt_cancel = now() WHERE system_envaluation_id = 1 AND status != 1;
UPDATE `user_inquiry` SET status = 1, order_id = "3", gmt_modified = now(), gmt_deal = now() WHERE id = 1;
