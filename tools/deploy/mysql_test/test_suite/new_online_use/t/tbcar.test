CREATE TABLE if not exists couponlimit (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreatetime` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodifytime` datetime NOT NULL COMMENT '修改时间', 
	`couponid` bigint(20) UNSIGNED NOT NULL COMMENT '优惠券ID', 
	`getdate` datetime NOT NULL COMMENT '发放日期', 
	`count` bigint(20) UNSIGNED NOT NULL COMMENT '已发放数量', 
	`gmtcreateuser` varchar(118) NOT NULL COMMENT '创建用户', 
	`gmtmodifyuser` varchar(118) NOT NULL COMMENT '最后修改用户', 
	PRIMARY KEY (`id`), 
	UNIQUE `coupon_get_date` (`couponid`, `getdate`)
)  AUTO_INCREMENT = 2084 CHARSET = utf8 COMMENT = '用于控制每个优惠券每天的领取个数. (注意: 因为领取是在UMP方, 所以这里做控制无法做到1,2,4,6,7,8,11,56,68,89,435,4523%无遗漏. 会有超发的情况. 业务方接受)';
CREATE TABLE if not exists history (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreatetime` datetime NOT NULL COMMENT '创建时间', 
	`userid` bigint(20) UNSIGNED NOT NULL COMMENT '用户ID', 
	`nick` varchar(50) NOT NULL COMMENT '用户昵称', 
	`type` varchar(50) NOT NULL COMMENT '操作类型', 
	`msg` varchar(100) NOT NULL COMMENT '日志', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 7972012 CHARSET = utf8 COMMENT = '做为日志记录. 记录用户的涉及积分变化/优惠券领取的操作.';
CREATE TABLE if not exists market_c2b (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户Id', 
	`solutions` varchar(118) NOT NULL COMMENT '用户方案', 
	`pre_pay` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '预付金额', 
	`user_nick` varchar(118) NOT NULL COMMENT '用户昵称', 
	`type` varchar(10) NOT NULL COMMENT '定制类型', 
	`status` int(11) DEFAULT '0' NOT NULL COMMENT '0:新建 1 已完成提交,-1 丢弃', 
	PRIMARY KEY (`id`), 
	KEY `select_index` (`user_id`, `type`, `status`)
)  AUTO_INCREMENT = 19306 CHARSET = utf8 COMMENT = 'c2b';
CREATE TABLE if not exists meeting (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`name` varchar(118) NOT NULL COMMENT '会议名称', 
	`gmt_start` datetime NOT NULL COMMENT '会议开始时间', 
	`gmt_end` datetime NOT NULL COMMENT '会议结束时间', 
	`location` varchar(50) NOT NULL COMMENT '会议地点', 
	`number` bigint(20) NOT NULL COMMENT '人数', 
	`promoter_id` bigint(20) NOT NULL COMMENT '发起人id', 
	`promoter_nick` varchar(50) NOT NULL COMMENT '发起人名称', 
	`sub_type` varchar(118) DEFAULT 'default' COMMENT '子类型', 
	`info_config` varchar(500) NOT NULL COMMENT '收集信息配置', 
	`status` int(11) DEFAULT '1' NOT NULL COMMENT '会议状态', 
	PRIMARY KEY (`id`), 
	KEY `status` (`status`)
)  AUTO_INCREMENT = 9 CHARSET = utf8 COMMENT = '代表一个招商会议';
CREATE TABLE if not exists merchant (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`meeting_id` bigint(20) NOT NULL COMMENT '会议id', 
	`sub_type` varchar(118) DEFAULT 'default' NOT NULL COMMENT '子类型', 
	`info` varchar(500) NOT NULL COMMENT '商家信息', 
	PRIMARY KEY (`id`), 
	KEY `meeting_id` (`meeting_id`), 
	KEY `sub_type` (`sub_type`)
)  AUTO_INCREMENT = 1710 CHARSET = utf8 COMMENT = '商家表';
CREATE TABLE if not exists point (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmtcreatetime` datetime NOT NULL COMMENT '创建时间', 
	`gmtmodifytime` datetime NOT NULL COMMENT '修改时间', 
	`userid` bigint(20) UNSIGNED NOT NULL COMMENT '用户id', 
	`nick` varchar(50) NOT NULL COMMENT '用户昵称', 
	`lastsignindate` datetime NOT NULL COMMENT '用户上一次签到时间', 
	`point` bigint(20) UNSIGNED NOT NULL COMMENT '用户当前积分', 
	`gmtcreateuser` varchar(50) NULL COMMENT '创建用户', 
	`gmtmodifyuser` varchar(50) NULL COMMENT '最后修改用户', 
	PRIMARY KEY (`id`), 
	UNIQUE `userid` (`userid`)
)  AUTO_INCREMENT = 296050 CHARSET = utf8 COMMENT = '用户签到积分表';
CREATE TABLE if not exists system_evaluation (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '系1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523估 Id', 
	`gmt_create` datetime NOT NULL COMMENT '建1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523', 
	`gmt_modified` datetime NOT NULL COMMENT '修1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523', 
	`car_id` bigint(20) UNSIGNED NOT NULL COMMENT '稷汽车 Id', 
	`price` decimal(10, 0) NOT NULL COMMENT '价格', 
	`status` int(11) NOT NULL COMMENT '// 价格 0. 系1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523 1. 汽车太1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523 2.1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523误,3. 正确// 1,2,4,6,7,8,11,56,68,89,435,4523 0. 样 1. 1,2,4,6,7,8,11,56,68,89,435,4523', 
	`source` int(11) DEFAULT '0' COMMENT '来源，默认是00：pc 1.手淘 2.闲鱼', 
	PRIMARY KEY (`id`), 
	KEY `envaluation_id_index` (`car_id`), 
	KEY `draw_index` (`car_id`, `gmt_modified`), 
	KEY `date_index` (`gmt_modified`), 
	KEY `price_index` (`price`)
)  AUTO_INCREMENT = 4062424 CHARSET = utf8 COMMENT = '系1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523估';
