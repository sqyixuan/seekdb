--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt 
#owner group:sql1 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists biz_meta (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '业务ID', 
	`name` varchar(64) NOT NULL COMMENT '业务名称', 
	`description` varchar(512) NULL COMMENT '业务描述', 
	`owner_id` bigint(20) NULL COMMENT '业务负责人ID', 
	`owner_nick` varchar(32) NULL COMMENT '业务负责人Nick', 
	`status` tinyint(4) NOT NULL COMMENT '业务状态', 
	`type` tinyint(4) NOT NULL COMMENT '业务类型', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`outer_id` varchar(64) NULL COMMENT '原有业务ID', 
	`features` varchar(512) NULL COMMENT '特征', 
	PRIMARY KEY (`id`), 
	KEY `idx_type` (`type`, `status`)
)  AUTO_INCREMENT = 217 CHARSET = utf8 COMMENT = '业务信息表';
CREATE TABLE if not exists biz_rule (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`biz_id` bigint(20) UNSIGNED NOT NULL COMMENT '业务ID', 
	`rule_id` bigint(20) UNSIGNED NOT NULL COMMENT '规则的ID', 
	`rule_model_id` bigint(20) UNSIGNED NULL COMMENT '规则的模型Id,为空使用该规则的默认线上模型', 
	`params` varchar(512) NULL COMMENT '规则参数', 
	`order_num` int(11) NULL COMMENT '应用规则的顺序', 
	`status` bigint(20) UNSIGNED NOT NULL COMMENT '状态0:正常 1:删除', 
	`features` varchar(512) NULL COMMENT '特征', 
	`sample_group_id` bigint(20) UNSIGNED NULL COMMENT '样本分组ID', 
	PRIMARY KEY (`id`), 
	KEY `biz_id` (`biz_id`, `status`), 
	KEY `rule_id` (`rule_id`, `status`)
)  CHARSET = utf8 COMMENT = '业务应用规则表';
CREATE TABLE if not exists cat (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`name` varchar(128) NOT NULL COMMENT '分类名称', 
	`description` varchar(512) NULL COMMENT '分类描述', 
	`group_id` bigint(20) NOT NULL COMMENT '样本类型ID', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分类创建者ID', 
	`user_nick` varchar(32) NOT NULL COMMENT '分类创建者Nick', 
	`status` tinyint(4) NOT NULL COMMENT '状态', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`order_num` int(11) NOT NULL COMMENT '分类排序', 
	`parent_id` bigint(20) UNSIGNED NOT NULL COMMENT '父节点的ID', 
	PRIMARY KEY (`id`), 
	KEY `idx_groupid` (`group_id`, `status`), 
	KEY `idx_parentid` (`parent_id`, `status`)
)  AUTO_INCREMENT = 25 CHARSET = utf8 COMMENT = '分类表';
--disable_warnings
drop table if exists info;
--enable_warnings
CREATE TABLE if not exists info (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`content` varchar(2048) NOT NULL COMMENT '文本内容', 
	`biz_id` bigint(20) NOT NULL COMMENT '业务方Id', 
	`outer_id` varchar(64) NULL COMMENT '外部主键', 
	`target_key` varchar(64) NULL COMMENT '信息主题ID', 
	`owner_id` bigint(20) NULL COMMENT '内容发布者ID', 
	`owner_nick` varchar(32) NULL COMMENT '内容发布者Nick', 
	`receiver_id` bigint(20) NULL COMMENT '接受者用户ID', 
	`receiver_nick` varchar(32) NULL COMMENT '接受者用户Nick', 
	`type` tinyint(4) NOT NULL COMMENT '1-评论\\r2-评价\\r...', 
	`from_type` tinyint(4) NOT NULL COMMENT '1 - 系统调用\\r2 - 消息接收\\r3 - 数据回流\\r4 - 用户上传', 
	`status` tinyint(4) NOT NULL COMMENT '0-正常\\r1-删除', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`biz_uid` bigint(20) NOT NULL COMMENT '信息所属业务方的用户ID', 
	`rule_id` bigint(20) UNSIGNED NOT NULL COMMENT '算法ID', 
	`cat_id` bigint(20) UNSIGNED NOT NULL COMMENT '分类Id', 
	`features` varchar(256) NULL COMMENT '扩展字段', 
	`score` float NULL COMMENT '分值', 
	PRIMARY KEY (`id`), 
	KEY `idx_bizid` (`biz_id`, `status`), 
	KEY `idx_bizid_catid` (`biz_id`, `cat_id`, `status`)
)  AUTO_INCREMENT = 103188542 CHARSET = utf8 COMMENT = '原始数据表, 记录各个业务方的原始数据';
CREATE TABLE if not exists page (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`title` varchar(118) NOT NULL COMMENT '页面名称', 
	`description` varchar(1024) NULL COMMENT '页面描述', 
	`owner_id` bigint(20) UNSIGNED NOT NULL COMMENT '页面归属者ID', 
	`owner_nick` varchar(32) NOT NULL COMMENT '页面归属者Nick', 
	`type` tinyint(4) NOT NULL COMMENT '页面类型', 
	`status` tinyint(4) NOT NULL COMMENT '页面状态', 
	`parent_id` bigint(20) UNSIGNED NULL COMMENT '父页面Id', 
	`config` varchar(512) NULL COMMENT '页面配置', 
	`order_num` int(11) NULL COMMENT '展示顺序', 
	`icon` varchar(64) NULL COMMENT '页面图表', 
	`features` varchar(1024) NULL COMMENT '其他信息', 
	`url` varchar(1024) NULL COMMENT '页面链接', 
	`level1` bigint(20) UNSIGNED NULL COMMENT '一级分类Id', 
	`level2` bigint(20) UNSIGNED NULL COMMENT '二级分类Id', 
	`level3` bigint(20) UNSIGNED NULL COMMENT '三级分类Id', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 1042 CHARSET = utf8 COMMENT = '页面管理表';
CREATE TABLE if not exists rule (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`name` varchar(64) NOT NULL COMMENT '规则名称', 
	`description` varchar(256) NULL COMMENT '规则描述', 
	`creator_id` bigint(20) UNSIGNED NOT NULL COMMENT '创建者Id', 
	`creator_nick` varchar(32) NOT NULL COMMENT '创建者Nick', 
	`type` int(11) NOT NULL COMMENT '类型', 
	`status` tinyint(4) NOT NULL COMMENT '状态', 
	`features` varchar(512) NULL COMMENT '特征', 
	PRIMARY KEY (`id`), 
	KEY `idx_type` (`type`)
)  CHARSET = utf8 COMMENT = '规则表';
CREATE TABLE if not exists rule_model (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`rule_id` bigint(20) UNSIGNED NOT NULL COMMENT '模型的规则ID', 
	`operator_id` bigint(20) UNSIGNED NOT NULL COMMENT '运行人id', 
	`operator_nick` varchar(32) NOT NULL COMMENT '运行人昵称', 
	`start_time` datetime NOT NULL COMMENT '运行开始时间', 
	`end_time` datetime NOT NULL COMMENT '运行结束时间', 
	`model_url` varchar(128) NOT NULL COMMENT '模型tfs地址', 
	`status` tinyint(4) NOT NULL COMMENT '模型状态 0:正常1:线上应用', 
	`params` varchar(512) NULL COMMENT '参数信息', 
	`features` varchar(512) NULL COMMENT '其他信息', 
	`sample_group_id` bigint(20) UNSIGNED NOT NULL COMMENT '样本类型ID', 
	`sample_count` int(11) NOT NULL COMMENT '训练样本的数量', 
	PRIMARY KEY (`id`), 
	KEY `idx_ruleid` (`rule_id`, `status`), 
	KEY `idx_operatorid` (`operator_id`, `status`), 
	KEY `idx_samplegroupid` (`sample_group_id`, `status`)
)  AUTO_INCREMENT = 351 CHARSET = utf8 COMMENT = '规则模型表';
CREATE TABLE if not exists sample (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`content` varchar(2048) NOT NULL COMMENT '信息内容', 
	`target_key` varchar(64) NULL COMMENT '信息主题Key', 
	`info_id` bigint(20) UNSIGNED NULL COMMENT '原始文本表ID', 
	`cat_id` bigint(20) UNSIGNED NULL COMMENT '分类Id', 
	`group_id` bigint(20) UNSIGNED NOT NULL COMMENT '样本类型Id', 
	`operator_id` bigint(20) UNSIGNED NOT NULL COMMENT '标注者ID', 
	`operator_nick` varchar(32) NOT NULL COMMENT '标注者Nick', 
	`auditor_id` bigint(20) UNSIGNED NULL COMMENT '审核者ID', 
	`auditor_nick` varchar(32) NULL COMMENT '审核者Nick', 
	`owner_id` bigint(20) UNSIGNED NULL COMMENT '内容发布者ID', 
	`owner_nick` varchar(32) NULL COMMENT '内容发布者Nick', 
	`receiver_id` bigint(20) UNSIGNED NULL COMMENT '接受者用户ID', 
	`receiver_nick` varchar(32) NULL COMMENT '接受者用户Nick', 
	`outer_id` bigint(20) UNSIGNED NULL COMMENT '外部主键', 
	`biz_id` bigint(20) UNSIGNED NULL COMMENT '业务方Id', 
	`type` tinyint(4) NOT NULL COMMENT '信息类型1、纯文本2、...', 
	`from_type` tinyint(4) NOT NULL COMMENT '信息来源类型', 
	`status` tinyint(4) NOT NULL COMMENT '信息状态', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`features` varchar(256) NULL COMMENT '特征', 
	PRIMARY KEY (`id`), 
	KEY `idx_groupid` (`group_id`, `status`), 
	KEY `idx_catid` (`cat_id`, `status`)
)  AUTO_INCREMENT = 4658 CHARSET = utf8 COMMENT = '标注的信息表';
CREATE TABLE if not exists sample_group (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`name` varchar(128) NOT NULL COMMENT '分类类型名称', 
	`description` varchar(512) NULL COMMENT '分类类型描述', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分类创建者ID', 
	`user_nick` varchar(32) NOT NULL COMMENT '分类创建者Nick', 
	`type` tinyint(4) NOT NULL COMMENT '1:单分类2:多分类', 
	`status` tinyint(4) NOT NULL COMMENT '状态-1:删除0:正常', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	PRIMARY KEY (`id`), 
	KEY `idx_type` (`type`, `status`)
)  AUTO_INCREMENT = 6 CHARSET = utf8 COMMENT = '分类类型表';
CREATE TABLE if not exists stat_base (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`biz_id` bigint(20) NOT NULL COMMENT '业务ID', 
	`biz_type` tinyint(4) NOT NULL COMMENT '业务类型', 
	`day` bigint(20) NOT NULL COMMENT '业务日期', 
	`detail` varchar(4096) NOT NULL COMMENT '详细的统计数据', 
	`type` tinyint(4) NOT NULL COMMENT '具体的统计类型', 
	`pv` bigint(20) NOT NULL COMMENT '业务的当天PV', 
	`status` tinyint(4) NOT NULL COMMENT '数据状态', 
	`biz_cat` bigint(20) NULL COMMENT '与业务相关的区分字段', 
	PRIMARY KEY (`id`), 
	KEY `idx_bizid_day` (`biz_id`, `day`, `status`)
)  AUTO_INCREMENT = 340170 CHARSET = utf8 COMMENT = '基础统计分析表';

