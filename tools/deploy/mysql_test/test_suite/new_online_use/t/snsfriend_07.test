CREATE TABLE if not exists taozihao_fans (
	`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '淘字号的user_id', 
	`role_id` int(10) UNSIGNED NOT NULL COMMENT '淘字号的角色ID', 
	`fan_id` bigint(20) UNSIGNED NOT NULL COMMENT '我的粉丝的id', 
	`twoway` tinyint(4) NULL COMMENT '双向好友标识, 1标识是双向好友.空或者0标识非双向好友', 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	`app_id` bigint(20) UNSIGNED NULL COMMENT '粉丝来源的应用', 
	`type` int(11) NULL COMMENT '各个appid下的子类型,各业务方自定义', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_taozihao_fans_userrolefan` (`app_id`, `user_id`, `role_id`, `fan_id`), 
	KEY `idx_taozihao_fans_userrolegmtcreate` (`user_id`, `role_id`, `gmt_create`), 
	KEY `idx_taozihao_fans_userroleappid` (`user_id`, `role_id`, `app_id`, `gmt_create`)
)  AUTO_INCREMENT = 74113 CHARSET = utf8 COMMENT = '淘字号的粉丝表.记录了所有关注我的人. 512张分表';
CREATE TABLE if not exists taozihao_fans_count (
	`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '淘字号的user_id', 
	`role_id` int(10) UNSIGNED NOT NULL COMMENT '淘字号的角色Id', 
	`fans_count` int(10) UNSIGNED NOT NULL COMMENT '粉丝总数', 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	`app_id` bigint(20) NULL, 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_taozihao_user_id` (`app_id`, `user_id`, `role_id`)
)  AUTO_INCREMENT = 1328489 CHARSET = utf8 COMMENT = '淘字号的粉丝的计数表,512张分表';
CREATE TABLE if not exists taozihao_group_info (
	`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '用户自己的userId', 
	`group_id` bigint(20) UNSIGNED NOT NULL COMMENT '组的id,通过seq生成.默认组除外', 
	`group_name` varchar(32) NOT NULL COMMENT '组的名字', 
	`group_desc` varchar(64) NULL COMMENT '组的描述', 
	`group_count` int(10) UNSIGNED NOT NULL COMMENT '组内的人数', 
	`is_delete` tinyint(4) NULL COMMENT '删除标志位.1标识删除.用户自定义组物理删除.默认组才使用这个标志位', 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	`app_id` bigint(20) NULL, 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_user_group` (`app_id`, `user_id`, `group_id`)
)  AUTO_INCREMENT = 64212 CHARSET = utf8 COMMENT = '用户关注淘字号的分组信息表.记录了默认组以及用户自定义组的信息  512张分表';
CREATE TABLE if not exists taozihao_subscribe (
	`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '自己的userId', 
	`subscribe_id` bigint(20) UNSIGNED NOT NULL COMMENT '我关注的淘字号的id', 
	`role_id` int(10) UNSIGNED NOT NULL COMMENT '我关注的淘字号的角色ID', 
	`twoway` tinyint(4) NULL COMMENT '双向好友标识, 1标识双向好友.空或者0标识非双向好友', 
	`group_ids` varchar(256) NULL COMMENT '我对关注用户的分组,每个组之间用,分隔', 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	`app_id` bigint(20) UNSIGNED NULL COMMENT '关系来源的应用', 
	`type` int(11) NULL COMMENT '各个appid下的子类型,各业务方自定义', 
	`attribute` varchar(512) NULL COMMENT '附加字段', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_taozihao_subscribe_0000_user_id` (`app_id`, `user_id`, `role_id`, `subscribe_id`), 
	KEY `idx_taozihao_subscribe_0000_user_id` (`user_id`, `gmt_create`)
)  AUTO_INCREMENT = 3446928 CHARSET = utf8 COMMENT = '淘字号';
CREATE TABLE if not exists taozihao_subscribe_count (
	`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT 'id', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '自己的userId', 
	`subscribe_count` int(10) UNSIGNED NOT NULL COMMENT '关注总数', 
	`twoway_count` int(10) UNSIGNED NOT NULL COMMENT '双向关注总数', 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	`app_id` bigint(20) NULL, 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_taozihao_subscribe_count_user_id` (`app_id`, `user_id`)
)  AUTO_INCREMENT = 1322969 CHARSET = utf8 COMMENT = '关注的淘字号总数512张表';
CREATE TABLE if not exists tmp_subcribe_mshop (
	`id` bigint(20) UNSIGNED DEFAULT '0' NOT NULL, 
	`subcriber_id` bigint(20) NOT NULL COMMENT '璁㈤槄鑰卛d', 
	`shop_owner_id` bigint(20) NOT NULL COMMENT '搴椾富id', 
	`gmt_create` datetime NOT NULL COMMENT '鍒涘缓鏃堕棿', 
	`gmt_modified` datetime NOT NULL COMMENT '淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿'
)  CHARSET = utf8;
CREATE TABLE if not exists tmp_subcribe_mshop_count (
	`id` bigint(20) UNSIGNED DEFAULT '0' NOT NULL COMMENT '鑷1,2,4,6,7,8,11,56,68,89,435,45231,2,4,6,7,8,11,56,68,89,435,4523涓婚敭', 
	`subcriber_id` bigint(20) NOT NULL COMMENT '璁㈤槄鑰卛d', 
	`micro_shop_count` bigint(20) NOT NULL COMMENT '璁㈤槄鐨勫簵閾烘暟鐩', 
	`gmt_create` datetime NOT NULL COMMENT '鍒涘缓鏃堕棿', 
	`gmt_modified` datetime NOT NULL COMMENT '淇1,2,4,6,7,8,11,56,68,89,435,4523敼鏃堕棿'
)  CHARSET = utf8;

