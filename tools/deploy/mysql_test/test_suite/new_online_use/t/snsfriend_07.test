CREATE TABLE if not exists sns_outer_group (
	`id` bigint(20) UNSIGNED NOT NULL, 
	`user_id` bigint(20) NOT NULL COMMENT '用户ID', 
	`group_name` varchar(64) NOT NULL COMMENT '分组名', 
	`item_count` int(11) NOT NULL COMMENT '包含关系数', 
	`gmt_lastuse` datetime NOT NULL COMMENT '最后使用时间', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_outergroup_userid` (`user_id`, `group_name`), 
	KEY `idx_outergroup_userid2` (`user_id`, `gmt_lastuse`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_outer_relation (
	`id` bigint(20) UNSIGNED NOT NULL, 
	`user_id` bigint(20) NOT NULL COMMENT '用户ID', 
	`partner_id` int(11) NOT NULL COMMENT '合作伙伴ID', 
	`outer_id` varchar(128) NOT NULL COMMENT 'outer_id变更字段类型为字符串', 
	`login_name` varchar(128) NULL COMMENT ' ', 
	`display_name` varchar(128) NULL COMMENT '显示名称', 
	`display_face` varchar(512) NULL COMMENT '显示头像URL', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`two_way` tinyint(4) NULL, 
	`location` varchar(128) NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_outrelation_userid` (`user_id`, `partner_id`, `login_name`), 
	KEY `index_outer_relation` (`user_id`, `partner_id`, `outer_id`, `two_way`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_outer_relation_group (
	`id` bigint(20) UNSIGNED NOT NULL, 
	`user_id` bigint(20) NOT NULL COMMENT '用户ID', 
	`group_id` bigint(20) NOT NULL COMMENT '分组ID', 
	`relation_id` bigint(20) NOT NULL COMMENT '关系ID', 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
	KEY `idx_orgroup_userid` (`user_id`, `group_id`, `relation_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_recommend (
	`user_id` bigint(20) UNSIGNED NOT NULL, 
	`friend_id` bigint(20) NOT NULL, 
	`friend_nick` varchar(32) NULL, 
	`friend_realname` varchar(256) NULL, 
	`relation_status` varchar(32) DEFAULT '0', 
	`gmt_create` datetime NULL, 
	`gmt_modified` datetime NULL, 
	`char_1` varchar(256) NULL, 
	`number_1` bigint(20) DEFAULT '0', 
	`number_2` bigint(20) NULL, 
	PRIMARY KEY (`user_id`, `friend_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_relations (
	`user_id` bigint(20) UNSIGNED NOT NULL, 
	`friend_id` bigint(20) NOT NULL, 
	`friend_nick` varchar(32) NOT NULL, 
	`friend_realname` varchar(256) NULL, 
	`relation_status` tinyint(4) NULL, 
	`feed_setting` varchar(100) NULL, 
	`activity_setting` varchar(100) NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`char_1` varchar(256) NULL, 
	`number_1` bigint(20) NULL, 
	`shield_status` tinyint(4) NULL, 
	PRIMARY KEY (`user_id`, `friend_id`), 
	KEY `user_id` (`user_id`, `gmt_modified`, `relation_status`, `shield_status`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_relations_count (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`user_id` bigint(20) NOT NULL COMMENT '用户id', 
	`friend_count` int(11) NOT NULL COMMENT '好友个数', 
