	PRIMARY KEY (`id`), 
	UNIQUE `uk_src_uid` (`user_id`)
)  AUTO_INCREMENT = 80259008 CHARSET = utf8;
CREATE TABLE if not exists sns_subscribe (
	`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`user_id` bigint(20) UNSIGNED NOT NULL, 
	`subscribe_id` bigint(20) UNSIGNED NOT NULL COMMENT '我关注的人的id', 
	`twoway` tinyint(4) NULL COMMENT '双向好友标识, 1标识双向好友.空或者0标识非双向好友', 
	`group_ids` varchar(256) NULL COMMENT '我对关注用户的分组,每个组之间用,分隔', 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	`app_id` bigint(20) UNSIGNED NULL COMMENT '关系来源的应用', 
	`type` int(11) NULL COMMENT '各个appid下的子类型,各业务方自定义', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_user_sub` (`user_id`, `subscribe_id`), 
	KEY `ind_user_gmt` (`user_id`, `gmt_create`), 
	KEY `idx_uid_gmt_create` (`user_id`, `gmt_create`)
)  AUTO_INCREMENT = 3801659 CHARSET = utf8 COMMENT = '我的关注,记录我所关注的人, 512张分表';
CREATE TABLE if not exists sns_subscribe_count (
	`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`user_id` bigint(20) UNSIGNED NOT NULL, 
	`subscribe_count` int(10) UNSIGNED NOT NULL COMMENT '关注总数', 
	`twoway_count` int(10) UNSIGNED NOT NULL COMMENT '双向关注总数', 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_user` (`user_id`)
)  AUTO_INCREMENT = 1910392 CHARSET = utf8 COMMENT = '512张表';
