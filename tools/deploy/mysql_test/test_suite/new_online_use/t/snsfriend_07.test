#owner: link.zt 
#owner group:sql1 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists contact_relation (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`phonehash` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段', 
	`phone` varchar(20) NOT NULL COMMENT '用户的电话号码', 
	`contact_phone` varchar(20) NOT NULL COMMENT '用户联系人的电话号码', 
	`display_name` varchar(32) NULL COMMENT '联系人的显示名', 
	`relation_type` int(10) UNSIGNED NOT NULL COMMENT '关系类型 0-单向，1-双向', 
	`status` int(10) UNSIGNED NOT NULL COMMENT '关系状态 1-正常状态 2-屏蔽状态', 
	`attribute` varchar(512) NULL COMMENT '附加字段', 
	`contact_phonehash` bigint(20) UNSIGNED NOT NULL COMMENT '联系人hash值', 
	PRIMARY KEY (`id`), 
	KEY `idx_common` (`phonehash`, `status`, `relation_type`, `gmt_modified`), 
	KEY `idx_hash` (`phonehash`, `contact_phonehash`)
)  CHARSET = utf8 COMMENT = '通讯录关系表';
CREATE TABLE if not exists expand_sina_follow_relation (
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_id` bigint(20) UNSIGNED NOT NULL COMMENT '分表字段,用户的淘宝id', 
	`target_ids`varchar(100)NOT NULL COMMENT '用户的扩展关系(二度关注关系)的淘宝用户id列表,用逗号分隔', 
	PRIMARY KEY (`user_id`)
)  CHARSET = utf8 COMMENT = '记录用户的扩展关系(二度关注关系)';
CREATE TABLE if not exists fans_blacklist (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`user_id` bigint(20) NOT NULL, 
	`black_user_id` bigint(20) NOT NULL, 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `ind_user` (`user_id`, `black_user_id`), 
	KEY `ind_user_gmt` (`user_id`, `gmt_create`)
)  AUTO_INCREMENT = 17071 CHARSET = utf8;
CREATE TABLE if not exists mshop_follower (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`shop_owner_id` bigint(20) NOT NULL COMMENT '店主id', 
	`subcriber_id` bigint(20) NOT NULL COMMENT '订阅者id', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_mf_soid` (`shop_owner_id`, `subcriber_id`), 
	KEY `idx_mf_soid` (`shop_owner_id`, `gmt_create`, `subcriber_id`)
)  AUTO_INCREMENT = 155863574 CHARSET = utf8 COMMENT = '微店的订阅者表';
CREATE TABLE if not exists mshop_follower_count (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL, 
	`shop_owner_id` bigint(20) NOT NULL COMMENT '店主id', 
	`shop_follower_count` bigint(20) NOT NULL COMMENT '店铺的粉丝数', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_mfc_soid` (`shop_owner_id`)
)  AUTO_INCREMENT = 52289002 CHARSET = utf8 COMMENT = '微店订阅者个数';
CREATE TABLE if not exists outer_follow_relation (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_create` datetime NOT NULL COMMENT '创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '修改时间', 
	`user_outer_id` varchar(128) NOT NULL COMMENT '分表字段,用户的外站id', 
	`user_id` bigint(20) UNSIGNED NULL COMMENT '用户的淘宝id,可能为空', 
	`follow_uid` bigint(20) UNSIGNED NULL COMMENT '关注的人的淘宝id,如果这个用户没有绑定就为空', 
	`follow_outer_id` varchar(128) NOT NULL COMMENT '关注的人的外站id', 
	`partner_id` int(11) NOT NULL COMMENT '来源的类型,比如新浪是4', 
	`login_name` varchar(32) NULL COMMENT '关注的人的外部的登录名,对应新浪个人信息中的screen_name', 
	`twoway` tinyint(3) UNSIGNED DEFAULT '0' NOT NULL COMMENT '双向的情况,双向为1,否则为0', 
	`is_delete` tinyint(3) UNSIGNED NULL COMMENT '删除的数据置为1', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_uoid_pid_foid` (`user_outer_id`, `partner_id`, `follow_outer_id`)
)  AUTO_INCREMENT = 13465784 CHARSET = utf8 COMMENT = '保存拉取的外站用户所有关注关系1.主动绑定时,拉取2层关注关系.2.和绑定用户发生关注动作时,拉取所有的关注关系';
CREATE TABLE if not exists sns_fans (
	`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`user_id` bigint(20) UNSIGNED NOT NULL, 
	`fan_id` bigint(20) UNSIGNED NOT NULL COMMENT '我的粉丝的id', 
	`twoway` tinyint(4) NULL COMMENT '双向好友标识, 1标识是双向好友.空或者0标识非双向好友', 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	`app_id` bigint(20) UNSIGNED NULL COMMENT '粉丝来源的应用', 
	`type` int(11) NULL COMMENT '各个appid下的子类型,各业务方自定义', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_user_fan` (`user_id`, `fan_id`), 
	KEY `ind_fan_user_gmt` (`user_id`, `gmt_create`), 
	KEY `ind_uid_appid_gmt` (`user_id`, `app_id`, `gmt_create`)
)  AUTO_INCREMENT = 3280387 CHARSET = utf8 COMMENT = '我的粉丝表.记录了所有关注我的人. 512张分表';
CREATE TABLE if not exists sns_fans_count (
	`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`user_id` bigint(20) UNSIGNED NOT NULL, 
	`fans_count` int(10) UNSIGNED NOT NULL, 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_user_fan` (`user_id`)
)  AUTO_INCREMENT = 2040090 CHARSET = utf8 COMMENT = '我的粉丝的计数表,512张分表';
CREATE TABLE if not exists sns_follow_statistic (
	`id` bigint(20) AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`user_id` bigint(20) NOT NULL, 
	`subscribe_id` bigint(20) NOT NULL, 
	`follow_type` int(11) NULL COMMENT '关注的类型', 
	`recomm_type` int(11) NULL COMMENT '可能认识的人推荐的类型', 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	`is_delete` tinyint(4) NULL COMMENT '删除标示,当关注表的数据被删除的时候,这里标示删除', 
	`app_id` bigint(20) UNSIGNED NULL COMMENT '关注来源的应用', 
	`is_taozihao` tinyint(4) NULL COMMENT '是否来自淘字号关注', 
	`role_id` smallint(6) NULL COMMENT '淘字号的roleId', 
	PRIMARY KEY (`id`)
)  AUTO_INCREMENT = 11840610 CHARSET = utf8;
CREATE TABLE if not exists sns_friend_group (
	`user_id` bigint(20) UNSIGNED NOT NULL, 
	`friend_id` bigint(20) NOT NULL, 
	`group_id` bigint(20) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	`gmt_modified` datetime NOT NULL, 
	`char_1` varchar(256) NULL, 
	`number_1` bigint(20) NULL, 
	PRIMARY KEY (`user_id`, `friend_id`, `group_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_group_info (
	`id` int(10) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '自增主键', 
	`user_id` bigint(20) UNSIGNED NOT NULL, 
	`group_id` bigint(20) UNSIGNED NOT NULL COMMENT '组的id,通过seq生成.默认组除外', 
	`group_name` varchar(32) NOT NULL COMMENT '组的名字', 
	`group_desc` varchar(64) NULL COMMENT '组的描述', 
	`group_count` int(10) UNSIGNED NOT NULL COMMENT '组内的人数', 
	`is_delete` tinyint(4) NULL COMMENT '删除标志位.1标识删除.用户自定义组物理删除.默认组才使用这个标志位', 
	`gmt_create` datetime NOT NULL COMMENT '记录创建时间', 
	`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间', 
	PRIMARY KEY (`id`), 
	UNIQUE `uk_user_group` (`user_id`, `group_id`)
)  AUTO_INCREMENT = 239218 CHARSET = utf8 COMMENT = '用户的分组信息表.记录了默认组以及用户自定义组的信息  512张分表';
CREATE TABLE if not exists sns_invite (
	`id` bigint(20) UNSIGNED NOT NULL, 
	`user_id` bigint(20) NOT NULL, 
	`type` tinyint(4) NOT NULL, 
	`account` varchar(200) NOT NULL, 
	`gmt_create` datetime NULL, 
	`gmt_modified` datetime NULL, 
	`char_1` varchar(256) NULL, 
	`number_1` bigint(20) NULL, 
	PRIMARY KEY (`id`), 
	KEY `ind_sns_invite_userid` (`user_id`, `account`, `type`)
) CHARSET = utf8;
CREATE TABLE if not exists sns_invite_account (
	`id` bigint(20) UNSIGNED NOT NULL, 
	`invite_id` bigint(20) NOT NULL, 
	`nick` varchar(118) NULL, 
	`account` varchar(118) NULL, 
	`status` tinyint(4) NULL, 
	`gmt_create` datetime NULL, 
	`account_user_id` bigint(20) NULL, 
	`type` tinyint(4) NULL, 
	`gmt_modified` datetime NULL, 
	`char_1` varchar(256) NULL, 
	`number_1` bigint(20) NULL, 
	PRIMARY KEY (`id`), 
	KEY `ind_invite_account_inviteid` (`invite_id`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_invite_from (
	`inviter_user_id` bigint(20) NOT NULL, 
	`received_user_id` bigint(20) NULL, 
	`invitekey` bigint(20) NOT NULL, 
	`type` tinyint(4) NULL, 
	`GMT_CREATE` datetime NOT NULL, 
	`gmt_modified` datetime NULL, 
	`status` tinyint(4) NULL, 
	`group_id` bigint(20) NULL, 
	`app_id` bigint(20) NULL, 
	`invite_target` varchar(118) NULL, 
	`Invite_target_type` tinyint(4) NULL, 
	`char_1` varchar(256) NULL, 
	`number_1` bigint(20) NULL, 
	`date_1` datetime NULL, 
	`add_friend_status` tinyint(4) NULL, 
	`accept_way` int(11) NULL, 
	PRIMARY KEY (`invitekey`), 
	KEY `IDX_friend_invitefrom_modified` (`gmt_modified`), 
	KEY `inviter_user_id` (`inviter_user_id`, `invite_target`, `GMT_CREATE`)
)  CHARSET = utf8;
CREATE TABLE if not exists sns_my_fans (
	`id` bigint(20) NOT NULL, 
	`user_id` bigint(20) NOT NULL, 
	`fans_id` bigint(20) NOT NULL, 
	`gmt_create` datetime NOT NULL, 
	PRIMARY KEY (`id`), 
