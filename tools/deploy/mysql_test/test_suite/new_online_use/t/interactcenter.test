#tags new_online_use 
#description:this case is use for test online use of ob1.0 

CREATE TABLE if not exists push_task_info (
	`id` bigint(20) UNSIGNED AUTO_INCREMENT NOT NULL COMMENT '主键', 
	`gmt_modified` bigint(20) NOT NULL COMMENT '修改时间', 
	`name` varchar(30) NOT NULL COMMENT '任务名称', 
	`description` varchar(255) NULL COMMENT '任务描述', 
	`properties` varchar(1024) NULL COMMENT '任务属性，包含kv数据', 
	`type` tinyint(4) DEFAULT '0' COMMENT '任务类型', 
	PRIMARY KEY (`id`)
)  CHARSET = utf8 COMMENT = '推送关系数据的任务，提醒模块使用';
CREATE TABLE if not exists trigger_task_info (
