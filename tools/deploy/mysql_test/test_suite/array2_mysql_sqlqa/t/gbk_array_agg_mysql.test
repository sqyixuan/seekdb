insert into tt3 values(1,1);
insert into tt3 values(2,-20);
insert into tt3 values(3,3);
insert into tt3 values(3,3);
insert into tt3 values(5,50);
insert into tt3 values(6,-6);
insert into tt3 values(9,null);
insert into tt3 values(7,false);
insert into tt3 values(8,true);
insert into tt3 values(8,null);
insert into tt3 values(7,false);
insert into tt3 values(6,-60);
select array_agg(b) from tt3;
select array_agg(b) from vtt3 limit 1;

select array_agg(id order by 1 nulls last,2 nulls first) from tt3;

select array_agg(distinct id order by 1 nulls last,2 nulls first) from tt3;

select array_agg(1 order by b desc nulls last ) from tt3;
select array_agg(distinct 1 order by b desc nulls last ,id nulls first) from tt3;

#distinct
select  array_agg( distinct b) from tt3;
select  array_agg( distinct b order by b) from tt3;
select  array_agg( distinct b order by b desc) from tt3;
select  array_agg( distinct b order by b asc) from tt3;


# order by
select  array_agg( b order by b) from tt3;
select  array_agg( b order by b asc) from tt3;
select  array_agg( b order by b desc) from tt3;
select  array_agg( b order by b desc nulls first) from tt3;
select  array_agg( b order by b  nulls first) from tt3;
select  array_agg( b order by b  nulls last) from tt3;
select  array_agg(distinct b order by b  nulls last) from tt3;
select  array_agg( distinct b order by b desc nulls first) from tt3;
select  array_agg( b order by b,id) from tt3;
select  array_agg( b order by 1) from tt3;
select  array_agg( b order by id desc) from tt3;
select  array_agg( distinct b order by id desc) from tt3;


