select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ cardinality(c2) a from tt2;

select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ cardinality(c2) a from vtt2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ cardinality(c2) a from vtt2;

