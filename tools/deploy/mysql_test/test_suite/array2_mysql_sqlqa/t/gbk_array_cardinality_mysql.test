drop view vtt1;
create view vtt1 as select * from tt1;

--error 0,1051
drop table tt2;
create table tt2(id int primary key,c1 array(int unsigned), c2 array(varchar(256)), c3 array(tinyint unsigned), c4 array(bigint unsigned), c5 array(float), c6 array(double), c7 array(smallint unsigned))
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);
insert into tt2 values(1,[2147483648,0, 2147483647],['test'],[127,0,128],[9223372036854775807,9223372036854775807,775,808,2,0],[3.402, 0, 1.175],
