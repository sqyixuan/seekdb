select * from tt1 group by cardinality([1,23]);
select cardinality(c1),cardinality(c2),cardinality(c3),cardinality(c5),cardinality(c6),cardinality(c7),cardinality(c4) from tt1 order by cardinality(c4) asc;
select distinct cardinality(c1),cardinality(c3) from tt1;
select distinct cardinality([1,2,3,4]) from tt1;

#with as
WITH Alice_Students AS (
    select cardinality(c1),cardinality(c2),cardinality(c3),cardinality(c5),cardinality(c6),cardinality(c7),cardinality(c4) from tt1
)
SELECT * FROM Alice_Students;

WITH Alice_Students AS (
    select cardinality([1,2,3,4,5])
)
SELECT * FROM Alice_Students;

#case when 
SELECT CASE cardinality([1,2,3,4,5]) WHEN cardinality([1,2,3,4,5])THEN cardinality([1,2,3,4,5]) WHEN cardinality([1,2,3,4,5,7,8]) THEN cardinality([1,2,3,4,5,7,8])  END;

SELECT CASE cardinality([1,2,3,4,5,7,8]) WHEN cardinality([1,2,3,4,5])THEN cardinality([1,2,3,4,5]) WHEN cardinality([1,2,3,4,5,7,8]) THEN cardinality([1,2,3,4,5,7,8])  END;

SELECT CASE cardinality(c1) WHEN cardinality(c1)THEN cardinality(c1) WHEN cardinality(c2) THEN cardinality(c2)  END from tt1;

SELECT CASE cardinality(c2) WHEN cardinality(c1)THEN cardinality(c1) WHEN cardinality(c2) THEN cardinality(c2)  END from tt1;

#where 比较运算符
select * from tt1 where cardinality(c5) =1;
select * from tt1 where  cardinality(c5)='1';
select * from tt1 where  cardinality(c5)=cardinality(c5);
select * from tt1 where  cardinality(c5)=cardinality(c5);

select * from tt1 where cardinality(c5)<'test';

select * from tt1 where cardinality(c5)<=>id;

select * from tt1 where cardinality(c5)!= cardinality([1,2,34,5,6]);

select * from tt1 where cardinality(c5) BETWEEN cardinality(c5) AND cardinality(c5);
select * from tt1 where cardinality(c5) not BETWEEN cardinality(c5) AND cardinality(c5);

select * from tt1 where cardinality(c5) not in (cardinality(c5),cardinality([1,2,5,7])) ;
select * from tt1 where cardinality(c5)  in (cardinality(c5),cardinality([1,2,5,7])) ;

select * from tt1 where cardinality(c5) like cardinality(c5);

select * from tt1 where cardinality(c5) not like cardinality(c5);

select * from tt1 where cardinality(c5) is true;
select * from tt1 where cardinality([1,2])  is not true;
select * from tt1 where cardinality([1])  is false;
select * from tt1 where cardinality(c1)  is not false;

select * from tt1 where cardinality(c5)  is not null;
select * from tt1 where cardinality(c5)  is  null;
