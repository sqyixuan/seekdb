drop table test;
create table test(a varchar(262144)[],a1 bigint[]);
insert into test values((SELECT CONCAT('[', GROUP_CONCAT(number ORDER BY number SEPARATOR ', '), ']') AS nums
FROM (
     SELECT FLOOR(1+RAND() * 1) AS number
    FROM TABLE(GENERATOR(100000))
) AS temp),(SELECT CONCAT('[', GROUP_CONCAT(number ORDER BY number SEPARATOR ', '), ']') AS nums
FROM (
     SELECT FLOOR(1+RAND() * 1) AS number
    FROM TABLE(GENERATOR(100000))
) AS temp));
select cardinality(a),cardinality(a1) from test;
