drop table if exists t1;
create table t1(c1 int ,  c2 varchar(256)[]) partition by hash(c1);
insert into t1 values(1,'[1,1,1]');
insert into t1 values(2,null);
select cardinality(a1) from t1 a,t1 b,unnest([[a.c1]],[[b.c2]])a(a1,a2);
select rb_build(a1) from t1 a,t1 b,unnest([[a.c1]],[[b.c2]])a(a1,a2);
select array_to_string(a1,'-') from t1 a,t1 b,unnest([[a.c1]],[[b.c2]])a(a1,a2);
select array_agg(a1) from t1 a,t1 b,unnest([[a.c1]],[[b.c2]])a(a1,a2);
select array_overlaps(a2,a1) from t1 a,t1 b,unnest([[a.c1]],[b.c2])a(a1,a2);
select array_contains_all(a2,a1) from t1 a,t1 b,unnest([[a.c1]],[b.c2])a(a1,a2);
#函数嵌套
select cardinality(array(1,2,3,4,5,6));
select cardinality(array_agg(id)) from tt1;
select array_agg(cardinality([1,2,3,4,5,6]));
select [[[cardinality(array(1,2,3,4,5,6))]]];
select array(cardinality([1,2,3,4,5,6]));
select cardinality( array_append([[1,2,3,4]],[1]));
select array_append([1,2,3,4,'test'],cardinality([1]));
select cardinality( array_distinct([[1,2,3,4,1]]));
select cardinality( array_map((x,y,z) -> (x is null and y is not null or z is not null), [[1]], [1],['abc']));
--echo bug 2024120400105949234   《[obmysql_array二期]array_map 参数嵌套传递，ob报4016》
select array_map((x)->(cardinality(array_map((x)->(x),x))),[[[[1]]]]);
--echo bug 2024120400105949234   《[obmysql_array二期]array_map 参数嵌套传递，ob报4016》
select array_map((x)->((array_map((x)->(x),x))),[[1]]);
select cardinality( array_remove([1,23], 1));
select array_remove([1,2,4,5],cardinality([[1,2]]));
select cardinality(string_to_array('1and2and3and', 'and'));
select  cardinality(array_agg(["1","2","3",""]));
select cardinality([[1,2], [3,4]] + [[1,2], [3,4]]);
--error 5083
select cardinality([["hello", "hi"], ["what", "is", "your", "name"]] = [["hello", "hi"], ["what", "is", "your", "name"]]);
select array_contains([1,2,3], cardinality([2]));
select cardinality(a1) from unnest([[1,2,3]]) a(a1);
select sum(cardinality(c1)) from tt1;
select count(cardinality(c1)) from tt1;
select avg(cardinality(c1)) from tt1;
select min(cardinality(c1)) from tt1;
select max(cardinality(c1)) from tt1;
select ABS(cardinality(c1)) from tt1;
select GREATEST(cardinality([1,2]),cardinality([1,2,5]));
select IFNULL(cardinality([1,2]),cardinality([1,2,5]));
--error 5083
select cardinality(JSON_ARRAY(1,2,3));
select JSON_ARRAY(cardinality([1,2,3]));

