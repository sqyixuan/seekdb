select cast(array_overlaps(c2,c2) as UNSIGNED) from tt1;
select cast(array_overlaps(c1,c1) as SIGNED) from tt1;
select cast(array_overlaps(c1,c1) as date) from tt1;
select cast(array_overlaps(c1,c1) as DATETIME) from tt1;
select cast(array_overlaps(c1,c1) as TIME) from vtt2;
select cast(array_overlaps(c1,c1) as FLOAT) from tt1;
