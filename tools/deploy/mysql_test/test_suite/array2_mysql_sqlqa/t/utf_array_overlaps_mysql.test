--error 0,1051
drop view vtt2;
create view vtt2 as select * from tt2;


#关闭向量化优化和batch优化
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_overlaps(c2,c2) a from tt2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_overlaps(c2,c2) a from tt2;

select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_overlaps(c2,c2) a from vtt2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_overlaps(c2,c2) a from vtt2;

select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_overlaps(c2,c2) a from vtt1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_overlaps(c2,c2) a from vtt1;
