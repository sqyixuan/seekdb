--echo bug 2024110800105034260   《【obmysql_array二期】group by/having cardinality(),ob报4016》
select * ,array_overlaps(c1,c1) from vtt1 group by id having array_overlaps(c1,c1)>1;

#order by
select * ,array_overlaps(c1,c1), c1 from tt1 order by array_overlaps(c1,c1);
select * ,array_overlaps(c1,c1), c1,c2 from tt1 order by array_overlaps(c1,c1) desc ;
select * ,array_overlaps(c2,c2), c1,c2 from tt1 order by array_overlaps(c2,c2) asc ;

select * ,array_overlaps(c1,c1), c1 from vtt1 order by array_overlaps(c1,c1);
select * ,array_overlaps(c1,c1), c1,c2 from vtt1 order by array_overlaps(c1,c1) desc ;
select * ,array_overlaps(c2,c2), c1,c2 from vtt1 order by array_overlaps(c2,c2) asc ;

select * ,array_overlaps(c1,c1), c1 from tt2 where id=1 order by array_overlaps(c1,c1);
select * ,array_overlaps(c1,c1), c1,c2 from tt2 where id=1  order by array_overlaps(c1,c1) desc ;
select * ,array_overlaps(c2,c2), c1,c2 from tt2  where id=1  order by array_overlaps(c2,c2) asc ;
select * ,array_overlaps(c1,c1), c1 from vtt2 where id=1 order by array_overlaps(c1,c1);
select * ,array_overlaps(c1,c1), c1,c2 from vtt2 where id=1  order by array_overlaps(c1,c1) desc ;
select * ,array_overlaps(c2,c2), c1,c2 from vtt2  where id=1  order by array_overlaps(c2,c2) asc ;

#distinct
select  distinct array_overlaps(c1,c1) from tt1 limit 2;
select  distinct array_overlaps(c1,c1) from tt2;
