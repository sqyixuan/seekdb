select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_overlaps(c2,c2) a from tt1;

select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_overlaps(c2,c2) a from tt2;
