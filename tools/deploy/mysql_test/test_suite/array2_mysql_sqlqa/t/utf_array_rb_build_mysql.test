purge recyclebin;
--disable_warnings
drop database IF EXISTS oblrp;
--enable_warnings
create database oblrp;
use oblrp;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
SET SESSION group_concat_max_len = 100000000;
set ob_default_lob_inrow_threshold = 0;
--result_format 4
--error 0,1051
drop table tt1;
create table tt1(id int,c1 array(int), c2 array(varchar(256)), c3 tinyint[][], c4 array(bigint), c5 array(float), c6 array(double), c7 array(smallint));
insert into tt1 values(1,[-2147483648,0, 2147483647],['test'],[[127,0,-128],[8,9]],[-9223372036854775808,9223372036854775807,775,808,2,0],[3.402, 0, 1.175],
[1.7976931348623157E+308, 2.2250738585072014E-308],[-32768,0,32767]);

insert into tt1 values(2,[-2147483648,0, 2147483647,4],['test'],[[127,0,-128],[8,9]],[-9223372,9223372036854775807,775,808,2,0,1],[3.402, 0, 1.175,4],
[1.7976931348623157E+308,1.2,2.2250738585072014E-308],[-32768,0,32767,0]);

insert into tt1 values(3,[-2,0, 25,4],['test'],[[127,0,-128],[8,9,10]],[-922,9223372036854775807,775,808,2,0,1],[3.402, 0, 1.175,4],
[1.7976931348623157E+308,1.2,2.2250738585072014E-308],[-32768,0,32767,0]);

--error 0,1051
drop view vtt1;
create view vtt1 as select * from tt1;

--error 5083
select * from tt1 order by c1,c2;

--error 0,1051
drop table tt2;
create table tt2(id int,c1 array(int unsigned), c2 array(varchar(256)), c3 array(tinyint unsigned), c4 array(bigint unsigned), c5 array(float), c6 array(double), c7 array(smallint unsigned))
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);
insert into tt2 values(1,[2147483648,0, 2147483647],['test'],[52,0,5],[ 852,9223372036854775807,775,808,2,0],[3.402, 0, 1.175],
[1.7976931348623157E+308, 2.2250738585072014E-308],[88,0,32767]);

insert into tt2 values(2,[87666,0, 2147483647,4],['test'],[5,0,7,6,50],[1,100000,9223372036854775807,775,808,2,0,1],[3.402, 0, 1.175,4],
[1.7976931348623157E+308,1.2,2.2250738585072014E-308],[68,0,32767,0,1]);

--error 0,1051
drop view vtt2;
create view vtt2 as select * from tt2;

select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ rb_build(c1) from tt2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ rb_build(c1) from tt2;

select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ rb_build(c1) from vtt2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ rb_build(c1) from vtt2;

select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ rb_build(c1) from vtt1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ rb_build(c1) from vtt1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_agg(c1) from tt1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ rb_build(c1) from tt1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */  rb_build(c1) from tt1;

select rb_build(c1),rb_build(c3),rb_build(c4),rb_build(c7)  from tt2;

