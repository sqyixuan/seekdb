--error 0,1051
drop view vtt1;
create view vtt1 as select * from tt1;

--error 0,1051
drop table tt2;
create table tt2(id int,c1 array(int unsigned), c2 array(varchar(256)), c3 array(tinyint unsigned), c4 array(bigint unsigned), c5 array(float), c6 array(double), c7 array(smallint unsigned))
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);
insert into tt2 values(1,[2147483648,0, 2147483647],['test'],[52,0,5],[ 852,9223372036854775807,775,808,2,0],[3.402, 0, 1.175],
[1.7976931348623157E+308, 2.2250738585072014E-308],[88,0,32767]);

insert into tt2 values(2,[87666,0, 2147483647,4],['test'],[5,0,7,6,50],[1,100000,9223372036854775807,775,808,2,0,1],[3.402, 0, 1.175,4],
[1.7976931348623157E+308,1.2,2.2250738585072014E-308],[68,0,32767,0,1]);

--error 0,1051
drop view vtt2;
create view vtt2 as select * from tt2;

#关闭向量化优化和batch优化
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_contains_all(c2,c2) a from tt2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_contains_all(c2,c2) a from tt2;

select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_contains_all(c2,c2) a from vtt2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_contains_all(c2,c2) a from vtt2;

select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_contains_all(c2,c2) a from vtt1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_contains_all(c2,c2) a from vtt1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_contains_all(c2,c2) a from tt1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_contains_all(c2,c2) a from tt1;

select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */  /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_contains_all(c2,c2) a from tt1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */  /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, array_contains_all(c2,c2) a from tt2;

#参数1
#数字array
select array_contains_all([1],[1]);
select array_contains_all([1],[1,2]);
select array_contains_all([1],[-1]);
select array_contains_all([-1],[-1]);
select array_contains_all([-1,-2],[-1]);
select array_contains_all([-1,-2],[-1,-3]);
select array_contains_all([-28],[-1]);
select array_contains_all([-28],[-28]);
select array_contains_all([-27],[-28]);
select array_contains_all([0],[0,0]);
select array_contains_all([1,1],[1]);
select array_contains_all([0],[0,0,1000]);
select array_contains_all([1,2,3,4,-5,60,70],[1,2,3,4,5]);
select array_contains_all([1,2,3,4,-5,60,70],[1,4,1,2,3,-5]);
