drop view vtt2;
create view vtt2 as select * from tt2;
select array_to_string(c1,'-','a'),array_to_string(c2,'-','a'),array_to_string(c3,'-','a'),array_to_string(c4,'-','a') ,array_to_string(c5,'-','a'),array_to_string(c6,'-','a'),array_to_string(c7,'-','a') from tt1;
select array_to_string(c1,'-','a'),array_to_string(c2,'-','a'),array_to_string(c3,'-','a'),array_to_string(c4,'-','a') ,array_to_string(c5,'-','a'),array_to_string(c6,'-','a'),array_to_string(c7,'-') from vtt1;
select array_to_string(c1,'-'),array_to_string(c2,'-'),array_to_string(c3,'-'),array_to_string(c4,'-') ,array_to_string(c5,'-'),array_to_string(c6,'-'),array_to_string(c7,'-') from tt2;
select  /*+enable_parallel_dml parallel(2) */ array_to_string(c1,'-','a'),array_to_string(c2,'-','a'),array_to_string(c3,'-','a'),array_to_string(c4,'-','a') ,array_to_string(c5,'-','a'),array_to_string(c6,'-','a'),array_to_string(c7,'-','a') from vtt2;

select array_to_string(c1,'-'),/*+read_consistency(weak) */ array_to_string(c2,'-'),array_to_string(c3,'-'),array_to_string(c4,'-') ,array_to_string(c5,'-'),array_to_string(c6,'-'),array_to_string(c7,'-') from tt2;

