insert into tt5 values(20,[6,7],null,'142143144.5E-7',null,[1,2,3,4,6]);

select * from tt5 partition(p0);
delete /*+enable_parallel_dml parallel(2) index(tt5 index_1) */ from tt5 partition(p0);
