drop function fun_test;
delimiter //;
create function fun_test()
returns longtext
begin
declare r longtext;
declare i int;
declare i1 int;
declare i2 int;
select cardinality([[1,2,34]]) into i;
select array_to_string([[1,2,34]],'a') into r;
select array_overlaps([1,2,34],[1,2,34]) into i1;
select array_contains_all([1,2,34],[1,2,34]) into i2;
insert into tt3 values(cardinality([[1,2,34]]),array_to_string([[1,2,34]],'a'),(select array_agg(1)),rb_build([12,3]));
replace into tt3 values(array_overlaps([1,2,34],[1,2,34]),array_to_string([[1,2,34]],'a'),(select array_agg(1)),rb_build([12,3]));
replace into tt3 values(array_contains_all([1,2,34],[1,2,34]),array_to_string([[1,2,34]],'a'),(select array_agg(1)),rb_build([12,3]));
return r;
end;
//
delimiter ;//
select fun_test();


