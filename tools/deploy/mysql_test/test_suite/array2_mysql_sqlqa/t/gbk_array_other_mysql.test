select array_to_string(a2,'1','a')  from mv1;
select array_overlaps(a2,a1)  from mv1;
select array_contains_all(a2,a1)  from mv1;
select array_agg( distinct v2.a order by v1.a,v2.d) from mv1 v1,mv1 v2 order by v1.id,v2.d;
