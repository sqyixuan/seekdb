#删除分区数据
drop table tt5;
create table tt5(id int primary key,v vector(2), a varchar(100),d double,a1 array(float),a2 int[])
partition by hash(id) partitions 4;
drop view vtt5;
create view vtt5 as select * from tt5;
create index index_1 on tt5(a) local;
insert into tt5 values(1,[1,2],'test','1.2E-2',[1,525.12E-2],[1,2,3,4,5]);
insert into tt5 values(2,[1,2],'test1','1.5E-2',[1,523.12E-2],[1,2,3,4,5]);
insert into tt5 values(3,[1,2],'test2','1.5E-2',[1,523.12E-2],[1,2,3,4,5]);
insert into tt5 values(4,[3,4],'test3','142143144.5E-7',[1,523.12E-2],[1,6,3,4,5]);
insert into tt5 values(5,[6,7],'test4','142143144.5E-7',[1,523.12E-2],[1,2,3,4,5]);
insert into tt5 values(6,null,'test4','142143144.5E-7',[1,523.12E-2],[5,2,3,4,5]);
insert into tt5 values(7,null,'test5','142143144.5E-7',[1,523.12E-2],[1,2,3,4,5]);
insert into tt5 values(8,[6,7],'test6','142143144.5E-7',[1,523.12E+2,1,6,9],[1,2,3,4,5]);
