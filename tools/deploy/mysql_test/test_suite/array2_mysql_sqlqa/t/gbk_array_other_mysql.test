--echo bug 2024121600106491380   《【obmysql_array二期】分区表含有array类型，MINUS,UNION,INTERSECT 只返回array时，报5083，非分区表正常返回》
--error 5083
select a2,a1 from tt5 UNION select a2,a1 from tt6;
select * from tt5 INTERSECT  select * from tt6;
