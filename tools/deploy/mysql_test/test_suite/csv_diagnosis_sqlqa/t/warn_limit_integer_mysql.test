####多文件异常场景####
--error 0,1051
drop table t1;
create table t1(
FIELD_NAME VARCHAR(100),
FUN_NAME varchar(100),
PRO_NAME VARCHAR (100),
PAC_NAME VARCHAR (100),
PAC_NOBO_NAME VARCHAR (100),
TYP_NAME VARCHAR(100) );

load data /*+ direct(true,0) parallel(4)  */  from files
(location = 'mysqltest_data_for_external_table/data/',
FORMAT (
    type = 'csv',
	FIELD_DELIMITER = ',',
	IGNORE_LAST_EMPTY_COLUMN = false
),
pattern = 'PL_JR02.dat'
)  into table t1 log errors reject limit 1 ;
show warnings;
select count(*) from t1;

###limit 50为单机上限 多线程导入时每条线程分配的诊断条数随机 所以limit无法限制实际诊断数量
--disable_warnings
load data   from (select c1,c2,c3,c4,c5,c6 from files
(location = 'mysqltest_data_for_external_table/data/',
FORMAT (
    type = 'csv',
	FIELD_DELIMITER = ','
),
pattern = '.dat$'
))  into table t1(FIELD_NAME,FUN_NAME,PRO_NAME,PAC_NAME,PAC_NOBO_NAME,TYP_NAME)  log errors reject limit 77;
--enable_warnings
--sorted_result
show warnings;
select count(*) from t1;

--enable_sorted_result
--error 0,1051
drop table t1;
create table t1(c1 int ,c2 int);

--disable_warnings
load data /*+ direct(true,0) parallel(2)  */  from files
(location = 'mysqltest_data_for_external_table/data_warn/mixed/',
FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    IGNORE_LAST_EMPTY_COLUMN = false
))  into table t1 log errors reject limit 49 ;
--enable_warnings
show warnings;
select * from t1;

--disable_warnings
load data /*+ direct(true,0) parallel(4)  */  from (select c2 from files
(location = 'mysqltest_data_for_external_table/data_warn/mixed/',
FORMAT (
    type = 'csv',
	FIELD_DELIMITER = ','
)))  into table t1(c2)  log errors reject limit 64;
--enable_warnings
show warnings;
select * from t1;

--error 0,1051
drop table t1;

--source mysql_test/test_suite/csv_diagnosis_sqlqa/include/clean_data_for_external_table.inc
