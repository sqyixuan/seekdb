####少列####
####同时验证诊断上限64条####
--error 0,1051
drop table t1;
create table t1(order_id int,customer_name varchar(3));
##显示诊断64，实际诊断66
load data /*+ direct(true,0) parallel(2)  */  from files
(location = 'mysqltest_data_for_external_table/data_warn/missing_column/',
FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    IGNORE_LAST_EMPTY_COLUMN = false
)
)  into table t1  log errors reject limit 66;
show warnings;
select * from t1;

load data /*+ direct(true,0) parallel(2)  */  from (select * from files
(location = 'mysqltest_data_for_external_table/data_warn/missing_column/',
FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    EMPTY_FIELD_AS_NULL = true,
    SKIP_HEADER = 1
)
))  into table t1  log errors reject limit 33;
show warnings;
select * from t1;

