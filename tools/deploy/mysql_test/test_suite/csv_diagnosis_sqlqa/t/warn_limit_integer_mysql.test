#####测试limit xx######
#####数值列插字符####
--error 0,1051
drop table t1;
create table t1(c1 int ,c2 int);

--error 11088
load data /*+ direct(true,0) parallel(2)  */  from files
(location = 'mysqltest_data_for_external_table/data_warn/type_string_in_number/',
FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ','
),
PATTERN 'type_string_in_number.csv'
)  into table t1 log errors reject limit 1 ;
show warnings;
select * from t1;

--error 0,1051
drop table t1;
create table t1(c1 int primary key,c2 int);

load data /*+ direct(true,0) parallel(2)  */  from (select * from files
(location = 'mysqltest_data_for_external_table/data_warn/type_string_in_number/',
FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ','
),
PATTERN 'type_string_in_number.csv'
))  into table t1  log errors reject limit 3;
show warnings;
select * from t1;

--error 11088
load data /*+ direct(true,0) parallel(2)  */  from (select * from files
(location = 'mysqltest_data_for_external_table/data_warn/type_string_in_number/',
