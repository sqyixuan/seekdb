--result_format 4
PURGE RECYCLEBIN;
--source mysql_test/include/oss_config_for_import.inc

####分区表，视图导入####
--error 0,1051
drop table t1;
create table t1(
id int,
name CHAR (10),
mon CHAR (10),
age CHAR (10),
tel_number varCHAR (50) ) partition by hash(id) partitions 4;

##不指定分区，走诊断
--source mysql_test/test_suite/csv_diagnosis_sqlqa/include/replace_oss_info.inc

eval load data /*+ direct(true,0) parallel(2)  */  from files
(location = 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/',
FORMAT (
    type = 'csv'
),
PATTERN = 'test.csv\$'
)  into table t1 log errors reject limit unlimited ;
show warnings;
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);

##指定分区导入报错，不走诊断(预期)
--source mysql_test/test_suite/csv_diagnosis_sqlqa/include/replace_oss_info.inc

--error 1748
eval load data /*+ direct(true,0) parallel(2)  */  from files
(location = 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/',
FORMAT (
    type = 'csv'
),
PATTERN = 'test.csv\$'
)  into table t1 partition(p1) log errors reject limit unlimited ;
show warnings;
select * from t1 partition(p1);

##range
##指定分区符合分区规则，走诊断
--error 0,1051
drop table t1;
create table t1(
id int,
name CHAR (10),
mon CHAR (10),
age CHAR (10),
tel_number varCHAR (50) ) partition by range(id) (
partition p1 values less than (10),
partition p2 values less than (20),
partition p3 values less than maxvalue
);

--source mysql_test/test_suite/csv_diagnosis_sqlqa/include/replace_oss_info.inc

eval load data /*+ direct(true,0) parallel(4)  */  from (select c1,c2,c3,c4,c5 from files
(location = 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/',
FORMAT (
    type = 'csv'
),
PATTERN = 'test.csv\$'
))  into table t1 partition(p1) (id,name,mon,age,tel_number) log errors reject limit unlimited;
show warnings;
select * from t1 partition(p1);


