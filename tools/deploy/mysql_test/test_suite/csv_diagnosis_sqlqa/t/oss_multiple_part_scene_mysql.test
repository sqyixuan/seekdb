(location = 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/data_warn/mixed/',
FORMAT (
    type = 'csv',
	FIELD_DELIMITER = ','
)))  into table t1(c2)  log errors reject limit unlimited;
--enable_warnings
show warnings;
select * from t1;

