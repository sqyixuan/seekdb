####多文件异常场景####
--error 0,1051
drop table t1;
create table t1(
FIELD_NAME VARCHAR(100),
FUN_NAME varchar(100),
PRO_NAME VARCHAR (100),
PAC_NAME VARCHAR (100),
PAC_NOBO_NAME VARCHAR (100),
TYP_NAME VARCHAR(100) );

--source mysql_test/test_suite/csv_diagnosis_sqlqa/include/replace_oss_info.inc

eval load data /*+ direct(true,0) parallel(4)  */  from files
(location = 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/',
FORMAT (
    type = 'csv',
	FIELD_DELIMITER = ',',
	IGNORE_LAST_EMPTY_COLUMN = false
),
pattern = 'PL_JR02.dat'
)  into table t1 log errors reject limit unlimited ;
show warnings;
select count(*) from t1;

--disable_warnings
--source mysql_test/test_suite/csv_diagnosis_sqlqa/include/replace_oss_info.inc

eval load data /*+ direct(true,0) parallel(4)  */  from (select c1,c2,c3,c4,c5,c6 from files
(location = 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/',
FORMAT (
    type = 'csv',
	FIELD_DELIMITER = ',',
	IGNORE_LAST_EMPTY_COLUMN = false
),
pattern = '.dat\$'
))  into table t1(FIELD_NAME,FUN_NAME,PRO_NAME,PAC_NAME,PAC_NOBO_NAME,TYP_NAME)  log errors reject limit unlimited;
--enable_warnings
--sorted_result
show warnings;
select count(*) from t1;

####数值插字符
