##############################################################################
####load data                                                             ####
####    [/*+ insert hint*/]                                               ####
####    [REPLACE | IGNORE]                                                ####
####    FROM { <url_table_function_expr> |                                ####
####         ( SELECT expression_list FROM <url_table_function_expr> ) }  ####
####    INTO TABLE table_name                                             ####
####    [partition (partition_name1, [partition_name2 ...])]              ####
####    [(column_name_var [, column_name_var] ...)]                       ####
####    [log errors reject limit unlimited ]                              ####
##############################################################################

#####数值列插字符####
--error 0,1051
drop table t1;
create table t1(c1 int primary key,c2 int);

--source mysql_test/test_suite/external_table_oss_sqlqa/include/replace_oss_info.inc

eval load data   from files
(location = 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/data_warn/type_string_in_number/',
FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ','
),
PATTERN 'type_string_in_number.csv'
)  into table t1 log errors reject limit unlimited ;
show warnings;
select * from t1;

