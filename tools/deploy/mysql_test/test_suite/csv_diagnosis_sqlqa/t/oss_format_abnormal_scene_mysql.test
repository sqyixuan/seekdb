#####压缩csv####
--error 0,1051
drop table t1;
create table t1(id CHAR (10),
                name CHAR (10),
                mon CHAR (10),
                age CHAR (10),
                tel_number varCHAR (50));

--source mysql_test/test_suite/external_table_oss_sqlqa/include/replace_oss_info.inc

eval load data   from files
(location = 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/',
FORMAT (
    type = 'csv',
    compression = auto
),
PATTERN = 'test.csv\$'
)  into table t1 log errors reject limit unlimited ;
show warnings;
select * from t1;

--source mysql_test/test_suite/external_table_oss_sqlqa/include/replace_oss_info.inc

eval load data from (select * from files
(location = 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/external_table_compression/',
FORMAT (
    type = 'csv',
    compression = auto
),
PATTERN = 'test_ex_compression.csv.*'
))  into table t1  log errors reject limit unlimited;
show warnings;
select * from t1;
--source mysql_test/test_suite/external_table_oss_sqlqa/include/replace_oss_info.inc

--error 4257
eval load data   from files
(location = 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/external_table_compression/',
FORMAT (
    type = 'csv',
    compression = ZSTD
),
PATTERN = 'test_ex_compression.csv.deflate'
)  into table t1 log errors reject limit unlimited ;
show warnings;
select * from t1;

####压缩csv其他诊断场景####
--error 0,1051
drop table t1;
create table t1(id smallint ,
                name int ,
                mon tinyint ,
                age decimal ,
                tel_number bigint,
                id2 tinytext ,
                name2 varchar(10) ,
                mon2 text(10) ,
                age2 bigint UNSIGNED ,
                tel_number2 varbinary(50) );

--disable_warnings
--source mysql_test/test_suite/external_table_oss_sqlqa/include/replace_oss_info.inc

eval load data   from (select c2,c2,c2,c2,c2,c2,c2,c2,c2,c2 from files
(location = 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/external_table_compression/',
FORMAT (
    type = 'csv'
    ENCODING = 'UTF8MB4'
    SKIP_HEADER = 1
	LINE_DELIMITER = '\n'
	EMPTY_FIELD_AS_NULL = true
	compression = auto
),
PATTERN = 'test_ex_compression.csv.*'
))  into table t1  log errors reject limit unlimited;
--enable_warnings
--sorted_result
show warnings;
select * from t1;

