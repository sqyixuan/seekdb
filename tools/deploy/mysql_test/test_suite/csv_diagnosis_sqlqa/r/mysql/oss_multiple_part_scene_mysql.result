##range
##指定分区符合分区规则，走诊断
drop table t1;
create table t1(
id int,
name CHAR (10),
mon CHAR (10),
age CHAR (10),
tel_number varCHAR (50) ) partition by range(id) (
partition p1 values less than (10),
partition p2 values less than (20),
partition p3 values less than maxvalue
);
load data /*+ direct(true,0) parallel(4)  */  from (select c1,c2,c3,c4,c5 from files
(location = '#OSS_HOST#:#OSS_ACCESS_ID#@#OSS_ACCESS_KEY#/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/',
FORMAT (
    type = 'csv'
),
PATTERN = 'test.csv$'
))  into table t1 partition(p1) (id,name,mon,age,tel_number) log errors reject limit unlimited;
