####view(不支持load data)
drop table t1;
drop table t1_meta;
create table t1_meta(c1 int primary key,c2 int);
create view t1 as select * from t1_meta;
load data /*+ direct(true,0) parallel(2)  */  from files
(location = '#OSS_HOST#:#OSS_ACCESS_ID#@#OSS_ACCESS_KEY#/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/data_warn/type_string_in_number/',
FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ','
),
PATTERN 'type_string_in_number.csv'
)  into table t1 log errors reject limit unlimited ;
ERROR 0A000: load data to the view is not supported
drop view t1;
drop table t1_meta;
