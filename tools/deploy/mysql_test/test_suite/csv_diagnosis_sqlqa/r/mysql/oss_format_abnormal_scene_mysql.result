####压缩csv其他诊断场景####
drop table t1;
create table t1(id smallint ,
                name int ,
                mon tinyint ,
                age decimal ,
                tel_number bigint,
                id2 tinytext ,
                name2 varchar(10) ,
                mon2 text(10) ,
                age2 bigint UNSIGNED ,
                tel_number2 varbinary(50) );

load data   from (select c2,c2,c2,c2,c2,c2,c2,c2,c2,c2 from files
(location = '#OSS_HOST#:#OSS_ACCESS_ID#@#OSS_ACCESS_KEY#/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/external_table_compression/',
FORMAT (
    type = 'csv'
    ENCODING = 'UTF8MB4'
    SKIP_HEADER = 1
	LINE_DELIMITER = '\n'
	EMPTY_FIELD_AS_NULL = true
	compression = auto
),
PATTERN = 'test_ex_compression.csv.*'
))  into table t1  log errors reject limit unlimited;
show warnings;
Level	Code	Message
