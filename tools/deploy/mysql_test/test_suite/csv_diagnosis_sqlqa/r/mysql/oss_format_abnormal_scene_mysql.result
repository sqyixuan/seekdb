####fromat异常####(format只是相对异常，根据format出现的异常数据走诊断)
####type
drop table t1;
create table t1(
id CHAR (10),
name CHAR (10),
mon CHAR (10),
age CHAR (10),
tel_number varCHAR (50) );
load data   from files
(location = '#OSS_HOST#:#OSS_ACCESS_ID#@#OSS_ACCESS_KEY#/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/',
FORMAT (
    type = ''
),
PATTERN = '.*\.csv'
)  into table t1 log errors reject limit unlimited ;
ERROR 0A000: format '' not supported
show warnings;
Level	Code	Message
Error	1235	format '' not supported
select * from t1;
+------+------+------+------+------------+
| id   | name | mon  | age  | tel_number |
+------+------+------+------+------------+
+------+------+------+------+------------+

