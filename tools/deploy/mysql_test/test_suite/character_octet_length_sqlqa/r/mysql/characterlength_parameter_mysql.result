##比较函数##
SELECT
CHARACTER_LENGTH(GREATEST('a', NULL, 'c')),
CHARACTER_LENGTH(INTERVAL(23, 1, 15, 17, NULL, 44, 200)),
CHARACTER_LENGTH(ISNULL('test')),
CHARACTER_LENGTH(LEAST('aB','bCD','cDEF'));
+--------------------------------------------+----------------------------------------------------------+----------------------------------+--------------------------------------------+
| CHARACTER_LENGTH(GREATEST('a', NULL, 'c')) | CHARACTER_LENGTH(INTERVAL(23, 1, 15, 17, NULL, 44, 200)) | CHARACTER_LENGTH(ISNULL('test')) | CHARACTER_LENGTH(LEAST('aB','bCD','cDEF')) |
+--------------------------------------------+----------------------------------------------------------+----------------------------------+--------------------------------------------+
|                                       NULL |                                                        1 |                                1 |                                          2 |
+--------------------------------------------+----------------------------------------------------------+----------------------------------+--------------------------------------------+
##流程控制函数##
SELECT
CHARACTER_LENGTH(IF(0, 'TRUE', 'FALSE')),
CHARACTER_LENGTH(IFNULL(NULL+1, NULL+2)),
CHARACTER_LENGTH(NULLIF(NULL, 'abc'));
+------------------------------------------+------------------------------------------+---------------------------------------+
| CHARACTER_LENGTH(IF(0, 'TRUE', 'FALSE')) | CHARACTER_LENGTH(IFNULL(NULL+1, NULL+2)) | CHARACTER_LENGTH(NULLIF(NULL, 'abc')) |
+------------------------------------------+------------------------------------------+---------------------------------------+
|                                        5 |                                     NULL |                                  NULL |
+------------------------------------------+------------------------------------------+---------------------------------------+
