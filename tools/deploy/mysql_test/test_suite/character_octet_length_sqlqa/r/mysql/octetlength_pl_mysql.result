result_format: 4
SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';
SET SESSION sql_mode ='STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
####################OCTER_LENGTH()####################
drop table OCTET_LENGTH_table;
create table OCTET_LENGTH_table(id int, sal double, name varchar(40),date_time datetime);
insert into OCTET_LENGTH_table values(10,3000.265 ,'kebi','2020-05-01 12:01:35'),(15,2100.25,'maidd','2020-05-17 18:02:30'),(29,1500.69,'yaoming','2020-05-23 23:59:59');
drop procedure myOCTET_LENGTH;
create procedure myOCTET_LENGTH()
begin
	declare i int;
	declare a int;
	select OCTET_LENGTH(e.sal) into a from OCTET_LENGTH_table e where e.name = 'kebi';
	set i = 0;
	loop_label:loop
	insert into OCTET_LENGTH_table values(10,a,'kuli','2020-05-01 12:01:35');
	set i = i + 1;
	if i >= 10 then leave loop_label;
end if;
end loop;
end;//
select count(*) from OCTET_LENGTH_table;//
+----------+
| count(*) |
+----------+
|        3 |
+----------+
call myOCTET_LENGTH();//
select count(*) from OCTET_LENGTH_table;//
+----------+
| count(*) |
+----------+
|       13 |
+----------+
drop procedure myOCTET_LENGTH;//
create procedure myOCTET_LENGTH(in OCTET_LENGTHname varchar(10) )
begin
	declare i int;
	declare a int;
	select OCTET_LENGTH(e.sal) into a from OCTET_LENGTH_table e where e.name = OCTET_LENGTHname;
	set i := 1;
	repeat
	insert into OCTET_LENGTH_table values(10,2600.66,a,'2020-05-01 12:01:35');
	set i := i + 1;
	until i >= 10 end repeat;
end;//
select count(*) from OCTET_LENGTH_table;//
+----------+
| count(*) |
+----------+
|       13 |
+----------+
call myOCTET_LENGTH('kebi');//
select count(*) from OCTET_LENGTH_table;//
+----------+
| count(*) |
+----------+
|       22 |
+----------+
drop procedure myOCTET_LENGTH;//
create procedure myOCTET_LENGTH(out OCTET_LENGTHsal int )
begin
	declare i int;
	select OCTET_LENGTH(e.sal) into OCTET_LENGTHsal from OCTET_LENGTH_table e where e.name = 'maidd';
	set i := 1;
	while i <= 10 do
	insert into OCTET_LENGTH_table values(10,OCTET_LENGTHsal,'dulante','2020-05-01 12:01:35');
	set i := i + 1;
	end while;
end;//
select count(*) from OCTET_LENGTH_table;//
+----------+
| count(*) |
+----------+
|       22 |
+----------+
call myOCTET_LENGTH(@OCTET_LENGTHsal);//
select count(*) from OCTET_LENGTH_table;//
+----------+
| count(*) |
+----------+
|       32 |
+----------+
drop procedure myOCTET_LENGTH;//
create procedure myOCTET_LENGTH(out OCTET_LENGTHsal int, in OCTET_LENGTHname varchar(10),inout p3 int )
begin
	declare i int;
	select OCTET_LENGTH(e.sal) into OCTET_LENGTHsal from OCTET_LENGTH_table e where e.name = 'maidd';
	select OCTET_LENGTH(e.sal) into p3 from OCTET_LENGTH_table e where e.name = OCTET_LENGTHname;
	set i := 1;
	while i <= 10 do
	insert into OCTET_LENGTH_table values(10,OCTET_LENGTHsal,OCTET_LENGTHname,'2020-05-01 12:01:35');
	insert into OCTET_LENGTH_table values(10,p3,OCTET_LENGTHname,'2020-05-01 12:01:35');
	set i := i + 1;
	end while;
end;//
select count(*) from OCTET_LENGTH_table;//
+----------+
| count(*) |
+----------+
|       32 |
+----------+
call myOCTET_LENGTH(@OCTET_LENGTHsal,'yaoming',@p3);//
select count(*) from OCTET_LENGTH_table;//
+----------+
| count(*) |
+----------+
|       52 |
+----------+
drop function myOCTET_LENGTH;//
create function myOCTET_LENGTH()
returns int
begin
	declare a int;
	select OCTET_LENGTH(e.sal) from OCTET_LENGTH_table e where e.id = 15 into a;
	return a;
end;//
select myOCTET_LENGTH();//
+------------------+
| myOCTET_LENGTH() |
+------------------+
|                7 |
+------------------+
drop function myOCTET_LENGTH;//
create function myOCTET_LENGTH(OCTET_LENGTHname  varchar(20))
returns int
begin
	declare a int;
	select OCTET_LENGTH(e.sal) into a from OCTET_LENGTH_table e where e.name = OCTET_LENGTHname;
	return a;
end;//
select myOCTET_LENGTH('kebi');//
+------------------------+
| myOCTET_LENGTH('kebi') |
+------------------------+
|                      8 |
+------------------------+
drop function myOCTET_LENGTH;//
create function myOCTET_LENGTH(OCTET_LENGTHname varchar(10))
returns int
begin
	declare a int;
	declare i int DEFAULT 0;
	select OCTET_LENGTH(e.sal) into a from OCTET_LENGTH_table e where e.name = OCTET_LENGTHname;
	while i <= 10 do
	insert into OCTET_LENGTH_table values(10,a,'kuli','2020-05-01 12:01:35');
	set i := i + 1 ;
	end while;
	return a;
end;//
select myOCTET_LENGTH('kebi');//
+------------------------+
| myOCTET_LENGTH('kebi') |
+------------------------+
|                      8 |
+------------------------+
drop procedure myOCTET_LENGTH;
drop function myOCTET_LENGTH;
drop table OCTET_LENGTH_table;
