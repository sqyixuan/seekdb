##比较函数##
SELECT
OCTET_LENGTH(GREATEST('a', NULL, 'c')),
OCTET_LENGTH(INTERVAL(23, 1, 15, 17, NULL, 44, 200)),
OCTET_LENGTH(ISNULL('test')),
OCTET_LENGTH(LEAST('aB','bCD','cDEF'));
+----------------------------------------+------------------------------------------------------+------------------------------+----------------------------------------+
| OCTET_LENGTH(GREATEST('a', NULL, 'c')) | OCTET_LENGTH(INTERVAL(23, 1, 15, 17, NULL, 44, 200)) | OCTET_LENGTH(ISNULL('test')) | OCTET_LENGTH(LEAST('aB','bCD','cDEF')) |
+----------------------------------------+------------------------------------------------------+------------------------------+----------------------------------------+
|                                   NULL |                                                    1 |                            1 |                                      2 |
+----------------------------------------+------------------------------------------------------+------------------------------+----------------------------------------+
##流程控制函数##
SELECT
OCTET_LENGTH(IF(0, 'TRUE', 'FALSE')),
OCTET_LENGTH(IFNULL(NULL+1, NULL+2)),
OCTET_LENGTH(NULLIF(NULL, 'abc'));
+--------------------------------------+--------------------------------------+-----------------------------------+
| OCTET_LENGTH(IF(0, 'TRUE', 'FALSE')) | OCTET_LENGTH(IFNULL(NULL+1, NULL+2)) | OCTET_LENGTH(NULLIF(NULL, 'abc')) |
+--------------------------------------+--------------------------------------+-----------------------------------+
|                                    5 |                                 NULL |                              NULL |
+--------------------------------------+--------------------------------------+-----------------------------------+
