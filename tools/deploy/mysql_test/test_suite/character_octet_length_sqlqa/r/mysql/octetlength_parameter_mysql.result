####变量####
SET @A = '';
SET @B = 'ABc';
SET @C = '测试';
SET @D = 1;
SET @E = NULL;
SET @F = '!';
SET @G = "";
SET @H = 1.2;
SET @I = -1;
SET @J = 0;
SET @K = 1E-10;
