result_format: 4
SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';
SET SESSION sql_mode ='STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
####################OCTER_LENGTH()####################
####parameter####
SELECT OCTET_LENGTH(1);
+-----------------+
| OCTET_LENGTH(1) |
+-----------------+
|               1 |
+-----------------+
SELECT OCTET_LENGTH('abC');
+---------------------+
| OCTET_LENGTH('abC') |
+---------------------+
|                   3 |
+---------------------+
SELECT OCTET_LENGTH(NULL);
+--------------------+
| OCTET_LENGTH(NULL) |
+--------------------+
|               NULL |
+--------------------+
SELECT OCTET_LENGTH('');
+------------------+
| OCTET_LENGTH('') |
+------------------+
|                0 |
+------------------+
SELECT OCTET_LENGTH('!@$%^&*');
+-------------------------+
| OCTET_LENGTH('!@$%^&*') |
+-------------------------+
|                       7 |
+-------------------------+
SELECT OCTET_LENGTH("");
+------------------+
| OCTET_LENGTH("") |
+------------------+
|                0 |
+------------------+
SELECT OCTET_LENGTH(1.2);
+-------------------+
| OCTET_LENGTH(1.2) |
+-------------------+
|                 3 |
+-------------------+
SELECT OCTET_LENGTH(-1);
+------------------+
| OCTET_LENGTH(-1) |
+------------------+
|                2 |
+------------------+
SELECT OCTET_LENGTH(' ');
+-------------------+
| OCTET_LENGTH(' ') |
+-------------------+
|                 1 |
+-------------------+
SELECT OCTET_LENGTH(0);
+-----------------+
| OCTET_LENGTH(0) |
+-----------------+
|               1 |
+-----------------+
SELECT OCTET_LENGTH(1e-10);
+---------------------+
| OCTET_LENGTH(1e-10) |
+---------------------+
|                  12 |
+---------------------+
SELECT OCTET_LENGTH('1999-5-11 11:11:11');
+------------------------------------+
| OCTET_LENGTH('1999-5-11 11:11:11') |
+------------------------------------+
|                                 18 |
+------------------------------------+
SELECT OCTET_LENGTH(1,1);
ERROR 42000: Incorrect parameter count in the call to native function 'OCTET_LENGTH'
SELECT OCTET_LENGTH();
ERROR 42000: Incorrect parameter count in the call to native function 'OCTET_LENGTH'
SELECT OCTET_LENGTH('电话') FROM dual;
+------------------------+
| OCTET_LENGTH('电话')   |
+------------------------+
|                      6 |
+------------------------+
SELECT OCTET_LENGTH('abc') FROM dual;
+---------------------+
| OCTET_LENGTH('abc') |
+---------------------+
|                   3 |
+---------------------+
SELECT OCTET_LENGTH('ABC') FROM dual;
+---------------------+
| OCTET_LENGTH('ABC') |
+---------------------+
|                   3 |
+---------------------+
SELECT OCTET_LENGTH('123') FROM dual;
+---------------------+
| OCTET_LENGTH('123') |
+---------------------+
|                   3 |
+---------------------+
SELECT OCTET_LENGTH(123) FROM dual;
+-------------------+
| OCTET_LENGTH(123) |
+-------------------+
|                 3 |
+-------------------+
SELECT OCTET_LENGTH(-123) FROM dual;
+--------------------+
| OCTET_LENGTH(-123) |
+--------------------+
|                  4 |
+--------------------+
SELECT OCTET_LENGTH('!@#$%^') FROM dual;
+------------------------+
| OCTET_LENGTH('!@#$%^') |
+------------------------+
|                      6 |
+------------------------+
SELECT OCTET_LENGTH('') FROM dual;
+------------------+
| OCTET_LENGTH('') |
+------------------+
|                0 |
+------------------+
SELECT OCTET_LENGTH(null) FROM dual;
+--------------------+
| OCTET_LENGTH(null) |
+--------------------+
|               NULL |
+--------------------+
SELECT OCTET_LENGTH(1+9) FROM dual;
+-------------------+
| OCTET_LENGTH(1+9) |
+-------------------+
|                 2 |
+-------------------+
SELECT OCTET_LENGTH(11-6) FROM dual;
+--------------------+
| OCTET_LENGTH(11-6) |
+--------------------+
|                  1 |
+--------------------+
SELECT OCTET_LENGTH(4*5) FROM dual;
+-------------------+
| OCTET_LENGTH(4*5) |
+-------------------+
|                 2 |
+-------------------+
SELECT OCTET_LENGTH(20/4) FROM dual;
+--------------------+
| OCTET_LENGTH(20/4) |
+--------------------+
|                  6 |
+--------------------+
SELECT OCTET_LENGTH(abs(-10)) FROM dual;
+------------------------+
| OCTET_LENGTH(abs(-10)) |
+------------------------+
|                      2 |
+------------------------+
SELECT OCTET_LENGTH(4||5) FROM dual;
+--------------------+
| OCTET_LENGTH(4||5) |
+--------------------+
|                  1 |
+--------------------+
SELECT OCTET_LENGTH('2020-10-10 10:10:10') FROM dual;
+-------------------------------------+
| OCTET_LENGTH('2020-10-10 10:10:10') |
+-------------------------------------+
|                                  19 |
+-------------------------------------+
SELECT OCTET_LENGTH(OCTET_LENGTH('2020-10-10 10:10:10')) FROM dual;
+---------------------------------------------------+
| OCTET_LENGTH(OCTET_LENGTH('2020-10-10 10:10:10')) |
+---------------------------------------------------+
|                                                 2 |
+---------------------------------------------------+
