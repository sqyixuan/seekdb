--result_format 4



SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';
#show variables like "%char%";
####################CHARACTER_LENGTH()####################
--error  0,1051
drop table CHARACTER_LENGTH_table2;
--error 0,1051
drop table CHARACTER_LENGTH_table;
--error 0,1051
drop view CHARACTER_LENGTH_view;
create table CHARACTER_LENGTH_table(id int, order_id double, name varchar(40),date_time datetime);
insert into CHARACTER_LENGTH_table values(10,15.59,'kebi','2020-05-01 12:01:35'),(15,14.29,'maidi','2020-05-17 18:02:30'),(29,12.32,'yaoming','2020-05-23 23:59:59');

create table CHARACTER_LENGTH_table2(id int, sal double, order_number varchar(40),date_time datetime);
insert into CHARACTER_LENGTH_table2 values(10,3000.265 ,'10','2020-05-01 12:01:35'),(15,2100.25,'15.29','2020-05-17 18:02:30'),(29,1500.69,'12.32','2020-05-23 23:59:59');

#select
select CHARACTER_LENGTH(e.order_id) a,CHARACTER_LENGTH(e.name) b from CHARACTER_LENGTH_table e;
select p.a,p.b from (select CHARACTER_LENGTH(e.order_id) a,CHARACTER_LENGTH(e.name) b from CHARACTER_LENGTH_table e ) p ;
select e.id,e.name,CHARACTER_LENGTH(p.sal),p.date_time from CHARACTER_LENGTH_table e left join CHARACTER_LENGTH_table2 p on CHARACTER_LENGTH(p.order_number) = e.id order by 1 desc;
select e.id,e.name,CHARACTER_LENGTH(p.sal),p.date_time from CHARACTER_LENGTH_table e right join CHARACTER_LENGTH_table2 p on CHARACTER_LENGTH(p.order_number) = e.id order by 1 desc;
select e.id,e.name,CHARACTER_LENGTH(p.sal),p.date_time from CHARACTER_LENGTH_table e inner join CHARACTER_LENGTH_table2 p on CHARACTER_LENGTH(p.order_number) = e.id order by 1 desc;



#别名
select CHARACTER_LENGTH(e.order_id) a,CHARACTER_LENGTH(e.name) 姓名 from CHARACTER_LENGTH_table e;
select CHARACTER_LENGTH(e.name collate utf8mb4_general_ci) as 姓名 from CHARACTER_LENGTH_table e;
select CHARACTER_LENGTH(e.name collate utf8mb4_general_ci) 姓名 from CHARACTER_LENGTH_table e;


#exists
select e.id,e.name from CHARACTER_LENGTH_table e where exists(select * from CHARACTER_LENGTH_table2 p where CHARACTER_LENGTH(p.order_number) = e.id ) order by 1 desc;
select e.id,e.name from CHARACTER_LENGTH_table e where not exists(select * from CHARACTER_LENGTH_table2 p where CHARACTER_LENGTH(p.order_number) = e.id ) order by 1 desc;
select e.id,e.name from CHARACTER_LENGTH_table e where exists(select * from CHARACTER_LENGTH_table2 p where p.order_number = CHARACTER_LENGTH(e.id)) order by 1 desc;
select e.id,e.name from CHARACTER_LENGTH_table e where not exists(select * from CHARACTER_LENGTH_table2 p where p.order_number = CHARACTER_LENGTH(e.id))order by 1 desc;


#any
select e.id,e.name from CHARACTER_LENGTH_table e where e.id > any(select avg(CHARACTER_LENGTH(p.order_number)) from CHARACTER_LENGTH_table2 p);
select e.id,e.name from CHARACTER_LENGTH_table e where e.id < any(select avg(CHARACTER_LENGTH(p.order_number)) from CHARACTER_LENGTH_table2 p );
select e.id,e.name from CHARACTER_LENGTH_table e where e.id = any(select CHARACTER_LENGTH(p.order_number) from CHARACTER_LENGTH_table2 p );


#all
select e.id,e.name from CHARACTER_LENGTH_table e where e.id > all(select CHARACTER_LENGTH(p.order_number) from CHARACTER_LENGTH_table2 p where p.id = 29);
select e.id,e.name from CHARACTER_LENGTH_table e where e.id < all(select CHARACTER_LENGTH(p.order_number) from CHARACTER_LENGTH_table2 p where p.id = 29);
select e.id,e.name from CHARACTER_LENGTH_table e where e.id = all(select CHARACTER_LENGTH(p.order_number) from CHARACTER_LENGTH_table2 p where p.id = 10);

#like
select *  from CHARACTER_LENGTH_table a  where CHARACTER_LENGTH(a.order_id) like '%5%';
select CHARACTER_LENGTH(a.name)  from CHARACTER_LENGTH_table a where name like '%k%';


#别名
select CHARACTER_LENGTH(e.sal) aab from CHARACTER_LENGTH_table2 e;
select CHARACTER_LENGTH(e.sal) aab工资 from CHARACTER_LENGTH_table2 e;


#where
select e.id,e.sal from CHARACTER_LENGTH_table2 e where CHARACTER_LENGTH(e.sal) > 2000 order by e.id;
select e.id,e.sal from CHARACTER_LENGTH_table2 e where CHARACTER_LENGTH(e.sal) > 2000  and CHARACTER_LENGTH(e.sal) < 3000 order by e.id;
select e.id,e.sal from CHARACTER_LENGTH_table2 e where CHARACTER_LENGTH(e.sal) > 2000  or CHARACTER_LENGTH(e.order_number) > 15 order by e.id;
select CHARACTER_LENGTH(e.sal) from CHARACTER_LENGTH_table2 e where e.id>20 order by e.id desc;


#order by
select e.id,e.name,p.sal from CHARACTER_LENGTH_table e left join CHARACTER_LENGTH_table2 p on e.id = p.id where CHARACTER_LENGTH(p.sal) > 2000 order by CHARACTER_LENGTH(p.sal) limit 2;
select e.id,e.name,p.sal from CHARACTER_LENGTH_table e left join CHARACTER_LENGTH_table2 p on e.id = p.id where CHARACTER_LENGTH(p.sal) > 2000 order by CHARACTER_LENGTH(p.sal) desc limit 2;


#group by having
select e.id,sum(e.sal) from CHARACTER_LENGTH_table2 e where e.sal > 2000 group by 1 order by 1 desc;
select e.id,sum(e.sal) from CHARACTER_LENGTH_table2 e where e.sal > 1000 group by 1 having sum(CHARACTER_LENGTH(e.sal)) > 2000 order by 1 desc;



#cast when
select e.id 编号,case when CHARACTER_LENGTH(e.sal) < 2000 then '低' when CHARACTER_LENGTH(e.sal) < 3000 then '一般' else '高' end '工资' from CHARACTER_LENGTH_table2 e ;
select e.id 编号,case CHARACTER_LENGTH(e.sal)  when  1501 then '低' when 2100 then '一般' else '高' end '工资' from CHARACTER_LENGTH_table2 e;


#insert into as
insert into CHARACTER_LENGTH_table select *  from CHARACTER_LENGTH_table2 p where CHARACTER_LENGTH(p.sal)  = 8;
select *  from CHARACTER_LENGTH_table;
--error 0,1292
insert into CHARACTER_LENGTH_table select *  from CHARACTER_LENGTH_table2 p where CHARACTER_LENGTH(p.order_number)  = 2;


#update as
select *  from CHARACTER_LENGTH_table;
update CHARACTER_LENGTH_table set name = 'zanms' where CHARACTER_LENGTH(order_id) = 5;
select *  from CHARACTER_LENGTH_table where name = 'zanms';



#delete
delete from CHARACTER_LENGTH_table2 where CHARACTER_LENGTH(sal) = 4 ;
select CHARACTER_LENGTH(sal) from CHARACTER_LENGTH_table2;


#视图
create view CHARACTER_LENGTH_view as select e.id,e.name,p.sal,p.date_time from CHARACTER_LENGTH_table e left join CHARACTER_LENGTH_table2 p on e.id = p.id order by e.id desc;
select *  from CHARACTER_LENGTH_view;



#select
select CHARACTER_LENGTH(e.sal) a,CHARACTER_LENGTH(e.name) b from CHARACTER_LENGTH_view e;
select p.a,p.b from (select CHARACTER_LENGTH(e.sal) a,CHARACTER_LENGTH(e.name) b from CHARACTER_LENGTH_view e ) p ;
select e.id,e.name,CHARACTER_LENGTH(p.sal),p.date_time from CHARACTER_LENGTH_view e left join CHARACTER_LENGTH_table2 p on CHARACTER_LENGTH(p.order_number) = e.id order by 1 desc;
select e.id,e.name,CHARACTER_LENGTH(p.sal),p.date_time from CHARACTER_LENGTH_view e right join CHARACTER_LENGTH_table2 p on CHARACTER_LENGTH(p.order_number) = e.id order by p.id desc;
select e.id,e.name,CHARACTER_LENGTH(p.sal),p.date_time from CHARACTER_LENGTH_view e inner join CHARACTER_LENGTH_table2 p on CHARACTER_LENGTH(p.order_number) = e.id order by 1 desc;


#别名
select CHARACTER_LENGTH(e.name) a,CHARACTER_LENGTH(e.sal) 姓名 from CHARACTER_LENGTH_view e;
select CHARACTER_LENGTH(e.date_time) as 时间 from CHARACTER_LENGTH_view e;
select CHARACTER_LENGTH(e.date_time) 时间 from CHARACTER_LENGTH_view e;


# exists
select e.id,e.name from CHARACTER_LENGTH_table e where exists(select * from CHARACTER_LENGTH_view p where CHARACTER_LENGTH(p.id) = e.id ) order by 1 desc;
select e.id,e.name from CHARACTER_LENGTH_table e where not exists(select * from CHARACTER_LENGTH_view p where CHARACTER_LENGTH(p.id) = e.order_id ) order by 1 desc;
select e.id,e.name from CHARACTER_LENGTH_table e where exists(select * from CHARACTER_LENGTH_view p where p.id = CHARACTER_LENGTH(e.id)) order by 1 desc;
select e.id,e.name from CHARACTER_LENGTH_table e where not exists(select * from CHARACTER_LENGTH_view p where p.id = CHARACTER_LENGTH(e.order_id))order by 1 desc;



# any
select e.id,e.name from CHARACTER_LENGTH_table e where e.order_id > any(select CHARACTER_LENGTH(p.id) from CHARACTER_LENGTH_view p);
select e.id,e.name from CHARACTER_LENGTH_table e where e.order_id < any(select CHARACTER_LENGTH(p.id) from CHARACTER_LENGTH_view p);
select e.id,e.name from CHARACTER_LENGTH_table e where e.id = any(select CHARACTER_LENGTH(p.id) from CHARACTER_LENGTH_view p);



# all
select e.id,e.order_number from CHARACTER_LENGTH_table2 e where e.sal > all(select CHARACTER_LENGTH(p.sal) from CHARACTER_LENGTH_view p where p.id = 29);
select e.id,e.order_number from CHARACTER_LENGTH_table2 e where e.sal < all(select CHARACTER_LENGTH(p.sal) from CHARACTER_LENGTH_view p where p.id = 29);
select e.id,e.order_number from CHARACTER_LENGTH_table2 e where CHARACTER_LENGTH(e.sal) = all(select CHARACTER_LENGTH(p.sal) from CHARACTER_LENGTH_view p where p.id = 10);



# like
select *  from CHARACTER_LENGTH_view a  where CHARACTER_LENGTH(a.name) like '%5%';
select CHARACTER_LENGTH(a.name)  from CHARACTER_LENGTH_view a where name like '%k%';



# 别名
select CHARACTER_LENGTH(e.sal) aab from CHARACTER_LENGTH_view e;
select CHARACTER_LENGTH(e.sal) aab工资 from CHARACTER_LENGTH_view e;


# where
select e.id,e.sal from CHARACTER_LENGTH_view e where CHARACTER_LENGTH(e.sal) > 2000 order by e.id;
select e.id,e.sal from CHARACTER_LENGTH_view e where CHARACTER_LENGTH(e.sal) > 2000  and CHARACTER_LENGTH(e.sal) < 3000 order by e.id;
select e.id,e.sal from CHARACTER_LENGTH_view e where CHARACTER_LENGTH(e.sal) > 2000  or CHARACTER_LENGTH(e.id) > 15 order by e.id;
select CHARACTER_LENGTH(e.sal) from CHARACTER_LENGTH_view e where e.id>20 order by e.id desc;


# order by
select e.id,e.name,p.sal from CHARACTER_LENGTH_table e left join CHARACTER_LENGTH_view p on e.id = p.id where CHARACTER_LENGTH(p.sal) > 2000 order by CHARACTER_LENGTH(p.sal) limit 2;
select e.id,e.name,p.sal from CHARACTER_LENGTH_table e left join CHARACTER_LENGTH_view p on e.id = p.id where CHARACTER_LENGTH(p.sal) > 2000 order by CHARACTER_LENGTH(p.sal)desc limit 2;


# group by having
select e.id,sum(e.sal) from CHARACTER_LENGTH_view e where e.sal > 2000 group by 1 order by 1 desc;
select e.id,sum(e.sal) from CHARACTER_LENGTH_view e where e.sal > 1000 group by 1 having sum(CHARACTER_LENGTH(e.sal)) > 2000 order by 1 desc;



# cast when
select e.id 编号,case when CHARACTER_LENGTH(e.sal) < 2000 then '低' when CHARACTER_LENGTH(e.sal) < 3000 then '一般' else '高' end '工资' from CHARACTER_LENGTH_view e ;
select e.id 编号,case CHARACTER_LENGTH(e.sal)  when  1501 then '低' when 2100 then '一般' else '高' end '工资' from CHARACTER_LENGTH_view e;


--disable_warnings
--error 0,1051
drop table CHARACTER_LENGTH_table;
--error 0,1051
drop table CHARACTER_LENGTH_table2;
--error 0,1051
drop view CHARACTER_LENGTH_view;
--enable_warnings





