--result_format 4


--disable_warnings
SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';
SET SESSION sql_mode ='STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
#show variables like "%char%";
--enable_warnings

####################OCTER_LENGTH()####################

--error 0,1051
drop table OCTET_LENGTH_table;

create table OCTET_LENGTH_table(id int, sal double, name varchar(40),date_time datetime);
insert into OCTET_LENGTH_table values(10,3000.265 ,'kebi','2020-05-01 12:01:35'),(15,2100.25,'maidd','2020-05-17 18:02:30'),(29,1500.69,'yaoming','2020-05-23 23:59:59');

#函数嵌套
select e.id,e.name,OCTET_LENGTH(OCTET_LENGTH(e.sal)) from OCTET_LENGTH_table e order by e.id desc;

select e.id,e.name,OCTET_LENGTH(sum(e.sal)) from OCTET_LENGTH_table e order by e.id desc;
select e.id,e.name,sum(OCTET_LENGTH(e.sal)) from OCTET_LENGTH_table e group by 1,2 having sum(OCTET_LENGTH(e.sal)) >= 4 order by id desc;

select e.id,e.name,OCTET_LENGTH(max(e.sal)) from OCTET_LENGTH_table e order by e.id desc;
select e.id,e.name,max(OCTET_LENGTH(e.sal)) from OCTET_LENGTH_table e group by 1,2 having sum(OCTET_LENGTH(e.sal)) > 4 order by id desc;


select e.id,e.name,OCTET_LENGTH(min(e.sal)) from OCTET_LENGTH_table e order by e.id desc;
select e.id,e.name,min(OCTET_LENGTH(e.sal)) from OCTET_LENGTH_table e group by 1,2 having sum(OCTET_LENGTH(e.sal)) > 4 order by id desc;

select e.id,e.name,OCTET_LENGTH(avg(e.sal)) from OCTET_LENGTH_table e order by e.id desc;
select e.id,e.name,avg(OCTET_LENGTH(e.sal)) from OCTET_LENGTH_table e group by 1,2 having avg(OCTET_LENGTH(e.sal)) > 4 order by id desc;


select e.id,e.name,OCTET_LENGTH(abs(e.sal)) from OCTET_LENGTH_table e order by e.id desc;
select e.id,e.name,abs(OCTET_LENGTH(e.sal)) from OCTET_LENGTH_table e group by 1,2  order by id desc limit 2;

select e.id,e.name,OCTET_LENGTH(ceil(e.sal)) from OCTET_LENGTH_table e order by e.id desc;
select e.id,e.name,ceil(OCTET_LENGTH(e.sal)) from OCTET_LENGTH_table e group by 1,2  order by id desc limit 2;


select e.id,e.name,OCTET_LENGTH(floor(e.sal)) from OCTET_LENGTH_table e order by e.id desc;
select e.id,e.name,floor(OCTET_LENGTH(e.sal)) from OCTET_LENGTH_table e group by 1,2  order by id desc limit 2;


select e.id,e.name,OCTET_LENGTH(mod(e.sal,7.8)) from OCTET_LENGTH_table e order by e.id desc;
select e.id,e.name,mod(OCTET_LENGTH(e.sal),7.8) from OCTET_LENGTH_table e group by 1,2  order by id desc;


select e.id,e.name,OCTET_LENGTH(OCTET_LENGTH(e.sal)) from OCTET_LENGTH_table e order by e.id desc;
select e.id,e.name,OCTET_LENGTH(OCTET_LENGTH(e.sal)) from OCTET_LENGTH_table e group by 1,2  order by id desc;

select e.id,instr(OCTET_LENGTH(e.name),'i'),e.sal from OCTET_LENGTH_table e order by id desc;
select e.id,OCTET_LENGTH(instr(e.name,'i')),e.sal from OCTET_LENGTH_table e order by id desc;




#算数运算符
select e.id,e.name,OCTET_LENGTH(e.sal)+100 from OCTET_LENGTH_table e ;
select e.id,e.name,OCTET_LENGTH(e.sal)-100 from OCTET_LENGTH_table e ;
select e.id,e.name,OCTET_LENGTH(e.sal)*100 from OCTET_LENGTH_table e ;
select e.id,e.name,OCTET_LENGTH(e.sal)/100 from OCTET_LENGTH_table e ;


#逻辑运算符
select e.id,e.name,e.sal from OCTET_LENGTH_table e where OCTET_LENGTH(e.sal) > 1500 and OCTET_LENGTH(e.sal) < 3000;
select e.id,e.name,e.sal from OCTET_LENGTH_table e where OCTET_LENGTH(e.sal) > 2000 or e.id >20;
select e.id,e.name,e.sal from OCTET_LENGTH_table e where not(OCTET_LENGTH(e.sal)) < 1500;
select e.id,e.name,e.sal from OCTET_LENGTH_table e where not(OCTET_LENGTH(e.sal)) > 2000;


#比较运算符
select e.id,e.name,e.sal from OCTET_LENGTH_table e where OCTET_LENGTH(e.sal) >= 2000;
select e.id,e.name,e.sal from OCTET_LENGTH_table e where OCTET_LENGTH(e.sal) <= 2000;
select e.id,e.name,e.sal from OCTET_LENGTH_table e where OCTET_LENGTH(e.sal)  = 1501;
select e.id,e.name,e.sal from OCTET_LENGTH_table e where OCTET_LENGTH(e.sal)  > 1501;
select e.id,e.name,e.sal from OCTET_LENGTH_table e where OCTET_LENGTH(e.sal)  < 1502;
select e.id,e.name,e.sal from OCTET_LENGTH_table e where OCTET_LENGTH(e.sal) <> 1501;
select e.id,e.name,e.sal from OCTET_LENGTH_table e where OCTET_LENGTH(e.sal) != 1501;



#索引
create index OCTET_LENGTH_name on OCTET_LENGTH_table(id);

#select
select OCTET_LENGTH(e.id) from OCTET_LENGTH_table e;
select e.name,e.sal from OCTET_LENGTH_table e where OCTET_LENGTH(e.id) = '10';
select e.name,e.sal from OCTET_LENGTH_table e where OCTET_LENGTH(e.id) > '10' order by e.sal desc;

#insert
insert into OCTET_LENGTH_table  select * from OCTET_LENGTH_table e where OCTET_LENGTH(e.id) = '10';
select * from OCTET_LENGTH_table;


#update
update OCTET_LENGTH_table e set name = 'zanms' where OCTET_LENGTH(e.id) = '10';
select * from OCTET_LENGTH_table;


#delete
delete from OCTET_LENGTH_table  where OCTET_LENGTH(id) = '10' ;
select * from OCTET_LENGTH_table;




#约束
--error 0,1051
drop table OCTET_LENGTH_table;
create table OCTET_LENGTH_table(id int primary key, sal double unique, name varchar(40) not null,date_time datetime);
insert into OCTET_LENGTH_table values(10,3000.265 ,'kebi','2020-05-01 12:01:35'),(15,2100.25,'maidd','2020-05-17 18:02:30'),(29,1500.69,'yaoming','2020-05-23 23:59:59');

#select
select OCTET_LENGTH(id),OCTET_LENGTH(sal),OCTET_LENGTH(name) from OCTET_LENGTH_table;
select OCTET_LENGTH(id),OCTET_LENGTH(sal),OCTET_LENGTH(name) from OCTET_LENGTH_table where OCTET_LENGTH(sal) = 6;
select OCTET_LENGTH(id),OCTET_LENGTH(sal),OCTET_LENGTH(name) from OCTET_LENGTH_table where OCTET_LENGTH(sal) = 8 order by id;


#insert
insert into OCTET_LENGTH_table  select OCTET_LENGTH(id+1)id,OCTET_LENGTH(e.sal),OCTET_LENGTH(e.name),e.date_time from OCTET_LENGTH_table e where OCTET_LENGTH(e.sal) = 8 ;
select count(*) from OCTET_LENGTH_table;


#update
update OCTET_LENGTH_table  set name = 'zanms' where OCTET_LENGTH(sal) = 8;
select * from OCTET_LENGTH_table;


##delete
delete from OCTET_LENGTH_table  where OCTET_LENGTH(sal) = 8 ;
select count(*) from OCTET_LENGTH_table;



--disable_warnings
--error 0,1051
drop table OCTET_LENGTH_table;
--enable_warnings



