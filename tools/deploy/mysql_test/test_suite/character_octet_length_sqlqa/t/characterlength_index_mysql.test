--result_format 4



SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';
SET SESSION sql_mode ='STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
#show variables like "%char%";

####################CHARACTER_LENGTH()####################

--error 0,1051
drop table CHARACTER_LENGTH_table;

create table CHARACTER_LENGTH_table(id int, sal double, name varchar(40),date_time datetime);
insert into CHARACTER_LENGTH_table values(10,3000.265 ,'kebi','2020-05-01 12:01:35'),(15,2100.25,'maidd','2020-05-17 18:02:30'),(29,1500.69,'yaoming','2020-05-23 23:59:59');

#函数嵌套
select e.id,e.name,CHARACTER_LENGTH(CHARACTER_LENGTH(e.sal)) from CHARACTER_LENGTH_table e order by e.id desc;

select e.id,e.name,CHARACTER_LENGTH(sum(e.sal)) from CHARACTER_LENGTH_table e order by e.id desc;
select e.id,e.name,sum(CHARACTER_LENGTH(e.sal)) from CHARACTER_LENGTH_table e group by 1,2 having sum(CHARACTER_LENGTH(e.sal)) >= 4 order by id desc;

select e.id,e.name,CHARACTER_LENGTH(max(e.sal)) from CHARACTER_LENGTH_table e order by e.id desc;
select e.id,e.name,max(CHARACTER_LENGTH(e.sal)) from CHARACTER_LENGTH_table e group by 1,2 having sum(CHARACTER_LENGTH(e.sal)) > 4 order by id desc;


select e.id,e.name,CHARACTER_LENGTH(min(e.sal)) from CHARACTER_LENGTH_table e order by e.id desc;
select e.id,e.name,min(CHARACTER_LENGTH(e.sal)) from CHARACTER_LENGTH_table e group by 1,2 having sum(CHARACTER_LENGTH(e.sal)) > 4 order by id desc;

select e.id,e.name,CHARACTER_LENGTH(avg(e.sal)) from CHARACTER_LENGTH_table e order by e.id desc;
select e.id,e.name,avg(CHARACTER_LENGTH(e.sal)) from CHARACTER_LENGTH_table e group by 1,2 having avg(CHARACTER_LENGTH(e.sal)) > 4 order by id desc;


select e.id,e.name,CHARACTER_LENGTH(abs(e.sal)) from CHARACTER_LENGTH_table e order by e.id desc;
select e.id,e.name,abs(CHARACTER_LENGTH(e.sal)) from CHARACTER_LENGTH_table e group by 1,2  order by id desc limit 2;

select e.id,e.name,CHARACTER_LENGTH(ceil(e.sal)) from CHARACTER_LENGTH_table e order by e.id desc;
select e.id,e.name,ceil(CHARACTER_LENGTH(e.sal)) from CHARACTER_LENGTH_table e group by 1,2  order by id desc limit 2;


select e.id,e.name,CHARACTER_LENGTH(floor(e.sal)) from CHARACTER_LENGTH_table e order by e.id desc;
select e.id,e.name,floor(CHARACTER_LENGTH(e.sal)) from CHARACTER_LENGTH_table e group by 1,2  order by id desc limit 2;


select e.id,e.name,CHARACTER_LENGTH(mod(e.sal,7.8)) from CHARACTER_LENGTH_table e order by e.id desc;
select e.id,e.name,mod(CHARACTER_LENGTH(e.sal),7.8) from CHARACTER_LENGTH_table e group by 1,2  order by id desc;


select e.id,e.name,CHARACTER_LENGTH(CHARACTER_LENGTH(e.sal)) from CHARACTER_LENGTH_table e order by e.id desc;
select e.id,e.name,CHARACTER_LENGTH(CHARACTER_LENGTH(e.sal)) from CHARACTER_LENGTH_table e group by 1,2  order by id desc;

select e.id,instr(CHARACTER_LENGTH(e.name),'i'),e.sal from CHARACTER_LENGTH_table e order by id desc;
select e.id,CHARACTER_LENGTH(instr(e.name,'i')),e.sal from CHARACTER_LENGTH_table e order by id desc;




#算数运算符
select e.id,e.name,CHARACTER_LENGTH(e.sal)+100 from CHARACTER_LENGTH_table e ;
select e.id,e.name,CHARACTER_LENGTH(e.sal)-100 from CHARACTER_LENGTH_table e ;
select e.id,e.name,CHARACTER_LENGTH(e.sal)*100 from CHARACTER_LENGTH_table e ;
select e.id,e.name,CHARACTER_LENGTH(e.sal)/100 from CHARACTER_LENGTH_table e ;


#逻辑运算符
select e.id,e.name,e.sal from CHARACTER_LENGTH_table e where CHARACTER_LENGTH(e.sal) > 1500 and CHARACTER_LENGTH(e.sal) < 3000;
select e.id,e.name,e.sal from CHARACTER_LENGTH_table e where CHARACTER_LENGTH(e.sal) > 2000 or e.id >20;
select e.id,e.name,e.sal from CHARACTER_LENGTH_table e where not(CHARACTER_LENGTH(e.sal)) < 1500;
select e.id,e.name,e.sal from CHARACTER_LENGTH_table e where not(CHARACTER_LENGTH(e.sal)) > 2000;


#比较运算符
select e.id,e.name,e.sal from CHARACTER_LENGTH_table e where CHARACTER_LENGTH(e.sal) >= 2000;
select e.id,e.name,e.sal from CHARACTER_LENGTH_table e where CHARACTER_LENGTH(e.sal) <= 2000;
select e.id,e.name,e.sal from CHARACTER_LENGTH_table e where CHARACTER_LENGTH(e.sal)  = 1501;
select e.id,e.name,e.sal from CHARACTER_LENGTH_table e where CHARACTER_LENGTH(e.sal)  > 1501;
select e.id,e.name,e.sal from CHARACTER_LENGTH_table e where CHARACTER_LENGTH(e.sal)  < 1502;
select e.id,e.name,e.sal from CHARACTER_LENGTH_table e where CHARACTER_LENGTH(e.sal) <> 1501;
select e.id,e.name,e.sal from CHARACTER_LENGTH_table e where CHARACTER_LENGTH(e.sal) != 1501;



#索引
create index CHARACTER_LENGTH_name on CHARACTER_LENGTH_table(id);

#select
select CHARACTER_LENGTH(e.id) from CHARACTER_LENGTH_table e;
select e.name,e.sal from CHARACTER_LENGTH_table e where CHARACTER_LENGTH(e.id) = '10';
select e.name,e.sal from CHARACTER_LENGTH_table e where CHARACTER_LENGTH(e.id) > '10' order by e.sal desc;

#insert
insert into CHARACTER_LENGTH_table  select * from CHARACTER_LENGTH_table e where CHARACTER_LENGTH(e.id) = '10';
select * from CHARACTER_LENGTH_table;


#update
update CHARACTER_LENGTH_table e set name = 'zanms' where CHARACTER_LENGTH(e.id) = '10';
select * from CHARACTER_LENGTH_table;


#delete
delete from CHARACTER_LENGTH_table  where CHARACTER_LENGTH(id) = '10' ;
select * from CHARACTER_LENGTH_table;




#约束
--error 0,1051
drop table CHARACTER_LENGTH_table;
create table CHARACTER_LENGTH_table(id int primary key, sal double unique, name varchar(40) not null,date_time datetime);
insert into CHARACTER_LENGTH_table values(10,3000.265 ,'kebi','2020-05-01 12:01:35'),(15,2100.25,'maidd','2020-05-17 18:02:30'),(29,1500.69,'yaoming','2020-05-23 23:59:59');

#select
select CHARACTER_LENGTH(id),CHARACTER_LENGTH(sal),CHARACTER_LENGTH(name) from CHARACTER_LENGTH_table;
select CHARACTER_LENGTH(id),CHARACTER_LENGTH(sal),CHARACTER_LENGTH(name) from CHARACTER_LENGTH_table where CHARACTER_LENGTH(sal) = 6;
select CHARACTER_LENGTH(id),CHARACTER_LENGTH(sal),CHARACTER_LENGTH(name) from CHARACTER_LENGTH_table where CHARACTER_LENGTH(sal) = 8 order by id;


#insert
insert into CHARACTER_LENGTH_table  select CHARACTER_LENGTH(id+1)id,CHARACTER_LENGTH(e.sal),CHARACTER_LENGTH(e.name),e.date_time from CHARACTER_LENGTH_table e where CHARACTER_LENGTH(e.sal) = 8 ;
select count(*) from CHARACTER_LENGTH_table;


#update
update CHARACTER_LENGTH_table  set name = 'zanms' where CHARACTER_LENGTH(sal) = 8;
select * from CHARACTER_LENGTH_table;


##delete
delete from CHARACTER_LENGTH_table  where CHARACTER_LENGTH(sal) = 8 ;
select count(*) from CHARACTER_LENGTH_table;



--disable_warnings
--error 0,1051
drop table CHARACTER_LENGTH_table;
--enable_warnings






