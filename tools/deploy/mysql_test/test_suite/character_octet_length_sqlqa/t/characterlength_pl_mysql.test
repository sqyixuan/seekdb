--result_format 4



SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';
SET SESSION sql_mode ='STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
#show variables like "%char%";

####################CHARACTER_LENGTH()####################
--error 0,1051
drop table CHARACTER_LENGTH_table;

create table CHARACTER_LENGTH_table(id int, sal double, name varchar(40),date_time datetime);
insert into CHARACTER_LENGTH_table values(10,3000.265 ,'kebi','2020-05-01 12:01:35'),(15,2100.25,'maidd','2020-05-17 18:02:30'),(29,1500.69,'yaoming','2020-05-23 23:59:59');



#无参存储过程
--error 0,1305
drop procedure myCHARACTER_LENGTH;
DELIMITER //;
create procedure myCHARACTER_LENGTH()
begin
	declare i int;
	declare a int;
	select CHARACTER_LENGTH(e.sal) into a from CHARACTER_LENGTH_table e where e.name = 'kebi';
	set i = 0;
	loop_label:loop
	insert into CHARACTER_LENGTH_table values(10,a,'kuli','2020-05-01 12:01:35');
	set i = i + 1;
	if i >= 10 then leave loop_label;
end if;
end loop;
end;//
select count(*) from CHARACTER_LENGTH_table;//
call myCHARACTER_LENGTH();//
select count(*) from CHARACTER_LENGTH_table;//


#只有一个in参数的存储过程
--error 0,1305
drop procedure myCHARACTER_LENGTH;//
create procedure myCHARACTER_LENGTH(in CHARACTER_LENGTHname varchar(10) )
begin
	declare i int;
	declare a int;
	select CHARACTER_LENGTH(e.sal) into a from CHARACTER_LENGTH_table e where e.name = CHARACTER_LENGTHname;
	set i := 1;
	repeat
	insert into CHARACTER_LENGTH_table values(10,2600.66,a,'2020-05-01 12:01:35');
	set i := i + 1;
	until i >= 10 end repeat;
end;//
select count(*) from CHARACTER_LENGTH_table;//
call myCHARACTER_LENGTH('kebi');//
select count(*) from CHARACTER_LENGTH_table;//



#存储过程包含out
--error 0,1305
drop procedure myCHARACTER_LENGTH;//
create procedure myCHARACTER_LENGTH(out CHARACTER_LENGTHsal int )
begin
	declare i int;
	select CHARACTER_LENGTH(e.sal) into CHARACTER_LENGTHsal from CHARACTER_LENGTH_table e where e.name = 'maidd';
	set i := 1;
	while i <= 10 do
	insert into CHARACTER_LENGTH_table values(10,CHARACTER_LENGTHsal,'dulante','2020-05-01 12:01:35');
	set i := i + 1;
	end while;
end;//
select count(*) from CHARACTER_LENGTH_table;//
call myCHARACTER_LENGTH(@CHARACTER_LENGTHsal);//
select count(*) from CHARACTER_LENGTH_table;//



#存储过程包含inout
--error 0,1305
drop procedure myCHARACTER_LENGTH;//
create procedure myCHARACTER_LENGTH(out CHARACTER_LENGTHsal int, in CHARACTER_LENGTHname varchar(10),inout p3 int )
begin
	declare i int;
	select CHARACTER_LENGTH(e.sal) into CHARACTER_LENGTHsal from CHARACTER_LENGTH_table e where e.name = 'maidd';
	select CHARACTER_LENGTH(e.sal) into p3 from CHARACTER_LENGTH_table e where e.name = CHARACTER_LENGTHname;
	set i := 1;
	while i <= 10 do
	insert into CHARACTER_LENGTH_table values(10,CHARACTER_LENGTHsal,CHARACTER_LENGTHname,'2020-05-01 12:01:35');
	insert into CHARACTER_LENGTH_table values(10,p3,CHARACTER_LENGTHname,'2020-05-01 12:01:35');
	set i := i + 1;
	end while;
end;//

select count(*) from CHARACTER_LENGTH_table;//
call myCHARACTER_LENGTH(@CHARACTER_LENGTHsal,'yaoming',@p3);//
select count(*) from CHARACTER_LENGTH_table;//






#无参的自定义函数
--error 0,1305
drop function myCHARACTER_LENGTH;//
create function myCHARACTER_LENGTH()
returns int
begin
	declare a int;
	select CHARACTER_LENGTH(e.sal) from CHARACTER_LENGTH_table e where e.id = 15 into a;
	return a;
end;//
select myCHARACTER_LENGTH();//


#自定义函数有参数
--error 0,1305
drop function myCHARACTER_LENGTH;//
create function myCHARACTER_LENGTH(CHARACTER_LENGTHname  varchar(20))
returns int
begin
	declare a int;
	select CHARACTER_LENGTH(e.sal) into a from CHARACTER_LENGTH_table e where e.name = CHARACTER_LENGTHname;
	return a;
end;//
select myCHARACTER_LENGTH('kebi');//


#定义参数用循环
--error 0,1305
drop function myCHARACTER_LENGTH;//
create function myCHARACTER_LENGTH(CHARACTER_LENGTHname varchar(10))
returns int
begin
	declare a int;
	declare i int DEFAULT 0;
	select CHARACTER_LENGTH(e.sal) into a from CHARACTER_LENGTH_table e where e.name = CHARACTER_LENGTHname;
	while i <= 10 do
	insert into CHARACTER_LENGTH_table values(10,a,'kuli','2020-05-01 12:01:35');
	set i := i + 1 ;
	end while;
	return a;
end;//
select myCHARACTER_LENGTH('kebi');//


DELIMITER ;//


--disable_warnings
--error 0,1305
drop procedure myCHARACTER_LENGTH;
--error 0,1305
drop function myCHARACTER_LENGTH;
--error 0,1051
drop table CHARACTER_LENGTH_table;
--enable_warnings






