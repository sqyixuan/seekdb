--echo  #无条件连接
select /*+no_rewrite*/ * from t1,t2 where c1 > (select max(a1) from t2 where t1.c1 = t2.a1) order by c1 desc limit 1;
explain basic select /*+no_rewrite*/ * from t1,t2 where c1 > (select max(a1) from t2 where t1.c1 = t2.a1) order by c1 desc limit 1;
select /*+parallel(6) no_rewrite*/ * from t1,t2 where c1 > (select max(a1) from t2 where t1.c1 = t2.a1) order by c1 desc limit 1;
explain basic select /*+parallel(6) no_rewrite*/ * from t1,t2 where c1 > (select max(a1) from t2 where t1.c1 = t2.a1) order by c1 desc limit 1;

select /*+no_rewrite*/ * from t1 cross join t2 where c1 = any (select max(a1) from t2 where t1.c1 = t2.a1) order by c1 desc limit 1;
explain basic select /*+no_rewrite*/ * from t1 cross join t2 where c1 = any (select max(a1) from t2 where t1.c1 = t2.a1) order by c1 desc limit 1;

select /*+parallel(6) no_rewrite*/ * from t1 cross join t2 where c1 = any (select max(a1) from t2 where t1.c1 = t2.a1) order by c1 desc limit 1;
explain basic select /*+parallel(6) no_rewrite*/ * from t1 cross join t2 where c1 = any (select max(a1) from t2 where t1.c1 = t2.a1) order by c1 desc limit 1;

select /*+no_rewrite*/ * from t1 cross join t2 where c1 = all  (select max(a1) from t2 where t1.c1 = t2.a1) group by t1.c1 having max(t1.c1)<5 order by t1.c1 desc limit 1;
explain basic select /*+no_rewrite*/ * from t1 cross join t2 where c1 = all  (select max(a1) from t2 where t1.c1 = t2.a1) group by t1.c1 having max(t1.c1)<5 order by t1.c1 desc limit 1;

select /*+parallel(6) no_rewrite*/ * from t1 cross join t2 where c1 = all  (select max(a1) from t2 where t1.c1 = t2.a1) group by t1.c1 having max(t1.c1)<5 order by t1.c1 desc limit 1;
explain basic select /*+parallel(6) no_rewrite*/ * from t1 cross join t2 where c1 = all  (select max(a1) from t2 where t1.c1 = t2.a1) group by t1.c1 having max(t1.c1)<5 order by t1.c1 desc limit 1;

select /*+no_rewrite*/ * from t1 natural join t2 where c1 >= some (select max(a1) from t2 where t1.c1 = t2.a1) order by c1 desc limit 1 ;
explain basic select /*+no_rewrite*/ * from t1 natural join t2 where c1 >= some (select max(a1) from t2 where t1.c1 = t2.a1) order by c1 desc limit 1 ;

select /*+parallel(6) no_rewrite*/ * from t1 natural join t2 where c1 >= some (select max(a1) from t2 where t1.c1 = t2.a1) order by c1 desc limit 1 ;
explain basic select /*+parallel(6) no_rewrite*/ * from t1 natural join t2 where c1 >= some (select max(a1) from t2 where t1.c1 = t2.a1) order by c1 desc limit 1 ;

select /*+no_rewrite*/ * from t1 inner join t2 on t1.c1 = t2.a1 where exists (select max(a1) from t2 where t1.c1 = t2.a1) order by c1 desc ;
explain basic select /*+no_rewrite*/ * from t1 inner join t2 on t1.c1 = t2.a1 where exists (select max(a1) from t2 where t1.c1 = t2.a1) order by c1 desc ;

select /*+no_rewrite*/ * from t1 inner join t2 on t1.c1 = t2.a1 where exists  (select max(a1) from t2 where t1.c1 = t2.a1) group by t1.c1 having max(t1.c1) < 4 order by t1.c1 desc limit 2;
explain basic select /*+no_rewrite*/ * from t1 inner join t2 on t1.c1 = t2.a1 where exists  (select max(a1) from t2 where t1.c1 = t2.a1) group by t1.c1 having max(t1.c1) < 4 order by t1.c1 desc limit 2;

select /*+parallel(6) no_rewrite*/ * from t1 inner join t2 on t1.c1 = t2.a1 where exists  (select max(a1) from t2 where t1.c1 = t2.a1) group by t1.c1 having max(t1.c1) < 4 order by t1.c1 desc limit 2;
explain basic select /*+parallel(6) no_rewrite*/ * from t1 inner join t2 on t1.c1 = t2.a1 where exists  (select max(a1) from t2 where t1.c1 = t2.a1) group by t1.c1 having max(t1.c1) < 4 order by t1.c1 desc limit 2;

select /*+no_rewrite*/ * from t1 left join t2 on t1.c1 = t2.a1 where not exists (select min(a1) from t2 where t1.c1 = t2.a1) order by c1 desc ;
explain basic select /*+no_rewrite*/ * from t1 left join t2 on t1.c1 = t2.a1 where not exists (select min(a1) from t2 where t1.c1 = t2.a1) order by c1 desc ;

select /*+parallel(6) no_rewrite*/ * from t1 left join t2 on t1.c1 = t2.a1 where not exists (select min(a1) from t2 where t1.c1 = t2.a1) order by c1 desc ;
explain basic select /*+parallel(6) no_rewrite*/ * from t1 left join t2 on t1.c1 = t2.a1 where not exists (select min(a1) from t2 where t1.c1 = t2.a1) order by c1 desc ;


select /*+no_rewrite*/ * from t1 right join t2 on t1.c1 = t2.a1 where not exists (select min(a1) from t2 where t1.c1 = t2.a1) order by c1 desc ;
explain basic select /*+no_rewrite*/ * from t1 right join t2 on t1.c1 = t2.a1 where not exists (select min(a1) from t2 where t1.c1 = t2.a1) order by c1 desc ;

select /*+parallel(6) no_rewrite*/ * from t1 right join t2 on t1.c1 = t2.a1 where not exists (select min(a1) from t2 where t1.c1 = t2.a1) order by c1 desc ;
explain basic select /*+parallel(6) no_rewrite*/ * from t1 right join t2 on t1.c1 = t2.a1 where not exists (select min(a1) from t2 where t1.c1 = t2.a1) order by c1 desc ;


select c1,c2,(select max(a1) from t2 where t2.a1 = t1.c1) from t1 order by c1 ;
explain select /*+no_rewrite*/ c1,c2,(select max(a1) from t2 where t2.a1 = t1.c1) from t1 order by c1  ;


