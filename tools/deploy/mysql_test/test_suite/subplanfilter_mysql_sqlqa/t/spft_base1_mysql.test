delete /*+no_rewrite*/ from t2 where a1 like (select /*+no_rewrite*/ c1 from t1 where c1 like  (select max(a1) from t2 where t2.a1=t1.c1) group by c1 having max(c1) <5 order by c1 desc limit 1);
explain basic delete /*+no_rewrite*/ from t2 where a1 like (select /*+no_rewrite*/ c1 from t1 where c1 like  (select max(a1) from t2 where t2.a1=t1.c1) group by c1 having max(c1) <5 order by c1 desc limit 1);

delete /*+no_rewrite*/ from t2 where exists (select /*+no_rewrite*/ c1 from t1 where  exists  (select min(a1) from t2 where t2.a1=t1.c1 group by a1 having min(a1)<6 order by a1 desc limit 1) group by c1 order by c1 desc limit 1);
