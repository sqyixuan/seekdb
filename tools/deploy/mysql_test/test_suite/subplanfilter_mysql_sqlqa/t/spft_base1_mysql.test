select /*+no_rewrite*/ c1,c2,(select max(a1) from t1,t2 where t2.a1 = t1.c1) from t1;
explain  basic select /*+no_rewrite*/ c1,c2,(select max(a1) from t1,t2 where t2.a1 = t1.c1) from t1;

select /*+no_rewrite*/ c1 from t1 where c1 > (select min(a1) from t2,t1 where t2.a1=t1.c1);
select /*+no_rewrite*/ * from t1,t2 where c1 >(select max(a1) from t1 cross join t2);


