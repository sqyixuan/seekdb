explain basic select /*+parallel(6) no_rewrite*/ * from t1 where  exists  (select min(a1) from t2 where t2.a1=t1.c1 group by a1 having min(a1)<6 order by a1 desc limit 1) group by c1 order by c1 desc limit 2;

--echo  #not exists
select /*+no_rewrite*/ * from t1 where  not exists  (select max(a1) from t2 where t2.a1=t1.c1);
explain basic select /*+no_rewrite*/ * from t1 where  not exists  (select max(a1) from t2 where t2.a1=t1.c1);

