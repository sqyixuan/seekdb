--echo  #insert
insert tt1 select /*+no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2) order by c1 limit 1 ;
#explain basic insert tt1 select /*+no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2) order by c1;
insert tt1 select /*+parallel(6) no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2) order by c1;
#explain basic insert tt1 select /*+parallel(6) no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2) order by c1;


insert tt1 select /*+no_rewrite*/ * from tt1 where c1 in (select a1 from tt2 where a1 > 4 and a1 is not null) order by c1;
