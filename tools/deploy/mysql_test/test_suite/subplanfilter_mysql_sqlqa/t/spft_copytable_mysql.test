select distinct * from tt1 right join tt2 on tt1.c1 = tt2.a1 where tt1.c1 > (select min(a1) from tt2) order by tt1.c1;
select /*+no_rewrite*/ distinct * from tt1 right join tt2 on tt1.c1 = tt2.a1 where tt1.c1 > (select min(a1) from tt2) order by tt1.c1;
