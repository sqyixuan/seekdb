--disable_warnings
drop database if exists db1;
--enable_warnings
create database db1;
use db1;

create table t1(c1 int,c2 varchar(20));
insert into t1 values(1,'张三');
insert into t1 values(2,'李四');
insert into t1 values(3,'王五');
insert into t1 values(4,'马六');
insert into t1 values(5,'田七');
insert into t1 values(7,'腊八');
create table tt1 as select * from t1;
create table t2(a1 int,a2 varchar(20));
insert into t2 values(1,'abc');
insert into t2 values(2,'def');
insert into t2 values(3,'ghi');
insert into t2 values(4,'jkl');
insert into t2 values(5,null);
insert into t2 values(6,'mno');
create table tt2 as select * from t2;

--echo  #驱动非相关子查询计算
--echo  #in
select * from tt1 where c1 in (select a1 from tt2)order by c1;
select /*+no_rewrite*/ * from tt1 where c1 in (select a1 from tt2) order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where c1 in (select a1 from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 in (select a1 from tt2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 in (select a1 from tt2) order by c1;

--echo  #not in
select * from tt1 where c1 not in (select a1 from tt2) order by c1;
select /*+no_rewrite*/ * from tt1 where c1 not in (select a1 from tt2) order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where c1 not in (select a1 from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 not in (select a1 from tt2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 not in (select a1 from tt2) order by c1;

--echo  #any
select * from tt1 where c1 > any (select a1 from tt2) order by c1;
select /*+no_rewrite*/ * from tt1 where c1 > any (select a1 from tt2) order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where c1 > any (select a1 from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 > any (select a1 from tt2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 > any (select a1 from tt2) order by c1;

--echo  #all
select * from tt1 where c1 > all (select a1 from tt2) order by c1;
select /*+no_rewrite*/ * from tt1 where c1 > all (select a1 from tt2) order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where c1 > all (select a1 from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 > all (select a1 from tt2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 > all (select a1 from tt2) order by c1;

--echo  #some
select * from tt1 where c1 <> some (select a1 from tt2) order by c1;
select /*+no_rewrite*/ * from tt1 where c1 <> some (select a1 from tt2) order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where c1 <> some (select a1 from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 <> some (select a1 from tt2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 <> some (select a1 from tt2) order by c1;

--echo  #exists
select * from tt1 where c1 = exists (select a1 from tt2) order by c1;
select /*+no_rewrite*/ * from tt1 where c1 = exists (select a1 from tt2) order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where c1 = exists (select a1 from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 = exists (select a1 from tt2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 = exists (select a1 from tt2) order by c1;

--echo  #not exists
select * from tt1 where not exists (select max(a1) from tt2) order by c1;
select /*+no_rewrite*/ * from tt1 where not exists (select max(a1) from tt2) order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where not exists (select max(a1) from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where not exists (select max(a1) from tt2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where not exists (select max(a1) from tt2) order by c1;

--echo  #like
select * from tt1 where c1 like (select min(a1) from tt2) order by c1;
select /*+no_rewrite*/ * from tt1 where c1 like (select min(a1) from tt2) order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where c1 like (select min(a1) from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 like (select min(a1) from tt2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 like (select min(a1) from tt2) order by c1;

--echo  #比较运算符 >,<,>=,<=,=,<>,!=
select * from tt1 where c1 > (select min(a1) from tt2) order by c1;
select /*+no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2) order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2) order by c1;
