#explain basic select /*+no_rewrite*/ * from tt1 where c1 >= (select min(a1) from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 >= (select min(a1) from tt2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 >= (select min(a1) from tt2) order by c1;


select * from tt1 where c1 < (select max(a1) from tt2) order by c1;
select /*+no_rewrite*/ * from tt1 where c1 < (select max(a1) from tt2) order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where c1 < (select max(a1) from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 < (select max(a1) from tt2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 < (select max(a1) from tt2) order by c1;

select * from tt1 where c1 <= (select max(a1) from tt2) order by c1;
select /*+no_rewrite*/ * from tt1 where c1 <= (select max(a1) from tt2) order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where c1 <= (select max(a1) from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 <= (select max(a1) from tt2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 <= (select max(a1) from tt2) order by c1;

select * from tt1 where c1 = (select min(a1) from tt2) order by c1;
select /*+no_rewrite*/ * from tt1 where c1 = (select min(a1) from tt2) order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where c1 = (select min(a1) from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 = (select min(a1) from tt2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 = (select min(a1) from tt2) order by c1;

select * from tt1 where c1 != (select min(a1) from tt2) order by c1;
select /*+no_rewrite*/ * from tt1 where c1 != (select min(a1) from tt2) order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where c1 != (select min(a1) from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 != (select min(a1) from tt2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 != (select min(a1) from tt2) order by c1;

select * from tt1 where c1 <> (select max(a1) from tt2) order by c1;
select /*+no_rewrite*/ * from tt1 where c1 <> (select max(a1) from tt2) order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where c1 <> (select max(a1) from tt2) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 <> (select max(a1) from tt2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 <> (select max(a1) from tt2) order by c1;

--echo  #gruop by .......having

select * from tt1 where c1 > (select min(a1) from tt2) group by c1 having max(c1) >5  order by c1;
select /*+no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2) group by c1 having max(c1) >5  order by c1;
#explain basic select /*+no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2) group by c1 having max(c1) >5  order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2) group by c1 having max(c1) >5  order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2) group by c1 having max(c1) >5  order by c1;

select /*+parallel(6) no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2) group by c1 having max(c1) >(select min(a1) from tt2)  order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2) group by c1 having max(c1) >(select min(a1) from tt2)  order by c1;


--echo  #不同join


select distinct tt1.c1 from tt1,tt2 where tt1.c1 > (select min(a1) from tt2) order by tt1.c1;
select /*+no_rewrite*/ distinct tt1.c1 from tt1,tt2 where tt1.c1 > (select min(a1) from tt2) order by tt1.c1;
#explain basic select /*+no_rewrite*/ distinct tt1.c1 from tt1,tt2 where tt1.c1 > (select min(a1) from tt2) order by tt1.c1;
select /*+no_rewrite*/ distinct tt1.c1 from tt1,tt2 where tt1.c1 > (select min(a1) from tt2) group by tt1.c1 having max(tt1.c1) <5 order by tt1.c1;
#explain basic select /*+no_rewrite*/ distinct tt1.c1 from tt1,tt2 where tt1.c1 > (select min(a1) from tt2) group by tt1.c1 having max(tt1.c1) <5 order by tt1.c1;
select /*+parallel(6) no_rewrite*/ distinct tt1.c1 from tt1,tt2 where tt1.c1 > (select min(a1) from tt2) group by tt1.c1 having max(tt1.c1) <5 order by tt1.c1;
