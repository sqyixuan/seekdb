insert tt1 select /*+no_rewrite*/ c1,a2 from tt1,tt2 where tt1.c1 > (select min(a1) from tt2) order by c1 limit 1;
#explain basic insert tt1 select /*+no_rewrite*/ c1,a2 from tt1,tt2 where tt1.c1 > (select min(a1) from tt2) order by c1 limit 1;
