#explain basic select /*+no_rewrite*/ distinct tt1.c1 from tt1 natural join tt2 where tt1.c1 > (select min(a1) from tt2) group by tt1.c1 having max(tt1.c1) <5 order by tt1.c1;
select /*+parallel(6) no_rewrite*/ distinct tt1.c1 from tt1 natural join tt2 where tt1.c1 > (select min(a1) from tt2) group by tt1.c1 having max(tt1.c1) <5 order by tt1.c1;
#explain basic select /*+parallel(6) no_rewrite*/ distinct tt1.c1 from tt1 natural join tt2 where tt1.c1 > (select min(a1) from tt2) group by tt1.c1 having max(tt1.c1) <5 order by tt1.c1;

select distinct * from tt1 inner join tt2 on tt1.c1 = tt2.a1 where tt1.c1 > (select min(a1) from tt2) order by tt1.c1;
select /*+no_rewrite*/ distinct * from tt1 inner join tt2 on tt1.c1 = tt2.a1 where tt1.c1 > (select min(a1) from tt2) order by tt1.c1;
#explain basic select /*+no_rewrite*/ distinct * from tt1 inner join tt2 on tt1.c1 = tt2.a1 where tt1.c1 > (select min(a1) from tt2) order by tt1.c1;
select /*+no_rewrite*/ distinct * from tt1 inner join tt2 on tt1.c1 = tt2.a1  where tt1.c1 > (select min(a1) from tt2) group by tt1.c1 having max(tt1.c1) <5 order by tt1.c1;
#explain basic select /*+no_rewrite*/ distinct * from tt1 inner join tt2 on  tt1.c1 = tt2.a1  where tt1.c1 > (select min(a1) from tt2) group by tt1.c1 having max(tt1.c1) <5 order by tt1.c1;
