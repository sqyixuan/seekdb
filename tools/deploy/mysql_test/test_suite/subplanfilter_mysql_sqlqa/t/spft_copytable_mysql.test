insert tt1 select /*+no_rewrite*/ * from tt1 where c1 like (select max(a1) from tt2 group by a1 having max(a1)>4 limit 1)  order by c1 limit 1;
#explain basic insert tt1 select /*+no_rewrite*/ * from tt1 where c1 like (select max(a1) from tt2 group by a1 having max(a1)>4 limit 1)order by c1  limit 1;
