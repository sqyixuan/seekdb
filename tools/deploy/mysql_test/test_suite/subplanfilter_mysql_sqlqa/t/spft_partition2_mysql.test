#owner : xiaoyi.xy
#owner group : SQL-SQL2
#tags : subplanfilter, optimizer
#description : 不同分区中测试
#author : wb-zwc01059807



--disable_warnings
drop database if exists db1;
--enable_warnings
create database db1;
use db1;



--echo  #list

create table t1(c1 int,c2 varchar(20)) partition by list(c1)
(
partition p0 values in(1,2,3,4),
partition p1 values in(5,6,7,8)
);
create table t2(a1 int,a2 varchar(20)) partition by list(a1)
(
partition p0 values in(1,2,3,4,5),
partition p1 values in(6,7,8,9,10)
);

insert into t1 values(1,'a'),(2,'b'),(3,'c'),(4,'d'),(5,'e'),(6,'f'),(7,'g'),(8,'h');
insert into t2 values(1,'一'),(2,'二'),(3,'三'),(4,'四'),(5,'五'),(6,'六'),(7,'七'),(8,'八'),(9,'九'),(10,'十');

--source mysql_test/test_suite/subplanfilter_mysql_sqlqa/include/spft_partition_mysql.inc

drop table t1;
drop table t2;

--echo  #key
create table t1(c1 int primary key , c2 varchar(20))
partition by key(c1)
partitions 2;
create table t2(a1 int not null,a2 varchar(20),unique key(a1))
partition by key(a1)
partitions 2;

insert into t1 values(1,'a'),(2,'b'),(3,'c'),(4,'d'),(5,'e'),(6,'f'),(7,'g'),(8,'h');
insert into t2 values(1,'一'),(2,'二'),(3,'三'),(4,'四'),(5,'五'),(6,'六'),(7,'七'),(8,'八'),(9,'九'),(10,'十');

--source mysql_test/test_suite/subplanfilter_mysql_sqlqa/include/spft_partition_mysql.inc

drop table t1;
drop table t2;



drop database db1;
