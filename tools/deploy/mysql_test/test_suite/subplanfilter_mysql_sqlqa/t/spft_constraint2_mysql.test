--disable_warnings
drop database if exists db1;
--enable_warnings
create database db1;
use db1;


--echo  #唯一
create table t1(c1 int,c2 varchar(60) ,constraint c1_uqk unique(c1));
create table t2(a1 int,a2 varchar(60), constraint a1_uqk unique(a1));
insert into t1 values(-1,'负一-1');
insert into t1 values(0,null);
insert into t1 values(1,'张三33');
insert into t1 values(2,'李四44');
insert into t1 values(3,'王五55');
insert into t1 values(4,'马六66');
insert into t1 values(5,'田七77');
insert into t1 values(7,'腊八88');

insert into t2 values(1,'asc');
insert into t2 values(2,'gfh');
insert into t2 values(3,'hjk');
insert into t2 values(4,'dfr');
insert into t2 values(5,'czx');
insert into t2 values(6,'egh');

--source mysql_test/test_suite/subplanfilter_mysql_sqlqa/include/spft_constraint_mysql.inc

drop table t1;
drop table t2;


drop database db1;
