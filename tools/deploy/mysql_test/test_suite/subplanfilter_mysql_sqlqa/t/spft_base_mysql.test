#explain basic select /*+no_rewrite*/ * from t1 where c1 != (select min(a1) from t2) order by c1;
select /*+parallel(6) no_rewrite*/ * from t1 where c1 != (select min(a1) from t2) order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from t1 where c1 != (select min(a1) from t2) order by c1;

select * from t1 where c1 <> (select max(a1) from t2) order by c1;
select /*+no_rewrite*/ * from t1 where c1 <> (select max(a1) from t2) order by c1;
#explain basic select /*+no_rewrite*/ * from t1 where c1 <> (select max(a1) from t2) order by c1;
