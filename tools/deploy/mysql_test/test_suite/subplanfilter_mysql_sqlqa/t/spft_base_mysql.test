select /*+parallel(6) no_rewrite*/ * from t1 where c1 > (select min(a1) from t2) group by c1 having max(c1) >(select min(a1) from t2)  order by c1;
#explain basic select /*+parallel(6) no_rewrite*/ * from t1 where c1 > (select min(a1) from t2) group by c1 having max(c1) >(select min(a1) from t2)  order by c1;


--echo  #不同join
select distinct t1.c1 from t1,t2 where t1.c1 > (select min(a1) from t2) order by t1.c1;
select /*+no_rewrite*/ distinct t1.c1 from t1,t2 where t1.c1 > (select min(a1) from t2) order by t1.c1;
