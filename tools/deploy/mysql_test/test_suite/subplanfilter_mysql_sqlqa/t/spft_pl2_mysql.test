drop trigger if exists tg1;
delimiter //;
create trigger tg1
AFTER
insert on t3
for each ROW
BEGIN
	insert t1 select /*+no_rewrite*/ max(c1),c2 from t1 where c1 > any (select a1 from t2 where a1 >5 and a1 is not null);
END
//
delimiter ;//
insert into t3 values(1,1);
select * from t1;


drop trigger if exists tg1;
delimiter //;
create trigger tg1
AFTER
update on t3
for each ROW
BEGIN
	update /*+no_rewrite*/ t1 set c1 = 103 where c1 in (select max(a1) from t2 where a1 < 6);
    update /*+no_rewrite*/ t1 set c1 = 105 where c1 > any (select a1 from t2 where a1 > 5 and a1 is not null);
END
//
delimiter ;//
--error 1442
update t3 set a1 =2 where a1 = (select min(c1) from t1);
select * from t1;



drop trigger if exists tg1;
delimiter //;
create trigger tg1
AFTER
delete on t3
for each ROW
BEGIN
	    delete /*+no_rewrite*/ from t1 where c1 < all (select avg(a1) from t2);
		delete /*+no_rewrite*/ from t1 where c1 < (select min(a1) from t2);
END
//
delimiter ;//
delete from t3 where a1 = 3;
select * from t1;














drop database db1;
