--disable_warnings
drop database if exists db1;
--enable_warnings
create database db1;
use db1;


--echo  #外键
CREATE TABLE t1(c1 int primary key ,c2 varchar(60));
create table t2(
        a1 int,
        a2 varchar(60),
        FOREIGN key (a1) REFERENCES t1(c1)
);
insert into t1 values(-1,'负一-1');
