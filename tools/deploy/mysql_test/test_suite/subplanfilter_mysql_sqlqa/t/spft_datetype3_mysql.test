select /*+no_rewrite*/ bin(c1)  from t1 where c1 < any (select min(a1) from t2 where t2.a1 > t1.c1) group by c1 having max(c1) > 4 order by c1;
explain basic select /*+no_rewrite*/ bin(c1)  from t1 where c1 < any (select min(a1) from t2 where t2.a1 > t1.c1) group by c1 having max(c1) > 4 order by c1;

select /*+parallel(6) no_rewrite*/ bin(c1)  from t1 where c1 < any (select min(a1) from t2 where t2.a1 > t1.c1) group by c1 having max(c1) > 4 order by c1;
explain basic select /*+parallel(6) no_rewrite*/ bin(c1)  from t1 where c1 < any (select min(a1) from t2 where t2.a1 > t1.c1) group by c1 having max(c1) > 4 order by c1;

select /*+no_rewrite*/ bin(c1)  from t1 where c1 > all (select min(a1) from t2 where t2.a1 <= t1.c1 group by a1 having min(a1) < 4 ) order by c1;
explain basic select /*+no_rewrite*/ bin(c1)  from t1 where c1 > all (select min(a1) from t2 where t2.a1 <= t1.c1 group by a1 having min(a1) < 4 ) order by c1;

select /*+parallel(6) no_rewrite*/ bin(c1)  from t1 where c1 > all (select min(a1) from t2 where t2.a1 <= t1.c1 group by a1 having min(a1) < 4 ) order by c1;
explain basic select /*+parallel(6) no_rewrite*/ bin(c1)  from t1 where c1 > all (select min(a1) from t2 where t2.a1 <= t1.c1 group by a1 having min(a1) < 4 ) order by c1;

select /*+no_rewrite*/ bin(c1)  from t1 where c1 <> some (select min(a1) from t2 where t2.a1 <> t1.c1 group by a1) group by c1 having min(c1) <3 order by c1;
explain basic select /*+no_rewrite*/ bin(c1)  from t1 where c1 <> some (select min(a1) from t2 where t2.a1 <> t1.c1 group by a1) group by c1 having min(c1) <3 order by c1;

