select /*+parallel(6) no_rewrite*/ bin(c1) from t1 where c1 >= (select max(a1) from t2) order by c1 ;

select /*+no_rewrite*/ bin(c1) from t1 where c1 <= (select count(a1) from t2) order by c1 ;
select /*+parallel(6) no_rewrite*/ bin(c1) from t1 where c1 <= (select count(a1) from t2) order by c1 ;

select /*+no_rewrite*/ bin(c1) from t1 where c1 <> (select min(a1) from t2) order by c1 ;
select /*+parallel(6) no_rewrite*/ bin(c1) from t1 where c1 <> (select min(a1) from t2) order by c1 ;

select /*+no_rewrite*/ bin(c1) from t1 where c1 != (select max(a1) from t2) order by c1 ;
select /*+parallel(6) no_rewrite*/ bin(c1) from t1 where c1 != (select max(a1) from t2) order by c1 ;

--echo  #in
select /*+no_rewrite*/ count(c1) from t1 where c1 in (select max(a1) from t2) order by c1 ;
select /*+parallel(6) no_rewrite*/ count(c1) from t1 where c1 in (select max(a1) from t2) order by c1 ;

select /*+no_rewrite*/ bin(max(c1)) from t1 where c1 not in (select min(a1) from t2) order by c1 ;
select /*+parallel(6) no_rewrite*/ bin(max(c1)) from t1 where c1 not in (select min(a1) from t2) order by c1 ;

--echo  #all
select /*+no_rewrite*/ bin(min(c1)) from t1 where c1 < all (select max(a1) from t2) order by c1 ;
select /*+parallel(6) no_rewrite*/ bin(min(c1)) from t1 where c1 < all (select max(a1) from t2) order by c1 ;

--echo  #any
select /*+no_rewrite*/ bin(avg(c1)) from t1 where c1 = any (select min(a1) from t2) order by c1 ;
select /*+parallel(6) no_rewrite*/ bin(avg(c1))  from t1 where c1 = any (select min(a1) from t2) order by c1 ;

--echo  #some
select /*+no_rewrite*/ count(c1) from t1 where c1 > some (select min(a1) from t2) order by c1 ;
select /*+parallel(6) no_rewrite*/ count(c1) from t1 where c1 > some (select min(a1) from t2) order by c1 ;

--echo  #exists
select /*+no_rewrite*/ bin(c1) from t1 where exists (select min(a1) from t2) order by c1 ;
select /*+parallel(6) no_rewrite*/ bin(c1)  from t1 where exists (select min(a1) from t2) order by c1 ;

--echo  #not exists
select /*+no_rewrite*/ bin(c1)  from t1 where not exists (select max(a1) from t2) order by c1 ;
select /*+parallel(6) no_rewrite*/ bin(c1)  from t1 where not exists (select max(a1) from t2) order by c1 ;

--echo  #like
select /*+no_rewrite*/ count(c1) from t1 where c1 like (select max(a1) from t2) order by c1 ;
select /*+parallel(6) no_rewrite*/ count(c1) from t1 where c1 like (select max(a1) from t2) order by c1 ;



