select /*+no_rewrite*/ bin(c1)  from t1 where c1 > (select min(a1) from t2 where t2.a1 > t1.c1) order by c1;
explain basic select /*+no_rewrite*/ bin(c1)  from t1 where c1 < (select avg(a1) from t2 where t2.a1 > t1.c1) order by c1;

select /*+parallel(6) no_rewrite*/ bin(c1)  from t1 where c1 > (select min(a1) from t2 where t2.a1 > t1.c1) order by c1;
explain basic select /*+parallel(6) no_rewrite*/ bin(c1)  from t1 where c1 < (select avg(a1) from t2 where t2.a1 > t1.c1) order by c1;

select /*+no_rewrite*/ bin(c1)  from t1 where c1 >= (select avg(a1) from t2 where t2.a1 = t1.c1) order by c1;
explain basic select /*+no_rewrite*/ bin(c1)  from t1 where c1 >= (select avg(a1) from t2 where t2.a1 = t1.c1) order by c1;

select /*+parallel(6) no_rewrite*/ bin(c1)  from t1 where c1 >= (select avg(a1) from t2 where t2.a1 = t1.c1) order by c1;
