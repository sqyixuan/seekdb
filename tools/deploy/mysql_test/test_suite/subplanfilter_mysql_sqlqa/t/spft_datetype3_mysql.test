select /*+no_rewrite*/ bin(c1)  from t1,t2 where t1.c1 = t2.a1 and t1.c1 = all (select count(a1) from t2) order by t1.c1;
explain basic select /*+no_rewrite*/ bin(c1)  from t1,t2 where t1.c1 = t2.a1 and t1.c1 = all (select count(a1) from t2) order by t1.c1;

