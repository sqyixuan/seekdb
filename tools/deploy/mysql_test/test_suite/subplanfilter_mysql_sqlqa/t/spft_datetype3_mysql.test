select /*+no_rewrite*/ bin(c1)  from t1 left join t2 on t1.c1 = t2.a1 where t1.c1 > some (select min(a1) from t2) order by t1.c1;
explain basic select /*+no_rewrite*/ bin(c1)  from t1 left join t2 on t1.c1 = t2.a1 where t1.c1 > some (select min(a1) from t2) order by t1.c1;

select /*+parallel(6) no_rewrite*/ bin(c1)  from t1 left join t2 on t1.c1 = t2.a1 where t1.c1 > some (select min(a1) from t2) order by t1.c1;
