#tags : subplanfilter, optimizer
#description : datetype
#author : wb-zwc01059807



--disable_warnings
drop database if exists db1;
--enable_warnings
create database db1;
use db1;



--echo  #double
create table t1(c1 double , c2 double unsigned);
create table t2(a1 double , a2 double unsigned);
insert into t1 values(-1.1,1.1),(-0.2,0.222),(1,1.555),(2,2.6666);
insert into t2 values(-1.1,1.1),(-0.2,0.222),(1,1.555),(2,null);

--source mysql_test/test_suite/subplanfilter_mysql_sqlqa/include/spft_datetype_mysql.inc

drop table t1;
drop table t2;



--echo #decimal
create table t1(c1 decimal(10,3) , c2 decimal(10,3) unsigned);
create table t2(a1 decimal(10,3) , a2 decimal(10,3) unsigned);
insert into t1 values (-1001,20001),(1002,20002),(1003,20003),(-1004,20004),(1005,20005);
insert into t2 values (null,20001),(1002,20002),(1003,20003),(-1004,20004),(1005,null);

--source mysql_test/test_suite/subplanfilter_mysql_sqlqa/include/spft_datetype_mysql.inc

drop table t1;
drop table t2;



drop database db1;
