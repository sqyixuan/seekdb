--echo  #not exists
select /*+no_rewrite*/ * from tt1 where  not exists  (select max(a1) from tt2 where tt2.a1=tt1.c1);
explain basic select /*+no_rewrite*/ * from tt1 where  not exists  (select max(a1) from tt2 where tt2.a1=tt1.c1);
select /*+no_rewrite*/ * from tt1 where  not exists  (select max(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having max(a1)>6) group by c1 order by c1 desc limit 2;
