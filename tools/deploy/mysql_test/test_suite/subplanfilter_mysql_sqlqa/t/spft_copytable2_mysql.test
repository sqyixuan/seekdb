--echo  #like
select /*+no_rewrite*/ * from tt1 where c1 like  (select max(a1) from tt2 where tt2.a1=tt1.c1);
explain basic select /*+no_rewrite*/ * from tt1 where c1 like  (select max(a1) from tt2 where tt2.a1=tt1.c1);
select /*+no_rewrite*/ * from tt1 where c1 like  (select max(a1) from tt2 where tt2.a1=tt1.c1) group by c1 having max(c1) <5 order by c1 desc limit 2;
explain basic select /*+no_rewrite*/ * from tt1 where c1 like  (select max(a1) from tt2 where tt2.a1=tt1.c1) group by c1 having max(c1) <5 order by c1 desc limit 2;
