explain basic insert into tt1 select /*+no_rewrite*/ * from tt1 where c1 >= (select min(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having min(a1)>3) order by c1 desc limit 2;
insert into tt1 select /*+parallel(6) no_rewrite*/ * from tt1 where c1 >= (select min(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having min(a1)>3) order by c1 desc limit 2;
