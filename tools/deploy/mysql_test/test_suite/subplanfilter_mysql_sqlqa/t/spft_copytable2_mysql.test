--echo  #无条件连接
select /*+no_rewrite*/ * from tt1,tt2 where c1 > (select max(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc limit 1;
explain basic select /*+no_rewrite*/ * from tt1,tt2 where c1 > (select max(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc limit 1;
select /*+parallel(6) no_rewrite*/ * from tt1,tt2 where c1 > (select max(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc limit 1;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1,tt2 where c1 > (select max(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc limit 1;

select /*+no_rewrite*/ * from tt1 cross join tt2 where c1 = any (select max(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc limit 1;
explain basic select /*+no_rewrite*/ * from tt1 cross join tt2 where c1 = any (select max(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc limit 1;
select /*+parallel(6) no_rewrite*/ * from tt1 cross join tt2 where c1 = any (select max(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc limit 1;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1 cross join tt2 where c1 = any (select max(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc limit 1;

select /*+no_rewrite*/ * from tt1 cross join tt2 where c1 = all  (select max(a1) from tt2 where tt1.c1 = tt2.a1) group by tt1.c1 having max(tt1.c1)<5 order by tt1.c1 desc limit 1;
explain basic select /*+no_rewrite*/ * from tt1 cross join tt2 where c1 = all  (select max(a1) from tt2 where tt1.c1 = tt2.a1) group by tt1.c1 having max(tt1.c1)<5 order by tt1.c1 desc limit 1;
select /*+parallel(6) no_rewrite*/ * from tt1 cross join tt2 where c1 = all  (select max(a1) from tt2 where tt1.c1 = tt2.a1) group by tt1.c1 having max(tt1.c1)<5 order by tt1.c1 desc limit 1;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1 cross join tt2 where c1 = all  (select max(a1) from tt2 where tt1.c1 = tt2.a1) group by tt1.c1 having max(tt1.c1)<5 order by tt1.c1 desc limit 1;

select /*+no_rewrite*/ * from tt1 natural join tt2 where c1 >= some (select max(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc limit 1 ;
explain basic select /*+no_rewrite*/ * from tt1 natural join tt2 where c1 >= some (select max(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc limit 1 ;
select /*+parallel(6) no_rewrite*/ * from tt1 natural join tt2 where c1 >= some (select max(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc limit 1 ;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1 natural join tt2 where c1 >= some (select max(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc limit 1 ;

select /*+no_rewrite*/ * from tt1 inner join tt2 on tt1.c1 = tt2.a1 where exists (select max(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc ;
explain basic select /*+no_rewrite*/ * from tt1 inner join tt2 on tt1.c1 = tt2.a1 where exists (select max(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc ;
select /*+no_rewrite*/ * from tt1 inner join tt2 on tt1.c1 = tt2.a1 where exists  (select max(a1) from tt2 where tt1.c1 = tt2.a1) group by tt1.c1 having max(tt1.c1) < 4 order by tt1.c1 desc limit 2;
explain basic select /*+no_rewrite*/ * from tt1 inner join tt2 on tt1.c1 = tt2.a1 where exists  (select max(a1) from tt2 where tt1.c1 = tt2.a1) group by tt1.c1 having max(tt1.c1) < 4 order by tt1.c1 desc limit 2;
select /*+parallel(6) no_rewrite*/ * from tt1 inner join tt2 on tt1.c1 = tt2.a1 where exists  (select max(a1) from tt2 where tt1.c1 = tt2.a1) group by tt1.c1 having max(tt1.c1) < 4 order by tt1.c1 desc limit 2;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1 inner join tt2 on tt1.c1 = tt2.a1 where exists  (select max(a1) from tt2 where tt1.c1 = tt2.a1) group by tt1.c1 having max(tt1.c1) < 4 order by tt1.c1 desc limit 2;

select /*+no_rewrite*/ * from tt1 left join tt2 on tt1.c1 = tt2.a1 where not exists (select min(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc ;
explain basic select /*+no_rewrite*/ * from tt1 left join tt2 on tt1.c1 = tt2.a1 where not exists (select min(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc ;
select /*+parallel(6) no_rewrite*/ * from tt1 left join tt2 on tt1.c1 = tt2.a1 where not exists (select min(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc ;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1 left join tt2 on tt1.c1 = tt2.a1 where not exists (select min(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc ;

select /*+no_rewrite*/ * from tt1 right join tt2 on tt1.c1 = tt2.a1 where not exists (select min(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc ;
explain basic select /*+no_rewrite*/ * from tt1 right join tt2 on tt1.c1 = tt2.a1 where not exists (select min(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc ;
select /*+parallel(6) no_rewrite*/ * from tt1 right join tt2 on tt1.c1 = tt2.a1 where not exists (select min(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc ;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1 right join tt2 on tt1.c1 = tt2.a1 where not exists (select min(a1) from tt2 where tt1.c1 = tt2.a1) order by c1 desc ;


select c1,c2,(select max(a1) from tt2 where tt2.a1 = tt1.c1) from tt1 order by c1 ;
explain select /*+no_rewrite*/ c1,c2,(select max(a1) from tt2 where tt2.a1 = tt1.c1) from tt1 order by c1  ;


--echo  #insert
