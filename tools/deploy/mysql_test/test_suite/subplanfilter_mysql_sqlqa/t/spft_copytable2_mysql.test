--disable_warnings
drop database if exists db1;
--enable_warnings
create database db1;
use db1;


--echo  #驱动相关子查询
create table t1(c1 int,c2 varchar(20));
insert into t1 values(1,'张三');
insert into t1 values(2,'李四');
insert into t1 values(3,'王五');
insert into t1 values(4,'马六');
insert into t1 values(5,'田七');
insert into t1 values(7,'腊八');
create table tt1 as select * from t1;
create table t2(a1 int,a2 varchar(20));
insert into t2 values(1,'abc');
insert into t2 values(2,'def');
insert into t2 values(3,'ghi');
insert into t2 values(4,'jkl');
insert into t2 values(5,null);
insert into t2 values(6,'mno');
create table tt2 as select * from t2;

--echo  #运算符
select /*+no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2 where tt2.a1=tt1.c1) order by c1;
explain basic select /*+no_rewrite*/ * from tt1 where c1 > (select min(a1) from tt2 where tt2.a1=tt1.c1) order by c1;
select /*+no_rewrite*/ * from tt1 where c1 >= (select min(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having min(a1)>3) order by c1;
explain basic select /*+no_rewrite*/ * from tt1 where c1 >= (select min(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having min(a1)>3) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 >= (select min(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having min(a1)>3) order by c1;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 >= (select min(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having min(a1)>3) order by c1;

select /*+no_rewrite*/ * from tt1 where c1 < (select min(a1) from tt2 where tt2.a1=tt1.c1) order by c1;
explain basic select /*+no_rewrite*/ * from tt1 where c1 < (select min(a1) from tt2 where tt2.a1=tt1.c1) order by c1;
select /*+no_rewrite*/ * from tt1 where c1 <= (select min(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having min(a1)>3) order by c1;
explain basic select /*+no_rewrite*/ * from tt1 where c1 <= (select min(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having min(a1)>3) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 <= (select min(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having min(a1)>3) order by c1;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 <= (select min(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having min(a1)>3) order by c1;

select /*+no_rewrite*/ * from tt1 where c1 <> (select max(a1) from tt2 where tt2.a1=tt1.c1) order by c1;
explain basic select /*+no_rewrite*/ * from tt1 where c1 <> (select max(a1) from tt2 where tt2.a1=tt1.c1) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 <> (select max(a1) from tt2 where tt2.a1=tt1.c1) order by c1;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 <> (select max(a1) from tt2 where tt2.a1=tt1.c1) order by c1;

select /*+no_rewrite*/ * from tt1 where c1 != (select max(a1) from tt2 where tt2.a1=tt1.c1) order by c1;
explain basic select /*+no_rewrite*/ * from tt1 where c1 != (select max(a1) from tt2 where tt2.a1=tt1.c1) order by c1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 != (select max(a1) from tt2 where tt2.a1=tt1.c1) order by c1;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 != (select max(a1) from tt2 where tt2.a1=tt1.c1) order by c1;

--echo  #in
select /*+no_rewrite*/ * from tt1 where c1 in  (select max(a1) from tt2 where tt2.a1=tt1.c1);
explain basic select /*+no_rewrite*/ * from tt1 where c1 in  (select max(a1) from tt2 where tt2.a1=tt1.c1);
select /*+no_rewrite*/ * from tt1 where c1 in  (select max(a1) from tt2 where tt2.a1=tt1.c1) group by c1 order by c1 desc limit 1;
explain basic select /*+no_rewrite*/ * from tt1 where c1 in  (select max(a1) from tt2 where tt2.a1=tt1.c1) group by c1 order by c1 desc limit 1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 in  (select max(a1) from tt2 where tt2.a1=tt1.c1) group by c1 order by c1 desc limit 1;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 in  (select max(a1) from tt2 where tt2.a1=tt1.c1) group by c1 order by c1 desc limit 1;

--echo  #not in
select /*+no_rewrite*/ * from tt1 where c1 not in  (select max(a1) from tt2 where tt2.a1=tt1.c1);
explain basic select /*+no_rewrite*/ * from tt1 where c1 not in  (select max(a1) from tt2 where tt2.a1=tt1.c1);
select /*+no_rewrite*/ * from tt1 where c1 not in  (select max(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having max(a1) >5 order by a1 desc limit 1) group by c1 order by c1 desc limit 1;
explain basic select /*+no_rewrite*/ * from tt1 where c1 not in  (select max(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having max(a1) >5 order by a1 desc limit 1) group by c1 order by c1 desc limit 1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 not in  (select max(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having max(a1) >5 order by a1 desc limit 1) group by c1 order by c1 desc limit 1;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 not in  (select max(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having max(a1) >5 order by a1 desc limit 1) group by c1 order by c1 desc limit 1;


--echo  #any
select /*+no_rewrite*/ * from tt1 where c1 = any  (select max(a1) from tt2 where tt2.a1=tt1.c1);
explain basic select /*+no_rewrite*/ * from tt1 where c1 = any  (select max(a1) from tt2 where tt2.a1=tt1.c1);
select /*+no_rewrite*/ * from tt1 where c1 = any   (select max(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having max(a1) <6 order by a1 desc limit 1) group by c1 order by c1 desc limit 1;
explain basic select /*+no_rewrite*/ * from tt1 where c1 = any   (select max(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having max(a1) <6 order by a1 desc limit 1) group by c1 order by c1 desc limit 1;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 = any   (select max(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having max(a1) <6 order by a1 desc limit 1) group by c1 order by c1 desc limit 1;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 = any   (select max(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having max(a1) <6 order by a1 desc limit 1) group by c1 order by c1 desc limit 1;


--echo  #all
select /*+no_rewrite*/ * from tt1 where c1 = all (select min(a1) from tt2 where tt2.a1=tt1.c1);
explain basic select /*+no_rewrite*/ * from tt1 where c1 = all (select min(a1) from tt2 where tt2.a1=tt1.c1);
select /*+no_rewrite*/ * from tt1 where c1 = all (select min(a1) from tt2 where tt2.a1=tt1.c1 and tt2.a1<5 group by a1 order by a1 desc limit 1);
explain basic select /*+no_rewrite*/ * from tt1 where c1 = all (select min(a1) from tt2 where tt2.a1=tt1.c1 and tt2.a1<5 group by a1 order by a1 desc limit 1);
select /*+parallel(6) no_rewrite pq_subquery(none all)*/ * from tt1 where c1 = all (select min(a1) from tt2 where tt2.a1=tt1.c1 and tt2.a1<5 group by a1 order by a1 desc limit 1);
explain basic select /*+parallel(6) no_rewrite pq_subquery(none all)*/ * from tt1 where c1 = all (select min(a1) from tt2 where tt2.a1=tt1.c1 and tt2.a1<5 group by a1 order by a1 desc limit 1);

--echo  #some
select /*+no_rewrite*/ * from tt1 where c1 = some (select min(a1) from tt2 where tt2.a1=tt1.c1);
explain basic select /*+no_rewrite*/ * from tt1 where c1 = some (select min(a1) from tt2 where tt2.a1=tt1.c1);
select /*+no_rewrite*/ * from tt1 where c1 = some (select min(a1) from tt2 where tt2.a1=tt1.c1) group by c1 having max(c1) < 5 order by c1 desc limit 2;
explain basic select /*+no_rewrite*/ * from tt1 where c1 = some (select min(a1) from tt2 where tt2.a1=tt1.c1) group by c1 having max(c1) < 5 order by c1 desc limit 2;
select /*+parallel(6) no_rewrite*/ * from tt1 where c1 = some (select min(a1) from tt2 where tt2.a1=tt1.c1) group by c1 having max(c1) < 5 order by c1 desc limit 2;
explain basic select /*+parallel(6) no_rewrite*/ * from tt1 where c1 = some (select min(a1) from tt2 where tt2.a1=tt1.c1) group by c1 having max(c1) < 5 order by c1 desc limit 2;


--echo  #exists
select /*+no_rewrite*/ * from tt1 where  exists  (select min(a1) from tt2 where tt2.a1=tt1.c1);
explain basic select /*+no_rewrite*/ * from tt1 where  exists  (select min(a1) from tt2 where tt2.a1=tt1.c1);
select /*+no_rewrite*/ * from tt1 where  exists  (select min(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having min(a1)<6 order by a1 desc limit 1) group by c1 order by c1 desc limit 2;
explain basic select /*+no_rewrite*/ * from tt1 where  exists  (select min(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having min(a1)<6 order by a1 desc limit 1) group by c1 order by c1 desc limit 2;
select /*+parallel(6) no_rewrite*/ * from tt1 where  exists  (select min(a1) from tt2 where tt2.a1=tt1.c1 group by a1 having min(a1)<6 order by a1 desc limit 1) group by c1 order by c1 desc limit 2;
