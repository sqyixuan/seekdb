select /*+no_rewrite*/ * from v_t1 cross join v_t2 where c1 = all  (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) group by v_t1.c1 having max(v_t1.c1)<5 order by v_t1.c1 desc limit 1;
explain basic select /*+no_rewrite*/ * from v_t1 cross join v_t2 where c1 = all  (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) group by v_t1.c1 having max(v_t1.c1)<5 order by v_t1.c1 desc limit 1;
select /*+parallel(6) no_rewrite*/ * from v_t1 cross join v_t2 where c1 = all  (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) group by v_t1.c1 having max(v_t1.c1)<5 order by v_t1.c1 desc limit 1;
explain basic select /*+parallel(6) no_rewrite*/ * from v_t1 cross join v_t2 where c1 = all  (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) group by v_t1.c1 having max(v_t1.c1)<5 order by v_t1.c1 desc limit 1;

select /*+no_rewrite*/ * from v_t1 natural join v_t2 where c1 >= some (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) order by c1 desc limit 1 ;
explain basic select /*+no_rewrite*/ * from v_t1 natural join v_t2 where c1 >= some (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) order by c1 desc limit 1 ;
select /*+parallel(6) no_rewrite*/ * from v_t1 natural join v_t2 where c1 >= some (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) order by c1 desc limit 1 ;
explain basic select /*+parallel(6) no_rewrite*/ * from v_t1 natural join v_t2 where c1 >= some (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) order by c1 desc limit 1 ;

select /*+no_rewrite*/ * from v_t1 inner join v_t2 on v_t1.c1 = v_t2.a1 where exists (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) order by c1 desc ;
explain basic select /*+no_rewrite*/ * from v_t1 inner join v_t2 on v_t1.c1 = v_t2.a1 where exists (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) order by c1 desc ;
select /*+no_rewrite*/ * from v_t1 inner join v_t2 on v_t1.c1 = v_t2.a1 where exists  (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) group by v_t1.c1 having max(v_t1.c1) < 4 order by v_t1.c1 desc limit 2;
explain basic select /*+no_rewrite*/ * from v_t1 inner join v_t2 on v_t1.c1 = v_t2.a1 where exists  (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) group by v_t1.c1 having max(v_t1.c1) < 4 order by v_t1.c1 desc limit 2;
select /*+parallel(6) no_rewrite*/ * from v_t1 inner join v_t2 on v_t1.c1 = v_t2.a1 where exists  (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) group by v_t1.c1 having max(v_t1.c1) < 4 order by v_t1.c1 desc limit 2;
