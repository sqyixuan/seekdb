explain basic select /*+no_rewrite*/ * from v_t1 where c1 like  (select max(a1) from v_t2 where v_t2.a1=v_t1.c1);
select /*+no_rewrite*/ * from v_t1 where c1 like  (select max(a1) from v_t2 where v_t2.a1=v_t1.c1) group by c1 having max(c1) <5 order by c1 desc limit 2;
