select /*+no_rewrite*/ * from v_t1 cross join v_t2 where c1 = any (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) order by c1 desc limit 1;
explain basic select /*+no_rewrite*/ * from v_t1 cross join v_t2 where c1 = any (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) order by c1 desc limit 1;
select /*+parallel(6) no_rewrite*/ * from v_t1 cross join v_t2 where c1 = any (select max(a1) from v_t2 where v_t1.c1 = v_t2.a1) order by c1 desc limit 1;
