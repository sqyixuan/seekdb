--echo  #all
select /*+no_rewrite*/ * from v_t1 where c1 = all (select min(a1) from v_t2 where v_t2.a1=v_t1.c1);
explain basic select /*+no_rewrite*/ * from v_t1 where c1 = all (select min(a1) from v_t2 where v_t2.a1=v_t1.c1);
select /*+no_rewrite*/ * from v_t1 where c1 = all (select min(a1) from v_t2 where v_t2.a1=v_t1.c1 and v_t2.a1<5 group by a1 order by a1 desc limit 1);
explain basic select /*+no_rewrite*/ * from v_t1 where c1 = all (select min(a1) from v_t2 where v_t2.a1=v_t1.c1 and v_t2.a1<5 group by a1 order by a1 desc limit 1);
select /*+parallel(6) no_rewrite*/ * from v_t1 where c1 = all (select min(a1) from v_t2 where v_t2.a1=v_t1.c1 and v_t2.a1<5 group by a1 order by a1 desc limit 1);
explain basic select /*+parallel(6) no_rewrite*/ * from v_t1 where c1 = all (select min(a1) from v_t2 where v_t2.a1=v_t1.c1 and v_t2.a1<5 group by a1 order by a1 desc limit 1);

--echo  #some
