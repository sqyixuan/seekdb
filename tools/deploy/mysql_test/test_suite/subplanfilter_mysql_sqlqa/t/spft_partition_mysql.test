#owner : xiaoyi.xy
#owner group : SQL-SQL2
#tags : subplanfilter, optimizer
#description : 在不同分区中测试。
#author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;




--echo  #分区
--echo  #range
create table t1(c1 int ,c2 varchar(20)) partition by range(c1)
(
partition p0 values less than(4),
partition p1 values less than(maxvalue)
);
create table t2(a1 int ,a2 varchar(20)) partition by range(a1)
(
partition p0 values less than(5),
partition p1 values less than(maxvalue)
);
insert into t1 values(1,'a'),(2,'b'),(3,'c'),(4,'d'),(5,'e'),(6,'f'),(7,'g'),(8,'h');
insert into t2 values(1,'一'),(2,'二'),(3,'三'),(4,'四'),(5,'五'),(6,'六'),(7,'七'),(8,'八'),(9,'九'),(10,'十');

--source mysql_test/test_suite/subplanfilter_mysql_sqlqa/include/spft_partition_mysql.inc

drop table t1;
drop table t2;


--echo  #hash
create table t1(c1 int ,c2 varchar(20)) partition by hash(c1)
(partition p0,
partition p1
);
create table t2(a1 int ,a2 varchar(20)) partition by hash(a1)
(partition p0,
partition p1
);

insert into t1 values(1,'a'),(2,'b'),(3,'c'),(4,'d'),(5,'e'),(6,'f'),(7,'g'),(8,'h');
insert into t2 values(1,'一'),(2,'二'),(3,'三'),(4,'四'),(5,'五'),(6,'六'),(7,'七'),(8,'八'),(9,'九'),(10,'十');

--source mysql_test/test_suite/subplanfilter_mysql_sqlqa/include/spft_partition_mysql.inc

drop table t1;
drop table t2;


drop database db1;
