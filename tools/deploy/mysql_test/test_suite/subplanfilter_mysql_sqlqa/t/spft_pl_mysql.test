                insert t1 select /*+no_rewrite*/ max(c1),c2 from t1 where c1 like (select max(a1) from t2 where a1 < 5 )  order by c1;
                insert into t1 select /*+no_rewrite*/ max(c1),c2 from t1 where c1 in  (select max(a1) from t2 where t2.a1=t1.c1);
                insert into t1 select /*+no_rewrite*/ max(c1),c2 from t1 where c1 not in  (select max(a1) from t2 where t2.a1=t1.c1);
        else
                insert into t1 select /*+no_rewrite*/ max(c1),c2 from t1 where c1 = any   (select max(a1) from t2 where t2.a1=t1.c1);
                insert into t1 select /*+no_rewrite*/ max(c1),c2 from t1 where c1 = all (select min(a1) from t2 where t2.a1=t1.c1);
                insert into t1 select /*+no_rewrite*/ max(c1),c2 from t1 where c1 = some (select min(a1) from t2 where t2.a1=t1.c1);
                insert into t1 select /*+no_rewrite*/ max(c1),c2 from t1 where  exists  (select min(a1) from t2 where t2.a1=t1.c1);
                insert into t1 select /*+no_rewrite*/ max(c1),c2 from t1 where c1 like  (select max(a1) from t2 where t2.a1=t1.c1);
        end if;
    set tem = tem + 1;
	if tem>10 then leave label;
	end if;
	end loop label;
end
//
delimiter ;//

call pro1(1,1);
call pro1(0,1);
call pro1(1,0);








drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1()
begin
	Declare i int default 1;
	label:loop
        if mod(i,10) = 0 then
            update /*+no_rewrite*/ t1 set c1 = 100 where c1 = (select min(a1) from t2);
        elseif mod(i,8)=0 then
            update /*+no_rewrite*/ t1 set c1 = 103 where c1 in (select max(a1) from t2 where a1 < 6);
            update /*+no_rewrite*/ t1 set c1 = 105 where c1 > any (select a1 from t2 where a1 > 5 and a1 is not null);
            update /*+no_rewrite*/ t1 set c1 = 106 where c1 <> some (select a1 from t2 where a1 < 5 and a1 is not null);
        elseif mod(i,7)=0 then
            update /*+no_rewrite*/ t1 set c1 = 107 where c1 < all (select a1 from t2 where a1 is not null);
            update /*+no_rewrite*/ t1 set c1 = 108 where c1 = exists (select a1 from t2 group by a1 having max(a1)>5);
            update /*+no_rewrite*/ t1 set c1 = 111 where c1 like (select min(a1) from t2);
        elseif mod(i,5)=0 then
            update /*+no_rewrite*/ t2 set a1 = 0 where a1 = (select /*+no_rewrite*/ c1 from t1 where c1 >= (select min(a1) from t2 where t2.a1=t1.c1));
            update /*+no_rewrite*/ t2 set a1 = 7 where a1 = (select /*+no_rewrite*/ c1 from t1 where c1 in  (select max(a1) from t2 where t2.a1=t1.c1));
            update /*+no_rewrite*/ t2 set a1 = 10 where a1 = any (select /*+no_rewrite*/ c1 from t1 where c1 = any   (select max(a1) from t2 where t2.a1=t1.c1));
        elseif mod(i,3)=0 then
            update /*+no_rewrite*/ t2 set a1 = 10 where a1 = all (select /*+no_rewrite*/ c1 from t1 where c1 = all (select min(a1) from t2 where t2.a1=t1.c1 ));
            update /*+no_rewrite*/ t2 set a1 = 10 where a1 = some (select /*+no_rewrite*/ c1 from t1 where c1 = some (select min(a1) from t2 where t2.a1=t1.c1));
        else
            update /*+no_rewrite*/ t2 set a1 = 20 where exists (select /*+no_rewrite*/ c1 from t1 where  exists  (select min(a1) from t2 where t2.a1=t1.c1));
        end if;
	set i = i + 1;
	if i>=10 then leave label;
	end if;
	end loop label;
end
//
delimiter ;//
call pro1();



drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1()
begin
	Declare i int default 1;
	label:loop
         if mod(i,10) = 0 then
            delete /*+parallel(6) no_rewrite*/ from t1 where c1 < (select min(a1) from t2);
        elseif mod(i,8)=0 then
            delete /*+parallel(6) no_rewrite*/ from t1 where c1 in (select min(a1) from t2);
            delete /*+parallel(6) no_rewrite*/ from t2 where a1 < any (select max(c1) from t1);
            delete /*+parallel(6) no_rewrite*/ from t1 where c1 < all (select avg(a1) from t2);
        elseif mod(i,7)=0 then
            delete /*+parallel(6) no_rewrite*/ from t1 where c1 = exists (select a1 from t2);
            delete /*+parallel(6) no_rewrite*/ from t1 where c1 like (select a1 from t2 where a1 = 4);
        elseif mod(i,5)=0 then
            delete /*+no_rewrite*/ from t2 where a1 in (select /*+no_rewrite*/ c1 from t1 where c1 in  (select max(a1) from t2 where t2.a1=t1.c1));
            delete /*+no_rewrite*/ from t2 where a1 = any (select /*+no_rewrite*/ c1 from t1 where c1 = any   (select max(a1) from t2 where t2.a1=t1.c1));
            delete /*+no_rewrite*/ from t2 where a1 = some (select /*+no_rewrite*/ c1 from t1 where c1 = some (select min(a1) from t2 where t2.a1=t1.c1));
        elseif mod(i,3)=0 then
            delete /*+no_rewrite*/ from t2 where not exists (select /*+no_rewrite*/ c1 from t1 where  not exists  (select max(a1) from t2 where t2.a1=t1.c1));
        else
            delete /*+no_rewrite*/ from t2 where a1 like (select /*+no_rewrite*/ c1 from t1 where c1 like  (select max(a1) from t2 where t2.a1=t1.c1));
        end if;
	set i = i + 1;
	if i>=10 then leave label;
	end if;
	end loop label;
end
//
delimiter ;//
call pro1();



drop database db1;
