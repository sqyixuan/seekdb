drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(aa int,bb int)
begin
Declare i int default 1;
repeat
    if aa = bb then
        select /*+no_rewrite*/ * from t1 where c1 in (select a1 from t2) order by c1;
        select /*+no_rewrite*/ * from t1 where c1 not in (select a1 from t2) order by c1;
        select /*+no_rewrite*/ * from t1 where c1 > any (select a1 from t2) order by c1;
        select /*+no_rewrite*/ * from t1 where c1 > all (select a1 from t2) order by c1;
    elseif aa > bb then
        select /*+no_rewrite*/ * from t1 where c1 <> some (select a1 from t2) order by c1;
        select /*+no_rewrite*/ * from t1 where c1 = exists (select a1 from t2) order by c1;
        select /*+no_rewrite*/ * from t1 where not exists (select max(a1) from t2) order by c1;
        select /*+no_rewrite*/ * from t1 where c1 like (select min(a1) from t2) order by c1;
    else
        select /*+no_rewrite*/ * from t1 where c1 >= (select min(a1) from t2 where t2.a1=t1.c1 group by a1 having min(a1)>3) order by c1;
        select /*+no_rewrite*/ * from t1 where c1 in  (select max(a1) from t2 where t2.a1=t1.c1) group by c1 order by c1 desc limit 1;
        select /*+no_rewrite*/ * from t1 where c1 = any   (select max(a1) from t2 where t2.a1=t1.c1 group by a1 having max(a1) <6 order by a1 desc ) group by c1 order by c1 desc;
        select /*+no_rewrite*/ * from t1 where c1 = all (select min(a1) from t2 where t2.a1=t1.c1 and t2.a1<5 group by a1 order by a1 desc );
        select /*+no_rewrite*/ * from t1 where c1 = some (select min(a1) from t2 where t2.a1=t1.c1) group by c1 having max(c1) < 5 order by c1 desc ;
    end if;
set i = i+1;
until i>=2
end repeat;
end
