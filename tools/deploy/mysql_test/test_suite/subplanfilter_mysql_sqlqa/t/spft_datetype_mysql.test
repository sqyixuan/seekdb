#owner : xiaoyi.xy
#owner group : SQL-SQL2
#tags : subplanfilter, optimizer
#description : 在不同数据类型中测试
#author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--echo  #数据类型
--echo  #char和varchar
create table t1(c1 char(10),c2 varchar(10));
create table t2(a1 char(10),a2 varchar(10));
insert into t1 values('aa','张三');
insert into t1 values('bb','李四');
insert into t1 values('cc','王五');
insert into t1 values('dd','马六');
insert into t1 values('ee','田七');
insert into t2 values('aa','张三');
insert into t2 values('bb','四');
insert into t2 values('cc','王五');
insert into t2 values('dd','六');
insert into t2 values('ee','田七');

--source mysql_test/test_suite/subplanfilter_mysql_sqlqa/include/spft_datetype_mysql.inc

drop table t1;
drop table t2;

--echo  #varbinary、binary
create table t1(c1 varbinary(30),c2 binary(30));
create table t2(a1 varbinary(30),a2 binary(30));
insert into t1 values(101,101),(202,202),(303,303),(404,404),(505,505);
insert into t2 values(101,101),(202,202),(303,303),(505,505);

--source mysql_test/test_suite/subplanfilter_mysql_sqlqa/include/spft_datetype_mysql.inc

drop table t1;
drop table t2;


drop database db1;
