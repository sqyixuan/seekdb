#owner group : SQL-SQL2
#tags : subplanfilter, optimizer
#description : 在不同数据类型中测试
#author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;


--echo  #datetime、timestamp
create table t1(c1 datetime,c2 timestamp);
create table t2(a1 datetime,a2 timestamp);
insert into t1 values('2018-10-01 08:08:00','2018-10-01 08:08:00'),
('2019-10-01 08:08:00','2019-10-01 08:08:00'),
('2020-10-01 08:08:00','2020-10-01 08:08:00'),
('2021-10-01 08:08:00','2021-10-01 08:08:00');
insert into t2 values('2017-10-01 08:08:00','2017-10-01 08:08:00'),
('2019-10-01 08:08:00','2019-10-01 08:08:00'),
('2020-10-01 08:08:00','2020-10-01 08:08:00'),
('2021-10-01 08:08:00','2021-10-01 08:08:00');

--source mysql_test/test_suite/subplanfilter_mysql_sqlqa/include/spft_datetype_mysql.inc

drop table t1;
drop table t2;



--echo  #year、date
create table t1(c1 year , c2 date);
create table t2(a1 year , a2 date);
insert into t1 values('2017','2017-08-08'),('2018','2018-08-08'),('2019','2019-08-08'),('2020','2020-08-08');
insert into t2 values('2017','2017-08-08'),('2018','2018-08-08'),('2019','2019-08-08'),('2020','2020-08-08'),('2021','2021-08-08');

--source mysql_test/test_suite/subplanfilter_mysql_sqlqa/include/spft_datetype_mysql.inc

drop table t1;
drop table t2;




drop database db1;
