#update
update /*+no_rewrite*/ tt1 set c1 = 100 where c1 = (select min(a1) from tt2);
update /*+no_rewrite*/ tt1 set c1 = 101 where c1 < (select max(a1) from tt2 where a1 < 4);
update /*+no_rewrite*/ tt1 set c1 = 102 where c1 > (select min(a1) from tt2 where a1 >= 3);
update /*+no_rewrite*/ tt1 set c1 = 103 where c1 in (select max(a1) from tt2 where a1 < 6);
update /*+no_rewrite*/ tt1 set c1 = 104 where c1 not in (select max(a1) from tt2 where a1 < 6);
update /*+no_rewrite*/ tt1 set c1 = 105 where c1 > any (select a1 from tt2 where a1 > 5 and a1 is not null);
update /*+no_rewrite*/ tt1 set c1 = 106 where c1 <> some (select a1 from tt2 where a1 < 5 and a1 is not null);
update /*+no_rewrite*/ tt1 set c1 = 107 where c1 < all (select a1 from tt2 where a1 is not null);
update /*+no_rewrite*/ tt1 set c1 = 108 where c1 = exists (select a1 from tt2 group by a1 having max(a1)>5);
update /*+no_rewrite*/ tt1 set c1 = 109 where not exists (select max(a1) from tt2);
update /*+no_rewrite*/ tt1 set c1 = 111 where c1 like (select min(a1) from tt2);
update /*+no_rewrite*/ tt1 set c1 = 112 where c1 not like (select min(a1) from tt2);
update /*+no_rewrite*/ tt1 set c1 = 113,c2 = '王五' where c1 > (select max(a1) from tt2 group by a1 having max(a1) > 5);
drop table t1;
drop table t2;
drop table tt1;
drop table tt2;
create table t1(c1 int,c2 varchar(20));
insert into t1 values(1,'张三');
insert into t1 values(2,'李四');
insert into t1 values(3,'王五');
insert into t1 values(4,'马六');
insert into t1 values(5,'田七');
insert into t1 values(7,'腊八');
create table tt1 as select * from t1;
create table t2(a1 int,a2 varchar(20));
insert into t2 values(1,'abc');
insert into t2 values(2,'def');
insert into t2 values(3,'ghi');
insert into t2 values(4,'jkl');
insert into t2 values(5,null);
insert into t2 values(6,'mno');
create table tt2 as select * from t2;
#delete
delete /*+no_rewrite*/ from tt1 where c1 = (select min(a1) from tt2);
delete /*+no_rewrite*/ from tt1 where c1 in (select min(a1) from tt2 group by a1 having min(a1)<10 );
delete /*+no_rewrite*/ from tt2 where a1 > any (select max(c1) from tt1);
delete /*+no_rewrite*/ from tt1 where c1 > all (select a1 from tt2 group by a1 having max(a1) > 5) ;
delete /*+no_rewrite*/ from tt1 where c1 =  some (select a1 from tt2 where a1 > 4 group by a1);
delete /*+no_rewrite*/ from tt1 where c1 = exists (select a1 from tt2);
delete /*+no_rewrite*/ from tt1 where c1 not in (select min(a1) from tt2 group by a1 having min(a1)>3);
delete /*+no_rewrite*/ from tt1 where c1 like (select a1 from tt2 where a1 = 4);
drop table t1;
drop table t2;
drop table tt1;
drop table tt2;
drop database db1;
