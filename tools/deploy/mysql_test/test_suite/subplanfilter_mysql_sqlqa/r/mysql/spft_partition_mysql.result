drop table t1;
drop table t2;
#hash
create table t1(c1 int ,c2 varchar(20)) partition by hash(c1)
(partition p0,
partition p1
);
create table t2(a1 int ,a2 varchar(20)) partition by hash(a1)
(partition p0,
partition p1
);
