drop database if exists db1;
create database db1;
use db1;
#分区
#range
create table t1(c1 int ,c2 varchar(20)) partition by range(c1)
(
partition p0 values less than(4),
partition p1 values less than(maxvalue)
);
create table t2(a1 int ,a2 varchar(20)) partition by range(a1)
(
partition p0 values less than(5),
partition p1 values less than(maxvalue)
);
insert into t1 values(1,'a'),(2,'b'),(3,'c'),(4,'d'),(5,'e'),(6,'f'),(7,'g'),(8,'h');
insert into t2 values(1,'一'),(2,'二'),(3,'三'),(4,'四'),(5,'五'),(6,'六'),(7,'七'),(8,'八'),(9,'九'),(10,'十');
#驱动非相关子查询
select /*+no_rewrite*/ * from t1 partition(p0) where t1.c1 > (select min(a1) from t2 partition(p0)) order by c1;
c1	c2
2	b
3	c
explain basic select /*+no_rewrite*/ * from t1 partition(p0) where t1.c1 > (select min(a1) from t2 partition(p0)) order by c1;
Query Plan
===============================
|ID|OPERATOR             |NAME|
-------------------------------
|0 |SORT                 |    |
|1 |└─SUBPLAN FILTER     |    |
|2 |  ├─TABLE FULL SCAN  |t1  |
|3 |  └─SCALAR GROUP BY  |    |
|4 |    └─TABLE FULL SCAN|t2  |
===============================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      sort_keys([t1.c1, ASC])
  1 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      exec_params_(nil), onetime_exprs_([subquery(1)(:0)]), init_plan_idxs_(nil), use_batch=false
  2 - output([t1.c1], [t1.c2]), filter([t1.c1 > :0]), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  3 - output([T_FUN_MIN(T_FUN_MIN(t2.a1))]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_MIN(T_FUN_MIN(t2.a1))])
  4 - output([T_FUN_MIN(t2.a1)]), filter(nil), rowset=16
      access([t2.a1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true, 
      pushdown_aggregation([T_FUN_MIN(t2.a1)])
select /*+parallel(6) no_rewrite*/ * from t1 partition(p0) where t1.c1 > (select min(a1) from t2 partition(p0)) order by c1;
c1	c2
2	b
3	c
explain basic select /*+parallel(6) no_rewrite*/ * from t1 partition(p0) where t1.c1 > (select min(a1) from t2 partition(p0)) order by c1;
