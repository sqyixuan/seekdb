drop database if exists db1;
create database db1;
use db1;
#驱动相关子查询
create table t1(c1 int,c2 varchar(20));
insert into t1 values(1,'张三');
insert into t1 values(2,'李四');
insert into t1 values(3,'王五');
insert into t1 values(4,'马六');
insert into t1 values(5,'田七');
insert into t1 values(7,'腊八');
create view v_t1 as select * from t1;
create table t2(a1 int,a2 varchar(20));
insert into t2 values(1,'abc');
insert into t2 values(2,'def');
insert into t2 values(3,'ghi');
insert into t2 values(4,'jkl');
insert into t2 values(5,null);
insert into t2 values(6,'mno');
create view v_t2 as select * from t2;
#运算符
select /*+no_rewrite*/ * from v_t1 where c1 > (select min(a1) from v_t2 where v_t2.a1=v_t1.c1) order by c1;
c1	c2
explain basic select /*+no_rewrite*/ * from v_t1 where c1 > (select min(a1) from v_t2 where v_t2.a1=v_t1.c1) order by c1;
Query Plan
===============================
|ID|OPERATOR             |NAME|
-------------------------------
|0 |SORT                 |    |
|1 |└─SUBPLAN FILTER     |    |
|2 |  ├─SUBPLAN SCAN     |v_t1|
|3 |  │ └─TABLE FULL SCAN|t1  |
|4 |  └─SCALAR GROUP BY  |    |
|5 |    └─TABLE FULL SCAN|t2  |
===============================
Outputs & filters:
-------------------------------------
  0 - output([v_t1.c1], [v_t1.c2]), filter(nil), rowset=16
      sort_keys([v_t1.c1, ASC])
  1 - output([v_t1.c1], [v_t1.c2]), filter([v_t1.c1 > subquery(1)]), rowset=16
      exec_params_([v_t1.c1(:0)]), onetime_exprs_(nil), init_plan_idxs_(nil), use_batch=false
  2 - output([v_t1.c1], [v_t1.c2]), filter(nil), rowset=16
      access([v_t1.c1], [v_t1.c2])
  3 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  4 - output([T_FUN_MIN(T_FUN_MIN(t2.a1))]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_MIN(T_FUN_MIN(t2.a1))])
  5 - output([T_FUN_MIN(t2.a1)]), filter([t2.a1 = :0]), rowset=16
      access([t2.a1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true, 
      pushdown_aggregation([T_FUN_MIN(t2.a1)])
select /*+no_rewrite*/ * from v_t1 where c1 >= (select min(a1) from v_t2 where v_t2.a1=v_t1.c1 group by a1 having min(a1)>3) order by c1;
c1	c2
4	马六
