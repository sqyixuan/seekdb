drop trigger if exists tg1;
create trigger tg1
AFTER
delete on t3
for each ROW
BEGIN
delete /*+no_rewrite*/ from t1 where c1 < all (select avg(a1) from t2);
delete /*+no_rewrite*/ from t1 where c1 < (select min(a1) from t2);
END
