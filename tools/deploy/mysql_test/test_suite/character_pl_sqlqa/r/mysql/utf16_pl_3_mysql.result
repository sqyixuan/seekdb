#Environmental cleaning
drop user hjw@'%';
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
#character-3  库默认utf16
set character_set_client =utf8;
set character_set_connection =utf8;
set character_set_results =utf8;
set character_set_database =utf16;
Show variables like 'character%';
Variable_name	Value
character_sets_dir	
character_set_client	utf8mb4
character_set_connection	utf8mb4
character_set_database	utf16
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	utf8mb4
character_set_system	utf8mb4
#character-3-7 异常处理
DROP PROCEDURE if EXISTS PROCEDURE_1;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE division_error CONDITION FOR SQLSTATE '22012';
DECLARE result VARCHAR(50) CHARACTER SET utf8;
DECLARE CONTINUE HANDLER FOR division_error
BEGIN
SET result = '发生错误';
END;
DECLARE EXIT HANDLER FOR SQLEXCEPTION
BEGIN
SET result = '其他异常发生';
END;
BEGIN
SET result = 'ऊँचाई ताप प्रदूषण में बिंदु पचास सेंटीमीटर';
END;
SELECT result;
END //
CALL PROCEDURE_1();
result
ऊँचाई ताप प्रदूषण में बिंदु पचास सेंटीमीटर
