#INSTR
DROP PROCEDURE IF EXISTS PROCEDURE_1;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE v_input VARCHAR(100) DEFAULT 'ຈໍານວນຮຸ້ນຂອງ IV overheat ຖ້າ';
DECLARE v_input1 VARCHAR(100) DEFAULT 'ານວນຮຸ້ນຂອງ ';
DECLARE output INT;
SELECT INSTR(v_input, v_input1) INTO output;
SELECT output;
END ;
/
CALL PROCEDURE_1();
output
