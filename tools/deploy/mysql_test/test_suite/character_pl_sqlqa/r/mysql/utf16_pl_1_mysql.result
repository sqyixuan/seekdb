CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE c1 nchar(37);
DECLARE c2 nchar(37);
SET c1 = 'AUHSERGWRGTEWTR';
SET c2 = '按发生过可达十公分';
IF c1 > c2 THEN
SELECT CONCAT('output:', c1);
ELSEIF c1 < c2 THEN
SELECT CONCAT('output:', c2);
ELSE
SELECT 'output: 相等';
END IF;
END ;
/
CALL PROCEDURE_1();
CONCAT('output:', c2)
