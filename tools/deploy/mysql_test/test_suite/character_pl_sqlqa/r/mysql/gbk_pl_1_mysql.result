#字符串比较=====普通级
DROP PROCEDURE IF EXISTS PROCEDURE_1;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE c1 CHAR(50);
DECLARE c2 CHAR(50);
SET c1 = 'Hello World!';
SET c2 = 'welcome!';
IF c1 > c2 THEN
SELECT CONCAT('output:', c1);
ELSEIF c1 < c2 THEN
SELECT CONCAT('output:', c2);
ELSE
SELECT 'output: 相等';
END IF;
END ;
/
CALL PROCEDURE_1();
CONCAT('output:', c2)
output:welcome!
