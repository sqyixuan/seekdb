#while循环
drop procedure if exists procedure_1;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i varchar(50) charset binary DEFAULT 1;
DECLARE j varchar(50) charset binary DEFAULT 50;
WHILE i < j  DO
select i from dual;
SET i = i + 1;
END WHILE;
COMMIT;
END /
call procedure_1();
i
i
i
i
i
