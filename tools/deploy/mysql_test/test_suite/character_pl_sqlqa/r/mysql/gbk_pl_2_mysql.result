#其他函数
DROP FUNCTION IF exists func_1;
create
function func_1(num1 varchar(150) charset gbk, num2 varchar(150) charset latin1)
returns varchar(150)
DETERMINISTIC
begin
declare res varchar(150);
if(num1 > num2) then
set res = num1;
elseif (num1 < num2) then
set res = num2;
else
set res = num1;
end if;
return res;
end;
/
Warnings:
Warning	5002	Resolve error
SELECT func_1(1,2);
ERROR HY000: Illegal mix of collations (gbk_chinese_ci,IMPLICIT), (latin1_swedish_ci,IMPLICIT)
SELECT func_1('dsagfsa','的赛果发热袜个人');
ERROR HY000: Illegal mix of collations (gbk_chinese_ci,IMPLICIT), (latin1_swedish_ci,IMPLICIT)
SELECT func_1('的赛果发热袜个人','dsagfsa');
ERROR HY000: Illegal mix of collations (gbk_chinese_ci,IMPLICIT), (latin1_swedish_ci,IMPLICIT)
SELECT func_1('的赛果发热袜个人','ああ、それは公式です');
ERROR HY000: Illegal mix of collations (gbk_chinese_ci,IMPLICIT), (latin1_swedish_ci,IMPLICIT)
SELECT func_1('ああ、それは公式です','的赛果发热袜个人');
ERROR HY000: Illegal mix of collations (gbk_chinese_ci,IMPLICIT), (latin1_swedish_ci,IMPLICIT)
DROP FUNCTION IF exists func_1;
