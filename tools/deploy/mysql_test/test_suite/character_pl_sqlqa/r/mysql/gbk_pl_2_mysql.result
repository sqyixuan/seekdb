#character-3-5 udf
#普通函数
drop FUNCTION func_1;
CREATE FUNCTION func_1(bb VARCHAR(150) charset binary)
RETURNS VARCHAR(150)
DETERMINISTIC
BEGIN
RETURN bb;
END ;
/
select func_1('ああ、それは公式です') from dual;
func_1('ああ、それは公式です')
ああ、それは公式です
DROP FUNCTION if EXISTS func_1;
CREATE FUNCTION func_1(bb VARCHAR(150) charset utf16)
RETURNS VARCHAR(150)
DETERMINISTIC
BEGIN
RETURN bb;
END ;
/
select func_1('ああ、それは公式です') from dual;
func_1('ああ、それは公式です')
ああ、それは公式です
DROP FUNCTION if EXISTS func_1;
