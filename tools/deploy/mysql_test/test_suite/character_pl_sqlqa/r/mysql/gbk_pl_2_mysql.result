drop procedure if exists procedure_1;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE i varchar(50) charset gbk DEFAULT '1';
DECLARE j varchar(50) charset binary DEFAULT 'ऊँचाई ताप प्रदूषण में बिंदु पचास सेंटीमीटर';
REPEAT
select i as a from dual;
SET i = i + 1;
UNTIL i > j-i+5 END REPEAT;
END;
/
