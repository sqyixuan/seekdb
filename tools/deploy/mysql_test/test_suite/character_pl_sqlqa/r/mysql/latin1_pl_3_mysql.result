#Environmental cleaning
drop user hjw@'%';
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
#character-5  库默认latin1
set character_set_client =latin1;
set character_set_connection =latin1;
set character_set_results =latin1;
set character_set_database =latin1;
Show variables like 'character%';
Variable_name	Value
character_sets_dir	
character_set_client	latin1
character_set_connection	latin1
character_set_database	latin1
character_set_filesystem	binary
character_set_results	latin1
character_set_server	utf8mb4
character_set_system	utf8mb4
#character-5-7 异常处理
DROP PROCEDURE if EXISTS PROCEDURE_1;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE division_error CONDITION FOR SQLSTATE '22012';
DECLARE result VARCHAR(50) CHARACTER SET utf8;
DECLARE CONTINUE HANDLER FOR division_error
BEGIN
SET result = '发生错误';
END;
DECLARE EXIT HANDLER FOR SQLEXCEPTION
BEGIN
SET result = '其他异常发生';
END;
BEGIN
SET result = 'အပူရှိန်ညစ်ညမ်းမှုကို ထောက်ပြပါ။';
END;
SELECT result;
END //
CALL PROCEDURE_1();
DROP PROCEDURE if EXISTS PROCEDURE_1;
