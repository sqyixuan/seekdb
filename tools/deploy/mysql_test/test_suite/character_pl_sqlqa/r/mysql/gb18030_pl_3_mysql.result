#Environmental cleaning
drop user hjw@'%';
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
#character-6  库默认gb18030
set character_set_client =gb18030;
set character_set_connection =gb18030;
set character_set_results =gb18030;
set character_set_database =gb18030;
Show variables like 'character%';
Variable_name	Value
character_sets_dir	
character_set_client	gb18030
character_set_connection	gb18030
character_set_database	gb18030
character_set_filesystem	binary
character_set_results	gb18030
character_set_server	utf8mb4
character_set_system	utf8mb4
#character-6-7 异常处理
DROP PROCEDURE if EXISTS PROCEDURE_1;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE division_error CONDITION FOR SQLSTATE '22012';
DECLARE result VARCHAR(50) CHARACTER SET utf8;
DECLARE CONTINUE HANDLER FOR division_error
BEGIN
SET result = '发生错误';
END;
DECLARE EXIT HANDLER FOR SQLEXCEPTION
BEGIN
SET result = '其他异常发生';
END;
BEGIN
SET result = 'အမှတ်ငါးဆယ်စင်တီမီတာ';
END;
SELECT result;
END //
ERROR HY000: Incorrect string value
