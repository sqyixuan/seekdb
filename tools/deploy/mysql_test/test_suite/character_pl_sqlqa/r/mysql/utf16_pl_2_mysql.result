#loop循环
drop procedure if exists procedure_1;
create procedure procedure_1()
begin
DECLARE i varchar(50) charset utf16 DEFAULT '1';
DECLARE j varchar(50) charset gb18030 DEFAULT 'ຈໍານວນຮຸ້ນສີ່';
lp : loop
select i as a from dual;
set i = i + 1;
if i > j-i+5 then
leave lp;
end if;
end loop;
end;
/
call procedure_1();
a
a
1
2
