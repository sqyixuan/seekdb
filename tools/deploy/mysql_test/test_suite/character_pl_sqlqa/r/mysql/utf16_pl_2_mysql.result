#其他函数
DROP FUNCTION IF exists func_1;
create
function func_1(num1 varchar(150) charset utf8mb4, num2 varchar(150) charset latin1)
returns varchar(150)
begin
declare res varchar(150);
if(num1 > num2) then
set res = num1;
elseif (num1 < num2) then
set res = num2;
else
set res = num1;
end if;
return res;
end;
/
SELECT func_1(1,2);
func_1(1,2)
2
SELECT func_1('dsagfsa','的赛果发热袜个人');
func_1('dsagfsa','的赛果发热袜个人')
dsagfsa
SELECT func_1('的赛果发热袜个人','dsagfsa');
func_1('的赛果发热袜个人','dsagfsa')
的赛果发热袜个人
SELECT func_1('的赛果发热袜个人','??? ??????? ??????');
func_1('的赛果发热袜个人','??? ??????? ??????')
的赛果发热袜个人
SELECT func_1('??? ??????? ??????','的赛果发热袜个人');
func_1('??? ??????? ??????','的赛果发热袜个人')
????????
DROP FUNCTION IF exists func_1;
