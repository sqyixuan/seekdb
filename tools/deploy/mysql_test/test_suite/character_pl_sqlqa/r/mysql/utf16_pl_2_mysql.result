#while循环
drop procedure if exists procedure_1;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE i varchar(50) charset utf16 DEFAULT '1';
DECLARE j varchar(50) charset binary DEFAULT 'ຈໍານວນຮຸ້ນສີ່';
REPEAT
select i as a from dual;
SET i = i + 1;
UNTIL i > j-i+5 END REPEAT;
END;
/
call procedure_1();
a
a
1
2
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'ຈໍານວນຮຸ້ນສີ່'
