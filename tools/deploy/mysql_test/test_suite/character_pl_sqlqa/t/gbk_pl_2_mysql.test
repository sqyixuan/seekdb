--echo #loop循环
drop procedure if exists procedure_1;
delimiter /;
--error 1366
create procedure procedure_1()
begin
    DECLARE i varchar(50) charset gbk DEFAULT '1';
	DECLARE j varchar(50) charset gb18030 DEFAULT 'ऊँचाई ताप प्रदूषण में बिंदु पचास सेंटीमीटर';
    lp : loop
        select i as a from dual;
        set i = i + 1;
        if i > j-i+5 then
            leave lp;
        end if;
    end loop;
end;
/
delimiter ;/
drop procedure if exists procedure_1;
delimiter /;
--error 1366
create procedure procedure_1()
begin
    DECLARE i varchar(50) charset gbk DEFAULT '1';
