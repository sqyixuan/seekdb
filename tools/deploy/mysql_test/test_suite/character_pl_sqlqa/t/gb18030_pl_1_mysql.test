--echo #CAST
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
--error 1366
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '的是个温柔特务干脆写是12531321';
  DECLARE result VARCHAR(100);
  SET result = CAST(v_input AS CHAR CHARACTER SET utf8);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
--error 1305
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'Fujitsu lo conocía y de repente dijo';
  DECLARE result VARCHAR(100);
  SET result = CAST(v_input AS CHAR CHARACTER SET utf16);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
--error 1366
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'มลพิษ';
  DECLARE result VARCHAR(100);
  SET result = CAST(v_input AS CHAR(150) CHARACTER SET GBK);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
--error 1305
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'sdgrewrip梵蒂冈特温柔';
  DECLARE result VARCHAR(100);
  SET result = CAST(v_input AS CHAR(150) CHARACTER SET GB18030);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '梵蒂冈特温柔';
  DECLARE result VARCHAR(100);
  SET result = CAST(v_input AS CHAR(150) CHARACTER SET latin1);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(50) DEFAULT '梵蒂冈特温柔';
  DECLARE result VARCHAR(300);
  SET result = CAST(v_input AS CHAR(200) CHARACTER SET binary);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();


--echo #字符串连接和截取
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '梵蒂冈特温柔';
  DECLARE v_input1 VARCHAR(100) DEFAULT 'bsgrew4rewgetrewht';
  SELECT v_input || v_input1 output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
