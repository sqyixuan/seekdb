--echo #字符转换
--echo #CONVERT
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '这个世界很美，停下脚步去看一看吧!';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING gbk);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '这个世界很美，停下脚步去看一看吧!';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING gb18030);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '这个世界很美，停下脚步去看一看吧!';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING UTF8);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '这个世界很美，停下脚步去看一看吧!';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING UTF16);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '这个世界很美，停下脚步去看一看吧!';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING latin1);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '这个世界很美，停下脚步去看一看吧!';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING binary);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'dsrgtewtrewtnberwer';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING gb18030);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
--error 1366
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '反对和规范规定实施地方';
