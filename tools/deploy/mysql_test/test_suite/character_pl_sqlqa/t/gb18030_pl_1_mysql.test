--echo #INSTR
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
--error 1366
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'u和但是如果珀尔外国人w 个入围';
  DECLARE v_input1 VARCHAR(100) DEFAULT '???';
  DECLARE output INT;
  SELECT INSTR(v_input, v_input1) INTO output;
  SELECT output;
END ;
/
DELIMITER ;/
--error 1305
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'dsgfeshtrewnhew!';
  DECLARE v_input1 VARCHAR(100) DEFAULT '???';
  DECLARE output INT;
  SELECT INSTR(v_input, v_input1) INTO output;
  SELECT output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();






