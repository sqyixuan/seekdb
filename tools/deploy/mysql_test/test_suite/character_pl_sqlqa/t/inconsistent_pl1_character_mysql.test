--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);


--echo #租户为utf8
purge recyclebin;
let $char_charset = 'utf8';
#--source create_tenant_by_charset.inc
--source conn_tenant.inc


--echo #character-7	  字符集不一致

--echo #character-7-1 租户为默认utf8
--echo #库gbk/表字段latin1/18030
set character_set_client =utf8;
set character_set_connection =utf8;
set character_set_results =utf8;
set character_set_database =gbk;
Show variables like 'character%';


--echo #存储过程=====while循环
drop procedure if exists procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i varchar(50) DEFAULT 1;
DECLARE j varchar(50) DEFAULT 10;
WHILE i < j  DO
SELECT CONVERT('手段和各位和特务' USING latin1) AS c1;
SELECT CONVERT('手段和各位和特务' USING gb18030) AS c2;
SELECT CONVERT('Agar အစစ်ပါ။' USING UTF8) AS c3;
SET i = i + 1;
END WHILE;
COMMIT;
END ;
/
delimiter ;/
call procedure_1();

--echo #repeat循环
drop procedure if exists procedure_1;
delimiter /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE i varchar(50) DEFAULT 1;
DECLARE j varchar(50) DEFAULT 1;
REPEAT
SELECT CONVERT('手段和各位和特务' USING latin1) AS c1;
SELECT CONVERT('手段和各位和特务' USING gb18030) AS c2;
SELECT CONVERT('Agar အစစ်ပါ။' USING UTF8) AS c3;
SET i = i + 1;
UNTIL i > j-i+5 END REPEAT;
END;
/
delimiter ;/
call procedure_1();

--echo #loop循环
drop procedure if exists procedure_1;
delimiter /;
create procedure procedure_1()
begin
DECLARE i varchar(50) DEFAULT 1;
DECLARE j varchar(50) DEFAULT 1;
lp : loop
SELECT CONVERT('手段和各位和特务' USING latin1) AS c1;
SELECT CONVERT('手段和各位和特务' USING gb18030) AS c2;
SELECT CONVERT('Agar အစစ်ပါ။' USING UTF8) AS c3;
set i = i + 1;
if i > j-i+5 then
leave lp;
end if;
end loop;
end;
/
delimiter ;/
call procedure_1();



--echo #触发器======insert
--echo #insert
--error 0,1051
drop table test1;
--error 0,1051
drop table test2;
--error 1360
drop TRIGGER TRIGGER_1;
CREATE table test2(c1 int);
insert into test2 values(6);
select * from test2;
CREATE TABLE test1(
h1 varchar(100),
h2 varchar(100) charset latin1,
h3 varchar(100) charset gb18030);

delimiter /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
insert into test1(h1,h2,h3) values(
'爱人覅我确认',
(SELECT CONVERT('u饿哦通过' USING latin1)),
(SELECT CONVERT('Agar အစစ်ပါ။'  USING gb18030)));
END ;
/
delimiter ;/
update test2 set c1=9;
select * from test1;
drop TRIGGER if EXISTS TRIGGER_1;
delimiter /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
insert into test1(h1,h2,h3) values(
'认为他还让我挺好',
(SELECT CONVERT('shgtrsAgar အစစ်ပါ။' USING latin1)),
(SELECT CONVERT('Agar အစစ်ပါ။ safrs'  USING gb18030)));
END ;
/
delimiter ;/
update test2 set c1=9;
select * from test1;
drop TRIGGER if EXISTS TRIGGER_1;

--echo #触发器======update
delimiter /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
update test1 set h1='的手工缝纫',h2=(SELECT CONVERT('dshbewgt' USING latin1)),h3=(SELECT CONVERT('任务和沙特人'  USING gb18030)) where h1='爱人覅我确认';
END ;
/
delimiter ;/
update test2 set c1=9;
select * from test1;
drop TRIGGER if EXISTS TRIGGER_1;


--echo #触发器======delete
delimiter /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
delete from test1 where h2=(SELECT CONVERT('dshbewgt' USING latin1));
END ;
/
delimiter ;/
update test2 set c1=9;
select * from test1;
drop TRIGGER if EXISTS TRIGGER_1;
delimiter /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
delete from test1 where h2=(SELECT CONVERT(null USING gb18030));
END ;
/
delimiter ;/
--error 1267
update test2 set c1=9;
select * from test1;


--echo #自定义函数
drop FUNCTION if EXISTS func_1;
delimiter /;
CREATE FUNCTION func_1(bb VARCHAR(150) charset latin1)
RETURNS VARCHAR(150)
DETERMINISTIC
BEGIN
  RETURN bb;
END ;
/
delimiter ;/
select func_1(null) from dual;
select func_1('dsahfiwr') from dual;
select func_1('和个人四u额我个人') from dual;
select func_1('Agar အစစ်ပါ။') from dual;


drop FUNCTION if EXISTS func_1;
delimiter /;
CREATE FUNCTION func_1(bb VARCHAR(150) charset latin1)
RETURNS VARCHAR(150)
DETERMINISTIC
BEGIN
  RETURN (select '和个人四u额我个人' from dual);
END ;
/
delimiter ;/
select func_1(null) from dual;
select func_1('dsahfiwr') from dual;
select func_1('和个人四u额我个人') from dual;
select func_1('Agar အစစ်ပါ။') from dual;




