--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);


--echo #character-5  库默认latin1

set character_set_client =latin1;
set character_set_connection =latin1;
set character_set_results =latin1;
set character_set_database =latin1;
Show variables like 'character%';



--echo #character-5-7 异常处理
DROP PROCEDURE if EXISTS PROCEDURE_1;
DELIMITER //;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
    DECLARE division_error CONDITION FOR SQLSTATE '22012';
    DECLARE result VARCHAR(50) CHARACTER SET utf8;
    DECLARE CONTINUE HANDLER FOR division_error
    BEGIN
        SET result = '发生错误';
    END;

    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
        SET result = '其他异常发生';
    END;
    BEGIN
        SET result = 'အပူရှိန်ညစ်ညမ်းမှုကို ထောက်ပြပါ။';
    END;
    SELECT result;
END //
DELIMITER ;//
CALL PROCEDURE_1();
DROP PROCEDURE if EXISTS PROCEDURE_1;
DELIMITER //;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
    DECLARE division_error CONDITION FOR SQLSTATE '22012';
    DECLARE result VARCHAR(50) CHARACTER SET binary;
    DECLARE CONTINUE HANDLER FOR division_error
    BEGIN
        SET result = '发生错误';
    END;

    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
        SET result = '其他异常发生';
    END;
    BEGIN
        SET result = 'အပူရှိန်ညစ်ညမ်းမှုကို ထောက်ပြပါ။';
    END;
    SELECT result;
END //
DELIMITER ;//
CALL PROCEDURE_1();
DROP PROCEDURE if EXISTS PROCEDURE_1;
DELIMITER //;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
    DECLARE division_error CONDITION FOR SQLSTATE '22012';
    DECLARE result VARCHAR(50) CHARACTER SET utf16;
    DECLARE CONTINUE HANDLER FOR division_error
    BEGIN
        SET result = '发生错误';
    END;

    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
        SET result = '其他异常发生';
    END;
    BEGIN
        SET result = 'အပူရှိန်ညစ်ညမ်းမှုကို ထောက်ပြပါ။';
    END;
    SELECT result;
END //
DELIMITER ;//
CALL PROCEDURE_1();
DROP PROCEDURE if EXISTS PROCEDURE_1;
DELIMITER //;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
    DECLARE division_error CONDITION FOR SQLSTATE '22012';
    DECLARE result VARCHAR(50) CHARACTER SET gbk;
    DECLARE CONTINUE HANDLER FOR division_error
    BEGIN
        SET result = '发生错误';
    END;

    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
        SET result = '其他异常发生';
    END;
    BEGIN
        SET result = 'အပူရှိန်ညစ်ညမ်းမှုကို ထောက်ပြပါ။';
    END;
    SELECT result;
END //
DELIMITER ;//
--error 1366
CALL PROCEDURE_1();
DROP PROCEDURE if EXISTS PROCEDURE_1;
DELIMITER //;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
    DECLARE division_error CONDITION FOR SQLSTATE '22012';
    DECLARE result VARCHAR(50) CHARACTER SET latin1;
    DECLARE CONTINUE HANDLER FOR division_error
    BEGIN
        SET result = '发生错误';
    END;

    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
        SET result = '其他异常发生';
    END;
    BEGIN
        SET result = 'အပူရှိန်ညစ်ညမ်းမှုကို ထောက်ပြပါ။';
    END;
    SELECT result;
END //
DELIMITER ;//
CALL PROCEDURE_1();
DROP PROCEDURE if EXISTS PROCEDURE_1;
DELIMITER //;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
    DECLARE division_error CONDITION FOR SQLSTATE '22012';
    DECLARE result VARCHAR(50) CHARACTER SET gb18030;
    DECLARE CONTINUE HANDLER FOR division_error
    BEGIN
        SET result = '发生错误';
    END;

    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
        SET result = '其他异常发生';
    END;
    BEGIN
        SET result = 'အပူရှိန်ညစ်ညမ်းမှုကို ထောက်ပြပါ။';
    END;
    SELECT result;
END //
DELIMITER ;//
CALL PROCEDURE_1();
DROP PROCEDURE if EXISTS PROCEDURE_1;





--echo #character-5-8   游标
DROP PROCEDURE if EXISTS PROCEDURE_2;
--error 0,1051
drop table test1;
CREATE table test1(id int,name VARCHAR(150) charset binary);
insert into test1 values(1,'都是给微软');
select * from test1;
DELIMITER //;
CREATE PROCEDURE PROCEDURE_2()
BEGIN
DECLARE done BOOL DEFAULT FALSE;
DECLARE emp_id INT;
DECLARE emp_name VARCHAR(150);
DECLARE cur CURSOR FOR SELECT id, name FROM test1;
DECLARE EXIT HANDLER FOR NOT FOUND SET done = TRUE;
OPEN cur;
read_loop: LOOP
    FETCH cur INTO emp_id, emp_name;
    IF done THEN
        LEAVE read_loop;
    END IF;
    SELECT emp_id, emp_name;
END LOOP;
CLOSE cur;
END //
DELIMITER ;//
CALL PROCEDURE_2();
DROP PROCEDURE if EXISTS PROCEDURE_2;
DROP table if EXISTS test1;
CREATE table test1(id int,name VARCHAR(150) charset utf16);
insert into test1 values(1,'反对和特瑞特');
select * from test1;
DELIMITER //;
CREATE PROCEDURE PROCEDURE_2()
BEGIN
DECLARE done BOOL DEFAULT FALSE;
DECLARE emp_id INT;
DECLARE emp_name VARCHAR(150);
DECLARE cur CURSOR FOR SELECT id, name FROM test1;
DECLARE EXIT HANDLER FOR NOT FOUND SET done = TRUE;
OPEN cur;
read_loop: LOOP
    FETCH cur INTO emp_id, emp_name;
    IF done THEN
        LEAVE read_loop;
    END IF;
    SELECT emp_id, emp_name;
END LOOP;
CLOSE cur;
END //
DELIMITER ;//
CALL PROCEDURE_2();
DROP PROCEDURE if EXISTS PROCEDURE_2;
DROP table if EXISTS test1;
CREATE table test1(id int,name VARCHAR(150) charset gbk);
--error 1366
insert into test1 values(1,'အပူရှိန်ညစ်ညမ်းမှုကို ထောက်ပြပါ။');
insert into test1 values(1,'dsjhtfdjgd');
select * from test1;
DELIMITER //;
CREATE PROCEDURE PROCEDURE_2()
BEGIN
DECLARE done BOOL DEFAULT FALSE;
DECLARE emp_id INT;
DECLARE emp_name VARCHAR(150);
DECLARE cur CURSOR FOR SELECT id, name FROM test1;
DECLARE EXIT HANDLER FOR NOT FOUND SET done = TRUE;
OPEN cur;
read_loop: LOOP
    FETCH cur INTO emp_id, emp_name;
    IF done THEN
        LEAVE read_loop;
    END IF;
    SELECT emp_id, emp_name;
END LOOP;
CLOSE cur;
END //
DELIMITER ;//
CALL PROCEDURE_2();
DROP PROCEDURE if EXISTS PROCEDURE_2;
DROP table if EXISTS test1;
CREATE table test1(id int,name VARCHAR(150) charset latin1);
insert into test1 values(1,'dsjhtfdjgd');
select * from test1;
DELIMITER //;
CREATE PROCEDURE PROCEDURE_2()
BEGIN
DECLARE done BOOL DEFAULT FALSE;
DECLARE emp_id INT;
DECLARE emp_name VARCHAR(150);
DECLARE cur CURSOR FOR SELECT id, name FROM test1;
DECLARE EXIT HANDLER FOR NOT FOUND SET done = TRUE;
OPEN cur;
read_loop: LOOP
    FETCH cur INTO emp_id, emp_name;
    IF done THEN
        LEAVE read_loop;
    END IF;
    SELECT emp_id, emp_name;
END LOOP;
CLOSE cur;
END //
DELIMITER ;//
CALL PROCEDURE_2();
DROP PROCEDURE if EXISTS PROCEDURE_2;
DROP table if EXISTS test1;
CREATE table test1(id int,name VARCHAR(150) charset gb18030);
insert into test1 values(1,'第三个特认为他');
select * from test1;
DELIMITER //;
CREATE PROCEDURE PROCEDURE_2()
BEGIN
DECLARE done BOOL DEFAULT FALSE;
DECLARE emp_id INT;
DECLARE emp_name VARCHAR(150);
DECLARE cur CURSOR FOR SELECT id, name FROM test1;
DECLARE EXIT HANDLER FOR NOT FOUND SET done = TRUE;
OPEN cur;
read_loop: LOOP
    FETCH cur INTO emp_id, emp_name;
    IF done THEN
        LEAVE read_loop;
    END IF;
    SELECT emp_id, emp_name;
END LOOP;
CLOSE cur;
END //
DELIMITER ;//
CALL PROCEDURE_2();
DROP PROCEDURE if EXISTS PROCEDURE_2;
DROP table if EXISTS test1;






