--echo #character-5-2   存储过程
--echo #while循环
drop procedure if exists procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i varchar(50) charset binary DEFAULT 1;
DECLARE j varchar(50) charset binary DEFAULT 50;
WHILE i < j  DO
select i from dual;
SET i = i + 1;
END WHILE;
COMMIT;
END /
delimiter ;/
call procedure_1();
drop procedure if exists procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i varchar(50) charset utf16 DEFAULT 1;
DECLARE j varchar(50) charset utf16 DEFAULT 50;
WHILE i < j  DO
select i from dual;
SET i = i + 1;
END WHILE;
COMMIT;
END /
delimiter ;/
call procedure_1();
drop procedure if exists procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i varchar(50) charset gbk DEFAULT 1;
DECLARE j varchar(50) charset gbk DEFAULT 50;
WHILE i < j  DO
select i from dual;
SET i = i + 1;
END WHILE;
COMMIT;
END /
delimiter ;/
call procedure_1();
drop procedure if exists procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i varchar(50) charset latin1 DEFAULT 1;
DECLARE j varchar(50) charset latin1 DEFAULT 50;
WHILE i < j  DO
select i from dual;
SET i = i + 1;
END WHILE;
COMMIT;
END /
delimiter ;/
call procedure_1();
drop procedure if exists procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i varchar(50) charset gb18030 DEFAULT 1;
DECLARE j varchar(50) charset gb18030 DEFAULT 50;
WHILE i < j  DO
select i from dual;
SET i = i + 1;
END WHILE;
COMMIT;
END /
delimiter ;/
call procedure_1();
drop procedure if exists procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i varchar(50) charset latin1 DEFAULT 'asas';
DECLARE j varchar(50) charset latin1 DEFAULT 'အမြင့်ငါးဆယ်စင်တီမီတာတွင်';
WHILE i < j  DO
select i from dual;
SET i = i + 1;
END WHILE;
COMMIT;
END /
delimiter ;/
--error 1406
call procedure_1();
drop procedure if exists procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i varchar(50) charset utf8 DEFAULT 'asas';
DECLARE j varchar(50) charset latin1 DEFAULT 'အမြင့်ငါးဆယ်စင်တီမီတာတွင်';
WHILE i < j  DO
select i from dual;
SET i = i + 1;
