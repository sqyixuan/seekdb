delimiter /;
create procedure procedure_1()
begin
    DECLARE i varchar(50) charset latin1 DEFAULT '1';
	DECLARE j varchar(50) charset latin1 DEFAULT 'အမြင့်ငါးဆယ်စင်တီမီတာတွင်';
    lp : loop
        select i as a from dual;
