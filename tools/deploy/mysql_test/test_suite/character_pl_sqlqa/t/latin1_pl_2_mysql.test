BEGIN
DECLARE i varchar(50) charset latin1 DEFAULT '1';
DECLARE j varchar(50) charset gb18030 DEFAULT '的沙特人';
REPEAT
select i as a from dual;
SET i = i + 1;
UNTIL i > j-i+5 END REPEAT;
END;
