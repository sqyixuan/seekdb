--echo #while循环
drop procedure if exists procedure_1;
delimiter /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE i varchar(50) charset latin1 DEFAULT '1';
DECLARE j varchar(50) charset binary DEFAULT 'အမြင့်ငါးဆယ်စင်တီမီတာတွင်';
REPEAT
select i as a from dual;
SET i = i + 1;
UNTIL i > j-i+5 END REPEAT;
END;
/
delimiter ;/
--error 1406
call procedure_1();
drop procedure if exists procedure_1;
delimiter /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE i varchar(50) charset latin1 DEFAULT '1';
DECLARE j varchar(50) charset utf16 DEFAULT 'အမြင့်ငါးဆယ်စင်တီမီတာတွင်';
REPEAT
select i as a from dual;
SET i = i + 1;
UNTIL i > j-i+5 END REPEAT;
END;
/
delimiter ;/
--error 1406
call procedure_1();
drop procedure if exists procedure_1;
delimiter /;
