--echo #character-5-3 触发器
--echo #insert
--error 0,1051
drop table test1;
--error 0,1051
drop table test2;
--error 1360
drop TRIGGER TRIGGER_1;
CREATE table test2(c1 int);
insert into test2 values(6);
select * from test2;
CREATE TABLE test1(
h1 varchar(100),
h2 varchar(100) charset binary,
h3 varchar(100) charset utf16,
h4 varchar(100) charset gbk,
h5 varchar(100) charset latin1,
h6 varchar(100) charset gb18030);

delimiter /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
insert into test1(h1,h2,h3,h6) values(
'Ah, itu resmi',
'Ah, waa rasmi',
'ah ????????????',
'ああ、それは公式です');
END ;
/
delimiter ;/
update test2 set c1=9;
select * from test1;
drop TRIGGER if EXISTS TRIGGER_1;
delimiter /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
insert into test1(h4) values('Ah, ew ferm? ye');
END ;
/
delimiter ;/
update test2 set c1=9;
drop TRIGGER if EXISTS TRIGGER_1;
delimiter /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
insert into test1(h5) values('အမြင့်ငါးဆယ်စင်တီမီတာတွင်');
END ;
/
delimiter ;/
update test2 set c1=9;
drop TRIGGER if EXISTS TRIGGER_1;


--echo #update
select * from test1;
select * from test2;
delimiter /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
update test1 set h5='dsgfagsd' where h5 is null;
update test1 set h4='aaaabaaa' where h4 is null;
END ;
/
delimiter ;/
update test2 set c1=4;
select * from test1;
drop TRIGGER if EXISTS TRIGGER_1;
delimiter /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
update test1 set
h1='反对各五个发热我个人问题',
h2='dsgferthert ',
h3='Աղտոտվածություն',
h6='အမြင့်ငါးဆယ်စင်တီမီတာတွင်';
END ;
/
delimiter ;/
update test2 set c1=4;
select * from test1;
drop TRIGGER if EXISTS TRIGGER_1;


--echo #delete
--error 0,1051
drop table test1;
--error 0,1051
drop table test2;
--error 1360
drop TRIGGER TRIGGER_1;
CREATE table test2(c1 int);
insert into test2 values(6);
select * from test2;
CREATE TABLE test1(
h1 varchar(100),
h2 varchar(100) charset binary,
h3 varchar(100) charset utf16,
h6 varchar(100) charset gb18030);
insert into test1(h1,h2,h3,h6) values(
'Ah, itu resmi',
'Ah, waa rasmi',
'ah ????????????',
'ああ、それは公式です');
select * from test1;
delimiter /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
	DELETE from test1 where h6='ああ、それは公式です';
END ;
/
delimiter ;/
update test2 set c1=4;
select * from test1;
drop TRIGGER if EXISTS TRIGGER_1;
drop table test1;
drop table test2;



--echo #character-5-5 udf
--echo #普通函数
--error 0,1305
drop FUNCTION func_1;
delimiter /;
CREATE FUNCTION func_1(bb VARCHAR(150) charset binary)
RETURNS VARCHAR(150)
DETERMINISTIC
BEGIN
  RETURN bb;
END ;
/
delimiter ;/
select func_1('အမြင့်ငါးဆယ်စင်တီမီတာတွင်') from dual;
DROP FUNCTION if EXISTS func_1;
delimiter /;
CREATE FUNCTION func_1(bb VARCHAR(150) charset utf16)
RETURNS VARCHAR(150)
DETERMINISTIC
BEGIN
  RETURN bb;
END ;
/
delimiter ;/
select func_1('官方可有苦头') from dual;
DROP FUNCTION if EXISTS func_1;
delimiter /;
CREATE FUNCTION func_1(bb VARCHAR(150) charset gbk)
RETURNS VARCHAR(150)
DETERMINISTIC
BEGIN
  RETURN bb;
END ;
/
delimiter ;/
select func_1('官方可有苦头') from dual;
DROP FUNCTION if EXISTS func_1;
delimiter /;
CREATE FUNCTION func_1(bb VARCHAR(150) charset latin1)
RETURNS VARCHAR(150)
DETERMINISTIC
BEGIN
  RETURN bb;
END ;
/
delimiter ;/
select func_1('官方可有苦头') from dual;
DROP FUNCTION if EXISTS func_1;
delimiter /;
CREATE FUNCTION func_1(bb VARCHAR(150) charset gb18030)
RETURNS VARCHAR(150)
DETERMINISTIC
BEGIN
  RETURN bb;
END ;
/
delimiter ;/
select func_1('官方可有苦头') from dual;


--echo #其他函数
DROP FUNCTION IF exists func_1;
delimiter /;
create
        function func_1(num1 varchar(150) charset utf8mb4, num2 varchar(150) charset latin1)
        returns varchar(150)
        DETERMINISTIC
    begin
        declare res varchar(150);
        if(num1 > num2) then
            set res = num1;
        elseif (num1 < num2) then
            set res = num2;
        else
            set res = num1;
        end if;
        return res;
    end;
   /
delimiter ;/
SELECT func_1(1,2);
SELECT func_1('dsagfsa','的赛果发热袜个人');
SELECT func_1('的赛果发热袜个人','dsagfsa');
SELECT func_1('的赛果发热袜个人','အမြင့်ငါးဆယ်စင်တီမီတာတွင် ');
SELECT func_1('အမြင့်ငါးဆယ်စင်တီမီတာတွင်','的赛果发热袜个人');
DROP FUNCTION IF exists func_1;







