--echo #loop循环
drop procedure if exists procedure_1;
delimiter /;
create procedure procedure_1()
begin
    DECLARE i varchar(50) charset latin1 DEFAULT '1';
	DECLARE j varchar(50) charset gb18030 DEFAULT '鬼iu哦百谷虎';
    lp : loop
        select i as a from dual;
        set i = i + 1;
        if i > j-i+5 then
            leave lp;
        end if;
    end loop;
end;
/
delimiter ;/
call procedure_1();
drop procedure if exists procedure_1;
delimiter /;
create procedure procedure_1()
begin
    DECLARE i varchar(50) charset latin1 DEFAULT '1';
	DECLARE j varchar(50) charset binary DEFAULT '胡哈哈';
    lp : loop
        select i as a from dual;
        set i = i + 1;
        if i > j-i+5 then
            leave lp;
        end if;
    end loop;
end;
/
delimiter ;/
call procedure_1();
drop procedure if exists procedure_1;
delimiter /;
create procedure procedure_1()
begin
    DECLARE i varchar(50) charset latin1 DEFAULT '1';
	DECLARE j varchar(50) charset utf16 DEFAULT 'အမြင့်ငါးဆယ်စင်တီမီတာတွင်';
    lp : loop
        select i as a from dual;
        set i = i + 1;
        if i > j-i+5 then
            leave lp;
        end if;
    end loop;
end;
/
delimiter ;/
--error 1406
call procedure_1();
drop procedure if exists procedure_1;
delimiter /;
