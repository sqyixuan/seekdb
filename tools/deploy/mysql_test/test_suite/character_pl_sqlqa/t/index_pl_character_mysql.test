--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);


--echo #character-8	  约束和索引

--echo #character-8-2 索引
--echo #字符集为gbk
SELECT @@character_set_connection;
set names gbk;
SELECT @@character_set_connection;
Show variables like 'character%';

--error 0,1051
drop table test1;
CREATE table test1(
id bigint(10) AUTO_INCREMENT,
h1 varchar(150) charset utf8,
h2 varchar(150) charset GBK,
h3 varchar(150) charset GB18030,
h4 varchar(150) charset latin1 DEFAULT 'sdgewr',
h5 varchar(150) charset binary ,
CHECK(h5 > 2),PRIMARY KEY(id,h1));
SHOW FULL COLUMNS FROM test1;
CREATE UNIQUE index index_1 on test1(h1);
CREATE index index_2 on test1(h2);
CREATE index index_3 on test1(h1,h2,h3,h4,h5);
CREATE index index_4 on test1(h4 asc);

drop procedure if exists procedure_1;
DELIMITER /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i int DEFAULT 1;
WHILE i < 2  DO
insert into test1(h1,h2,h3,h5) values('sfasas','asfsafdsa','asfsagsa','5123');
SET i = i + 1;
END WHILE;
COMMIT;
END /
DELIMITER ;/
call procedure_1();
select * from test1 order by id asc;
--error 1062
call procedure_1();
drop procedure if exists procedure_1;
DELIMITER /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i int DEFAULT 1;
WHILE i < 2  DO
insert into test1(h1,h2,h3,h5) values(CONVERT('राति जकाँ' USING GBK),CONVERT('राति जकाँ' USING latin1),CONVERT('但是国会大厦' USING binary),LENGTH(CONVERT('多少股份我sfs' USING utf8)));
SET i = i + 1;
END WHILE;
COMMIT;
END /
DELIMITER ;/
call procedure_1();
select * from test1 order by id asc;
drop procedure if exists procedure_1;
DELIMITER /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i int DEFAULT 1;
WHILE i < 2  DO
insert into test1(h1,h2,h3,h5) values(CONVERT('राति जकाँ' USING utf16),CONVERT('fdsgds' USING latin1),CONVERT('大师傅撒' USING binary),LENGTH(CONVERT('多少股份我sfs' USING GBK)));
SET i = i + 1;
END WHILE;
COMMIT;
END /
DELIMITER ;/
--error 1062
call procedure_1();
select * from test1 order by id asc;
drop procedure if exists procedure_1;
DELIMITER /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i int DEFAULT 1;
WHILE i < 2  DO
update test1 set h1=CONVERT('रातिdsf जकाँ' USING utf16),h2=CONVERT('fdsgds' USING latin1),h4='zsdf',h5='123' where id=1;
SET i = i + 1;
END WHILE;
COMMIT;
END /
DELIMITER ;/
call procedure_1();
select * from test1 order by id asc;
drop procedure if exists procedure_1;
DELIMITER /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i int DEFAULT 1;
WHILE i < 2  DO
update test1 set h1=CONVERT('रातिdsf जकाँ' USING gb18030),h2=CONVERT('fdsgds' USING gb18030),h4=CONVERT('zsdf' USING gb18030),h5='123' where id=1;
SET i = i + 1;
END WHILE;
COMMIT;
END /
DELIMITER ;/
call procedure_1();
select * from test1 order by id asc;
drop procedure if exists procedure_1;
DELIMITER /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i int DEFAULT 1;
WHILE i < 2  DO
DELETE from test1 where h2=CONVERT('fdsgds' USING gb18030);
SET i = i + 1;
END WHILE;
COMMIT;
END /
DELIMITER ;/
--error 1267
call procedure_1();
select * from test1 order by id asc;


--echo #触发器
--error 0,1360
DROP TRIGGER TRIGGER_1;
drop table if EXISTS test1;
--error 0,1051
drop table test2;
CREATE table test2(c1 int);
insert into test2 values(6);
select * from test2;
CREATE table test1(
id bigint(10) AUTO_INCREMENT,
h1 varchar(150) charset utf8,
h2 varchar(150) charset GBK ,
h3 varchar(150) charset GB18030,
h4 varchar(150) charset latin1 DEFAULT 'sdgewr',
h5 varchar(150) charset binary ,
CHECK(h5 > 2),PRIMARY KEY(id,h1));
SHOW FULL COLUMNS FROM test1;
CREATE UNIQUE index index_1 on test1(h1);
CREATE index index_2 on test1(h2);
CREATE index index_3 on test1(h1,h2,h3,h4,h5);
CREATE index index_4 on test1(h4 asc);
select * from test1 order by id asc;

--echo #insert
DELIMITER /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
insert into test1(h1,h2,h3,h5) values(CONVERT('राति जकाँ' USING utf8),CONVERT('राति जकाँ' USING utf8),CONVERT('但是国会大厦' USING utf8),LENGTH(CONVERT('多少股份我sfs' USING utf8)));
END ;
/
DELIMITER ;/
update test2 set c1=9;
select * from test1 order by id asc;
DROP TRIGGER if EXISTS TRIGGER_1;
DELIMITER /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
insert into test1(h1,h2,h3,h5) values(CONVERT('dsfds' USING GBK),CONVERT('ccccc' USING GBK),CONVERT('fff' USING GBK),LENGTH(CONVERT('dssa' USING GBK)));
END ;
/
DELIMITER ;/
update test2 set c1=9;
select * from test1 order by id asc;
DROP TRIGGER if EXISTS TRIGGER_1;
DELIMITER /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
insert into test1(h1,h2,h3,h5) values(CONVERT('ggg' USING latin1),CONVERT('hhhh' USING latin1),CONVERT('rrr' USING latin1),LENGTH(CONVERT('qqqq' USING latin1)));
END ;
/
DELIMITER ;/
update test2 set c1=9;
select * from test1 order by id asc;

--echo #update
DROP TRIGGER if EXISTS TRIGGER_1;
DELIMITER /;
--error 1366
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
update test1 set h1=CONVERT('राति 多少给多少' USING gbk),h2=CONVERT('的是个温柔' USING gb18030),h3=CONVERT('fdshgesr' USING BINARY),h5=LENGTH(CONVERT('21343' USING latin1)) where id=2;
END ;
/
DELIMITER ;/
update test2 set c1=9;
select * from test1 order by id asc;

DROP TRIGGER if EXISTS TRIGGER_1;
DELIMITER /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
update test1 set h1=CONVERT('21643' USING gbk),h2=CONVERT('dszfdsf' USING gb18030),h3=CONVERT('fdshgesr' USING BINARY),h5=LENGTH(CONVERT('21343' USING latin1)) where id=2;
END ;
/
DELIMITER ;/
update test2 set c1=9;
select * from test1 order by id asc;

--echo #delete
DROP TRIGGER if EXISTS TRIGGER_1;
DELIMITER /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
DELETE from test1 where h1=CONVERT('21643' USING utf8);
DELETE from test1 where h3=CONVERT('fdshgesr' USING utf8);
END ;
/
DELIMITER ;/
update test2 set c1=9;
select * from test1 order by id asc;
DROP TRIGGER if EXISTS TRIGGER_1;
DELIMITER /;
CREATE TRIGGER TRIGGER_1 BEFORE UPDATE ON test2
FOR EACH ROW
BEGIN
DELETE from test1 where h4=CONVERT('sdgewr' USING gbk);
END ;
/
DELIMITER ;/
--error 1267
update test2 set c1=9;
select * from test1 order by id asc;

--echo #字符集为latin1
SELECT @@character_set_connection;
set names latin1;
SELECT @@character_set_connection;
Show variables like 'character%';

