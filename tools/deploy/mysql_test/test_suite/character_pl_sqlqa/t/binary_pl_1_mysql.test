--echo #字符转换
--echo #CONVERT
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '这个世界很美，停下脚步去看一看吧!';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING gbk);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '这个世界很美，停下脚步去看一看吧!';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING gb18030);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '这个世界很美，停下脚步去看一看吧!';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING UTF8);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '这个世界很美，停下脚步去看一看吧!';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING UTF16);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '这个世界很美，停下脚步去看一看吧!';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING latin1);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT '这个世界很美，停下脚步去看一看吧!';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING binary);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'IV มีความร้อนมากเกินไปกี่หุ้นถ้า';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING UTF8);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'IV มีความร้อนมากเกินไปกี่หุ้นถ้า';
  DECLARE result VARCHAR(100);
  SET result = CONVERT(v_input USING UTF8);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();


--echo #CAST
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'IV มีความร้อนมากเกินไปกี่หุ้นถ้า';
  DECLARE result VARCHAR(100);
  SET result = CAST(v_input AS CHAR CHARACTER SET utf8);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'IV มีความร้อนมากเกินไปกี่หุ้นถ้า';
  DECLARE result VARCHAR(100);
  SET result = CAST(v_input AS CHAR CHARACTER SET utf16);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'IV มีความร้อนมากเกินไปกี่หุ้นถ้า';
  DECLARE result VARCHAR(100);
  SET result = CAST(v_input AS CHAR(150) CHARACTER SET GBK);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'IV มีความร้อนมากเกินไปกี่หุ้นถ้า';
  DECLARE result VARCHAR(100);
  SET result = CAST(v_input AS CHAR(150) CHARACTER SET GB18030);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(150) DEFAULT 'IV มีความร้อนมากเกินไปกี่หุ้นถ้า';
  DECLARE result VARCHAR(100);
  SET result = CAST(v_input AS CHAR(150) CHARACTER SET latin1);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(150) DEFAULT '然后将而犹太人';
  DECLARE result VARCHAR(150);
  SET result = CAST(v_input AS CHAR(400) CHARACTER SET binary);
  SELECT CONCAT('转换后的字符串为: ', result) AS output;
END ;
/
DELIMITER ;/
--error 1406
CALL PROCEDURE_1();




--echo #字符串连接和截取
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'IV มีความร้อนมากเกินไปกี่หุ้นถ้า';
  DECLARE v_input1 VARCHAR(100) DEFAULT 'IV 的身份感到十分';
  SELECT v_input || v_input1 output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'safgasgfasgf!';
  DECLARE v_input1 VARCHAR(100) DEFAULT '萨弗迪挖坟挖坟';
  SELECT v_input || v_input1 output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'มีความร้อนมากเกินไปกี่หุ้นถ้า';
  DECLARE v_input1 VARCHAR(100) DEFAULT '萨弗迪挖坟挖坟';
  SELECT v_input || v_input1 output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();



--echo #CONCAT
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'มีความร้อนมากเกินไปกี่หุ้นถ้า';
  DECLARE v_input1 VARCHAR(100) DEFAULT '萨弗迪挖坟挖坟';
  SELECT CONCAT(v_input,v_input1) output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'asdfsafsa!';
  DECLARE v_input1 VARCHAR(100) DEFAULT '萨弗迪挖坟挖坟';
  SELECT CONCAT(v_input,v_input1) output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'asdfsafsa!';
  DECLARE v_input1 VARCHAR(100) DEFAULT '萨弗迪挖坟挖坟';
  SELECT CONCAT(CAST(v_input AS CHAR(150) CHARACTER SET gbk),v_input1) output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'asdfsafsa!';
  DECLARE v_input1 VARCHAR(100) DEFAULT '萨弗迪挖坟挖坟';
  SELECT CONCAT(CAST(v_input AS CHAR(150) CHARACTER SET latin1),v_input1) output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();


--echo #SUBSTR
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'asdfsafsa!';
  SELECT SUBSTR(CAST(v_input AS CHAR(150) CHARACTER SET latin1),3) output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'มีความร้อนมากเกินไปกี่หุ้นถ้า';
  SELECT SUBSTR(v_input,3) output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'IV को कति सेयर ओभर हिट भएमा';
  SELECT SUBSTR(v_input,3) output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();


--echo #INSTR
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'IV को कति सेयर ओभर हिट भएमा';
  DECLARE v_input1 VARCHAR(100) DEFAULT 'IV';
  DECLARE output INT;
  SELECT INSTR(v_input, v_input1) INTO output;
  SELECT output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
  DECLARE v_input VARCHAR(100) DEFAULT 'dsgfeshtrewnhew!';
  DECLARE v_input1 VARCHAR(100) DEFAULT '???';
  DECLARE output INT;
  SELECT INSTR(v_input, v_input1) INTO output;
  SELECT output;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();






