grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);


--echo #character-2  库默认binary


set character_set_client =binary;
set character_set_connection =binary;
set character_set_results =binary;
set character_set_database =binary;
Show variables like 'character%';



--echo #character-2-1 其他 pl
--echo #字符串比较=====普通级
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE c1 CHAR(50);
DECLARE c2 CHAR(50);
SET c1 = 'Hello World!';
SET c2 = 'welcome!';
IF c1 > c2 THEN
SELECT CONCAT('output:', c1);
ELSEIF c1 < c2 THEN
SELECT CONCAT('output:', c2);
ELSE
SELECT 'output: 相等';
END IF;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE c1 VARCHAR(50);
DECLARE c2 VARCHAR(50);
SET c1 = 'Hello World!';
SET c2 = 'Hello World!';
IF c1 > c2 THEN
SELECT CONCAT('output:', c1);
ELSEIF c1 < c2 THEN
SELECT CONCAT('output:', c2);
ELSE
SELECT 'output: 相等';
END IF;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE c1 CHAR(50);
DECLARE c2 VARCHAR(50);
SET c1 = 'Hello World!';
SET c2 = 'welcome!';
IF c1 > c2 THEN
SELECT CONCAT('output:', c1);
ELSEIF c1 < c2 THEN
SELECT CONCAT('output:', c2);
ELSE
SELECT 'output: 相等';
END IF;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE c1 CHAR(100);
DECLARE c2 VARCHAR(100);
SET c1 = 'Hello World!';
SET c2 = 'IV มีความร้อนมากเกินไปกี่หุ้นถ้า';
IF c1 > c2 THEN
SELECT CONCAT('output:', c1);
ELSEIF c1 < c2 THEN
SELECT CONCAT('output:', c2);
ELSE
SELECT 'output: 相等';
END IF;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();
DROP PROCEDURE IF EXISTS PROCEDURE_1;
DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE c1 CHAR(100);
DECLARE c2 VARCHAR(100);
SET c1 = 'IV มีความร้อนมากเกินไปกี่หุ้นถ้า';
SET c2 = '但是风格是个人';
IF c1 > c2 THEN
SELECT CONCAT('output:', c1);
ELSEIF c1 < c2 THEN
SELECT CONCAT('output:', c2);
ELSE
SELECT 'output: 相等';
END IF;
END ;
/
DELIMITER ;/
CALL PROCEDURE_1();


