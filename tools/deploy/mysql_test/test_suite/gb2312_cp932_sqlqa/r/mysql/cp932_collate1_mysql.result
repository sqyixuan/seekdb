DROP database testob;
create database testob;
### show create database testob;
use testob;
drop table cast_test_table2;
create table cast_test_table2(name varchar(10));
### show create table cast_test_table2;
use test;
drop table t1;
create table t1(c0 varchar(100) collate cp932_japanese_ci) character set cp932;
insert into t1 values('a');
insert into t1 values('A');
drop table t2;
create table t2(c0 varchar(100) collate cp932_japanese_ci primary key) character set cp932;
insert into t2 values('a');

select p.c0,e.c0 from t2 e inner join t1 p on e.c0 = p.c0 order by p.c0;
+------+----+
| c0   | c0 |
+------+----+
| a    | a  |
| A    | a  |
+------+----+
alter table t1 add constraint foreignconst1 foreign key (c0) references t2(c0);
select p.c0,e.c0 from t2 e inner join t1 p on e.c0 = p.c0 order by p.c0;
+------+----+
| c0   | c0 |
+------+----+
| a    | a  |
| A    | a  |
+------+----+
drop table t1;
drop table t2;

drop table test_cp932_bak;
create table test_cp932_bak(c0 char(100) collate cp932_japanese_ci,c1 char(100) collate cp932_bin,c2 char(100) collate cp932_japanese_ci,c3 char(100) collate cp932_bin,c4 char(100) collate utf8mb4_unicode_ci,c5 char(100) collate cp932_japanese_ci,c6 char(100) collate cp932_bin,sal int,id int) character set cp932;

drop procedure test_cp932_bak_ascii_pro;

create procedure test_cp932_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_cp932_bak values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
/
call test_cp932_bak_ascii_pro();
/
