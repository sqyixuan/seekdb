###   hex(c1),
###   hex(@u:=convert(c1 using utf8))
###   FROM cp932_bin_table order by c1;
drop table test_cp932_bak;
create table test_cp932_bak(c0 varchar(100) collate cp932_japanese_ci,c1 varchar(100) collate cp932_bin,c2 varchar(100) collate cp932_japanese_ci,c3 varchar(100) collate cp932_bin,c4 varchar(100) collate utf8mb4_unicode_ci,c5 varchar(100) collate cp932_japanese_ci,c6 varchar(100) collate cp932_bin,sal int,id int) character set cp932;

drop procedure test_cp932_bak_ascii_pro;

create procedure test_cp932_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_cp932_bak values(char(i),char(i),char(i),char(i),char(i),char(i),char(i),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call test_cp932_bak_ascii_pro();
/
