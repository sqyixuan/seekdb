drop table test_cp932_bak;

CREATE TABLE test_cp932_bak(
    c0 TEXT COLLATE cp932_japanese_ci,
    c1 TEXT COLLATE cp932_bin,
    c2 TEXT COLLATE cp932_japanese_ci,
    c3 TEXT COLLATE cp932_bin,
    c4 TEXT COLLATE utf8mb4_unicode_ci,
    c5 TEXT COLLATE cp932_japanese_ci,
    c6 TEXT COLLATE cp932_bin,
    sal INT,
    id INT
) CHARACTER SET cp932;

drop procedure test_cp932_bak_ascii_pro;

CREATE PROCEDURE test_cp932_bak_ascii_pro()
BEGIN
  DECLARE i INT DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO test_cp932_bak(c0, c1, c2, c3, c4, c5, c6, sal, id)
    VALUES(CONVERT(CHAR(i) USING cp932), CONVERT(CHAR(i) USING cp932), CONVERT(CHAR(i) USING cp932), CONVERT(CHAR(i) USING cp932), CONVERT(CHAR(i) USING cp932), CONVERT(CHAR(i) USING cp932), CONVERT(CHAR(i) USING cp932), i, i);
    SET i = i + 1;
  END WHILE;
  COMMIT;
END /

CALL test_cp932_bak_ascii_pro();
