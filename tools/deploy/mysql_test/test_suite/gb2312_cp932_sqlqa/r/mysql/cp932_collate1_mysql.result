DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET cp932;
use db1;

drop table cp932_table;
drop procedure build_cp932_table;
drop table cp932_bin_table;
drop procedure build_cp932_bin_table;

create table cp932_table(c1 char(3) charset cp932 collate cp932_japanese_ci);
create table cp932_bin_table(c1 char(3) charset cp932 collate cp932_bin);

DROP PROCEDURE build_cp932_table;

create procedure build_cp932_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into cp932_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_cp932_table();
/

