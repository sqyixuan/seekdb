DROP table db1.t3;
CREATE TABLE db1.t3 (
    order_id INT AUTO_INCREMENT PRIMARY KEY,
    customer_id INT NOT NULL,
    order_date DATE NOT NULL
) CHARACTER SET = eucjpms;

use db1;
drop table sales_orders;
CREATE TABLE sales_orders (
    order_id INT AUTO_INCREMENT,
    customer_id INT NOT NULL,
    product_id INT NOT NULL,
    quantity INT NOT NULL,
    order_date DATE NOT NULL,
    KEY idx_order_date (order_date)
) CHARACTER SET = eucjpms
PARTITION BY RANGE(YEAR(order_date)) (
    PARTITION p2015 VALUES LESS THAN (2016),
    PARTITION p2016 VALUES LESS THAN (2017),
    PARTITION p2017 VALUES LESS THAN (2018),
    PARTITION p2018 VALUES LESS THAN (2019),
    PARTITION p2019 VALUES LESS THAN (2020),
    PARTITION p2020 VALUES LESS THAN (2021),
    PARTITION p2021 VALUES LESS THAN (2022),
    PARTITION p2022 VALUES LESS THAN (2023),
    PARTITION p2023 VALUES LESS THAN (2024),
    PARTITION future VALUES LESS THAN MAXVALUE
);

DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET ascii;
use db1;
### show create database db1;
alter DATABASE db1 CHARACTER SET eucjpms;
### show create database db1;
DROP table db1.t1;
CREATE TABLE db1.t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = eucjpms;

DROP PROCEDURE build_eucjpms_table;

create procedure build_eucjpms_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_eucjpms_table();
/

