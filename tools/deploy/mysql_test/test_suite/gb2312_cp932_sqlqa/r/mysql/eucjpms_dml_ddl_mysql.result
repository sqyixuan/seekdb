DELETE FROM db2.t2 WHERE a = 'Y';
DELETE FROM db2.t2;
TRUNCATE TABLE db2.t2;

########################## DDL ########################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET eucjpms;
use db1;
DROP table db1.t1;
CREATE TABLE db1.t1 (
    id INT AUTO_INCREMENT PRIMARY KEY COMMENT 'id_',
    a char(1) COMMENT 'a_'
)DEFAULT CHARACTER SET = eucjpms;

DROP PROCEDURE build_eucjpms_table;

create procedure build_eucjpms_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_eucjpms_table();
/

