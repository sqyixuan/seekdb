########################## update ########################
update db2.t2 set a = 'a' where a='a';
select * from db2.t2 where a='a' order by a;
+------+
| a    |
+------+
| a    |
| a    |
| a    |
| a    |
+------+

update db2.t2 set a = 'A' where a='a';
select * from db2.t2 where a='A' order by a;
+------+
| a    |
+------+
| A    |
| A    |
| A    |
| A    |
+------+

update db2.t2 set a = ']' where a='{';
select * from db2.t2 where a=']' order by a;
+------+
| a    |
+------+
| ]    |
| ]    |
| ]    |
| ]    |
+------+

update db2.t2 t1 set a=(select a from db1.t2 t2 where t1.a=t2.a) where exists(select 1 from db1.t2 where  t1.a=t2.a);
ERROR 21000: Subquery returns more than 1 row

