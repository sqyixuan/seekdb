INSERT INTO db2.t2  (select a from db2.t2 order by a);

select * from db2.t2 order by a;
CREATE OR REPLACE VIEW db2.v_t2 AS
SELECT a FROM db2.t2;
INSERT INTO db2.v_t2 (a) VALUES ('x');

