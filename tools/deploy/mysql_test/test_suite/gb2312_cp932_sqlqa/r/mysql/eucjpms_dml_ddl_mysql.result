purge recyclebin;
result_format: 4
#Environmental cleaning
###?ГЦД¶???
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##  eucjpms
##?ГЦЦх?ҙЗЕцБ°»ъЙдҪё?ГЦ
set names 'eucjpms' COLLATE eucjpms_japanese_ci;
set character_set_database = 'eucjpms';
set character_set_server = 'eucjpms';
set character_set_results = 'utf8mb4';
show character set where Charset = 'eucjpms';
Charset	Description	Default collation	Maxlen
eucjpms	UJIS for Windows Japanese	eucjpms_japanese_ci	3
show variables like '%character%';
Variable_name	Value
character_sets_dir	
character_set_client	eucjpms
character_set_connection	eucjpms
character_set_database	eucjpms
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	eucjpms
character_set_system	utf8mb4
show variables like'%collation%';
Variable_name	Value
collation_connection	eucjpms_japanese_ci
collation_database	eucjpms_japanese_ci
collation_server	eucjpms_japanese_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
########################## select ########################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET eucjpms;
use db1;
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(100)
)DEFAULT CHARACTER SET = eucjpms;

DROP PROCEDURE build_eucjpms_table;

create procedure build_eucjpms_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_eucjpms_table();
/
INSERT INTO T2(a) VALUES (_eucjpms 0x6F54);
INSERT INTO T2(a) VALUES (_eucjpms 0xA1E0);
INSERT INTO T2(a) VALUES (_eucjpms 0x82A1);
INSERT INTO T2(a) VALUES (0x6F54);
INSERT INTO T2(a) VALUES (0xA1E0);
INSERT INTO T2(a) VALUES (0x82A1);
INSERT INTO T2(a) VALUES (0xa2a1);
INSERT INTO T2(a) VALUES (0xA1E0);
INSERT INTO T2(a) VALUES (0xA2B2);
INSERT INTO T2(a) VALUES (0x8FFEFE);

select * from t2 order by id;
select id,a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t2 order by id;

select ascii(a)||HEX(a)||LEFT(HEX(a), 2)||UNHEX(HEX(a)) from db1.t2 order by id;

##with as
with with_as_name as(
    select id,a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t2
)
select * from with_as_name order by with_as_name.id;

SELECT CONCAT('Hello, ', 'World!')as 'hw';
select CAST('balance' AS CHAR);
select DISTINCT a from db1.t2 order by 1;
select DISTINCT a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t2 order by 1,2;

DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET eucjpms;
use db1;
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = eucjpms;
DROP PROCEDURE build_eucjpms_table;

create procedure build_eucjpms_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_eucjpms_table();
/

select * from t2 order by id;
select id,a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t2 order by id;

select t2222.* from t2 t2222 order by id;
DROP DATABASE db2;
CREATE DATABASE db2 CHARACTER SET eucjpms;
use db2;

DROP table db2.t2;
CREATE TABLE db2.t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = eucjpms;

DROP PROCEDURE build_eucjpms_table;

create procedure build_eucjpms_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_eucjpms_table();
/

select * from db2.t2 order by id;
select * from db1.t2 order by id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 order by t1.id and t1.a;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id order by t1.id;
select count(*) from db1.t2,db2.t2 where convert(db1.t2.a using eucjpms)=db2.t2.a;
