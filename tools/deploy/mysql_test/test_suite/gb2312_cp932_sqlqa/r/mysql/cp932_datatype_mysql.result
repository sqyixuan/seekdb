SELECT 'The number is: ' || 42;
+-------------------------+
| 'The number is: ' || 42 |
+-------------------------+
|                       1 |
+-------------------------+

SELECT 'Today is: ' || 2024-01;
+-------------------------+
| 'Today is: ' || 2024-01 |
+-------------------------+
|                       1 |
+-------------------------+
SELECT '123' + 45;
+------------+
| '123' + 45 |
+------------+
|        168 |
+------------+

SELECT TIMESTAMP '1970-01-01 00:00:00';
+---------------------------------+
| TIMESTAMP '1970-01-01 00:00:00' |
+---------------------------------+
| 1970-01-01 00:00:00             |
+---------------------------------+

SELECT '2024-0?-15' + INTERVAL '1 day';
select CAST(42 AS VARCHAR(10);

SELECT NOW() -NOW() + 3600;
+---------------------+
| NOW() -NOW() + 3600 |
+---------------------+
|                3600 |
+---------------------+
SELECT CAST(TIMESTAMP '2024-04-15 12:34:56' AS DATE);
+-----------------------------------------------+
| CAST(TIMESTAMP '2024-04-15 12:34:56' AS DATE) |
+-----------------------------------------------+
| 2024-04-15                                    |
+-----------------------------------------------+
SELECT ASCII('A');
+------------+
| ASCII('A') |
+------------+
|         65 |
+------------+
SELECT SUBSTR('Hello, World!', 7, 5);
+-------------------------------+
| SUBSTR('Hello, World!', 7, 5) |
+-------------------------------+
|  Worl                         |
+-------------------------------+
SELECT TRIM('   Hello, World!   ');
+-----------------------------+
| TRIM('   Hello, World!   ') |
+-----------------------------+
| Hello, World!               |
+-----------------------------+
SELECT LTRIM('   Hello, World!');
+---------------------------+
| LTRIM('   Hello, World!') |
+---------------------------+
| Hello, World!             |
+---------------------------+
SELECT RTRIM('Hello, World!   ');
+---------------------------+
| RTRIM('Hello, World!   ') |
+---------------------------+
| Hello, World!             |
+---------------------------+
