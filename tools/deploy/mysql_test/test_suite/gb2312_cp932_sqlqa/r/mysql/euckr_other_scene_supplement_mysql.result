DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
    a VARCHAR(10) CHARACTER SET euckr COLLATE euckr_korean_ci,
    b VARCHAR(10) CHARACTER SET euckr COLLATE euckr_korean_ci
) DEFAULT CHARACTER SET = euckr;
INSERT INTO t1 VALUES
    (CONVERT(_utf16 0x4F USING euckr), CONVERT(_utf16 0x1EE0 USING euckr)),
    (CONVERT(_utf16 0x1EE0 USING euckr), CONVERT(_utf16 0x1EE7 USING euckr)),
    (CONVERT(_utf16 0x55 USING euckr), CONVERT(_utf16 0x1E7A USING euckr)),
    (CONVERT(_utf16 0x1E7A USING euckr), CONVERT(_utf16 0x1E7C USING euckr)),
    (CONVERT(_utf16 0x1E7A USING euckr), CONVERT(_utf16 0x1E80 USING euckr)),
    (CONVERT(_utf16 0x4F USING euckr), CONVERT(_utf16 0x1ED6 USING euckr)),
    (CONVERT(_utf16 0x1ED6 USING euckr), CONVERT(_utf16 0x1EE4 USING euckr));
SELECT
    a,
    b,
    HEX(CONVERT(a USING utf16)) AS U16_a,
    HEX(CONVERT(b USING utf16)) AS U16_b,
    a < b
FROM t1
ORDER BY 3;
+------+------+-------+-------+-------+
| a    | b    | U16_a | U16_b | a < b |
