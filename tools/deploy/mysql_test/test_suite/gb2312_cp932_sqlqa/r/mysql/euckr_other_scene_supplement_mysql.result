DROP PROCEDURE init_rec;
CREATE PROCEDURE init_rec(IN p1 VARCHAR(10))
BEGIN
  DECLARE a CHAR(10);
  DECLARE b CHAR(10);
  DECLARE k CHAR(10);
  SET a = LPAD(CONVERT('®¨®£????????????ÝŌ???????' USING euckr), LENGTH(p1), '®¨');
  SET b = LPAD(CONVERT('?????????ÓŪ?žŽ„ŗ?Úť' USING euckr), LENGTH(p1)-1, '?');
  SET k = LPAD(CONVERT('ķ…Űų_TRIG_Űų' USING euckr), LENGTH(p1)+1, '?');
  SELECT CONCAT('r.a = ', a) AS a_output;
  SELECT CONCAT('r.b = ', b) AS b_output;
  SELECT CONCAT('r.k = ', k) AS k_output;
END //
