DROP TABLE IF EXISTS t1;
CREATE TABLE t1 SELECT
    LPAD(CONVERT(_utf8 '?' USING euckr), 10, CONVERT(_utf8 '?' USING euckr)) AS l,
    RPAD(CONVERT(_utf8 '?' USING euckr), 10, CONVERT(_utf8 '?' USING euckr)) AS r;
