DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET gb2312;
use db1;

drop table test_gb2312;
CREATE TABLE test_gb2312 (id int AUTO_INCREMENT PRIMARY KEY, a char(10) CHARACTER SET gb2312) DEFAULT CHARSET=gb2312;

DROP PROCEDURE create_gb2312;
CREATE PROCEDURE create_gb2312()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO test_gb2312 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
call create_gb2312();
