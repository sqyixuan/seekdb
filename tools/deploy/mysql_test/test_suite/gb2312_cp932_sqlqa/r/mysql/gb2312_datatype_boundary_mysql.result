    id INT AUTO_INCREMENT PRIMARY KEY,
    json_data JSON
) CHARACTER SET gb2312;

INSERT INTO json_test (json_data) VALUES
('{"name": "Alice", "age": 30, "is_student": false, "courses": ["Math", "Science"], "address": {"city": "Beijing", "zip": null}}'),
('{"products": [{"id": 1, "name": "Product A", "price": 100.50}, {"id": 2, "name": "Product B", "price": 150.00}], "available": true}'),
('{"message": "Hello, World!", "count": 5, "is_valid": true, "tags": null}'),
('{"is_empty": false, "items": [1, 2, 3, 4, 5], "settings": {"theme": "dark", "notifications": true}}');
