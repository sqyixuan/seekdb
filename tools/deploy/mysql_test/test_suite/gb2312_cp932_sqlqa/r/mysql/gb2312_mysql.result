DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET UTF8MB4;
use db1;

SET NAMES utf8mb4;
show variables like '%character%';
Variable_name	Value
character_set_client	utf8mb4
character_set_connection	utf8mb4
character_set_database	utf8mb4
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	utf8mb4
character_set_system	utf8mb4
character_sets_dir	
show variables like'%collation%';
Variable_name	Value
collation_connection	utf8mb4_general_ci
collation_database	utf8mb4_general_ci
collation_server	utf8mb4_general_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
DROP TABLE t1;
CREATE TABLE t1(a VARCHAR(100) COLLATE utf8mb4_0900_ai_ci, key idx (a)) ;
INSERT INTO t1 VALUES(_utf16 0x1EC2), (_utf16 0x1EC3), (_utf16 0x1EC5), (_utf16 0x1EC0), (_utf16 0x1EC7), (_Utf16 0x1EBF);
insert into t1 values('?????????????');

SELECT HEX(CONVERT(a USING utf16)) FROM t1 ORDER BY a;
+------------------------------------------------------+
| HEX(CONVERT(a USING utf16))                          |
+------------------------------------------------------+
| 003F003F003F003F003F003F003F003F003F003F003F003F003F |
| 1EBF                                                 |
| 1EC0                                                 |
| 1EC2                                                 |
| 1EC3                                                 |
| 1EC5                                                 |
| 1EC7                                                 |
+------------------------------------------------------+
select /*+ index(t1 primary) */* from t1 where a like '%?????????????%';
+---------------+
| a             |
+---------------+
| ????????????? |
+---------------+
select /*+ index(t1 idx) */* from t1 where a like '%?????????????%';
+---------------+
| a             |
+---------------+
| ????????????? |
+---------------+

select /*+ index(t1 primary) */* from t1 where a like '%_Utf16 0x1EBF%';
+------+
| a    |
+------+
+------+
select /*+ index(t1 idx) */* from t1 where a like '%_Utf16 0x1EBF%';
+------+
| a    |
+------+
+------+
select /*+ index(t1 idx) */* from t1 where a like '%1EBF%';
+------+
| a    |
+------+
+------+

