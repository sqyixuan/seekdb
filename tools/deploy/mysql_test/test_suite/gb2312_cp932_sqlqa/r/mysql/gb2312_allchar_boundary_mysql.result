SELECT SUBSTRING('??_TRIG_?', 3),
SUBSTRING('??_TRIG_?', 3, 2),
SUBSTRING('??_TRIG_?', -3),
SUBSTRING('??_TRIG_?', 3, -2),
SUBSTRING('??_TRIG_?' from -4 for 2);

