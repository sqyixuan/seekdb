purge recyclebin;
result_format: 4
#Environmental cleaning
result_format: 4
Charset	Description	Default collation	Maxlen
gb2312	GB2312 Simplified Chinese	gb2312_chinese_ci	2
Variable_name	Value
character_sets_dir	
character_set_client	gb2312
character_set_connection	gb2312
character_set_database	gb2312
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	gb2312
character_set_system	utf8mb4
############################# Ооич?л═ #############################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET gb2312;
use db1;

drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(100),
    nchar_column NATIONAL CHAR(100),
    varchar_column VARCHAR(100),
    nvarchar_column NATIONAL VARCHAR(100),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = gb2312;

DROP PROCEDURE build_gb2312_table;

create procedure build_gb2312_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128|| (i >= 0xA1 && i < 0xE0) ) THEN
      insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_gb2312_table();
/

DROP PROCEDURE build_gb2312_table;
/

create procedure build_gb2312_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_gb2312_table();
/

