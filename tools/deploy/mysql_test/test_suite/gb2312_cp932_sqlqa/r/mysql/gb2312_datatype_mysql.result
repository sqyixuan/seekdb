############################# ???л═ #############################
DROP table t3;
CREATE TABLE t3 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    date_column DATE,
    timestamp_column TIMESTAMP,
    interval_value VARCHAR(255),
    interval_unit ENUM('seconds', 'minutes', 'hours', 'days', 'weeks', 'months', 'years')
) DEFAULT CHARACTER SET = gb2312;
select * from t3 order by id;
+----+-------------+------------------+----------------+---------------+
| id | date_column | timestamp_column | interval_value | interval_unit |
+----+-------------+------------------+----------------+---------------+
+----+-------------+------------------+----------------+---------------+
insert into t3(date_column,timestamp_column,interval_value,interval_unit)
    values('2023-06-07', '2023-06-07 14:30:00', 15, 'days');
insert into t3(date_column,timestamp_column,interval_value,interval_unit)
    values('2023-06-07', '2023-06-07 14:30:00', 15, 'days');
select * from t3 order by id;
+----+-------------+---------------------+----------------+---------------+
| id | date_column | timestamp_column    | interval_value | interval_unit |
+----+-------------+---------------------+----------------+---------------+
|  1 | 2023-06-07  | 2023-06-07 14:30:00 | 15             | days          |
|  2 | 2023-06-07  | 2023-06-07 14:30:00 | 15             | days          |
+----+-------------+---------------------+----------------+---------------+

############################# кС╦ч?л═ #############################
DROP TABLE IF EXISTS t1;

CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    enum_column ENUM('A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J'),
    set_column SET('K', 'L', 'M', 'N', 'O', 'P', 'Q', 'R', 'S', 'T'),
    json_column JSON
)DEFAULT CHARACTER SET = gb2312;
INSERT INTO t1(enum_column, set_column, json_column) VALUES('A', 'K', JSON_OBJECT('number', 1));
INSERT INTO t1(enum_column, set_column, json_column) VALUES('B', 'L', JSON_OBJECT('number', 2));
INSERT INTO t1(enum_column, set_column, json_column) VALUES('C', 'M', JSON_OBJECT('number', 3));

SELECT * FROM t1;
+----+-------------+------------+---------------+
| id | enum_column | set_column | json_column   |
+----+-------------+------------+---------------+
|  1 | A           | K          | {"number": 1} |
|  2 | B           | L          | {"number": 2} |
|  3 | C           | M          | {"number": 3} |
+----+-------------+------------+---------------+
SELECT CONVERT(enum_column USING gb2312) AS char_value FROM t1;
+------------+
| char_value |
+------------+
| A          |
| B          |
| C          |
+------------+
SELECT CAST(enum_column AS CHAR CHARSET gb2312) AS string_value FROM t1;
+--------------+
| string_value |
+--------------+
| A            |
| B            |
| C            |
+--------------+
SELECT CAST(enum_column AS CHAR CHARSET UTF8) AS string_value FROM t1;
+--------------+
| string_value |
+--------------+
| A            |
| B            |
| C            |
+--------------+
SELECT CONVERT(set_column USING gb2312) AS char_value FROM t1;
+------------+
| char_value |
+------------+
| K          |
| L          |
| M          |
+------------+
SELECT CAST(set_column AS CHAR CHARSET gb2312) AS string_value FROM t1;
+--------------+
| string_value |
+--------------+
| K            |
| L            |
| M            |
+--------------+
SELECT CAST(set_column AS CHAR CHARSET UTF8) AS string_value FROM t1;
+--------------+
| string_value |
+--------------+
| K            |
| L            |
| M            |
+--------------+
SELECT CONVERT(json_column USING gb2312) AS char_value FROM t1;
+---------------+
| char_value    |
+---------------+
| {"number": 1} |
| {"number": 2} |
| {"number": 3} |
+---------------+
SELECT CAST(json_column AS CHAR CHARSET gb2312) AS string_value FROM t1;
+---------------+
| string_value  |
+---------------+
| {"number": 1} |
| {"number": 2} |
| {"number": 3} |
+---------------+
SELECT CAST(json_column AS CHAR CHARSET UTF8) AS string_value FROM t1;
+---------------+
| string_value  |
+---------------+
| {"number": 1} |
| {"number": 2} |
| {"number": 3} |
+---------------+

SELECT DATE('2012-12-12') + INTERVAL 123 DAY;
+---------------------------------------+
| DATE('2012-12-12') + INTERVAL 123 DAY |
+---------------------------------------+
| 2013-04-14                            |
+---------------------------------------+
SELECT date_column,(date_column + INTERVAL 123 DAY)as "new_date_column" from t3;
+-------------+-----------------+
| date_column | new_date_column |
+-------------+-----------------+
| 2023-06-07  | 2023-10-08      |
| 2023-06-07  | 2023-10-08      |
+-------------+-----------------+
select * from t3 order by id;
+----+-------------+---------------------+----------------+---------------+
| id | date_column | timestamp_column    | interval_value | interval_unit |
+----+-------------+---------------------+----------------+---------------+
|  1 | 2023-06-07  | 2023-06-07 14:30:00 | 15             | days          |
|  2 | 2023-06-07  | 2023-06-07 14:30:00 | 15             | days          |
+----+-------------+---------------------+----------------+---------------+
select length(id),length(date_column),length(timestamp_column),length(interval_value),length(12) from t3 order by id;
+------------+---------------------+--------------------------+------------------------+------------+
| length(id) | length(date_column) | length(timestamp_column) | length(interval_value) | length(12) |
+------------+---------------------+--------------------------+------------------------+------------+
|          1 |                  10 |                       19 |                      2 |          2 |
|          1 |                  10 |                       19 |                      2 |          2 |
+------------+---------------------+--------------------------+------------------------+------------+

