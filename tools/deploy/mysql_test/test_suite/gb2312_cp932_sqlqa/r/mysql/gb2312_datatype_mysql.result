drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    BINARY_column BINARY(100),
    BINARY_column2 BINARY(200),
    VARBINARY_column VARBINARY(100),
    VARBINARY_column2 VARBINARY(200),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = gb2312;

DROP PROCEDURE build_gb2312_table;

create procedure build_gb2312_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128) THEN
      insert into t1(BINARY_column,BINARY_column2,VARBINARY_column,VARBINARY_column2,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_gb2312_table();
/

insert into t1(BINARY_column,BINARY_column2,VARBINARY_column,VARBINARY_column2,text_column,blob_column) values (0xF1F2,0xF1F2,0xF1F2,0xF1F2,0xF1F2,0xF1F2);
insert into t1(BINARY_column,BINARY_column2,VARBINARY_column,VARBINARY_column2,text_column,blob_column) values (_gb2312 0x44,_gb2312 0x44,_gb2312 0x44,_gb2312 0x44,_gb2312 0x44,_gb2312 0x44);
