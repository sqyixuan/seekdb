############################# ?Оо?л═ #############################
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    numeric_column DECIMAL(10, 2) NOT NULL,
    float_column FLOAT,
    double_column DOUBLE
)DEFAULT CHARACTER SET = gb2312;

DROP PROCEDURE build_gb2312_table;
/

create procedure build_gb2312_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t2(numeric_column,float_column,double_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
/

