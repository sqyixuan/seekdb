set names cp932;
select collation(concat(convert("abc" using gb18030_2022), convert("cde" using cp932))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (gb18030_2022_chinese_ci,IMPLICIT), (cp932_japanese_ci,IMPLICIT)
select collation(concat(convert("abc" using gb18030), convert("cde" using cp932))) as combined_string from dual;
