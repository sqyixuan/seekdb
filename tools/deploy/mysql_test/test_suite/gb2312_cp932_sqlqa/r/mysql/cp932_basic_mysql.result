purge recyclebin;
result_format: 4
#Environmental cleaning
###?’u’´???
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##  cp932
##?’u›َ?ٹإ“–‘Oژڑ•„ڈW?’u
set names 'cp932' COLLATE cp932_japanese_ci;
set character_set_database = 'cp932';
set character_set_server = 'cp932';
set character_set_results = 'utf8mb4';
show character set where Charset = 'cp932';
Charset	Description	Default collation	Maxlen
cp932	SJIS for Windows Japanese	cp932_japanese_ci	2
show variables like '%character%';
Variable_name	Value
character_sets_dir	
character_set_client	cp932
character_set_connection	cp932
character_set_database	cp932
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	cp932
character_set_system	utf8mb4
show variables like'%collation%';
Variable_name	Value
collation_connection	cp932_japanese_ci
collation_database	cp932_japanese_ci
collation_server	cp932_japanese_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
# ?Œڑ‘d??ژw’èژڑ•„ڈWپC??“–‘OŒn?ژڑ•„ڈW
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET cp932;
use db1;

drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100));

DROP PROCEDURE build_cp932_table;

create procedure build_cp932_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_cp932_table();
/

