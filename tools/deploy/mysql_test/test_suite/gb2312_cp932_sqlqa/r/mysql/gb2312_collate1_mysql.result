drop table test_gb2312_bak;
create table test_gb2312_bak(c0 varchar(100) collate gb2312_chinese_ci ,c1 varchar(100) collate gb2312_bin,c2 varchar(100) collate gb2312_chinese_ci ,c3 varchar(100) collate gb2312_bin,c4 varchar(100) collate utf8mb4_unicode_ci,c5 varchar(100) collate gb2312_chinese_ci ,c6 varchar(100) collate gb2312_bin,sal int,id int) character set gb2312;

drop procedure test_gb2312_bak_ascii_pro;

create procedure test_gb2312_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_gb2312_bak values(char(i),char(i),char(i),char(i),char(i),char(i),char(i),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call test_gb2312_bak_ascii_pro();
/
ERROR HY000: Incorrect string value

