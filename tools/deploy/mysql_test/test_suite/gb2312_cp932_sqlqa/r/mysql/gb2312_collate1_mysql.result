drop table test_gb2312_bak;
create table test_gb2312_bak(c0 varchar(100),c1 varchar(100),full varchar(100) collate gb2312_bin generated always as(concat(c0,c1)) ) character set gb2312;

drop procedure build_gb2312_table;

create procedure build_gb2312_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_gb2312_bak(c0,c1) values(unhex(hex(i)),unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_gb2312_table();
/
