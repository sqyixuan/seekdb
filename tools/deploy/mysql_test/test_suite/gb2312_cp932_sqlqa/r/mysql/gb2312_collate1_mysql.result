drop table test_gb2312_bak;

CREATE TABLE test_gb2312_bak(
    c0 TEXT COLLATE gb2312_chinese_ci ,
    c1 TEXT COLLATE gb2312_bin,
    c2 TEXT COLLATE gb2312_chinese_ci ,
    c3 TEXT COLLATE gb2312_bin,
    c4 TEXT COLLATE utf8mb4_unicode_ci,
    c5 TEXT COLLATE gb2312_chinese_ci ,
    c6 TEXT COLLATE gb2312_bin,
    sal INT,
    id INT
) CHARACTER SET gb2312;

drop procedure test_gb2312_bak_ascii_pro;

CREATE PROCEDURE test_gb2312_bak_ascii_pro()
BEGIN
  DECLARE i INT DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO test_gb2312_bak(c0, c1, c2, c3, c4, c5, c6, sal, id)
    VALUES(CONVERT(CHAR(i) USING gb2312), CONVERT(CHAR(i) USING gb2312), CONVERT(CHAR(i) USING gb2312), CONVERT(CHAR(i) USING gb2312), CONVERT(CHAR(i) USING gb2312), CONVERT(CHAR(i) USING gb2312), CONVERT(CHAR(i) USING gb2312), i, i);
    SET i = i + 1;
  END WHILE;
  COMMIT;
END /
CALL test_gb2312_bak_ascii_pro();
