#### ĎŚŹ¨é ?? ###
SELECT
    lcase(code_utf8) AS code_utf8_lower,
    lcase(desc_varchar_utf8mb4) AS desc_varchar_utf8mb4_lower,
    lcase(code_gbk) AS code_gbk_lower,
    lcase(code_gb18030) AS code_gb18030_lower,
    lcase(code_cp932) AS code_cp932_lower
FROM t_multicharset;
+-----------------+----------------------------+----------------+--------------------+------------------+
| code_utf8_lower | desc_varchar_utf8mb4_lower | code_gbk_lower | code_gb18030_lower | code_cp932_lower |
+-----------------+----------------------------+----------------+--------------------+------------------+
| NULL            | NULL                       | NULL           | NULL               | NULL             |
| NULL            | NULL                       | NULL           | NULL               | NULL             |
+-----------------+----------------------------+----------------+--------------------+------------------+

SELECT
    LOWER(code_utf8) AS code_utf8_lower,
    LOWER(desc_varchar_utf8mb4) AS desc_varchar_utf8mb4_lower,
    LOWER(code_gbk) AS code_gbk_lower,
    LOWER(code_gb18030) AS code_gb18030_lower,
    LOWER(code_cp932) AS code_cp932_lower
FROM t_multicharset;
+-----------------+----------------------------+----------------+--------------------+------------------+
| code_utf8_lower | desc_varchar_utf8mb4_lower | code_gbk_lower | code_gb18030_lower | code_cp932_lower |
+-----------------+----------------------------+----------------+--------------------+------------------+
| NULL            | NULL                       | NULL           | NULL               | NULL             |
| NULL            | NULL                       | NULL           | NULL               | NULL             |
+-----------------+----------------------------+----------------+--------------------+------------------+

SELECT
    UPPER(code_utf8) AS code_utf8_upper,
    UPPER(desc_varchar_utf8mb4) AS desc_varchar_utf8mb4_upper,
    UPPER(code_gbk) AS code_gbk_upper,
    UPPER(code_gb18030) AS code_gb18030_upper,
    UPPER(code_cp932) AS code_cp932_upper
FROM t_multicharset;
+-----------------+----------------------------+----------------+--------------------+------------------+
| code_utf8_upper | desc_varchar_utf8mb4_upper | code_gbk_upper | code_gb18030_upper | code_cp932_upper |
+-----------------+----------------------------+----------------+--------------------+------------------+
| NULL            | NULL                       | NULL           | NULL               | NULL             |
| NULL            | NULL                       | NULL           | NULL               | NULL             |
+-----------------+----------------------------+----------------+--------------------+------------------+

SELECT
    ucase(code_utf8) AS code_utf8_upper,
    ucase(desc_varchar_utf8mb4) AS desc_varchar_utf8mb4_upper,
    ucase(code_gbk) AS code_gbk_upper,
    ucase(code_gb18030) AS code_gb18030_upper,
    ucase(code_cp932) AS code_cp932_upper
FROM t_multicharset;
+-----------------+----------------------------+----------------+--------------------+------------------+
| code_utf8_upper | desc_varchar_utf8mb4_upper | code_gbk_upper | code_gb18030_upper | code_cp932_upper |
+-----------------+----------------------------+----------------+--------------------+------------------+
| NULL            | NULL                       | NULL           | NULL               | NULL             |
| NULL            | NULL                       | NULL           | NULL               | NULL             |
+-----------------+----------------------------+----------------+--------------------+------------------+

