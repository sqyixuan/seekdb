character_sets_dir	
character_set_client	cp932
character_set_connection	cp932
character_set_database	cp932
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	cp932
character_set_system	utf8mb4
show variables like'%collation%';
Variable_name	Value
collation_connection	cp932_japanese_ci
collation_database	cp932_japanese_ci
collation_server	cp932_japanese_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
############################# éöēĄ?Ć^ #############################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET cp932;
use db1;

drop table t1;
ERROR 42S02: Unknown table 'db1.t1'
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(10),
    nchar_column NATIONAL CHAR(10),
    varchar_column VARCHAR(10),
    nvarchar_column NATIONAL VARCHAR(10),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = cp932;

DROP PROCEDURE build_cp932_table;

create procedure build_cp932_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128) THEN
      insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_cp932_table();
/

select * from t1 order by id;
