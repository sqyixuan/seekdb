DROP TABLE t_test3;
CREATE TABLE t_test3(CODE CHAR(100) CHARSET GBK,CODE2 CHAR(100) charset cp932 collate cp932_japanese_ci);
INSERT INTO t_test3 SELECT CONVERT(code USING GBK),CONVERT(code USING cp932) FROM T_TEST ORDER BY 1;

