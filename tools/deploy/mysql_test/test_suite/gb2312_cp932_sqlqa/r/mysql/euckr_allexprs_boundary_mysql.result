purge recyclebin;
result_format: 4
#Environmental cleaning
###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
##设置并查看当前字符集设置
set names 'euckr' COLLATE euckr_korean_ci;
set character_set_database = 'euckr';
set character_set_server = 'euckr';
set character_set_results = 'utf8mb4';
show character set where Charset = 'euckr';
Charset	Description	Default collation	Maxlen
euckr	EUC-KR Korean	euckr_korean_ci	2
show variables like '%character%';
Variable_name	Value
character_sets_dir	
character_set_client	euckr
character_set_connection	euckr
character_set_database	euckr
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	euckr
character_set_system	utf8mb4
show variables like'%collation%';
Variable_name	Value
collation_connection	euckr_korean_ci
collation_database	euckr_korean_ci
collation_server	euckr_korean_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
############################# 字符串文本 #############################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET euckr;
use db1;
###### 函数、表达式  ######
###### replace  ######
### 中文列名展示不稳定，暂时注释
### SELECT replace('中文测试','中','文');
### SELECT REPLACE('特殊符号与标点测试', '特殊符号与标点', '文');
### SELECT REPLACE('数字测试0123456789', '0123456789', '文');
### SELECT REPLACE('大写字母测试ABCDEFGHIJKLMNOPQRSTUVWXYZ', 'ABCDEFGHIJKLMNOPQRSTUVWXYZ', '文');
### SELECT REPLACE('小写字母测试abcdefghijklmnopqrstuvwxyz', 'abcdefghijklmnopqrstuvwxyz', '文');
### SELECT REPLACE('含有各种字符测试라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ', '라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ', '文');
### SELECT REPLACE('西里尔字母测试나다ｶｶス佟丌®、ｶｶｶｶｶｶ', '나다ｶｶス佟丌®、ｶｶｶｶｶｶ', '文');
### SELECT REPLACE('汉字测试', '汉字', '文');
### SELECT REPLACE('其他字符测试乀乁乄乇乑', '乀乁乄乇乑', '文');
### SELECT REPLACE('各种特殊符号测试ｶｶｶｶ丂丄丅丌丒丟', 'ｶｶｶｶ丂丄丅丌丒丟', '文');
### SELECT REPLACE('组合字符测试许體_TRIG_體', '许體_TRIG_體', '文');
###### LENGTH、OCTET_LENGTH、CHAR_LENGTH  ######
###### 中文字符集
SELECT LENGTH('许'), OCTET_LENGTH('许'), CHAR_LENGTH('许');

###### 特殊字符集
SELECT LENGTH('ｶｶｶｶｶｶｶｶｶｶｶｶ龔'''), OCTET_LENGTH('ｶｶｶｶｶｶｶｶｶｶｶｶ龔'''), CHAR_LENGTH('ｶｶｶｶｶｶｶｶｶｶｶｶ龔''');

###### 希腊字符集
SELECT LENGTH('나다ｶｶス佟丌®、ｶｶ龔'), OCTET_LENGTH('나다ｶｶス佟丌®、ｶｶ龔'), CHAR_LENGTH('나다ｶｶス佟丌®、ｶｶ龔');

###### 希腊小写字母字符集
SELECT LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶ龔'), OCTET_LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶ龔'), CHAR_LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶ龔');

###### 斯拉夫字符集
SELECT LENGTH('나다ｶｶス佟丌®、ｶｶｶｶｶｶ'), OCTET_LENGTH('나다ｶｶス佟丌®、ｶｶｶｶｶｶ'), CHAR_LENGTH('나다ｶｶス佟丌®、ｶｶｶｶｶｶ');

###### 其他斯拉夫字符集
SELECT LENGTH('나다ｶｶス佟丌®、'), OCTET_LENGTH('나다ｶｶス佟丌®、'), CHAR_LENGTH('나다ｶｶス佟丌®、');

######  常见符号字符集
SELECT LENGTH(' !"#$%&''()*+,-./'), OCTET_LENGTH(' !"#$%&''()*+,-./'), CHAR_LENGTH(' !"#$%&''()*+,-./');

###### 数字字符集
SELECT LENGTH('0123456789:;<=>ｶｶｶｶ'), OCTET_LENGTH('0123456789:;<=>ｶｶｶｶ'), CHAR_LENGTH('0123456789:;<=>ｶｶｶｶ');

######  大写字母字符集
SELECT LENGTH('@ABCDEFGHIJKLMNO'), OCTET_LENGTH('@ABCDEFGHIJKLMNO'), CHAR_LENGTH('@ABCDEFGHIJKLMNO');

###### 其他大写字母字符集
SELECT LENGTH('PQRSTUVWXYZ[\\]^_'), OCTET_LENGTH('PQRSTUVWXYZ[\\]^_'), CHAR_LENGTH('PQRSTUVWXYZ[\\]^_');

###### 小写字母字符集
SELECT LENGTH('abcdefghijklmno'), OCTET_LENGTH('abcdefghijklmno'), CHAR_LENGTH('abcdefghijklmno');

###### 其他小写字母字符集
SELECT LENGTH('pqrstuvwxyz{|}~'), OCTET_LENGTH('pqrstuvwxyz{|}~'), CHAR_LENGTH('pqrstuvwxyz{|}~');

###### 拉丁字符集（带重音的字母）
SELECT LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ나다ｶｶス佟丌®、ｶｶｶｶ'), OCTET_LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ나다ｶｶス佟丌®、ｶｶｶｶ'), CHAR_LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ나다ｶｶス佟丌®、ｶｶｶｶ');

######  拉丁字符集（带重音的后续字母）
SELECT LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ나다ｶｶス佟丌®、ｶｶ龔'), OCTET_LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ나다ｶｶス佟丌®、ｶｶ龔'), CHAR_LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ나다ｶｶス佟丌®、ｶｶ龔');

###### 其他复杂字符集
SELECT LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶｶｶｶｶ'), OCTET_LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶｶｶｶｶ'), CHAR_LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶｶｶｶｶ');

######  其他小写拉丁字符集（带重音）
SELECT LENGTH('áàｶｶｶｶｶｶｶｶｶｶǎā나다ｶｶス佟丌®、ｶｶ龔éèｶｶｶｶ'), OCTET_LENGTH('áàｶｶｶｶｶｶｶｶｶｶǎā나다ｶｶス佟丌®、ｶｶ龔éèｶｶｶｶ'), CHAR_LENGTH('áàｶｶｶｶｶｶｶｶｶｶǎā나다ｶｶス佟丌®、ｶｶ龔éèｶｶｶｶ');

######  其他复杂小写拉丁字符集
SELECT LENGTH('ɡｶｶｶｶｶｶｶｶｶｶｶｶ龔íìｶｶ龔ǐｶｶｶｶīｶｶ龔'), OCTET_LENGTH('ɡｶｶｶｶｶｶｶｶｶｶｶｶ龔íìｶｶ龔ǐｶｶｶｶīｶｶ龔'), CHAR_LENGTH('ɡｶｶｶｶｶｶｶｶｶｶｶｶ龔íìｶｶ龔ǐｶｶｶｶīｶｶ龔');

###### 更多拉丁字符集（带重音）
SELECT LENGTH('ｶｶｶｶｶｶｶｶｶｶｶｶ龔ńňｶｶ龔óòｶｶ龔ǒｶｶｶｶō나다ｶｶス佟丌®、'), OCTET_LENGTH('ｶｶｶｶｶｶｶｶｶｶｶｶ龔ńňｶｶ龔óòｶｶ龔ǒｶｶｶｶō나다ｶｶス佟丌®、'), CHAR_LENGTH('ｶｶｶｶｶｶｶｶｶｶｶｶ龔ńňｶｶ龔óòｶｶ龔ǒｶｶｶｶō나다ｶｶス佟丌®、');

###### 其他复杂拉丁字符集
SELECT LENGTH('나다ｶｶス佟丌®、ｶｶｶｶｶｶúùüｶｶ龔ǔｶｶｶｶūｶｶｶｶｶｶｶｶｶｶǘǜǚǖ나다ｶｶス佟丌®、'), OCTET_LENGTH('나다ｶｶス佟丌®、ｶｶｶｶｶｶúùüｶｶ龔ǔｶｶｶｶūｶｶｶｶｶｶｶｶｶｶǘǜǚǖ나다ｶｶス佟丌®、'), CHAR_LENGTH('나다ｶｶス佟丌®、ｶｶｶｶｶｶúùüｶｶ龔ǔｶｶｶｶūｶｶｶｶｶｶｶｶｶｶǘǜǚǖ나다ｶｶス佟丌®、');

###### 汉字字符集
SELECT LENGTH('丂丄丅丌丒丟丣两丨丫丮丯丰丵乀乁乄乇乑'),
       OCTET_LENGTH('丂丄丅丌丒丟丣两丨丫丮丯丰丵乀乁乄乇乑'),
       CHAR_LENGTH('丂丄丅丌丒丟丣两丨丫丮丯丰丵乀乁乄乇乑');

###### 更多字符集
SELECT LENGTH('仃仐仚仛仠仡仢仨仯仱仳仵份仾仿伀伂伃伈伋伌伒伕伖众'),
       OCTET_LENGTH('仃仐仚仛仠仡仢仨仯仱仳仵份仾仿伀伂伃伈伋伌伒伕伖众'),
       CHAR_LENGTH('仃仐仚仛仠仡仢仨仯仱仳仵份仾仿伀伂伃伈伋伌伒伕伖众');

###### 更多混合字符集
SELECT LENGTH('伙伮伱你伳伵伷伹伻伾佀佂佈佉佋佌佒佔佖佘'),
       OCTET_LENGTH('伙伮伱你伳伵伷伹伻伾佀佂佈佉佋佌佒佔佖佘'),
       CHAR_LENGTH('伙伮伱你伳伵伷伹伻伾佀佂佈佉佋佌佒佔佖佘');

###### 特殊字符集
SELECT LENGTH('許體_TRIG_體'),
       OCTET_LENGTH('許體_TRIG_體'),
       CHAR_LENGTH('許體_TRIG_體');

###### FIND_IN_SET ######
select FIND_IN_SET(_latin1'B', _latin1'a,b,c,d') from dual;
select FIND_IN_SET(_euckr '繁體ing',_euckr '繁體ing') as euckr_res from dual;
SELECT FIND_IN_SET(_euckr '나다ｶｶス佟丌®、\'', _euckr '나다ｶｶス佟丌®、\'') AS euckr_res FROM dual;
SELECT FIND_IN_SET(_euckr '나다ｶｶス佟丌®、ｶｶｶｶｶｶü', _euckr '나다ｶｶス佟丌®、ｶｶｶｶｶｶü') AS euckr_res FROM dual;
SELECT FIND_IN_SET(_euckr '나다ｶｶス佟丌®、ｶｶ龔', _euckr '나다ｶｶス佟丌®、ｶｶ龔') AS euckr_res FROM dual;
SELECT FIND_IN_SET(_euckr '나다ｶｶス佟丌®、ｶｶｶｶｶｶ', _euckr '나다ｶｶス佟丌®、ｶｶｶｶｶｶ') AS euckr_res FROM dual;
SELECT FIND_IN_SET(_euckr '@ABCDEFGHIJKLMNO', _euckr '@ABCDEFGHIJKLMNO') AS euckr_res FROM dual;
SELECT FIND_IN_SET(_euckr 'abcdefghijklmno', _euckr 'abcdefghijklmno') AS euckr_res FROM dual;
SELECT FIND_IN_SET(_euckr '라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ나다ｶｶス佟丌®、ｶｶ龔', _euckr '라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ나다ｶｶス佟丌®、ｶｶ龔') AS euckr_res FROM dual;
SELECT FIND_IN_SET(_euckr 'ｶｶｶｶｶｶｶｶｶｶｶｶ龔', _euckr 'ｶｶｶｶｶｶｶｶｶｶｶｶ龔') AS euckr_res FROM dual;
SELECT FIND_IN_SET(_euckr '丂丄丅丌丒丟丣', _euckr '丂丄丅丌丒丟丣') AS euckr_res FROM dual;
SELECT FIND_IN_SET(_euckr '許體_TRIG_體', _euckr '許體_TRIG_體') AS euckr_res FROM dual;

###### CAST ######
SELECT CAST( 'abc' AS NATIONAL CHAR );
SELECT CAST( 'abc' AS NCHAR );
SELECT CAST( _euckr '繁體ing' AS NATIONAL CHAR );
SELECT CAST( _euckr '繁體ing' AS NCHAR );

SELECT CAST(_euckr ' '!'#$%&''()*+,-./' AS NATIONAL CHAR);
SELECT CAST(_euckr ' '!'#$%&''()*+,-./' AS NCHAR);

SELECT CAST(_euckr '0123456789:;<=>ｶｶｶｶ' AS NATIONAL CHAR);
SELECT CAST(_euckr '0123456789:;<=>ｶｶｶｶ' AS NCHAR);

SELECT CAST(_euckr '@ABCDEFGHIJKLMNO' AS NATIONAL CHAR);
SELECT CAST(_euckr '@ABCDEFGHIJKLMNO' AS NCHAR);

###### REVERSE ######
SELECT REVERSE(_euckr 'abcdefghijklmno');
SELECT REVERSE(_euckr 'pqrstuvwxyz{|}~');

###### NULLIF ######
SELECT NULLIF('abcdefghijklmno', 123), NULLIF('123', 123), NULLIF(NULL, 'pqrstuvwxyz{|}~');

###### 字符串函数 ######
SELECT BIT_LENGTH('나다ｶｶス佟丌®、');
SELECT BIT_LENGTH('¤№ｶｶｶｶｶｶｶｶｶｶｶｶ龔');
SELECT BIT_LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶｶｶｶｶ');
SELECT BIT_LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶ');
SELECT BIT_LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶ');
SELECT BIT_LENGTH('@ABCDEFGHIJKLMNO');
SELECT BIT_LENGTH('abcdefghijklmno');
SELECT BIT_LENGTH('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあ');
SELECT BIT_LENGTH('êěｶｶｶｶē나다ｶｶス佟丌®、íìｶｶ龔ǐｶｶｶｶīｶｶ龔');
SELECT BIT_LENGTH('ｶｶｶｶｶｶｶｶｶｶｶｶ龔ńňｶｶ龔óòｶｶ龔ǒｶｶｶｶō나다ｶｶス佟丌®、');
SELECT BIT_LENGTH('丂丄丅丌丒丟丣两丨丫丮丯丰丵乀乁乄乇乑');
SELECT BIT_LENGTH('許體_TRIG_體');

SELECT CHARSET(char('나다ｶｶス佟丌®、')), CHARSET(char('나다ｶｶス佟丌®、' USING utf8mb4));
SELECT CHARSET(char('나다ｶｶス佟丌®、')), CHARSET(char('나다ｶｶス佟丌®、' USING euckr));
SELECT CHARSET(char('나다ｶｶス佟丌®、')), CHARSET(char('나다ｶｶス佟丌®、' USING GB18030));

SELECT CHARSET(char('¤№ｶｶｶｶｶｶｶｶｶｶｶｶ龔')), CHARSET(char('¤№ｶｶｶｶｶｶｶｶｶｶｶｶ龔' USING utf8mb4));
SELECT CHARSET(char('¤№ｶｶｶｶｶｶｶｶｶｶｶｶ龔')), CHARSET(char('¤№ｶｶｶｶｶｶｶｶｶｶｶｶ龔' USING euckr));
SELECT CHARSET(char('¤№ｶｶｶｶｶｶｶｶｶｶｶｶ龔')), CHARSET(char('¤№ｶｶｶｶｶｶｶｶｶｶｶｶ龔' USING GB18030));

SELECT CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶｶｶｶｶ')), CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶｶｶｶｶ' USING utf8mb4));
SELECT CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶｶｶｶｶ')), CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶｶｶｶｶ' USING euckr));
SELECT CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶｶｶｶｶ')), CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶｶｶｶｶ' USING GB18030));

SELECT CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶ')), CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶ' USING utf8mb4));
SELECT CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶ')), CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶ' USING euckr));
SELECT CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶ')), CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶ' USING GB18030));

SELECT CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶ')), CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶ' USING utf8mb4));
SELECT CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶ')), CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶ' USING euckr));
SELECT CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶ')), CHARSET(char('라마ｶｶテキ驍撙イモあ龔乜乣ŅÑЌЎｶｶあｶｶｶｶ' USING GB18030));

SELECT CHARSET(char('@ABCDEFGHIJKLMNO')), CHARSET(char('@ABCDEFGHIJKLMNO' USING utf8mb4));
SELECT CHARSET(char('@ABCDEFGHIJKLMNO')), CHARSET(char('@ABCDEFGHIJKLMNO' USING euckr));
SELECT CHARSET(char('@ABCDEFGHIJKLMNO')), CHARSET(char('@ABCDEFGHIJKLMNO' USING GB18030));

SELECT CHARSET(char('abcdefghijklmno')), CHARSET(char('abcdefghijklmno' USING utf8mb4));
SELECT CHARSET(char('abcdefghijklmno')), CHARSET(char('abcdefghijklmno' USING euckr));
SELECT CHARSET(char('abcdefghijklmno')), CHARSET(char('abcdefghijklmno' USING GB18030));

