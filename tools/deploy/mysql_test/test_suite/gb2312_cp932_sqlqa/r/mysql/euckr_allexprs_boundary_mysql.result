DROP TABLE films;
CREATE TABLE films (
    id INT PRIMARY KEY,
    title VARCHAR(255),
    director VARCHAR(255),
    release_year INT,
    genre VARCHAR(100)
);
INSERT INTO films (id, title, director, release_year, genre) VALUES
