purge recyclebin;
result_format: 4
#Environmental cleaning


result_format: 4
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
SET sql_mode = '';

###?÷√≤¢≤Èø¥?«∞◊÷∑˚ºØ?÷√
set names 'gb2312';
set character_set_database = 'gb2312';
set character_set_server = 'gb2312';
set character_set_results = 'utf8mb4';
show character set where Charset = 'gb2312';
Charset	Description	Default collation	Maxlen
gb2312	GB2312 Simplified Chinese	gb2312_chinese_ci	2
show variables like 'character_set%';
Variable_name	Value
character_sets_dir	
character_set_client	gb2312
character_set_connection	gb2312
character_set_database	gb2312
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	gb2312
character_set_system	utf8mb4
# ?Ω®◊‚??÷∏∂®◊÷∑˚ºØ£¨???«∞œµ?◊÷∑˚ºØ
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET gb2312;
use db1;
drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100));

DROP PROCEDURE build_gb2312_table;

create procedure build_gb2312_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128|| (i >= 0xA1 && i < 0xE0) ) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_gb2312_table();
/

DROP PROCEDURE build_gb2312_table;
/

create procedure build_gb2312_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_gb2312_table();
/


