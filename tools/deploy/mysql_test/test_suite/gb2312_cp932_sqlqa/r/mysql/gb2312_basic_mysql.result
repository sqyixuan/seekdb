select collation(concat(convert("abc" using utf8), convert("cde" using gb2312))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf8mb4_general_ci |
+--------------------+
select collation(concat(convert("abc" using utf16), convert("cde" using gb2312))) as combined_string from dual;
+------------------+
| combined_string  |
+------------------+
| utf16_general_ci |
+------------------+

select collation(concat(convert("abc" using tis620), convert("cde" using gb2312))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (tis620_thai_ci,IMPLICIT), (gb2312_chinese_ci,IMPLICIT)
select collation(concat(convert("abc" using latin1), convert("cde" using gb2312))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (latin1_swedish_ci,IMPLICIT), (gb2312_chinese_ci,IMPLICIT)
select collation(concat(convert("abc" using ascii), convert("cde" using gb2312))) as combined_string from dual;
+-------------------+
| combined_string   |
+-------------------+
| gb2312_chinese_ci |
+-------------------+

