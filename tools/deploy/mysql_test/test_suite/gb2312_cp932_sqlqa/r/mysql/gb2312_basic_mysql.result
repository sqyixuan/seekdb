| a    | collation(a)      | hex(a) |
+------+-------------------+--------+
| A    | gb2312_chinese_ci | 41     |
| A    | gb2312_chinese_ci | 41     |
| A    | gb2312_chinese_ci | 41     |
| a	   | gb2312_chinese_ci | 6109   |
| a    | gb2312_chinese_ci | 61     |
| a    | gb2312_chinese_ci | 61     |
| a    | gb2312_chinese_ci | 61     |
| a    | gb2312_chinese_ci | 61     |
| abc  | gb2312_chinese_ci | 616263 |
| abc  | gb2312_chinese_ci | 616263 |
+------+-------------------+--------+
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
select a, hex(a) from t1 where a = 'a ';
