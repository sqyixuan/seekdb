CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(1) charset ujis collate ujis_bin);

DROP PROCEDURE build_ujis_table;

create procedure build_ujis_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_ujis_table();
/
