set names ujis;
select collation(concat(convert("abc" using gb18030_2022), convert("cde" using ujis))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (gb18030_2022_chinese_ci,IMPLICIT), (ujis_japanese_ci,IMPLICIT)
select collation(concat(convert("abc" using gb18030), convert("cde" using ujis))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (gb18030_chinese_ci,IMPLICIT), (ujis_japanese_ci,IMPLICIT)
select collation(concat(convert("abc" using utf8), convert("cde" using ujis))) as combined_string from dual;
+--------------------+
| combined_string    |
+--------------------+
| utf8mb4_general_ci |
+--------------------+
select collation(concat(convert("abc" using utf16), convert("cde" using ujis))) as combined_string from dual;
+------------------+
| combined_string  |
+------------------+
| utf16_general_ci |
+------------------+
select collation(concat(convert("abc" using tis620), convert("cde" using ujis))) as combined_string from dual;
ERROR HY000: Illegal mix of collations (tis620_thai_ci,IMPLICIT), (ujis_japanese_ci,IMPLICIT)
