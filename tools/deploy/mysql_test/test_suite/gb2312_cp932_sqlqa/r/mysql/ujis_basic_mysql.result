### DBēséwíŤéöēĄŹWĀCć—ópĆn?ŗ“?éöēĄŹW
DROP DATABASE db2;
CREATE DATABASE db2;
use db2;
drop table db2.t1;
CREATE TABLE db2.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(1));
DROP PROCEDURE build_ujis_table;

create procedure build_ujis_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_ujis_table();
/
ERROR HY000: Incorrect string value

INSERT INTO T1(a) VALUES (_ujis 0xa2a1);
INSERT INTO T1(a) VALUES (_ujis 0xA4A2);
INSERT INTO T1(a) VALUES (0xa2a1);
INSERT INTO T1(a) VALUES (0xA4A2);
INSERT INTO T1(a) VALUES (0xF1F2);

