purge recyclebin;
result_format: 4
#Environmental cleaning
###?íuíī???
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
##?íuõů?äŇďĖĎOéöēĄŹW?íu
set names 'ujis' COLLATE ujis_japanese_ci;
set character_set_database = 'ujis';
set character_set_server = 'ujis';
set character_set_results = 'utf8mb4';
show character set where Charset = 'ujis';
Charset	Description	Default collation	Maxlen
ujis	EUC-JP Japanese	ujis_japanese_ci	3
show variables like '%character%';
Variable_name	Value
character_sets_dir	
character_set_client	ujis
character_set_connection	ujis
character_set_database	ujis
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	ujis
character_set_system	utf8mb4
show variables like'%collation%';
Variable_name	Value
collation_connection	ujis_japanese_ci
