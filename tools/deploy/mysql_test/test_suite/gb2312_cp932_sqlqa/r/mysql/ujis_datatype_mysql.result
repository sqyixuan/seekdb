### ĎīĎľéöēĄŹW? ujis
use db1;
drop table t11;
ERROR 42S02: Unknown table 'db1.t11'
CREATE TABLE t11 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(1),
    nchar_column NATIONAL CHAR(1),
    varchar_column VARCHAR(1),
    nvarchar_column NATIONAL VARCHAR(1),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = utf8mb4;

DROP PROCEDURE build_ujis_table;

create procedure build_ujis_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t11(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_ujis_table();
/

insert into t11(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (_ujis 0x878A,_ujis 0x878A,_ujis 0x878A,_ujis 0x878A,_ujis 0x878A,_ujis 0x878A);
ERROR HY000: Invalid ujis character string: '878A'
insert into t11(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (0x9373,0x9373,0x9373,0x9373,0x9373,0x9373);
ERROR HY000: Incorrect string value
insert into t11(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (0xF1F2,0xF1F2,0xF1F2,0xF1F2,0xF1F2,0xF1F2);
ERROR HY000: Incorrect string value
select * from t11 order by id;
