DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET ujis;
use db1;

drop table t1;
CREATE TABLE t1 (char_column CHAR(1))DEFAULT CHARACTER SET = ujis;
insert into t1 values(unhex(hex(0xa4a2)));
select * from t1 ;
