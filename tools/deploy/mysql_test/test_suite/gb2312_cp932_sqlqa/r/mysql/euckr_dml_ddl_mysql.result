    id INT AUTO_INCREMENT PRIMARY KEY COMMENT 'id_',
    a char(1) COMMENT 'a_'
)DEFAULT CHARACTER SET = euckr;

DROP PROCEDURE build_euckr_table;

create procedure build_euckr_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_euckr_table();
/

