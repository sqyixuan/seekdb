drop table t1;

create table t1 (
  ujis char(1) character set ujis,
  sjis char(1) character set sjis,
  name char(64)
);
insert into t1 (sjis,name) values (0x00A5,'U+00A5 YEN SIGN');
ERROR 22001: Data too long for column 'sjis' at row 1
insert into t1 (sjis,name) values (0x2014,'U+2014 EM DASH');
