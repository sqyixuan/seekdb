### SET @@session.max_error_count = 0;
update ignore t1 set sjis=ujis, ujis2=sjis;
ERROR HY000: Incorrect string value
### SET @@session.max_error_count = DEFAULT;
Characters with safe Unicode round trip
select hex(ujis), hex(sjis), hex(ujis2), name from t1 where ujis=ujis2 order by ujis;
+-----------+-----------+------------+--------------+
| hex(ujis) | hex(sjis) | hex(ujis2) | name         |
+-----------+-----------+------------+--------------+
| 20        |           |            | U+0020 SPACE |
+-----------+-----------+------------+--------------+
