### OB äøMYSQL ę¾ē¤ŗē»ęäøäøč“ć
set names utf8mb4;
INSERT INTO t1(a) VALUES('å¼ äø');
ERROR HY000: Incorrect string value
set names eucjpms;

drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(10) charset eucjpms collate eucjpms_bin);

DROP PROCEDURE build_eucjpms_table;

create procedure build_eucjpms_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_eucjpms_table();
/

