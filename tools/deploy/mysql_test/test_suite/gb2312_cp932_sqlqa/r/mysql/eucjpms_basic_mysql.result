# åå»ŗē§ę·ę¶ęå®å­ē¬¦éļ¼éŖčÆå½åē³»ē»å­ē¬¦é
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET eucjpms;
use db1;

drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100));

DROP PROCEDURE build_eucjpms_table;

create procedure build_eucjpms_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_eucjpms_table();
/

