### DBäøęå®å­ē¬¦éļ¼éēØē³»ē»é»č®¤å­ē¬¦é
DROP DATABASE db2;
CREATE DATABASE db2;
use db2;
drop table db2.t1;
CREATE TABLE db2.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(10));
DROP PROCEDURE build_eucjpms_table;

create procedure build_eucjpms_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_eucjpms_table();
/

