########################## update ########################
update db2.t2 set a = 'a' where a='a';
select * from db2.t2 where a='a' order by a;
+------+
| a    |
+------+
+------+

update db2.t2 set a = 'A' where a='a';
select * from db2.t2 where a='A' order by a;
+------+
| a    |
+------+
+------+

update db2.t2 set a = ']' where a='{';
select * from db2.t2 where a=']' order by a;
+------+
| a    |
+------+
+------+

