########################## DDL ########################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET gb2312;
use db1;
DROP table db1.t1;
CREATE TABLE db1.t1 (
    id INT AUTO_INCREMENT PRIMARY KEY COMMENT 'id_',
    a char(100) COMMENT 'a_'
)DEFAULT CHARACTER SET = gb2312;

DROP PROCEDURE build_gb2312_table;

create procedure build_gb2312_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_gb2312_table();
/

