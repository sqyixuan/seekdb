purge recyclebin;
result_format: 4
#Environmental cleaning
result_format: 4
Charset	Description	Default collation	Maxlen
gb2312	GB2312 Simplified Chinese	gb2312_chinese_ci	2
Variable_name	Value
character_sets_dir	
character_set_client	gb2312
character_set_connection	gb2312
character_set_database	gb2312
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	gb2312
character_set_system	utf8mb4
########################## select ########################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET gb2312;
use db1;

DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(100)
)DEFAULT CHARACTER SET = gb2312;

DROP PROCEDURE build_gb2312_table;

create procedure build_gb2312_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_gb2312_table();
/

