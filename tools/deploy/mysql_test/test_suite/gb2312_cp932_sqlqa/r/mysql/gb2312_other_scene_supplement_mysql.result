SET NAMES gb2312;
SELECT
    LPAD(_gb2312 'әә', 10, _gb2312 'ЧЦ') AS l_char,
    RPAD(_gb2312 'әә', 10, _gb2312 'ЧЦ') AS r_char,
    LPAD(_gb2312 'ІвКФ', 10, _gb2312 'ЧЦ·ы') AS l_varchar,
    RPAD(_gb2312 'ІвКФ', 10, _gb2312 'ЧЦ·ы') AS r_varchar,
    LPAD('ІвКФОДұҫ', 10, 'ЧЦ·ыМоід') AS l_text,
    RPAD('ІвКФОДұҫ', 10, 'ЧЦ·ыМоід') AS r_text,
    LPAD(_binary 'ІвКФ¶юҪшЦЖ', 10, _binary 'Моід¶юҪшЦЖ') AS l_blob,
    RPAD(_binary 'ІвКФ¶юҪшЦЖ', 10, _binary 'Моід¶юҪшЦЖ') AS r_blob;
+----------------------+----------------------+----------------------+----------------------+----------------------+----------------------+------------+------------+
| l_char               | r_char               | l_varchar            | r_varchar            | l_text               | r_text               | l_blob     | r_blob     |
+----------------------+----------------------+----------------------+----------------------+----------------------+----------------------+------------+------------+
| ЧЦЧЦЧЦЧЦЧЦЧЦЧЦЧЦЧЦәә                    | әәЧЦЧЦЧЦЧЦЧЦЧЦЧЦЧЦЧЦ                     | ЧЦ·ыЧЦ·ыЧЦ·ыЧЦ·ыІвКФ                 | ІвКФЧЦ·ыЧЦ·ыЧЦ·ыЧЦ·ы                 | ЧЦ·ыМоідЧЦ·ыІвКФОДұҫ                  | ІвКФОДұҫЧЦ·ыМоідЧЦ·ы                  | ІвКФ¶юҪшЦЖ          | ІвКФ¶юҪшЦЖ          |
+----------------------+----------------------+----------------------+----------------------+----------------------+----------------------+------------+------------+

SET NAMES gb2312;
SET @ivar = 1234;
SET @str1 = 'SELECT ?';
SET @str2 = CONVERT(@str1 USING gb2312);
PREPARE stmt1 FROM @str2;
EXECUTE stmt1 USING @ivar;
+------+
| ?    |
+------+
| 1234 |
+------+

