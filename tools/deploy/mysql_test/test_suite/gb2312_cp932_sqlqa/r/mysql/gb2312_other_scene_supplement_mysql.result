CREATE PROCEDURE test_gb2312_character_set()
BEGIN
    DECLARE v_char CHAR(255);
    DECLARE v_varchar VARCHAR(255);
    DECLARE v_text TEXT;
    SET v_char = 'ІвКФ';
    SET v_varchar = 'іӨЧЦ·ыҙ®ІвКФ';
    SET v_text = 'ХвКЗТ»ёціӨОДұҫІвКФЎЈGB2312ЧЦ·ыјҜҝЙТФҙжҙўәәЧЦЎЈ';
    SELECT
        CHAR_LENGTH(v_char) AS char_length,
        CHAR_LENGTH(v_varchar) AS varchar_length,
        CHAR_LENGTH(v_text) AS text_length;
END$$

CALL test_gb2312_character_set();
+-------------+----------------+-------------+
| char_length | varchar_length | text_length |
+-------------+----------------+-------------+
|           2 |              6 |          26 |
+-------------+----------------+-------------+

DROP TABLE IF EXISTS my_rec_types;
Warnings:
Note	1051	Unknown table 'db1.my_rec_types'
CREATE TABLE my_rec_types (
    field_char CHAR(10) CHARACTER SET gb2312,
    field_varchar VARCHAR(10) CHARACTER SET gb2312,
    field_text TEXT CHARACTER SET gb2312,
    field_blob BLOB
);

CREATE PROCEDURE init_rec(IN p1 VARCHAR(10))
BEGIN
    INSERT INTO my_rec_types (field_char, field_varchar, field_text, field_blob)
    VALUES (
        LPAD(CONVERT('ДгәГ' USING gb2312), CHAR_LENGTH(p1), '?'),
        LPAD(CONVERT('ІвКФ' USING gb2312), CHAR_LENGTH(p1) - 1, '?'),
        LPAD(CONVERT('ХвКЗТ»¶ООДұҫ' USING gb2312), CHAR_LENGTH(p1) + 1, '?'),
        CONVERT('ХвКЗТ»ёц BLOB КэҫЭ' USING gb2312)
    );
END //

CALL init_rec('ІвКФКэҫЭ');
SELECT field_char, field_varchar, field_text, field_blob FROM my_rec_types;
+------------+---------------+------------+--------------------+
| field_char | field_varchar | field_text | field_blob         |
+------------+---------------+------------+--------------------+
| ??ДгәГ         | ?ІвКФ             | ХвКЗТ»¶ООД          | ХвКЗТ»ёц BLOB КэҫЭ            |
+------------+---------------+------------+--------------------+
DROP TABLE my_rec_types;
DROP PROCEDURE init_rec;

