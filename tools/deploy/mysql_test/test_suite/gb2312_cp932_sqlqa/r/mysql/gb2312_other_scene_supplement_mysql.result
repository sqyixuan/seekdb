  (CONVERT('әәЧЦ3' USING gb2312), CONVERT('әәЧЦ4' USING gb2312), CONVERT('ХвКЗБнТ»¶ОІвКФОДұҫ' USING gb2312), NULL),
  (CONVERT('әәЧЦ5' USING gb2312), CONVERT('әәЧЦ6' USING gb2312), CONVERT('УЦКЗТ»¶ОІвКФОДұҫ' USING gb2312), NULL);

