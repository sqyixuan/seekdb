purge recyclebin;
result_format: 4
#Environmental cleaning
###ЙиЦГі¬КұКұјд
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
##ЙиЦГІўІйҝҙөұЗ°ЧЦ·ыјҜЙиЦГ
set names 'gb2312' COLLATE gb2312_chinese_ci;
set character_set_database = 'gb2312';
set character_set_server = 'gb2312';
set character_set_results = 'utf8mb4';
show character set where Charset = 'gb2312';
Charset	Description	Default collation	Maxlen
gb2312	GB2312 Simplified Chinese	gb2312_chinese_ci	2
show variables like '%character%';
Variable_name	Value
character_sets_dir	
character_set_client	gb2312
character_set_connection	gb2312
character_set_database	gb2312
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	gb2312
character_set_system	utf8mb4
show variables like'%collation%';
Variable_name	Value
collation_connection	gb2312_chinese_ci
collation_database	gb2312_chinese_ci
collation_server	gb2312_chinese_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
############################# ЧЦ·ыАаРН #############################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET gb2312;
use db1;

drop table t1;
CREATE TABLE t1 (
  a CHAR(255) CHARACTER SET gb2312,
  b VARCHAR(255) CHARACTER SET gb2312,
  c TEXT CHARACTER SET gb2312,
  d BLOB
) CHARACTER SET gb2312;

