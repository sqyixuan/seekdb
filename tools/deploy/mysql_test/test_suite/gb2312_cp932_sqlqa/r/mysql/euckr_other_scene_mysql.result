#### Ņ’▌╗ euckr Ē«▌¼??
SET NAMES euckr;
DROP TABLE t1;
CREATE TABLE t1 (b VARCHAR(2));
INSERT INTO t1 VALUES ('0'),('1'),('2'),('3'),('4'),('5'),('6'),('7');
INSERT INTO t1 VALUES ('8'),('9'),('A'),('B'),('C'),('D'),('E'),('F');
DROP TABLE head;
DROP TABLE tail;
CREATE  TABLE head AS SELECT concat(b1.b, b2.b) AS head FROM t1 b1, t1 b2;
CREATE  TABLE tail AS SELECT concat(b1.b, b2.b) AS tail FROM t1 b1, t1 b2;
DROP TABLE t1;

CREATE TABLE t1 AS
SELECT concat(head, tail) AS code
FROM head, tail
WHERE (head BETWEEN '80' AND 'FF') AND   (tail BETWEEN '20' AND 'FF')
ORDER BY head, tail;
SELECT COUNT(*) FROM t1;
+----------+
| COUNT(*) |
+----------+
|    28672 |
+----------+

DROP TABLE t_test;
CREATE TABLE t_test AS
SELECT concat(head, tail) AS code
FROM head, tail
WHERE (head BETWEEN '80' AND '81') AND   (tail BETWEEN 'FA' AND 'FF')
ORDER BY head, tail;
SELECT COUNT(*) FROM t_test;
+----------+
| COUNT(*) |
+----------+
|       12 |
+----------+

