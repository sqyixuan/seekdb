DROP TABLE IF EXISTS t_multicharset;
CREATE TABLE t_multicharset (
    code_utf8 CHAR(100) CHARSET utf8 COLLATE utf8_general_ci,
    desc_varchar_utf8mb4 VARCHAR(100) CHARSET utf8mb4 COLLATE utf8mb4_general_ci,
    code_gbk CHAR(100) CHARSET gbk COLLATE gbk_chinese_ci,
    code_gb18030 CHAR(100) CHARSET gb18030 COLLATE gb18030_chinese_ci,
    code_euckr CHAR(100) CHARSET euckr COLLATE euckr_korean_ci,
    data_json JSON
);

