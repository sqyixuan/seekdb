drop table test_euckr_bak;

CREATE TABLE test_euckr_bak(
    c0 TEXT COLLATE euckr_korean_ci,
    c1 TEXT COLLATE euckr_bin,
    c2 TEXT COLLATE euckr_korean_ci,
    c3 TEXT COLLATE euckr_bin,
    c4 TEXT COLLATE utf8mb4_unicode_ci,
    c5 TEXT COLLATE euckr_korean_ci,
    c6 TEXT COLLATE euckr_bin,
    sal INT,
    id INT
) CHARACTER SET euckr;

drop procedure test_euckr_bak_ascii_pro;

CREATE PROCEDURE test_euckr_bak_ascii_pro()
BEGIN
  DECLARE i INT DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO test_euckr_bak(c0, c1, c2, c3, c4, c5, c6, sal, id)
    VALUES(CONVERT(CHAR(i) USING euckr), CONVERT(CHAR(i) USING euckr), CONVERT(CHAR(i) USING euckr), CONVERT(CHAR(i) USING euckr), CONVERT(CHAR(i) USING euckr), CONVERT(CHAR(i) USING euckr), CONVERT(CHAR(i) USING euckr), i, i);
    SET i = i + 1;
  END WHILE;
  COMMIT;
END /

CALL test_euckr_bak_ascii_pro();
