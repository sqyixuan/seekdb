drop table test_euckr_bak;
create table test_euckr_bak(c0 char(100) collate euckr_korean_ci,c1 char(100) collate euckr_bin,c2 char(100) collate euckr_korean_ci,c3 char(100) collate euckr_bin,c4 char(100) collate utf8mb4_unicode_ci,c5 char(100) collate euckr_korean_ci,c6 char(100) collate euckr_bin,sal int,id int) character set euckr;

drop procedure test_euckr_bak_ascii_pro;

create procedure test_euckr_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_euckr_bak values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
/
call test_euckr_bak_ascii_pro();
/
