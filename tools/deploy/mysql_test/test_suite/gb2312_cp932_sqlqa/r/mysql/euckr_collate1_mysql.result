create table euckr_table(c1 char(3) charset euckr collate euckr_korean_ci);
create table euckr_bin_table(c1 char(3) charset euckr collate euckr_bin);

DROP PROCEDURE build_euckr_table;

create procedure build_euckr_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into euckr_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_euckr_table();
/
