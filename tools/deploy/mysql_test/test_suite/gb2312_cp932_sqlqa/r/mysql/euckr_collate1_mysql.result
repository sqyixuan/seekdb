drop table test_euckr_bak;

CREATE TABLE test_euckr_bak(
    c0 SET('$', 'A', 'B') COLLATE euckr_korean_ci,
    c1 SET('$', 'A', 'B') COLLATE euckr_bin,
    c2 SET('$', 'A', 'B') COLLATE euckr_korean_ci,
    c3 SET('$', 'A', 'B') COLLATE euckr_bin,
    c4 SET('$', 'A', 'B') COLLATE utf8mb4_unicode_ci,
    c5 SET('$', 'A', 'B') COLLATE euckr_korean_ci,
    c6 SET('$', 'A', 'B') COLLATE euckr_bin,
    sal INT,
    id INT
) CHARACTER SET euckr;

INSERT INTO test_euckr_bak (c0,c1,c2,c3,c4,c5,c6,sal) VALUES
('A', 'A', 'A', 'A', 'A', 'A', 'A', 2300),
