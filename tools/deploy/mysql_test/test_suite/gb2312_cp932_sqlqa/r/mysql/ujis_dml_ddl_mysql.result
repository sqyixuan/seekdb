########################## éöēĄ???ĎīĎľéöēĄŹW ########################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET ujis;
use db1;
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = ujis;

DROP PROCEDURE build_ujis_table;

create procedure build_ujis_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_ujis_table();
/

