purge recyclebin;
result_format: 4
#Environmental cleaning
###?íuíī???
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##  ujis
##?íuõů?äŇďĖĎOéöēĄŹW?íu
set names 'ujis' COLLATE ujis_japanese_ci;
set character_set_database = 'ujis';
set character_set_server = 'ujis';
set character_set_results = 'utf8mb4';
show character set where Charset = 'ujis';
Charset	Description	Default collation	Maxlen
ujis	EUC-JP Japanese	ujis_japanese_ci	3
show variables like '%character%';
Variable_name	Value
character_sets_dir	
character_set_client	ujis
character_set_connection	ujis
character_set_database	ujis
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	ujis
character_set_system	utf8mb4
show variables like'%collation%';
Variable_name	Value
collation_connection	ujis_japanese_ci
collation_database	ujis_japanese_ci
collation_server	ujis_japanese_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
########################## select ########################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET ujis;
use db1;
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = ujis;

DROP PROCEDURE build_ujis_table;

create procedure build_ujis_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_ujis_table();
/
ERROR HY000: Incorrect string value
INSERT INTO T2(a) VALUES (_ujis 0xA2AF);
INSERT INTO T2(a) VALUES (_ujis 0xA2B0);
