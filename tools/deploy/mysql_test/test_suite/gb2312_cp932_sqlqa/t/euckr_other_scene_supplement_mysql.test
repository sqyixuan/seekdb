INSERT INTO t1 VALUES(CONVERT(_utf8 '?' USING euckr));
INSERT INTO t1 VALUES(CONVERT(_utf8 'Æ' USING euckr));
INSERT INTO t1 VALUES(CONVERT(_utf8 'Ø' USING euckr));
INSERT INTO t1 VALUES(CONVERT(_utf8 '?' USING euckr));
SELECT CONVERT(a USING euckr) FROM t1 ORDER BY a DESC;


