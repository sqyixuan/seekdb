                       (CONVERT(_utf8mb4 '?' USING euckr)),
                       (CONVERT(_utf8mb4 '?' USING euckr)),
                       (CONVERT(_utf8mb4 '?' USING euckr)),
                       (CONVERT(_utf8mb4 '?' USING euckr)),
                       (CONVERT(_utf8mb4 '?' USING euckr));
SELECT * FROM t1 ORDER BY a;
SELECT HEX(CONVERT(a USING euckr)) FROM t1 ORDER BY a;

