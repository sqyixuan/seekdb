DROP PROCEDURE init_rec;
DELIMITER //;
CREATE PROCEDURE init_rec(IN p1 VARCHAR(10))
BEGIN
  DECLARE a CHAR(10);
  DECLARE b CHAR(10);
  DECLARE k CHAR(10);
  SET a = LPAD(CONVERT('ºª????????????佈???????' USING euckr), LENGTH(p1), 'º');
  SET b = LPAD(CONVERT('?????????佺?佾侁?侄' USING euckr), LENGTH(p1)-1, '?');
  SET k = LPAD(CONVERT('許體_TRIG_體' USING euckr), LENGTH(p1)+1, '?');
  SELECT CONCAT('r.a = ', a) AS a_output;
  SELECT CONCAT('r.b = ', b) AS b_output;
  SELECT CONCAT('r.k = ', k) AS k_output;
END //
DELIMITER ;//
CALL init_rec('許體_TRIG_體');

