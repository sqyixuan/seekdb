DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
    a VARCHAR(1) CHARACTER SET euckr COLLATE euckr_korean_ci
) DEFAULT CHARACTER SET = euckr COLLATE euckr_korean_ci;
INSERT INTO t1 VALUES ('?'), ('?'), ('æ'), ('Ø'), ('?');
SELECT * FROM t1 ORDER BY a DESC;

DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
    a VARCHAR(10) CHARACTER SET euckr COLLATE euckr_korean_ci
) DEFAULT CHARACTER SET = euckr COLLATE euckr_korean_ci;
