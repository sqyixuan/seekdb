DROP TABLE IF EXISTS sample_table;
CREATE TABLE sample_table (
    char_0 CHAR(0) CHARACTER SET euckr,
    char_1 CHAR(1) CHARACTER SET euckr,
    char_255 CHAR(255) CHARACTER SET euckr,
    char_256 CHAR(256) CHARACTER SET euckr
) DEFAULT CHARSET=euckr;
INSERT INTO sample_table (char_0, char_1, char_255, char_256) VALUES
('', 'A', LPAD('', 255, 'A'), LPAD('', 256, 'B'));
SELECT * FROM sample_table;

SET sql_mode = '';
DROP TABLE IF EXISTS sample_table2;
CREATE TABLE sample_table2 (
    varchar_0 VARCHAR(0) CHARACTER SET euckr,
    varchar_1 VARCHAR(1) CHARACTER SET euckr,
    varchar_262144 VARCHAR(262144) CHARACTER SET euckr,
    varchar_262146 VARCHAR(262146) CHARACTER SET euckr
) DEFAULT CHARACTER SET=euckr;

SELECT JSON_ARRAY(CONVERT('허가하' USING euckr)) FROM DUAL;
SELECT JSON_ARRAY(CONVERT('허가' USING euckr)) FROM DUAL;
SELECT JSON_OBJECT(
    'char12', CONVERT('허가' USING euckr)
) FROM DUAL;

DELIMITER $$;
CREATE PROCEDURE Test_EUCKR_Character_Set()
BEGIN
    DECLARE v_var4 CHAR(200);
    DECLARE n_var4 CHAR(200);
    SET v_var4 = LPAD(CONVERT('긴 문자열 테스트_최대 상황도 여기서 32767자로 도달' USING euckr), 200, ' ');
    SET n_var4 = LPAD(CONVERT('????????????????????' USING utf8mb4), 200, ' ');
    SELECT CONCAT('CHAR Length 200: ', v_var4) AS Output;
    SELECT CONCAT('CHAR Length 200: ', n_var4) AS Output;
END $$
DELIMITER ;$$
CALL Test_EUCKR_Character_Set();

