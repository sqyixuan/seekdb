DROP TABLE IF EXISTS t1;
CREATE TABLE t1 SELECT
    LPAD(CONVERT(_utf8 '?' USING euckr), 10, CONVERT(_utf8 '?' USING euckr)) AS l,
    RPAD(CONVERT(_utf8 '?' USING euckr), 10, CONVERT(_utf8 '?' USING euckr)) AS r;
### SHOW CREATE TABLE t1;
SELECT HEX(l), HEX(r) FROM t1;

SET NAMES 'euckr' COLLATE euckr_korean_ci;
SET @ivar = 1234;
SET @str1 = 'select ?';
SET @str2 = CONVERT(@str1 USING euckr);
PREPARE stmt1 FROM @str2;
EXECUTE stmt1 USING @ivar;

