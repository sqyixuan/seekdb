select * from t1 order by id;
SELECT CONVERT(blob_column USING gb2312) AS char_value FROM t1;
SELECT CAST(blob_column AS CHAR CHARSET gb2312) AS string_value FROM t1;
SELECT CAST(blob_column AS CHAR CHARSET UTF8MB4) AS string_value FROM t1 ORDER BY 1;
SELECT CONVERT(text_column USING gb2312) AS char_value FROM t1;
SELECT CAST(text_column AS CHAR CHARSET gb2312) AS string_value FROM t1;
SELECT CAST(text_column AS CHAR CHARSET UTF8) AS string_value FROM t1;
