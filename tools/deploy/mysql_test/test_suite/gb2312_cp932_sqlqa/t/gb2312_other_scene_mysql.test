purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
--echo ##设置并查看当前字符集设置
set names 'gb2312' COLLATE gb2312_chinese_ci;
set character_set_database = 'gb2312';
set character_set_server = 'gb2312';
set character_set_results = 'utf8mb4';
show character set where Charset = 'gb2312';
show variables like '%character%';
show variables like'%collation%';
--enable_sorted_result

--echo ############################# 字符类型 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET gb2312;
use db1;

--error 0,1051
drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(100),
    nchar_column NATIONAL CHAR(100),
    varchar_column VARCHAR(100),
    nvarchar_column NATIONAL VARCHAR(100),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = gb2312;

--error 0,1305
DROP PROCEDURE build_gb2312_table;

delimiter /;
create procedure build_gb2312_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_gb2312_table();
/
delimiter ;/

insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (_gb2312 0xA1A1,_gb2312 0xA1A1,_gb2312 0xA1A1,_gb2312 0xA1A1,_gb2312 0xA1A1,_gb2312 0xA1A1);
