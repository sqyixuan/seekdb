        REPEAT(CONVERT('＠', CHAR CHARACTER SET gb2312), 16), -- gb2312中的特殊字符'@'
        REPEAT(CONVERT('・', CHAR CHARACTER SET gb2312), 16)  -- gb2312中的特殊字符'・'
    )
);

