INSERT INTO T_TEST VALUES (HEX(CONVERT(0xAA USING gb2312)));

SELECT * FROM T_TEST;
DESC T_TEST;

--echo ### 常用函数验证 ###

SELECT CONVERT(code USING utf8mb4) FROM T_TEST ORDER BY 1;
SELECT CONVERT(code USING gb2312) FROM T_TEST ORDER BY 1;
SELECT BINARY code FROM T_TEST ORDER BY 1;
SELECT ASCII(code) FROM T_TEST ORDER BY 1;

### OB显示结果与MYSQL不一致。
SELECT CODE,CHAR(CODE USING gb2312) FROM T_TEST ORDER BY 1;
SELECT HEX(CODE),HEX(CHAR(CODE USING gb2312)) FROM T_TEST ORDER BY 1;
SELECT UNHEX(HEX(CODE)),UNHEX(HEX(CHAR(CODE USING gb2312))) FROM T_TEST ORDER BY 1;

SELECT CHAR(CODE USING gb2312) FROM T_TEST ORDER BY 1;

SELECT CAST(code AS CHAR CHARSET utf8) FROM T_TEST ORDER BY 1;
SELECT CAST(code AS CHAR CHARSET gb2312) FROM T_TEST ORDER BY 1;
SELECT LOCATE('substr', code) FROM T_TEST ORDER BY 1;
SELECT LOCATE('substr', code, 3) FROM T_TEST ORDER BY 1;
SELECT SUBSTR(code, 2, 5) FROM T_TEST ORDER BY 1;
SELECT LTRIM(code) FROM T_TEST ORDER BY 1;
SELECT RTRIM(code) FROM T_TEST ORDER BY 1;

--ERROR 0,1051
DROP TABLE t_test2;
CREATE TABLE t_test2(CODE CHAR(100) CHARSET UTF8MB4);
--ERROR 1366
INSERT INTO t_test2 SELECT * FROM t_test;

SELECT CONVERT(code USING utf8) FROM t_test2 ORDER BY 1;
SELECT CONVERT(code USING gb2312) FROM t_test2 ORDER BY 1;
SELECT BINARY code FROM t_test2 ORDER BY 1;
SELECT ASCII(code) FROM t_test2 ORDER BY 1;
SELECT CHAR(code USING gb2312) FROM t_test2 ORDER BY 1;
SELECT CAST(code AS CHAR CHARSET utf8) FROM t_test2 ORDER BY 1;
SELECT CAST(code AS CHAR CHARSET gb2312) FROM t_test2 ORDER BY 1;
SELECT LOCATE('substr', code) FROM t_test2 ORDER BY 1;
SELECT LOCATE('substr', code, 3) FROM t_test2 ORDER BY 1;
SELECT SUBSTR(code, 2, 5) FROM t_test2 ORDER BY 1;
SELECT LTRIM(code) FROM t_test2 ORDER BY 1;
SELECT RTRIM(code) FROM t_test2 ORDER BY 1;

--echo #### 字符集混合测试 ###

--ERROR 0,1051
DROP TABLE t_test3;
CREATE TABLE t_test3(CODE CHAR(100) CHARSET GB2312,CODE2 CHAR(100) charset gb2312 collate gb2312_chinese_ci);
INSERT INTO t_test3 SELECT CODE,CODE FROM t_test;

SELECT CONVERT(code USING utf8) FROM t_test3 ORDER BY 1;
SELECT CONVERT(code USING gb2312) FROM t_test3 ORDER BY 1;
SELECT BINARY code FROM t_test3 ORDER BY 1;
SELECT ASCII(code) FROM t_test3 ORDER BY 1;
SELECT CHAR(code USING gb2312) FROM t_test3 ORDER BY 1;
SELECT CAST(code AS CHAR CHARSET utf8) FROM t_test3 ORDER BY 1;
SELECT CAST(code AS CHAR CHARSET gb2312) FROM t_test3 ORDER BY 1;
SELECT LOCATE('substr', code) FROM t_test3 ORDER BY 1;
SELECT LOCATE('substr', code, 3) FROM t_test3 ORDER BY 1;
SELECT SUBSTR(code, 2, 5) FROM t_test3 ORDER BY 1;
SELECT LTRIM(code) FROM t_test3 ORDER BY 1;
SELECT RTRIM(code) FROM t_test3 ORDER BY 1;

