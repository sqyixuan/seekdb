--echo #### 查询系统表 ###
--disable_result_log

SELECT TABLE_SCHEMA, TABLE_NAME, TABLE_TYPE
FROM information_schema.TABLES
WHERE TABLE_SCHEMA NOT IN ('information_schema', 'mysql', 'performance_schema', 'sys');

SELECT TABLE_NAME, COLUMN_NAME, DATA_TYPE, COLUMN_TYPE, IS_NULLABLE, COLUMN_DEFAULT, COLUMN_KEY, EXTRA
FROM information_schema.COLUMNS
WHERE TABLE_SCHEMA = 'your_database_name';

SELECT COLUMN_NAME, DATA_TYPE, COLUMN_TYPE, IS_NULLABLE, COLUMN_DEFAULT, COLUMN_KEY, EXTRA
FROM information_schema.COLUMNS
WHERE TABLE_SCHEMA = 'your_database_name' AND TABLE_NAME = 'your_table_name';

SELECT TABLE_SCHEMA, TABLE_NAME, COLUMN_NAME, DATA_TYPE
FROM information_schema.COLUMNS
WHERE DATA_TYPE IN ('varchar', 'int', 'datetime');
--enable_result_log

--echo #### 大小写，重音等是否敏感 ###
ALTER TABLE t_multicharset ADD COLUMN code_utf8_unicode_ci VARCHAR(100) CHARSET utf8 COLLATE utf8_unicode_ci;
INSERT INTO t_multicharset (code_utf8_unicode_ci) VALUES ('é'), ('e');
SELECT * FROM t_multicharset WHERE code_utf8_unicode_ci = 'e';
SELECT * FROM t_multicharset WHERE code_utf8_unicode_ci = 'é';

--echo #### 大小写转换 ###
SELECT
    lcase(code_utf8) AS code_utf8_lower,
    lcase(desc_varchar_utf8mb4) AS desc_varchar_utf8mb4_lower,
    lcase(code_gbk) AS code_gbk_lower,
    lcase(code_gb18030) AS code_gb18030_lower,
    lcase(code_gb2312) AS code_gb2312_lower
FROM t_multicharset;

SELECT
    LOWER(code_utf8) AS code_utf8_lower,
    LOWER(desc_varchar_utf8mb4) AS desc_varchar_utf8mb4_lower,
    LOWER(code_gbk) AS code_gbk_lower,
    LOWER(code_gb18030) AS code_gb18030_lower,
    LOWER(code_gb2312) AS code_gb2312_lower
FROM t_multicharset;

SELECT
    UPPER(code_utf8) AS code_utf8_upper,
    UPPER(desc_varchar_utf8mb4) AS desc_varchar_utf8mb4_upper,
    UPPER(code_gbk) AS code_gbk_upper,
    UPPER(code_gb18030) AS code_gb18030_upper,
    UPPER(code_gb2312) AS code_gb2312_upper
FROM t_multicharset;

SELECT
    ucase(code_utf8) AS code_utf8_upper,
    ucase(desc_varchar_utf8mb4) AS desc_varchar_utf8mb4_upper,
    ucase(code_gbk) AS code_gbk_upper,
    ucase(code_gb18030) AS code_gb18030_upper,
    ucase(code_gb2312) AS code_gb2312_upper
FROM t_multicharset;

--echo #### 模糊查询 ###

SELECT * FROM t_multicharset WHERE code_utf8 LIKE '%Text%';
SELECT * FROM t_multicharset WHERE desc_varchar_utf8mb4 LIKE 'UTF%';
SELECT * FROM t_multicharset WHERE desc_varchar_utf8mb4 LIKE '%?';
SELECT * FROM t_multicharset WHERE code_gbk LIKE '%文本%' OR code_gb18030 LIKE '%文本%';
SELECT * FROM t_multicharset WHERE code_gb2312 LIKE '%テキ%';
SELECT * FROM t_multicharset
WHERE code_utf8 LIKE '%Text%'
OR desc_varchar_utf8mb4 LIKE '%Text%'
OR code_gbk LIKE '%文本%'
OR code_gb18030 LIKE '%文本%'
OR code_gb2312 LIKE '%テキ%';

--error 1139,3697
SELECT * FROM t_multicharset WHERE desc_varchar_utf8mb4 REGEXP '[\x{1F600}-\x{1F64F}]';

--echo #### 增加JSON数据类型测试 ###

ALTER TABLE t_multicharset ADD COLUMN data_json JSON;
UPDATE t_multicharset
SET data_json = '{"key1": "value1", "key2": "value2"}'
WHERE code_utf8 = 'UTF-8 Text';

DROP TABLE IF EXISTS t_multicharset;
CREATE TABLE t_multicharset (
    code_utf8 CHAR(100) CHARSET utf8 COLLATE utf8_general_ci,
    desc_varchar_utf8mb4 VARCHAR(100) CHARSET utf8mb4 COLLATE utf8mb4_general_ci,
    code_gbk CHAR(100) CHARSET gbk COLLATE gbk_chinese_ci,
    code_gb18030 CHAR(100) CHARSET gb2312 COLLATE gb2312_chinese_ci,
    code_gb2312 CHAR(100) CHARSET gb2312 COLLATE gb2312_chinese_ci,
    data_json JSON
);

INSERT INTO t_multicharset
(code_utf8, desc_varchar_utf8mb4, code_gbk, code_gb18030, code_gb2312, data_json)
VALUES
('UTF-8 Text', 'UTF-8mb4 Text ?', 'GBK文本', 'GB18030文本', 'gb2312テキスト', '{"key1": "value1", "key2": "value2"}');

SELECT data_json FROM t_multicharset;
SELECT JSON_UNQUOTE(JSON_EXTRACT(data_json, '$.key1')) AS key1_value FROM t_multicharset;
SELECT data_json->>'$.key1' AS key1_value FROM t_multicharset;

