--echo #### 全部 gb2312 字符验证
SET NAMES gb2312;
--ERROR 0,1051
DROP TABLE t1;
CREATE TABLE t1 (b VARCHAR(2));
INSERT INTO t1 VALUES ('0'),('1'),('2'),('3'),('4'),('5'),('6'),('7');
INSERT INTO t1 VALUES ('8'),('9'),('A'),('B'),('C'),('D'),('E'),('F');
--ERROR 0,1051
DROP TABLE head;
--ERROR 0,1051
DROP TABLE tail;
CREATE  TABLE head AS SELECT concat(b1.b, b2.b) AS head FROM t1 b1, t1 b2;
CREATE  TABLE tail AS SELECT concat(b1.b, b2.b) AS tail FROM t1 b1, t1 b2;
DROP TABLE t1;
CREATE TABLE t1 AS
SELECT concat(head, tail) AS code
FROM head, tail
WHERE (head BETWEEN 'D9' AND 'DB')
AND   (tail BETWEEN 'FA' AND 'FF')
ORDER BY head, tail;
INSERT t1 (code) SELECT head FROM head WHERE (head BETWEEN 'A1' AND 'DF');
SELECT COUNT(*) FROM t1;

#
# Populate table t1 with all codes [80..FF][20..FF]
# Expected valid gb2312 codes [A1..F7][A1..FE]
#

--ERROR 0,1051
DROP TABLE t_test;
CREATE TABLE t_test AS
SELECT concat(head, tail) AS code
FROM head, tail
WHERE (head BETWEEN 'A1' AND 'F7')
AND   (tail BETWEEN 'A1' AND 'FE')
ORDER BY head, tail;
UPDATE IGNORE t_test SET code=unhex(code) ORDER BY code;
SELECT COUNT(*) FROM t_test;

INSERT INTO T_TEST VALUES (_gb2312 0xA1B0);
INSERT INTO T_TEST VALUES (_gb2312 0xF7FE);
INSERT INTO T_TEST VALUES (_gb2312 0x113344);
INSERT INTO T_TEST VALUES (0xA1B0);
INSERT INTO T_TEST VALUES (0xF7FE);
INSERT INTO T_TEST VALUES (0x113344);

INSERT INTO T_TEST VALUES (0x1);
INSERT INTO T_TEST VALUES (0x111);
INSERT INTO T_TEST VALUES (0x11111);
INSERT INTO T_TEST VALUES (0x2020);
INSERT INTO T_TEST VALUES ('?');
INSERT INTO T_TEST VALUES (QUOTE('?'));

INSERT INTO T_TEST VALUES (_gb2312 0x041004110412);
INSERT INTO T_TEST VALUES (_gb2312 0xC3D2);
INSERT INTO T_TEST VALUES (_gb2312 0xA2A1);
INSERT INTO T_TEST VALUES (_gb2312 0xB0A1);
INSERT INTO T_TEST VALUES (HEX(CONV(CONVERT('123' USING gb2312), -10, 16)));
INSERT INTO T_TEST VALUES ('1.2xxx');
INSERT INTO T_TEST VALUES ('abc');
INSERT INTO T_TEST VALUES (_gb2312 0xC3D2);

INSERT INTO T_TEST VALUES ('??');
