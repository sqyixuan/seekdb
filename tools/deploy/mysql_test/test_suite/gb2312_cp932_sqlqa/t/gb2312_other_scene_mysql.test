--echo #### 正交数据类型 ###
drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(1),
    nchar_column NATIONAL CHAR(1),
    varchar_column VARCHAR(1),
    nvarchar_column NATIONAL VARCHAR(1),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = gb2312;

--error 0,1305
DROP PROCEDURE build_gb2312_table;
delimiter /;
create procedure build_gb2312_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_gb2312_table();
/
delimiter ;/
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (_gb2312 0xA1A1,_gb2312 0xA1A1,_gb2312 0xA1A1,_gb2312 0xA1A1,_gb2312 0xA1A1,_gb2312 0xA1A1);
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (0x9373,0x9373,0x9373,0x9373,0x9373,0x9373);
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (0xF1F2,0xF1F2,0xF1F2,0xF1F2,0xF1F2,0xF1F2);

SET @longgb2312String = REPEAT(_gb2312 0xA1A1, 255);

--ERROR 1300
