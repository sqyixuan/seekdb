INSERT INTO T2(a) VALUES (0xa2a1);
INSERT INTO T2(a) VALUES (0xA2B2);
INSERT INTO T2(a) VALUES (0xF1F2);

select * from t2 order by id;
select id,a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t2 order by 1,2;
SELECT CONVERT(a USING utf8mb4) COLLATE utf8mb4_unicode_ci FROM db1.t2 order by 1;
SELECT CONVERT(a USING gb18030_2022) FROM db1.t2 order by 1;
SELECT CONVERT(a USING ujis) FROM db1.t2 order by 1;
