SELECT
    id,
    a,
    rowid,
    rownum
FROM db1.t2;

SELECT id, a, CHAR_LENGTH(a) AS char_length FROM db2.t2;
SELECT id, a, INSTR(a, 'char_to_find') AS char_position FROM db2.t2;
SELECT id, a, LOWER(a) AS lowercase_a FROM db2.t2;
SELECT id, a, UPPER(a) AS uppercase_a FROM db2.t2;
SELECT id, a, REPLACE(a, 'old_char', 'new_char') AS replaced_a FROM db2.t2;
SELECT id, a, ABS(id) AS abs_id FROM db2.t2;
SELECT id, a, FLOOR(id) AS floor_id FROM db2.t2;
SELECT id, a, MOD(id, 2) AS mod_id FROM db2.t2;
SELECT id, a, ROUND(id) AS rounded_id FROM db2.t2;
SELECT id, a, CONCAT(a, '_suffix') AS concatenated_a FROM db2.t2;
SELECT id, a, FORMAT(id, 2) AS formatted_id FROM db2.t2;
SELECT id, a, HEX(a) AS hex_a FROM db2.t2;
SELECT id, a, SUBSTR(a, 1, 1) AS substring_a FROM db2.t2;
SELECT id, a, COALESCE(a, 'default') AS nvl_a FROM db2.t2;
SELECT id, a, IFNULL(a, 'replacement') AS ifnull_a FROM db2.t2;
SELECT id, a, CASE WHEN a IS NOT NULL THEN a ELSE 'replacement' END AS nvl2_a FROM db2.t2;
