INSERT INTO T2(a) VALUES (0xA2B0);
INSERT INTO T2(a) VALUES (0xA4A2);
INSERT INTO T2(a) VALUES (0xa2a1);
--error 1406
INSERT INTO T2(a) VALUES (0xa1a2a1a3);
INSERT INTO T2(a) VALUES (0xA2B2);
