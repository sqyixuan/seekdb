SELECT CAST(_ujis '@ABCDEFGHIJKLMNO' AS NATIONAL CHAR);
SELECT CAST(_ujis '@ABCDEFGHIJKLMNO' AS NCHAR);

SELECT CAST(_ujis 'PQRSTUVWXYZ[\\]^_' AS NATIONAL CHAR);
SELECT CAST(_ujis 'PQRSTUVWXYZ[\\]^_' AS NCHAR);

SELECT CAST(_ujis 'abcdefghijklmno' AS NATIONAL CHAR);
SELECT CAST(_ujis 'abcdefghijklmno' AS NCHAR);

SELECT CAST(_ujis 'pqrstuvwxyz{|}~' AS NATIONAL CHAR);
SELECT CAST(_ujis 'pqrstuvwxyz{|}~' AS NCHAR);


