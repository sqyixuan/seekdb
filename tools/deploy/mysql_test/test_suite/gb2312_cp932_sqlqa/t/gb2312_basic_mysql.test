--echo -------------------test padding rule----------------------
insert into t1(a) values ('a '), ('a\t'),('a  ');
select a,collation(a),hex(a) from t1 where a like "%a%";
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
select a, hex(a) from t1 where a = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select a, hex(a) from t1 where a = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";

--echo -------------------test charset function----------------------
select weight_string(_gb2312 'a' collate gb2312_chinese_ci ), weight_string(_gb2312 'A' collate gb2312_chinese_ci );
select weight_string(_gb2312 'a' collate gb2312_bin), weight_string(_gb2312 'A' collate gb2312_bin);

set collation_connection = gb2312_chinese_ci ;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');

set collation_connection = gb2312_bin;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');

SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a = 'v';
SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a like '%v%';
SELECT HEX(cx), cy
FROM (SELECT GROUP_CONCAT(a ORDER BY binary a SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(a) ORDER BY BINARY a) AS cy
      FROM t1
      GROUP BY a
     ) AS dt order by cy;

--error 0,1051
drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100) charset gb2312 collate gb2312_chinese_ci );

