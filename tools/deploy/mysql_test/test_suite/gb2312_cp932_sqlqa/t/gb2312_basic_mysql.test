purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--disable_query_log
connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;
--disable_warnings
#call oceanbase.drop_tenant('tenant_charset_test');
--enable_warnings
#call oceanbase.create_mysql_tenant_1c2g_with_arg('tenant_charset_test','charset=gb2312');
--source mysql_test/test_suite/hkscs_utf16le_sqlqa/include/conn_tenant_mysql.inc
--result_format 4
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
SET sql_mode = '';

###?置并查看?前字符集?置
set names 'gb2312';
set character_set_database = 'gb2312';
set character_set_server = 'gb2312';
set character_set_results = 'utf8mb4';
show character set where Charset = 'gb2312';
show variables like 'character_set%';
--enable_query_log

--echo # ?建租??指定字符集，???前系?字符集
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET gb2312;
use db1;
--character_set gb2312
--enable_sorted_result

--error 0,1051
drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100));

--error 0,1305
DROP PROCEDURE build_gb2312_table;

delimiter /;
create procedure build_gb2312_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128|| (i >= 0xA1 && i < 0xE0) ) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_gb2312_table();
/

--error 0,1305
DROP PROCEDURE build_gb2312_table;
/

create procedure build_gb2312_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_gb2312_table();
/

