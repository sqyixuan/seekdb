       HEX(CONVERT(c4 USING utf16)) AS c4_hex
FROM t1
ORDER BY c1;

DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
    a CHAR(100) CHARACTER SET ujis,
    b VARCHAR(100) CHARACTER SET ujis,
    c TEXT CHARACTER SET ujis,
    d BLOB
);
INSERT INTO t1 (a, b, c) VALUES
    (CONVERT('テスト1' USING ujis), CONVERT('テスト2' USING ujis), CONVERT('これはテストです。' USING ujis));
INSERT INTO t1 (a, b, c) VALUES
    (CONVERT('テスト3' USING ujis), CONVERT('テスト4' USING ujis), CONVERT('日本語のテストです。' USING ujis));
INSERT INTO t1 (a, b, c) VALUES
    (CONVERT('テスト5' USING ujis), CONVERT('テスト6' USING ujis), CONVERT('システムテストの確認。' USING ujis));
INSERT INTO t1 (a, b, c) VALUES
    (CONVERT('テスト7' USING ujis), CONVERT('テスト8' USING ujis), CONVERT('テストメッセージ。' USING ujis));
INSERT INTO t1 (a, b, c) VALUES
    (CONVERT('テスト9' USING ujis), CONVERT('テスト10' USING ujis), CONVERT('これは別のテストです。' USING ujis));
SELECT HEX(CONVERT(a USING utf8)) AS a_hex,
       HEX(CONVERT(b USING utf8)) AS b_hex,
       HEX(CONVERT(c USING utf8)) AS c_hex
FROM t1;

SET NAMES ujis;
SELECT
    LPAD(_ujis 'あ', 10, _ujis 'い') AS l_char,
    RPAD(_ujis 'あ', 10, _ujis 'い') AS r_char,
    LPAD(CONVERT('あ' USING ujis), 10, CONVERT('い' USING ujis)) AS l_varchar,
    RPAD(CONVERT('あ' USING ujis), 10, CONVERT('い' USING ujis)) AS r_varchar,
    LPAD(CONVERT('あ' USING ujis), 10, CONVERT('い' USING ujis)) AS l_text,
    RPAD(CONVERT('あ' USING ujis), 10, CONVERT('い' USING ujis)) AS r_text,
    HEX('あ') AS blob_value_lpad,
    HEX('い') AS blob_value_rpad;

SET NAMES ujis;
SET @ivar = 1234;
SET @str1 = 'SELECT ?';
CREATE TABLE ujis_test (
    col_char CHAR(10) CHARACTER SET ujis,
    col_varchar VARCHAR(255) CHARACTER SET ujis,
    col_text TEXT CHARACTER SET ujis,
    col_blob BLOB
);
SET @str2 = CONVERT(@str1 USING ujis);
PREPARE stmt1 FROM @str2;
EXECUTE stmt1 USING @ivar;
DROP TABLE IF EXISTS ujis_test;
DEALLOCATE PREPARE stmt1;


DROP TABLE IF EXISTS sample_table_ujis;
