DROP TABLE IF EXISTS test_ujis;
CREATE TABLE test_ujis (
    col_char CHAR(255),
    col_varchar VARCHAR(255),
    col_text TEXT,
    col_blob BLOB
) CHARACTER SET ujis;
SET @v_var1 = '??字符';
SET @v_var2 = REPEAT('??字符', 37);
SET @v_var3 = REPEAT('??字符', 200);
SET @v_var4 = REPEAT('??字符', 1000);
INSERT INTO test_ujis (col_char, col_varchar, col_text, col_blob)
VALUES (@v_var1, @v_var2, @v_var3, @v_var4);
SELECT 'CHAR length: ' AS type, col_char AS value FROM test_ujis;
SELECT 'VARCHAR length: ' AS type, col_varchar AS value FROM test_ujis;
SELECT 'TEXT length: ' AS type, col_text AS value FROM test_ujis;
SELECT 'BLOB data size: ' AS type, OCTET_LENGTH(col_blob) AS value FROM test_ujis;


DROP TABLE IF EXISTS my_records;
CREATE TABLE my_records (
    a CHAR(10),
    b VARCHAR(10),
    c TEXT,
    d BLOB,
    e VARCHAR(255)
);
INSERT INTO my_records (a, b, c, d, e)
VALUES (LPAD((_ujis 'いろはにほへと'), 10, 'い'),
        LPAD((_ujis'ちりぬるを'), 10, 'ち'),
        'さしすせそ',
        UNHEX(_ujis'なにぬねの'),
        LPAD((_ujis'なにぬねの'), 255, 'な'));
SELECT
    CONCAT('a = ', a) AS a,
    CONCAT('b = ', b) AS b,
    CONCAT('c = ', c) AS c,
    CONCAT('e = ', e) AS e
FROM my_records;

DELIMITER //;
CREATE PROCEDURE display_values()
BEGIN
    DECLARE finished INT DEFAULT 0;
    DECLARE r_a CHAR(10);
    DECLARE r_b VARCHAR(10);
    DECLARE r_c TEXT;
    DECLARE r_e VARCHAR(255);
    DECLARE cur CURSOR FOR SELECT a, b, c, e FROM my_records;
    DECLARE CONTINUE HANDLER FOR NOT FOUND SET finished = 1;
    OPEN cur;
    read_loop: LOOP
        FETCH cur INTO r_a, r_b, r_c, r_e;
        IF finished THEN
            LEAVE read_loop;
        END IF;
        SELECT CONCAT('r.a = ', r_a) AS `Result`,
               CONCAT('r.b = ', r_b) AS `Result`,
               CONCAT('r.c = ', r_c) AS `Result`,
               CONCAT('r.e = ', r_e) AS `Result`;
    END LOOP;

    CLOSE cur;
END //

DELIMITER ;//
CALL display_values();
