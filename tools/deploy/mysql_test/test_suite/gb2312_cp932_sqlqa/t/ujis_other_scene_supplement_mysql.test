    char_255 CHAR(255) CHARACTER SET ujis,
    char_256 CHAR(256) CHARACTER SET ujis,
    varchar_0 VARCHAR(0) CHARACTER SET ujis,
    varchar_1 VARCHAR(1) CHARACTER SET ujis,
    varchar_255 VARCHAR(255) CHARACTER SET ujis,
    varchar_256 VARCHAR(256) CHARACTER SET ujis,
    text_field TEXT CHARACTER SET ujis,
    blob_field BLOB,
    text_field_255 TEXT CHARACTER SET ujis,
    blob_field_65535 BLOB(65535)
) DEFAULT CHARSET=ujis;
