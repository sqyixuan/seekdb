DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
    a CHAR(10) CHARACTER SET ujis,
    b VARCHAR(10) CHARACTER SET ujis,
    c TEXT CHARACTER SET ujis,
    d BLOB
);
INSERT INTO t1 VALUES
    (CONVERT(_ujis 'あ' USING ujis), CONVERT(_ujis 'い' USING ujis), CONVERT(_ujis 'う' USING ujis), CONVERT(_ujis 'え' USING ujis)),
    (CONVERT(_ujis 'お' USING ujis), CONVERT(_ujis 'か' USING ujis), CONVERT(_ujis 'き' USING ujis), CONVERT(_ujis 'く' USING ujis)),
    (CONVERT(_ujis 'け' USING ujis), CONVERT(_ujis 'こ' USING ujis), CONVERT(_ujis 'さ' USING ujis), NULL),
    (NULL, CONVERT(_ujis 'し' USING ujis), CONVERT(_ujis 'す' USING ujis), NULL);
SELECT
    a, b, c, HEX(CONVERT(a USING ujis)) AS U16_a, HEX(CONVERT(b USING ujis)) AS U16_b,
    a < b AS comparison_a_b
FROM t1
ORDER BY 4;


