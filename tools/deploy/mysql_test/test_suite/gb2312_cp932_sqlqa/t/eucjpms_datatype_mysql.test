SELECT CONVERT(set_column USING eucjpms) AS char_value FROM t1;
SELECT CAST(set_column AS CHAR CHARSET eucjpms) AS string_value FROM t1;
SELECT CAST(set_column AS CHAR CHARSET UTF8) AS string_value FROM t1;
SELECT CONVERT(json_column USING eucjpms) AS char_value FROM t1;
SELECT CAST(json_column AS CHAR CHARSET eucjpms) AS string_value FROM t1;
SELECT CAST(json_column AS CHAR CHARSET UTF8) AS string_value FROM t1;

