#### -- 删除已存在的表和存储过程，避免错误
--error 0,1051
DROP TABLE IF EXISTS t1;
--error 0,1305
DROP PROCEDURE IF EXISTS build_eucjpms_table;

### -- 创建新表，使用 ENUM、SET和 JSON 数据类型
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    enum_column ENUM('A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J'), 
    set_column SET('K', 'L', 'M', 'N', 'O', 'P', 'Q', 'R', 'S', 'T'),   
    json_column JSON                                                    
)DEFAULT CHARACTER SET = eucjpms;

delimiter //;

CREATE PROCEDURE build_eucjpms_table()
BEGIN
	DECLARE i INT;
    DECLARE enum_val ENUM('A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J');
    DECLARE set_val SET('K', 'L', 'M', 'N', 'O', 'P', 'Q', 'R', 'S', 'T');
    DECLARE json_val JSON;
    
	SET i = 0;
	WHILE i < 256 DO
		IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
			SET enum_val = ELT(i MOD 10 + 1, 'A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J');
            SET set_val = 'K,L'; 
            SET json_val = JSON_OBJECT('number', i);
			INSERT INTO t1(enum_column, set_column, json_column) 
			VALUES(enum_val, set_val, json_val);
		END IF;
		SET i = i + 1;
	END WHILE;
	COMMIT;
END;
//

### -- 调用存储过程来填充表
CALL build_eucjpms_table();
//

delimiter ;//

SELECT * FROM t1;
SELECT CONVERT(enum_column USING eucjpms) AS char_value FROM t1;
SELECT CAST(enum_column AS CHAR CHARSET eucjpms) AS string_value FROM t1;
