purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###?置超???
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--echo ##  cp932
--echo ##?置并?看当前字符集?置
set names 'cp932' COLLATE cp932_japanese_ci;
set character_set_database = 'cp932';
set character_set_server = 'cp932';
set character_set_results = 'utf8mb4';
show character set where Charset = 'cp932';
show variables like '%character%';
show variables like'%collation%';
--disable_warnings
--enable_sorted_result

--echo # ?建租??指定字符集，??当前系?字符集
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET cp932;
use db1;

--error 0,1051
drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100));

--error 0,1305
DROP PROCEDURE build_cp932_table;

delimiter /;
create procedure build_cp932_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_cp932_table();
/
delimiter ;/

INSERT INTO T1(a) VALUES (_cp932 0xED40ED41ED42);
INSERT INTO T1(a) VALUES (_cp932 0x8372835E);
INSERT INTO T1(a) VALUES (_cp932 0x8352835E);
INSERT INTO T1(a) VALUES (0xED40ED41ED42);
INSERT INTO T1(a) VALUES (0x8372835E);
INSERT INTO T1(a) VALUES (0x8352835E);
INSERT INTO T1(a) VALUES (0x8140);
INSERT INTO T1(a) VALUES (0x8180);
INSERT INTO T1(a) VALUES (0x82A1);
INSERT INTO T1(a) VALUES (0xF1F2);

INSERT INTO T1(a) VALUES (0x8372835E);
INSERT INTO T1(a) VALUES (0x8352835E);
INSERT INTO T1(a) VALUES (QUOTE('?'));

select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t1;
select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t1 order by a;

--echo -------------------test padding rule----------------------

insert into t1(a) values ('a\t');
insert into t1(a) values ('a '),('a  ');
select a,collation(a),hex(a) from t1 where a like "%a%";
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
select a, hex(a) from t1 where a = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select a, hex(a) from t1 where a = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";

--echo -------------------test charset function----------------------
select weight_string(_cp932 'a' collate cp932_japanese_ci), weight_string(_cp932 'A' collate cp932_japanese_ci);
select weight_string(_cp932 'a' collate cp932_bin), weight_string(_cp932 'A' collate cp932_bin);

set collation_connection = cp932_japanese_ci;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');
set collation_connection = cp932_bin;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');

SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a = 'v';
SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a like '%v%';
SELECT HEX(cx), cy
FROM (SELECT GROUP_CONCAT(a ORDER BY binary a SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(a) ORDER BY BINARY a) AS cy
      FROM t1
      GROUP BY a
     ) AS dt order by cy;

