--echo  ### 字符转换 euckr 转换成 gb18030 显示
--error 0,1051
drop table db2.t1;
CREATE TABLE db2.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(20));
INSERT INTO db2.t1(a) VALUES (9);
INSERT INTO db2.t1(a) VALUES ('H');
INSERT INTO db2.t1(a) VALUES (_euckr 'nihao'),(_euckr '你好');
INSERT INTO db2.t1(a) VALUES (_euckr 'nihao'),(_euckr '你好');
select * from db2.t1 order by id;
select id,a,convert(a, char(20) CHARACTER SET gb18030) from db2.t1 order by id;
select id,a,convert(a, char(20) CHARACTER SET euckr) from db2.t1 order by id;
--error 1115
select id,a,convert(a, char(20) CHARACTER SET utf8mb4_german2_ci) from db2.t1 order by id;
--error 1115
select id,a,convert(a, char(20) CHARACTER SET utf8mb4_croatian_ci) from db2.t1 order by id;

