purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--echo ##  euckr
--echo ##设置并查看当前字符集设置
set names 'euckr' COLLATE euckr_korean_ci;
set character_set_database = 'euckr';
set character_set_server = 'euckr';
set character_set_results = 'utf8mb4';
show character set where Charset = 'euckr';
show variables like '%character%';
show variables like'%collation%';
--disable_warnings
--enable_sorted_result

--echo # 创建租户时指定字符集，验证当前系统字符集
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET euckr;
use db1;

--error 0,1051
drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100));

--error 0,1305
DROP PROCEDURE build_euckr_table;

delimiter /;
create procedure build_euckr_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
--error 1366
call build_euckr_table();
/
delimiter ;/

INSERT INTO T1(a) VALUES (_euckr 0xA2E6);
INSERT INTO T1(a) VALUES (_euckr 0xFEF7);
INSERT INTO T1(a) VALUES (_euckr 0xA141);
INSERT INTO T1(a) VALUES (0xA2E6);
INSERT INTO T1(a) VALUES (0xFEF7);
INSERT INTO T1(a) VALUES (0xA141);
INSERT INTO T1(a) VALUES (0xA161);

INSERT INTO T1(a) VALUES (0x82A1);
INSERT INTO T1(a) VALUES (0xFEF7);
INSERT INTO T1(a) VALUES (0xA141);
INSERT INTO T1(a) VALUES (QUOTE('마'));

select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t1;
select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t1 order by a;

--echo -------------------test padding rule----------------------

insert into t1(a) values ('a\t');
insert into t1(a) values ('a '),('a  ');
select a,collation(a),hex(a) from t1 where a like "%a%";
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";
select a, hex(a) from t1 where a = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE,PAD_CHAR_TO_FULL_LENGTH";
select a, hex(a) from t1 where a = 'a ';
set @@sql_mode="STRICT_ALL_TABLES,NO_ZERO_IN_DATE";

--echo -------------------test charset function----------------------
select weight_string(_euckr 'a' collate euckr_korean_ci), weight_string(_euckr 'A' collate euckr_korean_ci);
select weight_string(_euckr 'a' collate euckr_bin), weight_string(_euckr 'A' collate euckr_bin);

set collation_connection = euckr_korean_ci;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');
set collation_connection = euckr_bin;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');

SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a = 'a';
SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a like '%a%';
SELECT HEX(cx), cy
FROM (SELECT GROUP_CONCAT(a ORDER BY binary a SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(a) ORDER BY BINARY a) AS cy
      FROM t1
      GROUP BY a
     ) AS dt order by cy;

--error 0,1051
drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100) charset euckr collate euckr_korean_ci);

