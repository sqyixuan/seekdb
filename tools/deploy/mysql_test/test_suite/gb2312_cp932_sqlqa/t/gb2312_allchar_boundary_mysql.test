SELECT CHAR_LENGTH(_gb2312 "ЗБ?_1");
SELECT OCTET_LENGTH(_gb2312 "ЗБ?_1");

SELECT SUBSTRING('??_TRIG_?', 3),
SUBSTRING('??_TRIG_?', 3, 2),
SUBSTRING('??_TRIG_?', -3),
SUBSTRING('??_TRIG_?', 3, -2),
SUBSTRING('??_TRIG_?' from -4 for 2);

SELECT SUBSTRING(_gb2312 'ЗБ?_1', 3),
SUBSTRING(_gb2312 'ЗБ?_1', 3, 2),
SUBSTRING(_gb2312 'ЗБ?_1', -3),
SUBSTRING(_gb2312 'ЗБ?_1', 3, -2),
SUBSTRING(_gb2312 'ЗБ?_1' from -4 for 2);
