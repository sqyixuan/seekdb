    pk INT PRIMARY KEY COMMENT '主键，包含字符：???????¤№?????????????????????????????????????????????',
    col1 VARCHAR(255) COMMENT '?@ABCDEFGHIJKLMNO',
    col2 VARCHAR(255) COMMENT '?abcdefghijklmno',
    col3 VARCHAR(255) COMMENT '?????????????????????',
    col4 VARCHAR(255) COMMENT '?êě?ē???????íì??ǐ?ī??',
    col5 VARCHAR(255) COMMENT '??????????óò??ǒ?ō????',
    col6 VARCHAR(255) COMMENT '????丌???两丨丫??丰????乇?',
    col7 VARCHAR(255) COMMENT '???_TRIG_?'
);

### SHOW FULL COLUMNS FROM tbl_max_count;

SELECT *
/*
    这是一个多行注释示例。
    包含字符：¤№????????????????????
    以及其他多种字符。
*/
