--echo ########## 发散case ###
--ERROR 0,1051
DROP TABLE charset_gb2312_03;

CREATE TABLE charset_gb2312_03 (
    c1 VARCHAR(100),
    c2 VARCHAR(100) CHARACTER SET gb2312 COLLATE gb2312_bin GENERATED ALWAYS AS (SUBSTR(c1, 1, 100))
) PARTITION BY KEY(c2) PARTITIONS 3;

INSERT INTO charset_gb2312_03(c1) VALUES
('???????'),
('¤№?????'),
('???????????????'),
('??????????????'),
('???????????'),
('@ABCDEFGHIJKLMNO'),
('abcdefghijklmno'),
('????????????????????'),
('êě?ē???????íì??ǐ?ī??'),
('?????????óò??ǒ?ō????'),
('???丌???两丨丫??丰????乇?'),
('??_TRIG_?');

SELECT * FROM charset_gb2312_03 WHERE c1='???????';

--ERROR 0,1051
DROP TABLE IF EXISTS charset_gb2312_03;
CREATE TABLE charset_gb2312_03 (
    id INT NOT NULL,
    c1 VARCHAR(100) CHARACTER SET gb2312 COLLATE gb2312_bin,
    c2 VARCHAR(100) CHARACTER SET gb2312 COLLATE gb2312_bin GENERATED ALWAYS AS (CONCAT(c1, ' - Generated')) VIRTUAL ,
    created_at DATE
) PARTITION BY RANGE (YEAR(created_at)) (
    PARTITION p0 VALUES LESS THAN (2020),
    PARTITION p1 VALUES LESS THAN (2021),
    PARTITION p2 VALUES LESS THAN (2022),
    PARTITION p3 VALUES LESS THAN (2023),
    PARTITION p4 VALUES LESS THAN (MAXVALUE)
);

INSERT INTO charset_gb2312_03 (id,c1,created_at) VALUES
(1,'???????','20200101'),
(1,'???????????????','20220101'),
(1,'??????????????','20230101'),
(1,'@ABCDEFGHIJKLMNO','20210101');

INSERT INTO charset_gb2312_03 (id,c1,created_at) VALUES
(1,'??_TRIG_?','20200101');
SELECT * FROM charset_gb2312_03 WHERE c1='???????';

--ERROR 0,1051
DROP TABLE charset_gb2312_example;
CREATE TABLE charset_gb2312_example (
    a VARCHAR(100) CHARACTER SET gb2312 COLLATE gb2312_bin,
    b VARCHAR(100) CHARACTER SET gb2312 COLLATE gb2312_bin,
    c VARCHAR(100) CHARACTER SET gb2312 COLLATE gb2312_bin,
    d VARCHAR(300) GENERATED ALWAYS AS (CONCAT(a, b, c))
);

