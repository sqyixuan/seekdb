--error 0,1305
DROP PROCEDURE build_ujis_table;

delimiter /;
create procedure build_ujis_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t2(char_column,varchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_ujis_table();
/
delimiter ;/

insert into t2(char_column,varchar_column,text_column,blob_column) values (_ujis 0xa2a1,_ujis 0xa2a1,_ujis 0xa2a1,_ujis 0xa2a1);
insert into t2(char_column,varchar_column,text_column,blob_column) values (0xA4A2,0xA4A2,0xA4A2,0xA4A2);
insert into t2(char_column,varchar_column,text_column,blob_column) values (0xF1F2,0xF1F2,0xF1F2,0xF1F2);

