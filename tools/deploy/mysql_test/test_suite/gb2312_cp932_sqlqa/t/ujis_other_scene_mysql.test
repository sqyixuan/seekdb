drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(1),
    nchar_column NATIONAL CHAR(1),
    varchar_column VARCHAR(1),
    nvarchar_column NATIONAL VARCHAR(1),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = ujis;

--error 0,1305
DROP PROCEDURE build_ujis_table;
delimiter /;
create procedure build_ujis_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_ujis_table();
/
delimiter ;/
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (_ujis 0xa2a1,_ujis 0xa2a1,_ujis 0xa2a1,_ujis 0xa2a1,_ujis 0xa2a1,_ujis 0xa2a1);
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (0xA4A2,0xA4A2,0xA4A2,0xA4A2,0xA4A2,0xA4A2);
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (0xF1F2,0xF1F2,0xF1F2,0xF1F2,0xF1F2,0xF1F2);

SET @longujisString = REPEAT(_ujis 0xa2a1, 255); 
SET @longBlobData = REPEAT(_ujis 0xA4A2, 1024*1024); 

UPDATE t1
SET 
    char_column = _ujis 0xa2a1,       
    nchar_column = _ujis 0xa2a1,      
    varchar_column = @longujisString, 
    nvarchar_column = @longujisString,
    text_column = @longujisString,    
    blob_column = @longBlobData;     
--disable_result_log
SELECT * FROM t1;
