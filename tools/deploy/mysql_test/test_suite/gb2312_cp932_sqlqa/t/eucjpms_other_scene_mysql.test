drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(1),
    nchar_column NATIONAL CHAR(1),
    varchar_column VARCHAR(1),
    nvarchar_column NATIONAL VARCHAR(1),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = eucjpms;

--error 0,1305
DROP PROCEDURE build_eucjpms_table;
delimiter /;
create procedure build_eucjpms_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_eucjpms_table();
/
delimiter ;/
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (_eucjpms 0xA1E0,_eucjpms 0xA1E0,_eucjpms 0xA1E0,_eucjpms 0xA1E0,_eucjpms 0xA1E0,_eucjpms 0xA1E0);
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (0xF9FC,0xF9FC,0xF9FC,0xF9FC,0xF9FC,0xF9FC);
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values (0x8180,0x8180,0x8180,0x8180,0x8180,0x8180);

SET @longeucjpmsString = REPEAT(_eucjpms 0xA1E0, 255);
SET @longBlobData = REPEAT(_eucjpms 0xF9FC, 1024*1024);

UPDATE t1
SET
    char_column = _eucjpms 0xA1E0,
    nchar_column = _eucjpms 0xA1E0,
    varchar_column = @longeucjpmsString,
    nvarchar_column = @longeucjpmsString,
    text_column = @longeucjpmsString,
    blob_column = @longBlobData;
--disable_result_log
SELECT * FROM t1;
--enable_result_log

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

CREATE TABLE t1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(255) CHARACTER SET eucjpms,
    nchar_column NATIONAL CHAR(255),
    varchar_column VARCHAR(255) CHARACTER SET eucjpms,
    nvarchar_column NATIONAL VARCHAR(255),
    text_column TEXT CHARACTER SET eucjpms,
    blob_column BLOB
) DEFAULT CHARACTER SET = eucjpms;

