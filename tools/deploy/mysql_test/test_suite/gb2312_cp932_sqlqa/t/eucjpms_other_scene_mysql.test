--error 0,1305
DROP PROCEDURE build_eucjpms_table;

delimiter /;
create procedure build_eucjpms_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t2(char_column,varchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_eucjpms_table();
/
delimiter ;/

insert into t2(char_column,varchar_column,text_column,blob_column) values (_eucjpms 0xA1E0,_eucjpms 0xA1E0,_eucjpms 0xA1E0,_eucjpms 0xA1E0);
