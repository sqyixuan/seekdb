SET NAMES eucjpms;
--ERROR 0,1051
DROP TABLE t1;
CREATE TABLE t1 (b VARCHAR(2));
INSERT INTO t1 VALUES ('0'),('1'),('2'),('3'),('4'),('5'),('6'),('7');
INSERT INTO t1 VALUES ('8'),('9'),('A'),('B'),('C'),('D'),('E'),('F');
--ERROR 0,1051
DROP TABLE head;
--ERROR 0,1051
DROP TABLE tail;
CREATE  TABLE head AS SELECT concat(b1.b, b2.b) AS head FROM t1 b1, t1 b2;
CREATE  TABLE tail AS SELECT concat(b1.b, b2.b) AS tail FROM t1 b1, t1 b2;
DROP TABLE t1;
CREATE TABLE t1 AS
SELECT concat(head, tail) AS code
FROM head, tail
WHERE (head BETWEEN '80' AND 'FF') AND (head NOT BETWEEN '8E' AND '8F')
AND (tail BETWEEN '20' AND 'FF')
ORDER BY head, tail;
INSERT t1 (code) SELECT head FROM head WHERE (head BETWEEN '8E' AND '8F');
SELECT COUNT(*) FROM t1;

# Populate JIS-X-0212 range
# Expected valid codes [8F][A1..FE][A1..FE] (1x94x94=8836 characters)
#

--ERROR 0,1051
DROP TABLE t_test;
CREATE TABLE t_test AS
SELECT concat(head, tail) AS code
FROM head, tail
WHERE (head BETWEEN '80' AND 'FF') AND (head NOT BETWEEN '8E' AND '8F')
AND (tail BETWEEN '20' AND 'FF')
ORDER BY head, tail;
SELECT COUNT(*) FROM t_test;

INSERT INTO T_TEST VALUES (_eucjpms 0xA1E0);
INSERT INTO T_TEST VALUES (_eucjpms 0xF9FC);
