--error 0,1305
DROP PROCEDURE create_cp932;
DELIMITER //;
CREATE PROCEDURE create_cp932()
BEGIN
  DECLARE i INT DEFAULT 0;
  DECLARE max_value INT DEFAULT 256;

  WHILE i <= max_value DO
    select char(i);
    SET i = i + 1;
  END WHILE;
END;
//
DELIMITER ;//

call create_cp932();

