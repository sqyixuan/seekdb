SELECT CONVERT(set_column USING cp932) AS char_value FROM t1;
SELECT CAST(set_column AS CHAR CHARSET cp932) AS string_value FROM t1;
SELECT CAST(set_column AS CHAR CHARSET UTF8) AS string_value FROM t1;
SELECT CONVERT(json_column USING cp932) AS char_value FROM t1;
SELECT CAST(json_column AS CHAR CHARSET cp932) AS string_value FROM t1;
SELECT CAST(json_column AS CHAR CHARSET UTF8) AS string_value FROM t1;

