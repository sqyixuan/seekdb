drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(10),
    nchar_column NATIONAL CHAR(10),
    varchar_column VARCHAR(10),
    nvarchar_column NATIONAL VARCHAR(10),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = cp932;

--error 0,1305
DROP PROCEDURE build_cp932_table;
delimiter /;
create procedure build_cp932_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
--error 1366
call build_cp932_table();
/
delimiter ;/


