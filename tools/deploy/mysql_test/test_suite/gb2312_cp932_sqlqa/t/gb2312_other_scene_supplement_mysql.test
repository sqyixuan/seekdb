# owner group: sql1
# tags: charset, gb2312
# description:gb2312 charset case
# author:wb-sl672505

purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
--echo ##设置并查看当前字符集设置
set names 'gb2312' COLLATE gb2312_chinese_ci;
set character_set_database = 'gb2312';
set character_set_server = 'gb2312';
set character_set_results = 'utf8mb4';
show character set where Charset = 'gb2312';
show variables like '%character%';
show variables like'%collation%';
--enable_sorted_result

--echo ############################# 字符类型 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET gb2312;
use db1;

--error 0,1051
drop table t1;
CREATE TABLE t1 (
  a CHAR(255) CHARACTER SET gb2312,
  b VARCHAR(255) CHARACTER SET gb2312,
  c TEXT CHARACTER SET gb2312,
  d BLOB
) CHARACTER SET gb2312;

INSERT INTO t1 VALUES
  (CONVERT('汉字1' USING gb2312), CONVERT('汉字2' USING gb2312), CONVERT('这是一段测试文本' USING gb2312), NULL),
  (CONVERT('汉字3' USING gb2312), CONVERT('汉字4' USING gb2312), CONVERT('这是另一段测试文本' USING gb2312), NULL),
  (CONVERT('汉字5' USING gb2312), CONVERT('汉字6' USING gb2312), CONVERT('又是一段测试文本' USING gb2312), NULL);

SELECT * FROM t1;
SELECT a AS like_a FROM t1 WHERE a LIKE '汉%';
SELECT b AS like_ba FROM t1 WHERE b LIKE '汉字%';
SELECT c AS like_ca FROM t1 WHERE c LIKE '这是一段%';


DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
    a CHAR(10) CHARACTER SET gb2312,
    b VARCHAR(10) CHARACTER SET gb2312,
    c TEXT CHARACTER SET gb2312,
    d BLOB
);
INSERT INTO t1 VALUES
    (CONVERT(_utf8 '汉' USING gb2312), CONVERT(_utf8 '字' USING gb2312),
     CONVERT(_utf8 '符' USING gb2312), CONVERT(_utf8 '集' USING gb2312)),
    (CONVERT(_utf8 '测试' USING gb2312), CONVERT(_utf8 '数据' USING gb2312),
     CONVERT(_utf8 '内容' USING gb2312), NULL);
SELECT * FROM t1 ORDER BY a DESC;


DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
    a CHAR(10) CHARACTER SET gb2312,
    b VARCHAR(10) CHARACTER SET gb2312,
    c TEXT CHARACTER SET gb2312,
    d BLOB
);
INSERT INTO t1(a,b) VALUES
    ('你', '好'),
    ('早', '上'),
    ('谢', '谢'),
    ('再', '见'),
    ('好', '吗'),
    ('吗', '您'),
    ('您', '好');
SELECT
    a,
    b,
    HEX(CONVERT(a USING gb2312)) AS gb2312_a,
    HEX(CONVERT(b USING gb2312)) AS gb2312_b,
    a < b
FROM t1
ORDER BY 3;


DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
    col_char CHAR(10) CHARACTER SET gb2312,
    col_varchar VARCHAR(10) CHARACTER SET gb2312,
    col_text TEXT CHARACTER SET gb2312,
    col_blob BLOB
);
INSERT INTO t1 VALUES
    (CONVERT(_utf8mb4 '测试1' USING gb2312),
     CONVERT(_utf8mb4 '测试2' USING gb2312),
     CONVERT(_utf8mb4 '这是一段文本' USING gb2312),
     CONVERT(_utf8mb4 '二进制数据' USING gb2312));

### OB 与MYSQL5.7一致，与MYSQL8.0不一致。
SELECT HEX(CONVERT(col_char USING gb2312)),
       HEX(CONVERT(col_varchar USING gb2312)),
       HEX(CONVERT(col_text USING gb2312)),
       HEX(col_blob)
FROM t1
ORDER BY col_varchar;


DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
    col_char CHAR(100) CHARACTER SET gb2312,
    col_varchar VARCHAR(100) CHARACTER SET gb2312,
    col_text TEXT CHARACTER SET gb2312,
    col_blob BLOB
);
INSERT INTO t1 (col_char) VALUES ('测试字符1');
INSERT INTO t1 (col_varchar) VALUES ('测试字符2');
INSERT INTO t1 (col_text) VALUES ('测试字符3');
INSERT INTO t1 (col_blob) VALUES (CONVERT('测试字符4' USING gb2312));
SELECT CONVERT(col_char USING gb2312) AS col_char_gb2312,
       CONVERT(col_varchar USING gb2312) AS col_varchar_gb2312,
       CONVERT(col_text USING gb2312) AS col_text_gb2312,
       HEX(col_blob) AS col_blob_hex
FROM t1;

SET NAMES gb2312;
SELECT
    LPAD(_gb2312 '汉', 10, _gb2312 '字') AS l_char,
    RPAD(_gb2312 '汉', 10, _gb2312 '字') AS r_char,
    LPAD(_gb2312 '测试', 10, _gb2312 '字符') AS l_varchar,
    RPAD(_gb2312 '测试', 10, _gb2312 '字符') AS r_varchar,
    LPAD('测试文本', 10, '字符填充') AS l_text,
    RPAD('测试文本', 10, '字符填充') AS r_text,
    LPAD(_binary '测试二进制', 10, _binary '填充二进制') AS l_blob,
    RPAD(_binary '测试二进制', 10, _binary '填充二进制') AS r_blob;


SET NAMES gb2312;
SET @ivar = 1234;
SET @str1 = 'SELECT ?';
SET @str2 = CONVERT(@str1 USING gb2312);
PREPARE stmt1 FROM @str2;
EXECUTE stmt1 USING @ivar;

DROP TABLE IF EXISTS test_gb2312;
CREATE TABLE test_gb2312 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    char_col CHAR(10) CHARACTER SET gb2312,
    varchar_col VARCHAR(255) CHARACTER SET gb2312,
    text_col TEXT CHARACTER SET gb2312,
    blob_col BLOB
);
INSERT INTO test_gb2312 (char_col, varchar_col, text_col) VALUES ('测试', '测试字符串', '这是一段测试文本');
SELECT * FROM test_gb2312;
DROP TABLE test_gb2312;


DROP TABLE IF EXISTS sample_table;
CREATE TABLE sample_table (
    char_0 CHAR(0) CHARACTER SET gb2312,
    char_1 CHAR(1) CHARACTER SET gb2312,
    char_255 CHAR(255) CHARACTER SET gb2312,
    char_256 CHAR(256) CHARACTER SET gb2312,
    varchar_0 VARCHAR(0) CHARACTER SET gb2312,
    varchar_1 VARCHAR(1) CHARACTER SET gb2312,
    varchar_255 VARCHAR(255) CHARACTER SET gb2312,
    varchar_256 VARCHAR(256) CHARACTER SET gb2312,
    text_field TEXT CHARACTER SET gb2312,
    blob_field BLOB
) DEFAULT CHARSET=gb2312;
INSERT INTO sample_table (char_0, char_1, char_255, char_256, varchar_0, varchar_1, varchar_255, varchar_256, text_field, blob_field) VALUES
('', 'A', LPAD('', 255, 'A'), LPAD('', 256, 'B'), '', 'C', LPAD('', 255, 'C'), LPAD('', 256, 'D'), '这是一段文本', NULL);
SELECT * FROM sample_table;

SET sql_mode = '';
DROP TABLE IF EXISTS sample_table_gb2312;
CREATE TABLE sample_table_gb2312 (
    char_0 CHAR(0) CHARACTER SET gb2312,
    char_1 CHAR(1) CHARACTER SET gb2312,
    varchar_0 VARCHAR(0) CHARACTER SET gb2312,
    varchar_1 VARCHAR(1) CHARACTER SET gb2312,
    varchar_255 VARCHAR(255) CHARACTER SET gb2312,
    text_field TEXT CHARACTER SET gb2312,
    blob_field BLOB,
    tinyblob_field TINYBLOB,
    mediumblob_field MEDIUMBLOB,
    longblob_field LONGBLOB
) DEFAULT CHARSET=gb2312;

SELECT '测试字符' AS test_char FROM DUAL;
SELECT '测试字符' AS test_varchar FROM DUAL;
SELECT '这是一个用于测试的文本' AS test_text FROM DUAL;
SELECT '测试二进制数据' AS test_blob FROM DUAL;

SELECT JSON_ARRAY('字符数组' 'GB2312测试') AS json_array_gb2312 FROM DUAL;
SELECT JSON_OBJECT('key1', 'GB2312测试') AS json_object_gb2312 FROM DUAL;
SELECT JSON_ARRAY(JSON_OBJECT('key1', 'GB2312测试'), JSON_OBJECT('key2', '更多测试')) AS json_combined_gb2312 FROM DUAL;


DELIMITER $$;
CREATE PROCEDURE test_gb2312_character_set()
BEGIN
    DECLARE v_char CHAR(255);
    DECLARE v_varchar VARCHAR(255);
    DECLARE v_text TEXT;
    SET v_char = '测试';
    SET v_varchar = '长字符串测试';
    SET v_text = '这是一个长文本测试。GB2312字符集可以存储汉字。';
    SELECT
        CHAR_LENGTH(v_char) AS char_length,
        CHAR_LENGTH(v_varchar) AS varchar_length,
        CHAR_LENGTH(v_text) AS text_length;
END$$

DELIMITER ;$$
CALL test_gb2312_character_set();


DROP TABLE IF EXISTS my_rec_types;
CREATE TABLE my_rec_types (
    field_char CHAR(10) CHARACTER SET gb2312,
    field_varchar VARCHAR(10) CHARACTER SET gb2312,
    field_text TEXT CHARACTER SET gb2312,
    field_blob BLOB
);

DELIMITER //;
CREATE PROCEDURE init_rec(IN p1 VARCHAR(10))
BEGIN
    INSERT INTO my_rec_types (field_char, field_varchar, field_text, field_blob)
    VALUES (
        LPAD(CONVERT('你好' USING gb2312), CHAR_LENGTH(p1), '?'),
        LPAD(CONVERT('测试' USING gb2312), CHAR_LENGTH(p1) - 1, '?'),
        LPAD(CONVERT('这是一段文本' USING gb2312), CHAR_LENGTH(p1) + 1, '?'),
        CONVERT('这是一个 BLOB 数据' USING gb2312)
    );
END //
DELIMITER ;//

CALL init_rec('测试数据');
SELECT field_char, field_varchar, field_text, field_blob FROM my_rec_types;
DROP TABLE my_rec_types;
DROP PROCEDURE init_rec;


--echo #########清空回收站,删除测试数据库,表等 ##########

--error 0,1008
DROP DATABASE db1;
--error 0,1008
DROP DATABASE db2;

purge recyclebin;