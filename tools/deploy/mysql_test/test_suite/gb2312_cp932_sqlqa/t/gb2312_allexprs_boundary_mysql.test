--echo ###### NULLIF ######
SELECT NULLIF('????ス佟丌?、''', 123), NULLIF('123', 123), NULLIF(NULL, '啊啊啊啊啊啊?');
SELECT NULLIF('????テキ?撙イモあ?乜?????啊あ啊啊啊啊', 123), NULLIF('123', 123), NULLIF(NULL, '????テキ?撙イモあ?乜?????啊あ啊啊啊啊');
SELECT NULLIF('????テキ?撙イモあ?乜?????啊あ啊啊', 123), NULLIF('123', 123), NULLIF(NULL, '????ス佟丌?、啊?');
SELECT NULLIF('abcdefghijklmno', 123), NULLIF('123', 123), NULLIF(NULL, 'pqrstuvwxyz{|}~');

SELECT NULLIF('????テキ?撙イモあ?乜?????啊あ????テキ?撙イモあ?乜?????啊あ', 123), NULLIF('123', 123), NULLIF(NULL, '????テキ?撙イモあ?乜?????啊あ????テキ?撙イモあ?乜?????啊あ');
SELECT NULLIF('????テキ?撙イモあ?乜?????啊あ????テキ?撙イモあ?乜?????啊あ', 123), NULLIF('123', 123), NULLIF(NULL, '????テキ?撙イモあ?乜?????啊あ????テキ?撙イモあ?乜?????啊あ');
SELECT NULLIF('????テキ?撙イモあ?乜?????啊あ????テキ?撙イモあ?乜?????啊あ', 123), NULLIF('123', 123), NULLIF(NULL, '啊啊áà啊啊啊啊啊ǎā????ス佟丌?、啊?éè啊啊');
SELECT NULLIF('佟佣?佬???????佾??侄啊啊啊啊啊啊?', 123), NULLIF('123', 123), NULLIF(NULL, '??_TRIG_?');

