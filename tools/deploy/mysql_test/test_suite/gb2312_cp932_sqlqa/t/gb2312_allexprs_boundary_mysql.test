# author:wb-sl672505

purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
--echo ##设置并查看当前字符集设置
set names 'gb2312' COLLATE gb2312_chinese_ci;
set character_set_database = 'gb2312';
set character_set_server = 'gb2312';
set character_set_results = 'utf8mb4';
show character set where Charset = 'gb2312';
show variables like '%character%';
show variables like'%collation%';
--enable_sorted_result


--echo ############################# 字符串文本 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET gb2312;
use db1;
--echo ###### 函数、表达式  ######

--echo ###### replace  ######

### 中文列名展示不稳定，暂时注释
--disable_result_log
SELECT replace('中文测试','中','文');
SELECT REPLACE('特殊符号与标点测试', '特殊符号与标点', '文');
SELECT REPLACE('数字测试0123456789', '0123456789', '文');
SELECT REPLACE('大写字母测试ABCDEFGHIJKLMNOPQRSTUVWXYZ', 'ABCDEFGHIJKLMNOPQRSTUVWXYZ', '文');
SELECT REPLACE('小写字母测试abcdefghijklmnopqrstuvwxyz', 'abcdefghijklmnopqrstuvwxyz', '文');
SELECT REPLACE('含有各种字符测试????テキ?撙イモあ?乜?????啊あ', '????テキ?撙イモあ?乜?????啊あ', '文');
SELECT REPLACE('西里尔字母测试????ス佟丌?、啊啊啊', '????ス佟丌?、啊啊啊', '文');
SELECT REPLACE('汉字测试', '汉字', '文');
SELECT REPLACE('其他字符测试???乇?', '???乇?', '文');
SELECT REPLACE('各种特殊符号测试啊啊???丌??', '啊啊???丌??', '文');
SELECT REPLACE('组合字符测试许?_TRIG_?', '许?_TRIG_?', '文');

--echo ###### LENGTH、OCTET_LENGTH、CHAR_LENGTH  ######
--echo ###### 中文字符集
SELECT LENGTH('许'), OCTET_LENGTH('许'), CHAR_LENGTH('许');

--echo ###### 特殊字符集
SELECT LENGTH('啊啊啊啊啊啊?'''), OCTET_LENGTH('啊啊啊啊啊啊?'''), CHAR_LENGTH('啊啊啊啊啊啊?''');

--echo ###### 希腊字符集
SELECT LENGTH('????ス佟丌?、啊?'), OCTET_LENGTH('????ス佟丌?、啊?'), CHAR_LENGTH('????ス佟丌?、啊?');

--echo ###### 希腊小写字母字符集
SELECT LENGTH('????テキ?撙イモあ?乜?????啊あ啊?'), OCTET_LENGTH('????テキ?撙イモあ?乜?????啊あ啊?'), CHAR_LENGTH('????テキ?撙イモあ?乜?????啊あ啊?');

--echo ###### 斯拉夫字符集
SELECT LENGTH('????ス佟丌?、啊啊啊'), OCTET_LENGTH('????ス佟丌?、啊啊啊'), CHAR_LENGTH('????ス佟丌?、啊啊啊');

--echo ###### 其他斯拉夫字符集
SELECT LENGTH('????ス佟丌?、'), OCTET_LENGTH('????ス佟丌?、'), CHAR_LENGTH('????ス佟丌?、');

--echo ######  常见符号字符集
SELECT LENGTH(' !"#$%&''()*+,-./'), OCTET_LENGTH(' !"#$%&''()*+,-./'), CHAR_LENGTH(' !"#$%&''()*+,-./');

--echo ###### 数字字符集
SELECT LENGTH('0123456789:;<=>啊啊'), OCTET_LENGTH('0123456789:;<=>啊啊'), CHAR_LENGTH('0123456789:;<=>啊啊');

--echo ######  大写字母字符集
SELECT LENGTH('@ABCDEFGHIJKLMNO'), OCTET_LENGTH('@ABCDEFGHIJKLMNO'), CHAR_LENGTH('@ABCDEFGHIJKLMNO');

--echo ###### 其他大写字母字符集
SELECT LENGTH('PQRSTUVWXYZ[\\]^_'), OCTET_LENGTH('PQRSTUVWXYZ[\\]^_'), CHAR_LENGTH('PQRSTUVWXYZ[\\]^_');

--echo ###### 小写字母字符集
SELECT LENGTH('abcdefghijklmno'), OCTET_LENGTH('abcdefghijklmno'), CHAR_LENGTH('abcdefghijklmno');

--echo ###### 其他小写字母字符集
SELECT LENGTH('pqrstuvwxyz{|}~'), OCTET_LENGTH('pqrstuvwxyz{|}~'), CHAR_LENGTH('pqrstuvwxyz{|}~');

--echo ###### 拉丁字符集（带重音的字母）
SELECT LENGTH('????テキ?撙イモあ?乜?????啊あ????ス佟丌?、啊啊'), OCTET_LENGTH('????テキ?撙イモあ?乜?????啊あ????ス佟丌?、啊啊'), CHAR_LENGTH('????テキ?撙イモあ?乜?????啊あ????ス佟丌?、啊啊');

--echo ######  拉丁字符集（带重音的后续字母）
SELECT LENGTH('????テキ?撙イモあ?乜?????啊あ????ス佟丌?、啊?'), OCTET_LENGTH('????テキ?撙イモあ?乜?????啊あ????ス佟丌?、啊?'), CHAR_LENGTH('????テキ?撙イモあ?乜?????啊あ????ス佟丌?、啊?');

--echo ###### 其他复杂字符集
SELECT LENGTH('????テキ?撙イモあ?乜?????啊あ????テキ?撙イモあ?乜?????啊あ啊啊啊啊'), OCTET_LENGTH('????テキ?撙イモあ?乜?????啊あ????テキ?撙イモあ?乜?????啊あ啊啊啊啊'), CHAR_LENGTH('????テキ?撙イモあ?乜?????啊あ????テキ?撙イモあ?乜?????啊あ啊啊啊啊');

--echo ######  其他小写拉丁字符集（带重音）
SELECT LENGTH('áà啊啊啊啊啊ǎā????ス佟丌?、啊?éè啊啊'), OCTET_LENGTH('áà啊啊啊啊啊ǎā????ス佟丌?、啊?éè啊啊'), CHAR_LENGTH('áà啊啊啊啊啊ǎā????ス佟丌?、啊?éè啊啊');

--echo ######  其他复杂小写拉丁字符集
SELECT LENGTH('?啊啊啊啊啊啊?íì啊?ǐ啊啊ī啊?'), OCTET_LENGTH('?啊啊啊啊啊啊?íì啊?ǐ啊啊ī啊?'), CHAR_LENGTH('?啊啊啊啊啊啊?íì啊?ǐ啊啊ī啊?');

--echo ###### 更多拉丁字符集（带重音）
SELECT LENGTH('啊啊啊啊啊啊???啊?óò啊?ǒ啊啊ō????ス佟丌?、'), OCTET_LENGTH('啊啊啊啊啊啊???啊?óò啊?ǒ啊啊ō????ス佟丌?、'), CHAR_LENGTH('啊啊啊啊啊啊???啊?óò啊?ǒ啊啊ō????ス佟丌?、');

--echo ###### 其他复杂拉丁字符集
SELECT LENGTH('????ス佟丌?、啊啊啊úùü啊?ǔ啊啊ū啊啊啊啊啊ǘǜǚǖ????ス佟丌?、'), OCTET_LENGTH('????ス佟丌?、啊啊啊úùü啊?ǔ啊啊ū啊啊啊啊啊ǘǜǚǖ????ス佟丌?、'), CHAR_LENGTH('????ス佟丌?、啊啊啊úùü啊?ǔ啊啊ū啊啊啊啊啊ǘǜǚǖ????ス佟丌?、');

--echo ###### 汉字字符集
SELECT LENGTH('???丌???两丨丫??丰????乇?'),
       OCTET_LENGTH('???丌???两丨丫??丰????乇?'),
       CHAR_LENGTH('???丌???两丨丫??丰????乇?');

--echo ###### 更多字符集
SELECT LENGTH('仃????仡?仨??仳仵份?仿?????????众'),
       OCTET_LENGTH('仃????仡?仨??仳仵份?仿?????????众'),
       CHAR_LENGTH('仃????仡?仨??仳仵份?仿?????????众');

--echo ###### 更多混合字符集
SELECT LENGTH('伙??你???????????????佘'),
       OCTET_LENGTH('伙??你???????????????佘'),
       CHAR_LENGTH('伙??你???????????????佘');

--echo ###### 特殊字符集
SELECT LENGTH('??_TRIG_?'),
       OCTET_LENGTH('??_TRIG_?'),
       CHAR_LENGTH('??_TRIG_?');

--echo ###### FIND_IN_SET ######

select FIND_IN_SET(_latin1'B', _latin1'a,b,c,d') from dual;
select FIND_IN_SET(_gb2312 '繁?ing',_gb2312 '繁?ing') as gb2312_res from dual;
SELECT FIND_IN_SET(_gb2312 '????ス佟丌?、\'', _gb2312 '????ス佟丌?、\'') AS gb2312_res FROM dual;
SELECT FIND_IN_SET(_gb2312 '????ス佟丌?、啊啊啊ü', _gb2312 '????ス佟丌?、啊啊啊ü') AS gb2312_res FROM dual;
SELECT FIND_IN_SET(_gb2312 '????ス佟丌?、啊?', _gb2312 '????ス佟丌?、啊?') AS gb2312_res FROM dual;
SELECT FIND_IN_SET(_gb2312 '????ス佟丌?、啊啊啊', _gb2312 '????ス佟丌?、啊啊啊') AS gb2312_res FROM dual;
SELECT FIND_IN_SET(_gb2312 '@ABCDEFGHIJKLMNO', _gb2312 '@ABCDEFGHIJKLMNO') AS gb2312_res FROM dual;
SELECT FIND_IN_SET(_gb2312 'abcdefghijklmno', _gb2312 'abcdefghijklmno') AS gb2312_res FROM dual;
SELECT FIND_IN_SET(_gb2312 '????テキ?撙イモあ?乜?????啊あ????ス佟丌?、啊?', _gb2312 '????テキ?撙イモあ?乜?????啊あ????ス佟丌?、啊?') AS gb2312_res FROM dual;
SELECT FIND_IN_SET(_gb2312 '啊啊啊啊啊啊?', _gb2312 '啊啊啊啊啊啊?') AS gb2312_res FROM dual;
SELECT FIND_IN_SET(_gb2312 '???丌???', _gb2312 '???丌???') AS gb2312_res FROM dual;
SELECT FIND_IN_SET(_gb2312 '??_TRIG_?', _gb2312 '??_TRIG_?') AS gb2312_res FROM dual;

--echo ###### CAST ######

SELECT CAST( 'abc' AS NATIONAL CHAR );
SELECT CAST( 'abc' AS NCHAR );
SELECT CAST( _gb2312 '繁?ing' AS NATIONAL CHAR );
SELECT CAST( _gb2312 '繁?ing' AS NCHAR );

SELECT CAST(_gb2312 '????ス佟丌?、''¤№啊啊啊啊啊啊?' AS NATIONAL CHAR);
SELECT CAST(_gb2312 '????ス佟丌?、''¤№啊啊啊啊啊啊?' AS NCHAR);

SELECT CAST(_gb2312 '????テキ?撙イモあ?乜?????啊あ啊啊啊啊' AS NATIONAL CHAR);
SELECT CAST(_gb2312 '????テキ?撙イモあ?乜?????啊あ啊啊啊啊' AS NCHAR);

