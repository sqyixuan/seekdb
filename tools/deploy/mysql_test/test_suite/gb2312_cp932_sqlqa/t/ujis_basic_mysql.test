purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###?置超???
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
--echo ##?置并?看当前字符集?置
set names 'ujis' COLLATE ujis_japanese_ci;
set character_set_database = 'ujis';
set character_set_server = 'ujis';
set character_set_results = 'utf8mb4';
show character set where Charset = 'ujis';
show variables like '%character%';
show variables like'%collation%';
--enable_sorted_result

--echo # ?建租??指定字符集，??当前系?字符集
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET ujis;
use db1;

--error 0,1051
drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(1));

--error 0,1305
DROP PROCEDURE build_ujis_table;

delimiter /;
create procedure build_ujis_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
--error 1366
call build_ujis_table();
/
delimiter ;/

INSERT INTO T1(a) VALUES (_ujis 0xa2a1);
