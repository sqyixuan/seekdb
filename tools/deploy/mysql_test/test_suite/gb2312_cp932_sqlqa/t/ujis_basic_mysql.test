--echo -------------------test charset function----------------------
select weight_string(_ujis 'a' collate ujis_japanese_ci), weight_string(_ujis 'A' collate ujis_japanese_ci);
select weight_string(_ujis 'a' collate ujis_bin), weight_string(_ujis 'A' collate ujis_bin);

set collation_connection = ujis_japanese_ci;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');
set collation_connection = ujis_bin;
select 'abc' like 'ABC';
select instr('XABCdfdabc','abc');

SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a = 'v';
SELECT a, hex(a), hex(@u:=convert(a using utf8)) FROM t1 where a like '%v%';
SELECT HEX(cx), cy
FROM (SELECT GROUP_CONCAT(a ORDER BY binary a SEPARATOR '') AS cx,
             GROUP_CONCAT(HEX(a) ORDER BY BINARY a) AS cy
      FROM t1
      GROUP BY a
     ) AS dt order by cy;

