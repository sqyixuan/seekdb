    c1 TEXT COLLATE ujis_bin,
    c2 TEXT COLLATE ujis_japanese_ci,
    c3 TEXT COLLATE ujis_bin,
    c4 TEXT COLLATE utf8mb4_unicode_ci,
    c5 TEXT COLLATE ujis_japanese_ci,
    c6 TEXT COLLATE ujis_bin,
    sal INT,
    id INT
) CHARACTER SET ujis;

--error 0,1305
drop procedure test_ujis_bak_ascii_pro;

delimiter /;
CREATE PROCEDURE test_ujis_bak_ascii_pro()
BEGIN
  DECLARE i INT DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO test_ujis_bak(c0, c1, c2, c3, c4, c5, c6, sal, id)
    VALUES(CONVERT(CHAR(i) USING ujis), CONVERT(CHAR(i) USING ujis), CONVERT(CHAR(i) USING ujis), CONVERT(CHAR(i) USING ujis), CONVERT(CHAR(i) USING ujis), CONVERT(CHAR(i) USING ujis), CONVERT(CHAR(i) USING ujis), i, i);
    SET i = i + 1;
  END WHILE;
  COMMIT;
END /
DELIMITER ;/

CALL test_ujis_bak_ascii_pro();
