--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET ujis;
use db1;

--error 0,1051
drop table ujis_table;
--error 0,1305
drop procedure build_ujis_table;
--error 0,1051
drop table ujis_bin_table;
--error 0,1305
drop procedure build_ujis_bin_table;

create table ujis_table(c1 char(3) charset ujis collate ujis_japanese_ci);
create table ujis_bin_table(c1 char(3) charset ujis collate ujis_bin);

--error 0,1305
DROP PROCEDURE build_ujis_table;

delimiter /;
create procedure build_ujis_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 || (i >= 0xA1 && i < 0xE0)) THEN
      insert into ujis_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
--error 1366
call build_ujis_table();
/
delimiter ;/

INSERT INTO ujis_table(c1) VALUES (_ujis 0xa2a1);
