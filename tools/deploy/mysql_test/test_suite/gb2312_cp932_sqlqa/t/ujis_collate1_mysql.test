--error 0,1305
drop procedure build_ujis_table;

delimiter /;
create procedure build_ujis_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_ujis_bak(c0,c1) values(unhex(hex(i)),unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
--error 1366
call build_ujis_table();
/
