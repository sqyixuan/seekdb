--echo #Environmental cleaning
connection default;
purge recyclebin;
--result_format 4
--echo #Environmental cleaning

###?置并查看?前字符集?置
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
--echo ##?置并查看?前字符集?置
set names 'gb2312' COLLATE gb2312_chinese_ci;
set character_set_database = 'gb2312';
set character_set_server = 'gb2312';
set character_set_results = 'utf8mb4';
show character set where Charset = 'gb2312';
show variables like '%character%';
show variables like'%collation%';
--enable_sorted_result

--enable_query_log
--echo ===================================================test basic code ==================================================

--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET gb2312;
use db1;

--error 0,1051
drop table gb2312_table;
--error 0,1305
drop procedure build_gb2312_table;
--error 0,1051
drop table gb2312_bin_table;
--error 0,1305
drop procedure build_gb2312_bin_table;

create table gb2312_table(c1 char(30) charset gb2312 collate gb2312_chinese_ci );
create table gb2312_bin_table(c1 char(30) charset gb2312 collate gb2312_bin);

--error 0,1305
DROP PROCEDURE build_gb2312_table;

delimiter /;
create procedure build_gb2312_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into gb2312_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_gb2312_table();
/
