with
table1 as(select c0 from test_gb2312_bak where c1 = 'A' order by 1),
table2 as(select c1 from test_gb2312_bak where c1 = 'A' order by 1)
select table1.c0,table2.c1 from table1,table2 where table1.c0 = table2.c1 order by 1,2;

with
table1 as(select c1 from test_gb2312_bak where c1 = 'A' order by 1),
table2 as(select c1 as c2 from test_gb2312_bak where c1 = 'A' order by 1)
select table1.c1,table2.c2 from table1,table2 where table1.c1 = table2.c2 order by 1,2;

