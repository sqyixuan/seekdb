       FROM wf_table3
       WINDOW w as (PARTITION BY a ORDER BY a DESC ROWS UNBOUNDED PRECEDING)
       ORDER BY a;
       
--echo wf_sql-1-5-1 PL/SQL 索引
drop table wf_table3 ;
create table wf_table3(a CHAR(10));
CREATE INDEX a1 ON wf_table3(a);
SELECT CUME_DIST() OVER(PARTITION BY a ORDER BY a DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table3
       ORDER BY a;
       
--echo wf_sql-1-5-2 PL/SQL 存储过程
delimiter //;
--error 0,1305
drop procedure wf_pro;//
CREATE  PROCEDURE wf_pro( out wf varchar(200),inout  wf1 varchar(200))
begin
	declare i int;
    set i := 2;
	SELECT CUME_DIST() OVER(PARTITION BY money ORDER BY num DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1
       WHERE num = i
       ORDER BY name into wf ;
	SELECT LAG(money,1,0) OVER w AS wf1
       FROM wf_table1
       where num = i
       WINDOW w as (PARTITION BY name ORDER BY money DESC ROWS UNBOUNDED PRECEDING)
       ORDER BY num into wf1;
END;
//

call wf_pro(@wf,@wf1);//
SELECT @wf1;//
SELECT @wf;//
--error 0,1305
drop procedure wf_pro;//

--echo wf_sql-1-5-3 PL/SQL 函数function
--error 0,1305
drop FUNCTION wf_func;//
CREATE  FUNCTION wf_func(para int)
returns  int
begin
	declare a int;
	SELECT LAG(money,1,0) OVER w AS wf1
       FROM wf_table1
       where num = para
       WINDOW w as (PARTITION BY name ORDER BY money DESC ROWS UNBOUNDED PRECEDING)
       ORDER BY num into a;
	return a;
END;
//

SELECT  wf_func(2);//

--error 0,1305
drop FUNCTION wf_func;//
delimiter ;//

--echo wf_sql-1-6-1 常用sql CAST
SELECT name, cast(CUME_DIST() OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING) as decimal(9,2))  AS money
       FROM wf_table1
       ORDER BY name;
--echo wf_sql-1-6-2 常用sql DISTINCT
SELECT DISTINCT name, cast(CUME_DIST() OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING) as decimal(9,2))  AS money
       FROM wf_table1
       ORDER BY name;
SELECT DISTINCT name, CUME_DIST() OVER w AS money
       FROM wf_table1
       WINDOW w as (PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING)
       ORDER BY name;
       
--echo wf_sql-1-6-3 常用sql dual    
SELECT cast(CUME_DIST() OVER(PARTITION BY '1'  ROWS UNBOUNDED PRECEDING) as decimal(9,2))  AS money
       FROM dual;
SELECT CUME_DIST() OVER w AS money
       FROM dual
       WINDOW w as (PARTITION BY '1'  ROWS UNBOUNDED PRECEDING);

