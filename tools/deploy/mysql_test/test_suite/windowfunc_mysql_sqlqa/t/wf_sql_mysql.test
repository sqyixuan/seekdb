insert into wf_table3 values('-10.23');
SELECT a, CUME_DIST() OVER(PARTITION BY a ORDER BY a DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table3
       ORDER BY a;
SELECT a, CUME_DIST() OVER w AS wf1
       FROM wf_table3
       WINDOW w as (PARTITION BY a ORDER BY a DESC ROWS UNBOUNDED PRECEDING)
       ORDER BY a;
SELECT a, LAG(a,1,0) OVER(PARTITION BY a ORDER BY a DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table3
       ORDER BY a;
SELECT a, LAG(a,1,0) OVER w AS wf1
       FROM wf_table3
       WINDOW w as (PARTITION BY a ORDER BY a DESC ROWS UNBOUNDED PRECEDING)
       ORDER BY a;

