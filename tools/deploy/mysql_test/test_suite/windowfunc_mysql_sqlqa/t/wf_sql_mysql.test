--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user liuyq@'%';
--enable_warnings
create user liuyq identified by 'liuyq';
grant all on *.* to liuyq WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,liuyq,liuyq,test,$OBMYSQL_PORT);

--error 0,1051
DROP TABLE wf_table1;
--error 0,1051
DROP TABLE wf_table2;

CREATE TABLE wf_table1(num INT,name varchar(20),money char(20),perimeter NUMERIC(20,10) AS (2 * 3.14159265 * num));
INSERT INTO wf_table1(num,name,money) VALUES(1,'Bing',-100);
INSERT INTO wf_table1(num,name,money) VALUES(2,'Bing',+104564564646.11514);
INSERT INTO wf_table1(num,name,money) VALUES(3,'Reachl',-0.23566000);
INSERT INTO wf_table1(num,name,money) VALUES(4,'Reachl',0.23566000);
INSERT INTO wf_table1(num,name,money) VALUES(5,'friends','');
INSERT INTO wf_table1(num,name,money) VALUES(6,'@#￥！%……&*~',NULL);
INSERT INTO wf_table1(num,name,money) VALUES(7,'Bing',11);
INSERT INTO wf_table1(num,name,money) VALUES(8,'NULL',NULL);
ALTER TABLE wf_table1 ADD COLUMN age INT AS (num + 1);

CREATE TABLE wf_table2(num INT,name varchar(20),money char(20));
INSERT INTO wf_table2(num,name,money) VALUES(1,'BOB',-1);
INSERT INTO wf_table2(num,name,money) VALUES(2,'ABC',+1);
INSERT INTO wf_table2(num,name,money) VALUES(3,'AD',0);

--echo wf_sql-1-1-1 常用函数
SELECT name, FIRST_VALUE(INSTR(name, 'ea' )) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, INSTR(FIRST_VALUE(money) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING),'s') AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, INSTR(FIRST_VALUE(money) OVER w,'s') AS wf1
       FROM wf_table1
       WINDOW w as (PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING)
       ORDER BY name;

SELECT name, LAG(money,1,LENGTH(name)) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, LAG(money,LENGTH(name),1) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, LENGTH(LAG(money,1,LENGTH(name)) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING)) AS wf1
       FROM wf_table1
       ORDER BY name;

SELECT name, LAST_VALUE(LOWER(name)) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, upper(LAST_VALUE(LOWER(name)) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING)) AS wf1
       FROM wf_table1
       ORDER BY name;

SELECT name, NTH_VALUE(REPLACE(name,'ing','ING'),2) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, REPLACE(NTH_VALUE(REPLACE(name,'ing','ING'),1) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING),'ING','ing') AS wf1
       FROM wf_table1
       ORDER BY name;
   
SELECT name, NTH_VALUE(substr(name,2),2) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, substr(NTH_VALUE(substr(name,2),1) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING),2) AS wf1
       FROM wf_table1
       ORDER BY name;

SELECT name, AVG(abs(money)) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, mod(AVG(money) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING),3) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, mod(AVG(money) OVER w,3) AS wf1
       FROM wf_table1
       WINDOW w as (PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING)
       ORDER BY name;
     
SELECT name, round(CUME_DIST() OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING),2) AS wf1
       FROM wf_table1
       ORDER BY name;
--echo wf_sql-1-2-1 执行顺序
SELECT w1.name,AVG(w1.money) a1 from wf_table1 w1
JOIN wf_table2 w2
on w1.num=w2.num
where w1.num<9
GROUP BY w1.name 
HAVING a1>-1;

SELECT w1.name,AVG(w1.money) a1,ROW_NUMBER() OVER(ORDER BY w1.name DESC ROWS 1 PRECEDING) AS wf1 from wf_table1 w1
JOIN wf_table2 w2
on w1.num=w2.num
where w1.num<9
GROUP BY w1.name 
HAVING a1>-1;

SELECT w1.name,AVG(w1.money) a1,ROW_NUMBER() OVER(ORDER BY w1.name ROWS 1 PRECEDING) AS wf1 from wf_table1 w1
JOIN wf_table2 w2
on w1.num=w2.num
where w1.num<9
GROUP BY w1.name 
ORDER BY a1 DESC
LIMIT 1;

SELECT w1.name,AVG(w1.money) a1,ROW_NUMBER() OVER w AS wf1 from wf_table1 w1
JOIN wf_table2 w2
on w1.num=w2.num
where w1.num<9
GROUP BY w1.name 
WINDOW w as (ORDER BY w1.name ROWS 1 PRECEDING)
ORDER BY a1 DESC
LIMIT 1;

SELECT DISTINCT name, ROW_NUMBER() OVER(ORDER BY name DESC ROWS 1 PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
      
--echo wf_sql-1-3-1 表和视图 空表
--error 0,1051
DROP TABLE wf_table3;
CREATE TABLE wf_table3(num INT,name varchar(20),money char(20));
SELECT DISTINCT name, ROW_NUMBER() OVER(ORDER BY name DESC ROWS 1 PRECEDING) AS wf1
       FROM wf_table3
       ORDER BY name;

--echo wf_sql-1-3-2 参数数据类型
--error 0, 1051
drop table wf_table3;
create table wf_table3(a TINYINT(10));
insert into wf_table3 values('-128');
SELECT a, CUME_DIST() OVER(PARTITION BY a ORDER BY a DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table3
       ORDER BY a;
SELECT a, CUME_DIST() OVER w AS wf1
       FROM wf_table3
       WINDOW w as (PARTITION BY a ORDER BY a DESC ROWS UNBOUNDED PRECEDING)
       ORDER BY a;
SELECT a, LAG(a,1,0) OVER(PARTITION BY a ORDER BY a DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table3
       ORDER BY a;
SELECT a, LAG(a,1,0) OVER w AS wf1
       FROM wf_table3
       WINDOW w as (PARTITION BY a ORDER BY a DESC ROWS UNBOUNDED PRECEDING)
       ORDER BY a;

