--echo wf_sql-1-4-4 foreign key 外键约束 
--error 0, 1051
drop table wf_table3 ;
CREATE TABLE WF_TABLE11(a1 char(10) not null primary key);
insert into WF_TABLE11 values('-10');
create table wf_table3(a char(10) NOT NULL,FOREIGN KEY (a)  references WF_TABLE11(a1));
insert into wf_table3 values('-10');
SELECT a, CUME_DIST() OVER(PARTITION BY a ORDER BY a DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table3
       ORDER BY a;
SELECT a, CUME_DIST() OVER w AS wf1
       FROM wf_table3
       WINDOW w as (PARTITION BY a ORDER BY a DESC ROWS UNBOUNDED PRECEDING)
       ORDER BY a;
SELECT a, LAG(a,1,0) OVER(PARTITION BY a ORDER BY a DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table3
       ORDER BY a;
SELECT a, LAG(a,1,0) OVER w AS wf1
       FROM wf_table3
       WINDOW w as (PARTITION BY a ORDER BY a DESC ROWS UNBOUNDED PRECEDING)
       ORDER BY a;


