--echo over_clause-2-1 partition_clause
SELECT name, MAX(money) OVER(PARTITION BY name) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, MAX(money) OVER(PARTITION BY name,num) AS wf1
       FROM wf_table1
       ORDER BY name;
      
SELECT name, MAX(money) OVER(PARTITION BY COUNT(name)) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, MAX(money) OVER(PARTITION BY STDDEV_SAMP(money)) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, MAX(money) OVER(PARTITION BY STDDEV_SAMP(num),COUNT(money)) AS wf1
       FROM wf_table1
