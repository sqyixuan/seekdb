connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

# many test cases use random rows of non-grouped columns as input of window functions
# we disable hash rollup to keep result unchanged
connection default;
alter system set _use_hash_rollup = 'disabled';
alter system flush plan cache global;

--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user liuyq@'%';
--enable_warnings
create user liuyq identified by 'liuyq';
grant all on *.* to liuyq WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,liuyq,liuyq,test,$OBMYSQL_PORT);
--disable_abort_on_error
--disable_warnings
--error 0,1051
DROP TABLE wf_table1;

CREATE TABLE wf_table1(num INT,name varchar(200),money char(20),perimeter NUMERIC(20,10) AS (2 * 3.14159265 * num));
INSERT INTO wf_table1(num,name,money) VALUES(1,'Bing',-100);
INSERT INTO wf_table1(num,name,money) VALUES(2,'Bing',+104564564646.11514);
INSERT INTO wf_table1(num,name,money) VALUES(3,'Reachl',-0.23566000);
INSERT INTO wf_table1(num,name,money) VALUES(4,'Reachl',0.23566000);
INSERT INTO wf_table1(num,name,money) VALUES(5,'friends','');
INSERT INTO wf_table1(num,name,money) VALUES(6,'@#￥！%……&*~',NULL);
INSERT INTO wf_table1(num,name,money) VALUES(2,'Bing',10);
INSERT INTO wf_table1(num,name,money) VALUES(NULL,'NULL',NULL);
ALTER TABLE wf_table1 ADD COLUMN age INT AS (num + 1);

alter system flush plan cache global;
--sleep 2

--echo over_clause-1-1 partition_clause
SELECT name, SUM(money) OVER(PARTITION BY name) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(PARTITION BY name,num) AS wf1
       FROM wf_table1
       ORDER BY name;
      
SELECT name, SUM(money) OVER(PARTITION BY COUNT(name)) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(PARTITION BY STDDEV_SAMP(money)) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(PARTITION BY STDDEV_SAMP(num),COUNT(money)) AS wf1
       FROM wf_table1
       ORDER BY name;
       
--echo over_clause-1-2 order_clause
SELECT name, SUM(money) OVER(ORDER BY name) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(ORDER BY num,name) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(ORDER BY num,name,num,name,num,name,money,money,num,name,num,name,num,name,money,money) AS wf1
       FROM wf_table1
       ORDER BY name;
       
SELECT name, SUM(money) OVER(ORDER BY perimeter) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(ORDER BY age) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(ORDER BY age,perimeter,perimeter,perimeter,perimeter,age,name,num) AS wf1
       FROM wf_table1
       ORDER BY name;
--error 1064       
SELECT name, SUM(money) OVER(ORDER BY name as a) AS wf1
       FROM wf_table1
       ORDER BY name;
       
SELECT name, SUM(money) OVER(ORDER BY COUNT(*)) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(ORDER BY STDDEV_SAMP(num),COUNT(money)) AS wf1
       FROM wf_table1
       ORDER BY name;
       
SELECT name, SUM(money) OVER(ORDER BY money ASC) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(ORDER BY money DESC) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(ORDER BY money DESC,name DESC) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(ORDER BY money DESC,num ASC) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(ORDER BY money ,num DESC) AS wf1
       FROM wf_table1
       ORDER BY name;
      
SELECT name, SUM(money) OVER(ORDER BY '1') AS wf1
       FROM wf_table1
       ORDER BY name;
--error 3592
SELECT name, SUM(money) OVER(ORDER BY 1) AS wf1
       FROM wf_table1
       ORDER BY name;
--error 1064
SELECT name, SUM(money) OVER(ORDER BY  ) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(ORDER BY '') AS wf1
       FROM wf_table1
       ORDER BY name;
--error 1054
SELECT name, SUM(money) OVER(ORDER BY nam) AS wf1
       FROM wf_table1
       ORDER BY name;
      
SELECT name, SUM(money) OVER(PARTITION BY STDDEV_SAMP(money) ORDER BY money DESC,name DESC) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(PARTITION BY money ORDER BY name DESC,name DESC) AS wf1
       FROM wf_table1
       ORDER BY name;

