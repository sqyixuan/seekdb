--echo over_clause-1-5-1 partition_clause+order_clause+frame_clause_rows
SELECT name, SUM(money) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
--error 1149
SELECT name, SUM(money) OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED FOLLOWING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(PARTITION BY money ORDER BY name DESC ROWS CURRENT ROW) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(PARTITION BY money ORDER BY name ROWS 1 PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(PARTITION BY money ORDER BY name DESC ROWS 0 PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
