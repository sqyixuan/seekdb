       FROM wf_table1
       ORDER BY name;
      
SELECT name, SUM(money) OVER(PARTITION BY money,name ORDER BY money DESC,name DESC ROWS BETWEEN CURRENT ROW AND CURRENT ROW) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(PARTITION BY money,name ORDER BY money DESC,name DESC ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING) AS wf1
       FROM wf_table1
       ORDER BY name;
--error 5561
SELECT name, SUM(money) OVER(PARTITION BY money,name ORDER BY money DESC,name DESC ROWS BETWEEN CURRENT ROW AND 1 PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(PARTITION BY money,name ORDER BY money DESC,name DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS wf1
       FROM wf_table1
       ORDER BY name;
--echo over_clause-1-5-2 partition_clause+order_clause+frame_clause_range
SELECT name, SUM(money) OVER(PARTITION BY money ORDER BY name DESC RANGE UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(PARTITION BY money ORDER BY name DESC RANGE UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1;
SELECT name, SUM(money) OVER(PARTITION BY money ORDER BY name DESC RANGE UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1
       GROUP BY name;
SELECT name, SUM(money) OVER(PARTITION BY money ORDER BY name DESC RANGE CURRENT ROW) AS wf1
       FROM wf_table1
       ORDER BY name;
