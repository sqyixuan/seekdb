--echo window_spec-1-1-8-1 其他
SELECT name,SUM(money) OVER winf AS wf1 
		FROM wf_table1
       WINDOW winf AS (PARTITION BY money ROWS UNBOUNDED PRECEDING)
       ORDER BY name;
--error 1064
SELECT name,SUM(money) OVER 'OVER' AS wf1 
		FROM wf_table1
       WINDOW 'OVER' AS (PARTITION BY money ROWS UNBOUNDED PRECEDING)
       ORDER BY name;
SELECT name,SUM(money) OVER w
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ROWS UNBOUNDED PRECEDING)
       ORDER BY name;
--error 5929
SELECT name,SUM(money) OVER w
		FROM wf_table1
       WINDOW w1 AS (PARTITION BY money ROWS UNBOUNDED PRECEDING)
       ORDER BY name;
SELECT name,SUM(money) OVER(PARTITION BY money,name ORDER BY money DESC,name DESC ROWS BETWEEN CURRENT ROW AND CURRENT ROW) AS wf1
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ROWS UNBOUNDED PRECEDING)
       ORDER BY name;
--error 1064
SELECT name,SUM(money) OVER w
		FROM wf_table1
       WINDOW w AS ('')
       ORDER BY name; 
--error 1064
SELECT name,SUM(money) OVER w
		FROM wf_table1
       WINDOW w AS (1)
       ORDER BY name; 
--error 1064
SELECT name,SUM(money) OVER w
		FROM wf_table1
       WINDOW w;
      
SELECT name,SUM(money) OVER(w ORDER BY name)
		FROM wf_table1
       WINDOW w AS (PARTITION BY name);
SELECT name,SUM(money) OVER(w ORDER BY name)
		FROM wf_table1
       WINDOW w AS (PARTITION BY money);
--error 5929
SELECT name,SUM(money) OVER(w ORDER BY name)
		FROM wf_table1
       WINDOW w1 AS (w2), w2 AS (), w3 AS (w1);
--error 1054
SELECT name,SUM(money) OVER w1,w2,w3
		FROM wf_table1
       WINDOW w1 AS (w2), w2 AS (), w3 AS (w1);
--error 1235
SELECT name,SUM(money) OVER(w ORDER BY name)
		FROM wf_table1
       WINDOW  w1 AS (w2), w2 AS (w3), w3 AS (w1);
--echo window_spec-1-2-1 partition_clause
SELECT name, MAX(money) OVER w AS wf1
       FROM wf_table1
       WINDOW w AS (PARTITION BY name)
       ORDER BY name;
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY name,num)
       ORDER BY name;       
--echo window_spec-1-2-2 order_clause
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY name)
       ORDER BY name; 
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY num,name,num,name,num,name,money,money,num,name,num,name,num,name,money,money)
       ORDER BY name; 
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY age,perimeter,perimeter,perimeter,perimeter,age,name,num)
       ORDER BY name; 
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY '')
       ORDER BY name;
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ORDER BY money ASC,name DESC)
       ORDER BY name;

--echo window_spec-1-2-3-1 frame_clause_rows
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS UNBOUNDED PRECEDING)
       ORDER BY name;
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS CURRENT ROW)
       ORDER BY name;
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS 0 PRECEDING)
       ORDER BY name;
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS 999999999999999999 PRECEDING)
       ORDER BY name;
--error 3596
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS INTERVAL 5 DAY PRECEDING)
       ORDER BY name;
--echo window_spec-1-2-3-2 frame_clause_rows_BETWEEN
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND CURRENT ROW)
       ORDER BY name;
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND 1 FOLLOWING)
       ORDER BY name;
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN  UNBOUNDED PRECEDING AND CURRENT ROW)
       ORDER BY name;
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN 999999999999999999  PRECEDING AND UNBOUNDED FOLLOWING)
       ORDER BY name;
SELECT name,MAX(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN 5  PRECEDING AND 0 FOLLOWING)
       ORDER BY name;
