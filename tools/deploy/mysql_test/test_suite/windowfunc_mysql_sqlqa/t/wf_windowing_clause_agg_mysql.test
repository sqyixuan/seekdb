SELECT name,SUM(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS  1 FOLLOWING)
       ORDER BY name;
--error 1064
SELECT name,SUM(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS -1 FOLLOWING)
       ORDER BY name;
--echo window_spec-1-1-3-2 frame_clause_rows_BETWEEN
SELECT name,SUM(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND CURRENT ROW)
       ORDER BY name;
