       WINDOW w AS (ROWS '2' PRECEDING)
       ORDER BY name;
SELECT name,SUM(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS abs(1) PRECEDING)
       ORDER BY name;
--error 3586
SELECT name,SUM(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS 10000000000000000000 PRECEDING)
       ORDER BY name;
SELECT name,SUM(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS 999999999999999999 PRECEDING)
       ORDER BY name;
--error 3596
SELECT name,SUM(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS INTERVAL 5 DAY PRECEDING)
       ORDER BY name;
