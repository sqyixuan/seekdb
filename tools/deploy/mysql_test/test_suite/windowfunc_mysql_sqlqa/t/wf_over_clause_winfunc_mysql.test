connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection obsys;
# many test cases use random rows of non-grouped columns as input of window functions
# we disable hash rollup to keep result unchanged
alter system set _use_hash_rollup = 'disabled';

connection default;
alter system flush plan cache global;

--disable_abort_on_error
--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user liuyq@'%';
--enable_warnings
create user liuyq identified by 'liuyq';
grant all on *.* to liuyq WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,liuyq,liuyq,test,$OBMYSQL_PORT);

--disable_warnings
--error 0,1051
DROP TABLE wf_table1;

CREATE TABLE wf_table1(num INT,name varchar(200),money char(20),perimeter NUMERIC(20,10) AS (2 * 3.14159265 * num));
INSERT INTO wf_table1(num,name,money) VALUES(1,'Bing',-100);
INSERT INTO wf_table1(num,name,money) VALUES(2,'Bing',+104564564646.11514);
INSERT INTO wf_table1(num,name,money) VALUES(3,'Reachl',-0.23566000);
INSERT INTO wf_table1(num,name,money) VALUES(4,'Reachl',0.23566000);
INSERT INTO wf_table1(num,name,money) VALUES(5,'friends','');
INSERT INTO wf_table1(num,name,money) VALUES(6,'@#￥！%……&*~',NULL);
INSERT INTO wf_table1(num,name,money) VALUES(2,'Bing',10);
INSERT INTO wf_table1(num,name,money) VALUES(NULL,'NULL',NULL);

--echo over_clause-2-1-1 partition_clause
SELECT name, CUME_DIST() OVER(PARTITION BY name) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(PARTITION BY name,num) AS wf1
       FROM wf_table1
       ORDER BY name;
      
SELECT name, CUME_DIST() OVER(PARTITION BY COUNT(name)) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(PARTITION BY STDDEV_SAMP(money)) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(PARTITION BY STDDEV_SAMP(num),COUNT(money)) AS wf1
       FROM wf_table1
       ORDER BY name;
       
--echo over_clause-2-1-2 order_clause
SELECT name, CUME_DIST() OVER(ORDER BY name) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ORDER BY num,name,num,name,num,name,money,money,num,name,num,name,num,name,money,money) AS wf1
       FROM wf_table1
       ORDER BY name;
       
SELECT name, CUME_DIST() OVER(ORDER BY perimeter) AS wf1
       FROM wf_table1
       ORDER BY name;
       
SELECT name, CUME_DIST() OVER(ORDER BY COUNT(*)) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ORDER BY STDDEV_SAMP(num),COUNT(money)) AS wf1
       FROM wf_table1
       ORDER BY name;
       
SELECT name, CUME_DIST() OVER(ORDER BY money ASC) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ORDER BY money DESC) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ORDER BY money DESC,num ASC) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ORDER BY money ,num DESC) AS wf1
       FROM wf_table1
       ORDER BY name;
      
SELECT name, CUME_DIST() OVER(ORDER BY '1') AS wf1
       FROM wf_table1
       ORDER BY name;
--error 3592
SELECT name, CUME_DIST() OVER(ORDER BY 1) AS wf1
       FROM wf_table1
       ORDER BY name;
      
--echo over_clause-2-1-3-1 frame_clause_rows
SELECT name, CUME_DIST() OVER(ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ROWS CURRENT ROW) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ROWS  1 PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ROWS  NULL PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ROWS  '2' PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ROWS  num PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ROWS  COUNT(1) PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ROWS  999999999999999999 PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
--error 3596
SELECT name, CUME_DIST() OVER(ROWS  INTERVAL 5 DAY PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
--echo over_clause-2-1-3-2 frame_clause_rows_BETWEEN
SELECT name, CUME_DIST() OVER(ROWS BETWEEN CURRENT ROW AND CURRENT ROW) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ROWS BETWEEN CURRENT ROW AND 999999999999999999 FOLLOWING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ROWS BETWEEN CURRENT ROW AND 10000000000000000000 FOLLOWING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ROWS BETWEEN CURRENT ROW AND COUNT(1) FOLLOWING) AS wf1
       FROM wf_table1
       ORDER BY name;
     
SELECT name, CUME_DIST() OVER(ROWS BETWEEN  UNBOUNDED PRECEDING AND CURRENT ROW) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ROWS BETWEEN UNBOUNDED PRECEDING AND  UNBOUNDED FOLLOWING) AS wf1
       FROM wf_table1
       ORDER BY name;
    
SELECT name, CUME_DIST() OVER(ROWS BETWEEN  1  PRECEDING AND CURRENT ROW) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(ROWS BETWEEN 5  PRECEDING AND 0 FOLLOWING) AS wf1
       FROM wf_table1
       ORDER BY name;
--echo over_clause-2-1-4-1 frame_clause_range
SELECT name, CUME_DIST() OVER(RANGE UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(RANGE CURRENT ROW) AS wf1
       FROM wf_table1
       ORDER BY name;
--error 3587
SELECT name, CUME_DIST() OVER(RANGE  INTERVAL 5 DAY PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
--echo over_clause-2-1-4-2 frame_clause_range_BETWEEN
SELECT name, CUME_DIST() OVER(RANGE BETWEEN CURRENT ROW AND CURRENT ROW) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(RANGE BETWEEN CURRENT ROW AND  UNBOUNDED FOLLOWING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(RANGE BETWEEN  UNBOUNDED PRECEDING AND CURRENT ROW) AS wf1
       FROM wf_table1
       ORDER BY name;
--error 3587
SELECT name, CUME_DIST() OVER(RANGE BETWEEN  1  PRECEDING AND CURRENT ROW) AS wf1
       FROM wf_table1
       ORDER BY name;

--echo over_clause-2-1-5-1 partition_clause+order_clause+frame_clause_rows
SELECT name, CUME_DIST() OVER(PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(PARTITION BY money ORDER BY name DESC ROWS CURRENT ROW) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, CUME_DIST() OVER(PARTITION BY money ORDER BY name ROWS 1 PRECEDING) AS wf1
