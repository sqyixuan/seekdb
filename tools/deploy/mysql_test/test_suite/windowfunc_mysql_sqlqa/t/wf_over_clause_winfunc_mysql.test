--echo over_clause-2-2-1 partition_clause
SELECT name, DENSE_RANK() OVER(PARTITION BY name) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, DENSE_RANK() OVER(PARTITION BY name,num) AS wf1
       FROM wf_table1
       ORDER BY name;
      
SELECT name, DENSE_RANK() OVER(PARTITION BY COUNT(name)) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, DENSE_RANK() OVER(PARTITION BY STDDEV_SAMP(money)) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, DENSE_RANK() OVER(PARTITION BY STDDEV_SAMP(num),COUNT(money)) AS wf1
       FROM wf_table1
       ORDER BY name;
       
--echo over_clause-2-2-2 order_clause
SELECT name, DENSE_RANK() OVER(ORDER BY name) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, DENSE_RANK() OVER(ORDER BY num,name,num,name,num,name,money,money,num,name,num,name,num,name,money,money) AS wf1
       FROM wf_table1
       ORDER BY name;
       
SELECT name, DENSE_RANK() OVER(ORDER BY perimeter) AS wf1
       FROM wf_table1
       ORDER BY name;
       
SELECT name, DENSE_RANK() OVER(ORDER BY COUNT(*)) AS wf1
       FROM wf_table1
       ORDER BY name;
