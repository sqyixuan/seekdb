--echo window_spec-2-11-1 partition_clause
SELECT name, ROW_NUMBER() OVER w AS wf1
       FROM wf_table1
       WINDOW w AS (PARTITION BY name)
       ORDER BY name;
SELECT name,ROW_NUMBER() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY name,num)
       ORDER BY name;       
--echo window_spec-2-11-2 order_clause
SELECT name,ROW_NUMBER() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY name)
       ORDER BY name; 
SELECT name,ROW_NUMBER() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY num,name,num,name,num,name,money,money,num,name,num,name,num,name,money,money)
       ORDER BY name; 
SELECT name,ROW_NUMBER() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY age,perimeter,perimeter,perimeter,perimeter,age,name,num)
       ORDER BY name; 
SELECT name,ROW_NUMBER() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY '')
       ORDER BY name;
SELECT name,ROW_NUMBER() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ORDER BY money ASC,name DESC)
       ORDER BY name;

