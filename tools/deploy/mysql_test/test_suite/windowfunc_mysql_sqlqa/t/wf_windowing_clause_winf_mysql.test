--disable_abort_on_error
--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user liuyq@'%';
--enable_warnings
create user liuyq identified by 'liuyq';
grant all on *.* to liuyq WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,liuyq,liuyq,test,$OBMYSQL_PORT);

--disable_warnings
--error 0,1051
DROP TABLE wf_table1;

CREATE TABLE wf_table1(num INT,name varchar(200),money char(20),perimeter NUMERIC(20,10) AS (2 * 3.14159265 * num));
INSERT INTO wf_table1(num,name,money) VALUES(1,'Bing',-100);
INSERT INTO wf_table1(num,name,money) VALUES(2,'Bing',+104564564646.11514);
INSERT INTO wf_table1(num,name,money) VALUES(3,'Reachl',-0.23566000);
INSERT INTO wf_table1(num,name,money) VALUES(4,'Reachl',0.23566000);
INSERT INTO wf_table1(num,name,money) VALUES(5,'friends','');
INSERT INTO wf_table1(num,name,money) VALUES(6,'@#￥！%……&*~',NULL);
INSERT INTO wf_table1(num,name,money) VALUES(2,'Bing',10);
INSERT INTO wf_table1(num,name,money) VALUES(NULL,'NULL',NULL);
ALTER TABLE wf_table1 ADD COLUMN age INT AS (num + 1);

--echo window_spec-2-1-1 partition_clause
SELECT name, CUME_DIST() OVER w AS wf1
       FROM wf_table1
       WINDOW w AS (PARTITION BY name)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY name,num)
       ORDER BY name;       
--echo window_spec-2-1-2 order_clause
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY name)
       ORDER BY name; 
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY num,name,num,name,num,name,money,money,num,name,num,name,num,name,money,money)
       ORDER BY name; 
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY perimeter)
       ORDER BY name; 
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY age,perimeter,perimeter,perimeter,perimeter,age,name,num)
       ORDER BY name; 
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY money ASC)
       ORDER BY name; 
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY money DESC)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY money DESC,name DESC,num ASC)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY money ASC,name DESC,num ASC)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY '1')
       ORDER BY name;
--error 3592
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY 1)
       ORDER BY name;
--error 1064
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY )
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY '')
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ORDER BY money ASC,name ASC)
       ORDER BY name;

--echo window_spec-2-1-3-1 frame_clause_rows
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS UNBOUNDED PRECEDING)
       ORDER BY name;
--error 1149
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS UNBOUNDED FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS CURRENT ROW)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS 1 PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS 0 PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS 1.52313 PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS -0 PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS --1 PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS +1 PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS NULL PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS '2' PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS abs(1) PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS 10000000000000000000 PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS 999999999999999999 PRECEDING)
       ORDER BY name;
--error 3596
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS INTERVAL 5 DAY PRECEDING)
       ORDER BY name;
--error 1149
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS  1 FOLLOWING)
       ORDER BY name;
--error 1064
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS -1 FOLLOWING)
       ORDER BY name;
--echo window_spec-2-1-3-2 frame_clause_rows_BETWEEN
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND CURRENT ROW)
       ORDER BY name;
--error 1149
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND UNBOUNDED PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND  UNBOUNDED FOLLOWING)
       ORDER BY name;
--error 5561
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND 1 PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND 0 FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND 1 FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND -1 FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND 50.124 FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND 999999999999999999 FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND 10000000000000000000 FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND '2' FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND NULL FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN CURRENT ROW AND 1 FOLLOWING)
       ORDER BY name;
      
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN  UNBOUNDED PRECEDING AND CURRENT ROW)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN UNBOUNDED PRECEDING AND  UNBOUNDED FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN UNBOUNDED PRECEDING AND 1 PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN UNBOUNDED PRECEDING AND 999999999999999999 FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN  1  PRECEDING AND CURRENT ROW)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN 999999999999999999  PRECEDING AND UNBOUNDED FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN 5  PRECEDING AND 0 FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ROWS BETWEEN 1  PRECEDING AND 1 FOLLOWING)
       ORDER BY name;
--echo window_spec-2-1-4-1 frame_clause_range
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (RANGE UNBOUNDED PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (RANGE CURRENT ROW)
       ORDER BY name;
--error 3587
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (RANGE  1 PRECEDING)
       ORDER BY name;
--error 3587
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (RANGE  INTERVAL 5 DAY PRECEDING)
       ORDER BY name;
--echo window_spec-2-1-4-2 frame_clause_range_BETWEEN
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (RANGE BETWEEN CURRENT ROW AND CURRENT ROW)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (RANGE BETWEEN UNBOUNDED PRECEDING AND  UNBOUNDED FOLLOWING)
       ORDER BY name;
--error 3587
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (RANGE BETWEEN  1  PRECEDING AND CURRENT ROW)
       ORDER BY num;

--echo window_spec-2-1-5-1 partition_clause+order_clause+frame_clause_rows
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ORDER BY name DESC ROWS UNBOUNDED PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ORDER BY name DESC ROWS CURRENT ROW)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ORDER BY name DESC ROWS 999999999999999999 PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money,name ORDER BY money DESC,name DESC ROWS 5 PRECEDING)
       ORDER BY name;

SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money,name ORDER BY money DESC,name DESC ROWS BETWEEN CURRENT ROW AND CURRENT ROW)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money,name ORDER BY money DESC,name DESC ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money,name ORDER BY money DESC,name DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money,name ORDER BY money DESC,name DESC ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money,name ORDER BY money DESC,name DESC ROWS BETWEEN UNBOUNDED PRECEDING AND 1 PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money,name ORDER BY money DESC,name DESC ROWS BETWEEN 1  PRECEDING AND 1 PRECEDING)
       ORDER BY name;

--echo window_spec-2-1-5-2 partition_clause+order_clause+frame_clause_range
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ORDER BY name DESC RANGE UNBOUNDED PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ORDER BY name DESC RANGE UNBOUNDED PRECEDING);
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       GROUP BY name
       WINDOW w AS (PARTITION BY money ORDER BY name DESC RANGE UNBOUNDED PRECEDING);
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ORDER BY name DESC RANGE CURRENT ROW)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money,name ORDER BY money DESC,name DESC RANGE BETWEEN CURRENT ROW AND CURRENT ROW)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money,name ORDER BY money DESC,name DESC RANGE BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money,name ORDER BY money DESC,name DESC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money,name ORDER BY money DESC,name DESC RANGE BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING)
       ORDER BY name;
--echo window_spec-2-1-6-1 order_clause+frame_clause_rows
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY name DESC ROWS UNBOUNDED PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY name DESC ROWS CURRENT ROW)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY money DESC,name DESC ROWS 5 PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY money DESC,name DESC ROWS BETWEEN CURRENT ROW AND CURRENT ROW)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY money DESC,name DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW)
       ORDER BY name;

--echo window_spec-2-1-6-2 order_clause+frame_clause_range
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY name DESC RANGE UNBOUNDED PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY name DESC RANGE CURRENT ROW)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY money DESC,name DESC RANGE BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (ORDER BY money DESC,name DESC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW)
       ORDER BY name;
--echo window_spec-2-1-7-1 partition_clause+frame_clause_rows
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ROWS UNBOUNDED PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ROWS CURRENT ROW)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ROWS 999999999999999999 PRECEDING)
       ORDER BY name;
SELECT name,CUME_DIST() OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money,name ROWS BETWEEN 1  PRECEDING AND 1 PRECEDING)
       ORDER BY name;

