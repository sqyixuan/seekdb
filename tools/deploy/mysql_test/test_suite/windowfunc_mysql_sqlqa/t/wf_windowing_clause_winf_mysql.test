		FROM wf_table1
       WINDOW w AS (ORDER BY '')
       ORDER BY name;
SELECT name,LAG(money) OVER w AS wf1 
		FROM wf_table1
       WINDOW w AS (PARTITION BY money ORDER BY money ASC,name DESC)
       ORDER BY name;

