--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user liuyq@'%';
--enable_warnings
create user liuyq identified by 'liuyq';
grant all on *.* to liuyq WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,liuyq,liuyq,test,$OBMYSQL_PORT);

--disable_warnings
--error 0,1051
DROP TABLE wf_table1;

CREATE TABLE wf_table1(num INT,name varchar(200),money char(20),perimeter NUMERIC(20,10) AS (2 * 3.14159265 * num));
INSERT INTO wf_table1(num,name,money) VALUES(1,'Bing',-100);
INSERT INTO wf_table1(num,name,money) VALUES(2,'Bing',+104564564646.11514);
INSERT INTO wf_table1(num,name,money) VALUES(3,'Reachl',-0.23566000);
INSERT INTO wf_table1(num,name,money) VALUES(4,'Reachl',0.23566000);
INSERT INTO wf_table1(num,name,money) VALUES(5,'friends','');
INSERT INTO wf_table1(num,name,money) VALUES(6,'@#￥！%……&*~',NULL);
INSERT INTO wf_table1(num,name,money) VALUES(2,'Bing',10);
INSERT INTO wf_table1(num,name,money) VALUES(NULL,'NULL',NULL);
ALTER TABLE wf_table1 ADD COLUMN age INT AS (num + 1);

--echo winfunc-1-1-1 结果集数
SELECT name, SUM(money) OVER()
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER()
       FROM wf_table1
       group BY name
       ORDER BY name;
SELECT name, SUM(money) OVER(PARTITION BY num) AS wf1, SUM(money) OVER(PARTITION BY name) AS wf2
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(PARTITION BY num) AS wf1, SUM(money) OVER(PARTITION BY name) AS wf2,SUM(money) OVER(PARTITION BY money) AS wf3,SUM(money) OVER(PARTITION BY money) AS wf4,SUM(money) OVER(PARTITION BY money) AS wf5
       FROM wf_table1
       ORDER BY name;
--echo winfunc-1-1-2 函数个数
SELECT name, SUM(money) OVER(PARTITION BY num) AS wf1, MAX(money) OVER(PARTITION BY name) AS wf2,MIN(money) OVER(PARTITION BY money) AS wf3
       FROM wf_table1
       ORDER BY name;
SELECT name, MAX(num) OVER(PARTITION BY name) AS wf2, SUM(money) OVER(PARTITION BY num) AS wf1, MIN(money) OVER(PARTITION BY money) AS wf3
       FROM wf_table1
       ORDER BY name;
--echo winfunc-1-1-3-1 expr column number
SELECT name, SUM(money) OVER(PARTITION BY name,name) AS wf1
       FROM wf_table1
       ORDER BY name;   
SELECT name, SUM(money) OVER(PARTITION BY name,money,num,name,money,num) AS wf1
       FROM wf_table1
       ORDER BY name; 
--error 1241
SELECT name, SUM(money) OVER(PARTITION BY (name,money,num),name,money,num) AS wf1
       FROM wf_table1
       ORDER BY name; 
SELECT name, SUM(money) OVER(PARTITION BY (name)) AS wf1
       FROM wf_table1
       ORDER BY name; 
--error 1054
SELECT name, SUM(money) OVER(PARTITION BY name,money,num,als) AS wf1
       FROM wf_table1
       ORDER BY name;
--echo winfunc-1-1-3-1 expr 生成列
SELECT name, SUM(money) OVER(PARTITION BY perimeter) AS wf1
       FROM wf_table1
       ORDER BY name;
SELECT name, SUM(money) OVER(PARTITION BY age) AS wf1
       FROM wf_table1
       ORDER BY name;
