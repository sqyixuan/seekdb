wf_sql-1-2-1 执行顺序
SELECT w1.name,AVG(w1.money) a1 from wf_table1 w1
JOIN wf_table2 w2
on w1.num=w2.num
where w1.num<9
GROUP BY w1.name 
HAVING a1>-1;
name	a1
Bing	52282282273.05757
Reachl	-0.23566
SELECT w1.name,AVG(w1.money) a1,ROW_NUMBER() OVER(ORDER BY w1.name DESC ROWS 1 PRECEDING) AS wf1 from wf_table1 w1
JOIN wf_table2 w2
on w1.num=w2.num
where w1.num<9
GROUP BY w1.name 
HAVING a1>-1;
name	a1	wf1
Reachl	-0.23566	1
Bing	52282282273.05757	2
SELECT w1.name,AVG(w1.money) a1,ROW_NUMBER() OVER(ORDER BY w1.name ROWS 1 PRECEDING) AS wf1 from wf_table1 w1
JOIN wf_table2 w2
on w1.num=w2.num
where w1.num<9
GROUP BY w1.name 
ORDER BY a1 DESC
LIMIT 1;
name	a1	wf1
Bing	52282282273.05757	1
SELECT w1.name,AVG(w1.money) a1,ROW_NUMBER() OVER w AS wf1 from wf_table1 w1
JOIN wf_table2 w2
on w1.num=w2.num
where w1.num<9
GROUP BY w1.name 
WINDOW w as (ORDER BY w1.name ROWS 1 PRECEDING)
ORDER BY a1 DESC
LIMIT 1;
name	a1	wf1
Bing	52282282273.05757	1
SELECT DISTINCT name, ROW_NUMBER() OVER(ORDER BY name DESC ROWS 1 PRECEDING) AS wf1
FROM wf_table1
ORDER BY name;
name	wf1
