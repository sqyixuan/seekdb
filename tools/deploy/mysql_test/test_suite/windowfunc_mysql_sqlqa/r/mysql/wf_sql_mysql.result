Bing	5
Bing	6
Bing	7
friends	4
NULL	3
Reachl	1
Reachl	2
wf_sql-1-3-1 表和视图 空表
DROP TABLE wf_table3;
CREATE TABLE wf_table3(num INT,name varchar(20),money char(20));
SELECT DISTINCT name, ROW_NUMBER() OVER(ORDER BY name DESC ROWS 1 PRECEDING) AS wf1
FROM wf_table3
ORDER BY name;
name	wf1
