--result_format 4
PURGE RECYCLEBIN;
--source mysql_test/test_suite/external_table_tmp_url_sqlqa/include/copy_data_for_external_table.inc

##outfile(支持)##
--error 1086
select * from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
)
PATTERN 'zct2_1.csv')
into outfile 'external_table_tmp_url_sqlqa_data/data_zct2/zct2_2.csv'  FIELDS TERMINATED BY ' ' OPTIONALLY ENCLOSED BY  '"' LINES  TERMINATED BY '\n'  single = FALSE
;

select * from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
)
PATTERN 'zct2_2.csv');


####load data####
##data type##
DROP TABLE IF EXISTS zct2;
CREATE TABLE zct2(c1 TINYINT,c2 SMALLINT,c3 MEDIUMINT,c4 int,c5 BIGINT,c6 DECIMAL(5,2),c7 float(5,2),c8 double(5,2),c9 bit(20),c10 TINYINT(255) UNSIGNED,c11 SMALLINT(255) UNSIGNED,c12 MEDIUMINT(255) UNSIGNED,c13 int (255) UNSIGNED,c14 bigint(255) UNSIGNED,c15 decimal UNSIGNED,c16 float(5,2) UNSIGNED,c17 double(5,2) UNSIGNED,c18 datetime,c19 timestamp,c20 date,c21 time,c22 year,c23 char(25),c24 varchar(50),c25 binary,c26 varbinary(50),c27 TINYBLOB,c28 BLOB,c29 MEDIUMBLOB,c30 LONGBLOB,c31 TINYTEXT,c32 TEXT,c33 MEDIUMTEXT,c34 LONGTEXT,c35 ENUM('','a','1','中') CHARACTER SET utf16 ,c36 set('a', '1','','中') CHARACTER SET utf16,c37 json,c38 GEOMETRY);

load data  /*+ direct(true,0) parallel(2)  */ from   files(location = 'external_table_tmp_url_sqlqa_data/data_zct2/'
,FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
),PATTERN 'zct2_2.csv')
into table zct2(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16,c17,c18,c19,c20,c21,c22,c23,c24,c25,c26,c27,c28,c29,c30,c31,c32,c33,c34,c35,c36);
select * from zct2;

##
load data  /*+ direct(true,0) parallel(2)  */ from   (select c1 from files(location = 'external_table_tmp_url_sqlqa_data/data_zct2/',
FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
),PATTERN 'zct2_2.csv'))into table zct2(c1);
select c1 from zct2;

delete from zct2 where c1 is null or c1 in
( select c1 from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
type = 'csv',
FIELD_DELIMITER = ' ',
FIELD_OPTIONALLY_ENCLOSED_BY='"',
LINE_DELIMITER = '\n')
PATTERN 'zct2_2.csv'));

insert /*+ direct(true,0) parallel(2)  */ into zct2(c1,c2,c3,c4,c5,c6,c7,c8,c9,c21,c23,c24,c26,c27,c28,c29,c30,c31,c32,c33,c34)
(select c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1 from 'external_table_tmp_url_sqlqa_data/data_zct2/'
 (FORMAT (
 type = 'csv',
 FIELD_DELIMITER = ' ',
 FIELD_OPTIONALLY_ENCLOSED_BY='"',
 LINE_DELIMITER = '\n')
 PATTERN 'zct2_2.csv'));
select * from zct2;

