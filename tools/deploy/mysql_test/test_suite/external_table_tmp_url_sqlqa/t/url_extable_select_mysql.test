##SIMPLE SELECT##
select c1 c1,c2 c2,c3 c3,c4 c4,c5 c5,c6 c6 from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
))
;

select DISTINCT c1 ID, c2 NAME,c3 MON,c4 AGE,c5 TEL_NUMBER,c6 BIR from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) order by 1
;

select UNIQUE c1 ID, c2 NAME,c3 MON,c4 AGE,c5 TEL_NUMBER from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) order by 1
;

select ALL c1 ID, c2 NAME,c3 MON,c4 AGE,c5 TEL_NUMBER,c6 BIR from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"'
)
PATTERN 'zct2_1.csv') order by 1
;

select c3*10 MON,c1+10 ID from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) order by 1
;

select c2 || '-' || C4 AS NG from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) order by 1
;

select c3 MON,CASE WHEN C3 >= 4000 THEN 'H' WHEN C3 >= 3000 THEN 'N' ELSE 'L' END AS T from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) order by 1
;

##WHERE##
select  c1 ID, c2 NAME,c3 MON,c4 AGE,c5 TEL_NUMBER,c6 BIR from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) WHERE C1 < 3 order by 1
;

select  c1 ID, c2 NAME,c3 MON,c4 AGE,c5 TEL_NUMBER,c6 BIR from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) WHERE C4 = 40 order by 1
;

select  c1 ID, c2 NAME,c3 MON,c4 AGE,c5 TEL_NUMBER,c6 BIR from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) WHERE C3> 4000 AND C1 >3 order by 1
;

select  c1 ID, c2 NAME,c3 MON,c4 AGE,c5 TEL_NUMBER,c6 BIR from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) WHERE C3 > 4000 OR C1 >3 order by 1
;

##GROUP BY##
select  c1 ID,max(c3) MON,min(c4) AGE from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) GROUP BY ID ORDER BY ID
;

select  c1 ID,max(c3) MON,min(c4) AGE from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) GROUP BY ID HAVING C1 > 3 AND SUM(C3) > 4000 ORDER BY ID ASC
;

select  c1 ID,c2 NAME,count(*) from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) GROUP BY ID,NAME WITH ROLLUP ORDER BY ID
;

select  c1 ID,c2 NAME,count(*) from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) GROUP BY c1,c2,c3,c4,c5,c6 ORDER BY c1,c2,c3,c4,c5,c6
;

##ORDER BY##
select  * from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) WHERE c1 > 1 ORDER BY c1
;

select  c2 NAME,count(*) from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) GROUP BY NAME ORDER BY NAME
;

select  c3 MON,count(*) from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) WHERE C1 >1 GROUP BY MON ORDER BY MON
;

select  C4 AGE,count(*) from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) WHERE C1 >1 GROUP BY AGE HAVING AGE <30 ORDER BY AGE
;

select  * from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) ORDER BY C5,C6
;


