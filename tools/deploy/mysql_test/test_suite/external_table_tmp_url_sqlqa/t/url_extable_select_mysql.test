##子查询##
select  c1 ID, c2 NAME,c3 MON,c4 AGE,c5 TEL_NUMBER,c6 BIR from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) WHERE c5 BETWEEN
(SELECT  MAX(LOWER(c6)) FROM
'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
   type = 'csv',
   FIELD_DELIMITER = ',',
   FIELD_OPTIONALLY_ENCLOSED_BY='"',
   EMPTY_FIELD_AS_NULL = true
 )))
AND
(SELECT COUNT(c3) FROM
'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
   type = 'csv',
   FIELD_DELIMITER = ',',
   FIELD_OPTIONALLY_ENCLOSED_BY='"',
   EMPTY_FIELD_AS_NULL = true
 ))
WHERE c3 NOT IN ('1000') OR (c1 IN (NULL) AND c3 IS NOT NULL) OR c2 LIKE '%')
;

select  c1 ID, c2 NAME,c3 MON,c4 AGE,c5 TEL_NUMBER,c6 BIR from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
))WHERE c5 NOT IN
(SELECT  MIN(ROUND(c5)) FROM
'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
))
WHERE (c2 LIKE 'NULL%' OR c1 <> -1) AND c1 IN ('1000',''));

####create table/view as select##
DROP TABLE IF EXISTS ex_t1;
--error 1146
create table ex_t1 as select  c1 ID, c2 NAME,c3 MON,c4 AGE,c5 TEL_NUMBER,c6 BIR from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
));

create view ex_t1 as select  c1 ID, c2 NAME,c3 MON,c4 AGE,c5 TEL_NUMBER,c6 BIR from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
));
--error 1356
select * from ex_t1;

drop view ex_t1;

create table ex_t1(
id CHAR(10)  ,
name varchar(50) ,
mon VARCHAR(50) ,
age VARCHAR(50) ,
tel_number VARCHAR(50) ,
bir VARCHAR(50));

load data  /*+ direct(true,0) parallel(2)  */ from  files(location = 'external_table_tmp_url_sqlqa_data/data5/'
,FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
))into table ex_t1;

SELECT * FROM EX_T1 A WHERE A.ID =
(SELECT c1 FROM
'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
))
 WHERE c3 = 3500 );

SELECT * FROM EX_T1 A WHERE A.ID IN
(SELECT c1 FROM
'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
))
WHERE c2 IS NOT NULL );

SELECT * FROM EX_T1 A WHERE A.ID NOT IN
(SELECT c1 FROM
'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
     type = 'csv',
     FIELD_DELIMITER = ',',
     FIELD_OPTIONALLY_ENCLOSED_BY='"',
     EMPTY_FIELD_AS_NULL = true
))
WHERE c2 IS NULL );

SELECT * FROM EX_T1 A WHERE EXISTS
(SELECT c1 FROM
'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
     type = 'csv',
     FIELD_DELIMITER = ',',
     FIELD_OPTIONALLY_ENCLOSED_BY='"',
     EMPTY_FIELD_AS_NULL = true
))
WHERE c2 IS NOT NULL );

SELECT * FROM
'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
     type = 'csv',
     FIELD_DELIMITER = ',',
     FIELD_OPTIONALLY_ENCLOSED_BY='"',
     EMPTY_FIELD_AS_NULL = true
)) where
c1 <ALL (SELECT B.ID FROM EX_T1 B WHERE B.MON >4000 );

SELECT * FROM EX_T1 A WHERE A.ID =SOME
(SELECT c1 FROM
'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
     type = 'csv',
     FIELD_DELIMITER = ',',
     FIELD_OPTIONALLY_ENCLOSED_BY='"',
     EMPTY_FIELD_AS_NULL = true
))
WHERE c6 IS NOT NULL  );

SELECT * FROM
(SELECT * FROM
 'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
      type = 'csv',
      FIELD_DELIMITER = ',',
      FIELD_OPTIONALLY_ENCLOSED_BY='"',
      EMPTY_FIELD_AS_NULL = true
 ))) A WHERE A.c1 IN (SELECT ID FROM EX_T1 B WHERE B.ID >1);

SELECT * FROM
(SELECT * FROM
  'external_table_tmp_url_sqlqa_data/data5/'
  (FORMAT (
       type = 'csv',
       FIELD_DELIMITER = ',',
       FIELD_OPTIONALLY_ENCLOSED_BY='"',
       EMPTY_FIELD_AS_NULL = true
  )) WHERE c1 IN (SELECT B.ID FROM EX_T1 B)) C;

SELECT
(SELECT c1 FROM
   'external_table_tmp_url_sqlqa_data/data5/'
   (FORMAT (
        type = 'csv',
        FIELD_DELIMITER = ',',
        FIELD_OPTIONALLY_ENCLOSED_BY='"',
        EMPTY_FIELD_AS_NULL = true
   )) WHERE c1 = 1)
C1 FROM EX_T1;

SELECT
(SELECT c1 FROM
    'external_table_tmp_url_sqlqa_data/data5/'
    (FORMAT (
         type = 'csv',
         FIELD_DELIMITER = ',',
         FIELD_OPTIONALLY_ENCLOSED_BY='"',
         EMPTY_FIELD_AS_NULL = true
    )) WHERE c1 = 1) C1
FROM
(SELECT * FROM
 'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
      type = 'csv',
      FIELD_DELIMITER = ',',
      FIELD_OPTIONALLY_ENCLOSED_BY='"',
      EMPTY_FIELD_AS_NULL = true
 ))) a
WHERE a.c2 IN
(SELECT c2 FROM
 'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
      type = 'csv',
      FIELD_DELIMITER = ',',
      FIELD_OPTIONALLY_ENCLOSED_BY='"',
      EMPTY_FIELD_AS_NULL = true
 ))
WHERE c1 = 1);

SELECT * FROM EX_T1 A WHERE A.ID in
(SELECT c1 FROM
 'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
      type = 'csv',
      FIELD_DELIMITER = ',',
      FIELD_OPTIONALLY_ENCLOSED_BY='"',
      EMPTY_FIELD_AS_NULL = true
 ))
WHERE A.MON = 3500 );

SELECT * FROM EX_T1 A WHERE A.ID not in
(SELECT c1 FROM
 'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
      type = 'csv',
      FIELD_DELIMITER = ',',
      FIELD_OPTIONALLY_ENCLOSED_BY='"',
      EMPTY_FIELD_AS_NULL = true
 ))
WHERE A.NAME IS NULL );

SELECT * FROM
 'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
      type = 'csv',
      FIELD_DELIMITER = ',',
      FIELD_OPTIONALLY_ENCLOSED_BY='"',
      EMPTY_FIELD_AS_NULL = true
 ))
WHERE C1 !=ANY (SELECT B.ID FROM EX_T1 B WHERE C4 < 40 );


##JOIN##
--sorted_result
SELECT /*+ USE_PX PARALLEL(4)*/ * FROM
 'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
      type = 'csv',
      FIELD_DELIMITER = ',',
      FIELD_OPTIONALLY_ENCLOSED_BY='"',
      EMPTY_FIELD_AS_NULL = true
 ))
JOIN EX_T1 B ON C1 = B.ID WHERE C1 IS NULL OR B.ID IS NOT NULL GROUP BY C1 HAVING C1 = 1 ORDER BY C1;

SELECT /*+ USE_PX PARALLEL(4)*/ COUNT(*) FROM
(select * from 'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
      type = 'csv',
      FIELD_DELIMITER = ',',
      FIELD_OPTIONALLY_ENCLOSED_BY='"',
      EMPTY_FIELD_AS_NULL = true
 ) PATTERN 'test05.csv')) a
, (select * from 'external_table_tmp_url_sqlqa_data/data5/'
   (FORMAT (
        type = 'csv',
        FIELD_DELIMITER = ',',
        FIELD_OPTIONALLY_ENCLOSED_BY='"',
        EMPTY_FIELD_AS_NULL = true
   )))b WHERE a.C1 IS NULL
;

SELECT  * FROM
 'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
      type = 'csv',
      FIELD_DELIMITER = ',',
      FIELD_OPTIONALLY_ENCLOSED_BY='"',
      EMPTY_FIELD_AS_NULL = true
 ))
FULL JOIN (SELECT  * FROM EX_T1 B WHERE ID IS NULL OR AGE IS NOT NULL) B ON c1 = B.ID WHERE c2 = B.MON;

select * from
(SELECT * FROM
 'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
      type = 'csv',
      FIELD_DELIMITER = ',',
      FIELD_OPTIONALLY_ENCLOSED_BY='"',
      EMPTY_FIELD_AS_NULL = true
 ))) A LEFT JOIN
 (SELECT  * FROM
  'external_table_tmp_url_sqlqa_data/data5/'
  (FORMAT (
       type = 'csv',
       FIELD_DELIMITER = ',',
       FIELD_OPTIONALLY_ENCLOSED_BY='"',
       EMPTY_FIELD_AS_NULL = true
  ))
 WHERE c2 NOT LIKE 'b'  OR c1 < 40) B ON A.c4 = B.c4;

SELECT /*+ USE_PX PARALLEL(2)*/ COUNT(*) FROM
(SELECT  * FROM
   'external_table_tmp_url_sqlqa_data/data5/'
   (FORMAT (
        type = 'csv',
        FIELD_DELIMITER = ',',
        FIELD_OPTIONALLY_ENCLOSED_BY='"',
        EMPTY_FIELD_AS_NULL = true
   ))) A
RIGHT JOIN
(SELECT  * FROM
   'external_table_tmp_url_sqlqa_data/data5/'
   (FORMAT (
        type = 'csv',
        FIELD_DELIMITER = ',',
        FIELD_OPTIONALLY_ENCLOSED_BY='"',
        EMPTY_FIELD_AS_NULL = true
   ))) B ON A.c4 = B.c4 WHERE A.c2 IS NULL OR B.c6 NOT LIKE '%' GROUP BY A.c2;

SELECT /*+ USE_PX PARALLEL(2)*/ COUNT(*) FROM
(select * from
   'external_table_tmp_url_sqlqa_data/data5/'
   (FORMAT (
        type = 'csv',
        FIELD_DELIMITER = ',',
        FIELD_OPTIONALLY_ENCLOSED_BY='"',
        EMPTY_FIELD_AS_NULL = true) ))A,
EX_T1 B,
T1 C WHERE A.c4 = B.AGE AND A.c1 = C.c1 AND A.c6 IS NOT NULL OR C.c2 LIKE '%';


DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS EX_t1;

--source mysql_test/test_suite/external_table_tmp_url_sqlqa/include/clean_data_for_external_table.inc
