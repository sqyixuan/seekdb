INSERT INTO zct2 (c1, c2, c3, c4, c5, c6, c7, c8, c9, c10, c11, c12, c13, c14, c15, c16, c17, c18, c19, c20, c21, c22, c23, c24, c25, c26, c27, c28, c29, c30, c31, c32, c33, c34, c35, c36, c37, c38)  VALUES  (null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null,null);

#select  c1, c2, c3, c4, c5, c6, c7, c8, c9, c10, c11, c12, c13, c14, c15, c16, c17, c18, c19, c20, c21, c22, c23, c24, c25, c26, c27, c28, c29, c30, c31, c32, c33, c34, c35, c36 from zct2 into outfile 'external_table_tmp_url_sqlqa_data/data_zct2/zct2_1.csv'  FIELDS TERMINATED BY ' ' OPTIONALLY ENCLOSED BY  '"' LINES  TERMINATED BY '\n'  single = FALSE  ;

select * from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
)
PATTERN 'zct2_1.csv')
;

####压缩csv
####目前不支持
--disable_parsing
select c1, c2, c3, c4, c5, c6, c7, c8, c9, c10, c11, c12, c13, c14, c15, c16, c17, c18, c19, c20, c21, c22, c23, c24, c25, c26, c27, c28, c29, c30, c31, c32, c33, c34, c35, c36 from zct2 into outfile 'external_table_tmp_url_sqlqa_data/data_zct2/tmp_csv.gz'
format(
type = 'csv',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4',
COMPRESSION = gzip
FILE_EXTENSION = '.gz'
) single = true;

select * from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
type = 'csv',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4',
COMPRESSION = gzip
)
PATTERN 'tmp_csv.gz')
;
--enable_parsing

####format
