##SKIP_BLANK_LINES
select * from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    ENCODING = 'BINARY',
    SKIP_BLANK_LINES = true
)
PATTERN 'zct2_1.csv')
;

select * from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    SKIP_BLANK_LINES = true
)
PATTERN 'test03.csv')
;

select * from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    SKIP_BLANK_LINES = true,
    SKIP_HEADER = 1
)
PATTERN 'test03.csv')
;

##TRIM_SPACE
select * from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    TRIM_SPACE = true
)
PATTERN 'test03.csv')
;

select * from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv'
	LINE_DELIMITER = char(10)
	FIELD_DELIMITER = ','
	ESCAPE = '\\'
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	NULL_IF = ('')
	SKIP_HEADER = 0
	SKIP_BLANK_LINES = FALSE
	TRIM_SPACE = TRUE
)
PATTERN 'test03.csv')
;

##EMPTY_FIELD_AS_NULL
select * from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    ENCODING = 'BINARY',
    SKIP_BLANK_LINES = true,
    EMPTY_FIELD_AS_NULL = TRUE
)
PATTERN 'zct2_1.csv')
;

select * from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    ENCODING = 'UTF8MB4',
    EMPTY_FIELD_AS_NULL = TRUE
)
PATTERN 'zct2_1.csv')
;


