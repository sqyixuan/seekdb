##NULL_IF
##有问题，会截掉数据
##已修复##
select * from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    ENCODING = 'BINARY',
    NULL_IF = ('a')
)
PATTERN 'zct2.csv_0.csv')
;

select * from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    NULL_IF = ('a')
)
PATTERN 'zct2_1.csv')
;

select * from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    NULL_IF = ('longtext')
)
PATTERN 'zct2_1.csv')
;

