# tags: external_table
# description: test url external table

--result_format 4
PURGE RECYCLEBIN;
--source mysql_test/test_suite/external_table_tmp_url_sqlqa/include/copy_data_for_external_table.inc

#####字段解析#####
select c1 from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    SKIP_BLANK_LINES = true
)
PATTERN 'test03.csv')
;

#--error 1054
select c1 from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    SKIP_BLANK_LINES = true,
    SKIP_HEADER = 1
)
PATTERN 'test03.csv')
;

select 工资,年龄,手机号 from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    SKIP_BLANK_LINES = true,
    parse_header = true
)
PATTERN 'test03.csv')
;

select ` 工号 `,` "姓名" ` from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    SKIP_BLANK_LINES = true,
    parse_header = true
)
PATTERN 'test03.csv')
;

select c1 as a,c2 as b,c3 as c,c4 as d,c5 as f from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
)
PATTERN 'test03.csv')
;

select c1 as `工号`,c2 as `姓名`,c3 as `工资`,c4 as `年龄`,c5 as `手机号` from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
)
PATTERN 'test03.csv')
;

select ` 工号 ` as a,` "姓名" ` as b,工资 as c,年龄 as d,手机号 as f  from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n',
    parse_header = true
)
PATTERN 'test03.csv')
;

select c2,c1,c3,c5,c4 from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
)
PATTERN 'test03.csv')
;

--error 1054
select c6 from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
)
PATTERN 'test03.csv')
;

####函数嵌套
select c1,c36,c1,c36 from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
)
PATTERN 'zct2_1.csv')
;

select c34,c35,concat(c34,c35) from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
)
PATTERN 'zct2_1.csv')
;

select c1,trim(c1),concat(c2,c1) from 'external_table_tmp_url_sqlqa_data/data3/'
(FORMAT (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true
)
PATTERN 'test03.csv')
;

select upper(c23),lower(c24),substr(c24,1,3),length(c24),replace(c27,c27,'TYPE') from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
)
PATTERN 'zct2_1.csv')
;

select c1+0 AS ID,cast(c2 as char(10)) AS NAME,round(c3,1) AS MON,c2||c4 AS AGE,cast(c5 as decimal(5,2)) AS DEC,cast(c6 as date) AS BIR from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
	FIELD_DELIMITER = ',',
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34),
	ENCODING = 'UTF8MB4',
	SKIP_HEADER = 0,
	EMPTY_FIELD_AS_NULL = true
))
;

select case when c3 > 4000 then 'Y' else 'N' end from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
	FIELD_DELIMITER = ',',
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34),
	ENCODING = 'UTF8MB4',
	SKIP_HEADER = 0,
	EMPTY_FIELD_AS_NULL = true
))
;

select nvl(c3,'kong') from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true
))
;

select count(*) from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
)
PATTERN 'zct2_1.csv')
;

select count(*),sum(c1),max(c2),min(c3),avg(c4) from 'external_table_tmp_url_sqlqa_data/data_zct2/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
)
PATTERN 'zct2_1.csv')
;

--source mysql_test/test_suite/external_table_tmp_url_sqlqa/include/clean_data_for_external_table.inc
