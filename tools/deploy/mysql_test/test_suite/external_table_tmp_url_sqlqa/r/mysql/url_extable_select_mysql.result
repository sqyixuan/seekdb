select  c1 ID, c2 NAME,c3 MON,c4 AGE,c5 TEL_NUMBER,c6 BIR from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) WHERE c5 BETWEEN
(SELECT  MAX(LOWER(c6)) FROM
'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
   type = 'csv',
   FIELD_DELIMITER = ',',
   FIELD_OPTIONALLY_ENCLOSED_BY='"',
   EMPTY_FIELD_AS_NULL = true
 )))
AND
(SELECT COUNT(c3) FROM
'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
   type = 'csv',
   FIELD_DELIMITER = ',',
   FIELD_OPTIONALLY_ENCLOSED_BY='"',
   EMPTY_FIELD_AS_NULL = true
 ))
WHERE c3 NOT IN ('1000') OR (c1 IN (NULL) AND c3 IS NOT NULL) OR c2 LIKE '%')
;
