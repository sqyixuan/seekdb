select c3 MON,CASE WHEN C3 >= 4000 THEN 'H' WHEN C3 >= 3000 THEN 'N' ELSE 'L' END AS T from 'external_table_tmp_url_sqlqa_data/data5/'
(FORMAT (
    type = 'csv',
    FIELD_DELIMITER = ',',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    EMPTY_FIELD_AS_NULL = true
)) order by 1
;
