##JOIN##
SELECT /*+ USE_PX PARALLEL(4)*/ * FROM
 'external_table_tmp_url_sqlqa_data/data5/'
 (FORMAT (
      type = 'csv',
      FIELD_DELIMITER = ',',
      FIELD_OPTIONALLY_ENCLOSED_BY='"',
      EMPTY_FIELD_AS_NULL = true
 ))
JOIN EX_T1 B ON C1 = B.ID WHERE C1 IS NULL OR B.ID IS NOT NULL GROUP BY C1 HAVING C1 = 1 ORDER BY C1;
