    type = 'csv',
    FIELD_DELIMITER = ' ',
    FIELD_OPTIONALLY_ENCLOSED_BY='"',
    LINE_DELIMITER = '\n'
)PATTERN 'zct2_2.csv'))into table zct2(c20);
select c20 from zct2;
