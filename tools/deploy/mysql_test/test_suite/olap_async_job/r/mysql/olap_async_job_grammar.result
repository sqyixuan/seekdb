purge recyclebin;
result_format: 4
drop user hrh@'%';
create user hrh identified by 'hrh';
grant all on *.* to hrh WITH GRANT OPTION;


SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';

------------------------------------------------------------------------------------
################## 环境
drop table source_table;
CREATE TABLE source_table ( 
  id int
);
drop table write_table;
CREATE TABLE write_table ( 
  id int
);
drop table load_table;
CREATE TABLE load_table ( W0_TEST0 INT , W0_TEST1 CHAR(100) , W0_TEST2 TIME );

drop table external_table;
create external table external_table( W0_TEST0 INT , W0_TEST1 CHAR(100) , W0_TEST2 TIME ) format (type = 'PARQUET') location '/tmp/asdf/asdf';

insert into source_table values(1);
insert into source_table values(2);

################## olap job grammar
############ submit job
###### case 1
submit job insert overwrite write_table select id from source_table where id = 1;

select * from write_table where id = 1;
+------+
| id   |
+------+
|    1 |
+------+

###### case 2
submit job insert into write_table(id) select id from source_table where id = 2;

select * from write_table where id = 2;
+------+
| id   |
+------+
|    2 |
+------+

###### case 3
submit job create table copy_table AS select * from source_table;
等待所有 job 完成 ...

select * from copy_table;
+------+
| id   |
+------+
|    1 |
|    2 |
+------+

###### case 4


submit job LOAD DATA INFILE 'data_for_mysqltest_loaddata/data/A0.txt' REPLACE INTO TABLE load_table FIELDS TERMINATED BY ',' ;

select * from load_table order by W0_TEST0 DESC , W0_TEST1 DESC , W0_TEST2 DESC;
+----------+----------+----------+
| W0_TEST0 | W0_TEST1 | W0_TEST2 |
+----------+----------+----------+
|        4 | D        | 00:00:03 |
|        3 | C        | 00:00:02 |
|        2 | B        | 00:00:01 |
|        1 | A        | 00:00:00 |
+----------+----------+----------+

###### case 5 外表
submit job insert overwrite load_table select * from external_table;

select * from load_table order by W0_TEST0 DESC , W0_TEST1 DESC , W0_TEST2 DESC;
+----------+----------+----------+
| W0_TEST0 | W0_TEST1 | W0_TEST2 |
+----------+----------+----------+
+----------+----------+----------+

drop table source_table;
drop table write_table;
drop table copy_table;
drop table load_table;
drop table external_table;

###### case 6
drop table t;
CREATE TABLE t ( 
  id int
);

submit job SELECT id FROM t;
ERROR 0A000: sql type not supported
submit job SELECT COUNT(*) FROM t;
ERROR 0A000: sql type not supported
submit job UPDATE t SET id = 20 WHERE id = 1;
ERROR 0A000: sql type not supported
submit job DELETE FROM t WHERE id = 2;
ERROR 0A000: sql type not supported

############ show job
###### 测试 root 用户, 数据准备
进入 sys 注入一个错误的 job name, 后续 submit job 都会生成错误的 job name
alter system set_tp tp_name = ERRSIM_SUBMIT_ERR_JOB_NAME, error_code = 4000, frequency = 1;
清空所有 job 信息
alter system change tenant sys;
delete from OCEANBASE.__all_scheduler_job_run_detail_v2 where job > 0;
alter system change tenant sys;
这里生成的 job 是错误的 job name 
submit job select 1 from dual;
进入 sys 取消错误注入, 后续 submit job 都会生成正确的 job name
alter system set_tp tp_name = ERRSIM_SUBMIT_ERR_JOB_NAME, error_code = 4000, frequency = 0;

进入 root 开始测试
###### case 1 查询所有 job, 第一个应该是 ERRSIM_JOB
ERRSIM_JOB;
###### case 2 再创建 2 个 JOB, show job status 应该只有 3 个
submit job select 1 from dual;
submit job select 1 from dual;
获取第 4 行，应该为空
No such row;
###### case 3 show job status 第 3 个 JOB 一定是 ERRSIM_JOB
ERRSIM_JOB;
###### case 4 show job status where 应该只有一个 job 
获取第 2 行，应该为空
No such row;
###### case 5 show job status where 应该只有一个 job, 查询第一行 一定是 ERRSIM_JOB
ERRSIM_JOB;
等待 ERRSIM_JOB 从 JOB 表删除 ...


###### 测试普通用户,数据准备
在登陆 hrh 前开启错误 job name 注入
alter system set_tp tp_name = ERRSIM_SUBMIT_ERR_JOB_NAME, error_code = 4000, frequency = 1;

进入 hrh 开始测试
创建一个错误 job
submit job select 1 from dual;
回到 sys 关闭错误注入
alter system set_tp tp_name = ERRSIM_SUBMIT_ERR_JOB_NAME, error_code = 4000, frequency = 0;

回到 hrh 开始测试

###### case 6 普通用户只能看见自己的 job, 应该只有一行
获取第 2 行，应该为空
No such row;
###### case 7 普通用户只能看见自己的 job, 第 1 个 JOB 一定是 ERRSIM_JOB
ERRSIM_JOB;
###### case 8 再创建 2 个 JOB, show job status 应该只有 3 个
submit job select 1 from dual;
submit job select 1 from dual;
获取第 4 行，应该为空
No such row;
###### case 9 show job status 第 3 个 JOB 一定是 ERRSIM_JOB
ERRSIM_JOB;
###### case 10 show job status where 应该只有一个 job 
获取第 2 行，应该为空
No such row;
###### case 11 show job status where 应该只有一个 job, 查询第一行 一定是 ERRSIM_JOB
ERRSIM_JOB;
回到 root, 应该能看到所有用户的 job

###### case 12 root 应该能看到所有用户的 job
现在一共 6 个 job 获取第 6 行，应该为 ERRSIM_JOB
ERRSIM_JOB;
############ cancel job
###### 数据准备
等所有 JOB 都执行完 ...


进入 sys
注入一个错误的 job name, 后续 submit job 都会生成错误的 job name
alter system set_tp tp_name = ERRSIM_SUBMIT_ERR_JOB_NAME, error_code = 4000, frequency = 1;
注入一个错误的 job start date, 后续 submit job 都会生成错误的 job start date
alter system set_tp tp_name = ERRSIM_SUBMIT_ERR_JOB_START_TIME, error_code = 4000, frequency = 1;
清空所有 job 信息
alter system change tenant sys;
delete from OCEANBASE.__all_scheduler_job_run_detail_v2 where job > 0;
alter system change tenant sys;

回到 root 开始测试

###### case 1 删除一个不存在的 job 
cancel job 'un_konow_job';

###### case 2 删除一个已提交, 但未调度的 job
这里生成的 job 是错误的 job name 和 开始时间为 4000年
submit job select 1 from dual;
获取 ERRSIM_JOB 的状态，应该是 SUBMITED
SUBMITTED;
cancel job 'ERRSIM_JOB';

获取 ERRSIM_JOB 的状态，应该是 CANCELED
CANCELLED;
等待这个 job 实际被删除 ...


###### case 3 删除一个正在运行的 job
数据准备
注入一个错误的 job name, 后续 submit job 都会生成错误的 job name
alter system set_tp tp_name = ERRSIM_SUBMIT_ERR_JOB_NAME, error_code = 4000, frequency = 1;
恢复 job start date
alter system set_tp tp_name = ERRSIM_SUBMIT_ERR_JOB_START_TIME, error_code = 4000, frequency = 0;
清空所有 job 信息
alter system change tenant sys;
delete from OCEANBASE.__all_scheduler_job_run_detail_v2 where job > 0;
alter system change tenant sys;

回到 root 开始测试
这里会创建一个 job name 是 ERRSIM_JOB, 超时时间 60 秒
submit job select /*+QUERY_TIMEOUT(60000000)*/ sleep(60);
等这个 job 被调度 ...


获取 ERRSIM_JOB 的状态，应该是 RUNNING
RUNNING;
cancel job 'ERRSIM_JOB';

获取 ERRSIM_JOB 的状态，应该是 CANCELED
CANCELLED;
清空错误注入
alter system set_tp tp_name = ERRSIM_SUBMIT_ERR_JOB_NAME, error_code = 4000, frequency = 0;

回到 root
