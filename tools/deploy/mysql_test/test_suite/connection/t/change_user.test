#owner: dachuan.sdc
#owner group: SQL2
#description: test max_user_connections and change_user
--disable_query_log
--error 0, 1396
drop user shanting1;
--error 0, 1396
drop user shanting2;
create user shanting1 with max_user_connections 3 max_connections_per_hour 5;
create user shanting2 with max_user_connections 3 max_connections_per_hour 5;
grant usage on test.* to shanting2;
grant all on test.* to shanting2;
connect (conn_shanting1,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);
show variables like '%connections%';
select current_user(), current_user;

## change user from shanting1 to shanting2
change_user shanting2,,test;
show variables like '%connections%';
select current_user(), current_user;

--disable_result_log
## test three connections available for shanting1.
connect (conn_shanting1_1,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_shanting1_2,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_shanting1_3,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);
--error 1226
connect (conn_shanting1_4,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);


## test only two connections available for shanting2.
connect (conn_shanting2_1,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_shanting2_2,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);
--error 1226
connect (conn_shanting2_3,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);


## now, close the original connection which has changed user from shanting1 to shanting2
dirty_close conn_shanting1;
## test one more connection available for shanting2
--error 1226
connect (conn_shanting1_5,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_shanting2_4,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);


# test there are four connect history of shanting1.
dirty_close conn_shanting1_1;
dirty_close conn_shanting1_2;
dirty_close conn_shanting1_3;
connect (conn_shanting1_5,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);
--error 1226
connect (conn_shanting1_6,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);


# test there four connect history of shanting2.
dirty_close conn_shanting2_1;
dirty_close conn_shanting2_2;
connect (conn_shanting2_5,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);
--error 1226
connect (conn_shanting2_6,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);

connection default;
drop user shanting1;
drop user shanting2;
