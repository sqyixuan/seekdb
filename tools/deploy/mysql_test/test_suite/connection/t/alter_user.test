--source mysql_test/include/check_schema_sync.inc
connection default;
select user, max_connections, max_user_connections from mysql.user where user = 'shanting1';
connect (conn_sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);

let $tenant_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $user_id = query_get_value(select user_id from __all_virtual_user where user_name = 'shanting1', user_id, 1);
--disable_query_log
eval select operation_type, ddl_stmt_str from __all_virtual_ddl_operation where ddl_stmt_str like '%SET%_CONNECTIONS%' and user_id = $user_id;
##let $user_id = query_get_value(select user_id from __all_virtual_user where user_name = 'shanting1', user_id, 1);
##--disable_query_log
##eval select operation_type, ddl_stmt_str from __all_virtual_ddl_operation where ddl_stmt_str like '%SET%_CONNECTIONS%' and user_id = $user_id;

## test three connections available for shanting1.
connect (conn_shanting1_1,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_shanting1_2,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_shanting1_3,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);
--error 1226
connect (conn_shanting1_4,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);

connection default;
alter user shanting1 with max_user_connections 4;
## test one more connection available for shanting1.
connect (conn_shanting1_4,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);
--error 1226
connect (conn_shanting1_5,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);

dirty_close conn_shanting1_1;
dirty_close conn_shanting1_2;
dirty_close conn_shanting1_3;
dirty_close conn_shanting1_4;
connect (conn_shanting1_5,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);
--error 1226
connect (conn_shanting1_6,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);
connection default;
alter user shanting1 with max_connections_per_hour 7;
## test two more connections available for shanting1.
connect (conn_shanting1_6,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_shanting1_7,$OBMYSQL_MS0,shanting1,,*NO-ONE*,$OBMYSQL_PORT);

connection default;
drop user shanting1;
