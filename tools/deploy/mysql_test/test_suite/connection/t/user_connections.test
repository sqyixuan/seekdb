#owner: dachuan.sdc
#owner group: SQL2
#description: test max_connections and max_user_connections

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,,$OBMYSQL_PORT);
connection sys;

--disable_result_log
--disable_query_log
--disable_warnings
#call oceanbase.drop_tenant_force('test_connection');
#call oceanbase.create_mysql_tenant_mini_with_arg('test_connection', "charset='utf8mb4'");
#--source mysql_test/include/check_tenant_sync.inc

connect (conn_root1,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);
connection conn_root1;
show variables like '%connections%';

--error 0, 1396
drop user shanting;

connect (conn_root2,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);
create user shanting;
GRANT USAGE ON *.* TO shanting;

--error 1231
set global max_connections = -2147483648;
--error 1231
set global max_connections = -1;
--error 1231
set global max_connections = 0;
set global max_connections = 2147483647;
--error 1231
set global max_connections = 2147483648;

set global max_connections = 6;
--sleep 5
connect (conn_st3,$OBMYSQL_MS0,shanting,,*NO-ONE*,$OBMYSQL_PORT);

--disable_result_log
# reach tenant max connections, only user with super privilege is allowed to connect.
--error 1040
connect (conn_st4,$OBMYSQL_MS0,shanting,,*NO-ONE*,$OBMYSQL_PORT);
--error 1040
connect (conn_st4,$OBMYSQL_MS0,shanting,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_root4,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);
# even user with super privilege is not allowed to connect when reach max connections + 1.
--error 1040
connect (conn_root5,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);
--error 1040
connect (conn_root5,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);

# close one connection then create another connection
dirty_close conn_st3;
--error 1040
connect (conn_st5,$OBMYSQL_MS0,shanting,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_root5,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);

# close one connection then create another connection
dirty_close conn_root2;
--error 1040
connect (conn_st6,$OBMYSQL_MS0,shanting,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_root6,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);
--error 1040
connect (conn_root7,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);


# increase max connections.
set global max_connections = 8;
sleep 2;
connect (conn_root7,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);
--error 1040
connect (conn_st8,$OBMYSQL_MS0,shanting,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_root8,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);

--enable_result_log
show variables like '%connections%';
--disable_result_log
--error 1040
connect (conn_root9,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);


# change tenant should not effect resource of target tenant.
dirty_close conn_root8;
connection sys;
alter system change tenant sys;
connect (conn_root9,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);
dirty_close sys;
#--error 1040
#connect (conn_root10,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);

--enable_result_log
show variables like '%connections%';
--disable_result_log
--error 1229
set max_connections = 10;
--error 1621
set max_user_connections = 10;


set global max_connections = 100;
sleep 1;
connect (conn_shanting0,$OBMYSQL_MS0,shanting,,*NO-ONE*,$OBMYSQL_PORT);
connection conn_root9;
set global max_user_connections = 3;
sleep 1;

# use system variable max_user_connections if it's not specified when user created.
# connection before set max_user_connections non_zero is ignored.
# as a result, conn_shanting0 is ignored, so we can create three more connections.
connect (conn_shanting1,$OBMYSQL_MS0,shanting,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_shanting2,$OBMYSQL_MS0,shanting,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_shanting3,$OBMYSQL_MS0,shanting,,*NO-ONE*,$OBMYSQL_PORT);
--error 1226
connect (conn_shanting4,$OBMYSQL_MS0,shanting,,*NO-ONE*,$OBMYSQL_PORT);


connection conn_root1;
drop user shanting;
create user shanting2 with max_user_connections 5 max_connections_per_hour 7;
--sleep 5
--enable_result_log
select max_user_connections, max_connections from mysql.user where user = 'SHANTING2';
--disable_result_log
SET GLOBAL max_user_connections =0;
# if max_user_connections is specified when create user, system variable 'max_user_connections' is ignored.
connect (conn_shanting2_1,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);
dirty_close conn_shanting2_1;

# current connections of user shanting2 is zero, connect history is one.
connect (conn_shanting2_2,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_shanting2_3,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_shanting2_4,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_shanting2_5,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_shanting2_6,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);
# reach max user connections now.
--error 1226
connect (conn_shanting2_7,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);
dirty_close conn_shanting2_2;
dirty_close conn_shanting2_3;
dirty_close conn_shanting2_4;
dirty_close conn_shanting2_5;
dirty_close conn_shanting2_6;

# current connections of user shanting2 is zero, connect history is 6.
connect (conn_shanting2_7,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);
--error 1226
connect (conn_shanting2_8,$OBMYSQL_MS0,shanting2,,*NO-ONE*,$OBMYSQL_PORT);


connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,,$OBMYSQL_PORT);
SET GLOBAL max_user_connections =0;
set global max_connections = 2147483;
drop user shanting2;
--disable_query_log
#call oceanbase.drop_tenant_force('test_connection');
