--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: chenxiansen.cxs
# owner group: SQL2
# tags: ccl
#
# test of sql ccl rule for multi_stmt 
#


--enable_warnings
--enable_info
--result_format 4

--disable_query_log
--disable_result_log

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;
sleep 3;
connection default;
alter system set _rowsets_enabled=false;
sleep 3;
--enable_result_log
--enable_query_log


create table tt22(c1 decimal(12,3));

CREATE CONCURRENT_LIMITING_RULE ccl0 ON *.* TO '%'@'%' FOR ALL FILTER BY KEYWORD('into tt22') WITH MAX_CONCURRENCY = 0 ;

set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;

delimiter //;
insert into tt22 values(2.222);insert into tt22 values(3.333323);//
insert into tt22 values(5.5555);insert into tt22 values(6.6666);//
insert into tt22 values(8.8);insert into tt22 values(9.0219);//
delimiter ;//
commit;
select * from tt22;

drop table tt22;
drop concurrent_limiting_rule ccl0;

alter system set ob_enable_batched_multi_statement=false;
alter system set _rowsets_enabled=true;
set autocommit = true;
