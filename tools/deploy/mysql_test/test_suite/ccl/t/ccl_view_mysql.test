#owner: zhl413386
#owner group: sql3
#tag: ccl

--result_format 4
desc oceanbase.CDB_OB_CCL_RULES;
desc oceanbase.DBA_OB_CCL_RULES;
desc oceanbase.gv$OB_SQL_CCL_STATUS;

CREATE CONCURRENT_LIMITING_RULE TEST_CCL_DROP ON *.* TO '%'@'%' FOR ALL FILTER BY KEYWORD('E') WITH MAX_CONCURRENCY = 0;
DrOP CONCURRENT_LIMITING_RULE TEST_CCL_DROP;

CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS `global_emergency_ccl_rule`
ON test.*
TO `%`@`%`
FOR select
WITH MAX_CONCURRENCY = 0;
sleep 5;

select 1 as tenant_id, ccl_rule_name from oceanbase.DBA_OB_CCL_RULES;

create table t1(c1 int);
--error 0,11087
select * from t1;
select b.CCL_RULE_NAME from oceanbase.gv$ob_sql_audit a, oceanbase.DBA_OB_CCL_RULES b where trace_id = last_trace_id() and a.CCL_RULE_ID != 0 and a.CCL_RULE_ID = b.CCL_RULE_ID;

drop table t1;
drop CONCURRENT_LIMITING_RULE `global_emergency_ccl_rule`;