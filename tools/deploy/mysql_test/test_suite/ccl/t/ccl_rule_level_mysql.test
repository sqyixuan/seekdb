#owner: zhl413386
#owner group: sql3
#tag: ccl

--result_format 4

#Test different impact scopes
#1.global scope
#2.dml scope
#3.databse&table scope
#4.user scope

connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
--disable_warnings
drop database if exists ccl_db;
create database ccl_db;
use ccl_db;

create table ccl_t1 (c1 int, c2 varchar(32));

insert into ccl_t1 values(1, "123");
insert into ccl_t1 values(2, "456");
insert into ccl_t1 values(3, "789");

create table ccl_t2 (c1 int, c2 varchar(32));
insert into ccl_t2 values(1, "123");
insert into ccl_t2 values(2, "456");
insert into ccl_t2 values(3, "789");



--enable_warnings

--disable_result_log

select * from ccl_t1 where c2 = 123;

#1.global scope
CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS global_emergency_ccl_rule
ON *.*
TO '%'@'%'
FOR all
FILTER BY KEYWORD('ccl_t1', 'c2 = 123')
WITH MAX_CONCURRENCY = 0;

--error 0,11087
select * from ccl_t1 where c2 = 123;
select * from ccl_t1 where c2 = 124;

DROP CONCURRENT_LIMITING_RULE IF EXISTS global_emergency_ccl_rule;

#2.dml scope
#select
CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS global_emergency_select_ccl_rule
ON *.*
TO '%'@'%'
FOR select
FILTER BY KEYWORD('ccl_t1', 'c2 = 123')
WITH MAX_CONCURRENCY = 0;

--error 0,11087
select * from ccl_t1 where c2 = 123;
delete from ccl_t1 where c2 = 123;
insert into ccl_t1 values(1, "123");
update ccl_t1 set c2 = 123 where c1 = 1;

#insert
CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS global_emergency_insert_ccl_rule
ON *.*
TO '%'@'%'
FOR insert
FILTER BY KEYWORD('ccl_t1', 'values(1, "123")')
WITH MAX_CONCURRENCY = 0;

--error 0,11087
insert into ccl_t1 values(1, "123");

#delete
CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS global_emergency_delete_ccl_rule
ON *.*
TO '%'@'%'
FOR delete
FILTER BY KEYWORD('ccl_t1', 'c2 = 123')
WITH MAX_CONCURRENCY = 0;

--error 0,11087
delete from ccl_t1 where c2 = 123;

#update
CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS global_emergency_update_ccl_rule
ON *.*
TO '%'@'%'
FOR update
FILTER BY KEYWORD('ccl_t1', 'c2 = 123')
WITH MAX_CONCURRENCY = 0;

--error 0,11087
update ccl_t1 set c2 = 123 where c1 = 1;

DROP CONCURRENT_LIMITING_RULE IF EXISTS global_emergency_select_ccl_rule;
DROP CONCURRENT_LIMITING_RULE IF EXISTS global_emergency_insert_ccl_rule;
DROP CONCURRENT_LIMITING_RULE IF EXISTS global_emergency_delete_ccl_rule;
DROP CONCURRENT_LIMITING_RULE IF EXISTS global_emergency_update_ccl_rule;


#3.databse&table scope
CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS ccl_db_ccl_rule
ON ccl_db.*
TO '%'@'%'
FOR all
WITH MAX_CONCURRENCY = 0;

#dml in ccl_t1 should be limit
--error 0,11087
select * from ccl_t1 where c2 = 123;
--error 0,11087
delete from ccl_t1 where c2 = 123;
--error 0,11087
insert into ccl_t1 values(1, "123");
--error 0,11087
update ccl_t1 set c2 = 123 where c1 = 1;

#dml in ccl_t2 also should be limit
--error 0,11087
select * from ccl_t2 where c2 = 123;
--error 0,11087
delete from ccl_t2 where c2 = 123;
--error 0,11087
insert into ccl_t2 values(1, "123");
--error 0,11087
update ccl_t2 set c2 = 123 where c1 = 1;

DROP CONCURRENT_LIMITING_RULE IF EXISTS ccl_db_ccl_rule;

#focus on ccl_db.ccl_t1
CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS ccl_t1_ccl_rule
ON ccl_db.ccl_t1
TO '%'@'%'
FOR all
WITH MAX_CONCURRENCY = 0;

#dml in ccl_t1 should be limit
--error 0,11087
select * from ccl_t1 where c2 = 123;
--error 0,11087
delete from ccl_t1 where c2 = 123;
--error 0,11087
insert into ccl_t1 values(1, "123");
--error 0,11087
update ccl_t1 set c2 = 123 where c1 = 1;

#dml in ccl_t2 not limit
select * from ccl_t2 where c2 = 123;
delete from ccl_t2 where c2 = 123;
insert into ccl_t2 values(1, "123");
update ccl_t2 set c2 = 123 where c1 = 1;

DROP CONCURRENT_LIMITING_RULE IF EXISTS ccl_t1_ccl_rule;

#different database ccl rule should not works
create database ccl_db1;
use ccl_db1;
create table ccl_t1 (c1 int, c2 varchar(32));
insert into ccl_t1 values(1, "123");
insert into ccl_t1 values(2, "456");
insert into ccl_t1 values(3, "789");

select * from ccl_t1 where c2 = 123;

CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS ccl_db_ccl_rule
ON ccl_db.*
TO '%'@'%'
FOR all
WITH MAX_CONCURRENCY = 0;

select * from ccl_t1 where c2 = 123;

use ccl_db;
--error 0,11087
select * from ccl_t1 where c2 = 123;

drop database ccl_db1;
DROP CONCURRENT_LIMITING_RULE IF EXISTS ccl_db_ccl_rule;

# global rule, different query share the concurrency
SET @@ob_trx_timeout = 10000000000;
SET @@ob_query_timeout = 10000000000;

CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS ccl_t1_ccl_rule
ON ccl_db.ccl_t1
TO '%'@'%'
FOR select
WITH MAX_CONCURRENCY = 1;

send select sleep(3), * from ccl_t1;

connection conn2;
use ccl_db;
--error 0,11087
select * from ccl_t1;

connection conn1;
--error 0,11087
reap;

DROP CONCURRENT_LIMITING_RULE IF EXISTS ccl_t1_ccl_rule;

#4.user scope
drop user if exists user1; 
create user 'user1' identified by '123';
GRANT ALL ON *.* TO user1;
connect (conn3,$OBMYSQL_MS0,user1,123,ccl_db,$OBMYSQL_PORT);

select CURRENT_USER();
CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS global_emergency_ccl_rule
ON *.*
TO 'user1'@'%'
FOR select
WITH MAX_CONCURRENCY = 0;

#'user1' user should be limited
--error 0,11087
select * from ccl_t1;

#but user 'admin' should not be limited
disconnect conn3;
connection conn1;
select * from ccl_t1;

DROP CONCURRENT_LIMITING_RULE IF EXISTS global_emergency_ccl_rule;

drop database ccl_db;

connection conn0;
--enable_result_log
select count(distinct ddl_stmt_str)>0 from __all_virtual_ddl_operation where ddl_stmt_str like '%CONCURRENT_LIMITING_RULE%';
disconnect conn1;
disconnect conn2;
