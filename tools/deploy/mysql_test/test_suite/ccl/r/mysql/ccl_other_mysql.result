result_format: 4
create table ccl_t1 (c1 int, c2 varchar(32));

insert into ccl_t1 values(1, '123');
insert into ccl_t1 values(2, '456');
insert into ccl_t1 values(3, '789');

select * from ccl_t1 where c2 = 123;
+------+------+
| c1   | c2   |
+------+------+
|    1 | 123  |
+------+------+

CREATE CONCURRENT_LIMITING_RULE ccl_t1_rule_cafe
ON test.ccl_t1
TO '%'@'%'
FOR select
WITH MAX_CONCURRENCY = 0;

DROP CONCURRENT_LIMITING_RULE CCL_t1_rule_cafe;

CREATE CONCURRENT_LIMITING_RULE ccl_t1_rule_café
ON test.ccl_t1
TO '%'@'%'
FOR select
WITH MAX_CONCURRENCY = 0;

select ccl_rule_name from oceanbase.DBA_OB_CCL_RULES;
+-------------------+
| ccl_rule_name     |
+-------------------+
| ccl_t1_rule_café  |
+-------------------+

DROP CONCURRENT_LIMITING_RULE ccl_t1_rule_cafe;

CREATE CONCURRENT_LIMITING_RULE ccl_t1_rule_cafe
ON test.CCL_t1
TO '%'@'%'
FOR select
WITH MAX_CONCURRENCY = 0;

select * from ccl_t1;

DROP CONCURRENT_LIMITING_RULE ccl_t1_rule_cafe;

CREATE CONCURRENT_LIMITING_RULE ccl_t1_rule_cafe
ON test.ccl_t1
TO '%'@'%'
FOR select
WITH MAX_CONCURRENCY = 0;

select * from ccl_t1;

rename table ccl_t1 to ccl_t2;

select * from ccl_t2;
+------+------+
| c1   | c2   |
+------+------+
|    1 | 123  |
|    2 | 456  |
|    3 | 789  |
+------+------+

DROP CONCURRENT_LIMITING_RULE ccl_t1_rule_cafe;
drop table ccl_t2;

CREATE CONCURRENT_LIMITING_RULE ccl00 ON *.* TO '%'@'%' FOR insert FILTER BY KEYWORD('') WITH MAX_CONCURRENCY = 0 per sql;
