result_format: 4

drop database if exists ccl_db;
create database ccl_db;
use ccl_db;

create table ccl_t1 (c1 int, c2 varchar(32));

insert into ccl_t1 values(1, "123");
insert into ccl_t1 values(2, "456");
insert into ccl_t1 values(3, "789");

create table ccl_t2 (c1 int, c2 varchar(32));
insert into ccl_t2 values(1, "123");
insert into ccl_t2 values(2, "456");
insert into ccl_t2 values(3, "789");

select * from ccl_t1 where c2 = 123;

CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS global_emergency_ccl_rule
ON *.*
TO '%'@'%'
FOR all
FILTER BY KEYWORD('ccl_t1', 'c2 = 123')
WITH MAX_CONCURRENCY = 0 per sql;

select * from ccl_t1 where c2 = 123;
select * from ccl_t1 where c2 = 124;

DROP CONCURRENT_LIMITING_RULE IF EXISTS global_emergency_ccl_rule;

CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS global_emergency_select_ccl_rule
ON *.*
TO '%'@'%'
FOR select
FILTER BY KEYWORD('ccl_t1', 'c2 = 123')
WITH MAX_CONCURRENCY = 0 per sql;

select * from ccl_t1 where c2 = 123;
delete from ccl_t1 where c2 = 123;
insert into ccl_t1 values(1, "123");
update ccl_t1 set c2 = 123 where c1 = 1;

CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS global_emergency_insert_ccl_rule
ON *.*
TO '%'@'%'
FOR insert
FILTER BY KEYWORD('ccl_t1', 'values(1, "123")')
WITH MAX_CONCURRENCY = 0 per sql;

insert into ccl_t1 values(1, "123");

CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS global_emergency_delete_ccl_rule
ON *.*
TO '%'@'%'
FOR delete
FILTER BY KEYWORD('ccl_t1', 'c2 = 123')
WITH MAX_CONCURRENCY = 0 per sql;

delete from ccl_t1 where c2 = 123;

CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS global_emergency_update_ccl_rule
ON *.*
TO '%'@'%'
FOR update
FILTER BY KEYWORD('ccl_t1', 'c2 = 123')
WITH MAX_CONCURRENCY = 0 per sql;

update ccl_t1 set c2 = 123 where c1 = 1;

DROP CONCURRENT_LIMITING_RULE IF EXISTS global_emergency_select_ccl_rule;
DROP CONCURRENT_LIMITING_RULE IF EXISTS global_emergency_insert_ccl_rule;
DROP CONCURRENT_LIMITING_RULE IF EXISTS global_emergency_delete_ccl_rule;
DROP CONCURRENT_LIMITING_RULE IF EXISTS global_emergency_update_ccl_rule;

CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS ccl_db_ccl_rule
ON ccl_db.*
TO '%'@'%'
FOR all
WITH MAX_CONCURRENCY = 0 per sql;

select * from ccl_t1 where c2 = 123;
delete from ccl_t1 where c2 = 123;
insert into ccl_t1 values(1, "123");
update ccl_t1 set c2 = 123 where c1 = 1;

select * from ccl_t2 where c2 = 123;
delete from ccl_t2 where c2 = 123;
insert into ccl_t2 values(1, "123");
update ccl_t2 set c2 = 123 where c1 = 1;

DROP CONCURRENT_LIMITING_RULE IF EXISTS ccl_db_ccl_rule;

CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS ccl_t1_ccl_rule
ON ccl_db.ccl_t1
TO '%'@'%'
FOR all
WITH MAX_CONCURRENCY = 0 per sql;

select * from ccl_t1 where c2 = 123;
delete from ccl_t1 where c2 = 123;
insert into ccl_t1 values(1, "123");
update ccl_t1 set c2 = 123 where c1 = 1;

select * from ccl_t2 where c2 = 123;
delete from ccl_t2 where c2 = 123;
insert into ccl_t2 values(1, "123");
update ccl_t2 set c2 = 123 where c1 = 1;

DROP CONCURRENT_LIMITING_RULE IF EXISTS ccl_t1_ccl_rule;

create database ccl_db1;
use ccl_db1;
create table ccl_t1 (c1 int, c2 varchar(32));
insert into ccl_t1 values(1, "123");
insert into ccl_t1 values(2, "456");
insert into ccl_t1 values(3, "789");

select * from ccl_t1 where c2 = 123;

CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS ccl_db_ccl_rule
ON ccl_db.*
TO '%'@'%'
FOR all
WITH MAX_CONCURRENCY = 0 per sql;

select * from ccl_t1 where c2 = 123;

use ccl_db;
select * from ccl_t1 where c2 = 123;

drop database ccl_db1;
DROP CONCURRENT_LIMITING_RULE IF EXISTS ccl_db_ccl_rule;

SET @@ob_trx_timeout = 10000000000;
SET @@ob_query_timeout = 10000000000;

CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS ccl_t1_ccl_rule
ON ccl_db.ccl_t1
TO '%'@'%'
FOR select
WITH MAX_CONCURRENCY = 1 per sql;

select sleep(3), * from ccl_t1;

use ccl_db;
select * from ccl_t1;


DROP CONCURRENT_LIMITING_RULE IF EXISTS ccl_t1_ccl_rule;

drop database ccl_db;

