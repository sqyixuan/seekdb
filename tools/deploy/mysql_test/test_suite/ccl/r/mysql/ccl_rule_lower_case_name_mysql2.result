drop database if exists ccl_db;
create database ccl_db;
use ccl_db;
create table ccl_t1 (c1 int, c2 varchar(32));
insert into ccl_t1 values(1, "123");
insert into ccl_t1 values(2, "456");
insert into ccl_t1 values(3, "789");
CREATE CONCURRENT_LIMITING_RULE IF NOT EXISTS ccl_t1_rule
ON ccl_db.CCL_t1
TO '%'@'%'
FOR select
WITH MAX_CONCURRENCY = 0;
select affect_database, affect_table from oceanbase.DBA_OB_CCL_RULES;
affect_database	affect_table
ccl_db	ccl_t1
select * from ccl_t1;
select * from CCL_t1;
DROP CONCURRENT_LIMITING_RULE ccl_t1_rule;
drop table ccl_t1;
drop database ccl_db;
