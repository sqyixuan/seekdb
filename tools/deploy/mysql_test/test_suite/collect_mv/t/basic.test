# owner: yht146439
# owner group: storage
# description: collect mv basic query

--disable_warnings
set session ob_query_timeout=1000000000;
--error 0,9757
drop materialized view basic_mv_1;
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 int primary key, c2 int, c3 varchar(64)) partition by hash(c1) partitions 8;
create table t2(c1 int primary key, c2 int) duplicate_scope = 'cluster' duplicate_read_consistency = 'weak';

CREATE MATERIALIZED VIEW basic_mv_1 (
    PRIMARY KEY (c1)
) partition by hash(c1) partitions 8
refresh fast enable query rewrite enable on query computation
AS
SELECT 
    a.c1 AS c1,
    b.c1 AS b_c1,
    a.c2 AS a_c2,
    b.c2 AS b_c2,
    a.c3 AS a_c3
FROM 
    t1 a join t2 b on a.c1 = b.c1;

--enable_sorted_result

select * from basic_mv_1;
insert into t1 values(1,1,repeat('a',64));
select * from basic_mv_1;
insert into t2 values(0,0);
select * from basic_mv_1;
insert into t2 values(1,1);
select * from basic_mv_1;

insert into t2 values(2,2);
insert into t1 values(2,2,repeat('b',64));
select * from basic_mv_1;

update t1 set c2 = 11,c3 = repeat('ab',32) where c1 = 1;
select * from basic_mv_1;
update t1 set c2 = 111,c3 = repeat('abc',20) where c1 = 1;
select * from basic_mv_1;

insert into t1 values(3,3,repeat('c',64)),(4,4,repeat('d',64)),(5,5,repeat('e',64));
insert into t2 values(3,3),(4,4),(5,5),(6,6);
select * from basic_mv_1;

update t1 set c2 = 444,c3 = repeat('abcd',10) where c1 = 4;
update t2 set c2 = 44 where c1 = 4;
select * from basic_mv_1;

delete from t1 where c1 = 1;
select * from basic_mv_1;
select * from basic_mv_1 where c1 in (1,2,3,4,5,6);
delete from t2 where c2 = 2;
insert into t2 values(22,2);
select * from basic_mv_1;

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

select * from basic_mv_1;
insert into t1 values(1,1,repeat('a',64));
select * from basic_mv_1;
select * from basic_mv_1 where c1 in (1,2,3,4,5,6);

delete from t1 where c1 = 1;
insert into t1 values(33,33,repeat('c',64));
update t2 set c2 = 33 where c1 = 3;
select * from basic_mv_1;

let $scn1 = query_get_value(select last_refresh_scn as mv_scn from oceanbase.__all_virtual_mview where mview_id = (select table_id from oceanbase.__all_virtual_table where table_name = 'basic_mv_1'), mv_scn, 1);
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

let $__i__=240;
while($__i__ > 0)
{
    sleep 1;
    dec $__i__;
    let $scn2=query_get_value(select last_refresh_scn as mv_scn from oceanbase.__all_virtual_mview where mview_id = (select table_id from oceanbase.__all_virtual_table where table_name = 'basic_mv_1'), mv_scn, 1);
    if($scn1 != $scn2)
    {
        let $__i__ = -5;
    }
}
if($__i__ != -5)
{
    --echo wait last refresh scn refresh failed
}

select * from basic_mv_1;
insert into t1 values(11,11,repeat('a',64)),(12,12,repeat('b',64));
insert into t2 values(11,11),(12,12),(13,13);
select * from basic_mv_1;

delete from t1 where c1 in (2,5);
select * from basic_mv_1;
update t1 set c2=1333,c3=repeat('h',64) where c1 = 33;
update t1 set c2 = 1111 where c1 = 11;
select * from basic_mv_1;

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

select * from basic_mv_1;
delete from t2 where 1=1;
select * from basic_mv_1;

alter system minor freeze;
--source mysql_test/include/wait_daily_merge.inc

select * from basic_mv_1;

drop materialized view basic_mv_1;
drop table t1,t2;