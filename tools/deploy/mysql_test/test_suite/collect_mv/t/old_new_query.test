# owner: yht146439
# owner group: storage
# description: incremental query invisible old_new data

--disable_warnings
set session ob_query_timeout=1000000000;
--error 0,9757
drop table if exists old_new_t1;
--enable_warnings

create table old_new_t1(c1 int primary key, c2 int, c3 varchar(64)) partition by hash(c1) partitions 4;

--disable_query_log
--let $count = 1
while($count < 101)
{
  --let $stmt1=insert into old_new_t1(c1,c2,c3) values ($count,$count,concat($count,'abc'));
  eval $stmt1;
  inc $count;
}
--enable_sorted_result


--enable_query_log
select ora_rowscn into @r1_scn from old_new_t1 where c1 = 55;
update old_new_t1 set c2 = c2 + 100 where c1 = 55;
