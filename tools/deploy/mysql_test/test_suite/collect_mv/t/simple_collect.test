select/*+no_mv_rewrite*/ count(*) from collect_mv as of snapshot @scn3;
select/*+no_mv_rewrite*/ count(*) from collect_info as of snapshot @scn3 a join collect_item as of snapshot @scn3 b on a.item_type = b.item_type and a.item_id = b.item_id;

