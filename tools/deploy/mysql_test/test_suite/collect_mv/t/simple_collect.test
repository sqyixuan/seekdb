{
    sleep 1;
    dec $__i__;
    let $scn2=query_get_value(select last_refresh_scn as mv_scn from oceanbase.__all_virtual_mview where mview_id = (select table_id from oceanbase.__all_virtual_table where table_name = 'collect_mv'), mv_scn, 1);
    if($scn1 != $scn2)
    {
        let $__i__ = -5;
    }
}
