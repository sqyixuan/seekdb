set session ob_query_timeout=1000000000;
drop materialized view basic_nlj_mv_1;
drop table if exists t1,t2;
CREATE TABLE `t1` (
`c1` int(11) NOT NULL,
`c2` int(11) NOT NULL,
PRIMARY KEY (`c1`, `c2`)
) partition by hash(c1) partitions 1;
CREATE TABLE `t2` (
`c2` int(11) NOT NULL,
`c3` int(11) DEFAULT NULL,
PRIMARY KEY (`c2`)
) DUPLICATE_SCOPE = 'CLUSTER' DUPLICATE_READ_CONSISTENCY = 'WEAK';
CREATE MATERIALIZED VIEW basic_nlj_mv_1(c1,c2,t2_c2,t2_c3, primary key(c1,c2))
partition by hash(c1) partitions 1
refresh fast enable query rewrite enable on query computation
AS
select /*+LEADING(t1) USE_NL(t2) USE_DAS(t2) NO_USE_NL_MATERIALIZATION(t2) */ t1.c1 as c1, t1.c2 as c2, t2.c2 as t2_c2, t2.c3 as t2_c3 from t1 join t2 on t1.c2 = t2.c2;
SET query_rewrite_enabled = 'force';
alter system set _hash_join_enabled = false;
alter system set _optimizer_sortmerge_join_enabled=false;
alter system flush plan cache;
select * from basic_nlj_mv_1;
