set session ob_query_timeout=1000000000;
drop materialized view collect_mv;
drop table if exists collect_info,collect_item;
CREATE TABLE `collect_info` (
`user_id` bigint(20) NOT NULL COMMENT '用户ID',
`item_type` bigint(20) NOT NULL DEFAULT '1' COMMENT '收藏类型。0:店铺、1：宝贝、3：内容',
`item_id` varchar(256) COLLATE utf8mb4_bin NOT NULL COMMENT '宝贝id内容id店铺id',
`delete_time` timestamp(6) NULL DEFAULT NULL COMMENT '删除时间',
`info_status` bigint(20) DEFAULT NULL COMMENT '是否删除',
`info_collect_time` timestamp(6) NULL DEFAULT NULL COMMENT '收藏时间',
`info_gm_create` timestamp(6) NULL DEFAULT NULL COMMENT '创建时间',
`info_gm_modified` timestamp(6) NULL DEFAULT NULL COMMENT '修改时间',
`info_from` varchar(256) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '添加来源',
`info_top_flag` bigint(20) DEFAULT NULL COMMENT '是否置顶',
`info_is_hate` bigint(20) DEFAULT NULL COMMENT '是否讨厌',
`info_is_share` bigint(20) DEFAULT NULL COMMENT '是否分享',
`buy_time` timestamp(6) NULL DEFAULT NULL COMMENT '最后一次确认收货时间',
PRIMARY KEY (`user_id`, `item_type`, `item_id`)
) partition by hash(user_id) partitions 2;
CREATE TABLE `collect_item` (
`item_type` bigint(20) NOT NULL DEFAULT '1' COMMENT '收藏类型。0:店铺、1：宝贝、3：内容',
`item_id` varchar(256) COLLATE utf8mb4_bin NOT NULL COMMENT '宝贝id内容id店铺id',
`item_invalid` bigint(20) DEFAULT NULL COMMENT '宝贝是否有效',
`item_title` varchar(1024) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '标题',
`item_picurl` varchar(1024) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '图片地址',
`item_price` bigint(20) DEFAULT NULL COMMENT '宝贝价格',
`item_status` bigint(20) DEFAULT NULL COMMENT '状态',
`item_collector_count` bigint(20) DEFAULT '0' COMMENT '喜欢人数',
`item_collect_count` bigint(20) DEFAULT '0' COMMENT '收藏人气',
`item_gm_create` timestamp(6) NULL DEFAULT NULL COMMENT '创建时间',
PRIMARY KEY (`item_type`, `item_id`)
) DUPLICATE_SCOPE = 'CLUSTER' DUPLICATE_READ_CONSISTENCY = 'WEAK';
CREATE MATERIALIZED VIEW `collect_mv` (PRIMARY KEY (user_id, item_type, item_id))
partition by hash(user_id) partitions 2
REFRESH FAST ON DEMAND ENABLE QUERY REWRITE ENABLE ON QUERY COMPUTATION  AS
select /*+ READ_CONSISTENCY( WEAK ) LEADING(("a" "b")) NO_REWRITE USE_NL("a") USE_NL("b") USE_DAS("b") NO_USE_NL_MATERIALIZATION("b") */
`a`.`user_id` AS `user_id`,`a`.`item_type` AS `item_type`,`a`.`item_id` AS `item_id`,`a`.`delete_time` AS `delete_time`,`a`.`info_status` AS `info_status`,
`a`.`info_collect_time` AS `info_collect_time`,`a`.`info_gm_create` AS `info_gm_create`,`a`.`info_gm_modified` AS `info_gm_modified`,`a`.`info_from` AS `info_from`,
`a`.`info_top_flag` AS `info_top_flag`,`a`.`info_is_hate` AS `info_is_hate`,`a`.`info_is_share` AS `info_is_share`,`a`.`buy_time` AS `buy_time`,
`b`.`item_type` AS `b_item_type`,`b`.`item_id` AS `b_item_id`,`b`.`item_invalid` AS `item_invalid`,`b`.`item_title` AS `item_title`,`b`.`item_picurl` AS `item_picurl`,
`b`.`item_price` AS `item_price`,`b`.`item_status` AS `item_status`,`b`.`item_collector_count` AS `item_collector_count`,`b`.`item_collect_count` AS `item_collect_count`,
`b`.`item_gm_create` AS `item_gm_create`
from (`test`.`collect_info` `a` join `test`.`collect_item` `b` on (`a`.`item_type` = `b`.`item_type`) and (`a`.`item_id` = `b`.`item_id`));
SET query_rewrite_enabled = 'force';
select * from collect_mv;
