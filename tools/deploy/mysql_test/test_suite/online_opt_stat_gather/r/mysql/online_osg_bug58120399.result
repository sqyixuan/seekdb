drop table if exists t1;
drop table if exists t2;
drop procedure if exists batch_insert;
create table t1 (c1 bigint primary key, c2 varchar(256), c3 varchar(256), c4 datetime, c5 datetime) WITH COLUMN GROUP (each column);
create table t2 (c1 bigint primary key, c2 varchar(256), c3 varchar(256), c4 datetime, c5 datetime) WITH COLUMN GROUP (each column);
create procedure batch_insert(in args int)
begin
declare i int;
set i = 0;
start transaction;
while i < args do
insert into t1(c1,c2,c3,c4,c5) values(i, concat('C2_MKKHJHHS_XXXSDSDSDDSDSSJJJJDSHH_', i), concat('C3_MKKHJHHS_XXXMMMMMMJJJDSHH_', i), '2023-01-01 01:11:11', '2023-01-01 01:11:11');
set i = i+1;
if i % 10000 = 0 then
commit;
end if;
end while;
commit;
end $$
call batch_insert(100000);
call dbms_stats.set_global_prefs('ONLINE_ESTIMATE_PERCENT', '1');
call dbms_stats.set_table_prefs('TEST', 'T2', 'ONLINE_ESTIMATE_PERCENT', '100');
insert /*+ query_timeout(100000000) append parallel(2) enable_parallel_dml */ into t2 select c1, c2, c3, c4, c5 from t1;
result_format: 4
select TABLE_NAME,NUM_ROWS,SAMPLE_SIZE from oceanbase.DBA_TAB_STATISTICS where table_name in ('t2') order by table_name;
+------------+----------+-------------+
| TABLE_NAME | NUM_ROWS | SAMPLE_SIZE |
+------------+----------+-------------+
| t2         |   100000 |      100000 |
+------------+----------+-------------+
select TABLE_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,HIGH_VALUE from oceanbase.DBA_TAB_COL_STATISTICS where table_name in ('t2') order by table_name, column_name;
+------------+-------------+--------------+----------------------------------------+--------------------------------------------+
| TABLE_NAME | COLUMN_NAME | NUM_DISTINCT | LOW_VALUE                              | HIGH_VALUE                                 |
+------------+-------------+--------------+----------------------------------------+--------------------------------------------+
| t2         | c1          |        97060 | 0                                      | 99999                                      |
| t2         | c2          |        97346 | 'C2_MKKHJHHS_XXXSDSDSDDSDSSJJJJDSHH_0' | 'C2_MKKHJHHS_XXXSDSDSDDSDSSJJJJDSHH_99999' |
| t2         | c3          |       100352 | 'C3_MKKHJHHS_XXXMMMMMMJJJDSHH_0'       | 'C3_MKKHJHHS_XXXMMMMMMJJJDSHH_99999'       |
| t2         | c4          |            1 | '2023-01-01 01:11:11'                  | '2023-01-01 01:11:11'                      |
| t2         | c5          |            1 | '2023-01-01 01:11:11'                  | '2023-01-01 01:11:11'                      |
+------------+-------------+--------------+----------------------------------------+--------------------------------------------+
drop table if exists t1;
drop table if exists t2;
