drop table if exists t1;
create table t1 (c1 bigint primary key, c2 bigint, c3 bigint);
set @num = 0;
insert into t1 select @num := @num + 1, @num, case when @num % 5 = 0 then null else @num end from table(generator(1000));
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'FOR ALL COLUMNS SIZE 128');
delete from t1;
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'FOR COLUMNS c1 SIZE 1 c2 SIZE 1');
select OWNER, TABLE_NAME, NUM_ROWS from oceanbase.DBA_TAB_STATISTICS where owner = 'TEST' and table_name = 'T1';
OWNER	TABLE_NAME	NUM_ROWS
test	t1	0
select OWNER, TABLE_NAME, COLUMN_NAME, NUM_DISTINCT, NUM_NULLS,AVG_COL_LEN  from oceanbase.DBA_TAB_COL_STATISTICS where owner = 'TEST' and table_name = 'T1' order by 1,2,3;
OWNER	TABLE_NAME	COLUMN_NAME	NUM_DISTINCT	NUM_NULLS	AVG_COL_LEN
test	t1	c1	0	0	0
test	t1	c2	0	0	0
test	t1	c3	790	200	16
insert /*+ GATHER_OPTIMIZER_STATISTICS */ into t1 select @num := @num + 1, @num, case when @num % 5 = 0 then null else @num end from table(generator(10));
select OWNER, TABLE_NAME, NUM_ROWS from oceanbase.DBA_TAB_STATISTICS where owner = 'TEST' and table_name = 'T1';
OWNER	TABLE_NAME	NUM_ROWS
test	t1	10
select OWNER, TABLE_NAME, COLUMN_NAME, NUM_DISTINCT, NUM_NULLS,AVG_COL_LEN  from oceanbase.DBA_TAB_COL_STATISTICS where owner = 'TEST' and table_name = 'T1' order by 1,2,3;
OWNER	TABLE_NAME	COLUMN_NAME	NUM_DISTINCT	NUM_NULLS	AVG_COL_LEN
test	t1	c1	10	0	20
test	t1	c2	10	0	20
test	t1	c3	806	2	18
drop table if exists t1;
