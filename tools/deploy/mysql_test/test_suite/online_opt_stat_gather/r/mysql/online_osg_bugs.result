COLUMN_NAME	NUM_DISTINCT	NUM_NULLS
c1	1	1
drop table t100;
##bug:issue/48383438
drop table t1;
drop table t2;
set names Latin1;
create table t1(
c1 char(10),
c2 varchar(255),
c3 tinyblob,
c4 tinytext,
c5 blob,
c6 text,
c7 mediumblob,
c8 mediumtext,
c9 longblob,
c10 longtext
) charset = latin1;
insert into t1() values('富强','民主','文明','和谐','自由','平等','公正','法治','爱国','敬业');
select * from t1;
c1	c2	c3	c4	c5	c6	c7	c8	c9	c10
富强	民主	文明	和谐	自由	平等	公正	法治	爱国	敬业
create table t2 as select c1,c2,c3,c4,c5,c6,c7,c8,c9,c10 from t1;
select * from t2;
c1	c2	c3	c4	c5	c6	c7	c8	c9	c10
富强	民主	文明	和谐	自由	平等	公正	法治	爱国	敬业
