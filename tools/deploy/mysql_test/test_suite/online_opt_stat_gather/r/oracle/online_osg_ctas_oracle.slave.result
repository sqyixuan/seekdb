drop table t1;
drop table t2;
drop table t3;
drop table t4;
drop table t5;
drop table t5_2;
drop table t6;
drop table tt;
drop view tab_stat_view;
drop view col_stat_view;
drop view col_part_stat_view;
drop view col_subpart_stat_view;
create view tab_stat_view as select OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, NUM_ROWS, AVG_ROW_LEN, OBJECT_TYPE from ALL_TAB_STATISTICS where owner = 'TEST' order by PARTITION_NAME;
create view col_stat_view as select OWNER, TABLE_NAME, COLUMN_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, NUM_NULLS, AVG_COL_LEN from ALL_tab_col_statistics where owner = 'TEST' ORDER BY COLUMN_NAME;
create view col_part_stat_view as select OWNER, TABLE_NAME, COLUMN_NAME, PARTITION_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, NUM_NULLS, AVG_COL_LEN from ALL_PART_COL_STATISTICS where owner = 'TEST' ORDER BY COLUMN_NAME, PARTITION_NAME;
create view col_subpart_stat_view as select OWNER, TABLE_NAME, COLUMN_NAME, SUBPARTITION_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, NUM_NULLS, AVG_COL_LEN from ALL_SUBPART_COL_STATISTICS where owner = 'TEST' ORDER BY COLUMN_NAME, SUBPARTITION_NAME;
create table t1(c1 int);
create table t2 (c1 int) partition by hash(c1) partitions 4;
create table t3(c1 int, c2 int) partition by range(c1) subpartition by hash(c2) (partition p0 values less than(5000) (subpartition sp0, subpartition sp1), partition p1 values less than (MAXVALUE) (subpartition sp2, subpartition sp3));
create table t4(c1 varchar(100), c2 varchar(100));
create table t5(c1 int, c2 float, c3 binary_double, c4 number, c5 decimal, c6 timestamp, c7 date, c8 char(50), c9 varchar(10), c10 raw(10), c11 blob, c12 clob);
create table t5_2(c1 int, c2 float, c3 binary_double, c4 number, c5 decimal, c6 timestamp, c7 date, c8 char(50), c9 varchar(10), c10 raw(10), c11 clob);
create table t6(c1 int, c2 float, c3 timestamp, c4 varchar(10));
insert into t1 select level from dual connect by level<=10000;
insert into t2 select level from dual connect by level<=10000;
insert into t3 select level, level + 10000 from dual connect by level<=10000;
insert into t4 values ('a','a'), ('b', 'b'), ('c','c');
insert into t5 values (1,1,1,1,1,'1970-01-01 08:59:59', '1970-01-01 08:59:59', 'a', 'a', 'a', 'a', 'a');
insert into t5_2 values (1,1,1,1,1,'1970-01-01 08:59:59', '1970-01-01 08:59:59', 'a', 'a', 'a', 'a');
insert into t5_2 values (2,2,2,2,2,'1980-01-01 08:59:59', '1980-01-01 08:59:59', 'b', 'b', 'b', 'b');
insert into t5_2 values (3,3,3,3,3,'1990-01-01 08:59:59', '1990-01-01 08:59:59', 'c', 'c', 'c', 'c');
insert into t5_2 values (4,4,4,4,4,'2000-01-01 08:59:59', '2000-01-01 08:59:59', 'd', 'd', 'd', 'd');
insert into t5_2 values (5,5,5,5,5,'2010-01-01 08:59:59', '2010-01-01 08:59:59', 'e', 'e', 'e', 'e');
begin
FOR i IN 1..1000 LOOP 
insert into t6 values (i,i,'2020-01-01 01:00:00', 'e');
END LOOP;
end//
