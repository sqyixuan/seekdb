CREATE TABLE t0(c0 INT  NULL, c1 BINARY_FLOAT , c2 NUMBER(10,4)  NULL UNIQUE , c3 VARCHAR2(100)  NULL, c4 INT  )  DUPLICATE_SCOPE = 'CLUSTER';
CREATE TABLE t1 as select * from T0;
explain INSERT /*+GATHER_OPTIMIZER_STATISTICS */ INTO T1(C0) select C0 from (select C0, rownum rn from T0 where rownum < 2+1) where rn >= 0;
Query Plan
=========================================================================
|ID|OPERATOR                      |NAME           |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------------
|0 |OPTIMIZER STATS MERGE         |               |1       |17          |
|1 |└─PX COORDINATOR              |               |1       |16          |
|2 |  └─EXCHANGE OUT DISTR        |:EX10000       |1       |16          |
|3 |    └─INSERT                  |               |1       |16          |
|4 |      └─OPTIMIZER STATS GATHER|               |1       |3           |
|5 |        └─SUBPLAN SCAN        |ANONYMOUS_VIEW2|1       |3           |
|6 |          └─TABLE FULL SCAN   |T0             |1       |3           |
=========================================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil), rowset=16
  1 - output([column_conv(NUMBER,PS:(-1,0),NULL,ANONYMOUS_VIEW2.C0)]), filter(nil), rowset=16
  2 - output([column_conv(NUMBER,PS:(-1,0),NULL,ANONYMOUS_VIEW2.C0)]), filter(nil), rowset=16
      is_single, dop=1
  3 - output([column_conv(NUMBER,PS:(-1,0),NULL,ANONYMOUS_VIEW2.C0)]), filter(nil)
      columns([{T1: ({T1: (T1.__pk_increment, T1.C0, T1.C1, T1.C2, T1.C3, T1.C4)})}]), partitions(p0), 
      column_values([T_HIDDEN_PK], [column_conv(NUMBER,PS:(-1,0),NULL,ANONYMOUS_VIEW2.C0)], [column_conv(BINARY_FLOAT,PS:(-1,-85),NULL,cast(NULL, BINARY_FLOAT(-1,
       -85)))], [column_conv(DECIMAL_INT,PS:(10,4),NULL,cast(NULL, DECIMAL_INT(10, 4)))], [column_conv(VARCHAR2,utf8mb4_bin,length:100,NULL,cast(NULL, VARCHAR2(1048576 
      )))], [column_conv(NUMBER,PS:(-1,0),NULL,cast(NULL, NUMBER(-1, 0)))])
  4 - output([column_conv(NUMBER,PS:(-1,0),NULL,ANONYMOUS_VIEW2.C0)]), filter(nil), rowset=16
  5 - output([ANONYMOUS_VIEW2.C0]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW2.C0])
  6 - output([T0.C0]), filter(nil), rowset=16
      access([T0.C0]), partitions(p0)
      limit(cast(cast(cast(CEIL(cast(2 + 1, NUMBER(-1, -85))) - cast(1, NUMBER(-1, -85)), BIGINT(-1, 0)), NUMBER(-1, -85)) - cast(0, NUMBER(-1, -85)), BIGINT(-1,
       0))), offset(0), is_index_back=false, is_global_index=false, 
      range_key([T0.__pk_increment]), range(MIN ; MAX)always true
DROP TABLE T0;
DROP TABLE T1;
