# tags: dbms_stats, optimizer, opt_stats

--echo ## 
--disable_warnings
drop table if exists t100;
--enable_warnings

create table t100(c1 double(23,0) zerofill);
insert into t100 values(null),(1000);
CALL dbms_stats.gather_table_stats(NULL,'t100');
select COLUMN_NAME, NUM_DISTINCT, NUM_NULLS from oceanbase.dba_tab_col_statistics where table_name='t100';
INSERT /*+parallel(3) enable_parallel_dml GATHER_OPTIMIZER_STATISTICS */ INTO t100 select * from t100 where c1 is not null limit 1;
select COLUMN_NAME, NUM_DISTINCT, NUM_NULLS from oceanbase.dba_tab_col_statistics where table_name='t100';
drop table t100;


--echo ##bug:issue/48383438

--error 0,942,1051
drop table t1;
--error 0,942,1051
drop table t2;

set names Latin1;

create table t1(
c1 char(10),
c2 varchar(255),
c3 tinyblob,
c4 tinytext,
c5 blob,
c6 text,
c7 mediumblob,
c8 mediumtext,
c9 longblob,
c10 longtext
) charset = latin1;
insert into t1() values('富强','民主','文明','和谐','自由','平等','公正','法治','爱国','敬业');
select * from t1;
create table t2 as select c1,c2,c3,c4,c5,c6,c7,c8,c9,c10 from t1;
select * from t2;

--echo issue: 
--disable_warnings
drop table if exists test2,test1;
--enable_warnings
set ob_query_timeout=6000000000;

CREATE TABLE test2(c9 DOUBLE NOT NULL,
                  c35 DOUBLE NOT NULL,
                  c75 BINARY(234) NOT NULL)
             partition BY KEY(c35)
             subpartition BY KEY(c9)
             subpartitions 47 partitions 29;
insert into test2 values(1.0,2.0,1);

CREATE TABLE test1(c9 DOUBLE NOT NULL,
                  c35 DOUBLE NOT NULL,
                  c75 BINARY(234) NOT NULL)
             partition BY KEY(c35)
             subpartition BY KEY(c9)
             subpartitions 47 partitions 29;
--explain_protocol 2
insert /*+ append enable_parallel_dml parallel(auto) query_timeout(360000000000)*/ into test1 select * from test2;
--explain_protocol 0

set ob_query_timeout=10000000;
--disable_warnings
drop table if exists test2,test1;
--enable_warnings
