--disable_warnings
drop database  IF EXISTS  ob100x;
--enable_warnings
create database ob100x  character set utf16;
use ob100x;
select database();

DROP TABLE IF exists   EMPEMP;
create TABLE EMPEMP(empno   int,ename   VARCHAR(100));
INSERT INTO EMPEMP VALUES(1,'SMITH01');
INSERT INTO EMPEMP VALUES(2,'SMITH02');
INSERT INTO EMPEMP VALUES(3,'SMITH03');
INSERT INTO EMPEMP VALUES(4,'SMITH04');
 
--echo      名称-1-1-1       表名字以普通小写字母开头   
DROP TABLE IF exists   EMP;
create TABLE emp(empno   INTEGER);
create or replace view  empdetail_view   as    select   *    from   empemp;
select   *   from   empemp   emp;




--echo      名称-1-1-2       表名字以普通大写字母开头   

DROP TABLE IF exists   EMP;
create TABLE EMP(empno   INTEGER);
CREATE OR REPLACE VIEW  EMPDETAIL_VIEW   AS    SELECT   *    FROM   EMPEMP;
SELECT   *   FROM   EMPEMP    EMP   order  by   empno;



