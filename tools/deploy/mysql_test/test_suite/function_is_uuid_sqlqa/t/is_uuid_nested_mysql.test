--echo     #function-4-5   流程控制函数
SELECT case IS_UUID('6ccd780c-baba-1026-9564-5b8c656024db') when IS_UUID('6ccd780cbaba102695645b8c656024db') then 1 when 2 then 2 end;
SELECT case IS_UUID('15746554-baba-1026-9564-451245174515') when IS_UUID('6ccd780cbaba102695645b8c656024db') then 1 when 2 then 2 end;
SELECT case IS_UUID('15746554-baba-1026-9564-451245174515') when IS_UUID('15641254125241035441354135415405') then 1 when 2 then 2 end;
SELECT case when IS_UUID('15641254125241035441354135415405') >0 then 99 else 66 end;
SELECT case when IS_UUID('15641254125241035441354135415405') <0 then 99 else 66 end;
SELECT case when IS_UUID('15641254125241035441354135415405') =0 then 99 else 66 end;
SELECT case when IS_UUID('54107412065') !=0 then 99 else 66 end;
SELECT case when IS_UUID(54107412065) !=0 then 99 else 66 end;
SELECT if(IS_UUID('15641254125241035441354135415405') >0 ,88,33);
SELECT if(IS_UUID('15641254125241035441354135415405') <0 ,88,33);
SELECT if(IS_UUID(uuid()) <0 ,88,33);
SELECT if(IS_UUID(uuid()) >0 ,88,33);
SELECT if(IS_UUID(uuid()) !=0 ,88,33);
SELECT if(IS_UUID('6ccd780c-baba-1026-9564-5b8c656024db') >0 ,88,33);
SELECT if(IS_UUID('6ccd780c-baba-1026-9564-5b8c656024db') <null ,88,33);
SELECT if(IS_UUID('6ccd780c-baba-1026-9564-5b8c656024db') >null ,88,33);
SELECT if(IS_UUID('null') >null ,88,33);
SELECT if(IS_UUID(null) =null ,88,33);
--error 0,1582
SELECT ifnull(IS_UUID('15641254125241035441354135415405') >0 ,88,33);
SELECT ifnull(IS_UUID('15641254125241035441354135415405'),null);
SELECT ifnull(IS_UUID('15641254125241035441354135415405'),'null');
SELECT ifnull(IS_UUID(15641254125241035441354135415405),'null');
SELECT ifnull(IS_UUID(15641254125241035441354135415405),null);
SELECT ifnull(IS_UUID('null'),null);
SELECT ifnull(IS_UUID(null),null);
--echo     #function-4-5   json函数
select is_uuid(JSON_ARRAY()) from dual;
select is_uuid(JSON_ARRAY_APPEND(@j, '$.b', 'x')) from dual;
select is_uuid(JSON_ARRAY_INSERT(@j, '$[1]', 'x')) from dual;
select is_uuid(JSON_CONTAINS(@j, @j2, '$.a')) from dual;
SET @j = '{"a": 1, "b": 2, "c": {"d": 4}}';
select is_uuid(JSON_CONTAINS_PATH(@j, 'one', '$.a', '$.e')) from dual;
select is_uuid(JSON_DEPTH('{}')) from dual;
select is_uuid(JSON_EXTRACT('1', "$.id")) from dual;
SET @j = '{ "a": 1, "b": [2, 3]}';
select is_uuid(JSON_INSERT(@j, '$.a', 10, '$.c', '[true, false]')) from dual;
select is_uuid(JSON_KEYS('{"a": 1, "b": {"c": 30}}')) from dual;
select is_uuid(JSON_LENGTH('[1, 2, {"a": 3}]')) from dual;
select is_uuid(JSON_MERGE('[1, 2]', '[true, false]', '{"a":100}')) from dual;
select is_uuid(JSON_MERGE_PATCH('[1, 2]', '[true, false]')) from dual;
select is_uuid(JSON_MERGE_PRESERVE('[1, 2]', '[true, false]')) from dual;
select is_uuid(JSON_OBJECT('id', 87, 'name', 'carrot')) from dual;
select is_uuid(JSON_OVERLAPS("[1,3,5,7]", "[2,6,8]")) from dual;
select is_uuid(JSON_PRETTY('{"a":"10","b":"15","x":"25"}')) from dual;
select is_uuid(JSON_QUOTE('{"name":sam, "scores":[100,200,300]}')) from dual;
SET @j = '["a", ["b", "c"], "d"]';
select is_uuid(JSON_REMOVE(@j, '$[8]')) from dual;
SET @j = '{ "a": 1, "b": [2, 3]}';
select is_uuid(JSON_REPLACE(@j, '$.a', 10, '$.c', '[true, false]')) from dual;
SET @j = '["abc", [{"k": "10"}, "def"], {"x":"abc"}, {"y":"bcd"}]';
select is_uuid(JSON_SEARCH(@j, 'all', '10', NULL, '$[*]')) from dual;
SET @j = '{ "a": 1, "b": [2, 3]}';
select is_uuid(JSON_SET(@j, '$.a', 10, '$.c', '[true, false]')) from dual;
SET @j = '[100, "sakila", [1, 3, 5], 425.05]';
select is_uuid(JSON_STORAGE_SIZE(@j)) from dual;
SET @j = '{"a": [10, true]}';
select is_uuid(JSON_TYPE(@j)) from dual;
SET @j = '"abc"';
select is_uuid(JSON_UNQUOTE(@j)) from dual;
select is_uuid(JSON_VALID('{"a": 1}')) from dual;
select is_uuid(JSON_VALUE('{"fname": "Joe", "lname": "Palmer"}', '$.fname')) from dual;
select is_uuid(JSON_ARRAYAGG('["color", "fabric", "color", "fabric"]')) from dual;
--error 0,1064
select is_uuid(JSON_OBJECTAGG('{"key": 4}')) from dual;
