CREATE FUNCTION function_1() RETURNS int
BEGIN
DECLARE i int DEFAULT 1;
loop1:LOOP
IF i<10 THEN
UPDATE test1 SET h1=h1+is_uuid('6ccd780c-baba-1026-9564-5b8c656024db')-is_uuid('-0120..24512443212421.21324213');
LEAVE loop1;
END IF;
SET i = i+6;
END LOOP;
RETURN i;
END;
/
