drop table test1;
drop procedure procedure_1;
create procedure procedure_1(aa int,bb int)
begin
if aa = bb then
select is_uuid('6ccd780c-baba-1026-9564-5b8c656024db');
elseif aa > bb then
select is_uuid('-0120..24512443212421.21324213');
else
select is_uuid('6ccd780c-baba-1026-9564-5b8c656024db')*2+is_uuid('-0120..24512443212421.21324213');
end if;
end;
/
