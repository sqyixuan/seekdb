CREATE FUNCTION FUNCTION_1() RETURNS int
BEGIN
DECLARE v1 decimal(20,1) DEFAULT 1;
WHILE v1<30 DO
UPDATE test1 SET h1=is_uuid('6ccd780c-baba-1026-9564-5b8c656024db')+9;
SET v1=v1+5;
END WHILE;
RETURN v1;
END;
/
