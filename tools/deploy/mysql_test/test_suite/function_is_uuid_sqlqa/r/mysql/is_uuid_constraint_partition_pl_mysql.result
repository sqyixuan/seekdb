FOR EACH ROW
BEGIN
insert into test2 values(is_uuid('6ccd780c-baba-1026-9564-5b8c656024db'),is_uuid('-0120..24512443212421.21324213'),is_uuid('-0120..24512443212421.21324213')*is_uuid('6ccd780c-baba-1026-9564-5b8c656024db')+is_uuid('6ccd780c-baba-1026-9564-5b8c656024db'));
END
