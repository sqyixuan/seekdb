索引
drop table t1;
CREATE TABLE t1 (
c1 INT PRIMARY KEY,
c2 varchar(30) NOT null,
c3 char(30) DEFAULT 3.14159,
c4 char(10)
)
PARTITION BY RANGE COLUMNS(c1) (
PARTITION p1 VALUES LESS THAN (10),
PARTITION p2 VALUES LESS THAN (20),
PARTITION p3 VALUES LESS THAN (30)
);
insert into t1(c1,c2,c3,c4) values(1,1,1,1),(12,12,12,12),(23,23,23,23),(4,4,4,4);
drop table t2;
CREATE TABLE t2 (
c1 INT PRIMARY KEY,
c2 varchar(30) NOT null,
c3 char(30) DEFAULT 3.14159,
c4 char(10)
);
insert into t2(c1,c2,c3,c4) values(2,2,2,2),(13,13,13,13),(24,24,24,24),(5,5,5,5);
