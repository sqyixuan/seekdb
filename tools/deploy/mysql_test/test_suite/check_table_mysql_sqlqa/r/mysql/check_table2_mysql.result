desc my_table;
Field	Type	Null	Key	Default	Extra
id	int(11)	NO	PRI	NULL	auto_increment
new_name	varchar(100)	YES		NULL	
c3	char(30)	YES		3.14159	
CHECK TABLE my_table,my_table1,my_table2;
