复制视图
DROP TABLE t1;
CREATE TABLE t1(num INT,food char(20),price varchar(200));
INSERT INTO t1 VALUES(1,'面包',-5.12315);
INSERT INTO t1 VALUES(2,'牛奶','');
INSERT INTO t1 VALUES(3,'大面包',-0.13545);
INSERT INTO t1 VALUES(4,'奶牛奶',-1200);
drop view v1;
CREATE VIEW v1 AS SELECT * FROM t1 WHERE num > 2 ;
drop view v2;
CREATE VIEW v2 AS SELECT * FROM v1;
CHECK TABLE v2,v1;
Table	Op	Msg_type	Msg_text
test.v2	check	status	OK
test.v1	check	status	OK
