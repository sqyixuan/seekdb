联合多表的视图
DROP TABLE t3;
CREATE TABLE t3 (
id INT,
created_at DATE
)
PARTITION BY RANGE (YEAR(created_at)) (
PARTITION p0 VALUES LESS THAN (2020),
PARTITION p1 VALUES LESS THAN (2021),
PARTITION p2 VALUES LESS THAN (2022)
);
INSERT INTO t3 (id, created_at) VALUES (1, '2019-01-01');
INSERT INTO t3 (id, created_at) VALUES (2, '2020-01-01');
INSERT INTO t3 (id, created_at) VALUES (3, '2021-01-01');
drop view v2;
CREATE VIEW v2 AS SELECT t1.num, SUM(t1.price) AS a, t3.id FROM t1 JOIN t3 ON t1.num = t3.id GROUP BY t1.num;
CHECK TABLE v2,v1;
Table	Op	Msg_type	Msg_text
test.v2	check	status	OK
test.v1	check	status	OK
ALTER TABLE t1 DROP COLUMN food;
