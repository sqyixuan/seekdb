CHECK TABLE t4  FAST;
CHECK TABLE t4  MEDIUM;
CHECK TABLE t4  EXTENDED;
CHECK TABLE t4  CHANGED;
CHECK TABLE t4  FAST QUICK MEDIUM;
CHECK TABLE t4  FOR UPGRADE FAST QUICK MEDIUM EXTENDED CHANGED;
