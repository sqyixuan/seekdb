--echo 二级分区
--error 0,1051
DROP TABLE t9;
CREATE TABLE t9 (
    c1 INT ,
    c2 INT NOT null,
    c3 char(30) DEFAULT 3.14159,
	c4 char(10)
)
PARTITION BY RANGE(c1)
	SUBPARTITION BY RANGE COLUMNS(c2)
       SUBPARTITION TEMPLATE 
        (SUBPARTITION mp0 VALUES LESS THAN(10),
         SUBPARTITION mp1 VALUES LESS THAN(20),
         SUBPARTITION mp2 VALUES LESS THAN(30)
        )(
    PARTITION p1 VALUES LESS THAN (10),
    PARTITION p2 VALUES LESS THAN (20),
    PARTITION p3 VALUES LESS THAN (30)
);
 
insert into t9(c1,c2,c3,c4) values(1,1,1,1),(12,12,12,12),(23,23,23,23),(4,4,4,4);

