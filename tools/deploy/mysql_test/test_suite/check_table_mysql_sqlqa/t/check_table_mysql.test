--echo 分区表
--echo range 分区
--error 0,1051
DROP TABLE t3;
CREATE TABLE t3 (
    id INT,
    created_at DATE
)
PARTITION BY RANGE (YEAR(created_at)) (
    PARTITION p0 VALUES LESS THAN (2020),
    PARTITION p1 VALUES LESS THAN (2021),
    PARTITION p2 VALUES LESS THAN (2022)
);

INSERT INTO t3 (id, created_at) VALUES (1, '2019-01-01');
INSERT INTO t3 (id, created_at) VALUES (2, '2020-01-01');
INSERT INTO t3 (id, created_at) VALUES (3, '2021-01-01');

CHECK TABLE t3;
CHECK TABLE t3  FOR UPGRADE;
CHECK TABLE t3  QUICK;
CHECK TABLE t3  FAST;
CHECK TABLE t3  MEDIUM;
CHECK TABLE t3  EXTENDED;
CHECK TABLE t3  CHANGED;
CHECK TABLE t3  FAST QUICK MEDIUM;
CHECK TABLE t3  FOR UPGRADE FAST QUICK MEDIUM EXTENDED CHANGED;
--error 1064
ALTER TABLE t3 CHECK PARTITION p1;

CHECK TABLE t3,t2,t1  FOR UPGRADE;
CHECK TABLE t3,t2  QUICK;
CHECK TABLE t3,t1  FAST;
CHECK TABLE t2,t3  MEDIUM;
CHECK TABLE t3,t1,t2  EXTENDED;
CHECK TABLE t1,t2,t3  CHANGED;
CHECK TABLE t1,t3,t2  FAST QUICK MEDIUM;
CHECK TABLE t3,t2,t1  FOR UPGRADE FAST QUICK MEDIUM EXTENDED CHANGED;

--echo RANGE COLUMNS 分区
--error 0,1051
DROP TABLE t4;
CREATE TABLE t4 (
    id INT,
    created_at DATE,
    status VARCHAR(10)
)
PARTITION BY RANGE COLUMNS(created_at, status) (
    PARTITION p0 VALUES LESS THAN ('2020-01-01', 'new'),
    PARTITION p1 VALUES LESS THAN ('2020-01-01', 'shipped'),
    PARTITION p2 VALUES LESS THAN ('2021-01-01', 'new')
);

INSERT INTO t4 (id, created_at, status) VALUES (1, '2019-01-01', 'new');
INSERT INTO t4 (id, created_at, status) VALUES (2, '2019-05-01', 'shipped');
INSERT INTO t4 (id, created_at, status) VALUES (3, '2020-06-01', 'new');

