--echo 联合多表的视图

--error 0,1051
DROP TABLE t3;
CREATE TABLE t3 (
    id INT,
    created_at DATE
)
PARTITION BY RANGE (YEAR(created_at)) (
    PARTITION p0 VALUES LESS THAN (2020),
    PARTITION p1 VALUES LESS THAN (2021),
    PARTITION p2 VALUES LESS THAN (2022)
);

INSERT INTO t3 (id, created_at) VALUES (1, '2019-01-01');
INSERT INTO t3 (id, created_at) VALUES (2, '2020-01-01');
INSERT INTO t3 (id, created_at) VALUES (3, '2021-01-01');

