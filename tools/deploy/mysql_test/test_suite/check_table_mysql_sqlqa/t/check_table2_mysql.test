# owner: peihan.dph
# description: check table 

--echo 特殊表名
--error 0,1051
drop table my_table;
CREATE TABLE my_table(
  c_1 int
);
CHECK TABLE my_table;

--error 0,1051
drop table `my-table!@#`;
CREATE TABLE `my-table!@#` (
  `col$#` int
);
CHECK TABLE `my-table!@#`;

--echo 跨database的表
--error 0,1008
DROP DATABASE lyq_test;
CREATE DATABASE lyq_test CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;

USE lyq_test;

--error 0,1051
drop table `my-table!@#`;
CREATE TABLE `my-table!@#` (
  `col$#` int
);

CHECK TABLE `my-table!@#`;
--error 0,1008
DROP DATABASE lyq_test2;
CREATE DATABASE lyq_test2 CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;

USE lyq_test2;

--error 0,1051
drop table `my-table!@#`;
CREATE TABLE `my-table!@#` (
  `col$#` int
);

CHECK TABLE `my-table!@#`;

CHECK TABLE lyq_test2.`my-table!@#`;
CHECK TABLE lyq_test2.`my-table!@#`,lyq_test.`my-table!@#`;
--error 1066
CHECK TABLE `my-table!@#`,lyq_test2.`my-table!@#`;

--echo 临时表 ob424版本mysql模式不支持临时表

--error 0,1051
drop table my_table;
--error 1235
CREATE TEMPORARY TABLE my_table (
    id INT AUTO_INCREMENT,
    name VARCHAR(100),
    PRIMARY KEY(id)
);

--echo 复制表

--error 0,1051
drop table my_table;

CREATE TABLE my_table (
    id INT AUTO_INCREMENT,
    name VARCHAR(100),
	c2 INT NOT null,
    c3 char(30) DEFAULT 3.14159,
    PRIMARY KEY(id)
);

INSERT INTO my_table(name,c2,c3) VALUES('a',1,1);
INSERT INTO my_table(name,c2,c3) VALUES('b',2,2);
INSERT INTO my_table(name,c2,c3) VALUES('c',3,3);

CHECK TABLE my_table;
--error 0,1051
drop table my_table1;
CREATE TABLE my_table1 select * from my_table;
CHECK TABLE my_table,my_table1;
--error 0,1051
drop table my_table2;
CREATE TABLE my_table2 like my_table1;
CHECK TABLE my_table,my_table1,my_table2;

--echo 修改列类型 

ALTER TABLE my_table2 MODIFY COLUMN name CHAR(50);
desc my_table2;
sleep 2;
CHECK TABLE my_table,my_table1,my_table2;

ALTER TABLE my_table CHANGE COLUMN name new_name VARCHAR(100);

desc my_table;
sleep 2;
CHECK TABLE my_table,my_table1,my_table2;

ALTER TABLE my_table DROP COLUMN c2;
desc my_table;
sleep 2;
CHECK TABLE my_table,my_table1,my_table2;

--echo truncate表

TRUNCATE TABLE my_table1;
desc my_table;
sleep 2;
CHECK TABLE my_table,my_table1,my_table2;

