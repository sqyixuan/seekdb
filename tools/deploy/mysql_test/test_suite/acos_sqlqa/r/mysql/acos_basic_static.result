drop table if exists caitest;
drop table if exists ctest;
drop table if exists ctest1;
drop table if exists ctest3;
create table caitest (v_test varchar(200));
insert into caitest values('1');
select acos(v_test/100) from caitest;
acos(v_test/100)
1.5607961601207294
#参数个数
select acos() from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'acos'
select acos('-1') from  dual;
acos('-1')
3.141592653589793
select acos('-1',0) from  dual;
ERROR 42000: Incorrect parameter count in the call to native function 'acos'
select acos(power(-0.325415,3)) from  dual;
acos(power(-0.325415,3))
1.6052629465967472
#验证非数值参数
select acos('a1') from  dual;
acos('a1')
1.5707963267948966
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'a1'
#验证各参数类型的边界值-1,1
select acos((1e-30)+1) from dual;
acos((1e-30)+1)
0
select acos(-(1e-30)-1) from dual;
acos(-(1e-30)-1)
3.141592653589793
select acos(20) from dual;
acos(20)
NULL
select acos(-20) from dual;
acos(-20)
NULL
select acos(1) from dual;
acos(1)
0
select acos(-1) from dual;
acos(-1)
3.141592653589793
#varchar类型
drop table caitest;
create table caitest(v_test varchar(200)) ;
insert into caitest values('1');
select acos(v_test/100) from caitest;
acos(v_test/100)
1.5607961601207294
#date/interval类型
select acos('20191001') from  dual;
acos('20191001')
NULL
select acos('20191001'/2E14-1) from  dual;
acos('20191001'/2E14-1)
3.1411433096085917
select acos('2019-10-01') from  dual;
acos('2019-10-01')
NULL
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: '2019-10-01'
select acos('2019:10:01') from  dual;
acos('2019:10:01')
NULL
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: '2019:10:01'
select acos('20191001030204') from  dual;
acos('20191001030204')
NULL
select acos('20191001030204'/2E14-1) from  dual;
acos('20191001030204'/2E14-1)
2.6883798412602435
select acos('2019-10-01 03:02:05') from  dual;
acos('2019-10-01 03:02:05')
NULL
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: '2019-10-01 03:02:05'
#float类型
drop table caitest;
create table caitest(v_test float) ;
insert into caitest values(0.132);
insert into caitest values(-0.132);
insert into caitest values(0);
select acos(v_test/100) from caitest;
acos(v_test/100)
1.5694763264187208
1.5721163271710723
1.5707963267948966
select acos(v_test/100)-acos(v_test/100) from caitest;
acos(v_test/100)-acos(v_test/100)
0
0
0
#double类型,运算
drop table caitest;
create  table   caitest(v_test double) ;
insert into caitest values(0.132);
insert into caitest values(-0.132);
insert into caitest values(0);
select acos(v_test/100) from caitest;
acos(v_test/100)
1.5694763264115683
1.572116327178225
1.5707963267948966
select (acos(v_test/100)-3*acos(v_test/100))/10 from caitest;
(acos(v_test/100)-3*acos(v_test/100))/10
-0.3138952652823137
-0.31442326543564497
-0.3141592653589793
#float,double,number隐式转换
create table ctest1(v_test float,v_test2 double);
insert into ctest1 values(0.9451458745213652145777777777777777777777777777777,-0.663524120032055485112);
select acos(v_test/100), acos(v_test2) from ctest1;
acos(v_test/100)	acos(v_test2)
1.5613447276185384	2.296315721763248
insert into ctest1 values(0.9451458745213652145777777777777777777777777777777,-0.663524120032055485112);
select acos(v_test/100), acos(v_test2) from ctest1;
acos(v_test/100)	acos(v_test2)
1.5613447276185384	2.296315721763248
1.5613447276185384	2.296315721763248
insert into ctest1 values(0.9451458745213652145777777777777777777777777777777,-0.663524120032055485112d);
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'd)' at line 1
select acos(v_test/100),acos(v_test2) from ctest1;
acos(v_test/100)	acos(v_test2)
1.5613447276185384	2.296315721763248
1.5613447276185384	2.296315721763248
#float,double,number边界值
select acos(-1.0e-130) from dual;
acos(-1.0e-130)
1.5707963267948966
#oracle及ob超边界值时均显示为0
select acos(-1.0e-131) from dual;
acos(-1.0e-131)
1.5707963267948966
#varchar等类型录入其他类型值
create table ctest3(v_test varchar(200),v_test1 char(200));
insert into ctest3 values(0.9451458745213652145777777777777777777777777777777,-0.663524120032055485112);
select acos(v_test/100), acos(v_test1) from ctest3;
acos(v_test/100)	acos(v_test1)
1.5613447273274437	2.296315721763248
drop table ctest3;
#函数嵌套(sum,modd等)
SELECT acos(MOD(.011211,4)) FROM DUAL;
acos(MOD(.011211,4))
1.5595850919363485
SELECT acos(MOD(-0.11,11)) FROM DUAL;
acos(MOD(-0.11,11))
1.6810193767826433
SELECT acos(round(-0.11,11)) FROM DUAL;
acos(round(-0.11,11))
1.6810193767826433
SELECT acos(round(0.11,3)) FROM DUAL;
acos(round(0.11,3))
1.46057327680715
SELECT sum(acos(0.111)-100) FROM DUAL;
sum(acos(0.111)-100)
-98.54043288484573
SELECT MOD((sum(acos(0.2111)-100)),50) FROM DUAL;
MOD((sum(acos(0.2111)-100)),50)
-48.641903857077196
SELECT acos(1/POWER(10,20)) FROM DUAL;
acos(1/POWER(10,20))
1.5707963267948966
SELECT acos(-1/POWER(10,20)) FROM DUAL;
acos(-1/POWER(10,20))
1.5707963267948966
#静态sql(函数嵌套，dml等)
drop table caitest;
create table caitest(v_test varchar(30),v_test1 varchar(30));
insert into caitest values('-0.202','0');
select acos(v_test/100),acos(v_test1)  from caitest;
acos(v_test/100)	acos(v_test1)
1.5728163281686338	1.5707963267948966
insert into caitest values('-0.202','0.22');
select acos(v_test/100),acos(v_test1)  from caitest;
acos(v_test/100)	acos(v_test1)
1.5728163281686338	1.5707963267948966
1.5728163281686338	1.3489818562981022
#存在非数字型参数
insert into caitest values('-0.202','aa12');
select acos(v_test/100),acos(v_test1)  from caitest;
acos(v_test/100)	acos(v_test1)
1.5728163281686338	1.5707963267948966
1.5728163281686338	1.3489818562981022
1.5728163281686338	1.5707963267948966
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'aa12'
delete  from caitest where v_test1='aa12';
#group by having
insert into caitest values('-0.202','0');
insert into caitest values('-0.202','0.22');
select v_test,v_test1,acos(v_test1) from caitest group by v_test,v_test1 having acos(v_test1)>=0;
v_test	v_test1	acos(v_test1)
-0.202	0	1.5707963267948966
-0.202	0.22	1.3489818562981022
insert into caitest values('-0.202','0');
insert into caitest values('-0.202','aa12');
select v_test,v_test1,acos(v_test1) from caitest group by v_test,v_test1 having acos(v_test1)>=0;
v_test	v_test1	acos(v_test1)
-0.202	0	1.5707963267948966
-0.202	0.22	1.3489818562981022
-0.202	aa12	1.5707963267948966
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'aa12'
Warning	1292	Truncated incorrect DOUBLE value: 'aa12'
delete from caitest;
insert into caitest values('-0.202','0');
insert into caitest values('-0.202','0.22');
insert into caitest values('0.202','-0.22');
insert into caitest values('0.202','0.22');
#order by
select v_test1,acos(v_test/100) from caitest order by acos(v_test/100) desc;
v_test1	acos(v_test/100)
0	1.5728163281686338
0.22	1.5728163281686338
-0.22	1.5687763254211595
0.22	1.5687763254211595
#case when
select sum(acos(case when acos(v_test/100)>0 then 0.2 else 0.1 end)/acos(-0.1)) from  caitest;
sum(acos(case when acos(v_test/100)>0 then 0.2 else 0.1 end)/acos(-0.1))
3.278200158870836
select sum(acos((case v_test when '-0.202' then acos(v_test/100) when '0.202' then acos(v_test1) end)/acos(-1))) t1 from  caitest;
t1
4.1834373030366985
#distinct
select distinct acos(v_test/100) from caitest;
acos(v_test/100)
1.5728163281686338
1.5687763254211595
#空值
drop table caitest;
create table caitest(v_test varchar(30),v_test1 varchar(30));
select acos(v_test/100),acos(v_test1)  from caitest;
acos(v_test/100)	acos(v_test1)
drop table caitest;
