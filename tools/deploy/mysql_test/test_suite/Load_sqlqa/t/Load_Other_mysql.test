--disable_abort_on_error
--result_format 4
--disable_warnings
--error 0,1396
drop user WCY@'%';
create user WCY identified by 'WCY';
grant all on *.* to WCY WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,WCY,WCY,test,$OBMYSQL_PORT);
connection conn;

let $LOAD_SOURCE_DATA_FOLDER = "$PWD/mysql_test/test_suite/Load_sqlqa/data/Load_Other_mysql/";
--source mysql_test/include/copy_data_for_load_dir.inc
#--source mysql_test/test_suite/Load_sqlqa/include/Load_Other_mysql1.inc

--error 0,1051
DROP TABLE W0CASE;
--error 0,1051
DROP TABLE W1CASE;
--enable_warnings

--ECHO #该文档中，放置的case为load对应secure_file_priv以及报错信息的部分。

--ECHO #obmysql_mysql_load_3_3
--ECHO #obmysql_mysql_load_3_3_1
show variables like '%secure%';
connection default;

drop user WCY@'%';
create user WCY identified by 'WCY';
grant all on *.* to WCY WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,WCY,WCY,test,$OBMYSQL_PORT);
connection conn1;
show variables like '%secure%';

CREATE TABLE W0CASE (W0_TEST0 INT , W0_TEST1 CHAR(100));
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_Other_mysql/A0.txt' INTO TABLE W0CASE FIELDS TERMINATED BY ',' ;
--sorted_result
SELECT * FROM W0CASE ORDER BY W0_TEST0 DESC , W0_TEST1 DESC ;
DROP TABLE W0CASE ;

--ECHO #obmysql_mysql_load_3_3_3
connection default;

drop user WCY@'%';
create user WCY identified by 'WCY';
grant all on *.* to WCY WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn2,$OBMYSQL_MS0,WCY,WCY,test,$OBMYSQL_PORT);
connection conn2;
show variables like '%secure%';

CREATE TABLE W0CASE (W0_TEST0 INT , W0_TEST1 CHAR(100));
--ERROR 1017
LOAD DATA INFILE 'A0.txt' INTO TABLE W0CASE FIELDS TERMINATED BY ',' ;
--sorted_result
SELECT * FROM W0CASE ORDER BY W0_TEST0 DESC , W0_TEST1 DESC ;
