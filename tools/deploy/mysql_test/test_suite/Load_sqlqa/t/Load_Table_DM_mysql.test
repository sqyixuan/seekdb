--enable_warnings

--ECHO #该文档中，放置的case为load对应表，仅带set和col_name_or_user_var的部分，主要来load对应表的一般处理，同时这些表不带有主键，索引等约束。

--ECHO #obmysql_mysql_load_1
--ECHO #obmysql_mysql_load_1_1
--ECHO #CHAR, VARCHAR,TINYTEXT,TEXT,MEDIUMTEXT,LONGTEXT,ENUM,SET
CREATE TABLE W0CASE (W0_TEST0 CHAR(10), W0_TEST1 VARCHAR(10),W0_TEST2 TINYTEXT,W0_TEST3 TEXT, W0_TEST4 MEDIUMTEXT, W0_TEST5 LONGTEXT, W0_TEST6 ENUM('1','g'), W0_TEST7 SET('2','h'));
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_Table_DM_mysql/A0.txt' INTO TABLE W0CASE FIELDS TERMINATED BY ',' (W0_TEST0);
--sorted_result
SELECT * FROM W0CASE;
DROP TABLE W0CASE ;

