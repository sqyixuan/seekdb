--disable_abort_on_error
--result_format 4
--disable_warnings
--error 0,1396
drop user WCY@'%';
create user WCY identified by 'WCY';
grant all on *.* to WCY WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,WCY,WCY,test,$OBMYSQL_PORT);
connection conn;

let $LOAD_SOURCE_DATA_FOLDER = "$PWD/mysql_test/test_suite/Load_sqlqa/data/Load_Table_IC_mysql/";
