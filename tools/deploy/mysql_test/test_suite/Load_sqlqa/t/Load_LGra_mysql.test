--disable_abort_on_error
--result_format 4
--disable_warnings
--error 0,1396
drop user WCY@'%';
create user WCY identified by 'WCY';
grant all on *.* to WCY WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,WCY,WCY,test,$OBMYSQL_PORT);
connection conn;

let $LOAD_SOURCE_DATA_FOLDER = "$PWD/mysql_test/test_suite/Load_sqlqa/data/Load_LGra_mysql/";
--source mysql_test/include/copy_data_for_load_dir.inc
#--source mysql_teist/test_suite/Load_sqlqa/include/Load_LGra_mysql1.inc

--error 0,1051
DROP TABLE W0CASE;
--error 0,1051
DROP TABLE W1CASE;
--error 0,1051
DROP VIEW V0;
--enable_warnings

--ECHO #该文件中，放置的case都是针对load语法使用上的，对load语法各部分进行拆分及整合测试验证。

--ECHO #obmysql_mysql_load_2_1
--ECHO #obmysql_mysql_load_2_1_1
CREATE TABLE W0CASE ( W0_TEST0 INT , W0_TEST1 CHAR(100) , W0_TEST2 TIME );
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_LGra_mysql/A0.txt' REPLACE INTO TABLE W0CASE FIELDS TERMINATED BY ',' ;
--sorted_result
SELECT * FROM W0CASE ORDER BY W0_TEST0 DESC , W0_TEST1 DESC , W0_TEST2 DESC;
DELETE FROM W0CASE;
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_LGra_mysql/A1.txt' REPLACE INTO TABLE W0CASE FIELDS TERMINATED BY ',' ;
--sorted_result
SELECT * FROM W0CASE ORDER BY W0_TEST0 DESC , W0_TEST1 DESC , W0_TEST2 DESC;
DROP TABLE W0CASE;

