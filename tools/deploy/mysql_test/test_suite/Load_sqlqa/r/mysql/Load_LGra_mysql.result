#obmysql_mysql_load_2_1
#obmysql_mysql_load_2_1_1
CREATE TABLE W0CASE ( W0_TEST0 INT , W0_TEST1 CHAR(100) , W0_TEST2 TIME );
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_LGra_mysql/A0.txt' REPLACE INTO TABLE W0CASE FIELDS TERMINATED BY ',' ;
SELECT * FROM W0CASE ORDER BY W0_TEST0 DESC , W0_TEST1 DESC , W0_TEST2 DESC;
+----------+----------+----------+
| W0_TEST0 | W0_TEST1 | W0_TEST2 |
+----------+----------+----------+
|        1 | A        | 00:00:00 |
|        2 | B        | 00:00:01 |
|        3 | C        | 00:00:02 |
|        4 | D        | 00:00:03 |
+----------+----------+----------+
DELETE FROM W0CASE;
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_LGra_mysql/A1.txt' REPLACE INTO TABLE W0CASE FIELDS TERMINATED BY ',' ;
SELECT * FROM W0CASE ORDER BY W0_TEST0 DESC , W0_TEST1 DESC , W0_TEST2 DESC;
+----------+----------+----------+
| W0_TEST0 | W0_TEST1 | W0_TEST2 |
+----------+----------+----------+
|        5 | A1       | 00:00:04 |
|        6 | B2       | 00:00:05 |
|        7 | C3       | 00:00:06 |
|        8 | D4       | 00:00:07 |
+----------+----------+----------+
DROP TABLE W0CASE;

