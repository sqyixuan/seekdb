ERROR 42S02: Table doesn't exist
DROP TABLE W0CASE ;

CREATE TABLE W0CASE ( W0_TEST0 INT , W0_TEST1 CHAR(100) )
            PARTITION BY RANGE COLUMNS (W0_TEST0)
            ( PARTITION P0 VALUES LESS THAN (10), PARTITION P1 VALUES LESS THAN (20) );
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_Other_mysql/A9.txt' INTO TABLE W0CASE FIELDS TERMINATED BY ',' ;
ERROR HY000: Table has no partition for value
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_Other_mysql/A10.txt' INTO TABLE W0CASE FIELDS TERMINATED BY ',' ;
ERROR HY000: Incorrect integer value
DROP TABLE W0CASE ;

