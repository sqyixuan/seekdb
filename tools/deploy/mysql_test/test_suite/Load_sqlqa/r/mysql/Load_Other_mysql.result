ERROR 42000: Field separator argument is not what is expected; check the manual
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_Other_mysql/A7.txt' INTO TABLE W0CASE FIELDS ESCAPED BY '，' TERMINATED BY '|||//' ;
ERROR 42000: Field separator argument is not what is expected; check the manual
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_Other_mysql/A7.txt' INTO TABLE W0CASE FIELDS ESCAPED BY '，' TERMINATED BY '|||//' ;
ERROR 42000: Field separator argument is not what is expected; check the manual
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_Other_mysql/A7.txt' INTO TABLE W0CASE FIELDS ESCAPED BY '，' TERMINATED BY '|||//' LINES TERMINATED BY '//\\';
ERROR 42000: Field separator argument is not what is expected; check the manual
DROP TABLE W0CASE ;

