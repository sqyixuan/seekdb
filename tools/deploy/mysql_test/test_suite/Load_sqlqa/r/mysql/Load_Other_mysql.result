drop user WCY@'%';
create user WCY identified by 'WCY';
grant all on *.* to WCY WITH GRANT OPTION;





DROP TABLE W0CASE;
DROP TABLE W1CASE;
#该文档中，放置的case为load对应secure_file_priv以及报错信息的部分。
#obmysql_mysql_load_3_3
#obmysql_mysql_load_3_3_1
show variables like '%secure%';
Variable_name	Value
require_secure_transport	OFF
secure_auth	ON
secure_file_priv	/

drop user WCY@'%';
create user WCY identified by 'WCY';
grant all on *.* to WCY WITH GRANT OPTION;


show variables like '%secure%';
Variable_name	Value
require_secure_transport	OFF
secure_auth	ON
secure_file_priv	/

CREATE TABLE W0CASE (W0_TEST0 INT , W0_TEST1 CHAR(100));
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_Other_mysql/A0.txt' INTO TABLE W0CASE FIELDS TERMINATED BY ',' ;
SELECT * FROM W0CASE ORDER BY W0_TEST0 DESC , W0_TEST1 DESC ;
+----------+----------+
| W0_TEST0 | W0_TEST1 |
+----------+----------+
|        1 | a        |
+----------+----------+
DROP TABLE W0CASE ;

#obmysql_mysql_load_3_3_3

drop user WCY@'%';
create user WCY identified by 'WCY';
grant all on *.* to WCY WITH GRANT OPTION;


show variables like '%secure%';
Variable_name	Value
require_secure_transport	OFF
secure_auth	ON
secure_file_priv	/

CREATE TABLE W0CASE (W0_TEST0 INT , W0_TEST1 CHAR(100));
LOAD DATA INFILE 'A0.txt' INTO TABLE W0CASE FIELDS TERMINATED BY ',' ;
ERROR HY000: File not exist
SELECT * FROM W0CASE ORDER BY W0_TEST0 DESC , W0_TEST1 DESC ;
+----------+----------+
| W0_TEST0 | W0_TEST1 |
+----------+----------+
+----------+----------+
DROP TABLE W0CASE ;

#obmysql_mysql_load_3_4
#obmysql_mysql_load_3_4_1

drop user WCY@'%';
create user WCY identified by 'WCY';
grant all on *.* to WCY WITH GRANT OPTION;


show variables like '%secure%';
Variable_name	Value
require_secure_transport	OFF
secure_auth	ON
secure_file_priv	/
CREATE TABLE W0CASE (W0_TEST0 INT , W0_TEST1 INT);
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_Other_mysql/A0.txt' INTO TABLE W0CASE FIELDS TERMINATED BY ',' ;
ERROR HY000: Incorrect integer value
SELECT * FROM W0CASE ORDER BY W0_TEST0 DESC , W0_TEST1 DESC ;
+----------+----------+
| W0_TEST0 | W0_TEST1 |
+----------+----------+
+----------+----------+
DROP TABLE W0CASE ;

CREATE TABLE W0CASE (W0_TEST0 INT , W0_TEST1 TIME);
#TIME类型有问题
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_Other_mysql/A1.txt' INTO TABLE W0CASE FIELDS TERMINATED BY ',' ;
SELECT * FROM W0CASE ORDER BY W0_TEST0 DESC , W0_TEST1 DESC ;
+----------+----------+
| W0_TEST0 | W0_TEST1 |
+----------+----------+
|        1 | 00:01:00 |
+----------+----------+
DROP TABLE W0CASE ;

CREATE TABLE W0CASE (W0_TEST0 DATE , W0_TEST1 TIME);
#DATE类型有问题
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_Other_mysql/A2.txt' INTO TABLE W0CASE FIELDS TERMINATED BY ',' ;
SELECT * FROM W0CASE ORDER BY W0_TEST0 DESC , W0_TEST1 DESC ;
+------------+----------+
| W0_TEST0   | W0_TEST1 |
+------------+----------+
| 0000-00-00 | 00:00:00 |
+------------+----------+
DROP TABLE W0CASE ;

CREATE TABLE W0CASE (W0_TEST0 DATE , W0_TEST1 REAL);
#OB :ERROR   -4262   Truncated incorrect DOUBLE value , MYSQL :ERROR 1265 (01000): Data truncated for column 'W0_TEST1' at row 1. 相比较而言，ob的报错信息不够精确
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_Other_mysql/A3.txt' INTO TABLE W0CASE FIELDS TERMINATED BY ',' ;
ERROR 01000: Data truncated for argument
SELECT * FROM W0CASE ORDER BY W0_TEST0 DESC , W0_TEST1 DESC ;
+----------+----------+
| W0_TEST0 | W0_TEST1 |
+----------+----------+
+----------+----------+
DROP TABLE W0CASE ;

