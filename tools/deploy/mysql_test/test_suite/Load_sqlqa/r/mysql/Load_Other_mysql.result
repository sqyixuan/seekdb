CREATE TABLE W0CASE (W0_TEST0 CHAR(100) , W0_TEST1 REAL );
LOAD DATA INFILE 'data_for_mysqltest_loaddata/Load_Other_mysql/A7.txt' INTO TABLE W0CASE FIELDS TERMINATED ',' ;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '','' at line 1
