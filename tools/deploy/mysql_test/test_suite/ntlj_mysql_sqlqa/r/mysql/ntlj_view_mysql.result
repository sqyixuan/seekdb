drop database if exists db1;
create database db1;
use db1;
#测试在视图中使用nestedloopjoin算子
create table t1(c1 int,c2 int);
create table t2(a1 int,a2 int);
create table t3(b1 int,b2 int);
insert into t1 values(4,2);
insert into t1 values(3,8);
insert into t1 values(5,3);
insert into t1 values(7,9);
insert into t1 values(9,10);
insert into t1 values(11,2);
insert into t2 values(1,3);
insert into t2 values(2,5);
insert into t2 values(5,4);
insert into t2 values(7,3);
insert into t2 values(9,8);
insert into t2 values(11,1);
insert into t2 values(13,6);
insert into t3 values(2,null);
insert into t3 values(5,3);
insert into t3 values(null,6);
insert into t3 values(null,null);
create view v_t1 as select * from t1;
create view v_t2 as select * from t2;
create view v_t3 as select * from t3;
#无条件连接中使用nestedloopjoin
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2;
count(*)
42
select /*+use_nl(v_t2,v_t3)*/ count(*) from v_t2,v_t3;
count(*)
28
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 natural join v_t2;
count(*)
42
select /*+use_nl(v_t2,v_t3)*/ count(*) from v_t2 natural join v_t3;
count(*)
28
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2 where v_t1.c2> v_t2.a2;
count(*)
23
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2 where v_t1.c2> v_t2.a2 order by v_t1.c1 desc;
count(*)
23
select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2;
count(*)
42
select /*+parallel(6) use_nl(v_t2,v_t3)*/ count(*) from v_t2,v_t3;
count(*)
28
select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 natural join v_t2;
count(*)
42
select /*+parallel(6) use_nl(v_t2,v_t3)*/ count(*) from v_t2 natural join v_t3;
count(*)
28
select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2 where v_t1.c2> v_t2.a2;
count(*)
23
select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2 where v_t1.c2> v_t2.a2 order by v_t1.c1 desc;
count(*)
23
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2;
count(*)
42
select /*+use_nl(v_t2,v_t3)*/ count(*) from v_t2 cross join v_t3 order by v_t2.a1;
count(*)
28
select /*+use_nl(v_t1,v_t2)*/ max(v_t2.a1) from v_t1 cross join v_t2;
max(v_t2.a1)
13
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 order by v_t1.c1 desc;
count(*)
42
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2  where v_t2.a1 >3 order by v_t1.c1 desc;
count(*)
30
select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2;
count(*)
42
select /*+parallel(6) use_nl(v_t2,v_t3)*/ count(*) from v_t2 cross join v_t3 order by v_t2.a1;
count(*)
28
select /*+parallel(6) use_nl(v_t1,v_t2)*/ max(v_t2.a1) from v_t1 cross join v_t2;
max(v_t2.a1)
