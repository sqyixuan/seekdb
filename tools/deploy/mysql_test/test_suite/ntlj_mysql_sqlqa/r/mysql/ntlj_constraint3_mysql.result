#无条件连接
select count(*) from t1,t2;
count(*)
150
select /*+parallel(6)*/ count(*) from t1,t2;
count(*)
150
select count(*) from t1 cross join t2;
count(*)
150
select /*+parallel(6)*/ count(*) from t1 cross join t2;
count(*)
150
select count(*) from t1 natural join t2;
count(*)
150
select /*+parallel(6)*/ count(*) from t1 natural join t2;
count(*)
150
SELECT count(*) FROM (SELECT * FROM t1 NATURAL JOIN t2)a,(SELECT * FROM t1 CROSS JOIN t2)b;
count(*)
22500
SELECT /*+parallel(6)*/ count(*) FROM (SELECT /*+parallel(6)*/ * FROM t1 NATURAL JOIN t2)a,(SELECT /*+parallel(6)*/ * FROM t1 CROSS JOIN t2)b;
