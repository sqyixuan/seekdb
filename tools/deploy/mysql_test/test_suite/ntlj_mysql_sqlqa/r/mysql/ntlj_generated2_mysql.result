drop database if exists db1;
create database db1;
use db1;
#虚拟列为唯一约束时作为连接列
CREATE TABLE t1(c1 int,c2 int GENERATED ALWAYS AS (7 * c1) VIRTUAL unique );
CREATE TABLE t2(a1 int,a2 int GENERATED ALWAYS AS (7 * a1) VIRTUAL unique);
insert into t1(c1) values(1);
insert into t1(c1) values(2);
insert into t1(c1) values(5);
insert into t1(c1) values(7);
insert into t1(c1) values(null);
insert into t1(c1) values(11);
insert into t2(a1) values(1);
insert into t2(a1) values(2);
insert into t2(a1) values(5);
insert into t2(a1) values(7);
insert into t2(a1) values(null);
insert into t2(a1) values(null);
insert into t2(a1) values(13);
