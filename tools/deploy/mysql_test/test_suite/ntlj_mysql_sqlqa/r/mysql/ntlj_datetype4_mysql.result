drop database if exists db1;
create database db1;
use db1;
#bit
create table t1 (c1 bit(30),c2 bit(64));
create table t2 (a1 bit(30),a2 bit(64));
insert into t1 values(1,1),(2,2),(3,3),(5,5);
insert into t2 values(1,1),(2,2),(3,3),(5,5),(6,6);
select bin(c1),bin(c2),bin(a1),bin(a2) from t1,t2;
bin(c1)	bin(c2)	bin(a1)	bin(a2)
1	1	1	1
10	10	1	1
11	11	1	1
101	101	1	1
1	1	10	10
10	10	10	10
11	11	10	10
101	101	10	10
1	1	11	11
10	10	11	11
11	11	11	11
101	101	11	11
1	1	101	101
10	10	101	101
11	11	101	101
101	101	101	101
1	1	110	110
10	10	110	110
11	11	110	110
101	101	110	110
explain select bin(c1),bin(c2),bin(a1),bin(a2) from t1,t2;
