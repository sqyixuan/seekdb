drop database if exists db1;
create database db1;
use db1;
#复制表中使用Nestedloopjoin
create table t1(c1 int,c2 int);
create table t2(a1 int,a2 int);
create table t3(b1 int,b2 int);
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(4,6);
insert into t2 values(1,2);
insert into t2 values(2,2);
insert into t2 values(3,4);
insert into t2 values(5,7);
insert into t3 values(1,null);
insert into t3 values(null,1);
insert into t3 values(null,null);
create table tt1 as select * from t1;
create table tt2 as select * from t2;
create table tt3 as select * from t3;
#无条件指定连接中使用NEST LOOP JOIN
select /*+use_nl(tt1,tt2)*/ count(*) from tt1,tt2;
count(*)
16
select /*+use_nl(tt2,tt3)*/ count(*) from tt2,tt3;
count(*)
12
select /*+use_nl(tt1,tt2)*/ count(*) from tt1 natural join tt2;
count(*)
16
select /*+use_nl(tt2,tt3)*/ count(*) from tt2 natural join tt3;
count(*)
12
select /*+use_nl(tt1,tt2)*/ count(*) from tt1,tt2 where tt1.c2> tt2.a2;
count(*)
5
select /*+use_nl(tt1,tt2)*/ count(*) from tt1,tt2 where tt1.c2> tt2.a2 order by tt1.c1 desc;
count(*)
5
select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2;
count(*)
16
select /*+use_nl(tt2,tt3)*/ count(*) from tt2 cross join tt3 order by tt2.a1;
