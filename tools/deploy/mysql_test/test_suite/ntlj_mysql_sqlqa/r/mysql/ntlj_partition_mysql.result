select /*+use_nl(t1,t2)*/ count(*) from t1 partition(p3) right join t2 partition(p1) on t1.c1 = t2.a1;
count(*)
5
select /*+parallel(6) use_nl(t1,t2)*/ count(*) from t1 partition(p3) right join t2 partition(p1) on t1.c1 = t2.a1;
count(*)
5
