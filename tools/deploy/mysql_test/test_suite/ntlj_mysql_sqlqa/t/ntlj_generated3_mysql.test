##description : 生成列作为Join连接列进行测试
##author : wb-zwc01059807


--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;




--echo	#虚拟列 为not null作为连接列
create table t1(c1 int,c2 int generated always as (5 * c1) virtual not null);
create table t2(a1 int,a2 int generated always as (5 * a1) virtual not null);
insert into t1(c1) values(3);
insert into t1(c1) values(6);
insert into t1(c1) values(9);
insert into t1(c1) values(10);
insert into t1(c1) values(15);
insert into t2(a1) values(3);
insert into t2(a1) values(6);
insert into t2(a1) values(9);
insert into t2(a1) values(12);
insert into t2(a1) values(15);
insert into t2(a1) values(18);


--source mysql_test/test_suite/ntlj_mysql_sqlqa/include/ntlj_generated_mysql.inc

drop table t1;
drop table t2;

drop database db1;


