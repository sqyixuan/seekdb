--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;


--echo  #char和varchar
create table t1(c1 char(10),c2 varchar(10));
create table t2(a1 char(10),a2 varchar(10));
insert into t1 values('aa','张三');
insert into t1 values('bb','李四');
insert into t1 values('cc','王五');
insert into t1 values('dd','马六');
insert into t1 values('ee','田七');

insert into t2 values('aa','张三');
insert into t2 values('bb','四');
insert into t2 values('cc','王五');
insert into t2 values('dd','六');
insert into t2 values('ee','田七');
select * from t1;
select * from t2;

--source mysql_test/test_suite/ntlj_mysql_sqlqa/include/ntlj_datetype_mysql.inc

drop table t1;
drop table t2;


--echo  #year、date
create table t1(c1 year , c2 date);
create table t2(a1 year , a2 date);
insert into t1 values('2017','2017-08-08'),('2018','2018-08-08'),('2019','2019-08-08'),('2020','2020-08-08');
insert into t2 values('2017','2017-08-08'),('2018','2018-08-08'),('2019','2019-08-08'),('2020','2020-08-08'),('2021','2021-08-08');
select * from t1;
select * from t2;

--source mysql_test/test_suite/ntlj_mysql_sqlqa/include/ntlj_datetype_mysql.inc

drop table t1;
drop table t2;




drop database db1;
