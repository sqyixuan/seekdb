SELECT /*+use_nl(t1,t2)*/ * FROM t1 LEFT JOIN t2 ON t1.c1 = t2.a1 WHERE t2.a2 = (SELECT max(c1) FROM (SELECT * FROM t1 NATURAL JOIN t2)a NATURAL JOIN (SELECT * FROM t1 CROSS JOIN t2)b) order by t1.c1;
