SELECT /*+use_nl(t2,t1)*/ * FROM t2 LEFT JOIN t1 ON t2.a1 = t1.c1 WHERE t2.a2 != (select /*+use_nl(t1,t2)*/min(a2) from t1 right join  t2 on t1.c1=t2.a1 where t1.c1 is NULL) order by t1.c1;
