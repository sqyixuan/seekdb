SELECT /*+parallel(6) use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t1.c1 <(SELECT /*+parallel(6)*/ max(a2) FROM t1,t2) order by t1.c1;
#explain basic SELECT /*+parallel(6) use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t1.c1 <(SELECT /*+parallel(6)*/ max(a2) FROM t1,t2) order by t1.c1;

SELECT /*+use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t2.a2 > (SELECT max(c1) FROM (SELECT * FROM t1 CROSS JOIN t2)a NATURAL JOIN (SELECT * FROM t1,t2)b) order by t1.c1;
#explain basic SELECT /*+use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t2.a2 > (SELECT max(c1) FROM (SELECT * FROM t1 CROSS JOIN t2)a NATURAL JOIN (SELECT * FROM t1,t2)b) order by t1.c1;
SELECT /*+parallel(6) use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t2.a2 > (SELECT /*+parallel(6)*/ max(c1) FROM (SELECT /*+parallel(6)*/ * FROM t1 CROSS JOIN t2)a NATURAL JOIN (SELECT /*+parallel(6)*/ * FROM t1,t2)b) order by t1.c1;
#explain basic SELECT /*+parallel(6) use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t2.a2 > (SELECT /*+parallel(6)*/ max(c1) FROM (SELECT /*+parallel(6)*/ * FROM t1 CROSS JOIN t2)a NATURAL JOIN (SELECT /*+parallel(6)*/ * FROM t1,t2)b) order by t1.c1;

SELECT /*+use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t1.c1 = (SELECT /*+use_nl(t1,t2)*/ max(c1) FROM t1 right JOIN t2 ON t1.c1 = t2.a1) order by t1.c1;
#explain basic SELECT /*+use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t1.c1 = (SELECT /*+use_nl(t1,t2)*/ max(c1) FROM t1 right JOIN t2 ON t1.c1 = t2.a1) order by t1.c1;
SELECT /*+parallel(6) use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t1.c1 = (SELECT /*+parallel(6) use_nl(t1,t2)*/ max(c1) FROM t1 right JOIN t2 ON t1.c1 = t2.a1) order by t1.c1;
#explain basic SELECT /*+parallel(6) use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t1.c1 = (SELECT /*+parallel(6) use_nl(t1,t2)*/ max(c1) FROM t1 right JOIN t2 ON t1.c1 = t2.a1) order by t1.c1;

SELECT /*+use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t1.c2 != (SELECT /*+use_nl(t1,t2)*/ max(c2) FROM t1,t2 WHERE t1.c1 = t2.a1 AND t1.c1 <(SELECT max(a1) FROM t1,t2)) order by t1.c1;
#explain basic SELECT /*+use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t1.c2 != (SELECT /*+use_nl(t1,t2)*/ max(c2) FROM t1,t2 WHERE t1.c1 = t2.a1 AND t1.c1 <(SELECT max(a1) FROM t1,t2)) order by t1.c1;
SELECT /*+parallel(6) use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t1.c2 != (SELECT /*+parallel(6) use_nl(t1,t2)*/ max(c2) FROM t1,t2 WHERE t1.c1 = t2.a1 AND t1.c1 <(SELECT /*+parallel(6)*/ max(a1) FROM t1,t2)) order by t1.c1;
#explain basic SELECT /*+parallel(6) use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t1.c2 != (SELECT /*+parallel(6) use_nl(t1,t2)*/ max(c2) FROM t1,t2 WHERE t1.c1 = t2.a1 AND t1.c1 <(SELECT /*+parallel(6)*/ max(a1) FROM t1,t2)) order by t1.c1;

