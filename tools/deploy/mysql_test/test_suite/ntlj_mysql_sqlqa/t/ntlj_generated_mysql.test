--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--echo  #虚拟列
CREATE TABLE t1(c1 int,c2 int GENERATED ALWAYS AS (5 * c1) VIRTUAL);
CREATE TABLE t2(a1 int,a2 int GENERATED ALWAYS AS (10 * a1) VIRTUAL);
insert into t1(c1) values(2);
insert into t1(c1) values(4);
insert into t1(c1) values(6);
insert into t1(c1) values(8);
insert into t1(c1) values(10);
insert into t1(c1) values(null);
insert into t1(c1) values(14);

insert into t2(a1) values(1);
insert into t2(a1) values(3);
insert into t2(a1) values(5);
insert into t2(a1) values(7);
insert into t2(a1) values(null);
insert into t2(a1) values(11);
insert into t2(a1) values(null);

--source mysql_test/test_suite/ntlj_mysql_sqlqa/include/ntlj_generated_mysql.inc

drop table t1;
drop table t2;


drop database db1;

