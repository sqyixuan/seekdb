explain select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1 right join  t2 on t1.c2=t2.a2 where t1.c2 is null;

select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c2 not in(select a2 from t2);
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c2 not in(select a2 from t2);
select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c2 != all(select a2 from t2);
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c2 != all(select a2 from t2);
select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1 left join  t2 on t1.c2=t2.a2 where t2.a2 is null;
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1 left join  t2 on t1.c2=t2.a2 where t2.a2 is null;
select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1 right join  t2 on t1.c2=t2.a2 where t1.c2 is null;
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1 right join  t2 on t1.c2=t2.a2 where t1.c2 is null;

drop table t1;
drop table t2;








