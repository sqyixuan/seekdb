#owner : xiaoyi.xy
#owner group : SQL-SQL2
#tags : nestedloopjoin
#description : 不同数据类型作为Join连接列测试
#author : wb-zwc01059807
#tags: optimizer


--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;



--echo  #bit
create table t1 (c1 bit(30),c2 bit(64));
create table t2 (a1 bit(30),a2 bit(64));
insert into t1 values(1,1),(2,2),(3,3),(5,5);
insert into t2 values(1,1),(2,2),(3,3),(5,5),(6,6);

select bin(c1),bin(c2),bin(a1),bin(a2) from t1,t2;
explain select bin(c1),bin(c2),bin(a1),bin(a2) from t1,t2;
select bin(c1),bin(c2),bin(a1),bin(a2) from t1 natural join t2;
explain select bin(c1),bin(c2),bin(a1),bin(a2) from t1 natural join t2;
select  bin(c1),bin(c2),bin(a1),bin(a2) from t1 cross join t2;
explain select  bin(c1),bin(c2),bin(a1),bin(a2) from t1 cross join t2;

select /*+parallel(6)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1,t2;
explain select /*+parallel(6)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1,t2;
select /*+parallel(6)*/  bin(c1),bin(c2),bin(a1),bin(a2) from t1 natural join t2;
explain select /*+parallel(6)*/  bin(c1),bin(c2),bin(a1),bin(a2) from t1 natural join t2;
select  /*+parallel(6)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 cross join t2;
explain select  /*+parallel(6)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 cross join t2;


select bin(c1),bin(c2),bin(a1),bin(a2) from t1,t2 where t1.c1 = t2.a1;
explain select bin(c1),bin(c2),bin(a1),bin(a2) from t1,t2 where t1.c1 = t2.a1;
select /*+use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1,t2 where t1.c1 = t2.a1;
explain select /*+use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1,t2 where t1.c1 = t2.a1;
select bin(c1),bin(c2),bin(a1),bin(a2) from t1 inner join t2 on t1.c1 = t2.a1;
explain select bin(c1),bin(c2),bin(a1),bin(a2) from t1 inner join t2 on t1.c1 = t2.a1;
select /*+use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 inner join t2 on t1.c1 = t2.a1;
explain select /*+use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 inner join t2 on t1.c1 = t2.a1;

select /*+parallel(6)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1,t2 where t1.c1 = t2.a1;
explain select /*+parallel(6)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1,t2 where t1.c1 = t2.a1;
select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1,t2 where t1.c1 = t2.a1;
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1,t2 where t1.c1 = t2.a1;
select /*+parallel(6)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 inner join t2 on t1.c1 = t2.a1;
explain select /*+parallel(6)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 inner join t2 on t1.c1 = t2.a1;
select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 inner join t2 on t1.c1 = t2.a1;
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 inner join t2 on t1.c1 = t2.a1;


select bin(c1),bin(c2),bin(a1),bin(a2) from t1 left join t2 on t1.c1 = t2.a1;
explain select bin(c1),bin(c2),bin(a1),bin(a2) from t1 left join t2 on t1.c1 = t2.a1;
select /*+use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 left join t2 on t1.c1 = t2.a1;
explain select /*+use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 left join t2 on t1.c1 = t2.a1;
select /*+use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 left outer join t2 on t1.c1 = t2.a1;
explain select /*+use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 left outer join t2 on t1.c1 = t2.a1;


select bin(c1),bin(c2),bin(a1),bin(a2) from t1 full join t2 on t1.c1 = t2.a1 order by t1.c1;
explain select bin(c1),bin(c2),bin(a1),bin(a2) from t1 full join t2 on t1.c1 = t2.a1 order by t1.c1;
select /*+use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 full join t2 on t1.c1 = t2.a1 order by t1.c1;
explain select /*+use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 full join t2 on t1.c1 = t2.a1 order by t1.c1;

select /*+parallel(6)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 full join t2 on t1.c1 = t2.a1 order by t1.c1;
explain select /*+parallel(6)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 full join t2 on t1.c1 = t2.a1 order by t1.c1;
select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 full join t2 on t1.c1 = t2.a1 order by t1.c1;
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 full join t2 on t1.c1 = t2.a1 order by t1.c1;


--echo	#半连接
--echo	#NESTED LOOP SEMI JOIN
select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 in(select a1 from t2);
explain select /*+use_nl(t1,t2)*/ bin(c1) from t1  where c1 in(select a1 from t2);
select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 = any(select a1 from t2);
explain select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 = any(select a1 from t2);

select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 in(select a1 from t2);
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 in(select a1 from t2);
select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 = any(select a1 from t2);
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 = any(select a1 from t2);

--echo	#NESTED LOOP JOIN
select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 <(select max(a1) from t2);
explain select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 <(select max(a1) from t2);
select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 >=(select min(a1) from t2);
explain select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 >=(select min(a1) from t2);
select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 <=(select min(a1) from t2);
explain select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 <=(select min(a1) from t2);


select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 <(select max(a1) from t2);
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 <(select max(a1) from t2);
select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 >=(select min(a1) from t2);
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 >=(select min(a1) from t2);
select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 <=(select min(a1) from t2);
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 <=(select min(a1) from t2);


--echo	#NESTED-LOOP ANTI JOIN
select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 not in(select a1 from t2);
explain select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 not in(select a1 from t2);
select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 != all(select a2 from t2);
explain select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 != all(select a2 from t2);
select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1 left join  t2 on t1.c1=t2.a1 where t2.a1 is null;
explain select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1 left join  t2 on t1.c1=t2.a1 where t2.a1 is null;
select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1 right join  t2 on t1.c1=t2.a1 where t1.c1 is not null;
explain select /*+use_nl(t1,t2)*/ bin(c1),bin(c2) from t1 right join  t2 on t1.c1=t2.a1 where t1.c1 is not null;

select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 not in(select a1 from t2);
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 not in(select a1 from t2);
select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 != all(select a2 from t2);
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1  where c1 != all(select a2 from t2);
select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1 left join  t2 on t1.c1=t2.a1 where t2.a1 is null;
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1 left join  t2 on t1.c1=t2.a1 where t2.a1 is null;
select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1 right join  t2 on t1.c1=t2.a1 where t1.c1 is not null;
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2) from t1 right join  t2 on t1.c1=t2.a1 where t1.c1 is not null;

