select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 left join t2 on t1.c2 = t2.a2;
explain select /*+parallel(6) use_nl(t1,t2)*/ bin(c1),bin(c2),bin(a1),bin(a2) from t1 left join t2 on t1.c2 = t2.a2;
