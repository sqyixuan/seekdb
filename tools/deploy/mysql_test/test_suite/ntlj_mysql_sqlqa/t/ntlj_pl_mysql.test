--echo  #while

create table t1(c1 int, c2 int);
create table t2(a1 int, a2 int);
insert into t1 values (1,1),(2,2),(3,3),(5,5),(6,6),(7,null);
insert into t2 values (2,1),(3,3),(5,5),(6,6),(7,7),(8,8);
delimiter //;
create procedure pro1(a int)
begin
    declare i int;
    set i = 1;
    while i<a
    do
                select * from t1,t2;
                select * from t1 natural join t2;
                select * from t1 cross join t2;
                select /*+use_nl(t1,t2)*/ * from t1,t2 where t1.c1 = t2.a1;
                select /*+use_nl(t1,t2)*/ * from t1 inner join t2 on t1.c1 = t2.a1;
                select /*+use_nl(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.a1;
                select /*+use_nl(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.a1;
                select /*+use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
                select /*+use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);

                select /*+parallel(6)*/ * from t1,t2;
                select /*+parallel(6)*/ * from t1 natural join t2;
                select /*+parallel(6)*/ * from t1 cross join t2;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1,t2 where t1.c1 = t2.a1;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1 inner join t2 on t1.c1 = t2.a1;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.a1;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.a1;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);
                set i = i+1;
    end while;
end//

delimiter ;//

--disable_result_log
call pro1(2);
--enable_result_log



drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(a int)
begin
    declare i int;
    set i = 1;
    while i<a
    do
           insert into t1 select /*+parallel(6)*/ a1,a2 from t1,t2 limit 1;
           insert into t1 select /*+parallel(6)*/ a1,a2 from t1 cross join t2 limit 1;
           insert into t1 select /*+parallel(6)*/ a1,a2 from t1 natural join t2 limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1,t2 where t1.c1 = t2.a1 limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 inner join t2 on t1.c1 =  t2.a1 order by t1.c1 limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 left join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 right join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2) limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2) limit 1;
           update /*+parallel(6)*/ t1,t2 set a1 = 20 where c1 = 1;
           update /*+parallel(6)*/ t1 cross join t2 set a1 = 66  where c1 = 1;
           update /*+parallel(6)*/ t1 natural join t2 set c1 = 33 where c2 = 1;
           set i = i+1;
    end while;
end//

delimiter ;//
call pro1(2);





--echo  #loop

drop   table     if   exists   t1;
drop   table     if   exists   t2;
drop   procedure if   exists   pro1;
create table t1(c1 int, c2 int);
create table t2(a1 int, a2 int);
insert into t1 values (1,1),(2,2),(3,3),(5,5),(6,6),(7,null);
insert into t2 values (2,1),(3,3),(5,5),(6,6),(7,7),(8,8);

delimiter //;
create procedure pro1()
begin
	Declare tem int default 10;
	label:loop
                select * from t1,t2;
                select * from t1 natural join t2;
                select * from t1 cross join t2;
                select /*+use_nl(t1,t2)*/ * from t1,t2 where t1.c1 = t2.a1;
                select /*+use_nl(t1,t2)*/ * from t1 inner join t2 on t1.c1 = t2.a1;
                select /*+use_nl(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.a1;
                select /*+use_nl(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.a1;
                select /*+use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
                select /*+use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);

                select /*+parallel(6)*/ * from t1,t2;
                select /*+parallel(6)*/ * from t1 natural join t2;
                select /*+parallel(6)*/ * from t1 cross join t2;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1,t2 where t1.c1 = t2.a1;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1 inner join t2 on t1.c1 = t2.a1;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.a1;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.a1;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);
	set tem = tem + 1;
	if tem>10 then leave label;
	end if;
	end loop label;
	select  * from t1;
end//

delimiter ;//

--disable_result_log
call pro1();
--enable_result_log






drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1()
begin
	Declare tem int default 10;
	label:loop
           insert into t1 select /*+parallel(6)*/ a1,a2 from t1,t2 limit 1;
           insert into t1 select /*+parallel(6)*/ a1,a2 from t1 cross join t2 limit 1;
           insert into t1 select /*+parallel(6)*/ a1,a2 from t1 natural join t2 limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1,t2 where t1.c1 = t2.a1 limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 inner join t2 on t1.c1 =  t2.a1 order by t1.c1 limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 left join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 right join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2) limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2) limit 1;
           update /*+parallel(6)*/ t1,t2 set a1 = 20 where c1 = 1;
           update /*+parallel(6)*/ t1 cross join t2 set a1 = 66  where c1 = 1;
           update /*+parallel(6)*/ t1 natural join t2 set c1 = 33 where c2 = 1;
	set tem = tem + 1;
	if tem>10 then leave label;
	end if;
	end loop label;
	select  * from t1;
end//

delimiter ;//
