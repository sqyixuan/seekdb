delimiter //;
create function func1() returns int
begin
Declare a1 int default 1;
repeat
           insert into t1 select /*+parallel(6)*/ a1,a2 from t1,t2 limit 1;
           insert into t1 select /*+parallel(6)*/ a1,a2 from t1 cross join t2 limit 1;
           insert into t1 select /*+parallel(6)*/ a1,a2 from t1 natural join t2 limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1,t2 where t1.c1 = t2.a1 limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 inner join t2 on t1.c1 =  t2.a1 order by t1.c1 limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 left join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 right join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2) limit 1;
           insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2) limit 1;
           update /*+parallel(6)*/ t1,t2 set a1 = 20 where c1 = 1;
           update /*+parallel(6)*/ t1 cross join t2 set a1 = 66  where c1 = 1;
           update /*+parallel(6)*/ t1 natural join t2 set c1 = 33 where c2 = 1;
set a1 = a1+1;
until a1>=10
end repeat;
return 1;
end//

