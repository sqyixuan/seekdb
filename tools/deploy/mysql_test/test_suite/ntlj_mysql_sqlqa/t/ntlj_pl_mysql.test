--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;


--echo  #if条件语句
drop   table     if   exists   t1;
drop   table     if   exists   t2;
drop   procedure if   exists   pro1;
create table t1(c1 int, c2 int);
create table t2(a1 int, a2 int);
insert into t1 values (1,1),(2,2),(3,3),(5,5),(6,6),(7,null);
insert into t2 values (2,1),(3,3),(5,5),(6,6),(7,7),(8,8);

delimiter //;
create procedure pro1(aa int,bb int)
begin
        if  aa < bb  then
            select * from t1,t2;
            select * from t1 natural join t2;
            select * from t1 cross join t2;
         else
            select /*+parallel(6)*/ * from t1,t2;
            select /*+parallel(6)*/ * from t1 natural join t2;
            select /*+parallel(6)*/ * from t1 cross join t2;
        end if;

end//

delimiter ;//

--disable_result_log
call pro1(1,2);
call pro1(2,1);
--enable_result_log


drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(aa int,bb int)
begin
        if  aa<bb  then
            select /*+use_nl(t1,t2)*/ * from t1,t2 where t1.c1 = t2.a1;
            select /*+use_nl(t1,t2)*/ * from t1 inner join t2 on t1.c1 = t2.a1;
            select /*+use_nl(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.a1;
            select /*+use_nl(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.a1;
            select /*+use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
            select /*+use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);
         else
            select /*+parallel(6) use_nl(t1,t2)*/ * from t1,t2 where t1.c1 = t2.a1;
            select /*+parallel(6) use_nl(t1,t2)*/ * from t1 inner join t2 on t1.c1 = t2.a1;
            select /*+parallel(6) use_nl(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.a1;
            select /*+parallel(6) use_nl(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.a1;
            select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
            select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);
        end if;
end//

delimiter ;//

--disable_result_log
call pro1(1,2);
call pro1(2,1);
--enable_result_log


--echo  #循环语句
drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1()
begin
Declare a1 int default 1;
repeat
                select * from t1,t2;
                select * from t1 natural join t2;
                select * from t1 cross join t2;
                select /*+use_nl(t1,t2)*/ * from t1,t2 where t1.c1 = t2.a1;
                select /*+use_nl(t1,t2)*/ * from t1 inner join t2 on t1.c1 = t2.a1;
                select /*+use_nl(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.a1;
                select /*+use_nl(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.a1;
                select /*+use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
                select /*+use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);

                select /*+parallel(6)*/ * from t1,t2;
                select /*+parallel(6)*/ * from t1 natural join t2;
                select /*+parallel(6)*/ * from t1 cross join t2;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1,t2 where t1.c1 = t2.a1;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1 inner join t2 on t1.c1 = t2.a1;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.a1;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.a1;
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
                select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);
set a1 = a1+1;
until a1>=2
end repeat;

end//

delimiter ;//

--disable_result_log
call pro1();
--enable_result_log




drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1()
begin
Declare a1 int default 1;
repeat
            insert into t1 select a1,a2 from t1,t2 limit 1;
            insert into t1 select a1,a2 from t1 cross join t2 limit 1;
            insert into t1 select a1,a2 from t1 natural join t2 limit 1;
            insert into t1 select /*+use_nl(t1,t2)*/ a1,a2 from t1,t2 where t1.c1 = t2.a1 limit 1;
            insert into t1 select /*+use_nl(t1,t2)*/ a1,a2 from t1 inner join t2 on t1.c1 =  t2.a1 order by t1.c1 limit 1;
            insert into t1 select /*+use_nl(t1,t2)*/ a1,a2 from t1 left join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
            insert into t1 select /*+use_nl(t1,t2)*/ a1,a2 from t1 right join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
            insert into t1 select /*+use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2) limit 1;
            insert into t1 select /*+use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2) limit 1;
            update t1,t2 set a1 = 100 where c1 = 1;
            update t1 cross join t2 set a1 = 99  where c1 = 1;
            update t1 natural join t2 set c1 = 2020 where c2 = 1;
set a1 = a1+1;
until a1>=2
end repeat;

end//

delimiter ;//
call pro1();


drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1()
begin
Declare a1 int default 1;
repeat
           insert into t1 select /*+parallel(6)*/ a1,a2 from t1,t2 limit 1;
           insert into t1 select /*+parallel(6)*/ a1,a2 from t1 cross join t2 limit 1;
           insert into t1 select /*+parallel(6)*/ a1,a2 from t1 natural join t2 limit 1;
