#tags : nestedloopjoin
#description : 测试各种JOIN使用NestedLoopJoin
#author : wb-zwc01059807


--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

create table t1(c1 int,c2 int);
create table t2(a1 int,a2 int);
create table t3(b1 int,b2 int);
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(4,6);
insert into t2 values(1,2);
insert into t2 values(2,2);
insert into t2 values(3,4);
insert into t2 values(5,7);
insert into t3 values(1,null);
insert into t3 values(null,1);
insert into t3 values(null,null);

--echo  #case when
SELECT CASE WHEN c1>(SELECT max(b1) FROM t2,t3) THEN '1111' ELSE '2222' END FROM t1;
explain basic SELECT CASE WHEN c1>(SELECT max(b1) FROM t2,t3) THEN '1111' ELSE '2222' END FROM t1;
SELECT CASE WHEN c1>(SELECT /*+parallel(6) use_nl(t2,t3)*/ max(b1) FROM t2,t3) THEN '1111' ELSE '2222' END FROM t1;
explain basic SELECT CASE WHEN c1>(SELECT /*+parallel(6) use_nl(t2,t3)*/ max(b1) FROM t2,t3) THEN '1111' ELSE '2222' END FROM t1;

SELECT c1+a1 FROM t1,t2 WHERE (CASE WHEN c1 = (SELECT min(c1) FROM t2,t3) THEN 1  WHEN a1 = (SELECT max(c1) FROM t1,t2) THEN 2 ELSE 0 END ) = 1 ORDER BY c1+a1 desc;
SELECT  /*+parallel(6)*/ c1+a1 FROM t1,t2 WHERE (CASE WHEN c1 = (SELECT /*+parallel(6)*/ min(c1) FROM t2,t3) THEN 1  WHEN a1 = (SELECT /*+parallel(6)*/ max(c1) FROM t1,t2) THEN 2 ELSE 0 END ) = 1 ORDER BY c1+a1 desc;

SELECT CASE WHEN c1>(SELECT max(b1) FROM t2,t3) THEN '1111' ELSE '2222' END FROM t1;
SELECT CASE WHEN c1>(SELECT /*+parallel(6) use_nl(t2,t3)*/ max(b1) FROM t2,t3) THEN '1111' ELSE '2222' END FROM t1;

SELECT c1+a1 FROM t1,t2 WHERE (CASE WHEN c1 = (SELECT min(c1) FROM t2,t3) THEN 1  WHEN a1 = (SELECT max(c1) FROM t1,t2) THEN 2 ELSE 0 END ) = 1 ORDER BY c1+a1 desc;
SELECT  /*+parallel(6)*/ c1+a1 FROM t1,t2 WHERE (CASE WHEN c1 = (SELECT /*+parallel(2)*/ min(c1) FROM t2,t3) THEN 1  WHEN a1 = (SELECT /*+parallel(2)*/ max(c1) FROM t1,t2) THEN 2 ELSE 0 END ) = 1 ORDER BY c1+a1 desc;

SELECT CASE WHEN c1>(SELECT max(b1) FROM t2 CROSS JOIN t3) THEN '1111' ELSE '2222' END FROM t1;
SELECT CASE WHEN c1>(SELECT /*+parallel(6) use_nl(t2,t3)*/ max(b1) FROM t2 CROSS JOIN t3) THEN '1111' ELSE '2222' END FROM t1;

SELECT c1+a1 FROM t1 CROSS JOIN t2 WHERE (CASE WHEN c1 = (SELECT min(c1) FROM t2 CROSS JOIN t3) THEN 1  WHEN a1 = (SELECT max(c1) FROM t1 CROSS JOIN t2) THEN 2 ELSE 0 END ) = 1 ORDER BY c1+a1 desc;
SELECT  /*+parallel(6)*/ c1+a1 FROM t1 CROSS  JOIN t2 WHERE (CASE WHEN c1 = (SELECT /*+parallel(6)*/ min(c1) FROM t2 CROSS JOIN t3) THEN 1  WHEN a1 = (SELECT /*+parallel(6)*/ max(c1) FROM t1 CROSS JOIN t2) THEN 2 ELSE 0 END ) = 1 ORDER BY c1+a1 desc;

SELECT CASE WHEN c1>(select /*+use_nl(t1,t2)*/ max(c2) from t1,t2 where t1.c1=t2.a1) THEN '1111' ELSE '2222' END FROM t1;
SELECT CASE WHEN c1>(select /*+parallel(6) use_nl(t1,t2)*/ max(c2) from t1,t2 where t1.c1=t2.a1) THEN '1111' ELSE '2222' END FROM t1;

SELECT CASE WHEN c1>(select /*+use_nl(t1,t2)*/ max(c2) from t1 inner join  t2 on t1.c1 = t2.a1) THEN '1111' ELSE '2222' END FROM t1;
SELECT CASE WHEN c1>(select /*+parallel(6) use_nl(t1,t2)*/ max(c2) from t1 inner join t2 on  t1.c1 = t2.a1) THEN '1111' ELSE '2222' END FROM t1;

SELECT CASE WHEN c1>(select /*+use_nl(t1,t2)*/ avg(c2) from t1 left join  t2 on t1.c1=t2.a1) THEN '1111' ELSE '2222' END FROM t1;
SELECT CASE WHEN c1>(select /*+parallel(6) use_nl(t1,t2)*/ avg(c2) from t1 left join  t2 on t1.c1=t2.a1) THEN '1111' ELSE '2222' END FROM t1;

SELECT CASE WHEN c1>(select /*+use_nl(t1,t2)*/ avg(c2) from t1 right join  t2 on t1.c1=t2.a1) THEN '1111' ELSE '2222' END FROM t1;
SELECT CASE WHEN c1>(select /*+parallel(6) use_nl(t1,t2)*/ avg(c2) from t1 right join  t2 on t1.c1=t2.a1) THEN '1111' ELSE '2222' END FROM t1;

--echo  #嵌套

SELECT count(*)  FROM (SELECT * FROM t1,t2)a,(SELECT * FROM t2,t3)b ORDER BY c1 asc,b1 desc;
SELECT /*+parallel(6) */ count(*)  FROM (SELECT /*+parallel(6) use_nl(t1,t2)*/ * FROM t1,t2)a ,(SELECT /*+parallel(6) use_nl(t2,t3)*/ * FROM t2,t3)b ORDER BY c1 ASC,b1 desc;

SELECT count(*)  FROM (SELECT * FROM t1 NATURAL JOIN t2)a NATURAL JOIN (SELECT * FROM t2 NATURAL JOIN t3)b ORDER BY c1 asc,b1 desc;
SELECT /*+parallel(6) */ count(*)  FROM (SELECT /*+parallel(6)*/ * FROM t1 NATURAL JOIN t2)a NATURAL JOIN (SELECT /*+parallel(6)*/ * FROM t2 NATURAL JOIN t3)b ORDER BY c1 ASC,b1 desc;


SELECT count(*)  FROM (SELECT * FROM t1,t2)a,(SELECT * FROM t2,t3)b ORDER BY c1 ASC,b1 desc;
SELECT /*+parallel(6) */ count(*)  FROM (SELECT /*+parallel(6) */ * FROM t1,t2)a,(SELECT /*+parallel(6) */ * FROM t2,t3)b ORDER BY c1 ASC,b1 desc;

SELECT count(*)  FROM (SELECT /*+use_nl(t1,t2)*/ * FROM t1 CROSS JOIN t2)a CROSS join(SELECT /*+use_nl(t2,t3)*/ * FROM t2 CROSS JOIN t3)b ORDER BY c1 ASC,b1 desc;
SELECT /*+parallel(6) */ count(*)  FROM (SELECT /*+parallel(6) use_nl(t1,t2)*/ * FROM t1 CROSS JOIN t2)a CROSS join(SELECT /*+parallel(6) use_nl(t2,t3)*/ * FROM t2 CROSS JOIN t3)b ORDER BY c1 ASC,b1 desc;

SELECT count(*)  FROM (SELECT * FROM t1,t2)a CROSS JOIN (SELECT * FROM t2,t3)b ORDER BY c1 asc,b1 desc;
SELECT /*+parallel(6) */ count(*)  FROM (SELECT /*+parallel(6) use_nl(t1,t2)*/ * FROM t1,t2)a CROSS JOIN (SELECT /*+parallel(6) use_nl(t2,t3)*/ * FROM t2,t3)b ORDER BY c1 ASC,b1 desc;

SELECT count(*) FROM (select c1+c2 from t1,t2,t3)a,(select c1+c2 from t1,t2,t3)b;
SELECT /*+parallel(8)*/ count(*)  FROM (select /*+parallel(8)*/ c1+c2 from t1,t2,t3)a,(select /*+parallel(8)*/ c1+c2 from t1,t2,t3)b;

SELECT count(*)  FROM (select * from t1 cross join t2 cross join t3)a CROSS JOIN (select * from t1 cross join t2 cross join t3)b;
SELECT /*+parallel(8)*/ count(*)  FROM (select /*+parallel(8)*/ * from t1 cross join t2 cross join t3)a CROSS JOIN (select /*+parallel(8)*/ * from t1 cross join t2 cross join t3)b;

SELECT count(*)  FROM (select * from t1 natural join t2 natural join t3)a natural JOIN (select * from t1 natural join t2 natural join t3)b;
SELECT /*+parallel(8)*/ count(*)  FROM (select /*+parallel(8)*/ * from t1 natural join t2 natural join t3)a natural JOIN (select /*+parallel(8)*/ * from t1 natural join t2 natural join t3)b;

SELECT count(*) FROM (select * from t1 natural join t2 natural join t3)a CROSS JOIN (select * from t1 natural join t2 natural join t3)b CROSS JOIN (select * from t1 cross join t2 cross join t3)c;
SELECT /*+parallel(8)*/ count(*) FROM (select /*+parallel(8)*/ * from t1 natural join t2 natural join t3)a CROSS JOIN (select /*+parallel(8)*/ * from t1 natural join t2 natural join t3)b CROSS JOIN (select /*+parallel(8)*/ * from t1 cross join t2 cross join t3)c;

SELECT count(*) FROM (select * from t1 natural join t2 natural join t3)a,(select * from t1 cross join t2 cross join t3)b,(select * FROM t1,t2,t3)c;
SELECT /*+parallel(8)*/ count(*) FROM (select /*+parallel(8)*/ * from t1 natural join t2 natural join t3)a,(select /*+parallel(8)*/ * from t1 cross join t2 cross join t3)b,(select /*+parallel(8)*/ * from t1,t2,t3)c;

SELECT count(*) FROM (select * from t1 cross join t2 cross join t3)a NATURAL JOIN (SELECT * FROM t1,t2,t3)b NATURAL JOIN (SELECT * FROM t1 CROSS JOIN t2,t3)c;
SELECT  /*+parallel(8)*/ count(*) FROM (select /*+parallel(8)*/ * from t1 cross join t2 cross join t3)a NATURAL JOIN (SELECT /*+parallel(8)*/ * FROM t1,t2,t3)b NATURAL JOIN (SELECT /*+parallel(8)*/ * FROM t1 CROSS JOIN t2,t3)c;

select count(*)  from (select /*+use_nl(t1,t2)*/ * from t1 left join t2 on t1.c1=t2.a1)a ,(select /*+use_nl(t2,t3)*/ * from t2 left join t3 on t2.a1=t3.b1)b  where a.c1=b.a1;
select /*+parallel(8)*/ count(*)  from (select /*+parallel(8) use_nl(t1,t2)*/ * from t1 left join t2 on t1.c1=t2.a1)a ,(select /*+parallel(8) use_nl(t2,t3)*/ * from t2 left join t3 on t2.a1=t3.b1)b  where a.c1=b.a1;

SELECT count(*) FROM (select /*+use_nl(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1)a,(select /*+use_nl(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1)b WHERE a.c1 = b.a1;
SELECT /*+parallel(6)*/count(*) FROM (select /*+use_nl(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1)a,(select /*+use_nl(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1)b WHERE a.c1 = b.a1;


select count(*)  from (select * from t1 cross join t2)a left join (select * from t1 natural join t2 natural join t3)b on a.c1 = b.a1;
select /*+parallel(8)*/ count(*)  from (select /*+parallel(8)*/ * from t1 cross join t2)a left join (select /*+parallel(8)*/ * from t1 natural join t2 natural join t3)b on a.c1 = b.a1;

select count(*)  from (select * from t1,t2)a left join (select /*+use_nl(t1,t2)*/ * from t1,t2 where t1.c1 = t2.a1)b on a.c1 = b.a1;
select /*+parallel(8)*/ count(*)  from (select /*+parallel(8)*/ * from t1,t2)a left join (select /*+parallel(8) use_nl(t1,t2)*/ * from t1,t2 where t1.c1 = t2.a1)b on a.c1 = b.a1;

select count(*)  from (select /*+use_nl(t1,t2)*/ * from t1 left join t2 on  t1.c1 = t2.a1)a left join (select /*+use_nl(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.a1)b on a.c1 = b.a1;
select /*+parallel(8)*/ count(*)  from (select /*+parallel(8) use_nl(t1,t2)*/ * from t1 left join t2 on  t1.c1 = t2.a1)a left join (select /*+parallel(8) use_nl(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.a1)b on a.c1 = b.a1;

select count(*)  from (select * from t1 natural join t2 )a left join (select /*+use_nl(t1,t2)*/ * from t1 full join t2 on t1.c1 = t2.a1)b on a.c1 = b.a1;
select /*+parallel(8)*/ count(*)  from (select /*+parallel(8)*/ * from t1 natural join t2 )a left join (select /*+parallel(8) use_nl(t1,t2)*/ * from t1 full join t2 on t1.c1 = t2.a1)b on a.c1 = b.a1;

select count(*)  from (select * from t1 cross join t2)a right join (select * from t1 natural join t2 natural join t3)b on a.c1 = b.a1;
select /*+parallel(8)*/ count(*)  from (select /*+parallel(8)*/ * from t1 cross join t2)a right join (select /*+parallel(8)*/ * from t1 natural join t2 natural join t3)b on a.c1 = b.a1;

select count(*)  from (select * from t1,t2)a right join (select /*+use_nl(t1,t2)*/ * from t1,t2 where t1.c1 = t2.a1)b on a.c1 = b.a1;
select /*+parallel(8)*/ count(*)  from (select /*+parallel(8)*/ * from t1,t2)a right join (select /*+parallel(8) use_nl(t1,t2)*/ * from t1,t2 where t1.c1 = t2.a1)b on a.c1 = b.a1;

select count(*)  from (select /*+use_nl(t1,t2)*/ * from t1 left join t2 on  t1.c1 = t2.a1)a right join (select /*+use_nl(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.a1)b on a.c1 = b.a1;
select /*+parallel(8)*/ count(*)  from (select /*+parallel(8) use_nl(t1,t2)*/ * from t1 left join t2 on  t1.c1 = t2.a1)a right join (select /*+parallel(8) use_nl(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.a1)b on a.c1 = b.a1;

select count(*)  from (select * from t1 natural join t2 )a right join (select /*+use_nl(t1,t2)*/ * from t1 full join t2 on t1.c1 = t2.a1)b on a.c1 = b.a1;
select /*+parallel(8)*/ count(*)  from (select /*+parallel(8)*/ * from t1 natural join t2 )a right join (select /*+parallel(8) use_nl(t1,t2)*/ * from t1 full join t2 on t1.c1 = t2.a1)b on a.c1 = b.a1;

SELECT /*+use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t2.a1 > (SELECT /*+use_nl(t2,t3)*/ max(b1) FROM t2,t3 WHERE t2.a1 = t3.b1) ORDER BY c1 desc;
SELECT /*+parallel(8) use_nl(t1,t2)*/ * FROM t1,t2 WHERE t1.c1 = t2.a1 AND t2.a1 > (SELECT /*+parallel(8) use_nl(t2,t3)*/ max(b1) FROM t2,t3 WHERE t2.a1 = t3.b1) ORDER BY c1 desc;

SELECT /*+use_nl(t1,t2)*/ * FROM t1 INNER JOIN t2 ON t1.c1 = t2.a1 where t2.a1 >(SELECT /*+use_nl(t1,t2)*/ max(b1) FROM t2 INNER JOIN t3 ON t2.a1 = t3.b1);
SELECT /*+parallel(8) use_nl(t1,t2)*/ * FROM t1 INNER JOIN t2 ON t1.c1 = t2.a1 where t2.a1 >(SELECT /*+parallel(8) use_nl(t1,t2)*/ max(b1) FROM t2 INNER JOIN t3 ON t2.a1 = t3.b1);

SELECT /*+use_nl(t1,t2)*/ * FROM t1 inner JOIN t2 ON t1.c1=t2.a1 WHERE t1.c1  in (SELECT a1 FROM t2 WHERE t2.a1 IN (SELECT c1 FROM t1)) ORDER BY t1.c1,t1.c2;
SELECT /*+parallel(8) use_nl(t1,t2)*/ * FROM t1 inner JOIN t2 ON t1.c1=t2.a1 WHERE t1.c1  in (SELECT a1 FROM t2 WHERE t2.a1 IN (SELECT c1 FROM t1)) ORDER BY t1.c1,t1.c2;

SELECT /*+use_nl(t2,t3)*/ * FROM t2 INNER JOIN t3 ON t2.a1 = t3.b1 WHERE t2.a1 > (SELECT /*+use_nl(t3,t2)*/ min(b1) FROM t3 LEFT JOIN t2 ON t3.b1 = t2.a1);
SELECT /*+parallel(8) use_nl(t2,t3)*/ * FROM t2 INNER JOIN t3 ON t2.a1 = t3.b1 WHERE t2.a1 > (SELECT /*+parallel(8) use_nl(t3,t2)*/ min(b1) FROM t3 LEFT JOIN t2 ON t3.b1 = t2.a1);

SELECT /*+use_nl(t1,t2)*/ * FROM t1 LEFT JOIN t2 ON t1.c1 = t2.a1 WHERE t1.c2 > (SELECT /*+use_nl(t1,t2)*/ max(c1) FROM t1 LEFT JOIN t2 ON t1.c1 = t2.a1);
SELECT /*+parallel(8) use_nl(t1,t2)*/ * FROM t1 LEFT JOIN t2 ON t1.c1 = t2.a1 WHERE t1.c2 > (SELECT /*+parallel(8) use_nl(t1,t2)*/ max(c1) FROM t1 LEFT JOIN t2 ON t1.c1 = t2.a1);

SELECT /*+use_nl(t1,t3)*/ * FROM t1 LEFT JOIN t3 ON t1.c1 = t3.b1 WHERE t1.c1 != (SELECT /*+use_nl(t2,t3)*/ min(a1) FROM t2,t3 WHERE t2.a1 = t3.b1);
SELECT /*+parallel(8) use_nl(t1,t3)*/ * FROM t1 LEFT JOIN t3 ON t1.c1 = t3.b1 WHERE t1.c1 != (SELECT /*+parallel(8) use_nl(t2,t3)*/ min(a1) FROM t2,t3 WHERE t2.a1 = t3.b1);

SELECT /*+use_nl(t1,t2)*/ * FROM t1 RIGHT JOIN t2 ON t1.c1 = t2.a1 WHERE t2.a2 > (SELECT /*+use_nl(t1,t2)*/ max(t1.c2) FROM t1 LEFT JOIN t2 ON t1.c1 = t2.a1);
SELECT /*+parallel(8) use_nl(t1,t2)*/ * FROM t1 RIGHT JOIN t2 ON t1.c1 = t2.a1 WHERE t2.a2 > (SELECT /*+parallel(8) use_nl(t1,t2)*/ max(t1.c2) FROM t1 LEFT JOIN t2 ON t1.c1 = t2.a1);

--echo  #insert
insert into t1 select a1,a2 from t1,t2 limit 1;
explain basic insert into t1 select a1,a2 from t1,t2 limit 1;
insert into t1 select /*+parallel(6)*/ a1,a2 from t1,t2 limit 1;
explain basic insert into t1 select /*+parallel(6)*/ a1,a2 from t1,t2 limit 1;


insert into t1 select a1,a2 from t1 cross join t2 limit 1;
explain basic insert into t1 select a1,a2 from t1 cross join t2 limit 1;
insert into t1 select /*+parallel(6)*/ a1,a2 from t1 cross join t2 limit 1;
explain basic insert into t1 select /*+parallel(6)*/ a1,a2 from t1 cross join t2 limit 1;

insert into t1 select a1,a2 from t1 natural join t2 limit 1;
explain basic insert into t1 select a1,a2 from t1 natural join t2 limit 1;
insert into t1 select /*+parallel(6)*/ a1,a2 from t1 natural join t2 limit 1;
explain basic insert into t1 select /*+parallel(6)*/ a1,a2 from t1 natural join t2 limit 1;


insert into t1 select /*+use_nl(t1,t2)*/ a1,a2 from t1,t2 where t1.c1 = t2.a1 limit 1;
explain basic insert into t1 select /*+use_nl(t1,t2)*/ a1,a2 from t1,t2 where t1.c1 = t2.a1 limit 1;
insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1,t2 where t1.c1 = t2.a1 limit 1;
explain basic insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1,t2 where t1.c1 = t2.a1 limit 1;


insert into t1 select /*+use_nl(t1,t2)*/ a1,a2 from t1 inner join t2 on t1.c1 =  t2.a1 order by t1.c1 limit 1;
explain basic insert into t1 select /*+use_nl(t1,t2)*/ a1,a2 from t1 inner join t2 on t1.c1 =  t2.a1 order by t1.c1 limit 1;
insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 inner join t2 on t1.c1 =  t2.a1 order by t1.c1 limit 1;
explain basic insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 inner join t2 on t1.c1 =  t2.a1 order by t1.c1 limit 1;

insert into t1 select /*+use_nl(t1,t2)*/ a1,a2 from t1 left join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
explain basic insert into t1 select /*+use_nl(t1,t2)*/ a1,a2 from t1 left join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 left join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
explain basic insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 left join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;


insert into t1 select /*+use_nl(t1,t2)*/ a1,a2 from t1 right join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
explain basic insert into t1 select /*+use_nl(t1,t2)*/ a1,a2 from t1 right join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 right join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
explain basic insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ a1,a2 from t1 right join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;

insert into t1 select /*+use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2) limit 1;
explain basic insert into t1 select /*+use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2) limit 1;
insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2) limit 1;
explain basic insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2) limit 1;

insert into t1 select /*+use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2) limit 1;
explain basic insert into t1 select /*+use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2) limit 1;
insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2) limit 1;
explain basic insert into t1 select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2) limit 1;

--echo  #update
update t1,t2 set a1 = 100 where c1 = 1;
explain basic update t1,t2 set a1 = 100 where c1 = 1;
update /*+parallel(6)*/ t1,t2 set a1 = 101 where c1 = 1;
explain basic update /*+parallel(6)*/ t1,t2 set a1 = 100 where c1 = 1;


update t1 cross join t2 set a1 = 99  where c1 = 1;
explain basic update t1 cross join t2 set a1 = 99  where c1 = 1;
update /*+parallel(6)*/ t1 cross join t2 set a1 = 99  where c1 = 1;
explain basic update /*+parallel(6)*/ t1 cross join t2 set a1 = 99  where c1 = 1;


update t1 natural join t2 set c1 = 2020 where c2 = 1;
explain basic update t1 natural join t2 set c1 = 2020 where c2 = 1;
update /*+parallel(6)*/ t1 natural join t2 set c1 = 2021 where c2 = 1;
explain basic update /*+parallel(6)*/ t1 natural join t2 set c1 = 2020 where c2 = 1;

delete  from t1;
delete  from t2;
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(4,6);
insert into t2 values(1,2);
insert into t2 values(2,2);
insert into t2 values(3,4);
insert into t2 values(5,7);

update /*+use_nl(t1,t2)*/ t1 inner join t2 on t1.c1 = t2.a1 set t2.a2 = 1 where t2.a2 = 2;
explain basic update /*+use_nl(t1,t2)*/ t1 inner join t2 on t1.c1 = t2.a1 set t2.a2 = 1 where t2.a2 = 2;
update /*+parallel(6) use_nl(t1,t2)*/ t1 inner join t2 on t1.c1 = t2.a1 set t2.a2 = 2 where t2.a2 = 1;
explain basic update /*+parallel(6) use_nl(t1,t2)*/ t1 inner join t2 on t1.c1 = t2.a1 set t2.a2 = 2 where t2.a2 = 1;

