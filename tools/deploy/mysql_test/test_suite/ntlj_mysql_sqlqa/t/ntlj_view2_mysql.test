--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

create table t1(c1 int,c2 int);
create table t2(a1 int,a2 int);
create table t3(b1 int,b2 int);
insert into t1 values(4,2);
insert into t1 values(3,8);
insert into t1 values(5,3);
insert into t1 values(7,9);
insert into t1 values(9,10);
insert into t1 values(11,2);
insert into t2 values(1,3);
insert into t2 values(2,5);
insert into t2 values(5,4);
insert into t2 values(7,3);
insert into t2 values(9,8);
insert into t2 values(11,1);
insert into t2 values(13,6);
insert into t3 values(2,null);
insert into t3 values(5,3);
insert into t3 values(null,6);
insert into t3 values(null,null);
create view v_t1 as select * from t1;
create view v_t2 as select * from t2;
create view v_t3 as select * from t3;

--echo  #嵌套
select count(*) from (select * from v_t1,v_t2)a,(select * from v_t1 cross join v_t2)b;
#explain basic  select count(*) from (select * from v_t1,v_t2)a,(select * from v_t1 cross join v_t2)b;

select count(*) from (select * from v_t1 NATURAL join v_t2)a,(select /*+use_nl(v_t1,v_t2)*/ * from v_t1,v_t2 where v_T1.c1 = v_t2.a1)b;
#explain basic  select count(*) from (select * from v_t1 NATURAL join v_t2)a,(select /*+use_nl(v_t1,v_t2)*/ * from v_t1,v_t2 where v_T1.c1 = v_t2.a1)b;

select count(*) from (select /*+use_nl(v_t1,v_t2)*/ * from v_t1 left join v_t2 on v_t1.c1 = v_t2.a1)a,(select /*+use_nl(v_t1,v_t2)*/ * from v_t1 right join v_t2 on v_t1.c1 = v_t2.a1)b;
#explain basic  select count(*) from (select /*+use_nl(v_t1,v_t2)*/ * from v_t1 left join v_t2 on v_t1.c1 = v_t2.a1)a,(select /*+use_nl(v_t1,v_t2)*/ * from v_t1 right join v_t2 on v_t1.c1 = v_t2.a1)b;

select /*+parallel(4)*/count(*) from (select /*+parallel(4)*/ * from v_t1,v_t2)a,(select /*+parallel(4)*/ * from v_t1 cross join v_t2)b;
#explain basic  select /*+parallel(4)*/ count(*) from (select /*+parallel(4)*/ * from v_t1,v_t2)a,(select /*+parallel(4)*/ * from v_t1 cross join v_t2)b;

select /*+parallel(4)*/ count(*) from (select /*+parallel(4)*/ * from v_t1 NATURAL join v_t2)a,(select /*+parallel(4) use_nl(v_t1,v_t2)*/ * from v_t1,v_t2 where v_T1.c1 = v_t2.a1)b;
#explain basic  select /*+parallel(4)*/ count(*) from (select /*+parallel(4)*/ * from v_t1 NATURAL join v_t2)a,(select /*+parallel(4) use_nl(v_t1,v_t2)*/ * from v_t1,v_t2 where v_T1.c1 = v_t2.a1)b;

