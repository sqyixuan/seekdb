select count(*) from (select * from v_t1,v_t2)a cross join (select * from v_t1 cross join v_t2)b;
#explain basic  select count(*) from (select * from v_t1,v_t2)a cross join (select * from v_t1 cross join v_t2)b;

select count(*) from (select * from v_t1 NATURAL join v_t2)a cross join (select /*+use_nl(v_t1,v_t2)*/ * from v_t1,v_t2 where v_T1.c1 = v_t2.a1)b;
