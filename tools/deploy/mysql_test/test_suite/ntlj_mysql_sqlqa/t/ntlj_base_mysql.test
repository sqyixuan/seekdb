#owner : xiaoyi.xy
#owner group : SQL-SQL2
#tags : nestedloopjoin
#description : 测试各种JOIN使用NestedLoopJoin
#author : wb-zwc01059807


--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;



--echo  #测试NTL支持的各种Join
create table t1(c1 int,c2 int);
create table t2(a1 int,a2 int);
create table t3(b1 int,b2 int);
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(4,6);
insert into t2 values(1,2);
insert into t2 values(2,2);
insert into t2 values(3,4);
insert into t2 values(5,7);
insert into t3 values(1,null);
insert into t3 values(null,1);
insert into t3 values(null,null);

--echo  #无条件连接
select /*+use_nl(t1,t2)*/ count(*) from t1,t2 order by t1.c1;
#explain basic select /*+use_nl(t1,t2)*/ count(*) from t1,t2 order by t1.c1;
select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1,t2 order by t1.c1;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1,t2 order by t1.c1;

select /*+use_nl(t1,t2)*/ count(*)  from t1,t2 order by t1.c1;
#explain basic select /*+use_nl(t1,t2)*/ count(*)  from t1,t2 order by t1.c1;
select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1,t2 order by t1.c1;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1,t2 order by t1.c1;

select /*+use_nl(t1,t2)*/ count(*)  from t1,t2 order by t1.c1;
#explain basic select /*+use_nl(t1,t2)*/ count(*)  from t1,t2 order by t1.c1;
select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1,t2 order by t1.c1;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1,t2 order by t1.c1;

select /*+use_nl(t2,t3)*/ count(*)  from t2 natural join t3 order by t2.a1;
#explain basic select /*+use_nl(t2,t3)*/ count(*)  from t2 natural join t3 order by t2.a1;
select /*+parallel(6) use_nl(t2,t3)*/ count(*)  from t2 natural join t3 order by t2.a1;
#explain basic select /*+parallel(6) use_nl(t2,t3)*/ count(*)  from t2 natural join t3 order by t2.a1;

select /*+use_nl(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2;
#explain basic select /*+use_nl(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2;
select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2;

select /*+use_nl(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2 order by t1.c1 desc;
#explain basic select /*+use_nl(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2 order by t1.c1 desc;
select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2 order by t1.c1 desc;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2 order by t1.c1 desc;


SELECT count(*)  FROM (SELECT * FROM t1,t2)a,(SELECT * FROM t2,t3)b ORDER BY c1 asc,b1 desc;
#explain basic SELECT count(*)  FROM (SELECT * FROM t1,t2)a,(SELECT * FROM t2,t3)b ORDER BY c1 asc,b1 desc;
SELECT /*+parallel(2) */ count(*)  FROM (SELECT /*+parallel(2) use_nl(t1,t2)*/ * FROM t1,t2)a ,(SELECT /*+parallel(2) use_nl(t2,t3)*/ * FROM t2,t3)b ORDER BY c1 ASC,b1 desc;
#explain basic SELECT /*+parallel(2) */ count(*)  FROM (SELECT /*+parallel(2) use_nl(t1,t2)*/ * FROM t1,t2)a ,(SELECT /*+parallel(2) use_nl(t2,t3)*/ * FROM t2,t3)b ORDER BY c1 ASC,b1 desc;

SELECT count(*)  FROM (SELECT * FROM t1 NATURAL JOIN t2)a NATURAL JOIN (SELECT * FROM t2 NATURAL JOIN t3)b ORDER BY c1 asc,b1 desc;
#explain basic SELECT count(*)  FROM (SELECT * FROM t1 NATURAL JOIN t2)a NATURAL JOIN (SELECT * FROM t2 NATURAL JOIN t3)b ORDER BY c1 asc,b1 desc;

SELECT /*+parallel(2) */ count(*) FROM (SELECT /*+parallel(2)*/ * FROM t1 NATURAL JOIN t2)a NATURAL JOIN (SELECT /*+parallel(2)*/ * FROM t2 NATURAL JOIN t3)b ORDER BY c1 ASC,b1 desc;
#explain basic SELECT /*+parallel(2) */ count(*) FROM (SELECT /*+parallel(2)*/ * FROM t1 NATURAL JOIN t2)a NATURAL JOIN (SELECT /*+parallel(2)*/ * FROM t2 NATURAL JOIN t3)b ORDER BY c1 ASC,b1 desc;
SELECT /*+parallel(2) */ count(*) FROM (SELECT /*+parallel(2)*/ * FROM t1 NATURAL JOIN t2)a NATURAL JOIN (SELECT /*+parallel(2)*/ * FROM t2 NATURAL JOIN t3)b ORDER BY c1 ASC,b1 desc;
#explain basic SELECT /*+parallel(2) */ count(*) FROM (SELECT /*+parallel(2)*/ * FROM t1 NATURAL JOIN t2)a NATURAL JOIN (SELECT /*+parallel(2)*/ * FROM t2 NATURAL JOIN t3)b ORDER BY c1 ASC,b1 desc;

--echo  #cross join
select /*+use_nl(t1,t2)*/ count(*)  from t1 cross join t2;
#explain basic select /*+use_nl(t1,t2)*/ count(*)  from t1 cross join t2;
select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1 cross join t2;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1 cross join t2;

select /*+use_nl(t2,t3)*/ count(*)  from t2 cross join t3 order by t2.a1;
#explain basic select /*+use_nl(t2,t3)*/ count(*)  from t2 cross join t3 order by t2.a1;
select /*+parallel(6) use_nl(t2,t3)*/ count(*)  from t2 cross join t3 order by t2.a1;
#explain basic select /*+parallel(6) use_nl(t2,t3)*/ count(*)  from t2 cross join t3 order by t2.a1;

select /*+use_nl(t1,t2)*/ max(t2.a1) from t1 cross join t2;
#explain basic select /*+use_nl(t1,t2)*/ max(t2.a1) from t1 cross join t2;
select /*+parallel(6) use_nl(t1,t2)*/ max(t2.a1) from t1 cross join t2;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ max(t2.a1) from t1 cross join t2;

select /*+use_nl(t1,t2)*/ count(*)  from t1 cross join t2 order by t1.c1 desc;
#explain basic select /*+use_nl(t1,t2)*/ count(*)  from t1 cross join t2 order by t1.c1 desc;
select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1 cross join t2 order by t1.c1 desc;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1 cross join t2 order by t1.c1 desc;

select /*+use_nl(t1,t2)*/ count(*)  from t1 cross join t2  where t2.a1 >3 order by t1.c1 desc;
#explain basic select /*+use_nl(t1,t2)*/ count(*)  from t1 cross join t2  where t2.a1 >3 order by t1.c1 desc;
select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1 cross join t2  where t2.a1 >3 order by t1.c1 desc;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ count(*)  from t1 cross join t2  where t2.a1 >3 order by t1.c1 desc;

SELECT count(*)  FROM (SELECT * FROM t1,t2)a,(SELECT * FROM t2,t3)b ORDER BY c1 ASC,b1 desc;
#explain basic SELECT count(*)  FROM (SELECT * FROM t1,t2)a,(SELECT * FROM t2,t3)b ORDER BY c1 ASC,b1 desc;
SELECT /*+parallel(2) */ count(*)  FROM (SELECT /*+parallel(2) use_nl(t1,t2)*/ * FROM t1 CROSS JOIN t2)a CROSS join(SELECT /*+parallel(2) use_nl(t2,t3)*/ * FROM t2 CROSS JOIN t3)b ORDER BY c1 ASC,b1 desc;
#explain basic SELECT /*+parallel(2) */ count(*)  FROM (SELECT /*+parallel(2) use_nl(t1,t2)*/ * FROM t1 CROSS JOIN t2)a CROSS join(SELECT /*+parallel(2) use_nl(t2,t3)*/ * FROM t2 CROSS JOIN t3)b ORDER BY c1 ASC,b1 desc;
SELECT count(*)  FROM (SELECT * FROM t1,t2)a CROSS JOIN (SELECT * FROM t2,t3)b ORDER BY c1 asc,b1 desc;
#explain basic SELECT count(*)  FROM (SELECT * FROM t1,t2)a CROSS JOIN (SELECT * FROM t2,t3)b ORDER BY c1 asc,b1 desc;
SELECT /*+parallel(2) */ count(*)  FROM (SELECT /*+parallel(2) use_nl(t1,t2)*/ * FROM t1,t2)a CROSS JOIN (SELECT /*+parallel(2) use_nl(t2,t3)*/ * FROM t2,t3)b ORDER BY c1 ASC,b1 desc;
#explain basic SELECT /*+parallel(2) */ count(*)  FROM (SELECT /*+parallel(2) use_nl(t1,t2)*/ * FROM t1,t2)a CROSS JOIN (SELECT /*+parallel(2) use_nl(t2,t3)*/ * FROM t2,t3)b ORDER BY c1 ASC,b1 desc;

--echo #内连接
select /*+use_nl(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+use_nl(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1;
select /*+parallel(6) use_nl(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1;

select /*+use_nl(t2,t3)*/ * from t2,t3 where t2.a1=t3.b1 order by t2.a1;
#explain basic select /*+use_nl(t2,t3)*/ * from t2,t3 where t2.a1=t3.b1 order by t2.a1;
select /*+parallel(6) use_nl(t2,t3)*/ * from t2,t3 where t2.a1=t3.b1 order by t2.a1;
#explain basic select /*+parallel(6) use_nl(t2,t3)*/ * from t2,t3 where t2.a1=t3.b1 order by t2.a1;

select /*+use_nl(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1 desc;
#explain basic select /*+use_nl(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1 desc;
select /*+parallel(6) use_nl(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1 desc;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1 desc;

select /*+use_nl(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+use_nl(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t1.c1;
select /*+parallel(6) use_nl(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t1.c1;

select /*+use_nl(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t2.a2 desc;
#explain basic select /*+use_nl(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t2.a2 desc;
select /*+parallel(6) use_nl(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t2.a2 desc;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t2.a2 desc;

--echo  #left join
select /*+use_nl(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1;
#explain basic select /*+use_nl(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1;
select /*+parallel(6) use_nl(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1;

select /*+use_nl(t2,t3)*/ * from t2 left join t3 on t2.a1=t3.b1;
#explain basic select /*+use_nl(t2,t3)*/ * from t2 left join t3 on t2.a1=t3.b1;
select /*+parallel(6) use_nl(t2,t3)*/ * from t2 left join t3 on t2.a1=t3.b1;
#explain basic select /*+parallel(6) use_nl(t2,t3)*/ * from t2 left join t3 on t2.a1=t3.b1;

select /*+use_nl(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;
#explain basic select /*+use_nl(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;
select /*+parallel(6) use_nl(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;


select /*+use_nl(t1,t2)*/ count(*) from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;
#explain basic select /*+use_nl(t1,t2)*/ count(*) from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;
select /*+parallel(6) use_nl(t1,t2)*/ count(*) from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ count(*) from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;

--echo  #right join
select /*+use_nl(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1;
#explain basic select /*+use_nl(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1;
select /*+parallel(6) use_nl(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1;

select /*+use_nl(t2,t3)*/ * from t2 right join  t3 on t2.a1=t3.b1;
#explain basic select /*+use_nl(t2,t3)*/ * from t2 right join  t3 on t2.a1=t3.b1;
select /*+parallel(6) use_nl(t2,t3)*/ * from t2 right join  t3 on t2.a1=t3.b1;
#explain basic select /*+parallel(6) use_nl(t2,t3)*/ * from t2 right join  t3 on t2.a1=t3.b1;

select /*+use_nl(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 order by t2.a2 desc;
#explain basic select /*+use_nl(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 order by t2.a2 desc;
select /*+parallel(6) use_nl(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 order by t2.a2 desc;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 order by t2.a2 desc;

select /*+use_nl(t1,t2)*/ count(*) from t1 right join  t2 on t1.c1=t2.a1 ;
#explain basic select /*+use_nl(t1,t2)*/ count(*) from t1 right join  t2 on t1.c1=t2.a1 ;
select /*+parallel(6) use_nl(t1,t2)*/ count(*) from t1 right join  t2 on t1.c1=t2.a1 ;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ count(*) from t1 right join  t2 on t1.c1=t2.a1 ;

--echo  #full join
select /*+use_nl(t1,t2)*/ * from t1 full join  t2 on t1.c1=t2.a1;
#explain basic select /*+use_nl(t1,t2)*/ * from t1 full join  t2 on t1.c1=t2.a1;
select /*+parallel(6) use_nl(t1,t2)*/ * from t1 full join  t2 on t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1 full join  t2 on t1.c1=t2.a1 order by t1.c1;

select /*+use_nl(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+use_nl(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 order by t1.c1;
select /*+parallel(6) use_nl(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 order by t1.c1;

select /*+use_nl(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 where t1.c1 is null or t2.a1 is null order by t1.c1;
#explain basic select /*+use_nl(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 where t1.c1 is null or t2.a1 is null order by t1.c1;
select /*+parallel(6) use_nl(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 where t1.c1 is null or t2.a1 is null order by t1.c1;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 where t1.c1 is null or t2.a1 is null order by t1.c1;

--echo  #半连接
--echo  #semi join
select /*+use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
#explain basic select /*+use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 in(select a1 from t2);

select /*+use_nl(t1,t2)*/ * from t1  where c1 = any(select a1 from t2);
#explain basic select /*+use_nl(t1,t2)*/ * from t1  where c1 = any(select a1 from t2);
select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 = any(select a1 from t2);
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 = any(select a1 from t2);

--echo	#NEST LOOP JOIN
select /*+use_nl(t1,t2)*/distinct * from t1 inner join t2 on t1.c1=t2.a1 order by t1.c1;
select /*+parallel(6) use_nl(t1,t2)*/distinct * from t1 inner join t2 on t1.c1=t2.a1 order by t1.c1;

select /*+use_nl(t1,t2)*/ * from t1  where c2 >(select avg(a1) from t2);
select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 >(select avg(a1) from t2);

select /*+use_nl(t1,t2)*/ * from t1  where c1 <(select max(a1) from t2);
select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 <(select max(a1) from t2);

select /*+use_nl(t1,t2)*/ * from t1  where c1 >=(select min(a1) from t2);
select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 >=(select min(a1) from t2);

select /*+use_nl(t1,t2)*/ * from t1  where c1 <=(select min(a1) from t2);
select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 <=(select min(a1) from t2);

select /*+use_nl(t1,t2)*/ * from t1  where c1 !=(select avg(a1) from t2);
select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 !=(select avg(a1) from t2);

select /*+use_nl(t1,t2)*/ * from t1  where c1 <> (select avg(a1) from t2);
select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 <>(select avg(a1) from t2);

--echo  #反链接
--echo  #anti join
select /*+use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);
#explain basic select /*+use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);
select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);

select /*+use_nl(t1,t2)*/ * from t1  where c1 != all(select a1 from t2);
#explain basic select /*+use_nl(t1,t2)*/ * from t1  where c1 != all(select a1 from t2);
select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 != all(select a1 from t2);
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1  where c1 != all(select a1 from t2);

select /*+use_nl(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 where t2.a1 is null;
#explain basic select /*+use_nl(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 where t2.a1 is null;
select /*+parallel(6) use_nl(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 where t2.a1 is null;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 where t2.a1 is null;

select /*+use_nl(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 where t1.c1 is null;
#explain basic select /*+use_nl(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 where t1.c1 is null;
select /*+parallel(6) use_nl(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 where t1.c1 is null;
#explain basic select /*+parallel(6) use_nl(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 where t1.c1 is null;

--echo  #3表
select count(*)  from t1,t2,t3;
select  /*+parallel(6)*/ count(*)  from t1,t2,t3;

select count(*)  from t1,t2,t3 where b2 is not null;
select  /*+parallel(6)*/ count(*)  from t1,t2,t3 where b2 is not null;

select count(*)  from t1,t2,t3 where a2>1 and c1<3 order by c1 desc;
select  /*+parallel(6)*/ count(*)  from t1,t2,t3 where a2>1 and c1<3 order by c1 desc;

select count(*)  from t1 natural join t2 natural join t3;
