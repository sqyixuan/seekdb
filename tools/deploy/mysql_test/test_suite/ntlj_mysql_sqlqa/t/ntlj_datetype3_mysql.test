--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;


--echo  #datetime、timestamp
create table t1(c1 datetime,c2 timestamp);
create table t2(a1 datetime,a2 timestamp);
insert into t1 values('2018-10-01 08:08:00','2018-10-01 08:08:00'),
('2019-10-01 08:08:00','2019-10-01 08:08:00'),
('2020-10-01 08:08:00','2020-10-01 08:08:00'),
('2021-10-01 08:08:00','2021-10-01 08:08:00');

insert into t2 values('2017-10-01 08:08:00','2017-10-01 08:08:00'),
('2019-10-01 08:08:00','2019-10-01 08:08:00'),
('2020-10-01 08:08:00','2020-10-01 08:08:00'),
('2021-10-01 08:08:00','2021-10-01 08:08:00');

--source mysql_test/test_suite/ntlj_mysql_sqlqa/include/ntlj_datetype_mysql.inc

drop table t1;
drop table t2;



--echo  #varbinary、binary
create table t1(c1 varbinary(30),c2 binary(30));
create table t2(a1 varbinary(30),a2 binary(30));
insert into t1 values(101,101),(202,202),(303,303),(404,404),(505,505);
insert into t2 values(101,101),(202,202),(303,303),(505,505);
select * from t1;
select * from t2;

--source mysql_test/test_suite/ntlj_mysql_sqlqa/include/ntlj_datetype_mysql.inc

drop table t1;
drop table t2;





drop database db1;

