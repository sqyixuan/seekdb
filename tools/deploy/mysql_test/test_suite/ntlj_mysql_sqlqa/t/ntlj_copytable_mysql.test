#owner group : SQL-SQL2
#tags : nestedloopjoin
#description : 在复制表中测试NestedLoopJoin
#author : wb-zwc01059807


--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--echo  #复制表中使用Nestedloopjoin
create table t1(c1 int,c2 int);
create table t2(a1 int,a2 int);
create table t3(b1 int,b2 int);
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(4,6);
insert into t2 values(1,2);
insert into t2 values(2,2);
insert into t2 values(3,4);
insert into t2 values(5,7);
insert into t3 values(1,null);
insert into t3 values(null,1);
insert into t3 values(null,null);
create table tt1 as select * from t1;
create table tt2 as select * from t2;
create table tt3 as select * from t3;


--echo	#无条件指定连接中使用NEST LOOP JOIN
select /*+use_nl(tt1,tt2)*/ count(*) from tt1,tt2;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1,tt2;
select /*+use_nl(tt2,tt3)*/ count(*) from tt2,tt3;
#explain basic  select /*+use_nl(tt2,tt3)*/ count(*) from tt2,tt3;
select /*+use_nl(tt1,tt2)*/ count(*) from tt1 natural join tt2;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1 natural join tt2;
select /*+use_nl(tt2,tt3)*/ count(*) from tt2 natural join tt3;
#explain basic  select /*+use_nl(tt2,tt3)*/ count(*) from tt2 natural join tt3;
select /*+use_nl(tt1,tt2)*/ count(*) from tt1,tt2 where tt1.c2> tt2.a2;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1,tt2 where tt1.c2> tt2.a2;
select /*+use_nl(tt1,tt2)*/ count(*) from tt1,tt2 where tt1.c2> tt2.a2 order by tt1.c1 desc;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1,tt2 where tt1.c2> tt2.a2 order by tt1.c1 desc;


select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2;
select /*+use_nl(tt2,tt3)*/ count(*) from tt2 cross join tt3 order by tt2.a1;
#explain basic  select /*+use_nl(tt2,tt3)*/ count(*) from tt2 cross join tt3 order by tt2.a1;
select /*+use_nl(tt1,tt2)*/ max(tt2.a1) from tt1 cross join tt2;
#explain basic  select /*+use_nl(tt1,tt2)*/ max(tt2.a1) from tt1 cross join tt2;
select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2 order by tt1.c1 desc;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2 order by tt1.c1 desc;
select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2  where tt2.a1 >3 order by tt1.c1 desc;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2  where tt2.a1 >3 order by tt1.c1 desc;


--echo	#3表
select count(*) from tt1,tt2,tt3;
#explain basic  select count(*) from tt1,tt2,tt3;
select  /*+use_nl(tt1,tt2)*/ count(*)from tt1,tt2,tt3;
#explain basic  select  /*+use_nl(tt1,tt2)*/ count(*) from tt1,tt2,tt3;
select count(*) from tt1,tt2,tt3 where b2 is not null;
#explain basic  select count(*) from tt1,tt2,tt3 where b2 is not null;
select /*+use_nl(tt1,tt2)*/ count(*) from tt1,tt2,tt3 where b2 is not null;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1,tt2,tt3 where b2 is not null;
select count(c1+c2) from tt1,tt2,tt3 where b2 is not null;
#explain basic  select count(c1+c2) from tt1,tt2,tt3 where b2 is not null;
select /*+use_nl(tt1,tt2)*/ count(c1+c2) from tt1,tt2,tt3 where b2 is not null;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(c1+c2) from tt1,tt2,tt3 where b2 is not null;
select count(*) from tt1,tt2,tt3 where a2>1 and c1<3 order by c1 desc;
#explain basic  select count(*)from tt1,tt2,tt3 where a2>1 and c1<3 order by c1 desc;
select /*+use_nl(tt1,tt2)*/ count(*) from tt1,tt2,tt3 where a2>1 and c1<3 order by c1 desc;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1,tt2,tt3 where a2>1 and c1<3 order by c1 desc;
select /*+use_nl(tt1,tt2)*/ distinct * from tt1,tt2,tt3 where a2>1 and c1<3 order by c1, a1, a2, b1 desc;
#explain basic  select /*+use_nl(tt1,tt2)*/ distinct * from tt1,tt2,tt3 where a2>1 and c1<3 order by c1, a1, a2, b1 desc;
select /*+use_nl(tt1,tt2)*/ DISTINCT sum(c1+c2) from tt1,tt2,tt3 where a2>1 and c1<3 order by c1 desc;
#explain basic  select /*+use_nl(tt1,tt2)*/ DISTINCT sum(c1+c2) from tt1,tt2,tt3 where a2>1 and c1<3 order by c1 desc;


select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2 cross join tt3;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2 cross join tt3;
select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2 cross join tt3;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2 cross join tt3;
select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2 cross join tt3 where  tt3.b2 is null;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2 cross join tt3 where tt3.b2 is null;
select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2 cross join tt3 where tt1.c1>1 and tt2.a2 <5 order by tt1.c2 desc;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1 cross join tt2 cross join tt3 where tt1.c1>1 and tt2.a2 <5 order by tt1.c2 desc;
select /*+use_nl(tt1,tt2)*/ distinct * from tt1 cross join tt2 cross join tt3 where tt1.c1>1 and tt2.a2 <5 order by tt1.c2, a1, a2, b1 desc;
#explain basic  select /*+use_nl(tt1,tt2)*/ distinct * from tt1 cross join tt2 cross join tt3 where tt1.c1>1 and tt2.a2 <5 order by tt1.c2, a1, a2, b1 desc;


--echo	#内连接中使用NEST LOOP JOIN
select /*+use_nl(tt1,tt2)*/ * from tt1,tt2 where tt1.c1=tt2.a1;
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1,tt2 where tt1.c1=tt2.a1;
select /*+use_nl(tt2,tt3)*/ * from tt2,tt3 where tt2.a1=tt3.b1;
#explain basic  select /*+use_nl(tt2,tt3)*/ * from tt2,tt3 where tt2.a1=tt3.b1;
select /*+use_nl(tt1,tt2)*/ * from tt1,tt2 where tt1.c1=tt2.a1 order by tt1.c1 desc;
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1,tt2 where tt1.c1=tt2.a1 order by tt1.c1 desc;
select /*+use_nl(tt1,tt2)*/ distinct tt2.a2 from tt1,tt2 where tt1.c1=tt2.a1;
#explain basic  select /*+use_nl(tt1,tt2)*/ distinct tt2.a2 from tt1,tt2 where tt1.c1=tt2.a1;
select /*+use_nl(tt1,tt2)*/ distinct tt2.a2 from tt1,tt2 where tt1.c1=tt2.a1 order by tt2.a2 desc;
#explain basic  select /*+use_nl(tt1,tt2)*/ distinct tt2.a2 from tt1,tt2 where tt1.c1=tt2.a1 order by tt2.a2 desc;


--echo	#inner join
select /*+use_nl(tt1,tt2)*/ * from tt1 inner join  tt2 on tt1.c1=tt2.a1;
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1 inner join  tt2 on tt1.c1=tt2.a1;
select /*+use_nl(tt2,tt3)*/ * from tt2 inner join  tt3 on tt2.a1=tt3.b1;
#explain basic  select /*+use_nl(tt2,tt3)*/ * from tt2 inner join  tt3 on tt2.a1=tt3.b1;
select /*+use_nl(tt1,tt2)*/ * from tt1 inner join  tt2 on tt1.c1=tt2.a1 order by tt1.c1 desc;
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1 inner join  tt2 on tt1.c1=tt2.a1 order by tt1.c1 desc;


--echo	#外连接中使用NSET LOOP JOIN
--echo	#left join
select /*+use_nl(tt1,tt2)*/ * from tt1 left join  tt2 on tt1.c1=tt2.a1;
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1 left join  tt2 on tt1.c1=tt2.a1;
select /*+use_nl(tt2,tt3)*/ * from tt2 left join tt3 on tt2.a1=tt3.b1;
#explain basic  select /*+use_nl(tt2,tt3)*/ * from tt2 left join tt3 on tt2.a1=tt3.b1;
select /*+use_nl(tt1,tt2)*/ * from tt1 left join  tt2 on tt1.c1=tt2.a1 order by tt1.c2 desc;
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1 left join  tt2 on tt1.c1=tt2.a1 order by tt1.c2 desc;
select /*+use_nl(tt1,tt2)*/ count(*) from tt1 left join  tt2 on tt1.c1=tt2.a1 order by tt1.c2 desc;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1 left join  tt2 on tt1.c1=tt2.a1 order by tt1.c2 desc;
select * from (select /*+use_nl(tt1,tt2)*/ * from tt1 left join tt2 on tt1.c1=tt2.a1)a ,(select /*+use_nl(tt2,tt3)*/ * from tt2 left join tt3 on tt2.a1=tt3.b1)b  where a.c1=b.a1;
#explain basic  select * from (select /*+use_nl(tt1,tt2)*/ * from tt1 left join tt2 on tt1.c1=tt2.a1)a ,(select /*+use_nl(tt2,tt3)*/ * from tt2 left join tt3 on tt2.a1=tt3.b1)b  where a.c1=b.a1;

--echo	#right join
select /*+use_nl(tt1,tt2)*/ * from tt1 right join  tt2 on tt1.c1=tt2.a1;
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1 right join  tt2 on tt1.c1=tt2.a1;
select /*+use_nl(tt2,tt3)*/ * from tt2 right join  tt3 on tt2.a1=tt3.b1;
#explain basic  select /*+use_nl(tt2,tt3)*/ * from tt2 right join  tt3 on tt2.a1=tt3.b1;
select /*+use_nl(tt1,tt2)*/ * from tt1 right join  tt2 on tt1.c1=tt2.a1 order by tt2.a2 desc;
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1 right join  tt2 on tt1.c1=tt2.a1 order by tt2.a2 desc;
select /*+use_nl(tt1,tt2)*/ count(*) from tt1 right join  tt2 on tt1.c1=tt2.a1 ;
#explain basic  select /*+use_nl(tt1,tt2)*/ count(*) from tt1 right join  tt2 on tt1.c1=tt2.a1 ;


select /*+use_nl(tt1,tt2)*/ * from tt1 full join  tt2 on tt1.c1=tt2.a1;
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1 full join  tt2 on tt1.c1=tt2.a1;


--echo	#半连接
--echo	#SEMI JOIN
--echo	#转化为SUBPLAN FILTER
select /*+use_nl(tt1,tt2)*/ * from tt1  where EXISTS(select 1 from tt2 where a1=a2);
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1  where EXISTS(select 1 from tt2 where a1=a2);

--echo	#NESTED LOOP SEMI JOIN
select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 in(select a1 from tt2);
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 in(select a1 from tt2);
select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 = any(select a1 from tt2);
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 = any(select a1 from tt2);

--echo	#NEST LOOP JOIN
select /*+use_nl(tt1,tt2)*/distinct * from tt1 join tt2 on tt1.c1=tt2.a1;
#explain basic  select /*+use_nl(tt1,tt2)*/ distinct * from tt1 join tt2 on tt1.c1=tt2.a1;
select /*+use_nl(tt1,tt2)*/ * from tt1  where c2 >(select avg(a1) from tt2);
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 >(select avg(a1) from tt2);
select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 <(select max(a1) from tt2);
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 <(select max(a1) from tt2);
select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 >=(select min(a1) from tt2);
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 >=(select min(a1) from tt2);
select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 <=(select min(a1) from tt2);
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 <=(select min(a1) from tt2);
select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 !=(select avg(a1) from tt2);
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 !=(select avg(a1) from tt2);
select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 <> (select avg(a1) from tt2);
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 <>(select avg(a1) from tt2);

--echo	#反链接
--echo	#ANTI JOIN
--echo	#转化为SUBPLAN FILTER
select /*+use_nl(tt1,tt2)*/ * from tt1  where not EXISTS(select 1 from tt2 where a1=a2);
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1  where not EXISTS(select 1 from tt2 where a1=a2);

--echo	#NESTED-LOOP ANTI JOIN
select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 not in(select a1 from tt2);
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 not in(select a1 from tt2);
select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 != all(select a1 from tt2);
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 != all(select a1 from tt2);
select /*+use_nl(tt1,tt2)*/ * from tt1 left join  tt2 on tt1.c1=tt2.a1 where tt2.a1 is null;
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1 left join  tt2 on tt1.c1=tt2.a1 where tt2.a1 is null;
select /*+use_nl(tt1,tt2)*/ * from tt1 right join  tt2 on tt1.c1=tt2.a1 where tt1.c1 is null;
#explain basic  select /*+use_nl(tt1,tt2)*/ * from tt1 right join  tt2 on tt1.c1=tt2.a1 where tt1.c1 is null;




--echo	#INSERT
insert into tt1 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 in(select a1 from tt2);
#explain basic  insert into tt1 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 in(select a1 from tt2);
select count(*) from tt1;


insert into tt2 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 = any(select a1 from tt2);
#explain basic  insert into tt2 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 = any(select a1 from tt2);
select count(*) from tt2;

insert into tt2 select /*+use_nl(tt1,tt2)*/ * from tt1  where c2 >(select avg(a1) from tt2);
#explain basic  insert into tt2 select /*+use_nl(tt1,tt2)*/ * from tt1  where c2 >(select avg(a1) from tt2);
select count(*) from tt2;

insert into tt2 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 <(select max(a1) from tt2);
#explain basic  insert into tt2 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 <(select max(a1) from tt2);
select count(*) from tt2;

insert into tt2 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 >=(select min(a1) from tt2);
#explain basic  insert into tt2 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 >=(select min(a1) from tt2);
select count(*) from tt2;


insert into tt1 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 <=(select min(a1) from tt2);
#explain basic  insert into tt1 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 <=(select min(a1) from tt2);
select count(*) from tt1;


insert into tt1 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 !=(select avg(a1) from tt2);
#explain basic  insert into tt1 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 !=(select avg(a1) from tt2);
select count(*) from tt1;


insert into tt1 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 <> (select avg(a1) from tt2);
#explain basic  insert into tt1 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 <> (select avg(a1) from tt2);
select count(*) from tt1;


insert into tt2 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 not in(select a1 from tt2);
#explain basic  insert into tt2 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 not in(select a1 from tt2);
select count(*) from tt2;


insert into tt1 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 != all(select a1 from tt2);
#explain basic  insert into tt1 select /*+use_nl(tt1,tt2)*/ * from tt1  where c1 != all(select a1 from tt2);
select count(*) from tt1;



--echo	#DELETE
delete from tt1 where c1 = (select /*+use_nl(tt1,tt2)*/ max(c1) from tt1  where c1 in(select a1 from tt2));
#explain basic  delete from tt1 where c1 = (select /*+use_nl(tt1,tt2)*/ max(c1) from tt1  where c1 in(select a1 from tt2));
select count(*) from tt1;

delete from tt1 where c1 = (select /*+use_nl(tt1,tt2)*/ min(c1) from tt1  where c2 >(select avg(a1) from tt2));
#explain basic  delete from tt1 where c1 = (select /*+use_nl(tt1,tt2)*/ min(c1) from tt1  where c2 >(select avg(a1) from tt2));
select count(*) from tt1;

drop table t1;
drop table t2;
drop table t3;
drop table tt1;
drop table tt2;
drop table tt3;




DROP database db1;



