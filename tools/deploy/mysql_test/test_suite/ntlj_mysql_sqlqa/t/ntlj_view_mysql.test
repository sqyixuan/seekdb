#owner : xiaoyi.xy
#owner group : SQL-SQL2
#tags : nestedloopjoin
#description : 在视图中测试NestedLoopJoin
#author : wb-zwc01059807


--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--echo  #测试在视图中使用nestedloopjoin算子

create table t1(c1 int,c2 int);
create table t2(a1 int,a2 int);
create table t3(b1 int,b2 int);
insert into t1 values(4,2);
insert into t1 values(3,8);
insert into t1 values(5,3);
insert into t1 values(7,9);
insert into t1 values(9,10);
insert into t1 values(11,2);
insert into t2 values(1,3);
insert into t2 values(2,5);
insert into t2 values(5,4);
insert into t2 values(7,3);
insert into t2 values(9,8);
insert into t2 values(11,1);
insert into t2 values(13,6);
insert into t3 values(2,null);
insert into t3 values(5,3);
insert into t3 values(null,6);
insert into t3 values(null,null);
create view v_t1 as select * from t1;
create view v_t2 as select * from t2;
create view v_t3 as select * from t3;

--echo  #无条件连接中使用nestedloopjoin
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2;
select /*+use_nl(v_t2,v_t3)*/ count(*) from v_t2,v_t3;
#explain basic  select /*+use_nl(v_t2,v_t3)*/ count(*) from v_t2,v_t3;
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 natural join v_t2;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 natural join v_t2;
select /*+use_nl(v_t2,v_t3)*/ count(*) from v_t2 natural join v_t3;
#explain basic  select /*+use_nl(v_t2,v_t3)*/ count(*) from v_t2 natural join v_t3;
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2 where v_t1.c2> v_t2.a2;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2 where v_t1.c2> v_t2.a2;

select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2 where v_t1.c2> v_t2.a2 order by v_t1.c1 desc;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2 where v_t1.c2> v_t2.a2 order by v_t1.c1 desc;


select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2;
select /*+parallel(6) use_nl(v_t2,v_t3)*/ count(*) from v_t2,v_t3;
#explain basic  select /*+parallel(6) use_nl(v_t2,v_t3)*/ count(*) from v_t2,v_t3;
select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 natural join v_t2;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 natural join v_t2;
select /*+parallel(6) use_nl(v_t2,v_t3)*/ count(*) from v_t2 natural join v_t3;
#explain basic  select /*+parallel(6) use_nl(v_t2,v_t3)*/ count(*) from v_t2 natural join v_t3;
select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2 where v_t1.c2> v_t2.a2;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2 where v_t1.c2> v_t2.a2;

select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2 where v_t1.c2> v_t2.a2 order by v_t1.c1 desc;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2 where v_t1.c2> v_t2.a2 order by v_t1.c1 desc;



select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2;
select /*+use_nl(v_t2,v_t3)*/ count(*) from v_t2 cross join v_t3 order by v_t2.a1;
#explain basic  select /*+use_nl(v_t2,v_t3)*/ count(*) from v_t2 cross join v_t3 order by v_t2.a1;
select /*+use_nl(v_t1,v_t2)*/ max(v_t2.a1) from v_t1 cross join v_t2;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ max(v_t2.a1) from v_t1 cross join v_t2;
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 order by v_t1.c1 desc;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 order by v_t1.c1 desc;

select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2  where v_t2.a1 >3 order by v_t1.c1 desc;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2  where v_t2.a1 >3 order by v_t1.c1 desc;



select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2;
select /*+parallel(6) use_nl(v_t2,v_t3)*/ count(*) from v_t2 cross join v_t3 order by v_t2.a1;
#explain basic  select /*+parallel(6) use_nl(v_t2,v_t3)*/ count(*) from v_t2 cross join v_t3 order by v_t2.a1;
select /*+parallel(6) use_nl(v_t1,v_t2)*/ max(v_t2.a1) from v_t1 cross join v_t2;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ max(v_t2.a1) from v_t1 cross join v_t2;
select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 order by v_t1.c1 desc;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 order by v_t1.c1 desc;

select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2  where v_t2.a1 >3 order by v_t1.c1 desc;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2  where v_t2.a1 >3 order by v_t1.c1 desc;


--echo	#3表
select count(*) from v_t1,v_t2,v_t3;
#explain basic  select count(*) from v_t1,v_t2,v_t3;
select  /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2,v_t3;
#explain basic  select  /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2,v_t3;
select count(*) from v_t1,v_t2,v_t3 where b2 is not null;
#explain basic  select count(*) from v_t1,v_t2,v_t3 where b2 is not null;
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2,v_t3 where b2 is not null;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2,v_t3 where b2 is not null;
select count(c1+c2) from v_t1,v_t2,v_t3 where b2 is not null;
#explain basic  select count(c1+c2) from v_t1,v_t2,v_t3 where b2 is not null;
select /*+use_nl(v_t1,v_t2)*/ count(c1+c2) from v_t1,v_t2,v_t3 where b2 is not null;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(c1+c2) from v_t1,v_t2,v_t3 where b2 is not null;
select count(*) from v_t1,v_t2,v_t3 where a2>1 and c1<3 order by c1 desc;
#explain basic  select sum(c1+c2) from v_t1,v_t2,v_t3 where a2>1 and c1<3 order by c1 desc;

select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2,v_t3 where a2>1 and c1<3 order by c1 desc;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ sum(c1+c2) from v_t1,v_t2,v_t3 where a2>1 and c1<3 order by c1 desc;


select /*+parallel(6)*/ count(*) from v_t1,v_t2,v_t3;
#explain basic  select /*+parallel(6)*/ count(*) from v_t1,v_t2,v_t3;
select  /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2,v_t3;
#explain basic  select  /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2,v_t3;
select /*+parallel(6)*/ count(*) from v_t1,v_t2,v_t3 where b2 is not null;
#explain basic  select /*+parallel(6)*/ count(*) from v_t1,v_t2,v_t3 where b2 is not null;
select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2,v_t3 where b2 is not null;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2,v_t3 where b2 is not null;
select /*+parallel(6)*/ count(c1+c2) from v_t1,v_t2,v_t3 where b2 is not null;
#explain basic  select /*+parallel(6)*/ count(c1+c2) from v_t1,v_t2,v_t3 where b2 is not null;
select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(c1+c2) from v_t1,v_t2,v_t3 where b2 is not null;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(c1+c2) from v_t1,v_t2,v_t3 where b2 is not null;
select  /*+parallel(6)*/  count(*) from v_t1,v_t2,v_t3 where a2>1 and c1<3 order by c1 desc;
#explain basic  select  /*+parallel(6)*/  sum(c1+c2) from v_t1,v_t2,v_t3 where a2>1 and c1<3 order by c1 desc;

select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1,v_t2,v_t3 where a2>1 and c1<3 order by c1 desc;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ sum(c1+c2) from v_t1,v_t2,v_t3 where a2>1 and c1<3 order by c1 desc;


select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3;
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3;
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3 where  v_t3.b2 is null;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3 where v_t3.b2 is null;

select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3 where v_t1.c1>1 and v_t2.a2 <5 order by v_t1.c2 desc;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3 where v_t1.c1>1 and v_t2.a2 <5 order by v_t1.c2 desc;

select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3;
select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3;
select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3 where  v_t3.b2 is null;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3 where v_t3.b2 is null;

select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3 where v_t1.c1>1 and v_t2.a2 <5 order by v_t1.c2 desc;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 cross join v_t2 cross join v_t3 where v_t1.c1>1 and v_t2.a2 <5 order by v_t1.c2 desc;

--echo	#内连接中使用NEST LOOP JOIN
select /*+use_nl(v_t1,v_t2)*/ * from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t2.a1;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ * from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by  v_t2.a1;
select /*+use_nl(v_t2,v_t3)*/ * from v_t2,v_t3 where v_t2.a1=v_t3.b1 order by v_t2.a1;
#explain basic  select /*+use_nl(v_t2,v_t3)*/ * from v_t2,v_t3 where v_t2.a1=v_t3.b1 order by v_t2.a1;
select /*+use_nl(v_t1,v_t2)*/ * from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t1.c1 desc;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ * from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t1.c1 desc;
select /*+use_nl(v_t1,v_t2)*/ distinct v_t2.a2 from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t2.a1;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ distinct v_t2.a2 from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t2.a1;

select /*+use_nl(v_t1,v_t2)*/ distinct v_t2.a2 from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t2.a2 desc;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ distinct v_t2.a2 from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t2.a2 desc;


select /*+parallel(6) use_nl(v_t1,v_t2)*/ * from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t2.a1;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ * from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t2.a1;
select /*+parallel(6) use_nl(v_t2,v_t3)*/ * from v_t2,v_t3 where v_t2.a1=v_t3.b1 order by v_t2.a1;
#explain basic  select /*+parallel(6) use_nl(v_t2,v_t3)*/ * from v_t2,v_t3 where v_t2.a1=v_t3.b1 order by v_t2.a1;
select /*+parallel(6) use_nl(v_t1,v_t2)*/ * from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t1.c1 desc;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ * from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t1.c1 desc;
select /*+parallel(6) use_nl(v_t1,v_t2)*/ distinct v_t2.a2 from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t2.a1;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ distinct v_t2.a2 from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t2.a1;

select /*+parallel(6) use_nl(v_t1,v_t2)*/ distinct v_t2.a2 from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t2.a2 desc;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ distinct v_t2.a2 from v_t1,v_t2 where v_t1.c1=v_t2.a1 order by v_t2.a2 desc;


--echo	#left join
select /*+use_nl(v_t1,v_t2)*/ * from v_t1 left join  v_t2 on v_t1.c1=v_t2.a1 order by v_t2.a1;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ * from v_t1 left join  v_t2 on v_t1.c1=v_t2.a1 order by v_t2.a1;
select /*+use_nl(v_t2,v_t3)*/ * from v_t2 left join v_t3 on v_t2.a1=v_t3.b1 order by v_t2.a1;
#explain basic  select /*+use_nl(v_t2,v_t3)*/ * from v_t2 left join v_t3 on v_t2.a1=v_t3.b1 order by v_t2.a1;
select /*+use_nl(v_t1,v_t2)*/ * from v_t1 left join  v_t2 on v_t1.c1=v_t2.a1 order by v_t1.c2 desc;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ * from v_t1 left join  v_t2 on v_t1.c1=v_t2.a1 order by v_t1.c2 desc;

select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 left join  v_t2 on v_t1.c1=v_t2.a1 order by v_t1.c2 desc;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 left join  v_t2 on v_t1.c1=v_t2.a1 order by v_t1.c2 desc;

select /*+parallel(6) use_nl(v_t1,v_t2)*/ * from v_t1 left join  v_t2 on v_t1.c1=v_t2.a1 order by v_t2.a1;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ * from v_t1 left join  v_t2 on v_t1.c1=v_t2.a1 order by v_t2.a1;
select /*+parallel(6) use_nl(v_t2,v_t3)*/ * from v_t2 left join v_t3 on v_t2.a1=v_t3.b1 order by v_t2.a1;
#explain basic  select /*+parallel(6) use_nl(v_t2,v_t3)*/ * from v_t2 left join v_t3 on v_t2.a1=v_t3.b1 order by v_t2.a1;
select /*+parallel(6) use_nl(v_t1,v_t2)*/ * from v_t1 left join  v_t2 on v_t1.c1=v_t2.a1 order by v_t1.c2 desc;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ * from v_t1 left join  v_t2 on v_t1.c1=v_t2.a1 order by v_t1.c2 desc;

select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 left join  v_t2 on v_t1.c1=v_t2.a1 order by v_t1.c2 desc;
#explain basic  select /*+parallel(6) use_nl(v_t1,v_t2)*/ count(*) from v_t1 left join  v_t2 on v_t1.c1=v_t2.a1 order by v_t1.c2 desc;


--echo	#right join
select /*+use_nl(v_t1,v_t2)*/ * from v_t1 right join  v_t2 on v_t1.c1=v_t2.a1 order by v_t2.a1;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ * from v_t1 right join  v_t2 on v_t1.c1=v_t2.a1 order by v_t2.a1;
select /*+use_nl(v_t2,v_t3)*/ * from v_t2 right join  v_t3 on v_t2.a1=v_t3.b1 order by v_t2.a1;
#explain basic  select /*+use_nl(v_t2,v_t3)*/ * from v_t2 right join  v_t3 on v_t2.a1=v_t3.b1 order by v_t2.a1;
select /*+use_nl(v_t1,v_t2)*/ * from v_t1 right join  v_t2 on v_t1.c1=v_t2.a1 order by v_t2.a2 desc;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ * from v_t1 right join  v_t2 on v_t1.c1=v_t2.a1 order by v_t2.a2 desc;
select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 right join  v_t2 on v_t1.c1=v_t2.a1 order by v_t2.a1;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ count(*) from v_t1 right join  v_t2 on v_t1.c1=v_t2.a1  order by v_t2.a1;

select /*+use_nl(v_t1,v_t2)*/ * from v_t1 right join  v_t2 on v_t1.c1=v_t2.a1 where v_t2.a2 is not null or v_t2.a2 >1   order by v_t2.a2 desc;
#explain basic  select /*+use_nl(v_t1,v_t2)*/ * from v_t1 right join  v_t2 on v_t1.c1=v_t2.a1 where v_t2.a2 is not null or v_t2.a2 >1   order by v_t2.a2 desc;

select /*+parallel(6)  use_nl(v_t1,v_t2)*/ * from v_t1 right join  v_t2 on v_t1.c1=v_t2.a1 order by v_t2.a1;
#explain basic  select /*+parallel(6)  use_nl(v_t1,v_t2)*/ * from v_t1 right join  v_t2 on v_t1.c1=v_t2.a1 order by v_t2.a1;
select /*+parallel(6)  use_nl(v_t2,v_t3)*/ * from v_t2 right join  v_t3 on v_t2.a1=v_t3.b1 order by v_t2.a1;
