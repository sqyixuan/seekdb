--echo json_table

--error 0,1051,942
DROP TABLE json_test1;
CREATE TABLE json_test1(
	c1 DECIMAL(38,0), 
  c2 VARCHAR(100) ,
  c3 json not null,
  c4 json,
  c5 VARCHAR(100));
  
