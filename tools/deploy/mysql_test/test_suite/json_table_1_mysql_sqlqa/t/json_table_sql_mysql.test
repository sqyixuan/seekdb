--echo mysql_json_table-4-4 mysql_json_table-5 表类型
--error 0,1051,942
DROP TABLE json_test1;
CREATE TABLE json_test1(
	c1 int PRIMARY KEY, 
  c2 VARCHAR(100) ,
  c3 json not null,
  c4 json,
  c5 VARCHAR(100))
  PARTITION BY RANGE (c1)
  (PARTITION less_3 VALUES less than (3),
  PARTITION b_3_8 VALUES less than (8),
  PARTITION b_8_2000 VALUES less than (2000),
  PARTITION greater_2000 VALUES less than MAXVALUE);
  
insert into json_test1 values(1,12,'12','"2022-10-10"',null);
insert into json_test1 values(2,'{"a":[1,2]}','12','"2022-10-10"','123.12');
insert into json_test1 values(3,'"a"','[{"MailID":2,"AttachFlag":"8"},{"MailID":3,"AttachFlag":"9"}]',null,'"sadf"');
insert into json_test1 values(4,'[1,"asdfasd1",{"a":12321564654},{"a":[1,2]},[]]','[1,2,{},{"a":[1,2]},[]]',null,'[1,"a",[],{}]');
insert into json_test1 values(5,'{"a":[1,2]}','[1,"asdfasd1",{"a":12321564654},{"a":[1,2]},[]]',null,'{"a":[1,2]}');
insert into json_test1 values(6,'true','true',null,'false');
insert into json_test1 values(7777,'[]','[{"MailID":22,"AttachFlag":"88"},{"MailID":33,"AttachFlag":"99"}]',null,'false');

