a2 varchar(100) PATH '$[1]' default '0' ON EMPTY default '1' ON ERROR,
a3 varchar(100) PATH '$[2]' default '0' ON EMPTY default '1' ON ERROR,
a4 varchar(100) PATH '$[2]' default '0' ON EMPTY default '1' ON ERROR,
a5 varchar(100) PATH '$[0]')) as t;

select * from json_test1;

insert into json_test1(c1,c3,c5) select t.* from json_test1 ,JSON_TABLE(json_test1.c3,"$[*]" COLUMNS(a1 FOR ORDINALITY,
a3 varchar(100) PATH '$[2]' default '0' ON EMPTY default '1' ON ERROR,
a5 varchar(100) PATH '$[0]')) as t;

select * from json_test1;

delete from json_test1;

insert into json_test1 select t.a1,t.a2,t.a3,t.a4,t.a1 from json_test2 t2,JSON_TABLE(t2.c3,"$[*]" COLUMNS(
a2 varchar(100) PATH '$[1]' default '0' ON EMPTY default '1' ON ERROR,
a3 varchar(100) PATH '$[2]' default '0' ON EMPTY default '1' ON ERROR,
a4 varchar(100) PATH '$[2]' default '0' ON EMPTY default '1' ON ERROR,
a5 varchar(100) PATH '$[0]' ,
a1 FOR ORDINALITY)) as t;

select * from json_test1;

