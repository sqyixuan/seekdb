update json_test1 t1 INNER JOIN JSON_TABLE('[{"MailID":2,"AttachFlag":"8"},{"MailID":3,"AttachFlag":"9"}]','$[*]' COLUMNS(a FOR ORDINALITY ,
 b VARCHAR(200) PATH "$.MailID" default '9999' ON EMPTY default '8888' ON ERROR,
 c VARCHAR(200) PATH "$.AttachFlag" ,
 d VARCHAR(200) EXISTS PATH '$.b[1]',
 NESTED PATH "$" COLUMNS(aa FOR ORDINALITY, bb varchar(100) PATH "$" default '99999' ON EMPTY default '88888' ON ERROR,cc int EXISTS PATH '$[0]' ))) as t  on t1.c1 = t.b
 set t1.c2 = t.c;
select * from json_test1;

update json_test1 t1 INNER JOIN JSON_TABLE(t1.c3,'$[*]' COLUMNS(a FOR ORDINALITY ,
 b VARCHAR(200) PATH "$.MailID" default '9999' ON EMPTY default '8888' ON ERROR,
 c VARCHAR(200) PATH "$.AttachFlag" ,
 d VARCHAR(200) EXISTS PATH '$.b[1]',
 NESTED PATH "$" COLUMNS(aa FOR ORDINALITY, bb varchar(100) PATH "$" default '99999' ON EMPTY default '88888' ON ERROR,cc int EXISTS PATH '$[0]' ))) as t  on t1.c1 = t.b
 set t1.c2 = t.bb;
select * from json_test1;

update json_test1 set c2 = (select t.a from json_test2 t2, JSON_TABLE(t2.c2,'$[*]' COLUMNS(a FOR ORDINALITY ,
 b VARCHAR(200) PATH "$.b[1]" default '0' ON EMPTY default '1' ON ERROR,
 c VARCHAR(200) EXISTS PATH '$.b[1]')) as t  where t.a = 1)
  where c1 = 1;
select * from json_test1;
update json_test1 t1 INNER JOIN JSON_TABLE(t1.c3,'$[*]' COLUMNS(a FOR ORDINALITY ,
 b VARCHAR(200) PATH "$.a[1]" default '0' ON EMPTY default '1' ON ERROR,
 c VARCHAR(200) EXISTS PATH '$.b[1]')) as t  on t1.c1 = t.a
 set t1.c2 = t.b;
select * from json_test1;

update json_test1 t1 INNER JOIN JSON_TABLE(t1.c3,'$[*]' COLUMNS(a FOR ORDINALITY ,
 b int PATH "$.MailID" default '0' ON EMPTY default '1' ON ERROR,
 c VARCHAR(200) PATH "$.AttachFlag" ,
 d VARCHAR(200) EXISTS PATH '$.b[1]')) as t  on t1.c1 = t.b
 set t1.c2 = t.c;
