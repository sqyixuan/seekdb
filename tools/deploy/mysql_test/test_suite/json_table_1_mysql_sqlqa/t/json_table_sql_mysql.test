--echo mysql_json_table-4-4 select group by cte

select avg(t.a) from json_test1 t1 INNER JOIN JSON_TABLE(t1.c3,'$[*]' COLUMNS(a FOR ORDINALITY ,
 b VARCHAR(200) PATH "$.b[1]" default '0' ON EMPTY default '1' ON ERROR,
 c VARCHAR(200) EXISTS PATH '$.b[1]')) as t  on t1.c1 = t.a
 ;

SELECT max(t.a2 ) FROM json_test1 t1, JSON_TABLE(t1.c3, '$' 
  COLUMNS ( a FOR ORDINALITY ,
  a1 json PATH '$.MailID' DEFAULT '10000' ON EMPTY DEFAULT '20000' ON ERROR,
a2 json PATH '$' DEFAULT '110000' ON EMPTY DEFAULT '220000' ON ERROR,
a3 VARCHAR(200) EXISTS PATH '$[1]',
a4 json PATH '$[*]')) AS t  
group by t.a2,t.a3,t1.c3
having t.a2 > 0 and t.a2 like '%1%'
order by t.a3;

SELECT max(t.a2 ) FROM json_test1 t1, JSON_TABLE('[1,"aaaa汉",true,null,[1,"aaaa汉",true,null],{"a": true, "b": [null,"汉字"]}]', '$[*]' 
  COLUMNS ( a2 json PATH '$' DEFAULT '110000' ON EMPTY DEFAULT '220000' ON ERROR)) AS t  
group by t.a2;


WITH json_cte AS (
    SELECT t1.c1,t.* FROM json_test1 t1, JSON_TABLE(t1.c3, '$' 
  COLUMNS ( a FOR ORDINALITY ,
  a1 json PATH '$[0]' DEFAULT '10000' ON EMPTY DEFAULT '20000' ON ERROR,
a2 json PATH '$[0]' DEFAULT '110000' ON EMPTY DEFAULT '220000' ON ERROR,
a3 VARCHAR(200) EXISTS PATH '$[1]',
a4 json PATH '$[0]')) AS t
) SELECT tt.* from json_cte t1,JSON_TABLE(t1.a1, '$' 
  COLUMNS ( a FOR ORDINALITY ,
  a1 json PATH '$[0]' DEFAULT '10000' ON EMPTY DEFAULT '20000' ON ERROR,
a2 json PATH '$[0]' DEFAULT '110000' ON EMPTY DEFAULT '220000' ON ERROR,
a3 VARCHAR(200) EXISTS PATH '$[1]',
a4 json PATH '$[0]')) AS tt;

WITH json_cte AS (
    SELECT t1.* FROM json_test1 t1
) SELECT tt.* from json_cte t1,JSON_TABLE('[1,"aaaa汉",true,null,[1,"aaaa汉",true,null],{"a": true, "b": [null,"汉字"]}]', '$[*]' 
  COLUMNS ( a FOR ORDINALITY ,
  a1 json PATH '$[0]' DEFAULT '10000' ON EMPTY DEFAULT '20000' ON ERROR,
a2 json PATH '$[0]' DEFAULT '110000' ON EMPTY DEFAULT '220000' ON ERROR,
a3 VARCHAR(200) EXISTS PATH '$[1]',
a4 json PATH '$[0]')) AS tt order by tt.a;

