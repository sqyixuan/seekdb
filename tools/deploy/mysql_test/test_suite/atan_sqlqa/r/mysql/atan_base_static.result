drop database if exists luofan_db;
drop table if exists caitest;
create database luofan_db;
use luofan_db;
create table caitest (v_test varchar(200));
insert into caitest values('2125');
select atan(v_test) from caitest;
atan(v_test)
1.5703257385943403
#参数个数
select atan('125') from  dual;
atan('125')
1.56279649745501
select atan(power(10,3)) from  dual;
atan(power(10,3))
1.5697963271282298
#验证非数值参数
select atan('aa123') from  dual;
atan('aa123')
0
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'aa123'
#varchar类型
drop table caitest;
create  table caitest(v_test varchar(200));
insert into caitest values('2125');
select atan(v_test) from caitest;
atan(v_test)
1.5703257385943403
#date/interval类型
select atan('20191001') from  dual;
atan('20191001')
1.570796277267882
select atan('2019-10-01') from  dual;
atan('2019-10-01')
1.5703010321350512
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: '2019-10-01'
select atan('2019:10:01') from  dual;
atan('2019:10:01')
1.5703010321350512
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: '2019:10:01'
select atan('20191001030204') from  dual;
atan('20191001030204')
1.570796326794847
select atan('2019-10-01 03:02:05') from  dual;
atan('2019-10-01 03:02:05')
1.5703010321350512
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: '2019-10-01 03:02:05'
#边界值
select atan(-1.0e-130) from dual;
atan(-1.0e-130)
-1e-130
select atan(-1.0e-131) from dual;
atan(-1.0e-131)
-1e-131
select atan(1.0e+125) from dual;
atan(1.0e+125)
1.5707963267948966
select atan(1.0e+126) from dual;
atan(1.0e+126)
1.5707963267948966
#blob类型
drop table caitest;
create table caitest(v_test blob);
insert into caitest values('123');
select atan(v_test)  from caitest;
atan(v_test)
1.5626664246149526
#函数嵌套(sum,modd等)
SELECT atan(MOD(11,4)) FROM DUAL;
atan(MOD(11,4))
1.2490457723982544
SELECT atan(MOD(11,11)) FROM DUAL;
atan(MOD(11,11))
0
SELECT atan(round(11,11)) FROM DUAL;
atan(round(11,11))
1.4801364395941514
SELECT atan(round(11,3)) FROM DUAL;
atan(round(11,3))
1.4801364395941514
SELECT sum(atan(11)-100) FROM DUAL;
sum(atan(11)-100)
-98.51986356040585
SELECT MOD((sum(atan(11)-100)),50) FROM DUAL;
MOD((sum(atan(11)-100)),50)
-48.51986356040585
SELECT atan(1/POWER(10,200)) FROM DUAL;
atan(1/POWER(10,200))
1e-200
SELECT atan(-1/POWER(10,200)) FROM DUAL;
atan(-1/POWER(10,200))
-1e-200
#静态sql(函数嵌套，dml等)
drop table caitest;
create table caitest(v_test varchar(30),v_test1 varchar(30));
insert into caitest values('-20.2','0');
select atan(v_test),atan(v_test1)  from caitest;
atan(v_test)	atan(v_test1)
-1.5213317581933052	0
insert into caitest values('-20.2','22');
select atan(v_test),atan(v_test1)  from caitest;
atan(v_test)	atan(v_test1)
-1.5213317581933052	0
-1.5213317581933052	1.5253730473733196
#存在非数字型参数
insert into caitest values('-20.2','aa12');
select atan(v_test),atan(v_test1)  from caitest;
atan(v_test)	atan(v_test1)
-1.5213317581933052	0
-1.5213317581933052	1.5253730473733196
-1.5213317581933052	0
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'aa12'
delete  from caitest where v_test1='aa12';
#group by having
insert into caitest values('-20.2','0');
insert into caitest values('-20.2','22');
select v_test,v_test1,atan(v_test1) from caitest group by v_test,v_test1 having atan(v_test1)>=0;
v_test	v_test1	atan(v_test1)
-20.2	0	0
-20.2	22	1.5253730473733196
insert into caitest values('-20.2','0');
insert into caitest values('-20.2','aa12');
select v_test,v_test1,atan(v_test1) from caitest group by v_test,v_test1 having atan(v_test1)>=0;
v_test	v_test1	atan(v_test1)
-20.2	0	0
-20.2	22	1.5253730473733196
-20.2	aa12	0
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'aa12'
Warning	1292	Truncated incorrect DOUBLE value: 'aa12'
delete from caitest;
insert into caitest values('-20.2','0');
insert into caitest values('-20.2','22');
insert into caitest values('20.2','-22');
insert into caitest values('20.2','22');
#order by
select v_test1,atan(v_test) from caitest order by atan(v_test) desc;
v_test1	atan(v_test)
-22	1.5213317581933052
22	1.5213317581933052
0	-1.5213317581933052
22	-1.5213317581933052
#case when
select sum(case when atan(v_test)>0 then 2 else 1 end) from  caitest;
sum(case when atan(v_test)>0 then 2 else 1 end)
6
select sum(atan(case when atan(v_test)>0 then 2 else 1 end)/atan(-0.1)) from  caitest;
sum(atan(case when atan(v_test)>0 then 2 else 1 end)/atan(-0.1))
-37.97677271415618
select sum(atan((case v_test when '-20.2' then atan(v_test) when '20.2' then atan(v_test)+100 end)/atan(-0.1))) t1 from  caitest;
t1
-0.12887768107622177
#distinct
select distinct atan(v_test) from caitest;
atan(v_test)
-1.5213317581933052
1.5213317581933052
#空值
drop table caitest;
create table caitest(v_test varchar(30),v_test1 varchar(30));
select atan(v_test),atan(v_test1)  from caitest;
atan(v_test)	atan(v_test1)
drop table caitest;
drop database luofan_db;
