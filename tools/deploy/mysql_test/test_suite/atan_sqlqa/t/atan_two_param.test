#owner: luofan.zp
#owner group: SQL2
#description: ATAN
#tags: select,delete,insert,DROP,dual

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop database if exists luofan_db;
drop table if exists atan_table001;
--enable_warnings
create database luofan_db;
use luofan_db;

--disable_warnings
--disable_abort_on_error
-- echo atan 参数个数要求
select atan(3,1) from dual;
SELECT atan(atan(1,2),2) from dual;
select atan(NULL,null)  from dual;
SELECT atan(10,null) from dual;
SELECT atan(NULL,10) from dual;

-- echo 空值 0
select atan(0) from dual;
select atan(' ') from dual;
select atan('   ') from dual;

--error 0, 1582
select atan(3,1,1) from dual;
select atan(3*3,1,1) from dual;
SELECT atan() from dual;

-- echo  atan
select atan(-1,3) from dual;
SELECT atan(0,1) from dual;
SELECT atan(1,0) from dual;
SELECT atan(0,-1) from dual;
SELECT atan(-1e-10,-1) from dual;
SELECT atan(-1,0) from dual;
select atan(atan(atan(2,3),atan(2,4)),2)from dual;
SELECT atan(2,1)/atan(2,3)*atan(2,2) from dual;
SELECT (atan(2,1)-atan(2,2)) from dual;
SELECT atan(10e3,2) from dual;

-- echo 零值，除0
SELECT atan(0,0) from dual;
select atan(3/0,1)  from dual;
SELECT atan(1,3/0) from dual;

--error 0,1054
SELECT atan(a,1) from dual;
SELECT atan(1,a) from dual;

-- echo  atan char
drop table if exists atan_table001;
create table atan_table001(a char(2));
insert into atan_table001 values('3');
SELECT atan(e.a,e.a) from atan_table001 e;

drop table if exists atan_table001;
create table atan_table001(a char(20));
insert into atan_table001 values('1e1');
SELECT atan(e.a,e.a) from atan_table001 e;

drop table if exists atan_table001;
create table atan_table001(a char(20));
insert into atan_table001 values('b');
SELECT atan(e.a,e.a) from atan_table001 e;

-- echo atan varchar
drop table if exists atan_table001;
create table atan_table001(a VARCHAR(20));
insert into atan_table001 values('10');
SELECT atan(e.a,e.a) from atan_table001 e;

drop table if exists atan_table001;
create table atan_table001(a VARCHAR(20));
insert into atan_table001 values('1.0E+001');
SELECT e.a from atan_table001 e;
SELECT atan(e.a,e.a) from atan_table001 e;

-- echo atan blob
drop table if exists atan_table001;
create table atan_table001(a BLOB);
insert into atan_table001 values('10');
SELECT atan(e.a,e.a) from atan_table001 e;

-- echo atan decimal
drop table if exists atan_table001;
create table atan_table001(a DECIMAL);
insert into atan_table001 values('10');
SELECT atan(e.a,e.a) from atan_table001 e;


-- echo atan integer
drop table if exists atan_table001;
create table atan_table001(a INTEGER);
insert into atan_table001 values('10.5');
SELECT atan(e.a,e.a) from atan_table001 e;

--echo atan 参数类型不同
drop table if exists atan_table001;
create table atan_table001(a char(2),b VARCHAR(20));
insert into atan_table001 values(3,4);
SELECT atan(e.a,e.b) from atan_table001 e;

-- echo atan length
select  atan(length('Hello World!'),1) from dual;
SELECT  atan(length('ab'),1) from dual;

-- echo atan replace
select atan(replace('1','1','10'),1) from dual;

-- echo atan abs(value)
select atan(abs(-10),1) from dual;

-- echo atan ceil(value)
select atan(ceil(2.3),1) from dual;

-- echo atan floor(value)
select  atan(floor(2.3),2) from dual;

-- echo atan round
select atan(round(555.666)/5,1) from dual;
select atan(round(555.666,2)/5,1) from dual;
select atan(round(555.666,-2)/5,1) from dual;

drop table atan_table001;

#clean up
drop database luofan_db;