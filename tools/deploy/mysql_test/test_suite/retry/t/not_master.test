#owner: jingfeng.jf
#owner group: SQL2
#tags: retry 


--error 0, 942,1051
drop table t1;
--error 0, 942,1051
drop table t2;

create table t1 (c1 int, c2 int);
insert into t1 values (-4038, 1000000);
insert into t1 values (-4038, 2000000);
insert into t1 values (-4038, 3000000);

set ob_query_timeout = 10000000;
select errno(c1,c2) from t1;
select /*+ parallel(3) */ errno(c1,c2) from t1 limit 1;

set ob_query_timeout = 100000;
--error 4012
select errno(c1,c2) from t1;
--error 4012
select /*+ parallel(3) */ errno(c1,c2) from t1 limit 1;


# test can not retry after any row emitted
set ob_query_timeout = 5000000;
create table t2 (c1 int, c2 int);
insert into t2 values (0, 1000000);
insert into t2 values (1, 1000000);
insert into t2 values (2, 1000000);
insert into t2 values (3, 1000000);
insert into t2 values (-4038, 1000000);

# in local plan case: t1 values can surely be output before -4038 row, so you can do retry in this case
--error 4038
select c1 from t1 union all select errno(c1) from t2;
# in local plan case: batch mode is enabled automaticly, no value can output before -4038 row (the are in same batch), so you can do retry in this case
--error 4012
select errno(c1) from t2;
# in distributed plan case: error triggered before batch result send back to QC, no row outputed
--error 4012
select /*+ parallel(2) */ errno(c1) from t2 order by c1 asc;

drop table t1;
drop table t2;
