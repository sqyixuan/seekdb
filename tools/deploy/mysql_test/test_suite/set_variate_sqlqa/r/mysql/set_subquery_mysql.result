DROP PROCEDURE p_test01;
CREATE  PROCEDURE p_test01(in j int)
begin
	
	case 
	    when j in(select id from t3) 
		then set @a=(select name from t3 where id=1);
		select @a;
		else set @b=(select 1 from (select id from t3) tt);
		select @b;
	end case;
	set @n=(select '2010-1-10');
	insert into vtt1(d) values(@n);
	update vtt1 set d=@n where d =@n;
	delete from vtt1  where d=@n;
	
end;
