    select @a;
	set @a=(select (case when id =1 then 5 end) from tt1 where id=1);
    select @a;
	set @b=(select distinct tt2.id from tt1 inner join tt2 on tt1.id=tt2.id);
    select @b;
	set @a=(select d from tt2 where exists  (select id from tt1));
    select @a;
	set @a=(select id from tt2 where id >=some(select id from tt1));
    select @a;
	set @a=(select distinct id from (select id from tt1 where id >(select 2)) tt5);
    select @a;
	set @a=(select a from tt1 where id <(select 2 from dual));
