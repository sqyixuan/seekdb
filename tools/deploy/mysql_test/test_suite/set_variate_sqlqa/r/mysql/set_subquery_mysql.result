drop trigger tr_test;
CREATE  trigger tr_test before insert on tt1
for each row
begin
    set @i=(select 1);
    while @i <= 5 DO
    set @a:=(select 3);
	set @a=(select d from tt2 order by id);
	set @a=(select distinct d from tt2 group by d);
	set @a=(select d from tt2 where exists  (select id from tt2));
	set @i=(select (@i+1));
	end while;
