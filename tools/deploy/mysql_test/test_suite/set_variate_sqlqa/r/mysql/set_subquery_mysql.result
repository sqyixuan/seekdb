drop table t1;
create table t1( id int,name varchar(30),t date)partition by list (id)
(
partition part_1 values in ( 1, 3, 5, 7 ),
partition part_2 values in( 2, 4, 6, 8 ),
partition part_default values in(10,20,30,40,50)
);
insert into t1 values(1,'test01','2020-10-10');
insert into t1 values(10,'test02','2020-10-11');
insert into t1 values(20,'test03','2020-10-12');
set @a=(select id from t1);
ERROR 21000: Subquery returns more than 1 row
set @a=(select id from t1 where id =1);
select @a;
+------+
| @a   |
+------+
|    1 |
+------+
drop table t1;
create table t1( id int,name varchar(30),t date)PARTITION BY RANGE (id) SUBPARTITION BY HASH (id % 4) SUBPARTITIONS 2(
     PARTITION p0 VALUES LESS THAN (3000000),
     PARTITION p1 VALUES LESS THAN (6000000)
);
insert into t1 values(1,'test01','2020-10-10');
insert into t1 values(10,'test02','2020-10-11');
insert into t1 values(20,'test03','2020-10-12');
set @a=(select id from t1);
ERROR 21000: Subquery returns more than 1 row
