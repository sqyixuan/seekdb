begin
    set @i=(select abs(1));
    repeat
    set @a=(select 3);
	set @a:=(select d from tt2 order by id);
	set @a=(select distinct d from tt2 group by d);
	set @a=(select d from tt2 where exists  (select id from tt2));
	set @a=(select a from tt2 where id=1);
	set @i=@i+(select 1);
	until @i>5
end repeat;
end;
//
delimiter ;//
insert into tt1 values(1,'tr01','2019-10-10');
update tt1 set id=10;
set @b=(select @a);

