drop table if exists ts;
drop table if exists t1;
drop table if exists t2;
drop table if exists t2x;
drop table if exists ```t1```;
purge recyclebin;
alter system set debug_sync_timeout = '60s';
set ob_global_debug_sync = 'reset';
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;

# smaller auto split size;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TABLET_SIZE", error_code = 1048576, frequency = 1;
alter system set enable_auto_split = true;
create table t1(c1 int primary key, c2 varchar(1024));
insert into t1 select row_number() over (), randstr(1024, random()) from table(generator(2000));
alter system minor freeze;
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
partition_name
P8192
P8193
drop table t1;
alter system set enable_auto_split = false;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TABLET_SIZE", error_code = 0, frequency = 0;

# delay data split
alter system set_tp tp_name = "EN_WRITE_SPLIT_START_LOG_DELAY_SEC", error_code = 20, frequency = 1;
create table t1(c1 int primary key) partition by range(c1) (partition p0 values less than (10));
insert into t1 values (1), (6);
alter table t1 reorganize partition p0 into (partition p00 values less than (5), partition p01 values less than (10));
alter system minor freeze;
select ddl_type, status from oceanbase.__all_ddl_task_status;
ddl_type	status
102	37
alter system set_tp tp_name = "EN_WRITE_SPLIT_START_LOG_DELAY_SEC", error_code = 0, frequency = 0;
drop table t1;

# block auto split schedule
alter system set_tp tp_name = "EN_AUTO_SPLIT_TABLET_SIZE", error_code = 1048576, frequency = 1;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TASK_CNT_LESS_THAN", error_code = 1, frequency = 1;
alter system set enable_auto_split = true;
create table t1(c1 int primary key, c2 varchar(1024));
insert into t1 select row_number() over (), randstr(1024, random()) from table(generator(2000));
alter system minor freeze;
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
partition_name
NULL
drop table t1;
alter system set enable_auto_split = false;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TABLET_SIZE", error_code = 0, frequency = 0;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TASK_CNT_LESS_THAN", error_code = 0, frequency = 0;
alter system reset debug_sync_timeout;
