alter system set debug_sync_timeout = '60s';
set ob_global_debug_sync = 'reset';
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
drop table if exists t1;
drop table if exists t2;
purge recyclebin;

# prepare data
create table t1(c1 int, c2 text, c3 int, primary key(c1)) LOB_INROW_THRESHOLD=100 partition by range(c1) size('10g') (partition p0 values less than (maxvalue));
create table t2(c1 int auto_increment primary key, c2 text, c3 int);
insert into t2 select row_number() over (), randstr(256, random()), 0 from table(generator(32768));
select count(*), min(c1), max(c1) from t2;
count(*)	min(c1)	max(c1)
32768	1	32768

# large insert
insert /*+enable_parallel_dml parallel(4) query_timeout(10000000000)*/ into t1 select * from t2;
truncate table t1;
insert /*+enable_parallel_dml parallel(4) query_timeout(10000000000)*/ into t1 select * from t2;
select sleep(1 + RAND() * 3);
sleep(1 + RAND() * 3)
0
alter table t1 reorganize partition p0 into (partition p0 values less than (1000), partition p1 values less than (maxvalue));
select count(*) from t1 partition (p0);
count(*)
999
select count(*) from t1 partition (p1);
count(*)
31769
select count(*) from t1;
count(*)
32768

# batch replace with all row replaced
replace /*+enable_parallel_dml parallel(4) query_timeout(10000000000)*/ into t1 select c1, c2, 1 from t1;
select sleep(1 + RAND() * 3);
sleep(1 + RAND() * 3)
0
alter table t1 reorganize partition p1 into (partition p1 values less than (10000), partition p2 values less than (maxvalue));
select count(*) from t1 partition (p0);
count(*)
999
select count(*) from t1 partition (p1);
count(*)
9000
select count(*) from t1 partition (p2);
count(*)
22769
select count(*) from t1;
count(*)
32768
select sum(c1), sum(c3) from t1;
sum(c1)	sum(c3)
536887296	32768

# insert into on duplicate key update with all row update
insert /*+enable_parallel_dml parallel(4) query_timeout(10000000000)*/ into t1 select c1, c2, 5 from t1 as tt on duplicate key update t1.c3 = tt.c3 + 1;
select sleep(1 + RAND() * 3);
sleep(1 + RAND() * 3)
0
alter table t1 reorganize partition p2 into (partition p2 values less than (20000), partition p3 values less than (maxvalue));
select count(*) from t1 partition (p0);
count(*)
999
select count(*) from t1 partition (p1);
count(*)
9000
select count(*) from t1 partition (p2);
count(*)
10000
select count(*) from t1 partition (p3);
count(*)
12769
select count(*) from t1;
count(*)
32768
select sum(c1), sum(c3) from t1;
sum(c1)	sum(c3)
536887296	65536

# large update
update /*+enable_parallel_dml parallel(4) query_timeout(10000000000)*/ t1 set c1 = c1+10000000, c3 = c3 + 1 where c1 >= 20000;
select sleep(1 + RAND() * 3);
sleep(1 + RAND() * 3)
0
alter table t1 reorganize partition p3 into (partition p3 values less than (25000), partition p4 values less than (maxvalue));
select count(*) from t1 partition (p0);
count(*)
999
select count(*) from t1 partition (p1);
count(*)
9000
select count(*) from t1 partition (p2);
count(*)
10000
select count(*) from t1 partition (p3);
count(*)
0
select count(*), min(c1), max(c1) from t1 partition (p4);
count(*)	min(c1)	max(c1)
12769	10020000	10032768
select count(*) from t1;
count(*)
32768
select sum(c1), sum(c3) from t1;
sum(c1)	sum(c3)
128226887296	78305

# large delete
select min(c1) + (select floor(count(*)/2) from t1 partition(p4)) from t1 partition(p4);
min(c1) + (select floor(count(*)/2) from t1 partition(p4))
10026384
delete /*+enable_parallel_dml parallel(4) query_timeout(10000000000)*/ from t1 partition(p4);
select sleep(1 + RAND() * 3);
sleep(1 + RAND() * 3)
0
alter table t1 reorganize partition p4 into (partition p4 values less than (10032769), partition p5 values less than (maxvalue));
select count(*) from t1 partition (p0);
count(*)
999
select count(*) from t1 partition (p1);
