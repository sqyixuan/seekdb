drop table t1;

# partitioned table to partitioned table
create table t1(c1 int, c2 int, c3 char(10), c4 int, c5 text, primary key(c1)) partition by range(c1) (
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (maxvalue));
create index i1 on t1(c1) local;
create index i2 on t1(c2) global;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for continue_signal execute 10000';
alter table t1 reorganize partition p0 into (partition p00 values less than (5), partition p01 values less than (10));
select table_name,partition_name,subpartition_name,partition_ordinal_position,subpartition_ordinal_position,partition_method,subpartition_method,partition_expression,subpartition_expression,partition_comment from information_schema.partitions where table_schema = 'test' and table_name = 't1' order by table_name,partition_name;
table_name	partition_name	subpartition_name	partition_ordinal_position	subpartition_ordinal_position	partition_method	subpartition_method	partition_expression	subpartition_expression	partition_comment
t1	p00	NULL	2	NULL	RANGE	NULL	c1	NULL	
t1	p01	NULL	3	NULL	RANGE	NULL	c1	NULL	
t1	p1	NULL	4	NULL	RANGE	NULL	c1	NULL	
t1	p2	NULL	5	NULL	RANGE	NULL	c1	NULL	
select ddl_type from oceanbase.__all_ddl_task_status;
ddl_type
102
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
drop table t1;
