drop table if exists t1;
drop table if exists t2;
drop table if exists t2x;
alter system set debug_sync_timeout = '60s';
set ob_global_debug_sync = 'reset';

# part_idx
create table t1(c1 int, c2 int, c3 char(10), c4 int, c5 text, primary key(c1)) partition by range(c1) (
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (maxvalue));
create index i1 on t1(c1) local;
alter table t1 reorganize partition p1 into (partition p10 values less than (15), partition p11 values less than (20));
select part_name, part_idx from oceanbase.__all_part_history where table_id in (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')) order by table_id, part_id, part_name, part_idx;
