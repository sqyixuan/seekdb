drop table if exists t1;
alter system set debug_sync_timeout = '9999999s';
set ob_global_debug_sync = 'reset';
set ob_query_timeout=100000000000000;
CREATE TABLE t1 (id bigint not null auto_increment, dob bigint, primary key(id))
PARTITION BY RANGE(id) (
PARTITION p0 VALUES LESS THAN (3000),
PARTITION p1 VALUES LESS THAN (4000),
PARTITION p2 VALUES LESS THAN (5000)
);
insert /*+ append parallel(8) enable_parallel_dml */ into t1(dob) select random() from table(generator(4500));
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for continue_signal execute 1000';
ALTER TABLE t1 REORGANIZE PARTITION p0 INTO (PARTITION p0_1 VALUES LESS THAN (1000), PARTITION p0_2 VALUES LESS THAN (2000), PARTITION p0_3 VALUES LESS THAN (3000));
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
