drop procedure if exists pro1;
CREATE  PROCEDURE pro1(in i int,j int)
begin
while i <= j DO
insert into t_lob_text values(i,concat(i,'A'),concat(i,'B'),concat(i,'C'),concat(i,'D'),concat(i,'E'),concat(i,'F'),point(i,1));
set i = i + 1;
end WHILE;
end
//
call pro1(7,156);
