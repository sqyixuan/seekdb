# insert split dst with truncate info
create table t1(c1 int auto_increment, c2 varchar(2048), primary key (c1)) partition by range(c1) (partition p0 values less than (50000), partition p1 values less than (maxvalue));
create unique index i1 on t1(c2) global partition by range columns(c2) (partition p0 values less than (maxvalue));
insert into t1(c2) select concat(uuid(),randstr(2012, random())) from table(generator(50000));
create table t1_p0(c1 int, c2 varchar(2048), primary key (c1));
insert into t1_p0 select * from t1 partition(p0);
alter table t1 truncate partition p0;
select /*+index(t1 i1)*/ count(c2) from t1;
count(c2)
1
alter table t1 partition by range() size('128MB');
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for continue_signal execute 10000';
insert into t1(c2) select concat(uuid(),randstr(2012, random())) from table(generator(50000));
insert into t1 select * from t1_p0;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
drop table t1;
drop table t1_p0;

# insert split src with truncate info
