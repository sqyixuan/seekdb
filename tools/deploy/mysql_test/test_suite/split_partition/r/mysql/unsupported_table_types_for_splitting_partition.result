drop table if exists t22;
drop table if exists t1;
drop table if exists t2;
drop database if exists db1;
purge recyclebin;

# vector index
alter system set ob_vector_memory_limit_percentage = 44;
drop table if exists t1;
create table t1(c1 vector(3), c2 int primary key, vector index idx_1(c1) with (distance=l2, type=hnsw)) partition by range(c2) (partition p0 values less than (maxvalue));
alter table t1 reorganize partition p0 into (partition p01 values less than (5), partition p01 values less than (maxvalue));
ERROR 0A000: split partition of a table with vec index is not supported
drop table t1;

# column store replica
drop tenant if exists tenant1 purge;
DROP RESOURCE POOL if exists pool_split_cs_replica;
DROP RESOURCE UNIT if exists unit_split_cs_replica;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TABLET_SIZE", error_code = 1048576, frequency = 1;
create table t1(c1 int primary key, c2 varchar(1024) not null) PARTITION BY RANGE COLUMNS(c1) (
PARTITION p1 VALUES LESS THAN(10),
PARTITION p2 VALUES LESS THAN(20),
PARTITION p3 VALUES LESS THAN(30),
PARTITION p4 VALUES LESS THAN(MAXVALUE)
);
ALTER TABLE t1 REORGANIZE PARTITION p1 INTO (PARTITION p1_new VALUES LESS THAN(5), PARTITION p1_new2 VALUES LESS THAN(10));
ERROR 0A000: split with column store replica not supported
alter system set global_index_auto_split_policy = 'all';
create index i1 on t1(c2) global;
insert into t1 select row_number() over (), randstr(1024, random()) from table(generator(2000));
alter system minor freeze;
alter system reset global_index_auto_split_policy;
drop tenant tenant1 purge;
DROP RESOURCE POOL pool_split_cs_replica;
DROP RESOURCE UNIT unit_split_cs_replica;
create database db1;
use db1;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
drop table if exists t_range_columns;
Warnings:
Note	1051	Unknown table 'db1.t_range_columns'

# 支持用户分区表进行手动分区分裂
create table t_range_columns(
c1 int primary key,
c2 varchar(30) not null
);
insert into t_range_columns values (6,'AA');
insert into t_range_columns values (9,'AA');
insert into t_range_columns values (16,'AA');
insert into t_range_columns values (12,'AA');
insert into t_range_columns values (26,'AA');
insert into t_range_columns values (36,'AA');
ALTER TABLE t_range_columns PARTITION BY RANGE COLUMNS(c1)
(PARTITION p1 VALUES LESS THAN(10),
PARTITION p2 VALUES LESS THAN(20),
PARTITION p3 VALUES LESS THAN(30),
PARTITION p4 VALUES LESS THAN(40)
);
ALTER TABLE t_range_columns REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
PARTITION p1_new2 VALUES LESS THAN(10));
show create table t_range_columns;
Table	Create Table
t_range_columns	CREATE TABLE `t_range_columns` (
  `c1` int(11) NOT NULL,
  `c2` varchar(30) NOT NULL,
  PRIMARY KEY (`c1`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range columns(c1)
(partition `p1_new` values less than (5),
partition `p1_new2` values less than (10),
partition `p2` values less than (20),
partition `p3` values less than (30),
partition `p4` values less than (40))
drop table t_range_columns;

# 不支持列存表进行分区分裂
create table t_range_columns(
c1 int primary key,
c2 varchar(30) not null
) PARTITION BY RANGE COLUMNS(c1)
(PARTITION p1 VALUES LESS THAN(10),
PARTITION p2 VALUES LESS THAN(20),
PARTITION p3 VALUES LESS THAN(30)
);
alter table t_range_columns add column group(each column);
ALTER TABLE t_range_columns REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
PARTITION p1_new2 VALUES LESS THAN(10));
ERROR 0A000: column store table is not supported
alter table t_range_columns drop column group(each column);
alter table t_range_columns add column group(all columns, each column);
ALTER TABLE t_range_columns REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
PARTITION p1_new2 VALUES LESS THAN(10));
ERROR 0A000: column store table is not supported
drop table t_range_columns;

# 临时表不支持创建分区

# 不支持对物化视图进行分区分裂
create table t_range_columns(
c1 int primary key,
c2 varchar(30) not null
) PARTITION BY RANGE COLUMNS(c1)
(PARTITION p1 VALUES LESS THAN(10),
PARTITION p2 VALUES LESS THAN(20),
PARTITION p3 VALUES LESS THAN(30)
);
create materialized view mv1 PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
PARTITION p2 VALUES LESS THAN(20),
PARTITION p3 VALUES LESS THAN(30)) as select * from t_range_columns;
ALTER TABLE mv1 REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
PARTITION p1_new2 VALUES LESS THAN(10)
);
ERROR 0A000: alter partition of materialized view is not supported
drop table t_range_columns;

# 不支持分区分裂的主表含有空间索引
drop table if exists t_range_columns;
create table t_range_columns(
c1 int primary key,
c2 varchar(30) not null,
g GEOMETRY NOT NULL SRID 4326, SPATIAL INDEX(g)
) PARTITION BY RANGE COLUMNS(c1)
(PARTITION p1 VALUES LESS THAN(10),
PARTITION p2 VALUES LESS THAN(20),
PARTITION p3 VALUES LESS THAN(30)
);
ALTER TABLE t_range_columns REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
PARTITION p1_new2 VALUES LESS THAN(10));
ERROR 0A000: split partition of a table with spatial index is not supported
drop table t_range_columns;

# 不支持分区分裂的主表含有全文索引
create table t_range_columns(
c1 int primary key,
c2 varchar(30) not null,
fulltext(c2)
) PARTITION BY RANGE COLUMNS(c1)
(PARTITION p1 VALUES LESS THAN(10),
PARTITION p2 VALUES LESS THAN(20),
PARTITION p3 VALUES LESS THAN(30)
);
ALTER TABLE t_range_columns REORGANIZE PARTITION p1 INTO (PARTITION p1_new VALUES LESS THAN(5),  PARTITION p1_new2 VALUES LESS THAN(10));
ERROR 0A000: split partition of a table with fulltext index is not supported
drop table t_range_columns;

# 不支持分区分裂的主表含有多值索引
create table t_range_columns(
c1 int primary key,
c2 varchar(30) not null,
custinfo JSON,
INDEX json_multivalue( (CAST(custinfo->'$.zipcode' AS double ARRAY)))
) PARTITION BY RANGE COLUMNS(c1)
(PARTITION p1 VALUES LESS THAN(10),
PARTITION p2 VALUES LESS THAN(20),
PARTITION p3 VALUES LESS THAN(30)
);
ALTER TABLE t_range_columns REORGANIZE PARTITION p1 INTO (PARTITION p1_new VALUES LESS THAN(5),  PARTITION p1_new2 VALUES LESS THAN(10));
ERROR 0A000: split partition of a table with fulltext index is not supported
drop table t_range_columns;

# 不支持inc major分裂
alter system set direct_load_allow_fallback=False;
create table t1 (c1 int, c2 int);
create table t2 (c1 int primary key, c2 int) partition by range (c1) (partition p1 values less than (10));
insert into t1 values (1, 11), (2, 22), (3, 33), (4, 44);
insert /*+ direct(true, 0, 'inc_replace') enable_parallel_dml parallel(2) */ into t2 select * from t1;
select * from t2 order by c1,c2;
c1	c2
1	11
2	22
3	33
4	44
alter table t2 reorganize partition p1 into (partition p1_new values less than(5), partition p1_new2 values less than(10));
ERROR 0A000: splitting partition with inc major ddl sstables is not supported
drop table t1;
drop table t2;
alter system set direct_load_allow_fallback=True;

# 正常的自动分区的场景
drop table if exists t22;
alter system set enable_auto_split = true;
set session ob_query_timeout=1000000000000;
create table t22(a int, b VARCHAR(150), c int, d VARCHAR(4000),primary key(a,b)) partition by range(a) (partition p1 values less than (50000000), partition p2 values less than MAXVALUE);
select count(*) from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where table_name = 't22' order by gmt_modified desc limit 1);
count(*)
2
insert into t22(a,b,c,d) select row_number() over (), 'x', null, randstr(1024, random()) from table(generator(2000));
alter system minor freeze;
count(1) > 2
1
drop table t22;

# 主表是列存表的自动分区场景
create table t22(a int, b VARCHAR(150), c int, d VARCHAR(4000),primary key(a,b)) partition by range(a) (partition p1 values less than (50000000), partition p2 values less than MAXVALUE);
alter table t22 add column group(each column);
select count(*) from information_schema.partitions where table_name = 't22';
count(*)
2
insert into t22(a,b,c,d) select row_number() over (), 'x', null, randstr(1024, random()) from table(generator(2000));
alter system minor freeze;
select count(*) from information_schema.partitions where table_name = 't22';
count(*)
2
drop table t22;

# 主表带有全文索引的自动分区的场景
create table t22(a int, b VARCHAR(150), c int, d VARCHAR(4000),primary key(a,b), fulltext(d)) partition by range(a) (partition p1 values less than (50000000), partition p2 values less than MAXVALUE);
select count(*) from information_schema.partitions where table_name = 't22';
count(*)
2
insert into t22(a,b,c,d) select row_number() over (), 'x', null, randstr(1024, random()) from table(generator(2000));
alter system minor freeze;
select count(*) from information_schema.partitions where table_name = 't22';
count(*)
2
drop table t22;

# 主表带有多值索引的自动分区的场景
create table t22(a int, b VARCHAR(150), c int, d VARCHAR(4000), custinfo JSON, INDEX json_multivalue( (CAST(custinfo->'$.zipcode' AS double ARRAY))), primary key(a,b)) partition by range(a) (partition p1 values less than (50000000), partition p2 values less than MAXVALUE);
select count(*) from information_schema.partitions where table_name = 't22';
count(*)
2
insert into t22(a,b,c,d) select row_number() over (), 'x', null, randstr(1024, random()) from table(generator(2000));
alter system minor freeze;
select count(*) from information_schema.partitions where table_name = 't22';
count(*)
2
drop table t22;
alter system reset enable_auto_split;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TABLET_SIZE", error_code = 0, frequency = 0;
