create table t11(a int, b VARCHAR(150), c int, d VARCHAR(4000),primary key(a,b,c))  
partition by range(a) (partition p0 values less than (5000000),
partition p1 values less than (10000000), 
partition p2 values less than (25000000), 
partition p3 values less than (50000000),
partition p4 values less than (75000000),
partition p5 values less than (90000000),  
partition p6 values less than (MAXVALUE));
create index gkey ON t11(c,d) GLOBAL PARTITION BY RANGE(c) (partition p0 values less than (MAXVALUE));
