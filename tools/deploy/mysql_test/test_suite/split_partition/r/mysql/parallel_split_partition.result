21	31	p2	41	c
31	41	p3	51	d
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for continue_signal execute 10000';
alter table t1 reorganize partition p00 into (partition p000 values less than (3), partition p001 values less than (5));
alter table t1 drop partition p2;
select * from t1 order by c1;
c1	c2	c3	c4	c5
1	11	p0	21	a
21	31	p2	41	c
31	41	p3	51	d
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
select * from t1 order by c1;
