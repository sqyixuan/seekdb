drop table if exists ts;
drop table if exists t1;
drop table if exists t2;
drop table if exists t2x;
drop table if exists ```t1```;
purge recyclebin;
alter system set debug_sync_timeout = '60s';
set ob_global_debug_sync = 'reset';
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
alter system set enable_auto_split = true;

# prepare source table
create table ts(c1 int auto_increment primary key);
insert into ts select null from table(generator(50000));

# single int primary key non-partitioned table without presetting partition key
create table ```t1```(```a``A` int auto_increment primary key, d VARCHAR(4000));
insert into ```t1```(d) select randstr(4000, random()) from table(generator(50000));
select partition_name from information_schema.partitions where table_name = '`t1`' order by 1;
partition_name
P8192
P8193
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = '`t1`') order by schema_version;
ddl_stmt_str
create table ```t1```(```a``A` int auto_increment primary key, d VARCHAR(4000))
/*ob_auto_split*/ ALTER TABLE ```t1``` PARTITION BY RANGE(```a``A`) (PARTITION `P8192` VALUES LESS THAN (...), PARTITION `P8193` VALUES LESS THAN (MAXVALUE))
drop table ```t1```;

# single double primary key non-partitioned table without presetting partition key
create table t1(c1 double primary key, c2 VARCHAR(4000));
insert into t1 select c1, randstr(4000, random()) from ts;
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
partition_name
P8192
P8193
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = 't1') order by schema_version;
ddl_stmt_str
create table t1(c1 double primary key, c2 VARCHAR(4000))
/*ob_auto_split*/ ALTER TABLE `t1` PARTITION BY RANGE COLUMNS(`c1`) (PARTITION `P8192` VALUES LESS THAN (...), PARTITION `P8193` VALUES LESS THAN (MAXVALUE))
drop table t1;

# single date primary key non-partitioned table without presetting partition key
create table t1(c1 date primary key, c2 VARCHAR(4000));
insert into t1 select date_add('1000-01-01', interval (c1) day), randstr(4000, random()) from ts;
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
partition_name
