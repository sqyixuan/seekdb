create table t1(a int auto_increment primary key, d VARCHAR(4000)) partition by range(a) size('128MB') (partition ```p0,p1``` values less than (maxvalue))
/*ob_auto_split*/ ALTER TABLE `t1` REORGANIZE PARTITION ```p0,p1``` INTO (PARTITION `P8192` VALUES LESS THAN (...), PARTITION `P8193` VALUES LESS THAN (MAXVALUE))
drop table t1;

# multi primary key partitioned table
create table t1(a int auto_increment, b VARBINARY(150), c int, d VARCHAR(4000), primary key(a,b,c)) partition by range columns(a,b) size('128MB') (partition ```p0,p1``` values less than (maxvalue, maxvalue));
insert into t1(b,c,d) select randstr(150, random()), uniform(1, 100000000, random()), randstr(4000, random()) from table(generator(50000));
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
partition_name
