/*ob_auto_split*/ ALTER TABLE `t1` PARTITION BY RANGE COLUMNS(`c1`) (PARTITION `P8192` VALUES LESS THAN ('...'), PARTITION `P8193` VALUES LESS THAN (MAXVALUE))
