# high_bound_val should be not null
select count(*) from oceanbase.__all_part where high_bound_val is not null and table_id in (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')) group by high_bound_val;
count(*)
3
