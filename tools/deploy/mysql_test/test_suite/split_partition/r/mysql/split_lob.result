set autocommit = 0;
set ob_query_timeout=1000000000000;
set autocommit = 0;
drop table if exists t1;
drop table if exists t2;
purge recyclebin;

# auto split table with lob
create table t1(a int auto_increment primary key, b VARCHAR(150), c int, d VARCHAR(4000)) partition by range() size('unlimited');
alter table t1 add e text;
create index i1 on t1(c) local;
alter table t1 partition by range() size('128MB');
select auto_part,auto_part_size,part_func_type,part_level from oceanbase.__all_table where table_name = 't1';
auto_part	auto_part_size	part_func_type	part_level
1	134217728	3	0
select auto_part,auto_part_size,part_func_type,part_level from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1');
