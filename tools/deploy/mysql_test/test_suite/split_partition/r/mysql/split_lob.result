# uncommitted lob row
create table t1(c1 int, c2 text, primary key(c1)) partition by range(c1) (
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (maxvalue));
insert into t1 values(1, repeat('p00_something1', 1000));
insert into t1 values(2, repeat('p00_something2', 1000));
insert into t1 values(3, repeat('p00_something3', 1000));
insert into t1 values(5, repeat('p01_something5', 1000));
select * from t1;
c1	c2
alter table t1 reorganize partition p0 into (partition p00 values less than (5), partition p01 values less than (10));
select c1, left(c2, 20) from t1 order by c1;
c1	left(c2, 20)
1	p00_something1p00_so
2	p00_something2p00_so
3	p00_something3p00_so
5	p01_something5p01_so
select c1, length(c2) from t1 order by c1;
c1	length(c2)
1	14000
2	14000
3	14000
5	14000
commit;
select c1, left(c2, 20) from t1 partition (p00) order by c1;
c1	left(c2, 20)
1	p00_something1p00_so
2	p00_something2p00_so
3	p00_something3p00_so
select c1, left(c2, 20) from t1 partition (p01) order by c1;
c1	left(c2, 20)
5	p01_something5p01_so
select c1, length(c2) from t1 order by c1;
c1	length(c2)
1	14000
2	14000
3	14000
5	14000
drop table t1;

# committed lob row
create table t1(c1 int, c2 text, primary key(c1)) partition by range(c1) (
partition p0 values less than (10),
