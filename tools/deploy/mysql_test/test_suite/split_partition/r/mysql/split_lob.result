# aborted lob row
create table t1(c1 int, c2 text, primary key(c1)) partition by range(c1) (
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (maxvalue));
insert into t1 values(0, repeat('0_p00_from_p0_major', 1000));
insert into t1 values(1, repeat('1_p00_from_p0_major', 1000));
insert into t1 values(5, repeat('5_p01_from_p0_major', 1000));
insert into t1 values(6, repeat('6_p01_from_p0_major', 1000));
commit;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
insert into t1 values(2, repeat('2_p00_from_p0_minor', 1000));
insert into t1 values(3, repeat('3_p00_from_p0_minor', 1000));
insert into t1 values(4, repeat('4_p00_from_p0_minor', 1000));
insert into t1 values(7, repeat('7_p01_from_p0_minor', 1000));
select c1, left(c2, 20) from t1 order by c1;
c1	left(c2, 20)
0	0_p00_from_p0_major0
1	1_p00_from_p0_major1
5	5_p01_from_p0_major5
6	6_p01_from_p0_major6
select c1, length(c2) from t1 order by c1;
c1	length(c2)
0	19000
1	19000
5	19000
6	19000
rollback;
select c1, left(c2, 20) from t1 order by c1;
c1	left(c2, 20)
0	0_p00_from_p0_major0
1	1_p00_from_p0_major1
5	5_p01_from_p0_major5
6	6_p01_from_p0_major6
select c1, length(c2) from t1 order by c1;
c1	length(c2)
0	19000
1	19000
5	19000
6	19000
alter table t1 reorganize partition p0 into (partition p00 values less than (5), partition p01 values less than (10));
select c1, left(c2, 20) from t1 partition (p00) order by c1;
c1	left(c2, 20)
0	0_p00_from_p0_major0
1	1_p00_from_p0_major1
select c1, left(c2, 20) from t1 partition (p01) order by c1;
c1	left(c2, 20)
5	5_p01_from_p0_major5
6	6_p01_from_p0_major6
select c1, length(c2) from t1 order by c1;
c1	length(c2)
0	19000
1	19000
5	19000
6	19000
drop table t1;

# insert delete lob row
create table t1(c1 int, c2 text, primary key(c1)) partition by range(c1) (
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (maxvalue));
insert into t1 values(1, repeat('p00_something1', 1000));
insert into t1 values(2, repeat('p00_something2', 1000));
insert into t1 values(3, repeat('p00_something3', 1000));
insert into t1 values(5, repeat('p01_something5', 1000));
commit;
delete from t1;
select * from t1;
c1	c2
alter table t1 reorganize partition p0 into (partition p00 values less than (5), partition p01 values less than (10));
select c1, left(c2, 20) from t1 order by c1;
c1	left(c2, 20)
1	p00_something1p00_so
2	p00_something2p00_so
3	p00_something3p00_so
5	p01_something5p01_so
select c1, length(c2) from t1 order by c1;
c1	length(c2)
1	14000
2	14000
3	14000
5	14000
select * from t1;
c1	c2
commit;
select * from t1 partition (p00);
c1	c2
select * from t1 partition (p01);
c1	c2
select * from t1;
c1	c2
drop table t1;

# insert lob after split
create table t1(c1 int, c2 text, primary key(c1)) partition by range(c1) (
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (maxvalue));
insert into t1 values(1, repeat('p00_something1', 1000));
insert into t1 values(2, repeat('p00_something2', 1000));
insert into t1 values(3, repeat('p00_something3', 1000));
insert into t1 values(5, repeat('p01_something5', 1000));
commit;
alter table t1 reorganize partition p0 into (partition p00 values less than (5), partition p01 values less than (10));
delete from t1;
commit;
insert into t1 values(1, repeat('p00_something1', 1000));
insert into t1 values(2, repeat('p00_something2', 1000));
insert into t1 values(3, repeat('p00_something3', 1000));
insert into t1 values(5, repeat('p01_something5', 1000));
commit;
select c1, left(c2, 20) from t1 order by c1;
c1	left(c2, 20)
1	p00_something1p00_so
2	p00_something2p00_so
3	p00_something3p00_so
5	p01_something5p01_so
delete from t1;
commit;
drop table t1;

# split lob to more partitions
CREATE TABLE t1 (
`col1` int(11) NOT NULL,
`col2` int(11) DEFAULT NULL,
`col3` string DEFAULT NULL,
`col4` text DEFAULT NULL,
PRIMARY KEY (`col1`)
) partition by range(col1)
(partition `p0` values less than (5000),
partition `p1` values less than (10000),
partition `p2` values less than (15000),
partition `p_max` values less than (MAXVALUE));
