5	5_p01_from_p0_major5
6	6_p01_from_p0_major6
select c1, length(c2) from t1 order by c1;
c1	length(c2)
0	19000
1	19000
5	19000
6	19000
commit;
select c1, left(c2, 20) from t1 order by c1;
c1	left(c2, 20)
0	0_p00_from_p0_major0
1	1_p00_from_p0_major1
2	2_p00_from_p0_minor2
3	3_p00_from_p0_minor3
4	4_p00_from_p0_minor4
5	5_p01_from_p0_major5
6	6_p01_from_p0_major6
7	7_p01_from_p0_minor7
select c1, length(c2) from t1 order by c1;
