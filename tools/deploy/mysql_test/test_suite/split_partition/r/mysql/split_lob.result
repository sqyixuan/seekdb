0	19000
1	19000
2	19000
3	19000
4	19000
5	19000
6	19000
7	19000
alter table t1 reorganize partition p0 into (partition p00 values less than (5), partition p01 values less than (10));
select c1, left(c2, 20) from t1 partition (p00) order by c1;
c1	left(c2, 20)
