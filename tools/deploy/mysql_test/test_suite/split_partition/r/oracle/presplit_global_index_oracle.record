drop table t1;
purge recyclebin;
alter system set debug_sync_timeout = '60s';
set ob_global_debug_sync = 'reset';
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
set ob_query_timeout = 1000000000;
alter system set global_index_auto_split_policy = 'all';

# no auto split for non-partitioned unspecifed index
create table t1(c1 int, c2 int, c3 int);
create index i1 on t1(c1);
select index_type, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
index_type	auto_part	auto_part_size
7	0	0
alter table t1 drop column c3;
alter table t1 force;
select index_type, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
index_type	auto_part	auto_part_size
7	0	0
drop table t1;

# auto split for non-partitioned unspecifed index with auto-partitioned data table
alter system set enable_auto_split = true;
create table t1(c1 int, c2 int, c3 int primary key, c4 int);
create index i1 on t1(c1);
select index_type, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
index_type	auto_part	auto_part_size
3	1	134217728
alter table t1 drop column c4;
alter table t1 force;
select index_type, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
index_type	auto_part	auto_part_size
3	1	134217728
drop table t1;
alter system set enable_auto_split = false;

# auto split for non-partitioned unspecifed index with partitioned data table
create table t1(c1 int, c2 int, c3 int, c4 int) partition by hash(c3) partitions 1;
create index i1 on t1(c1);
select index_type, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
index_type	auto_part	auto_part_size
3	1	134217728
alter table t1 drop column c4;
alter table t1 force;
select index_type, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
index_type	auto_part	auto_part_size
3	1	134217728
drop table t1;
alter system set global_index_auto_split_policy = 'distributed';
