--echo
--echo # index skip scan split dst
create table t1(pk1 int, c1 int, c2 int, primary key(pk1)) partition by range(pk1) (partition p0 values less than (maxvalue));
alter system set _optimizer_skip_scan_enabled = true;
alter system flush plan cache;
--let $loop=1
--disable_query_log
while($loop < 5001)
{
  eval insert into t1 (pk1,c1,c2) values ($loop, $loop % 3, $loop);
  inc $loop;
}
--enable_query_log
call dbms_stats.set_global_prefs('ESTIMATE_BLOCK', 'FALSE');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.set_global_prefs('ESTIMATE_BLOCK', 'TRUE');
create index t1_idx1 on t1(pk1,c1,c2) local;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for continue_signal execute 10000';
connection conn1;
send alter table t1 reorganize partition p0 into (partition p00 values less than (2500), partition p01 values less than (maxvalue));
connection default;
sleep 3;
select count(distinct c1),count(distinct c2) from t1;
select /*+ index_ss(t1 t1_idx1) */ * from t1 where c2 = 1234;
select /*+ index(t1 primary) */ * from t1 where c2 = 1234;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection conn1;
reap;
connection default;
drop table if exists t1;

