drop table if exists t1;
set global max_allowed_packet=134217728;
create table t1(c1 int, c2 int, c3 longtext, primary key(c1)) partition by range(c1) (partition p0 values less than (5), partition p1 values less than (maxvalue));
create index idx1 on t1(c2);
