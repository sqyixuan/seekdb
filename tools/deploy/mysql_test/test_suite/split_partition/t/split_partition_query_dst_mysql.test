select c1, length(c1), substr(c2, 261, 26), substr(c2, 26001, 26) from t1 partition (p10);
select c1, length(c1), substr(c2, 261, 26), substr(c2, 26001, 26) from t1 partition (p11);
select c1, length(c1), substr(c2, 261, 26), substr(c2, 26001, 26) from t1 partition (p11) where c1 = 5;
select c1, length(c1), substr(c2, 261, 26), substr(c2, 26001, 26) from t1 partition (p11) where c1 > 5 and c1 < 10;

connection obsys;
set ob_global_debug_sync = 'reset';
