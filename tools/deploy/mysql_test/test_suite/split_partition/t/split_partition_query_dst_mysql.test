insert into t1 values(2, repeat('abcdefghijklmnopqrstuvwxyz', 1000000));
insert into t1 values(3, repeat('abcdefghijklmnopqrstuvwxyz', 1000000));
insert into t1 values(4, repeat('abcdefghijklmnopqrstuvwxyz', 1000000));
