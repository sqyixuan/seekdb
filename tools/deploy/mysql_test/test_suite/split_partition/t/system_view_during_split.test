# owner: lihongqin.lhq
# owner group: storage
# description: this case is use for testing system view behavior during split partition
#

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t2x;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '60s';
sleep 3;
set ob_global_debug_sync = 'reset';

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn5,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--echo
--echo # part_idx
create table t1(c1 int, c2 int, c3 char(10), c4 int, c5 text, primary key(c1)) partition by range(c1) (
  partition p0 values less than (10),
  partition p1 values less than (20),
  partition p2 values less than (maxvalue));
create index i1 on t1(c1) local;
alter table t1 reorganize partition p1 into (partition p10 values less than (15), partition p11 values less than (20));
select part_name, part_idx from oceanbase.__all_part_history where table_id in (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')) order by table_id, part_id, part_name, part_idx;
drop table t1;

--echo
--echo # partitioned table to partitioned table
create table t1(c1 int, c2 int, c3 char(10), c4 int, c5 text, primary key(c1)) partition by range(c1) (
  partition p0 values less than (10),
  partition p1 values less than (20),
  partition p2 values less than (maxvalue));
create index i1 on t1(c1) local;
create index i2 on t1(c2) global;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for continue_signal execute 10000';
connection conn1;
send alter table t1 reorganize partition p0 into (partition p00 values less than (5), partition p01 values less than (10));
connection default;
sleep 3;
select table_name,partition_name,subpartition_name,partition_ordinal_position,subpartition_ordinal_position,partition_method,subpartition_method,partition_expression,subpartition_expression,partition_comment from information_schema.partitions where table_schema = 'test' and table_name = 't1' order by table_name,partition_name;
select ddl_type from oceanbase.__all_ddl_task_status;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection conn1;
reap;
connection default;
drop table t1;

