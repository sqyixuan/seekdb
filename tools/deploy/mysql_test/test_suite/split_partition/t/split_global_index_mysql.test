#test global index key without range key 
connection conn1;
--disable_warnings
drop table if exists t22;
--enable_warnings
alter system set enable_auto_split = true;
set session ob_query_timeout=1000000000000;
--sleep 5
create table t22(a int, b VARCHAR(150), c int, d VARCHAR(4000),primary key(a,b)) partition by range(a) (partition p1 values less than (50000000), partition p2 values less than MAXVALUE);
#global index: no range key 
create index gkey1 on t22(a,d) global;

connection obsys;
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name='t22',table_id,1);
let $gkey1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name like '%gkey1%' and data_table_id = $table_id, table_id, 1);
let $gkey1_src_tablet_id = query_get_value(select tablet_id from oceanbase.__all_virtual_table where table_id = $gkey1_id, tablet_id, 1);


let $p1_ls_id = query_get_value(select LS_ID from oceanbase.CDB_OB_TABLE_LOCATIONS where table_id = $gkey1_id and role = 'LEADER' and tablet_id = $gkey1_src_tablet_id, LS_ID, 1);
let $p1_svr_ip = query_get_value(select SVR_IP from oceanbase.CDB_OB_TABLE_LOCATIONS where table_id = $gkey1_id and role = 'LEADER' and tablet_id = $gkey1_src_tablet_id, SVR_IP, 1);
let $p1_svr_port = query_get_value(select SVR_PORT from oceanbase.CDB_OB_TABLE_LOCATIONS where table_id = $gkey1_id and role = 'LEADER' and tablet_id = $gkey1_src_tablet_id, SVR_PORT, 1);


connection conn1;

let $times_insert = 0;
while ($times_insert < 20)
{
  --inc $times_insert
  insert into t22(a,b,c,d) select 
    uniform(1, 100000000, random()),
    randstr(150, random()) c1,
    uniform(1, 100000000, random()),
    randstr(4000, random()) c1
  from 
    table(generator(5000));
}
connection obsys;

connection obsys;
let $times_check = 0;
while ($times_check < 10)
{
  sleep 15;
  --inc $times_check
  let $partition_count = query_get_value(select count(1) as count from (select distinct(src_tablet_id) from oceanbase.__all_virtual_tablet_reorganize_history where src_tablet_id = $gkey1_src_tablet_id), count, 1);
  if ($partition_count == 1) 
  {
    let $times_check = 11;
  }
}

--replace_regex /table_id = [0-9]*/table_id = gkey1_id/g
eval select count(1) > 1 from __all_virtual_part where table_id = $gkey1_id;
--sleep 5
#make sure that the position of tablets are located at the same places before and after the split 

--replace_regex /LS_ID = [0-9]*/LS_ID = origin_ls_id/g /table_id = [0-9]*/table_id = origin_table_id/g /src_tablet_id = [0-9]*/src_tablet_id = origin_src_tablet_id/g 
eval select LS_ID = $p1_ls_id from oceanbase.CDB_OB_TABLE_LOCATIONS where table_id = $gkey1_id and role = 'LEADER' and tablet_id in (select dest_tablet_id from __all_virtual_tablet_reorganize_history where src_tablet_id = $gkey1_src_tablet_id);
--replace_regex /SVR_IP = '.*'/SVR_IP = origin_svr_ip/g /table_id = [0-9]*/table_id = origin_table_id/g /src_tablet_id = [0-9]*/src_tablet_id = origin_src_tablet_id/g 
eval select SVR_IP = '$p1_svr_ip' from oceanbase.CDB_OB_TABLE_LOCATIONS where table_id = $gkey1_id and role = 'LEADER' and tablet_id in (select dest_tablet_id from __all_virtual_tablet_reorganize_history where src_tablet_id = $gkey1_src_tablet_id);
--replace_regex /SVR_PORT = [0-9]*/SVR_PORT = origin_svr_port/g /table_id = [0-9]*/table_id = origin_table_id/g /src_tablet_id = [0-9]*/src_tablet_id = origin_src_tablet_id/g 
eval select SVR_PORT = $p1_svr_port from oceanbase.CDB_OB_TABLE_LOCATIONS where table_id = $gkey1_id and role = 'LEADER' and tablet_id in (select dest_tablet_id from __all_virtual_tablet_reorganize_history where src_tablet_id = $gkey1_src_tablet_id);

#make sure the values in __all_virtual_ddl_operation are expected
--replace_regex /table_id = [0-9]*/table_id = gkey1_id/g
eval select ddl_stmt_str from __all_virtual_ddl_operation where operation_type = $OB_DDL_SPLIT_PARTITION and table_id = $gkey1_id;

connection conn1;
drop table t22;
alter system set enable_auto_split = false;
--replace_regex /PRIMARY_ZONE = '.*'/PRIMARY_ZONE = "origin_primary_zone"/g
eval alter tenant sys PRIMARY_ZONE = '$origin_primary_zone';
