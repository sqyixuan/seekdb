# owner: yangjiali.yjl
# owner group: storage
# description: split with tmp table

connect (conn_user,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn_user;

--disable_warnings
drop database if exists yjl_auto_split;
create database yjl_auto_split;
use yjl_auto_split;

drop table if exists t1;
drop table if exists t2;

create table t1 (c1 int, c2 int, primary key(c1));
create temporary table t2 like t1;
alter table t2 comment='abc';
create index idx1 on t2(c2) global;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t2;

drop table if exists t1;
drop table if exists t2;
drop database if exists yjl_auto_split;