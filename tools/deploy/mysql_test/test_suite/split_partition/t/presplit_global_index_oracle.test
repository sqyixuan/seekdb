# owner: lihongqin.lhq
# owner group: storage
# description: this case is use for testing global index presplit
#

--error 0,942
drop table t1;

purge recyclebin;

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '60s';
sleep 3;
set ob_global_debug_sync = 'reset';

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn5,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connection default;
set ob_query_timeout = 1000000000;

alter system set global_index_auto_split_policy = 'all';

--echo
--echo # no presplit for non-partitioned unspecifed index
create table t1(c1 varchar(2048), c2 int, c3 int);
insert into t1 select randstr(2048, random()), 1, null from table(generator(100000));
create index i1 on t1(c1);
connection obsys;
select index_type, part_num, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
connection default;
alter table t1 drop column c3;
alter table t1 force;
connection obsys;
select index_type, part_num, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
connection default;
drop table t1;

--echo
--echo # no presplit for non-partitioned global index
create table t1(c1 varchar(2048), c2 int, c3 int);
insert into t1 select randstr(2048, random()), 1, null from table(generator(100000));
create index i1 on t1(c1) global;
connection obsys;
select index_type, part_num, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
connection default;
alter table t1 drop column c3;
alter table t1 force;
connection obsys;
select index_type, part_num, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
connection default;
drop table t1;

--echo
--echo # auto split for non-partitioned unspecifed index with auto-partitioned data table
alter system set enable_auto_split = true;
create table t1(c1 int, c2 int, c3 int primary key, c4 int);
create index i1 on t1(c1);
connection obsys;
select index_type, part_num, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
connection default;
alter table t1 drop column c4;
alter table t1 force;
connection obsys;
select index_type, part_num, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
connection default;
drop table t1;
alter system set enable_auto_split = false;

--echo
--echo # presplit for non-partitioned unspecifed index with partitioned data table
create table t1(c1 varchar(2048), c2 int, c3 int, c4 int) partition by hash(c3) partitions 1;
insert into t1 select randstr(2048, random()), 1, rownum, null from table(generator(100000));
create index i1 on t1(c1);
connection obsys;
select index_type, part_num, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
connection default;
alter table t1 drop column c4;
alter table t1 force;
connection obsys;
select index_type, part_num, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
connection default;
drop table t1;

--echo
--echo # presplit for partitioned global index with non-partitioned data table
create table t1(c1 varchar(2048), c2 int, c3 int);
insert into t1 select randstr(2048, random()), 1, null from table(generator(100000));
create index i1 on t1(c1) global partition by range(c1) (partition p0 values less than (maxvalue));
connection obsys;
select index_type, part_num, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
connection default;
alter table t1 drop column c3;
alter table t1 force;
connection obsys;
select index_type, part_num, auto_part, auto_part_size from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 't1' order by gmt_modified desc limit 1);
connection default;
drop table t1;

--echo
--echo # presplit defensive check for hash partitioned global index with non-partitioned data table 
--error 0,942
drop table sales;
create table sales (c1 NUMBER primary key, C2 DATE, amount NUMBER) PARTITION BY RANGE () size('128mb');
create index sales_idx on sales(c1, c2) global partition by hash(c1, c2) partitions 2;
connection obsys;
select index_type, part_num, auto_part, auto_part_size, part_func_type, part_func_expr from __all_virtual_table where (tenant_id, data_table_id) = (select tenant_id, table_id from __all_virtual_table where table_name = 'sales' order by gmt_modified desc limit 1);
connection default;
drop table sales;

alter system set global_index_auto_split_policy = 'distributed';

