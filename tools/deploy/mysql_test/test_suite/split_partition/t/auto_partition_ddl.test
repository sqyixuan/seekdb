# alter column of global index
CREATE TABLE auto_npt (c1 int, c2 int, c3 int, c4 int, primary key(c1,c2)) partition by range(c1) size('1GB');
CREATE INDEX global_idx ON auto_npt(c3,c4) GLOBAL;

ALTER TABLE auto_npt CHANGE c1 new_c1 int;
ALTER TABLE auto_npt CHANGE c3 new_c3 int;
--error 1167
ALTER TABLE auto_npt CHANGE new_c3 c3 blob;


ALTER TABLE auto_npt MODIFY new_c3 FLOAT;

ALTER TABLE auto_npt DROP COLUMN new_c3;
let $table_id=query_get_value(select table_id from oceanbase.__all_table where table_name='auto_npt',table_id,1);
let $global_idx = query_get_value(select table_id from oceanbase.__all_table where data_table_id=$table_id order by table_id, table_id, 1);
--disable_query_log
eval select index_type, part_level, part_func_type, part_func_expr, part_num, auto_part, auto_part_size from oceanbase.__all_table where table_id = $global_idx;
eval select column_name,rowkey_position,index_position,partition_key_position,data_type from oceanbase.__all_column where table_id = $global_idx;
--enable_query_log
ALTER TABLE auto_npt DROP COLUMN c4;
DROP TABLE auto_npt;

CREATE TABLEGROUP tblgroup1 SHARDING = 'NONE';
CREATE TABLE auto_npt (c1 int, c2 int, c3 int, c4 int, primary key(c1,c2)) TABLEGROUP = tblgroup1 partition by range(c1) size('1GB');
CREATE TABLE auto_npt_1 (c1 int, c2 int, c3 int, c4 int, primary key(c1,c2)) partition by range(c1) size('1GB');
CREATE TABLE auto_npt_2 (c1 int, c2 int, c3 int, c4 int, primary key(c1,c2)) partition by range(c1) size('1GB');
ALTER TABLEGROUP tblgroup1 ADD auto_npt_1;
ALTER TABLE auto_npt_2 SET TABLEGROUP tblgroup1;
DROP TABLE auto_npt, auto_npt_1, auto_npt_2;
DROP TABLEGROUP tblgroup1;


--disable_warnings
DROP TABLE if exists t1;
--enable_warnings
--echo #自动分区不兼容partition number语句
--error 1064
create table t1(i int ,primary key(i)) partition by range(i) partitions 3;


create table t1(i int, primary key(i)) partition by range(i) partitions 2 size('1GB') (partition p1 values less than (50000000), partition p2 values less than MAXVALUE);
select auto_part from oceanbase.__all_table where table_name = 't1';
drop table t1;

create table t1(i int, primary key(i)) partition by range(i) partitions 2 size('unlimited') (partition p1 values less than (50000000), partition p2 values less than MAXVALUE);
select auto_part from oceanbase.__all_table where table_name = 't1';
drop table t1;

alter system set enable_auto_split = true;
--sleep 5
create table t1(i int, primary key(i)) partition by range(i) partitions 2 (partition p1 values less than (50000000), partition p2 values less than MAXVALUE);
select auto_part from oceanbase.__all_table where table_name = 't1'; 

--error 1064 
ALTER TABLE t1 PARTITION BY RANGE() partitions 2 SIZE('1GB');
--error 1064
ALTER TABLE t1 PARTITION BY RANGE() partitions 2 SIZE('unlimited');

--echo	#year类型分区键
--disable_warnings
DROP TABLE IF EXISTS year_table;
--enable_warnings
--error 1654
Create table year_table(y year primary key) partition by range columns(y) (partition t1 values less than('1998'), partition p2 values less than MAXVALUE);
Create table year_table(y year primary key) partition by range columns(y) (partition t1 values less than(1998), partition p2 values less than MAXVALUE);
drop table year_table;
--echo	#double unsigned类型分区键
--disable_warnings
DROP TABLE IF EXISTS double_u_table;
--enable_warnings
Create table double_u_table(y double unsigned primary key) partition by range columns(y) (partition t1 values less than(824), partition p2 values less than MAXVALUE);
drop table double_u_table;
--echo	#float unsigned类型分区键
--disable_warnings
DROP TABLE IF EXISTS float_u_table;
--enable_warnings
Create table float_u_table(y float unsigned primary key) partition by range columns(y) (partition t1 values less than(824), partition p2 values less than MAXVALUE);
drop table float_u_table;
--echo	#DECIMAL UNSIGNED类型分区键
--disable_warnings
DROP TABLE IF EXISTS decimal_u_table;
--enable_warnings
Create table decimal_u_table(y decimal(10,5) unsigned primary key) partition by range columns(y) (partition t1 values less than(824), partition p2 values less than MAXVALUE);
drop table decimal_u_table;
--echo	#numeric unsigned类型分区键
--disable_warnings
DROP TABLE IF EXISTS numeric_u_table;
--enable_warnings
Create table numeric_u_table(y numeric unsigned primary key) partition by range columns(y) (partition t1 values less than(824), partition p2 values less than MAXVALUE);
drop table numeric_u_table;
--echo	#number unsigned类型分区键
--disable_warnings
DROP TABLE IF EXISTS number_u_table;
--enable_warnings
Create table number_u_table(y number unsigned primary key) partition by range columns(y) (partition t1 values less than(824), partition p2 values less than MAXVALUE);

alter system set enable_auto_split = false;


--echo modify auto-partition attribute of a table in the tablegroup which contains only one table 

--disable_warnings
DROP TABLEGROUP if exists tblgroup1;
DROP TABLE IF EXISTS t1,t2,t3,t4,t5,t6;
--enable_warnings

create tablegroup tblgroup1;
create table t1(c1 int primary key) tablegroup = tblgroup1 partition by range(c1) (partition p1 values less than(500));
alter table t1 partition by range() size('128mb');
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;

create tablegroup tblgroup2;
create table t2(c1 int primary key) tablegroup = tblgroup2;
alter table t2 partition by range() size('128mb');
--source mysql_test/include/show_create_table_old_version.inc
show create table t2;

create tablegroup tblgroup3;
create table t3(c1 int primary key) tablegroup = tblgroup3 partition by range(c1) size('128mb') (partition p1 values less than(500));
alter table t3 partition by range() size('129mb');
--source mysql_test/include/show_create_table_old_version.inc
show create table t3;

create tablegroup tblgroup4;
create table t4(c1 int primary key) tablegroup = tblgroup4 partition by range();
alter table t4 partition by range() size('129mb');
--source mysql_test/include/show_create_table_old_version.inc
show create table t4;


--echo modify auto-partition attribute of a table in the tablegroup which contains more than one table 


create tablegroup tblgroup5;

create table t5(c1 int primary key) tablegroup = tblgroup5 partition by range();
create table t6(c1 int primary key) tablegroup = tblgroup5 partition by range();


alter table t5 partition by range() size('129mb');
alter table t6 partition by range() size('129mb');

--source mysql_test/include/show_create_table_old_version.inc
show create table t5;
--source mysql_test/include/show_create_table_old_version.inc
show create table t6;
drop table t1,t2,t3,t4,t5,t6;
DROP TABLEGROUP tblgroup1;
DROP TABLEGROUP tblgroup2;
DROP TABLEGROUP tblgroup3;
DROP TABLEGROUP tblgroup4;
DROP TABLEGROUP tblgroup5;

#test online modify partition key of global index 
-- echo test online modify partition key of global index 

create table t1(c1 int, c2 int, c3 int, c4 int, primary key (c1,c2)) partition by range(c1) size ( '1GB' );
create index g_idx on t1(c3,c4) global partition by range(c3) (partition p1 values less than(MAXVALUE));
alter table t1 change c3 new_c3 int;

#even changing the column type from int to bigint is online ddl, we still disable this behavior
--error 4179
alter table t1 modify new_c3 bigint NULL;

alter table t1 modify new_c3 int NOT NULL;
alter table t1 modify new_c3 int NULL;

#test  online modify presetting-partition key of global index 
-- echo test online modify presetting-partition key of global index 
alter system set enable_auto_split=true;
create table t2(c1 int, c2 int, c3 int, c4 int, primary key (c1,c2)) partition by range(c1) size ( '1GB' );
create index g_idx on t2(c3,c4) global;
alter table t2 change c3 new_c3 int;

#notice this is different from the partitioned global index, because the c3 is only the presetting-partition key.
alter table t2 modify new_c3 bigint NULL;

alter table t2 modify new_c3 int NOT NULL;
alter table t2 modify new_c3 int NULL;

drop table t1,t2;

create table t1(c1 int, c2 int, c3 int, primary key(c1, c2));
alter table t1 partition by range columns(`c1`, `c2`) size('128g');
drop table t1;

create table t1(c1 int, c2 int, `,` int, primary key(c1, c2, `,`));
--error 1064
alter table t1 partition by range columns(`c1`,,,`c2`) size('128m');
alter table t1 partition by range columns(`c1`, `c2`, `,`) size('128m');
drop table t1;

