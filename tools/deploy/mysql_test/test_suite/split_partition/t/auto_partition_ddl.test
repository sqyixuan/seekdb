--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: wanyue.wy
# owner group: trans
# tags: ddl

--disable_warnings
DROP TABLE if exists auto_npt;
DROP TABLEGROUP if exists tblgroup1;
--enable_warnings

# alter column of data table
CREATE TABLE auto_npt (c1 int, c2 int, c3 int, c4 int, primary key(c1,c2)) partition by range() size('1GB');
let $table_id=query_get_value(select table_id from oceanbase.__all_table where table_name='auto_npt',table_id,1);
--disable_query_log
eval select rowkey_column_num, part_func_expr, part_func_type from oceanbase.__all_table where table_id = $table_id;
--enable_query_log

ALTER TABLE auto_npt DROP PRIMARY KEY,ADD PRIMARY KEY (c1);
let $table_id=query_get_value(select table_id from oceanbase.__all_table where table_name='auto_npt',table_id,1);
--disable_query_log
eval select rowkey_column_num, part_func_expr, part_func_type from oceanbase.__all_table where table_id = $table_id;
--enable_query_log

ALTER TABLE auto_npt DROP PRIMARY KEY,ADD PRIMARY KEY (c2,c3);
let $table_id=query_get_value(select table_id from oceanbase.__all_table where table_name='auto_npt',table_id,1);
--disable_query_log
eval select rowkey_column_num, part_func_expr, part_func_type from oceanbase.__all_table where table_id = $table_id;
--enable_query_log
DROP TABLE auto_npt;

CREATE TABLE auto_npt (c1 int, c2 int, c3 int, c4 int, primary key(c1,c2)) partition by range(c1) size('1GB');
