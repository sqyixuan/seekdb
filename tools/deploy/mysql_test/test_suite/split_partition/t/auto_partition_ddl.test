let $table_id=query_get_value(select table_id from oceanbase.__all_table where table_name='auto_npt',table_id,1);
--disable_query_log
eval select rowkey_column_num from oceanbase.__all_table where table_id = $table_id;
eval select column_name,rowkey_position,index_position,partition_key_position,data_type from oceanbase.__all_column where table_id = $table_id;
