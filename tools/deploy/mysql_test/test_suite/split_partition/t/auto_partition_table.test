--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: wanyue.wy
# owner group: trans
# tags: ddl

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set_tp tp_no = 524, error_code = 0, frequency = 0;
connection default;

--disable_warnings
drop table if exists auto_npt;
drop table if exists auto_pt;
drop table if exists list_pt;
drop table if exists npt;
drop table if exists pt;
drop table if exists pt2;
drop table if exists t1;
--enable_warnings

# auto-partitioned non-partitioned table
alter system SET enable_auto_split = true;
alter system SET auto_split_tablet_size = '128mb';
--sleep 5
CREATE TABLE auto_npt (c1 int, c2 int, c3 int, c4 int default null, c5 int default null, primary key(c1,c2)) partition by range(c1) size('1GB');
CREATE UNIQUE INDEX local_uni_idx ON auto_npt(c1) LOCAL;
CREATE INDEX local_idx ON auto_npt(c2) LOCAL;
CREATE INDEX global_idx ON auto_npt(c3) GLOBAL;
CREATE INDEX global_idx2 ON auto_npt(c4, c5) GLOBAL
        PARTITION BY RANGE COLUMNS(c4, c5)
        (PARTITION p0 VALUES LESS THAN(50, 50),
         PARTITION p1 VALUES LESS THAN(100, 100),
         PARTITION p_max VALUES LESS THAN (MAXVALUE, MAXVALUE)
        );
CREATE UNIQUE INDEX global_uni_idx ON auto_npt(c5) GLOBAL
       PARTITION BY RANGE COLUMNS(c5)
       (PARTITION p0_i VALUES LESS THAN(30),
        PARTITION p1_i VALUES LESS THAN(80),
        PARTITION p_max_i VALUES LESS THAN (MAXVALUE)
       );

CREATE UNIQUE INDEX global_uni_idx2 ON auto_npt(c5) GLOBAL;


let $table_id=query_get_value(select table_id from oceanbase.__all_table where table_name='auto_npt',table_id,1);
let $global_idx = query_get_value(select table_id from oceanbase.__all_table where data_table_id=$table_id order by table_id, table_id, 3);
let $global_idx2 = query_get_value(select table_id from oceanbase.__all_table where data_table_id=$table_id order by table_id, table_id, 4);
let $global_uni_idx = query_get_value(select table_id from oceanbase.__all_table where data_table_id=$table_id order by table_id, table_id, 5);
let $global_uni_idx2 = query_get_value(select table_id from oceanbase.__all_table where data_table_id=$table_id order by table_id, table_id, 6);

--disable_query_log
eval select part_level, part_func_type, part_func_expr, part_num, auto_part, auto_part_size
      from oceanbase.__all_table where table_id = $table_id;
eval select index_type, part_level, part_func_type, part_func_expr, part_num, auto_part, auto_part_size
      from oceanbase.__all_table where table_id = $global_idx;
eval select index_type, part_level, part_func_type, part_func_expr, part_num, auto_part, auto_part_size
      from oceanbase.__all_table where table_id = $global_idx2;
eval select index_type, part_level, part_func_type, part_func_expr, part_num, auto_part, auto_part_size
      from oceanbase.__all_table where table_id = $global_uni_idx;
eval select index_type, part_level, part_func_type, part_func_expr, part_num, auto_part, auto_part_size
      from oceanbase.__all_table where table_id = $global_uni_idx2;
--enable_query_log
drop table auto_npt;

