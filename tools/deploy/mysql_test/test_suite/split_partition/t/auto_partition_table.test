#打开自动分区, 非hbase表(case sensitivity)预期选取主键(K,Q,T)作为分区键
-- echo we expect the 'K','Q','T' columns to be the multiple partition keys 
alter system set enable_auto_split=true;
alter system set auto_split_tablet_size = '128MB';
--sleep 5 
--echo auto split Non-hbase table should pick K,Q,T as partition key 
create table htable1 (
  k varbinary(1024), 
  Q varbinary(256), 
  T bigint, 
  v varbinary(1048576) NOT NULL, 
  primary key(k, q, t)) 
TABLEGROUP =  htable1;
--disable_query_log
let $times_insert = 0;
set session ob_query_timeout=1000000000000;	
while ($times_insert < 10)
{
  --inc $times_insert
  insert into htable1(K,Q,T,V) select 
    randstr(10, random()) c1,
    randstr(150, random()) c1,
    uniform(1, 1000, random()),
    randstr(4000, random()) c1
   from 
    table(generator(8000));
}
--enable_query_log

--disable_query_log
let $times_check = 0;
while ($times_check < 10)
{
  sleep 10;
  --inc $times_check
  let $partition_count = query_get_value(select count(1) as count from oceanbase.__all_part where table_id = $table_id, count, 1);
  if ($partition_count > 1) 
  {
    let $times_check = 11;
  }
}
--enable_query_log

let $table_id=query_get_value(select table_id from oceanbase.__all_table where table_name='htable1', table_id, 1);
--disable_query_log
eval select part_level, part_func_type, part_func_expr, auto_part, auto_part_size
      from oceanbase.__all_table where table_id = $table_id;
--enable_query_log
alter system set enable_auto_split=false;
drop table htable1;
drop tablegroup htable1;


#打开自动分区, hbase表带TTL列(case sensitivity)和时序类型hbase表预期选取主键(K)作为分区键
connection obsys;
alter system set_tp tp_no = 524, error_code = 1048576, frequency = 1;
sleep 2;
connection default;
alter system SET enable_auto_split = true;


--disable_warnings
drop table if exists hbase_c_00$info;
drop table if exists hbase_t_00$info;
--enable_warnings


CREATE TABLE `hbase_c_00$info` (
  `K` varbinary(1024) NOT NULL,
  `Q` varbinary(256) NOT NULL,
  `T` bigint(20) NOT NULL,
  `V` varbinary(1024) DEFAULT NULL,
  `TTL` bigint(20) DEFAULT NULL,
  PRIMARY KEY (`K`, `Q`, `T`)) KV_ATTRIBUTES = '{"Hbase": {"TimeToLive": 10800, "MaxVersions": 2}}';

CREATE TABLE `hbase_t_00$info` (
  `K` varbinary(1024) NOT NULL,
  `T` bigint(20) NOT NULL,
  `S` bigint(20) NOT NULL,
  `V` json NOT NULL,
  `G` bigint(20) GENERATED ALWAYS AS (ABS(`T`)) VIRTUAL,
  PRIMARY KEY (`K`, `T`, `S`)
) KV_ATTRIBUTES = '{"Hbase": {"TimeToLive": 10800}}';

let $table_id_ttl = query_get_value(select table_id from oceanbase.__all_table where table_name like 'hbase_c_00%info', table_id, 1);
let $table_id_timeseries = query_get_value(select table_id from oceanbase.__all_table where table_name like 'hbase_t_00%info', table_id, 1);

insert into hbase_c_00$info(K,Q,T,V) select 
    randstr(500, random()) c1,
    randstr(150, random()) c1,
    uniform(1, 1000, random()),
    '[1, {"a": "b"}]'
   from 
    table(generator(8000));

insert into hbase_t_00$info(K,T,S,V) select 
    randstr(500, random()) c1,
    uniform(1, 1000, random()),
    uniform(1, 1000, random()),
    '[1, {"a": "b"}, [2, "qwe"]]'
   from 
    table(generator(8000));
connection obsys;
alter system minor freeze tenant = all_user;
--source mysql_test/include/wait_minor_merge.inc
connection default;

--disable_query_log
let $times_check = 0;
while ($times_check < 10)
{
  sleep 10;
  --inc $times_check
  let $partition_count = query_get_value(select count(1) as count from oceanbase.__all_part where table_id = $table_id_ttl, count, 1);
  if ($partition_count > 1) 
  {
    let $times_check = 11;
  }
}
let $times_check = 0;
while ($times_check < 10)
{
  sleep 10;
  --inc $times_check
  let $partition_count = query_get_value(select count(1) as count from oceanbase.__all_part where table_id = $table_id_timeseries, count, 1);
  if ($partition_count > 1) 
  {
    let $times_check = 11;
  }
}
--enable_query_log

select part_func_expr from oceanbase.__all_table where table_name like 'hbase_c_00%info';
select part_func_expr from oceanbase.__all_table where table_name like 'hbase_t_00%info';


--disable_warnings
drop table if exists hbase_c_00$info;
drop table if exists hbase_t_00$info;
--enable_warnings
connection obsys;
alter system set_tp tp_no = 524, error_code = 0, frequency = 0;
connection default;
alter system SET enable_auto_split = false;

#hbase表二级分区分区列可以为其他列

--disable_warnings
drop table if exists test$partitionFamily1sec;
drop table if exists test_changan$info;
--enable_warnings

CREATE TABLE `test$partitionFamily1sec` (
  `K` varbinary(1024) NOT NULL,
  `Q` varbinary(256) NOT NULL,
  `T` bigint(20) NOT NULL,
  `V` varbinary(1024) DEFAULT NULL,
  `G` bigint(20) GENERATED ALWAYS AS (ABS(T)),
  PRIMARY KEY (`K`, `Q`, `T`)
) PARTITION BY RANGE COLUMNS(`G`) SUBPARTITION BY KEY(`K`) SUBPARTITIONS 17 (
  PARTITION `p0` VALUES LESS THAN (1728921600000),
  PARTITION `p1` VALUES LESS THAN (1729008000000),
  PARTITION `p2` VALUES LESS THAN (1729094400000),
  PARTITION `p3` VALUES LESS THAN MAXVALUE
);
drop table test$partitionFamily1sec;

#hbase表一级key分区可以为其他列
create table test_changan$info
(
  K        varbinary(1024),
  Q        varbinary(256),
  T        bigint,
  V        varbinary(1048576) NOT NULL,
  K_PREFIX varbinary(1024) generated always as (substring(K, 1, 13)),
  primary key (K, Q, T)
) partition by key (K_PREFIX) partitions 5;
drop table test_changan$info;

