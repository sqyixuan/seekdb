  k varbinary(1024), 
  q varbinary(256), 
  t bigint, 
  v varbinary(1048576) NOT NULL, 
  primary key(k, q, t)) 
TABLEGROUP =  htable1 partition by range columns(k,q) size("128MB") (partition p1 values less than (MAXVALUE,MAXVALUE));
