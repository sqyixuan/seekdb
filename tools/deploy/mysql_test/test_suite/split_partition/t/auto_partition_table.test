CREATE TABLE pt (c1 double, c2 int)
    PARTITION BY RANGE(c1)
    (PARTITION p0 VALUES LESS THAN(50),
      PARTITION p1 VALUES LESS THAN(100),
      PARTITION p_max VALUES LESS THAN (MAXVALUE)
    );

--disable_warnings
drop table if exists htable1;
drop tablegroup if exists htable1;
--enable_warnings

CREATE TABLEGROUP htable1;
#打开自动分区,hbase表预期选取K键作为分区键
-- echo enable auto_split we expect the 'K' column to be the partition key
alter system set auto_split_tablet_size = '128MB';
--sleep 5 
--echo auto split hbase table should pick K as partition key 
create table htable1 (
  K varbinary(1024), 
  Q varbinary(256), 
  T bigint, 
  V varbinary(1048576) NOT NULL, 
  primary key(K, Q, T)) 
TABLEGROUP =  htable1;
--disable_query_log
let $table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='htable1', table_id, 1);
let $times_insert = 0;
set session ob_query_timeout=1000000000000;	
while ($times_insert < 11)
{
  --inc $times_insert
  insert into htable1(K,Q,T,V) select 
    randstr(10, random()) c1,
    randstr(150, random()) c1,
    uniform(1, 1000, random()),
    randstr(4000, random()) c1
   from 
    table(generator(8000));
}
--enable_query_log

--disable_query_log
let $times_check = 0;
while ($times_check < 10)
{
  sleep 10;
  --inc $times_check
  let $partition_count = query_get_value(select count(1) as count from oceanbase.__all_part where table_id = $table_id, count, 1);
  if ($partition_count > 1) 
  {
    let $times_check = 11;
  }
}
--enable_query_log

--disable_query_log
eval select part_level, part_func_type, part_func_expr, part_num, auto_part, auto_part_size
      from oceanbase.__all_table where table_id = $table_id;
