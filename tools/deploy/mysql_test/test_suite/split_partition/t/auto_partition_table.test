# auto-partitioned partitioned table
CREATE TABLE auto_pt (c1 int, c2 int, c3 int, c4 int default null, c5 int default null, primary key(c1,c2))
    PARTITION BY RANGE COLUMNS(c1) size('1GB')
    (PARTITION p0 VALUES LESS THAN(50),
      PARTITION p1 VALUES LESS THAN(100),
      PARTITION p_max VALUES LESS THAN (MAXVALUE)
    );
CREATE UNIQUE INDEX local_uni_idx ON auto_pt(c1) LOCAL;
CREATE INDEX local_idx ON auto_pt(c2) LOCAL;
CREATE INDEX global_idx ON auto_pt(c3) GLOBAL;
