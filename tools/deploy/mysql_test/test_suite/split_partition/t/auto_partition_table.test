alter system SET enable_auto_split = true;
alter system SET auto_split_tablet_size = '256mb';
--sleep 5
let $enable_auto_split = query_get_value(show parameters where name='enable_auto_split',value,1);
let $auto_split_tablet_size = query_get_value(show parameters where name='auto_split_tablet_size',value,1);
while ($enable_auto_split == 0)
{
  sleep 5;
  let $enable_auto_split = query_get_value(show parameters where name='enable_auto_split',value,1);
}
while ($auto_split_tablet_size != '256mb')
{
  sleep 5;
  let $auto_split_tablet_size = query_get_value(show parameters where name='auto_split_tablet_size',value,1);
}
