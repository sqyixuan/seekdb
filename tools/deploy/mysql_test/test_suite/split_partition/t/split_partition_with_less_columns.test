--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: liujixiong.ljx
# owner group: ddl
# description: to test split ssatbles with less columns.

--echo 1. to split sstable with less columns.
--disable_warnings
drop table if exists test_sstables;
--enable_warnings
create table test_sstables(c1 bigint, c2 bigint, primary key(c1))
  partition by range(c1) (
    partition p0 values less than (1), 
    partition p1 values less than (10000), 
    partition p2 values less than MAXVALUE);
insert into test_sstables values(4000, 4000), (4500, 4500), (5000, 5000), (5500, 5500);
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
alter table test_sstables add column c3 bigint;
alter table test_sstables add column c4 int default 11;
alter table test_sstables add column c5 char(20) default ' oceanbase ';
alter table test_sstables add column c6 char(20) default 'oracle        ';
alter table test_sstables reorganize partition p1 into ( partition p1_0 values less than (5000), partition p1_1 values less than (10000));
select *, hex(c5), hex(c6) from test_sstables order by 1;
drop table test_sstables;

--echo
--echo 2. columns number of scan exceeds columns number in the macro block.
--disable_warnings
drop table if exists test_sstables;
drop sequence if exists seq_small;
drop sequence if exists seq_large;
--enable_warnings
create sequence seq_small INCREMENT BY 1 start with 1 minvalue 1 maxvalue 100000 nocycle noorder nocache;
create sequence seq_large INCREMENT BY 1 start with 5001 minvalue 1 maxvalue 100000 nocycle noorder nocache;
create table test_sstables(c1 bigint, c2 bigint, primary key(c1))
  partition by range(c1) (
    partition p0 values less than (1), 
    partition p1 values less than (10000), 
    partition p2 values less than MAXVALUE);
insert into test_sstables select seq_small.nextval, random() from table(generator(30));
insert into test_sstables select seq_large.nextval, random() from table(generator(30));
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc
alter table test_sstables add column c3 bigint;
alter table test_sstables add column c4 text not null;
alter table test_sstables add column c5 longtext;

insert into test_sstables select seq_small.nextval, random(), random(), randstr(10, random()), randstr(10000, random()) from table(generator(20));
insert into test_sstables select seq_large.nextval, random(), random(), randstr(10, random()), randstr(10000, random()) from table(generator(20));
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

alter table test_sstables add column c6 bigint;
alter table test_sstables add column c7 text;
alter table test_sstables add column c8 longtext not null;
insert into test_sstables (c1, c2, c4, c8) values(5000, 5000, '  oceanbase  ', '  oceanbase--test  ');
--source mysql_test/include/wait_minor_merge.inc
alter table test_sstables reorganize partition p1 into ( partition p1_0 values less than (5000), partition p1_1 values less than (10000));
alter table test_sstables drop primary key;
drop sequence seq_small;
drop sequence seq_large;
drop table test_sstables;
