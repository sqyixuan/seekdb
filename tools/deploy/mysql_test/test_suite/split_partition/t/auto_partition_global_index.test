# owner: lihongqin.lhq
# owner group: storage
# tags: ddl

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings

let $tenant_id = `select effective_tenant_id() from dual`;
connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;

alter system SET enable_auto_split = false;
alter system SET auto_split_tablet_size = '129mb';

--disable_query_log
--enable_query_log

--error 4147
alter system set global_index_auto_split_policy = 'any';

--echo
--echo # create global index on non-partitioned table
create table t1(c1 int primary key, c2 int, c3 int);
create index i1 on t1(c1) global;
create index i2 on t1(c2) global partition by range(c2) (partition p0 values less than (maxvalue));
create index i3 on t1(c2, c1) global partition by range(c2) (partition p0 values less than (maxvalue));
create index i4 on t1(c2, c1) global partition by range columns(c2, c1) (partition p0 values less than (maxvalue, maxvalue));
create index i5 on t1(c3) global partition by hash(c3) partitions 2;
--error 1235
create index i6 on t1(c2, c1) global partition by range(c1) (partition p0 values less than (maxvalue));
select right(table_name,2),index_type,auto_part,auto_part_size from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')order by table_name;
alter table t1 drop index i1, drop index i2, drop index i3, drop index i4, drop index i5;
alter table t1 add index i1(c1) global,
add index i2(c2) global partition by range(c2) (partition p0 values less than (maxvalue)),
add index i3(c2, c1) global partition by range(c2) (partition p0 values less than (maxvalue)),
add index i4(c2, c1) global partition by range columns(c2, c1) (partition p0 values less than (maxvalue, maxvalue)),
add index i5(c3) global partition by hash(c3) partitions 2;
--error 1235
alter table t1 add index i6(c2, c1) global partition by range(c1) (partition p0 values less than (maxvalue));
select right(table_name,2),index_type,auto_part,auto_part_size from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')order by table_name;
drop table t1;

--echo
--echo # create global index on partitioned table
create table t1(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 2;
create index i1 on t1(c1) global;
create index i2 on t1(c2) global partition by range(c2) (partition p0 values less than (maxvalue));
create index i3 on t1(c2, c1) global partition by range(c2) (partition p0 values less than (maxvalue));
create index i4 on t1(c2, c1) global partition by range columns(c2, c1) (partition p0 values less than (maxvalue, maxvalue));
create index i5 on t1(c3) global partition by hash(c3) partitions 2;
--error 1235
create index i6 on t1(c2, c1) global partition by range(c1) (partition p0 values less than (maxvalue));
select right(table_name,2),index_type,auto_part,auto_part_size from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')order by table_name;
alter table t1 drop index i1, drop index i2, drop index i3, drop index i4, drop index i5;
alter table t1 add index i1(c1) global,
add index i2(c2) global partition by range(c2) (partition p0 values less than (maxvalue)),
add index i3(c2, c1) global partition by range(c2) (partition p0 values less than (maxvalue)),
add index i4(c2, c1) global partition by range columns(c2, c1) (partition p0 values less than (maxvalue, maxvalue)),
add index i5(c3) global partition by hash(c3) partitions 2;
--error 1235
alter table t1 add index i6(c2, c1) global partition by range(c1) (partition p0 values less than (maxvalue));
select right(table_name,2),index_type,auto_part,auto_part_size from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')order by table_name;
drop table t1;

--echo
--echo # create non-partitioned table with global index
create table t1(c1 int primary key, c2 int, c3 int,
  index i1(c1) global,
  index i2(c2) global partition by range(c2) (partition p0 values less than (maxvalue)),
  index i3(c2, c1) global partition by range(c2) (partition p0 values less than (maxvalue)),
  index i4(c2, c1) global partition by range columns(c2, c1) (partition p0 values less than (maxvalue, maxvalue)),
  index i5(c3) global partition by hash(c3) partitions 2);
select right(table_name,2),index_type,auto_part,auto_part_size from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')order by table_name;
drop table t1;

--echo
--echo # create partitioned table with global index
create table t1(c1 int primary key, c2 int, c3 int,
  index i1(c1) global,
  index i2(c2) global partition by range(c2) (partition p0 values less than (maxvalue)),
  index i3(c2, c1) global partition by range(c2) (partition p0 values less than (maxvalue)),
  index i4(c2, c1) global partition by range columns(c2, c1) (partition p0 values less than (maxvalue, maxvalue)),
  index i5(c3) global partition by hash(c3) partitions 2) partition by hash(c1) partitions 2;
select right(table_name,2),index_type,auto_part,auto_part_size from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')order by table_name;
drop table t1;

--echo
--echo # disable global index auto split when create
alter system set global_index_auto_split_policy='off';
create table t1(c1 int primary key, c2 int) partition by range(c1) size('128mb') (partition p0 values less than (10), partition p1 values less than (maxvalue));
create index i1 on t1(c2) global;
select auto_part,auto_part_size,table_type,part_num from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1' order by schema_version desc limit 1);
drop table t1;

--echo
--echo # disable global index auto split after create
connection obsys;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TABLET_SIZE", error_code = 1048576, frequency = 1;
connection default;
alter system set global_index_auto_split_policy = 'all';
create table t1(c1 varchar(2048), c2 int) partition by hash(c2) partitions 2;
create index i1 on t1(c1) global;
select auto_part,auto_part_size,table_type,part_num from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1' order by schema_version desc limit 1);
alter system set global_index_auto_split_policy = 'off';
insert into t1 select randstr(2048, random()), 1 from table(generator(2000));
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
sleep 10;
select auto_part,auto_part_size,table_type,part_num from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1' order by schema_version desc limit 1);
alter system reset global_index_auto_split_policy;

connection obsys;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TABLET_SIZE", error_code = 0, frequency = 0;

--disable_query_log
--enable_query_log

