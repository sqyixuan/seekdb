# owner: lihongqin.lhq
# owner group: storage
# description: this case is use for testing OB_TABLET_IS_SPLIT_SRC error
#

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t2x;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '60s';
sleep 3;
set ob_global_debug_sync = 'reset';

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn5,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

let $tenant_id = `select effective_tenant_id() from dual`;

--echo
--echo # __all_virtual_memstore_info
create table t1(c1 int, c2 int, c3 char(10), c4 int, c5 text, primary key(c1)) partition by range(c1) (
  partition p0 values less than (10),
  partition p1 values less than (20),
  partition p2 values less than (maxvalue));
create index i1 on t1(c1) local;
create index i2 on t1(c2) global;
let $table_id = `select table_id from oceanbase.__all_table where table_name = 't1'`;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for continue_signal execute 10000';
connection conn1;
send alter table t1 reorganize partition p0 into (partition p00 values less than (5), partition p01 values less than (10));
connection obsys;
sleep 3;
--disable_query_log
eval select count(*) from __all_virtual_memstore_info where tablet_id = (select target_object_id from __all_virtual_ddl_task_status where object_id = $table_id);
--enable_query_log
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection conn1;
reap;
connection default;
drop table t1;

