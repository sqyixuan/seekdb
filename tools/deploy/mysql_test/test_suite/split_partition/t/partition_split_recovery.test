#测试单表的全局索引自动分裂, 然后同时进行兜底恢复
connection obsys1;
alter system set debug_sync_timeout = '600s';
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for continue_signal1 execute 100000';


connection conn1;
alter system set enable_auto_split=true;
--disable_warnings
drop table if exists t11; 
--enable_warnings
create table t11(a int, b VARCHAR(150), c int, d VARCHAR(4000),primary key(a,b,c))  
partition by range(a) (partition p0 values less than (5000000),
partition p1 values less than (10000000), 
partition p2 values less than (25000000), 
partition p3 values less than (50000000),
partition p4 values less than (75000000),
partition p5 values less than (90000000),  
partition p6 values less than (MAXVALUE));

create index gkey ON t11(c,d) GLOBAL PARTITION BY RANGE(c) (partition p0 values less than (MAXVALUE));
set ob_query_timeout=100000000000000;

let $times_insert = 0;
while ($times_insert < 10)
{
  --inc $times_insert
  insert into t11(a,b,c,d) select 
    uniform(1, 100000000, random()),
    randstr(150, random()) c1,
    uniform(1, 1000, random()),
    randstr(4000, random()) c1
  from 
    table(generator(8000));
}

connection obsys1;
ALTER SYSTEM MINOR FREEZE TENANT = ALL;

sleep 80; #wait auto split task start 

select ddl_type from __all_virtual_ddl_task_status;

let $table_id  = `select table_id from oceanbase.__all_virtual_table where table_name='t11'`;
let $gidx_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where data_table_id=$table_id, table_id, 1);
let $trace_id = query_get_value(select trace_id from oceanbase.__all_virtual_ddl_task_status where object_id = $gidx_table_id order by gmt_create, trace_id, 1);
--disable_query_log
eval alter system cancel task '$trace_id';
--enable_query_log

set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal1';


let $times_check = 0;
while ($times_check < 30) 
{
  --sleep 10
  --inc $times_check
  let $num = query_get_value(select count(1) as count from __all_virtual_ddl_task_status where ddl_type = 100 or ddl_type = 102, count, 1);
  if ($num == 0) 
  {
    let $times_check = 30;
  }
}

select * from __all_virtual_ddl_task_status where ddl_type = 100 or ddl_type = 102;
connection conn1;
select count(*) from t11;

--disable_query_log
eval select index_status, index_type, index_column_num from oceanbase.__all_table where data_table_id = '$table_id';
--enable_query_log
drop table t11;
alter system set enable_auto_split=false;


#测试单表的多个分区分裂任务卡住及该表上的全局索引多个分区自动分裂卡住, 然后同时进行兜底恢复
connection obsys1;
alter system set debug_sync_timeout = '600s';
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for continue_signal1 execute 100000';


connection conn1;
alter system set enable_auto_split=true;
set ob_query_timeout=100000000000000;
--disable_warnings
drop table if exists t11; 
--enable_warnings
create table t11(a int, b VARCHAR(150), c int, d VARCHAR(4000),primary key(a,b,c))  
partition by range(a) (partition p0 values less than (50000000), partition p1 values less than (MAXVALUE));

create index gkey ON t11(c,d) GLOBAL PARTITION BY RANGE(c) (partition p0 values less than (50000000), partition p1 values less than (MAXVALUE));



let $times_insert = 0;
while ($times_insert < 10)
{
  --inc $times_insert
  insert into t11(a,b,c,d) select 
    uniform(1, 100000000, random()),
    randstr(150, random()) c1,
    uniform(1, 100000000, random()),
    randstr(4000, random()) c1
  from 
    table(generator(15000));
}

connection obsys1;
ALTER SYSTEM MINOR FREEZE TENANT = ALL;

sleep 100; #wait auto split task start 

select ddl_type from __all_virtual_ddl_task_status;

let $table_id  = `select table_id from oceanbase.__all_virtual_table where table_name='t11'`;
let $trace_id = query_get_value(select trace_id from oceanbase.__all_virtual_ddl_task_status where object_id = $table_id order by gmt_create, trace_id, 1);
--disable_query_log
eval alter system cancel task '$trace_id';
--enable_query_log

set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal1';
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal1';
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal1';
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal1';

let $times_check = 0;
while ($times_check < 40) 
{
  --sleep 10
  --inc $times_check
  let $num = query_get_value(select count(1) as count from __all_virtual_ddl_task_status where ddl_type = 100 or ddl_type = 102, count, 1);
  if ($num == 0) 
  {
    let $times_check = 40;
  }
}

select * from __all_virtual_ddl_task_status where ddl_type = 100 or ddl_type = 102;
connection conn1;
select count(*) from t11;

--disable_query_log
eval select index_status, index_type, index_column_num from oceanbase.__all_table where data_table_id = '$table_id';
--enable_query_log
drop table t11;
alter system set enable_auto_split=false;
