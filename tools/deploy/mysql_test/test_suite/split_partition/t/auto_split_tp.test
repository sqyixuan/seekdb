# owner: lihongqin.lhq
# owner group: storage
# description: this case is use for testing ddl_stmt_str generated by auto split
#

--disable_warnings
drop table if exists ts;
drop table if exists t1;
drop table if exists t2;
drop table if exists t2x;
drop table if exists ```t1```;
--enable_warnings

purge recyclebin;

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '60s';
sleep 3;
set ob_global_debug_sync = 'reset';

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn5,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connection default;
set ob_query_timeout = 1000000000;

--echo
--echo # smaller auto split size;
connection obsys;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TABLET_SIZE", error_code = 1048576, frequency = 1;
sleep 2;
connection default;
alter system set enable_auto_split = true;
sleep 3;
create table t1(c1 int primary key, c2 varchar(1024));
insert into t1 select row_number() over (), randstr(1024, random()) from table(generator(2000));
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
let $part_cnt = query_get_value(select count(*) as cnt from information_schema.partitions where table_name = 't1',cnt,1);
while ($part_cnt <= 1) {
  let $part_cnt = query_get_value(select count(*) as cnt from information_schema.partitions where table_name = 't1',cnt,1);
  sleep 1;
}
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
drop table t1;
alter system set enable_auto_split = false;
connection obsys;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TABLET_SIZE", error_code = 0, frequency = 0;
connection default;

--echo
--echo # delay data split
connection obsys;
alter system set_tp tp_name = "EN_WRITE_SPLIT_START_LOG_DELAY_SEC", error_code = 20, frequency = 1;
sleep 2;
connection default;
create table t1(c1 int primary key) partition by range(c1) (partition p0 values less than (10));
insert into t1 values (1), (6);
send alter table t1 reorganize partition p0 into (partition p00 values less than (5), partition p01 values less than (10));
connection conn1;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
connection conn1;
sleep 5;
select ddl_type, status from oceanbase.__all_ddl_task_status;
connection obsys;
alter system set_tp tp_name = "EN_WRITE_SPLIT_START_LOG_DELAY_SEC", error_code = 0, frequency = 0;
connection default;
reap;
drop table t1;

--echo
--echo # block auto split schedule
connection obsys;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TABLET_SIZE", error_code = 1048576, frequency = 1;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TASK_CNT_LESS_THAN", error_code = 1, frequency = 1;
sleep 2;
connection default;
alter system set enable_auto_split = true;
create table t1(c1 int primary key, c2 varchar(1024));
insert into t1 select row_number() over (), randstr(1024, random()) from table(generator(2000));
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
sleep 10;
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
drop table t1;
alter system set enable_auto_split = false;
connection obsys;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TABLET_SIZE", error_code = 0, frequency = 0;
alter system set_tp tp_name = "EN_AUTO_SPLIT_TASK_CNT_LESS_THAN", error_code = 0, frequency = 0;
connection default;

connection obsys;
alter system reset debug_sync_timeout;

