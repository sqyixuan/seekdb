##owner: zhenjiang.xzj
##owner group: 底层引擎部-存储-索引与DDL
##description: 自动分区分裂全局索引
##tags: split_partition

--disable_warnings
drop table if exists t22;

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--sleep 2


#test global index key with range key 
connection conn1;
alter system set enable_auto_split = true;
--sleep 5
set session ob_query_timeout=1000000000000;	

create table t22(c1 int primary key, c2 int, index(c1,c2), index(c2));
create index i1 on t22(c1,c2);
create index i2 on t22(c2);
alter table t22 add index(c1,c2);
alter table t22 add index(c2);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t22;

drop table t22;
create table t22(café int primary key, c2 int, index(cafe, c2), index(c2));
create index i1 on t22(cafe,c2);
create index i2 on t22(c2);
alter table t22 add index(cafe,c2);
alter table t22 add index(c2);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t22;

drop table t22;
create table t22(c1 int primary key, c2 int, index(C1, c2), index(c2));
create index i1 on t22(C1,c2);
create index i2 on t22(c2);
alter table t22 add index(C1,c2);
alter table t22 add index(c2);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t22;

connection conn1;
drop table t22;
alter system set enable_auto_split = false;
--enable_warnings
