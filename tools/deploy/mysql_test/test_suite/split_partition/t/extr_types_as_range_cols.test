create table t22(a timestamp, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a,b,c)) partition by range columns(a);
alter table t22 partition by range columns(a) (partition p1 values less than('2024-08-20 20:29:57'), partition p2 values less than MAXVALUE);
alter table t22 reorganize partition p1 into (partition p1_1 values less than('2024-08-20 20:00:00'), partition p2_2 values less than('2024-08-20 20:29:57'));
let $table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 't22', table_id, 1);
--replace_regex /table_id = [0-9]*/table_id = t22_id/g
eval select count(1) from oceanbase.__all_part where table_id = $table_id;
drop table t22;

#test auto_part table with special range column(timestamp, decimal, double, float, etc.)
--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11,t12,t13,t14,t15,t16,t17,t18,t19,t20,t21,t22,t23,t24,t25,t26,t27;
--enable_warnings
# test partition by range()
create table t1(a timestamp, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range ();
create table t2(a decimal, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range ();
create table t3(a float, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range ();
create table t4(a double, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range ();
create table t5(a int, b VARCHAR(150), c timestamp, d VARCHAR(4000), primary key(a)) partition by range ();
create table t6(a numeric, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range ();
create table t7(a date, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range ();
create table t8(a time, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range ();
create table t9(a datetime, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range ();
create table t10(a varchar(1024), b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range ();
create table t11(a varbinary(1024), b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range ();
create table t12(a char, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range ();
create table t13(a binary, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range ();
create table t14(a int, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range columns(a);
create table t15(a double, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range columns(a);
create table t16(a int, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a)) partition by range (a);
create table t17(a int, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a));
create table t18(a double, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a));
create table t19(a int, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a));
create table t20(a int, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a, b)) partition by range ();
Create table t21(a int,primary key(a));
Create table t22(a double,primary key(a));
Create table t23(a int, b int, primary key(a, b));
Create table t24(a int,primary key(a)) partition by range columns();
Create table t25(a double,primary key(a)) partition by range columns();
Create table t26(a int, b int, primary key(a, b)) partition by range columns();
Create table t27(a int, b int, primary key(a, b)) partition by range columns(a, b);
alter table t17 partition by range columns(a);
alter table t18 partition by range columns(a);
alter table t19 partition by range (a);

--replace_regex /database_id = [0-9]*/database_id = db_id/g
eval select part_func_type,table_name from oceanbase.__all_table where table_name in ('t1','t2','t3','t4','t5','t6','t7','t8',
                                                                                't9','t10','t11','t12','t13','t14','t15','t16',
                                                                                't17','t18','t19','t20','t21','t22','t23',
                                                                                 't24', 't25', 't26', 't27') and database_id = $db_id order by table_name;
alter table t17 partition by range (a);
alter table t19 partition by range columns(a);
--replace_regex /database_id = [0-9]*/database_id = db_id/g
eval select part_func_type,table_name from oceanbase.__all_table where table_name in ('t17', 't19') and database_id = $db_id order by table_name;

alter table t17 partition by range();
alter table t18 partition by range();
alter table t19 partition by range();
--replace_regex /database_id = [0-9]*/database_id = db_id/g
eval select part_func_type,table_name from oceanbase.__all_table where table_name in ('t17','t18', 't19') and database_id = $db_id order by table_name;

alter table t17 partition by range columns();
alter table t18 partition by range columns();
alter table t19 partition by range columns();
--replace_regex /database_id = [0-9]*/database_id = db_id/g
eval select part_func_type,table_name from oceanbase.__all_table where table_name in ('t17','t18', 't19') and database_id = $db_id order by table_name;

ALTER TABLE t1 DROP PRIMARY KEY, ADD PRIMARY KEY(c);
ALTER TABLE t2 DROP PRIMARY KEY, ADD PRIMARY KEY(c);
ALTER TABLE t3 DROP PRIMARY KEY, ADD PRIMARY KEY(c);
ALTER TABLE t4 DROP PRIMARY KEY, ADD PRIMARY KEY(c);
ALTER TABLE t5 DROP PRIMARY KEY, ADD PRIMARY KEY(a,c);
--replace_regex /database_id = [0-9]*/database_id = db_id/g
eval select part_func_type,table_name from oceanbase.__all_table where table_name in ('t1','t2','t3','t4','t5') and database_id = $db_id order by table_name;
drop table t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11,t12,t13,t14,t15,t16,t17,t18,t19,t20,t21,t22,t23,t24,t25,t26,t27;


#test alter table auto_partition 
create table t1(a int, b int, primary key(a,b));
ALTER TABLE t1 PARTITION BY RANGE COLUMNS(a,b) SIZE('1GB');
create table t2(a double, primary key(a));
ALTER TABLE t2 PARTITION BY RANGE() SIZE('1GB');
create table t3(a int, b int, primary key(a));
ALTER TABLE t3 PARTITION BY RANGE(a) SIZE('1GB');
create table t4(a int, b int, primary key(a));
ALTER TABLE t4 PARTITION BY RANGE() SIZE('1GB');
--replace_regex /database_id = [0-9]*/database_id = db_id/g
eval select part_func_type,table_name from oceanbase.__all_table where table_name in ('t1','t2','t3','t4') and database_id = $db_id order by table_name;
drop table t1,t2,t3,t4;



#test global index table with special range column(timestamp, decimal, double, float)
create table t1(a timestamp, b VARCHAR(150), c int, d VARCHAR(4000), e double, f int, g decimal unsigned, primary key(a)) partition by range ();
--error 1235
create index gkey on t1(b) global partition by range columns(b);
--error 1235
create index gkey on t1(b) global partition by range();
create index 1_global_key on t1(b) global partition by range columns(b) (
  partition p0 values less than ('a'), 
  partition p1 values less than ('b'), 
  partition p2 values less than MAXVALUE
);


create index 2_global_key on t1(e) global;
create index 3_global_key on t1(c) global;
create index 4_global_key on t1(c,e) global;
create index 5_global_key on t1(c,f) global;
create index 6_global_key on t1(g) global;
--replace_regex /database_id = [0-9]*/database_id = db_id/g
let $t1_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1' and database_id = $db_id, table_id, 1);
let $a_global_key = query_get_value(select table_id from oceanbase.__all_table where table_name like '%1_global_key%' and data_table_id = $t1_id, table_id, 1);
let $b_global_key = query_get_value(select table_id from oceanbase.__all_table where table_name like '%2_global_key%' and data_table_id = $t1_id, table_id, 1);
let $c_global_key = query_get_value(select table_id from oceanbase.__all_table where table_name like '%3_global_key%' and data_table_id = $t1_id, table_id, 1);
let $d_global_key = query_get_value(select table_id from oceanbase.__all_table where table_name like '%4_global_key%' and data_table_id = $t1_id, table_id, 1);
let $e_global_key = query_get_value(select table_id from oceanbase.__all_table where table_name like '%5_global_key%' and data_table_id = $t1_id, table_id, 1);
let $f_global_key = query_get_value(select table_id from oceanbase.__all_table where table_name like '%6_global_key%' and data_table_id = $t1_id, table_id, 1);

--replace_regex /table_id = [0-9]*/table_id = gkey_id/g
eval select part_func_type,part_func_expr from oceanbase.__all_table where table_id = $a_global_key;
--replace_regex /table_id = [0-9]*/table_id = gkey_id/g
eval select part_func_type,part_func_expr from oceanbase.__all_table where table_id = $b_global_key;
--replace_regex /table_id = [0-9]*/table_id = gkey_id/g
eval select part_func_type,part_func_expr from oceanbase.__all_table where table_id = $c_global_key;
--replace_regex /table_id = [0-9]*/table_id = gkey_id/g
eval select part_func_type,part_func_expr from oceanbase.__all_table where table_id = $d_global_key;
--replace_regex /table_id = [0-9]*/table_id = gkey_id/g
eval select part_func_type,part_func_expr from oceanbase.__all_table where table_id = $e_global_key;
--replace_regex /table_id = [0-9]*/table_id = gkey_id/g
eval select part_func_type,part_func_expr from oceanbase.__all_table where table_id = $f_global_key;
drop table t1;
alter system SET enable_auto_split = false;
--sleep 5
