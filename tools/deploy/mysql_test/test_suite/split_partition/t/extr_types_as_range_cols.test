#test timestamp
create table t22(a timestamp, b int, c int default null, primary key(a)) partition by range columns(a) (partition p0 values less than ('2023-04-03 11:30:45'), partition p1 values less than ('2023-04-07 15:25:10'), partition p2 values less than MAXVALUE);

