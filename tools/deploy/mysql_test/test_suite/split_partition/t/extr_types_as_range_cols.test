let $table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 't22', table_id, 1);
--replace_regex /table_id = [0-9]*/table_id = t22_id/g
eval select count(1) from oceanbase.__all_part where table_id = $table_id;
drop table t22;


create table t22(a decimal(8,3), b VARCHAR(150), c int, d VARCHAR(4000), primary key(a,c)) partition by range columns(a);
alter table t22 partition by range columns(a) (partition p1 values less than(100), partition p2 values less than MAXVALUE);
alter table t22 reorganize partition p1 into (partition p1_1 values less than(50), partition p1_2 values less than(100));
let $table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 't22', table_id, 1);
