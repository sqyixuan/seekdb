##owner: ly435438
##owner group: 底层引擎部-存储-索引与DDL
##description: test manul split of tablet having decimal,double,float,timestamp as range coulmns


#test double

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;


connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

--disable_query_log
--disable_warnings
drop table if exists t22;
--enable_warnings
alter system SET enable_auto_split = false;
--sleep 5
let $enable_auto_split = query_get_value(show parameters where name='enable_auto_split',value,1);
while ($enable_auto_split == 1)
{
  sleep 10;
  let $enable_auto_split = query_get_value(show parameters where name='enable_auto_split',value,1);
}
--enable_query_log

create table t22(a double, b int, c int default null, primary key(a)) partition by range columns(a) (partition p0 values less than (3.0), partition p1 values less than (6.1), partition p2 values less than MAXVALUE);

let $t22_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 't22', table_id, 1);
let $db_id = query_get_value(select database_id from oceanbase.__all_database where database_name = 'test', database_id, 1);

insert into t22(a, b) values(5.6, 0);
insert into t22(a, b) values(5.7, 1);
insert into t22(a, b) values(5.8, 2);
insert into t22(a, b) values(5.9, 3);
insert into t22(a, b) values(6.0, 4);
insert into t22(a, b) values(6.1, 5);
insert into t22(a, b) values(6.2, 6);
insert into t22(a, b) values(6.3, 7);
insert into t22(a, b) values(6.4, 8);
alter table t22 reorganize partition p1 into (partition p1_0 values less than (5.8), partition p1_1 values less than (6.1));
--replace_regex /table_id = [0-9]*/table_id = t22_id/g
eval select part_name from oceanbase.__all_part where table_id = $t22_id;
--replace_regex /table_id = [0-9]*/table_id = t22_id/g
eval select high_bound_val from oceanbase.__all_part where table_id = $t22_id order by high_bound_val;
--replace_regex /table_id = [0-9]*/table_id = t22_id/g
eval select part_func_type from oceanbase.__all_table where table_id = $t22_id;
select * from t22 partition(p0);
select * from t22 partition(p1_0);
select * from t22 partition(p1_1);
select * from t22 partition(p2);

drop table t22;



