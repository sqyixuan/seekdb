drop table t22;


#test mixed timestamp, decimal, double, float 

create table t22(a double, b float, c decimal(5,2), d timestamp, primary key(a, b, c, d)) partition by range columns(a, b, c, d) (partition p0 values less than (10.0, 100.1, 59.22, '2023-04-01 08:15:30'), 
partition p1 values less than (100.0, 100.2, 59.22, '2023-04-01 08:15:30'), partition p2 values less than (MAXVALUE, MAXVALUE, MAXVALUE, MAXVALUE));
let $t22_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 't22', table_id, 1);
insert into t22(a, b, c, d) values(5.0, 100.2, 59.22, '2023-04-01 08:15:30');
insert into t22(a, b, c, d) values(10.0, 99.2, 59.22, '2023-04-01 08:15:30');
insert into t22(a, b, c, d) values(25.99, 100.2, 59.22, '2023-04-01 08:15:30');
insert into t22(a, b, c, d) values(50.0, 100.2, 59.22, '2023-04-01 08:15:30');
insert into t22(a, b, c, d) values(100.0, 100.2, 59.22, '2023-04-01 07:15:30');
insert into t22(a, b, c, d) values(199.99, 100.2, 59.22, '2023-04-01 08:15:30');
insert into t22(a, b, c, d) values(200.0, 100.2, 59.22, '2023-04-01 08:15:30');
insert into t22(a, b, c, d) values(300.0, 100.2, 59.22, '2023-04-01 08:15:30');
insert into t22(a, b, c, d) values(500.0, 100.2, 59.22, '2023-04-01 08:15:30');
alter table t22 reorganize partition p1 into (partition p1_0 values less than (50.0, 100.2, 59.22, '2023-04-01 08:15:30'), partition p1_1 values less than (100.0, 100.2, 59.22, '2023-04-01 08:15:30'));
--replace_regex /table_id = [0-9]*/table_id = t22_id/g
eval select part_name from oceanbase.__all_part where table_id = $t22_id;
--replace_regex /table_id = [0-9]*/table_id = t22_id/g
eval select high_bound_val from oceanbase.__all_part where table_id = $t22_id order by high_bound_val;
--replace_regex /table_id = [0-9]*/table_id = t22_id/g
eval select part_func_type from oceanbase.__all_table where table_id = $t22_id;
select * from t22 partition(p0);
select * from t22 partition(p1_0);
select * from t22 partition(p1_1);
select * from t22 partition(p2);
drop table t22;

# test auto_split 
SET ob_query_timeout = 100000000000;
--disable_query_log
alter system SET enable_auto_split = true;
alter system SET auto_split_tablet_size = '128mb';
--sleep 5
let $enable_auto_split = query_get_value(show parameters where name='enable_auto_split',value,1);
while ($enable_auto_split == 0)
{
  sleep 10;
  let $enable_auto_split = query_get_value(show parameters where name='enable_auto_split',value,1);
}
--enable_query_log

create table t22(a double, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a,c)) partition by range columns(a);
alter table t22 partition by range columns(a) (partition p1 values less than(100), partition p2 values less than MAXVALUE);
alter table t22 reorganize partition p1 into (partition p1_1 values less than(50), partition p1_2 values less than(100));
let $table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 't22', table_id, 1);
--replace_regex /table_id = [0-9]*/table_id = t22_id/g
eval select count(1) from oceanbase.__all_part where table_id = $table_id;
drop table t22;


create table t22(a float, b VARCHAR(150), c int, d VARCHAR(4000), primary key(a,c)) partition by range columns(a);
