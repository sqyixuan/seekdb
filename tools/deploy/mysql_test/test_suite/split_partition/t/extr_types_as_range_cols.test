insert into t22(a, b) values('2023-04-09 17:33:29', 8);
alter table t22 reorganize partition p1 into (partition p1_0 values less than ('2023-04-04 12:05:55'), partition p1_1 values less than ('2023-04-07 15:25:10'));
--replace_regex /table_id = [0-9]*/table_id = t22_id/g
