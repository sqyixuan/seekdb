# owner: lihongqin.lhq
# owner group: storage
# description: this case is use for testing ddl_stmt_str generated by auto split
#

--disable_warnings
drop table if exists ts;
drop table if exists t1;
drop table if exists t2;
drop table if exists t2x;
drop table if exists ```t1```;
--enable_warnings

purge recyclebin;

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '60s';
sleep 3;
set ob_global_debug_sync = 'reset';

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn5,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connection default;
set ob_query_timeout = 1000000000;

alter system set enable_auto_split = true;
sleep 3;

--echo
--echo # prepare source table
create table ts(c1 int auto_increment primary key);
insert into ts select null from table(generator(50000));

--echo
--echo # single int primary key non-partitioned table without presetting partition key
create table ```t1```(```a``A` int auto_increment primary key, d VARCHAR(4000));
insert into ```t1```(d) select randstr(4000, random()) from table(generator(50000));
let $part_cnt = query_get_value(select count(*) as cnt from information_schema.partitions where table_name = '`t1`',cnt,1);
while ($part_cnt <= 1) {
  let $part_cnt = query_get_value(select count(*) as cnt from information_schema.partitions where table_name = '`t1`',cnt,1);
  sleep 1;
}
select partition_name from information_schema.partitions where table_name = '`t1`' order by 1;
--replace_regex /VALUES LESS THAN \([0-9]+/VALUES LESS THAN (.../g
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = '`t1`') order by schema_version;
drop table ```t1```;

--echo
--echo # single double primary key non-partitioned table without presetting partition key
create table t1(c1 double primary key, c2 VARCHAR(4000));
insert into t1 select c1, randstr(4000, random()) from ts; 
let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
while ($part_cnt <= 1) {
  let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
  sleep 1;
}
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
--replace_regex /VALUES LESS THAN \([0-9.]+/VALUES LESS THAN (.../g
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = 't1') order by schema_version;
drop table t1;

--echo
--echo # single date primary key non-partitioned table without presetting partition key
create table t1(c1 date primary key, c2 VARCHAR(4000));
insert into t1 select date_add('1000-01-01', interval (c1) day), randstr(4000, random()) from ts; 
let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
while ($part_cnt <= 1) {
  let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
  sleep 1;
}
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
--replace_regex /VALUES LESS THAN \('[0-9:-]+'/VALUES LESS THAN ('...'/g
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = 't1') order by schema_version;
drop table t1;

--echo
--echo # single datetime primary key non-partitioned table without presetting partition key
create table t1(`C1` datetime primary key, c2 VARCHAR(4000));
insert into t1 select timestampadd(day, c1, '1000-01-01 00:00:00'), randstr(4000, random()) from ts; 
let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
while ($part_cnt <= 1) {
  let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
  sleep 1;
}
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
--replace_regex /VALUES LESS THAN \('[0-9 :-]+'/VALUES LESS THAN ('...'/g
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = 't1') order by schema_version;
drop table t1;

--echo
--echo # single char primary key non-partitioned table without presetting partition key
create table t1(`C1` char(10) primary key, c2 VARCHAR(4000));
insert into t1 select c1, randstr(4000, random()) from ts; 
let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
while ($part_cnt <= 1) {
  let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
  sleep 1;
}
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
--replace_regex /VALUES LESS THAN \('[0-9]+'/VALUES LESS THAN ('...'/g
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = 't1') order by schema_version;
drop table t1;

--echo
--echo # single binary primary key non-partitioned table without presetting partition key
create table t1(c1 binary(10) primary key, c2 VARCHAR(4000));
insert into t1 select c1, randstr(4000, random()) from ts; 
let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
while ($part_cnt <= 1) {
  let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
  sleep 1;
}
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
--replace_regex /VALUES LESS THAN \('[0-9]+'/VALUES LESS THAN ('...'/g
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = 't1') order by schema_version;
drop table t1;

--echo
--echo # multi primary key non-partitioned table without presetting partition key
create table t1(a int, `B` VARCHAR(150), d VARCHAR(4000), primary key(b,a));
insert into t1(a,b,d) select c1, randstr(150, random()), randstr(4000, random()) from ts;
let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
while ($part_cnt <= 1) {
  let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
  sleep 1;
}
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
--replace_regex /VALUES LESS THAN \('[0-9a-zA-Z]+',[0-9]+/VALUES LESS THAN ('...',.../g
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = 't1') order by schema_version;
drop table t1;

alter system set enable_auto_split = false;
sleep 3;

--echo
--echo # single primary key non-partitioned table with presetting partition key
create table t1(a int auto_increment primary key, d VARCHAR(4000)) partition by range(a) size('128MB');
insert into t1(d) select randstr(4000, random()) from table(generator(50000));
let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
while ($part_cnt <= 1) {
  let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
  sleep 1;
}
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
--replace_regex /VALUES LESS THAN \([0-9]+/VALUES LESS THAN (.../g
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = 't1') order by schema_version;
drop table t1;

--echo
--echo # single primary key non-partitioned table with presetting partition key containing comma
create table t1(```a,b``` int auto_increment primary key, d VARCHAR(4000)) partition by range(```a,b```) size('128MB');
insert into t1(d) select randstr(4000, random()) from table(generator(50000));
let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
while ($part_cnt <= 1) {
  let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
  sleep 1;
}
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
--replace_regex /VALUES LESS THAN \([0-9]+/VALUES LESS THAN (.../g
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = 't1') order by schema_version;
drop table t1;

--echo
--echo # multi primary key non-partitioned table with presetting partition key
create table t1(`A` int auto_increment, b VARCHAR(150), d VARCHAR(4000), primary key(`A`,b)) partition by range(`A`) size('128MB');
insert into t1(b,d) select randstr(150, random()), randstr(4000, random()) from table(generator(50000));
let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
while ($part_cnt <= 1) {
  let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
  sleep 1;
}
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
--replace_regex /VALUES LESS THAN \([0-9]+/VALUES LESS THAN (.../g
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = 't1') order by schema_version;
drop table t1;
create table t1(a int auto_increment, b VARCHAR(150), d VARCHAR(4000), primary key(a,b)) partition by range columns(a,b) size('128MB');
insert into t1(b,d) select randstr(150, random()), randstr(4000, random()) from table(generator(50000));
let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
while ($part_cnt <= 1) {
  let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
  sleep 1;
}
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
--replace_regex /VALUES LESS THAN \([0-9]+,\'[0-9a-zA-Z]+\'/VALUES LESS THAN (...,'...'/g
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = 't1') order by schema_version;
drop table t1;

--echo
--echo # single primary key partitioned table
create table t1(a int auto_increment primary key, d VARCHAR(4000)) partition by range(a) size('128MB') (partition ```p0,p1``` values less than (maxvalue));
insert into t1(d) select randstr(4000, random()) from table(generator(50000));
let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
while ($part_cnt <= 1) {
  let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
  sleep 1;
}
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
--replace_regex /VALUES LESS THAN \([0-9]+/VALUES LESS THAN (.../g
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = 't1') order by schema_version;
drop table t1;

--echo
--echo # multi primary key partitioned table
create table t1(a int auto_increment, b VARBINARY(150), c int, d VARCHAR(4000), primary key(a,b,c)) partition by range columns(a,b) size('128MB') (partition ```p0,p1``` values less than (maxvalue, maxvalue));
insert into t1(b,c,d) select randstr(150, random()), uniform(1, 100000000, random()), randstr(4000, random()) from table(generator(50000));
let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
while ($part_cnt <= 1) {
  let $part_cnt = `select count(*) from information_schema.partitions where table_name = 't1'`;
  sleep 1;
}
select partition_name from information_schema.partitions where table_name = 't1' order by 1;
--replace_regex /VALUES LESS THAN \([0-9]+,\'[0-9a-zA-Z]+\'/VALUES LESS THAN (...,'...'/g
select ddl_stmt_str from oceanbase.__all_ddl_operation where ddl_stmt_str != '' and table_id = (select table_id from oceanbase.__all_table where table_name = 't1') order by schema_version;
drop table t1;

