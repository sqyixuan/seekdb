# owner: lihongqin.lhq
# owner group: storage
# description: this case is use for testing global index presplit
#

--disable_warnings
drop table if exists ts;
drop table if exists t1;
drop table if exists t2;
drop table if exists t2x;
drop table if exists ```t1```;
--enable_warnings

purge recyclebin;

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '60s';
sleep 3;
set ob_global_debug_sync = 'reset';

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connect (conn5,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 1000000000;
connection default;
set ob_query_timeout = 1000000000;

alter system set global_index_auto_split_policy = 'off';

--echo
--echo # presplit with drop column offline ddl
create table t1(c1 int primary key, c2 varchar(2048), c3 int, c4 int) partition by range(c1) (partition p0 values less than (maxvalue));
insert into t1 select row_number() over(), randstr(2048, random()), 1, null from table(generator(100000));
create index i1 on t1(c1,c2,c3,c4) global;
alter table t1 partition by range() size('128MB');
alter table t1 drop c3;
alter table t1 force;
select part_level, part_func_type, part_func_expr, part_num, sub_part_func_type, sub_part_func_expr, sub_part_num from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1');
select part_type, part_num, sub_part_type, def_sub_part_num, part_expr, sub_part_expr from oceanbase.__all_part_info where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1'));
select count(*) from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1'));
drop table t1;

--echo
--echo # presplit to multiple columns (with range column type)
create table t1(c1 int primary key, c2 varchar(2048), c3 int, c4 int) partition by range(c1) (partition p0 values less than (maxvalue));
insert into t1 select row_number() over(), randstr(2048, random()), 1, null from table(generator(100000));
create index i1 on t1(c2,c3,c4) global;
alter table t1 partition by range() size('128MB');
alter table t1 drop c3;
alter table t1 force;
select part_level, part_func_type, part_func_expr, part_num, sub_part_func_type, sub_part_func_expr, sub_part_num from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1');
select part_type, part_num, sub_part_type, def_sub_part_num, part_expr, sub_part_expr from oceanbase.__all_part_info where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1'));
select count(*) from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1'));
drop table t1;

--echo
--echo # presplit to single column (with range column type)
create table t1(c1 int primary key, c2 varchar(2048), c3 float, c4 int) partition by range(c1) (partition p0 values less than (maxvalue));
insert into t1 select row_number() over(), randstr(2048, random()), 1, null from table(generator(100000));
create index i1 on t1(c2,c3) global;
alter table t1 partition by range() size('128MB');
alter table t1 drop c3;
alter table t1 force;
select part_level, part_func_type, part_func_expr, part_num, sub_part_func_type, sub_part_func_expr, sub_part_num from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1');
select part_type, part_num, sub_part_type, def_sub_part_num, part_expr, sub_part_expr from oceanbase.__all_part_info where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1'));
select count(*) from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1'));
drop table t1;


--echo
--echo # test presplit in the case of creating new global index
create table t1(c1 int primary key, c2 varchar(2048), c3 float, c4 int) partition by range(c1) (partition p0 values less than (maxvalue));
alter table t1 partition by range() size('128MB');
insert into t1 select row_number() over(), randstr(2048, random()), 1, null from table(generator(200000));
call dbms_stats.gather_table_stats('test', 't1');
create index i1 on t1(c2,c3) global;
select part_level, part_func_type, part_func_expr, part_num, sub_part_func_type, sub_part_func_expr, sub_part_num from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1');
select part_type, part_num, sub_part_type, def_sub_part_num, part_expr, sub_part_expr from oceanbase.__all_part_info where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1'));
select count(*) from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1'));
drop table t1;

