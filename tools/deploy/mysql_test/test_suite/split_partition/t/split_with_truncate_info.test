# owner: lihongqin.lhq
# owner group: storage
# description: this case is use for testing split with truncate info
#

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t2x;
drop table if exists t1_p0;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '60s';
sleep 3;
set ob_global_debug_sync = 'reset';

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 10000000000;
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 10000000000;
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 10000000000;
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 10000000000;
connect (conn5,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set ob_query_timeout = 10000000000;
connection default;
set ob_query_timeout = 10000000000;
purge recyclebin;
alter system set _ob_enable_truncate_partition_preserve_global_index = true;

--echo
--echo # split finish with truncate info
create table t1(c1 int auto_increment, c2 varchar(2048), primary key (c1)) partition by range(c1) (partition p0 values less than (50000), partition p1 values less than (maxvalue));
create index i1 on t1(c2) global partition by range columns(c2) (partition p0 values less than (maxvalue));
insert into t1(c2) select randstr(2048, random()) from table(generator(50000));
alter table t1 truncate partition p0;
alter table t1 partition by range() size('128MB');
insert into t1(c2) select randstr(2048, random()) from table(generator(50000));
let $part_cnt = query_get_value(select count(*) as cnt from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')),cnt,1);
while ($part_cnt <= 1) {
  let $part_cnt = query_get_value(select count(*) as cnt from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')),cnt,1);
  sleep 1;
}
select /*+index(t1 i1)*/ count(c2) from t1;
drop table t1;

--echo
--echo # query split dst with truncate info
create table t1(c1 int auto_increment, c2 varchar(2048), primary key (c1)) partition by range(c1) (partition p0 values less than (50000), partition p1 values less than (maxvalue));
create index i1 on t1(c2) global partition by range columns(c2) (partition p0 values less than (maxvalue));
insert into t1(c2) select randstr(2048, random()) from table(generator(50000));
alter table t1 truncate partition p0;
select /*+index(t1 i1)*/ count(c2) from t1;
alter table t1 partition by range() size('128MB');
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for continue_signal execute 10000';
connection default;
insert into t1(c2) select randstr(2048, random()) from table(generator(50000));
let $part_cnt = query_get_value(select count(*) as cnt from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')),cnt,1);
while ($part_cnt <= 1) {
  let $part_cnt = query_get_value(select count(*) as cnt from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')),cnt,1);
  sleep 1;
}
select /*+index(t1 i1)*/ count(c2) from t1;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection default;
drop table t1;

--echo
--echo # query split src with truncate info
create table t1(c1 int auto_increment, c2 varchar(2048), primary key (c1)) partition by range(c1) (partition p0 values less than (50000), partition p1 values less than (maxvalue));
create index i1 on t1(c2) global partition by range columns(c2) (partition p0 values less than (maxvalue));
insert into t1(c2) select randstr(2048, random()) from table(generator(50000));
alter table t1 truncate partition p0;
select /*+index(t1 i1)*/ count(c2) from t1;
alter table t1 partition by range() size('128MB');
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for continue_signal execute 10000';
set ob_global_debug_sync = 'AFTER_CREATE_SPLIT_TASK wait_for continue_signal execute 10000';
set ob_global_debug_sync = 'BEFORE_ADD_REFRESH_SCHEMA_TASK wait_for continue_signal execute 10000';
set ob_global_debug_sync = 'BEFORE_ADD_ASYNC_REFRESH_SCHEMA_TASK wait_for continue_signal execute 10000';
connection default;
insert into t1(c2) select randstr(2048, random()) from table(generator(50000));
let $part_cnt = query_get_value(select count(*) as cnt from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')),cnt,1);
while ($part_cnt <= 1) {
  let $part_cnt = query_get_value(select count(*) as cnt from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')),cnt,1);
  sleep 1;
}
select /*+index(t1 i1)*/ count(c2) from t1;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
connection default;
drop table t1;

--echo
--echo # insert split dst with truncate info
create table t1(c1 int auto_increment, c2 varchar(2048), primary key (c1)) partition by range(c1) (partition p0 values less than (50000), partition p1 values less than (maxvalue));
create unique index i1 on t1(c2) global partition by range columns(c2) (partition p0 values less than (maxvalue));
insert into t1(c2) select concat(uuid(),randstr(2012, random())) from table(generator(50000));
create table t1_p0(c1 int, c2 varchar(2048), primary key (c1));
insert into t1_p0 select * from t1 partition(p0);
alter table t1 truncate partition p0;
select /*+index(t1 i1)*/ count(c2) from t1;
alter table t1 partition by range() size('128MB');
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for continue_signal execute 10000';
connection default;
insert into t1(c2) select concat(uuid(),randstr(2012, random())) from table(generator(50000));
let $part_cnt = query_get_value(select count(*) as cnt from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')),cnt,1);
while ($part_cnt <= 1) {
  let $part_cnt = query_get_value(select count(*) as cnt from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')),cnt,1);
  sleep 1;
}
insert into t1 select * from t1_p0;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection default;
drop table t1;
drop table t1_p0;

--echo
--echo # insert split src with truncate info
create table t1(c1 int auto_increment, c2 varchar(2048), primary key (c1)) partition by range(c1) (partition p0 values less than (50000), partition p1 values less than (maxvalue));
create unique index i1 on t1(c2) global partition by range columns(c2) (partition p0 values less than (maxvalue));
insert into t1(c2) select concat(uuid(),randstr(2012, random())) from table(generator(50000));
create table t1_p0(c1 int, c2 varchar(2048), primary key (c1));
insert into t1_p0 select * from t1 partition(p0);
alter table t1 truncate partition p0;
select /*+index(t1 i1)*/ count(c2) from t1;
alter table t1 partition by range() size('128MB');
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for continue_signal execute 10000';
set ob_global_debug_sync = 'AFTER_CREATE_SPLIT_TASK wait_for continue_signal execute 10000';
set ob_global_debug_sync = 'BEFORE_ADD_REFRESH_SCHEMA_TASK wait_for continue_signal execute 10000';
set ob_global_debug_sync = 'BEFORE_ADD_ASYNC_REFRESH_SCHEMA_TASK wait_for continue_signal execute 10000';
connection default;
insert into t1(c2) select concat(uuid(),randstr(2012, random())) from table(generator(50000));
let $part_cnt = query_get_value(select count(*) as cnt from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')),cnt,1);
while ($part_cnt <= 1) {
  let $part_cnt = query_get_value(select count(*) as cnt from oceanbase.__all_part where table_id = (select table_id from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1')),cnt,1);
  sleep 1;
}
insert into t1 select * from t1_p0;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
connection default;
drop table t1;
