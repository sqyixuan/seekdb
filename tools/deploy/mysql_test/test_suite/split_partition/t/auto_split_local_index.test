##owner: buming.lj
##owner group: 底层引擎部-存储-索引与DDL
##description: 自动分区局部索引
##tags: split_partition

--disable_warnings
drop table if exists t1;

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--sleep 2


connection conn1;
create table t1(c1 int primary key, c2 int, index(c2) local);

alter table t1 partition by range columns (c1) size ('128mb');

alter table t1 change c1 c1x char(10);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
