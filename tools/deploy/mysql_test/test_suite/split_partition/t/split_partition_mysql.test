--echo	#二级分区分裂
DROP TABLE IF EXISTS erji_pt;
CREATE TABLE erji_pt (
    c1 int,
    c2 int,
    primary key(c1,c2)
) PARTITION BY RANGE(c1) SUBPARTITION BY HASH(c2) (
    PARTITION p0 VALUES LESS THAN (10) (
        SUBPARTITION s0,
        SUBPARTITION s1,
        SUBPARTITION s2
    ),
    PARTITION p1 VALUES LESS THAN (20) (
        SUBPARTITION s3,
        SUBPARTITION s4,
        SUBPARTITION s5
    ),
    PARTITION p2 VALUES LESS THAN (MAXVALUE) (
        SUBPARTITION s6,
        SUBPARTITION s7,
        SUBPARTITION s8
    )
);

