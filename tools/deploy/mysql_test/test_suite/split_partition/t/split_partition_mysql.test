--echo 手动分裂单表table group里的表, sharding 属性为partition 
create tablegroup tg1 SHARDING = 'PARTITION';
create table tmp (col int primary key, col2 int) tablegroup = tg1 partition by range(col) (partition p1 values less than (100));
create index idx1 ON tmp(col2);
Alter table tmp reorganize partition p1 into (partition p1_1 values less than (50), partition p1_2 values less than (100));


--echo 手动分裂多表table group里的表, sharding 属性为partition, 预期错误 
create table tmp_1 (col int primary key) tablegroup = tg1 partition by range(col) (partition p1_1 values less than (50), partition p1_2 values less than (100));
--error 1235 
Alter table tmp_1 reorganize partition p1_1 into (partition p1_1_1 values less than (25), partition p1_1_2 values less than (50));


--echo 自动分裂单表table group里的表, sharding 属性为partition 
create tablegroup tg2 SHARDING = 'PARTITION';
create table t22(a int, b VARCHAR(150), c int, d VARCHAR(4000),primary key(a,b,c)) tablegroup = tg2 partition by range(a) size("128mb") (partition p1 values less than (50000000), partition p2 values less than MAXVALUE);
let $t22_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't22', table_id, 1);

let $times_insert = 0;
while ($times_insert < 10)
{
  --inc $times_insert
  insert into t22(a,b,c,d) select 
    uniform(1, 100000000, random()),
    randstr(150, random()) c1,
    uniform(1, 100000000, random()),
    randstr(4000, random()) c1
  from 
    table(generator(10000));
}
--disable_query_log
let $times_check = 0;
while ($times_check < 10)
{
  sleep 10;
  --inc $times_check
  let $partition_count = query_get_value(select count(1) as count from oceanbase.__all_part where table_id = $t22_id, count, 1);
  if ($partition_count > 2) 
  {
    let $times_check = 11;
  }
  insert into t22(a,b,c,d) select 
    uniform(1, 100000000, random()),
    randstr(150, random()) c1,
    uniform(1, 100000000, random()),
  randstr(4000, random()) c1
  from 
    table(generator(10000));
}
--enable_query_log
--replace_regex /table_id = [0-9]*/table_id = table_id/g
eval select count(1) > 2 from oceanbase.__all_part where table_id = $t22_id;

--echo 往tablegroup里添加自动分区表以及普通表, sharding 属性为partition 
create tablegroup tg3 SHARDING = 'PARTITION';
create table tmp_3 (col int primary key) tablegroup = tg3 partition by range(col) (partition p1_1 values less than (50), partition p1_2 values less than (100));
create table tmp_4 (col int primary key) partition by range(col) (partition p1_1 values less than (50), partition p1_2 values less than (100));
create table tmp_5 (col int primary key) partition by range(col) size("128mb") (partition p1_1 values less than (50), partition p1_2 values less than (100));
alter tablegroup tg3 add tmp_4;
alter table tmp_5 set tablegroup=tg3;

--disable_warnings
DROP TABLE IF EXISTS tmp,t22,tmp_1,tmp_2,tmp_3,tmp_4,tmp_5;
DROP TABLEGROUP IF EXISTS tg0;
DROP TABLEGROUP IF EXISTS tg1;
DROP TABLEGROUP IF EXISTS tg2;
DROP TABLEGROUP IF EXISTS tg3;
purge recyclebin;
--enable_warnings







--echo 手动分裂单表table group里的表, sharding 属性为adptive
