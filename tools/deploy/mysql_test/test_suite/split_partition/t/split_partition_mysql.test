DROP TRIGGER IF EXISTS tg1;
delimiter //;
CREATE TRIGGER tg1
AFTER update ON trg_table2
FOR EACH ROW
BEGIN
	INSERT INTO trg_table values(1,'a'),(3,'a');
	INSERT INTO trg_table values(7,'a');
	INSERT INTO trg_table values(18,'c');
	INSERT INTO trg_table values(24,'e');
	UPDATE trg_table  SET c1 = 20 WHERE c1 = 18;
	UPDATE trg_table  SET c1 = 26 WHERE c1 = 24;
	DELETE FROM trg_table partition(p0_new2) WHERE c1 = 6;
END
//
delimiter ;//

