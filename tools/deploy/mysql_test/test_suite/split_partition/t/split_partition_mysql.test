BEGIN
	INSERT INTO pro_table partition(p0_new) values(25,'A');
	INSERT INTO pro_table partition(p0_new2) values(50,'B');
	INSERT INTO pro_table partition(p1_new) values(75,'c');
	INSERT INTO pro_table partition(p1_new2) values(100,'D');
	INSERT INTO pro_table partition(p2_new) values(125,'E');
	INSERT INTO pro_table partition(p2_new2) values(150,'F');
END
//
DELIMITER ;//

--error 1748
CALL pro_dml_insert();

DROP PROCEDURE pro_dml_insert;

DROP procedure IF EXISTS pro_dml_update;
DELIMITER //;
CREATE PROCEDURE pro_dml_update()
BEGIN
	UPDATE pro_table SET c1 = 22 WHERE c1 >0 AND c1 <25;
	UPDATE pro_table SET c1 = 36 WHERE c1 >25 AND c1 <50;
	UPDATE pro_table SET c1 = 66 WHERE c1 >50 AND c1 <75;
	UPDATE pro_table SET c1 = 86 WHERE c1 >75 AND c1 <100;
	UPDATE pro_table SET c1 = 116 WHERE c1>100 AND c2<125;
	UPDATE pro_table SET c1 = 136 WHERE c1 >125 AND c1 <150;
END
//
DELIMITER ;//

--echo	#违反主键约束。
--error 1062
CALL pro_dml_update();



DROP procedure IF EXISTS pro_dml_update;
