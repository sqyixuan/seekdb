--echo	#function中分裂一个分区 ，
--echo	#ERROR 1422 (HY000): Explicit or implicit commit is not allowed in stored function or trigger.
DELIMITER //;
--error 1422
CREATE FUNCTION func1()
RETURNS INT
DETERMINISTIC
BEGIN
  	ALTER TABLE p_table REORGANIZE PARTITION p0 INTO
	(PARTITION p0_new VALUES LESS THAN(5),
	 PARTITION p0_new2 VALUES LESS THAN(10)
	 );
  RETURN 1;
END //
DELIMITER ;//



