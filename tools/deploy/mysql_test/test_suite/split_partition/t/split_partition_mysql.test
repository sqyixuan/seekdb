##owner: zhenjiang.xzj
##owner group: 底层引擎部-存储-索引与DDL
##description: 手动分区分裂测试
##tags: split_partition
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings
connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;
create database db1;
use db1;


SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--disable_query_log
alter system SET enable_auto_split = false;
let $enable_auto_split = query_get_value(show parameters where name='enable_auto_split',value,1);
--sleep 5
while ($enable_auto_split == 1)
{
  sleep 5;
  let $enable_auto_split = query_get_value(show parameters where name='enable_auto_split',value,1);
}
--enable_query_log

drop table if exists t1;

--echo	#分裂分区名称
drop table if exists t1;
CREATE TABLE t1 (id INT, dob DATE, primary key(id))
    PARTITION BY RANGE(id) (
        PARTITION p0 VALUES LESS THAN (30),
        PARTITION p1 VALUES LESS THAN (40),
        PARTITION p2 VALUES LESS THAN (50)
    );
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;


--echo	#分区分裂名为 ''
--error 1064
ALTER TABLE t1 REORGANIZE PARTITION p2 INTO (
    PARTITION '' VALUES LESS THAN (45),
    PARTITION p2 VALUES LESS THAN (50)
);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;


--echo	#分裂分区名为NULL
--error 1064
ALTER TABLE t1 REORGANIZE PARTITION p2 INTO (
    PARTITION null VALUES LESS THAN (45),
    PARTITION p2 VALUES LESS THAN (50)
);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;


--echo	#分裂分区名重复，
--error 1517
ALTER TABLE t1 REORGANIZE PARTITION p2 INTO (
    PARTITION p1 VALUES LESS THAN (45),
    PARTITION p2 VALUES LESS THAN (50)
);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;



--echo	#分裂分区名为数值
--error 1064
ALTER TABLE t1 REORGANIZE PARTITION p1 INTO (
    PARTITION 12345789 VALUES LESS THAN (45),
    PARTITION p2 VALUES LESS THAN (50)
);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;



--echo	#分裂区名为字符串
ALTER TABLE t1 REORGANIZE PARTITION p2 INTO (
    PARTITION aaaaaa123 VALUES LESS THAN (45),
    PARTITION p2 VALUES LESS THAN (50)
);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;


alter table t1 drop partition aaaaaa123;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;


--echo	#特殊字符
--error 1064
ALTER TABLE t1 REORGANIZE PARTITION p2 INTO (
    PARTITION @!%^&^ VALUES LESS THAN (45),
    PARTITION p2 VALUES LESS THAN (50)
);


--echo	#分裂区名的长度  max
ALTER TABLE t1 REORGANIZE PARTITION p2 INTO (
    PARTITION p123456789123456789123456789123456789123456789123456789123456789 VALUES LESS THAN (45),
    PARTITION p2 VALUES LESS THAN (50)
);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

alter table t1 drop partition p123456789123456789123456789123456789123456789123456789123456789;


--echo	#分裂区名最大长度 64
--error 1059
ALTER TABLE t1 REORGANIZE PARTITION p2 INTO (
    PARTITION p1234567891234567891234567891234567891234567891234567891234567891 VALUES LESS THAN (45),
    PARTITION p2 VALUES LESS THAN (50)
);


--echo	#OB不支持最后一个分区value值 递增。
--error 1493
ALTER TABLE t1 REORGANIZE PARTITION p2 INTO (
    PARTITION p_1 VALUES LESS THAN (45),
    PARTITION p2_1 VALUES LESS THAN (48),
    PARTITION p2_2 values LESS THAN (52)
);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

drop table t1;



--echo	#hash分区分裂 (不支持，预期报错)
drop table if exists t_hash;
create table t_hash(
c1 int primary key,
c2 varchar(60) not null
);

ALTER TABLE t_hash PARTITION BY HASH(c1) PARTITIONS 8;

--error 1235
ALTER TABLE t_hash REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN (10),
 PARTITION p1_new2 VALUES LESS THAN MAXVALUE);

--error 1064
ALTER TABLE t_hash REORGANIZE PARTITION p1 INTO
(PARTITION p1_new,
 PARTITION p1_new2);

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_hash;

drop table t_hash;


--echo	#list分区
drop table if exists t_list;
create table t_list(
c1 int primary key,
c2 varchar(30) not null
);

ALTER TABLE t_list PARTITION BY LIST(c1)
(PARTITION p1 VALUES IN (1,3,5),
 PARTITION p2 VALUES IN (2,4,6),
 PARTITION p3 VALUES IN (7,8,9,10));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_list;

--echo	#OB不支持list分区分裂，mysql正常执行。
--error 1235
ALTER TABLE t_list REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES IN (1),
 PARTITION p1_new2 VALUES IN (3,5));

--error 1235
ALTER TABLE t_list REORGANIZE PARTITION p3 INTO
(PARTITION p3_new VALUES IN (7,8,9),
 PARTITION p3 VALUES IN (10));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_list;


drop table t_list;

--echo	#key分区分裂（不支持，预期报错）
drop table if exists t_key;
create table t_key(
c1 int primary key,
c2 varchar(30) not null
);


ALTER TABLE t_key PARTITION BY KEY(c1)
PARTITIONS 8;

--error 1235
ALTER TABLE t_key REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN (100),
 PARTITION p1_new2 VALUES LESS THAN MAXVALUE);

--error 1064
ALTER TABLE t_key REORGANIZE PARTITION p1 INTO
(PARTITION p1_new ,
 PARTITION p1_new2 );


--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_key;

drop table t_key;



--echo	#list columns  预期报错，不支持list columns分区分裂
drop table if exists t_list_columns;
create table t_list_columns(
c1 int primary key,
c2 varchar(30) not null
);

ALTER TABLE t_list_columns PARTITION BY LIST COLUMNS(c1)
(PARTITION p1 VALUES IN (1,3,5),
 PARTITION p2 VALUES IN (2,4,6),
 PARTITION p3 VALUES IN (7,8,9,10));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_list_columns;

--error 1235
ALTER TABLE t_list_columns REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES IN (1),
 PARTITION p1_new2 VALUES IN (3,5));

--error 1235
ALTER TABLE t_list_columns REORGANIZE PARTITION p3 INTO
(PARTITION p3_new VALUES IN (7,8,9),
 PARTITION p3 VALUES IN (10));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_list_columns;

drop table t_list_columns;




--echo	#range columns

create table t_range_columns(
c1 int primary key,
c2 varchar(30) not null
);

insert into t_range_columns values (6,'AA');
insert into t_range_columns values (9,'AA');
insert into t_range_columns values (16,'AA');
insert into t_range_columns values (12,'AA');
insert into t_range_columns values (26,'AA');
insert into t_range_columns values (36,'AA');

--error 1526
ALTER TABLE t_range_columns PARTITION BY RANGE COLUMNS(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));



ALTER TABLE t_range_columns PARTITION BY RANGE COLUMNS(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30),
 PARTITION p4 VALUES LESS THAN(40)
 );


--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_range_columns;

ALTER TABLE t_range_columns REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_range_columns;

select * from t_range_columns partition(p1_new);
select * from t_range_columns partition(p1_new2);
select * from t_range_columns partition(p2);
select * from t_range_columns partition(p3);
select * from t_range_columns partition(p4);


drop table t_range_columns;




--echo	#验证分裂后分区约束完整性
--echo	#primary key,auto_increment
drop table if exists t_pk_range;
create table t_pk_range(
c1 int primary key AUTO_INCREMENT,
c2 varchar(30) not null
);

insert into t_pk_range(c2) values('A'),('C'),('D'),('E'),('C'),('D'),('E'),('C'),('D'),('E'),('C'),('D'),('E');

ALTER TABLE t_pk_range PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));

ALTER TABLE t_pk_range REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_pk_range;

select * from t_pk_range order by c1;
select * from t_pk_range partition(p1_new);
select * from t_pk_range partition(p1_new2);
select * from t_pk_range partition(p2);
select * from t_pk_range partition(p3);

desc t_pk_range;


--echo	#default
drop table if exists t_df_range;
create table t_df_range(
c1 int primary key default 1,
c2 varchar(30) not null default 'AA'
);

insert into t_df_range(c2) values ('#%#$Y');
insert into t_df_range values (6,'撒结果');
insert into t_df_range values (9,'AA21a');
insert into t_df_range values (16,'CCDDE');
insert into t_df_range values (12,'张2ASSD');
insert into t_df_range values (26,'Ec....');
insert into t_df_range values (27,'6t6t6t6');


ALTER TABLE t_df_range PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));

ALTER TABLE t_df_range REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10));

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_df_range;

select * from t_df_range partition(p1_new);
select * from t_df_range partition(p1_new2);
select * from t_df_range partition(p2);
select * from t_df_range partition(p3);


insert into t_df_range values(15,'CC');
insert into t_df_range values(18,'CC');
select * from t_df_range partition(p2);

update t_df_range set c1 = 29 where c1 = 26;
select * from t_df_range partition(p3);

drop table t_df_range;


--echo	#unique key
drop table if exists t_uk_range;
create table t_uk_range(
c1 int unique key not null default 1,
c2 varchar(30) not null default 'AA'
);

ALTER TABLE t_uk_range PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));

--echo	#OB不支持 对分区列为唯一列进行分区分裂
--error 1235
ALTER TABLE t_uk_range REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10));

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_uk_range;
desc t_uk_range;



--echo	#多个一级分区分裂（暂不支持，预期报错。）
drop table if exists t_range;
create table t_range(
c1 int primary key,
c2 varchar(30) not null
);

ALTER TABLE t_range PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_range;

--echo	#分裂p1,p2
--error 1235
ALTER TABLE t_range REORGANIZE PARTITION p1,p2 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10),
 PARTITION p2_new VALUES LESS THAN(15),
 PARTITION p2_new2 VALUES LESS THAN(20)
 );
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_range;

drop table t_range;


--echo	#对设置了tablegroup的表进行分裂

drop tablegroup if exists my_tablegroup;
CREATE tablegroup my_tablegroup;


drop table if exists t_range;
create table t_range(
c1 int primary key,
c2 varchar(30) not null
)tablegroup = my_tablegroup PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));

--echo	#预期失败
--error 1235
ALTER TABLE t_range REORGANIZE PARTITION p1,p2 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10),
 PARTITION p2_new VALUES LESS THAN(15),
 PARTITION p2_new2 VALUES LESS THAN(20)
 );
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_range;


drop table if exists t_range;
drop tablegroup my_tablegroup;



--echo	#两个分区键进行分区分裂
drop table if exists t_tpt_table;
CREATE TABLE t_tpt_table (
  id INT,
  name VARCHAR(50),
  year1 INT,
  month1 INT,
  primary key(id,year1,month1)
) PARTITION BY RANGE COLUMNS(year1, month1) (
  PARTITION p201801 VALUES LESS THAN (2018, 2),
  PARTITION p201805 VALUES LESS THAN (2018, 6),
  PARTITION p201807 VALUES LESS THAN (2018, 8),
  PARTITION p201809 VALUES LESS THAN (2018, 10),
  PARTITION p201811 VALUES LESS THAN (2018, 12)
);


--error 1235
ALTER TABLE  t_tpt_table REORGANIZE PARTITION p201805 INTO
(PARTITION p201803 VALUES LESS THAN(2018,3),
 PARTITION p201804 VALUES LESS THAN(2018,4),
 PARTITION p201805 VALUES LESS THAN (2018, 6)
);

--error 1235
ALTER TABLE  t_tpt_table REORGANIZE PARTITION p201811 INTO
(PARTITION p201901 VALUES LESS THAN(2019,1),
 PARTITION p201902 VALUES LESS THAN(2019,2)
 );

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_tpt_table;

drop table t_tpt_table;



--echo	#无主键列分区表
drop table if exists t_nopk_table;
create table t_nopk_table(
c1 int ,
c2 varchar(60) not null
) PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));

--echo	#分裂无主键分区表         (OB不支持。预期报错)
--error 1235
ALTER TABLE t_nopk_table REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10)
 );

--echo	#分裂无分区键表
drop table if exists t_nopt_table;
create table t_nopt_table(
c1 int ,
c2 varchar(60) not null
);

--error 1505
ALTER TABLE t_nopt_table REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10)
 );


--echo	#分区键与主键前缀不同             ####################################################
drop table if exists t_diffpk_table;
--error 1503
create table t_diffpk_table(
c1 int ,
c2 int ,
primary key(c2)
) PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));





--echo	#分裂分区定义value
drop table if exists t_tvalue_table;
create table t_tvalue_table(
c1 int primary key,
c2 varchar(30) not null
) PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));

--echo	#分裂value 属于原分区value范围
ALTER TABLE t_tvalue_table REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10)
 );


--echo	#分裂value 不属于原分区value范围
--error 1493
ALTER TABLE t_tvalue_table REORGANIZE PARTITION p2 INTO
(PARTITION p2_new VALUES LESS THAN(15),
 PARTITION p2_new2 VALUES LESS THAN(21)
 );

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_tvalue_table;


--echo	#分裂最后一个分区，扩大分裂后value范围              OB不支持扩大最后一个分区
--error 1493
ALTER TABLE t_tvalue_table REORGANIZE PARTITION p3 INTO
(PARTITION p3_new VALUES LESS THAN(25),
 PARTITION p3_new2 VALUES LESS THAN(30),
 PARTITION p3_new3 VALUES LESS THAN(100000),
 PARTITION p3_new4 VALUES LESS THAN(1000000000)
 );
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_tvalue_table;


--echo	#分裂分区名重复
--error 1493
ALTER TABLE t_tvalue_table REORGANIZE PARTITION p3 INTO
(PARTITION p1_new VALUES LESS THAN(40),
 PARTITION p3_new2 VALUES LESS THAN(50),
 PARTITION p3_new3 VALUES LESS THAN(60)
 );

--echo	#分裂后value按降序 排
--error 1493
ALTER TABLE t_tvalue_table REORGANIZE PARTITION p3 INTO
(PARTITION p3_new40 VALUES LESS THAN(40),
 PARTITION p3_new50 VALUES LESS THAN(50),
 PARTITION p3_new60 VALUES LESS THAN(60)
 );

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_tvalue_table;
drop table t_tvalue_table;


--echo	#分裂后修改分区键
--echo	#分裂后删除分区键约束

drop table if exists test1;
create table test1(
c1 int primary key,
c2 varchar(30) not null
) PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));
insert into  test1 values (1,'AA');
insert into  test1 values (3,'BBD');
insert into  test1 values (5,'ACCEA');
insert into  test1 values (7,'SAGA');
insert into  test1 values (11,'ATR3643A');
insert into  test1 values (13,'567&^');
insert into  test1 values (17,'zs');
insert into  test1 values (19,'zs');

ALTER TABLE test1 REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10)
 );

select * from test1 partition (p1_new);
select * from test1 partition (p1_new2);
select * from test1 partition (p2);
select * from test1 partition (p3);


--echo	#分裂后删除分区键主键列约束
alter table test1 drop primary key;

select * from test1 partition (p1_new);
select * from test1 partition (p1_new2);
select * from test1 partition (p2);
select * from test1 partition (p3);

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table test1;

--echo	#分裂无主键列分区(OB不支持，预期报错。)
--error 1235
ALTER TABLE test1 REORGANIZE PARTITION p2 INTO
(PARTITION p2_new VALUES LESS THAN(15),
 PARTITION p2_new2 VALUES LESS THAN(20)
 );

--echo	#给分区键添加约束
alter table test1 add primary key(c1);

--echo	#修改数据类型
--error 1659
alter table test1 modify c1 float primary key;
--error 1659
alter table test1 modify c1 float not null;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table test1;

--echo	#分裂后归并分区（预期报错，OB不支持）
--error 1235
alter table test1 reorganize PARTITION p1_new,p1_new2 into(
partition p1 values less than(10)
);

--error 1235
alter table test1 reorganize PARTITION p2_new,p2_new2 into(
partition p2 values less than(20)
);

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table test1;
drop table test1;


--echo	#分裂后修改分区名称
drop table if exists test1;
create table test1(
c1 int primary key,
c2 varchar(30) not null
) PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));

ALTER TABLE test1 REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10)
 );

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table test1;

--echo	#修改分区名名称
--error 1064
ALTER TABLE test1 REMOVE PARTITION (p1_new);



--echo	#分裂后重新定义分区表
drop table if exists test1;
create table test1(
c1 int primary key,
c2 varchar(30) not null
) PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));

insert into  test1 values (1,'AA');
insert into  test1 values (3,'BBD');
insert into  test1 values (5,'ACCEA');
insert into  test1 values (7,'SAGA');
insert into  test1 values (11,'ATR3643A');
insert into  test1 values (13,'567&^');
insert into  test1 values (17,'zs');
insert into  test1 values (19,'zs');

ALTER TABLE test1 REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10)
 );

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show CREATE TABLE test1;

select * from test1 partition (p1_new);
select * from test1 partition (p1_new2);
select * from test1 partition (p2);
select * from test1 partition (p3);


--echo	#重新定义多个分区
ALTER TABLE test1
PARTITION BY RANGE(c1) (
    PARTITION p0 VALUES LESS THAN (8),
    PARTITION p1 VALUES LESS THAN (16),
    PARTITION p2 VALUES LESS THAN (24),
    PARTITION p3 VALUES LESS THAN (MAXVALUE)
);

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show CREATE TABLE test1;


select * from test1 partition (p0);
