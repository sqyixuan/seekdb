BEGIN
	UPDATE pro_table SET c1 = 22 WHERE c1 =20 ;
	UPDATE pro_table SET c1 = 36 WHERE c1 =40;
	UPDATE pro_table SET c1 = 66 WHERE c1 =65;
	UPDATE pro_table SET c1 = 86 WHERE c1 =80;
	UPDATE pro_table SET c1 = 116 WHERE c1 =110;
	UPDATE pro_table SET c1 = 136 WHERE c1 =140;
END
//
DELIMITER ;//

