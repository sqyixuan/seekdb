SELECT * FROM pro_table PARTITION(p1_new2);
SELECT * FROM pro_table PARTITION(p2_new2);


--echo	#对分裂后的分区再次分裂
DROP PROCEDURE IF EXISTS pro_ddl_1;
DELIMITER //;
CREATE PROCEDURE pro_ddl_1()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    ROLLBACK;
  END;
  START TRANSACTION;
	ALTER TABLE pro_table REORGANIZE PARTITION p0_new INTO
	(PARTITION p0_new_1 VALUES LESS THAN(10),
	PARTITION p0_new VALUES LESS THAN(25)
	);
	ALTER TABLE pro_table REORGANIZE PARTITION p1_new INTO
	(PARTITION p1_new_1 VALUES LESS THAN(60),
	PARTITION p1_new VALUES LESS THAN(75)
	);
	ALTER TABLE pro_table REORGANIZE PARTITION p2_new INTO
	(PARTITION p2_new_1 VALUES LESS THAN(110),
	PARTITION p2_new_2 VALUES LESS THAN(115),
	PARTITION p2_new VALUES LESS THAN(125)
	);
  COMMIT;
END
//
DELIMITER ;//

CALL pro_ddl_1();
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show CREATE TABLE pro_table;


