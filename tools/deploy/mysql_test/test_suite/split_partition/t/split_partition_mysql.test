--echo	#PL中分区分裂的使用
--echo	#触发器+ddl，进行分区分裂操作
DROP TRIGGER IF exists tg1;
DROP TABLE IF EXISTS tg_table;

CREATE TABLE tg_table(
c1 int PRIMARY KEY,
c2 varchar(30) NOT null
)PARTITION BY RANGE(c1)(
   PARTITION p0 VALUES LESS THAN (10),
   PARTITION p1 VALUES LESS THAN (20),
   PARTITION p2 VALUES LESS THAN (30)
);

--echo	#ERROR 1422 (HY000): Explicit or implicit commit is not allowed in stored function or trigger.
delimiter //;
--error 1422
CREATE TRIGGER tg1
AFTER INSERT ON tg_table
FOR EACH ROW
BEGIN
ALTER TABLE tg_table REORGANIZE PARTITION p0 INTO(PARTITION p0_new VALUES LESS THAN(5),PARTITION p0_new2 VALUES LESS THAN(10));
END//
delimiter ;//




--echo	#存储过程+ddl，进行分区分裂操作
DROP TABLE IF EXISTS p_table;
DROP PROCEDURE IF EXISTS alter_p_table;

CREATE TABLE p_table(
c1 int PRIMARY KEY,
c2 varchar(30) NOT null
)PARTITION BY RANGE(c1)(
   PARTITION p0 VALUES LESS THAN (10),
   PARTITION p1 VALUES LESS THAN (20),
   PARTITION p2 VALUES LESS THAN (30)
);

insert into p_table values(1,'A');
insert into p_table values(7,'A');
insert into p_table values(8,'A');
insert into p_table values(9,'A');
insert into p_table values(10,'A');
insert into p_table values(14,'A');
insert into p_table values(17,'A');
insert into p_table values(19,'A');
insert into p_table values(22,'A');
insert into p_table values(25,'A');
insert into p_table values(29,'A');


--echo	#procedure内分裂一个分区
DELIMITER //;
CREATE PROCEDURE alter_p_table()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    ROLLBACK;
  END;
  START TRANSACTION;
	ALTER TABLE p_table REORGANIZE PARTITION p0 INTO
	(PARTITION p0_new VALUES LESS THAN(5),
	 PARTITION p0_new2 VALUES LESS THAN(10)
	 );
  COMMIT;
END //
DELIMITER ;//

CALL alter_p_table();
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show CREATE TABLE p_table;

select * from p_table partition(p0_new);
select * from p_table partition(p0_new2);
select * from p_table partition(p1);
select * from p_table partition(p2);





DROP PROCEDURE IF EXISTS alter_p_table;
--echo	#procedure内多个分区分裂
DELIMITER //;
CREATE PROCEDURE alter_p_table()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    ROLLBACK;
  END;
  START TRANSACTION;
	ALTER TABLE p_table REORGANIZE PARTITION p1 INTO
	(PARTITION p1_new VALUES LESS THAN(15),
	 PARTITION p1_new2 VALUES LESS THAN(20)
	 );
	ALTER TABLE p_table REORGANIZE PARTITION p2 INTO
	(PARTITION p2_new VALUES LESS THAN(25),
	 PARTITION p2_new2 VALUES LESS THAN(30)
	 );
  COMMIT;
END //
DELIMITER ;//


CALL alter_p_table();

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show CREATE TABLE p_table;
select * from p_table partition(p0_new);
select * from p_table partition(p0_new2);
select * from p_table partition(p1_new);
select * from p_table partition(p1_new2);
select * from p_table partition(p2_new);
select * from p_table partition(p2_new2);


