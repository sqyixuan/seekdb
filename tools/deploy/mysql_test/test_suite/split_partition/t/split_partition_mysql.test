--echo	#分裂后存储过程对分裂的分区操作
DROP TABLE IF EXISTS pro_table;
CREATE TABLE pro_table(
c1 int PRIMARY KEY,
c2 varchar(120) NOT null
)PARTITION BY RANGE(c1)(
   PARTITION p0 VALUES LESS THAN (50),
   PARTITION p1 VALUES LESS THAN (100),
   PARTITION p2 VALUES LESS THAN (150)
);


ALTER TABLE pro_table REORGANIZE PARTITION p0 INTO
(PARTITION p0_new VALUES LESS THAN(25),
PARTITION p0_new2 VALUES LESS THAN(50)
);

ALTER TABLE pro_table REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(75),
PARTITION p1_new2 VALUES LESS THAN(100)
);

ALTER TABLE pro_table REORGANIZE PARTITION p2 INTO
(PARTITION p2_new VALUES LESS THAN(125),
PARTITION p2_new2 VALUES LESS THAN(150)
);

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show CREATE TABLE pro_table;

DROP procedure IF EXISTS pro_dml_insert;
DELIMITER //;
CREATE PROCEDURE pro_dml_insert()
BEGIN
	INSERT INTO pro_table partition(p0_new) values(20,'A'),(24,'A');
	INSERT INTO pro_table partition(p0_new2) values(40,'B'),(49,'B');
	INSERT INTO pro_table partition(p1_new) values(65,'c'),(74,'c');
	INSERT INTO pro_table partition(p1_new2) values(80,'D'),(99,'D');
	INSERT INTO pro_table partition(p2_new) values(110,'E'),(124,'E');
	INSERT INTO pro_table partition(p2_new2) values(140,'F'),(149,'F');
END
//
DELIMITER ;//

CALL pro_dml_insert();

SELECT * FROM pro_table order by c1;
SELECT * FROM pro_table PARTITION(p0_new);
SELECT * FROM pro_table PARTITION(p0_new2);
SELECT * FROM pro_table PARTITION(p1_new);
SELECT * FROM pro_table PARTITION(p1_new2);
SELECT * FROM pro_table PARTITION(p2_new);
SELECT * FROM pro_table PARTITION(p2_new2);



