drop table t1;

CREATE TABLE t1(c0 int , c1 int , c2 int  , PRIMARY KEY(c1, c2))  
PARTITION BY RANGE (c2) SUBPARTITION BY RANGE (c1) subpartition template 
(subpartition sp0 VALUES LESS THAN(-1000000000), 
 subpartition sp3 VALUES LESS THAN(maxvalue))
(partition p0 VALUES LESS THAN(-1000000000), 
 partition p3 VALUES LESS THAN(maxvalue));

drop database db1;
purge recyclebin;

