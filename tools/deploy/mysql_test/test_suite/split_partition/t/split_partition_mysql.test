--echo	#对分裂分区进行delete操作
DROP procedure IF EXISTS pro_dml_delete;  
DELIMITER //;
CREATE PROCEDURE pro_dml_delete()
BEGIN
	DELETE FROM pro_table partition(p0_new2);
	DELETE FROM pro_table partition(p1_new2);
	DELETE FROM pro_table partition(p2_new2);
END
//
DELIMITER ;//

CALL pro_dml_delete();

SELECT * FROM pro_table order by c1;
