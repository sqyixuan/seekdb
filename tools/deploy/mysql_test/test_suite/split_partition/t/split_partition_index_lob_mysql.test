##owner: zhenjiang.xzj
##owner group: 底层引擎部-存储-索引与DDL
##description: 手动分区分裂测试
##tags: split_partition
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;


SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--disable_query_log
alter system SET enable_auto_split = false;
let $enable_auto_split = query_get_value(show parameters where name='enable_auto_split',value,1);
--sleep 5
while ($enable_auto_split == 1)
{
  sleep 5;
  let $enable_auto_split = query_get_value(show parameters where name='enable_auto_split',value,1);
}
--enable_query_log

--echo	#分裂局部索引
drop table if exists t_range;
create table t_range(
c1 int primary key,
c2 varchar(30) not null
) PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));

insert into t_range values(1,'Qqwer');
insert into t_range values(3,'gagnasj');
insert into t_range values(7,'打发十分');
insert into t_range values(8,'#￥……#');
insert into t_range values(12,'【】。；，归属');
insert into t_range values(16,'SAGASN');
insert into t_range values(15,'##……是的');
insert into t_range values(21,'/613撒*12');
insert into t_range values(29,'%……H仔细');
insert into t_range values(25,'asd8gasg8');
insert into t_range values(5,'1ewg5as3');

--echo	#创建局部索引
CREATE INDEX t_range_c1 ON t_range (c1) local;

ALTER TABLE t_range REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10)
 );
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_range;
select * from t_range where c1 > 10;
select * from t_range partition(p1_new) where c1 > 1 and c1 <10;
select * from t_range partition(p1_new2) where c1 != 7;
select * from t_range partition(p2) order by c1 desc,c2 asc;
select * from t_range partition(p3);

update t_range set c1 = 26 where c1 = 12;
--error 1062
update t_range set c1 = 15 where c1 = 1;

--error 1526
update t_range set c1 = 30 where c1 = 15;


select * from t_range partition(p2);
select * from t_range partition(p3);

delete from t_range where c1 <5;
select * from t_range partition(p1_new);

drop index t_range_c1 on t_range;


CREATE INDEX t_range_c1 ON t_range (c1) GLOBAL;

ALTER TABLE t_range REORGANIZE PARTITION p2 INTO
(PARTITION p2_new VALUES LESS THAN(15),
 PARTITION p2_new2 VALUES LESS THAN(20)
 );
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_range;

select * from t_range;
select * from t_range partition(p1_new);
select * from t_range partition(p1_new2);
select * from t_range partition(p2_new);
select * from t_range partition(p2_new2);
select * from t_range partition(p3);



--echo	#主表分区列只有局部索引，分裂场景
drop table if exists t_range;
create table t_range(
c1 int,
c2 varchar(30) not null,
index index_c1(c1) local
) PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_range;

--echo	#预期报错
--error 1235
ALTER TABLE t_range REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10)
 );

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_range;
drop table t_range;


--echo	#分裂其他列上有局部索引的场景
drop table if exists t_range;
create table t_range(
c1 int primary key,
c2 varchar(30) not null,
index index_c2(c2) local
) PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));


insert into t_range values(1,'Qqwer');
insert into t_range values(3,'gagnasj');
insert into t_range values(7,'打发十分');
insert into t_range values(8,'#￥……#');
insert into t_range values(12,'【】。；，归属');
insert into t_range values(16,'SAGASN');
insert into t_range values(15,'##……是的');
insert into t_range values(21,'/613撒*12');
insert into t_range values(29,'%……H仔细');
insert into t_range values(25,'asd8gasg8');
insert into t_range values(5,'1ewg5as3');


ALTER TABLE t_range REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10)
 );

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_range;

select * from t_range order by c1,c2;
select * from t_range partition(p1_new) where c2 = 'Qqwer';
select * from t_range partition(p1_new2);
select * from t_range partition(p2);
select * from t_range partition(p3);

drop table t_range;



--echo	#唯一局部索引
drop table if exists test1;
create table test1(c1 int,c2 varchar(60),c3 decimal(10,2),primary key(c1))
partition by range(c1)(
	PARTITION p1 VALUES LESS THAN(30),
	PARTITION p2 VALUES LESS THAN(60),
 	PARTITION p3 VALUES LESS THAN(90),
 	PARTITION p4 VALUES less THAN(MAXVALUE)
);

CREATE UNIQUE INDEX u_index_c1_c2 ON test1(c1,c2) LOCAL;

--error 1503
CREATE UNIQUE INDEX u_index_c1_c2 ON test1(c3) LOCAL;


drop procedure if exists pro1;
DELIMITER //;
CREATE  PROCEDURE pro1(in i int,j int)
begin
    while i <= j DO
        insert into test1 values(i,concat("李",i),i*0.1);
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//

call pro1(1,120);


ALTER TABLE test1 REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(15),
 PARTITION p1_new2 VALUES LESS THAN(30)
 );

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table test1;

select * from test1 partition(p1_new);
select * from test1 partition(p1_new2);

update test1 set c1 = 130 where c1 = 1;

select * from test1 partition(p4) where c1 = 130;

delete from test1 where c1 < 15;

select * from test1 partition(p1_new);


drop table test1;


--echo	#组合索引
--echo	#手动分裂分区键上的组合索引
drop table if exists dl_idx_test;
create table dl_idx_test(
c1 int primary key,
c2 varchar(30) not null default 'AABB',
index index_c1_c2(c1,c2)
)PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(100),
 PARTITION p2 VALUES LESS THAN(200),
 PARTITION p3 VALUES LESS THAN(300)
);

drop procedure if exists pro1;
DELIMITER //;
CREATE  PROCEDURE pro1(in i int,j int)
begin
    while i <= j DO
        insert into dl_idx_test values(i,concat("王",i));
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//

call pro1(0,249);

select count(*) from dl_idx_test;


ALTER TABLE dl_idx_test REORGANIZE PARTITION p3 INTO
(PARTITION p3_new VALUES LESS THAN(250),
 PARTITION p3 VALUES LESS THAN(300)
 );

select count(*) from dl_idx_test partition(p3_new);
select * from dl_idx_test partition(p3);

update dl_idx_test set c1 = 288 where c1 = 201;
select * from dl_idx_test partition(p3);


ALTER TABLE dl_idx_test REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(50),
 PARTITION p1 VALUES LESS THAN(100)
 );

delete from dl_idx_test where c1 < 80;

select count(*) from dl_idx_test partition(p1_new);
select count(*) from dl_idx_test partition(p1);

drop table dl_idx_test;




--echo	#gis索引
--echo	#创建空间列的分区表
drop table if exists spatial_data;
CREATE TABLE spatial_data (
    c1 INT not null,
    point GEOMETRY not null,
    PRIMARY KEY (c1)
) PARTITION BY RANGE (c1) (
    PARTITION p0 VALUES LESS THAN (100),
    PARTITION p1 VALUES LESS THAN (200),
    PARTITION p2 VALUES LESS THAN (300)
);

ALTER TABLE spatial_data ADD SPATIAL INDEX idx_point (point);


drop procedure if exists pro1;
DELIMITER //;
CREATE  PROCEDURE pro1(in i int,j int)
begin
    while i <= j DO
        insert into spatial_data values(i,point(i*2,i+1));
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//

call pro1(0,299);


--echo	#预期报错，OB不支持
--error 1235
ALTER TABLE spatial_data REORGANIZE PARTITION p0 INTO
(PARTITION p0_new VALUES LESS THAN(50),
 PARTITION p0 VALUES LESS THAN(100)
 );




--echo	#lob表的分区 ，预期报错。
--echo	#text
drop table if exists t_text;
create table t_text(
c1 int primary key,
c2 text(30) not null
) PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));

drop procedure if exists pro1;
DELIMITER //;
CREATE  PROCEDURE pro1(in i int,j int)
begin
    while i <= j DO
        insert into t_text values(i,concat("李",i));
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//

call pro1(1,29);


ALTER TABLE t_text REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(10)
 );

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_text;

select * from t_text partition(p1_new);
select * from t_text partition(p1_new2);


--echo	#添加局部索引
--error 1167
CREATE INDEX t_text_c2 ON t_text (c2) local;
--error 1167
CREATE INDEX t_text_c1 ON t_text (c2) GLOBAL;


CREATE INDEX t_text_c1 ON t_text (c1) GLOBAL;

CREATE INDEX t_text_c2 ON t_text (c1) local;


ALTER TABLE t_text REORGANIZE PARTITION p2 INTO
(PARTITION p2_new VALUES LESS THAN(15),
 PARTITION p2_new2 VALUES LESS THAN(20)
 );


--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_text;

select * from t_text partition(p2_new);
select * from t_text partition(p2_new2);


drop table t_text;


--error 1167
create table t_text(
c1 int ,
c2 text(30) primary key
) PARTITION BY RANGE(c2)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));





--echo	#blob
drop table if exists t_blob;
create table t_blob(
c1 int primary key,
c2 blob
) PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(10),
 PARTITION p2 VALUES LESS THAN(20),
 PARTITION p3 VALUES LESS THAN(30));

CREATE INDEX index_c1 ON t_blob (c1) local;

drop procedure if exists pro1;
DELIMITER //;
CREATE  PROCEDURE pro1(in i int,j int)
begin
    while i <= j DO
        insert into t_blob values(i,concat("liwosgngsi",i*3));
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//

call pro1(1,29);


ALTER TABLE t_blob REORGANIZE PARTITION p3 INTO
(PARTITION p3_new VALUES LESS THAN(28),
 PARTITION p3_new2 VALUES LESS THAN(30)
 );

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_blob;

select * from t_blob partition(p3_new);
select * from t_blob partition(p3_new2);


drop table t_blob;


--echo	#lob/text
drop table if exists t_lob_text;
create table t_lob_text(
c1 int primary key,
c2 TINYBLOB not null,
c3 TINYTEXT not null,
c4 MEDIUMBLOB not null,
c5 MEDIUMTEXT,
c6 LONGBLOB,
c7 LONGTEXT,
point GEOMETRY
)partition by range(c1)(
 PARTITION p1 VALUES LESS THAN(50),
 PARTITION p2 VALUES LESS THAN(100),
 PARTITION p3 VALUES LESS THAN(150),
 PARTITION p4 VALUES LESS THAN(MAXVALUE)
);

--error 1167
create index index_c2_c3 on t_lob_text(c2,c3);
--error 1167
CREATE UNIQUE INDEX lob_index_c1_c2 ON t_lob_text(c1,c2) LOCAL;


insert into t_lob_text(c1,c2,c3,c4,c5,c6) values(1,'A','B','C','D','E');
insert into t_lob_text(c1,c2,c3,c4,c5,c6) values(2,'2A','2B','2C','2D','2E');
insert into t_lob_text(c1,c2,c3,c4,c5,c6) values(3,'2A','2B','2C','2D','2E');

insert into t_lob_text(c1,c2,c3,c4,c5,c7) values(4,'4A','4B','4C','4D','4E');
insert into t_lob_text(c1,c2,c3,c4,c5,c7) values(5,'5A','5B','5C','5D','5E');
insert into t_lob_text(c1,c2,c3,c4,c5,c7) values(6,'6A','6B','6C','6D','6E');

insert into t_lob_text(c1,c2,c3,c4,c6,c7) values(157,'7A','7B','7C','7D','7E');
insert into t_lob_text(c1,c2,c3,c4,c6,c7) values(178,'8A','8B','8C','8D','8E');
insert into t_lob_text(c1,c2,c3,c4,c6,c7) values(199,'9A','9B','9C','9D','9E');

select * from t_lob_text order by c1;


drop procedure if exists pro1;
DELIMITER //;
CREATE  PROCEDURE pro1(in i int,j int)
begin
    while i <= j DO
        insert into t_lob_text values(i,concat(i,'A'),concat(i,'B'),concat(i,'C'),concat(i,'D'),concat(i,'E'),concat(i,'F'),point(i,1));
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//

call pro1(7,156);


ALTER TABLE t_lob_text REORGANIZE PARTITION p1 INTO
(PARTITION p1_new VALUES LESS THAN(5),
 PARTITION p1_new2 VALUES LESS THAN(25),
 PARTITION p1 VALUES LESS THAN(50)
 );


ALTER TABLE t_lob_text REORGANIZE PARTITION p1 INTO
(PARTITION p1_new3 VALUES LESS THAN(30),
 PARTITION p1_new4 VALUES LESS THAN(40),
 PARTITION p1 VALUES LESS THAN(50)
 );


--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_lob_text;
select * from t_lob_text partition(p1_new);
select * from t_lob_text partition(p1_new2);
select * from t_lob_text partition(p1_new3);
select * from t_lob_text partition(p1_new4);
select * from t_lob_text partition(p1);


ALTER TABLE t_lob_text REORGANIZE PARTITION p4 INTO
(PARTITION p4_new VALUES LESS THAN(155),
 PARTITION p4_new2 VALUES LESS THAN(160),
 PARTITION p4 VALUES LESS THAN(MAXVALUE)
 );

select * from t_lob_text partition(p4_new);
select * from t_lob_text partition(p4_new2);
select * from t_lob_text partition(p4);


drop table t_lob_text;





drop database db1;
