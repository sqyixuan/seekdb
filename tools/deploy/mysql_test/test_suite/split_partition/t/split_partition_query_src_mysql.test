# owner: yangjiali.yjl
# owner group: storage
# description: testing query split table src tablet while split partition is on going
#

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set debug_sync_timeout = '300s';
sleep 3;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
connection conn2;

--echo
--echo # query main table partition has left min
### partition has left min

connection conn1;
drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, primary key(c1)) partition by range(c1) (partition p0 values less than (5), partition p1 values less than (10));
insert into t1 values(1,1,1);
insert into t1 values(2,2,2);
insert into t1 values(3,3,3);
insert into t1 values(4,4,4);
insert into t1 values(5,5,5);
insert into t1 values(6,6,6);
insert into t1 values(7,7,7);
insert into t1 values(8,8,8);
insert into t1 values(9,9,9);

connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'AFTER_CREATE_SPLIT_TASK wait_for continue_signal execute 10000';
set ob_global_debug_sync = 'BEFORE_ADD_REFRESH_SCHEMA_TASK wait_for continue_signal execute 10000';
set ob_global_debug_sync = 'BEFORE_ADD_ASYNC_REFRESH_SCHEMA_TASK wait_for continue_signal execute 10000';

connection conn2;
send alter table t1 reorganize partition p0 into (partition p00 values less than (3), partition p01 values less than (5));

connection conn1;
sleep 5;
select * from t1 order by c1;
select * from t1 partition (p0);
select * from t1 partition (p1);
select c1,c2 from t1 order by c1;
select c1,c2 from t1 partition (p0);
select c1,c2 from t1 partition (p1);
select c1,c2,c3 from t1 partition (p0);
select c1,c2,c3 from t1 partition (p1);
select * from t1 partition (p0) where c1=1;
select * from t1 partition (p0) where c1=2;
select * from t1 partition (p0) where c1=3;
select * from t1 partition (p0) where c1=4;
select * from t1 partition (p1) where c1=5;
select * from t1 partition (p1) where c1=6;
select * from t1 partition (p1) where c1=7;
select * from t1 partition (p1) where c1=8;
select * from t1 partition (p1) where c1=9;
select * from t1 partition (p0) where c1=1 and c2=1;
select * from t1 partition (p0) where c1>1 and c2>1;
select * from t1 partition (p0) where c1=3 and c2=3;
select * from t1 partition (p0) where c1>3 and c2>3;
select * from t1 partition (p1) where c1=5 and c2=5;
select * from t1 partition (p1) where c1>5 and c2>5;

connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'now signal continue_signal';

connection conn2;
reap;

