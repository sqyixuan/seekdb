purge recyclebin;
################Setting ''_ optimizer_ null_ aware_ Antijoin 'is true################
SET "_optimizer_null_aware_antijoin"=true;
DROP TABLE t1 CASCADE CONSTRAINTS;
DROP TABLE t2 CASCADE CONSTRAINTS;
#VIEW
CREATE TABLE t1(c0 INT,c1 VARCHAR2(50));
CREATE TABLE t2(c0 INT,c1 VARCHAR2(50));
INSERT INTO t1 VALUES(1,'A');
INSERT INTO t1 VALUES(2,12);
INSERT INTO t1 VALUES(3,'A');
INSERT INTO t1 VALUES(4,NULL);
INSERT INTO t1 VALUES(5,'$ % &');
INSERT INTO t2 VALUES(1,12);
INSERT INTO t2 VALUES(2,'AB');
INSERT INTO t2 VALUES(3,'');
INSERT INTO t2 VALUES(4,NULL);
INSERT INTO t2 VALUES(5,'$%&');
CREATE OR REPLACE VIEW v1 AS SELECT * FROM t1;
CREATE OR REPLACE VIEW v2 AS SELECT * FROM t2;
SELECT * FROM v1 ORDER BY c0,c1;
C0	C1
1	A
2	12
3	A
4	NULL
5	$ % &
SELECT * FROM v2 ORDER BY c0,c1;
C0	C1
1	12
2	AB
3	NULL
4	NULL
5	$%&
SELECT /*USE_HASH(v1,v2)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2) ORDER BY v1.c0,v1.c1;
C0	C1	C0	C1
EXPLAIN BASIC SELECT /*USE_HASH(v1,v2) READ_CONSISTENCY (weak)*/ * FROM v1,v2 WHERE v1.c1 NOT IN (SELECT c1 FROM v2) ORDER BY v1.c0,v1.c1;
Query Plan
=======================================
|ID|OPERATOR                     |NAME|
---------------------------------------
|0 |EXCHANGE IN REMOTE           |    |
|1 | EXCHANGE OUT REMOTE         |    |
|2 |  SORT                       |    |
|3 |   NESTED-LOOP JOIN CARTESIAN|    |
|4 |    TABLE SCAN               |T2  |
|5 |    MATERIAL                 |    |
|6 |     HASH RIGHT ANTI JOIN NA |    |
|7 |      TABLE SCAN             |T2  |
|8 |      TABLE SCAN             |T1  |
=======================================

Outputs & filters: 
-------------------------------------
  0 - output([T1.C0], [T1.C1], [T2.C0], [T2.C1]), filter(nil)
  1 - output([T1.C0], [T1.C1], [T2.C0], [T2.C1]), filter(nil)
  2 - output([T1.C0], [T1.C1], [T2.C0], [T2.C1]), filter(nil), sort_keys([T1.C0, ASC], [T1.C1, ASC])
  3 - output([T1.C0], [T1.C1], [T2.C0], [T2.C1]), filter(nil), 
      conds(nil), nl_params_(nil)
  4 - output([T2.C0], [T2.C1]), filter(nil), 
      access([T2.C0], [T2.C1]), partitions(p0)
  5 - output([T1.C0], [T1.C1]), filter(nil)
  6 - output([T1.C0], [T1.C1]), filter(nil), 
      equal_conds([T1.C1 = T2.C1]), other_conds(nil)
  7 - output([T2.C1]), filter(nil), 
      access([T2.C1]), partitions(p0)
  8 - output([T1.C0], [T1.C1]), filter(nil), 
      access([T1.C0], [T1.C1]), partitions(p0)

