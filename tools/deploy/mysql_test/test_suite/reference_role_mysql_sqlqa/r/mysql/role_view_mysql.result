切换default用户
DROP USER lyq_test;
CREATE USER 'lyq_test' IDENTIFIED BY '123456';
GRANT ALL ON *.* TO lyq_test with grant option;
DROP DATABASE lyq_database;
CREATE DATABASE lyq_database CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DROP DATABASE lyq_database2;
CREATE DATABASE lyq_database2 CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
创建角色
drop ROLE role001;
CREATE ROLE role001;
drop ROLE role002;
CREATE ROLE role002;
SET GLOBAL activate_all_roles_on_login = on;
GRANT role001 TO lyq_test WITH ADMIN OPTION;
GRANT role002 TO lyq_test WITH ADMIN OPTION;
切换角色1用户
SET ROLE role001;
drop table t1;
CREATE TABLE t1(num INT ,food char(20),price varchar(200),PRIMARY KEY (num));
INSERT INTO t1 VALUES(1,'面包',-5.12315);
