切换default用户
DROP USER lyq_test;
CREATE USER 'lyq_test' IDENTIFIED BY '123456';
GRANT ALL ON *.* TO lyq_test with grant option;
REVOKE REFERENCES ON *.* FROM lyq_test;
创建database
DROP DATABASE lyq_database;
CREATE DATABASE lyq_database CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
切换外键用户
DROP TABLE t1;
CREATE TABLE t1(num INT ,food char(20),price varchar(200),PRIMARY KEY (num));
INSERT INTO t1 VALUES(1,'面包',-5.12315);
DROP TABLE t2;
CREATE TABLE t2(num INT ,food char(20),price varchar(200),PRIMARY KEY (num));
INSERT INTO t2 VALUES(1,'面包',-5.12315);
切换default用户
列级授权支持grant,revoke,show，但是创建外键时要求至少有table级别的references权限
GRANT REFERENCES(num) ON lyq_database.t1 TO lyq_test;
SHOW GRANTS FOR lyq_test;
Grants for lyq_test@%
GRANT ALTER, CREATE, CREATE USER, DELETE, DROP, INSERT, UPDATE, SELECT, INDEX, CREATE VIEW, SHOW VIEW, SHOW DATABASES, SUPER, PROCESS, FILE, ALTER TENANT, ALTER SYSTEM, CREATE RESOURCE POOL, CREATE RESOURCE UNIT, REPLICATION SLAVE, REPLICATION CLIENT, DROP DATABASE LINK, CREATE DATABASE LINK, EXECUTE, ALTER ROUTINE, CREATE ROUTINE, CREATE TABLESPACE, SHUTDOWN, RELOAD, LOCK TABLES, CREATE ROLE, DROP ROLE, TRIGGER, EVENT, CREATE CATALOG, USE CATALOG, CREATE AI MODEL, ALTER AI MODEL, DROP AI MODEL, ACCESS AI MODEL ON *.* TO 'lyq_test' WITH GRANT OPTION
GRANT REFERENCES (`num`) ON `lyq_database`.`t1` TO 'lyq_test'
切换外键用户
DROP TABLE fk_t1;
CREATE TABLE fk_t1 (
c1 INT,
c2 INT,
c3 varchar(200),
CONSTRAINT fk_t1_c1 FOREIGN KEY (c1) REFERENCES t1(num) ON DELETE CASCADE ON UPDATE RESTRICT
);
ERROR 42000: REFERENCES command denied to user 'lyq_test'@'%' for table 't1'
alter创建外键
DROP TABLE fk_t1;
CREATE TABLE fk_t1 (
c1 INT,
c2 INT,
c3 varchar(200));
ALTER TABLE fk_t1 ADD CONSTRAINT fk_t1_c1 FOREIGN KEY (c1) REFERENCES t1(num) ON DELETE NO ACTION ON UPDATE CASCADE;
ERROR 42000: REFERENCES command denied to user 'lyq_test'@'%' for table 't1'
SHOW GRANTS FOR lyq_test;
