SELECT GRANTEE, ROUTINE_SCHEMA, COUNT(ROUTINE_NAME) AS routine_count
FROM information_schema.role_routine_grants
WHERE ROUTINE_SCHEMA = 'lyq_database' AND PRIVILEGE_TYPE = 'EXECUTE'
GROUP BY GRANTEE, ROUTINE_SCHEMA
HAVING routine_count > 0
ORDER BY GRANTEE;
GRANTEE	ROUTINE_SCHEMA	routine_count
role001	lyq_database	1
role002	lyq_database	1
