# owner: linyi.cl
# description: role_routine_grants

--echo 切换default用户
--disable_result_log
connection default;
--error 0,1396
DROP USER lyq_test;
CREATE USER 'lyq_test' IDENTIFIED BY '123456';
--enable_result_log
GRANT ALL ON *.* TO lyq_test with grant option;
--error 0,1008
DROP DATABASE lyq_database;
CREATE DATABASE lyq_database CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;

--echo 创建角色
--error 0,1396
drop ROLE role001;
CREATE ROLE role001;

--error 0,1396
drop ROLE role002;
CREATE ROLE role002;

SET GLOBAL activate_all_roles_on_login = on;
GRANT role001 TO lyq_test WITH ADMIN OPTION;
GRANT role002 TO lyq_test WITH ADMIN OPTION;

--echo 切换角色1用户
connect(lyq_test,$OBMYSQL_MS0,lyq_test,123456,lyq_database,$OBMYSQL_PORT);


SET ROLE role001;

--error 0,1051
drop table t1;
CREATE TABLE t1(num INT ,food char(20),price varchar(200),PRIMARY KEY (num));
INSERT INTO t1 VALUES(1,'面包',-5.12315);
--echo 存储过程
--error 0,1305
drop PROCEDURE p1;
DELIMITER //;

CREATE PROCEDURE p1()
BEGIN
  SELECT * from t1;
END //

DELIMITER ;//

--echo 例程权限
GRANT EXECUTE ON PROCEDURE lyq_database.p1 TO 'role001';
select * from information_schema.role_routine_grants order by GRANTEE;
--error 0,1305
GRANT EXECUTE ON PROCEDURE lyq_database.p2 TO 'role001';
select * from information_schema.role_routine_grants order by GRANTEE;
--error 1064
GRANT EXECUTE lyq_database.p1 TO 'role001';
select * from information_schema.role_routine_grants order by GRANTEE;
--error 1064
REVOKE EXECUTE lyq_database.p1 FROM 'role001';
select * from information_schema.role_routine_grants order by GRANTEE;

REVOKE EXECUTE ON PROCEDURE lyq_database.p1 FROM 'role001';
select * from information_schema.role_routine_grants order by GRANTEE;
--error 5362
REVOKE ALL ON lyq_database.p1 FROM 'role001';
select * from information_schema.role_table_grants;

GRANT ALL ON lyq_database.* TO 'role001';
select * from information_schema.role_table_grants; 
select * from information_schema.role_column_grants;
select * from information_schema.role_routine_grants order by GRANTEE;

GRANT ALL ON *.* TO 'role001';
select * from information_schema.role_table_grants; 
select * from information_schema.role_column_grants;
select * from information_schema.role_routine_grants order by GRANTEE;

--echo 不能授予角色的权限 
--error 1144
GRANT CREATE ROUTINE ON lyq_database.p1 TO 'role001';
select * from information_schema.role_routine_grants order by GRANTEE; 


--echo 函数
--error 0,1305
drop FUNCTION f1;
DELIMITER //;

CREATE FUNCTION f1(productId INT) RETURNS VARCHAR(100)
DETERMINISTIC
READS SQL DATA
BEGIN
  DECLARE productName VARCHAR(100);

  SELECT price INTO productName from t1 where num = productId;

  RETURN productName;
END //

DELIMITER ;//

GRANT EXECUTE ON FUNCTION lyq_database.f1 TO 'role001';
select * from information_schema.role_routine_grants order by GRANTEE;

--error 0,1360
drop TRIGGER trg2_t;
 
delimiter //;
--disable_warnings
 
CREATE TRIGGER trg2_t BEFORE INSERT ON t1 FOR EACH ROW 
BEGIN
  INSERT INTO t1 VALUES (1,1,1);
END;
//
 
delimiter ;//
--error 1064
GRANT EXECUTE ON TRIGGER lyq_database.trg2_t TO 'role001';
select * from information_schema.role_routine_grants order by GRANTEE;

--error 1305
GRANT EXECUTE ON PROCEDURE lyq_database.trg2_t TO 'role001';
select * from information_schema.role_routine_grants order by GRANTEE;

--echo 不同角色
SET ROLE role002;

GRANT EXECUTE ON FUNCTION lyq_database.f1 TO 'role002' with grant option; 
select * from information_schema.role_routine_grants order by GRANTEE;
GRANT EXECUTE ON PROCEDURE lyq_database.p1 TO 'role002';
select * from information_schema.role_routine_grants order by GRANTEE;

SET ROLE role001;
GRANT EXECUTE ON FUNCTION lyq_database.f1 TO 'role001';
select * from information_schema.role_routine_grants order by GRANTEE;
GRANT EXECUTE ON PROCEDURE lyq_database.p1 TO 'role001' with grant option;
select * from information_schema.role_routine_grants order by GRANTEE;

--echo 切换角色1用户
disconnect lyq_test;
connect(lyq_test,$OBMYSQL_MS0,lyq_test,123456,lyq_database,$OBMYSQL_PORT);
GRANT EXECUTE ON FUNCTION lyq_database.f1 TO 'role001';
select * from information_schema.role_routine_grants order by GRANTEE;
GRANT EXECUTE ON PROCEDURE lyq_database.p1 TO 'role001' with grant option;
select * from information_schema.role_routine_grants order by GRANTEE;

SELECT GRANTEE, ROUTINE_SCHEMA, COUNT(ROUTINE_NAME) AS routine_count
FROM information_schema.role_routine_grants
WHERE ROUTINE_SCHEMA = 'lyq_database' AND PRIVILEGE_TYPE = 'EXECUTE'
GROUP BY GRANTEE, ROUTINE_SCHEMA
HAVING routine_count > 0
ORDER BY GRANTEE;

--echo 将角色授予角色,再将角色授予用户
--echo 切换default用户
connection default;

--echo 撤销角色
REVOKE role002,role001 FROM lyq_test;
SELECT * FROM mysql.role_edges where TO_USER = 'lyq_test';

--echo 切换角色1用户
disconnect lyq_test;
connect(lyq_test,$OBMYSQL_MS0,lyq_test,123456,lyq_database,$OBMYSQL_PORT);
select * from information_schema.role_routine_grants order by GRANTEE;

GRANT ALTER ROUTINE ON PROCEDURE lyq_database.p1 TO 'role002' with grant option;
select * from information_schema.role_routine_grants order by GRANTEE;
GRANT ALTER ROUTINE ON FUNCTION lyq_database.f1 TO 'role002';
select * from information_schema.role_routine_grants order by GRANTEE;


--echo 切换default用户
connection default;
--error 0,1396
drop ROLE role003;
CREATE ROLE role003;

GRANT role001 TO role003 WITH ADMIN OPTION;
GRANT role003 TO lyq_test WITH ADMIN OPTION;

--echo 切换角色1用户
disconnect lyq_test;
connect(lyq_test,$OBMYSQL_MS0,lyq_test,123456,lyq_database,$OBMYSQL_PORT);

select * from information_schema.role_routine_grants order by GRANTEE;

SET ROLE role003;

GRANT ALTER ROUTINE ON PROCEDURE lyq_database.p1 TO 'role003' with grant option;
select * from information_schema.role_routine_grants order by GRANTEE;
GRANT ALTER ROUTINE ON FUNCTION lyq_database.f1 TO 'role003';
select * from information_schema.role_routine_grants order by GRANTEE;
REVOKE ALTER ROUTINE ON PROCEDURE lyq_database.p1 FROM 'role003';
select * from information_schema.role_routine_grants order by GRANTEE;


--echo 同时授权多个角色
--error 3530
SET ROLE role001;
GRANT ALTER ROUTINE ON PROCEDURE lyq_database.p1 TO 'role001','role003';
select * from information_schema.role_routine_grants order by GRANTEE;
GRANT ALTER ROUTINE ON FUNCTION lyq_database.f1 TO 'role003','role001','role002' with grant option;
select * from information_schema.role_routine_grants order by GRANTEE;
REVOKE ALTER ROUTINE ON PROCEDURE lyq_database.p1 FROM 'role001', 'role003';
select * from information_schema.role_routine_grants order by GRANTEE;
REVOKE ALTER ROUTINE ON PROCEDURE lyq_database.p1 FROM 'role003','role002';
select * from information_schema.role_routine_grants order by GRANTEE;


--echo 没有授予的角色
GRANT ALTER ROUTINE ON PROCEDURE lyq_database.p1 TO 'role002';
select * from information_schema.role_routine_grants order by GRANTEE;
GRANT ALTER ROUTINE ON FUNCTION lyq_database.f1 TO 'role002' with grant option;
select * from information_schema.role_routine_grants order by GRANTEE;

--echo 切换default用户
connection default;
--disable_result_log
--error 0,1396
DROP USER lyq_test;
--enable_result_log
--error 0,1008
DROP DATABASE lyq_database;
--error 0,1396
drop ROLE role001;
--error 0,1396
drop ROLE role002;




