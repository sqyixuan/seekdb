c1 INT,
c2 INT,
c3 varchar(200),
CONSTRAINT fk_t1_c1 FOREIGN KEY (c1) REFERENCES t1(num) ON DELETE CASCADE ON UPDATE RESTRICT
);

INSERT INTO fk_t1 VALUES(1,1,1);
--error 1452
INSERT INTO fk_t1 VALUES(5,5,5);

--echo 删除外键
ALTER TABLE fk_t1 DROP FOREIGN KEY fk_t1_c1;

INSERT INTO fk_t1 VALUES(5,5,5);
delete from fk_t1 where c1 = 5;

--echo alter创建外键
ALTER TABLE fk_t1 ADD CONSTRAINT fk_t1_c1 FOREIGN KEY (c1) REFERENCES t1(num) ON DELETE NO ACTION ON UPDATE CASCADE;
--error 1452
INSERT INTO fk_t1 VALUES(5,5,5);

select * from t1;
select * from fk_t1;

