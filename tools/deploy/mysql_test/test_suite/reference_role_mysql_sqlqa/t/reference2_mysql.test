--echo 切换default用户
connection default;

--disable_result_log
--error 0,1396
DROP USER lyq_test;
CREATE USER 'lyq_test' IDENTIFIED BY '123456';
--enable_result_log
GRANT ALL ON *.* TO lyq_test with grant option;
REVOKE REFERENCES ON *.* FROM lyq_test;

--echo 创建database
--error 0,1008
DROP DATABASE lyq_database;
CREATE DATABASE lyq_database CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;

--echo 切换外键用户
connect(lyq_test,$OBMYSQL_MS0,lyq_test,123456,lyq_database,$OBMYSQL_PORT);

--error 0,1051
DROP TABLE t1;
CREATE TABLE t1(num INT ,food char(20),price varchar(200),PRIMARY KEY (num));
INSERT INTO t1 VALUES(1,'面包',-5.12315);

--error 0,1051
DROP TABLE t2;
