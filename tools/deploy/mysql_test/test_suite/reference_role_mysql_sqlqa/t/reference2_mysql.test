--error 5133
REVOKE REFERENCES ON lyq_database.* FROM lyq_test;
--error 5362
REVOKE REFERENCES ON lyq_database.t1 FROM lyq_test;
GRANT REFERENCES ON lyq_database.t1 TO lyq_test; 
GRANT REFERENCES ON lyq_database.* TO lyq_test with grant option;
SHOW GRANTS FOR lyq_test;

--echo 切换外键用户
disconnect lyq_test;
connect(lyq_test,$OBMYSQL_MS0,lyq_test,123456,lyq_database,$OBMYSQL_PORT);

--error 0,1051
DROP TABLE fk_t1;
CREATE TABLE fk_t1 (
c1 INT,
c2 INT,
c3 varchar(200),
CONSTRAINT fk_t1_c1 FOREIGN KEY (c1) REFERENCES t2(num) ON DELETE CASCADE ON UPDATE RESTRICT
);

--error 0,1051
DROP TABLE fk_t1;
