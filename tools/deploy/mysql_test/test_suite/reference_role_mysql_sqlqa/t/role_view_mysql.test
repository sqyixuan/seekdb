--echo 分区表
--error 0,1051
DROP TABLE t3;
CREATE TABLE t3 (
    id INT,
    created_at DATE,
	order_year INT AS (YEAR(created_at)) STORED
)
PARTITION BY RANGE (YEAR(created_at)) (
    PARTITION p0 VALUES LESS THAN (2020),
    PARTITION p1 VALUES LESS THAN (2021),
    PARTITION p2 VALUES LESS THAN (2022)
);

INSERT INTO t3 (id, created_at) VALUES (1, '2019-01-01');

GRANT delete,update,show view ON lyq_database.t3 TO 'role001';
select * from information_schema.role_table_grants order by GRANTOR,GRANTEE,TABLE_SCHEMA,TABLE_NAME,PRIVILEGE_TYPE,IS_GRANTABLE;

GRANT SELECT (id, order_year) ON lyq_database.t3 TO 'role001';
