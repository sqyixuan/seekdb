SELECT GRANTEE, TABLE_SCHEMA, COUNT(DISTINCT PRIVILEGE_TYPE) AS privilege_type_count
FROM information_schema.role_table_grants
WHERE TABLE_SCHEMA = 'lyq_database'
GROUP BY GRANTEE, TABLE_SCHEMA
HAVING privilege_type_count >= 2
ORDER BY GRANTEE;

SELECT GRANTEE, TABLE_SCHEMA, TABLE_NAME, COUNT(COLUMN_NAME) AS permissions_count
FROM information_schema.role_column_grants
WHERE TABLE_SCHEMA = 'lyq_database'
GROUP BY GRANTEE, TABLE_SCHEMA, TABLE_NAME
HAVING permissions_count < 10
ORDER BY GRANTEE;

WITH TableGrantsCTE AS (
  SELECT GRANTEE, TABLE_SCHEMA, TABLE_NAME
  FROM information_schema.role_table_grants
  WHERE PRIVILEGE_TYPE IN ('SELECT', 'INSERT', 'UPDATE', 'DELETE')
)
SELECT GRANTEE, TABLE_SCHEMA, TABLE_NAME FROM TableGrantsCTE
UNION
SELECT 'RoleWithoutTablePrivileges' AS GRANTEE, '--' AS TABLE_SCHEMA, '--' AS TABLE_NAME
FROM dual
WHERE NOT EXISTS (SELECT 1 FROM TableGrantsCTE) order by GRANTEE, TABLE_SCHEMA, TABLE_NAME;


