# owner: linyi.cl
# description: create role

--echo 切换default用户
connection default;
--disable_result_log
--error 0,1396
DROP USER lyq_test;
CREATE USER 'lyq_test' IDENTIFIED BY '123456';
--enable_result_log
GRANT ALL ON *.* TO lyq_test with grant option;
--error 0,1008
DROP DATABASE lyq_database;
CREATE DATABASE lyq_database CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;

--echo 禁用CREATE USER,CREATE ROLE
REVOKE CREATE USER,CREATE ROLE ON *.* FROM lyq_test;
SHOW GRANTS FOR lyq_test;
--echo 切换创建的用户
connect(lyq_test,$OBMYSQL_MS0,lyq_test,123456,lyq_database,$OBMYSQL_PORT);

--error 1227
CREATE ROLE role001;

--echo 单独验证CREATE USER和CREATE ROLE
--echo 切换default用户
connection default;
GRANT CREATE USER ON *.* TO lyq_test; 
SHOW GRANTS FOR lyq_test;

--echo 切换创建的用户
disconnect lyq_test;
connect(lyq_test,$OBMYSQL_MS0,lyq_test,123456,lyq_database,$OBMYSQL_PORT);
--error 0,1396
DROP ROLE role001;
CREATE ROLE role001;
