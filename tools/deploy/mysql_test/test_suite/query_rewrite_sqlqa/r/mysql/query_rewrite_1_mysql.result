########## 处理测试环境 ##########
drop user whh@'%';
drop database whh1;
drop database whh1271111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111;
drop database whh12811111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111;
create user whh identified by 'whh';
create database whh1;
create database whh1271111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111;
create database whh12811111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111;
grant all on *.* to whh with grant option;


# 修改租户级配置项,重写功能开启
alter system set enable_user_defined_rewrite_rules = 'ON';
set @@sql_mode='strict_all_tables';
purge recyclebin;
result_format: 4
>>>>>>>>>>>>>>>>>>>>>>>>>>> qr-mysql-4 测试的表对象	 <<<<<<<<<<<<<<<<<<<<<<<<<
drop table t1;
create table t1 (
  id int not null primary key,
  c1_char char(20),
  c2_vcha varchar(20),
  c3_text text,
  c4_enum enum('枚举','enum1','enum2','enum3') default null,
  c5_set1 set('集合','set1','set2','set3','set4') default null,
  index index1 (c1_char)
)charset = utf8mb4 partition by hash(id) partitions 3;
insert into t1 values(1,'char1','varchar1','text1','枚举','集合');
insert into t1 values(2,'char2','varchar2','text2','enum1','set1');
insert into t1 values(3,'char3','varchar3','text3','enum2','set2');
insert into t1 values(4,'char4','varchar4','text4','enum3','set3,set4');
drop table t2;
create table t2 (
  id int,
  c1_tint tinyint,
  c2_sint smallint,
  c3_mint mediumint,
  c4_bint bigint,
  c5_floa float,
  c6_doub double,
  c7_deci decimal,
  primary key(id,c1_tint),
  index index2 (id,c1_tint)
)partition by range (c1_tint) ( 
 partition p0 values less than (10), 
 partition p1 values less than (20), 
 partition p2 values less than maxvalue);
