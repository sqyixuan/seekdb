# 时间日期字面量
call dbms_udr.create_rule(date'2022-11-01','whh1','select ?,1', 'select ? * 2,1','YES');
select 2,1;
+-------+---+
| ? * 2 | 1 |
+-------+---+
|     4 | 1 |
+-------+---+
call dbms_udr.disable_rule (date'2022-11-01');
select 2,1;
+---+---+
| 2 | 1 |
+---+---+
| 2 | 1 |
+---+---+
call dbms_udr.enable_rule (date'2022-11-01');
select 2,1;
+-------+---+
| ? * 2 | 1 |
+-------+---+
|     4 | 1 |
+-------+---+
call dbms_udr.remove_rule (date'2022-11-01');
select 2,1;
+---+---+
| 2 | 1 |
+---+---+
| 2 | 1 |
+---+---+
call dbms_udr.create_rule(time'15:00:00','whh1','select :A,2,:B', 'select :A * 2 * :B','YES');
select 2,2,3;
+-------------+
| :A * 2 * :B |
+-------------+
|          12 |
+-------------+
call dbms_udr.disable_rule (time'15:00:00');
select 2,2,3;
+---+---+---+
| 2 | 2 | 3 |
+---+---+---+
| 2 | 2 | 3 |
+---+---+---+
call dbms_udr.enable_rule (time'15:00:00');
select 2,2,3;
+-------------+
| :A * 2 * :B |
+-------------+
|          12 |
+-------------+
call dbms_udr.remove_rule (time'15:00:00');
select 2,2,3;
+---+---+---+
| 2 | 2 | 3 |
+---+---+---+
| 2 | 2 | 3 |
+---+---+---+
call dbms_udr.create_rule(timestamp'2022-11-14 15:00:00','whh1','select :A / 2', 'select :A * 2','YES');
select 4 / 2;
+--------+
| :A * 2 |
+--------+
|      8 |
+--------+
call dbms_udr.disable_rule (timestamp'2022-11-14 15:00:00');
select 4 / 2;
+--------+
| 4 / 2  |
+--------+
| 2.0000 |
+--------+
call dbms_udr.enable_rule (timestamp'2022-11-14 15:00:00');
select 4 / 2;
+--------+
| :A * 2 |
+--------+
|      8 |
+--------+
call dbms_udr.remove_rule (timestamp'2022-11-14 15:00:00');
select 4 / 2;
+--------+
| 4 / 2  |
+--------+
| 2.0000 |
+--------+
# 字符与数值混合字面量
call dbms_udr.create_rule('123rule_name123','whh1','select :A', 'select :A + :A','YES');
select 10;
+---------+
| :A + :A |
+---------+
|      20 |
+---------+
call dbms_udr.remove_rule ('123rule_name123');
call dbms_udr.create_rule('rule_name123','whh1','select :A', 'select :A * :A','YES');
select 10;
+---------+
| :A * :A |
+---------+
|     100 |
+---------+
call dbms_udr.remove_rule ('rule_name123');
# 含有特殊字符的字面量
call dbms_udr.create_rule('@#$%^&*','whh1','select :A', 'select :A * 2','YES');
select 10;
+--------+
| :A * 2 |
+--------+
|     20 |
+--------+
call dbms_udr.remove_rule ('@#$%^&*');
call dbms_udr.create_rule('rule\n','whh1','select ?,2', 'select ? + 1,2','YES');
select 10,2;
+-------+---+
| ? + 1 | 2 |
+-------+---+
|    11 | 2 |
+-------+---+
call dbms_udr.remove_rule ('rule\n');
call dbms_udr.create_rule('rule\t','whh1','select :A,2', 'select :A + 1,2','YES');
select 10,2;
+--------+---+
| :A + 1 | 2 |
+--------+---+
|     11 | 2 |
+--------+---+
call dbms_udr.remove_rule ('rule\t');
call dbms_udr.create_rule('rule\r','whh1','select ?', 'select lower(?)','YES');
select 'WANG';
+----------+
| lower(?) |
+----------+
| wang     |
+----------+
select 10;
+----------+
| lower(?) |
+----------+
| 10       |
+----------+
call dbms_udr.remove_rule ('rule\r');
call dbms_udr.create_rule('rule
name','whh1','select :A', 'select upper(:A)','YES');
select 'query rewrite';
+---------------+
| upper(:A)     |
+---------------+
| QUERY REWRITE |
+---------------+
call dbms_udr.remove_rule ('rule
name');
