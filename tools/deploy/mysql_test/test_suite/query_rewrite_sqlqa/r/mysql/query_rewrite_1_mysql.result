######## 标签：qr-mysql-5-1 创建重写
#### rule_name 
# null
call dbms_udr.create_rule(null,'whh1','select ?', 'select ? + 1','YES');
ERROR HY000: Invalid argument
# 汉字常量
call dbms_udr.create_rule('规则名称','whh1','select ?', 'select ? + 1','YES');
select 10;
+-------+
| ? + 1 |
+-------+
|    11 |
+-------+
call dbms_udr.remove_rule ('规则名称');
# 用户自定义变量
set @name = 'rule_name';
call dbms_udr.create_rule(@name,'whh1','select ?', 'select ? + 2','YES');
select 10;
+-------+
| ? + 2 |
+-------+
|    12 |
+-------+
call dbms_udr.remove_rule (@name);
# 字符类型字面量
call dbms_udr.create_rule('rule_name','whh1','select ?', 'select ? * 2','YES');
select 10;
+-------+
| ? * 2 |
+-------+
|    20 |
+-------+
call dbms_udr.remove_rule ('rule_name');
call dbms_udr.create_rule(' ','whh1','select ?', 'select ? * 2','YES');
select 2;
+-------+
| ? * 2 |
+-------+
|     4 |
+-------+
call dbms_udr.remove_rule (' ');
# 一段超长字符串字面量
call dbms_udr.create_rule(rpad('rule_name',255,'x'),'whh1','select ?','select ? + 3','YES');
select 10;
+-------+
| ? + 3 |
+-------+
|    13 |
+-------+
call dbms_udr.remove_rule (rpad('rule_name',255,'x'));
call dbms_udr.create_rule(rpad('rule_name',256,'x'),'whh1','select ?','select ? + 4','YES');
select 10;
+-------+
| ? + 4 |
+-------+
|    14 |
+-------+
call dbms_udr.remove_rule (rpad('rule_name',256,'x'));
call dbms_udr.create_rule(rpad('rule_name',257,'x'),'whh1','select ?','select ? + 5','YES');
ERROR 22001: Data too long for column
