|  1 |      11 |      12 |      13 |      14 |    15.1 |    16.5 |      17 |
+----+---------+---------+---------+---------+---------+---------+---------+
select * from t2 where id > 1 limit 3;
+----+---------+---------+---------+---------+---------+---------+---------+
| id | c1_tint | c2_sint | c3_mint | c4_bint | c5_floa | c6_doub | c7_deci |
+----+---------+---------+---------+---------+---------+---------+---------+
|  2 |      21 |      22 |      23 |      24 |    25.1 |    26.5 |      27 |
|  3 |      31 |      32 |      33 |      34 |    35.1 |    36.5 |      37 |
|  4 |      41 |      42 |      43 |      44 |    45.1 |    46.5 |      47 |
+----+---------+---------+---------+---------+---------+---------+---------+
select * from t2 where id > 1 order by id;
+----+---------+---------+---------+---------+---------+---------+---------+
| id | c1_tint | c2_sint | c3_mint | c4_bint | c5_floa | c6_doub | c7_deci |
+----+---------+---------+---------+---------+---------+---------+---------+
|  2 |      21 |      22 |      23 |      24 |    25.1 |    26.5 |      27 |
|  3 |      31 |      32 |      33 |      34 |    35.1 |    36.5 |      37 |
|  4 |      41 |      42 |      43 |      44 |    45.1 |    46.5 |      47 |
|  5 |      41 |      52 |      53 |      54 |    55.1 |    56.5 |      57 |
|  8 |      81 |      82 |      83 |      84 |    85.1 |    86.5 |      87 |
+----+---------+---------+---------+---------+---------+---------+---------+
select id,c1_tint,c2_sint from t2 where id > 1 order by id;
+----+---------+---------+
| id | c1_tint | c2_sint |
+----+---------+---------+
|  2 |      21 |      22 |
|  3 |      31 |      32 |
|  4 |      41 |      42 |
|  5 |      41 |      52 |
|  8 |      81 |      82 |
+----+---------+---------+
call dbms_udr.remove_rule ('rule1');
call dbms_udr.create_rule('rule2','whh1','select count(*) from t1 where id > ?', 'select 10000 as "query rewrite" from t1 where id >= ? order by id desc','YES');
select count(*) from t1 where id > 1;
+---------------+
| query rewrite |
+---------------+
|         10000 |
|         10000 |
|         10000 |
|         10000 |
+---------------+
select count(id) from t1 where id > 1;
+-----------+
| count(id) |
+-----------+
|         3 |
+-----------+
select count(*) from t1  where id > 1 order by id;
+----------+
| count(*) |
+----------+
|        3 |
+----------+
call dbms_udr.remove_rule ('rule2');
call dbms_udr.create_rule('rule2','whh1','select id,c1_tint,c2_sint from t2 where id > ?', 'select c2_sint,c1_tint,id from t2 where id > ?+1 order by id desc','YES');
select * from t2 where id > 1 order by id;
+----+---------+---------+---------+---------+---------+---------+---------+
| id | c1_tint | c2_sint | c3_mint | c4_bint | c5_floa | c6_doub | c7_deci |
+----+---------+---------+---------+---------+---------+---------+---------+
|  2 |      21 |      22 |      23 |      24 |    25.1 |    26.5 |      27 |
|  3 |      31 |      32 |      33 |      34 |    35.1 |    36.5 |      37 |
|  4 |      41 |      42 |      43 |      44 |    45.1 |    46.5 |      47 |
|  5 |      41 |      52 |      53 |      54 |    55.1 |    56.5 |      57 |
|  8 |      81 |      82 |      83 |      84 |    85.1 |    86.5 |      87 |
+----+---------+---------+---------+---------+---------+---------+---------+
select id,c1_tint,c2_sint from t2 where id > 1;
+---------+---------+----+
| c2_sint | c1_tint | id |
+---------+---------+----+
|      82 |      81 |  8 |
|      52 |      41 |  5 |
|      42 |      41 |  4 |
|      32 |      31 |  3 |
+---------+---------+----+
SELECT ID,C1_TINT,C2_SINT FROM T2 where id > 1 order by id;
+----+---------+---------+
| ID | C1_TINT | C2_SINT |
+----+---------+---------+
|  2 |      21 |      22 |
|  3 |      31 |      32 |
|  4 |      41 |      42 |
|  5 |      41 |      52 |
|  8 |      81 |      82 |
+----+---------+---------+
select id,c1_tint,c2_sint from t2 where id > 1 order by id;
+----+---------+---------+
| id | c1_tint | c2_sint |
+----+---------+---------+
|  2 |      21 |      22 |
|  3 |      31 |      32 |
|  4 |      41 |      42 |
|  5 |      41 |      52 |
|  8 |      81 |      82 |
+----+---------+---------+
call dbms_udr.remove_rule ('rule2');
call dbms_udr.create_rule('rule3','whh1','select * from t1 where ? > 1', 'select "query_rewrite",* from t1 where ?+1 > 1 order by id','YES');
select * from t1 where 1 > 1;
+---------------+----+---------+----------+---------+---------+-----------+
| query_rewrite | id | c1_char | c2_vcha  | c3_text | c4_enum | c5_set1   |
+---------------+----+---------+----------+---------+---------+-----------+
| query_rewrite |  1 | char1   | varchar1 | text1   | 枚举    | 集合      |
| query_rewrite |  2 | char2   | varchar2 | text2   | enum1   | set1      |
| query_rewrite |  3 | char3   | varchar3 | text3   | enum2   | set2      |
| query_rewrite |  4 | char4   | varchar4 | text4   | enum3   | set3,set4 |
+---------------+----+---------+----------+---------+---------+-----------+
call dbms_udr.remove_rule ('rule3');
# 修改租户级配置项,重写功能关闭
alter system set enable_user_defined_rewrite_rules = 'OFF';
# Clean up users
drop user whh@'%';
drop database whh1;
