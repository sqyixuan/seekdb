######## 标签：qr-mysql-3-6 6、SET语句
#### SET语句
call dbms_udr.create_rule('rule8','whh1','set @a = ?', 'set @a = ?*100','YES');
set @a = 1;
select @a;
+------+
| @a   |
+------+
|  100 |
+------+
set @a = 1+2;
select @a;
+------+
| @a   |
+------+
|    3 |
+------+
set @a1 = 1;
select @a1;
+------+
| @a1  |
+------+
|    1 |
+------+
set @a = 3,@a2 = 4;
select @a,@a2;
+------+------+
| @a   | @a2  |
+------+------+
|    3 |    4 |
+------+------+
call dbms_udr.remove_rule ('rule8');
call dbms_udr.create_rule('rule9','whh1','set @b1 = :A,@b2 = :B', 'set @b1 = :B-(-100),@b2 = :A-(-200)','YES');
set @b1 = 1;
select @b1;
+------+
| @b1  |
+------+
|    1 |
+------+
set @b2 = 2;
select @b2;
+------+
| @b2  |
+------+
|    2 |
+------+
set @b1 = 3,@b2 = 4;
select @b1,@b2;
+------+------+
| @b1  | @b2  |
+------+------+
|  104 |  203 |
+------+------+
set @b2 = 5,@b1 = 6;
select @b2,@b1;
+------+------+
| @b2  | @b1  |
+------+------+
|    5 |    6 |
+------+------+
set @b1 = 7,@b2 = 8,@b3 = 9;
select @b1,@b2,@b3;
+------+------+------+
| @b1  | @b2  | @b3  |
+------+------+------+
|    7 |    8 |    9 |
+------+------+------+
call dbms_udr.remove_rule ('rule9');
call dbms_udr.create_rule('rule10','whh1','set @c1 = ?, @c2 = 2', 'set @c1 = ?*10, @c2 = 20','YES');
set @c1 = 1;
select @c1;
+------+
| @c1  |
+------+
|    1 |
+------+
set @c2 = 2;
select @c2;
+------+
| @c2  |
+------+
|    2 |
+------+
set @c1 = 10,@c2 = 2;
select @c1,@c2;
+------+------+
| @c1  | @c2  |
+------+------+
|   10 |    2 |
+------+------+
set @c1 = 10, @c2 = 2;
select @c1,@c2;
+------+------+
| @c1  | @c2  |
+------+------+
|  100 |   20 |
+------+------+
set @c1 = 20, @c2 = 3-1;
select @c1,@c2;
+------+------+
| @c1  | @c2  |
+------+------+
|   20 |    2 |
+------+------+
set @c1 = 20+10, @c2 = 2;
select @c1,@c2;
+------+------+
| @c1  | @c2  |
+------+------+
|   30 |    2 |
+------+------+
set @c1 = 40, @c2 = 2,@c3 = 4;
select @c1,@c2,@c3;
+------+------+------+
| @c1  | @c2  | @c3  |
+------+------+------+
|   40 |    2 |    4 |
+------+------+------+
call dbms_udr.remove_rule ('rule10');
#### pattern，replacement(语句模板-不同类型语句)
#### insert -- >  重写支持的SQL类型
call dbms_udr.create_rule('rule1','whh1','insert into t4 (id,c1_tint,c2_vcha) values(:A,:B,:C)', 'update t5 set c2_vcha = CONCAT("t4-insert: ",:A,:B,:C) where id = :A +(-10)','YES');
insert into t4 (id,c1_tint,c2_vcha) values(11,100,"insert-->update1");
insert into t4 (id,c2_vcha,c1_tint) values(12,"insert-->update2",110);
insert into t4 values(13,120,"insert-->update3");
select * from t4 order by id;
+----+---------+------------------+
| id | c1_tint | c2_vcha          |
+----+---------+------------------+
|  1 |      22 | 查询             |
|  2 |     100 | query rewrite1   |
|  3 |      20 | 测试             |
|  4 |      40 | 用例             |
|  5 |      41 | 52               |
|  5 |      50 | mysql            |
|  7 |      70 | table t4         |
|  8 |       3 | 3                |
|  8 |       4 | NULL             |
|  8 |      81 | 82               |
| 11 |      21 | query rewrite2   |
| 12 |     110 | insert-->update2 |
| 13 |     120 | insert-->update3 |
+----+---------+------------------+
select * from t5 order by id;
+----+---------+----------------------------------+
| id | c1_tint | c2_vcha                          |
+----+---------+----------------------------------+
|  1 |      10 | t4-insert: 11100insert-->update1 |
|  2 |      20 | 重写2                            |
|  3 |      30 | 测试2                            |
|  5 |      50 | mysql                            |
|  6 |      60 | table t4                         |
|  8 |      10 | t4表                             |
|  8 |      20 | 2                                |
+----+---------+----------------------------------+
