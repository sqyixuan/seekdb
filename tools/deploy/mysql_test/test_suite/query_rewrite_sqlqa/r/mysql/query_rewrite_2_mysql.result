drop view v1;
create view v1 as select * from t2;
#### pattern，replacement(参数标记个数，参数标记位置,语句模板)
######## 标签：qr-mysql-3-1 1、SELECT语句
## 视图
call dbms_udr.create_rule('rule0','whh1','select * from v1 where id = ?', 'select * from v1 where id > ? order by id desc','YES');
select * from v1 where id = 2;
+----+---------+---------+---------+---------+---------+---------+---------+
| id | c1_tint | c2_sint | c3_mint | c4_bint | c5_floa | c6_doub | c7_deci |
+----+---------+---------+---------+---------+---------+---------+---------+
|  8 |      81 |      82 |      83 |      84 |    85.1 |    86.5 |      87 |
|  5 |      41 |      52 |      53 |      54 |    55.1 |    56.5 |      57 |
|  4 |      41 |      42 |      43 |      44 |    45.1 |    46.5 |      47 |
|  3 |      31 |      32 |      33 |      34 |    35.1 |    36.5 |      37 |
+----+---------+---------+---------+---------+---------+---------+---------+
select * from v1 where id = 1+1;
+----+---------+---------+---------+---------+---------+---------+---------+
| id | c1_tint | c2_sint | c3_mint | c4_bint | c5_floa | c6_doub | c7_deci |
+----+---------+---------+---------+---------+---------+---------+---------+
|  2 |      21 |      22 |      23 |      24 |    25.1 |    26.5 |      27 |
+----+---------+---------+---------+---------+---------+---------+---------+
select * from v1 where id = 2 and c1_tint> 10;
+----+---------+---------+---------+---------+---------+---------+---------+
| id | c1_tint | c2_sint | c3_mint | c4_bint | c5_floa | c6_doub | c7_deci |
+----+---------+---------+---------+---------+---------+---------+---------+
|  2 |      21 |      22 |      23 |      24 |    25.1 |    26.5 |      27 |
+----+---------+---------+---------+---------+---------+---------+---------+
select * from v1 where id = 2 order by id;
+----+---------+---------+---------+---------+---------+---------+---------+
| id | c1_tint | c2_sint | c3_mint | c4_bint | c5_floa | c6_doub | c7_deci |
+----+---------+---------+---------+---------+---------+---------+---------+
|  2 |      21 |      22 |      23 |      24 |    25.1 |    26.5 |      27 |
