#### select -- >  重写支持的SQL类型
call dbms_udr.create_rule('rule9','whh1','select * from t1 where id = :A', 'update t1 set c1_char = CONCAT(:A,"select-->update") where id = :A','YES');
select * from t1 where id = 1;
select * from t1 where abs(id) = 2;
+----+---------+----------+---------+---------+---------+
| id | c1_char | c2_vcha  | c3_text | c4_enum | c5_set1 |
+----+---------+----------+---------+---------+---------+
|  2 | char2   | varchar2 | text2   | enum1   | set1    |
+----+---------+----------+---------+---------+---------+
select * from t1 where id = 2+1;
+----+---------+----------+---------+---------+---------+
| id | c1_char | c2_vcha  | c3_text | c4_enum | c5_set1 |
+----+---------+----------+---------+---------+---------+
|  3 | char3   | varchar3 | text3   | enum2   | set2    |
+----+---------+----------+---------+---------+---------+
select * from t1 where id = 1 or c1_char is not null order by id;
+----+------------------+----------+---------+---------+-----------+
| id | c1_char          | c2_vcha  | c3_text | c4_enum | c5_set1   |
+----+------------------+----------+---------+---------+-----------+
|  1 | 1select-->update | varchar1 | text1   | 枚举    | 集合      |
|  2 | char2            | varchar2 | text2   | enum1   | set1      |
|  3 | char3            | varchar3 | text3   | enum2   | set2      |
|  4 | char4            | varchar4 | text4   | enum3   | set3,set4 |
|  6 | qr-old5          | qr-old5  | qr-old5 | NULL    | NULL      |
|  7 | qr-6             | qr-6     | qr-6    | NULL    | NULL      |
|  8 | 2                | 4        | 6       | NULL    | NULL      |
|  9 | 语句             | 字段     | 不同    | 枚举    | NULL      |
| 10 | 插入             | 全部     | 字段    | 枚举    | 集合      |
+----+------------------+----------+---------+---------+-----------+
select id,c1_char,c2_vcha from t1 where id = 4;
+----+---------+----------+
| id | c1_char | c2_vcha  |
+----+---------+----------+
|  4 | char4   | varchar4 |
+----+---------+----------+
select * from t1 order by id;
+----+------------------+----------+---------+---------+-----------+
| id | c1_char          | c2_vcha  | c3_text | c4_enum | c5_set1   |
+----+------------------+----------+---------+---------+-----------+
|  1 | 1select-->update | varchar1 | text1   | 枚举    | 集合      |
|  2 | char2            | varchar2 | text2   | enum1   | set1      |
|  3 | char3            | varchar3 | text3   | enum2   | set2      |
|  4 | char4            | varchar4 | text4   | enum3   | set3,set4 |
|  6 | qr-old5          | qr-old5  | qr-old5 | NULL    | NULL      |
|  7 | qr-6             | qr-6     | qr-6    | NULL    | NULL      |
|  8 | 2                | 4        | 6       | NULL    | NULL      |
|  9 | 语句             | 字段     | 不同    | 枚举    | NULL      |
| 10 | 插入             | 全部     | 字段    | 枚举    | 集合      |
+----+------------------+----------+---------+---------+-----------+
