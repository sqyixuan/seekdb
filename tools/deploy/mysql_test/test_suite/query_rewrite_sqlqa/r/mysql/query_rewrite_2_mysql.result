#### enabled 
## 参数省略
call dbms_udr.create_rule(
  'rule_name1',
  'whh1',
  'select ?,? from dual', 
  'select ?+1,?+2 from dual');
select 1,2 from dual;
+-----+-----+
| ?+1 | ?+2 |
+-----+-----+
|   2 |   4 |
+-----+-----+
call dbms_udr.remove_rule ('rule_name1');
## 字符类型字面量
call dbms_udr.create_rule(
  'rule_name8',
  'whh1',
  'select ? from dual', 
  'select ? + 10 from dual',
  '1');
ERROR HY000: Invalid argument
call dbms_udr.create_rule(
  'rule_name9',
  'whh1',
  'select ? from dual', 
  'select ? + 20 from dual',
  '0');
