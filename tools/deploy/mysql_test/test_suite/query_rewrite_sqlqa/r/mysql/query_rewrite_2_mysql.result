call dbms_udr.remove_rule ('rule6');
call dbms_udr.create_rule('rule6','whh1','update t4 set c1_tint = :A order by id desc limit :B', 'update t4 set c1_tint = :A + 10,c2_vcha="query rewrite2" order by id desc limit :B','YES');
