|  5 |      41 | 52               |
|  5 |      50 | mysql            |
|  7 |      70 | table t4         |
|  8 |       3 | 3                |
|  8 |       4 | NULL             |
|  8 |      81 | 82               |
| 11 |      21 | query rewrite2   |
| 12 |     110 | insert-->update2 |
| 13 |     120 | insert-->update3 |
| 21 |      20 | NULL             |
| 33 |     120 | insert-->insert3 |
