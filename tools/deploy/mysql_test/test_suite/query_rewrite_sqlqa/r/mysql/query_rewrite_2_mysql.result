  'rule_name11',
  'whh1',
  'select ? from dual', 
  'select ? + 40 from dual',
  'y');
ERROR HY000: Invalid argument
call dbms_udr.create_rule(
  'rule_name12',
  'whh1',
  'select ? from dual', 
  'select ? + 40 from dual',
  'ok');
ERROR HY000: Invalid argument
# 'YE'||'S'，'y'||'e'||'s'，'n'||'o'
call dbms_udr.create_rule(
  'rule_name19',
