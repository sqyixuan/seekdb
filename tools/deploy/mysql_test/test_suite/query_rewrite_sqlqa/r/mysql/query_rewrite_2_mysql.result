  'rule_name18',
  'whh1',
  'select ? from dual', 
  'select ? * 4 from dual',
  rpad('yes',256,' '));
ERROR HY000: Invalid argument
call dbms_udr.create_rule(
  'rule_name18',
  'whh1',
  'select ? from dual', 
  'select ? * 4 from dual',
  rpad('yes',257,' '));
