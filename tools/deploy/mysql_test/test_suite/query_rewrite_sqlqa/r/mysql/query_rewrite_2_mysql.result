ERROR 01000: Truncated incorrect DOUBLE value
call dbms_udr.create_rule(
  'rule_name20',
  'whh1',
  'select ? from dual', 
  'select ? * 5 from dual', 
  'y'||'e'||'s');
ERROR 01000: Truncated incorrect DOUBLE value
call dbms_udr.create_rule(
  'rule_name20',
  'whh1',
  'select ? from dual', 
  'select ? * 6 from dual', 
  'n'||'o');
ERROR 01000: Truncated incorrect DOUBLE value
# 'YES','Yes','yes','NO','No','no'
call dbms_udr.create_rule(
  'rule_name13',
  'whh1',
  'select ? from dual', 
  'select ? + 50 from dual',
  'YES');
select 1 from dual;
+--------+
| ? + 50 |
+--------+
|     51 |
+--------+
call dbms_udr.remove_rule ('rule_name13');
call dbms_udr.create_rule(
  'rule_name14',
  'whh1',
  'select ? from dual', 
  'select ? + 60 from dual',
  'Yes');
select 2 from dual;
+--------+
| ? + 60 |
+--------+
|     62 |
+--------+
call dbms_udr.remove_rule ('rule_name14');
call dbms_udr.create_rule(
  'rule_name15',
  'whh1',
  'select ? from dual', 
  'select ? + 70 from dual',
  'yes');
select 3 from dual;
+--------+
| ? + 70 |
+--------+
|     73 |
+--------+
call dbms_udr.remove_rule ('rule_name15');
call dbms_udr.create_rule(
  'rule_name16',
  'whh1',
  'select ? from dual', 
  'select ? * 2 from dual',
  'NO');
select 1 from dual;
+---+
| 1 |
+---+
| 1 |
+---+
call dbms_udr.enable_rule ('rule_name16');
select 1 from dual;
+-------+
| ? * 2 |
+-------+
|     2 |
+-------+
call dbms_udr.remove_rule ('rule_name16');
call dbms_udr.create_rule(
  'rule_name17',
  'whh1',
  'select ? from dual', 
  'select ?  * 3 from dual',
  'No');
select 2 from dual;
+---+
| 2 |
+---+
| 2 |
+---+
call dbms_udr.enable_rule ('rule_name17');
select 2 from dual;
+--------+
| ?  * 3 |
+--------+
|      6 |
+--------+
call dbms_udr.remove_rule ('rule_name17');
call dbms_udr.create_rule(
  'rule_name18',
  'whh1',
  'select ? from dual', 
  'select ? * 4 from dual',
  'no');
select 3 from dual;
+---+
| 3 |
+---+
| 3 |
+---+
call dbms_udr.enable_rule ('rule_name18');
select 3 from dual;
+-------+
| ? * 4 |
+-------+
|    12 |
+-------+
call dbms_udr.remove_rule ('rule_name18');
# 一段超长字符串字面量
call dbms_udr.create_rule(
  'rule_name18',
  'whh1',
  'select ? from dual', 
  'select ? * 4 from dual',
  rpad('yes',255,' '));
ERROR HY000: Invalid argument
