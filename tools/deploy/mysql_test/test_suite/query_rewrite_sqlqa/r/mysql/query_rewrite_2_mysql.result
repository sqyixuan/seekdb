|  1 |      11 |     100 |      13 |      14 |    15.1 |    16.5 |      17 |
|  2 |      21 |     300 |      23 |      24 |    25.1 |    26.5 |      27 |
|  3 |     100 |     100 |     400 |      34 |    35.1 |    36.5 |      37 |
|  5 |      41 |     200 |      53 |      54 |    55.1 |    56.5 |      57 |
+----+---------+---------+---------+---------+---------+---------+---------+
call dbms_udr.remove_rule ('rule5');
