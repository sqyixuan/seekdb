######## 标签：qr-mysql-5-7 重写功能关闭
alter system set enable_user_defined_rewrite_rules = 'ON';
call dbms_udr.create_rule('rule1','whh1','select ?', 'select ? + 10','YES');
select db_name,rule_name,pattern,replacement,normalized_pattern,status from oceanbase.DBA_OB_USER_DEFINED_RULES where db_name = 'WHH1';
+---------+-----------+----------+---------------+--------------------+--------+
| db_name | rule_name | pattern  | replacement   | normalized_pattern | status |
+---------+-----------+----------+---------------+--------------------+--------+
| whh1    | rule1     | select ? | select ? + 10 | select ?           | ENABLE |
+---------+-----------+----------+---------------+--------------------+--------+
select 10;
+--------+
| ? + 10 |
+--------+
|     20 |
+--------+
call dbms_udr.create_rule('rule2','whh1','select :A,:B', 'select :A+:B','YES');
select db_name,rule_name,pattern,replacement,normalized_pattern,status from oceanbase.DBA_OB_USER_DEFINED_RULES where db_name = 'WHH1';
+---------+-----------+--------------+---------------+--------------------+--------+
| db_name | rule_name | pattern      | replacement   | normalized_pattern | status |
+---------+-----------+--------------+---------------+--------------------+--------+
| whh1    | rule1     | select ?     | select ? + 10 | select ?           | ENABLE |
| whh1    | rule2     | select :A,:B | select :A+:B  | select ?,?         | ENABLE |
+---------+-----------+--------------+---------------+--------------------+--------+
select 10,20;
+-------+
| :A+:B |
+-------+
|    30 |
+-------+
# 重写功能关闭
alter system set enable_user_defined_rewrite_rules = 'OFF';
select 10;
+----+
| 10 |
+----+
| 10 |
+----+
call dbms_udr.remove_rule ('rule1');
select 10,20;
+----+----+
| 10 | 20 |
+----+----+
| 10 | 20 |
+----+----+
call dbms_udr.remove_rule ('rule2');
# Clean up users
drop user whh@'%';
drop database whh1;
