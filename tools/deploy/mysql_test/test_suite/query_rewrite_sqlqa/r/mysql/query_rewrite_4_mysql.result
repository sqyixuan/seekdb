|  3 |      31 |      32 |      33 |      34 |    35.1 |    36.5 |      37 |
|  2 |      21 |      22 |      23 |      24 |    25.1 |    26.5 |      27 |
+----+---------+---------+---------+---------+---------+---------+---------+
select fun_disable('rulename1');
+--------------------------+
| fun_disable('rulename1') |
+--------------------------+
| >>>>disable_rule ok      |
+--------------------------+
select * from t2 where id = 1;
+----+---------+---------+---------+---------+---------+---------+---------+
| id | c1_tint | c2_sint | c3_mint | c4_bint | c5_floa | c6_doub | c7_deci |
+----+---------+---------+---------+---------+---------+---------+---------+
|  1 |      11 |      12 |      13 |      14 |    15.1 |    16.5 |      17 |
+----+---------+---------+---------+---------+---------+---------+---------+
