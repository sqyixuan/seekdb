######## 标签：qr-mysql-5-5 重写的使用场景
#### 自定义函数中
## 在自定义函数中调用创建/删除/修改重写规则方法
drop function fun_create;$$
create function fun_create() returns varchar(20) NO SQL
begin
  call dbms_udr.create_rule('rulename0','whh1','select :A,:B', 'select pow(:A,:B)','YES');
  return '>>>>create_rule ok';
end;
$$
drop function fun_remove;$$
create function fun_remove() returns varchar(20) NO SQL
begin
  call dbms_udr.remove_rule ('rulename0');
  return '>>>>remove_rule ok';
end;
$$
drop function fun_enable;$$
create function fun_enable() returns varchar(20) NO SQL
begin
  call dbms_udr.enable_rule ('rulename0');
  return '>>>>enable_rule ok';
end;
$$
drop function fun_disable;$$
create function fun_disable() returns varchar(20) NO SQL
begin
  call dbms_udr.disable_rule ('rulename0');
  return '>>>>disable_rule ok';
end;
$$
select fun_create();
+--------------------+
| fun_create()       |
+--------------------+
| >>>>create_rule ok |
+--------------------+
select 10,2;
+------------+
| pow(:A,:B) |
+------------+
|        100 |
+------------+
select fun_disable();
+---------------------+
| fun_disable()       |
+---------------------+
| >>>>disable_rule ok |
+---------------------+
select 10,2;
+----+---+
| 10 | 2 |
+----+---+
| 10 | 2 |
+----+---+
select fun_enable();
+--------------------+
| fun_enable()       |
+--------------------+
| >>>>enable_rule ok |
+--------------------+
select 10,2;
+------------+
| pow(:A,:B) |
+------------+
|        100 |
+------------+
select fun_remove();
+--------------------+
| fun_remove()       |
+--------------------+
| >>>>remove_rule ok |
+--------------------+
select 10,2;
+----+---+
| 10 | 2 |
+----+---+
| 10 | 2 |
+----+---+
## 创建/删除/修改重写规则方法的参数是自定义函数形参
drop function fun_create;$$
create function fun_create(name varchar(256),owner varchar(128),sql1 longtext,sql2 longtext,enabled varchar(128)) returns varchar(20) NO SQL
begin
  call dbms_udr.create_rule(name,owner,sql1,sql2,enabled);
  return '>>>>create_rule ok';
end;
$$
drop function fun_remove;$$
create function fun_remove(name varchar(256)) returns varchar(20) NO SQL
begin
  call dbms_udr.remove_rule(name);
  return '>>>>remove_rule ok';
end;
$$
drop function fun_enable;$$
create function fun_enable(name varchar(256)) returns varchar(20) NO SQL
begin
  call dbms_udr.enable_rule(name);
  return '>>>>enable_rule ok';
end;
$$
drop function fun_disable;$$
create function fun_disable(name varchar(256)) returns varchar(20) NO SQL
begin
  call dbms_udr.disable_rule(name);
  return '>>>>disable_rule ok';
end;
$$
select fun_create('rulename1','whh1','select * from t2 where id = ?', 'select * from t2 where id > ? order by id desc','YES');
+------------------------------------------------------------------------------------------------------------------------+
| fun_create('rulename1','whh1','select * from t2 where id = ?', 'select * from t2 where id > ? order by id desc','YES') |
+------------------------------------------------------------------------------------------------------------------------+
| >>>>create_rule ok                                                                                                     |
+------------------------------------------------------------------------------------------------------------------------+
select * from t2 where id = 1;
+----+---------+---------+---------+---------+---------+---------+---------+
