| WANG |
+------+
call dbms_udr.enable_rule ('rulename3\r');
select 'WANG';
+----------+
| lower(?) |
+----------+
| wang     |
+----------+
call dbms_udr.remove_rule ('rulename3\r');
call dbms_udr.create_rule('rulename4
name','whh1','select :A', 'select upper(:A)','YES');
select 'query rewrite';
+---------------+
| upper(:A)     |
+---------------+
| QUERY REWRITE |
+---------------+
call dbms_udr.disable_rule ('rulename4
name');
select 'query rewrite';
+---------------+
| query rewrite |
+---------------+
| query rewrite |
+---------------+
call dbms_udr.enable_rule ('rulename4
name');
select 'query rewrite';
+---------------+
| upper(:A)     |
+---------------+
| QUERY REWRITE |
+---------------+
call dbms_udr.remove_rule ('rulename4
name');
# 修改规则时所需的参数用用户自定义变量传入
set @name='rule_name4';
call dbms_udr.create_rule(@name,'whh1','select ?','select ? + 3','YES');
select 2;
+-------+
| ? + 3 |
+-------+
|     5 |
+-------+
call dbms_udr.disable_rule (@name);
select 2;
+---+
| 2 |
+---+
| 2 |
+---+
call dbms_udr.enable_rule (@name);
select 2;
+-------+
| ? + 3 |
+-------+
|     5 |
+-------+
call dbms_udr.remove_rule (@name);
#### 修改规则时所需的参数用内置函数返回结果传入 
call dbms_udr.create_rule(upper('rule_name5'),lower('whh1'),concat('select ? ','from dual'),concat('select ?*2 ','from dual'),'YES');
select 2 from dual;
+-----+
| ?*2 |
+-----+
|   4 |
+-----+
call dbms_udr.disable_rule (upper('rule_name5'));
select 2 from dual;
+---+
| 2 |
+---+
| 2 |
+---+
call dbms_udr.enable_rule (upper('rule_name5'));
select 2 from dual;
+-----+
| ?*2 |
+-----+
|   4 |
+-----+
call dbms_udr.remove_rule (upper('rule_name5'));
#### 修改规则时所需的参数用function函数返回结果传入
drop function fun1;$$
create function fun1 (par int) returns varchar(20) NO SQL
begin
  if par = 1 then
    return 'rule_name1';
  elseif  par = 2 then
    return 'whh1';
  elseif  par = 3 then
    return 'select ? from dual';
  elseif  par = 4 then
    return 'select ?*2 from dual';
  else
    return '0';
  end if;
end;
$$
call dbms_udr.create_rule(fun1(1),fun1(2),fun1(3),fun1(4),'YES');
select 2 from dual;
+-----+
| ?*2 |
+-----+
|   4 |
+-----+
call dbms_udr.disable_rule (fun1(1));
select 2 from dual;
+---+
| 2 |
+---+
| 2 |
+---+
call dbms_udr.enable_rule (fun1(1));
select 2 from dual;
+-----+
| ?*2 |
+-----+
|   4 |
+-----+
call dbms_udr.remove_rule (fun1(1));
# 修改租户级配置项,重写功能关闭
alter system set enable_user_defined_rewrite_rules = 'OFF';
# Clean up users
drop user whh@'%';
drop database whh1;
