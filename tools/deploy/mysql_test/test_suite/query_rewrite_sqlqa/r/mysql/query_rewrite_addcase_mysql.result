######## qr-mysql-7-2 相同 pattern 不同 replacement
## 禁用最先创建的规则后是否第二时间创建的规则被启用，查看视图及sql_audit
call dbms_udr.remove_rule ('rule11');
call dbms_udr.remove_rule ('rule12');
call dbms_udr.remove_rule ('rule13');
call dbms_udr.create_rule(
  'rule11',
  'whh1',
  'select :A,:B,0 from dual', 
  'select :A+1,:B+1,1,"rule11" from dual',
  'YES');
call dbms_udr.create_rule(
  'rule12',
  'whh1',
  'select :A,:B,0 from dual', 
  'select :A*2,:B*2,2,"rule12" from dual',
  'YES');
call dbms_udr.create_rule(
  'rule13',
  'whh1',
  'select :A,:B,0 from dual', 
  'select :A*3,:B*3,3,"rule13" from dual',
  'YES');
SELECT DB_NAME,RULE_NAME,PATTERN,REPLACEMENT,NORMALIZED_PATTERN,STATUS FROM OCEANBASE.DBA_OB_USER_DEFINED_RULES;
+---------+-----------+--------------------------+---------------------------------------+------------------------+--------+
| DB_NAME | RULE_NAME | PATTERN                  | REPLACEMENT                           | NORMALIZED_PATTERN     | STATUS |
+---------+-----------+--------------------------+---------------------------------------+------------------------+--------+
| whh1    | rule11    | select :A,:B,0 from dual | select :A+1,:B+1,1,"rule11" from dual | select ?,?,? from dual | ENABLE |
| whh1    | rule12    | select :A,:B,0 from dual | select :A*2,:B*2,2,"rule12" from dual | select ?,?,? from dual | ENABLE |
| whh1    | rule13    | select :A,:B,0 from dual | select :A*3,:B*3,3,"rule13" from dual | select ?,?,? from dual | ENABLE |
+---------+-----------+--------------------------+---------------------------------------+------------------------+--------+
select 10,20,0 from dual;
+------+------+---+--------+
| :A+1 | :B+1 | 1 | rule11 |
+------+------+---+--------+
|   11 |   21 | 1 | rule11 |
+------+------+---+--------+
call dbms_udr.disable_rule('rule11');
SELECT DB_NAME,RULE_NAME,PATTERN,REPLACEMENT,NORMALIZED_PATTERN,STATUS FROM OCEANBASE.DBA_OB_USER_DEFINED_RULES;
+---------+-----------+--------------------------+---------------------------------------+------------------------+---------+
| DB_NAME | RULE_NAME | PATTERN                  | REPLACEMENT                           | NORMALIZED_PATTERN     | STATUS  |
+---------+-----------+--------------------------+---------------------------------------+------------------------+---------+
| whh1    | rule11    | select :A,:B,0 from dual | select :A+1,:B+1,1,"rule11" from dual | select ?,?,? from dual | DISABLE |
| whh1    | rule12    | select :A,:B,0 from dual | select :A*2,:B*2,2,"rule12" from dual | select ?,?,? from dual | ENABLE  |
| whh1    | rule13    | select :A,:B,0 from dual | select :A*3,:B*3,3,"rule13" from dual | select ?,?,? from dual | ENABLE  |
+---------+-----------+--------------------------+---------------------------------------+------------------------+---------+
select 10,20,0 from dual;
+------+------+---+--------+
| :A*2 | :B*2 | 2 | rule12 |
+------+------+---+--------+
|   20 |   40 | 2 | rule12 |
+------+------+---+--------+
call dbms_udr.disable_rule('rule12');
SELECT DB_NAME,RULE_NAME,PATTERN,REPLACEMENT,NORMALIZED_PATTERN,STATUS FROM OCEANBASE.DBA_OB_USER_DEFINED_RULES;
+---------+-----------+--------------------------+---------------------------------------+------------------------+---------+
| DB_NAME | RULE_NAME | PATTERN                  | REPLACEMENT                           | NORMALIZED_PATTERN     | STATUS  |
+---------+-----------+--------------------------+---------------------------------------+------------------------+---------+
| whh1    | rule11    | select :A,:B,0 from dual | select :A+1,:B+1,1,"rule11" from dual | select ?,?,? from dual | DISABLE |
| whh1    | rule12    | select :A,:B,0 from dual | select :A*2,:B*2,2,"rule12" from dual | select ?,?,? from dual | DISABLE |
| whh1    | rule13    | select :A,:B,0 from dual | select :A*3,:B*3,3,"rule13" from dual | select ?,?,? from dual | ENABLE  |
+---------+-----------+--------------------------+---------------------------------------+------------------------+---------+
select 10,20,0 from dual;
+------+------+---+--------+
| :A*3 | :B*3 | 3 | rule13 |
+------+------+---+--------+
|   30 |   60 | 3 | rule13 |
+------+------+---+--------+
call dbms_udr.disable_rule('rule13');
SELECT DB_NAME,RULE_NAME,PATTERN,REPLACEMENT,NORMALIZED_PATTERN,STATUS FROM OCEANBASE.DBA_OB_USER_DEFINED_RULES;
+---------+-----------+--------------------------+---------------------------------------+------------------------+---------+
| DB_NAME | RULE_NAME | PATTERN                  | REPLACEMENT                           | NORMALIZED_PATTERN     | STATUS  |
+---------+-----------+--------------------------+---------------------------------------+------------------------+---------+
| whh1    | rule11    | select :A,:B,0 from dual | select :A+1,:B+1,1,"rule11" from dual | select ?,?,? from dual | DISABLE |
| whh1    | rule12    | select :A,:B,0 from dual | select :A*2,:B*2,2,"rule12" from dual | select ?,?,? from dual | DISABLE |
| whh1    | rule13    | select :A,:B,0 from dual | select :A*3,:B*3,3,"rule13" from dual | select ?,?,? from dual | DISABLE |
