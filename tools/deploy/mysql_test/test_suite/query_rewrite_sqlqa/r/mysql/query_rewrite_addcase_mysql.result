purge recyclebin;
result_format: 4
########## 处理测试环境 ##########
drop user whh@'%';
drop database whh1;
create user whh identified by 'whh';
create database whh1;
grant all on *.* to whh with grant option;


# 修改租户级配置项,重写功能开启
alter system set enable_user_defined_rewrite_rules = 'ON';
set @@sql_mode='strict_all_tables';
>>>>>>>>>>>>>>>>>>>>>>>>>>> qr-mysql-7 补充功能测试 <<<<<<<<<<<<<<<<<<<<<<<<<
######## qr-mysql-7-1 相同 pattern 相同replacement
## 禁用最先创建的规则后是否第二时间创建的规则被启用，查看视图及sql_audit
call dbms_udr.remove_rule ('rule1');
call dbms_udr.remove_rule ('rule2');
call dbms_udr.remove_rule ('rule3');
call dbms_udr.create_rule(
  'rule1',
  'whh1',
  'select :A,:B from dual', 
  'select :A*2,:B*2 from dual',
  'YES');
call dbms_udr.create_rule(
  'rule2',
  'whh1',
  'select :A,:B from dual', 
  'select :A*2,:B*2 from dual',
  'YES');
call dbms_udr.create_rule(
  'rule3',
  'whh1',
  'select :A,:B from dual', 
  'select :A*2,:B*2 from dual',
  'YES');
SELECT DB_NAME,RULE_NAME,PATTERN,REPLACEMENT,NORMALIZED_PATTERN,STATUS FROM OCEANBASE.DBA_OB_USER_DEFINED_RULES;
+---------+-----------+------------------------+----------------------------+----------------------+--------+
| DB_NAME | RULE_NAME | PATTERN                | REPLACEMENT                | NORMALIZED_PATTERN   | STATUS |
+---------+-----------+------------------------+----------------------------+----------------------+--------+
| whh1    | rule1     | select :A,:B from dual | select :A*2,:B*2 from dual | select ?,? from dual | ENABLE |
| whh1    | rule2     | select :A,:B from dual | select :A*2,:B*2 from dual | select ?,? from dual | ENABLE |
| whh1    | rule3     | select :A,:B from dual | select :A*2,:B*2 from dual | select ?,? from dual | ENABLE |
+---------+-----------+------------------------+----------------------------+----------------------+--------+
select 10,20 from dual;
+------+------+
| :A*2 | :B*2 |
+------+------+
|   20 |   40 |
+------+------+
call dbms_udr.disable_rule('rule1');
SELECT DB_NAME,RULE_NAME,PATTERN,REPLACEMENT,NORMALIZED_PATTERN,STATUS FROM OCEANBASE.DBA_OB_USER_DEFINED_RULES;
+---------+-----------+------------------------+----------------------------+----------------------+---------+
| DB_NAME | RULE_NAME | PATTERN                | REPLACEMENT                | NORMALIZED_PATTERN   | STATUS  |
+---------+-----------+------------------------+----------------------------+----------------------+---------+
| whh1    | rule1     | select :A,:B from dual | select :A*2,:B*2 from dual | select ?,? from dual | DISABLE |
| whh1    | rule2     | select :A,:B from dual | select :A*2,:B*2 from dual | select ?,? from dual | ENABLE  |
| whh1    | rule3     | select :A,:B from dual | select :A*2,:B*2 from dual | select ?,? from dual | ENABLE  |
+---------+-----------+------------------------+----------------------------+----------------------+---------+
select 10,20 from dual;
+------+------+
| :A*2 | :B*2 |
+------+------+
|   20 |   40 |
+------+------+
call dbms_udr.disable_rule('rule2');
SELECT DB_NAME,RULE_NAME,PATTERN,REPLACEMENT,NORMALIZED_PATTERN,STATUS FROM OCEANBASE.DBA_OB_USER_DEFINED_RULES;
+---------+-----------+------------------------+----------------------------+----------------------+---------+
| DB_NAME | RULE_NAME | PATTERN                | REPLACEMENT                | NORMALIZED_PATTERN   | STATUS  |
+---------+-----------+------------------------+----------------------------+----------------------+---------+
| whh1    | rule1     | select :A,:B from dual | select :A*2,:B*2 from dual | select ?,? from dual | DISABLE |
| whh1    | rule2     | select :A,:B from dual | select :A*2,:B*2 from dual | select ?,? from dual | DISABLE |
| whh1    | rule3     | select :A,:B from dual | select :A*2,:B*2 from dual | select ?,? from dual | ENABLE  |
+---------+-----------+------------------------+----------------------------+----------------------+---------+
select 10,20 from dual;
+------+------+
| :A*2 | :B*2 |
+------+------+
|   20 |   40 |
+------+------+
