#### qr-mysql-7-4 不同pattern不同replacement
## 观察启用，禁用，删除，添加的表现，查看视图及sql_audit
call dbms_udr.remove_rule ('rule31');
call dbms_udr.remove_rule ('rule32');
call dbms_udr.remove_rule ('rule33');
call dbms_udr.create_rule(
  'rule31',
  'whh1',
  'select :A,:B,31 from dual', 
  'select :A+:B+1 from dual',
  'YES');
call dbms_udr.create_rule(
  'rule32',
  'whh1',
  'select :A,:B,32 from dual', 
  'select :A+:B+2 from dual',
  'YES');
call dbms_udr.create_rule(
  'rule33',
  'whh1',
  'select :A,:B,33 from dual', 
  'select :A+:B+3 from dual',
  'YES');
SELECT DB_NAME,RULE_NAME,PATTERN,REPLACEMENT,NORMALIZED_PATTERN,STATUS FROM OCEANBASE.DBA_OB_USER_DEFINED_RULES;
+---------+-----------+---------------------------+--------------------------+------------------------+--------+
| DB_NAME | RULE_NAME | PATTERN                   | REPLACEMENT              | NORMALIZED_PATTERN     | STATUS |
+---------+-----------+---------------------------+--------------------------+------------------------+--------+
| whh1    | rule31    | select :A,:B,31 from dual | select :A+:B+1 from dual | select ?,?,? from dual | ENABLE |
| whh1    | rule32    | select :A,:B,32 from dual | select :A+:B+2 from dual | select ?,?,? from dual | ENABLE |
| whh1    | rule33    | select :A,:B,33 from dual | select :A+:B+3 from dual | select ?,?,? from dual | ENABLE |
+---------+-----------+---------------------------+--------------------------+------------------------+--------+
select 10,20,31 from dual;
+---------+
| :A+:B+1 |
+---------+
|      31 |
+---------+
select 10,20,32 from dual;
+---------+
| :A+:B+2 |
+---------+
|      32 |
+---------+
select 10,20,33 from dual;
+---------+
| :A+:B+3 |
+---------+
|      33 |
+---------+
