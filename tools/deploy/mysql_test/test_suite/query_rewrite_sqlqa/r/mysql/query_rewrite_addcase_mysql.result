######## qr-mysql-7-3 不同 pattern 相同 replacement
## 禁用最先创建的规则后是否第二时间创建的规则被启用，查看视图及sql_audit
call dbms_udr.remove_rule ('rule21');
call dbms_udr.remove_rule ('rule22');
call dbms_udr.remove_rule ('rule23');
call dbms_udr.create_rule(
  'rule21',
  'whh1',
  'select :A,:B,1 from dual', 
  'select :A * :B from dual',
  'YES');
call dbms_udr.create_rule(
  'rule22',
  'whh1',
  'select :A,:B,2 from dual', 
  'select :A * :B from dual',
  'YES');
call dbms_udr.create_rule(
  'rule23',
  'whh1',
  'select :A,:B,3 from dual', 
  'select :A * :B from dual',
  'YES');
SELECT DB_NAME,RULE_NAME,PATTERN,REPLACEMENT,NORMALIZED_PATTERN,STATUS FROM OCEANBASE.DBA_OB_USER_DEFINED_RULES;
+---------+-----------+--------------------------+--------------------------+------------------------+--------+
| DB_NAME | RULE_NAME | PATTERN                  | REPLACEMENT              | NORMALIZED_PATTERN     | STATUS |
+---------+-----------+--------------------------+--------------------------+------------------------+--------+
| whh1    | rule21    | select :A,:B,1 from dual | select :A * :B from dual | select ?,?,? from dual | ENABLE |
| whh1    | rule22    | select :A,:B,2 from dual | select :A * :B from dual | select ?,?,? from dual | ENABLE |
| whh1    | rule23    | select :A,:B,3 from dual | select :A * :B from dual | select ?,?,? from dual | ENABLE |
+---------+-----------+--------------------------+--------------------------+------------------------+--------+
select 10,20,1 from dual;
+---------+
| :A * :B |
+---------+
|     200 |
+---------+
select 10,20,2 from dual;
+---------+
| :A * :B |
+---------+
|     200 |
+---------+
select 10,20,3 from dual;
+---------+
| :A * :B |
+---------+
|     200 |
+---------+
call dbms_udr.disable_rule('rule21');
SELECT DB_NAME,RULE_NAME,PATTERN,REPLACEMENT,NORMALIZED_PATTERN,STATUS FROM OCEANBASE.DBA_OB_USER_DEFINED_RULES;
+---------+-----------+--------------------------+--------------------------+------------------------+---------+
| DB_NAME | RULE_NAME | PATTERN                  | REPLACEMENT              | NORMALIZED_PATTERN     | STATUS  |
+---------+-----------+--------------------------+--------------------------+------------------------+---------+
| whh1    | rule21    | select :A,:B,1 from dual | select :A * :B from dual | select ?,?,? from dual | DISABLE |
| whh1    | rule22    | select :A,:B,2 from dual | select :A * :B from dual | select ?,?,? from dual | ENABLE  |
| whh1    | rule23    | select :A,:B,3 from dual | select :A * :B from dual | select ?,?,? from dual | ENABLE  |
+---------+-----------+--------------------------+--------------------------+------------------------+---------+
select 10,20,1 from dual;
+----+----+---+
| 10 | 20 | 1 |
+----+----+---+
| 10 | 20 | 1 |
+----+----+---+
select 10,20,2 from dual;
+---------+
| :A * :B |
+---------+
|     200 |
+---------+
select 10,20,3 from dual;
+---------+
| :A * :B |
+---------+
|     200 |
+---------+
