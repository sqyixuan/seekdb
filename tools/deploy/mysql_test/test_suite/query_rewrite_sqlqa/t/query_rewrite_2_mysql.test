# owner: luofan.zp
# owner group: sql-sql2
# description: Query Rewrite - Mysql模式
# tags: ddl,dml,pl
# author: whh01047778


purge recyclebin;
--result_format 4

--echo ########## 处理测试环境 ##########
--disable_warnings
--error 0,1396
drop user whh@'%';
--error 0,1008
drop database whh1;
--enable_warnings

create user whh identified by 'whh';
create database whh1;
grant all on *.* to whh with grant option;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$obmysql_ms0,whh,whh,whh1,$obmysql_port);

--echo # 修改租户级配置项,重写功能开启
alter system set enable_user_defined_rewrite_rules = 'ON';
sleep 5;
set @@sql_mode='strict_all_tables';

--source mysql_test/test_suite/query_rewrite_sqlqa/t/create_table.inc

--echo #### pattern，replacement(参数标记个数，参数标记位置,语句模板)
--echo ######## 标签：qr-mysql-3-1 1、SELECT语句
--echo ## 视图
call dbms_udr.create_rule('rule0','whh1','select * from v1 where id = ?', 'select * from v1 where id > ? order by id desc','YES');
select * from v1 where id = 2;
select * from v1 where id = 1+1;
select * from v1 where id = 2 and c1_tint> 10;
select * from v1 where id = 2 order by id;
select id,c1_tint,c2_sint from v1 where id = 2;
call dbms_udr.remove_rule ('rule0');

call dbms_udr.create_rule('rule1','whh1','select * from v1 where c1_tint between :A and :B', 'select * from v1 where c1_tint between :A and :A+:B order by id desc','YES');
select * from v1 where c1_tint between 11 and 21;
select * from v1 where c1_tint between 11 and 1+21 order by id;
select * from v1 where c1_tint between 11 and 21 or c2_sint > 10 order by id;
select * from v1 where c1_tint between 11 and 21 order by id;
select id,c1_tint,c2_sint from v1 where c1_tint between 11 and 21;
call dbms_udr.remove_rule ('rule1');


--echo #### SELECT ... INTO 语句
call dbms_udr.create_rule('rule2','whh1','select :A into @p from dual', 'select concat("query rewrite-",:A) into @p from dual','YES');
select 'whh1' into @p from dual;
select @p;
select 'whh1' into @p1 from dual;
select @p1;
call dbms_udr.remove_rule ('rule2');


--echo #### WHERE子句 (普通表达式)
call dbms_udr.create_rule('rule3','whh1','select * from t1 where id = ?', 'select "query rewrite",* from t1 where id >= ?  order by id desc limit 3','YES');
select * from t1 where id = 1;
select * from t1 where id = 1+1;
select * from t1 where id = 1 or c1_char is not NULL order by id;
select * from t1 where abs(id) = 1;
select c1_char from t1 where id = 1;
call dbms_udr.remove_rule ('rule3');

call dbms_udr.create_rule('rule4','whh1','select * from t1 where id in (?)', 'select "query rewrite",* from t1 where id in (?+1) order by id desc','YES');
select * from t1 where id in (1);
select * from t1 where id in (1+1);
select * from t1 where id in (1,2);
select * from t1 where abs(id) in (1);
select c1_char from t1 where id in (1);
call dbms_udr.remove_rule ('rule4');

call dbms_udr.create_rule('rule5','whh1','select c2_vcha from t1 where c2_vcha like ?', 'select "query rewrite",upper(c2_vcha) from t1 where c2_vcha like ? order by id desc','YES');
select c2_vcha from t1 where c2_vcha like '%var%';
select c2_vcha from t1 where c2_vcha like '%var%' limit 1;
select c2_vcha from t1 where left(c2_vcha,5) like '%var%' order by id;
select c2_vcha from t1 where c2_vcha like '%var%' or id > 2 order by id;
select * from t1 where c2_vcha like '%var%' order by id;
call dbms_udr.remove_rule ('rule5');

call dbms_udr.create_rule('rule6','whh1','select * from t1 where id > any (select ? from dual)', 'select "query rewrite",* from t1 where id > any (select ?+1 from dual) order by id desc','YES');
select * from t1 where id > any (select 1 from dual);
select * from t1 where id > any (select 1 from dual) order by id limit 2;
select * from t1 where id > any (select 1 from dual limit 1) order by id;
select c1_char from t1 where id > any (select 1 from dual) order by id;
call dbms_udr.remove_rule ('rule6');

call dbms_udr.create_rule('rule7','whh1','select * from t1 where exists (select * from t1 where id < ?)', 'select "query rewrite",* from t1 where not exists (select * from t1 where id < ? ) order by id desc','YES');
select * from t1 where exists (select * from t1 where id < 1);
select * from t1 where exists (select * from t1 where id < 1-1);
select * from t1 where exists (select * from t1 where id < 1 or c1_char is not null) order by id;
select * from t1 where exists (select * from t1 where id < 1) or c1_char is not null order by id;
call dbms_udr.remove_rule ('rule7');

call dbms_udr.create_rule('rule8','whh1','select * from t1 where id between :A and :B+1', 'select "query rewrite",* from t1 where id between :A and :B+2 order by id desc','YES');
select * from t1 where id between 1 and 1;
select * from t1 where id between 1 and 1+1;
select * from t1 where id between 1 and 1+1 order by id;
call dbms_udr.remove_rule ('rule8');

call dbms_udr.create_rule('rule9','whh1','select * from t2 where (c1_tint,c2_sint) in ((:A,:B))', 'select "query rewrite",* from t2 where (c1_tint,c2_sint) in ((:A,:B),(:A+10,:B+10)) order by id desc','YES');
select * from t2 where (c1_tint,c2_sint) in ((11,12));
select * from t2 where (c1_tint,c2_sint) in ((11,11+1));
select * from t2 where (c1_tint,c2_sint) in ((11,12)) and c1_tint is not null;
select * from t2 where c1_tint is not null and (c1_tint,c2_sint) in ((11,12));
call dbms_udr.remove_rule ('rule9');

--echo # <、<=、>、>=、=、!=、<>
call dbms_udr.create_rule('rule1','whh1','select id from t2 where id < ?', 'select * from t2 where id <= ?+2 order by id desc','YES');
select id from t2 where id < 2;
call dbms_udr.remove_rule ('rule1');

call dbms_udr.create_rule('rule2','whh1','select id from t2 where id <= ?', 'select * from t2 where id < ?-1 order by id desc','YES');
select id from t2 where id <= 3;
call dbms_udr.remove_rule ('rule2');

call dbms_udr.create_rule('rule3','whh1','select id from t2 where id > :a', 'select * from t2 where id >= :a*2 order by id desc','YES');
select id from t2 where id > 2;
call dbms_udr.remove_rule ('rule3');

call dbms_udr.create_rule('rule4','whh1','select id from t2 where id >= :a', 'select * from t2 where id > :a/2 order by id desc','YES');
select id from t2 where id >= 4;
call dbms_udr.remove_rule ('rule4');

call dbms_udr.create_rule('rule5','whh1','select id from t2 where c3_mint != :a', 'select * from t2 where c3_mint != :a+10 order by id desc','YES');
select id from t2 where c3_mint != 13;
select id from t2 where c3_mint != 33;
call dbms_udr.remove_rule ('rule5');

call dbms_udr.create_rule('rule6','whh1','select id from t2 where id <> :a', 'select * from t2 where id <> :a+1 order by id desc','YES');
select id from t2 where id <> 1;
call dbms_udr.remove_rule ('rule6');


--echo #### GROUP BY子句，HAVING子句
call dbms_udr.create_rule('rule10','whh1','select * from t2 group by c1_tint having c1_tint > ?', 'select "query rewrite",* from t2 group by c1_tint having count(c1_tint) >= ? order by id desc','YES');
select * from t2 group by c1_tint having c1_tint > 1;
select * from t2 group by c1_tint having c1_tint > 1 order by id desc;
select * from t2 group by c1_tint having c1_tint > 1 and c2_sint = 22;
call dbms_udr.remove_rule ('rule10');

--echo #### LIMIT子句
call dbms_udr.create_rule('rule11','whh1','select * from t3 limit ?', 'select "query rewrite",* from t3  order by id desc limit ?','YES');
select * from t3 limit 2;
select * from t3 limit 2,1;
select * from t3 order by id desc limit 2;
call dbms_udr.remove_rule ('rule11');

call dbms_udr.create_rule('rule11','whh1','select * from t3 limit ?,?', 'select "query rewrite",* from t3 order by id desc limit ?,?','YES');
select * from t3 limit 1;
select * from t3 limit 1,2;
select * from t3 order by id desc limit 1,2;
call dbms_udr.remove_rule ('rule11');

call dbms_udr.create_rule('rule11','whh1','select * from t3 limit :A,:B', 'select "query rewrite",* from t3  order by id desc limit :B,:A','YES');
select * from t3 limit 1,2;
select * from t3 order by id limit 1,2;
call dbms_udr.remove_rule ('rule11');


--echo #### JOIN 子句
call dbms_udr.create_rule('rule12','whh1','select * from t2 left join t4 on t2.id=t4.id where t2.id = ?', 'select * from t2 right join t4 on t2.id=t4.id where t4.id >= ? order by t2.id desc','YES');
select * from t2 left join t4 on t2.id=t4.id where t2.id = 2;
select * from t2 left join t4 on t2.id=t4.id where t2.id = 1+1;
select * from t2 left join t4 on t2.id=t4.id where t2.id = 2 order by t2.id;
call dbms_udr.remove_rule ('rule12');

call dbms_udr.create_rule('rule13','whh1','select * from t2 right join t4 on t2.id=t4.id where t4.id = ?', 'select * from t2 left join t4 on t2.id=t4.id where t2.id >= ? order by t2.id desc','YES');
select * from t2 right join t4 on t2.id=t4.id where t4.id = 1;
select * from t2 right join t4 on t2.id=t4.id where t4.id = 1+1;
select * from t2 right join t4 on t2.id=t4.id where t4.id = 2 order by t2.id desc;
select * from t2 right join t4 on t2.id=t4.id where t4.id = 2 and t2.c1_tint <> 20;
call dbms_udr.remove_rule ('rule13');

call dbms_udr.create_rule('rule14','whh1','select * from t2 inner join t4 on t2.id=t4.id where t2.id = ?', 'select * from t2 inner join t4 on t2.id=t4.id where t2.id >= ?+1 order by t2.id desc','YES');
select * from t2 inner join t4 on t2.id=t4.id where t2.id = 1;
select * from t2 inner join t4 on t2.id=t4.id where t2.id = 1+1;
select * from t2 inner join t4 on t2.id=t4.id where t2.id = 2 order by t2.id asc;
select * from t2 inner join t4 on t2.id=t4.id where t2.id = 2 and t2.c1_tint <> 20;
call dbms_udr.remove_rule ('rule14');


--echo #### UNION 子句
call dbms_udr.create_rule('rule16','whh1','(select * from t1 where id = :A) union (select * from t3 where id = :B)', '(select * from t1 where id > :A+:B order by id desc) union (select * from t3 where id > :B order by id desc)','YES');
(select * from t1 where id = 1) union (select * from t3 where id = 1);
(select * from t1 where id = 1) union (select * from t3 where id = 1) limit 2;
call dbms_udr.remove_rule ('rule16');


--echo #### INTERSECT 子句
call dbms_udr.create_rule('rule17','whh1','(select * from t4 where id = :A) intersect (select * from t5 where id = :B)', '(select * from t4 where id > :A) intersect (select * from t5 where id > :B+1 order by id desc)','YES');
(select * from t4 where id = 1) intersect (select * from t5 where id = 1);
(select * from t4 where id = 1) intersect (select * from t5 where id = 1) limit 2;
(select * from t4 where id = 1 limit 2) intersect (select * from t5 where id = 1 limit 2);
call dbms_udr.remove_rule ('rule17');


--echo #### EXCEPT  子句
call dbms_udr.create_rule('rule18','whh1','(select * from t4 where id > :A) except (select * from t5 where id > :B)', '(select * from t4 where id > :A order by id) intersect (select * from t5 where id > :B+1 order by id)','YES');
(select * from t4 where id > 1) except (select * from t5 where id > 1);
(select * from t4 where id > 1) except (select * from t5 where id > 1) limit 2;
(select * from t4 where id > 1 and id < 5) except (select * from t5 where id > 1 and id < 5);
(select * from t4 where id > 1 limit 2) except (select * from t5 where id > 1  limit 2);
call dbms_udr.remove_rule ('rule18');


--echo #### 带括号的查询表达式
call dbms_udr.create_rule('rule19','whh1','select * from t4 except (select * from t4 intersect select * from t5 where id > ? )', 'select * from t4 except (select * from t4 intersect select * from t5 where id > ?+1) order by id desc','YES');
select * from t4 except (select * from t4 intersect select * from t5 where id > 1);
select * from t4 except (select * from t4 intersect select * from t5 where id > 1+1);
select * from t4 except (select * from t4 intersect select * from t5 where id > 1 or c1_tint > 10);
call dbms_udr.remove_rule ('rule19');


--echo #### SELECT 子查询
call dbms_udr.create_rule('rule20','whh1','select * from t1 where id in (select id from t2 where c1_tint > ?)', 'select "query_rewrite",* from t1 where id in (select id from t2 where c1_tint > ?+10 limit 1) order by id desc','YES');
select * from t1 where id in (select id from t2 where c1_tint > 10);
select * from t1 where id in (select id from t2 where c1_tint > 10+1 limit 1);
select * from t1 where id in (select id from t2 where c1_tint >= 10 limit 1);
select * from t1 where id in (select id from t2 where c1_tint >= 10 and c2_sint > 20 limit 1);
call dbms_udr.remove_rule ('rule20');

call dbms_udr.create_rule('rule21','whh1','select * from t1 where id = any (select id from t2 where t1.id = t2.id and t2.c1_tint > ?)', 'select "query_rewrite",* from t1 where id = any (select id from t2 where t1.id = t2.id and t2.c1_tint > ?+10) order by id desc limit 2','YES');
select * from t1 where id = any (select id from t2 where t1.id = t2.id and t2.c1_tint > 10);
select * from t1 where id = any (select id from t2 where t1.id = t2.id and t2.c1_tint > 9-1) order by id;
select id,c1_char,c2_vcha  from t1 where id = any (select id from t2 where t1.id = t2.id and t2.c1_tint > 9);
call dbms_udr.remove_rule ('rule21');

call dbms_udr.create_rule('rule22','whh1','select * from t2 where id = (select id from t4 where c1_tint > :A limit 1) and c1_tint > :B', 'select "query_rewrite",* from t2 where id > (select id from t2 where c1_tint > :A+10 limit 1) and c1_tint > :B+10 order by id desc','YES');
select * from t2 where id = (select id from t4 where c1_tint > 20 limit 1) and c1_tint > 20;
select * from t2 where id = (select id from t4 where c1_tint > 19+1 limit 1) and c1_tint > 20;
call dbms_udr.remove_rule ('rule22');


--echo ######## 标签：qr-mysql-3-2 2、INSERT语句
--echo #### INSERT语句
call dbms_udr.create_rule('rule1','whh1','insert into t1 (id,c1_char,c2_vcha,c3_text) values(:A,:B,:C,:D)', 'insert into t1 (id,c1_char,c2_vcha,c3_text) values(:A + 1, concat("qr-",:B),concat("qr-",:C), concat("qr-",:D))','YES');
insert into t1 (id,c1_char,c2_vcha,c3_text) values(5,'old5','old5','old5');
insert into t1 (id,c1_char,c2_vcha,c3_text) values(6,6,6,6);
insert into t1 (id,c1_char,c2_vcha,c3_text) values(8,1+1,2+2,3+3);
insert into t1 (id,c1_char,c2_vcha,c3_text,c4_enum) values(9,'语句','字段','不同','枚举');
insert into t1 values(10,'插入','全部','字段','枚举','集合');
select * from t1 order by id;
call dbms_udr.remove_rule ('rule1');

call dbms_udr.create_rule('rule2','whh1','insert into t4 values(8,?,?)', 'insert into t5 values(8,?*10,?)','YES');
insert into t4 values(8,1,'t4表');
insert into t4 values(8,2,2);
insert into t4(id,c1_tint,c2_vcha) values(8,3,3);
insert into t4(id,c1_tint) values(8,4);
select * from t4 order by id;
select * from t5 order by id;
call dbms_udr.remove_rule ('rule2');


--echo #### INSERT INTO... SELECT 语句
call dbms_udr.create_rule('rule3','whh1','insert into t4 select id,c1_tint,c2_sint from t2 where id = ?', 'insert into t4 select c1_tint,c2_sint,c3_mint from t2 where id =  ?/2 order by id desc','YES');
insert into t4 select id,c1_tint,c2_sint from t2 where id = 2;
insert into t4 select id,c1_tint,c2_sint from t2 where id = 8 order by id;
insert into t4(id,c1_tint,c2_vcha) select id,c1_tint,c2_sint from t2 where id = 5;
select * from t2 order by id;
select * from t4 order by id;
call dbms_udr.remove_rule ('rule3');


--echo #### INSERT ... ON DUPLICATE KEY UPDATE 语句
call dbms_udr.create_rule('rule4','whh1','insert into t2(id,c1_tint,c2_sint) values(3,31,?) on duplicate key update c2_sint = c2_sint * ?', 'insert into t2(id,c1_tint,c2_sint) values(3,31,?) on duplicate key update c2_sint = c2_sint * ? *10','YES');
insert into t2(id,c1_tint,c2_sint) values(3,31,3) on duplicate key update c2_sint = c2_sint * 10;
insert into t2(id,c1_tint,c2_sint) values(3,31,4) on duplicate key update c2_sint = c2_sint * (2*2);
insert into t2 values(3,31,5,33,34,35.1,36.5,37.12) on duplicate key update c2_sint = c2_sint * 2;
select * from t2 order by id;
call dbms_udr.remove_rule ('rule4');


--echo ######## 标签：qr-mysql-3-3 3、REPLACE语句
call dbms_udr.create_rule('rule5','whh1','replace into t2 (id,c1_tint,c2_sint) values(3,31,:A)', 'replace into t2 (id,c1_tint,c2_sint) values(3,31,:A%3)','YES');
replace into t2 (id,c1_tint,c2_sint) values(3,31,100);
replace into t2 (id,c1_tint,c2_sint) values(3,30+1,100*2);
replace into t2 (id,c1_tint,c2_sint,c4_bint) values(3,31,300,34);
replace into t2 values(3,31,32,400,34,35.1,36.5,37.12);
select * from t2 order by id;
call dbms_udr.remove_rule ('rule5');


--echo ######## 标签：qr-mysql-3-4 4、UPDATE语句
call dbms_udr.create_rule('rule6','whh1','update t4 set c1_tint = :A where id = :B ', 'update t4 set c1_tint = :A * 10,c2_vcha="query rewrite1" where id = 1+:B','YES');
update t4 set c1_tint = 10 where id = 1;
update t4 set c1_tint = 20 where id = 3 limit 1;
select * from t4 order by id;
call dbms_udr.remove_rule ('rule6');

call dbms_udr.create_rule('rule6','whh1','update t4 set c1_tint = :A order by id desc limit :B', 'update t4 set c1_tint = :A + 10,c2_vcha="query rewrite2" order by id desc limit :B','YES');
update t4 set c1_tint = 11 order by id desc limit 1;
update t4 set c1_tint = 22 order by id limit 1;
select * from t4 order by id;
call dbms_udr.remove_rule ('rule6');


--echo ######## 标签：qr-mysql-3-5 5、DELETE语句
call dbms_udr.create_rule('rule7','whh1','delete from t2 where id = :A', 'delete from t2 where id = :A+1','YES');
delete from t2 where id = 3;
select * from t2 order by id;
call dbms_udr.remove_rule ('rule7');

call dbms_udr.create_rule('rule7','whh1','delete from t2 order by id limit :A', 'delete from t2 order by id desc limit :A','YES');
delete from t2 order by id limit 1;
select * from t2 order by id;
call dbms_udr.remove_rule ('rule7');

--echo ######## 标签：qr-mysql-3-6 6、SET语句
--echo #### SET语句
call dbms_udr.create_rule('rule8','whh1','set @a = ?', 'set @a = ?*100','YES');
set @a = 1;
select @a;

set @a = 1+2;
select @a;

set @a1 = 1;
select @a1;

set @a = 3,@a2 = 4;
select @a,@a2;
call dbms_udr.remove_rule ('rule8');


call dbms_udr.create_rule('rule9','whh1','set @b1 = :A,@b2 = :B', 'set @b1 = :B-(-100),@b2 = :A-(-200)','YES');
set @b1 = 1;
select @b1;

set @b2 = 2;
select @b2;

set @b1 = 3,@b2 = 4;
select @b1,@b2;

set @b2 = 5,@b1 = 6;
select @b2,@b1;

set @b1 = 7,@b2 = 8,@b3 = 9;
select @b1,@b2,@b3;
call dbms_udr.remove_rule ('rule9');


call dbms_udr.create_rule('rule10','whh1','set @c1 = ?, @c2 = 2', 'set @c1 = ?*10, @c2 = 20','YES');
set @c1 = 1;
select @c1;

set @c2 = 2;
select @c2;

set @c1 = 10,@c2 = 2;
select @c1,@c2;

set @c1 = 10, @c2 = 2;
select @c1,@c2;

set @c1 = 20, @c2 = 3-1;
select @c1,@c2;

set @c1 = 20+10, @c2 = 2;
select @c1,@c2;

set @c1 = 40, @c2 = 2,@c3 = 4;
select @c1,@c2,@c3;
call dbms_udr.remove_rule ('rule10');


--echo #### pattern，replacement(语句模板-不同类型语句)
--echo #### insert -- >  重写支持的SQL类型
call dbms_udr.create_rule('rule1','whh1','insert into t4 (id,c1_tint,c2_vcha) values(:A,:B,:C)', 'update t5 set c2_vcha = CONCAT("t4-insert: ",:A,:B,:C) where id = :A +(-10)','YES');
insert into t4 (id,c1_tint,c2_vcha) values(11,100,"insert-->update1");
insert into t4 (id,c2_vcha,c1_tint) values(12,"insert-->update2",110);
insert into t4 values(13,120,"insert-->update3");
select * from t4 order by id;
select * from t5 order by id;
call dbms_udr.remove_rule ('rule1');

call dbms_udr.create_rule('rule2','whh1','insert into t4 (id,c1_tint,c2_vcha) values(:A,:B,:C)', 'select * from t4 where id = :A and c1_tint=:B and c2_vcha=:C order by id desc','YES');
insert into t4 (id,c1_tint,c2_vcha) values(1,10,"查询");
insert into t4 (id,c2_vcha,c1_tint) values(21,"重写",20);
insert into t4 values(22,30,"测试");
select * from t4 order by id;
call dbms_udr.remove_rule ('rule2');

call dbms_udr.create_rule('rule3','whh1','insert into t4 (id,c1_tint,c2_vcha) values(:A,:B,:C)', 'insert into t5 (id,c1_tint,c2_vcha) values(:A,:B,concat("qr-",:C))','YES');
insert into t4 (id,c1_tint,c2_vcha) values(31,100,"insert-->insert1");
insert into t4 (id,c2_vcha,c1_tint) values(32,"insert-->insert2",110);
insert into t4 values(33,120,"insert-->insert3");
select * from t4 order by id;
select * from t5 order by id;
call dbms_udr.remove_rule ('rule3');

call dbms_udr.create_rule('rule4','whh1','insert into t4 (id,c1_tint,c2_vcha) values(:A,:B,:C)', 'delete from t5 where id = :A and c1_tint=:B and c2_vcha=concat("qr-",:C)','YES');
insert into t4 (id,c1_tint,c2_vcha) values(31,100,"insert-->insert1");
select * from t4 order by id;
select * from t5 order by id;
call dbms_udr.remove_rule ('rule4');

--echo #### update -- >  重写支持的SQL类型
call dbms_udr.create_rule('rule5','whh1','update t2 set c2_sint = :A where id = :B', 'update t2 set c2_sint = :A/2 where id = :B','YES');
update t2 set c2_sint = 200 where id = 1;
update t2 set c2_sint = 300 where id = 2 and c1_tint = 21;
update t2 set c2_sint = 100,c1_tint=100 where id = 3;
update t2 set c2_sint = abs(-200) where id = 5;
select * from t2 order by id;
call dbms_udr.remove_rule ('rule5');

call dbms_udr.create_rule('rule6','whh1','update t2 set c2_sint = :A where id = :B', 'select * from t2 where id = :B and c2_sint=:A order by id desc','YES');
update t2 set c2_sint = 100 where id = 1;
update t2 set c2_sint = 300 where id = 2 and c1_tint = 21;
select * from t2 order by id;
call dbms_udr.remove_rule ('rule6');

call dbms_udr.create_rule('rule7','whh1','update t2 set c2_sint = :A where id = :B', 'insert into t2(id,c1_tint,c2_sint) values(:B,:A,:A)','YES');
update t2 set c2_sint = 101 where id = 1;
select * from t2 order by id;
call dbms_udr.remove_rule ('rule7');

call dbms_udr.create_rule('rule8','whh1','update t2 set c1_tint = :A where id = :B and c2_sint = :C', 'delete from t2 where id = :B and c1_tint=:A and c2_sint = :C','YES');
update t2 set c1_tint = 100 where id = 1 and c2_sint = 101;
select * from t2 order by id;
call dbms_udr.remove_rule ('rule8');


--echo #### select -- >  重写支持的SQL类型
call dbms_udr.create_rule('rule9','whh1','select * from t1 where id = :A', 'update t1 set c1_char = CONCAT(:A,"select-->update") where id = :A','YES');
select * from t1 where id = 1;
select * from t1 where abs(id) = 2;
select * from t1 where id = 2+1;
select * from t1 where id = 1 or c1_char is not null order by id;
select id,c1_char,c2_vcha from t1 where id = 4;
select * from t1 order by id;
call dbms_udr.remove_rule ('rule9');

call dbms_udr.create_rule('rule10','whh1','select * from t1 where id = ?', 'select "query rewrite",id,c1_char,c2_vcha,c3_text from t1 where id = ?+1 order by id desc','YES');
select * from t1 where id = 1;
select * from t1 where abs(id) = 2;
select * from t1 where id = 2+1;
select id,c1_char,c2_vcha from t1 where id = 4;
select * from t1 order by id;
call dbms_udr.remove_rule ('rule10');

call dbms_udr.create_rule('rule11','whh1','select * from t1 where id = ?', 'insert into t1(id,c1_char) values(?+20,"select-->insert")','YES');
select * from t1 where id = 1;
select * from t1 where abs(id) = 2;
select * from t1 where id = 2+1;
select * from t1 order by id;
call dbms_udr.remove_rule ('rule11');

call dbms_udr.create_rule('rule12','whh1','select * from t1 where id = ?', 'delete from t1 where id = ? order by id','YES');
select * from t1 where id = 8;
select * from t1 where id = abs(-9);
select * from t1 where id = 2+8;
select * from t1 order by id;
call dbms_udr.remove_rule ('rule12');


--echo #### delete -- >  重写支持的SQL类型
call dbms_udr.create_rule('rule13','whh1','delete from t4 where id = :A', 'update t4 set c2_vcha = null where id = :A order by id','YES');
delete from t4 where id = 21;
delete from t4 where id = 21+1;
delete from t4 where id = 32 order by id;
select * from t4 order by id;
call dbms_udr.remove_rule ('rule13');

call dbms_udr.create_rule('rule14','whh1','delete from t4 where id = ?', 'select * from t4 where id = ? order by id','YES');
delete from t4 where id = 21;
delete from t4 where id = abs(-33);
select * from t4 order by id;
call dbms_udr.remove_rule ('rule14');

call dbms_udr.create_rule('rule15','whh1','delete from t4 where id = :A', 'insert into t4 values(:A+1,:A+0,"delete-->insert")','YES');
delete from t4 where id = 42;
delete from t4 where id = 11+1;
select * from t4 order by id;
call dbms_udr.remove_rule ('rule15');

call dbms_udr.create_rule('rule16','whh1','delete from t4 where id = :A', 'delete from t4 where id = :A*2','YES');
delete from t4 where id = 1;
delete from t4 where id = 20+1;
select * from t4 order by id;
call dbms_udr.remove_rule ('rule16');


--echo #### replace -- >  重写支持的SQL类型
call dbms_udr.create_rule('rule17','whh1','replace into t2 (id,c1_tint,c2_sint) values(2,21,:A)', 'update t2 set c3_mint = :A where id = 2','YES');
replace into t2 (id,c1_tint,c2_sint) values(2,21,100);
replace into t2 (id,c1_tint,c2_sint) values(2,30+1,100*2);
replace into t2 (id,c1_tint,c2_sint,c4_bint) values(3,31,100,34);
replace into t2 values(3,31,32,400,34,35.1,36.5,37.12);
select * from t2 order by id;
call dbms_udr.remove_rule ('rule17');

call dbms_udr.create_rule('rule18','whh1','replace into t2 (id,c1_tint,c2_sint) values(3,31,:A)', 'select * from t2 where id = 3 and c1_tint=31 and c2_sint=:A order by id desc','YES');
replace into t2 (id,c1_tint,c2_sint) values(3,31,32);
select * from t2 order by id;
call dbms_udr.remove_rule ('rule18');

call dbms_udr.create_rule('rule19','whh1','replace into t2 (id,c1_tint,c2_sint) values(3,31,:A)', 'insert into t2 (id,c1_tint,c2_sint) values(:A,:A,:A)','YES');
replace into t2 (id,c1_tint,c2_sint) values(3,31,10);
replace into t2 (id,c1_tint,c2_sint) values(3,30+1,11+1);
select * from t2 order by id;
call dbms_udr.remove_rule ('rule19');

call dbms_udr.create_rule('rule20','whh1','replace into t2 (id,c1_tint,c2_sint) values(3,31,:A)', 'delete from t2 where c2_sint = :A and c1_tint=31 and id=3','YES');
replace into t2 (id,c1_tint,c2_sint) values(3,31,12);
select * from t2 order by id;
call dbms_udr.remove_rule ('rule20');


--echo #### set -- >  重写支持的SQL类型
call dbms_udr.create_rule('rule21','whh1','set @p1=:A,@p2=:B,@p3=:C', 'update t4 set id = :A,c1_tint = :B,c2_vcha = :C where id = :A','YES');
set @p1=7,@p2=77,@p3='set-->update';
select * from t4 order by id;
call dbms_udr.remove_rule ('rule21');

call dbms_udr.create_rule('rule22','whh1','set @p1=:A,@p2=:B,@p3=:C', 'insert into t4 values(:A,:B,:C)','YES');
set @p1=10,@p2=10,@p3='set-->insert';
select * from t4 order by id;
call dbms_udr.remove_rule ('rule22');

call dbms_udr.create_rule('rule23','whh1','set @p1=:A', 'select "query rewrite",* from t4 where id = :A order by id desc','YES');
set @p1=10;
select * from t4 order by id;
call dbms_udr.remove_rule ('rule23');

call dbms_udr.create_rule('rule24','whh1','set @p1=:A,@p2=:B,@p3=:C', 'delete from t4 where id = :A and c1_tint = :B and c2_vcha = :C','YES');
set @p1=10,@p2=10,@p3='set-->insert';
select * from t4 order by id;
call dbms_udr.remove_rule ('rule24');


