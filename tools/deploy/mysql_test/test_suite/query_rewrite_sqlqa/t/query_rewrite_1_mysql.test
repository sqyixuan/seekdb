select 3;
call dbms_udr.remove_rule ('rule4');

call dbms_udr.create_rule('rule5','whh1','select :A from dual', 'select :A from dual','YES');
select 3 from dual;
call dbms_udr.remove_rule ('rule5');

call dbms_udr.create_rule('rule2','whh1','select ? a', 'select ? + 1 + 2 b','YES');
select db_name,rule_name,pattern,replacement,normalized_pattern,status from oceanbase.DBA_OB_USER_DEFINED_RULES where db_name = 'WHH1';
select 10 a;
call dbms_udr.remove_rule ('rule2');

call dbms_udr.create_rule('rule3','whh1','select :A as a', 'select :A + :A  as b','YES');
select 10;
select 10 as a;
select 10 as 'a';
select 10 as A;
select 10,1;
select 10+1;
select 10 from dual;
select c1_tint from t2;
select 10 from v1;
call dbms_udr.remove_rule ('rule3');

call dbms_udr.create_rule('rule1','whh1','select :a1 + :a2', 'select :a2,:a1','YES');
select 1 + 2;
call dbms_udr.remove_rule ('rule1');

call dbms_udr.create_rule('rule2','whh1','select ? + ?', 'select ? * ?','YES');
select 10 + 2;
call dbms_udr.remove_rule ('rule2');

call dbms_udr.create_rule('rule3','whh1','select :a + (:b*2)', 'select (:b + :a) *2','YES');
select 10 + (3*2);
call dbms_udr.remove_rule ('rule3');

call dbms_udr.create_rule('rule4','whh1','select :A1,:A2', 'select :A1*2,:a2*3','YES');
select 1,1;
call dbms_udr.remove_rule ('rule4');

call dbms_udr.create_rule('rule5','whh1','select :abc,2', 'select :abc*2,2','YES');
select 1,2;
call dbms_udr.remove_rule ('rule5');

call dbms_udr.create_rule('rule6','whh1','select cast(? as signed) from dual', 'select cast(?+5.6 as signed) from dual','YES');
--disable_warnings
select cast(1.1 as signed);
select cast(1.1 as signed) from dual;
select cast(1.5 as signed) from dual;
select cast(1+1 as signed) from dual;
select cast('1.234' as signed) from dual;
select cast('1.234' as signed) from dual limit 1;
select cast('1.234' as signed)+1 from dual;
select * from (select cast(1.1 as signed) from dual);
--enable_warnings
call dbms_udr.remove_rule ('rule6');


--echo ## 虚拟表 - SELECT ...; - 运算符  （模板有空格，匹配语句也得有空格）
call dbms_udr.create_rule('rule0','whh1','select ? - 3 ', 'select 3-? as query_rewrite','YES');
select 10-3;
select 10 - 3;
select -10 - 3;
select -3 + 10;
select 10;
select 10-3 from dual;
call dbms_udr.remove_rule ('rule0');

call dbms_udr.create_rule('rule0','whh1','select :A-2', 'select 2-:A as query_rewrite','YES');
select 10-2;
select 10 - 2;
select -10-2;
select - 2 + 10;
select 10-2 from dual;
call dbms_udr.remove_rule ('rule0');

call dbms_udr.create_rule('rule1','whh1','select ? + ?', 'select ?,? as query_rewrite','YES');
select 10 + 20;
select -10 + 20;
select -10 + -20;
select (-10) + (-20);
select 10 + 20 from dual;
call dbms_udr.remove_rule ('rule1');

call dbms_udr.create_rule('rule1','whh1','select :A + :B', 'select :B,:A as query_rewrite','YES');
select 10 + 20;
select -10 + -20;
select -10 + (-20);
select 10 + 20 from dual;
call dbms_udr.remove_rule ('rule1');

call dbms_udr.create_rule('rule2','whh1','select :A,:B,:C', 'select :A*2,:B/2,:C%4','YES');
select 10,20,30;
select 10 ,20 ,30;
select 10-1,20-1,30-1;
select 10,20,30 from dual;
call dbms_udr.remove_rule ('rule2');

call dbms_udr.create_rule('rule2','whh1','select :A*2,:B/2,:C%4', 'select :A,:B,:C','YES');
select 10*2,20/2,30%4;
select 10,20,30;
select 10*2,20/2,30%4 from dual;
call dbms_udr.remove_rule ('rule2');

call dbms_udr.create_rule('rule3','whh1','select :A,:B', 'select :A DIV 2,:B MOD 2','YES');
select 33,33;
select 33 , 33;
select 33,33 from dual;
call dbms_udr.remove_rule ('rule3');

call dbms_udr.create_rule('rule3','whh1','select :A DIV 2,:B MOD 2', 'select :A,:B','YES');
select 33 DIV 2,33 MOD 2;
select 33 DIV 2,33 MOD 2 from dual;
call dbms_udr.remove_rule ('rule3');

call dbms_udr.create_rule('rule4','whh1','select :A', 'select not :A, !:A,:A and 0,:A or 1,:A xor 1','YES');
select 1;
select 0;
select 2;
select 3 from dual;
call dbms_udr.remove_rule ('rule4');

call dbms_udr.create_rule('rule4','whh1','select not :A,!:B,:C and 0,:D or 1,:E xor 1', 'select :A,:B,:C,:D,:E','YES');
select not 1,!2,3 and 0,4 or 1,5 xor 1;
select not 2,!4,6 and 0,8 or 1,0 xor 1;
call dbms_udr.remove_rule ('rule4');

call dbms_udr.create_rule('rule5','whh1','select :A,:B', 'select :A & :B,:A | :B,:A ^ :B, ~ :A ,:A <<1,:B>>1','YES');
select 3,5;
select 3 ,5;
select 3, 5;
select 3 , 5;
select 3,5 from dual;
call dbms_udr.remove_rule ('rule5');

call dbms_udr.create_rule('rule5','whh1','select :A & :B,:C | :D,:E ^ :F, ~ :G ,:H <<1,:I>>1','select :A,:B,:C,:D,:E,:F,:G,:H,:I', 'YES');
select 1 & 2,3 | 4,5 ^ 6, ~ 7 ,8 <<1,9>>1;
select 0 & null,1 | 0,2 ^ 3, ~ 4 ,5 <<1,5>>1;
call dbms_udr.remove_rule ('rule5');

call dbms_udr.create_rule('rule6','whh1','select :A,:B', 'select :A = :B,:A <> :B,:A != :B, :A <=> :B','YES');
select 2,3;
select 2,null;
select null,null;
select null,null from dual;
call dbms_udr.remove_rule ('rule6');

call dbms_udr.create_rule('rule6','whh1','select :A = :B,:C <> :D,:E != :F, :G <=> :H','select :A,:B,:C,:D,:E,:F,:G,:H', 'YES');
select 1 = 2,3 <> 4,5 != 6, 7 <=> 8;
select 1 = 1.0,null <> null,2 != 3, null <=> 0;
call dbms_udr.remove_rule ('rule6');

call dbms_udr.create_rule('rule7','whh1','select :A,:B', 'select :A < :B,:A <= :B,:A > :B, :A >= :B','YES');
select 2,3;
select 2,null;
select null,null;
call dbms_udr.remove_rule ('rule7');

call dbms_udr.create_rule('rule7','whh1','select :A < :B,:C <= :D,:E > :F, :G >= :H','select :A,:B,:C,:D,:E,:F,:G,:H', 'YES');
select 1 < 2,3 <= 4,5 > 6, 7 >= 8;
select null < 2,0 <= 4,5 > 7, 9 >= 0;
call dbms_udr.remove_rule ('rule7');

call dbms_udr.create_rule('rule8','whh1','select :A,:B', 'select :A between 1 and :B,:A in (:A,:A+1,:A*2,:B),:A not in (:A,:A+1,:A*2,:B)','YES');
select 2,10;
call dbms_udr.remove_rule ('rule8');

call dbms_udr.create_rule('rule8','whh1','select :A between 1 and 9,:B in (:C,:D,:E),:F not in (2,4,6)','select :A,:B,:C,:D,:E,:F', 'YES');
select 1 between 1 and 9,2 in (3,6,9),3 not in (2,4,6);
select 4 between 1 and 9,2 in (3,2+1,4*2),3 not in (4,2,6);
call dbms_udr.remove_rule ('rule8');

call dbms_udr.create_rule('rule9','whh1','select :A ', 'select :A like "%test%", :A regexp "rewrite"','YES');
select 'query rewrite test case';
select 'query';
select 1;
select 1 from dual;
call dbms_udr.remove_rule ('rule9');

call dbms_udr.create_rule('rule9','whh1','select :A like "%test%", :B regexp "rewrite"','select :A,:B','YES');
select 'A query rewrite TEST' like "%test%", 'B query rewrite test' regexp "rewrite";
select 'a' like "%test%", 'b' regexp "rewrite";
select 'A' LIKE "%test%", 'B' REGEXP "rewrite";
select 'A' LIKE "%TEST%", 'B' REGEXP "REWRITE";
call dbms_udr.remove_rule ('rule9');

call dbms_udr.create_rule('rule10','whh1','select :A ', 'select :A is null, :A is not null','YES');
select '';
select null;
select 'null';
select 0;
call dbms_udr.remove_rule ('rule10');

call dbms_udr.create_rule('rule10','whh1','select :A is null, :B is not null','select :A,:B','YES');
select null is null, null is not null;
select 0 is null, 0 is not null;
select '' is null, '' is not null;
select '' IS NULL, '' IS NOT NULL;
call dbms_udr.remove_rule ('rule10');


--echo ## 虚拟表 - SELECT ... FROM DUAL ;
call dbms_udr.create_rule('rule0','whh1','select :A,:B,3 from dual', 'select :A+1,:B+2,3,"query rewrite" from dual','YES');
select 1,2 from dual;
select 1,2,3;
select 1,2,3 from dual;
SELECT 1,2,3 FROM DUAL;
select 1,2,2+1 from dual;
select 1,1+2,3 from dual;
select 1,2,3,4 from dual;
call dbms_udr.remove_rule ('rule0');

call dbms_udr.create_rule('rule1','whh1','select :A,:B,:C from dual', 'select :C,:B,:A,"query rewrite" from dual','YES');
select 1,2,3 from dual;
SELECT 1,2,3 FROM DUAL;
select 1,2,2+1 from dual;
select 1,2,3,4 from dual;
call dbms_udr.remove_rule ('rule1');

call dbms_udr.create_rule('rule2','whh1','select mod(?, 2) from dual', 'select mod(?+3, 2) as "query rewrite" from dual','YES');
select mod(7, 2) from dual;
select mod(4+4, 2) from dual;
select mod(9, 2.0) from dual;
select mod(10, 5-3) from dual;
select mod(7, 2) from dual limit 1;
call dbms_udr.remove_rule ('rule2');


--echo ## 普通表
call dbms_udr.create_rule('rule0','whh1','select * from t1 a order by id', 'select * from t1 b order by id desc','YES');
select * from t1 order by id;
select * from t1 a order by id;
call dbms_udr.remove_rule ('rule0');

call dbms_udr.create_rule('rule0','whh1','select * from t1 where id > ?', 'select /*+ index(t1 index) */ * from t1 where id >= ? order by id desc','YES');
select * from t1 where id > 1;
select * from t1 where id > 1 order by id;
select * from t1 where id > 1 limit 1;
SELECT * FROM T1 WHERE ID > 1 order by id;
call dbms_udr.remove_rule ('rule0');

call dbms_udr.create_rule('rule1','whh1','select * from t2 where id > ?', 'select * from t2 partition(p1) where id >= ? order by id desc','YES');
select * from t2 where id > 1;
select * from t2 where id > 1 limit 3;
select * from t2 where id > 1 order by id;
select id,c1_tint,c2_sint from t2 where id > 1 order by id;
call dbms_udr.remove_rule ('rule1');

call dbms_udr.create_rule('rule2','whh1','select count(*) from t1 where id > ?', 'select 10000 as "query rewrite" from t1 where id >= ? order by id desc','YES');
select count(*) from t1 where id > 1;
select count(id) from t1 where id > 1;
select count(*) from t1  where id > 1 order by id;
call dbms_udr.remove_rule ('rule2');

call dbms_udr.create_rule('rule2','whh1','select id,c1_tint,c2_sint from t2 where id > ?', 'select c2_sint,c1_tint,id from t2 where id > ?+1 order by id desc','YES');
select * from t2 where id > 1 order by id;
select id,c1_tint,c2_sint from t2 where id > 1;
SELECT ID,C1_TINT,C2_SINT FROM T2 where id > 1 order by id;
select id,c1_tint,c2_sint from t2 where id > 1 order by id;
call dbms_udr.remove_rule ('rule2');

call dbms_udr.create_rule('rule3','whh1','select * from t1 where ? > 1', 'select "query_rewrite",* from t1 where ?+1 > 1 order by id','YES');
select * from t1 where 1 > 1;
call dbms_udr.remove_rule ('rule3');


