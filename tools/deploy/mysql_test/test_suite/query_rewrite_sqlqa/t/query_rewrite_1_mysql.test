select 1,2,3;
call dbms_udr.remove_rule ('rule1');

call dbms_udr.create_rule('rule2','whh1','select ?,?,?,?,?,?,?,?,?', 'select ?+1,?,?,?,?,?,?,?,?+10','YES');
select 1,2,3,4,5,6,7,8,9;
