--error 0,1008
drop database whh1271111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111;
--error 0,1008
drop database whh12811111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111;
--enable_warnings

create user whh identified by 'whh';
create database whh1;
create database whh1271111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111;
create database whh12811111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111;
grant all on *.* to whh with grant option;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$obmysql_ms0,whh,whh,whh1,$obmysql_port);

--echo # 修改租户级配置项,重写功能开启
alter system set enable_user_defined_rewrite_rules = 'ON';
set @@sql_mode='strict_all_tables';

