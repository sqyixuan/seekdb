call dbms_udr.create_rule('rule11','whh1','create database whh', 'create database whh2','YES');
--error 1235
call dbms_udr.create_rule('rule11','whh1','alter table t2 drop column c', 'alter table t2 drop column d','yes');
--error 1235
call dbms_udr.create_rule('rule11','whh1','drop table t1', 'drop table t2','YES');
--error 1235
call dbms_udr.create_rule('rule11','whh1','select 1', 'drop table t2','YES');
--error 1235
call dbms_udr.create_rule('rule11','whh1','COMMIT', 'select 1','YES');


--echo ## 创建重写规则的模板规则中:{name} 序号重复
--error 1235
call dbms_udr.create_rule('rule12','whh1','select :A,:a from dual', 'select :A,:a+2 from dual','YES');

--error 1235
call dbms_udr.create_rule('rule13','whh1','select :A,:A,:B from dual', 'select :A,:A+2,:B*3 from dual','YES');


--echo ## 创建重写规则的sql语句模板（pattern）中不能包含 “常量” - ? 或者 “常量” - {:char_str} 的场景
--error 1235
call dbms_udr.create_rule('rule14','whh1','select 2-? from dual', 'select 2*? from dual','YES');

--error 1235
call dbms_udr.create_rule('rule15','whh1','select 3-:A from dual', 'select 3*:A from dual','YES');


--echo ######## 标签：qr-mysql-6-2 删除重写规则    
--echo ## 删除规则名称(rule_name)不存在的重写规则
call dbms_udr.remove_rule ('no_exist_rule');


--echo ## 删除重写规则时传递参数个数不符
--error 1318
call dbms_udr.remove_rule ();
--error 1318
call dbms_udr.remove_rule ('rule1','');
--error 1318
call dbms_udr.remove_rule ('rule1',1);
--error 1318
call dbms_udr.remove_rule ('rule1',1,2);


--echo ## 删除重写规则时传递参数数据类型不符
--error 1318
call dbms_udr.remove_rule ();
--error 1210
call dbms_udr.remove_rule (null);
--error 1149
call dbms_udr.remove_rule (year'2022');


--echo ######## 标签：qr-mysql-6-3 重写规则生效/失效
--echo ## 修改规则名称(rule_name)不存在的重写规则
call dbms_udr.enable_rule ('no_exist_rule');

call dbms_udr.disable_rule ('no_exist_rule');

--echo ## 修改重写规则生效/失效时传递参数个数不符
--error 1318
call dbms_udr.enable_rule ();
--error 1318
call dbms_udr.enable_rule ('rule',1);
--error 1318
call dbms_udr.enable_rule ('rule',1,2);

--error 1318
call dbms_udr.disable_rule ();
--error 1318
call dbms_udr.disable_rule ('rule',1);
--error 1318
call dbms_udr.disable_rule ('rule',1,2);

--echo ## 修改重写规则生效/失效时传递参数数据类型不符
--error 1318
call dbms_udr.enable_rule ();
--error 1235
call dbms_udr.enable_rule ('');
call dbms_udr.enable_rule (' ');
--error 1210
call dbms_udr.enable_rule (null);
--error 1149
call dbms_udr.enable_rule (year'2022');

--error 1318
call dbms_udr.disable_rule ();
--error 1235
call dbms_udr.disable_rule ('');
call dbms_udr.disable_rule (' ');
--error 1210
call dbms_udr.disable_rule (null);
--error 1149
call dbms_udr.disable_rule (year'2022');


--echo ######## 标签：qr-mysql-5-7 重写功能关闭
alter system set enable_user_defined_rewrite_rules = 'ON';
#show parameters like 'enable_user_defined_rewrite_rules';

call dbms_udr.create_rule('rule1','whh1','select ?', 'select ? + 10','YES');
select db_name,rule_name,pattern,replacement,normalized_pattern,status from oceanbase.DBA_OB_USER_DEFINED_RULES where db_name = 'WHH1';
select 10;

call dbms_udr.create_rule('rule2','whh1','select :A,:B', 'select :A+:B','YES');
select db_name,rule_name,pattern,replacement,normalized_pattern,status from oceanbase.DBA_OB_USER_DEFINED_RULES where db_name = 'WHH1';
select 10,20;

--echo # 重写功能关闭
alter system set enable_user_defined_rewrite_rules = 'OFF';
sleep 5;
#show parameters like 'enable_user_defined_rewrite_rules';

select 10;
call dbms_udr.remove_rule ('rule1');

select 10,20;
call dbms_udr.remove_rule ('rule2');


--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user whh@'%';
--error 0,1008
drop database whh1;
--enable_warnings
