--echo ## 创建重写规则的模板规则中“?”跟:{name}以外符号充当匹配参数值的参数标记
call dbms_udr.create_rule('rule','whh1','select $', 'select $+1','YES');
select 4;
call dbms_udr.remove_rule ('rule');


--error 1235
call dbms_udr.create_rule('rule','whh1','select :1', 'select :1+1','YES');
