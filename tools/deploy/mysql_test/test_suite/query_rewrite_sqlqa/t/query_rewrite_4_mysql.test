--error 1064
call dbms_udr.create_rule('rule3','whh1','select &', 'select &+1','YES');



--echo ## 创建重写规则的模板规则中参数标记出现非参数值的地方
--echo # SQL 关键字
--error 1064
call dbms_udr.create_rule('rule11','whh1','select * from t1 ? id > ?', 'select * from t1 ? id > ?+1','YES');
--error 1064
call dbms_udr.create_rule('rule11','whh1','select cast(0.123 as ?) from dual', 'select cast(0.123 as ?) from dual','YES');

--echo # 标识符
