purge recyclebin;
--result_format 4

--echo ########## 处理测试环境 ##########
--disable_warnings
--error 0,1396
drop user whh@'%';
--error 0,1008
drop database whh1;
--enable_warnings

create user whh identified by 'whh';
create database whh1;
grant all on *.* to whh with grant option;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$obmysql_ms0,whh,whh,whh1,$obmysql_port);

--echo # 修改租户级配置项,重写功能开启
alter system set enable_user_defined_rewrite_rules = 'ON';
sleep 5;
set @@sql_mode='strict_all_tables';

--source mysql_test/test_suite/query_rewrite_sqlqa/t/create_table.inc

--echo ######## 标签：qr-mysql-5-5 重写的使用场景
--echo #### 自定义函数中
--echo ## 在自定义函数中调用创建/删除/修改重写规则方法
delimiter $$;
--error 0,1305
drop function fun_create;$$
create function fun_create() returns varchar(20) NO SQL
begin
  call dbms_udr.create_rule('rulename0','whh1','select :A,:B', 'select pow(:A,:B)','YES');
  return '>>>>create_rule ok';
end;
$$

--error 0,1305
drop function fun_remove;$$
create function fun_remove() returns varchar(20) NO SQL
begin
  call dbms_udr.remove_rule ('rulename0');
  return '>>>>remove_rule ok';
end;
$$

--error 0,1305
drop function fun_enable;$$
create function fun_enable() returns varchar(20) NO SQL
begin
  call dbms_udr.enable_rule ('rulename0');
  return '>>>>enable_rule ok';
end;
$$

--error 0,1305
drop function fun_disable;$$
create function fun_disable() returns varchar(20) NO SQL
begin
  call dbms_udr.disable_rule ('rulename0');
  return '>>>>disable_rule ok';
end;
$$

delimiter ;$$
select fun_create();
select 10,2;

select fun_disable();
select 10,2;

select fun_enable();
select 10,2;

select fun_remove();
select 10,2;


--echo ## 创建/删除/修改重写规则方法的参数是自定义函数形参
delimiter $$;
--error 0,1305
drop function fun_create;$$
create function fun_create(name varchar(256),owner varchar(128),sql1 longtext,sql2 longtext,enabled varchar(128)) returns varchar(20) NO SQL
begin
  call dbms_udr.create_rule(name,owner,sql1,sql2,enabled);
  return '>>>>create_rule ok';
end;
$$

--error 0,1305
drop function fun_remove;$$
create function fun_remove(name varchar(256)) returns varchar(20) NO SQL
begin
  call dbms_udr.remove_rule(name);
  return '>>>>remove_rule ok';
end;
$$

--error 0,1305
drop function fun_enable;$$
create function fun_enable(name varchar(256)) returns varchar(20) NO SQL
begin
  call dbms_udr.enable_rule(name);
  return '>>>>enable_rule ok';
end;
$$

--error 0,1305
drop function fun_disable;$$
create function fun_disable(name varchar(256)) returns varchar(20) NO SQL
begin
  call dbms_udr.disable_rule(name);
  return '>>>>disable_rule ok';
end;
$$

delimiter ;$$
select fun_create('rulename1','whh1','select * from t2 where id = ?', 'select * from t2 where id > ? order by id desc','YES');
select * from t2 where id = 1;

select fun_disable('rulename1');
select * from t2 where id = 1;

select fun_enable('rulename1');
select * from t2 where id = 1;

select fun_remove('rulename1');
select * from t2 where id = 1;


--echo ## 创建/删除/修改重写规则方法的参数是自定义函数中声明局部变量
delimiter $$;
--error 0,1305
drop function fun_create;$$
create function fun_create() returns varchar(20) NO SQL
begin
  declare name varchar(256);
  declare owner varchar(128);
  declare sql1 longtext;
  declare sql2 longtext;
  declare enabled varchar(128);
  set name='rulename2';
  set owner='whh1';
  set sql1='select :A,:B from dual';
  set sql2='select :A,:A+:B from dual';
  set enabled='YES';
  call dbms_udr.create_rule(name,owner,sql1,sql2,enabled);
  return '>>>>create_rule ok';
end;
$$

--error 0,1305
drop function fun_remove;$$
create function fun_remove() returns varchar(20) NO SQL
begin
  declare name varchar(256);
  set name='rulename2';
  call dbms_udr.remove_rule (name);
  return '>>>>remove_rule ok';
end;
$$

--error 0,1305
drop function fun_enable;$$
create function fun_enable() returns varchar(20) NO SQL
begin
  declare name varchar(256);
  set name='rulename2';
  call dbms_udr.enable_rule (name);
  return '>>>>enable_rule ok';
end;
$$

--error 0,1305
drop function fun_disable;$$
create function fun_disable() returns varchar(20) NO SQL
begin
  declare name varchar(256);
  set name='rulename2';
  call dbms_udr.disable_rule (name);
  return '>>>>disable_rule ok';
end;
$$

delimiter ;$$
select fun_create();
select 2,4 from dual;

select fun_disable();
select 2,4 from dual;

select fun_enable();
select 2,4 from dual;

select fun_remove();
select 2,4 from dual;


--echo #### 存储过程中
--echo ## 在存储过程中调用创建/删除/修改重写规则方法
delimiter $$;
--error 0,1305
drop procedure pro_create;$$
create procedure pro_create()
begin
  call dbms_udr.create_rule('rulename0','whh1','select ?,4', 'select 3+?,4','YES');
end;
$$

--error 0,1305
drop procedure pro_remove;$$
create procedure pro_remove()
begin
  call dbms_udr.remove_rule ('rulename0');
end;
$$

--error 0,1305
drop procedure pro_enable;$$
create procedure pro_enable()
begin
  call dbms_udr.enable_rule ('rulename0');
end;
$$

--error 0,1305
drop procedure pro_disable;$$
create procedure pro_disable()
begin
  call dbms_udr.disable_rule ('rulename0');
end;
$$

delimiter ;$$
call pro_create();
select 10,4;

call pro_disable();
select 10,4;

call pro_enable();
select 10,4;

call pro_remove();
select 10,4;


--echo ## 创建/删除/修改重写规则方法的参数是存储过程形参
delimiter $$;
--error 0,1305
drop procedure pro_create;$$ 
create procedure pro_create(name varchar(256),owner varchar(128),sql1 longtext,sql2 longtext,enabled varchar(128))
begin
  call dbms_udr.create_rule(name,owner,sql1,sql2,enabled);
end;
$$

--error 0,1305
drop procedure pro_remove;$$
create procedure pro_remove(name varchar(256))
begin
  call dbms_udr.remove_rule (name);
end;
$$

--error 0,1305
drop procedure pro_enable;$$
create procedure pro_enable(name varchar(256))
begin
  call dbms_udr.enable_rule (name);
end;
$$

--error 0,1305
drop procedure pro_disable;$$
create procedure pro_disable(name varchar(256))
begin
  call dbms_udr.disable_rule (name);
end;
$$

delimiter ;$$
call pro_create('rulename1','whh1','select * from t1 where id = ?', 'select "query rewrite",id,c1_char,c2_vcha,c3_text from t1 where id > ?+1 order by id desc','YES');
select * from t1 where id = 1;

call pro_disable('rulename1');
select * from t1 where id = 1;

call pro_enable('rulename1');
select * from t1 where id = 1;

call pro_remove('rulename1');
select * from t1 where id = 1;


--echo ## 创建/删除/修改重写规则方法的参数是存储过程中声明局部变量
delimiter $$;
--error 0,1305
drop procedure pro_create;$$ 
create procedure pro_create()
begin
  declare name varchar(256);
  declare owner varchar(128);
  declare sql1 longtext;
  declare sql2 longtext;
  declare enabled varchar(128);
  set name='rulename2';
  set owner='whh1';
  set sql1='select :A,:B from dual';
  set sql2='select :A+2,:B*2 from dual';
  set enabled='YES';
  call dbms_udr.create_rule(name,owner,sql1,sql2,enabled);
end;
$$

--error 0,1305
drop procedure pro_remove;$$
create procedure pro_remove()
begin
  declare name varchar(256);
  set name='rulename2';
  call dbms_udr.remove_rule (name);
end;
$$

--error 0,1305
drop procedure pro_enable;$$
create procedure pro_enable()
begin
  declare name varchar(256);
  set name='rulename2';
  call dbms_udr.enable_rule (name);
end;
$$

--error 0,1305
drop procedure pro_disable;$$
create procedure pro_disable()
begin
  declare name varchar(256);
  set name='rulename2';
  call dbms_udr.disable_rule (name);
end;
$$

delimiter ;$$
call pro_create();
select 2,4 from dual;

call pro_disable();
select 2,4 from dual;

call pro_enable();
select 2,4 from dual;

call pro_remove();
select 2,4 from dual;


--echo #### 预处理语句中
--echo ## 在预处理语句中调用创建/删除/修改重写规则方法
prepare st_create from "call dbms_udr.create_rule('rulename1','whh1','select :A', 'select :A+:A','YES')";
prepare st_disable from "call dbms_udr.disable_rule ('rulename1')";
prepare st_enable from "call dbms_udr.enable_rule ('rulename1')";
prepare st_remove from "call dbms_udr.remove_rule ('rulename1')";

execute st_create;
select 3;

execute st_disable;
select 3;

execute st_enable;
select 3;

execute st_remove;
select 3;

drop prepare st_create;
drop prepare st_disable;
drop prepare st_enable;
drop prepare st_remove;

--echo ## 创建/删除/修改重写规则方法的参数通过参数传递
prepare st_create from "call dbms_udr.create_rule(?,?,?,?,?)";
prepare st_enable from "call dbms_udr.enable_rule (?)";
prepare st_disable from "call dbms_udr.disable_rule (?)";
prepare st_remove from "call dbms_udr.remove_rule (?)";

set @p1='rulename2';
set @p2='whh1';
set @p3='select :A from dual';
set @p4='select concat("query rewrite: ",:A) from dual';
set @p5='YES';

execute st_create using @p1,@p2,@p3,@p4,@p5;
select 'case' from dual;

execute st_disable using @p1;
select 'case' from dual;

execute st_enable using @p1;
select 'case' from dual;

execute st_remove using @p1;
select 'case' from dual;

drop prepare st_create;
drop prepare st_disable;
drop prepare st_enable;
drop prepare st_remove;


--echo ######## 标签：qr-mysql-5-6 同时创建多个相同的重写规则,会随机的选择匹配到的第一个
call dbms_udr.create_rule('rulename5-6-1','whh1','select ?,2', 'select ? + 10,2','YES');
select 10,2;

call dbms_udr.create_rule('rulename5-6-2','whh1','select ?,2', 'select ? + 20,2','YES');
select 10,2;

call dbms_udr.remove_rule ('rulename5-6-1');
call dbms_udr.remove_rule ('rulename5-6-2');


--echo >>>>>>>>>>>>>>>>>>>>>>>>>>> qr-mysql-6 重写的异常场景 	<<<<<<<<<<<<<<<<<<<<<<<<<
--echo ######## 标签：qr-mysql-6-1 创建重写规则  
--echo ## 创建规则名称已存在(rule_name)的重写规则
call dbms_udr.create_rule('rule1','whh1','select ?', 'select ?+1','YES');
select 1;
select 1,2;
select 1 from dual;

--error 1062
call dbms_udr.create_rule('rule1','whh1','select ?,2,?', 'select ?+1,2,?+3','YES');

--error 1062
call dbms_udr.create_rule('RULE1','whh1','select :A,3,:B', 'select :A+1,3,:B+3','YES');

call dbms_udr.remove_rule ('rule1');


--echo ## 创建重写规则时传递参数个数不符
--error 1318
call dbms_udr.create_rule();
--error 1318
call dbms_udr.create_rule('rule2');
--error 1318
call dbms_udr.create_rule('rule2','whh1');
--error 1318
call dbms_udr.create_rule('rule2','whh1','select ?');
--error 1318
call dbms_udr.create_rule('whh1','select ?', 'select ? * 2');
--error 1318
call dbms_udr.create_rule('rule2','select ?', 'select ? * 2');
--error 1318
call dbms_udr.create_rule('rule2','whh1', 'select ? * 2');
--error 1318
call dbms_udr.create_rule('rule2','whh1','select ?');

call dbms_udr.create_rule('rule2','whh1','select ?', 'select ? * 2');
select 10;
call dbms_udr.remove_rule ('rule2');

--error 1318
call dbms_udr.create_rule('rule2','whh1','select ?', 'select ? * 2','YES','7');
--error 1318
call dbms_udr.create_rule('rule2','whh1','select ?', 'select ? * 2','YES','7','8');


--echo ## 创建重写规则时传递参数数据类型不符
--echo # rule_name
--error 1064
call dbms_udr.create_rule('whh1','select ?','select ? * 2','YES');
--error 1064
call dbms_udr.create_rule(,'whh1','select ?', 'select ? * 2','YES');
--error 1235
call dbms_udr.create_rule('','whh1','select ?', 'select ? * 2','YES');
--error 1210
call dbms_udr.create_rule(null,'whh1','select ?', 'select ? * 2','YES');
--error 1149
call dbms_udr.create_rule(year'2022','whh1','select :A+:B', 'select :A*:B','YES');

--echo # rule_owner_name
--error 1064
call dbms_udr.create_rule('rule3','select ?', 'select ? * 2','YES');
--error 1064
call dbms_udr.create_rule('rule3',,'select ?', 'select ? * 2','YES');
--error 1048
call dbms_udr.create_rule('rule3','','select ?', 'select ? * 2','YES');
--error 1210
call dbms_udr.create_rule('rule3',null,'select ?', 'select ? * 2','YES');
--error 1149
call dbms_udr.create_rule('rule3',year'2022','select ?', 'select ? * 2','YES');

--echo # pattern
--error 1064
call dbms_udr.create_rule('rule4','whh1','select ? * 2','YES');
--error 1064
call dbms_udr.create_rule('rule4','whh1',,'select ? * 2','YES');
--error 1235
call dbms_udr.create_rule('rule4','whh1','','select ? * 2','YES');
--error 1065
