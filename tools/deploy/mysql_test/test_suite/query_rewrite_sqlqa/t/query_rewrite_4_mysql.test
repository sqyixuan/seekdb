--echo ## 创建重写规则的sql语句模板（pattern）不合法
--error 1064
call dbms_udr.create_rule('rule7','whh1','select ? form dual', 'select ? / 2 from dual','YES');
--error 1064
call dbms_udr.create_rule('rule7','whh1','select ? from dual', 'select ? / 2 form dual','YES');
--error 1064
call dbms_udr.create_rule('rule7','whh1','select ? form dual limit -1', 'select ? / 2 from dual limit -1','YES');

--echo ## 创建重写规则的sql语句模板（pattern）最后有其他符号/多个语句
call dbms_udr.create_rule('rule7','whh1','select ? from dual;', 'select ? / 2 from dual;','YES');
select db_name,rule_name,pattern,replacement,normalized_pattern,status from oceanbase.DBA_OB_USER_DEFINED_RULES where db_name = 'WHH1';
select 3 from dual;
call dbms_udr.remove_rule ('rule7');

--error 1235
call dbms_udr.create_rule('rule7','whh1','select ?,1;select ?,2', 'select ?*2,1;select ?*4,2','YES');

--error 1235
