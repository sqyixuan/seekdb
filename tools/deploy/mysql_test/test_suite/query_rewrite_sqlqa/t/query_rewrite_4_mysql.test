call dbms_udr.create_rule('rule4','whh1','select ?',year'2022','YES');

--echo # enabled
--error 1064
call dbms_udr.create_rule('rule6','whh1','select ?', 'select ? * 2',);
--error 1210
call dbms_udr.create_rule('rule6','whh1','select ?', 'select ? * 2','');
--error 1210
call dbms_udr.create_rule('rule6','whh1','select ?', 'select ? * 2',' ');
--error 1210
call dbms_udr.create_rule('rule6','whh1','select ?', 'select ? * 2',null);
