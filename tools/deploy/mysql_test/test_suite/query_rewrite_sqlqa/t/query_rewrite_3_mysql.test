purge recyclebin;
--result_format 4

--echo ########## 处理测试环境 ##########
--disable_warnings
--error 0,1396
drop user whh@'%';
--error 0,1008
drop database whh1;
--enable_warnings

create user whh identified by 'whh';
create database whh1;
grant all on *.* to whh with grant option;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$obmysql_ms0,whh,whh,whh1,$obmysql_port);

--echo # 修改租户级配置项,重写功能开启
alter system set enable_user_defined_rewrite_rules = 'ON';
set @@sql_mode='strict_all_tables';

--source mysql_test/test_suite/query_rewrite_sqlqa/t/create_table.inc

--echo ######## 标签：qr-mysql-5-1 创建重写
--echo #### enabled 
--echo # TRUE
--error 1210
call dbms_udr.create_rule(
  'rule_name2',
  'whh1',
  'select ? from dual', 
  'select SUBSTR(?, 2, 6) from dual',
  TRUE);

--echo # FALSE
--error 1210
call dbms_udr.create_rule(
  'rule_name3',
  'whh1',
  'select ? from dual', 
  'select SUBSTR(?, 2, 6) from dual', 
  FALSE);


--echo ## 数值常量
--echo # 0
--error 1210
call dbms_udr.create_rule(
  'rule_name4',
  'whh1',
  'select ? from dual', 
  'select ? * 1 from dual',
  0);

--echo # 1
--error 1210
call dbms_udr.create_rule(
  'rule_name4',
  'whh1',
  'select ? from dual', 
  'select ? * 2 from dual', 
  1);

--echo # -1，1.0，1.5，……
--error 1210
call dbms_udr.create_rule(
  'rule_name5',
  'whh1',
  'select ? from dual', 
  'select ? * 3 from dual',
  -1);

--error 1210
call dbms_udr.create_rule(
  'rule_name6',
  'whh1',
  'select ? from dual', 
  'select ? * 4 from dual',
  1.0);

--error 1210
call dbms_udr.create_rule(
  'rule_name7',
  'whh1',
  'select ? from dual', 
  'select ? * 5 from dual',
  1.5);


--echo ## 时间日期字面量
--error 1210
call dbms_udr.create_rule(
  'rule_name19',
  'whh1',
  'select ?,1 from dual', 
  'select ? * 2,1 from dual',
  time'15:C0:00');

--error 1210
call dbms_udr.create_rule(
  'rule_name19',
  'whh1',
  'select ?,1 from dual', 
  'select ? * 2,1 from dual',
  date'2022-11-21');


--echo ## NULL
--error 1210
call dbms_udr.create_rule(
  'rule_name20',
  'whh1',
  'select ? from dual', 
  'select ? + 1 from dual',
  NULL);


--echo ## 汉字常量
--error 1210
call dbms_udr.create_rule(
  'rule_name21',
  'whh1',
  'select ? from dual', 
  'select ? + 50 from dual',
  '是');


--echo ## 字符与数值混合字面量
--error 1210
call dbms_udr.create_rule(
  'rule_name22',
  'whh1',
  'select ? from dual', 
  'select ? + 70 from dual', 
  '12yes');

--error 1210
call dbms_udr.create_rule(
  'rule_name23',
  'whh1',
  'select ? from dual', 
  'select ? + 80 from dual',
  'yes12');


--echo ## 含有特殊字符的字面量
--error 1210
call dbms_udr.create_rule(
  'rule_name24',
  'whh1',
  'select ? from dual', 
  'select ? + 90 from dual', 
  '@#$%^&*');

--error 1210
call dbms_udr.create_rule(
  'rule_name25',
  'whh1',
  'select ? from dual', 
  'select ? + 100 from dual', 
  'yes@');

--echo # \n,\t,\r,换行符
--error 1210
call dbms_udr.create_rule(
  'rule_name26',
  'whh1',
  'select ? from dual', 
  'select ? * 1 from dual', 
  'yes\n');

--error 1210
call dbms_udr.create_rule(
  'rule_name27',
  'whh1',
  'select ? from dual', 
  'select ? * 2 from dual', 
  'yes\t');

--error 1210
call dbms_udr.create_rule(
  'rule_name28',
  'whh1',
  'select ? from dual', 
  'select ? * 3 from dual', 
  'yes\r');

--echo # 含有空格
--error 1210
call dbms_udr.create_rule(
  'rule_name29',
  'whh1',
  'select ? from dual', 
  'select ? * 4 from dual', 
  'yes ');

--error 1210
call dbms_udr.create_rule(
  'rule_name30',
  'whh1',
  'select ? from dual', 
  'select ? * 5 from dual', 
  'y e s');

--error 1210
call dbms_udr.create_rule(
  'rule_name31',
  'whh1',
  'select ? from dual', 
  'select ? * 6 from dual', 
  ' yes');


--echo #### 创建规则的5个参数用用户自定义变量传入
set @name='rule1',@owern='whh1',@pattern='select ?',@replacement='select ? * 3',@enable='YES';
call dbms_udr.create_rule(@name,@owern,@pattern,@replacement,@enable);
select 2;
call dbms_udr.remove_rule (@name);


--echo #### 创建规则时所需的参数用内置函数返回结果传入 
call dbms_udr.create_rule(upper('rule2'),lower('whh1'),concat('select ? ','from dual'),concat('select ?*4 ','from dual'),trim(' YES '));
select 2 from dual;
call dbms_udr.remove_rule (upper('rule2'));


--echo #### 创建规则时所需的参数用function函数返回结果传入
delimiter $$;
--error 0,1305
drop function fun1;$$
create function fun1 (par int) returns varchar(20) NO SQL
begin
  if par = 1 then
    return 'rule_name1';
  elseif  par = 2 then
    return 'whh1';
  elseif  par = 3 then
    return 'select ? from dual';
  elseif  par = 4 then
    return 'select ?*5 from dual';
  else
    return 'YES';
  end if;
end;
$$

delimiter ;$$

call dbms_udr.create_rule(fun1(1),fun1(2),fun1(3),fun1(4),fun1(5));
select 2 from dual;
call dbms_udr.remove_rule (fun1(1));


--echo ######## 标签：qr-mysql-5-2 删除重写
--echo #### rule_name 
--echo # null
--error 1210
call dbms_udr.remove_rule (null);

--echo # 汉字常量
call dbms_udr.create_rule('中文汉字','whh1','select ?', 'select ?+1','YES');
select 2;
call dbms_udr.remove_rule ('中文汉字');
select 2;

--echo # 用户自定义变量
set @name = 'user_var';
call dbms_udr.create_rule(@name,'whh1','select ?', 'select ?+2','YES');
select 2;
call dbms_udr.remove_rule (@name);
select 2;

--echo # 字符类型字面量
call dbms_udr.create_rule('rule_name3','whh1','select ?', 'select ?+3','YES');
select 2;
call dbms_udr.remove_rule ('rule_name3');
select 2;

--echo # 一段超长字符串字面量
call dbms_udr.create_rule(rpad('rule_name1',255,'x'),'whh1','select ?','select ? + 3','YES');
select 10;
call dbms_udr.remove_rule (rpad('rule_name1',255,'x'));
select 10;

call dbms_udr.create_rule(rpad('rule_name2',256,'x'),'whh1','select ?','select ? + 4','YES');
select 10;
call dbms_udr.remove_rule (rpad('rule_name2',256,'x'));
select 10;

--error 1406
call dbms_udr.remove_rule (rpad('rule_name2',257,'x'));


--echo # 字符与数值混合字面量
call dbms_udr.create_rule('rule_name123','whh1','select ?', 'select ?+4','YES');
select 2;
call dbms_udr.remove_rule ('rule_name123');
select 2;

--echo # 含有特殊字符的字面量
call dbms_udr.create_rule('@#$%^&*','whh1','select :A', 'select :A * 2','YES');
select 10;
call dbms_udr.remove_rule ('@#$%^&*');
select 10;

call dbms_udr.create_rule('rule1\n','whh1','select ?,2', 'select ? + 1,2','YES');
select 10,2;
call dbms_udr.remove_rule ('rule1\n');
select 10,2;

call dbms_udr.create_rule('rule2\t','whh1','select :A,2', 'select :A + 2,2','YES');
select 10,2;
call dbms_udr.remove_rule ('rule2\t');
select 10,2;

call dbms_udr.create_rule('rule3\r','whh1','select ?', 'select lower(?)','YES');
select 'WANG';
select 10;
call dbms_udr.remove_rule ('rule3\r');
select 'WANG';

call dbms_udr.create_rule('rule4
name','whh1','select :A', 'select upper(:A)','YES');
select 'query rewrite';
call dbms_udr.remove_rule ('rule4
name');
select 'query rewrite';


--echo # 删除规则时所需的参数用用户自定义变量传入
set @name='rule_name4';
call dbms_udr.create_rule(@name,'whh1','select ?','select ? * 3','YES');
select 2;
call dbms_udr.remove_rule (@name);
select 2;

--echo #### 删除规则时所需的参数用内置函数返回结果传入 
call dbms_udr.create_rule(upper('rule_name5'),lower('whh1'),concat('select ? ','from dual'),concat('select ?/2 ','from dual'),'YES');
select 2 from dual;
call dbms_udr.remove_rule (upper('rule_name5'));
select 2 from dual;


--echo #### 删除规则时所需的参数用function函数返回结果传入
delimiter $$;
--error 0,1305
drop function fun1;$$
create function fun1 (par int) returns varchar(20) NO SQL
begin
  if par = 1 then
    return 'rule_name6';
  elseif  par = 2 then
    return 'whh1';
  elseif  par = 3 then
    return 'select ? from dual';
  elseif  par = 4 then
    return 'select ?*2 from dual';
  else
    return '0';
  end if;
end;
$$

delimiter ;$$

call dbms_udr.create_rule(fun1(1),fun1(2),fun1(3),fun1(4),'YES');
select 2 from dual;
call dbms_udr.remove_rule (fun1(1));
select 2 from dual;


--echo ######## 标签：qr-mysql-5-3，qr-mysql-5-4 重写生效，重写失效
--echo #### rule_name 
--echo # null
--error 1210
call dbms_udr.enable_rule (null);

--error 1210
call dbms_udr.disable_rule (null);


--echo # 汉字常量
call dbms_udr.create_rule('中文汉字','whh1','select :A', 'select :A * :A','YES');
select 2;
call dbms_udr.disable_rule ('中文汉字');
select 2;
call dbms_udr.enable_rule ('中文汉字');
select 2;
call dbms_udr.remove_rule ('中文汉字');

--echo # 用户自定义变量
set @name = 'user_var1';
call dbms_udr.create_rule(@name,'whh1','select :A,:B', 'select :B,:A','YES');
select 2,3;
call dbms_udr.disable_rule (@name);
select 2,3;
call dbms_udr.enable_rule (@name);
select 2,3;
call dbms_udr.remove_rule (@name);

--echo # 字符类型字面量
call dbms_udr.create_rule('rule_name3','whh1','select ?', 'select ?+2','YES');
select 2;
call dbms_udr.disable_rule ('rule_name3');
select 2;
call dbms_udr.enable_rule ('rule_name3');
select 2;
call dbms_udr.remove_rule ('rule_name3');

--echo # 一段超长字符串字面量
call dbms_udr.create_rule(rpad('rule_name1',255,'x'),'whh1','select ?','select ? + 1','YES');
select 10;
call dbms_udr.disable_rule (rpad('rule_name1',255,'x'));
select 10;
call dbms_udr.enable_rule (rpad('rule_name1',255,'x'));
select 10;
call dbms_udr.remove_rule (rpad('rule_name1',255,'x'));

call dbms_udr.create_rule(rpad('rule_name2',256,'x'),'whh1','select ?','select ? + 2','YES');
select 10;
call dbms_udr.disable_rule (rpad('rule_name2',256,'x'));
select 10;
call dbms_udr.enable_rule (rpad('rule_name2',256,'x'));
select 10;
call dbms_udr.remove_rule (rpad('rule_name2',256,'x'));

--error 1406
call dbms_udr.disable_rule(rpad('rule_name3',257,'x'));
--error 1406
call dbms_udr.enable_rule(rpad('rule_name3',257,'x'));


--echo # 字符与数值混合字面量
call dbms_udr.create_rule('123rule_name123','whh1','select ?', 'select ?*2','YES');
select 3;
call dbms_udr.disable_rule ('123rule_name123');
select 3;
call dbms_udr.enable_rule ('123rule_name123');
select 3;
call dbms_udr.remove_rule ('123rule_name123');

--echo # 含有特殊字符的字面量
call dbms_udr.create_rule('@#$%^&*','whh1','select :A', 'select :A * 2','YES');
select 10;
call dbms_udr.disable_rule ('@#$%^&*');
select 10;
call dbms_udr.enable_rule ('@#$%^&*');
select 10;
call dbms_udr.remove_rule ('@#$%^&*');

call dbms_udr.create_rule('rulename1\n','whh1','select ?,2', 'select ? + 1,2','YES');
select 10,2;
call dbms_udr.disable_rule ('rulename1\n');
select 10,2;
call dbms_udr.enable_rule ('rulename1\n');
select 10,2;
call dbms_udr.remove_rule ('rulename1\n');

call dbms_udr.create_rule('rulename2\t','whh1','select :A,2', 'select :A + 2,2','YES');
select 10,2;
call dbms_udr.disable_rule ('rulename2\t');
select 10,2;
call dbms_udr.enable_rule ('rulename2\t');
select 10,2;
call dbms_udr.remove_rule ('rulename2\t');

call dbms_udr.create_rule('rulename3\r','whh1','select ?', 'select lower(?)','YES');
select 'WANG';
call dbms_udr.disable_rule ('rulename3\r');
select 'WANG';
call dbms_udr.enable_rule ('rulename3\r');
select 'WANG';
call dbms_udr.remove_rule ('rulename3\r');

call dbms_udr.create_rule('rulename4
name','whh1','select :A', 'select upper(:A)','YES');
select 'query rewrite';
call dbms_udr.disable_rule ('rulename4
name');
select 'query rewrite';
call dbms_udr.enable_rule ('rulename4
name');
select 'query rewrite';
call dbms_udr.remove_rule ('rulename4
name');

--echo # 修改规则时所需的参数用用户自定义变量传入
set @name='rule_name4';
call dbms_udr.create_rule(@name,'whh1','select ?','select ? + 3','YES');
select 2;
call dbms_udr.disable_rule (@name);
select 2;
call dbms_udr.enable_rule (@name);
select 2;
call dbms_udr.remove_rule (@name);

--echo #### 修改规则时所需的参数用内置函数返回结果传入 
call dbms_udr.create_rule(upper('rule_name5'),lower('whh1'),concat('select ? ','from dual'),concat('select ?*2 ','from dual'),'YES');
select 2 from dual;
call dbms_udr.disable_rule (upper('rule_name5'));
select 2 from dual;
call dbms_udr.enable_rule (upper('rule_name5'));
select 2 from dual;
call dbms_udr.remove_rule (upper('rule_name5'));

--echo #### 修改规则时所需的参数用function函数返回结果传入
delimiter $$;
drop function fun1;$$
create function fun1 (par int) returns varchar(20) NO SQL
begin
  if par = 1 then
    return 'rule_name1';
  elseif  par = 2 then
    return 'whh1';
  elseif  par = 3 then
    return 'select ? from dual';
  elseif  par = 4 then
    return 'select ?*2 from dual';
  else
    return '0';
  end if;
end;
$$

delimiter ;$$

call dbms_udr.create_rule(fun1(1),fun1(2),fun1(3),fun1(4),'YES');
select 2 from dual;
call dbms_udr.disable_rule (fun1(1));
select 2 from dual;
call dbms_udr.enable_rule (fun1(1));
select 2 from dual;
call dbms_udr.remove_rule (fun1(1));


--echo # 修改租户级配置项,重写功能关闭
alter system set enable_user_defined_rewrite_rules = 'OFF';

--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user whh@'%';
--error 0,1008
drop database whh1;
--enable_warnings
