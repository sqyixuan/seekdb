# description: Query Rewrite - Mysql模式（补充功能测试）
# tags: ddl,dml,pl
# author: whh01047778


purge recyclebin;
--result_format 4

--echo ########## 处理测试环境 ##########
--disable_warnings
--error 0,1396
drop user whh@'%';
--error 0,1008
drop database whh1;
--enable_warnings

create user whh identified by 'whh';
create database whh1;
grant all on *.* to whh with grant option;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$obmysql_ms0,whh,whh,whh1,$obmysql_port);
connect (conn2,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);

# 视图 GV$OB_SQL_AUDIT 在系统租户下才能查看，多次执行时以前结果还会存在，所以暂时注释掉
connection conn1;
--echo # 修改租户级配置项,重写功能开启
alter system set enable_user_defined_rewrite_rules = 'ON';
set @@sql_mode='strict_all_tables';

--echo >>>>>>>>>>>>>>>>>>>>>>>>>>> qr-mysql-7 补充功能测试 <<<<<<<<<<<<<<<<<<<<<<<<<
--echo ######## qr-mysql-7-1 相同 pattern 相同replacement
--echo ## 禁用最先创建的规则后是否第二时间创建的规则被启用，查看视图及sql_audit
call dbms_udr.remove_rule ('rule1');
call dbms_udr.remove_rule ('rule2');
call dbms_udr.remove_rule ('rule3');
call dbms_udr.create_rule(
  'rule1',
  'whh1',
  'select :A,:B from dual', 
  'select :A*2,:B*2 from dual',
  'YES');

call dbms_udr.create_rule(
  'rule2',
  'whh1',
  'select :A,:B from dual', 
  'select :A*2,:B*2 from dual',
  'YES');

call dbms_udr.create_rule(
  'rule3',
  'whh1',
  'select :A,:B from dual', 
  'select :A*2,:B*2 from dual',
  'YES');

SELECT DB_NAME,RULE_NAME,PATTERN,REPLACEMENT,NORMALIZED_PATTERN,STATUS FROM OCEANBASE.DBA_OB_USER_DEFINED_RULES;
sleep 5;
select 10,20 from dual;
#connection conn2;
#SELECT TENANT_NAME,USER_NAME,DB_NAME,QUERY_SQL,RULE_NAME FROM GV$OB_SQL_AUDIT WHERE DB_NAME='WHH1' AND QUERY_SQL = 'SELECT 10,20 FROM DUAL';

