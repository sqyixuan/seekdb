--disable_warnings
drop database if exists tc_column_zerofill;
create database tc_column_zerofill;
use tc_column_zerofill;


DROP TABLE  IF EXISTS t4;
--enable_warnings
CREATE TABLE t4(c1 TINYINT   ZEROFILL NULL);
SHOW TABLES;

insert into t4 values(1);
select * from t4;

