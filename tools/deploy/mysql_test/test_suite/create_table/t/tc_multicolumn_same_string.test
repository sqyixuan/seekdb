--disable_warnings
drop database if exists tc_multicolumn_same_string;
--enable_warnings

create database tc_multicolumn_same_string;
use tc_multicolumn_same_string;

--disable_warnings
DROP TABLE IF EXISTS m2;
--enable_warnings
CREATE TABLE m2(c1 CHAR(1) NULL, c2 CHAR(5) NOT NULL, c3 CHAR(255) NULL, c4 CHAR(4) NOT NULL PRIMARY KEY, c5 CHAR(30) NOT NULL UNIQUE KEY);
