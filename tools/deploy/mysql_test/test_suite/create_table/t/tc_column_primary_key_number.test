# 当 pk 的列族中存在在建表时显式声明 default value 的列，mysql 模式下应该建表失败并报错
--error 1171
create table t1(c1 BIT default null, primary key(c1));
--error 1171
create table t1(c1 TINYINT default null, primary key(c1));
--error 1171
create table t1(c1 SMALLINT default null, primary key(c1));
--error 1171
create table t1(c1 MEDIUMINT default null, primary key(c1));
--error 1171
create table t1(c1 INT default null, primary key(c1));
--error 1171
create table t1(c1 INTEGER default null, primary key(c1));
--error 1171
create table t1(c1 BIGINT default null, primary key(c1));
--error 1171
create table t1(c1 DECIMAL default null, primary key(c1));
--error 1171
create table t1(c1 DEC default null, primary key(c1));
--error 1171
create table t1(c1 NUMERIC default null, primary key(c1));
--error 1171
create table t1(c1 DOUBLE default null, primary key(c1));
--error 1171
create table t1(c1 REAL default null, primary key(c1));
--error 1171
create table t1(c1 FLOAT default null, primary key(c1));
--error 1171
create table t1(c1 DATE default null, primary key(c1));
--error 1171
create table t1(c1 TIME default null, primary key(c1));
--error 1171
create table t1(c1 DATETIME default null, primary key(c1));
--error 1171
create table t1(c1 YEAR default null, primary key(c1));

# 测试由多列构成的 pk 中，至少有一列在建表时被声明为 default null 的情况，mysql 模式下应该建表失败并报错
--error 1171
create table t1(c1 int, c2 int default null, primary key(c1, c2));
--error 1171
create table t1(c1 int default null, c2 int default null, primary key(c1, c2));

drop database tc_column_primary_key_number;
