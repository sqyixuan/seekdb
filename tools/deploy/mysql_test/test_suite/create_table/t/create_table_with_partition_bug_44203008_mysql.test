--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL2
# description: test escapse character in part_name
# bugfix#

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1(a bigint, b date)partition by range columns(b) 
(
    partition part_1 values less than ('2016-09-01'),
    partition `part_1\b` values less than ('2020-09-01')
);

INSERT INTO t1 VALUES(1,'2010-11-21');

INSERT INTO t1 VALUES(2,'2018-12-23');

SELECT * FROM t1 PARTITION (`part_1\b`);
