# owner: rongxuan.lc
# description: 本case是为了验证建分区表超过1000时的汇报问题；
#

--disable_warnings
drop database if exists db_create;
create database db_create;
use db_create;
set ob_query_timeout=100000000;
--enable_warnings

##create table
create table test(c1 int primary key, c2 int) partition by hash(c1) partitions 1024;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
##检查主存在；
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'test', table_id, 1);
connection default;
##写入数据；
let $count = 2049;
while ($count > 0)
{
  eval insert into test values($count, 1);
  dec $count;
}

drop database db_create;
