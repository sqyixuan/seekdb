--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: lijinmao.ljm
# owner group: sql1
# tags: ddl

--disable_warnings
drop table if exists flyway_schema_history, flyway_schema_history1, flyway_schema_history2;
--enable_warnings

create table `flyway_schema_history` (
  `installed_rank` INT not null,
  `version` VARCHAR(50),
  `description` VARCHAR(200) not null,
  `type` VARCHAR(20) not null,
  `script` VARCHAR(1000) not null,
  `checksum` INT,
  `installed_by` VARCHAR(100) not null,
  `installed_on` TIMESTAMP not null default CURRENT_TIMESTAMP,
  `execution_time` INT not null,
  `success` BOOL not null,
  constraint `flyway_schema_history_pk` primary key (`installed_rank`)
) as
select
	1 as "installed_rank",
	'1' as "version",
	'<< Flyway Baseline >>' as "description",
	'BASELINE' as "type",
	'<< Flyway Baseline >>' as "script",
	null as "checksum",
	'test' as "installed_by",
	CURRENT_TIMESTAMP as "installed_on",
	0 as "execution_time",
	true as "success";

create table `flyway_schema_history1` as
select
	1 as "installed_rank",
	'1' as "version",
	'<< Flyway Baseline >>' as "description",
	'BASELINE' as "type",
	'<< Flyway Baseline >>' as "script",
	null as "checksum",
	'test' as "installed_by",
	CURRENT_TIMESTAMP as "installed_on",
	0 as "execution_time",
	true as "success";

create table `flyway_schema_history2` (
  `installed_rank` INT not null,
  `version` VARCHAR(50),
  `description` VARCHAR(200) not null,
  `type` VARCHAR(20) not null,
  `script` VARCHAR(1000) not null,
  `checksum` INT,
  `installed_by` VARCHAR(100) not null,
  `installed_on` TIMESTAMP not null default CURRENT_TIMESTAMP,
  `execution_time` INT not null,
  `success` BOOL not null,
  constraint `flyway_schema_history_pk` primary key (`installed_rank`)
) as
select
	1 as "installed_rank",
  1 as "installed_rank1",
	'1' as "version",
  '1' as "version1",
	'<< Flyway Baseline >>' as "description",
	'BASELINE' as "type",
	'<< Flyway Baseline >>' as "script",
	null as "checksum",
	'test' as "installed_by",
	CURRENT_TIMESTAMP as "installed_on",
	0 as "execution_time",
	true as "success";

--result_format 4

desc flyway_schema_history;
desc flyway_schema_history1;
desc flyway_schema_history2;

drop table flyway_schema_history, flyway_schema_history1, flyway_schema_history2;