# owner: bin.lb
# owner group: SQL3
# description: 指定column id 建表
# tags: ddl

--result_format 4
--disable_warnings
#use drc user
create user if not exists __oceanbase_inner_drc_user;
grant all privileges on *.* to __oceanbase_inner_drc_user;
--source mysql_test/include/check_schema_sync.inc
connect (conn_drc,$OBMYSQL_MS0,__oceanbase_inner_drc_user,,oceanbase,$OBMYSQL_PORT);
connection conn_drc;
drop database if exists jx_db;
create database jx_db;
use jx_db;
drop table if exists tt0, tt1,tt2,tt3,tt4,tt5,tt6;

--error 1064
create table tt0 (i int primary key id 1, j int id -1);
create table tt1 (i int primary key id 19, j int id 20);
--error 1210
create table tt2 (i int primary key id 1, j int id 2);
--error 1210
create table tt3 (i int primary key id 0, j int id 3);
--error 1210
create table tt4 (i int primary key id 11110, j int id 311111);

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
select table_name, column_name, column_id from oceanbase.__all_virtual_table a, oceanbase.__all_virtual_column b where a.database_id in ( select database_id from oceanbase.__all_virtual_database where database_name='jx_db') and a.table_name like 'tt%' and b.table_id = a.table_id order by 1, 2,3;
disconnect obsys;
connection conn_drc;

drop table if exists tt0, tt1,tt2,tt3,tt4,tt5,tt6;

create table tt1 (i int primary key, j int id 20);
--error 1210
create table tt2 (i int primary key, j int id 2);
--error 1210
create table tt3 (i int primary key, j int id 3);
--error 1210
create table tt4 (i int primary key, j int id 311111);

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
select table_name, column_name, column_id from oceanbase.__all_virtual_table a, oceanbase.__all_virtual_column b where a.database_id in ( select database_id from oceanbase.__all_virtual_database where database_name='jx_db') and a.table_name like 'tt%' and b.table_id = a.table_id order by 1, 2,3;
disconnect obsys;
connection conn_drc;

drop table if exists tt0, tt1,tt2,tt3,tt4,tt5,tt6;

--error 4029
create table tt1 (i int primary key, j int id 16);
create table tt2 (i int primary key, j int id 17);
create table tt3 (i int primary key, j int id 18);
create table tt4 (i int primary key id 16, j int);
--error 4029
create table tt5 (i int primary key id 17, j int);
create table tt6 (i int primary key id 18, j int);


drop table if exists tt_base_table_virtual_1;
create table if not exists tt_base_table_virtual_1(c1 varchar(10) primary key id 17, c2 varchar(8) generated always as (substring(c1, 2)) virtual id 22, c3 int id 33) partition by key(c2) partitions 5;
insert into tt_base_table_virtual_1 (c1, c3) values('abcde', 10);
select * from tt_base_table_virtual_1;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
select table_name, column_name, column_id from oceanbase.__all_virtual_table a, oceanbase.__all_virtual_column b where a.database_id in ( select database_id from oceanbase.__all_virtual_database where database_name='jx_db') and a.table_name like 'tt%' and b.table_id = a.table_id order by 1, 2,3;
disconnect obsys;
connection conn_drc;

drop table if exists tt0, tt1,tt2,tt3,tt4,tt5,tt6,tt_base_table_virtual_1;
drop database if exists jx_db;
drop user __oceanbase_inner_drc_user;
set @@recyclebin = on;
