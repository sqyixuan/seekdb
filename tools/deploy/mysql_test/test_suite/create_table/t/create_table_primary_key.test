--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: link.zt
# owner group: SQL3
# description:
#   测试建表的时候主键不容许设置成NULL；
#   测试建表的时候指定主键index type

--disable_warnings
drop table if exists t1;
--enable_warnings

--error 1171
create table t1(c1 int, c2 timestamp null primary key);

--error 1171
create table t1(c1 int, c2 timestamp null, primary key(c2));

--error 1171
create table t1(c1 int null, c2 int, primary key(c1));


--disable_warnings
drop database if exists jx_db;
--enable_warnings
create database jx_db;
use jx_db;
create table jx_t1(c1 int, c2 int, primary key using btree (c2));
create table jx_t2(c1 int, c2 int, primary key using hash (c2));

create table jx_t3(c1 int, c2 timestamp, primary key (c2) using btree);
create table jx_t4(c1 int, c2 timestamp, primary key (c2) using hash);

create table jx_t5(c1 int, c2 timestamp, primary key using btree (c2) using btree);
create table jx_t6(c1 int, c2 timestamp, primary key using hash (c2) using hash);

create table jx_t7(c1 int, c2 timestamp, primary key using hash (c2) using btree);
create table jx_t8(c1 int, c2 timestamp, primary key using btree(c2) using hash);
# bugfix:15759741
create table test(collect int);
drop database jx_db;
