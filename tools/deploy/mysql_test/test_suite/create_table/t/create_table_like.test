--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql2
#description: todo
#tags: ddl
--disable_warnings
drop database if exists hualong;
drop database if exists hualong2;
--enable_warnings

create database hualong;

use hualong;

# local index with partition table
create table t1(c1 int, c2 int) partition by hash(c2+c1) partitions 4;
insert into t1 values (1, 10);
create index i1 on t1(c2) local;
insert into t1 values (2, 2);
create table t2 like t1;
insert into t2 values (1, 10);
insert into t2 values (2, 11);
select * from t2 order by c2;
show index from t2;
select count(*) from information_schema.partitions where table_name = 't2';
drop table t1, t2;

create table t1 (c1 int primary key, c2 int, c3 varchar(11) default 'column3');
insert into t1(c1,c2) values (1,2), (3,4);
desc t1;
create table t2 like t1;
create table ttt (like t1);
create table tttt (like t2);
desc t2;

create index idx1 on t1 (c2);
create unique index uidx on t1 (c1, c3);
--source mysql_test/include/check_all_idx_ok.inc
show index from t1;
create table hualong.t3 like hualong.t1;
desc t3;
--source mysql_test/include/check_all_idx_ok.inc
show index from t3;

##like a view
create view v1 as select * from t1;
create view v2 as select * from t2;

--error ER_WRONG_OBJECT
create table hualong2.view1 like v1;

##view v2 exist
--error ER_WRONG_OBJECT
create table v2 like v1;

--error ER_TABLE_EXISTS_ERROR
create table t2 like t1;

--error ER_BAD_DB_ERROR
create table hualong2.v1 like t1;

##target table not exist
--error ER_NO_SUCH_TABLE
create table t4 like txxx;

--error ER_BAD_DB_ERROR
create table t4 like hualong2.txxx;

#if not exist
--error ER_WRONG_OBJECT
create table if not exists v2 like v1;

#should report warning
--disable_warnings
create table if not exists t3 like t1;
--enable_warnings
create table if not exists t4 like t1;
show tables from hualong;

--error ER_NONUNIQ_TABLE 
create table t1 like t1;

create database hualong2;
create table hualong2.t5 like hualong.t1;
insert into hualong2.t5 values (1,2,'a'), (3,4,'b');
select * from hualong2.t5;
show tables from hualong2;
show tables from hualong;
--source mysql_test/include/check_all_idx_ok.inc
show index from hualong2.t5;

#
create table hualong.t6(c1 int primary key, c2 varchar(11), c3 char(11), c4 date, index i1 (c1), unique i2 (c1, c2));
alter table hualong.t6 add index i3(c3);
alter table hualong.t6 add unique index i4(c1, c4);
--source mysql_test/include/check_all_idx_ok.inc
show index from hualong.t6;
connect (jx_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection jx_obsys;
alter system suspend merge;
--source mysql_test/include/majorfreeze.inc
connection default;
create table hualong.t6_like like hualong.t6;
connection jx_obsys;
alter system resume merge;
--source mysql_test/include/wait_daily_merge.inc
--source mysql_test/include/check_all_idx_ok_unq.inc
connection default;
--source mysql_test/include/check_all_idx_ok.inc
show index from hualong.t6_like;

#create table like based on system table
--error ER_WRONG_OBJECT
create table backup__all_auto_increment like oceanbase.__all_auto_increment;
#connection jx_obsys;
#select table_type from oceanbase.__all_virtual_table where table_id = (select max(table_id) table_id from oceanbase.__all_virtual_table where table_name = 'backup__all_auto_increment');
connection default;

--error ER_WRONG_OBJECT
create table jx_like_virtual like oceanbase.__tenant_virtual_warning;
#select table_type from oceanbase.__all_virtual_table where table_id = (select max(table_id) table_id from oceanbase.__all_virtual_table where table_name = 'jx_like_virtual');

--error ER_WRONG_OBJECT
create table jx_like_sys_view like oceanbase.GV$OB_SQL_AUDIT;
#select table_type from oceanbase.__all_virtual_table where table_id = (select max(table_id) table_id from oceanbase.__all_virtual_table where table_name = 'jx_like_sys_view');

drop database hualong2;
drop database hualong;
