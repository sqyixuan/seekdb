# owner: xiaoyi.xy
# owner group: SQL3
# description: 本case是为了测试唯一索引键一定包含所有的分区键

--disable_warnings
drop table if exists test;
drop table if exists t1, t2, t3;
--enable_warnings

###主键覆盖
create table test(c1 int, c2 int) partition by hash(c1);
drop table test;
create table test(c1 int, c2 int) partition by hash(c1) partitions 4;
drop table test;
create table test(c1 int primary key, c2 int) partition by hash(c1) partitions 4;
drop table test;
--error 1503
create table test(c1 int primary key, c2 int) partition by hash(c2) partitions 4;
create table test(c1 int, c2 int, c3 int) partition by hash(c2+c1);
drop table test;
create table test(c1 int, c2 int, c3 int, primary key(c1, c2)) partition by hash(c2+c1);

###唯一索引覆盖
drop table test;
--error 1503
create table test(c1 int primary key, c2 int unique key) partition by hash(c2);
create table test(c1 int, c2 int unique key, primary key(c1,c2)) partition by hash(c2);
drop table test;
create table test(c1 int, c2 int, c3 int, primary key(c1,c2), unique key(c2,c3)) partition by hash(c2);
drop table test;

###索引
create table test(c1 int primary key, c2 int, index(c2)) partition by hash(c1);
drop table test;
create table test(c1 int, c2 int, c3 int, primary key(c1,c2),  index(c2,c3)) partition by hash(c2);
drop table test;

#####多个索引
create table test(c1 int, c2 int, c3 int, c4 int, primary key(c1), unique key(c1, c2), key(c2,c3)) partition by hash(c1);
drop table test;

####create index
create table test(c1 int primary key, c2 int, c3 int) partition by hash(c1);
create index t_index on test (c1, c2);
create unique index t_index3 on test(c1,c3);
drop table test;
###alter table add unique key
create table test(c1 int, c2 int) partition by hash(c2);
alter table test add index(c1) local;
alter table test add column c3 int;
###alter table add primary key
--error 1503
alter table test add primary key(c1);
alter table test add primary key(c2);
sleep 3;
### alter table add column c4 primary key
drop table test;
create table test(c1 int, c2 int) partition by hash(c2);
--error 1235
alter table test add column c4 int primary key;
alter table test modify column c2 int primary key;
###alter table add column c4 unique key;
##
#link.zt: 修复该bug，取消下行的注释
drop table test;

##无主键
create table test(c1 int, c2 int) partition by hash(c2) partitions 4;
drop table test;
create table test(c1 int, c2 int) partition by key(c1) partitions 4;
drop table test;
create table test(c1 int, c3 int) partition by hash(abs(c1) + c3) partitions 4;
drop table test;

##自增键
--error 1503
create table test(c1 int auto_increment primary key, c2 int) partition by hash(c2) partitions 4;

create table test(c1 int auto_increment primary key, c2 int) partition by hash(c1) partitions 4;
drop table test;

#####增加一些其他case,比如partition by key, c1+c2, hash(abs(c1) + 1), hash(abs(c2)+ c1),
#primary 和unique key集合互相包含的情况 c1 + c2 + abs(c1)

create table test(c1 int primary key, c2 int) partition by key(c1) partitions 4;
drop table test;
--error 1503
create table test(c1 int primary key, c2 int) partition by key(c2) partitions 4;
--error 1503
create table test(c1 int primary key, c2 int, unique key(c1, c2)) partition by hash(c1+c2) partitions 4;
--error 1503
create table test(c1 int primary key, c2 int, unique key(c1, c2)) partition by hash(abs(c1) + c2) partitions 4;
--error 1503
create table test(c1 int primary key, c2 int, unique key(c1, c2) local) partition by hash(abs(c1) + c2) partitions 4;
create table test(c1 int primary key, c2 int, index(c1, c2) local) partition by key(c1) partitions 4;
drop table test;
--error 1503
create table test(c1 int primary key, c2 int) partition by hash(abs(c2) + c1) partitions 4;
create table test(c1 int, c2 int, primary key(c1,c2)) partition by hash(abs(c2) + c1) partitions 4;
drop table test;
create table test(c1 int, c2 int, c3 int, c4 char, primary key(c1, c3), index(c2,c3) local) partition by hash(abs(c1) + c3) partitions 4;
drop table test;
--error 1503
create table test(c1 int, c2 int, c3 int, c4 char, primary key(c1, c3), unique index(c2,c3) local) partition by hash(abs(c1) + c3) partitions 4;
--error 1503
create table test(c1 int, c2 int, c3 int, c4 char, primary key(c1, c3), unique index(c2,c3)) partition by hash(abs(c1 + c2) + c3) partitions 4;
create table test(c1 int, c2 int, c3 int, c4 char, primary key(c1, c3, c2), unique index(c1, c2,c3) LOCAL) partition by hash(abs(c1 + c2) + c3) partitions 4;
drop table test;
--error 1503
create table test(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, primary key(c1), unique index(c1,c4)local, unique index(c2, c4)local) partition by hash(c1 + c4) partitions 4;
--error 1503
create table test(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, primary key(c1), unique index(c1,c4), unique index(c2, c4)) partition by hash(abs(c1+c2) + c4) partitions 4;
--error 1503
create table test(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, primary key(c1, c4), unique index(c1,c4) local, unique index(c2, c4)local) partition by hash(abs(c1+c2) + c4) partitions 4;
create table test(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, primary key(c1, c4, c2, c6), unique index(c1,c4, c2) local, unique index(c2, c4, c6,c1)local) partition by hash(abs(c1+c2) + c4) partitions 4;
drop table test;

# 测试 mysql 模式下，建表时主键和唯一索引能建到完全相同（包括顺序）的列或列族上
create table t1(c1 int, c2 int, primary key(c1), constraint t1_uk1 unique(c1));
create table t2(c1 int, c2 int, primary key(c1, c2), constraint t1_uk1 unique(c1, c2));
create table t3(c1 int, c2 int, c3 int, primary key(c1, c2, c3), constraint t1_uk1 unique(c1, c2, c3));
drop table t1,t2,t3;

# 测试 mysql 模式下，建表时唯一索引和唯一索引能建到完全相同（包括顺序）的列或列族上
create table t1(c1 int, c2 int, constraint t1_uk1 unique(c1), constraint t1_uk2 unique(c1));
create table t2(c1 int, c2 int, constraint t1_uk1 unique(c1, c2), constraint t1_uk2 unique(c1, c2));
create table t3(c1 int, c2 int, c3 int, constraint t1_uk1 unique(c1, c2, c3), constraint t1_uk2 unique(c1, c2, c3));
drop table t1,t2,t3;
