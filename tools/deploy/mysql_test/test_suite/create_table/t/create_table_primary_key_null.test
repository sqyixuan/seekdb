--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: 本case是为了测试建表的时候主键不容许设置成NULL；

--disable_warnings
drop table if exists t1;
--enable_warnings

--error 1171
create table t1(c1 int, c2 timestamp null primary key);

--error 1171
create table t1(c1 int, c2 timestamp null, primary key(c2));

--error 1171
create table t1(c1 int null, c2 int, primary key(c1));
