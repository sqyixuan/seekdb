--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
 
 
--disable_warnings
drop table if exists t1,t2;
--enable_warnings

CREATE TABLE t1(c0 INT(5) ZEROFILL);
INSERT INTO t1 VALUES(1),(2), (3), (4), (5), (6);

CREATE TABLE t2 AS SELECT * FROM t1;

--result_format 4 
SELECT c0 FROM t1;
SELECT c0 FROM t2;

drop table t1,t2;