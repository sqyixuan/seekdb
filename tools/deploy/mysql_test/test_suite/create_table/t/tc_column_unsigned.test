--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql2
#description: todo

--disable_warnings
drop database if exists tc_column_unsigned;
create database tc_column_unsigned;
use tc_column_unsigned;

DROP TABLE IF EXISTS t3;
--enable_warnings
CREATE TABLE t3(c1 TINYINT UNSIGNED NULL);
SHOW TABLES;


--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t3;
DROP TABLE IF EXISTS t3;
SHOW TABLES;
CREATE TABLE t3(c1 SMALLINT UNSIGNED NULL);
SHOW TABLES;


