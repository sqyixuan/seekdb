--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
#description: create table as select 

--result_format 4

--disable_warnings
drop table if exists t1, t2, t3, t4, t5, t6, t7, t8, t9, is_ac_user, tmp_user;
--enable_warnings

create table t1(a int, b int);
CREATE TABLE `is_ac_user` (
 `USER_ID` bigint(10) NOT NULL,
 `USER_NAME` varchar(50) NOT NULL,
 `PASSWORD` varchar(100) DEFAULT NULL,
 `REAL_NAME` varchar(200) NOT NULL,
 `CERTI_CODE` varchar(50) DEFAULT NULL,
 `USER_CATE` decimal(3,0) DEFAULT NULL,
 `HEAD_ID` decimal(3,0) DEFAULT NULL,
 `ORGAN_ID` varchar(40) DEFAULT NULL,
 `DEPT_CODE` varchar(40) DEFAULT NULL,
 `RAW_STAFF_ID` decimal(10,0) DEFAULT NULL,
 `PWD_CHANGE` datetime DEFAULT CURRENT_TIMESTAMP,
 `PWD_NEED_CHANGE` varchar(3) NOT NULL DEFAULT 'Y',
 `DISABLED` varchar(3) NOT NULL DEFAULT 'N',
 `DISABLE_CAUSE` decimal(3,0) DEFAULT NULL,
 `INVALID_LOGIN` decimal(10,0) NOT NULL DEFAULT '0',
 `LATEST_IP` varchar(100) DEFAULT NULL,
 `LATEST_IP_OLD` varchar(100) DEFAULT NULL,
 `LATEST_LOGIN_TIME` datetime DEFAULT CURRENT_TIMESTAMP,
 `LATEST_LOGIN_OLD` datetime DEFAULT NULL,
 `LATEST_LOGOUT_TIME` datetime DEFAULT NULL,
 `LATEST_ACCESS_TIME` datetime DEFAULT NULL,
 `FCD` datetime DEFAULT CURRENT_TIMESTAMP,
 `FCU` decimal(10,0) DEFAULT NULL,
 `LCD` datetime DEFAULT NULL,
 `LCU` decimal(10,0) DEFAULT NULL,
 `IS_FIRST_LOGIN` decimal(10,0) DEFAULT '1',
 `IS_LOCKED` decimal(10,0) DEFAULT NULL,
 `ENCRYPTION` decimal(1,0) DEFAULT '1',
 `LOCKED_TIME` datetime DEFAULT NULL,
 `LOCKED_TYPE` decimal(1,0) DEFAULT NULL,
 `RAW_STAFF_CODE` varchar(40) DEFAULT NULL,
 `PACKAGE_NOTE` varchar(50) DEFAULT NULL,
 `ETL_NOTE` varchar(50) DEFAULT NULL,
 `USER_STATUS` decimal(1,0) NOT NULL DEFAULT '0',
 `PROCEDURE_NOTE` varchar(250) DEFAULT NULL,
  PRIMARY KEY (`USER_ID`)
)partition by hash(`user_id`) partitions 18;

--disable_query_log
--disable_result_log
insert into t1 values (1, 1), (2, 2);
select count(*) from t1;
--enable_query_log
--enable_result_log

create table t2 as select 1, 2 from dual;
select * from t2;

create table t3 as select (@i:=1) from dual;
select * from t3;

create table t4 as select count(*) from t1;
select * from t4;

create table t5 as select a + 1, b from t1;
select * from t5;

create table t6 as select a + 1 a1, b from t1;
select * from t6;

create table t7 as select (@i:=1), b + @i from t1;
select * from t7;

CREATE TABLE tmp_user as SELECT user_id,organ_id,branch_id,seq,CONCAT('etest',SUBSTR(organ_id,1,3),'_',seq,'@agent') 
AS user_name FROM ( SELECT a.user_id,a.organ_id, (@i:=CASE WHEN SUBSTR(a.organ_id,1,3)=@branch THEN @i+1 ELSE 1 END) AS seq,
(@branch:=CASE WHEN SUBSTR(a.organ_id,1,3)=@branch THEN @branch ELSE SUBSTR(a.organ_id,1,3) END) AS branch_id FROM is_ac_user a,
(SELECT @i:=0,@branch:='0') t WHERE a.user_cate=104 AND a.disabled='N' ORDER BY SUBSTR(a.organ_id,1,3),a.user_id ) a;
select * from tmp_user;

create table t8 (login_id varchar(60));
create table t9 as select (@i:=case when @pre_parent_code=login_id then @i+1 else 1 end ) rownum,(@pre_parent_code:=login_id) con,login_id from (select * from t8 limit 4) c, (select @i:=0,@pre_parent_code:='') as a;

drop table t1, t2, t3, t4, t5, t6, t7, t8, t9, is_ac_user, tmp_user;

create table t1 (c1 decimal(65, 30), c2 decimal(65, 30));
create table t2 as select (c1 + c2) as add_op, (c1 - c2) as minus_op, (c1 * c2) as mul_op, (c1 / c2) as div_op, (c1 + c2 - c1 * c2 + c1 / c2) as mix from t1;
desc t2;
drop table t1, t2;

--disable_warnings
drop table if exists t1, t2, t3, t4, t5, t6;
--enable_warnings

CREATE TABLE t1(name char(50) DEFAULT '111');
CREATE TABLE t2(name char(50)) AS SELECT * FROM t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
CREATE TABLE t3(name char(5)) AS SELECT * FROM t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t3;
CREATE TABLE t4 AS SELECT * FROM t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t4;
alter table t1 alter column name set default '222';
create table t5 as select * from t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
create table t6 as select name as a from t1;
CREATE TABLE t7(c0 INT(3), c1 INT GENERATED ALWAYS AS (c0*2) STORED COMMENT '数值生成列');
CREATE TABLE t8 AS SELECT * FROM t7;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t8;

--disable_warnings
drop table if exists t1, t2, t3, t4, t5, t6, t7;
--enable_warnings

create table t1 select 1 as a, 'aaa' as b, 2.5 as c, 25E-1 as d;
describe t1;
create table t2 as select 1 as a, 'aaa' as b, 2.5 as c, 25E-1 as d from dual;
describe t2;
create table t3(a bigint(1), b varchar(3), c decimal(2,1), d double);
describe t3;
create table t4 select benchmark(0,0);
describe t4;
create table t5 as select 1, benchmark(0,0);
describe t5;
create table t6 as select 1, 1.0, 1E3, 'a', TRUE, 5-1, NULL;
describe t6;
create table t7 as select c, c+c, c+1, 1+1 from t1;
describe t7;

drop table t1, t2, t3, t4, t5, t6, t7;

--disable_result_log
