--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql2
#description: todo

--disable_warnings
drop database if exists tc_column_primary_key_string;
create database tc_column_primary_key_string;
use tc_column_primary_key_string;


DROP TABLE IF EXISTS t9;
--enable_warnings
CREATE TABLE t9(c1 CHAR(10) NOT NULL PRIMARY KEY);
SHOW TABLES;


--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t9;
DROP TABLE IF EXISTS t9;
SHOW TABLES;
CREATE TABLE t9(c1 VARCHAR(10) NOT NULL PRIMARY KEY);
SHOW TABLES;


--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t9;
DROP TABLE IF EXISTS t9;
SHOW TABLES;
CREATE TABLE t9(c1 BINARY(10) NOT NULL PRIMARY KEY);
SHOW TABLES;


--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t9;
DROP TABLE IF EXISTS t9;
SHOW TABLES;
CREATE TABLE t9(c1 VARBINARY(10) NOT NULL PRIMARY KEY);
SHOW TABLES;


--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t9;
DROP TABLE IF EXISTS t9;
SHOW TABLES;

# 当 pk 的列族中存在在建表时显式声明 default value 的列，mysql 模式下应该建表失败并报错
--error 1171
create table t1(c1 CHAR(10) default null, primary key(c1));
--error 1171
create table t1(c1 VARCHAR(10) default null, primary key(c1));
--error 1171
create table t1(c1 BINARY(10) default null, primary key(c1));
--error 1171
create table t1(c1 VARBINARY(10) default null, primary key(c1));

# 测试由多列构成的 pk 中，至少有一列在建表时被声明为 default null 的情况，mysql 模式下应该建表失败并报错
--error 1171
create table t1(c1 CHAR(10), c2 CHAR(10) default null, primary key(c1, c2));
--error 1171
create table t1(c1 CHAR(10) default null, c2 CHAR(10) default null, primary key(c1, c2));

drop database tc_column_primary_key_string;
