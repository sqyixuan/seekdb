--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql2
#description: todo

--disable_warnings
drop database if exists tc_column_autoincrement;
create database tc_column_autoincrement;
use tc_column_autoincrement;


DROP TABLE IF EXISTS t8;
--enable_warnings
CREATE TABLE t8(c1 TINYINT NOT NULL AUTO_INCREMENT PRIMARY KEY);
SHOW TABLES;
