# owner: dachuan.sdc
# owner group: SQL
# description: 本case是为了测试唯一索引键一定包含所有的分区键

--disable_warnings
drop database if exists hualong;
drop table if exists test;
--enable_warnings
create database hualong;

###主键覆盖
create table test(c1 int, c2 int) partition by range(c1) (partition p2 values less than MAXVALUE);
drop table test;
create table test(c1 int, c2 int) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;

create table test(c1 int primary key, c2 int) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;

--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table test(c1 int primary key, c2 int) partition by range(c2) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);

create table test(c1 int, c2 int, c3 int) partition by range(c2+c1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);

drop table test;
create table test(c1 int, c2 int, c3 int, primary key(c1, c2)) partition by range(c2+c1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);


###唯一索引覆盖 只有一个partition
drop table test;
create table test(c1 int primary key, c2 int, unique key (c2) global) partition by range(c1) (partition p2 values less than MAXVALUE);
drop table test;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table test(c1 int primary key, c2 int unique key) partition by range(c2) (partition p2 values less than MAXVALUE);

create table test(c1 int, c2 int unique key, primary key(c1,c2)) partition by range(c2) (partition p2 values less than MAXVALUE);
drop table test;

create table test(c1 int, c2 int, c3 int, primary key(c1,c2), unique key(c1,c3) global) partition by range(c2) (partition p2 values less than MAXVALUE);
drop table test;

create table test(c1 int, c2 int, c3 int, primary key(c1,c2), unique key(c2,c3)) partition by range(c2) (partition p2 values less than MAXVALUE);
drop table test;
### 唯一索引，包含多个partition
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table test(c1 int, c2 int, c3 int, primary key(c1,c2), unique key(c1,c3) local) partition by range(c2) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);

create table test(c1 int, c2 int, c3 int, primary key(c1,c2), unique key(c2,c3) local) partition by range(c2) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;

###普通索引
create table test(c1 int primary key, c2 int, index(c2)) partition by range(c1) (partition p2 values less than MAXVALUE);
drop table test;
create table test(c1 int, c2 int, c3 int, primary key(c1,c2),  index(c2,c3)) partition by range(c2) (partition p2 values less than MAXVALUE);
drop table test;
create table test(c1 int primary key, c2 int, index(c2) local) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;
create table test(c1 int, c2 int, c3 int, primary key(c1,c2),  index(c2,c3) local) partition by range(c2) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;

#####多个索引
create table test(c1 int, c2 int, c3 int, c4 int, primary key(c1), unique key(c1, c2), key(c2,c3)) partition by range(c1) (partition p2 values less than MAXVALUE);
drop table test;

create table test(c1 int, c2 int, c3 int, c4 int, primary key(c1), unique key(c1, c2) local, key(c2,c3) local) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;

--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table test(c1 int, c2 int, c3 int, c4 int, primary key(c1), unique key(c1, c2) local, unique key(c2,c3) local) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);

####create index
create table test(c1 int primary key, c2 int, c3 int) partition by range(c1) (partition p2 values less than MAXVALUE);
create index t_index on test (c1, c2);
create unique index t_index2 on test(c2) global;
create unique index t_index3 on test(c1,c3);
drop table test;

create table test(c1 int primary key, c2 int, c3 int) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
create index t_index on test (c1, c2) local;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create unique index t_index2 on test(c2) local;
create unique index t_index3 on test(c1,c3) local;
drop table test;

###alter table add unique key
create table test(c1 int, c2 int primary key) partition by range(c2) (partition p2 values less than MAXVALUE);
alter table test add index(c1) local;
alter table test add column c3 int;
alter table test add unique index(c2) local;
###alter table add column c4 unique key;
--error 1503
alter table test add column c4 int unique key;
drop table test;

create table test(c1 int, c2 int) partition by range(c2) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
alter table test add index(c1) local;
alter table test add column c3 int;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
alter table test add unique index(c3) local;

###alter table add primary key
--error 1503
alter table test add primary key(c1);
alter table test add primary key(c2);
sleep 3;
### alter table add column c4 primary key
drop table test;
create table test(c1 int, c2 int) partition by range(c2) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
--error 1235
alter table test add column c4 int primary key;
alter table test modify column c2 int primary key;
drop table test;

##无主键
create table test(c1 int, c2 int) partition by range(c2) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;
create table test(c1 int, c3 int) partition by range(abs(c1) + c3) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;

##自增键
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table test(c1 int auto_increment primary key, c2 int) partition by range(c2) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
create table test(c1 int auto_increment primary key, c2 int) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;

#####增加一些其他case,比如partition by range, c1+c2, hash(abs(c1) + 1), hash(abs(c2)+ c1),
#primary 和unique key集合互相包含的情况 c1 + c2 + abs(c1)

--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table test(c1 int primary key, c2 int) partition by range(c2) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
--error 1503
create table test(c1 int primary key, c2 int, unique key(c1, c2)) partition by range(c1+c2) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
create table test(c1 int primary key, c2 int, unique key(c1, c2)) partition by range(abs(c1) + 1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;
--error 1503
create table test(c1 int primary key, c2 int, unique key(c1, c2)) partition by range(abs(c1) + c2) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
create table test(c1 int primary key, c2 int, index(c1, c2)) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table test(c1 int primary key, c2 int, unique key(c1, c2) local) partition by range(abs(c1) + c2) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table test(c1 int primary key, c2 int) partition by range(abs(c2) + c1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
create table test(c1 int, c2 int, primary key(c1,c2)) partition by range(abs(c2) + c1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;
create table test(c1 int, c2 int, c3 int, c4 char, primary key(c1, c3), index(c2,c3) local) partition by range(abs(c1) + c3) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;
create table test(c1 int, c2 int, c3 int, c4 char, primary key(c1, c3), index(c2,c3)) partition by range(abs(c1) + c3) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table test(c1 int, c2 int, c3 int, c4 char, primary key(c1, c3), unique index(c2,c3) local) partition by range(abs(c1) + c3) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
create table test(c1 int, c2 int, c3 int, c4 char, primary key(c1, c3), unique index(c2,c3) global) partition by range(abs(c1) + c3) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;
--error 1503
create table test(c1 int, c2 int, c3 int, c4 char, primary key(c1, c3), unique index(c2,c3)) partition by range(abs(c1 + c2) + c3) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
create table test(c1 int, c2 int, c3 int, c4 char, primary key(c1, c3, c2), unique index(c1, c2,c3) LOCAL) partition by range(abs(c1 + c2) + c3) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table test(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, primary key(c1), unique index(c1,c4)local, unique index(c2, c4)local) partition by range(c1 + c4) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
--error 1503
create table test(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, primary key(c1), unique index(c1,c4), unique index(c2, c4)) partition by range(abs(c1+c2) + c4) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table test(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, primary key(c1, c4), unique index(c1,c4) local, unique index(c2, c4)local) partition by range(abs(c1+c2) + c4) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
create table test(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, primary key(c1, c4, c2, c6), unique index(c1,c4, c2) local, unique index(c2, c4, c6,c1)local) partition by range(abs(c1+c2) + c4) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than MAXVALUE);
drop table test;
drop database hualong;
