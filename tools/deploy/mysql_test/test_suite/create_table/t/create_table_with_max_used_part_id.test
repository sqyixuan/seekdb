# owner: zhaoziqian.zzq
# owner group: RS
# description: 测试create table with max_used_part_id
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
set @@recyclebin = off;
--enable_query_log

let $index = 0;

#connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
#connection conn_sys;

# case 1: only __oceanbase_inner_drc_user can create table with max_used_part_id
--disable_warnings
drop database if exists ym_db;
--enable_warnings
eval create database ym_db;
use ym_db;

--error 1064
eval create table t1 (c1 int primary key, c2 int) max_used_part_id = 100;
--error 1064
eval create table t1 (c1 int primary key, c2 int) max_used_part_id = -1 partition by hash(c1) partitions 2;
--error 1064
eval create table t1 (c1 int primary key, c2 int) max_used_part_id = 100 partition by hash(c1) partitions 2;

--disable_warnings
eval drop table if exists t_with_max_used_part_id_$index;
--enable_warnings

eval create table t_with_max_used_part_id_$index (c1 int primary key, c2 int) partition by hash(c1) partitions 2;

# alter table with max_used_part_id not supported
--error 1064
eval alter table t_with_max_used_part_id_$index set max_used_part_id = -1;
--error 1064
eval alter table t_with_max_used_part_id_$index set max_used_part_id = 90;
--error 1064
eval alter table t_with_max_used_part_id_$index set max_used_part_id = 200;

--disable_warnings
eval drop table if exists t_with_max_used_part_id_$index;
--enable_warnings

drop database if exists ym_db;

# case 2: use __oceanbase_inner_drc_user
--disable_warnings
eval create user if not exists __oceanbase_inner_drc_user;
grant all privileges on *.* to __oceanbase_inner_drc_user;
drop database if exists ym_db;
eval create database ym_db;
--enable_warnings
--source mysql_test/include/check_schema_sync.inc
connect (conn_drc,$OBMYSQL_MS0,__oceanbase_inner_drc_user,,*NO-ONE*,$OBMYSQL_PORT);
connection conn_drc;
use ym_db;

# create non-partition table with max_used_part_id not supported
--error 1235
eval create table t1 (c1 int primary key, c2 int) max_used_part_id = 100;

# max_used_part_id invalid
--error 1064
eval create table t1 (c1 int primary key, c2 int) max_used_part_id = -1 partition by hash(c1) partitions 2;

# max_used_part_id less than partitions num
--error 1210
eval create table t1 (c1 int primary key, c2 int) max_used_part_id = 2 partition by hash(c1) partitions 4;
--error 1210
eval create table t1 (c1 int primary key, c2 int) max_used_part_id = 0 partition by range(c1) (partition p0 values less than (100), partition p1 values less than (MAXVALUE));
--error 1210
eval create table t1 (c1 int primary key, c2 int) max_used_part_id = 0 partition by list(c1) (partition p0 values in (0, 1), partition p2 values in (DEFAULT));

--error 1210
eval create table t1 (c1 int primary key, c2 int) max_used_part_id = 0 partition by hash(c1) subpartition by range(c1) subpartition template (subpartition p0 values less than (100), subpartition p1 values less than (200), subpartition p2 values less than (MAXVALUE)) partitions 2;
--error 1210
eval create table t1 (c1 int primary key, c2 int) max_used_part_id = 0 partition by range(c1) subpartition by hash(c1) subpartitions 2 (partition p0 values less than (100), partition p1 values less than (MAXVALUE));
--error 1210
eval create table t1 (c1 int primary key, c2 int) max_used_part_id = 0 partition by list(c1) subpartition by hash(c1) subpartitions 2 (partition p0 values in (0, 1), partition p1 values in (DEFAULT));

# max_used_part_id less than part_id
--error 1210
eval create table t1 (c1 int primary key, c2 int) max_used_part_id = 4 partition by range(c1) (partition p0 values less than (100) id 2, partition p1 values less than (MAXVALUE) id 5);
--error 1210
eval create table t1 (c1 int primary key, c2 int) max_used_part_id = 4 partition by range(c1) subpartition by hash(c1) subpartitions 2 (partition p0 values less than (100) id 2, partition p1 values less than (MAXVALUE) id 5);


# hash
inc $index;
connection conn_drc;
use ym_db;
--disable_warnings
eval drop table if exists t_with_max_used_part_id_$index;
--enable_warnings

eval create table t_with_max_used_part_id_$index (c1 int primary key, c2 int) max_used_part_id = 100 partition by hash(c1) partitions 2;

connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
connection conn_sys;
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = "t_with_max_used_part_id_$index", table_id, 1);
--replace_regex /table_id = "[0-9]*"/table_id = 1/g
eval select max_used_part_id from oceanbase.__all_virtual_table where table_id = "$table_id" order by max_used_part_id asc;
--replace_regex /table_id = "[0-9]*"/table_id = 1/g
eval select part_id from oceanbase.__all_virtual_part where table_id = "$table_id" order by part_id asc;
--replace_regex /table_id = "[0-9]*"/table_id = 1/g

eval select distinct(partition_id) as partition_id from oceanbase.__all_virtual_partition_table where table_id = "$table_id" order by partition_id asc;
connection conn_drc;
use ym_db;
# alter table with max_used_part_id not supported
--error 1064
eval alter table t_with_max_used_part_id_$index set max_used_part_id = -1;
--error 1064
eval alter table t_with_max_used_part_id_$index set max_used_part_id = 90;
--error 1064
eval alter table t_with_max_used_part_id_$index set max_used_part_id = 200;

--disable_warnings
eval drop table if exists t_with_max_used_part_id_$index;
--enable_warnings

# range
inc $index;
connection conn_drc;
use ym_db;
--disable_warnings
eval drop table if exists t_with_max_used_part_id_$index;
--enable_warnings

eval create table t_with_max_used_part_id_$index (c1 int primary key, c2 int) max_used_part_id = 100 partition by range(c1) (partition p0 values less than (100), partition p1 values less than (MAXVALUE));

