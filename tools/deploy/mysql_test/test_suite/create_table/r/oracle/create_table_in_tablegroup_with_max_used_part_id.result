create user if not exists __oceanbase_inner_drc_user;
grant all privileges on *.* to __oceanbase_inner_drc_user;
drop database if exists ym_db;
create database ym_db;
use ym_db;
drop tablegroup if exists tg_range;
create tablegroup tg_range partition by range (partition p0 values less than (100), partition p1 values less than (MAXVALUE));
drop table if exists t_in_tg_1;
create table t_in_tg_1(c1 int primary key, c2 int) tablegroup = "tg_range" max_used_part_id = 10 partition by range(c1) (partition p0 values less than (100) id 2, partition p1 values less than (maxvalue) id 5);
drop table if exists t_in_tg_2;
create table t_in_tg_2(c1 int primary key, c2 int) tablegroup = "tg_range" max_used_part_id = 20 partition by range(c1) (partition p0 values less than (100) id 7, partition p1 values less than (maxvalue) id 8);
alter tablegroup tg_range drop partition (p1);
alter tablegroup tg_range add partition (partition p1 values less than(200), partition p2 values less than(300));
