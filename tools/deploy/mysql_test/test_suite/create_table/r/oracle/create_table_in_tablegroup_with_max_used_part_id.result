drop tablegroup if exists tg_range_hash;
create tablegroup tg_range_hash partition by range subpartition by hash subpartitions 2 (partition p0 values less than (100), partition p1 values less than (MAXVALUE));
drop table if exists t_in_tg_3;
create table t_in_tg_3(c1 int primary key, c2 int) tablegroup = "tg_range_hash" max_used_part_id = 10 partition by range(c1) subpartition by hash(c1) subpartitions 2 (partition p0 values less than (100) id 2, partition p1 values less than (maxvalue) id 5);
drop table if exists t_in_tg_4;
create table t_in_tg_4(c1 int primary key, c2 int) tablegroup = "tg_range_hash" max_used_part_id = 20 partition by range(c1) subpartition by hash(c1) subpartitions 2 (partition p0 values less than (100) id 7, partition p1 values less than (maxvalue) id 8);
alter tablegroup tg_range_hash drop partition (p1);
alter tablegroup tg_range_hash add partition (partition p1 values less than(200), partition p2 values less than(300));
