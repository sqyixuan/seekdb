drop table if exists t1,t2;
CREATE TABLE t1(c0 INT(5) ZEROFILL);
INSERT INTO t1 VALUES(1),(2), (3), (4), (5), (6);
CREATE TABLE t2 AS SELECT * FROM t1;
result_format: 4 
SELECT c0 FROM t1;
+-------+
| c0    |
+-------+
| 00001 |
| 00002 |
| 00003 |
| 00004 |
| 00005 |
| 00006 |
+-------+
SELECT c0 FROM t2;
+-------+
| c0    |
+-------+
| 00001 |
| 00002 |
| 00003 |
| 00004 |
| 00005 |
| 00006 |
+-------+

drop table t1,t2;
