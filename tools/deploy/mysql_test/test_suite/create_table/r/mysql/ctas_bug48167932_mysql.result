drop table if exists test,test1;
create table test1(a int, b int, c int);
CREATE TABLE test (
a INT NOT NULL AUTO_INCREMENT,
PRIMARY KEY (a),
KEY(b)
) SELECT b,c FROM test1;
show create table test;
