drop database if exists hualong;
drop database if exists hualong2;
create database hualong;
use hualong;
create table t1(c1 int, c2 int) partition by hash(c2+c1) partitions 4;
insert into t1 values (1, 10);
create index i1 on t1(c2) local;
insert into t1 values (2, 2);
create table t2 like t1;
insert into t2 values (1, 10);
insert into t2 values (2, 11);
select * from t2 order by c2;
c1	c2
1	10
2	11
show index from t2;
