--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: peihan.dph
# owner group: SQL2
# tags: optimizer
# description:
#
# 测试hash join、group by、distinct、set等算子的dump逻辑


connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
#alter system set _max_trx_size='1G';

--disable_query_log
#call oceanbase.drop_tenant_force('dump_tenant');
#call oceanbase.create_mysql_tenant_1c2g('dump_tenant');
--source mysql_test/include/check_tenant_sync.inc

let $t_id = query_get_value(select tenant_id as t_id from oceanbase.__all_tenant where tenant_name = 'sys' limit 1,t_id, 1);
--enable_result_log
--enable_query_log
sleep 2;

connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

--disable_warnings
--error 0,1051
drop table t1;
--error 0,1051
drop table t111_var;
--error 0,1051
drop table t333_var;
--enable_warnings

create table t111_var(c0 bigint primary key,c1 varchar(4000), c2 varchar(4000), c3 varchar(4000), c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 longtext);

insert into t111_var values(1,repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('a',4000));
insert into t111_var select c0+1,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+1000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+1000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+1000000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10000000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100000000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
commit;
create table t333_var(c0 bigint ,c1 varchar(4000), c2 varchar(4000), c3 varchar(4000), c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 longtext);

insert into t333_var values(1,repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('a',4000));
insert into t333_var select c0+1,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
commit;

create index idx_t333_01 on t333_var(c0);

create table t1(c1 int,c2 int);
insert into t1 values(1,1);
insert into t1 values(2,2);
commit;


set  ob_query_timeout=400000000;
set  ob_trx_timeout=400000000;

alter system set _sort_area_size='2M';
alter system set _hash_area_size='4M';
##join dump
select /*+ use_hash(a b) */ SQL_CALC_FOUND_ROWS
 sum(a.c0),sum(length(a.c1)),sum(length(a.c2)),sum(length(a.c3)),sum(length(a.c4)),sum(length(a.c5)),sum(length(a.c6)),sum(length(a.c7)),
 sum(b.c0),sum(length(b.c1)),sum(length(b.c2)),sum(length(b.c3)),sum(length(b.c4)),sum(length(b.c5)),sum(length(b.c6)),sum(length(b.c7))
from t111_var a,t333_var b where a.c0=b.c0;


##rescan
select * from t1 c
where c.c1 in
(select /*+ use_hash(a b) */
 sum(a.c0)+sum(length(a.c1))+sum(length(a.c2))+sum(length(a.c3))+sum(length(a.c4))+sum(length(a.c5))+sum(length(a.c6))+sum(length(a.c7))+
 sum(b.c0)+sum(length(b.c1))+sum(length(b.c2))+sum(length(b.c3))+sum(length(b.c4))+sum(length(b.c5))+sum(length(b.c6))+sum(length(b.c7))
from t111_var a,t333_var b where a.c0=b.c0 and c.c1 >=1);

##groupby
select min(a.c0), sum(length(a.c1)),sum(length(a.c2)),sum(length(a.c3)),sum(length(a.c4)),sum(length(a.c5)),sum(length(a.c6)),sum(length(a.c7))
from (select * from t333_var a group by a.c0,a.c1,a.c2,a.c3,a.c4,a.c4,a.c5,a.c6,a.c7)a;

##rescan
select * from t1 c
where c.c1 not in
(select a.c0+sum(length(a.c1))+sum(length(a.c2))+sum(length(a.c3))+sum(length(a.c4))+sum(length(a.c5))+sum(length(a.c6))+sum(length(a.c7))
from (select * from t333_var a group by a.c0,a.c1,a.c2,a.c3,a.c4,a.c4,a.c5,a.c6,a.c7)a where c.c1 >= 1 group by a.c1);

select * from t1 c
where c.c1 not in
(select a.c0+sum(length(a.c1))+sum(length(a.c2))+sum(length(a.c3))+sum(length(a.c4))+sum(length(a.c5))+sum(length(a.c6))+sum(length(a.c7))
from (select * from t333_var a group by a.c0,a.c1,a.c2,a.c3,a.c4,a.c4,a.c5,a.c6,a.c7)a where c.c1 >=1);



##distinct
select a.c0,sum(length(a.c1)),sum(length(a.c2)),sum(length(a.c3)),sum(length(a.c4)),sum(length(a.c5)),sum(length(a.c6)),sum(length(a.c7))
from (select distinct a.c0,a.c1,a.c2,a.c3,a.c4,a.c5,a.c6,a.c7 from t333_var a)a;

select * from t1 c
where c.c1 not in
(select a.c0+sum(length(a.c1))+sum(length(a.c2))+sum(length(a.c3))+sum(length(a.c4))+sum(length(a.c5))+sum(length(a.c6))+sum(length(a.c7))
from (select distinct a.c0,a.c1,a.c2,a.c3,a.c4,a.c5,a.c6,a.c7 from t333_var a)a where c.c1 >=1);

select /*+ no_use_px */* from t1 c
where 65540096 in
(select count(*)+sum(length(a.c1))+sum(length(a.c2))+sum(length(a.c3))+sum(length(a.c4))+sum(length(a.c5))+sum(length(a.c6))+sum(length(a.c7)) c1
from (select distinct a.c0,a.c1,a.c2,a.c3,a.c4,a.c5,a.c6,a.c7 from t333_var a)a where c.c1 >=1);

select /*+ use_px parallel(2)*/* from t1 c
where 65540096 in
(select count(*)+sum(length(a.c1))+sum(length(a.c2))+sum(length(a.c3))+sum(length(a.c4))+sum(length(a.c5))+sum(length(a.c6))+sum(length(a.c7)) c1
from (select distinct a.c0,a.c1,a.c2,a.c3,a.c4,a.c5,a.c6,a.c7 from t333_var a)a where c.c1 >=1);

##sort
select a.c0,sum(length(a.c1)),sum(length(a.c2)),sum(length(a.c3)),sum(length(a.c4)),sum(length(a.c5)),sum(length(a.c6)),sum(length(a.c7))
from (select /*+ index(a primary) no_use_hash_aggregation*/ * from t333_var a order by a.c0 limit 1000000)a;

select * from t1 c
where c.c1 not in
(
select a.c0+sum(length(a.c1))+sum(length(a.c2))+sum(length(a.c3))+sum(length(a.c4))+sum(length(a.c5))+sum(length(a.c6))+sum(length(a.c7))
from (select /*+ index(a primary) no_use_hash_aggregation*/ * from t333_var a order by a.c0 limit 1000000)a
where c.c1 >=1
);

##prefix
select * from t1 c
where c.c1 not in
(
select a.c0+sum(length(a.c1))+sum(length(a.c2))+sum(length(a.c3))+sum(length(a.c4))+sum(length(a.c5))+sum(length(a.c6))+sum(length(a.c7))
from (select /*+ index(a primary) no_use_hash_aggregation*/ * from t333_var a order by a.c0,a.c1 limit 100000)a
where c.c1 >=1
);

##material

##set
select a.c0,sum(length(a.c1)),sum(length(a.c2)),sum(length(a.c3)),sum(length(a.c4)),sum(length(a.c5)),sum(length(a.c6)),sum(length(a.c7))
from (select /*+ no_use_hash_aggregation*/ * from t333_var a
  union select /*+ no_use_hash_aggregation*/ * from t111_var a)a;

select * from t1 c
where c.c1 not in
(
select a.c0+sum(length(a.c1))+sum(length(a.c2))+sum(length(a.c3))+sum(length(a.c4))+sum(length(a.c5))+sum(length(a.c6))+sum(length(a.c7))
from (select /*+ no_use_hash_aggregation*/ * from t333_var a
  union select /*+ no_use_hash_aggregation*/ * from t111_var a)a
where c.c1 >=1
);

select a.c0,sum(length(a.c1)),sum(length(a.c2)),sum(length(a.c3)),sum(length(a.c4)),sum(length(a.c5)),sum(length(a.c6)),sum(length(a.c7))
from (select /*+ no_use_hash_aggregation*/ * from t333_var a
  intersect select /*+ no_use_hash_aggregation*/ * from t111_var a)a;

select * from t1 c
where c.c1 not in
(
select a.c0+sum(length(a.c1))+sum(length(a.c2))+sum(length(a.c3))+sum(length(a.c4))+sum(length(a.c5))+sum(length(a.c6))+sum(length(a.c7))
from (select /*+ no_use_hash_aggregation*/ * from t333_var a
intersect select /*+ no_use_hash_aggregation*/ * from t111_var a)a
where c.c1 >=1
);

select a.c0,sum(length(a.c1)),sum(length(a.c2)),sum(length(a.c3)),sum(length(a.c4)),sum(length(a.c5)),sum(length(a.c6)),sum(length(a.c7))
from (select /*+ no_use_hash_aggregation*/ * from t333_var a
except select /*+ no_use_hash_aggregation*/ * from t111_var a)a;

select * from t1 c
where c.c1 not in
(
select a.c0+sum(length(a.c1))+sum(length(a.c2))+sum(length(a.c3))+sum(length(a.c4))+sum(length(a.c5))+sum(length(a.c6))+sum(length(a.c7))
from (select /*+ no_use_hash_aggregation*/ * from t333_var a
except select /*+ no_use_hash_aggregation*/ * from t111_var a)a
where c.c1 >=1
);

--replace_regex /con_id =[0-9]*/con_id =xxx/


alter system set _sort_area_size='100M';
alter system set _hash_area_size='100M';
sleep 2;

connection conn1;
drop table t1;
drop table t111_var;
drop table t333_var;

connection syscon;
--disable_query_log
#call oceanbase.drop_tenant_force('dump_tenant');
--enable_query_log
