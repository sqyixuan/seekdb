# owner: zongmei.zzm
# owner group: sql2

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (a int, b int, c int);

insert into t1 select 1 as a, 2 as b, 3 as c from table(generator(500));
insert into t1 select 2 as a, 3 as b, 4 as c from table(generator(500));
insert into t1 select 4 as a, 5 as b, 6 as c from table(generator(500));

alter system set _rowsets_max_rows = 2;
alter system flush plan cache global;
explain select sum(rank_val) from (select    /*+ PQ_DISTRIBUTE_WINDOW(LIST) parallel(2)*/ rank()  over (partition by b order by c) as rank_val from t1) tmp_t;
--sleep 1
select sum(rank_val) from (select    /*+ PQ_DISTRIBUTE_WINDOW(LIST) parallel(2)*/ rank()  over (partition by b order by c) as rank_val from t1) tmp_t;
select plan_line_id, plan_operation, sum(output_rows), sum(STARTS) rescan  from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() group by plan_line_id, plan_operation order by plan_line_id;

drop table t1;

alter system set _rowsets_max_rows = 256;
