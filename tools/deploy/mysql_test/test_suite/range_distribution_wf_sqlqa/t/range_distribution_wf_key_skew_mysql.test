explain basic select /*+ parallel(3)  */ c1, max(c1) over (partition by c5,c10 order by c8,c9,c10 DESC) t,
max(c2) over (partition by c8,c3,c10 order by c1,c1 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t2,
