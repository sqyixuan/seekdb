max(c2) over (partition by c8 order by c1 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t1,
max(c6) over (partition by c10,c4 order by c2,c3 RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t2 
from lyq_test order by c1,c2;
