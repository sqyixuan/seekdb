#owner:bin.lb
#owner group: SQL2
#description: obmysql 
#author: wb-lyq858317
#tags:optimizer, px

purge recyclebin;

--disable_warnings
drop database IF EXISTS lyq;
--enable_warnings

create database lyq  character set utf8;
use lyq;

--echo  mysql不支持并行执行，只是兼容parallel hint的语法。  obmysql模式支持并行

set _windowfunc_optimization_settings = 0;

--error 0,1051
DROP TABLE lyq_test_fk;

--error 0,1051
DROP TABLE lyq_test;
CREATE TABLE lyq_test(  
  c1 int primary key,  
  c2 float, 
  c3 DECIMAL(5,2) DEFAULT null, 
  c4 VARCHAR(100), 
  c5 bit(16),
  c6 datetime, 
  c7 json NOT NULL,
  c8 SET('a', 'b', 'c', 'd'),
  c9 timestamp,
  c10 varchar(100) GENERATED ALWAYS AS(c7) VIRTUAL COMMENT '生成列') 
  #PARALLEL 5
PARTITION BY key (c1) partitions 15;
  
--error 0,1305
DROP PROCEDURE get_data1;

DELIMITER //;
CREATE  PROCEDURE get_data1(in j int)
begin
DECLARE i int;
set i = 1;
    while i <= j DO
		insert into lyq_test(c1,c2,c3,c4,c5,c6,c7,c8,c9) values(i,i,CASE round(i/125, 0) WHEN 0 THEN null WHEN 1 THEN 6 WHEN 2 THEN 6 WHEN 3 THEN 6 WHEN 4 THEN 6 WHEN 5 THEN 6 WHEN 7 THEN 6 ELSE round(i/125, 0) END,
		CASE WHEN round(i/43, 0)<21 THEN '这是aseriqon一个字符串@$$测试lnczlbga' ELSE substr('这是aseriqon一个字符串@$$测试lnczlbga!%&^这是aseriqon一个字符串@$$测试',round(i/43, 0)) END,
		hex((CASE WHEN round(i/21, 0) = 0 THEN 1 WHEN round(i/42.5, 0) > 48 THEN 48 ELSE round(i/21, 0) END)),
		ADDDATE('2018-12-22 22:22:22',(CASE WHEN round(i/200, 0) > 3 THEN 3  ELSE round(i/200, 0) END)*10000) ,
		JSON_ARRAY(mod(i,5), "abc", NULL, TRUE, '{"a":100}'),
		CASE mod(i,5) WHEN 0 THEN null WHEN 3 THEN 'a,b,c,d' ELSE 'b,d' END,
		ADDDATE('2018-12-22 22:22:22', 1 ));
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//

call get_data1(2000);


create table lyq_test_fk(
c1 INT,
c2 VARCHAR(100)) 
#NOPARALLEL
;

--error 0,1305
DROP PROCEDURE get_data2;

DELIMITER //;
CREATE  PROCEDURE get_data2(in j int)
begin
DECLARE i int;
set i = 1;
    while i <= j DO
		insert into lyq_test_fk values(i,CASE mod(i,5) WHEN 0 THEN null ELSE mod(i,5) END);
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//

call get_data2(1800);

--echo create-1-1 普通索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T1 ON lyq_test(c1);

--echo create-1-3 组合索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T3 ON lyq_test(c3, c4,c5);

--echo create-1-4 hash索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T4 USING HASH ON lyq_test(c6);

--echo create-1-5 json 生成列索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T5 ON lyq_test(c10);

--echo create-1-6 全局分区索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T6 ON lyq_test(c1)
   GLOBAL   PARTITION BY RANGE (c1)(
PARTITION less_3 VALUES less than (2),
PARTITION b_3_8 VALUES less than (5),
PARTITION b_8_2000 VALUES less than (2000),
PARTITION greater_2000 VALUES less than MAXVALUE);


call dbms_stats.gather_table_stats('LYQ', 'lyq_test', method_opt=>'FOR ALL COLUMNS SIZE auto', granularity=>'ALL');

--echo rank() + hint
--echo 全局hint
explain basic select /*+ parallel(4) */ c2 from lyq_test where  c2 <= all (select rank() over (partition by c4 order by c1 ) t from lyq_test) order by c1;
--disable_result_log 
select /*+ parallel(4) */ c2 from lyq_test where  c2 <= all (select rank() over (partition by c4 order by c1) t from lyq_test) order by c1;
--enable_result_log

--echo table hint
explain basic select /*+ parallel(lyq_test 3)  */ c1 , min(t) from 
(select /*+ parallel(lyq_test 4) */  c1,c4, rank() over (partition by c6 order by c1 DESC) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
--disable_result_log 
select /*+ parallel(lyq_test 3) */ c1 , min(t) from 
(select /*+ parallel(lyq_test 4) */  c1,c4, rank() over (partition by c6 order by c1 DESC) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
--enable_result_log

--echo alter session
set _force_parallel_query_dop = 3;

explain basic select c2 from lyq_test where  c2 <= all (select rank() over (partition by c4 order by c1) t from lyq_test) order by c1;
--disable_result_log 
select c2 from lyq_test where  c2 <= all (select  rank() over (partition by c4 order by c1) t from lyq_test) order by c1;
--enable_result_log

--echo TABLE DOP

explain basic select /*+parallel(t1 4) */ c1 , min(t) from 
(select   c1,c4, rank() over (partition by c6 order by c1 DESC) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
--disable_result_log 
select   /*+ parallel(t1 4) */ c1 , min(t) from 
(select  c1,c4, rank() over (partition by c6 order by c1 DESC) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
--enable_result_log

--echo rank() + PQ_DISTRIBUTE_WINDOW  + 不同单列
--echo c1 主键 会被改写不需要window function
explain basic select /*+ parallel(3)  */ c1, rank() over (partition by c1 order by c2 ASC) t from lyq_test order by c1,c2;
--disable_result_log 
select /*+ parallel(3)  */ c1, rank() over (partition by c1 order by c2 ASC) t from lyq_test order by c1,c2;
--enable_result_log

--echo c2  PBY NDV > DOP * WF_PBY_DOP_RADIO
explain basic select /*+ parallel(3)  */ c1, rank() over (partition by c2 order by c1 DESC) t from lyq_test order by c1,c2;
--disable_result_log 
select /*+ parallel(3)  */ c1, rank() over (partition by c2 order by c1 DESC) t from lyq_test order by c1,c2;
--enable_result_log

