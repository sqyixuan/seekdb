explain basic select /*+ parallel(3) */ c1 , min(t) from (select c1,c4, min(c3) over (partition by c6 order by c1 DESC) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
--disable_result_log 
select /*+ parallel(3) */ c1 , min(t) from (select c1,c4, min(c3) over (partition by c6 order by c1 DESC) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
