explain basic select /*+ parallel(3) */ t , min(c1) over (partition by c4 order by c1 DESC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t
from (select c1,c4, min(c1) over (partition by c3 order by c1 DESC) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
--disable_result_log 
select /*+ parallel(3) */ t , min(c1) over (partition by c4 order by c1 DESC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t
from (select c1,c4, min(c1) over (partition by c3 order by c1 DESC) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
