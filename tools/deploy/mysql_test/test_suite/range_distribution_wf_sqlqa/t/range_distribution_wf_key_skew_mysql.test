(select /*+ parallel(lyq_test 4) */  c1,c4, max(c2) over (partition by c6 order by c1 DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW ) t from lyq_test order by c1,c2 ) t1 group by c1,c4 order by c1;
--disable_result_log 
select /*+ parallel(lyq_test 3) */ c1 , max(t) from 
(select /*+ parallel(lyq_test 4) */  c1,c4, max(c2) over (partition by c6 order by c1 DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
