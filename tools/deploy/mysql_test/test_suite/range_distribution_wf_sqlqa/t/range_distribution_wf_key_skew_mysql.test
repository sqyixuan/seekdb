--echo count() + 多个窗口函数
explain basic select /*+ parallel(3)  */ c1, count(c3) over (partition by c2,c6,c10 order by c2,c5,c6 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t ,
count(c2) over (partition by c8,c3,c10 order by c1,c10) t1,
count(c1) over (partition by c3 order by c2 RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW ) t2
from lyq_test order by c1,c2;
--disable_result_log 
select /*+ parallel(3)  */ c1, count(c3) over (partition by c2,c6,c10 order by c2,c5,c6 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t ,
count(c2) over (partition by c8,c3,c10 order by c1,c10 ) t1,
count(c1) over (partition by c3 order by c2 RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t2
from lyq_test order by c1,c2;
--enable_result_log

explain basic select /*+ parallel(3)  */ c1, count(c1) over (partition by c8,c6,c10 order by c2,c5,c6 DESC) t,
count(c2) over (partition by c8 order by c1 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t1,
count(c6) over (partition by c10,c4 order by c2,c3 RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t2 
from lyq_test order by c1,c2;
--disable_result_log 
select /*+ parallel(3)  */ c1, count(c3) over (partition by c8,c6,c10 order by c2,c5,c6 DESC) t,
count(c2) over (partition by c8 order by c1 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t1,
count(c6) over (partition by c10,c4 order by c2,c3 RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t2 
from lyq_test order by c1,c2;
--enable_result_log

explain basic select /*+ parallel(3)  */ c1, count(c1) over (partition by c5,c10 order by c8,c9,c10 DESC) t,
count(c2) over (partition by c8,c3,c10 order by c1,c1 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t2,
count(c3) over (partition by c6 order by c2,c5,c6 RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t3,
count(c6) over (partition by c2,c6,c10 order by c2,c5,c6 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t4
from lyq_test order by c1,c2;
--disable_result_log 
select /*+ parallel(3)  */ c1, count(c1) over (partition by c5,c10 order by c8,c9,c10 DESC) t,
count(c2) over (partition by c8,c3,c10 order by c1,c1 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t2,
count(c6) over (partition by c6 order by c2,c5,c6 RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t3,
count(c9) over (partition by c2,c6,c10 order by c2,c5,c6 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t4
from lyq_test order by c1,c2;
--enable_result_log

--echo count() + 查询与子查询
--echo with ... as

--disable_result_log
with
     e as (select /*+ parallel(3)  */ c1, c2, count(c1) over (partition by c5 order by c1 DESC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test where c4 like '%测试%' OR c2 is not null  order by c1,c2),
     d as (select /*+ parallel(lyq_test 4)  */ c1, count(c2) over (partition by c5,c10 order by c8,c9,c10 DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t
	 from lyq_test where c2 >= all(select c2 from lyq_test where c1 = 3))
select /*+ parallel(3)  */ e.c1, count(e.c2) over (partition by e.c2 order by e.c1 DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from e, d where e.c1 = d.c1 order by e.c1;
--enable_result_log

--disable_result_log
with
     e as (select /*+ parallel(3) */ c1, c2, count(c6) over (partition by c3 order by c2 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test where c4 like '%测试%' OR c2 is not null  order by c1,c2),
     d as (select /*+ parallel(lyq_test 4)  */ c1, count(c3) over (partition by c8,c6,c10 order by c2,c5,c6 DESC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t
	 from lyq_test where c2 >= all(select c2 from lyq_test where c1 = 3))
select /*+ parallel(3)  */ e.c1, count(e.c1) over (partition by e.c2 order by e.c1 DESC) t from e, d where e.c1 = d.c1 order by e.c1;
--enable_result_log

--echo  join
explain basic select /*+ parallel(3) */ t1.c1,t2.c1, count(t1.c1) over (partition by c10 order by c6 ASC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test t1,lyq_test_fk t2 where t1.c1 = t2.c1 order by t1.c1,t1.c2;
--disable_result_log 
select /*+ parallel(3) */ t1.c1,t2.c1, count(t1.c1) over (partition by c10 order by c6 ASC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test t1,lyq_test_fk t2 where t1.c1 = t2.c1 order by t1.c1,t1.c2;
--enable_result_log

explain basic select /*+ parallel(3)  */ t1.c1, count(t1.c2) over (partition by t1.c4 order by t1.c1 DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test t1 
right join lyq_test_fk t2 on t1.c1 = t2.c1 where t1.c4 like '%测试%' OR t1.c2 is not null order by  t1.c1,t1.c2;
--disable_result_log 
select /*+ parallel(3)  */ t1.c1, count(t1.c2) over (partition by t1.c4 order by t1.c1 DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test t1 
right join lyq_test_fk t2 on t1.c1 = t2.c1 where t1.c4 like '%测试%' OR t1.c2 is not null order by  t1.c1,t1.c2;
--enable_result_log

explain basic select /*+ parallel(3)  */ t1.c1, count(t1.c3) over (partition by t1.c4 order by t1.c1 DESC) t from lyq_test t1 
left join lyq_test_fk t2 on t1.c1 = t2.c1 where t1.c4 like '%测试%' OR t1.c2 is not null order by  t1.c1,t1.c2;
--disable_result_log 
select /*+ parallel(3)  */ t1.c1, count(t1.c3) over (partition by t1.c4 order by t1.c1 DESC) t from lyq_test t1 
left join lyq_test_fk t2 on t1.c1 = t2.c1 where t1.c4 like '%测试%' OR t1.c2 is not null order by  t1.c1,t1.c2;
--enable_result_log

explain basic select /*+ parallel(3)  */ t1.c1, count(t1.c6) over (partition by t1.c4 order by t1.c1 DESC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test t1 
full join lyq_test_fk t2 on t1.c1 = t2.c1 where t1.c4 like '%测试%' OR t1.c2 is not null order by  t1.c1,t1.c2;
--disable_result_log 
select /*+ parallel(3)  */ t1.c1, count(t1.c6) over (partition by t1.c4 order by t1.c1 DESC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test t1 
full join lyq_test_fk t2 on t1.c1 = t2.c1 where t1.c4 like '%测试%' OR t1.c2 is not null order by  t1.c1,t1.c2;
--enable_result_log

--echo 嵌套子查询

explain basic select /*+ parallel(4) */ c2 from lyq_test where  c2 <= some (select count(c2) over (partition by c10 order by c1 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test) order by c1;
--disable_result_log 
select /*+ parallel(4) */ c2 from lyq_test where  c2 <= some (select count(c2) over (partition by c10 order by c1 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test) order by c1;
--enable_result_log

explain basic select /*+ parallel(3) */ c1 , count(t) from (select c1,c4, count(c3) over (partition by c6 order by c1 DESC) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
--disable_result_log 
select /*+ parallel(3) */ c1 , count(t) from (select c1,c4, count(c3) over (partition by c6 order by c1 DESC) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
--enable_result_log

explain basic select /*+ parallel(3) */ c1 , count(c1) over (partition by c4 order by c1 DESC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t
from (select c1,c4, count(c1) over (partition by c3 order by c1 DESC) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
--disable_result_log 
select /*+ parallel(3) */ c1 , count(c1) over (partition by c4 order by c1 DESC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t
from (select c1,c4, count(c1) over (partition by c3 order by c1 DESC) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
--enable_result_log


--echo sum() + hint
--echo 全局hint
explain basic select /*+ parallel(4) */ c2 from lyq_test where  c2 <= all (select sum(c1) over (partition by c10 order by c1 RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test) order by c1;
--disable_result_log 
select /*+ parallel(4) */ c2 from lyq_test where  c2 <= all (select sum(c1) over (partition by c10 order by c1 RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test) order by c1;
--enable_result_log

--echo table hint
explain basic select /*+ parallel(lyq_test 3) */ c1 , sum(t) from 
(select /*+ parallel(lyq_test 4) */  c1,c4, sum(c2) over (partition by c6 order by c1 DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
--disable_result_log 
select /*+ parallel(lyq_test 3) */ c1 , sum(t) from 
(select /*+ parallel(lyq_test 4) */  c1,c4, sum(c2) over (partition by c6 order by c1 DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
--enable_result_log

--echo alter session
set _force_parallel_query_dop = 3;

explain basic select c2 from lyq_test where  c2 <= all (select sum(c3) over (partition by c10 order by c1) t from lyq_test) order by c1;
--disable_result_log 
select c2 from lyq_test where  c2 <= all (select sum(c3) over (partition by c10 order by c1) t from lyq_test) order by c1;
--enable_result_log

--echo TABLE DOP

explain basic select /*+parallel(t1 4) */ c1 , sum(t) from 
(select  /*+ */  c1,c4, sum(c4) over (partition by c6 order by c1 DESC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW ) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
--disable_result_log 
select   /*+ parallel(t1 4) */ c1 , sum(t) from 
(select  /*+ */  c1,c4, sum(c4) over (partition by c6 order by c1 DESC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
--enable_result_log


