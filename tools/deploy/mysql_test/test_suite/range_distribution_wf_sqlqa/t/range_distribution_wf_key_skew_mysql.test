--echo max() + 多个窗口函数
explain basic select /*+ parallel(3)  */ c1, max(c3) over (partition by c2,c6,c10 order by c2,c5,c6 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t ,
max(c2) over (partition by c8,c3,c10 order by c1,c10) t1,
max(c1) over (partition by c3 order by c2 RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW ) t2
from lyq_test order by c1,c2;
