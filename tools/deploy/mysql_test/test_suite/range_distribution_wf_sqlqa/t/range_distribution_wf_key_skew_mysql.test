rank() over (partition by c8,c3,c10 order by c1,c10) t1,
rank() over (partition by c3 order by c2 ) t2
from lyq_test order by c1,c2;
--disable_result_log 
select /*+ parallel(3)  */ c1, rank() over (partition by c2,c6,c10 order by c2,c5,c6) t ,
rank() over (partition by c8,c3,c10 order by c1,c10) t1,
rank() over (partition by c3 order by c2 ) t2
from lyq_test order by c1,c2;
--enable_result_log
--echo 不满足 满足 不满足
