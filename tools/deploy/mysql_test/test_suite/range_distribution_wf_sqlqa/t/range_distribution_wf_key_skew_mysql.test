--disable_result_log
with
     e as (select /*+ parallel(3) */ c1, c2, dense_rank() over (partition by c3 order by c2 ) t from lyq_test where c4 like '%测试%' OR c2 is not null  order by c1,c2),
     d as (select /*+ parallel(lyq_test 4)  */ c1, dense_rank() over (partition by c8,c6,c10 order by c2,c5,c6 DESC) t
	 from lyq_test where c2 >= all(select c2 from lyq_test where c1 = 3))
select /*+ parallel(3)  */ e.c1, dense_rank() over (partition by e.c2 order by e.c1 DESC) t from e, d where e.c1 = d.c1 order by e.c1;
--enable_result_log

--echo  join
explain basic select /*+ parallel(3) */ t1.c1,t2.c1, dense_rank() over (partition by c10 order by c6 ASC) t from lyq_test t1,lyq_test_fk t2 where t1.c1 = t2.c1 order by t1.c1,t1.c2;
--disable_result_log 
select /*+ parallel(3) */ t1.c1,t2.c1, dense_rank() over (partition by c10 order by c6 ASC) t from lyq_test t1,lyq_test_fk t2 where t1.c1 = t2.c1 order by t1.c1,t1.c2;
--enable_result_log

explain basic select /*+ parallel(3)  */ t1.c1, dense_rank() over (partition by t1.c4 order by t1.c1 DESC) t from lyq_test t1 
right join lyq_test_fk t2 on t1.c1 = t2.c1 where t1.c4 like '%测试%' OR t1.c2 is not null order by  t1.c1,t1.c2;
--disable_result_log 
select /*+ parallel(3)  */ t1.c1, dense_rank() over (partition by t1.c4 order by t1.c1 DESC) t from lyq_test t1 
right join lyq_test_fk t2 on t1.c1 = t2.c1 where t1.c4 like '%测试%' OR t1.c2 is not null order by  t1.c1,t1.c2;
--enable_result_log

explain basic select /*+ parallel(3)  */ t1.c1, dense_rank() over (partition by t1.c4 order by t1.c1 DESC) t from lyq_test t1 
left join lyq_test_fk t2 on t1.c1 = t2.c1 where t1.c4 like '%测试%' OR t1.c2 is not null order by  t1.c1,t1.c2;
--disable_result_log 
select /*+ parallel(3)  */ t1.c1, dense_rank() over (partition by t1.c4 order by t1.c1 DESC) t from lyq_test t1 
left join lyq_test_fk t2 on t1.c1 = t2.c1 where t1.c4 like '%测试%' OR t1.c2 is not null order by  t1.c1,t1.c2;
--enable_result_log

explain basic select /*+ parallel(3)  */ t1.c1, dense_rank() over (partition by t1.c4 order by t1.c1 DESC) t from lyq_test t1 
full join lyq_test_fk t2 on t1.c1 = t2.c1 where t1.c4 like '%测试%' OR t1.c2 is not null order by  t1.c1,t1.c2;
--disable_result_log 
