rank() over (partition by c8 order by c10) t1,
rank() over (partition by c10,c4 order by c2,c3) t2 
from lyq_test order by c1,c2;
--disable_result_log 
select /*+ parallel(3)  */ c1, rank() over (partition by c8,c6,c10 order by c2,c5,c6 DESC) t,
rank() over (partition by c8 order by c10) t1,
rank() over (partition by c10,c4 order by c2,c3) t2 
from lyq_test order by c1,c2;
