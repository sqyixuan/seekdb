d as (select /*+ parallel(lyq_test 4)  */ c1, max(c2) over (partition by c5,c10 order by c8,c9,c10 DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t
from lyq_test where c2 >= all(select c2 from lyq_test where c1 = 3))
select /*+ parallel(3)  */ e.c1, max(e.c2) over (partition by e.c2 order by e.c1 DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from e, d where e.c1 = d.c1 order by e.c1;
with
e as (select /*+ parallel(3) */ c1, c2, max(c6) over (partition by c3 order by c2 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t from lyq_test where c4 like '%测试%' OR c2 is not null  order by c1,c2),
d as (select /*+ parallel(lyq_test 4)  */ c1, max(c3) over (partition by c8,c6,c10 order by c2,c5,c6 DESC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) t
from lyq_test where c2 >= all(select c2 from lyq_test where c1 = 3))
select /*+ parallel(3)  */ e.c1, max(e.c1) over (partition by e.c2 order by e.c1 DESC) t from e, d where e.c1 = d.c1 order by e.c1;
join
