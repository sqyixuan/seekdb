purge recyclebin;
mysql不支持并行执行，只是兼容parallel hint的语法。  obmysql模式支持并行
set _windowfunc_optimization_settings = 0;
DROP TABLE lyq_test_fk;
DROP TABLE lyq_test;
CREATE TABLE lyq_test(  
c1 int primary key,  
c2 float, 
c3 DECIMAL(5,2) DEFAULT null, 
c4 VARCHAR(100), 
c5 bit(16),
c6 datetime, 
c7 json NOT NULL,
c8 SET('a', 'b', 'c', 'd'),
c9 timestamp,
c10 varchar(100) GENERATED ALWAYS AS(c7) VIRTUAL COMMENT '生成列') 
#PARALLEL 5
PARTITION BY LIST (c1)(
PARTITION p_list_unique_t_1 VALUES IN (1,2,3,4,5,6),
PARTITION p_list_unique_t_2 VALUES IN (7,8,9,10,11),
PARTITION p_list_unique_t_3 VALUES IN (12,13,14,15,16,17,18,19,20));
DROP PROCEDURE get_data1;
CREATE  PROCEDURE get_data1(in j int)
begin
DECLARE i int;
set i = 1;
while i <= j DO
insert into lyq_test(c1,c2,c3,c4,c5,c6,c7,c8,c9) values(i,i,round(i/125, 0),substr('这是aseriqon一个字符串@$$测试lnczlbga!%&^这是aseriqon一个字符串@$$测试',round(i/43, 0)),
hex((CASE round(i/42.5, 0) WHEN 0 THEN 1 ELSE round(i/42.5, 0) END)),ADDDATE('2018-12-22 22:22:22', round(i/800, 0)*10000) ,JSON_ARRAY(mod(i,5), "abc", NULL, TRUE, '{"a":100}'),
CASE mod(i,5) WHEN 0 THEN null ELSE 'b,d' END,ADDDATE('2018-12-22 22:22:22', 1 ));
set i = i + 1;
end WHILE;
end;
//
call get_data1(20);
create table lyq_test_fk(
c1 INT,
c2 VARCHAR(100)) 
#NOPARALLEL
;
DROP PROCEDURE get_data2;
CREATE  PROCEDURE get_data2(in j int)
begin
DECLARE i int;
set i = 1;
while i <= j DO
insert into lyq_test_fk values(i,CASE mod(i,5) WHEN 0 THEN null ELSE mod(i,5) END);
set i = i + 1;
end WHILE;
end;
//
call get_data2(18);
create-1-1 普通索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T1 ON lyq_test(c1);
create-1-3 组合索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T3 ON lyq_test(c3, c4,c5);
create-1-4 hash索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T4 USING HASH ON lyq_test(c6);
create-1-5 json 生成列索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T5 ON lyq_test(c10);
create-1-6 全局分区索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T6 ON lyq_test(c1)
GLOBAL   PARTITION BY RANGE (c1)(
PARTITION less_3 VALUES less than (2),
PARTITION b_3_8 VALUES less than (5),
PARTITION b_8_2000 VALUES less than (2000),
PARTITION greater_2000 VALUES less than MAXVALUE);
rank() + hint
全局hint
explain basic select /*+ parallel(4) */ c2 from lyq_test where  c2 <= all (select rank() over (partition by c4 order by c1 ) t from lyq_test) order by c1;
Query Plan
================================================================================
|ID|OPERATOR                                       |NAME                       |
--------------------------------------------------------------------------------
|0 |PX COORDINATOR MERGE SORT                      |                           |
|1 |└─EXCHANGE OUT DISTR                           |:EX10002                   |
|2 |  └─SORT                                       |                           |
|3 |    └─NESTED-LOOP ANTI JOIN                    |                           |
|4 |      ├─PX BLOCK ITERATOR                      |                           |
|5 |      │ └─TABLE FULL SCAN                      |lyq_test                   |
|6 |      └─MATERIAL                               |                           |
|7 |        └─EXCHANGE IN DISTR                    |                           |
|8 |          └─EXCHANGE OUT DISTR (BROADCAST)     |:EX10001                   |
|9 |            └─SUBPLAN SCAN                     |VIEW1                      |
|10|              └─WINDOW FUNCTION                |                           |
|11|                └─PARTITION SORT               |                           |
|12|                  └─EXCHANGE IN DISTR          |                           |
|13|                    └─EXCHANGE OUT DISTR (HASH)|:EX10000                   |
|14|                      └─PX BLOCK ITERATOR      |                           |
|15|                        └─TABLE FULL SCAN      |lyq_test(INDEX_lyq_test_T3)|
================================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(lyq_test.c2)]), filter(nil), rowset=256
      sort_keys([lyq_test.c1, ASC])
  1 - output([lyq_test.c1], [INTERNAL_FUNCTION(lyq_test.c2)]), filter(nil), rowset=256
      dop=4
  2 - output([lyq_test.c1], [lyq_test.c2]), filter(nil), rowset=256
      sort_keys([lyq_test.c1, ASC]), local merge sort
  3 - output([lyq_test.c1], [lyq_test.c2]), filter(nil), rowset=256
      conds([cast(lyq_test.c2, DOUBLE(-1, -1)) > VIEW1.t OR cast(lyq_test.c2, DOUBLE(-1, -1)) IS NULL]), nl_params_(nil), use_batch=false
  4 - output([lyq_test.c1], [lyq_test.c2]), filter(nil), rowset=256
  5 - output([lyq_test.c1], [lyq_test.c2]), filter(nil), rowset=256
      access([lyq_test.c1], [lyq_test.c2]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([lyq_test.c1]), range(MIN ; MAX)always true
  6 - output([VIEW1.t]), filter(nil), rowset=256
  7 - output([VIEW1.t]), filter(nil), rowset=256
  8 - output([VIEW1.t]), filter(nil), rowset=256
      dop=4
  9 - output([VIEW1.t]), filter(nil), rowset=256
      access([VIEW1.t])
 10 - output([cast(T_WIN_FUN_RANK(), DOUBLE(-1, -1))]), filter(nil), rowset=256
      win_expr(T_WIN_FUN_RANK()), partition_by([lyq_test.c4]), order_by([lyq_test.c1, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED 
      FOLLOWING)
 11 - output([lyq_test.c4], [lyq_test.c1]), filter(nil), rowset=256
      sort_keys([HASH(lyq_test.c4), ASC], [lyq_test.c4, ASC], [lyq_test.c1, ASC])
 12 - output([lyq_test.c4], [lyq_test.c1]), filter(nil), rowset=256
 13 - output([lyq_test.c4], [lyq_test.c1]), filter(nil), rowset=256
      (#keys=1, [lyq_test.c4]), dop=4
 14 - output([lyq_test.c1], [lyq_test.c4]), filter(nil), rowset=256
 15 - output([lyq_test.c1], [lyq_test.c4]), filter(nil), rowset=256
      access([lyq_test.c1], [lyq_test.c4]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([lyq_test.c3], [lyq_test.c4], [lyq_test.c5], [lyq_test.c1]), range(MIN,MIN,MIN,MIN ; MAX,MAX,MAX,MAX)always true
select /*+ parallel(4) */ c2 from lyq_test where  c2 <= all (select rank() over (partition by c4 order by c1) t from lyq_test) order by c1;
table hint
explain basic select /*+ parallel(lyq_test 3)  */ c1 , min(t) from 
(select /*+ parallel(lyq_test 4) */  c1,c4, rank() over (partition by c6 order by c1 DESC) t from lyq_test order by c1,c2  ) t1 group by c1,c4 order by c1;
