#owner: jiahua.cjh
#group: storage
#description: test tablet cnt limitation doesn't affect truncate table

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

#call oceanbase.drop_tenant_force('max_tablet_cnt_truncate_table');
#call oceanbase.create_mysql_tenant_1c2g('max_tablet_cnt_truncate_table');
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_result_log

disconnect obsys;

connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

# step 1: set _max_tablet_cnt_per_gb > 20000
alter system set _max_tablet_cnt_per_gb = 25000;
sleep 1;
select VALUE from oceanbase.V$OB_PARAMETERS where name='_max_tablet_cnt_per_gb';

# step 2: create more than 20000 tablets for 1g tenant
let $i = 0;
while ($i < 20) {
  eval create table unit_tablet_cnt_$i(c1 int primary key, c2 int) partition by hash(c1) partitions 1024;
  inc $i;
}

# step 3: set _max_tablet_cnt_per_gb = 20000, test the soft limit of truncate_table is 30000
alter system set _max_tablet_cnt_per_gb = 20000;
sleep 1;
select VALUE from oceanbase.V$OB_PARAMETERS where name='_max_tablet_cnt_per_gb';

# step 4: test cur_tablet_cnt > 20000, and succeed to truncate
truncate table unit_tablet_cnt_0;

--disable_query_log
--disable_result_log
connect (conn_admin,$OBMYSQL_MS0,admin@sys,admin,*NO-ONE*,$OBMYSQL_PORT);
#call oceanbase.drop_tenant_force('max_tablet_cnt_truncate_table');
--enable_result_log
--enable_query_log
