# owner: fengjingkun.fjk
# group: storage
# desc: test minor macro reuse

--disable_warnings
drop table if exists test;
--enable_warnings
alter system set minor_compact_trigger = 10;
create table test (c1 int primary key, c2 varchar(2048)) compression = 'none';
let $tablet_id = query_get_value(select tablet_id from oceanbase.__all_virtual_table where table_name = 'test', tablet_id, 1);
let $__tenant_id__ = query_get_value(select tenant_id from oceanbase.__all_virtual_table where table_name = 'test', tenant_id, 1);
let $__table_id__ = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'test', table_id, 1);

--disable_query_log
--disable_result_log

--let $count=0
while ($count < 3000)
{
  --let $stmt=INSERT INTO test VALUES($count, repeat($count,512))
  eval $stmt;
  inc $count;
}

--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc

--disable_query_log
--disable_result_log

while ($count < 6000)
{
  --let $stmt=INSERT INTO test VALUES($count, repeat($count,512))
  eval $stmt;
  inc $count;
}

--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc

--disable_query_log
--disable_result_log

while ($count < 9000)
{
  --let $stmt=INSERT INTO test VALUES($count, repeat($count,512))
  eval $stmt;
  inc $count;
}

--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc

let $__now_time__ = query_get_value(select now() as c, c, 1);
alter system set minor_compact_trigger = 2;
--source mysql_test/include/wait_mini_minor_merge_for_table.inc

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

let $minor_reuse_macro = query_get_value(select MIN(multiplexed_macro_block_count) as mb from oceanbase.__all_virtual_tablet_compaction_history where tablet_id = $tablet_id and tenant_id = $__tenant_id__ and type = 'MINOR_MERGE', mb, 1);
let $mini_macro = query_get_value(select MAX(macro_block_count) as mb from oceanbase.__all_virtual_tablet_compaction_history where tablet_id = $tablet_id and tenant_id = $__tenant_id__ and type = "MINI_MERGE", mb, 1);

--enable_query_log
--enable_result_log

--enable_query_log
--enable_result_log

if ($minor_reuse_macro <= $mini_macro) {
  --echo reuse macro failed
}

disconnect obsys;

connection default;
drop table test;
