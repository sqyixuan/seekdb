# owner: lixia.yq
# owner group: transaction
# description: 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

connection conn0;
alter system set minor_compact_trigger = 10;

connection conn1;
--disable_warnings
drop table if exists test_storage_del_col_table;
--enable_warnings

create table test_storage_del_col_table(i int primary key, c1 char(30), c256 char(255), dt datetime(6), d datetime(6));
sleep 1;

connection conn0;
let $__table_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ table_id from oceanbase.__all_virtual_table where table_name= 'test_storage_del_col_table', table_id, 1);
let $__tenant_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ tenant_id from oceanbase.__all_virtual_table where table_name= 'test_storage_del_col_table', tenant_id, 1);
let $__svr_cnt__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ count(*) as c from oceanbase.__all_server, c, 1);
connection conn1;

let $__tablet_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ tablet_id from oceanbase.__all_tablet_to_ls where table_id = $__table_id__, tablet_id, 1);
#insert
--disable_query_log
let $i=0;
while($i < 30) 
{
    eval insert into test_storage_del_col_table(i,c1,c256,dt,d) values($i,'1','$i+++++++++++$i','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

--disable_query_log
connection conn1;
while($i < 60) 
{
    eval insert into test_storage_del_col_table(i,c1,c256,dt,d) values($i,'1','$i+++++++++++$i','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

connection conn0;
let $i=300;
while ($i > 0)
{
  sleep 1;
  dec $i;
  let $minor_count = query_get_value(select count(1) as c from oceanbase.__all_virtual_table_mgr where table_type = 12 and tablet_id = $__tablet_id__ and tenant_id=$__tenant_id__ limit 1, c, 1);
  if ($minor_count == 2)
  {
    let $i = -5;
  }
}

if ($i != -5)
{
  --echo mini merge failed minor_count=$minor_count
}

# connection conn0;
# alter system major freeze tenant = sys;
# alter system major freeze tenant = all_user;
# alter system major freeze tenant = all_meta;

connection conn1;
alter table test_storage_del_col_table drop column c256;


connection conn1;
--disable_query_log
let $i=100;
while($i < 130)
{
    eval insert into test_storage_del_col_table(i,c1,dt,d) values($i,'1','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc


connection conn1;
--disable_query_log
while($i < 160)
{
    eval insert into test_storage_del_col_table(i,c1,dt,d) values($i,'1','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

