--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: chaser.ch
# owner group: storage
# tags: compat syntax
# description:
#
#

repair table t1;
show warnings;

repair table t1, t2;
show warnings;

repair table t1, t2, test.t3;
show warnings;

repair local table t1, t2, test.t3;
show warnings;

repair NO_WRITE_TO_BINLOG table t1, t2, test.t3;
show warnings;

repair table t1, t2, test.t3 quick;
show warnings;

repair NO_WRITE_TO_BINLOG table t1, t2, test.t3 USE_FRM;
show warnings;

repair local table t1, t2, test.t3 extended;
show warnings;

repair NO_WRITE_TO_BINLOG table t1 EXTENDED USE_FRM EXTENDED EXTENDED EXTENDED;
show warnings;

checksum table t1;
show warnings;

checksum table t1, t2;
show warnings;

checksum table t1, t2, test.t3;
show warnings;

checksum table t1 EXTENDED;
show warnings;

checksum table t1 quick;
show warnings;

--error 1064
checksum table t1 quick, EXTENDED;

#--error 0,3510
#drop tablespace ts1;

#create tablespace ts1 add datafile 'filename';
#drop tablespace ts1;

#create tablespace ts1 add datafile 'filename' FILE_BLOCK_SIZE = 1;
#alter tablespace ts1 ADD datafile 'filename' drop datafile 'file2';
#drop tablespace ts1 engine = innodb;

#create tablespace ts1 add datafile 'filename' FILE_BLOCK_SIZE = 1 USE LOGFILE GROUP 'abcd' EXTENT_SIZE = 1 INITIAL_SIZE = 1 AUTOEXTEND_SIZE = 1 MAX_SIZE = 1 NODEGROUP = 1 COMMENT = 'temp' wait engine = innodb;
#alter tablespace ts1 ADD datafile 'filename' drop datafile 'file2' INITIAL_SIZE = 1 ENGINE = innodb wait;
#drop tablespace ts1 engine = myisam;

#create tablespace ts1 FILE_BLOCK_SIZE = 1 EXTENT_SIZE = 1 INITIAL_SIZE = 1 MAX_SIZE = 1 NODEGROUP = 1 COMMENT = 'temp' wait engine = innodb;
#alter tablespace ts1 drop datafile 'file2' INITIAL_SIZE = 1 wait;
#drop tablespace ts1 engine = myisam;

#create tablespace ts1;
#alter tablespace ts1 ADD datafile 'filename' drop datafile 'file2' INITIAL_SIZE = 1 ENGINE = innodb wait;
#drop tablespace ts1;

show engine innodb status;
show engine innodb mutex;
show engine memory status;
show engine memory mutex;
show engine performance_schema status;

show open tables;
show open tables from test;
show open tables in test;
show open tables in test like '%aa%';
