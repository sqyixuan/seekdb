#owner: jiahua.cjh
#group: storage
#description: test tablet cnt limitation of tenant unit per gb

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

#call oceanbase.drop_tenant_force('unit_per_gb_tenant');
#call oceanbase.create_mysql_tenant_1c2g('unit_per_gb_tenant');
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_result_log

disconnect obsys;

connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
--disable_warnings
drop table if exists unit_tablet_cnt_0;
--enable_warnings
create table unit_tablet_cnt_0(c1 int primary key, c2 int) partition by hash(c1) partitions 1024;
create index rebuild_index_max on unit_tablet_cnt_0(c2) global;

# the actual limit of tablet_cnt of truncate_table is 30000
alter system set _max_tablet_cnt_per_gb = 1000;
sleep 1;
select VALUE from oceanbase.V$OB_PARAMETERS where name='_max_tablet_cnt_per_gb';

# truncate main table partition should trigger rebuild index (update global index) successfully.
TRUNCATE TABLE unit_tablet_cnt_0;

--disable_query_log
--disable_result_log
connect (conn_admin,$OBMYSQL_MS0,admin@sys,admin,*NO-ONE*,$OBMYSQL_PORT);
#call oceanbase.drop_tenant_force('unit_per_gb_tenant');
--enable_result_log
--enable_query_log
