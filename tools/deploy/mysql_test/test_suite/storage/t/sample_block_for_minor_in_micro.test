--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: houhaojun.hhj
# owner group: storage
# tags: sample block
# description: test function of sample block


connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--disable_query_log
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

# 1 create table
--disable_warnings
--enable_query_log
drop table if exists sample_block_for_minor_in_micro_t;
create table sample_block_for_minor_in_micro_t (c1 int primary key, c2 int, c3 varchar(256), c4 varchar(256), c5 varchar(256), c6 varchar(256)) ROW_FORMAT redundant BLOCK_SIZE 4096 COMPRESSION 'none';
sleep 3;
let $__table_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ table_id from oceanbase.__all_virtual_table where table_name= 'sample_block_for_minor_in_micro_t', table_id, 1);

--disable_query_log
let $__tablet_id__=query_get_value(SELECT tablet_id FROM oceanbase.__all_virtual_tablet_to_ls WHERE table_id = $__table_id__, tablet_id, 1);
--enable_query_log
# --echo $__tablet_id__;

alter system set ob_compaction_schedule_interval = '3s';
alter system set minor_compact_trigger = 10;
sleep 3;
--enable_warnings


# 2 insert data
--disable_query_log
let $i = 1;
while ($i <= 2000) {
  eval insert into sample_block_for_minor_in_micro_t values ($i, $i, repeat('padding', 10), repeat('padding', 10), repeat('padding', 10), repeat('padding', 10));
  inc $i;
}
let $j = 1;
while ($j <= 1000) {
  eval insert into sample_block_for_minor_in_micro_t values ($j * 2 + 5999, $j * 2 + 5999, repeat('padding', 10), repeat('padding', 10), repeat('padding', 10), repeat('padding', 10));
  inc $j;
}

# 3 test

# 3.1 test retire to row sample
--enable_query_log
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (30) seed(1);
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (50) seed(1);
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (80) seed(1);
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (30) seed(1) order by c1 desc;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (50) seed(1) order by c1 desc;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (80) seed(1) order by c1 desc;

# 3.2 test single minor sstable in micro mode
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

select c1 from sample_block_for_minor_in_micro_t sample block (99) seed(1) where c1 <= 5 order by c1 asc;
select c1 from sample_block_for_minor_in_micro_t sample block (99) seed(1) where c1 <= 5 order by c1 desc;
select c1 from sample_block_for_minor_in_micro_t sample block (99) seed(1) where c1 > 7996 order by c1 asc;
select c1 from sample_block_for_minor_in_micro_t sample block (99) seed(1) where c1 > 7996 order by c1 desc;

select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (10) seed(11);
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (30) seed(11);
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (50) seed(11);
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (70) seed(11);
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (90) seed(11);
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (10) seed(11) order by c1 desc;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (30) seed(11) order by c1 desc;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (50) seed(11) order by c1 desc;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (70) seed(11) order by c1 desc;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (90) seed(11) order by c1 desc;

select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (30) seed(22) where c1 >= 100 and c1 <= 2900;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (50) seed(22) where c1 >= 100 and c1 <= 2900;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (80) seed(22) where c1 >= 100 and c1 <= 2900;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (30) seed(22) where c1 >= 100 and c1 <= 2900 order by c1 desc;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (50) seed(22) where c1 >= 100 and c1 <= 2900 order by c1 desc;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (80) seed(22) where c1 >= 100 and c1 <= 2900 order by c1 desc;

# 3.3 test multi minor sstables in micro mode
--disable_query_log
let $i = 2001;
while ($i <= 4000) {
  eval insert into sample_block_for_minor_in_micro_t values ($i, $i, repeat('padding', 10), repeat('padding', 10), repeat('padding', 10), repeat('padding', 10));
  inc $i;
}
let $j = 1;
while ($j <= 1000) {
  eval insert into sample_block_for_minor_in_micro_t values ($j * 2 + 6000, $j * 2 + 6000, repeat('padding', 10), repeat('padding', 10), repeat('padding', 10), repeat('padding', 10));
  inc $j;
}
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc


let $__mini_sstable_count__=query_get_value(select count(*) mini_sstable_count from oceanbase.__all_virtual_table_mgr where tablet_id = $__tablet_id__ and table_type = 12 limit 1, mini_sstable_count, 1);
--echo mini_sstable_count:$__mini_sstable_count__;

let $__now_time__ = query_get_value(select now() as c, c, 1);
alter system set minor_compact_trigger = 1;

--source mysql_test/include/wait_mini_minor_merge_for_table.inc
--enable_query_log

let $__minor_sstable_count__=query_get_value(select count(*) minor_sstable_count from oceanbase.__all_virtual_table_mgr where tablet_id = $__tablet_id__ and table_type = 11 limit 1, minor_sstable_count, 1);
--echo minor_sstable_count:$__minor_sstable_count__;

select c1 from sample_block_for_minor_in_micro_t sample block (99) seed(2) where c1 <= 2002 and c1 >= 1999 order by c1 asc;
select c1 from sample_block_for_minor_in_micro_t sample block (99) seed(2) where c1 <= 2002 and c1 >= 1999 order by c1 desc;
select c1 from sample_block_for_minor_in_micro_t sample block (99) seed(2) where c1 <= 6002 and c1 >= 3999 order by c1 asc;
select c1 from sample_block_for_minor_in_micro_t sample block (99) seed(2) where c1 <= 6002 and c1 >= 3999 order by c1 desc;

select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (20) seed (3) where c1 >= 100 and c1 <= 7900;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (60) seed (3) where c1 >= 100 and c1 <= 7900;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (90) seed (3) where c1 >= 100 and c1 <= 7900;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (20) seed (3) where c1 >= 100 and c1 <= 7900 order by c1 desc;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (60) seed (3) where c1 >= 100 and c1 <= 7900 order by c1 desc;
select count(*), avg(c1) from sample_block_for_minor_in_micro_t sample block (90) seed (3) where c1 >= 100 and c1 <= 7900 order by c1 desc;

alter system set minor_compact_trigger = 2;
sleep 3;
alter system set ob_compaction_schedule_interval = '10s';
drop table if exists sample_block_for_minor_in_micro_t;

