--disable_query_log
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(c1 int primary key, c2 int, c3 int);
insert into t1 values(1,1,1);
--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc

alter table t1 add column (c4 int default 0);
alter table t1 add column (c5 int default 0);
alter table t1 add column (c6 int default 0);
alter table t1 add column (c7 int default 0);
alter table t1 add column (c8 int default 0);
select c4,c5,c6,c7, c2 from t1;

drop table t1;