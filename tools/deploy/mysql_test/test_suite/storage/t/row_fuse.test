--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: OUR GOAL: Make all this simple and effective!
--disable_abort_on_error

--disable_query_log
--source mysql_test/include/index_quick_major.inc
alter system set  switch_flow_percent_strategy = '1:1s;10:1s;30:1s;60:1s' server_type=rootserver;

--real_sleep 3
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk int primary key, a int);
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
let $table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);
disconnect obsys;
connection default;
#let $meta_table = query_get_value(select '__' '$table_id' '__meta__' as t, t, 1);

#row fuse case
#query
#empty ups_row + empty cs_row
#ups_row(OP_NEW_ADD ) + empty cs_row
#emptyt ups_row + cs_row
#ups_row(OP_NEW_ADD| OP_DEL_ROW | OP_VALID ) + cs_row

#daily merge
#ups_row(OP_NEW_ADD) + empty cs_row
#empyt ups_row + cs_row
#ups_row(OP_NEW_ADD | OP_DEL_ROW | OP_VALID ) + cs_row

insert into t1 values(1,0),(2,0),(4,0),(3,0);
insert into t1 values(0,0);
insert into t1 values(5,0),(6,0),(7,0);

# query: ups_row(OP_NEW_ADD) + empty cs_row
select * from t1;
# query: empty ups_row + empty cs_row
select * from t1 where pk = 9;


#daily merge: ups_row(OP_NEW_ADD ) + empty cs_row
--source mysql_test/include/majorfreeze.inc

--source mysql_test/include/wait_daily_merge.inc

#query: empty ups_row + cs_row
select * from t1;

delete from t1 where pk = 1;
# query: ups_row(OP_DEL_ROW) + cs_row
select * from t1 where pk = 1;

delete from t1 where pk = 2;
insert into t1 values(2, 5);
# query: ups_row(OP_NEW_ADD) + cs_row
select * from t1 where pk = 2;

update t1 set a = 10 where pk = 3;
# query: ups_row(OP_VALID) + cs_row
select * from t1 where pk = 3;


#daily merge: ups_row(empty | OP_NEW_ADD | OP_DEL_ROW | OP_VALID ) + cs_row
--source mysql_test/include/majorfreeze.inc

--source mysql_test/include/wait_daily_merge.inc

select * from t1;
drop table t1;
