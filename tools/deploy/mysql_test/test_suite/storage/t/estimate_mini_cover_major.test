# owner: yht146439
# owner group: storage
# description: estimate row when mini cover major

--disable_query_log
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
--enable_query_log

create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);

--disable_query_log
--let $count=0
while ($count < 1000)
{
  --let $stmt1=INSERT INTO t1 VALUES($count, $count)
  --let $stmt2=INSERT INTO t2 VALUES($count, $count)
  eval $stmt1;
  eval $stmt2;
  inc $count;
}

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

delete from t1;
delete from t2 limit 990;
begin;
--disable_query_log
--let $count=0
while ($count < 10)
{
  --let $stmt1=INSERT INTO t1 VALUES($count, $count)
  --let $stmt2=INSERT INTO t2 VALUES($count, $count)
  eval $stmt1;
  eval $stmt2;
  inc $count;
}
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc
commit;

--disable_query_log
--let $count=0
while ($count < 20)
{
  --let $stmt1=INSERT INTO t1 VALUES($count, $count)
  eval $stmt1;
  inc $count;
}
--enable_query_log

explain select * from t1;
explain select * from t2;

drop table t1,t2;