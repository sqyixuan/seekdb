--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: houhaojun.hhj
# owner group: storage
# tags: sample block
# description: test function of sample block


connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

# 1 create table
--disable_warnings
--enable_query_log
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 varchar(256), c4 varchar(256), c5 varchar(256), c6 varchar(256)) ROW_FORMAT redundant BLOCK_SIZE 4096 COMPRESSION 'none';
--enable_warnings

# 2 insert data
--disable_query_log
let $i = 1; 
while ($i <= 3000) {
  eval insert into t1 values ($i, $i, repeat('padding', 10), repeat('padding', 10), repeat('padding', 10), repeat('padding', 10));
  inc $i;
}
--enable_query_log

# 3 test
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

select c1 from t1 sample block (99) seed(1) where c1 <= 3 order by c1 asc;
select c1 from t1 sample block (99) seed(1) where c1 <= 3 order by c1 desc;
select c1 from t1 sample block (99) seed(1) where c1 > 2998 order by c1 asc;
select c1 from t1 sample block (99) seed(1) where c1 > 2998 order by c1 desc;

select count(*), avg(c1) from t1 sample block (10) seed(1);
select count(*), avg(c1) from t1 sample block (30) seed(1);
select count(*), avg(c1) from t1 sample block (50) seed(1);
select count(*), avg(c1) from t1 sample block (70) seed(1);
select count(*), avg(c1) from t1 sample block (90) seed(1);
select count(*), avg(c1) from t1 sample block (10) seed(1) order by c1 desc;
select count(*), avg(c1) from t1 sample block (30) seed(1) order by c1 desc;
select count(*), avg(c1) from t1 sample block (50) seed(1) order by c1 desc;
select count(*), avg(c1) from t1 sample block (70) seed(1) order by c1 desc;
select count(*), avg(c1) from t1 sample block (90) seed(1) order by c1 desc;

select count(*), avg(c1) from t1 sample block (30) seed(2) where c1 >= 50 and c1 <= 2950;
select count(*), avg(c1) from t1 sample block (50) seed(2) where c1 >= 50 and c1 <= 2950;
select count(*), avg(c1) from t1 sample block (80) seed(2) where c1 >= 50 and c1 <= 2950;
select count(*), avg(c1) from t1 sample block (30) seed(2) where c1 >= 50 and c1 <= 2950 order by c1 desc;
select count(*), avg(c1) from t1 sample block (50) seed(2) where c1 >= 50 and c1 <= 2950 order by c1 desc;
select count(*), avg(c1) from t1 sample block (80) seed(2) where c1 >= 50 and c1 <= 2950 order by c1 desc;
