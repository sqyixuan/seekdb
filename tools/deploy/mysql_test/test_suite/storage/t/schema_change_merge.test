--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: lixia.yq 
# owner group: STORAGE2
# description:
#
--source mysql_test/include/wait_tenant_major_merge.inc
--disable_query_log
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(id int primary key, name varchar(3000), age int, description varchar(5000)) compression = 'none';
--disable_query_log
let $i=0;
while($i < 3000) 
{
    eval insert into t1(id, name, age, description) values($i,repeat(rand(), 50), $i, repeat(rand(), 100));
    inc $i;
}
--enable_query_log
--echo insert 3000 rows

connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
let $__tenant_id__ = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = "sys", tenant_id, 1);
let $table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1' and tenant_id = $__tenant_id__, table_id, 1);
let $ls_id = query_get_value(select ls_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id and tenant_id = $__tenant_id__, ls_id, 1);
let $tablet_id = query_get_value(select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id and tenant_id = $__tenant_id__, tablet_id, 1);
disconnect obsys1;
connection default;
select count(*) from t1;
--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc


# add column
alter table t1 add column(c1 int);
--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc
select id, c1 from t1 order by id limit 10;
--real_sleep 1
connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
--disable_query_log
let $table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1' and tenant_id = $__tenant_id__, table_id, 1);
let $ls_id = query_get_value(select ls_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id and tenant_id = $__tenant_id__, ls_id, 1);
let $tablet_id = query_get_value(select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id and tenant_id = $__tenant_id__, tablet_id, 1);
let $version = query_get_value(select LAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $__tenant_id__, LAST_SCN, 1);
--enable_query_log
disconnect obsys1;
connection default;


#drop column
alter table t1 drop column c1;

--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc
select id from t1 order by id limit 10;
--real_sleep 1
connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
--disable_query_log
let $table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1' and tenant_id = $__tenant_id__, table_id, 1);
let $ls_id = query_get_value(select ls_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id and tenant_id = $__tenant_id__, ls_id, 1);
let $tablet_id = query_get_value(select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id and tenant_id = $__tenant_id__, tablet_id, 1);
let $version = query_get_value(select LAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $__tenant_id__, LAST_SCN, 1);
eval select multiplexed_macro_block_count from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$__tenant_id__ and ls_id=$ls_id and tablet_id=$tablet_id and compaction_scn=$version limit 1;
--enable_query_log
disconnect obsys1;

connection default;
alter table t1 modify description varchar(5200);
--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc
select id from t1 order by id limit 10;
--real_sleep 1
connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
--disable_query_log
let $table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1' and tenant_id = $__tenant_id__, table_id, 1);
let $ls_id = query_get_value(select ls_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id and tenant_id = $__tenant_id__, ls_id, 1);
let $tablet_id = query_get_value(select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id and tenant_id = $__tenant_id__, tablet_id, 1);
let $version = query_get_value(select LAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $__tenant_id__, LAST_SCN, 1);
eval select multiplexed_macro_block_count from oceanbase.__all_virtual_tablet_compaction_history where tenant_id = $__tenant_id__ and ls_id=$ls_id and tablet_id=$tablet_id and compaction_scn=$version limit 1;
--enable_query_log
disconnect obsys1;

#with progressive merge
connection default;
alter table t1 set progressive_merge_num=2;
--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc
select id from t1 order by id limit 10;
--real_sleep 1
connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
--disable_query_log
let $table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1' and tenant_id = $__tenant_id__, table_id, 1);
let $ls_id = query_get_value(select ls_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id and tenant_id = $__tenant_id__, ls_id, 1);
let $tablet_id = query_get_value(select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id and tenant_id = $__tenant_id__, tablet_id, 1);
let $version = query_get_value(select LAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $__tenant_id__, LAST_SCN, 1);
eval select multiplexed_macro_block_count from oceanbase.__all_virtual_tablet_compaction_history where tenant_id = $__tenant_id__ and ls_id=$ls_id and tablet_id=$tablet_id and compaction_scn=$version limit 1;
--enable_query_log
disconnect obsys1;

#full merge 
connection default;
alter table t1 set progressive_merge_num=1;
--real_sleep 3
--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc
connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
--disable_query_log
let $table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1' and tenant_id = $__tenant_id__, table_id, 1);
let $ls_id = query_get_value(select ls_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id and tenant_id = $__tenant_id__, ls_id, 1);
let $tablet_id = query_get_value(select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id and tenant_id = $__tenant_id__, tablet_id, 1);
let $version = query_get_value(select LAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $__tenant_id__, LAST_SCN, 1);
eval select multiplexed_macro_block_count from oceanbase.__all_virtual_tablet_compaction_history where tenant_id = $__tenant_id__ and ls_id=$ls_id and tablet_id=$tablet_id and compaction_scn=$version limit 1;
disconnect obsys1;
connection default;


drop table t1;
