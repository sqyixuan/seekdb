# owner: saitong.zst
# description: encoding for 4096 user column count

--disable_query_log
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

--disable_warnings
drop tenant if exists encoding_4k_col force;
eval drop resource pool if exists 4k_col_pool;
eval drop resource unit if exists 4k_col_unit;
--enable_warnings

eval create resource unit 4k_col_unit MAX_CPU=1, MEMORY_SIZE='2G';
eval create resource pool 4k_col_pool unit='4k_col_unit', unit_num=1;

--enable_query_log

create tenant encoding_4k_col replica_num = 1, resource_pool_list = ('4k_col_pool') set ob_tcp_invited_nodes='%';
--sleep 3
connect (encoding_4k_col,$OBMYSQL_MS0, root@encoding_4k_col, ,*NO-ONE*,$OBMYSQL_PORT);
connection encoding_4k_col;

set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

use test;

--disable_warnings
drop table if exists t_4k_cols;
--enable_warnings


# format sql
--let $create_table_sql = create table t_4k_cols (c0 int
--let $insert_sql = insert into t_4k_cols (c0
--let $values_stmt = values(7
--let $column_cnt = 1
while($column_cnt<=4095)
{
  --let $column_name=c$column_cnt
  --let $create_table_sql = $create_table_sql, $column_name int
  --let $insert_sql = $insert_sql, $column_name
  --let $values_stmt = $values_stmt, 7
  inc $column_cnt;
}

--let $create_table_sql = $create_table_sql ) row_format=compressed;
--echo $create_table_sql

--let $values_stmt = $values_stmt )
--let $insert_sql = $insert_sql ) $values_stmt;

# create table
eval $create_table_sql;

describe t_4k_cols;

# insert data

--echo $insert_sql
--disable_query_log
--let $cnt=32
while($cnt > 0)
{
  eval $insert_sql;
  dec $cnt;
}
connection obsys;
--enable_query_log


# compaction
alter system major freeze tenant = encoding_4k_col;
--source mysql_test/include/wait_daily_merge.inc

connection obsys;
drop tenant encoding_4k_col force;
drop resource pool 4k_col_pool;
drop resource unit 4k_col_unit;
connection default;
