# owner: houhaojun.hhj
# owner group: storage
# description: Validate estimate row count in minor sstable

--disable_query_log
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

let $table_name = "t1";
let $tenant_name = "sys";
let $minor_compact_trigger = 2;

alter system set minor_compact_trigger=2;

create table t1(pk int, c1 int, c2 int, primary key(pk));

insert into t1 values(1, 1, 1);
insert into t1 values(2, 2, 2);
insert into t1 values(3, 3, 3);

--source mysql_test/include/wait_minor_merge_exactly.inc
explain select * from t1;

insert into t1 values(4, 4, 4);
--source mysql_test/include/wait_minor_merge_exactly.inc

delete from t1 where pk=4;
--source mysql_test/include/wait_minor_merge_exactly.inc

explain select * from t1;

insert into t1 values(5, 5, 5);
--source mysql_test/include/wait_minor_merge_exactly.inc

delete from t1 where pk=5;
--source mysql_test/include/wait_minor_merge_exactly.inc

explain select * from t1;

insert into t1 values(6, 6, 6);
insert into t1 values(7, 7, 7);
--source mysql_test/include/wait_minor_merge_exactly.inc

delete from t1 where pk=6;
delete from t1 where pk=7;
--source mysql_test/include/wait_minor_merge_exactly.inc

explain select * from t1;

insert into t1 values(8, 8, 8);
insert into t1 values(9, 9, 9);
insert into t1 values(10, 10, 10);
--source mysql_test/include/wait_minor_merge_exactly.inc

delete from t1 where pk=8;
delete from t1 where pk=9;
delete from t1 where pk=10;
--source mysql_test/include/wait_minor_merge_exactly.inc

explain select * from t1;

insert into t1 values(11, 11, 11);
--source mysql_test/include/wait_minor_merge_exactly.inc

delete from t1 where pk=11;
--source mysql_test/include/wait_minor_merge_exactly.inc

explain select * from t1;

drop table t1;
