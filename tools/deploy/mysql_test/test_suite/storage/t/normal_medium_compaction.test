# owner: lixia.yq
# owner group: storage
# description: test normal medium compaction


--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

connection conn0;
alter system set minor_compact_trigger = 10;

connection conn0;
--disable_warnings
drop table if exists t1;
--enable_warnings

connection conn0;
create table t1(i int, c1 char(30), c256 char(255), dt datetime(6), d  datetime(6));

connection conn0;

#insert
--disable_query_log
let $i=0;
while($i < 30) 
{
    connection conn0;
    eval insert into t1(i,c1,c256,dt,d) values($i,'1','$i','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log
connection conn0;
--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc
--source mysql_test/include/wait_medium_compaction.inc

connection conn0;
alter system set minor_compact_trigger = 2;
