# owner: saitong.zst
# tags: encoding
# description: test for integer type improvement for integer base diff encoder

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists test_bmsql;
--enable_warnings

create table test_bmsql (
hist_id  integer,
h_c_id   integer,
h_c_d_id integer,
h_c_w_id integer) PROGRESSIVE_MERGE_NUM = 0 ;


--let $loop=0
while($loop < 30000)
{
  eval insert into test_bmsql (hist_id, h_c_id, h_c_d_id, h_c_w_id) values(10000 + $loop, 10000 + $loop, $loop * 100, $loop * 1000);
  inc $loop;
}
select count(1) from test_bmsql;
select min(h_c_id) from test_bmsql;
select max(h_c_id) from test_bmsql;

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--enable_query_log

alter system major freeze tenant sys;
alter system major freeze tenant all_user;
alter system major freeze tenant all_meta;
--source mysql_test/include/wait_daily_merge.inc


connection default;
alter table test_bmsql modify h_c_id bigint;
select min(h_c_id) from test_bmsql;
select max(h_c_id) from test_bmsql;

--disable_query_log
connection obsys;
--enable_query_log

alter system major freeze tenant sys;
alter system major freeze tenant all_user;
alter system major freeze tenant all_meta;
--source mysql_test/include/wait_daily_merge.inc

connection default;
select min(h_c_id) from test_bmsql;
select max(h_c_id) from test_bmsql;

drop table test_bmsql;

#test const decoder integer_mask

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int);
insert into t1(c1) values(-32768.51);
create index index1 on t1(c1);
alter table t1 modify c1 bigint;
update t1 set c1 = NULL;

drop table t1;

--disable_query_log
set global max_allowed_packet=16777216;
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log
