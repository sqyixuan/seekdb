# owner: lixia.yq
# owner group: transaction
# description: 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

connection conn0;
alter system set minor_compact_trigger = 2;

connection conn1;
--disable_warnings
drop table if exists t1;
--enable_warnings

connection conn1;
create table t1(i int primary key, c1 char(30), c256 char(255), dt datetime(6), d datetime(6), unique key(c1) global) partition by hash(i) partitions 16;
create index idx_t1 on t1(c256, d);

connection conn0;
let $__table_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ table_id from oceanbase.__all_virtual_table where table_name= 't1', table_id, 1);
let $__svr_cnt__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ count(*) as c from oceanbase.__all_virtual_server_stat, c, 1);

connection conn1;
#insert
--echo insert 0~30
--disable_query_log
let $i=0;
while($i < 30) 
{
    eval insert into t1(i,c1,c256,dt,d) values($i,'$i___$i','$i+++++++++++$i','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge_for_table.inc

connection conn1;
--echo insert 30~60
--disable_query_log
while($i < 60) 
{
    eval insert into t1(i,c1,c256,dt,d) values($i,'$i___$i','$i+++++++++++$i','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge_for_table.inc

connection conn1;
create index idx_t1_2 on t1(c256, dt, c1);

connection conn1;
--echo insert 100~130
--disable_query_log
let $i=100;
while($i < 130)
{
    eval insert into t1(i,c1,c256,dt,d) values($i,'$i___$i','$i+++++++++++$i','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge_for_table.inc


connection conn1;
--echo insert 130~160
--disable_query_log
while($i < 160)
{
    eval insert into t1(i,c1,c256,dt,d) values($i,'$i___$i','$i+++++++++++$i','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge_for_table.inc

connection conn0;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;

connection conn1;
drop table t1;
