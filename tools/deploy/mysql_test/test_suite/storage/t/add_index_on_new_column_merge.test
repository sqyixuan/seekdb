# owner: hanhui
# group: storage

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int primary key, c2 varchar(2048)) compression = 'none' row_format = redundant;

--disable_query_log
--disable_result_log

--let $count=0
while ($count < 3000)
{
  --let $stmt=INSERT INTO t1 VALUES($count, repeat($count,512))
  eval $stmt;
  inc $count;
}

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

alter table t1 add column c3 char(10) default null;

create index i1 on t1(c3);

--let $count=3001
while ($count < 4000)
{
  --let $stmt=INSERT INTO t1 VALUES($count, repeat($count,512), null)
  eval $stmt;
  inc $count;
}

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc


connection default;
drop table t1;
