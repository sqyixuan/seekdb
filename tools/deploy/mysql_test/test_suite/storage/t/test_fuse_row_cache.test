--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
# owner: houhaojun.hhj
# owner group: storage
# description: test for function of fuse row cache
# tags: fuse row cache

connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;

connection conn1;

# 1 create table
--enable_query_log
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int primary key, c2 int);


# 2 insert data
--disable_query_log
let $i = 1;
while ($i <= 10) 
{
  eval insert into t1 values ($i, $i+1);
  inc $i;
}

# 3 test 
--enable_query_log
select * from t1;

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

connection conn1;
update t1 set c2=222 where c1=2;
update t1 set c2=888 where c1=8;

select * from t1 where c1=2;
select * from t1 where c1=8;

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

select * from t1 where c1=8;
update t1 set c2=1111 where c1=1;
update t1 set c2=8888 where c1=8;
select * from t1 where c1=1;
select * from t1 where c1=8;

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

--disable_query_log
connection conn1;
set autocommit=0;
begin;
--enable_query_log

update t1 set c2=33333 where c1=3;
update t1 set c2=88888 where c1=8;

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

connection conn2;
select * from t1 where c1=3;
select * from t1 where c1=8;

connection conn1;
commit;

connection conn2;
select * from t1 where c1=3;
select * from t1 where c1=8;

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

connection conn2;
select * from t1 where c1=3;
select * from t1 where c1=8;
