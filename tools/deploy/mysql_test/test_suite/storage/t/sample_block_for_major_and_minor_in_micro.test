--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: houhaojun.hhj
# owner group: storage
# tags: sample block
# description: test function of sample block


connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--disable_warnings
--enable_query_log
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 varchar(256), c4 varchar(256), c5 varchar(256), c6 varchar(256)) ROW_FORMAT redundant BLOCK_SIZE 4096 COMPRESSION 'none';

--disable_query_log
let $i = 1; 
while ($i <= 2000) {
  eval insert into t1 values ($i, $i, repeat('padding', 10), repeat('padding', 10), repeat('padding', 10), repeat('padding', 10));
  inc $i;
}
let $j = 1;
while ($j <= 1000) {
  eval insert into t1 values ($j * 2 + 5999, $j * 2 + 5999, repeat('padding', 10), repeat('padding', 10), repeat('padding', 10), repeat('padding', 10));
  inc $j;
}

--enable_query_log
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

--disable_query_log
let $i = 2001; 
while ($i <= 4000) {
  eval insert into t1 values ($i, $i, repeat('padding', 10), repeat('padding', 10), repeat('padding', 10), repeat('padding', 10));
  inc $i;
}
let $j = 1;
while ($j <= 1000) {
  eval insert into t1 values ($j * 2 + 6000, $j * 2 + 6000, repeat('padding', 10), repeat('padding', 10), repeat('padding', 10), repeat('padding', 10));
  inc $j;
}
--enable_query_log
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

select c1 from t1 sample block (99) seed(1) where c1 <= 3 order by c1 asc;
select c1 from t1 sample block (99) seed(1) where c1 <= 3 order by c1 desc;
select c1 from t1 sample block (99) seed(1) where c1 > 7995 order by c1 asc;
select c1 from t1 sample block (99) seed(1) where c1 > 7995 order by c1 desc;

select count(*), avg(c1) from t1 sample block (15) seed(1);
select count(*), avg(c1) from t1 sample block (35) seed(1);
select count(*), avg(c1) from t1 sample block (55) seed(1);
select count(*), avg(c1) from t1 sample block (75) seed(1);
select count(*), avg(c1) from t1 sample block (95) seed(1);
select count(*), avg(c1) from t1 sample block (15) seed(1) order by c1 desc;
select count(*), avg(c1) from t1 sample block (35) seed(1) order by c1 desc;
select count(*), avg(c1) from t1 sample block (55) seed(1) order by c1 desc;
select count(*), avg(c1) from t1 sample block (75) seed(1) order by c1 desc;
select count(*), avg(c1) from t1 sample block (95) seed(1) order by c1 desc;

select count(*), avg(c1) from t1 sample block (25) seed(2) where c1 >= 50 and c1 <= 5950;
select count(*), avg(c1) from t1 sample block (45) seed(2) where c1 >= 50 and c1 <= 5950;
select count(*), avg(c1) from t1 sample block (85) seed(2) where c1 >= 50 and c1 <= 5950;
select count(*), avg(c1) from t1 sample block (25) seed(2) where c1 >= 50 and c1 <= 5950 order by c1 desc;
select count(*), avg(c1) from t1 sample block (45) seed(2) where c1 >= 50 and c1 <= 5950 order by c1 desc;
select count(*), avg(c1) from t1 sample block (85) seed(2) where c1 >= 50 and c1 <= 5950 order by c1 desc;
