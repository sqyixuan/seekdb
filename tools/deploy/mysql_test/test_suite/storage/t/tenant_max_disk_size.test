--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: chaser.ch
# owner group: storage
# tags: tenant disk usage
# description:
#
--disable_warnings
drop table if exists t1_disk;
--enable_warnings

# test create table with row_format option
create table t1_disk(a int, b varchar(100));
connect (obsys_disk,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection obsys_disk;
let $tenant_id  = query_get_value(select tenant_id from oceanbase.__all_virtual_table where table_name = 't1_disk', tenant_id, 1);
let $cur_data_size = query_get_value(select cast(sum(data_size)/1024/1024 + 1 as unsigned) as use_data_size from oceanbase.__all_space_usage where tenant_id = $tenant_id, use_data_size, 1);
let $t1_id  = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1_disk', table_id, 1);
--disable_query_log
eval alter system set tenant_disk_max_size = $cur_data_size tenant = 'mysql';
--enable_query_log
sleep 3;

connection default;
insert into t1_disk values(1, repeat('a', 25));
insert into t1_disk values(2, repeat('a', 25));
insert into t1_disk values(3, repeat('a', 25));

--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc

connection obsys_disk;
let $cnt  = 60;
if ($cnt > 0)
{
  let $use_data_size  = query_get_value(select sum(data_size) as use_data_size from oceanbase.__all_space_usage where tenant_id = $tenant_id, use_data_size, 1);
  if ($use_data_size > $cur_data_size) {
    let $cnt = -1;
  }
  dec $cnt;
  sleep 1;
}
if ($cnt == 0)
{
  --echo wait tenant enough space failed
}

sleep 25;

connection default;
--error 4184
insert into t1_disk values(4, repeat('a', 25));
delete from t1_disk where a = 1;

--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc

connection obsys_disk;
alter system set tenant_disk_max_size = 0 tenant = 'mysql';
sleep 25;

connection default;
insert into t1_disk values(5, repeat('a', 25));

connection default;
drop table if exists t1_disk;
