--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenjiang.xzj
#tags: optimizer
#owner group: storage
#description: fix select for update with self join bug

--disable_warnings
drop table if exists t;
--enable_warnings

create table t (id int primary key, c1 int, c2 int);
insert into t values (1, 2, 3);
insert into t values (2, 3, 4);

explain extended_noaddr select c1 from (select id from t where c1 = 2 order by c2 limit 1) v, t where v.id = t.id for update;
select c1 from (select id from t where c1 = 2 order by c2 limit 1) v, t where v.id = t.id for update;

drop table t;
