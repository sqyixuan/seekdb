set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;
drop table if exists unit_tablet_cnt_0;
create table unit_tablet_cnt_0(c1 int primary key, c2 int) partition by hash(c1) partitions 1024;
create index rebuild_index_max on unit_tablet_cnt_0(c2) global;
alter system set _max_tablet_cnt_per_gb = 1000;
select VALUE from oceanbase.V$OB_PARAMETERS where name='_max_tablet_cnt_per_gb';
VALUE
1000
TRUNCATE TABLE unit_tablet_cnt_0;
