drop table if exists t1_disk;
create table t1_disk(a int, b varchar(100));
insert into t1_disk values(1, repeat('a', 25));
insert into t1_disk values(2, repeat('a', 25));
insert into t1_disk values(3, repeat('a', 25));
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
insert into t1_disk values(4, repeat('a', 25));
ERROR 53100: Server out of disk space
delete from t1_disk where a = 1;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
alter system set tenant_disk_max_size = 0 tenant = 'mysql';
insert into t1_disk values(5, repeat('a', 25));
drop table if exists t1_disk;
