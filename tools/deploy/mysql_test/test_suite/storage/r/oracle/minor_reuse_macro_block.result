drop table if exists test;
create table test (c1 int primary key, c2 varchar(2048)) compression = 'none';
select ((select MIN(multiplexed_macro_block_count) from oceanbase.__all_virtual_tablet_compaction_history where tablet_id = 200001 and type like "%MINOR_MERGE") > 
(select MAX(macro_block_count) from oceanbase.__all_virtual_tablet_compaction_history where tablet_id = 200001  and type = "MINI_MERGE")) as reuse_test;
reuse_test
1
drop table test;
