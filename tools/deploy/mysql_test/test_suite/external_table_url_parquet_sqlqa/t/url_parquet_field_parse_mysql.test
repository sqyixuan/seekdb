####测试url外表字段####
select c1,c2,c3,c4,c9,c10,c11,c12,c14,c7,c13,c5,c6,c8 from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data2/'
format (type = 'parquet')
PATTERN = '000000_0$');

select c1,c2,c3,c4,c9,c10,c11,c12,c14,c7,c13,c5,c6,c8 from 'mysqltest_data_for_external_url_parquet/data/external_data2/'
(format (type = 'parquet')
PATTERN = '000000_0$') ;


####函数嵌套
select c1,c2,c1,c2 from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data2/'
format (type = 'parquet')
PATTERN = '000000_0$');

select c1,c2,c1,c2 from 'mysqltest_data_for_external_url_parquet/data/external_data2/'
(format (type = 'parquet')
PATTERN = '000000_0$') ;

select c1,c2,concat(c1,c2) from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data2/'
format (type = 'parquet')
PATTERN = '000000_0$');

select c1,c2,concat(c1,c2) from 'mysqltest_data_for_external_url_parquet/data/external_data2/'
(format (type = 'parquet')
PATTERN = '000000_0$') ;

select c1,trim(c1),concat(c1,c2) from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data2/'
format (type = 'parquet')
PATTERN = '000000_0$');

select c1,trim(c1),concat(c1,c2) from 'mysqltest_data_for_external_url_parquet/data/external_data2/'
(format (type = 'parquet')
PATTERN = '000000_0$') ;

select upper(c9),lower(c10),substr(c11,1,3),length(c12),replace(c9,c9,'TYPE') from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data2/'
format (type = 'parquet')
PATTERN = '000000_0$');

select upper(c9),lower(c10),substr(c11,1,3),length(c12),replace(c9,c9,'TYPE') from 'mysqltest_data_for_external_url_parquet/data/external_data2/'
(format (type = 'parquet')
PATTERN = '000000_0$') ;

select c1+0 AS ID,cast(c2 as char(10)) AS NAME,round(c3,1) AS MON,c2||c4 AS AGE,cast(c5 as decimal(5,2)) AS DEC,cast(c6 as date) AS BIR from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data2/'
format (type = 'parquet')
PATTERN = '000000_0$');

select c1+0 AS ID,cast(c2 as char(10)) AS NAME,round(c3,1) AS MON,c2||c4 AS AGE,cast(c5 as decimal(5,2)) AS DEC,cast(c6 as date) AS BIR from 'mysqltest_data_for_external_url_parquet/data/external_data2/'
(format (type = 'parquet')
PATTERN = '000000_0$') ;

