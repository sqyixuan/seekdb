####format(没影响)
select * from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data3/'
format (    type = 'parquet'
            FIELD_DELIMITER = ','
        	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
        	ENCODING = 'BINARY'
        	SKIP_HEADER = 0
        	EMPTY_FIELD_AS_NULL = true)
PATTERN = '^(?!.*\.crc$).*$');

select * from 'mysqltest_data_for_external_url_parquet/data/external_data3/'
(format (    type = 'parquet'
             FIELD_DELIMITER = ','
         	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
         	ENCODING = 'BINARY'
         	SKIP_HEADER = 0
         	EMPTY_FIELD_AS_NULL = true)
PATTERN = '^(?!.*\.crc$).*$') ;

