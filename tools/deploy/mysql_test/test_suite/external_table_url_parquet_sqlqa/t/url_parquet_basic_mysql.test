# owner: zhengjin.zz
# owner group: 技术部-SQL-外表和数据湖
# tags: external_table
# description: test url external table

--result_format 4
--enable_sorted_result
--source mysql_test/test_suite/external_table_url_parquet_sqlqa/include/copy_data_for_external_table.inc

connection default;

##手动测试后修改文件路径


####basic test####
select * from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data1/'
format (type = 'parquet')
PATTERN = "000000_0$");

select * from 'mysqltest_data_for_external_url_parquet/data/external_data1/'
(format (type = 'parquet')
PATTERN = "000000_0$");

select `int`,`string`,`decimal32`,`decimal64`,`date`,`timestamp` from files(
location = 'mysqltest_data_for_external_url_parquet/data/'
format (type = 'parquet')
PATTERN = 'parquet_cpp_example.parquet') limit 10;

select `int`,`string`,`decimal32`,`decimal64`,`date`,`timestamp` from 'mysqltest_data_for_external_url_parquet/data/'
(format (type = 'parquet')
PATTERN = 'parquet_cpp_example.parquet') limit 10;

