##special DATA
select c1,c2,c3,c4,c9,c10,c11,c12,c14 from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data3/'
format (type = 'parquet')
PATTERN = "^(?!.*\.crc$).*$");
