result_format: 4
####不同hive表属性场景
####create as SELECT
select c1 a1,c2 b2,c3 c3,c4 d4,c9 e9,c10 f10,c11 g11,c12 h12,c14 i14,c7 j7 from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data4/'
format (type = 'parquet')
PATTERN = '000000_0$');
+------+------+-------+--------+---------+----------+-------+---------+------------+---------+
| a1   | b2   | c3    | d4     | e9      | f10      | g11   | h12     | i14        | j7      |
+------+------+-------+--------+---------+----------+-------+---------+------------+---------+
|    1 |  101 |  1001 |  10001 | string1 | varchar1 | char1 | binary1 | 2021-01-01 |  123.46 |
|    3 |  103 |  1003 |  10003 | string3 | varchar3 | char3 | binary3 | 2021-01-03 |  789.01 |
|    5 |  105 |  1005 |  10005 | string5 | varchar5 | char5 | binary5 | 2021-01-05 |  345.68 |
|   -2 | -102 | -1002 | -10002 | string2 | varchar2 | char2 | binary2 | 2021-01-02 | -456.79 |
|   -4 | -104 | -1004 | -10004 | string4 | varchar4 | char4 | binary4 | 2021-01-04 |  -12.35 |
| NULL | NULL |  NULL |   NULL | NULL    | NULL     | NULL  | NULL    | NULL       |    NULL |
+------+------+-------+--------+---------+----------+-------+---------+------------+---------+
select c1 a1,c2 b2,c3 c3,c4 d4,c9 e9,c10 f10,c11 g11,c12 h12,c14 i14,c7 j7 from 'mysqltest_data_for_external_url_parquet/data/external_data4/'
(format (type = 'parquet')
PATTERN = '000000_0$') ;
+------+------+-------+--------+---------+----------+-------+---------+------------+---------+
| a1   | b2   | c3    | d4     | e9      | f10      | g11   | h12     | i14        | j7      |
+------+------+-------+--------+---------+----------+-------+---------+------------+---------+
|    1 |  101 |  1001 |  10001 | string1 | varchar1 | char1 | binary1 | 2021-01-01 |  123.46 |
|    3 |  103 |  1003 |  10003 | string3 | varchar3 | char3 | binary3 | 2021-01-03 |  789.01 |
|    5 |  105 |  1005 |  10005 | string5 | varchar5 | char5 | binary5 | 2021-01-05 |  345.68 |
|   -2 | -102 | -1002 | -10002 | string2 | varchar2 | char2 | binary2 | 2021-01-02 | -456.79 |
|   -4 | -104 | -1004 | -10004 | string4 | varchar4 | char4 | binary4 | 2021-01-04 |  -12.35 |
| NULL | NULL |  NULL |   NULL | NULL    | NULL     | NULL  | NULL    | NULL       |    NULL |
+------+------+-------+--------+---------+----------+-------+---------+------------+---------+
####PARTITIONED BY
select c2 b,c3 c from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data5/'
format (type = 'parquet')
PATTERN = '000000_0$');
+------+------------+
| b    | c          |
+------+------------+
| B    | 2025-06-14 |
| a    | 2024-06-14 |
| 中   | 2023-06-14 |
+------+------------+
select c2 b,c3 c from 'mysqltest_data_for_external_url_parquet/data/external_data5/'
(format (type = 'parquet')
PATTERN = '000000_0$') ;
+------+------------+
| b    | c          |
+------+------------+
| B    | 2025-06-14 |
| a    | 2024-06-14 |
| 中   | 2023-06-14 |
+------+------------+
drop table url_t3;
create table url_t3(a1 tinyint,b2 smallint,c3 int,d4 bigint,e5 float,f6 double,g7 decimal(10,2),h8 boolean,i9 varchar(20),j10 char(20),k11 binary(20),l12 varbinary(20),m13 timestamp,n14 date);
load data from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data4/'
format (type = 'parquet')
PATTERN = '000000_0$') into table url_t3;
select * from url_t3;
+------+------+-------+--------+-------+-------+---------+------+---------+----------+----------------------+---------+---------------------+------------+
| a1   | b2   | c3    | d4     | e5    | f6    | g7      | h8   | i9      | j10      | k11                  | l12     | m13                 | n14        |
+------+------+-------+--------+-------+-------+---------+------+---------+----------+----------------------+---------+---------------------+------------+
|    1 |  101 |  1001 |  10001 |  10.1 |  20.2 |  123.46 |    1 | string1 | varchar1 | char1                | binary1 | 2021-01-01 00:00:01 | 2021-01-01 |
|    3 |  103 |  1003 |  10003 |  10.3 |  20.4 |  789.01 |    1 | string3 | varchar3 | char3                | binary3 | 2021-01-03 00:00:03 | 2021-01-03 |
|    5 |  105 |  1005 |  10005 |  10.5 |  20.6 |  345.68 |    1 | string5 | varchar5 | char5                | binary5 | 2021-01-05 00:00:05 | 2021-01-05 |
|   -2 | -102 | -1002 | -10002 | -10.2 | -20.3 | -456.79 |    0 | string2 | varchar2 | char2                | binary2 | 2021-01-02 00:00:02 | 2021-01-02 |
|   -4 | -104 | -1004 | -10004 | -10.4 | -20.5 |  -12.35 |    0 | string4 | varchar4 | char4                | binary4 | 2021-01-04 00:00:04 | 2021-01-04 |
| NULL | NULL |  NULL |   NULL |  NULL |  NULL |    NULL | NULL | NULL    | NULL     | NULL                 | NULL    | NULL                | NULL       |
+------+------+-------+--------+-------+-------+---------+------+---------+----------+----------------------+---------+---------------------+------------+
