##子查询##
select  c1 ID, c2 NAME,c3 MON,c4 AGE,c5 TEL_NUMBER,c6 BIR from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data2/'
format (type = 'parquet')
PATTERN = '000000_0$') WHERE c5 BETWEEN
(SELECT  MAX(LOWER(c6)) FROM
files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data2/'
 format (type = 'parquet')
PATTERN = '000000_0$'))
AND
(SELECT COUNT(c3) FROM
files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data2/'
 format (type = 'parquet')
PATTERN = '000000_0$')
WHERE c3 NOT IN ('1000') OR (c1 IN (NULL) AND c3 IS NOT NULL) OR c2 LIKE '%')
;
+------+------+------+------+------------+------+
| ID   | NAME | MON  | AGE  | TEL_NUMBER | BIR  |
+------+------+------+------+------------+------+
+------+------+------+------+------------+------+
select  c1 ID, c2 NAME,c3 MON,c4 AGE,c5 TEL_NUMBER,c6 BIR from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data2/'
format (type = 'parquet')
PATTERN = '000000_0$')WHERE c5 NOT IN
(SELECT  MIN(ROUND(c5)) FROM
files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data2/'
format (type = 'parquet')
PATTERN = '000000_0$')
WHERE (c2 LIKE 'NULL%' OR c1 <> -1) AND c1 IN ('1000',''));
+------+------+------+------+------------+------+
| ID   | NAME | MON  | AGE  | TEL_NUMBER | BIR  |
+------+------+------+------+------------+------+
+------+------+------+------+------------+------+
