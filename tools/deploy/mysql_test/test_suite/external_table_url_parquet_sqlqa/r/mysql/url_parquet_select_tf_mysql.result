##GROUP BY##
select  c1 ID,max(c3) MON,min(c4) AGE from files(
location = 'mysqltest_data_for_external_url_parquet/data/external_data2/'
format (type = 'parquet')
PATTERN = '000000_0$') GROUP BY ID ORDER BY ID
;
