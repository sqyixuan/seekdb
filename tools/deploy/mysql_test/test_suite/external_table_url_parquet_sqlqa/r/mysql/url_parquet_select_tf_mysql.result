location = 'mysqltest_data_for_external_url_parquet/data/external_data2/'
format (type = 'parquet')
PATTERN = '000000_0$') GROUP BY ID HAVING C1 > 3 AND SUM(C3) > 400 ORDER BY ID ASC
;
