CREATE OR REPLACE TRIGGER after_logon_schema_trigger110
AFTER LOGON ON SCHEMA
DECLARE
  PRAGMA AUTONOMOUS_TRANSACTION;
BEGIN
  insert into tab_log values (seq1.nextval,user,systimestamp,'after_logon_schema_trigger110','schema');
  update tab_cunt set c1 = c1 + 1 where id = 110;
  commit;
END;
/
CREATE OR REPLACE TRIGGER after_logon_database_trigger111
AFTER LOGON ON database
DECLARE
  PRAGMA AUTONOMOUS_TRANSACTION;
BEGIN
  insert into tab_log values (seq1.nextval,user,systimestamp,'after_logon_database_trigger111','database');
  update tab_cunt set c1 = c1 + 2 where id = 110;
  commit;
END;
/
CREATE OR REPLACE TRIGGER before_logoff_schema_trigger112
BEFORE LOGOFF ON SCHEMA
DECLARE
  PRAGMA AUTONOMOUS_TRANSACTION;
BEGIN
  insert into tab_log values (seq1.nextval,user,systimestamp,'before_logoff_schema_trigger112','schema');
  update tab_cunt set c1 = c1 + 3 where id = 110;
  commit;
END;
/
