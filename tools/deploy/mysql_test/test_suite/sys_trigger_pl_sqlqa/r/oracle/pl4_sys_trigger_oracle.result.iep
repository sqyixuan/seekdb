#### 多个schema/database 触发器，其中某个触发器异常，验证触发器触发现象
#连接 WHH_USER1
call delete_all_objects(user);

select my_pack2.set_pack_cunt() from dual;
+--------------------------+
| MY_PACK2.SET_PACK_CUNT() |
+--------------------------+
|                        1 |
+--------------------------+

create or replace trigger dml_trigger before insert on tab02 for each row
  when (new.id >3)
DECLARE
  v_error_message varchar2(200);
begin
  my_pack2.pack_cunt := my_pack2.pack_cunt + 2;
  insert into tab01 values(1,'该sql异常报错');
  EXCEPTION
    WHEN OTHERS THEN
      v_error_message := SQLERRM;
      INSERT INTO tab_err VALUES (seq1.nextval,'【dml_trigger】' || v_error_message);
end;
/
CREATE OR REPLACE TRIGGER after_logon_schema_trigger91
AFTER LOGON ON SCHEMA
DECLARE
  PRAGMA AUTONOMOUS_TRANSACTION;
BEGIN
  my_pack2.pack_cunt := my_pack2.pack_cunt + 2;
  insert into tab_log values (seq1.nextval,user,systimestamp,'after_logon_schema_trigger91','my_pack2.pack_cunt='||my_pack2.pack_cunt);
  commit;
END;
/
CREATE OR REPLACE TRIGGER after_logon_schema_trigger92
AFTER LOGON ON SCHEMA FOLLOWS after_logon_schema_trigger91
DECLARE
  v_error_message varchar2(200);
  PRAGMA AUTONOMOUS_TRANSACTION;
BEGIN
  my_pack2.pack_cunt := my_pack2.pack_cunt + 2;
  insert into tab_log values (seq1.nextval,user,systimestamp,'after_logon_schema_trigger92','my_pack2.pack_cunt='||my_pack2.pack_cunt);
  insert into tab01 values(2,'该sql异常报错');
  EXCEPTION
    WHEN OTHERS THEN
      v_error_message := SQLERRM;
      INSERT INTO tab_err VALUES (seq1.nextval,'after_logon_schema_trigger92' || v_error_message);
  COMMIT;
END;
/
CREATE OR REPLACE TRIGGER after_logon_schema_trigger93
AFTER LOGON ON SCHEMA FOLLOWS after_logon_schema_trigger92
DECLARE
  PRAGMA AUTONOMOUS_TRANSACTION;
BEGIN
  my_pack2.pack_cunt := my_pack2.pack_cunt + 2;
  insert into tab_log values (seq1.nextval,user,systimestamp,'after_logon_schema_trigger93','my_pack2.pack_cunt='||my_pack2.pack_cunt);
  commit;
END;
/
CREATE OR REPLACE TRIGGER after_logon_schema_trigger94
AFTER LOGON ON SCHEMA FOLLOWS after_logon_schema_trigger93
DECLARE
  PRAGMA AUTONOMOUS_TRANSACTION;
BEGIN
  my_pack2.pack_cunt := my_pack2.pack_cunt + 2;
  insert into tab_log values (seq1.nextval,user,systimestamp,'after_logon_schema_trigger94','my_pack2.pack_cunt='||my_pack2.pack_cunt);
  insert into tab02 values(10,10);
  commit;
END;
/

