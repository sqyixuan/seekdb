ALTER TRIGGER "WHH_USER1"."BEFORE_LOGOFF_SCHEMA_TRIGGER13" ENABLE |
+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------BEGIN
  insert into tab_log values (seq1.nextval,user,systimestamp,'after_logon_schema_trigger1','my_pack2.pack_cunt='||my_pack2.get_pack_cunt());
  v := my_pack2.set_pack_cunt(my_pack2.get_pack_cunt() + 2);
  insert into tab_log values (seq1.nextval,user,systimestamp,'after_logon_schema_trigger1','my_pack2.pack_cunt='||my_pack2.get_pack_cunt());
  commit;
END;
/
CREATE OR REPLACE TRIGGER before_logoff_schema_trigger2
BEFORE LOGOFF ON SCHEMA FOLLOWS after_logon_schema_trigger1
DECLARE
  v number;
  PRAGMA AUTONOMOUS_TRANSACTION;
BEGIN
  insert into tab_log values (seq1.nextval,user,systimestamp,'before_logoff_schema_trigger2','my_pack2.pack_cunt='||my_pack2.get_pack_cunt());
  v := my_pack2.set_pack_cunt(my_pack2.get_pack_cunt() + 4);
  insert into tab_log values (seq1.nextval,user,systimestamp,'before_logoff_schema_trigger2','my_pack2.pack_cunt='||my_pack2.get_pack_cunt());
  commit;
END;
/
