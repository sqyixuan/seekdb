#连接 WHH_USER1

call WHH_USER1.delete_all_objects(user);

SELECT user,SYS_CONTEXT('USERENV','CURRENT_SCHEMA') schema FROM dual;
+-----------+-----------+
| USER      | SCHEMA    |
+-----------+-----------+
| WHH_USER1 | WHH_USER1 |
+-----------+-----------+

DROP TRIGGER WHH_USER1.after_logon_trigger11;
DROP TRIGGER WHH_USER1.before_logoff_trigger12;

CREATE OR REPLACE TRIGGER after_logon_trigger11
AFTER LOGON ON SCHEMA
DECLARE
  v number;
  PRAGMA AUTONOMOUS_TRANSACTION;
BEGIN
  v := my_pack2.set_pack_cunt(my_pack2.get_pack_cunt() + 1);
  insert into tab02 values (11,11);
  insert into tab02 values (12,seq1.nextval);
  insert into tab02 values (13,my_pack2.get_pack_cunt());
  insert into tab_log values (seq1.nextval,user,systimestamp,'after_logon_trigger11 SCHEMA','get_pack_cunt='||my_pack2.get_pack_cunt());
  commit;
END;
/
CREATE OR REPLACE TRIGGER before_logoff_trigger12
BEFORE LOGOFF ON database
DECLARE
  v number;
  PRAGMA AUTONOMOUS_TRANSACTION;
BEGIN
  v := my_pack2.set_pack_cunt(my_pack2.get_pack_cunt() + 2);
  insert into tab02 values (21,12);
  insert into tab02 values (22,seq1.nextval);
  insert into tab02 values (23,my_pack2.get_pack_cunt());
  insert into tab_log values (seq1.nextval,user,systimestamp,'before_logoff_trigger12 database','get_pack_cunt='||my_pack2.get_pack_cunt());
  commit;
END;
/

