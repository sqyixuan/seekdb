AFTER LOGON ON SCHEMA
DECLARE
  PRAGMA AUTONOMOUS_TRANSACTION;
BEGIN
  my_pack2.pack_cunt := my_pack2.pack_cunt + 3;
  insert into tab_log values (seq1.nextval,user,systimestamp,'after_logon_schema_trigger01','schema');
  commit;
END;
/
