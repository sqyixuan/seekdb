  PRAGMA AUTONOMOUS_TRANSACTION;
BEGIN
  insert into tab_log values (seq1.nextval,user,systimestamp,'before_logoff_database_trigger113','database');
  update tab_cunt set c1 = c1 + 4 where id = 110;
  commit;
END;
