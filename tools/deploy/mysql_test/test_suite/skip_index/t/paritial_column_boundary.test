# owner: baichangmin.bcm
#tags: optimizer
# description: basic test for brin index scan correctness

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t2;
--enable_warnings

create table t2 (
    a int auto_increment primary key skip_index(min_max),
    b bigint ,
    c char(30) ,
    d varchar(100) skip_index(min_max),
    e bigint skip_index(min_max)) row_format = dynamic block_size = 2048;
insert into t2 (b, c, d, e) values(1, "a", "yRnQaMpW9TxBRvDYWCF0fwyNp95fGBWLUThdP7jUNvKo", 1);
insert into t2 (b, c, d, e) values(2, "ab", "ub3vQ1", 10);
insert into t2 (b, c, d, e) values(3, "ab", "mjZRokGtoV5Tm", 100);
insert into t2 (b, c, d, e) values(NULL, "abcd", "UxaTNgfTmgfkCiKRczBSRG9zPq8gN49asymheZt2vpByiNoe4pgzXRlZGW5ZyUnLJni5IfCy84E", 1000);
insert into t2 (b, c, d, e) values(5, "abc", "O2iaD5OTigP1MMqzv7RHNAnwlml7U0QKrw5bKgezUykR5MWrcYCeiyEMLq6ZsiLivu5knaHEwudfYPjVlGnKJ", 10000);
insert into t2 (b, c, d, e) values(6, "abc", "hXXftiveAoz6ZpWyUqEweZRpIGXE0nd83qzPXihFPPX75Q1Xw9JlKpYYRvk", 1000);
insert into t2 (b, c, d, e) values(7, "abcd", "7EJkTApjpHEF1OJr96d33gIrK3wnIVb6cuM", 100);
insert into t2 (b, c, d, e) values(8, "abcde", "XiVsPxRmR8", 10);
insert into t2 (b, c, d, e) values(9, NULL, "nn1D75iRWXZzqAccVvYzfsQzJnlYshTp6GWcRYClFhTKGa1iUI5iFcbHxYkcH1QhX4uozmu5qa", 1);
insert into t2 (b, c, d, e) values(10, "abcde", "IOuTHvSnvBGgUlPJ71AzcgmvsV8sl9JnVSY6oxOnFbbb1iZYb5ROFw1lg2PYU82V7rj2VTn3Ty3nwhVvVvhBtwHbvW1CxV8z", 100);




--let $loop=16
while($loop > 0)
{
  insert into t2 (b, c, d, e) select b, c, d, e from t2;
  dec $loop;
}

select count(1) from t2;

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--enable_query_log

alter system major freeze tenant all;
--source mysql_test/include/wait_daily_merge.inc

connection default;

select count(1) from t2 where b < 5;
select count(1) from t2 where e > 50;

alter table t2 modify column b bigint SKIP_INDEX(MIN_MAX);
alter table t2 modify column e bigint;

alter table t2 set progressive_merge_num = 10;

connection obsys;

# test major freeze 1/10
alter system major freeze tenant all;
--source mysql_test/include/wait_daily_merge.inc

connection default;

select count(1) from t2 where b < 5;
select count(1) from t2 where e > 50;

#add column
alter table t2 add g bigint;
alter table t2 add f bigint skip_index(min_max);
--disable_query_log

--let $loop=16
while($loop > 0)
{
  insert into t2 (b, c, d, e, g, f) values(NULL, NULL, NULl, NULL, 1, 1);
  dec $loop;
}

connection obsys;
--enable_query_log
alter system major freeze tenant all;
--source mysql_test/include/wait_daily_merge.inc

connection default;

select count(1) from t2 where g < 5;
select count(1) from t2 where f < 5;

drop table t2;

--disable_query_log
set global max_allowed_packet=16777216;
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log

connection obsys;
alter system set _rowsets_enabled = true tenant = 'sys';
