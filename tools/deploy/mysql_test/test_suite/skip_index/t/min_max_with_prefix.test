# owner: saitong.zst
# tags: storage
# description: agg pushdown and filter on skip index with min/max prefix

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t_row, t_column;
--enable_warnings
--enable_query_log

create table t_row(
    c1 varchar(32768) SKIP_INDEX(MIN_MAX),
    c2 char(256) SKIP_INDEX(MIN_MAX),
    c3 tinytext SKIP_INDEX(MIN_MAX),
    c4 mediumtext SKIP_INDEX(MIN_MAX),
    c5 int);

create table t_column(
    c1 varchar(32768),
    c2 char(256),
    c3 tinytext,
    c4 mediumtext,
    c5 int) with column group (all columns, each column);

select length(repeat('t', 39));

--disable_query_log
--let $loop=0
while ($loop < 1000)
{
  eval insert into t_row values(
      concat(repeat('t', 39), $loop),
      concat(repeat('t', 39), $loop * 3),
      concat(repeat('t', 39), $loop * 10),
      concat(repeat('t', 39), $loop),
      $loop);
  inc $loop;
}

insert /*+ query_timeout(100000000) */ into t_column select * from t_row;

--enable_query_log

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

select min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4) from t_row;
select min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4) from t_column;

select count(1) from t_row where c1 = 'ttttttttttttttttttttttttttttttttttttttt0';
select count(1) from t_row where c2 = 'ttttttttttttttttttttttttttttttttttttttt0';
select count(1) from t_row where c3 = 'ttttttttttttttttttttttttttttttttttttttt0';
select count(1) from t_row where c4 = 'ttttttttttttttttttttttttttttttttttttttt0';

select count(1) from t_column where c1 = 'ttttttttttttttttttttttttttttttttttttttt0';
select count(1) from t_column where c2 = 'ttttttttttttttttttttttttttttttttttttttt0';
select count(1) from t_column where c3 = 'ttttttttttttttttttttttttttttttttttttttt0';
select count(1) from t_column where c4 = 'ttttttttttttttttttttttttttttttttttttttt0';

select count(1) from t_row where c1 > 'test';
select count(1) from t_row where c1 < 'test';
select count(1) from t_row where c4 > 'test';
select count(1) from t_row where c4 < 'test';

select count(1) from t_column where c1 > 'test';
select count(1) from t_column where c1 < 'test';
select count(1) from t_column where c4 > 'test';
select count(1) from t_column where c4 < 'test';

select count(1) from t_row where c1 != 'ttttttttttttttttttttttttttttttttttttttt0';
select count(1) from t_column where c1 != 'ttttttttttttttttttttttttttttttttttttttt0';
select count(1) from t_row where c4 != 'ttttttttttttttttttttttttttttttttttttttt0';
select count(1) from t_column where c4 != 'ttttttttttttttttttttttttttttttttttttttt0';

select count(1) from t_row where c1 > 'ttttttttttttttttttttttttttttttttttttttt0' and c4 < 'ttttttttttttttttttttttttttttttttttttttt999';
select count(1) from t_row where c1 > 'ttttttttttttttttttttttttttttttttttttttt0' and c4 < 'ttttttttttttttttttttttttttttttttttttttt999';
select count(1) from t_column where c1 > 'ttttttttttttttttttttttttttttttttttttttt0' and c4 < 'ttttttttttttttttttttttttttttttttttttttt999';
select count(1) from t_column where c1 > 'ttttttttttttttttttttttttttttttttttttttt0' and c4 < 'ttttttttttttttttttttttttttttttttttttttt999';

select * from t_row where c1 in ('ttttttttttttttttttttttttttttttttttttttt77', 'ttttttttttttttttttttttttttttttttttttttt89', 'a');
select * from t_row where c4 in ('ttttttttttttttttttttttttttttttttttttttt77', 'ttttttttttttttttttttttttttttttttttttttt89', 'a');
select * from t_column where c1 in ('ttttttttttttttttttttttttttttttttttttttt77', 'ttttttttttttttttttttttttttttttttttttttt89', 'a');
select * from t_column where c4 in ('ttttttttttttttttttttttttttttttttttttttt77', 'ttttttttttttttttttttttttttttttttttttttt89', 'a');

explain select min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(c5), max(c5) from t_row;
explain select /*+ DBMS_STATS */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(c5), max(c5) from t_row;
select min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(c5), max(c5) from t_row;
select /*+ DBMS_STATS */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(c5), max(c5) from t_row;

explain select min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(c5), max(c5) from t_column;
explain select /*+ DBMS_STATS */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(c5), max(c5) from t_column;

select min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(c5), max(c5) from t_column;
select /*+ DBMS_STATS */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(c5), max(c5) from t_column;

insert into t_row values('t', 't', 't', 't', 999999);
insert into t_column values('t', 't', 't', 't', 999999);

select min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(c5), max(c5) from t_row;
select /*+ DBMS_STATS */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(c5), max(c5) from t_row;
select min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(c5), max(c5) from t_column;
select /*+ DBMS_STATS */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(c5), max(c5) from t_column;

--disable_query_log
--disable_warnings
drop table if exists t_row, t_column;
--enable_warnings
--enable_query_log
