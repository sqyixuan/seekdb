# owner: liquanhong.lqh
# owner group: storage
# description: check skip index in_operator

--disable_query_log
connect (conn1, $OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
set @@session.explicit_defaults_for_timestamp=off;
set session ob_trx_timeout=100000000000;
alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 1;
sleep 2;
set @@recyclebin = off;
--enable_query_log

connection conn1;
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

CREATE TABLE t1 (c1 int(11) DEFAULT NULL) WITH COLUMN GROUP(each column);
CREATE TABLE t2 (c1 int(11) DEFAULT NULL) WITH COLUMN GROUP(each column);

--disable_query_log

let $cnt = 1;
while($cnt <= 100)
{
    eval insert into t1 values ($cnt);
    eval insert into t2 values (1);
    inc $cnt;
}

--enable_query_log

connection default;
alter system major freeze;
alter system flush plan cache;
--source mysql_test/include/wait_daily_merge.inc

connection conn1;

# datums[datums.count()-1] < min_datum <= max_datum
select * from t1 where c1 in (-2, 0, -3, -1);

# min_datum <= datums[pos] < max_datum
select * from t1 where c1 in (-2, 0, 1, -3, -1);

# min_datum <= max_datum < datums[0]
select * from t1 where c1 in (103, 101, 104, 102);

# datums[pos-1] < min_datum <= max_datum < datums[pos]
select * from t1 where c1 in (-2, 0, 103, 101, -3, -1, 104, 102);

# min_datum == max_datum == datums[pos]
select count(*) from t2 where c1 in (1, 1, 1);

# min_datum != max_datum and max_datum == datums[pos]
select * from t1 where c1 in (-2, 0, 100, -3, -1);

drop table t1;
drop table t2;
--disable_query_log
connection syscon;
alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 0;
set @@recyclebin = on;
--enable_query_log
