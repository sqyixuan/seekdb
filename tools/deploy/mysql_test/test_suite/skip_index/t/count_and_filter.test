# owner: baichangmin.bcm
#tags: optimizer
# description: basic test for brin index scan correctness

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (
    a int auto_increment primary key skip_index(min_max),
    b bigint skip_index(min_max),
    c char(30) skip_index(min_max),
    d varchar(100) skip_index(min_max),
    e bigint skip_index(min_max),
    f char(80) skip_index(min_max)) row_format = dynamic block_size = 2048;
insert into t1 (b, c, d, e, f) values(1, "a", repeat('a', 100), 1, CONCAT(REPEAT('a', 40), REPEAT(x'19', 40)));
insert into t1 (b, c, d, e, f) values(2, "ab", repeat("ab", 50), 10, CONCAT(REPEAT('a', 40), REPEAT(x'19', 40)));
insert into t1 (b, c, d, e, f) values(3, "ab", NULL, 100, CONCAT(REPEAT('a', 40), REPEAT(x'19', 40)));
insert into t1 (b, c, d, e, f) values(NULL, "abcd", repeat("ab", 50), 1000, CONCAT(REPEAT('a', 40), REPEAT(x'19', 40)));
insert into t1 (b, c, d, e, f) values(5, "abc", repeat("a", 100), 10000, CONCAT(REPEAT('a', 40), REPEAT(x'19', 40)));
insert into t1 (b, c, d, e, f) values(6, "abc", repeat("abcd", 25), 1000, CONCAT(REPEAT('a', 40), REPEAT('b', 40)));
insert into t1 (b, c, d, e, f) values(7, "abcd", repeat("abbb", 25), 100, CONCAT(REPEAT('a', 40), REPEAT('b', 40)));
insert into t1 (b, c, d, e, f) values(8, "abcde", repeat("accc", 25), 10, CONCAT(REPEAT('a', 40), REPEAT('b', 40)));
insert into t1 (b, c, d, e, f) values(9, NULL, repeat("ab", 50), 1, CONCAT(REPEAT('a', 40), REPEAT('b', 40)));
insert into t1 (b, c, d, e, f) values(10, "abcde", repeat("accc", 25), 100, CONCAT(REPEAT('a', 40), REPEAT('b', 40)));
--let $loop=12
while($loop > 0)
{
  insert into t1 (b, c, d, e, f) select b, c, d, e, f from t1;
  dec $loop;
}
select count(1) from t1;

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--enable_query_log

alter system major freeze tenant all;
--source mysql_test/include/wait_daily_merge.inc

connection default;
alter system set _enable_skip_index = true;

select count(1) from t1 where b > 11;
select count(1) from t1 where b > 11 and c != '';
select count(1) from t1 where (b > 11 and c != '') or c = 'ccc';
select count(1) from t1 where (b > 11 and c != '') and c like '%ccc%';
select count(1) from t1 where (b > 11 and c != '') or c like '%ccc%';
select count(1) from t1 where (b > 11 and c != '') or c like '%a%';
select count(1) from t1 where e > 0;
select count(1) from t1 where e > 0 or b < 0;
select count(1) from t1 where e > 0 and c like '%a%';
select count(1) from t1 where f > CONCAT(REPEAT('a', 40), REPEAT(x'19', 40));

--let $loop=10
while($loop > 0)
{
  insert into t1 (b, c, d, e, f) values(0, "ee", repeat("ee", 50), 0, repeat('a',80));
  dec $loop;
}

# count
select count(1) from t1;
select count(b) from t1;
select count(c) from t1;
select count(d) from t1;

# filter
# EQ NE LE LT GE GT BT IN NU NN

# int with null
select count(1) from t1 where b = 5;
select count(1) from t1 where b != 5;
select count(1) from t1 where b <= 5;
select count(1) from t1 where b < 5;
select count(1) from t1 where b >= 5;
select count(1) from t1 where b > 5;
select count(1) from t1 where b between 5 and 10;
select count(1) from t1 where b in (5, 6, 2222);

# char(30) with null
select count(1) from t1 where c = "ab";
select count(1) from t1 where c != "ab";
select count(1) from t1 where c < "ab";
select count(1) from t1 where c <= "ab";
select count(1) from t1 where c > "ab";
select count(1) from t1 where c >= "ab";
select count(1) from t1 where c between "a" and "abc";
select count(1) from t1 where c in ("a", "ab", "zz");

# varchar(100) with null
select count(1) from t1 where d = repeat("ab", 50);
select count(1) from t1 where d != repeat("ab", 50);
select count(1) from t1 where d < repeat("ab", 50);
select count(1) from t1 where d <= repeat("ab", 50);
select count(1) from t1 where d > repeat("ab", 50);
select count(1) from t1 where d >= repeat("ab", 50);
select count(1) from t1 where d between repeat("ab", 50) and repeat("accc", 25);
select count(1) from t1 where d in (repeat("ab", 50), repeat("accc", 25), repeat("zzzz", 25));

# char(80) without null
select count(1) from t1 where f = CONCAT(REPEAT('a', 40), REPEAT(x'19', 40));
select count(1) from t1 where f != CONCAT(REPEAT('a', 40), REPEAT(x'19', 40));
select count(1) from t1 where f < CONCAT(REPEAT('a', 40), REPEAT(x'19', 40));
select count(1) from t1 where f <= CONCAT(REPEAT('a', 40), REPEAT(x'19', 40));
select count(1) from t1 where f > CONCAT(REPEAT('a', 40), REPEAT(x'19', 40));
select count(1) from t1 where f >= CONCAT(REPEAT('a', 40), REPEAT(x'19', 40));
select count(1) from t1 where f between CONCAT(REPEAT('a', 40), REPEAT(x'19', 40)) and CONCAT(REPEAT('a', 40), REPEAT('c', 40));
select count(1) from t1 where f in (CONCAT(REPEAT('a', 40), REPEAT(x'19', 40)), CONCAT(REPEAT('a', 40), REPEAT('c', 40)));

# black filter  combine white filter
select count(1) from t1 where b > 5 and c > "ab" and d < repeat("accc", 25);
select count(1) from t1 where b > 5 and c > d;

connection obsys;

# test major freeze twice
alter system major freeze tenant all;
--source mysql_test/include/wait_daily_merge.inc

connection default;

# count
select count(1) from t1;
explain select count(b) from t1;
select count(b) from t1;
select count(c) from t1;
select count(d) from t1;

# filter
# EQ NE LE LT GE GT BT IN NU NN

# int with null
explain select count(1) from t1 where b = 5;
select count(1) from t1 where b = 5;
select count(1) from t1 where b != 5;
select count(1) from t1 where b <= 5;
select count(1) from t1 where b < 5;
select count(1) from t1 where b >= 5;
select count(1) from t1 where b > 5;
select count(1) from t1 where b between 5 and 10;
select count(1) from t1 where b in (5, 6, 2222);

# char(30) with null
select count(1) from t1 where c = "ab";
select count(1) from t1 where c != "ab";
select count(1) from t1 where c < "ab";
select count(1) from t1 where c <= "ab";
select count(1) from t1 where c > "ab";
select count(1) from t1 where c >= "ab";
select count(1) from t1 where c between "a" and "abc";
select count(1) from t1 where c in ("a", "ab", "zz");

# char(80) without null
select count(1) from t1 where f = CONCAT(REPEAT('a', 40), REPEAT(x'19', 40));
select count(1) from t1 where f != CONCAT(REPEAT('a', 40), REPEAT(x'19', 40));
select count(1) from t1 where f < CONCAT(REPEAT('a', 40), REPEAT(x'19', 40));
select count(1) from t1 where f <= CONCAT(REPEAT('a', 40), REPEAT(x'19', 40));
select count(1) from t1 where f > CONCAT(REPEAT('a', 40), REPEAT(x'19', 40));
select count(1) from t1 where f >= CONCAT(REPEAT('a', 40), REPEAT(x'19', 40));
select count(1) from t1 where f between CONCAT(REPEAT('a', 40), REPEAT(x'19', 40)) and CONCAT(REPEAT('a', 40), REPEAT('c', 40));
select count(1) from t1 where f in (CONCAT(REPEAT('a', 40), REPEAT(x'19', 40)), CONCAT(REPEAT('a', 40), REPEAT('c', 40)));

# varchar(100) with null
select count(1) from t1 where d = repeat("ab", 50);
select count(1) from t1 where d != repeat("ab", 50);
select count(1) from t1 where d < repeat("ab", 50);
select count(1) from t1 where d <= repeat("ab", 50);
select count(1) from t1 where d > repeat("ab", 50);
select count(1) from t1 where d >= repeat("ab", 50);
select count(1) from t1 where d between repeat("ab", 50) and repeat("accc", 25);
select count(1) from t1 where d in (repeat("ab", 50), repeat("accc", 25), repeat("zzzz", 25));

# black filter  combine white filter
explain select count(1) from t1 where b > 5 and c > "ab" and d < repeat("accc", 25);
select count(1) from t1 where b > 5 and c > "ab" and d < repeat("accc", 25);
select count(1) from t1 where b > 5 and c > d;

drop table t1;


--disable_query_log
set global max_allowed_packet=16777216;
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log

connection obsys;
alter system set _rowsets_enabled = true tenant = 'sys';
