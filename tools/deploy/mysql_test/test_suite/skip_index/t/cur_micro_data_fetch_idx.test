# owner: liquanhong.lqh
# owner group: storage
# description: check cur_micro_data_fetch_idx_ in locate_in_prefetched_data

--disable_query_log
connect (conn1, $OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
set @@session.explicit_defaults_for_timestamp=off;
set session ob_trx_timeout=100000000000;
alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 1;
sleep 2;
set @@recyclebin = off;
--enable_query_log

connection conn1;
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (
  c2 timestamp(1) NOT NULL DEFAULT '0000-00-00 00:00:00.0',
  c12 varbinary(65) NOT NULL,
  c20 char(152) COLLATE utf8mb4_bin NOT NULL,
  c23 char(152) COLLATE utf8mb4_bin NOT NULL,
  PRIMARY KEY (c23, c20, c12)
) AUTO_INCREMENT = 1000300 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = redundant REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 WITH COLUMN GROUP(all columns, each column);

let $LOAD_SOURCE_DATA_FOLDER = "$PWD/mysql_test/test_suite/skip_index/data/cur_micro_data_fetch_idx.tar.gz";
let $UNZIP_FILE= "cur_micro_data_fetch_idx.tar.gz";
--source mysql_test/include/copy_data_and_unzip.inc

connection conn1;
load data /*+ parallel(10) direct(true, 0) */
infile 'data_for_mysqltest_loaddata/cur_micro_data_fetch_idx.csv'
into table t1
FIELDS TERMINATED BY ',' ENCLOSED BY '\"';

connection default;
alter system major freeze;
alter system flush plan cache;
--source mysql_test/include/wait_daily_merge.inc

connection conn1;

select c23 from t1 where c23 like '%000%' and c2 > '1990-01-04 10:04:11.0' order by c23 desc;

drop table t1;
--disable_query_log
connection syscon;
set @@recyclebin = on;
alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 0;
--enable_query_log
