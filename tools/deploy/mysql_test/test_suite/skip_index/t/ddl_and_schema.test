create table test_sum_type(c1 BOOL SKIP_INDEX(SUM),
  c2 TINYINT SKIP_INDEX(SUM),
  c3 MEDIUMINT SKIP_INDEX(SUM),
  c4 INT SKIP_INDEX(SUM),
  c5 BIGINT SKIP_INDEX(SUM),
  c6 DECIMAL(5, 2) SKIP_INDEX(SUM),
  c7 FLOAT SKIP_INDEX(SUM),
  c8 DOUBLE SKIP_INDEX(SUM));

# test size limit
--disable_warnings
DROP TABLE IF EXISTS test_max_size;
--enable_warnings
--error ER_NOT_SUPPORTED_YET
CREATE TABLE test_max_size(
  c1 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c2 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c3 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c4 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c5 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c6 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c7 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c8 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c9 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c10 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c11 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c12 varchar(1024) SKIP_INDEX(MIN_MAX)
);
CREATE TABLE test_max_size(
  c1 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c2 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c3 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c4 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c5 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c6 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c7 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c8 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c9 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c10 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c11 varchar(1024) SKIP_INDEX(MIN_MAX)
);
DROP TABLE test_max_size;


# test secondary index
--disable_warnings
DROP TABLE IF EXISTS test_secondary_index;
--enable_warnings

CREATE TABLE test_secondary_index(c1 int SKIP_INDEX(MIN_MAX), c2 int SKIP_INDEX(MIN_MAX), c3 varchar(1024) SKIP_INDEX(MIN_MAX), INDEX i1 (c3, c2, c1));

connection obsys;
SELECT column_id, column_name, skip_index_attr FROM oceanbase.__all_virtual_column WHERE table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_secondary_index') ORDER BY column_id ASC;

SELECT column_id, column_name, skip_index_attr FROM oceanbase.__all_virtual_column WHERE table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE data_table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_secondary_index')) ORDER BY column_id ASC;

connection default;

DROP TABLE test_secondary_index;


#test alter column
--disable_warnings
DROP TABLE IF EXISTS test_alter_column;
--enable_warnings

CREATE TABLE test_alter_column(c1 int SKIP_INDEX(MIN_MAX), c2 int SKIP_INDEX(MIN_MAX), c3 varchar(1024), c4 float, INDEX i1 (c3, c2, c1));


connection obsys;

SELECT column_id, column_name, skip_index_attr FROM oceanbase.__all_virtual_column WHERE table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column') ORDER BY column_id ASC;
SELECT progressive_merge_round FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column';
SELECT column_id, column_name, skip_index_attr FROM oceanbase.__all_virtual_column WHERE table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE data_table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column')) ORDER BY column_id ASC;
SELECT progressive_merge_round FROM oceanbase.__all_virtual_table WHERE data_table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column');

connection default;

ALTER TABLE test_alter_column modify column c1 int;

connection obsys;

SELECT column_id, column_name, skip_index_attr FROM oceanbase.__all_virtual_column WHERE table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column') ORDER BY column_id ASC;
SELECT progressive_merge_round FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column';
SELECT column_id, column_name, skip_index_attr FROM oceanbase.__all_virtual_column WHERE table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE data_table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column')) ORDER BY column_id ASC;
SELECT progressive_merge_round FROM oceanbase.__all_virtual_table WHERE data_table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column');

connection default;

ALTER TABLE test_alter_column modify column c1 int SKIP_INDEX(MIN_MAX);

connection obsys;

SELECT column_id, column_name, skip_index_attr FROM oceanbase.__all_virtual_column WHERE table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column') ORDER BY column_id ASC;
SELECT progressive_merge_round FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column';
SELECT column_id, column_name, skip_index_attr FROM oceanbase.__all_virtual_column WHERE table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE data_table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column')) ORDER BY column_id ASC;
SELECT progressive_merge_round FROM oceanbase.__all_virtual_table WHERE data_table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column');

connection default;

ALTER TABLE test_alter_column modify column c1 int SKIP_INDEX();

connection obsys;

connection default;

ALTER TABLE test_alter_column modify column c1 int SKIP_INDEX(SUM);

connection obsys;

SELECT column_id, column_name, skip_index_attr FROM oceanbase.__all_virtual_column WHERE table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column') ORDER BY column_id ASC;
SELECT progressive_merge_round FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column';
SELECT column_id, column_name, skip_index_attr FROM oceanbase.__all_virtual_column WHERE table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE data_table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column')) ORDER BY column_id ASC;
SELECT progressive_merge_round FROM oceanbase.__all_virtual_table WHERE data_table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_alter_column');

connection default;

DROP TABLE test_alter_column;


# test add column
--disable_warnings
DROP TABLE IF EXISTS test_add_column;
--enable_warnings

CREATE TABLE test_add_column(
  c1 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c2 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c3 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c4 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c5 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c6 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c7 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c8 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c9 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c10 varchar(1024) SKIP_INDEX(MIN_MAX), 
  c11 varchar(1024) SKIP_INDEX(MIN_MAX)
);

connection obsys;

SELECT column_id, column_name, skip_index_attr FROM oceanbase.__all_virtual_column WHERE table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_add_column') ORDER BY column_id ASC;
SELECT progressive_merge_round FROM oceanbase.__all_virtual_table WHERE table_name = 'test_add_column';

connection default;
--error ER_NOT_SUPPORTED_YET
ALTER TABLE test_add_column ADD COLUMN (c12 varchar(1024) SKIP_INDEX(MIN_MAX));

connection obsys;

SELECT column_id, column_name, skip_index_attr FROM oceanbase.__all_virtual_column WHERE table_id = (SELECT table_id FROM oceanbase.__all_virtual_table WHERE table_name = 'test_add_column') ORDER BY column_id ASC;
SELECT progressive_merge_round FROM oceanbase.__all_virtual_table WHERE table_name = 'test_add_column';

connection default;

DROP TABLE test_add_column;


# test describe table and show create table

--disable_warnings
DROP TABLE IF EXISTS test_desc_table;
--enable_warnings

CREATE TABLE test_desc_table(
    c1 bigint auto_increment skip_index(min_max, sum),
    c2 int not null skip_index(),
    c3 int,
    c4 int skip_index(sum),
    c5 varchar(1024) skip_index(min_max));

SHOW CREATE TABLE test_desc_table;

DESC test_desc_table;

ALTER TABLE test_desc_table MODIFY COLUMN c4 int skip_index(min_max);

SHOW CREATE TABLE test_desc_table;

DESC test_desc_table;

DROP TABLE test_desc_table;

--disable_query_log
set global max_allowed_packet=16777216;
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log

connection obsys;
alter system set _rowsets_enabled = true tenant = 'sys';
