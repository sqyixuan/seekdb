# owner: saitong.zst
# tags: skip_index
# description: basic ddl for skip index and schema

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
disconnect default;
sleep 1;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
--enable_query_log


# test data type
--disable_warnings
DROP TABLE IF EXISTS test_data_type;
--enable_warnings
--error ER_NOT_SUPPORTED_YET
CREATE TABLE test_data_type(c1 JSON SKIP_INDEX(MIN_MAX));
--error ER_NOT_SUPPORTED_YET
CREATE TABLE test_data_type(c1 GEOMETRY SKIP_INDEX(MIN_MAX));
--error ER_NOT_SUPPORTED_YET
CREATE TABLE test_data_type(c1 POINT SKIP_INDEX(MIN_MAX));
--error ER_NOT_SUPPORTED_YET
CREATE TABLE test_data_type(c1 LINESTRING SKIP_INDEX(MIN_MAX));
--error ER_NOT_SUPPORTED_YET
CREATE TABLE test_data_type(c1 POLYGON SKIP_INDEX(MIN_MAX));
--error ER_NOT_SUPPORTED_YET
CREATE TABLE test_data_type(c1 MULTILINESTRING SKIP_INDEX(MIN_MAX));
--error ER_NOT_SUPPORTED_YET
CREATE TABLE test_data_type(c1 MULTIPOINT SKIP_INDEX(MIN_MAX));
--error ER_NOT_SUPPORTED_YET
CREATE TABLE test_data_type(c1 MULTIPOLYGON SKIP_INDEX(MIN_MAX));
--error ER_NOT_SUPPORTED_YET
CREATE TABLE test_data_type(c1 GEOMETRYCOLLECTION SKIP_INDEX(MIN_MAX));

CREATE TABLE test_data_type(c1 TEXT SKIP_INDEX(MIN_MAX));
DROP TABLE test_data_type;

CREATE TABLE test_data_type(c1 MEDIUMTEXT SKIP_INDEX(MIN_MAX));
DROP TABLE test_data_type;

CREATE TABLE test_data_type(c1 LONGTEXT SKIP_INDEX(MIN_MAX));
DROP TABLE test_data_type;

CREATE TABLE test_data_type(c1 TINYTEXT SKIP_INDEX(MIN_MAX));
DROP TABLE test_data_type;

CREATE TABLE test_data_type(c1 ENUM('value1','value2') SKIP_INDEX(MIN_MAX));
DROP TABLE test_data_type;

CREATE TABLE test_data_type(c1 SET('value1','value2') SKIP_INDEX(MIN_MAX));
DROP TABLE test_data_type;


