--enable_warnings
--error ER_NOT_SUPPORTED_YET
CREATE TABLE test_sum_type(c1 TEXT SKIP_INDEX(SUM));
--error ER_NOT_SUPPORTED_YET
CREATE TABLE test_sum_type(c1 MEDIUMTEXT SKIP_INDEX(SUM));
--error ER_NOT_SUPPORTED_YET
CREATE TABLE test_sum_type(c1 LONGTEXT SKIP_INDEX(SUM));
--error ER_NOT_SUPPORTED_YET
