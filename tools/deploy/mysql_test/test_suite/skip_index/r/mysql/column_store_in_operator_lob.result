drop table if exists t1;
CREATE TABLE t1 (
id int(11) DEFAULT NULL,
c1 varchar(20) COLLATE utf8mb4_bin DEFAULT NULL,
c2 int(11) DEFAULT NULL,
c3 char(20) COLLATE utf8mb4_bin DEFAULT NULL,
c4 datetime DEFAULT NULL,
c5 text COLLATE utf8mb4_bin DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 WITH COLUMN GROUP(all columns, each column);
alter system major freeze;
alter system flush plan cache;
set ob_query_timeout=1000000000;
select * from t1 where c5 in ('abc', 'def') order by c1;
id	c1	c2	c3	c4	c5
drop table t1;
