DROP TABLE IF EXISTS tt;
CREATE TABLE tt (
id VARCHAR(2000) PRIMARY KEY,
val_int INT,
val_0 VARCHAR(2000),
val_1 VARCHAR(2000),
val_2 VARCHAR(2000),
val_3 VARCHAR(2000),
val_4 VARCHAR(2000),
val_5 VARCHAR(2000),
val_6 VARCHAR(2000),
val_7 VARCHAR(2000),
val_8 VARCHAR(2000),
val_9 VARCHAR(2000)
)
row_format = redundant compression = 'none';
