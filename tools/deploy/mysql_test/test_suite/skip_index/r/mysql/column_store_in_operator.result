drop table if exists t1;
drop table if exists t2;
CREATE TABLE t1 (c1 int(11) DEFAULT NULL) WITH COLUMN GROUP(each column);
CREATE TABLE t2 (c1 int(11) DEFAULT NULL) WITH COLUMN GROUP(each column);
alter system major freeze;
alter system flush plan cache;
select * from t1 where c1 in (-2, 0, -3, -1);
c1
select * from t1 where c1 in (-2, 0, 1, -3, -1);
c1
1
select * from t1 where c1 in (103, 101, 104, 102);
c1
select * from t1 where c1 in (-2, 0, 103, 101, -3, -1, 104, 102);
c1
select count(*) from t2 where c1 in (1, 1, 1);
count(*)
100
select * from t1 where c1 in (-2, 0, 100, -3, -1);
c1
100
drop table t1;
drop table t2;
