--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhenling.zzg
# # owner group: SQL3
# # Test of functions tan
# # tags: tan, datatype,静态sql,dual,CRUD

--disable_warnings
drop database if exists tan_test;
create database tan_test;
use tan_test;

drop table if exists w0case;
drop table if exists w1case;
--enable_warnings

--echo # obmysql-tan 通过性测试
create table w0case(w_test varchar(100));
insert into w0case values('100');
select round(tan(w_test),5) from w0case;

--echo # obmysql-tan 参数数量
--error 01582
select tan() from w0case;
select round(tan(12),5) from dual;
--error 01582
select tan(12,1) from dual;
drop table w0case;
--disable_warnings
--echo # obmysql-tan char类型
create table w0case(w_test char(200));
insert into w0case values('111');
insert into w0case values('a');
insert into w0case values('a11');
insert into w0case values('33.4456456142f');
insert into w0case values('-33.445645614245d');
select round(tan(w_test),5) from w0case where w_test = '111';
select tan(w_test) from w0case where w_test = 'a';
select tan(w_test) from w0case where w_test = 'a11';
select tan(w_test) from w0case where w_test = '33.4456456142f';
select tan(w_test) from w0case where w_test = '-33.445645614245d';
drop table w0case;

--echo # obmysql-tan varchar type
create table w0case(w_test varchar(100));
insert into w0case values('111');
insert into w0case values('33.4456456142f');
insert into w0case values('-33.445645614245d');
select round(tan(w_test),5) from w0case where w_test = '111';
select tan(w_test) from w0case where w_test = '33.4456456142f';
select tan(w_test) from w0case where w_test = '-33.445645614245d';
--enable_warnings
--echo # obmysql date/datetime/interval type
SELECT ROUND(tan('20200601'),5) FROM dual;
SELECT tan('2020-06-01') FROM dual;
select tan('2020:06:01') from  dual;
select ROUND(tan('20191001030204'),5) from dual;
select tan('2020-06-01 03:02:05') from dual;
drop table w0case;

--echo # obmysql number type
CREATE TABLE w0case(w_test decimal(38,10));
INSERT INTO w0case VALUES (222);
INSERT INTO w0case VALUES (33.4);
INSERT INTO w0case VALUES(335.11111);
SELECT ROUND(tan(W_TEST),5) FROM W0CASE WHERE W_TEST = 222;
SELECT ROUND(tan(W_TEST),5) FROM W0CASE WHERE W_TEST = 33.4;
SELECT ROUND(tan(W_TEST),5) FROM W0CASE WHERE W_TEST = 335.11111;
SELECT ROUND(tan(-1.0e-130)) FROM dual;
SELECT tan(1.0e+126) FROM dual;

--echo # mysql及ob在超越边界值是返回值为0
SELECT tan(-1.0e-131) FROM dual;
--echo # mysql返回未0，ob返回为数值
SELECT tan(1.0e+125) FROM dual;
DROP TABLE W0CASE;
CREATE TABLE W0CASE(w_test varchar(100));
INSERT INTO W0CASE values('12h3');
DROP TABLE W0CASE;
--echo # obmysql blob type
CREATE TABLE W0CASE(w_test blob);
INSERT INTO W0CASE VALUES ('123');
SELECT ROUND(tan(w_test)) FROM W0CASE;
DROP TABLE W0CASE;

--echo # obmysql 特殊符号，空格等
--error 01064
SELECT tan(1 23) FROM dual;
--error 01064
SELECT tan(123%) FROM dual;
--echo # obmysql 函数嵌套
SELECT ROUND(tan(45),5) FROM dual;
SELECT tan(tan(12)) FROM dual;
SELECT tan(MOD(11,4)) FROM dual;
SELECT tan(POWER(3,2)) FROM  dual;

--echo # obmysql 多级函数嵌套/被嵌套
SELECT ROUND(POWER(tan(15),2),5) FROM dual;
SELECT ROUND(tan(POWER(2,3)),5) FROM dual WHERE tan(POWER(2,3))>tan(POWER(2,4));
SELECT ROUND(POWER(ROUND(ATAN(ROUND(tan(45),5)),5),2),5) FROM dual;
SELECT tan(ROUND(POWER(ROUND(ATAN(ROUND(tan(45),5)),5),2),5)) FROM dual;
SELECT ROUND(tan(POWER(2,3)),5) FROM dual WHERE tan(45) = tan(45);
SELECT tan(CAST('2019-05-20' AS DATE)) FROM dual;
SELECT tan(CAST('19.2' as decimal(10,2))) FROM dual;

--echo # obmysql 基础运算
SELECT tan(235-123) FROM dual;
SELECT tan(12*12) FROM dual;
SELECT tan(12+12) FROM dual;
SELECT tan(12/12) FROM dual;
SELECT tan(POWER(2,3)+POWER(2,2)) FROM dual;
CREATE TABLE w0case(w_test decimal(38,10));
INSERT INTO w0case VALUES(0);
INSERT INTO w0case VALUES(1);
INSERT INTO w0case VALUES(2);
INSERT INTO w0case VALUES(3);
SELECT tan(w_test) FROM w0case WHERE w_test IS NULL;
SELECT tan(w_test) FROM w0case WHERE w_test IS NOT NULL;
SELECT tan(w_test) FROM w0case WHERE w_test IN (0,1,2,3,4);
SELECT tan(w_test) FROM w0case WHERE w_test NOT IN (4,5,6);
SELECT tan(w_test) FROM w0case WHERE w_test BETWEEN 0 AND 4;
SELECT tan(w_test) FROM w0case WHERE w_test NOT BETWEEN 4 AND 6;
DROP TABLE W0CASE;

--echo # obmysql tan特殊值
SELECT TAN(0 * 3.14159265359/180) FROM dual;
SELECT TAN(45 * 3.14159265359/180) FROM dual;
SELECT TAN(90 * 3.14159265359/180) FROM dual;
SELECT TAN(180 * 3.14159265359/180) FROM dual;
SELECT TAN(270 * 3.14159265359/180) FROM dual;
SELECT TAN(360 * 3.14159265359/180) FROM dual;

--echo # obmysql 静态sql
--echo # obmysql select operation
CREATE TABLE w0case(w_test0 decimal(38,10),w_test1 varchar(11));
--echo # 空值查询
SELECT tan(W_TEST0) FROM W0CASE;
INSERT INTO w0case VALUES(0,'a');
--echo # 单值查询
SELECT tan(w_test0) FROM w0case;
INSERT INTO w0case VALUES(1,'b');
INSERT INTO w0case VALUES(2,'c');
INSERT INTO w0case VALUES(3,'d');
INSERT INTO w0case VALUES(4,'e');
INSERT INTO w0case VALUES(5,'f');
INSERT INTO w0case VALUES(15,'15');
INSERT INTO w0case VALUES(15,'15f');

--echo # 多值查询
SELECT tan(w_test0) FROM w0case;
--echo # group by having
SELECT tan(w_test0) FROM W0CASE GROUP BY w_test0;
SELECT tan(w_test0),w_test1 FROM W0CASE GROUP BY w_test0,w_test1 HAVING w_test1 = 'c';
SELECT tan(w_test0),w_test1 FROM W0CASE GROUP BY w_test0,w_test1 HAVING w_test1 IN ('a','b','c');
SELECT tan(w_test0),w_test1 FROM W0CASE GROUP BY w_test0,w_test1 HAVING w_test0 BETWEEN 0 AND 4;
SELECT tan(w_test0),w_test1 FROM W0CASE GROUP BY w_test0,w_test1 HAVING tan(w_test0)>0;
SELECT tan(w_test0),tan(w_test1) FROM W0CASE GROUP BY w_test0,w_test1 HAVING tan(w_test0)>0 AND w_test1 NOT IN('a','b','c','d','e','f') ;
SELECT tan(w_test0),tan(w_test1) FROM W0CASE GROUP BY w_test0,w_test1 HAVING w_test1 NOT IN('a','b','c','d','e','f','15') ;

--echo # order by 
SELECT tan(w_test0) FROM W0CASE ORDER BY w_test0;
SELECT tan(w_test0) FROM W0CASE ORDER BY w_test0 DESC;
SELECT tan(w_test0) FROM W0CASE ORDER BY w_test0 ASC;
SELECT tan(w_test0),w_test1 FROM W0CASE ORDER BY w_test1;
SELECT tan(w_test0),w_test1 FROM W0CASE ORDER BY w_test1 DESC;
SELECT tan(w_test0),w_test1 FROM W0CASE ORDER BY w_test1 ASC;
SELECT tan(w_test0),w_test1 FROM W0CASE GROUP BY w_test0,w_test1 HAVING tan(w_test0)>0 ORDER BY w_test0 DESC;

--echo # case when
SELECT CASE w_test0 WHEN 5 THEN tan(w_test0)+100 END AS si FROM W0CASE;
SELECT tan(CASE WHEN w_test0<100 THEN tan(w_test0) END)+tan(45) AS si FROM W0CASE;
SELECT tan(CASE WHEN w_test0>100 THEN tan(w_test0) ELSE 100 END)/tan(10) AS si FROM W0CASE;
--echo # distinct
SELECT DISTINCT tan(w_test0),w_test1 FROM W0CASE;
DROP TABLE W0CASE;
--echo # obmysql insert operation
CREATE TABLE W0CASE(w_test varchar(100));
--echo # 插入单条语句
INSERT INTO W0CASE VALUES(DEFAULT);
INSERT INTO W0CASE SELECT tan(10) FROM dual;
INSERT INTO W0CASE SELECT tan(10)*2 FROM dual;
INSERT INTO W0CASE SELECT tan(10)/2 FROM dual;
DROP TABLE W0CASE;

--echo # obmysql DELETE operation
CREATE TABLE w0case(w_test varchar(100));
INSERT INTO w0case VALUES ('100');
--echo # 单行/多行
DELETE FROM W0CASE we WHERE tan(we.w_test)<tan(20) ;
--echo # where
INSERT INTO w0case VALUES ('500');
DELETE FROM w0case WHERE tan(w_test) = (SELECT tan(w_test) FROM W0CASE WHERE w_test >ROUND(tan(W_TEST ),5) GROUP BY W_TEST HAVING ROUND(tan(W_TEST ),6 )>0 ) ; 
INSERT INTO w0case VALUES ('400');
INSERT INTO w0case VALUES ('300');
DELETE FROM W0CASE WHERE tan(W_TEST) > ( SELECT * FROM ( SELECT MIN(tan(W_TEST ) ) FROM W0CASE WHERE tan(W_TEST ) < 100 ORDER BY tan(W_TEST ) ) );
INSERT INTO w0case VALUES ('200');
DELETE FROM W0CASE WHERE tan(W_TEST ) IN (SELECT tan(W_TEST ) FROM W0CASE );
INSERT INTO w0case VALUES ('800');
DELETE FROM W0CASE WHERE tan(W_TEST) = ( SELECT tan(W_TEST) FROM ( SELECT * FROM W0CASE ORDER BY tan(W_TEST ) DESC ));
DROP TABLE IF EXISTS W0CASE;
DROP TABLE IF EXISTS w1case;

--echo # obmysql dual operation
SELECT tan(45) * tan(45) FROM dual;
SELECT tan(45) / tan(45) FROM dual;
SELECT tan(45) + tan(45) FROM dual;
SELECT tan(45) - tan(45) FROM dual;

--echo # cleanup
drop database tan_test;
