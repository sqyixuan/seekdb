#owner: luofan.zp
#owner group: SQL2
#description: ATAN2
#tags: select,delete,insert,DROP,dual
#author: wb-swh776788

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop database if exists luofan_db;
drop table if exists atan2_table001;
--enable_warnings
create database luofan_db;
use luofan_db;

--disable_warnings
--disable_abort_on_error
-- echo atan2 参数个数要求
select atan2(3,1) from dual;
SELECT atan2(atan2(1,2),2) from dual;
select atan2(NULL,null)  from dual;
SELECT atan2(10,null) from dual;
SELECT atan2(NULL,10) from dual;

-- echo 空值 0
select atan2(0) from dual;
select atan2(' ') from dual;
select atan2('   ') from dual;

--error 0, 1582
select atan2(3,1,1) from dual;
select atan2(3*3,1,1) from dual;
SELECT atan2() from dual;

-- echo  atan2
select atan2(-1,3) from dual;
SELECT atan2(0,1) from dual;
SELECT atan2(1,0) from dual;
SELECT atan2(0,-1) from dual;
SELECT atan2(-1e-10,-1) from dual;
SELECT atan2(-1,0) from dual;
select atan2(atan2(atan2(2,3),atan2(2,4)),2)from dual;
SELECT atan2(2,1)/atan2(2,3)*atan2(2,2) from dual;
SELECT (atan2(2,1)-atan2(2,2)) from dual;
SELECT atan2(10e3,2) from dual;

-- echo 零值，除0
SELECT atan2(0,0) from dual;
select atan2(3/0,1)  from dual;
SELECT atan2(1,3/0) from dual;

--error 0,1054
SELECT atan2(a,1) from dual;
SELECT atan2(1,a) from dual;

-- echo  atan2 char
drop table if exists atan2_table001;
create table atan2_table001(a char(2));
insert into atan2_table001 values('3');
SELECT atan2(e.a,e.a) from atan2_table001 e;

drop table if exists atan2_table001;
create table atan2_table001(a char(20));
insert into atan2_table001 values('1e1');
SELECT atan2(e.a,e.a) from atan2_table001 e;

drop table if exists atan2_table001;
create table atan2_table001(a char(20));
insert into atan2_table001 values('b');
SELECT atan2(e.a,e.a) from atan2_table001 e;

-- echo atan2 varchar
drop table if exists atan2_table001;
create table atan2_table001(a VARCHAR(20));
insert into atan2_table001 values('10');
SELECT atan2(e.a,e.a) from atan2_table001 e;

drop table if exists atan2_table001;
create table atan2_table001(a VARCHAR(20));
insert into atan2_table001 values('1.0E+001');
SELECT e.a from atan2_table001 e;
SELECT atan2(e.a,e.a) from atan2_table001 e;

-- echo atan2 blob
drop table if exists atan2_table001;
create table atan2_table001(a BLOB);
insert into atan2_table001 values('10');
SELECT atan2(e.a,e.a) from atan2_table001 e;

-- echo atan2 decimal
drop table if exists atan2_table001;
create table atan2_table001(a DECIMAL);
insert into atan2_table001 values('10');
SELECT atan2(e.a,e.a) from atan2_table001 e;


-- echo atan2 integer
drop table if exists atan2_table001;
create table atan2_table001(a INTEGER);
insert into atan2_table001 values('10.5');
SELECT atan2(e.a,e.a) from atan2_table001 e;

--echo atan2 参数类型不同
drop table if exists atan2_table001;
create table atan2_table001(a char(2),b VARCHAR(20));
insert into atan2_table001 values(3,4);
SELECT atan2(e.a,e.b) from atan2_table001 e;

-- echo atan2 length
select  atan2(length('Hello World!'),1) from dual;
SELECT  atan2(length('ab'),1) from dual;

-- echo atan2 replace
select atan2(replace('1','1','10'),1) from dual;

-- echo atan2 abs(value)
select atan2(abs(-10),1) from dual;

-- echo atan2 ceil(value)
select atan2(ceil(2.3),1) from dual;

-- echo atan2 floor(value)
select  atan2(floor(2.3),2) from dual;

-- echo atan2 round
select atan2(round(555.666)/5,1) from dual;
select atan2(round(555.666,2)/5,1) from dual;
select atan2(round(555.666,-2)/5,1) from dual;

drop table atan2_table001;

#clean up
drop database luofan_db;