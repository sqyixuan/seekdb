#owner: lana.lgx
#owner group: data
#description: dbms_mview_stats 
#tags: pl
#author: suzhi.yt

--disable_query_log

#################### Reset system default ####################
--echo #
--echo # Reset system default
--echo #

CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('COLLECTION_LEVEL', NULL);
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('RETENTION_PERIOD', NULL);
SELECT collection_level, retention_period FROM oceanbase.__all_mview_refresh_stats_sys_defaults;

#################### Case1 COLLECTION_LEVEL ####################
--echo #
--echo # Case1 COLLECTION_LEVEL
--echo #

CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('COLLECTION_LEVEL', 'NONE');
SELECT collection_level, retention_period FROM oceanbase.__all_mview_refresh_stats_sys_defaults;

CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('COLLECTION_LEVEL', 'TYPICAL');
SELECT collection_level, retention_period FROM oceanbase.__all_mview_refresh_stats_sys_defaults;

CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('COLLECTION_LEVEL', 'ADVANCED');
SELECT collection_level, retention_period FROM oceanbase.__all_mview_refresh_stats_sys_defaults;

--disable_result_log

--error 1210
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('COLLECTION_LEVEL', 'xxxxx');

--error 1210
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('COLLECTION_LEVEL', 'NULL');

--error 1318
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('COLLECTION_LEVEL');

--error 1210
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('COLLECTION_LEVEL', 0);

--enable_result_log

CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('COLLECTION_LEVEL', NULL);

#################### Case2 RETENTION_PERIOD ####################
--echo #
--echo # Case2 RETENTION_PERIOD
--echo #

CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('RETENTION_PERIOD', -1);
SELECT collection_level, retention_period FROM oceanbase.__all_mview_refresh_stats_sys_defaults;

CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('RETENTION_PERIOD', 1);
SELECT collection_level, retention_period FROM oceanbase.__all_mview_refresh_stats_sys_defaults;

CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('RETENTION_PERIOD', 100000);
SELECT collection_level, retention_period FROM oceanbase.__all_mview_refresh_stats_sys_defaults;

CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('RETENTION_PERIOD', 365000);
SELECT collection_level, retention_period FROM oceanbase.__all_mview_refresh_stats_sys_defaults;

--disable_result_log

--error 1210
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('RETENTION_PERIOD', -2);

--error 1210
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('RETENTION_PERIOD', 0);

--error 1210
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('RETENTION_PERIOD', 365001);

--error 1210
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('RETENTION_PERIOD', 99999999);

--error 1318
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('RETENTION_PERIOD');

--error 1366
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('RETENTION_PERIOD', 'NULL');

--enable_result_log

CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('RETENTION_PERIOD', NULL);

#################### Case3 Bad parameter name ####################
--echo #
--echo # Case3  Bad parameter name
--echo #

--disable_result_log

--error 1644
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT(NULL, NULL);

--error 1644
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT(NULL, 'NULL');

--error 1644
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('NULL', NULL);

--error 1644
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('NULL', 'NULL');

--error 1644
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT(NULL, 'ADVANCED');

--error 1644
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('xxx', 'ADVANCED');

--error 1644
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT(NULL, 31);

--error 1644
CALL DBMS_MVIEW_STATS.SET_SYSTEM_DEFAULT('xx', 31);

--enable_result_log

--enable_query_log 
