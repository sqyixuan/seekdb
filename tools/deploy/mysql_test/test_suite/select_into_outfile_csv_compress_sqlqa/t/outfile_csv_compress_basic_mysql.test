####format中参数的异常场景####
##parquet,orc相关参数不会起效##
--source mysql_test/include/select_into_outfile/delete_files.inc
select c1, c2, c3, c4, c5, c6, c7, c8, c9, c10, c11, c12, c13, c14, c15, c16, c17, c18, c19, c20, c21, c22, c23, c24, c25, c26, c27, c28, c29, c30, c31, c32, c33, c34, c35, c36, c37 from zct2 into outfile 'outfile_data_csv/tmp_csv'
format(
type = 'csv',
LINE_DELIMITER = '\n',
FIELD_DELIMITER = ',',
ESCAPE = '\\',
FIELD_OPTIONALLY_ENCLOSED_BY = '\"',
FIELD_ENCLOSED_BY = '\"',
NULL_IF = ('空'),
SKIP_HEADER = 0,
SKIP_BLANK_LINES = false,
TRIM_SPACE = false,
EMPTY_FIELD_AS_NULL = false,
ENCODING = 'utf8mb4',
COMPRESSION = gzip
FILE_EXTENSION = 'csv',
ROW_GROUP_SIZE = '1gB',
COMPRESSION_BLOCK_SIZE = '1kB',
STRIPE_SIZE = '1mb',
ROW_INDEX_STRIDE = 1
) single = false;

alter external table ex_par refresh;
select * from ex_par;

