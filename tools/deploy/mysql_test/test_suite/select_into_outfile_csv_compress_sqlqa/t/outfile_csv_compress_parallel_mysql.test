format(
type = 'csv'
COMPRESSION = none
FILE_EXTENSION = '.csv'
) single = false MAX_FILE_SIZE = '10B' BUFFER_SIZE = '1MB';

--error 0,1051
drop table ex_par;
create external table ex_par(
c1 INT as (metadata$filecol1),
c2 varchar(50) as (metadata$filecol2),
c3 date as (metadata$filecol3),
c4 datetime as (metadata$filecol4),
c6 time as (metadata$filecol5)
)
format(type = 'csv',COMPRESSION = auto) location 'outfile_data_csv/' pattern = 'tmp_csv';

SELECT count(*) FROM ex_par;
SELECT * FROM ex_par limit 10;

