--error 0,1051
drop table zct1_par_ra_ha;
create table zct1_par_ra_ha( A int, b varchar(10),c date,d blob,e decimal(10,2),f json) partition by range( A) subpartition by hash( A) (
partition p0 values less than (5) (
subpartition sp0,
subpartition sp1,
subpartition sp2),
partition p1 values less than (10) (
subpartition sp3,
subpartition sp4,
subpartition sp5),
partition p2 values less than (MAXVALUE) (
subpartition sp6,
subpartition sp7,
subpartition sp8));

