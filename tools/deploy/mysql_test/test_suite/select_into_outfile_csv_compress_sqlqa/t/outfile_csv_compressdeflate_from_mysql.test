####dual
##select outfile csv无法从dual导出null
--source mysql_test/include/select_into_outfile/delete_files.inc
select /*+parallel(3) */1 c1,'a' c2,'这行数据来自dual' c3,'' C4,'2021-07-01' C5,null c6 from dual into outfile 'outfile_data_csv/tmp_csv'
format(
type = 'csv'
COMPRESSION = deflate
FILE_EXTENSION = '.csv'
) single = false;

--error 0,1051
drop table ex_par;
create external table ex_par(
c1 BIGINT as (metadata$filecol1),
c2 varchar(50) as (metadata$filecol2),
c3 VARchar(50) as (metadata$filecol3),
C4 VARCHAR(10) as (metadata$filecol4),
C5 VARCHAR(10) as (metadata$filecol5),
C6 VARCHAR(10) as (metadata$filecol6)
)
format(type = 'csv',COMPRESSION = auto) location 'outfile_data_csv/' pattern = 'tmp_csv';

SELECT * FROM ex_par;


##系统表
##结果符合预期，结果可能不稳定，注释
--disable_parsing
select /*+parallel(3) */TABLE_NAME c1,TABLE_SCHEMA c2,'数据来自系统表' c3 from information_schema.TABLES t where TABLE_SCHEMA = 'mysql' or TABLE_SCHEMA ='test' into outfile 'outfile_data_csv/tmp_csv'
format(
type = 'csv'
COMPRESSION = deflate
FILE_EXTENSION = '.csv'
) single = false;

--error 0,1051
drop table ex_par;
create external table ex_par(
c1 char(50) as (metadata$filecol1),
c2 varchar(50) as (metadata$filecol2),
c3 VARchar(50) as (metadata$filecol3)
)
format(type = 'csv',COMPRESSION = auto) location 'outfile_data_csv/' pattern = 'tmp_csv';

SELECT * FROM ex_par;
