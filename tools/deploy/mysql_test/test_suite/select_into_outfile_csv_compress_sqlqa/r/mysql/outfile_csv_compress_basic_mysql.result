result_format: 4
PURGE RECYCLEBIN;


DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS zct2;
CREATE table t1(c1 int,c2 varchar(50),c3 DATE);
INSERT INTO t1 VALUES(1,'a','0001-01-01');
INSERT INTO t1 VALUES(2,'b','0002-02-02');
INSERT INTO t1 VALUES(3,'c','0003-03-03');
select * from t1 into outfile 'outfile_data_csv/tmp_csv.gz'
format(
type = 'csv',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4',
COMPRESSION = gzip
FILE_EXTENSION = '.gz'
) single = true;
drop table ex_par;
create external table ex_par(c1 int ,c2 varchar(50),c3 date)
format(
type = 'csv',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4',
COMPRESSION = gzip
) location 'outfile_data_csv/' pattern = 'tmp_csv';
select * from ex_par;
