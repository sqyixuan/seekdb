##parallel(5) false含lob类型->40个文件，5个线程文件数量不平均，行数平均##
select /*+parallel(5)*/ a,b,c,d,f,g,h,i from zct1 t into outfile 'outfile_data_csv/tmp_csv'
format(
type = 'csv'
COMPRESSION = zstd
FILE_EXTENSION = '.csv'
) single = false MAX_FILE_SIZE = '1B' BUFFER_SIZE = '1MB';
drop table ex_par;
create external table ex_par(
c1 INT as (metadata$filecol1),
c2 varchar(50) as (metadata$filecol2),
c3 date as (metadata$filecol3),
c4 datetime as (metadata$filecol4),
c5 datetime as (metadata$filecol9),
c6 time as (metadata$filecol5),
c7 smallint as (metadata$filecol6),
c8 varchar(50) as (metadata$filecol7),
c9 varchar(50) as (metadata$filecol8)
)
format(type = 'csv',COMPRESSION = auto) location 'outfile_data_csv/' pattern = 'tmp_csv_0_4_0';
SELECT count(*) FROM ex_par;
+----------+
| count(*) |
+----------+
|        0 |
+----------+
##parallel(5) false 9行数据->生成5个文件，每条线程写一个，最后一条线程数据减半##
insert into zct2 values(2, ' ', '2020-01-02', '2020-01-02 00:00:00', '2020-01-02 00:00:00', '00:00:01', 2021, 'Blob', 'Text', 2.1, 3.2, 4.3, 2 );
insert into zct2 select * from zct2;
insert into zct2 select * from zct2;
insert into zct2 values(2, ' ', '2020-01-02', '2020-01-02 00:00:00', '2020-01-02 00:00:00', '00:00:01', 2021, 'Blob', 'Text', 2.1, 3.2, 4.3, 2 );
select /*+parallel(5)*/ a,b,c,d,f,g,h,i from zct2 t into outfile 'outfile_data_csv/tmp_csv'
format(
type = 'csv'
COMPRESSION = zstd
FILE_EXTENSION = '.csv'
) single = false MAX_FILE_SIZE = '256mB' BUFFER_SIZE = '1MB';
drop table ex_par;
create external table ex_par(
c1 INT as (metadata$filecol1),
c2 varchar(50) as (metadata$filecol2),
c3 date as (metadata$filecol3),
c4 datetime as (metadata$filecol4),
c5 datetime as (metadata$filecol9),
c6 time as (metadata$filecol5),
c7 smallint as (metadata$filecol6),
c8 varchar(50) as (metadata$filecol7),
c9 varchar(50) as (metadata$filecol8)
)
format(type = 'csv',COMPRESSION = auto) location 'outfile_data_csv/' pattern = 'tmp_csv_0_4_0';
SELECT count(*) FROM ex_par;
