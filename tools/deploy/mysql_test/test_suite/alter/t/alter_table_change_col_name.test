# owner : dachuan.sdc
# owner group : SQL1
# description : 测试 mysql 模式下列名被改动之后主表和索引表的 part_func_expr 也要随之改变，否则可能会导致正确性问题
# tags: ddl

--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists xiaofeng_db1;
--enable_warnings
create database xiaofeng_db1;
use xiaofeng_db1;

## 测试一级分区表和全局索引
CREATE TABLE t1 (
   id INT NOT NULL, 
   fname VARCHAR(30), 
   lname VARCHAR(30), 
   hired DATE NOT NULL DEFAULT '1970-01-01', 
   separated DATE NOT NULL DEFAULT '9999-12-31', 
   job_code INT, 
   store_id INT
)
PARTITION BY HASH(YEAR(hired)) 
   PARTITIONS 4;
create index gidx_t1 on t1(hired) global partition by hash(YEAR(hired)) PARTITIONS 8;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
let $db_id = query_get_value(select DATABASE_ID from oceanbase.__all_database where DATABASE_NAME = 'xiaofeng_db1', DATABASE_ID, 1);
let $t1_id = query_get_value(select TABLE_ID from oceanbase.__all_table where DATABASE_ID = $db_id and TABLE_NAME = 't1', TABLE_ID, 1);
--disable_query_log
eval select PART_FUNC_EXPR from oceanbase.__all_table where DATA_TABLE_ID = $t1_id;
--enable_query_log
alter table t1 change column hired guyong DATE;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
--disable_query_log
eval select PART_FUNC_EXPR from oceanbase.__all_table where DATA_TABLE_ID = $t1_id;
--enable_query_log

## 测试二级分区表和全局索引
create table t2(a int, b int, c int, d int, e int, primary key(a,b,c,d))
partition by range columns(a, b) subpartition by key(c, d) subpartitions 2 (
  partition p0 values less than (5, 5),
  partition p1 values less than (maxvalue, maxvalue)
);
create index gidx on t2(c, d) global partition by key (c, d);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
let $t2_id = query_get_value(select TABLE_ID from oceanbase.__all_table where DATABASE_ID = $db_id and TABLE_NAME = 't2', TABLE_ID, 1);
--disable_query_log
eval select PART_FUNC_EXPR from oceanbase.__all_table where DATA_TABLE_ID = $t2_id;
--enable_query_log
alter table t2 change column a aa int;
# alter table t2 change column c cc int;
alter table t2 change column b bb int;
# alter table t2 change column d dd int;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
--disable_query_log
eval select PART_FUNC_EXPR from oceanbase.__all_table where DATA_TABLE_ID = $t2_id;
--enable_query_log

--echo #
--echo # BUG#29298845 - rename column name does not fix the check_expr of the check constraint
--echo #
create table t3(c1 int, c2 int, constraint cst check(c1 = c2));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t3;
alter table t3 change column c1 c12 int;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t3;
drop table t3;

# clean up
drop database xiaofeng_db1;
