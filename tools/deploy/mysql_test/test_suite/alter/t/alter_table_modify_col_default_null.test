--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL2
# description: 用于测试 mysql 模式下 alter table modify/change col 时不允许把主键列设置为 default null

--disable_warnings
drop database if exists xiaofeng_db;
--enable_warnings
create database xiaofeng_db;
use xiaofeng_db;

# 主键列为单列场景，modify 主键列为 default null
create table t1(c1 int primary key, c2 char);
alter table t1 modify c2 char default null;
--error ER_PRIMARY_CANT_HAVE_NULL
alter table t1 modify c1 int default null;

# 主键列为多列场景，modify 主键列为 default null
create table t2(c1 int, c2 char, c3 int, primary key(c1, c2));
alter table t2 modify c3 int default null;
--error ER_PRIMARY_CANT_HAVE_NULL
alter table t2 modify c1 int default null;
--error ER_PRIMARY_CANT_HAVE_NULL
alter table t2 modify c2 char default null;

# 主键列为单列场景，change 主键列为 default null
create table t3(c1 int primary key, c2 char);
alter table t3 change c2 c2 char default null;
--error ER_PRIMARY_CANT_HAVE_NULL
alter table t3 change c1 c1 int default null;

# 主键列为多列场景，change 主键列为 default null
create table t4(c1 int, c2 char, c3 int, primary key(c1, c2));
alter table t4 change c3 c3 int default null;
--error ER_PRIMARY_CANT_HAVE_NULL
alter table t4 change c1 c1 int default null;
--error ER_PRIMARY_CANT_HAVE_NULL
alter table t4 change c2 c2 char default null;

# clean up
drop table t1,t2;
drop table t3,t4;
drop database xiaofeng_db;
