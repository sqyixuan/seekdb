--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: 本case是为了测试alter table add column时，处理旧行填充值的问题；
# tags: ddl

--disable_warnings
drop table if exists test;
--enable_warnings

let $type=int;
let $value=5;
--source mysql_test/include/alter_table_default_value.inc
let $type=char(10);
let $value='abc';
--source mysql_test/include/alter_table_default_value.inc
let $type=binary(10);
let $value='abc';
--source mysql_test/include/alter_table_default_value.inc
let $type=varchar(10);
let $value='abc';
--source mysql_test/include/alter_table_default_value.inc
let $type=varbinary(10);
let $value='abc';
--source mysql_test/include/alter_table_default_value.inc
let $type=time;
let $value='12:23:12';
--source mysql_test/include/alter_table_default_value.inc
let $type=datetime;
let $value='2011-01-12 12:23:12';
--source mysql_test/include/alter_table_default_value.inc
let $type=year;
let $value='2011';
--source mysql_test/include/alter_table_default_value.inc
let $type=date;
let $value='2011-01-12';
--source mysql_test/include/alter_table_default_value.inc



set @@sql_mode='pad_char_to_full_length';
let $type=char(10);
let $value='abc';
--source mysql_test/include/alter_table_default_value.inc
set @@sql_mode = 'strict_all_tables';


##############
#  特殊处理timestamp列
##############
drop table test;
create table test(c1 int primary key, c2 int);
insert into test values(1, 2);
echo 'add the first column timestmp';
alter table test add column c6 timestamp;
select count(*) from test where datediff(now(), c6) < 1;

echo 'add the second timestamp column';
alter table test add column c7 timestamp;
select c7 from test;

drop table test;
create table test(c1 int primary key, c2 int);
insert into test values(1,2);
echo 'add the first column timestmp with not null';
alter table test add column c6 timestamp not null;
select count(*) from test where datediff(now(), c6) < 1;

drop table test;
create table test(c1 int primary key, c2 int);
insert into test values(1,2);
echo 'add the first column timestmp with null';
alter table test add column c6 timestamp null;
select * from test;

drop table test;
create table test(c1 int primary key, c2 int);
insert into test values(1,2);
echo 'add the first column timestmp wih default values';
alter table test add column c6 timestamp default '2010-12-23 21:23:23';
select * from test;


drop table test;
create table test(c1 int primary key, c2 int);
insert into test values(1,2);
echo 'add the first column timestmp wih default values and not null';
alter table test add column c6 timestamp not null default '2010-12-23 21:23:23';
select * from test;

drop table test;
create table test(c1 int primary key, c2 int);
insert into test values(1,2);
echo 'add the first column timestmp wih default values and null';
alter table test add column c6 timestamp null default '2010-12-23 21:23:23';
select * from test;

#bug: 
drop table test;
create table test(c1 timestamp default '2010-12-23 21:23:23', c2 int);
insert into test values('2010-12-24 21:23:23', 2);
echo 'add the first column timestmp wih as default column';
alter table test add column c6 timestamp as (default(c1));
select * from test;

###############
# 增加自增列报warning
###############
drop table test;
create table test(c1 int primary key, c2 int);
insert into test values(1,2);
alter table test add column c6 int auto_increment;
show warnings;

#########
#########
drop table test;
create table test(c1 int primary key, c2 int);
insert into test values(1,2);
alter table test modify column c2 int not null; 
show warnings;

######
#not null和null不能同时存在
########
drop table test;
--error 5252
create table test(c1 int primary key, c2 int not null null);

####
# binary列不容许调大
#####
create table test(c1 int primary key, c2 binary(5));
alter table test modify column c2 binary(10);
drop table test;
create table test(c1 int primary key, c2 varbinary(5));
alter table test modify column c2 varbinary(10);
drop table test;

####
# binary not null add column 默认值为'\0\0\0'
####
create table test(c1 int primary key, c2 int);
insert into test values(1,2);
alter table test add column c3 binary(5);
alter table test add column c4 binary(5) not null;
alter table test add column c5 varbinary(5);
alter table test add column c6 varbinary(5) not null;
select hex(c3),hex(c4),hex(c5),hex(c6) from test;
drop table test;

--echo #bugfix 
--error 1067
create table test(c1 float default '');
--error 1067
create table test(c1 double default '');
create table test(c1 int primary key);
--error 1067
alter table test add column c2 float default '';
--error 1067
alter table test add column c2 double default '';
drop table test;
