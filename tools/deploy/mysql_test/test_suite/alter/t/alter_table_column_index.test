# owner: link.zt
# owner group: SQL2
# description:
# 下面的sql测试alter table时增加给列增加unique key的功能
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--disable_warnings
drop table if exists test_alter_table_banliu_tab1;
--enable_warnings

create table test_alter_table_banliu_tab1 (col1 int, col2 int, col1_cmp int, col2_cmp int);

# test MODIFY COLUMN
--echo test modify column unique key
alter table test_alter_table_banliu_tab1 modify column col1 int unique;
alter table test_alter_table_banliu_tab1 add unique index (col1_cmp);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table test_alter_table_banliu_tab1;
show index from test_alter_table_banliu_tab1;
select * from information_schema.statistics where table_name = 'test_alter_table_banliu_tab1';
select * from information_schema.table_constraints where table_name = 'test_alter_table_banliu_tab1' order by 1,2,3;
connection my_obsys;
eval
select column_id, column_name, rowkey_position, is_hidden, nullable from oceanbase.__all_virtual_column where table_id in (select table_id from oceanbase.__all_virtual_table where table_name = 'test_alter_table_banliu_tab1');
connection default;
alter table test_alter_table_banliu_tab1 drop index col1_cmp;

# test CHANGE COLUMN
--echo test change column unique key
alter table test_alter_table_banliu_tab1 change column col2 col__2 int unique;
alter table test_alter_table_banliu_tab1 change column col2_cmp col__2_cmp int;
alter table test_alter_table_banliu_tab1 add unique index (col__2_cmp);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table test_alter_table_banliu_tab1;
show index from test_alter_table_banliu_tab1;
select * from information_schema.statistics where table_name = 'test_alter_table_banliu_tab1';
select * from information_schema.table_constraints where table_name = 'test_alter_table_banliu_tab1' order by 1,2,3;
connection my_obsys;
eval
select column_id, column_name, rowkey_position, is_hidden, nullable from oceanbase.__all_virtual_column where table_id in (select table_id from oceanbase.__all_virtual_table where table_name = 'test_alter_table_banliu_tab1');
connection default;
alter table test_alter_table_banliu_tab1 drop index col__2_cmp;

# test ADD COLUMN
--echo test add column unique key
alter table test_alter_table_banliu_tab1 add column col3 int unique;
alter table test_alter_table_banliu_tab1 add column col3_cmp int;
alter table test_alter_table_banliu_tab1 add unique index (col3_cmp);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table test_alter_table_banliu_tab1;
show index from test_alter_table_banliu_tab1;
select * from information_schema.statistics where table_name = 'test_alter_table_banliu_tab1';
select * from information_schema.table_constraints where table_name = 'test_alter_table_banliu_tab1' order by 1,2,3;
connection my_obsys;
eval
select column_id, column_name, rowkey_position, is_hidden, nullable from oceanbase.__all_virtual_column where table_id in (select table_id from oceanbase.__all_virtual_table where table_name = 'test_alter_table_banliu_tab1');
connection default;
alter table test_alter_table_banliu_tab1 drop index col3_cmp;

# test ADD COLUMNs
alter table test_alter_table_banliu_tab1 add column (col4 int unique, col5 char(20) unique, col6 int);
alter table test_alter_table_banliu_tab1 add column (col4_cmp int, col5_cmp char(20), col6_cmp int);
alter table test_alter_table_banliu_tab1 add unique index (col4_cmp);
alter table test_alter_table_banliu_tab1 add unique index (col5_cmp);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table test_alter_table_banliu_tab1;
show index from test_alter_table_banliu_tab1;
select * from information_schema.statistics where table_name = 'test_alter_table_banliu_tab1';
select * from information_schema.table_constraints where table_name = 'test_alter_table_banliu_tab1' order by 1,2,3;
connection my_obsys;
eval
select column_id, column_name, rowkey_position, is_hidden, nullable from oceanbase.__all_virtual_column where table_id in (select table_id from oceanbase.__all_virtual_table where table_name = 'test_alter_table_banliu_tab1');
connection default;
alter table test_alter_table_banliu_tab1 drop index col4_cmp, drop index col5_cmp;

drop table test_alter_table_banliu_tab1;

# test multi-partition table

--disable_warnings
drop table if exists test_alter_table_banliu_tab2;
--enable_warnings

create table test_alter_table_banliu_tab2 (col1 int, col2 int) partition by hash(col1) partitions 2;
alter table test_alter_table_banliu_tab2 modify col1 int unique;
alter table test_alter_table_banliu_tab2 modify col1 int unique;

drop table test_alter_table_banliu_tab2;

# bugfix#22793394 测试在有唯一索引的表上修改唯一索引列的类型，需要报不支持；修改非索引列的列类型是支持的
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int unique);
alter table t1 modify c1 bigint;
drop table t1;
create table t1(c1 int unique, c2 int);
alter table t1 modify c2 bigint;

# bugfix#24031071 测试用一条 alter table 语句同时有多个 modify column 子句的时候，可以正常检查表上索引的合法性
drop table t1;
create table t1(c1 varchar(1), c2 varchar(1), unique key(c1, c2));
--error 1071
alter table t1 modify c1 varchar(10000), modify c2 varchar(10000);
alter table t1 modify c1 varchar(10), modify c2 varchar(10);
--error 1071
alter table t1 change c1 c1 varchar(10000), change c2 c2 varchar(10000);
alter table t1 change c1 c1 varchar(10), change c2 c2 varchar(10);
drop table t1;

# bugfix#30908453 多个索引都包含了同一个列，用一条alter table一次性删掉所有包含了这个列的前缀索引，这个列就会被认为还在函数索引上而导致没法被drop/modify
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 varchar(10), c2 varchar(10), key i1(c1(3)), key i2(c1(3)));
alter table t1 drop key i1, drop key i2;
alter table t1 drop column c1;
drop table t1;
