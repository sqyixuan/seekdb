#owner: xiaoyi.xy
#owner group: sql1
##
## Test Name: alter_system_sql_audit
##
## Scope: Test alter system cmd for sql audit
##
## Date: 2018-11-22
##

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_query_log
--disable_result_log

alter system flush sql audit global;

connection default;

--echo
--echo // CASE#1 Test `alter system flush sql audit`

--echo
--echo // push sql audit

--echo
--enable_query_log
select 1 from dual;
select 1 from dual;

--echo
--echo // expect sql audit record number > 0
--enable_result_log
select count(*) > 0 from oceanbase.GV$OB_SQL_AUDIT where query_sql='select 1 from dual';

--echo
--echo // flush sql audit
connection conn_admin;

--disable_result_log
alter system flush sql audit global;

connection default;
--echo
--echo // expect sql audit number to be 0
--enable_result_log
select count(*) = 0 from oceanbase.GV$OB_SQL_AUDIT where query_sql='select 1 from dual';


--echo
--echo // CASE#2 Test system variable `ob_enable_sql_audit`

connect (conn_test,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_test;

--echo
--disable_result_log
set global ob_enable_sql_audit = false;

disconnect conn_test;
--sleep 3

connect (conn_test,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_test;

--echo
select 1 from dual;
select 1 from dual;

--echo
--echo // expect sql audit number = 0
--enable_result_log
select count(*) = 0 from oceanbase.GV$OB_SQL_AUDIT where query_sql='select 1 from dual';

--echo
set global ob_enable_sql_audit = true;




