create table jx_idx_t2222(c1 int, c2 int, c3 int, index(c2, c3));
insert into jx_idx_t2222 values(1,2,3);
set ob_enable_index_direct_select=1;
connection obsys;
let $index_table_name = query_get_value(select a.table_name c from oceanbase.__all_virtual_table a left join oceanbase.__all_virtual_table b on a.data_table_id = b.table_id where b.table_name = 'jx_idx_t2222' order by c desc limit 1, c, 1);
connection default;
--disable_query_log
eval select * from $index_table_name;
--enable_query_log

CREATE TABLE operation_version(id int primary key, `content_type` varchar(16) not null default '', `content` varchar(255) default '');
ALTER TABLE operation_version add `index_name` varchar(32) NOT NULL DEFAULT '' after `content_type`;
connection obsys;
select column_id, column_name, prev_column_id from oceanbase.__all_virtual_column where table_id in (
    select table_id from oceanbase.__all_virtual_table a left join oceanbase.__all_virtual_database b on a.database_id=b.database_id 
    where a.table_name = 'operation_version' and b.database_name='jx_db') order by column_id;
connection default;
--source mysql_test/include/show_create_table_old_version_replica2.inc
