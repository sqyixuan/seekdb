--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL2
# description: 本case是为了测试alter table add column指定column position: before / after column
# tags: ddl

--disable_warnings
drop database if exists jx_db;
create database jx_db;
use jx_db;
--enable_warnings

##############
# add column before/after/first
##############
create table t1(c1 int, c2 int, c3 int, index(c1));
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
select column_id, column_name, prev_column_id from oceanbase.__all_virtual_column where table_id in (
    select table_id from oceanbase.__all_virtual_table a left join oceanbase.__all_virtual_database b on a.database_id=b.database_id 
    where a.table_name = 't1' and b.database_name='jx_db') order by column_id;
connection default;
insert into t1 values(1, 2, 3);
desc t1;
show columns from t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
select * from t1;
select c1, c3 from t1;

create view v1 as select * from t1;
desc v1;

# add first
alter table t1 add column c4 varchar(20) default 'hello_ant' first;
connection obsys;
select column_id, column_name, prev_column_id from oceanbase.__all_virtual_column where table_id in (
    select table_id from oceanbase.__all_virtual_table a left join oceanbase.__all_virtual_database b on a.database_id=b.database_id 
    where a.table_name = 't1' and b.database_name='jx_db') order by column_id;
connection default;
desc t1;
show columns from t1;
