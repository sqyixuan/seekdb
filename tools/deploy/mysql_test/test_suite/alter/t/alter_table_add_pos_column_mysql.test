## 前缀索引
# 表中至少带有两个前缀索引，删除非最后一个前缀索引，#14894240
create table obschema_t_DDIgOJXS(obschema_c_0_jeo bit(32) NOT NULL default b'1101011011011011011010110110111',obschema_c_1_syehWM double auto_increment NOT NULL,obschema_c_2_4 varchar(1024) NULL default NULL,obschema_c_3_M varchar(200) NOT NULL default 'aEFGHI01',obschema_c_4_Am datetime NOT NULL default now(),obschema_c_5_4R int(255) NOT NULL,obschema_c_6_UQaAVy varchar(256) NULL,obschema_c_7_L9YZF varchar(512) NOT NULL,obschema_c_8_rzmpSW bigint(255) NOT NULL default 3,obschema_c_9_3NColy varchar(512) NOT NULL,index obschema_i_0_usFk(obschema_c_2_4(57)) LOCAL ,index obschema_i_1_Hv(obschema_c_2_4(383),obschema_c_4_Am) LOCAL ) progressive_merge_num=1;
connection obsys;
select column_id, column_name, prev_column_id from oceanbase.__all_virtual_column where table_id in (
    select table_id from oceanbase.__all_virtual_table a left join oceanbase.__all_virtual_database b on a.database_id=b.database_id 
    where a.table_name = 'obschema_t_DDIgOJXS' and b.database_name='jx_db') order by column_id;
connection default;
drop index obschema_i_0_usFk on obschema_t_DDIgOJXS;
connection obsys;
select column_id, column_name, prev_column_id from oceanbase.__all_virtual_column where table_id in (
    select table_id from oceanbase.__all_virtual_table a left join oceanbase.__all_virtual_database b on a.database_id=b.database_id 
    where a.table_name = 'obschema_t_DDIgOJXS' and b.database_name='jx_db') order by column_id;
connection default;

drop database jx_db;


