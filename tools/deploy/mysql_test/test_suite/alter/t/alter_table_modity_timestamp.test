--echo
--echo test for timestamp not null default value
set @@explicit_defaults_for_timestamp=on;
## explicit_defualt_for_timestamp must be ON
show variables like '%timestamp%';
--disable_warnings
drop table if exists add_time;
--enable_warnings
create table add_time(c1 int);
insert into add_time values(1),(2),(3);
alter table add_time add column(c2 timestamp not null);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table add_time;
select * from add_time;
drop table add_time;
