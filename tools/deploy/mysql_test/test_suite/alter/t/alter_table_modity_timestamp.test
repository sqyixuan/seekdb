--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: 本case是为了测试在alter table的时候处理timestamp列时的表现；
# tags: ddl, timestamp

--disable_warnings
drop table if exists test;
--enable_warnings

create table test (c1 int primary key);

echo 'the first timestamp + not null';
alter table test add column c2 timestamp not null on update current_timestamp;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table test;
echo 'alter column first timestamp drop default';
alter table test alter column c2 drop default;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table test;
echo 'alter column first timestamp add default';
