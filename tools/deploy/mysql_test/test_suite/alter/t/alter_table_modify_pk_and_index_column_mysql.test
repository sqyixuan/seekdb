# owner: dachuan.sdc
# owner group: SQL1
# description: 验证 alter table modify column 之后检查 string 类型的主键列和索引列长度逻辑出错的问题修复
# tags: ddl

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists xiaofeng_db1;
--enable_warnings
create database xiaofeng_db1;
use xiaofeng_db1;

## mysql 模式下字符串类型的长度语义默认是 char(字节) 语义，所以主键列和索引列中 string 类型列的长度和最大长度不能超过 16K byte（1 个 char(字符) 在 ob 的默认字符集下会换算成 4 个 byte(字节)）
create table t1(c1 varchar(4096) primary key, c2 varchar(4096), index t1_idx(c2));
--error 1071
alter table t1 modify c1 varchar(4097);
--error 1071
alter table t1 modify c2 varchar(4097);

create table t2(c1 varchar(2048), c2 varchar(2048), c3 varchar(2048), c4 varchar(2048),  primary key (c1, c2), index t2_idx(c3, c4));
--error 1071
alter table t2 modify c1 varchar(2049);
--error 1071
alter table t2 modify c3 varchar(2049);

# clean up
drop table t1;
drop table t2;
drop database xiaofeng_db1;