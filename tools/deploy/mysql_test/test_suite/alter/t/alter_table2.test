--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL2
# description:
#
use test;
--disable_warnings
drop table if exists at1;
drop table if exists jx_t1;
drop table if exists t1;
--enable_warnings
create table at1(c1 int primary key, c2 int not null default 5);
desc at1;
insert into at1 values (1,1),(2,2);
select * from at1;
#test defaut value of c3
alter table at1 add column c3 int not null default 3;
desc at1;
#test default value after add new row
insert into at1(c1,c2) values (3,3);
insert into at1(c1,c2,c3) values (4,4,4);
select * from at1;

#test default value of c2
insert into at1(c1,c3) values (5,5);
select * from at1;

#test default value alter change default value of c3
alter table at1 change c3 column3 int not null default 30;
desc at1;
#default value of c3 of old rows should not change
insert into at1 (c1,c2) values (6,6);
select * from at1;
alter table at1 alter column3 drop default;
desc at1;
select * from at1;
alter table at1 modify c2 int default 22, modify column3 int;
desc at1;
insert into at1(c1) values (7);
select * from at1;
alter table at1 drop column3;
desc at1;
alter table at1 add column (c3 int, c4 int default 4);
desc at1;
select * from at1;

alter table at1 add index idxt1 (c2,c3);
alter table at1 add index idxt2 (c3,c4);
alter table at1 add index idxt3 (c3);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table at1;
#alter table at1 drop column c3;
#show create table at1;
alter table at1 add unique uidx (c2,c4);
let $index_name = uidx;
--source mysql_test/include/check_all_idx_ok.inc
show index from at1;
sleep 1;
alter table at1 drop index uidx;
show index from at1;

#alter nullable
#
create table jx_t1 (c1 int);
insert into jx_t1 values (null);
--error ER_INVALID_USE_OF_NULL
alter table jx_t1 modify column c1 int not null;

#table option
#alter table at1 character set = 'utf8mb4';
alter table at1 set comment = 'I am table at1';
alter table at1 COMPRESSION = 'lz4_1.0';
#alter table example_1 set EXPIRE_INFO = thedate < date_sub(merging_frozen_time(), INTERVAL 1 DAY)
#alter table at1 replica_num = 1;
alter table at1 set block_size = 20480;
#alter table at1 set use_bloom_filter = true;
alter table at1 set progressive_merge_num = 2;
#alter table at1 progressive_merge_num = 2 use_bloom_filter = true;
create tablegroup tg1;
alter table at1 tablegroup = 'tg1';
#alter table at1 zone_list = ('z1', 'z2'); ??
#alter table at1 primary_zone = z1; ??
alter table at1 auto_increment = 2;
sleep 1;
alter table at1 rename to table1;
sleep 1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table table1;
alter table table1 rename to at1;
sleep 1;
--disable_warnings
drop table if exists at1;
--enable_warnings
drop tablegroup tg1;

# 测试新增列指定字符集
create table t1(c1 varchar(100));
alter table t1 add column c2 varchar(100) collate utf8mb4_bin;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

# 测试修改表的charset属性
alter table t1 CHARACTER SET = gbk;
alter table t1 collate = gbk_bin;
