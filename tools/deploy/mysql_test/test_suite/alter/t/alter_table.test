--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL2
# description:
#
#--disable_abort_on_error

## 1.创建正常的数据库,不带任何属性 
--disable_warnings
drop database  if exists db_1;
--enable_warnings
create database db_1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database db_1;

use db_1;

## 2. 创建表
CREATE TABLE m3(c1 BIGINT NULL, c2 CHAR(25) NOT NULL, c3 TINYINT(4) NULL, c4 CHAR(15) NOT NULL PRIMARY KEY, c5 INT NOT NULL UNIQUE KEY,c6 DECIMAL(10,8) NOT NULL DEFAULT 3.141592);

## 3. alter table drop default
create table t_0 (c0 float(5,3) not null primary key default 66.66, c1 bigint(181) not null);
desc t_0;

alter table t_0 alter column c0 drop default;
desc t_0;

## 4. alter table drop column
# drop first column
create table t_1(c0 decimal(5,3), c1 int(251) primary key, c2 float(5,3) not null default 55.55);
alter table t_1 drop column c0;
desc t_1;
# drop column
alter table t_1 drop column c2;
desc t_1;

## 5. 连续两次add column
create table t_5 (a int primary key);
 alter table t_5 add column nc1 double(5,3);
  alter table t_5 add column nc3 double(5,3);
desc t_5;

## 6. 修改列的default值
create table t_6(c0 tinyint(1) not null, c1 mediumint(207) not null primary key, c2 decimal(5,3) not null default 66.66);
desc t_6;
alter table t_6 alter column c2 set default 90.11;
desc t_6;

--disable_warnings
drop table if exists m3, t_0, t_1, t_5,t_6;
--enable_warnings

