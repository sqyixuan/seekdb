--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group:sql2
#description:
--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings
CREATE TABLE t1(c1 CHAR(30) NOT NULL, INDEX i1 (c1));
SHOW TABLES like 't1'; 
 --source mysql_test/include/show_create_table_old_version.inc
 show create table t1; 
ALTER TABLE t1 DROP KEY i1;
SHOW TABLES like 't1'; 
