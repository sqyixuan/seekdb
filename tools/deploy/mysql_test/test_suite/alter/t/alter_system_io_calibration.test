#owner: jianyun.sjy
#owner group: storage
##
## Test Name: alter_system_io_calibration
##
## Scope: Test alter system cmd for io calibration
##
## Date: 2022-03-29
##

connect(conn_sys, $OBMYSQL_MS0, root@sys, , oceanbase, $OBMYSQL_PORT);
connection conn_sys;

--echo // CASE 1: test built-in io calibration

--echo
--echo // cleanup io calibration data

alter system refresh io calibration calibration_info = ("");

select count(*) = 0 from GV$OB_IO_BENCHMARK;

--echo
--echo // run built-in io calibration

alter system run job "io_calibration";
# wait async job schedule
sleep 3;

select unique storage_name, status from GV$OB_IO_CALIBRATION_STATUS;

--echo
--echo // wait built-in io calibration finish

let $wait_count = 300;
let $server_count = `select count(*) from __all_virtual_io_calibration_status`;
while ($wait_count > 0)
{
  sleep 1;
  dec $wait_count;
  let $fail_count = `select count(*) from __all_virtual_io_calibration_status where status like "%FAIL%"`;
  if ($fail_count > 0)
  {
    let $wait_count = 0;
    --echo io calibration failed
  }
  let $succ_count = `select count(*) from __all_virtual_io_calibration_status where status like "READY"`;
  if ($succ_count == $server_count)
  {
    let $wait_count = 0;
    select unique storage_name, status from GV$OB_IO_CALIBRATION_STATUS;
  }
}

--echo
--echo // check io calibration data

select count(*) > 0 from GV$OB_IO_BENCHMARK;


--echo // CASE 2: test refresh io calibration data

--echo
--echo // cleanup io calibration data

alter system refresh io calibration calibration_info = ("");

select count(*) = 0 from GV$OB_IO_BENCHMARK;

--echo
--echo // admin set io calibration data

alter system refresh io calibration calibration_info = ("r:4K:100us:100000", "w:16K:200us:80000");
select count(*) > 0 from GV$OB_IO_BENCHMARK;


--echo
--echo // cleanup io calibration data

alter system refresh io calibration calibration_info = ("");

select count(*) = 0 from GV$OB_IO_BENCHMARK;
