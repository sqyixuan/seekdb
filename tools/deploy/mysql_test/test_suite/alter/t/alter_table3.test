--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL2
# description:
#
--disable_warnings
drop table if exists stu,name;
--enable_warnings
create table stu(id int primary key, name char(20));
insert into stu(id, name) values(1, 'zhang fei');
insert into stu(id, name) values(2, 'zhao yun');
insert into stu(id, name) values(3, 'zhen ji');
insert into stu(id, name) values(4, 'zhou yu');
insert into stu(id, name) values(5, 'zhu ge liang');
insert into stu(id, name) values(6, 'ma chao');

alter table stu add c1 int;
sleep 1;
alter table stu add column c2 char(90);
sleep 2;
--error 1054
alter table stu add c3 int, alter c3 drop default;
alter table stu change name name char(20);
alter table stu rename to stu1,rename to stu2,rename to stu5,rename to stu4;
alter table stu4 rename to stu;
--error 1054
alter table stu change column abcd acd char(11);
--error 1054
alter table stu change column abcd name char(11);


#--error 1235
#alter table stu add column ctm timestamp  default now();

#--error 1235
#alter table stu add column ctm2 timestamp default current_timestamp();

insert into stu (id, name, c1) values (7, 'han mei mei', 18);
insert into stu (id, name, c2) values (8, 'li lei', 'a boy');
select * from stu;

alter table stu add column c3 float, add column c4 varchar(1024), add column c5 int default 10;
sleep 2;
insert into stu (id, c3, c4, c5) values (9, '3.1415926', 'pi', 10);
select * from stu;
--error 1060
alter table stu add column c1 int;

--error 1068
alter table stu add column c7 int primary key;
--error 1064
alter table stu add column c7 createtime;
--error 1064
alter table stu add column c7 modifytime;
alter table stu add column c7 timestamp default now();
--error 1060
alter table stu add column c7 timestamp default current_timestamp();
alter table stu drop c7;
alter table stu drop c5;
sleep 1;
alter table stu drop column c4, drop c3, drop column c2;
sleep 2;
select * from stu;

--error 1235
alter table stu drop id;
--disable_warnings
drop table if exists stu_time;
--enable_warnings
create table stu_time(id int primary key, c_time datetime(6), m_time datetime);
sleep 2;
insert into stu_time(id) values(1);
alter table stu_time drop column c_time;
sleep 1;
alter table stu_time drop column m_time;
sleep 1;
drop table stu_time;

--error 1060
alter table stu add column c8 int, add column c8 int;
--error 1091
alter table stu drop column c8;
alter table stu drop column c1;
alter table stu add column c8 int;
sleep 1;
drop table stu;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 int);
create index c2 on t1(c2);

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name='t1' order by schema_version desc limit 1, table_id, 1);
let $idx = query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id='$table_id', table_name, 1);
connection default;

--echo test set table option
sleep 2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
SHOW CREATE TABLE t1;
--disable_query_log
#--replace_regex /__idx_[0-9]*/__idx/
#eval SHOW CREATE TABLE $idx;
--enable_query_log

--echo test set table option repeatedly
--error 1064
ALTER TABLE t1 SET EXPIRE_INFO (c2>1),SET TABLET_BLOCK_SIZE=10240, SET REPLICA_NUM=4, SET COMPRESSION 'method1', SET CONSISTENT_MODE=WEAK, set COMMENT 'table option test';
sleep 2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
SHOW CREATE TABLE t1;
--disable_query_log
#--replace_regex /__idx_[0-9]*/__idx/
#eval SHOW CREATE TABLE $idx;
connection obsys;
eval select expire_condition, compress_func_name, comment from oceanbase.__all_virtual_table where table_id =$table_id  or table_name='$idx';
eval select expire_condition, compress_func_name, comment from oceanbase.__all_virtual_table where table_id =$table_id  or table_name='$idx';
connection default;
--error 1064
eval ALTER TABLE t1 SET TABLE_ID=$table_id;
--enable_query_log
--error 1064
ALTER TABLE t1 SET JOIN_INFO '';
ALTER TABLE t1 SET DEFAULT CHARSET 'gbk';
ALTER TABLE t1 SET DEFAULT CHARACTER SET 'gbk';
sleep 1;
--disable_warnings
drop table if exists t2,t4;
--enable_warnings
--echo rename table
ALTER TABLE t1 RENAME TO t2;
sleep 1;
ALTER TABLE t2 RENAME TO t1;
sleep 1;
ALTER TABLE t1 RENAME TO t4,rename to t2;
--error 1146
ALTER TABLE t10 RENAME TO t5;
sleep 1;
--echo test alter column
ALTER TABLE t2 ADD c3 varchar(20) not null default 'aa', ADD c4 timestamp not null default '2013-06-20';
sleep 2;
desc t2;
ALTER TABLE t2 ADD c5 int not null;
ALTER TABLE t2 ALTER c2 SET default 12;
sleep 2;
desc t2;
--disable_query_log
--enable_query_log
--error 1064
ALTER TABLE t2 ALTER c2 SET NOT NULL;
ALTER TABLE t2 ALTER c2 DROP DEFAULT;
sleep 2;
desc t2;
--disable_query_log
--enable_query_log

--echo test drop column
ALTER TABLE t2 DROP c4;
sleep 2;
desc t2;
--echo test rename column
ALTER TABLE t2 change column c3 c4 varchar(20) not null default 'aa';
sleep 2;
desc t2;
--echo test drop index column
ALTER TABLE t2 DROP c2;

--echo test alter table option and column
ALTER TABLE t2 SET EXPIRE_INFO (c2>9), ALTER c4 SET DEFAULT 'bb';
sleep 2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
SHOW CREATE TABLE t2;
--disable_query_log
#--replace_regex /__idx_[0-9]*/__idx/
#eval SHOW CREATE TABLE $idx;
--enable_query_log
sleep 2;
desc t2;
drop table t2;

--disable_warnings
drop table if exists t_student;
--enable_warnings
create table t_student(id int primary key, name char(20), school varchar(32));
--error 1060
alter table t_student change name id char(20);
--error 1060
alter table t_student change name school char(20);

alter table t_student set progressive_merge_num=1;
alter table t_student set progressive_merge_num=2;
alter table t_student set progressive_merge_num=64;
alter table t_student set progressive_merge_num=65;
--error 1064
alter table t_student set progressive_merge_num=-1;
--error 1064
alter table t_student set progressive_merge_num=1.1;
--error 1064
alter table t_student set progressive_merge_num='abc';
--echo this is fine
alter table t_student change column name name char (20);
sleep 1;
ALTER TABLE t_student RENAME TO name;
sleep 2;
--error 1146
alter table t_student set progressive_merge_num=10;
alter table name  set progressive_merge_num=10;
sleep 2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table name;
--disable_warnings
drop table if exists name;
--enable_warnings

--echo test ALTER TABLE table_name MODIFY [COLUMN] column_name
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 varchar(100));
--echo modify column varchar length
alter table t1 modify column c2 varchar(101);
sleep 2;
desc t1;
alter table t1 modify c2 varchar(102);
sleep 2;
desc t1;
alter table t1 modify column c2 int;
alter table t1 modify column c2 varchar(100);
--echo forbid modify column primary key attribute
--error 1068
alter table t1 modify column c2 varchar(102) primary key;
alter table t1 modify column c1 int;
sleep 2;
desc t1;
#--echo forbid modify column attribute from nullable to not null
#--error 1235
#alter table t1 modify column c2 varchar(102) not null;
--echo not change column attribute
alter table t1 modify column c2 varchar(102);
sleep 2;
desc t1;
--echo modify column default value
alter table t1 modify column c2 varchar(102) default '11';
sleep 2;
desc t1;
--echo drop default value
alter table t1 modify column c2 varchar(102);
sleep 2;
desc t1;
--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_warnings
drop table if exists at1;
--enable_warnings
create table at1(c1 int not null primary key, c2 float);
alter table at1 add index idx1(c1);
alter table at1 add index (c1), add index (c1);
alter table at1 add index (c1);
alter table at1 add index (c1);
alter system set _enable_drop_and_add_index = true;
sleep 2;
alter table at1 drop index idx1, add index idx1(c1);
alter system set _enable_drop_and_add_index = false;
sleep 2;
alter table at1 drop index idx1;
alter table at1 add index idx1(c1);
drop table at1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key, b int) partition by hash(a) partitions 4;
alter table t1 add index idx2(b) global;
drop table t1;

##autoincrement
#auto_increment
--disable_warnings
drop table if exists at1;
--enable_warnings
create table at1(c1 int primary key);
alter table at1 add c2 int auto_increment;
insert into at1 values(1, 0);
insert into at1 values(2, 0);
select * from at1;
alter table at1 modify c2 int;
insert into at1 values(3, 0);
select * from at1;
alter table at1 add c3 int auto_increment;
insert into at1 values(4, 1, 0);
insert into at1 values(5, 1, 0);
select * from at1;
alter table at1 drop c2;
select * from at1;
alter table at1 change c3 c2 int auto_increment;
insert into at1 values(6, 0);
insert into at1 values(7, 0);
select * from at1;
alter table at1 modify c2 int;
insert into at1 values(8, 0);
insert into at1 values(9, 0);
select * from at1;

create view v_at1 as select * from at1;
--error 1347
alter table v_at1 rename to view_at1;
drop view v_at1;

