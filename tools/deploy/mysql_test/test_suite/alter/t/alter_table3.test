create index idx1 on t_pk_len(v1);
--error ER_TOO_LONG_KEY
alter table t_pk_len modify column v1 varchar(16400);
--error ER_TOO_LONG_KEY
alter table t_pk_len change column v1 vv1 varchar(16400);

create table t_pk_len2(pk varchar(100) primary key, v1 varchar(16285), v2 varchar(10));
--error ER_TOO_LONG_KEY
alter table t_pk_len2 add index idx_pk_len2 (v1);
--error ER_TOO_LONG_KEY
create index idx_pk_len2 on t_pk_len2 (v1);

create table t_pk_len3(pk varchar(100) primary key, v1 varchar(16284), v2 varchar(10));
alter table t_pk_len3 modify column pk varchar(102);
--error ER_TOO_LONG_KEY
alter table t_pk_len3 add index idxt3 (v1);

drop table t_pk_len, t_pk_len2, t_pk_len3;

# modify binary and char column
--disable_warnings
drop table if exists tbc;
--enable_warnings
create table tbc(c1 char(255) default 'abcd0000', c2 varchar(255) default 'abcd1111', c3 binary(255) default 'abcd2222', c4 varbinary(255) default 'abcd3333');
alter table tbc modify column c1 binary (255);
alter table tbc modify column c2 varbinary(255);
alter table tbc modify column c3 char(255);
alter table tbc modify column c4 varchar(255);

drop table tbc;

#modify int scale
--disable_warnings
drop table if exists tint;
drop table if exists tuint;
--enable_warnings
create table tint(c1 tinyint, c2 smallint, c3 mediumint, c4 int, c5 bigint);
insert into tint values(127, 32767, 8388607, 2147483647, 9223372036854775807);
insert into tint values(-128, -32768, -8388608, -2147483648, -9223372036854775808);
select * from tint;
desc tint;
alter table tint modify column c1 smallint, modify column c2 mediumint, modify column c3 int, modify column c4 bigint, modify column c5 bigint;
desc tint;
insert into tint values(32767, 8388607, 2147483647, 9223372036854775807, 9223372036854775807);
insert into tint values(-32768, -8388608, -2147483648, -9223372036854775808, -9223372036854775808);
select * from tint;
--error 1264
alter table tint modify column c1 tinyint;
--error 1264
alter table tint modify column c2 smallint;
--error 1264
alter table tint modify column c3 mediumint;
--error 1264
alter table tint modify column c4 int;
--error 1264
alter table tint modify column c1 smallint unsigned;

create table tuint(c1 tinyint unsigned, c2 smallint unsigned, c3 mediumint unsigned, c4 int unsigned, c5 bigint unsigned);
insert into tuint values(0, 0, 0, 0, 0);
insert into tuint values(255, 65535, 16777215, 4294967295, 18446744073709551615);
select * from tuint;
desc tuint;
alter table tuint modify column c1 smallint unsigned, modify column c2 mediumint unsigned, modify column c3 int unsigned, modify column c4 bigint unsigned, modify column c5 bigint unsigned;
desc tuint;
insert into tuint values(65535, 16777215, 4294967295, 18446744073709551615, 18446744073709551615);
select * from tuint;
--error 1264
alter table tuint modify column c1 tinyint unsigned;
--error 1264
alter table tuint modify column c2 smallint unsigned;
--error 1264
alter table tuint modify column c3 mediumint unsigned;
--error 1264
alter table tuint modify column c4 int unsigned;
--error 1264
alter table tuint modify column c1 smallint;

drop table tint;
drop table tuint;

