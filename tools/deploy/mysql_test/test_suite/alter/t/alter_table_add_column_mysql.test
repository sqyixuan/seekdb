--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# # owner group: SQL2
# # description: 本case是为了测试alter table add column指定column position: before / after column
# # tags: ddl

--disable_warnings
drop database if exists lf_db;
--enable_warnings
create database lf_db;
use lf_db;
#
# BUG#29650534 - obmysql设置列的先后顺序，视图中元数据的顺序错误
#
create table t1(c1 bigint , c2 bigint);
alter table t1 add column c3 bigint after c1;
select COLUMN_NAME, ORDINAL_POSITION from information_schema.`COLUMNS` where table_schema='lf_db' and table_name='t1';
drop table t1;
drop database lf_db;
