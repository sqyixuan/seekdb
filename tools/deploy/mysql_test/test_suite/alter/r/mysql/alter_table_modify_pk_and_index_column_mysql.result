drop database if exists xiaofeng_db1;
create database xiaofeng_db1;
use xiaofeng_db1;
create table t1(c1 varchar(4096) primary key, c2 varchar(4096), index t1_idx(c2));
alter table t1 modify c1 varchar(4097);
ERROR 42000: Specified key was too long; max key length is 16384 bytes
alter table t1 modify c2 varchar(4097);
ERROR 42000: Specified key was too long; max key length is 16384 bytes
create table t2(c1 varchar(2048), c2 varchar(2048), c3 varchar(2048), c4 varchar(2048),  primary key (c1, c2), index t2_idx(c3, c4));
alter table t2 modify c1 varchar(2049);
ERROR 42000: Specified key was too long; max key length is 16384 bytes
alter table t2 modify c3 varchar(2049);
ERROR 42000: Specified key was too long; max key length is 16384 bytes
drop table t1;
drop table t2;
drop database xiaofeng_db1;
