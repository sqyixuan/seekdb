## 测试二级分区表和全局索引
create table t2(a int, b int, c int, d int, e int, primary key(a,b,c,d))
partition by range columns(a, b) subpartition by key(c, d) subpartitions 2 (
  partition p0 values less than (5, 5),
  partition p1 values less than (maxvalue, maxvalue)
);
create index gidx on t2(c, d) global partition by key (c, d);
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `a` int(11) NOT NULL,
  `b` int(11) NOT NULL,
  `c` int(11) NOT NULL,
  `d` int(11) NOT NULL,
  `e` int(11) DEFAULT NULL,
  PRIMARY KEY (`a`, `b`, `c`, `d`),
  KEY `gidx` (`c`, `d`) BLOCK_SIZE 16384 GLOBAL
 partition by key(c, d)
(partition `p0`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by range columns(a, b) subpartition by key(c, d) subpartition template (
subpartition `p0`,
subpartition `p1`)
(partition `p0` values less than (5,5),
partition `p1` values less than (MAXVALUE,MAXVALUE))
+----------------+
| PART_FUNC_EXPR |
+----------------+
| c, d           |
+----------------+
alter table t2 change column a aa int;
alter table t2 change column b bb int;
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `aa` int(11) NOT NULL,
  `bb` int(11) NOT NULL,
  `c` int(11) NOT NULL,
  `d` int(11) NOT NULL,
  `e` int(11) DEFAULT NULL,
  PRIMARY KEY (`aa`, `bb`, `c`, `d`),
  KEY `gidx` (`c`, `d`) BLOCK_SIZE 16384 GLOBAL
 partition by key(c, d)
(partition `p0`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by range columns(`aa`, `bb`) subpartition by key(`c`, `d`) subpartition template (
subpartition `p0`,
subpartition `p1`)
(partition `p0` values less than (5,5),
partition `p1` values less than (MAXVALUE,MAXVALUE))
+----------------+
| PART_FUNC_EXPR |
+----------------+
| c, d           |
+----------------+
#
# BUG#29298845 - rename column name does not fix the check_expr of the check constraint
#
create table t3(c1 int, c2 int, constraint cst check(c1 = c2));
show create table t3;
Table	Create Table
t3	CREATE TABLE `t3` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  CONSTRAINT `cst` CHECK ((`c1` = `c2`))
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
alter table t3 change column c1 c12 int;
show create table t3;
Table	Create Table
t3	CREATE TABLE `t3` (
  `c12` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  CONSTRAINT `cst` CHECK ((`c12` = `c2`))
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
drop table t3;

drop database xiaofeng_db1;
