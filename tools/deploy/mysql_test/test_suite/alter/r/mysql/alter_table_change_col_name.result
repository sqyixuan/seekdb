result_format: 4
drop database if exists xiaofeng_db1;
create database xiaofeng_db1;
use xiaofeng_db1;

## 测试一级分区表和全局索引
CREATE TABLE t1 (
   id INT NOT NULL, 
   fname VARCHAR(30), 
   lname VARCHAR(30), 
   hired DATE NOT NULL DEFAULT '1970-01-01', 
   separated DATE NOT NULL DEFAULT '9999-12-31', 
   job_code INT, 
   store_id INT
)
PARTITION BY HASH(YEAR(hired)) 
   PARTITIONS 4;
create index gidx_t1 on t1(hired) global partition by hash(YEAR(hired)) PARTITIONS 8;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `id` int(11) NOT NULL,
  `fname` varchar(30) DEFAULT NULL,
  `lname` varchar(30) DEFAULT NULL,
  `hired` date NOT NULL DEFAULT '1970-01-01',
  `separated` date NOT NULL DEFAULT '9999-12-31',
  `job_code` int(11) DEFAULT NULL,
  `store_id` int(11) DEFAULT NULL,
  KEY `gidx_t1` (`hired`) BLOCK_SIZE 16384 GLOBAL
 partition by hash(year(hired))
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`,
partition `p5`,
partition `p6`,
partition `p7`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by hash(year(hired))
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`)
+----------------+
| PART_FUNC_EXPR |
+----------------+
| year(hired)    |
+----------------+
alter table t1 change column hired guyong DATE;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `id` int(11) NOT NULL,
  `fname` varchar(30) DEFAULT NULL,
  `lname` varchar(30) DEFAULT NULL,
  `guyong` date DEFAULT NULL,
  `separated` date NOT NULL DEFAULT '9999-12-31',
  `job_code` int(11) DEFAULT NULL,
  `store_id` int(11) DEFAULT NULL,
  KEY `gidx_t1` (`guyong`) BLOCK_SIZE 16384 GLOBAL
 partition by hash(year(`guyong`))
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`,
partition `p5`,
partition `p6`,
partition `p7`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by hash(year(`guyong`))
