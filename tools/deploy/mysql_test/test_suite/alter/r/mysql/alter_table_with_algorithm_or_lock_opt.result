drop table if exists test;
create table test(c0 int, c1 int, c2 varchar(20));
alter table test add index idx0(c0,c1), ALGORITHM = DEFAULT;
alter table test add index idx1(c0,c1), ALGORITHM = INPLACE;
alter table test add index idx2(c0,c1), ALGORITHM = COPY;
alter table test add index idx3(c0,c1), ALGORITHM = INSTANT;
alter table test add index idx4(c0,c1), LOCK = DEFAULT;
alter table test add index idx5(c0,c1), LOCK = NONE;
alter table test add index idx6(c0,c1), LOCK = SHARED;
alter table test add index idx7(c0,c1), LOCK = EXCLUSIVE;
alter table test add index idx8(c0,c1), LOCK = SHARED, ALGORITHM = INPLACE;
alter table test add index idx9(c0,c1), ALGORITHM = COPY, LOCK = EXCLUSIVE;
