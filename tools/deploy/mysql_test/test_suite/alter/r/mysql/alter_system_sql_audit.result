
// CASE#1 Test `alter system flush sql audit`

// push sql audit

select 1 from dual;
select 1 from dual;

// expect sql audit record number > 0
select count(*) > 0 from oceanbase.GV$OB_SQL_AUDIT where query_sql='select 1 from dual';
count(*) > 0
1

// flush sql audit
alter system flush sql audit global;

// expect sql audit number to be 0
select count(*) = 0 from oceanbase.GV$OB_SQL_AUDIT where query_sql='select 1 from dual';
count(*) = 0
1

// CASE#2 Test system variable `ob_enable_sql_audit`

set global ob_enable_sql_audit = false;

select 1 from dual;
select 1 from dual;

// expect sql audit number = 0
select count(*) = 0 from oceanbase.GV$OB_SQL_AUDIT where query_sql='select 1 from dual';
count(*) = 0
1

set global ob_enable_sql_audit = true;
