// CASE 1: test built-in io calibration

// cleanup io calibration data
alter system refresh io calibration calibration_info = ("");
select count(*) = 0 from GV$OB_IO_BENCHMARK;
count(*) = 0
1

// run built-in io calibration
alter system run job "io_calibration";
select unique storage_name, status from GV$OB_IO_CALIBRATION_STATUS;
storage_name	status
DATA	IN PROGRESS

// wait built-in io calibration finish
select unique storage_name, status from GV$OB_IO_CALIBRATION_STATUS;
storage_name	status
DATA	READY

// check io calibration data
select count(*) > 0 from GV$OB_IO_BENCHMARK;
count(*) > 0
1
// CASE 2: test refresh io calibration data

// cleanup io calibration data
alter system refresh io calibration calibration_info = ("");
select count(*) = 0 from GV$OB_IO_BENCHMARK;
count(*) = 0
1

// admin set io calibration data
alter system refresh io calibration calibration_info = ("r:4K:100us:100000", "w:16K:200us:80000");
select count(*) > 0 from GV$OB_IO_BENCHMARK;
count(*) > 0
1

// cleanup io calibration data
alter system refresh io calibration calibration_info = ("");
select count(*) = 0 from GV$OB_IO_BENCHMARK;
count(*) = 0
1
