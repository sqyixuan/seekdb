drop table if exists t1;
create table t1 (c1 int, c2 int);
insert into t1 values(1, 1);
alter system flush plan cache;
alter /*+ parallel(8) */table t1 add primary key pk(c1);
select substr(hints_info, 28, 11) from oceanbase.__all_virtual_plan_stat where query_sql like "INSERT /*+ monitor enable_parallel_dml parallel%" order by last_active_time desc limit 1;
substr(hints_info, 28, 11)
PARALLEL(8)
alter /*+ parallel(4) */table t1 add index idx(c2);
select substr(hints_info, 28, 11) from oceanbase.__all_virtual_plan_stat where query_sql like "INSERT /*+ monitor enable_parallel_dml parallel%" order by last_active_time desc limit 1;
substr(hints_info, 28, 11)
PARALLEL(4)
alter /*+ parallel(2) */table t1 modify column c1  varchar(100);
select substr(hints_info, 60, 11) from oceanbase.__all_virtual_plan_stat where query_sql like "INSERT /*+ monitor enable_parallel_dml parallel%" order by last_active_time desc limit 1;
substr(hints_info, 60, 11)
PARALLEL(2)
drop table t1;
