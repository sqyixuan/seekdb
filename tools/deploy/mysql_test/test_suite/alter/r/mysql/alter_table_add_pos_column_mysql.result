gen_t1	CREATE TABLE `gen_t1` (
  `c5` varchar(64) GENERATED ALWAYS AS (repeat('a',6)) STORED,
  `c9` varchar(64) GENERATED ALWAYS AS (repeat('a',6)) STORED,
  `c1` varchar(10) NOT NULL,
  `c6` varchar(64) GENERATED ALWAYS AS (repeat('a',6)) VIRTUAL,
  `c2` varchar(8) GENERATED ALWAYS AS (substr(`c1`,2)) VIRTUAL,
  `c3` int(11) DEFAULT NULL,
  `c10` varchar(64) GENERATED ALWAYS AS (repeat('a',6)) VIRTUAL,
  `c7` varchar(64) GENERATED ALWAYS AS (repeat('a',6)) STORED,
  `c4` varchar(64) GENERATED ALWAYS AS (substr(`c1`,2)) VIRTUAL,
  `c8` varchar(64) GENERATED ALWAYS AS (repeat('a',6)) VIRTUAL,
  PRIMARY KEY (`c1`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
