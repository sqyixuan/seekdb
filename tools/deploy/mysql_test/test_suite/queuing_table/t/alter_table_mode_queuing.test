--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: ouyanghongrong.oyh
# owner group: storage
# description: test queuing table
#
####

connect (conn0, $OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

connection conn0;
--disable_query_log
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log
let $__tenant_id__ = query_get_value(select 1 as tenant_id, tenant_id, 1);

create table t1(c1 int, c2 varchar(100));

eval select table_mode from __all_virtual_table where table_name = "t1";

let $i =1;
while ($i <= 30)
{
  eval insert into t1 values($i, 'abcdefgABCDEFG');
  inc $i;
}

alter table t1 set table_mode = 'queuing';

eval select table_mode from __all_virtual_table where table_name = "t1";

let $i =31;
while ($i <= 50)
{
  eval insert into t1 values($i, 'abcdefgABCDEFG');
  inc $i;
}

delete from t1 where c1 < 26;

select * from t1;

alter table t1 set table_mode = 'normal';

eval select table_mode from __all_virtual_table where table_name = "t1";

## Test 1: create queuing mode table
--disable_warnings
drop table if exists qt0;
drop table if exists qt1;
drop table if exists qt2;
drop table if exists qt3;
drop table if exists qt4;
drop table if exists qt5;
drop table if exists qt6;
drop table if exists qt7;
drop table if exists qt8;
drop table if exists qt9;
drop table if exists qt10;
--enable_warnings

create table qt0(c1 int, c2 int);
create table qt1(c1 int, c2 int) table_mode='normal';
create table qt2(c1 int, c2 int) table_mode='queuing';
create table qt3(c1 int, c2 int) table_mode='moderate';
create table qt4(c1 int, c2 int) table_mode='super';
create table qt5(c1 int, c2 int) table_mode='extreme';
--error 1235
create table qt6(c1 int, c2 int) table_mode='exterme';
--error 1235
create table qt6(c1 int, c2 int) table_mode='xxx';
create table qt6(c1 int, c2 int) table_mode='NoRmAL';
create table qt7(c1 int, c2 int) table_mode='QueuIng';
create table qt8(c1 int, c2 int) table_mode='MoDeRaTe';
create table qt9(c1 int, c2 int) table_mode='SuPeR';
create table qt10(c1 int, c2 int) table_mode='ExTrEmE';


# 66048: 10000001000000000, table_mode of normal
let $__normal_table_mode__ = 66048;
eval select table_mode - $__normal_table_mode__ as table_mode_flag from __all_virtual_table where table_name = "qt0";
eval select table_mode - $__normal_table_mode__ as table_mode_flag from __all_virtual_table where table_name = "qt1";
eval select table_mode - $__normal_table_mode__ as table_mode_flag from __all_virtual_table where table_name = "qt2";
eval select table_mode - $__normal_table_mode__ as table_mode_flag from __all_virtual_table where table_name = "qt3";
eval select table_mode - $__normal_table_mode__ as table_mode_flag from __all_virtual_table where table_name = "qt4";
eval select table_mode - $__normal_table_mode__ as table_mode_flag from __all_virtual_table where table_name = "qt5";
eval select table_mode - $__normal_table_mode__ as table_mode_flag from __all_virtual_table where table_name = "qt6";
eval select table_mode - $__normal_table_mode__ as table_mode_flag from __all_virtual_table where table_name = "qt7";
eval select table_mode - $__normal_table_mode__ as table_mode_flag from __all_virtual_table where table_name = "qt8";
eval select table_mode - $__normal_table_mode__ as table_mode_flag from __all_virtual_table where table_name = "qt9";
eval select table_mode - $__normal_table_mode__ as table_mode_flag from __all_virtual_table where table_name = "qt10";

--source mysql_test/include/show_create_table_old_version.inc
show create table qt0;
--source mysql_test/include/show_create_table_old_version.inc
show create table qt1;
--source mysql_test/include/show_create_table_old_version.inc
show create table qt2;
--source mysql_test/include/show_create_table_old_version.inc
show create table qt3;
--source mysql_test/include/show_create_table_old_version.inc
show create table qt4;
--source mysql_test/include/show_create_table_old_version.inc
show create table qt5;
--source mysql_test/include/show_create_table_old_version.inc
show create table qt6;
--source mysql_test/include/show_create_table_old_version.inc
show create table qt7;
--source mysql_test/include/show_create_table_old_version.inc
show create table qt8;
--source mysql_test/include/show_create_table_old_version.inc
show create table qt9;
--source mysql_test/include/show_create_table_old_version.inc
show create table qt10;

## Test 2: alter queuing mode 
alter table qt0 set table_mode = 'extreme';
alter table qt1 set table_mode = 'super';
alter table qt2 set table_mode = 'moderate';
alter table qt3 set table_mode = 'queuing';
alter table qt4 set table_mode = 'normal';
alter table qt5 set table_mode = 'normal';
--error 1235
alter table qt5 set table_mode='nomral';
--error 1235
alter table qt5 set table_mode='xxx';
alter table qt6 set table_mode='QuEuING';
alter table qt7 set table_mode='ModErAtE';
alter table qt8 set table_mode='SuPeR';
alter table qt9 set table_mode='ExTREMe';
