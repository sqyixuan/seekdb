CREATE TABLE format_test1 (
    c1 INT,
    c2 FLOAT,
    c3 DOUBLE,
    c4 CHAR(100),
    c5 NCHAR(100),     
    c6 VARCHAR(100),
    c7 VARCHAR(100),  
    c8 BLOB,
    c9 TEXT,         
    c10 DATETIME
);

