### create table format_test4(c1 number,c2 binary_float,c3 binary_double,c4 char(100),c5 nchar(100),c6 varchar2(100),c7 nvarchar2(100),c8 blob,c9 clob,c10 date);
### insert into format_test4 values(100000000,100.2356,0.00,'100.00','23.12','100.2356','1234','12','1234',to_date('2004-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss'));
### insert into format_test4 values(100000000,0.00,0+0,'100.00','23.12','100.2356','1234','123','12345',to_date('2021-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss'));

CREATE TABLE format_test4 (
    c1 INT,              
    c2 FLOAT,            
    c3 DOUBLE,           
    c4 CHAR(100),        
    c5 VARCHAR(100),     
    c6 VARCHAR(100),     
    c7 VARCHAR(100),     
    c8 BLOB,             
    c9 TEXT,             
    c10 DATETIME         
);

INSERT INTO format_test4 (c1, c2, c3, c4, c5, c6, c7, c8, c9, c10) VALUES
(100000000, 100.2356, 0.00, '100.00', '23.12', '100.2356', '1234', NULL, '1234', '2004-05-07 13:23:44'),
(100000000, 0.00, 0 + 0, '100.00', '23.12', '100.2356', '1234', NULL, '12345', '2021-05-07 13:23:44');

ALTER TABLE format_test4 ADD c11 VARCHAR(200) GENERATED ALWAYS AS (to_char(c4,'99G9999999v'));
ALTER TABLE format_test4 ADD c13 varchar(200) GENERATED ALWAYS AS (to_char(c4, '9,9999,9999BL'));
ALTER TABLE format_test4 ADD c14 varchar(200) GENERATED ALWAYS AS (to_char(c4, 'FMRn'));
ALTER TABLE format_test4 ADD c15 varchar(200) GENERATED ALWAYS AS (to_char(c4, '99999,99VC'));
ALTER TABLE format_test4 ADD c16 varchar(200) GENERATED ALWAYS AS (to_char(c4,'XXX'));
ALTER TABLE format_test4 ADD c17 varchar(200) GENERATED ALWAYS AS (to_char(c4, '9,,,9,,9,9,9$Mi'));
ALTER TABLE format_test4 ADD c18 varchar(200) GENERATED ALWAYS AS (to_char(c4, '9CB'));                                                         
ALTER TABLE format_test4 ADD c19 varchar(200) GENERATED ALWAYS AS (to_char(to_char(c4, '9CB')));
ALTER TABLE format_test4 ADD c20 varchar(200) GENERATED ALWAYS AS (to_char(c4, 'fmtm9'));
ALTER TABLE format_test4 ADD c21 varchar(200) GENERATED ALWAYS AS (to_char(c4, '9.99EEEE'));
ALTER TABLE format_test4 ADD c22 varchar(200) GENERATED ALWAYS AS (to_char(c4,'9999.9'));
ALTER TABLE format_test4 ADD c23 varchar(200) GENERATED ALWAYS AS (to_char(c4, '9999V999999EEEE')) ;

alter table format_test4 drop column c11;
alter table format_test4 drop column c13;
alter table format_test4 drop column c14;
alter table format_test4 drop column c15;
alter table format_test4 drop column c16;
alter table format_test4 drop column c17;
alter table format_test4 drop column c18;
alter table format_test4 drop column c19;
alter table format_test4 drop column c20;
alter table format_test4 drop column c21;
alter table format_test4 drop column c22;
alter table format_test4 drop column c23;

--disable_warnings
DROP TABLE IF EXISTS format_test4;
--enable_warnings

