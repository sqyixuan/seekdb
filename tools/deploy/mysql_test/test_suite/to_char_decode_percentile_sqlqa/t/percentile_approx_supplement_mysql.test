--echo ### 函数+函数嵌套

SELECT 
  PERCENTILE_CONT(dept_median, 0.5) AS global_median
FROM (
  SELECT PERCENTILE_CONT(sal, 0.5) AS dept_median 
  FROM emp 
  GROUP BY deptno
) t;

--ERROR 1064
WITH dept_stats AS (
  SELECT 
    deptno, 
    PERCENTILE_CONT(sal, array(0.25, 0.75)) AS pct_arr 
  FROM emp 
  GROUP BY deptno
)
SELECT 
  deptno,
  pct_arr[0] AS q1,
  pct_arr[1] AS q3,
  pct_arr[1] - pct_arr[0] AS iqr
FROM dept_stats;

SELECT 
  deptno,
  ROUND(PERCENTILE_CONT(sal, 0.5)) AS median_sal_rounded,
  FLOOR(PERCENTILE_CONT(sal, 0.8)) AS p80_floor
FROM emp 
GROUP BY deptno;

SELECT 
  deptno,
  PERCENTILE_CONT(sal, SIN(0.5) + 0.5) AS dynamic_p -- SIN(0.5)≈0.479
FROM emp 
GROUP BY deptno;

SELECT 
  deptno,
  CONCAT('Median:', CAST(PERCENTILE_CONT(sal, 0.5) AS DOUBLE)) AS sal_desc 
FROM emp 
GROUP BY deptno;

SELECT 
  CONCAT(
    '{ "dept": ', deptno, 
    ', "p80": ', PERCENTILE_CONT(sal, 0.8), 
    ' }'
  ) AS json_result 
FROM emp 
GROUP BY deptno;

SELECT 
  deptno,
  CASE 
    WHEN COUNT(*) > 5 THEN PERCENTILE_CONT(sal, 0.9)
    ELSE PERCENTILE_CONT(sal, 0.5)
  END AS adaptive_pct
FROM emp 
GROUP BY deptno;

SELECT 
  job,
  PERCENTILE_CONT(
    CASE WHEN sal > 2000 THEN sal ELSE NULL END, 
    0.5
  ) AS high_earners_median 
FROM emp 
GROUP BY job;

--ERROR 5852
SELECT 
  deptno,
  PERCENTILE_CONT(sal, ARRAY(0.1 * deptno, 0.2 * deptno)) AS dynamic_p_array 
FROM emp 
WHERE deptno IN (10, 20) 
GROUP BY deptno;

--ERROR 1582
SELECT 
  deptno,
  PERCENTILE_CONT(sal, 0.5, POWER(10, deptno)) AS precision_test
FROM emp 
GROUP BY deptno;

--ERROR 1582
SELECT 
  deptno,
  PERCENTILE_CONT(
    sal, 
    CASE WHEN comm IS NULL THEN 1.0 ELSE comm/100.0 END, 
    0.5
  ) AS weighted_median 
FROM emp 
GROUP BY deptno;

--ERROR 1582
SELECT 
  job,
  PERCENTILE_CONT(
    sal, 
    sal * (deptno / 10.0), 
    ARRAY(0.25, 0.75)
  ) AS complex_weight_pct 
FROM emp 
GROUP BY job;


SELECT 
  PERCENTILE_CONT(
    (SELECT sal FROM emp WHERE 1=0), 
    0.5
  ) AS empty_result;

### SELECT 
###   PERCENTILE_APPROX(
###     (SELECT sal FROM emp WHERE 1=0), 
###     0.5
###   ) AS empty_result;


SELECT 
  PERCENTILE_CONT(
    COALESCE(NULL, NULL, sal),
    0.5
  ) AS coalesce_test 
FROM emp 
GROUP BY deptno;

SELECT 
  deptno,
  PERCENTILE_CONT(sal, 0.9) AS p90 
FROM emp 
GROUP BY deptno
HAVING PERCENTILE_CONT(sal, 0.9) > 3000;

--ERROR 1064
SELECT 
  empno,
  sal,
  PERCENTILE_CONT(sal, 0.5) OVER (PARTITION BY deptno) AS dept_median
FROM emp;

--ERROR 1582
SELECT 
  PERCENTILE_CONT(sal, 0.5, 1) AS low_precision 
FROM emp;
--ERROR 1582
SELECT 
  PERCENTILE_CONT(sal, NULL, 0.5) AS all_null_weight 
FROM emp;

SELECT 
  PERCENTILE_CONT(pct, 0.5) AS meta_median 
FROM (
  SELECT PERCENTILE_CONT(sal, 0.3) AS pct FROM emp GROUP BY deptno
) t;

SELECT 
  PERCENTILE_CONT(job_pct, 0.75) AS global_p75 
FROM (
  SELECT 
    PERCENTILE_CONT(sal, 0.5) AS job_pct 
  FROM emp 
  GROUP BY job
) t;

--ERROR 1111
SELECT PERCENTILE_CONT(PERCENTILE_CONT(sal, 0.5), 0.5) FROM emp;
SELECT CONCAT(PERCENTILE_CONT(sal, 0.5), ename) FROM emp GROUP BY deptno; 

