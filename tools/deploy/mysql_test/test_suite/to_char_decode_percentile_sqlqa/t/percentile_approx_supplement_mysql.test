purge recyclebin;
--echo #Environmental cleaning
--result_format 4

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
--enable_sorted_result

--echo ###root用户
connect (root,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf8mb4;
use db1;
set sql_mode='';
SET sql_mode ='PIPES_AS_CONCAT';

--disable_warnings
drop table if exists emp;
--enable_warnings
create table  emp
(empno bigint,
ename string,
job string,
mgr bigint,
hiredate string,
sal bigint,
comm bigint,
deptno bigint);

INSERT INTO emp (empno, ename, job, mgr, hiredate, sal, comm, deptno) VALUES 
