--disable_warnings
drop table if exists url_decode_test;
--enable_warnings

CREATE TABLE url_decode_test (
  id INT COMMENT '测试用例ID',
  input STRING COMMENT '输入字符串',
  encoding STRING COMMENT '编码格式',
  expected STRING COMMENT '预期输出'
);

INSERT INTO url_decode_test VALUES
(1, '%E4%BD%A0%E5%A5%BD', 'UTF-8', '你好'),
(2, 'Hello+World%21', 'UTF-8', 'Hello World!'),
(3, '%2B%2F%3D%3A%2A%20', 'UTF-8', '+/=:* '),
(4, '%D6%D0%CE%C4', 'GBK', '中文'),
(5, '%C4%E3%BA%C3', 'GBK', '你好'),
(6, NULL, 'UTF-8', NULL),
(7, '', 'UTF-8', ''),
(8, '%ZZ', 'UTF-8', '%ZZ'), 
(9, '%A', 'UTF-8', '%A'),
(10, '%%20', 'UTF-8', '% '),
(11, 'a*b-c.d_%41%62', 'UTF-8', 'a*b-c.d_Ab'),
(12, '%2b%2F', 'UTF-8', '+/'),
(13, REPEAT('%E4%BD%A0', 1000), 'UTF-8', REPEAT('你', 1000)),
(14, REPEAT('%20', 5000), 'UTF-8', REPEAT(' ', 5000));

--ERROR 1210
SELECT 
  t.id,
  url_decode(t.input) AS actual_output,
  t.expected AS expected_output,
  CASE 
    WHEN url_decode(t.input) = t.expected THEN 'Pass' 
    WHEN url_decode(t.input) IS NULL AND t.expected IS NULL THEN 'Pass'
    ELSE 'Fail' 
  END AS test_result
FROM url_decode_test t;

SELECT url_decode('%E7%A4%BA%E4%BE%8B') + 10 AS decoded_plus_10; 

SELECT '示例' + 10 AS decoded_plus_10; 
SELECT url_decode('%E4%BD%A0%E5%A5%BD') - 5 AS decoded_minus_5; 
SELECT url_decode('Example+for+url_decode+%3A%2F%2F+dsf%28fasfs%29') * 2 AS decoded_times_2; 
SELECT url_decode('%E7%A4%BA%E4%BE%8B') / 3 AS decoded_divide_3;
SELECT (url_decode('%E7%A4%BA%E4%BE%8B') + 10) * 2 - 5 / 3 AS complex_calculation_1;
SELECT ((url_decode('%E4%BD%A0%E5%A5%BD') * 5) - 3) / 2 AS complex_calculation_2; 
SELECT url_decode('%E4%BD%A0%E5%A5%BD') + url_decode('%E7%A4%BA%E4%BE%8B') AS concat_decoded_strings; 
SELECT (url_decode('%E4%BD%A0%E5%A5%BD') + url_decode('%E7%A4%BA%E4%BE%8B')) * 2 AS concat_and_multiply; 
SELECT url_decode('Example+for+url_decode+%3A%2F%2F+dsf%28fasfs%29') + 'test' AS decoded_plus_string;
SELECT url_decode('Example+for+url_decode+%3A%2F%2F+dsf%28fasfs%29') / 'test' AS decoded_divide_string; 
SELECT url_decode('%E4%BD%A0%E5%A5%BD') * 'test' AS decoded_times_string; 
SELECT url_decode(NULL) + 5 AS decoded_plus_null;
SELECT url_decode('%E4%BD%A0%E5%A5%BD') + NULL AS decoded_plus_null_value;
SELECT url_decode('%E7%A4%BA%E4%BE%8B') * NULL AS decoded_times_null; 
SELECT LENGTH(url_decode('%E4%BD%A0%E5%A5%BD')) + 10 AS decoded_length_plus_10; 
SELECT LENGTH(url_decode('%E4%BD%A0%E5%A5%BD')) * 2 AS decoded_length_times_2; 
SELECT url_decode(REPEAT('%E4%BD%A0%E5%A5%BD', 10000)) + 5 AS decoded_plus_5_large_input;
SELECT url_decode('%45%46%47%48') + 100 AS decoded_large_input_plus_100;
SELECT (url_decode('%E4%BD%A0%E5%A5%BD') + 10) * (url_decode('%E7%A4%BA%E4%BE%8B') - 5) AS nested_calculation; 
SELECT url_decode('%E4%BD%A0%E5%A5%BD') + DATE '2025-02-16' AS decoded_date_plus;  

SELECT 
  url_decode('%41' || '%42') AS test1,      
  url_decode(CONCAT('%C4', '%E3')) AS test2; 

SELECT 
  url_decode('a%2B' || 'b%2A') AS test5,      
  url_decode('%20' || '+') AS test6;          
SELECT 
  url_decode(url_encode('测试*+=')) AS test7,   
  url_decode(url_encode('a%b_c')) AS test8; 

--ERROR 1210
SELECT 
  url_decode(SUBSTR('XX%41%42XX', 3, 4)) AS test9,  
  url_decode(REPLACE('a%2b+c', '+', '%20')) AS test10; 

SELECT SUBSTR('XX%41%42XX', 3, 3) AS test9; 
SELECT url_decode(SUBSTR('XX%41%42XX', 3, 3)) AS test9; 

SELECT REPLACE('a%2b+c', '+', '%20') AS test9; 
SELECT url_decode(REPLACE('a%2b+c', '+', '%20')) AS test10; 
  
SELECT 
  url_decode(url_decode('%25%32%42')) AS test11, 
  url_decode(url_decode('%252541')) AS test12;
  
--ERROR 1582
SELECT 
  url_decode('%D6%D0%CE%C4', CASE WHEN 1=1 THEN 'GBK' ELSE 'UTF-8' END) AS test13, 
  url_decode('%41%42', CONCAT('UTF', '-8')) AS test14; 
SELECT 
  url_decode('%' || (HEX(UNHEX('41')))) AS test15, 
