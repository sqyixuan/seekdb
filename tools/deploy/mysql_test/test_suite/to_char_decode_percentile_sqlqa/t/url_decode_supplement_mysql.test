SELECT LENGTH('你好') AS nested_decode_length;

SELECT UPPER(url_decode(url_decode('%E4%BD%A0%E5%A5%BD'))) AS nested_decode_upper; 
SELECT REPLACE(url_decode(url_decode('%E4%BD%A0%E5%A5%BD')), '你', '我') AS nested_decode_replace; 

