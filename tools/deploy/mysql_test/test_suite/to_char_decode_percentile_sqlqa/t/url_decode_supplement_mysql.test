--ERROR 1210
SELECT url_decode(url_decode(url_decode('%ZZ'))) AS nested_decode_invalid_three_times; 
SELECT LENGTH(url_decode(url_decode('%E4%BD%A0%E5%A5%BD'))) + 5 AS nested_decode_length_plus_5; 
SELECT (url_decode(url_decode('%E4%BD%A0%E5%A5%BD')) + LENGTH(url_decode('%E7%A4%BA%E4%BE%8B'))) * 2 AS nested_and_calculate_length; 
SELECT url_decode('%E4%BD%A0%E5%A5%BD') + DATE '2025-02-16' AS nested_decode_and_date_add;
SELECT JSON_UNQUOTE(url_decode(url_decode('%E4%BD%A0%E5%A5%BD'))) AS nested_decode_json;
