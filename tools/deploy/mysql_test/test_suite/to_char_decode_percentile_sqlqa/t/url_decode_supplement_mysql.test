--echo ### 使用table、column

--disable_warnings
drop table if exists test_url_decode;
--enable_warnings

CREATE TABLE test_url_decode (
    id INT PRIMARY KEY,
    string_input VARCHAR(255),  
    text_input TEXT,            
    tinyint_input TINYINT,      
    int_input INT,              
    float_input FLOAT,          
    double_input DOUBLE,        
    boolean_input BOOLEAN,      
    date_input DATE,            
    datetime_input DATETIME,    
    enum_input ENUM('a', 'b', 'c'),  
    json_input JSON,            
    encoding VARCHAR(50)   
);

