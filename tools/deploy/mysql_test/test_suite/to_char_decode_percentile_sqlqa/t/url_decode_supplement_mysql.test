purge recyclebin;
--echo #Environmental cleaning
--result_format 4

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
--enable_sorted_result

--echo ###root用户
connect (root,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf8mb4;
use db1;
set sql_mode='';
SET sql_mode ='PIPES_AS_CONCAT';

--disable_warnings
drop table if exists url_decode_test;
--enable_warnings

CREATE TABLE url_decode_test (
    id INT,
    encoded_data VARCHAR(1024),  
    encoding VARCHAR(10),        
    special_chars VARCHAR(255),  
    null_field VARCHAR(255)      
);

INSERT INTO url_decode_test VALUES
(1,'%E7%A4%BA%E4%BE%8Bfor+url_decode%3A%2F%2F+%28fdsf%29', 'UTF-8', '!#$&*()', NULL), 
(2,'Example+for+url_decode+%3A%2F%2F+dsf%28fasfs%29', 'GBK', '%^@+=', NULL), 
(3,'%20Hello%20World%20', 'UTF-8', '[]{}|<>', NULL), 
(4,'Test%20Null%20Field', 'UTF-8', '', NULL), 
(5,'%25%5E%40%2B%3D', 'UTF-8', '!', 'NULL'),
(6,'%2A%20%7E%25', 'GBK', '', NULL), 
(7,'Encode+Test+%2520+%2A+~', 'UTF-8', '', NULL);

SELECT url_decode('%E7%A4%BA%E4%BE%8Bfor+url_decode%3A%2F%2F+%28fdsf%29');
SELECT url_encode(' ');

### OB 对+号不做转换，odps转化为空格。
SELECT id, url_decode(encoded_data) AS decoded_data
FROM url_decode_test
WHERE id = 1;
--echo ### 期望输出: 示例for url_decode:// (fdsf)

--ERROR 1582
SELECT id, url_decode(encoded_data, 'GBK') AS decoded_gbk_data
FROM url_decode_test
WHERE id = 2;
--echo ### 期望输出: Example for url_decode:// dsf(fasfs)

SELECT id, url_decode(encoded_data) AS decoded_data_with_spaces
FROM url_decode_test
WHERE id = 3;
--echo ### 期望输出:  Hello World 

SELECT id, url_decode(null_field) AS decoded_null_field
FROM url_decode_test
WHERE id = 4;
--echo ### 期望输出: NULL

SELECT id, url_decode('%25%5E%40%2B%3D') AS decoded_percent_encoding
FROM url_decode_test
WHERE id = 5;
--echo ### 期望输出: %^@+=

SELECT id, url_decode(url_decode(encoded_data)) AS decoded_double
FROM url_decode_test
WHERE id = 1;

SELECT id, url_decode('Test ' || null_field) AS decoded_with_null
FROM url_decode_test
WHERE id = 4;

SELECT id, url_decode('A' || repeat('%20', 1024)) AS decoded_long_input
FROM url_decode_test
WHERE id = 1;

### ob报错，odps有乱码
--ERROR 1210
SELECT id, url_decode('%ZZ%XX') AS invalid_encoding
FROM url_decode_test
WHERE id = 1;

SELECT id, url_decode('%2A%20%7E%25') AS decoded_special_symbols
FROM url_decode_test
WHERE id = 6;

SELECT id, url_decode(url_decode('Encode+Test+%2520+%2A+~')) AS decoded_double_special
FROM url_decode_test
WHERE id = 7;

SELECT id, url_decode(REPEAT('%20', 2048)) AS decoded_max_length
FROM url_decode_test
WHERE id = 3;

SELECT id, url_decode('Hello+World') AS decoded_plus_to_space
FROM url_decode_test
WHERE id = 3;

### ob报错，odps有乱码
### OB严格按照，%[0-F][0-F]
