SELECT url_decode(url_decode('%E4%BD%A0%E5%A5%BD')) AS nested_decode_once; 
SELECT url_decode(url_decode(url_decode('%E4%BD%A0%E5%A5%BD'))) AS nested_decode_three_times; 
SELECT url_decode(url_decode('%E4%BD%A0%E5%A5%BD')) + 10 AS nested_decode_and_add; 
SELECT url_decode(url_decode('%E7%A4%BA%E4%BE%8B')) - 5 AS nested_decode_and_subtract; 
SELECT (url_decode(url_decode('%E4%BD%A0%E5%A5%BD')) + 10) * 2 / 5 AS complex_nested_calculation;  
SELECT CONCAT(url_decode(url_decode('%E4%BD%A0%E5%A5%BD')), url_decode('%E7%A4%BA%E4%BE%8B')) AS nested_concat; 

SELECT url_decode('%E4%BD%A0%E5%A5%BD') AS nested_decode_length;
SELECT url_decode(url_decode('%E4%BD%A0%E5%A5%BD')) AS nested_decode_length;

