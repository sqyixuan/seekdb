SELECT id, url_decode('Hello%ZWorld') AS decoded_invalid_encoding
FROM url_decode_test
WHERE id = 3;

SELECT id, url_decode(REPEAT('%20', 10000)) AS decoded_long_string
FROM url_decode_test
WHERE id = 3;

SELECT id, url_decode('Encode+Test+%20%2A+~') AS decoded_space_back
FROM url_decode_test
WHERE id = 7;

--echo ### 基础case
select url_decode('%E7%A4%BA%E4%BE%8Bfor+url_decode%3A%2F%2F+%28fdsf%29'); 
--ERROR 1582
select url_decode('Example+for+url_decode+%3A%2F%2F+dsf%28fasfs%29', 'GBK'); 

### OB默认支持UTF8，且支持一个入参。两个及以上入参时有报错。
--ERROR 1582
select url_decode('Example+for+url_decode+%3A%2F%2F+dsf%28fasfs%29', 'UTF8'); 
--ERROR 1582
select url_decode('Example+for+url_decode+%3A%2F%2F+dsf%28fasfs%29', 'UTF-8'); 

select url_decode('Example+for+url_decode+%3A%2F%2F+dsf%28fasfs%29');
select url_decode(''); 
select url_decode(NULL);
select url_decode('hello+world');
select url_decode('%E4%BD%A0%E5%A5%BD'); 

### ob报错，odps为NULL
--ERROR 1210
select url_decode('%'); 
--ERROR 1210
select url_decode('%%'); 
--ERROR 1210
select url_decode('%GG');
select url_decode('example%2Ecom-%2A-%5F'); 

### OB 代码层面没有对UTF8以外的字符集做限制。
SET NAMES UTF8;
select url_decode(_gbk '中文');
select url_decode(CONVERT(_UTF8 '中文' USING GBK));
SET NAMES GBK;
select url_decode(_gbk '中文');
select url_decode(CONVERT(_UTF8 '中文' USING GBK));
SET NAMES UTF8;
--ERROR 1300
select CONVERT(_GBK 0xF8FF USING utf8mb4);
--ERROR 1300
select url_decode(CONVERT(_GBK 0xF8FF USING utf8mb4));

SELECT HEX(CONVERT(_utf16 0xF8FF USING utf8mb4));
select url_decode(CONVERT(_utf16 0xF8FF USING utf8mb4));

