SELECT TO_CHAR(TIMESTAMP '2023-07-15 14:30:45', 'SSSSS') FROM DUAL;  

SELECT TO_CHAR(DATE '1000-01-01', 'BC YYYY') FROM DUAL;  
SELECT TO_CHAR(DATE '2023-07-15', 'AD YYYY') FROM DUAL;  

SELECT TO_CHAR(TIMESTAMP '2023-07-15 14:30:45', 'YYYY-MM-DD HH:MI:SS') FROM DUAL;  
SELECT TO_CHAR(TIMESTAMP '2023-07-15 14:30:45', 'fmYYYY-MM-DD') FROM DUAL;  
SELECT TO_CHAR(DATE '2023-07-15', 'YYYY-MM-DD HH24:MI:SS') FROM DUAL;  
SELECT TO_CHAR(TIMESTAMP '2023-07-15 14:30:45', '"Date:"YYYYMMDD"Time:"HH24MISS') FROM DUAL;  

SELECT TO_CHAR(TIMESTAMP '2023-07-15 14:30:45', 'HH24:MI:SSXFF') FROM DUAL;
SELECT TO_CHAR(TIMESTAMP '2023-01-01 00:00:00.123456', 'X') FROM DUAL;
SELECT TO_CHAR(TIMESTAMP '2023-01-01 00:00:00.123456', 'X') FROM DUAL;
SELECT TO_CHAR(TIMESTAMP '2023-01-01 00:00:00.123456', 'SSXFF') FROM DUAL;
SELECT TO_CHAR(TIMESTAMP '2023-07-15 14:30:45', 'SSXFF') FROM DUAL;
SELECT TO_CHAR(TIMESTAMP '2023-07-15 14:30:45', 'SSXFF6') FROM DUAL;
SELECT TO_CHAR(TIMESTAMP '2023-07-15 14:30:45', 'SSXFF') FROM DUAL;

