SELECT TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-dd');
SELECT TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-dd') || ' ' || TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'hh:mi:ss') AS combined_date_time;

SELECT TO_CHAR(1234567890123456789) + 1000 AS big_int_plus_1000;
SELECT TO_CHAR(12345.6789) - 100 AS decimal_minus_100;
SELECT TO_CHAR(123.456) * 2 AS double_times_2;
SELECT TO_CHAR(TRUE) + ' is true' AS boolean_plus_string;
SELECT TO_CHAR(NULL) + ' test' AS null_plus_string;

SELECT TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-dd') + ' additional text' AS datetime_plus_text;
SELECT TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-dd') - '2021-11-29' AS datetime_minus_string;
SELECT (TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-dd') + ' additional text') * 2 AS nested_calculation_1;
SELECT (TO_CHAR(1234567890123456789) + 1000) * 2 AS nested_calculation_2; 
SELECT TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-dd') || ' is the date' AS date_and_string_concat;
SELECT TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-dd') + 1000 AS date_plus_number;
SELECT (TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-dd') || ' is the date') * 2 AS date_format_calculation;
SELECT TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-dd hh:mi:ss') + ' additional info' AS datetime_with_text;
SELECT TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-xx') + 1000 AS invalid_format_plus_number;
SELECT (TO_CHAR(1234567890123456789) + 1000) * 2 - 500 / 2 AS complex_operation_with_bigint;
SELECT (TO_CHAR(12345.6789) - 100) * 2 + 50 AS complex_decimal_calculation;
SELECT TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-dd') || TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', ' hh:mi:ss') AS nested_date_string_concat;
SELECT (TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-dd') + ' is the date') * 2 AS date_string_repetition;
SELECT (TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-dd') || ' added') + 1000 AS date_string_addition;
SELECT TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-dd') || ' ' || TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'hh:mi:ss') AS complex_date_concat;
SELECT TO_CHAR(NULL) + ' test' AS null_to_string_plus; 
SELECT TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', 'yyyy-mm-dd') + NULL AS date_plus_null;

