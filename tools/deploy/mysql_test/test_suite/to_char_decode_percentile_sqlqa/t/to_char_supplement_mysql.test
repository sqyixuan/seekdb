SELECT 
  TO_CHAR(123) || TO_CHAR(456.78) AS test1, 
  CONCAT(TO_CHAR(TRUE), ':', TO_CHAR(FALSE)) AS test2;

SELECT 
  TO_CHAR(TO_CHAR(100 + 20.5)) AS test3,   
  TO_CHAR(ABS(-999)) AS test4;  

SELECT TO_CHAR(CAST('123.45' AS DECIMAL)) AS test5; 
  
SELECT 
  LENGTH(TO_CHAR(CAST('123.45' AS DECIMAL))) AS test5, 
  SUBSTR(TO_CHAR(POWER(2, 10)), 2, 3) AS test6; 

SELECT 
  TO_CHAR(datetime1, CONCAT('yyyy', '-', 'mm*dd')) AS test9,
  TO_CHAR(datetime1, CASE WHEN id=1 THEN 'hh:mi' ELSE 'yyyy' END) AS test10
FROM mf_date_fun_t;

SELECT 
  TO_CHAR(datetime1, CONCAT('yyyy', '-', 'mm*dd')) AS test9 
FROM mf_date_fun_t;

SELECT 
  TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', CONCAT('yyyy', '-', 'mm*dd')) AS test9 
FROM mf_date_fun_t;

SELECT 
  TO_CHAR(TIMESTAMP '2021-11-29 00:01:00', CASE WHEN id=1 THEN 'hh:mi' ELSE 'yyyy' END) AS test10
FROM mf_date_fun_t;

--ERROR 1305
SELECT 
  TO_CHAR(TO_DATE(TO_CHAR(datetime1, 'yyyy-mm-dd'), 'yyyy-mm-dd'), 'yyyymmdd') AS test11
FROM mf_date_fun_t;

SELECT 
  TO_CHAR(TO_CHAR(TO_CHAR(123.456))) AS test14, 
  TO_CHAR(TO_CHAR(TRUE)) AS test15;    

SELECT 
  TO_CHAR(12345678901234567890.123456789) AS test20, 
  TO_CHAR(CAST('9.99999999999999e30' AS DOUBLE)) AS test21;
  
SELECT 
  TO_CHAR(TIMESTAMP'9999-12-31 23:59:59', 'yyyy-mm-dd hh:mi:ss') AS test22,
  TO_CHAR(TIMESTAMP'0001-01-01 00:00:00', 'yyyymmdd') AS test23; 

--ERROR 5608
SELECT 
  TO_CHAR('非数值字符串') AS test24,   
  TO_CHAR(date3, 'yyyy') AS test25
FROM mf_date_fun_t;

SELECT 
  CASE 
    WHEN id % 2 = 0 THEN TO_CHAR(datetime1, 'hh:mi')
    ELSE TO_CHAR(date1, 'yyyymmdd')
  END AS test26
FROM mf_date_fun_t;

SELECT 
  TO_CHAR(
    datetime1, 
    IF(id > 5, CONCAT('yy', 'yy-mm'), 'dd')
  ) AS test27
FROM mf_date_fun_t;

SELECT TO_CHAR(TO_CHAR('text'));
