purge recyclebin;
--echo #Environmental cleaning
--result_format 4

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set timestamp = 1600000000;
set @@session.explicit_defaults_for_timestamp=off;
--enable_sorted_result

--echo ###root用户
connect (root,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf8mb4;
use db1;
set sql_mode='';
SET sql_mode ='PIPES_AS_CONCAT';

--echo ### ISO年周格式 IYYY-IW 的跨年逻辑验证
--echo ### 跨年日期（ISO标准中2012-12-31属于2013-W01）

### OB mysql与 OB oracle结果不一致。待修复后刷新result
SELECT TO_CHAR(DATE '2012-12-31', 'IYYY-IW') AS R FROM DUAL;
SELECT TO_CHAR(DATE '2013-01-01', 'IYYY-IW') AS R FROM DUAL;
SELECT TO_CHAR(DATE '2005-01-01', 'IYYY-IW') AS R FROM DUAL;
SELECT TO_CHAR(DATE '2020-12-31', 'IYYY-IW') AS R FROM DUAL;

SELECT 
  TO_CHAR(DATE '2112-04-01', 'IYYY') AS Y4,
  TO_CHAR(DATE '2112-04-01', 'IY')   AS Y2,
  TO_CHAR(DATE '2112-04-01', 'I')    AS Y1 
FROM DUAL;

SELECT 
  TO_CHAR(DATE '1999-12-31', 'IYYY') AS ISO_YEAR 
FROM DUAL;

### OB mysql与 OB oracle结果不一致。
SELECT 
  TO_CHAR(DATE '02-03-04', 'IYYY') AS Y4 
FROM DUAL;

--echo ### 跨年日期 ：WW格式周计算（Oracle标准，按年首周计算）
### OB mysql与 OB oracle结果不一致。
SELECT 
  TO_CHAR(DATE '2023-01-01', 'WW') AS WW_NUM, 
  TO_CHAR(DATE '2023-01-01', 'IW') AS IW_NUM  
FROM DUAL;

SELECT 
  TO_CHAR(DATE '2012-12-31', 'WW') AS WW_NUM,  
  TO_CHAR(DATE '2012-12-31', 'IW') AS IW_NUM   
FROM DUAL;

SELECT 
  TO_CHAR(DATE '2024-02-29', 'YYYY-MM-DD "|" IYYY-IW') AS FORMAT_COMBINE 
FROM DUAL;

SELECT 
  TO_CHAR(DATE '2015-06-15', 'IYYY/IW') AS SLASH_FORMAT 
FROM DUAL;

SELECT TO_CHAR(DATE '2012-12-31', 'IYYY-IW') AS R FROM DUAL;
SELECT 
  TO_CHAR(TIMESTAMP '2023-05-20 14:30:45', 'IYYY-MM-DD HH24:MI:SS') AS TS_FORMAT 
FROM DUAL;

--echo ### ISO年可能与公元年不同
SELECT 
  TO_CHAR(DATE '0001-01-01', 'IYYY-IW') AS MIN_DATE 
FROM DUAL; 

--ERROR 1525
SELECT TO_CHAR(DATE '2023-02-30', 'IYYY-IW') FROM DUAL; 

### OB mysql与 OB oracle结果不一致。
