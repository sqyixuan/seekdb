  url_encode('示例', 'UTF-8') AS utf8_result,  
  url_encode('示例', 'GBK') AS gbk_result;   

--ERROR 1582
SELECT 
  url_encode(CONCAT('中文', CHAR(0x80)), 'GBK') AS mixed_gbk, 
  url_encode(CONCAT('中文', CHAR(0x80)), 'UTF-8') AS mixed_utf8;
--ERROR 1582
SELECT 
  url_encode('test', RPAD('UTF-8', 1000, 'X')) AS long_encoding;

SELECT 
  url_encode('%%% &//\\') AS percent_slash,  
  url_encode('key=value&name=测试') AS query_string; 

SELECT 
  url_encode('订单号:A*B_C+D~E') AS mixed_case; 

--echo ### 运算符

select url_encode('Hello ' || 'World');
select url_encode('Age: ' || 25);
select url_encode('Name: ' || '!#$%&\'()*+,-./:;<=>?@[\\]^_`{|}~');
select url_encode('Sum: ' || (3 + 4));
select url_encode('Result: ' || (5 * 3));
select url_encode('Average: ' || (10.5 / 2));
select url_encode('Result of (5 + 3) * 2: ' || ((5 + 3) * 2));
select url_encode('Complex Result: ' || (100 - (20 * 3) + 5));
select url_encode('Priority Result: ' || (5 + 3 * 2));
select url_encode('Nested Calculation Result: ' || ((5 + 3) * (2 + 1)));
select url_encode('Sum with symbols: ' || (5 + 10) || '&' || (2 * 3));
select url_encode('Expression (5 + 3) * 2 = ' || ((5 + 3) * 2));
select url_encode('Computed Value with spaces: ' || (10 + 5));
select url_encode('Sum + with space: ' || (100 + 200));
select url_encode('Result: ' || (5 + 3) || '!#$%&\'()*');
select url_encode('Sum of Chinese characters: ' || (10 + 20) || '中文');
select url_encode('Sum of 5 and NULL: ' || (5 + NULL));
select url_encode('Empty String Result: ' || '');
select url_encode('Nested Calculation Result: ' || ((5 + (2 * 3)) * 2));
select url_encode('Length of "Hello World" after space replaced: ' || length('Hello World' || ' '));

select url_encode(url_encode('Hello World'));
select url_encode('Hello ' || 'World');
select url_encode(url_encode(url_encode('Hello World')));
select url_encode('Length of Hello World: ' || length('Hello World'));
select url_encode('Result of (5 + 3) * 2: ' || ((5 + 3) * 2));
select url_encode('Result: ' || (length('Hello World') + (5 * 3)));
select url_encode('Nested result: ' || (5 + (2 * length('Hello'))));
select url_encode('Result: ' || case when 1 > 0 then 'True' else 'False' end);
select url_encode('Result: ' || case when (5 + 3) > 7 then 'Greater' else 'Smaller' end);
select url_encode('Substr result: ' || substring('Hello World' from 7 for 5));
select url_encode('Concatenated result: ' || (substring('Hello', 1, 2) || ' ' || substring('World', 1, 3)));
select url_encode('Substr result: ' || substring('Hello World' from 7 for 5));
select url_encode('Concatenated result: ' || (substring('Hello', 1, 2) || ' ' || substring('World', 1, 3)));
select url_encode('Test with NULL: ' || null);
select url_encode(url_encode(null));
select url_encode('Test empty string: ' || '');
