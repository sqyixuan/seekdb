--echo ### 数据类型测试 
SELECT 
  url_encode(12345) AS int_input,       
  url_encode(TRUE) AS bool_input,          
  url_encode(3.14) AS double_input,        
  url_encode(DATE '2023-01-01') AS date_input, 
  url_encode(TIMESTAMP '2023-01-01 12:00:00') AS timestamp_input; 

SELECT 
  url_encode(CHAR(127)) AS ascii_127,     
  url_encode(CHAR(128)) AS ascii_128,    
  url_encode(CHAR(255)) AS ascii_255;   

SELECT 
  url_encode('🎉') AS emoji,         
  url_encode('日本語') AS japanese,     
  url_encode('русский') AS russian;   

SELECT 
  url_encode(' !"#$%&\'()*+,-./:;<=>?@[\\]^_`{|}~') AS reserved_chars;

