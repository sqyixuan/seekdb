--ERROR 1582
select url_encode(url_encode('Hello World', 'GBK'), 'UTF-8');
select url_encode(url_encode('Hello World@123!'));
select url_encode(url_encode('Test: !#$%&*'));
select url_encode('Result of calculation: ' || (5 + (3 * 2)));
select url_encode('Complex result: ' || (5 + (2 * 3)) * (10 / 2));
select url_encode('Result of complex nested expression: ' || ((5 + (3 * 2)) * (7 - 2)));

