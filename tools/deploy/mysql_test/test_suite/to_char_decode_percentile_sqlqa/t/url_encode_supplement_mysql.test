--disable_warnings
drop table if exists url_encode_test;
--enable_warnings

CREATE TABLE url_encode_test (
    id INT,
    text_data VARCHAR(255),
    encoding VARCHAR(10),
    special_chars VARCHAR(255),
    null_field VARCHAR(255)
);

INSERT INTO url_encode_test VALUES
(1,'Hello World', 'UTF-8', '!#$&*()', NULL), 
(2,'Hello World', 'GBK', '%^@+=', NULL), 
(3,'  Hello  ', 'UTF-8', '[]{}|<>', NULL), 
(4,'Special_characters@123', 'UTF-8', '!*#&^%', NULL), 
(5,'Test Null Field', 'UTF-8', '', NULL), 
(6,'Encode Test %20 %2A ~', 'UTF-8', '', 'NULL');

SELECT id, url_encode(text_data) AS encoded_text
FROM url_encode_test
WHERE id = 1;

SELECT id, url_encode(special_chars) AS encoded_special_chars
FROM url_encode_test
WHERE id = 2;

SELECT id, url_encode(text_data) AS encoded_text_with_spaces
FROM url_encode_test
WHERE id = 3;

SELECT id, url_encode(null_field) AS encoded_null_field
FROM url_encode_test
WHERE id = 5;

SELECT id, url_encode('Test ' || null_field) AS encoded_with_null
FROM url_encode_test
WHERE id = 5;

SELECT id, url_encode(special_chars) AS encoded_special_characters
FROM url_encode_test
WHERE id = 4;

SELECT id, url_encode(url_encode(text_data)) AS encoded_text_double
FROM url_encode_test
WHERE id = 1;

--ERROR 1582
SELECT id, url_encode(text_data, 'UTF-8') AS encoded_utf8_text
FROM url_encode_test
WHERE id = 1;

--ERROR 1582
SELECT id, url_encode(text_data, 'GBK') AS encoded_gbk_text
FROM url_encode_test
WHERE id = 2;

SELECT id, url_encode(null_field) AS encoded_null_string
FROM url_encode_test
WHERE id = 6;

SELECT id, url_encode('Test&Encode*Special_Character') AS encoded_special_characters
FROM url_encode_test
WHERE id = 6;

SELECT id, url_encode('Encode Test %20 %2A ~') AS encoded_test_with_percent
FROM url_encode_test
WHERE id = 6;

SELECT id, url_encode('Hello World') AS encoded_with_plus
FROM url_encode_test
WHERE id = 1;

SELECT id, url_encode('Hello%World') AS encoded_percent_char
FROM url_encode_test
WHERE id = 1;

SELECT id, url_encode('Test String with special chars: !#$%&*()') AS encoded_complex_string
FROM url_encode_test
WHERE id = 1;

--disable_warnings
drop table if exists url_encode_test;
drop table if exists encoding_types;
--enable_warnings

CREATE TABLE IF NOT EXISTS url_encode_test (
    id INT COMMENT '测试用例ID',
    input_str STRING COMMENT '输入字符串',
    encoding STRING COMMENT '编码格式',
    expected STRING COMMENT '预期结果（示例）'
);

CREATE TABLE IF NOT EXISTS encoding_types (
    encoding_name STRING
);

INSERT  INTO url_encode_test VALUES
(1, 'abcXYZ012', 'UTF-8', 'abcXYZ012'),
(2, '.-*_', 'UTF-8', '.-*_'),
(3, ' ', 'UTF-8', '+'),
(4, '!@#$%^&*()', 'UTF-8', '%21%40%23%24%25%5E%26%2A%28%29'),
(5, '[]{}|\\:\'"<>,?/', 'UTF-8', '%5B%5D%7B%7D%7C%5C%3B%3A%27%22%3C%3E%2C%3F%2F'),
(6, '示例αΩ', 'UTF-8', '%E7%A4%BA%E4%BE%8B%CE%B1%CE%A9'),
(7, '示例αΩ', 'GBK', '%CA%BE%C0%FD%CE%B1%CE%A9'), 
(8, '😊🚀', 'UTF-8', '%F0%9F%98%8A%F0%9F%9A%80'),
(9, '', 'UTF-8', ''),
(10, NULL, 'UTF-8', NULL),
(11, 'null_test', NULL, NULL),
(12, 'a', 'UTF-8', 'a'),
(13, 'A1_* - 测试@', 'UTF-8', 'A1_%2A%20-%20%E6%B5%8B%E8%AF%95%40');

INSERT  INTO  encoding_types VALUES
('UTF-8'),
('GBK'),
('ISO-8859-1'),
(NULL),
('Invalid_Encoding');

SELECT 
    t.id,
    t.input_str,
    t.encoding,
    url_encode(t.input_str) AS default_encode,
    url_encode(t.input_str) AS specified_encode,
    url_encode(t.input_str) AS encoding_test,
    url_encode(NULL) AS null_input_test,
    url_encode(t.input_str) AS null_encoding_test
FROM url_encode_test t
CROSS JOIN encoding_types e
WHERE t.id BETWEEN 1 AND 13 
ORDER BY t.id;

SELECT 
    url_encode('~`!@#$%^&*()_-+={[}]|\\:;"\'<,>.?/') AS special_chars;

SELECT 
    url_encode(
        CONCAT(
            'a', 
            '测试', 
            '!@#'
        )
    ) AS long_str_test;

SELECT 
    url_encode('test') AS invalid_encoding_test;

SELECT 
    url_encode('') AS empty_string,
    url_encode(' ') AS single_space;

--disable_warnings
drop table if exists url_encode_test_cases;
--enable_warnings

CREATE TABLE IF NOT EXISTS url_encode_test_cases (
    id INT,
    input STRING COMMENT '常规字符串输入',
    num_input BIGINT COMMENT '数字类型输入测试隐式转换',
    bin_input BINARY COMMENT '二进制类型输入测试',
    null_input STRING COMMENT 'NULL值测试',
    special_chars STRING COMMENT '特殊字符专用字段'
);

INSERT INTO url_encode_test_cases VALUES
(1, 'abcXYZ012', 12345, unhex('00FF'), NULL, 'basic_chars'),
(2, '-_.*', 0, unhex(''), NULL, '-_.*'),
(3, '  multi space  ', NULL, NULL, NULL, '  '),
(4, '~`!@#$%^&*()_+={}[]|\\:"\'<>,?/', NULL, NULL, NULL, 'special_full_set'),
(5, '中文测试αΩ😊', NULL, NULL, NULL, 'multi_byte'),
(6, '', NULL, NULL, NULL, 'empty_string'),
(7, NULL, NULL, NULL, NULL, 'all_null'),
(8, RPAD('a', 10000, 'b'), NULL, NULL, NULL, '10k_length'),
(9, "' OR 1=1; --", NULL, NULL, NULL, 'sql_injection_chars'),
(10, '%20%25test', NULL, NULL, NULL, 'pre_encoded'),
(11, CONCAT('ctrl', char(0), 'chars', char(8)), NULL, NULL, NULL, 'control_chars');

SELECT 
    id,
    url_encode(input) AS default_encode,
    url_encode(input) AS explicit_utf8,
    url_encode(input) AS gbk_encode
FROM url_encode_test_cases
WHERE id IN (1,2,5,6);

### ob支持BINARY等类型，odps不支持。
SELECT 
    id,
    url_encode(num_input) AS num_encode,     
    url_encode(bin_input) AS bin_encode      
FROM url_encode_test_cases
WHERE id = 1;

SELECT 
    url_encode(special_chars) AS utf8_result,
    url_encode(special_chars) AS gbk_result,
    url_encode(special_chars) AS default_result
FROM url_encode_test_cases
WHERE id = 4;

SELECT 
    url_encode('') AS empty_string,                 
    url_encode(' ') AS single_space,         
    url_encode(null_input) AS null_input,           
    url_encode('test') AS null_encoding,      
    url_encode(NULL) AS double_null           
FROM url_encode_test_cases
WHERE id IN (6,7);

SELECT 
    url_encode(input) AS invalid_encoding, 
    url_encode(char(999999)) AS invalid_unicode,                
    url_encode(input) AS over_params   
FROM url_encode_test_cases
WHERE id = 5;

### OB有报错 1267,ODPS无报错。
--ERROR 1267
SELECT 
    LENGTH(url_encode(input)) AS encoded_length, 
    url_encode(input) = RPAD('a', 10000, 'b') AS long_str_test  
FROM url_encode_test_cases
WHERE id = 8;

SELECT 
    url_encode(url_encode(input)) AS double_encode  
FROM url_encode_test_cases
WHERE id = 10;

SELECT 
    url_encode(input) AS ctrl_chars_encode
FROM url_encode_test_cases
WHERE id = 11;

SELECT 
    url_encode(input) AS injection_test
FROM url_encode_test_cases
WHERE id = 9;

--ERROR 1267
SELECT 
    input,
    url_encode(input) AS encoded
FROM url_encode_test_cases
WHERE id = 2
HAVING encoded NOT LIKE '%-%' 
   AND encoded NOT LIKE '%_%' 
   AND encoded NOT LIKE '%.%'
   AND encoded NOT LIKE '%*%';

--error 1582
SELECT 
    input,
    url_encode(input, 'UTF-8') AS utf8,
    url_encode(input, 'GBK') AS gbk
FROM url_encode_test_cases
WHERE id = 5
HAVING utf8 = gbk; 

--error 1267
SELECT 
    input,
    url_encode(input) AS encoded
FROM url_encode_test_cases
WHERE id = 3
HAVING encoded NOT LIKE '% %' 
   AND encoded LIKE '%+%';

--disable_warnings
drop table if exists nested_url_encode_test;
--enable_warnings

CREATE TABLE IF NOT EXISTS nested_url_encode_test (
    id INT,
    raw_str STRING,
    dynamic_encoding STRING
);

INSERT into nested_url_encode_test VALUES
(1, '测试/嵌套', 'UTF-8'),
(2, 'Multi Level::Nesting', 'GBK'),
(3, 'a+b*c-d_e.f', NULL),
(4, '带有空格 和%符号', 'UTF-8'),
(5, NULL, 'GBK'),
(6, '', 'UTF-8'),
(7, '🐧🎉', 'GBK');

SELECT 
    id,
    url_encode(url_encode(raw_str)) AS double_encode, 
    url_encode(url_encode(url_encode(raw_str))) AS triple_encode, 
    url_encode(url_encode(url_encode(url_encode(raw_str)))) AS quadruple_encode
FROM nested_url_encode_test
WHERE id IN (1,2,3,4);

SELECT 
    id,
    url_encode(CONCAT('prefix_', SUBSTR(raw_str, 2, 4), '_suffix')) AS concat_substr,
    url_encode(REPLACE(raw_str, '/', '%2F')) AS replace_before_encode,
    url_encode(REPLACE(raw_str, 'ab', 'AB')) AS replace_encode
FROM nested_url_encode_test
WHERE id IN (1,2,4);

SELECT 
    id,
    url_encode(URL_DECODE(url_encode(raw_str))) AS encode_decode_encode,
    URL_DECODE(url_encode(URL_DECODE(url_encode(raw_str)))) AS decode_encode_decode_encode
FROM nested_url_encode_test
WHERE id IN (1,4);

SELECT 
    id,
    CASE 
        WHEN LENGTH(raw_str) > 5 THEN url_encode(CONCAT(raw_str, '_append'))
        ELSE url_encode(url_encode(raw_str))
    END AS conditional_encode,
    COALESCE(url_encode(raw_str), 'DEFAULT') AS coalesce_encode
FROM nested_url_encode_test;

--ERROR 1267
SELECT 
    raw_str,
    url_encode(url_encode(raw_str)) AS double_result,
    url_encode(raw_str) AS single_result
FROM nested_url_encode_test
WHERE id = 4
HAVING double_result NOT LIKE REPLACE(single_result, '%', '%25');

SELECT 
    raw_str,
    URL_DECODE(url_encode(raw_str)) AS decoded_value
FROM nested_url_encode_test
WHERE id IN (1,2,4)
HAVING decoded_value != raw_str;

SELECT 
    t1.raw_str,
    t1.dynamic_encoding,
    url_encode(t1.raw_str) AS cross_encode
FROM nested_url_encode_test t1
CROSS JOIN nested_url_encode_test t2
WHERE t1.id = 1 AND t2.id = 2
HAVING cross_encode NOT IN (
    url_encode(t1.raw_str),
    url_encode(t1.raw_str)
);

SELECT 
    url_encode(url_encode(url_encode(NULL))) AS triple_null, 
    url_encode(url_encode('')) AS double_empty 
FROM nested_url_encode_test
WHERE id = 5;

--ERROR 1267
SELECT 
    url_encode(url_encode('a+b*c-d_e.f')) AS encoded_special,
    url_encode('a+b*c-d_e.f') AS single_encoded
FROM nested_url_encode_test
WHERE id = 3
HAVING encoded_special NOT LIKE '%2B%2A%2D%5F%2E%';

  
