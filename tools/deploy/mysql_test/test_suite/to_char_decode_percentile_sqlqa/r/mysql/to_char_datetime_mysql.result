| last_day_of_year |
+------------------+
| 365              |
+------------------+
SELECT TO_CHAR(DATE '2021-12-31', 'DDD') AS last_day_of_year  FROM DUAL;
+------------------+
| last_day_of_year |
+------------------+
| 365              |
+------------------+
SELECT TO_CHAR(TIMESTAMP '2021-07-01 14:08:23', 'Y,YYY***MM///DD HH12"时"') FROM dual;
+-----------------------------------------------------------------------+
| TO_CHAR(TIMESTAMP '2021-07-01 14:08:23', 'Y,YYY***MM///DD HH12"时"')  |
+-----------------------------------------------------------------------+
| 2,021***07///01 02时                                                  |
+-----------------------------------------------------------------------+
SELECT TO_CHAR(TIMESTAMP '2020-03-20 03:04:05', 'SYYYY"地球年"MM"火星月"DD"月球日"') FROM dual;
+----------------------------------------------------------------------------------------+
| TO_CHAR(TIMESTAMP '2020-03-20 03:04:05', 'SYYYY"地球年"MM"火星月"DD"月球日"')          |
+----------------------------------------------------------------------------------------+
|  2020地球年03火星月20月球日                                                            |
+----------------------------------------------------------------------------------------+
SELECT 
    TO_CHAR(DATE '1999-12-31', 'CC') AS cc_1999,
    TO_CHAR(DATE '2000-01-01', 'CC') AS cc_2000,
    TO_CHAR(DATE '9999-12-31', 'CC') AS cc_9999 
FROM dual;
ERROR HY000: date format is too long for internal buffer
SELECT TO_CHAR(datetime1, 'Q') AS quarter, TO_CHAR(datetime1, 'RM') AS roman_month FROM mf_date_fun_t;
ERROR 22007: Incorrect value
SELECT 
    TO_CHAR(TIMESTAMP '2023-05-05 00:00:00', 'HH-HH12-HH24') AS midnight,
    TO_CHAR(TIMESTAMP '2023-05-05 12:00:00', 'HH-HH12-HH24') AS noon 
FROM dual;
+----------+----------+
| midnight | noon     |
+----------+----------+
| 12-12-00 | 12-12-12 |
+----------+----------+
SELECT TO_CHAR(TIMESTAMP '2023-08-18 13:45:59.123456', 'YYYY-MM-DD"T"HH24:MI:SS.FF3') AS iso8601 FROM dual;
+-------------------------+
| iso8601                 |
+-------------------------+
| 2023-08-18T13:45:59.123 |
+-------------------------+
SELECT TO_CHAR(TIMESTAMP '2021-01-01 23:59:59', 'SSSSS') AS last_second FROM dual;
+-------------+
| last_second |
+-------------+
| 86399       |
+-------------+
SELECT 
    TO_CHAR(DATE '2024-01-01', 'IW') AS iso_week_1,
    TO_CHAR(DATE '2024-01-07', 'WW') AS std_week_1,
    TO_CHAR(DATE '2024-01-31', 'W') AS january_week5 
FROM dual;
+------------+------------+---------------+
| iso_week_1 | std_week_1 | january_week5 |
+------------+------------+---------------+
| 01         | 01         | 5             |
+------------+------------+---------------+
SELECT TO_CHAR(DATE '-1000-10-10', 'SYYYY-MM-DD BC') AS ancient_date FROM dual;
ERROR HY000: Incorrect DATE value: '-1000-10-10'
SELECT TO_CHAR(TIMESTAMP '2023-09-21 15:30:45', '"日期："YYYY"世纪："CC"季度："Q"儒略日："J"星期："DAY"时间："HH24:MI:SS') 
FROM dual;
ERROR HY000: date format is too long for internal buffer
SELECT 
    TO_CHAR(DATE '2021-01-11', 'MON') AS jan,
    TO_CHAR(DATE '2021-01-11', 'MONTH') AS january_full,
    TO_CHAR(DATE '2021-01-11', 'DY') AS weekday_short,
    TO_CHAR(DATE '2021-01-11', 'DAY') AS weekday_full 
FROM dual;
+------+--------------+---------------+--------------+
| jan  | january_full | weekday_short | weekday_full |
+------+--------------+---------------+--------------+
| JAN  | JANUARY      | MON           | MONDAY       |
+------+--------------+---------------+--------------+
SELECT 
    TO_CHAR(TIMESTAMP '2021-01-11', 'MON') AS jan,
    TO_CHAR(TIMESTAMP '2021-01-11', 'MONTH') AS january_full,
    TO_CHAR(TIMESTAMP '2021-01-11', 'DY') AS weekday_short,
    TO_CHAR(TIMESTAMP '2021-01-11', 'DAY') AS weekday_full 
FROM dual;
+------+--------------+---------------+--------------+
| jan  | january_full | weekday_short | weekday_full |
+------+--------------+---------------+--------------+
| JAN  | JANUARY      | MON           | MONDAY       |
+------+--------------+---------------+--------------+
SELECT 
    TO_CHAR(TIMESTAMP '1999-08-15', 'RR') AS rr_99,
    TO_CHAR(TIMESTAMP '2089-11-03', 'RRRR') AS rrrr_89 
FROM dual;
+-------+---------+
| rr_99 | rrrr_89 |
+-------+---------+
| 99    | 2089    |
+-------+---------+
