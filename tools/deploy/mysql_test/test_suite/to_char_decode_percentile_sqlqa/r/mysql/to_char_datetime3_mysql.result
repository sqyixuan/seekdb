purge recyclebin;
#Environmental cleaning
result_format: 4
###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set timestamp = 1600000000;
set @@session.explicit_defaults_for_timestamp=off;
###root用户
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf8mb4;
use db1;
set sql_mode='';
SET sql_mode ='PIPES_AS_CONCAT';
###  DY
SELECT TO_CHAR(DATE '2023-04-28', 'DY') AS day_short_1 FROM DUAL;
+-------------+
| day_short_1 |
+-------------+
| FRI         |
+-------------+
SELECT TO_CHAR(DATE '2023-04-24', 'DY') AS day_short_2 FROM DUAL;
+-------------+
| day_short_2 |
+-------------+
| MON         |
+-------------+
SELECT TO_CHAR(DATE '2023-04-30', 'DY') AS day_short_3 FROM DUAL;
+-------------+
| day_short_3 |
+-------------+
| SUN         |
+-------------+
SELECT TO_CHAR(DATE '2023-05-03', 'DY') AS day_short_4 FROM DUAL;
+-------------+
| day_short_4 |
+-------------+
| WED         |
+-------------+
SELECT TO_CHAR(DATE '2023-01-01', 'DY') AS day_short_5 FROM DUAL;
+-------------+
| day_short_5 |
+-------------+
| SUN         |
+-------------+
SELECT TO_CHAR(DATE '2023-02-30', 'DY') AS day_short_6 FROM DUAL;
ERROR HY000: Incorrect DATE value: '2023-02-30'
SELECT TO_CHAR(DATE '0001-01-01', 'DY') AS day_short_7 FROM DUAL;
+-------------+
| day_short_7 |
+-------------+
| MON         |
+-------------+
SELECT TO_CHAR(DATE '9999-12-31', 'DY') AS day_short_8 FROM DUAL;
+-------------+
| day_short_8 |
+-------------+
| FRI         |
+-------------+
SELECT TO_CHAR(TIMESTAMP '1999-12-31 23:59:59', 'DY') AS day_short_9 FROM DUAL;
+-------------+
| day_short_9 |
+-------------+
| FRI         |
+-------------+
