+--------------------------+
| text                     |
+--------------------------+
SELECT TO_CHAR(TIMESTAMP '2021-13-01 00:00:00', 'yyyy');
ERROR HY000: Incorrect DATETIME value: '2021-13-01 00:00:00'
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', '阿里金融yyyy-mm-dd');
ERROR 22007: Incorrect value
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy年mm月dd日');
ERROR 22007: Incorrect value
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd HH:MI:SS', 'UTF8');
ERROR 42000: Incorrect parameter count
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd HH:MI:SS', 'GBK');
ERROR 42000: Incorrect parameter count
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd HH:MI:SS', 'GB18030');
ERROR 42000: Incorrect parameter count
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd HH:MI:SS', 'UTF16');
ERROR 42000: Incorrect parameter count
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd HH:MI:SS', 'ASCII');
ERROR 42000: Incorrect parameter count
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd HH:MI:SS', 'LATIN1');
ERROR 42000: Incorrect parameter count
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd *dd');
+------------------------------------------------------------+
| TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd *dd') |
+------------------------------------------------------------+
| 2021-11-29 *29                                             |
+------------------------------------------------------------+
### ob 和 odps 结果不一致。
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd "yyyy-mm-dd"');
+---------------------------------------------------------------------+
| TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd "yyyy-mm-dd"') |
+---------------------------------------------------------------------+
| 2021-11-29 yyyy-mm-dd                                               |
+---------------------------------------------------------------------+
SELECT TO_CHAR(TIMESTAMP '2010-12-03 00:00:00', 'yyyy年mm月dd日');
ERROR 22007: Incorrect value
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd [yyyy-mm-dd]');
+---------------------------------------------------------------------+
| TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd [yyyy-mm-dd]') |
+---------------------------------------------------------------------+
| 2021-11-29 [2021-11-29]                                             |
+---------------------------------------------------------------------+
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy/mm/dd');
+--------------------------------------------------------+
| TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy/mm/dd') |
+--------------------------------------------------------+
| 2021/11/29                                             |
+--------------------------------------------------------+
SELECT TO_CHAR(TIMESTAMP '2010-12-03', 'yyyy-mm-dd');
+-----------------------------------------------+
| TO_CHAR(TIMESTAMP '2010-12-03', 'yyyy-mm-dd') |
+-----------------------------------------------+
| 2010-12-03                                    |
+-----------------------------------------------+
SELECT TO_CHAR(TIMESTAMP '20102401', 'yyyy-mm-dd');
ERROR HY000: Incorrect DATETIME value: '20102401'
SELECT TO_CHAR(TIMESTAMP '2021-13-01', 'yyyy-mm-dd');
ERROR HY000: Incorrect DATETIME value: '2021-13-01'
SELECT TO_CHAR(NULL, 'yyyy-mm-dd');
+-----------------------------+
| TO_CHAR(NULL, 'yyyy-mm-dd') |
+-----------------------------+
|                        NULL |
+-----------------------------+
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', NULL);
+------------------------------------------------+
| TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', NULL) |
+------------------------------------------------+
| NULL                                           |
+------------------------------------------------+
SELECT TO_CHAR(NULL, NULL);
+---------------------+
| TO_CHAR(NULL, NULL) |
+---------------------+
|                NULL |
+---------------------+
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd hh:mi:ss');
+-----------------------------------------------------------------+
| TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd hh:mi:ss') |
+-----------------------------------------------------------------+
| 2021-11-29 12:30:00                                             |
+-----------------------------------------------------------------+
SELECT TO_CHAR(12345678901234567890, '99999999999999999999');
+-------------------------------------------------------+
| TO_CHAR(12345678901234567890, '99999999999999999999') |
+-------------------------------------------------------+
|  12345678901234567890                                 |
+-------------------------------------------------------+
SELECT TO_CHAR(0, '0');
+-----------------+
| TO_CHAR(0, '0') |
+-----------------+
|  0              |
+-----------------+
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd') = '2021-11-29';
+-----------------------------------------------------------------------+
| TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd') = '2021-11-29' |
+-----------------------------------------------------------------------+
|                                                                     1 |
+-----------------------------------------------------------------------+
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd') = '2021-11-30';
+-----------------------------------------------------------------------+
| TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd') = '2021-11-30' |
+-----------------------------------------------------------------------+
|                                                                     0 |
+-----------------------------------------------------------------------+
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd hh:mi:ss') = '2021-11-29 12:30:00';
+-----------------------------------------------------------------------------------------+
| TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd hh:mi:ss') = '2021-11-29 12:30:00' |
+-----------------------------------------------------------------------------------------+
|                                                                                       1 |
+-----------------------------------------------------------------------------------------+
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd hh:mi') = '2021-11-29 12:30';
+-----------------------------------------------------------------------------------+
| TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd hh:mi') = '2021-11-29 12:30' |
+-----------------------------------------------------------------------------------+
|                                                                                 1 |
+-----------------------------------------------------------------------------------+
SELECT TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd hh') = '2021-11-29 12';
+-----------------------------------------------------------------------------+
| TO_CHAR(TIMESTAMP '2021-11-29 12:30:00', 'yyyy-mm-dd hh') = '2021-11-29 12' |
+-----------------------------------------------------------------------------+
|                                                                           1 |
+-----------------------------------------------------------------------------+
