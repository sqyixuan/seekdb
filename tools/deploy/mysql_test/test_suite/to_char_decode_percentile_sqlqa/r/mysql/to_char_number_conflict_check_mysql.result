purge recyclebin;
#Environmental cleaning
result_format: 4
###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
###root用户
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf8mb4;
use db1;
set sql_mode='';
SET sql_mode ='PIPES_AS_CONCAT';
