SELECT 
    id,
    url_encode(CONCAT('prefix_', SUBSTR(raw_str, 2, 4), '_suffix')) AS concat_substr,
    url_encode(REPLACE(raw_str, '/', '%2F')) AS replace_before_encode,
    url_encode(REPLACE(raw_str, 'ab', 'AB')) AS replace_encode
FROM nested_url_encode_test
WHERE id IN (1,2,4);
