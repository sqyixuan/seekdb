SELECT 
    id,
    CASE 
        WHEN LENGTH(raw_str) > 5 THEN url_encode(CONCAT(raw_str, '_append'))
        ELSE url_encode(url_encode(raw_str))
    END AS conditional_encode,
    COALESCE(url_encode(raw_str), 'DEFAULT') AS coalesce_encode
FROM nested_url_encode_test;
