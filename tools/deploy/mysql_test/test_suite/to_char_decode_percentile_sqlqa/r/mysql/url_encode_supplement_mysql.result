SELECT 
    input,
    url_encode(input) AS encoded
FROM url_encode_test_cases
WHERE id = 2
HAVING encoded NOT LIKE '%-%' 
   AND encoded NOT LIKE '%_%' 
   AND encoded NOT LIKE '%.%'
   AND encoded NOT LIKE '%*%';
ERROR HY000: Illegal mix of collations (utf8mb4_zh_0900_as_cs,COERCIBLE), (utf8mb4_general_ci,COERCIBLE)
SELECT 
    input,
    url_encode(input, 'UTF-8') AS utf8,
    url_encode(input, 'GBK') AS gbk
FROM url_encode_test_cases
WHERE id = 5
HAVING utf8 = gbk;
ERROR 42000: Incorrect parameter count in the call to native function 'url_encode'
SELECT 
    input,
    url_encode(input) AS encoded
FROM url_encode_test_cases
WHERE id = 3
HAVING encoded NOT LIKE '% %' 
   AND encoded LIKE '%+%';
