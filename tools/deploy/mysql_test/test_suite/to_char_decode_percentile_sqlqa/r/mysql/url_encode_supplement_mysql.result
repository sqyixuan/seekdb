purge recyclebin;
#Environmental cleaning
result_format: 4
###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
###root用户
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf8mb4;
use db1;
set sql_mode='';
SET sql_mode ='PIPES_AS_CONCAT';
set names 'UTF8';
### 基础功能测试 
select url_encode('Hello World');
+---------------------------+
| url_encode('Hello World') |
+---------------------------+
| Hello%20World             |
+---------------------------+
select url_encode('Hello World with space');
+--------------------------------------+
| url_encode('Hello World with space') |
+--------------------------------------+
| Hello%20World%20with%20space         |
+--------------------------------------+
select url_encode('Hello [World]?');
+------------------------------+
| url_encode('Hello [World]?') |
+------------------------------+
| Hello%20%5BWorld%5D%3F       |
+------------------------------+
select url_encode('示例for url_encode:// (fdsf)');
+----------------------------------------------------------+
| url_encode('示例for url_encode:// (fdsf)')               |
+----------------------------------------------------------+
| %E7%A4%BA%E4%BE%8Bfor%20url_encode%3A%2F%2F%20%28fdsf%29 |
+----------------------------------------------------------+
select url_encode('example-url_encode._-*');
+--------------------------------------+
| url_encode('example-url_encode._-*') |
+--------------------------------------+
| example-url_encode._-%2A             |
+--------------------------------------+
select url_encode('');
+----------------+
| url_encode('') |
+----------------+
|                |
+----------------+
select url_encode(NULL);
+------------------+
| url_encode(NULL) |
+------------------+
| NULL             |
+------------------+
select url_encode(NULL, 'UTF-8');
ERROR 42000: Incorrect parameter count in the call to native function 'url_encode'
select url_encode('中文测试', 'UTF-8');
ERROR 42000: Incorrect parameter count in the call to native function 'url_encode'
select url_encode('中文测试', 'GBK');
ERROR 42000: Incorrect parameter count in the call to native function 'url_encode'
select url_encode('中文测试', 'ISO-8859-1');
ERROR 42000: Incorrect parameter count in the call to native function 'url_encode'
select url_encode('示例for url_encode:// (fdsf)', 'UTF-8');
ERROR 42000: Incorrect parameter count in the call to native function 'url_encode'
select url_encode('示例for url_encode:// (fdsf)', 'GBK');
ERROR 42000: Incorrect parameter count in the call to native function 'url_encode'
