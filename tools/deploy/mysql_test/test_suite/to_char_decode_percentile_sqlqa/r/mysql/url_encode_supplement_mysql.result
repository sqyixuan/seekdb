+----------------------------------------------------------+
| %E7%A4%BA%E4%BE%8Bfor%20url_encode%3A%2F%2F%20%28fdsf%29 |
+----------------------------------------------------------+
SELECT url_encode('hello world') AS result;
+---------------+
| result        |
+---------------+
| hello%20world |
+---------------+
SELECT url_encode('示例') AS result;
+--------------------+
| result             |
+--------------------+
| %E7%A4%BA%E4%BE%8B |
+--------------------+
### 参数边界测试 
SELECT URL_ENCODE('abcXYZ.-*_') AS test_result;
+--------------+
| test_result  |
+--------------+
| abcXYZ.-%2A_ |
+--------------+
SELECT URL_ENCODE('hello world') AS test_result;
+---------------+
| test_result   |
+---------------+
| hello%20world |
+---------------+
SELECT URL_ENCODE('2024') AS test_result;
+-------------+
| test_result |
+-------------+
| 2024        |
+-------------+
SELECT URL_ENCODE('!@#$%^&()') AS test_result;
+-----------------------------+
| test_result                 |
+-----------------------------+
| %21%40%23%24%25%5E%26%28%29 |
+-----------------------------+
SELECT URL_ENCODE('示例') AS test_result;
+--------------------+
| test_result        |
+--------------------+
| %E7%A4%BA%E4%BE%8B |
+--------------------+
SELECT URL_ENCODE(UNHEX('00')) AS test_result;
+-------------+
| test_result |
+-------------+
| %00         |
+-------------+
SELECT URL_ENCODE(UNHEX('FF')) AS test_result;
+-------------+
| test_result |
+-------------+
| %FF         |
+-------------+
SELECT URL_ENCODE(UNHEX('7F')) AS test_result;
+-------------+
| test_result |
+-------------+
| %7F         |
+-------------+
SELECT URL_ENCODE('%AAabc') AS test_result;
+-------------+
| test_result |
+-------------+
| %25AAabc    |
+-------------+
SELECT URL_ENCODE('abc%BB') AS test_result;
+-------------+
| test_result |
+-------------+
| abc%25BB    |
+-------------+
SELECT URL_ENCODE('a1 测试_*') AS test_result;
+-----------------------------+
| test_result                 |
+-----------------------------+
| a1%20%E6%B5%8B%E8%AF%95_%2A |
+-----------------------------+
SELECT URL_ENCODE('%') AS test_result;
+-------------+
| test_result |
+-------------+
| %25         |
+-------------+
SELECT URL_ENCODE('%A') AS test_result;
+-------------+
| test_result |
+-------------+
| %25A        |
+-------------+
SELECT URL_ENCODE('%AG') AS test_result;
+-------------+
| test_result |
+-------------+
| %25AG       |
+-------------+
SELECT URL_ENCODE(UNHEX('1a2b')) AS test_result;
+-------------+
| test_result |
+-------------+
| %1A%2B      |
+-------------+
SELECT URL_ENCODE('abcdefghijklmnopqrstuvwxyz');
+------------------------------------------+
| URL_ENCODE('abcdefghijklmnopqrstuvwxyz') |
+------------------------------------------+
| abcdefghijklmnopqrstuvwxyz               |
+------------------------------------------+
SELECT URL_ENCODE('ABCDEFGHIJKLMNOPQRSTUVWXYZ');
+------------------------------------------+
| URL_ENCODE('ABCDEFGHIJKLMNOPQRSTUVWXYZ') |
+------------------------------------------+
| ABCDEFGHIJKLMNOPQRSTUVWXYZ               |
+------------------------------------------+
SELECT URL_ENCODE('.-*_');
+--------------------+
| URL_ENCODE('.-*_') |
+--------------------+
| .-%2A_             |
+--------------------+
SELECT URL_ENCODE('Hello World');
+---------------------------+
| URL_ENCODE('Hello World') |
+---------------------------+
| Hello%20World             |
+---------------------------+
SELECT URL_ENCODE('Hello! Welcome to URL Encoding.');
+-----------------------------------------------+
| URL_ENCODE('Hello! Welcome to URL Encoding.') |
+-----------------------------------------------+
| Hello%21%20Welcome%20to%20URL%20Encoding.     |
+-----------------------------------------------+
SELECT URL_ENCODE('示例');
+----------------------+
| URL_ENCODE('示例')   |
+----------------------+
| %E7%A4%BA%E4%BE%8B   |
+----------------------+
SELECT URL_ENCODE('test@example.com');
