select url_encode('!#$%&\'()*+,-./:;<=>?@[\\]^_`{|}~');
+---------------------------------------------------------------------------------------+
| url_encode('!#$%&\'()*+,-./:;<=>?@[\\]^_`{|}~')                                       |
+---------------------------------------------------------------------------------------+
| %21%23%24%25%26%27%28%29%2A%2B%2C-.%2F%3A%3B%3C%3D%3E%3F%40%5B%5C%5D%5E_%60%7B%7C%7D~ |
+---------------------------------------------------------------------------------------+
