| id   | encoded_special_characters        |
+------+-----------------------------------+
|    6 | Test%26Encode%2ASpecial_Character |
+------+-----------------------------------+
SELECT id, url_encode('Encode Test %20 %2A ~') AS encoded_test_with_percent
