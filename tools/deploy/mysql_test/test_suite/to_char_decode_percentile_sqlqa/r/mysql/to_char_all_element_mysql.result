purge recyclebin;
#Environmental cleaning
result_format: 4
###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
###root用户
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf8mb4;
use db1;
set sql_mode='';
SET sql_mode ='PIPES_AS_CONCAT';
##################################, (comma)正常测试-1-1-1##################
select to_char(12345, '9,,,9,,9,9,9') from dual;
+--------------------------------+
| to_char(12345, '9,,,9,,9,9,9') |
+--------------------------------+
|  1,,,2,,3,4,5                  |
+--------------------------------+
select to_char(12345, '9,9,9,9,9') from dual;
+-----------------------------+
| to_char(12345, '9,9,9,9,9') |
+-----------------------------+
|  1,2,3,4,5                  |
+-----------------------------+
select to_char(100000000, '9,9999,9999') from dual;
