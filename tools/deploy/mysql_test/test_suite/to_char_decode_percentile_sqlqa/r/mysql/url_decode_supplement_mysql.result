DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf8mb4;
use db1;
set sql_mode='';
SET sql_mode ='PIPES_AS_CONCAT';
drop table if exists url_decode_test;
CREATE TABLE url_decode_test (
    id INT,
    encoded_data VARCHAR(1024),  
    encoding VARCHAR(10),        
    special_chars VARCHAR(255),  
    null_field VARCHAR(255)      
);
