### 函数+函数嵌套
SELECT 
  PERCENTILE_CONT(dept_median, 0.5) AS global_median
FROM (
  SELECT PERCENTILE_CONT(sal, 0.5) AS dept_median 
  FROM emp 
  GROUP BY deptno
) t;
+---------------+
| global_median |
+---------------+
|          2450 |
+---------------+
WITH dept_stats AS (
  SELECT 
    deptno, 
    PERCENTILE_CONT(sal, array(0.25, 0.75)) AS pct_arr 
  FROM emp 
  GROUP BY deptno
)
SELECT 
  deptno,
  pct_arr[0] AS q1,
  pct_arr[1] AS q3,
  pct_arr[1] - pct_arr[0] AS iqr
FROM dept_stats;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '[0] AS q1,
  pct_arr[1] AS q3,
  pct_arr[1] - pct_arr[0] AS iqr
FROM dept_stats' at line 10
SELECT 
  deptno,
  ROUND(PERCENTILE_CONT(sal, 0.5)) AS median_sal_rounded,
  FLOOR(PERCENTILE_CONT(sal, 0.8)) AS p80_floor
FROM emp 
GROUP BY deptno;
+--------+--------------------+-----------+
| deptno | median_sal_rounded | p80_floor |
+--------+--------------------+-----------+
|     10 |               2450 |      5000 |
|     20 |               2975 |      3000 |
|     30 |               1375 |      1600 |
+--------+--------------------+-----------+
SELECT 
  deptno,
  PERCENTILE_CONT(sal, SIN(0.5) + 0.5) AS dynamic_p -- SIN(0.5)≈0.479
FROM emp 
GROUP BY deptno;
+--------+-------------------+
| deptno | dynamic_p         |
+--------+-------------------+
|     10 |              5000 |
|     20 |              3000 |
|     30 | 2721.409616276269 |
+--------+-------------------+
SELECT 
  deptno,
  CONCAT('Median:', CAST(PERCENTILE_CONT(sal, 0.5) AS DOUBLE)) AS sal_desc 
FROM emp 
GROUP BY deptno;
+--------+-------------+
| deptno | sal_desc    |
+--------+-------------+
|     10 | Median:2450 |
|     20 | Median:2975 |
|     30 | Median:1375 |
+--------+-------------+
SELECT 
  CONCAT(
    '{ "dept": ', deptno, 
    ', "p80": ', PERCENTILE_CONT(sal, 0.8), 
    ' }'
  ) AS json_result 
FROM emp 
GROUP BY deptno;
+-----------------------------+
| json_result                 |
+-----------------------------+
| { "dept": 10, "p80": 5000 } |
| { "dept": 20, "p80": 3000 } |
| { "dept": 30, "p80": 1600 } |
+-----------------------------+
SELECT 
  deptno,
  CASE 
    WHEN COUNT(*) > 5 THEN PERCENTILE_CONT(sal, 0.9)
    ELSE PERCENTILE_CONT(sal, 0.5)
  END AS adaptive_pct
FROM emp 
GROUP BY deptno;
+--------+--------------+
| deptno | adaptive_pct |
+--------+--------------+
|     10 |         5000 |
|     20 |         2975 |
|     30 |         2225 |
+--------+--------------+
SELECT 
  job,
  PERCENTILE_CONT(
    CASE WHEN sal > 2000 THEN sal ELSE NULL END, 
    0.5
  ) AS high_earners_median 
FROM emp 
GROUP BY job;
+-----------+---------------------+
| job       | high_earners_median |
+-----------+---------------------+
| ANALYST   |                3000 |
| CLERK     |                3725 |
| MANAGER   |                2850 |
| PRESIDENT |                5000 |
| SALESMAN  |                NULL |
+-----------+---------------------+
