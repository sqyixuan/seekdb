| TO_CHAR(DATE '2020-02-29', 'IYYY-IW') |
+---------------------------------------+
| 2020-09                               |
+---------------------------------------+
SELECT TO_CHAR(DATE '2023-01-01', 'WW') AS WW FROM DUAL;
+------+
| WW   |
+------+
| 01   |
+------+
SELECT 
  TO_CHAR(DATE '2012-12-31', 'WW') AS WW, 
  TO_CHAR(DATE '2012-12-31', 'IW') AS IW   
FROM DUAL;
+------+------+
| WW   | IW   |
+------+------+
| 53   | 01   |
+------+------+
