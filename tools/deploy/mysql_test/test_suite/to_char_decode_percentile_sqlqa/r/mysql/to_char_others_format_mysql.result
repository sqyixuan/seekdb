### create table format_test3(c1 number,c2 binary_float,c3 binary_double,c4 char(100),c5 nchar(100),c6 varchar2(100),c7 nvarchar2(100),c8 blob,c9 clob,c10 date);
CREATE TABLE format_test3 (
    c1 INT,             
    c2 FLOAT,           
    c3 DOUBLE,          
    c4 CHAR(100),       
    c5 VARCHAR(100),    
    c6 VARCHAR(100),    
    c7 VARCHAR(100),    
    c8 BLOB,            
    c9 TEXT,            
    c10 DATETIME        
);
