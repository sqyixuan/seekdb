purge recyclebin;
#Environmental cleaning
result_format: 4
###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
###root用户
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf8mb4;
use db1;
SET sql_mode ='PIPES_AS_CONCAT';
##################################数据类型-表 1-5##################################
drop table if exists format_test1;
### create table format_test1(c1 number,c2 binary_float,c3 binary_double,c4 char(100),c5 nchar(100),c6 varchar2(100),c7 nvarchar2(100),c8 blob,c9 clob,c10 date);
### insert into format_test1 values(29989329,1234.34,1234.34,'100.00','23.12','100.2356','1234','12','1234',to_date('2004-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss'));
### insert into format_test1 values(29989330,100.2356,100.2356,'100.00','23.12','100.2356','1234','123','12345',to_date('2021-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss'));
CREATE TABLE format_test1 (
    c1 INT,
    c2 FLOAT,
    c3 DOUBLE,
    c4 CHAR(100),
    c5 NCHAR(100),     
    c6 VARCHAR(100),
    c7 VARCHAR(100),  
    c8 BLOB,
    c9 TEXT,         
    c10 DATETIME
);
INSERT INTO format_test1 (c1, c2, c3, c4, c5, c6, c7, c8, c9, c10) VALUES
(29989329, 1234.34, 1234.34, '100.00', '23.12', '100.2356', '1234', NULL, '1234', '2004-05-07 13:23:44'),
(29989330, 100.2356, 100.2356, '100.00', '23.12', '100.2356', '1234', NULL, '12345', '2021-05-07 13:23:44');
