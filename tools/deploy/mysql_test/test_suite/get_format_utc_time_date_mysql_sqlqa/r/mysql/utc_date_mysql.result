CREATE PROCEDURE pro_test01(in a int)
begin
declare i int;
declare b int;
set i=a-19800320;
select a into b;
repeat
if a = utc_date()+0 then
insert into t1 values(a,a,a),(b,b,b);
elseif a> utc_date()-0  then 
insert into t1(t) values(a);
else 
insert into t1(v_id,v_name) values(a,b);
end if;
set i = i + 1;
until   i <=utc_date()-19800316
end repeat;
end;
