drop function  fn_test1;
create function fn_test1(aa  int ) returns int
begin
declare bb int ;
declare cc int;
declare dd int;
set @i=1;
if aa=utc_date() then
select aa into cc;
return(cc);
elseif aa>utc_date()+2 then
select aa into dd;
return(dd);
else
while @i <= utc_date()-20200908 DO
insert into t1 values(aa,aa);
update t1 set v_id=aa;
set @i=@i+(utc_date()-20200912);
end while;
select aa into bb;
return(bb);
end if;
end;
