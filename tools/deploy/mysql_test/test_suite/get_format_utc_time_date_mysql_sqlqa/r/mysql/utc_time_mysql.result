drop table t1;
create table t1(v_id int,v_a varchar(30),t time);
drop function  fn_test1;
create function fn_test1(aa int ) returns int
begin
declare bb int ;
declare cc int;
declare dd int;
set @i=1;
if aa=utc_time()+0  then
select aa into cc;
return(cc);
elseif aa>utc_time()+2 then
select aa into dd;
return(dd);
else
while @i <= utc_time()-25696 DO
insert into t1 values(aa,aa,aa);
update t1 set v_id=aa;
set @i=@i+(utc_time()-25700);
end while;
select aa into bb;
return(bb);
end if;
end;
//
select fn_test1(utc_time());
fn_test1(utc_time())
25701
select fn_test1(utc_time()+6);
fn_test1(utc_time()+6)
25707
select fn_test1(utc_time()-1);
fn_test1(utc_time()-1)
25700
drop function  fn_test1;
