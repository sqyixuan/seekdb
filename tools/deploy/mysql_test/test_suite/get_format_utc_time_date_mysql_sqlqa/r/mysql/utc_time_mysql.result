obmysql-utc_time-4-3 pl块
set timestamp =322455421.5895;
drop table t1;
create table t1(v_id int,v_name varchar(30),v_t time);
DROP PROCEDURE pro_test01;
CREATE PROCEDURE pro_test01(in a int)
begin
declare i int;
declare b int;
set i=a-25700;
select a into b;
while i <=utc_time()-25696  DO
if a = utc_time()+0 then
insert into t1 values(a,a,a),(b,b,b);
elseif a> utc_time()-0  then 
insert into t1(v_t) values(a);
else 
insert into t1(v_id,v_name) values(a,b);
end if;
set i = i + 1;
end WHILE;
end;
//
# 执行存储过程，if和white ob都判断错误，mysql正确
drop table t1;
create table t1(v_name varchar(30),t time);
DROP PROCEDURE pro_test01_1;
CREATE PROCEDURE pro_test01_1(in a varchar(20),out b varchar(20))
begin
select a into b;
if a>utc_time() then
insert into t1(v_name) values(b);
elseif a=utc_time(6) then
insert into t1 values(utc_time() ,a);
else 
insert into t1(t) values(a);
end if;
end;
//
CALL pro_test01_1('02:57:02',@c);
select @c;
@c
02:57:02
CALL pro_test01_1(utc_time(6),@c);
CALL pro_test01_1(utc_time()-1,@c);
CALL pro_test01_1(25699,@c);
