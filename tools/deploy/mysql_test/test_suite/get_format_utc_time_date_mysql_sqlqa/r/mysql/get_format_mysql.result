ERROR 22007: Incorrect datetime value for column 't' at row 1
DROP PROCEDURE pro_test02;
CREATE  PROCEDURE pro_test02(in a varchar(30) ,out b varchar(30))
begin
declare d varchar(30);
set d=a;
select d into b;
end;
//
CALL pro_test02(get_format(date,'jis'),@bb);
select @bb;
@bb
%Y-%m-%d
CALL pro_test02(get_format(datetime,'internal'),@cc);
select @cc;
@cc
%Y%m%d%H%i%s
CALL pro_test02(get_format(time,'usa'),@dd);
select @dd;
@dd
%h:%i:%s %p
drop table t1;
create table t1(id int,name varchar(30),d date,t time, dt datetime);
drop function  fn_test1;
create function fn_test1(aa  varchar(30) ) returns varchar(30)
begin
declare bb varchar(30) ;
declare cc varchar(30);
declare dd varchar(30);
set @i=1;
if aa =get_format(date,'jis') then
select aa into cc;
return(cc);
elseif aa=get_format(datetime,'eur') then
select aa into dd;
return(dd);
else
while @i <= 5 DO
insert into t1 values(@i, aa,str_to_date('2020-12-12 14:15:00',aa),str_to_date('2020-12-12 14:15:00',aa),str_to_date('2020-12-12 14:15:00',aa));
insert into t1 values(@i+1, aa,FROM_UNIXTIME(1600000000,aa),FROM_UNIXTIME(17000000000,aa),FROM_UNIXTIME(18000000000,aa));
set @i=@i+1;
end while;
select aa into bb;
return(bb);
end if;
end;
//
select fn_test1(get_format(date,'jis'));
fn_test1(get_format(date,'jis'))
%Y-%m-%d
select fn_test1(get_format(datetime,'eur'));
fn_test1(get_format(datetime,'eur'))
%Y-%m-%d %H.%i.%s
select fn_test1(get_format(time,'jis'));
