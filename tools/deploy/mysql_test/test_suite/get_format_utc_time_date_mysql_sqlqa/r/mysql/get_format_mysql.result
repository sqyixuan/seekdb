obmysql-get_format-4-1-3
drop table t1;
create table t1 (id int ,name varchar(20));
insert into t1 values(1,'test01');
insert into t1 values(2,'test02');
insert into t1 values(3,'test03');
insert into t1 values(4,'test04');
update t1 set name= get_format(date,'eur') where name='test01';
update t1 set name= get_format(datetime,'jis') where name='test02';
update t1 set name= get_format(time,'usa') where name='test03';
select * from t1;
id	name
1	%d.%m.%Y
2	%Y-%m-%d %H:%i:%s
3	%h:%i:%s %p
4	test04
update t1 set name=get_format(datetime,'iso')  where name in ('test01','test02');
update t1 set name= get_format(time,'internal') where id>2;
update t1 set name= get_format(date,'jis')  where id <3;
update t1 set name= get_format(date,'internal')  where id<=3;
update t1 set name= get_format(time,'iso') where id between 1 and 2 ;
update t1 set name= get_format(datetime,'eur') where id = 1  or name='test03' ;
update t1 set name= get_format(datetime,'eur') where name like '%y%' ;
update t1 set name= get_format(time,'jis') where name not like 'test%' ;
update t1 set name=get_format(datetime,'eur') >get_format(datetime,'eur') ;
update t1 set name= get_format(date,'internal') or get_format(date,'jis');
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: '%Y%m%d'
Warning	1292	Truncated incorrect DOUBLE value: '%Y-%m-%d'
update t1 set name= get_format(date,'internal') and get_format(date,'jis');
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: '%Y%m%d'
update t1 set name= get_format(date,'internal') | get_format(date,'jis');
Warnings:
Warning	1292	Truncated incorrect INTEGER value: '%Y%m%d'
Warning	1292	Truncated incorrect INTEGER value: '%Y-%m-%d'
