--error 0,1305
DROP PROCEDURE pro_test01;
DELIMITER //;
CREATE PROCEDURE pro_test01(in a int)
begin
    declare i int;
    declare b int;
    set i=a-25700;
    select a into b;
    while i <=utc_time()-25696  DO
         if a = utc_time()+0 then
              insert into t1 values(a,a,a),(b,b,b);
         elseif a> utc_time()-0  then 
              insert into t1(v_t) values(a);
         else 
              insert into t1(v_id,v_name) values(a,b);
         end if;
         set i = i + 1;
      end WHILE;
end;
//
DELIMITER ;//
