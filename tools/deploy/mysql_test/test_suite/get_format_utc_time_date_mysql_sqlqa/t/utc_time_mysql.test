DROP PROCEDURE pro_test01_1;
DELIMITER //;
CREATE PROCEDURE pro_test01_1(in a varchar(20),out b varchar(20))
begin
select a into b;
if a>utc_time() then
insert into t1(v_name) values(b);
elseif a=utc_time(6) then
insert into t1 values(utc_time() ,a);
else 
insert into t1(t) values(a);
end if;
end;
//
DELIMITER ;//
