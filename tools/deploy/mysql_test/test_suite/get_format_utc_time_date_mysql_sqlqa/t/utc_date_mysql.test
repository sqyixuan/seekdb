drop table t1;
create table t1 (id int ,name varchar(20),d date);
insert into t1 values(1,'test01','20200811');
insert into t1 values(2,'test02','20200915');
insert into t1 values(3,'test03','2020-08-20');
insert into t1 values(4,'test04','2020-09-15');
insert into t1 values(5,'test05','2020-09-13');
select utc_date() as a,utc_date()+1 from t1;
create table t2 as select utc_date(),utc_date()+1 from t1;
select * from t2;
--error 0,1051
drop table t2;
select DATEDIFF(utc_date()-1,utc_date()) from t1;
select MOD(utc_date()+5,utc_date()) from t1;
select time(utc_date()),COALESCE(utc_date()) from t1;
SELECT INSTR(utc_date(),utc_date()+0) from t1;
select LENGTH(utc_date()+1),LENGTH(utc_date()) from t1;
SELECT LOCATE(2,utc_date()+0,utc_date()-20200911) from t1;
select MD5(utc_date()),MD5(utc_date()+1) from t1;

select t1.*,utc_date()+0, utc_date() from t1 where utc_date()>d;
select t1.*,utc_date()-0, utc_date() from t1 where utc_date()>=d;
select t1.*,utc_date()-0, utc_date()  from t1 where utc_date()<=d;
