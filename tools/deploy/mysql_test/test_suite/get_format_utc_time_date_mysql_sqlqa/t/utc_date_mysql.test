select t1.*,utc_date()+0, utc_date()  from t1 where utc_date()+2<=d;
select t1.*,utc_date()-0, utc_date()  from t1 where utc_date()-3=d;
select t1.*,utc_date()+0, utc_date()  from t1 where utc_date()-0<d;
select t1.*,utc_date()+0, utc_date()  from t1 where d<utc_date()-0;
select t1.*,utc_date()-0, utc_date()  from t1 where d=utc_date() or utc_date()+1>=d;
select t1.*,utc_date()+0 as a, utc_date()  from t1 where d=utc_date() and utc_date()-1<=d;
