DROP PROCEDURE pro_test01;
DELIMITER //;
CREATE PROCEDURE pro_test01(in a varchar(30))
begin
declare i int;
set i=1;
while i <=5  DO
if a in (get_format(date,'eur'),get_format(date,'jis'),get_format(date,'internal'),get_format(date,'usa'),get_format(date,'iso')) then
insert into t1 values(i,a,DATE_FORMAT('2012-10-10',a),null,null);
elseif a in (get_format(datetime,'eur'),get_format(datetime,'jis'),get_format(datetime,'internal'),get_format(datetime,'usa'),get_format(datetime,'iso')) then
insert into t1 values(i,a,null,null,DATE_FORMAT('2012-10-10 15:12:40',a));
else 
insert into t1 values(i,a,null,DATE_FORMAT('15:12:40',a),null);
end if;
set i = i + 1;
end WHILE;
end;
//
DELIMITER ;//
CALL pro_test01(get_format(date,'eur'));
select * from t1;
CALL pro_test01(get_format(datetime,'jis'));
select * from t1;
--error 1292
CALL pro_test01(get_format(time,'iso'));


