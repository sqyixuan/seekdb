drop function  fn_test1;
DELIMITER //;
create function fn_test1(aa  varchar(30) ) returns varchar(30)
begin
   declare bb varchar(30) ;
   declare cc varchar(30);
   declare dd varchar(30);
   set @i=1;
   if aa =get_format(date,'jis') then
      select aa into cc;
      return(cc);
   elseif aa=get_format(datetime,'eur') then
      select aa into dd;
      return(dd);
   else
      while @i <= 5 DO
             insert into t1 values(@i, aa,str_to_date('2020-12-12 14:15:00',aa),str_to_date('2020-12-12 14:15:00',aa),str_to_date('2020-12-12 14:15:00',aa));
             insert into t1 values(@i+1, aa,FROM_UNIXTIME(1600000000,aa),FROM_UNIXTIME(17000000000,aa),FROM_UNIXTIME(18000000000,aa));
            set @i=@i+1;
     end while;
     select aa into bb;
     return(bb);
  end if;
end;
//
DELIMITER ;//
