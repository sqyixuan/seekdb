select v1.* ,GET_FORMAT(DATETIME,'eur') as a,GET_FORMAT(DATE,'iso') as b, GET_FORMAT(time,'internal') as c from v1 where GET_FORMAT(DATE,'internal')<>name;
select v1.* ,GET_FORMAT(DATETIME,'eur') as a,GET_FORMAT(DATE,'iso') as b, GET_FORMAT(time,'internal') as c from v1 where name =GET_FORMAT(DATE,'internal') or GET_FORMAT(DATETIME,'eur')=name;
select v1.* ,GET_FORMAT(DATETIME,'eur') as a,GET_FORMAT(DATE,'iso') as b, GET_FORMAT(time,'internal') as c from v1 where name >GET_FORMAT(DATE,'internal') and GET_FORMAT(DATETIME,'eur')<name;
select v1.*,GET_FORMAT(DATETIME,'iso') from v1 where name between  GET_FORMAT(DATE,'eur') and GET_FORMAT(DATE,'USA');
select v1.*,GET_FORMAT(DATETIME,'iso') from v1 where name like GET_FORMAT(date,'eur');
select v1.*,GET_FORMAT(DATETIME,'iso') from v1 where name not like GET_FORMAT(date,'eur');
select GET_FORMAT(DATE,'jis'),GET_FORMAT(time,'USA'),v1.* from v1 where exists (select GET_FORMAT(time,'jis'));
select GET_FORMAT(DATE,'jis'),GET_FORMAT(time,'USA'),v1.* from v1 where name <any (select GET_FORMAT(time,'jis'));
select GET_FORMAT(DATE,'jis'),GET_FORMAT(time,'USA'),v1.* from v1 where name >all (select GET_FORMAT(time,'jis'));
