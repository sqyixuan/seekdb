select v1.* ,GET_FORMAT(DATETIME,'eur') as a,GET_FORMAT(DATE,'iso') as b, GET_FORMAT(time,'internal') as c from v1 where name <=GET_FORMAT(time,'jis');
select v1.* ,GET_FORMAT(DATETIME,'eur') as a,GET_FORMAT(DATE,'iso') as b, GET_FORMAT(time,'internal') as c from v1 where name >=GET_FORMAT(time,'internal');
