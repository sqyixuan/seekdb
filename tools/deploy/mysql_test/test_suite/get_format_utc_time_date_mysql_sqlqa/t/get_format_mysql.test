select get_format(date,'eur')^get_format(dateTIME,'iso');
select get_format(time,'eur')>>get_format(TIME,'iso');
select get_format(time,'eur')<<get_format(date,'jis');
select get_format(time,'eur')||get_format(date,'jis')||get_format(dateTIME,'iso')||get_format(TIME,'INTERNAL')||get_format(dateTIME,'USA');
