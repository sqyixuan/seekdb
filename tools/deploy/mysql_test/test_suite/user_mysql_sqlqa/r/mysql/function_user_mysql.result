#user-5   索引
use ceshi;
drop table b;
CREATE TABLE b(f1 int(10),f2 int(10));
SELECT * from b;
f1	f2
CREATE INDEX b ON b(f1);
SELECT * from b;
f1	f2
INSERT INTO b VALUES(69,698);
SELECT * FROM b;
f1	f2
69	698
UPDATE b SET f1=77 where f1=69;
SELECT * FROM b;
f1	f2
77	698
SELECT f1,f2 FROM b;
f1	f2
77	698
DELETE FROM b WHERE f1=77;
SELECT * FROM b;
f1	f2
drop table b;
#user-6 约束
use ceshi;
drop table hz;
create table hz(id int(10),name varchar(10),fenshu int(10),banji int(10),xuexiao varchar(10));
insert into hz(id,name,fenshu,banji,xuexiao)value(1,"zhansan",5899,6224,"ligong"),(2,"xiaoli",1000,6223,"henankeji"),(3,"xiaoai",99,6223,"nongye"),(4,"xiaocao",100,6224,"zheda");
#非空
alter table hz modify id int not null;
alter table hz modify id int null;
#主键
alter table hz add primary key (id);
#唯一、自增长
alter table hz add unique yueshu(id);
alter table hz modify id int auto_increment;
alter table hz modify id int;
alter table hz drop key yueshu;
drop table hz;
#外键
use ceshi;
drop table beijing;
drop table shanghai;
create table beijing(
dept_name varchar(20),
budget int,
descript varchar(20),
primary key(dept_name)
);
create table shanghai(
shanghai_id varchar(20),
deptnames varchar(20),
credits int,
foreign key(deptnames) references beijing(dept_name));
drop table shanghai;
drop table beijing;
