desc 表1;
Field	Type	Null	Key	Default	Extra
id	int(10)	YES		NULL	
shuzi	bigint(20)	YES		NULL	
xingbie	varchar(20)	YES		NULL	
riqi	date	YES		NULL	
shijian	time	YES		NULL	
juti	datetime	YES		NULL	
