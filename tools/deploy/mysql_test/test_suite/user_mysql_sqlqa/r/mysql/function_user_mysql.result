3	xiaoai	99	6223	nongye
4	xiaocao	100	6224	zheda
create table f2(id int(10),name varchar(10),fenshu int(10),banji int(10),xuexiao varchar(30));
insert into f2(id,name,fenshu,banji,xuexiao)value(1,"xiaobei",99,6224,"qinghua"),(2,"xiaoqing",100,6223,"beida"),(3,"xiaozhu",99,6223,"zhongkeyuan"),(4,"xiaowang",100,6224,"shekeyuan");
SELECT * from f2;
