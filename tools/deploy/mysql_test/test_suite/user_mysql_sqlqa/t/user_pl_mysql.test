--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);

#存储过程 while、游标    

#insert into 
#show databases;
--error 0,1007
create database ceshi;
use ceshi;
#show tables;
--error 0,1051
DROP table test1;
create table test1(
	id int(5),
	name varchar(20)
);
#select * from test1;
drop procedure if exists test_process;
delimiter //;
create procedure test_process()
begin
        declare i int default 1;
        while i<10
        do
                insert into test1 values(i,concat('user',i));
                set i=i+1;
        end while;
        commit;
end //
delimiter ;//
#select * from test1;
#call test_process();
#select * from test1;
drop PROCEDURE test_process;
drop table test1;

#update
#show databases;
--error 0,1007
create database ceshi;
use ceshi;
#show tables;
--error 0,1051
DROP table hz;
create table test1(
	id int(5),
	name varchar(20)
);
insert into test1 value(1,"zhangsan");
insert into test1 value(2,"haha");
select * from test1;
drop procedure if exists test_process;
delimiter //;
create procedure test_process()
begin
        declare i int default 1;
        while i<10
        do
                insert into test1 values(i,concat('zhangsan',i));
                set i=i+1;
        end while;
        commit;
end //
delimiter ;//
#select * from test1;
#call test_process();
#select * from test1;
drop PROCEDURE test_process;
delimiter //;
create procedure test_process()
begin
        declare i int default 1;
        while i<3
        do
                UPDATE test1 SET name =case 'null' WHEN 4 THEN "USER4" WHEN 5 THEN "user5" WHEN 6 THEN "user6" END WHERE id IN (4,5,6);
                set i=i+1;
        end while;
        commit;
end //
delimiter ;//
#select * from test1;
#select * from test1;
drop PROCEDURE test_process;
drop table test1;




#select
#show databases;
--error 0,1007
create database ceshi;
use ceshi;
#show tables;
--error 0,1051
DROP table hz;
create table test1(
	id int(5),
	name varchar(20),
	fenshu int(20)
);
insert into test1 value(
	1,"zhangsan",98
);
insert into test1 value(
2,"haha",88
);
#select * from test1;
drop procedure if exists test_process;
delimiter //;
create procedure test_process()
begin
        declare i int default 1;
                SELECT * from test1 where name="haha";
                SELECT fenshu from test1 where name="haha";
                SELECT sum(fenshu) from test1;
        commit;
end //
delimiter ;//
#select * from test1;
#call test_process();
#select * from test1;
drop PROCEDURE test_process;
drop table test1;

#游标
--error 0,1051
DROP TABLE test2;
CREATE TABLE test2(
	f1 int(10),
	f2 varchar(20)
);
INSERT INTO test2 VALUE(0,"wangwu");
INSERT INTO test2 VALUE(1,"xiaoli");
INSERT INTO test2 VALUE(2,"xiaocao");
INSERT INTO test2 VALUE(NULL,NULL);
--error 0,1305
DROP PROCEDURE test2_pro;
delimiter //;
create procedure test2_pro()
begin
	DECLARE v1 int(10);
	DECLARE v2 varchar(20);
	DECLARE done INT DEFAULT 0;
	DECLARE youbiao CURSOR FOR SELECT avg(f2),f1 from test2 GROUP by f1;
	DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
	OPEN youbiao;
	FETCH youbiao INTO v1,v2;
	WHILE done<>1 DO
		INSERT INTO test2 VALUES(1,"zhangsan");
		FETCH youbiao INTO v1,v2;
	END WHILE;
	CLOSE youbiao;
END;
//
delimiter ;//
#SELECT* from test2;
CALL test2_pro();
#SELECT * FROM test2;
drop PROCEDURE test2_pro;
drop table test2;

