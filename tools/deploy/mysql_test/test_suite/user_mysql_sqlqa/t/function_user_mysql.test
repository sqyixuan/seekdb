--echo #user-4-2  视图的修改
use ceshi;
#show TABLES;
--error 0,1051
DROP TABLE hz;
--error 0,1051
drop view shitu;
create table hz(id int(10),user_name varchar(20),fenshu int(20),banji int(6));
insert into hz value(1,"xiaobai",99,6221);
insert into hz value(2,"xiaowang",98,6223);
insert into hz value(3,"dabai",100,6221);
insert into hz value(4,"xiaoliu",100,6223);
SELECT * from hz order by fenshu desc;
CREATE VIEW shitu as SELECT * FROM hz;
SELECT * from shitu order by fenshu desc;
UPDATE shitu SET user_name="xiaoliu" WHERE user_name="dabai"; 
SELECT * from shitu order by fenshu desc;
SELECT * from shitu where user_name="xiaoliu";
DELETE FROM shitu WHERE 1=1;
drop view shitu;
DROP TABLE hz;

--echo  #user-5   索引
