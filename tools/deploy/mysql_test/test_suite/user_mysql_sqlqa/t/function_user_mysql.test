--echo #比较运算
--error 0,1007
create database ceshi;
#show databases;
use ceshi;
#show TABLES;
--error 0,1051
DROP table hz;
create table hz(id int(10),user_name varchar(20),fenshu int(20),banji int(6));
insert into hz value(1,"xiaobai",99,6221),(2,"xiaowang",98,6223),(3,"dabai",100,6221),(4,"xiaoliu",100,6223);
insert into hz value(5,"xiaoai",79,6221),(6,"xiaobai",78,6223),(7,"dabai",20,6221),(8,"xiaogou",60,6223);
select * from hz;
SELECT sum(fenshu) from hz;
SELECT * FROM hz WHERE fenshu=98>(SELECT fenshu FROM hz WHERE id=5);
SELECT fenshu FROM hz WHERE fenshu=79>=(SELECT fenshu FROM hz WHERE id=5);
SELECT fenshu FROM hz where user_name="xiaogou"<(SELECT fenshu FROM hz where user_name="xiaowang");
SELECT fenshu FROM hz WHERE fenshu=79<=(SELECT fenshu FROM hz WHERE id=5);
SELECT fenshu FROM hz WHERE user_name="xiaoliu"<=(SELECT fenshu FROM hz WHERE id=3);
SELECT fenshu FROM hz WHERE id=5 !=(SELECT fenshu FROM hz WHERE id=6);
DROP table hz;










