INSERT INTO T3 SELECT C2,C2 FROM T2;
INSERT INTO T3 SELECT C3,C3 FROM T2;
INSERT INTO T3 SELECT C4,C4 FROM T2;

SELECT * FROM T3;

##BIT##
DROP TABLE IF EXISTS T2;
CREATE TABLE T2(C1 BIT);
INSERT INTO T2(C1) SELECT C1 FROM T1 WHERE C1 BETWEEN 0 AND 1;

SELECT * FROM T2;
SELECT CAST(C1 AS DECIMAL),CAST(C1 AS DECIMAL(65,0)) FROM T2;

DELETE FROM T3;
INSERT INTO T3 SELECT C1,C1 FROM T2;

SELECT * FROM T3;

