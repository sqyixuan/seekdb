##窗口函数##

##APPROX_COUNT_DISTINCT(expr) OVER over_clause##
SELECT APPROX_COUNT_DISTINCT(C1) OVER (PARTITION BY C2 ORDER BY C3 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) COL FROM T1;

##AVG([ DISTINCT | ALL ] expr) OVER(analytic_clause) ##
SELECT AVG(C1) OVER (PARTITION BY C2 ORDER BY C3 RANGE BETWEEN 2 PRECEDING AND 2 FOLLOWING) COL FROM T1;

##BIT_AND(expr) OVER (analytic_clause)##
SELECT BIT_AND(C1) OVER (PARTITION BY C2 ORDER BY C3 RANGE BETWEEN 2 PRECEDING AND 2 FOLLOWING) COL FROM T1;

##BIT_OR(expr) OVER (analytic_clause)##
SELECT BIT_OR(C1) OVER (PARTITION BY C2 ORDER BY C3 ROWS BETWEEN 2 PRECEDING AND 2 FOLLOWING) COL FROM T1;

##BIT_XOR(expr) OVER (analytic_clause)##
SELECT BIT_XOR(C1) OVER (PARTITION BY C2 ORDER BY C3 ROWS BETWEEN 2 PRECEDING AND 2 FOLLOWING) COL FROM T1;

##COUNT({ * | [ DISTINCT | ALL ] expr }) OVER (analytic_clause)##
SELECT COUNT(C1) OVER (PARTITION BY C2 ORDER BY C3 ROWS BETWEEN 2 PRECEDING AND 2 FOLLOWING) COL FROM T1;

##CUME_DIST() OVER ([ query_partition_clause ] order_by_clause)##
SELECT CUME_DIST() OVER (PARTITION BY C2 ORDER BY C3 ROWS BETWEEN 2 PRECEDING AND 2 FOLLOWING) COL FROM T1;

##DENSE_RANK() OVER([ query_partition_clause ] order_by_clause)##
SELECT DENSE_RANK() OVER (PARTITION BY C2 ORDER BY C3 ROWS BETWEEN 2 PRECEDING AND 2 FOLLOWING) COL FROM T1;

##FIRST_VALUE/LAST_VALUE { (expr) [ {RESPECT | IGNORE} NULLS ] | (expr [ {RESPECT | IGNORE} NULLS ])} OVER (analytic_clause)##
SELECT FIRST_VALUE(C1) RESPECT NULLS OVER (PARTITION BY C2 ORDER BY C3 ROWS BETWEEN 2 PRECEDING AND 2 FOLLOWING) COL FROM T1;

SELECT LAST_VALUE(C1) IGNORE NULLS OVER (PARTITION BY C2 ORDER BY C3 ROWS BETWEEN 2 PRECEDING AND 2 FOLLOWING) COL FROM T1;

##LAG( value_expr [, offset [, default]]) [ { RESPECT | IGNORE } NULLS ] OVER ()##
