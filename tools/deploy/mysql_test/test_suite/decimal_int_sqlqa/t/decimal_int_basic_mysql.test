##运算##
SELECT C1+C2+C3+C4+C5+C6+C7 FROM T1;
SELECT C1-C2-C3-C4-C5-C6-C7 FROM T1;
SELECT C1*C2*C3*C4*C5*C6*C7 FROM T1;
SELECT C1/C2/C3/C4/C5/C6/C7 FROM T1;
##decimal分支首次执行这条sql很慢##
SELECT C1%C2%C3%C4%C5%C6%C7 FROM T1 WHERE C1 != 0;
SELECT C1 DIV C2 DIV C3 DIV C4 DIV C5 DIV C6 DIV C7 FROM T1;
SELECT C1 MOD C2 MOD C3 MOD C4 MOD C5 MOD C6 MOD C7 FROM T1;

SELECT C1&C2|C3^C5<<C6>>C7 FROM T1;
SELECT +C3 ^ C2 % +C5 * +C7 FROM T1;
SELECT +C7 - C1 - +C1 << C1 FROM T1;
SELECT -C2 MOD C3 / -C3 + -C6 FROM T1;

##BINARY##
SELECT BINARY C1,BINARY C2,BINARY C3,BINARY C4,BINARY C5,BINARY C6,BINARY C7 FROM T1;

##CASE WHEN##
SELECT CASE WHEN C1 > C2 THEN 1 END FROM T1;
