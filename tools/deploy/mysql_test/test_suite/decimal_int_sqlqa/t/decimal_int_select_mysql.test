##JOIN##
CREATE TABLE T2(C1 DECIMAL ,C2 DECIMAL(10,2),C3 DECIMAL(65),C4 DECIMAL(1,0),C5 DECIMAL ,C6 DECIMAL(10,2),C7 DECIMAL(65));

INSERT INTO T2 VALUES (1.2,1.2,1.2,1.2,1.2,1.2,1.2);

SELECT * FROM T1 A,T1 B WHERE A.C1 = B.C1;
SELECT * FROM T1 A INNER JOIN T1 B ON A.C1 = B.C1;
SELECT * FROM T1 A LEFT JOIN T1 B ON A.C1 = B.C1;
SELECT * FROM T1 A RIGHT JOIN T1 B ON A.C1 = B.C1;
SELECT * FROM T1 A CROSS JOIN T1 B ON A.C1 = B.C1;
SELECT * FROM T1 A FULL JOIN T1 B ON A.C1 = B.C1;
SELECT * FROM T1 A NATURAL JOIN T1 B;
SELECT * FROM T1 A NATURAL LEFT JOIN T1 B ;

SELECT * FROM T1 A INNER JOIN T1 B ON A.C1 > B.C1;
SELECT * FROM T1 A INNER JOIN T1 B USING(C1) WHERE C1 != 0;

SELECT * FROM T1 A,T2 B WHERE A.C2 = B.C2;
SELECT * FROM T1 A INNER JOIN T2 B ON A.C2 = B.C3;
SELECT * FROM T1 A LEFT JOIN T2 B ON A.C2 = B.C4;
SELECT * FROM T1 A RIGHT JOIN T2 B ON A.C2 = B.C1;
SELECT * FROM T1 A FULL JOIN T2 B ON A.C2 = B.C1;

SELECT * FROM T1 A INNER JOIN T2 B ON A.C2 = B.C3 AND A.C2 > 100;
SELECT * FROM T1 A LEFT JOIN T2 B ON A.C2 = B.C3 WHERE A.C2 > 100 AND B.C3 IS NOT NULL;
SELECT * FROM T1 A RIGHT JOIN T2 B ON A.C2 = B.C1 WHERE ABS(A.C2) NOT BETWEEN 999 AND ABS(B.C4) OR A.C3 LIKE '-';
SELECT * FROM T1 A FULL JOIN T2 B ON A.C2 = B.C1 OR A.C3 BETWEEN -1e-130 AND ROUND(B.C2) OR FLOOR(A.C3) < 1E+38;

