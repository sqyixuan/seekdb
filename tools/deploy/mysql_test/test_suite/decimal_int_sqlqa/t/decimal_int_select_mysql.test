##关联子查询##
SELECT * FROM T1 A WHERE C1 IN (SELECT C1 FROM T2 B WHERE A.C2 = B.C2);

SELECT * FROM T1 A WHERE C1 IN (SELECT A.C3 FROM T2 B WHERE A.C1 = B.C1);

SELECT * FROM T2 A WHERE C2 * C1 BETWEEN (SELECT MIN(C1) SUB_COL FROM T1 WHERE A.C4 IS NOT NULL) AND (SELECT SUM(C1) SUB_COL FROM T1 WHERE A.C4 LIKE '%.%' OR A.C4 BETWEEN C4 * C1 AND C4 - C4 OR A.C3 NOT LIKE '-');

SELECT * FROM T3 A WHERE CEIL(C4) BETWEEN (SELECT COUNT(C3) SUB_COL FROM T1 WHERE A.C1 NOT BETWEEN 0.829454 AND 124.000000000000000000000000000000000001) AND (SELECT MIN(C1) SUB_COL FROM T2 WHERE A.C2 BETWEEN C3 - C1 AND 0.829454);

SELECT * FROM T3 A WHERE ABS(C3) <> SOME (SELECT C1 SUB_COL FROM T3 WHERE A.C1 IN(999,-1000,-1.25,999) AND A.C3 NOT IN (NULL));

SELECT * FROM T1 A WHERE C1 < ALL (SELECT AVG(C2) SUB_COL FROM T3 WHERE A.C1 NOT LIKE '-' OR A.C3 NOT LIKE 1 AND A.C4 > C3 * C4);

SELECT * FROM T2 A WHERE C4 = (SELECT SUM(C3) SUB_COL FROM T3 WHERE A.C3 = 0.829454 AND A.C3 NOT IN (NULL) AND A.C2 BETWEEN (1+3) AND 2654646415131313);

SELECT * FROM T1 A WHERE NOT EXISTS (SELECT C2 SUB_COL FROM T2 WHERE A.C1 LIKE '%.%' OR A.C1 IN (NULL));

SELECT * FROM T1 A WHERE NOT EXISTS (SELECT C3 SUB_COL FROM T3 WHERE A.C1 NOT LIKE '-' OR A.C1 IS NULL);

SELECT * FROM T3 A WHERE C4 <= (SELECT COUNT(C4) SUB_COL FROM T2 WHERE A.C1 LIKE '-' AND A.C4 IN((1+3),3.2455,-2,-0.829454) AND A.C1 >= C4 + C4);

SELECT * FROM T1 A WHERE CEIL(C4) < (SELECT SUM(C1) SUB_COL FROM T1 WHERE A.C4 LIKE '%.%');

SELECT * FROM T1 A WHERE C3 <> SOME (SELECT  C3 SUB_COL FROM T2 WHERE A.C3 NOT BETWEEN LENGTH(C1) AND C4 - C2 OR A.C4 LIKE 829.454 AND A.C2 LIKE C1);


##with##
WITH W_T1 AS (SELECT C2 FROM T1) SELECT * FROM W_T1;

WITH W_T1 AS (SELECT C2 FROM T1 WHERE C2 = 0) SELECT * FROM W_T1 WHERE C2 = 0;

WITH W_T1(C1) AS (SELECT C2 SUB_COL FROM T1 WHERE C2 <= 2654646415131313 AND C1 LIKE '-') SELECT * FROM W_T1 WHERE LENGTH(C1) LIKE '-' OR C1 NOT LIKE '-';

WITH W_T1(C1) AS (SELECT C3 SUB_COL FROM T3 WHERE C3 IN(999,5,-1.25,-0.829454)) SELECT * FROM W_T1 WHERE MOD(C1,C1) LIKE '%.%' OR ROUND(C1) NOT BETWEEN ROUND(C1) AND -1000;

WITH W_T1(C1) AS (SELECT C4 SUB_COL FROM T3 WHERE C4 BETWEEN ABS(C1) AND FLOOR(C3) OR C4 NOT LIKE '-') SELECT * FROM W_T1 WHERE CEIL(C1) NOT LIKE '%.%' OR CEIL(C1) >= UPPER(C1);

WITH W_T1(C1) AS (SELECT SUM(C1) SUB_COL FROM T3 WHERE C3 NOT BETWEEN ROUND(C4) AND C4 - C4) SELECT * FROM W_T1 WHERE UPPER(C1) NOT BETWEEN FLOOR(C1) AND 1 AND ABS(C1) NOT IN(123.999999999999999999999999999999999999,3.2455,-2,1E+38);

WITH W_T1(C1) AS (SELECT C2 SUB_COL FROM T1 WHERE C2 NOT LIKE FLOOR(C4) OR C4 BETWEEN C1 - C1 AND -0.829454) SELECT * FROM W_T1 WHERE LOWER(C1) NOT LIKE MOD(C1,C1) AND TRIM(C1) NOT LIKE ABS(C1);


