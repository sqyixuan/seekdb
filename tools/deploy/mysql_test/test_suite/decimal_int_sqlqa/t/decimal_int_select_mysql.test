SELECT C6 FROM T1 GROUP BY C6,C2,C1 WITH ROLLUP HAVING C6 != 0 % -1e+125 AND MIN(DISTINCT C1) != C6 ORDER BY C6;
SELECT C3 FROM T1 GROUP BY C3,C1,C3 WITH ROLLUP HAVING C3 NOT IN (NULL) AND COUNT(C3) NOT BETWEEN C3 AND C3 ORDER BY C3;
SELECT C7 FROM T1 GROUP BY C7,C6,C2 WITH ROLLUP HAVING C7 <> (1+3) AND MAX(DISTINCT C6) BETWEEN C7 AND '-0.829454' ORDER BY C7 DESC;
SELECT C3 FROM T1 GROUP BY C3,C7,C7 WITH ROLLUP HAVING C3 BETWEEN 10 >> 999 AND '-0.829454' AND GROUP_CONCAT(C3) BETWEEN C3 % C3 AND C3 ORDER BY C3 ASC;
SELECT C3 FROM T1 GROUP BY C3,C1,C1 WITH ROLLUP HAVING C3 NOT BETWEEN -1e+125 + C3 AND C3 OR COUNT(C1) NOT BETWEEN C3 AND C3 << '' ORDER BY C3 DESC;
SELECT C5 FROM T1 GROUP BY C5,C3,C6 WITH ROLLUP HAVING C5 = 1E-130 AND GROUP_CONCAT(C7) <= C5 % C5 ORDER BY C5;
