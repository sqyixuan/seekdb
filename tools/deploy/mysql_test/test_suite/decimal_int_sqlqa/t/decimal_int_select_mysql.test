SELECT ALL C1,C2,C3,C4,C5,C6,C7 FROM T1 ;
SELECT DISTINCT C1,C2,C3,C4,C5,C6,C7 FROM T1 ;
SELECT UNIQUE C1,C2,C3,C4,C5,C6,C7 FROM T1 ;

##WHERE##
SELECT * FROM T1 WHERE C2 = 0.00;
SELECT * FROM T1 WHERE C2 = C3;
SELECT * FROM T1 WHERE C2 = '0.00';
SELECT * FROM T1 WHERE C2 = 0.00 AND C3 = 0.9 AND C4 = 0.9;
SELECT * FROM T1 WHERE C2 = 0.00 OR C3 = -0.9 AND C4 = 0.9;

SELECT * FROM T1 WHERE C2 > 0.00;
SELECT * FROM T1 WHERE C2 < 0.00;
SELECT * FROM T1 WHERE C2 >= 0.00;
SELECT * FROM T1 WHERE C2 <= 0.00;
SELECT * FROM T1 WHERE C2 != 0.00;
SELECT * FROM T1 WHERE C2 <> 0.00;

SELECT * FROM T1 WHERE C2 LIKE 0.00;
SELECT * FROM T1 WHERE C2 LIKE C3;
SELECT * FROM T1 WHERE C2 NOT LIKE 0.00;
SELECT * FROM T1 WHERE C2 NOT LIKE C3;
SELECT * FROM T1 WHERE C2 LIKE 0.00 OR C3 LIKE '';
SELECT * FROM T1 WHERE C2 LIKE 0.00 OR C3 LIKE '' AND C4 LIKE '-';

SELECT * FROM T1 WHERE C2 BETWEEN -0.009 AND 0.009;
SELECT * FROM T1 WHERE C2 NOT BETWEEN -0.009 AND 0.009;
SELECT * FROM T1 WHERE C2 BETWEEN C3 AND C4;

SELECT * FROM T1 WHERE C2 IS NULL;
SELECT * FROM T1 WHERE C2 IS NOT NULL;
SELECT * FROM T1 WHERE C2 IS NULL AND C3 IS NULL AND C4 IS NULL;
SELECT * FROM T1 WHERE C2 IS NOT NULL OR C3 IS NOT NULL OR C4 IS NOT NULL;

SELECT * FROM T1 WHERE C2 IN (0.00,0.009,-0.009);
SELECT * FROM T1 WHERE C2 NOT IN (0.00,0.009,-0.009);

##RQG##
SELECT C6 FROM T1 WHERE C3 BETWEEN 20 AND 1E-130 AND C3 LIKE '%.%';
SELECT C2 FROM T1 WHERE C7 NOT BETWEEN 000009 AND -1.25 << C3 OR C1 LIKE (-1.25);
SELECT C2 FROM T1 WHERE C2 BETWEEN 100000 AND -1e-130;
SELECT UNIQUE C3 FROM T1 WHERE C7 NOT LIKE '%.%' OR C7 NOT BETWEEN 2654646415131313 >> 2654646415131313 AND 1E+64 AND C7 NOT BETWEEN 0.829454 AND 5 * 01010;
SELECT UNIQUE C1 FROM T1 WHERE C1 LIKE (3.2455 & -2) OR C6 = -2 AND C3 NOT LIKE '%.%';

SELECT C7 FROM T1 WHERE C6 != '829.454' DIV C6;
SELECT C6 FROM T1 WHERE C6 LIKE '-' AND C2 LIKE '-';
SELECT C2 FROM T1 WHERE C1 NOT LIKE (-1e-130);
SELECT C2 FROM T1 WHERE C7 LIKE ('829' ^ -0.829454) AND C3 LIKE '%.%';
SELECT C2 FROM T1 WHERE C2 NOT LIKE (C2 + -1E+64);
SELECT MIN(DISTINCT C7) FROM T1 WHERE C2 NOT LIKE (C3 DIV C2);
SELECT ALL C1 FROM T1 WHERE C2 IS NOT TRUE AND C1 NOT BETWEEN 829.454 AND 2654646415131313 AND C3 NOT LIKE '';
SELECT BIT_AND(C2) FROM T1 WHERE C6 NOT LIKE '%.%' AND C6 NOT LIKE '-' AND C3 LIKE '-';
SELECT MIN(DISTINCT C7) FROM T1 WHERE C2 NOT LIKE '-';
SELECT MIN(C6) FROM T1 WHERE C1 BETWEEN C6 % C3 AND C1 >> C2;
SELECT C1 FROM T1 WHERE C6 LIKE (100000 DIV C2) AND C7 <= C6 & C6;
SELECT APPROX_COUNT_DISTINCT(C7) FROM T1 WHERE C7 NOT BETWEEN 100000 AND (1+3) & C3 AND C2 LIKE '-' AND C7 NOT LIKE '-';
SELECT MAX(DISTINCT C1) FROM T1 WHERE C3 NOT LIKE '-' OR C6 LIKE '' AND C1 LIKE '';
SELECT AVG(C6) FROM T1 WHERE C7 LIKE '%.%';
SELECT BIT_XOR(C6) FROM T1 WHERE C7 BETWEEN 1E+125 AND 999 OR C2 NOT LIKE (C1 + C3) OR C1 IS NOT NULL;
SELECT C3 FROM T1 WHERE C1 NOT BETWEEN C2 << '829' AND C2 % C2;
SELECT DISTINCT C2 FROM T1 WHERE C1 NOT LIKE (-0.829454 MOD C1) OR C1 NOT BETWEEN -1.25 >> C7 AND 0 AND C3 >= C2 % 100000;
SELECT MIN(C2) FROM T1 WHERE C7 BETWEEN '829.454' AND -2;
SELECT C3 FROM T1 WHERE C7 LIKE (C6 + C7) OR C6 NOT BETWEEN 829.454 AND 829.454;
SELECT DISTINCT C3 FROM T1 WHERE C3 LIKE '-' OR C3 LIKE '' AND C6 NOT LIKE ((1+3) ^ 20);
SELECT MAX(DISTINCT C2) FROM T1 WHERE C3 NOT LIKE (-1e+125) AND C7 LIKE '' AND C3 IS NOT NULL;
SELECT ALL C2 FROM T1 WHERE C6 NOT LIKE '%.%' OR C1 NOT LIKE '-' OR C2 BETWEEN 20 << C7 AND -2;
SELECT C7 FROM T1 WHERE C6 LIKE '%.%';
SELECT C7 FROM T1 WHERE C2 NOT LIKE '%.%';
SELECT C7 FROM T1 WHERE C7 LIKE '' OR C2 < -1E+64 % '829';

##函数嵌套##
--disable_warnings
SELECT ALL C3 FROM T1 WHERE COS(C7) BETWEEN '0.829454' AND -1e+125 OR C6 IS NOT NULL AND MOD(C7,C2) IS NOT FALSE;
SELECT C6 FROM T1 WHERE LOG(C1,C1) BETWEEN (1+3) AND 0 OR ABS(C2) NOT BETWEEN C1 * C7 AND 3.2455;
SELECT C1 FROM T1 WHERE CONV(C7,10,16) NOT LIKE '' AND ABS(C6) NOT BETWEEN '' + C7 AND '' - C7;
SELECT APPROX_COUNT_DISTINCT(C7) FROM T1 WHERE LOG(C6) NOT BETWEEN C1 * C2 AND C6 >> C2;
SELECT C6 FROM T1 WHERE LOG2(C3) IS NOT FALSE OR LOG(C3,C2) NOT LIKE '';
SELECT C7 FROM T1 WHERE ASIN(C7) BETWEEN 1E+125 AND 2654646415131313 % C3;
SELECT BIT_XOR(C2) FROM T1 WHERE MOD(C1,C1) NOT BETWEEN C1 DIV 0.829454 AND 20 ^ '829';
SELECT C6 FROM T1 WHERE CEILING(C2) NOT IN(-1000,-0.829454,(1+3),01010);
SELECT C6 FROM T1 WHERE TRUNCATE(C2,C1) NOT LIKE '%.%' AND FLOOR(C2) IS NOT FALSE;
SELECT COUNT(C2) FROM T1 WHERE CONV(C1,10,2) LIKE '-' AND DEGREES(C6) LIKE (829.454 MOD C7) OR C2 BETWEEN '0.829454' AND 3.2455;
SELECT UNIQUE C2 FROM T1 WHERE SIGN(C2) LIKE '%.%' AND C3 IS NOT TRUE OR RAND(C3) LIKE '%.%';
SELECT MAX(DISTINCT C7) FROM T1 WHERE ROUND(C6,C3) <> 829.454;
SELECT MAX(C2) FROM T1 WHERE LOG(C2,C3) IS NOT FALSE;
SELECT BIT_XOR(C7) FROM T1 WHERE ROUND(C2) <> C3 / '829';
SELECT DISTINCT C1 FROM T1 WHERE EXP(C2) IS NOT NULL AND C1 LIKE '-' AND CRC32(C7) NOT LIKE '-';
SELECT C7 FROM T1 WHERE ATAN2(C1) NOT LIKE '' OR FLOOR(C3) NOT BETWEEN -1e-130 AND C2 >> 20;
SELECT C6 FROM T1 WHERE CONV(C2,10,16) BETWEEN C3 MOD C1 AND -1e-130 OR CONV(C3,10,16) NOT BETWEEN 1E-130 AND '829.454';
SELECT C6 FROM T1 WHERE SIN(C6) NOT LIKE '%.%';
SELECT BIT_AND(C3) FROM T1 WHERE LOG10(C2) BETWEEN '0.829454' % C6 AND C7 + 0 OR LN(C1) LIKE '' AND C7 LIKE '';
SELECT UNIQUE C6 FROM T1 WHERE COT(C3) NOT LIKE ('829') AND C2 NOT LIKE (C2 MOD C2) AND ATAN(C3) LIKE '%.%';
SELECT C1 FROM T1 WHERE LOG(C6,C1) = C7 << C3;
SELECT BIT_AND(C1) FROM T1 WHERE NEG(C2) >= 10 OR EXP(C2) <> -1e+125 AND C3 IS NOT FALSE;
SELECT C6 FROM T1 WHERE LN(C1) IS NOT NULL;
SELECT C7 FROM T1 WHERE SIGN(C1) = -2 DIV -1e+125 AND EXP(C6) NOT BETWEEN -0.829454 AND '0.829454' - 3.2455;
SELECT MIN(C2) FROM T1 WHERE ATAN2(C2,C6) LIKE (829.454) OR TAN(C2) NOT BETWEEN '829.454' AND 000009 AND C3 IS NOT FALSE;
SELECT BIT_XOR(C1) FROM T1 WHERE ROUND(C1) BETWEEN 1E-130 AND 5;
SELECT COUNT(C3) FROM T1 WHERE DEGREES(C3) IS NULL;
SELECT C3 FROM T1 WHERE ATAN2(C3,C6) < '-0.829454' DIV C3;
--enable_warnings

##GROUP BY##
SELECT C1 FROM T1 GROUP BY C1;
SELECT C1,C2,C3,C4,C5,C6,C7 FROM T1 GROUP BY C1,C2,C3,C4,C5,C6,C7;

SELECT MAX(C2),AVG(C3),SUM(C4) FROM T1 GROUP BY LOWER(C2);
SELECT MAX(C2),AVG(C3),SUM(C4) FROM T1 GROUP BY UPPER(C2);
SELECT MAX(C2),AVG(C3),SUM(C4) FROM T1 GROUP BY TRIM(C2);
SELECT MAX(C2),AVG(C3),SUM(C4) FROM T1 GROUP BY LENGTH(C2);
SELECT MAX(C2),AVG(C3),SUM(C4) FROM T1 GROUP BY ABS(C2);
SELECT MAX(C2),AVG(C3),SUM(C4) FROM T1 GROUP BY CEIL(C2);
SELECT MAX(C2),AVG(C3),SUM(C4) FROM T1 GROUP BY FLOOR(C2);
SELECT MAX(C2),AVG(C3),SUM(C4) FROM T1 GROUP BY MOD(C2,C3);
SELECT MAX(C2),AVG(C3),SUM(C4) FROM T1 GROUP BY ROUND(C2);
SELECT MAX(C2),AVG(C3),SUM(C4) FROM T1 GROUP BY C2+C3;
SELECT MAX(C2),AVG(C3),SUM(C4) FROM T1 GROUP BY C2-C1,C2*C4;
SELECT MAX(C2),AVG(C3),SUM(C4) FROM T1 GROUP BY C2||C1;

##HAVING##
SELECT C1 FROM T1 GROUP BY C1 HAVING C1 IN (MAX(C2));
SELECT C1 FROM T1 GROUP BY C1 HAVING C1 = MAX(C2);
SELECT C1 FROM T1 GROUP BY C1 HAVING C1 > MAX(C2);
SELECT C1 FROM T1 GROUP BY C1 HAVING C1 <= MAX(C2);

##RQG##
--disable_warnings
SELECT C3 FROM T1 GROUP BY C3,C7,C6 WITH ROLLUP HAVING C3 NOT BETWEEN C3 AND 0.829454 AND GROUP_CONCAT(C3) NOT BETWEEN C3 / C3 AND 000009 + C3 ORDER BY C3 ASC;
SELECT C5 FROM T1 GROUP BY C5,C7,C7 WITH ROLLUP HAVING C5 BETWEEN 0 AND C5 OR GROUP_CONCAT(C2) < C5 ORDER BY C5;
SELECT C2 FROM T1 GROUP BY C2,C6,C1 WITH ROLLUP HAVING C2 NOT BETWEEN -1000 AND 2654646415131313 OR MIN(C1) BETWEEN C2 >> '' AND (1+3) - C2 ORDER BY C2 DESC;
SELECT C3 FROM T1 GROUP BY C3,C3,C1 WITH ROLLUP HAVING C3 NOT BETWEEN C3 AND C3 AND SUM(C1) IS TRUE ORDER BY C3 ASC;
SELECT C1 FROM T1 GROUP BY C1,C1,C3 WITH ROLLUP HAVING C1 IS NULL AND COUNT(C7) IS NOT FALSE ORDER BY C1 DESC;
SELECT C1 FROM T1 GROUP BY C1,C7,C1 WITH ROLLUP HAVING C1 NOT BETWEEN C1 AND -1e-130 OR MAX(DISTINCT C3) NOT BETWEEN -1.25 + C1 AND 999 ORDER BY C1 ASC;
SELECT C6 FROM T1 GROUP BY C6,C2,C2 WITH ROLLUP HAVING C6 NOT BETWEEN 1E+125 + -0.829454 AND '829.454' / C6 AND MAX(DISTINCT C3) BETWEEN C6 AND C6 MOD C6 ORDER BY C6 DESC;
SELECT C3 FROM T1 GROUP BY C3,C6,C2 WITH ROLLUP HAVING C3 > C3 OR SUM(C7) NOT IN(0.829454,1E-130,-2,999) ORDER BY C3 ASC;
SELECT C1 FROM T1 GROUP BY C1,C7,C1 WITH ROLLUP HAVING C1 IS NOT TRUE OR SUM(C7) IS NOT NULL ORDER BY C1;
SELECT C4 FROM T1 GROUP BY C4,C6,C3 WITH ROLLUP HAVING C4 NOT BETWEEN '829' AND C4 ^ C4 AND MIN(C3) BETWEEN C4 + C4 AND C4 ORDER BY C4 DESC;
SELECT C2 FROM T1 GROUP BY C2,C6,C1 WITH ROLLUP HAVING C2 NOT IN (NULL) AND GROUP_CONCAT(C3) IS NULL ORDER BY C2;
SELECT C7 FROM T1 GROUP BY C7,C7,C3 WITH ROLLUP HAVING C7 NOT IN (NULL) AND MIN(C1) NOT BETWEEN 999 AND C7 ORDER BY C7 DESC;
SELECT C4 FROM T1 GROUP BY C4,C6,C1 WITH ROLLUP HAVING C4 NOT BETWEEN 01010 + -2 AND 10 % C4 AND MAX(DISTINCT C3) NOT IN(1E+125,-1e+125,2654646415131313,20) ORDER BY C4 ASC;
SELECT C3 FROM T1 GROUP BY C3,C2,C2 WITH ROLLUP HAVING C3 NOT BETWEEN 000009 AND C3 ^ 1 AND COUNT(C3) NOT BETWEEN C3 AND C3 ORDER BY C3;
SELECT C5 FROM T1 GROUP BY C5,C6,C6 WITH ROLLUP HAVING C5 NOT IN (NULL) AND MIN(DISTINCT C6) != '' + C5 ORDER BY C5;
SELECT C3 FROM T1 GROUP BY C3,C1,C7 WITH ROLLUP HAVING C3 <> 10 & 100000 AND SUM(C6) = -0.829454 ORDER BY C3 DESC;
