##其他类型join##
DROP TABLE T2;
CREATE TABLE T2(C1 CHAR(10),C2 VARCHAR(10),C3 BINARY(10),C4 VARBINARY(10),C5 FLOAT ,C6 DOUBLE,C7 INT);
INSERT INTO T2 VALUES ('1.2','1.2','1.2','1.2','1.2','1.2','1');
SELECT * FROM T1 A FULL JOIN T2 B ON A.C2 <=> B.C1 WHERE A.C7 LIKE (-0.829454 % '0.829454') OR B.C5 NOT BETWEEN '-0.829454' AND -1e+125 ^ A.C4;
