SELECT * FROM T1 A , T2 B WHERE A.C6 <= B.C4 AND A.C7 BETWEEN 1E-130 AND 0.829454 OR B.C2 IS FALSE;
+------+------+------+------+------+------+------+------+------+------+------+------+------+------+
| C1   | C2   | C3   | C4   | C5   | C6   | C7   | C1   | C2   | C3   | C4   | C5   | C6   | C7   |
