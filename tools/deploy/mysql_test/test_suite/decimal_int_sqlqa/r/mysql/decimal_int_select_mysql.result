+------+------+------+------+------+------+------+------+------+------+------+------+------+------+
SELECT * FROM T1 A , T2 B WHERE A.C1 <> B.C3 OR A.C7 >= A.C7 + 1E-130 AND B.C5 BETWEEN -1e-130 AND B.C4 DIV A.C5;
