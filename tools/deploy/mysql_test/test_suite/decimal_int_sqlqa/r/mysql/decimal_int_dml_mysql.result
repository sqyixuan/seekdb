##SAVEPOINT##
BEGIN;
UPDATE T2 SET C2 = 0.99 WHERE C2 IS NULL;
SAVEPOINT SP1;
UPDATE T2 SET C2 = -0.99 WHERE C2 = 1E+8-1;
SAVEPOINT SP2;
UPDATE T2 SET C2 = 0 WHERE C2 = -1E+8+1;
SAVEPOINT SP3;
SELECT C2 FROM T2;
+-------+
| C2    |
+-------+
|  0.99 |
| -0.99 |
|  0.00 |
|  0.99 |
+-------+
ROLLBACK TO SAVEPOINT SP2;
SELECT C2 FROM T2;
+--------------+
| C2           |
+--------------+
|         0.99 |
|        -0.99 |
| -99999999.00 |
|         0.99 |
+--------------+
DELETE FROM T2;
SAVEPOINT SP3;
ROLLBACK TO SAVEPOINT SP1;
SELECT * FROM T2;
