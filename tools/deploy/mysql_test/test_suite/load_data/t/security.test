--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL2
# description: Test security case for MySQL load data query
# 

connect (mysqlroot,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection mysqlroot;
grant all on *.* to admin;

--source mysql_test/include/check_schema_fast_sync.inc


# Prepare
--source mysql_test/include/copy_data_for_load.inc
connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn0;
--disable_warnings
drop table if exists t_my_loaddata_test;
--enable_warnings
create table t_my_loaddata_test (c1 int);

