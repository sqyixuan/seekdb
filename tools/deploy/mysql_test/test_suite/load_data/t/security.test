connection mysqlroot;
revoke file on *.* from admin;

--source mysql_test/include/check_schema_fast_sync.inc
connect (conn3,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--error 1227
load data infile 'data_for_mysqltest_loaddata/data_for_security.dat' into table t_my_loaddata_test;
--sorted_result
--error 1227
select * into outfile 'data_for_mysqltest_loaddata/data_for_security2.dat' from t_my_loaddata_test;

