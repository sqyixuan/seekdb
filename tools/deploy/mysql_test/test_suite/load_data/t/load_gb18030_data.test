--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL2
# description: Test simple case for MySQL load data query
# 

# Prepare
--source mysql_test/include/copy_data_for_load.inc
--disable_warnings
drop table if exists t1;
--enable_warnings


create table t1(c1 varchar(30000)) character set gb18030 collate gb18030_bin;

load data /*+ parallel(1) */ infile 'data_for_mysqltest_loaddata/double-cjk.txt' into table t1 character set gb18030 lines terminated by '\r\n';

--sorted_result
select * from t1;

drop table t1;

create table t1(c1 varchar(30000)) character set gb18030_2022 collate gb18030_2022_bin;

load data /*+ parallel(1) */ infile 'data_for_mysqltest_loaddata/double-cjk.txt' into table t1 character set gb18030_2022 lines terminated by '\r\n';

--sorted_result
select * from t1;

drop table t1;
