# owner: jim.wjh
# owner group: SQL2
# description: Test simple case for MySQL load data query
# 

# Prepare
--source mysql_test/include/copy_data_for_load.inc
--disable_warnings
drop table if exists t_my_loaddata_test;
--enable_warnings

# TEST 1

create table t_my_loaddata_test 
(
c1 int primary key, 
c2 int, 
c3 decimal, 
c4 varchar(10), 
c5 date, 
c6 timestamp, 
c7 char
);

load data
infile 'data_for_mysqltest_loaddata/data_with_empty_field.dat'
ignore
into table t_my_loaddata_test;

--sorted_result
select * from t_my_loaddata_test;

drop table t_my_loaddata_test;

# TEST 2 load stmt has set expr, when meet empty field

create table t_my_loaddata_test 
(
c1 int primary key, 
c2 int, 
c3 decimal, 
c4 varchar(10), 
c5 date, 
c6 timestamp, 
c7 char
);

--error 1235
load data
infile 'data_for_mysqltest_loaddata/data_with_empty_field2.dat'
ignore
into table t_my_loaddata_test
set c3 = c2, c4 = c2, c5 = c2, c6 = c2, c7 = c2;

--sorted_result
select * from t_my_loaddata_test;

drop table t_my_loaddata_test;


