--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL2
# description: Test simple case for MySQL load data query
# 

--result_format 4
# Prepare
--source mysql_test/include/copy_data_for_load.inc
--disable_warnings
drop table if exists t_my_loaddata_test;
--enable_warnings
create table t_my_loaddata_test (
c_TINYINT TINYINT,
c_SMALLINT SMALLINT,
c_MEDIUMINT MEDIUMINT,
c_INT INT,
c_BIGINT BIGINT,
c_FLOAT FLOAT,
c_DOUBLE DOUBLE,
c_DECIMAL DECIMAL,
c_DATE DATE,
c_TIME TIME,
c_YEAR YEAR,
c_DATETIME DATETIME,
c_TIMESTAMP TIMESTAMP,
c_CHAR CHAR(10),
c_VARCHAR VARCHAR(10)
);

# TEST 1

delete from t_my_loaddata_test;

load data
infile 'data_for_mysqltest_loaddata/empty_field.dat'
ignore
into table t_my_loaddata_test
fields terminated by '|';

--sorted_result
select * from t_my_loaddata_test order by 1;

# Clean Up

drop table t_my_loaddata_test;


create table t_my_loaddata_test(c1 varchar(100), c2 varchar(100));
load data
infile 'data_for_mysqltest_loaddata/null_field1.dat'
into table t_my_loaddata_test
fields terminated by ',';
--sorted_result
select * from t_my_loaddata_test order by 1;
delete from t_my_loaddata_test;
load data
infile 'data_for_mysqltest_loaddata/null_field1.dat'
into table t_my_loaddata_test
fields terminated by ',' enclosed by '"';
--sorted_result
select * from t_my_loaddata_test order by 1;

drop table t_my_loaddata_test;



--disable_warnings
drop table if exists web_returns;
--enable_warnings

CREATE TABLE `web_returns` (
  `wr_returned_date_sk` int(11) DEFAULT NULL,
  `wr_returned_time_sk` int(11) DEFAULT NULL,
  `wr_item_sk` int(11) NOT NULL,
  `wr_refunded_customer_sk` int(11) DEFAULT NULL,
  `wr_refunded_cdemo_sk` int(11) DEFAULT NULL,
  `wr_refunded_hdemo_sk` int(11) DEFAULT NULL,
  `wr_refunded_addr_sk` int(11) DEFAULT NULL,
  `wr_returning_customer_sk` int(11) DEFAULT NULL,
  `wr_returning_cdemo_sk` int(11) DEFAULT NULL,
  `wr_returning_hdemo_sk` int(11) DEFAULT NULL,
  `wr_returning_addr_sk` int(11) DEFAULT NULL,
  `wr_web_page_sk` int(11) DEFAULT NULL,
  `wr_reason_sk` int(11) DEFAULT NULL,
  `wr_order_number` int(11) NOT NULL,
  `wr_return_quantity` int(11) DEFAULT NULL,
  `wr_return_amt` decimal(7,2) DEFAULT NULL,
  `wr_return_tax` decimal(7,2) DEFAULT NULL,
  `wr_return_amt_inc_tax` decimal(7,2) DEFAULT NULL,
  `wr_fee` decimal(7,2) DEFAULT NULL,
  `wr_return_ship_cost` decimal(7,2) DEFAULT NULL,
  `wr_refunded_cash` decimal(7,2) DEFAULT NULL,
  `wr_reversed_charge` decimal(7,2) DEFAULT NULL,
  `wr_account_credit` decimal(7,2) DEFAULT NULL,
  `wr_net_loss` decimal(7,2) DEFAULT NULL
)TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(wr_returned_date_sk)
(partition part_1 values less than (2450846),
partition part_73 values less than (MAXVALUE));

load data infile 'data_for_mysqltest_loaddata/null_field2.dat'
into table web_returns
fields terminated by '|';
--sorted_result
select * from web_returns;


drop table web_returns;

