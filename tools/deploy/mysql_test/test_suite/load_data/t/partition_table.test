# TEST 4 partition mode = hash + range

create table t_my_loaddata_test (c1 int, c2 int, c3 int, c4 int, primary key(c1,c2)) 
partition by hash(c1)
subpartition by range(c2)
subpartition template 
(
subpartition p0 values less than (10),
subpartition p1 values less than (20),
subpartition p2 values less than (30),
subpartition p3 values less than (40),
subpartition p4 values less than (MAXVALUE)
)
partitions 3;

load data
infile 'data_for_mysqltest_loaddata/data_50_lines_int4.dat'
ignore
into table t_my_loaddata_test;
--sorted_result
select * from t_my_loaddata_test;
--sorted_result
select * from t_my_loaddata_test partition(p0sp0);
--sorted_result
select * from t_my_loaddata_test partition(p0sp1);
--sorted_result
select * from t_my_loaddata_test partition(p0sp2);
--sorted_result
select * from t_my_loaddata_test partition(p0sp3);
--sorted_result
select * from t_my_loaddata_test partition(p0sp4);
--sorted_result
select * from t_my_loaddata_test partition(p1sp0);
--sorted_result
select * from t_my_loaddata_test partition(p1sp1);
--sorted_result
select * from t_my_loaddata_test partition(p1sp2);
--sorted_result
select * from t_my_loaddata_test partition(p1sp3);
--sorted_result
select * from t_my_loaddata_test partition(p1sp4);
--sorted_result
select * from t_my_loaddata_test partition(p2sp0);
--sorted_result
select * from t_my_loaddata_test partition(p2sp1);
--sorted_result
select * from t_my_loaddata_test partition(p2sp2);
--sorted_result
select * from t_my_loaddata_test partition(p2sp3);
--sorted_result
select * from t_my_loaddata_test partition(p2sp4);
drop table t_my_loaddata_test;


# Clean Up

