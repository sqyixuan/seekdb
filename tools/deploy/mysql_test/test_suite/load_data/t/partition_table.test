--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL2
# description: Test simple case for MySQL load data query
# 

# Prepare
--source mysql_test/include/copy_data_for_load.inc
--disable_warnings
drop table if exists t_my_loaddata_test;
--enable_warnings

# TEST 1 partition mode = hash

create table t_my_loaddata_test (c1 int primary key, c2 int, c3 int, c4 int) partition by hash(c1) partitions 5;
load data
infile 'data_for_mysqltest_loaddata/data_50_lines_int4.dat'
ignore
into table t_my_loaddata_test;
--sorted_result
select * from t_my_loaddata_test;
--sorted_result
select * from t_my_loaddata_test partition(p0);
--sorted_result
select * from t_my_loaddata_test partition(p1);
--sorted_result
select * from t_my_loaddata_test partition(p2);
--sorted_result
select * from t_my_loaddata_test partition(p3);
--sorted_result
select * from t_my_loaddata_test partition(p4);
drop table t_my_loaddata_test;

# TEST 2 partition mode = range

create table t_my_loaddata_test (c1 int primary key, c2 int, c3 int, c4 int) 
partition by range(c1) 
(partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (30),
partition p3 values less than (40),
partition p4 values less than (MAXVALUE));
load data
infile 'data_for_mysqltest_loaddata/data_50_lines_int4.dat'
ignore
into table t_my_loaddata_test;
--sorted_result
select * from t_my_loaddata_test;
--sorted_result
select * from t_my_loaddata_test partition(p0);
--sorted_result
select * from t_my_loaddata_test partition(p1);
--sorted_result
select * from t_my_loaddata_test partition(p2);
--sorted_result
select * from t_my_loaddata_test partition(p3);
--sorted_result
select * from t_my_loaddata_test partition(p4);
drop table t_my_loaddata_test;

# TEST 3 partition mode = list

