# owner: jim.wjh
# owner group: SQL2
# description: Test simple case for MySQL load data query
# 

--disable_warnings
drop table if exists t_select_into;
drop table if exists t_my_loaddata_test;
--enable_warnings

# Prepare
create table t_select_into (
c1 tinyint,
c2 smallint,
c3 mediumint,
c4 int,
c5 number,
c6 float,
c7 double,
c8 datetime,
c9 timestamp,
c10 date,
c11 varchar(10),
c12 char
);
--disable_query_log
insert into t_select_into(c1) values (1);
insert into t_select_into(c2) values (-2);
insert into t_select_into(c3) values (3);
insert into t_select_into(c4) values (-4);
insert into t_select_into(c5) values (5);
insert into t_select_into(c6) values (6.2);
insert into t_select_into(c7) values (7.3);
insert into t_select_into(c8) values ('2000-01-01 01:01:01');
insert into t_select_into(c9) values ('2012-12-12 12:12:12');
insert into t_select_into(c10) values ('2020-11-11 11:11:11');
insert into t_select_into(c11) values ('a,b,c');
insert into t_select_into(c11) values ('a"b"c');
insert into t_select_into(c11) values ('a\nb\nc');
insert into t_select_into(c11) values ('a\\b\\c');
insert into t_select_into(c11) values ('a\0b\0c');
insert into t_select_into(c11) values ('a\tb\tc');
insert into t_select_into(c12) values ('\n');
--enable_query_log
--result_format 3
--sorted_result
select * from t_select_into;

--exec ssh $OBMYSQL_MS0 'rm -f $OBSERVER_DIR/select_into.outfile'
--echo # TEST 1
create table t_my_loaddata_test (
c1 tinyint,
c2 smallint,
c3 mediumint,
c4 int,
c5 number,
c6 float,
c7 double,
c8 datetime,
c9 timestamp,
c10 date,
c11 varchar(10),
c12 char
);
--disable_query_log
eval select * into outfile '$OBSERVER_DIR/select_into.outfile' from t_select_into;
eval load data infile '$OBSERVER_DIR/select_into.outfile' ignore into table t_my_loaddata_test;
--enable_query_log
--sorted_result
select * from t_my_loaddata_test;
drop table t_my_loaddata_test;
--exec ssh $OBMYSQL_MS0 'rm -f $OBSERVER_DIR/select_into.outfile'

--echo # TEST 2
create table t_my_loaddata_test (
c1 tinyint,
c2 smallint,
c3 mediumint,
c4 int,
c5 number,
c6 float,
c7 double,
c8 datetime,
c9 timestamp,
c10 date,
c11 varchar(10),
c12 char
);
--disable_query_log
eval select * into outfile '$OBSERVER_DIR/select_into.outfile' from t_select_into;
eval load data infile '$OBSERVER_DIR/select_into.outfile' ignore into table t_my_loaddata_test;
--enable_query_log
--sorted_result
select * from t_my_loaddata_test;
drop table t_my_loaddata_test;
--exec ssh $OBMYSQL_MS0 'rm -f $OBSERVER_DIR/select_into.outfile'

--result_format 1
