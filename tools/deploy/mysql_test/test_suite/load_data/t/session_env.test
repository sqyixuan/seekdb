# Prepare
--source mysql_test/include/copy_data_for_load.inc
--disable_warnings
drop table if exists t1;
--enable_warnings


--result_format 4

create table t1(c1 timestamp, c2 int);

--error 1366
load data infile 'data_for_mysqltest_loaddata/session_env.dat' into table t1 fields terminated by '|';

set sql_mode = '';
load data infile 'data_for_mysqltest_loaddata/session_env.dat' into table t1 fields terminated by '|';

select * from t1;

set time_zone = '-02:00';
load data infile 'data_for_mysqltest_loaddata/session_env.dat' into table t1 fields terminated by '|';

select * from t1;

drop table t1;
set sql_mode=default;
