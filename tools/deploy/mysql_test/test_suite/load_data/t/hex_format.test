--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL2
# description: Test simple case for MySQL load data query
# 

# Prepare
--source mysql_test/include/copy_data_for_load.inc
--disable_warnings
drop table if exists t_my_loaddata_test;
--enable_warnings
create table t_my_loaddata_test (c1 varchar(100), c2 varchar(100));

# TEST 1
--result_format 4
delete from t_my_loaddata_test;
load data
infile 'data_for_mysqltest_loaddata/hex_format.dat'
into table t_my_loaddata_test
fields terminated by x'2C' enclosed by x'27' escaped by x'5C'
lines terminated by x'0A';
--sorted_result
select * from t_my_loaddata_test;

# Clean Up

drop table t_my_loaddata_test;
