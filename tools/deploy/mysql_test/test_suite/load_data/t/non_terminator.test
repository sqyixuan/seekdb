# owner: jim.wjh
# owner group: SQL2
# description: Test simple case for MySQL load data query
# 

# Prepare
--source mysql_test/include/copy_data_for_load.inc
--disable_warnings
drop table if exists t_my_loaddata_test;
--enable_warnings

# TEST 1 non field term test
create table t_my_loaddata_test (c1 varchar(100));
load data
infile 'data_for_mysqltest_loaddata/non_field_term.dat'
ignore
into table t_my_loaddata_test
fields terminated by '' enclosed by '\'' escaped by '\\'
lines starting by '' terminated by '\n';
--sorted_result
select * from t_my_loaddata_test order by c1;
drop table t_my_loaddata_test;

# TEST 2 non field term test simple_mode
create table t_my_loaddata_test (c1 varchar(100), c2 varchar(100));
load data
infile 'data_for_mysqltest_loaddata/non_line_term_simple.dat'
ignore
into table t_my_loaddata_test
fields terminated by '\t' enclosed by '\'' escaped by '\\'
lines starting by '' terminated by '';
--sorted_result
select * from t_my_loaddata_test order by c1;
drop table t_my_loaddata_test;

# TEST 3 non line term test normal_mode
create table t_my_loaddata_test (c1 varchar(100), c2 varchar(100));
load data
infile 'data_for_mysqltest_loaddata/non_line_term.dat'
ignore
into table t_my_loaddata_test
fields terminated by '__' enclosed by '\'' escaped by '\\'
lines starting by '' terminated by '';
--sorted_result
select * from t_my_loaddata_test order by c1;
drop table t_my_loaddata_test;

# TEST 4 non line term or field term test
create table t_my_loaddata_test (c1 varchar(100), c2 varchar(100));
load data
infile 'data_for_mysqltest_loaddata/non_field_term.dat'
ignore
into table t_my_loaddata_test
fields terminated by '' enclosed by '\'' escaped by '\\'
lines starting by '' terminated by '';
--sorted_result
select * from t_my_loaddata_test order by c1;
drop table t_my_loaddata_test;

