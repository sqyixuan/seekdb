# owner: dingjincheng.djc
# owner group: SQL1
# description: Test load data in NO_BACKSLASH_ESCAPES mode
# 

# Prepare
--source mysql_test/include/copy_data_for_load.inc
--disable_warnings
drop table if exists t_my_loaddata_test;
--enable_warnings

--error 0,1051
drop table t1;

create table t1 (c1 varchar(1000), c2 varchar(1000), c3 varchar(1000));
set sql_mode="NO_BACKSLASH_ESCAPES";

--error 1083
load data infile 'data_for_mysqltest_loaddata/sql_mode_NBE.dat' into table t1
fields terminated by '' enclosed by '\\' escaped by '' lines terminated by 'ZZ';
--sorted_result
select * from t1 order by 1;
delete from t1;

--error 1083
load data infile 'data_for_mysqltest_loaddata/sql_mode_NBE.dat' into table t1
fields terminated by ',' enclosed by '"' escaped by '\\' lines terminated by 'ZZ';
--sorted_result
select * from t1 order by 1;
delete from t1;
  
load data infile 'data_for_mysqltest_loaddata/sql_mode_NBE.dat' into table t1
fields terminated by ',' lines terminated by 'ZZ';
--sorted_result
select * from t1 order by 1;
delete from t1;

set sql_mode=default;
drop table t1;
