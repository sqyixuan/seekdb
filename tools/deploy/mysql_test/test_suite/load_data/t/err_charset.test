--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL2
# description: Test simple case for MySQL load data query
# 

# Prepare
--source mysql_test/include/copy_data_for_load.inc
--disable_warnings
drop table if exists t_my_loaddata_test;
--enable_warnings

# TEST 1 
# extend ascii begins from 0x80 to 0xFF

create table t_my_loaddata_test (c1 varchar(100), c2 varchar(100));

--error 1083  #ERROR 1083 (42000): Field separator argument is not what is expected; check the manual
load data
infile 'data_for_mysqltest_loaddata/line_start_termindate_test.dat'
ignore
into table t_my_loaddata_test
fields terminated by 'SEP' enclosed by '大' escaped by '\\'
lines starting by 'START' terminated by 'END';

--sorted_result
select * from t_my_loaddata_test;

--error 1083  #ERROR 1083 (42000): Field separator argument is not what is expected; check the manual
load data
infile 'data_for_mysqltest_loaddata/line_start_termindate_test.dat'
ignore
into table t_my_loaddata_test
fields terminated by 'SEP' enclosed by '\'' escaped by '家'
lines starting by 'START' terminated by 'END';

--sorted_result
select * from t_my_loaddata_test;

load data
infile 'data_for_mysqltest_loaddata/line_start_termindate_test.dat'
ignore
into table t_my_loaddata_test
fields terminated by '晚上' enclosed by '\'' escaped by '\\'
lines starting by 'START' terminated by 'END';

--sorted_result
select * from t_my_loaddata_test;

load data
infile 'data_for_mysqltest_loaddata/line_start_termindate_test.dat'
ignore
into table t_my_loaddata_test
fields terminated by 'SEP' enclosed by '\'' escaped by '\\'
lines starting by '好。' terminated by 'END';

--sorted_result
select * from t_my_loaddata_test;

load data
infile 'data_for_mysqltest_loaddata/line_start_termindate_test.dat'
ignore
into table t_my_loaddata_test
fields terminated by 'SEP' enclosed by '\'' escaped by '\\'
lines starting by 'START' terminated by '今天';

--sorted_result
select * from t_my_loaddata_test;

drop table t_my_loaddata_test;


# Clean Up

