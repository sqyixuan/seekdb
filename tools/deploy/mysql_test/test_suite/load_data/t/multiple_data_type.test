--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL2
# description: Test simple case for MySQL load data query
# 

# Prepare
--source mysql_test/include/copy_data_for_load.inc
--disable_warnings
drop table if exists t_my_loaddata_test;
--enable_warnings

# TEST 1 non partition

create table t_my_loaddata_test (
c1 tinyint,
c2 smallint,
c3 mediumint,
c4 number,
c5 int,
c6 float,
c7 double,
c8 datetime,
c9 timestamp,
c10 date,
c11 varchar(10),
c12 char
);
load data
infile 'data_for_mysqltest_loaddata/data_multi_types.dat'
ignore
into table t_my_loaddata_test;
--sorted_result
select * from t_my_loaddata_test;
drop table t_my_loaddata_test;

# TEST 2 partition hash

let $i = 4;
while ($i)
{
eval create table t_my_loaddata_test (
c1 tinyint,
c2 smallint,
c3 mediumint,
c4 int,
c5 number,
c6 float,
c7 double,
c8 datetime,
c9 timestamp,
c10 date,
c11 varchar(10),
c12 char
) partition by hash(c$i) partitions 2;
load data
infile 'data_for_mysqltest_loaddata/data_multi_types.dat'
ignore
into table t_my_loaddata_test;
--sorted_result
select * from t_my_loaddata_test partition(p0);
--sorted_result
select * from t_my_loaddata_test partition(p1);
drop table t_my_loaddata_test;
dec $i;
}

# TEST 3 partition key

let $i = 8;
while ($i)
{
eval create table t_my_loaddata_test (
c1 tinyint,
c2 smallint,
c3 mediumint,
c4 int,
c5 number,
c6 float,
c7 double,
c8 datetime,
c9 timestamp,
c10 date,
c11 varchar(10),
c12 char
) partition by key(c$i) partitions 2;
load data
infile 'data_for_mysqltest_loaddata/data_multi_types.dat'
ignore
into table t_my_loaddata_test;
--sorted_result
select * from t_my_loaddata_test partition(p0);
--sorted_result
select * from t_my_loaddata_test partition(p1);
drop table t_my_loaddata_test;
dec $i;
}

