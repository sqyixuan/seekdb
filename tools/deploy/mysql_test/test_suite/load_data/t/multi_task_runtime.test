--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL2
# description: Test simple case for MySQL load data query
# 

# Prepare
--source mysql_test/include/copy_data_for_load.inc
--disable_warnings
drop table if exists t_my_loaddata_test;
--enable_warnings

# TEST 1

create table t_my_loaddata_test (c1 int primary key, c2 int, c3 int, c4 int);
load data
infile 'data_for_mysqltest_loaddata/data_2001_lines_int.dat'
ignore
into table t_my_loaddata_test;
--sorted_result
select * from t_my_loaddata_test;
drop table t_my_loaddata_test;

# TEST 2 unique index

create table t_my_loaddata_test (c1 int primary key, c2 int unique, c3 int, c4 int);
load data
infile 'data_for_mysqltest_loaddata/data_50_lines_int4.dat'
ignore
into table t_my_loaddata_test;
--sorted_result
select * from t_my_loaddata_test;
drop table t_my_loaddata_test;

# TEST 3 index and unique index 


create table t_my_loaddata_test (c1 int primary key, c2 int unique, c3 int, c4 int, index i_local_c4(c4) local);
load data
infile 'data_for_mysqltest_loaddata/data_50_lines_int4.dat'
ignore
into table t_my_loaddata_test;
--sorted_result
select * from t_my_loaddata_test;
drop table t_my_loaddata_test;

# TEST 4 hint
create table t_my_loaddata_test (c1 int primary key, c2 int, c3 int, c4 int);
load data /*+ batch_size(100) */
infile 'data_for_mysqltest_loaddata/data_2001_lines_int.dat'
ignore
into table t_my_loaddata_test;
--sorted_result
select * from t_my_loaddata_test;
drop table t_my_loaddata_test;
