--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL2
# 

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;

alter system set memory_limit='700G';
alter system set memstore_limit_percentage = 80;

let $char_charset = 'utf8';
let $nchar_charset = 'utf16';
--source mysql_test/test_suite/load_data/include/create_load_data_tenant.inc
--source mysql_test/test_suite/load_data/include/conn_tenant.inc

# Prepare
--source mysql_test/test_suite/load_data/include/create_table_lineitem.inc

# TEST 1
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
load data /*+ load_batch_size(100) parallel(80)*/ infile '/home/jim.wjh/data/tpch_100g_data/lineitem.tbl' 
into table lineitem
fields terminated by '|';


# Clean Up

drop table lineitem;

--source mysql_test/test_suite/load_data/include/drop_tenant.inc
