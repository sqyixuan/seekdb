--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL2
# description: Test simple case for MySQL load data query
# 

--result_format 4
# Prepare
--source mysql_test/include/copy_data_for_load.inc
--disable_warnings
drop table if exists t_my_loaddata_test;
--enable_warnings
create table t_my_loaddata_test (c1 varchar(100), c2 varchar(100), c3 varchar(100));

# TEST 1

delete from t_my_loaddata_test;
load data
infile 'data_for_mysqltest_loaddata/escape_enclosed_short_separator_test.dat'
ignore
into table t_my_loaddata_test;
--sorted_result
select * from t_my_loaddata_test order by c1;

# TEST 2

delete from t_my_loaddata_test;
load data 
infile 'data_for_mysqltest_loaddata/escape_enclosed_short_separator_test.dat'
ignore
into table t_my_loaddata_test
fields enclosed by '\'';
--sorted_result
select * from t_my_loaddata_test order by c1;

# Clean Up

drop table t_my_loaddata_test;
