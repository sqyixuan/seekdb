--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
# owner group: SQL2
# description: Test simple case for MySQL load data query
#

# Prepare
--source mysql_test/include/copy_data_for_load.inc
--disable_warnings
drop table if exists t_my_loaddata_test;
drop table if exists try;
--enable_warnings
create table t_my_loaddata_test(a int,b varchar(10));
delete from t_my_loaddata_test;
load data
infile 'data_for_mysqltest_loaddata/issue-24166399.dat'
into table t_my_loaddata_test
fields terminated by ','
ignore 10 rows;
--sorted_result
select * from t_my_loaddata_test;
drop table t_my_loaddata_test;

--disable_warnings
drop table if exists nwjzk;
--enable_warnings

CREATE TABLE `nwjzk` (
  `CJHBJLH` bigint(20) NOT NULL COMMENT '回报记录号',
  `CJAPID` char(3) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '应用标识',
  `CJSBJYDY` char(6) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '申报交易单元',
  `CJZQDM` char(8) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '证券代码',
  `CJZQDMY` char(4) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '证券代码源',
  `CJJJGDM` char(2) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '结算机构代码',
  `CJHBSJ` decimal(17,0) NOT NULL COMMENT '回报时间',
  `CJSSBBH` char(16) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '交易所成交申报编号',
  `CJKSBBH` char(10) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '客户成交申报编号',
  `CJSBLX` decimal(2,0) NOT NULL COMMENT '成交申报类型',
  `CJCJID` char(10) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '内部成交报告 ID',
  `CJYCJID` char(10) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '原内部成交报告 ID',
  `CJCJJG` decimal(13,4) NOT NULL COMMENT '成交价格',
  `CJCJSL` decimal(15,2) NOT NULL COMMENT '成交数量',
  `CJYWLX` decimal(4,0) NOT NULL COMMENT '成交申报业务类型',
  `CJZYWLX` decimal(4,0) NOT NULL COMMENT '成交申报子业务类型',
  `CJSBSYLX` decimal(4,0) NOT NULL COMMENT '订单申报所有者类型',
  `CJBGZXBH` char(16) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '报告执行编号',
  `CJBFX` char(1) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '本方参与人买卖方向',
  `CJBJYDY` char(6) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '本方交易单元',
  `CJBZQZH` char(12) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '本方证券账户',
  `CJBYYBDM` char(4) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '本方营业部代码',
  `CJBKDDBH` char(10) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '本方客户订单编号',
  `CJBSDDBH` char(16) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '本方交易所订单编号',
  `CJBZXBH` char(16) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '本方执行编号',
  `CJBDDSYLX` decimal(4,0) NOT NULL COMMENT '本方订单所有者类型',
  `CJDJYDY` char(6) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '对手方交易单元',
  `CJDZQZH` char(12) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '对手方证券账户',
  `CJDYYBDM` char(4) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '对手方营业部代码',
  `CJDKDDBH` char(10) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '对手方客户订单编号',
  `CJDSDDBH` char(16) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '对手方交易所订单号',
  `CJDZXBH` char(16) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '对手方执行编号',
  `CJDDDSYLX` decimal(4,0) NOT NULL COMMENT '对手方订单所有者类型',
  `CJBXYBS` char(1) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '本方信用标识',
  `CJDXYBS` char(1) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '对手方信用标识',
  `CJDQRQ` decimal(8,0) NOT NULL COMMENT '到期日期',
  `CJBYBZ1` char(1) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '备用标志 1',
  `CJBYBZ2` char(1) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '备用标志 2',
  `CJBYZD` char(20) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '备用字段 20',
  PRIMARY KEY (`CJHBJLH`),
  KEY `cjzqdm` (`CJZQDM`, `CJDZQZH`, `CJDJYDY`) BLOCK_SIZE 16384 GLOBAL,
  KEY `cjzqdm_3` (`CJZQDM`, `CJBZQZH`, `CJBJYDY`) BLOCK_SIZE 16384 GLOBAL
) CHARSET = utf8mb4 COLLATE = utf8mb4_bin COMMENT = '接口通信>集中库'
 partition by key(cjhbjlh) partitions 17
;

set @@session.ob_query_timeout = 1000000*60;
load data /*+ parallel(4) */ infile  'data_for_mysqltest_loaddata/clear.nwjzk.0_10000.csv'  into table nwjzk fields terminated by ','  ENCLOSED BY '\"' ignore 1 lines set CJBYZD = "";
--sorted_result
select count(*) from nwjzk;
drop table nwjzk;

CREATE TABLE `try` (   `c1` int(11) DEFAULT NULL );

LOAD DATA INFILE 'data_for_mysqltest_loaddata/test.1.0.csv' into table try  fields terminated by '|' enclosed by '''' lines starting by '' terminated by '\n' IGNORE 100000000000000000 rows;

drop table `try`;
