drop table if exists t1;
result_format: 4
create table t1(c1 timestamp, c2 int);

load data infile 'data_for_mysqltest_loaddata/session_env.dat' into table t1 fields terminated by '|';
ERROR HY000: Incorrect integer value

set sql_mode = '';
load data infile 'data_for_mysqltest_loaddata/session_env.dat' into table t1 fields terminated by '|';

select * from t1;
+---------------------+------+
| c1                  | c2   |
+---------------------+------+
| 3089-09-13 02:43:07 |    0 |
+---------------------+------+

set time_zone = '-02:00';
load data infile 'data_for_mysqltest_loaddata/session_env.dat' into table t1 fields terminated by '|';

select * from t1;
+---------------------+------+
| c1                  | c2   |
+---------------------+------+
| 3089-09-12 16:43:07 |    0 |
| 3089-09-13 02:43:07 |    0 |
+---------------------+------+

drop table t1;
set sql_mode=default;
