drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop view if exists tab_stat_view;
drop view if exists col_stat_view;
create table t1 (c1 varchar(100), c2 varchar(100));
create table t2 (c1 varchar(100), c2 varchar(100));
create table t3 (c1 varchar(100), c2 varchar(100));
create view tab_stat_view as select OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, NUM_ROWS, OBJECT_TYPE from oceanbase.DBA_TAB_STATISTICS where owner = 'test' order by PARTITION_NAME;
create view col_stat_view as select OWNER, TABLE_NAME, COLUMN_NAME, LOW_VALUE, HIGH_VALUE, NUM_NULLS from oceanbase.DBA_TAB_COL_STATISTICS where owner = 'test' ORDER BY COLUMN_NAME;
set _OPTIMIZER_GATHER_STATS_ON_LOAD = 1;
load data /*+APPEND*/
infile 'data_for_mysqltest_loaddata/line_start_termindate_test.dat'
into table t1
fields terminated by 'SEP' enclosed by '\'' escaped by '\\'
lines starting by 'START' terminated by 'END';
select * from t1;
c1	c2
hello	world
my	name
is	jim
nice	to
meet	you
select * from tab_stat_view where table_name = 'T1';
OWNER	TABLE_NAME	PARTITION_NAME	SUBPARTITION_NAME	NUM_ROWS	OBJECT_TYPE
test	t1	NULL	NULL	5	TABLE
select * from col_stat_view where table_name = 'T1';
OWNER	TABLE_NAME	COLUMN_NAME	LOW_VALUE	HIGH_VALUE	NUM_NULLS
test	t1	c1	'hello'	'nice'	0
test	t1	c2	'jim'	'you'	0
load data /*+GATHER_OPTIMIZER_STATISTICS*/
infile 'data_for_mysqltest_loaddata/line_start_termindate_test.dat'
into table t2
fields terminated by 'SEP' enclosed by '\'' escaped by '\\'
lines starting by 'START' terminated by 'END';
select * from t2;
c1	c2
hello	world
my	name
is	jim
nice	to
meet	you
select * from tab_stat_view where table_name = 'T2';
OWNER	TABLE_NAME	PARTITION_NAME	SUBPARTITION_NAME	NUM_ROWS	OBJECT_TYPE
test	t2	NULL	NULL	NULL	TABLE
select * from col_stat_view where table_name = 'T2';
OWNER	TABLE_NAME	COLUMN_NAME	LOW_VALUE	HIGH_VALUE	NUM_NULLS
test	t2	c1	NULL	NULL	NULL
test	t2	c2	NULL	NULL	NULL
set _OPTIMIZER_GATHER_STATS_ON_LOAD = 0;
load data /*+GATHER_OPTIMIZER_STATISTICS*/
infile 'data_for_mysqltest_loaddata/line_start_termindate_test.dat'
into table t3
fields terminated by 'SEP' enclosed by '\'' escaped by '\\'
lines starting by 'START' terminated by 'END';
select * from t3;
c1	c2
hello	world
is	jim
meet	you
my	name
nice	to
select * from tab_stat_view where table_name = 'T3';
OWNER	TABLE_NAME	PARTITION_NAME	SUBPARTITION_NAME	NUM_ROWS	OBJECT_TYPE
test	t3	NULL	NULL	NULL	TABLE
select * from col_stat_view where table_name = 'T3';
OWNER	TABLE_NAME	COLUMN_NAME	LOW_VALUE	HIGH_VALUE	NUM_NULLS
test	t3	c1	NULL	NULL	NULL
test	t3	c2	NULL	NULL	NULL
set _OPTIMIZER_GATHER_STATS_ON_LOAD = 1;
drop table t1;
drop table t2;
drop table t3;
drop view tab_stat_view;
drop view col_stat_view;
