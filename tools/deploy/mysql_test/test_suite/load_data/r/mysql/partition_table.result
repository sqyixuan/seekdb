create table t_my_loaddata_test (c1 int, c2 int, c3 int, c4 int, primary key(c1,c2)) 
partition by hash(c1)
subpartition by range(c2)
subpartition template 
(
subpartition p0 values less than (10),
subpartition p1 values less than (20),
subpartition p2 values less than (30),
subpartition p3 values less than (40),
subpartition p4 values less than (MAXVALUE)
)
partitions 3;
