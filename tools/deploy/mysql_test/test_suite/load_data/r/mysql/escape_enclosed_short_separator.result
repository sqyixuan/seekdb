result_format: 4


drop table if exists t_my_loaddata_test;
create table t_my_loaddata_test (c1 varchar(100), c2 varchar(100), c3 varchar(100));

delete from t_my_loaddata_test;
load data
infile 'data_for_mysqltest_loaddata/escape_enclosed_short_separator_test.dat'
ignore
into table t_my_loaddata_test;
select * from t_my_loaddata_test order by c1;
+-------+-------------------+--------+
| c1    | c2                | c3     |
+-------+-------------------+--------+
sd''''fasdf' | -5     |
| 1     | aasdfasdf         | -1     |
| 2     | aasd'fasdf'       | -2     |
| 3     | 'aasd'fasdf'      | -3     |
| 4     | 'aasd             | fasdf' |
| 5     | 'a	a
| 6     | 'asdf             | qqqq   |
| 7'    | 'asdf'            | '-7'   |
| 8     | '                 | -8     |
| 9     | asdfa	-9          | NULL   |
| asdf' | -6                | NULL   |
+-------+-------------------+--------+

delete from t_my_loaddata_test;
load data 
infile 'data_for_mysqltest_loaddata/escape_enclosed_short_separator_test.dat'
ignore
into table t_my_loaddata_test
fields enclosed by '\'';
select * from t_my_loaddata_test order by c1;
+------+-------------------+------+
| c1   | c2                | c3   |
+------+-------------------+------+
  | NULL |
9	asdfa	-9
asdf    | -6   |
sd''''fasdf' | -5   |
| 1    | aasdfasdf         | -1   |
| 2    | aasd'fasdf'       | -2   |
| 3    | aasd'fasdf        | -3   |
| 4    | aasd	fasdf        | -4   |
| 5    | 'a	a
| 6    | asdf	qqqq
| 7'   | 'asdf'            | -7   |
| 8    | '	-8
