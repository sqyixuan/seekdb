drop table if exists t_my_loaddata_test;
create table t_my_loaddata_test (
c1 tinyint,
c2 smallint,
c3 mediumint,
c4 int,
c5 number,
c6 float,
c7 double,
c8 datetime,
c9 timestamp,
c10 date,
c11 varchar(10),
c12 char
);
load data
infile 'data_for_mysqltest_loaddata/data_escape_special.dat'
ignore
into table t_my_loaddata_test;
select * from t_my_loaddata_test;
