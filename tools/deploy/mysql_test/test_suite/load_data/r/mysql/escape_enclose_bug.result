drop table if exists t_my_loaddata_test;
create table t_my_loaddata_test(c1 int primary key, c2 varchar(1000), c3 varchar(1000));
load data infile 'data_for_mysqltest_loaddata/enclose_with_escape_1.dat' into table t_my_loaddata_test
fields terminated by ',' enclosed by '"' escaped by '\\';
select * from t_my_loaddata_test order by 1;
c1	c2	c3
1	a,b	END
2	a,b"	END
3	a","b	END
4	"abc"	NULL
delete from t_my_loaddata_test;
load data infile 'data_for_mysqltest_loaddata/enclose_with_escape_1.dat' into table t_my_loaddata_test
fields terminated by ',' enclosed by '"' escaped by '"';
select * from t_my_loaddata_test order by 1;
c1	c2	c3
1	a,b	END
2	a,b\","END	NULL
3	a\	\"b"
4	abc\	NULL
delete from t_my_loaddata_test;
load data infile 'data_for_mysqltest_loaddata/enclose_with_escape_2.dat' into table t_my_loaddata_test
fields terminated by ',' enclosed by '"' escaped by '\\';
select * from t_my_loaddata_test order by 1;
c1	c2	c3
1	"	END
2	abc"def	END
3	abc","END	NULL
4	a"bc	END
5	a"tb	c	END
delete from t_my_loaddata_test;
load data infile 'data_for_mysqltest_loaddata/enclose_with_escape_2.dat' into table t_my_loaddata_test
fields terminated by ',' enclosed by '"' escaped by '"';
select * from t_my_loaddata_test order by 1;
c1	c2	c3
1	"	END
2	abc"def	END
3	abc","END	NULL
4	a"bc	END
5	a"tb\tc	END
delete from t_my_loaddata_test;
drop table t_my_loaddata_test;
