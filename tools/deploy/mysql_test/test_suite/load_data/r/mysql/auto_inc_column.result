drop table if exists t_my_loaddata_test;
create table t_my_loaddata_test (c1 CHAR(152) ,c2 INTEGER(127) ,c3 VARBINARY(76) ,c4 VARBINARY(63) ,c5 TIME,c6 TIMESTAMP(3)  NOT NULL default 0,c7 DATETIME,c8 INTEGER(127)  auto_increment,c9 INTEGER(127) ,c10 DECIMAL(64,16) ,c11 BIGINT(127) ,c12 CHAR(152) ,c13 BINARY(82) ,c14 CHAR(152) ,c15 VARCHAR(86) , primary key(c8,c15,c12))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c8,c15) PARTITIONS 20;
load data infile 'data_for_mysqltest_loaddata/auto_inc_column.dat'  into table t_my_loaddata_test fields terminated by ',';
