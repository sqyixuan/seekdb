result_format: 4


drop table if exists t_my_loaddata_test;
drop table if exists news_item;
create table t_my_loaddata_test (c1 varchar(16384));
load data infile 'data_for_mysqltest_loaddata/long_varchar.dat' into table t_my_loaddata_test;
select length(c1) LEN from t_my_loaddata_test;
+-------+
| LEN   |
+-------+
| 16384 |
+-------+
drop table t_my_loaddata_test;

CREATE TABLE news_item (
ni_id BIGINT(12) NOT NULL,
ni_headline VARCHAR(80) NOT NULL,
ni_summary VARCHAR(255) NOT NULL,
ni_item MEDIUMBLOB NOT NULL,
ni_dts DATETIME NOT NULL,
ni_source VARCHAR(30) NOT NULL,
ni_author VARCHAR(30),
PRIMARY KEY (ni_id)
) ;

LOAD DATA INFILE "data_for_mysqltest_loaddata/mediumblob.dat" INTO TABLE news_item FIELDS TERMINATED BY "|";
select length(ni_item) LEN from news_item;
+--------+
| LEN    |
+--------+
| 100000 |
| 100000 |
| 100000 |
| 100000 |
| 100000 |
| 100000 |
| 100000 |
| 100000 |
| 100000 |
| 100000 |
+--------+
drop table news_item;


