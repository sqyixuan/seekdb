result_format: 4


drop table if exists t_my_loaddata_test;
create table t_my_loaddata_test (c1 varchar(100), c2 varchar(100), c3 varchar(100));

delete from t_my_loaddata_test;
load data
infile 'data_for_mysqltest_loaddata/escape_enclosed_long_separator_test.dat'
ignore
into table t_my_loaddata_test
fields terminated by '__';
select * from t_my_loaddata_test;
+------+------------------------------------------+------+
| c1   | c2                                       | c3   |
+------+------------------------------------------+------+
| 1    | 'Normal'                                 | -1   |
| 2    | 'An enclose char ' in middle'            | -2   |
| 3    | 'An enclose char in tail''               | -3   |
| 4    | 'missing end enclose char                | -4   |
| 5    | missing begin enclose char'              | -5   |
| 6    | 'an enclose char ' is escaped'           | -6   |
| 7    | 'escape the head enclose char            | -7   |
| 8    | \'escaped\'escape char with enclose char | -8   |
| 9    | asdfa__-9                                | NULL |
+------+------------------------------------------+------+

delete from t_my_loaddata_test;
load data 
infile 'data_for_mysqltest_loaddata/escape_enclosed_long_separator_test.dat'
ignore
into table t_my_loaddata_test
fields enclosed by '\'' terminated by '__';
select * from t_my_loaddata_test;
+------+-------------------------------------------------------------------------------------------------+------+
| c1   | c2                                                                                              | c3   |
+------+-------------------------------------------------------------------------------------------------+------+
4__'missing end enclose char__-4__
5__missing begin enclose char | -5   |
| 1    | Normal                                                                                          | -1   |
| 2    | An enclose char ' in middle                                                                     | -2   |
| 3    | An enclose char in tail'__-3__
| 6    | an enclose char ' is escaped                                                                    | -6   |
| 7    | 'escape the head enclose char                                                                   | -7   |
| 8    | \'escaped\'escape char with enclose char                                                        | -8   |
| 9    | asdfa__-9                                                                                       | NULL |
+------+-------------------------------------------------------------------------------------------------+------+

drop table t_my_loaddata_test;
