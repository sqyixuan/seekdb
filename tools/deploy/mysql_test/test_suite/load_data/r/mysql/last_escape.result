drop table if exists t_my_loaddata_test;
create table t_my_loaddata_test (c1 int primary key, c2 varchar(100), c3 varchar(100));
load data
infile 'data_for_mysqltest_loaddata/last_escape.dat'
ignore
into table t_my_loaddata_test
fields enclosed by '';
select * from t_my_loaddata_test;
c1	c2	c3
1	asdfasdf'	////
2	asdfasdf'	////
3	asdfasdf\'	////
4	asdfasdf\'	////
5	asdfasdf	////	NULL
6	asdfasdf\	////
7	asdfasdf\	////	NULL
drop table t_my_loaddata_test;
create table t_my_loaddata_test (c1 int primary key, c2 varchar(100), c3 varchar(100));
load data
infile 'data_for_mysqltest_loaddata/last_escape2.dat'
ignore
into table t_my_loaddata_test
fields enclosed by '\'';
select * from t_my_loaddata_test;
c1	c2	c3
1	asdfasdf'	////
2	asdfasdf	////
3	asdfasdf\	////
4	asdfasdf\'	////
drop table t_my_loaddata_test;
