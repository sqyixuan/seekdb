# owner: muwei.ym
# group: storage
# desc: test pct_free

--disable_warnings
drop table if exists test;
--enable_warnings

create table test (c1 int primary key, c2 varchar(2048)) compression = 'none', pctfree = 30;

--disable_query_log
--disable_result_log

--let $count=0
while ($count < 3000)
{
  --let $stmt=INSERT INTO test VALUES($count, repeat($count,512))
  eval $stmt;
  inc $count;
}

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc


connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'test', table_id, 1);
let $tenant_id = query_get_value(select tenant_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id, tenant_id, 1);
let $ls_id = query_get_value(select 1 as ls_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id, ls_id, 1);
let $tablet_id = query_get_value(select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $table_id, tablet_id, 1);

let $stmt=select /*+ QUERY_TIMEOUT (10000000000000) */ (occupy_size / (2<<20)) < 0.75 from oceanbase.__all_virtual_tablet_sstable_macro_info where macro_block_type = 'data_block' and tablet_id=$tablet_id limit 1;
--disable_query_log
eval $stmt;

disconnect obsys;

connection default;
drop table test;