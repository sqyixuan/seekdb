--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dingjincheng.djc
# owner group: sql
# tags: optimizer
# description: test dynamic sampling feature

--disable_warnings
drop table if exists t_no_pk, t_pk, t_no_pk_part, t_pk_part;
--enable_warnings

create table t_no_pk(c1 int, c2 int, c3 int);

create table t_pk(c1 int, c2 int, c3 int, primary key(c1));

create table t_no_pk_part(c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;

create table t_pk_part(c1 int, c2 int, c3 int, primary key(c1)) partition by hash(c1) partitions 4;

