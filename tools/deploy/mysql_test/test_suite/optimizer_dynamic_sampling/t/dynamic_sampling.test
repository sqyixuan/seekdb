##bug:

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 varchar(20),
                c3 tinytext, c4 blob,
                c5 mediumtext, c6 longtext,
                c7 json, c8 geometry);

--disable_result_log
