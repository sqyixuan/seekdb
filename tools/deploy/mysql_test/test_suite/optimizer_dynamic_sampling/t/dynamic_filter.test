
# owner: wuyuming.wym
# owner group: sql
# tags: optimizer

connect(sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int, index i1(c1,c2,c3));
insert into t1 select uniform(0, 9, random(1)), uniform(0, 9, random(2)), uniform(0, 9, random(3)), uniform(0, 9, random(4)) from table(generator(10000));

create table t2(c1 int, c2 int, c3 int, c4 int);
insert into t2 values (1,1,1,1);

--enable_result_log
--enable_query_log
set ob_enable_transformation = 0;
set cardinality_estimation_model = 0;

--result_format 4

select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = 1 and c3 = 1 and c4 = 1;
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = 1 and c3 = 1 and c4 = (select 1 from dual);
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = 1 and c3 = (select 1 from dual) and c4 = 1;
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = (select 1 from dual) and c3 = 1 and c4 = 1;
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = 1 and c4 = (select 1 from dual);
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c3 = 1 and c4 = (select 1 from dual);
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = 1 and c3 = (select 1 from dual);
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c3 = (select 1 from dual) and c4 = 1;
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = (select 1 from dual) and c3 = 1;
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = (select 1 from dual) and c4 = 1;
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c4 = (select 1 from dual);
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c3 = (select 1 from dual);
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = (select 1 from dual);
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = (select 1 from dual) and c3 = 1 and c4 = (select 1 from dual);
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = 1 and c3 = (select 1 from dual) and c4 = (select 1 from dual);
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = (select 1 from dual) and c3 = (select 1 from dual) and c4 = 1;
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = (select 1 from dual) and c4 = (select 1 from dual);
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c3 = (select 1 from dual) and c4 = (select 1 from dual);
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = (select 1 from dual) and c3 = (select 1 from dual);
--source mysql_test/include/check_rows.inc
select /*+index(t1 i1) dynamic_sampling(1)*/ count(*) from t1 where c1 = (select 1 from dual) and c3 = (select 1 from dual) and c4 = (select 1 from dual);
--source mysql_test/include/check_rows.inc

set ob_enable_transformation = 1;
explain extended_noaddr select /*+dynamic_sampling(1) query_timeout(10000000)*/ count(*) from t2 v1, t2 v2 where (v1.c1 = v2.c1 or v1.c2 = v2.c2) and v1.c3 = 1 + sleep(0.6);

--error 4016
explain extended_noaddr select /*+dynamic_sampling(1) query_timeout(1000000)*/ count(*) from t2 v1, t2 v2 where (v1.c1 = v2.c1 or v1.c2 = v2.c2) and v1.c3 = 1 + sleep(0.6);

drop table t1,t2;