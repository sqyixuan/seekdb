# owner: wuyuming.wym
# owner group: sql
# tags: optimizer

connect(sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection sys;
alter system set_tp tp_name = EN_THROW_DS_ERROR, error_code = 4016, frequency = 1;
connection default;

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

set names gb18030;

create table t1(c1 int, c2 int, c3 int)
partition by range(c1)
(partition `10` values less than (10), partition `20` values less than (20), partition `30` values less than (30));

create table t2(c1 int, c2 int, c3 int)
partition by range(c1) subpartition by range (c2)
subpartition template(subpartition `010` values less than (10), subpartition `020` values less than (20), subpartition `030` values less than (30))
(partition `10` values less than (10), partition `20` values less than (20), partition `30` values less than (30));

CREATE TABLE t3(c1 INT,c2 INT,c3 INT)
PARTITION BY RANGE(c1)
SUBPARTITION BY RANGE(c2)
(PARTITION `10` VALUES LESS THAN(10)
   (SUBPARTITION `1010` VALUES LESS THAN(10),
    SUBPARTITION `1020` VALUES LESS THAN(20),
    SUBPARTITION `1030` VALUES LESS THAN(30)
   ),
  PARTITION `20` VALUES LESS THAN(20)
   (SUBPARTITION `2010` VALUES LESS THAN(10),
    SUBPARTITION `2020` VALUES LESS THAN(20),
    SUBPARTITION `2030` VALUES LESS THAN(30),
    SUBPARTITION `2040` VALUES LESS THAN(40)
   ),
  PARTITION `30` VALUES LESS THAN(30)
   (SUBPARTITION `3010` VALUES LESS THAN(10),
    SUBPARTITION `3020` VALUES LESS THAN(20),
    SUBPARTITION `3030` VALUES LESS THAN(30)
  )
);

create table t4(c1 int, c2 int, c3 int)
partition by range(c1)
(partition ```p1``` values less than (10), partition `��` values less than (20), partition ``` ��``` values less than (30));

set names utf8mb4;

insert into t1 select abs(random(1)) % 30, abs(random(2)) % 30, abs(random(3)) % 30 from table(generator(100));
insert into t2 select abs(random(1)) % 30, abs(random(2)) % 30, abs(random(3)) % 30 from table(generator(100));
insert into t3 select abs(random(1)) % 30, abs(random(2)) % 30, abs(random(3)) % 30 from table(generator(100));
insert into t4 select abs(random(1)) % 30, abs(random(2)) % 30, abs(random(3)) % 30 from table(generator(100));

--result_format 4
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t1 where c1 < 20 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t1 where c1 < 10 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t1 where c2 < 10 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t1 where c2 < 20 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t1 where c1 < 20 and c2 < 20 and c3 > 1;

explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t2 where c1 < 20 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t2 where c1 < 10 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t2 where c2 < 10 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t2 where c2 < 20 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t2 where c1 < 20 and c2 < 20 and c3 > 1;

explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t3 where c1 < 20 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t3 where c1 < 10 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t3 where c2 < 10 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t3 where c2 < 20 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t3 where c1 < 20 and c2 < 20 and c3 > 1;

explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t4 where c1 < 20 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t4 where c1 < 10 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t4 where c1 between 12 and 19 and c3 > 1;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t4 where c1 between 22 and 29 and c3 > 1;

set names gb18030;

--error 5018
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t4 where c1 < 20 and c3 < 25;
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t4 where c1 < 10 and c3 < 25;
--error 5018
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t4 where c1 between 12 and 19 and c3 < 25;
--error 1735
explain extended_noaddr select /*+dynamic_sampling(1)*/ * from t4 where c1 between 22 and 29 and c3 < 25;

drop table t1,t2,t3,t4;
connection sys;
alter system set_tp tp_name = EN_THROW_DS_ERROR, error_code = 4016, frequency = 0;
connection default;