alter system set_tp tp_name = EN_THROW_DS_ERROR, error_code = 4016, frequency = 1;
drop table if exists t1,t2,t3,t4;
set names gb18030;
create table t1(c1 int, c2 int, c3 int)
partition by range(c1)
(partition `10` values less than (10), partition `20` values less than (20), partition `30` values less than (30));
create table t2(c1 int, c2 int, c3 int)
partition by range(c1) subpartition by range (c2)
subpartition template(subpartition `010` values less than (10), subpartition `020` values less than (20), subpartition `030` values less than (30))
(partition `10` values less than (10), partition `20` values less than (20), partition `30` values less than (30));
CREATE TABLE t3(c1 INT,c2 INT,c3 INT)
PARTITION BY RANGE(c1)
SUBPARTITION BY RANGE(c2)
(PARTITION `10` VALUES LESS THAN(10)
(SUBPARTITION `1010` VALUES LESS THAN(10),
SUBPARTITION `1020` VALUES LESS THAN(20),
SUBPARTITION `1030` VALUES LESS THAN(30)
),
PARTITION `20` VALUES LESS THAN(20)
(SUBPARTITION `2010` VALUES LESS THAN(10),
SUBPARTITION `2020` VALUES LESS THAN(20),
SUBPARTITION `2030` VALUES LESS THAN(30),
SUBPARTITION `2040` VALUES LESS THAN(40)
),
PARTITION `30` VALUES LESS THAN(30)
(SUBPARTITION `3010` VALUES LESS THAN(10),
SUBPARTITION `3020` VALUES LESS THAN(20),
SUBPARTITION `3030` VALUES LESS THAN(30)
)
);
create table t4(c1 int, c2 int, c3 int)
partition by range(c1)
(partition ```p1``` values less than (10), partition `��` values less than (20), partition ``` ��``` values less than (30));
set names utf8mb4;
insert into t1 select abs(random(1)) % 30, abs(random(2)) % 30, abs(random(3)) % 30 from table(generator(100));
insert into t2 select abs(random(1)) % 30, abs(random(2)) % 30, abs(random(3)) % 30 from table(generator(100));
insert into t3 select abs(random(1)) % 30, abs(random(2)) % 30, abs(random(3)) % 30 from table(generator(100));
insert into t4 select abs(random(1)) % 30, abs(random(2)) % 30, abs(random(3)) % 30 from table(generator(100));
result_format: 4
