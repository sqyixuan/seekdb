drop table if exists t1,t2;
create table t1(c1 int, c2 int, c3 int, c4 int, index i1(c1,c2,c3));
insert into t1 select uniform(0, 9, random(1)), uniform(0, 9, random(2)), uniform(0, 9, random(3)), uniform(0, 9, random(4)) from table(generator(10000));
create table t2(c1 int, c2 int, c3 int, c4 int);
insert into t2 values (1,1,1,1);
set ob_enable_transformation = 0;
set cardinality_estimation_model = 0;
result_format: 4
