ALTER TABLE xg_fk_test1 ALTER COLUMN c3 SET DEFAULT 666;
#修改外键列默认值
ALTER TABLE xg_fk_test2 ALTER COLUMN a1 SET DEFAULT null;
ALTER TABLE xg_fk_test2 ALTER COLUMN a1 SET DEFAULT 456;
ALTER TABLE xg_fk_test2 ALTER COLUMN a3 SET DEFAULT 777;
ALTER TABLE xg_fk_test2 ALTER COLUMN a3 SET DEFAULT NULL;
desc xg_fk_test1;
Field	Type	Null	Key	Default	Extra
c1	int(11)	NO	PRI	123	
c2	varchar(30)	NO		aa	
c3	int(11)	YES	UNI	666	
desc xg_fk_test2;
Field	Type	Null	Key	Default	Extra
a1	int(20)	YES		456	
a2	varchar(30)	YES		NULL	
a3	int(11)	YES		NULL	
#修改主键列约束
ALTER TABLE xg_fk_test1 MODIFY COLUMN c1 int unique key;
ALTER TABLE xg_fk_test1 MODIFY COLUMN c1 int not null;
ALTER TABLE xg_fk_test1 MODIFY COLUMN c3 int not null;
ALTER TABLE xg_fk_test1 MODIFY COLUMN c3 int primary key;
ERROR 42000: Multiple primary key defined
alter table xg_fk_test1 modify column c1 int  foreign key(c1) REFERENCES xg_fk_test2(a3);
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'foreign key(c1) REFERENCES xg_fk_test2(a3)' at line 1
ALTER TABLE xg_fk_test1 MODIFY COLUMN c1 INT ADD CONSTRAINT fk_xg FOREIGN KEY(c1) REFERENCES xg_fk_test2(a3);
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'ADD CONSTRAINT fk_xg FOREIGN KEY(c1) REFERENCES xg_fk_test2(a3)' at line 1
#主键列为外键列
alter table xg_fk_test1 add CONSTRAINT zj_xg1 foreign key(c1) REFERENCES xg_fk_test2(a3);
ERROR HY000: Cannot add foreign key constraint
#修改外键列约束
ALTER TABLE xg_fk_test2 MODIFY COLUMN a1 int unique key;
ALTER TABLE xg_fk_test2 MODIFY COLUMN a3 int not null;
#删除主键列
alter table xg_fk_test1 drop column c1;
ERROR HY000: 'c1': used in a foreign key constraint
alter table xg_fk_test1 drop column c3;
ERROR HY000: 'c3': used in a foreign key constraint
#删除外键列
alter table xg_fk_test2 drop column a1;
ERROR HY000: 'a1': used in a foreign key constraint
alter table xg_fk_test2 drop column a3;
ERROR HY000: 'a3': used in a foreign key constraint
set foreign_key_checks	= off;
alter table xg_fk_test1 drop column c1;
ERROR HY000: 'c1': used in a foreign key constraint
alter table xg_fk_test1 drop column c3;
ERROR HY000: 'c3': used in a foreign key constraint
alter table xg_fk_test2 drop column a1;
ERROR HY000: 'a1': used in a foreign key constraint
alter table xg_fk_test2 drop column a3;
ERROR HY000: 'a3': used in a foreign key constraint
set foreign_key_checks	=  on;
ALTER TABLE xg_fk_test2 DROP INDEX a1;
ERROR HY000: 'a1': used in a foreign key constraint
#删除外键
alter table xg_fk_test2 drop FOREIGN key xgxg1;
alter table xg_fk_test2 drop FOREIGN key xgxg2;
drop table xg_fk_test1;
drop table xg_fk_test2;
drop database db1;
