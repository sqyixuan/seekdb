drop database if exists db1;
create database db1;
use db1;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
#不同数据类型外键。
#int
drop table if exists fk_int2;
Warnings:
Note	1051	Unknown table 'db1.fk_int2'
drop table if exists fk_int;
Warnings:
Note	1051	Unknown table 'db1.fk_int'
create table fk_int(
fk_int_c1 int primary KEY,
fk_int_c2 int unique key
);
create table fk_int2(
fk_int2_c1 int,
fk_int2_c2 int,
foreign key (fk_int2_c1) REFERENCES fk_int(fk_int_c1),
foreign key (fk_int2_c2) REFERENCES fk_int(fk_int_c2)
);
insert into fk_int values(1,1),(3,3),(5,5);
insert into fk_int2 values(3,3);
insert into fk_int2 values(6,6);
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
update fk_int2 set fk_int2_c1 = 5 where fk_int2_c2 = 3;
update fk_int2 set fk_int2_c1 = 2 where fk_int2_c1 = 5;
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
update fk_int2 set fk_int2_c2 = 4 where fk_int2_c1 = 5;
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
delete from fk_int where fk_int_c1 = 5;
ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails
delete from fk_int where fk_int_c2 = 3;
ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails
update fk_int set fk_int_c1 = 3 where fk_int_c2 = 5;
ERROR 23000: Duplicate entry '3' for key 'PRIMARY'
update fk_int set fk_int_c2 = 5 where fk_int_c2 = 3;
ERROR 23000: Duplicate entry '5' for key 'fk_int_c2'
delete from fk_int where fk_int_c1 = 5;
ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails
delete from fk_int where fk_int_c2 = 3;
ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails
select * from fk_int;
fk_int_c1	fk_int_c2
1	1
3	3
5	5
select * from fk_int2;
fk_int2_c1	fk_int2_c2
5	3
#关闭外键约束检查
set foreign_key_checks	= off;
insert into fk_int2 values(7,7),(3,1);
update fk_int2 set fk_int2_c1 = 100 where fk_int2_c2 = 1;
update fk_int2 set fk_int2_c2 = 100 where fk_int2_c1 = 5;
delete from fk_int where fk_int_c1 = 5;
delete from fk_int where fk_int_c2 = 1;
select * from fk_int;
fk_int_c1	fk_int_c2
3	3
select * from fk_int2;
fk_int2_c1	fk_int2_c2
5	100
7	7
100	1
