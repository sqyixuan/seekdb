#主外键表+dml+外键检查开关
drop table if exists t2;
drop table if exists t1;
create table t1(c1 int unique key ,c2 int primary key);
create table t2(
a1 int unique key,
a2 int primary key,
constraint aa foreign key(a1) REFERENCES t1(c1),
constraint bb foreign key(a2) REFERENCES t1(c2)
);
insert into t1 values(1,1),(3,3),(5,5);
insert into t2 values(1,1),(3,3);
set foreign_key_checks	= off;
insert into t2 values(5,5),(2,2);
set foreign_key_checks	= on;
#OB报错，mysql正常执行。
update t2 set a1 = 2 where a2 = 2;
#DDL+外键检查开关
set foreign_key_checks	= on;
drop table if exists ddl_fk_check2;
