drop function if exists func_test;
create function func_test(aa int,bb int)
RETURNS int
begin
if aa = bb then
insert into pro_test2 values(30,'san');
elseif aa > bb then
update pro_test2 set c1 = 200 where c1 = -30;
else
delete from pro_test where c1 = 90;
end if;
RETURN 1;
end
/
