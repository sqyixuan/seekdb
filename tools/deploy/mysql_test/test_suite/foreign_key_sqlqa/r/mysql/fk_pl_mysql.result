#function + dml触发外键
set foreign_key_checks	= 1;
drop function if exists func_test;
create function func_test(aa int,bb int)
RETURNS int
begin
if aa = bb then
insert into pro_test2 values(-30,'san');
elseif aa > bb then
update pro_test2 set c1 = 110 where c1 is null;
else
delete from pro_test where c1 = 50;
end if;
RETURN 1;
end
/
select func_test(1,1);
func_test(1,1)
1
select func_test(2,1);
func_test(2,1)
1
select func_test(1,2);
func_test(1,2)
1
