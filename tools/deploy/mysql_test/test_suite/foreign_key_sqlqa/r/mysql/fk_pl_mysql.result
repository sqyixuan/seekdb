#procedure + dml触发外键
drop table if exists pro_test2;
Warnings:
Note	1051	Unknown table 'db1.pro_test2'
drop table if exists pro_test;
Warnings:
Note	1051	Unknown table 'db1.pro_test'
create table pro_test(
c1 int not null unique key,
c2 varchar(30) primary key
);
create table pro_test2(
c1 int,
c2 varchar(30),
FOREIGN KEY(c1) REFERENCES pro_test(c1),
FOREIGN KEY(c2) REFERENCES pro_test(c2)
);
insert into pro_test values(-30,'SAN'),(50,'WU'),(-70,'Qi'),(90,'Jiu'),(-110,'YiYi');
insert into pro_test2 values(-30,'SAN'),(50,'WU'),(-70,'Qi'),(90,'Jiu');
select * from pro_test;
