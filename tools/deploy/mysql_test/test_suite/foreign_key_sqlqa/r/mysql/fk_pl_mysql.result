-70	Qi
-30	SAN
50	WU
-110	YiYi
select * from pro_test2;
c1	c2
-30	SAN
50	WU
-70	Qi
90	Jiu
drop procedure if exists pro1;
CREATE  PROCEDURE pro1(in i int,j int)
begin
while i <= j DO
insert into pro_test2 values(null,'YiYi');
set i = i + 1;
end WHILE;
end
/
call pro1(1,1);
select * from pro_test2;
c1	c2
-30	SAN
50	WU
-70	Qi
90	Jiu
NULL	YiYi
drop procedure if exists pro1;
create procedure pro1(aa int,bb int)
begin
if aa = bb then
insert into pro_test2 values(-30,'san');
elseif aa > bb then
update pro_test2 set c1 = 110 where c1 is null;
else
delete from pro_test where c1 = 50;
end if;
end
/
call pro1(1,1);
call pro1(2,1);
