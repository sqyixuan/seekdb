drop database if exists db1;
create database db1;
use db1;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
#PL+dml触发外键
#trigger(after) +dml触发外键
drop table if exists tg_test2;
Warnings:
Note	1051	Unknown table 'db1.tg_test2'
drop table if exists tg_test;
Warnings:
Note	1051	Unknown table 'db1.tg_test'
create table tg_test(
c1 int PRIMARY KEY,
c2 varchar(30) unique
);
create table tg_test2(
c1 int,
c2 varchar(30),
FOREIGN key(c1) REFERENCES tg_test(c1),
FOREIGN key(c2) REFERENCES tg_test(c2)
);
insert into tg_test values(1,'a'),(3,'b'),(5,'c'),(7,null);
insert into tg_test2 values(1,'a'),(3,'b'),(5,'c');
drop TRIGGER if exists tr1;
Warnings:
Note	1360	Trigger does not exist
create trigger tr1
after update on tg_test
for each row 
begin
insert into tg_test2 values(3,'a'),(5,'dd');
end
/
