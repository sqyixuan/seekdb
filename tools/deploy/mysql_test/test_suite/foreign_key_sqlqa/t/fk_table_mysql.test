##owner: qiaolinjun.qlj
##owner group: 创新研发
##description: 不同表中使用外键
##tags: foreign key
##author : wb-zwc01059807
 
--disable_warnings
drop database if exists db1;
--enable_warnings
 
create database db1;
use db1;
 
 
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;



--echo	#不同表中使用外键

--echo	#hash分区表外键自引用
drop table if exists hash_tb_zyy;

--echo	#OB执行成功，mysql报错 ERROR 1506 (HY000): Foreign keys are not yet supported in conjunction with partitioning
create table hash_tb_zyy(
c1 int primary key,
c2 varchar(30) not null,
c3 int not null,
FOREIGN key(c3) REFERENCES hash_tb_zyy(c1)
)partition by hash(c1) partitions 4;


drop table if exists hash_tb;
create table hash_tb(
c1 int primary KEY,
c2 varchar(30) not null default 'aa'
)partition by hash(c1) partitions 4;


drop table if exists hash_tb2;
create table hash_tb2(
a1 int primary KEY,
a2 varchar(60) not null default 'cc',
foreign key(a1) REFERENCES hash_tb(c1)
)
partition by hash(a1) partitions 4;




drop table if exists customers;
drop table if exists orders;

CREATE TABLE orders (
    order_id INT NOT NULL AUTO_INCREMENT,
    customer_id INT NOT NULL,
    order_date DATE NOT NULL,
    amount DECIMAL(10,2) NOT NULL,
    PRIMARY KEY (order_id, order_date)
) PARTITION BY RANGE (YEAR(order_date))
(
    PARTITION p0 VALUES LESS THAN (2015),
    PARTITION p1 VALUES LESS THAN (2016),
    PARTITION p2 VALUES LESS THAN (2017),
    PARTITION p3 VALUES LESS THAN (2018),
    PARTITION p4 VALUES LESS THAN MAXVALUE
);

CREATE TABLE customers (
    customer_id INT NOT NULL,
    name VARCHAR(50) NOT NULL,
    email VARCHAR(50) NOT NULL,
    PRIMARY KEY (customer_id)
) PARTITION BY HASH (customer_id)
PARTITIONS 4;

--echo	#ob创建成功，MYSQL不支持外键与分区一起使用。
ALTER TABLE orders ADD CONSTRAINT fk_orders_customers FOREIGN KEY (customer_id) REFERENCES customers (customer_id);





--echo	#range分区外键引用
--echo	#分区键作为主键列  
drop table if exists range_tb_zyy;
create table range_tb_zyy(
c1 int primary key not null AUTO_INCREMENT,
c2 varchar(30) not null,
c3 int not null,
FOREIGN key(c3) REFERENCES range_tb_zyy(c1)
)PARTITION BY RANGE(c1)
(
PARTITION p0 VALUES less than(10),
PARTITION p1 VALUES less than(15),
PARTITION p2 VALUES less than(MAXVALUE)
);

--echo	#外键作为分区列报错，MYSQL不支持分区列作为外键
drop table if exists range_tb_zyy;
--error 1503
create table range_tb_zyy(
c1 int  unique  key not null AUTO_INCREMENT,
c2 varchar(30) unique key  not null,
c3 int  unique key not null,
FOREIGN key(c1) REFERENCES range_tb_zyy(c3)
)PARTITION BY RANGE(c1)
(
PARTITION p0 VALUES less than(10),
PARTITION p1 VALUES less than(15),
PARTITION p2 VALUES less than(MAXVALUE)
);


--echo	#list分区外键自引用
drop table if exists list_tb_zyy;
create table list_tb_zyy(
c1 int unique key,
c2 int,
FOREIGN key(c2) REFERENCES list_tb_zyy(c1)
)partition by list(c1)
(
PARTITION p1 values in(1,2,3),
PARTITION p2 values in(4,5,6),
PARTITION p3 values in(7,8,9)
);




--echo	#key分区外键自引用
drop table if exists key_tb_zyy;
create table key_tb_zyy(
c1 int primary key,
c2 varchar(30),
c3 int not null,
c4 int not null,
c5 int not null,
key(c2,c3,c4,c5),
FOREIGN key(c3) REFERENCES key_tb_zyy(c1)
)PARTITION BY key(c1)
partitions 4;



--echo	#视图上创建外键
drop view if exists v_t1;
drop table if exists t1;
drop table if exists t2;

create table t1(
c1 int primary key
);

create view v_t1 as select * from t1;

create table t2(
a1 int primary key
);

--error 1064
alter view v_t1 add CONSTRAINT fk_v_t1 FOREIGN KEY(c1) REFERENCES t2(a1) on DELETE CASCADE;


--echo #复制表上创建外键
drop table if exists copy_test1;
drop table if exists test1;
create table test1(
c1 int primary key,
c2 varchar(30) not null unique key,
c3 int,
c4 int unique 
);


create table copy_test1 as select * from test1;

alter table copy_test1 add CONSTRAINT fk_ct_c1 FOREIGN KEY(c1) REFERENCES test1(c1);
alter table copy_test1 add CONSTRAINT fk_ct_c4 FOREIGN KEY(c4) REFERENCES test1(c4);

--error 1215
alter table copy_test1 add CONSTRAINT fk_ct_c3 FOREIGN KEY(c3) REFERENCES test1(c3);

--error 5320
alter table copy_test1 modify c1 int AUTO_INCREMENT;



drop table if exists copy_test1;
create table copy_test1 like  test1;

alter table copy_test1 add CONSTRAINT fk_ct_c3_p FOREIGN KEY(c3) REFERENCES copy_test1(c1);
alter table copy_test1 add CONSTRAINT fk_ct_c3_u FOREIGN KEY(c3) REFERENCES copy_test1(c4);
alter table test1 add CONSTRAINT fk_test_c1 FOREIGN KEY(c1) REFERENCES copy_test1(c1);
alter table test1 add CONSTRAINT fk_test_c2 FOREIGN KEY(c2) REFERENCES copy_test1(c2);


--error 1452
insert into copy_test1 values(1,'a',1,2);

insert into copy_test1 values(1,'a',1,1);
insert into test1 values(1,'a',2,3);
select * from copy_test1;
select * from test1;

drop table copy_test1,test1;


--echo	#临时表创建外键
--error 1235
create TEMPORARY table temp_test1(
c1 int primary key,
c2 int unique,
c3 int,
CONSTRAINT fk_temp_test1 FOREIGN key(c3) REFERENCES temp_test1(c1) on DELETE CASCADE,
CONSTRAINT fk_temp_test1 FOREIGN key(c3) REFERENCES temp_test1(c2) on DELETE CASCADE
);




drop database db1;
