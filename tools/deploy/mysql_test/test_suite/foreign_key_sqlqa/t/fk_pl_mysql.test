##owner group: 创新研发
##description: pl中触发外键
##tags: foreign key
##author : wb-zwc01059807
 
--disable_warnings
drop database if exists db1;
--enable_warnings
 
create database db1;
use db1;
 
 
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;



--echo	#PL+dml触发外键
--echo	#trigger(after) +dml触发外键
drop table if exists tg_test2;
drop table if exists tg_test;

create table tg_test(
c1 int PRIMARY KEY,
c2 varchar(30) unique
);

create table tg_test2(
c1 int,
c2 varchar(30),
FOREIGN key(c1) REFERENCES tg_test(c1),
FOREIGN key(c2) REFERENCES tg_test(c2)
);

insert into tg_test values(1,'a'),(3,'b'),(5,'c'),(7,null);
insert into tg_test2 values(1,'a'),(3,'b'),(5,'c');


drop TRIGGER if exists tr1;
delimiter /;
create trigger tr1
after update on tg_test
for each row 
begin
	insert into tg_test2 values(3,'a'),(5,'dd');
end
/
delimiter ;/

--error 1451
update tg_test set c1 = 9 where c1 = 1;

set foreign_key_checks	= 0;
update tg_test set c1 = 9 where c1 = 1;

select * from tg_test;
select * from tg_test2;


set foreign_key_checks	= 1;

drop TRIGGER if exists tr1;
delimiter /;
create trigger tr1
after insert on tg_test
for each row 
begin
	insert into tg_test2 values(3,'a'),(5,'dd');
end
/
delimiter ;/

--error 1452
insert into tg_test values(11,'qq');

set foreign_key_checks	= 0;
--echo	#OB与MYSQL rows affected不一致。
insert into tg_test values(11,'qq');

select * from tg_test;
select * from tg_test2;


set foreign_key_checks	= 1;

drop TRIGGER if exists tr1;
delimiter /;
create trigger tr1
after delete on tg_test
for each row 
begin
	delete from  tg_test2 where c2 = 'dd';
end
/
delimiter ;/

--error 1451
delete from tg_test where c1 = 5;
--echo	#OB与mysql rows affected不一致。
delete from tg_test where c2 is null;

select * from tg_test;
select * from tg_test2;

set foreign_key_checks	= 0;

delete from tg_test where c1 = 3;
select * from tg_test;
select * from tg_test2;

set foreign_key_checks	= 1;


--echo	#trigger(before) +dml触发外键
drop table if exists tg_test2;
drop table if exists tg_test;

create table tg_test(
c1 int PRIMARY KEY,
c2 varchar(30) unique
);

create table tg_test2(
c1 int,
c2 varchar(30),
FOREIGN key(c1) REFERENCES tg_test(c1),
FOREIGN key(c2) REFERENCES tg_test(c2)
);

insert into tg_test values(1,'a'),(3,'b'),(5,'c'),(7,null);
insert into tg_test2 values(1,'a'),(3,'b'),(5,'c');


drop TRIGGER if exists tr1;
delimiter /;
create trigger tr1
BEFORE update on tg_test2
for each row 
begin
	insert into tg_test values(3,'a'),(5,'dd');
end
/
delimiter ;/

--echo	#OB与MYSQL报错信息不一致。
--error 1062
update tg_test2 set c2 = null where c2 = 'a';

set foreign_key_checks	= 0;
--error 1062
update tg_test2 set c1 = 7 where c1 = 1;

select * from tg_test;
select * from tg_test2;

set foreign_key_checks	= 1;




drop TRIGGER if exists tr1;
delimiter /;
create trigger tr1
BEFORE insert on tg_test2
for each row 
begin
	update tg_test set c1 = 9 where c2 is null;
end
/
delimiter ;/

#--echo	#OB报错，mysql正常执行。
#--error 1442
#insert into tg_test2 values(9,null);


select * from tg_test;
select * from tg_test2;


drop TRIGGER if exists tr1;
delimiter /;
create trigger tr1
BEFORE delete on tg_test2
for each row 
begin
	delete from tg_test where c2 is null;
end
/
delimiter ;/

--echo	#ob与mysql rows affected不一致。
delete from tg_test2 where c2 = 'b';

select * from tg_test;
select * from tg_test2;

drop TRIGGER if exists tr1;
delimiter /;
create trigger tr1
BEFORE delete on tg_test2
for each row 
begin
	delete from tg_test where c2 = 'a';
end
/
delimiter ;/

--error 1451
delete from tg_test2 where c2 = 'c';

set foreign_key_checks	= 0;

--echo	#ob与mysql rows affected不一致。
delete from tg_test2 where c2 = 'c';


select * from tg_test;
select * from tg_test2;

set foreign_key_checks	= 1;


--echo	#procedure + dml触发外键
drop table if exists pro_test2;
drop table if exists pro_test;

create table pro_test(
c1 int not null unique key,
c2 varchar(30) primary key
);

create table pro_test2(
c1 int,
c2 varchar(30),
FOREIGN KEY(c1) REFERENCES pro_test(c1),
FOREIGN KEY(c2) REFERENCES pro_test(c2)
);

insert into pro_test values(-30,'SAN'),(50,'WU'),(-70,'Qi'),(90,'Jiu'),(-110,'YiYi');
insert into pro_test2 values(-30,'SAN'),(50,'WU'),(-70,'Qi'),(90,'Jiu');

select * from pro_test;
select * from pro_test2;


drop procedure if exists pro1;
DELIMITER /;
CREATE  PROCEDURE pro1(in i int,j int)
begin
    while i <= j DO
        insert into pro_test2 values(null,'YiYi');
        set i = i + 1;
    end WHILE;
end
/
DELIMITER ;/
call pro1(1,1);
select * from pro_test2;


drop procedure if exists pro1;
delimiter /;
create procedure pro1(aa int,bb int)
begin
    if aa = bb then
         insert into pro_test2 values(-30,'san');
    elseif aa > bb then
         update pro_test2 set c1 = 110 where c1 is null;
    else
         delete from pro_test where c1 = 50;
    end if;
end
/
delimiter ;/


call pro1(1,1);

--error 1452
call pro1(2,1);
--error 1451
call pro1(0,1);


set foreign_key_checks	= 0;

call pro1(2,1);
call pro1(0,1);

select * from pro_test;
select * from pro_test2;



--echo	#function + dml触发外键
set foreign_key_checks	= 1;

drop function if exists func_test;

delimiter /;
create function func_test(aa int,bb int)
RETURNS int
begin
    if aa = bb then
         insert into pro_test2 values(-30,'san');
    elseif aa > bb then
         update pro_test2 set c1 = 110 where c1 is null;
    else
         delete from pro_test where c1 = 50;
    end if;
    RETURN 1;
end
/
delimiter ;/

select func_test(1,1);
select func_test(2,1);
select func_test(1,2);

select * from pro_test;
select * from pro_test2;


drop function if exists func_test;

delimiter /;
create function func_test(aa int,bb int)
RETURNS int
begin
    if aa = bb then
         insert into pro_test2 values(30,'san');
    elseif aa > bb then
         update pro_test2 set c1 = 200 where c1 = -30;
    else
         delete from pro_test where c1 = 90;
    end if;
    RETURN 1;
end
/
delimiter ;/

--error 1452
select func_test(1,1);
--error 1452
select func_test(2,1);
--error 1451
select func_test(1,2);

select * from pro_test;
select * from pro_test2;

set foreign_key_checks	= 0;


select func_test(1,1);
select func_test(2,1);
select func_test(1,2);

select * from pro_test;
select * from pro_test2;

drop table pro_test2;
drop table pro_test;
drop function func_test;




drop database db1;
