insert into fk_decimal2 values(1.123456,-1.11111);
insert into fk_decimal2 values (3.3333,-6.6666);
insert into fk_decimal2 values (7.777,8.8);
insert into fk_decimal2 values (10.0001,null);

--error 1451
update fk_decimal set c1 = 20 where c2 = -6.6666;
--error 1452
update fk_decimal2 set a1 = 20 where a1 = 7.777000;

update fk_decimal2 set a1 = 3.333300 where a2 is null;
--error 1062
update fk_decimal set c1 = 3.333300 where c2 is null;

update fk_decimal set c1 = 10.54634 where c2 is null;

--error 1451
delete from fk_decimal where c1 = 1.123456;

delete from fk_decimal where c2 is null;
delete from fk_decimal2 where a2 is null;
delete from fk_decimal2 where a1 = 3.333300;

select * from fk_decimal;
select * from fk_decimal2;

set foreign_key_checks	= off;
insert into fk_decimal2 values(10,20);
update fk_decimal2 set a1 = 12 where a2 = -1.111110;
delete from fk_decimal where c1 = 1.123456;
select * from fk_decimal;
select * from fk_decimal2;


