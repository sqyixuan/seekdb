--echo	#datetime、year、timestamp、time
set foreign_key_checks	= on;

drop table if exists fk_date2;
drop table if exists fk_date;
create table fk_date(
c1 date not null primary key,
c2 datetime not null unique key,
c3 year not null unique key
);


create table fk_date2(
a1 date not null,
a2 datetime not null,
a3 year not null,
FOREIGN KEY (a1) REFERENCES fk_date(c1),
FOREIGN KEY (a2) REFERENCES fk_date(c2),
FOREIGN KEY (a3) REFERENCES fk_date(c3)
);

insert into fk_date values('2020-02-02','2020-02-02 02:02:02','2020');
insert into fk_date values('2021-06-06','2021-06-06 06:06:06','2021');
insert into fk_date values('2022-09-09','2022-09-09 09:09:09','2022');
insert into fk_date values('2023-12-12','2023-12-12 12:12:12','2023');

insert into fk_date2 values('2020-02-02','2020-02-02 02:02:02','2020');
insert into fk_date2 values('2021-06-06','2021-06-06 06:06:06','2021');
insert into fk_date2 values('2022-09-09','2022-09-09 09:09:09','2022');

select * from fk_date;
select * from fk_date2;

--error 1452
insert into fk_date2 values('2024-02-02','2020-02-02 02:02:02','2020');

set foreign_key_checks	= 0;

insert into fk_date2 values('2024-02-02','2020-02-02 02:02:02','2020');
update fk_date2 set a1 = '2024-04-04' where a3 = 2022;
delete from fk_date where c3 = 2022;

select * from fk_date;
select * from fk_date2;


set foreign_key_checks	= 1;
update fk_date2 set a1 = '2023-12-12' where a1 = '2024-02-02';
--error 1452
update fk_date2 set a1 = '2024-12-12' where a1 = '2024-04-04';

delete from fk_date2 where a3 = 2020;

select * from fk_date;
select * from fk_date2;


drop table fk_date2;
drop table fk_date;




--echo	#时间日期类型自引用外键。
drop table if exists fk_time_zyy;
create table fk_time_zyy(
c1 datetime not null unique key,
c2 year unique key,
c3 timestamp  unique key,
c4 time not null unique key,
c5 datetime,
c6 YEAR,
c7 timestamp,
c8 time,
FOREIGN KEY (c5) REFERENCES fk_time_zyy(c1),
FOREIGN KEY (c6) REFERENCES fk_time_zyy(c2),
FOREIGN KEY (c7) REFERENCES fk_time_zyy(c3),
FOREIGN KEY (c8) REFERENCES fk_time_zyy(c4)
);

insert into fk_time_zyy(c1,c2,c3,c4) values('2021-01-01 01:01:01',2021,'2021-02-02 02:02:02','03:03');
insert into fk_time_zyy values('2022-02-02 02:02:02',2022,'2022-04-04 04:04:04','04:04','2022-02-02 02:02:02',2022,'2022-04-04 04:04:04','04:04');
insert into fk_time_zyy values('2023-03-03 03:03:03',2023,'2023-03-03 03:03:03','06:06','2023-03-03 03:03:03',2023,'2023-03-03 03:03:03','06:06');

--echo	#修改null值
update fk_time_zyy set c5 ='2023-03-03 03:03:03' ,c6 =2022 ,c7 ='2022-04-04 04:04:04' ,c8 = '04:04:00' where c4='03:03:00';

--echo	#OB执行成功，mysql报错违反外键约束
#delete from fk_time_zyy where c7 = '2022/04/04 04/04/04';
delete from fk_time_zyy;

set foreign_key_checks	= 0;

insert into fk_time_zyy values('2023-05-01 01:01:01',2028,'2028-02-02 02:02:02','07:03','2030-06-07',2050,'2022-02-28','23:59:59');
update fk_time_zyy set c2 = 2090 where c5 = '2030-06-07';
delete from fk_time_zyy where c6 = 2050;

select * from fk_time_zyy;

drop table fk_time_zyy;




--echo	#varchar、char、text
set foreign_key_checks	= 1;
drop table if exists fk_string2;
drop table if exists fk_string;
create table fk_string(
c1 varchar(60),
c2 char(30)
);
CREATE unique INDEX idx_c1 ON fk_string (c1);
CREATE unique INDEX idx_c2 ON fk_string (c2);

create table fk_string2(
a1 varchar(60),
a2 char(30),
FOREIGN KEY (a1) REFERENCES fk_string(c1),
FOREIGN KEY (a2) REFERENCES fk_string(c2)
);


insert into fk_string values(null,null),('##','c6'),('张三','oo9'),('77q','88q');
insert into fk_string2 values('77q',null),('##','c6'),('张三','oo9');

--echo	#修改null值
update fk_string2 set a1 = '77q' where a2 is null;
update fk_string2 set a1 = null where a2 ='oo9';

select * from fk_string2;

delete from fk_string where c1 is null;

--error 1451
delete from fk_string where c1 ='##';

set foreign_key_checks	= 0;
insert into fk_string2 values('ZAQ','王维');
update fk_string set c1 = '66q' where c2 = 'c6';
delete from fk_string where c1 = '77q';

truncate fk_string;
drop table fk_string;

set foreign_key_checks	= 1;
--error 1452
insert into fk_string2 values('CC','DD');
--error 1452
update fk_string2 set a1 = 'WW' where a2 is null;
delete from fk_string2 where a2 is null;

--error 1215
create table fk_string(
c1 varchar(60),
c2 char(30)
);



--echo	#OB与mysql报错信息不一致。
--error 1215
create table fk_string(
c1 varchar(60) primary key,
c2 char(30)
);


create table fk_string(
c1 varchar(60) unique key,
c2 char(30) unique key
);

insert into fk_string values('AA','DD');
insert into fk_string2 values('AA','DD');

--error 1451
update fk_string set c1 = '##' where c2 = 'DD';
update fk_string2 set a2 = 'DD' where a1 is null;


delete from fk_string where c1 = '##';
delete from fk_string2 where a1 = 'ZAQ';

drop table fk_string2;
drop table fk_string;


drop table if exists fk_text2;
drop table if exists fk_text;

set foreign_key_checks	= 1;

create table fk_text(
c1 text(20)
);
CREATE unique INDEX idx_c1 ON fk_text (c1(20));

--echo #OB与MYSQL报错不一致。
--error 1215
create table fk_text2(
a1 text(20),
FOREIGN KEY (a1) REFERENCES fk_text(c1)
);


--echo	#varbinary、binary
set foreign_key_checks	= on;
drop table if exists t2;
drop table if exists t1;
create table t1(
c1 VARBINARY(30) primary key,
c2 BINARY(30) unique key
);

--error 5319
create table t2(
c1 VARBINARY(29),
c2 BINARY(29),
FOREIGN KEY(c1) REFERENCES t1(c1),
FOREIGN KEY(c2) REFERENCES t1(c2)
);

                    
create table t2(
c1 VARBINARY(30),
c2 BINARY(30),
FOREIGN KEY(c1) REFERENCES t1(c1),
FOREIGN KEY(c2) REFERENCES t1(c2)
);

insert into t1 values(1,null),(3,3),(7,7),(9,9),(5,5);
insert into t2 values(1,7),(3,3),(7,7),(5,5);

--error 1452
insert into t2 values(b'11',null);
insert into t2 values(3,null);

set foreign_key_checks	= 0;
insert into t2 values(b'11',null);
delete from t2 where c2 is null;

select * from t1;
select * from t2;

set foreign_key_checks	= 1;

update t1 set c2 = 11 where c1 = 1;

--error 1451
update t1 set c2 = 13 where c1 = 3;

set foreign_key_checks	= 0;
update t1 set c2 = 13 where c1 = 3;

delete from t1 where c1 = 1;

select * from t1;
select * from t2;

drop table t2;
drop table t1;


--echo	#enum、set
set foreign_key_checks	= on;
drop table if exists t2;
drop table if exists t1;
create table t1(
c1 enum('小学','初中','高中','大学') unique key,
c2 set('一年级','五年级','初二','高三','大四') unique key
);

create table t2(
c1 enum('小学','初中','高中','大学'),
c2 set('一年级','初二','高三','大四'),
FOREIGN KEY(c1) REFERENCES t1(c1),
FOREIGN KEY(c2) REFERENCES t1(c2)
);

insert into t1 values('小学','一年级'),('初中','初二'),('高中','高三'),('大学','大四');
insert into t1 values(null,'五年级');

insert into t2 values('小学','一年级'),('初中','初二'),('高中','高三'),('大学','大四');
--error 1265
insert into t2 values(null,'五年级');


select * from t1;
select * from t2;

update t2 set c1 = '初中' where c2 = '一年级';
update t2 set c1 = '高中' where c2 = '初二';

--error 1451
delete from t1 where c1 = '小学';

set foreign_key_checks	= 0;
delete from t1 where c1 = '小学';

set foreign_key_checks	= 1;
update t1 set c1 = '小学' where c1 is null;

select * from t1;
select * from t2;



drop table t2;
drop table t1;


--echo	#enum 和set 自引用外键列
drop table if exists t1;
--error 1215
create table t1 (
c1 enum('1','2','3') primary key,
c2 set('1','2','3'),
foreign key(c2) references t1(c1)
);



drop table if exists t1;
create table t1 (
c1 enum('1','2','3') primary key,
c2 enum('1','2','3'),
foreign key(c2) references t1(c1)
);

insert into t1 values(1,1);
--error 1452
insert into t1 values(2,3);
update t1 set c1 = 3 where c2 = 3;
delete from t1 where c1 = 1;



drop table if exists t1;
create table t1 (
c1 set('1','2','3') primary key,
c2 set('1','2','3'),
foreign key(c2) references t1(c1)
);

insert into t1 values(1,1);
--error 1452
insert into t1 values(2,3);
update t1 set c1 = 3 where c2 = 3;
delete from t1 where c1 = 1;

drop table t1;


--echo	#bit
set foreign_key_checks	= on;
drop table if exists fk_bit2;
drop table if exists fk_bit;
create table fk_bit(
c1 bit(64) primary key,
c2 bit(64) unique key
);

create table fk_bit2(
a1 bit(64) ,
a2 bit(64) ,
foreign key (a1) REFERENCES fk_bit(c1),
foreign key (a2) REFERENCES fk_bit(c2)
);

insert into fk_bit values (1,2);
insert into fk_bit values (3,3);
insert into fk_bit values (5,5);
insert into fk_bit values (7,8);

insert into fk_bit2 values (1,2);
insert into fk_bit2 values (3,3);

select hex(c1),hex(c2) from fk_bit;
select hex(a1),hex(a2) from fk_bit2;

--error 1452
insert into fk_bit2 values(10,5);
--error 1452
insert into fk_bit2 values(b'1010',5);
insert into fk_bit2 values(b'101',5);

--error 1452
update fk_bit2 set a1 = b'101010' where a1 = 5;
--error 1452
update fk_bit2 set a2 = b'101010' where a2 = 5;
update fk_bit2 set a1 = 7 where a2 = b'101';

--error 1451
delete from fk_bit where c1 = b'1';
--error 1451
delete from fk_bit where c1 = 7;

delete from fk_bit2 where a1 = b'11';
delete from fk_bit2 where a1 = 1;
select hex(c1),hex(c2) from fk_bit;
select hex(a1),hex(a2) from fk_bit2;

--echo	#bit类型外键自引用

drop table if exists fk_bit_zyy;
create table fk_bit_zyy (
    c1 bit(64) unique key,
    c2 bit(64) ,
    c3 bit(64) unique key,
    FOREIGN KEY (c3) REFERENCES fk_bit_zyy(c1),
    FOREIGN KEY (c2) REFERENCES fk_bit_zyy(c3)
);

--error 1452
insert into fk_bit_zyy values(1,2,3);

insert into fk_bit_zyy values(1,1,1);
insert into fk_bit_zyy values(2,2,2);
insert into fk_bit_zyy values(3,3,3);
select hex(c1),hex(c2),hex(c3) from fk_bit_zyy;

--echo	#OB与MYSQL报错信息不一致。
--error 1062
update fk_bit_zyy set c1 = 3 where c2 = 2;

--echo	#OB执行成功 ，mysql报错。
#delete from fk_bit_zyy where c1 = 3;


 
 
 
 


drop database db1;
