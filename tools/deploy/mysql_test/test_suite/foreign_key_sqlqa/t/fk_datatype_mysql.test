--disable_warnings
drop database if exists db1;
--enable_warnings

 
create database db1;
use db1;
 
 
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

 
 
 --echo	#不同数据类型外键。
--echo	#int
drop table if exists fk_int2;
drop table if exists fk_int;
create table fk_int(
fk_int_c1 int primary KEY,
fk_int_c2 int unique key
);

create table fk_int2(
fk_int2_c1 int,
fk_int2_c2 int,
foreign key (fk_int2_c1) REFERENCES fk_int(fk_int_c1),
foreign key (fk_int2_c2) REFERENCES fk_int(fk_int_c2)
);

insert into fk_int values(1,1),(3,3),(5,5);
insert into fk_int2 values(3,3);

--error 1452
insert into fk_int2 values(6,6);

update fk_int2 set fk_int2_c1 = 5 where fk_int2_c2 = 3;
--error 1452
update fk_int2 set fk_int2_c1 = 2 where fk_int2_c1 = 5;
--error 1452
update fk_int2 set fk_int2_c2 = 4 where fk_int2_c1 = 5;

--error 1451
delete from fk_int where fk_int_c1 = 5;
--error 1451
delete from fk_int where fk_int_c2 = 3;

--error 1062
update fk_int set fk_int_c1 = 3 where fk_int_c2 = 5;
--error 1062
update fk_int set fk_int_c2 = 5 where fk_int_c2 = 3;
--error 1451
delete from fk_int where fk_int_c1 = 5;
--error 1451
delete from fk_int where fk_int_c2 = 3;
select * from fk_int;
select * from fk_int2;

--echo	#关闭外键约束检查
set foreign_key_checks	= off;
insert into fk_int2 values(7,7),(3,1);

update fk_int2 set fk_int2_c1 = 100 where fk_int2_c2 = 1;
update fk_int2 set fk_int2_c2 = 100 where fk_int2_c1 = 5;

delete from fk_int where fk_int_c1 = 5;
delete from fk_int where fk_int_c2 = 1;

select * from fk_int;
select * from fk_int2;


--echo	#float、double、decimal
set foreign_key_checks	= on;

drop table if exists fk_jd;
drop table if exists fk_jd2;

create table fk_jd(
c1 float,
c2 float unique key,
c3 double,
c4 double unique key,
c5 decimal(4,2),
c6 decimal(6,3) unique key,
primary key(c1,c3,c5)
);

--error 1215
create table fk_jd2(
a1 float ,
a2 float ,
a3 double ,
a4 double ,
a5 decimal(4,2) ,
a6 decimal(6,3) ,
foreign key (a1) REFERENCES fk_jd(c1),
foreign key (a2) REFERENCES fk_jd(c2),
foreign key (a3) REFERENCES fk_jd(c3),
foreign key (a4) REFERENCES fk_jd(c4),
foreign key (a5) REFERENCES fk_jd(c5),
foreign key (a6) REFERENCES fk_jd(c6)
);


drop table if exists fk_float2;
drop table if exists fk_float;

create table fk_float(
c1 float(10,6) primary key,
c2 float(10,6) unique
);

create table fk_float2(
a1 float(10,6),
a2 float(10,6),
foreign key (a1) REFERENCES fk_float(c1),
foreign key (a2) REFERENCES fk_float(c2)
);

insert into fk_float values(1.123456,-1.11111);
insert into fk_float values (3.3333,-6.6666);
insert into fk_float values (7.777,8.8);
insert into fk_float values (10.0001,null);

insert into fk_float2 values(1.123456,-1.11111);
insert into fk_float2 values (3.3333,-6.6666);
insert into fk_float2 values (7.777,8.8);
insert into fk_float2 values (10.0001,null);

--error 1451
update fk_float set c1 = 20 where c2 = -6.6666;
--error 1452
update fk_float2 set a1 = 20 where a1 = 7.777000;

update fk_float2 set a1 = 3.333300 where a2 is null;
--error 1062
update fk_float set c1 = 3.333300 where c2 is null;

update fk_float set c1 = 10.54634 where c2 is null;

--error 1451
delete from fk_float where c1 = 1.123456;

delete from fk_float where c2 is null;
delete from fk_float2 where a2 is null;
delete from fk_float2 where a1 = 3.333300;

select * from fk_float;
select * from fk_float2;

set foreign_key_checks	= off;
insert into fk_float2 values(10,20);
update fk_float2 set a1 = 12 where a2 = -1.111110;
delete from fk_float where c1 = 1.123456;
select * from fk_float;
select * from fk_float2;


set foreign_key_checks	= on;
--echo	#double
drop table if exists fk_double2;
drop table if exists fk_double;

create table fk_double(
c1 double(10,4) primary key,
c2 double(10,4) unique
);

create table fk_double2(
a1 double(10,4),
a2 double(10,4),
foreign key (a1) REFERENCES fk_double(c1),
foreign key (a2) REFERENCES fk_double(c2)
);

