insert into fk_double2 values (3.3333,-6.6666);
insert into fk_double2 values (7.777,8.8);
insert into fk_double2 values (10.0001,null);
select * from fk_double;
select * from fk_double2;


--error 1451
update fk_double set c1 = 20 where c2 = -6.6666;
--error 1452
update fk_double2 set a1 = 20 where a1 = 7.7770;

update fk_double2 set a1 = 3.3333 where a2 is null;
--error 1062
update fk_double set c1 = 3.3333 where c2 is null;

update fk_double set c1 = 10.54634 where c2 is null;

--error 1451
delete from fk_double where c1 = 1.1235;

delete from fk_double where c2 is null;
delete from fk_double2 where a2 is null;
delete from fk_double2 where a1 = 3.3333;

select * from fk_double;
select * from fk_double2;

set foreign_key_checks	= off;
insert into fk_double2 values(10,20);
update fk_double2 set a1 = 12 where a2 = -1.1111;
delete from fk_double where c1 = 1.1235;
select * from fk_double;
select * from fk_double2;



set foreign_key_checks	= on;
--echo	#decimal
drop table if exists fk_decimal2;
drop table if exists fk_decimal;

create table fk_decimal(
c1 float(10,6) primary key,
c2 float(10,6) unique
);

create table fk_decimal2(
a1 float(10,6),
a2 float(10,6),
foreign key (a1) REFERENCES fk_decimal(c1),
foreign key (a2) REFERENCES fk_decimal(c2)
);

insert into fk_decimal values(1.123456,-1.11111);
insert into fk_decimal values (3.3333,-6.6666);
insert into fk_decimal values (7.777,8.8);
