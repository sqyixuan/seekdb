--disable_warnings
drop database if exists db1;
--enable_warnings
 
create database db1;
use db1;
 
 
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;


--echo	#ddl + dml + 外键检查开关场景
--echo	#外键自引用+dml+外键检查开关
drop table if exists zyy_dml_table;

create table zyy_dml_table(
c1 int primary key,
c2 varchar(30) unique key not null,
c3 int ,
c4 varchar(30) default 'a',
foreign key(c3) REFERENCES zyy_dml_table(c1),
foreign key(c4) REFERENCES zyy_dml_table(c2)
);



--echo	#insert
--error 1452
insert into zyy_dml_table(c1,c2,c3) values(1,'a',3);
insert into zyy_dml_table(c1,c2) values(1,'a');



--echo	#多列
insert into zyy_dml_table values(10,'c',null,'c'),(2,'2c',2,'2c'),(3,'3c',3,'3c');

--echo	#insert ..set..

insert into zyy_dml_table set c1 = 6 , c2 = '6a' , c4 = '6a';

--echo	#insert ignore
--echo	#OB报错，mysql正常执行。
##--error 1452
##insert ignore into zyy_dml_table values(11,'c',11,'c');

--echo	#insert on duplicate key
--error 1452
insert into zyy_dml_table values(2,'dd',2,'cc') on duplicate key UPDATE c2 = 'dd',c4 = 'cc';

--echo	#OB执行成功，MYSQL报错。 
#insert into zyy_dml_table values(2,'dd',2,'dd') on duplicate key UPDATE c2 = 'dd',c4 = 'dd';
select * from zyy_dml_table;


--echo	#update单个字段
--error 1062
update zyy_dml_table set  c1 = 20 where c3 is null;


--echo	#replace
--echo	#OB执行成功，mysql报错，
##replace into zyy_dml_table values(1,'b',null,'b');

--error 1451
replace into zyy_dml_table values(3,'2c',3,'2c');

--echo	#OB执行成功，mysql报错，
##replace into zyy_dml_table values(1,2,null,null);

select * from zyy_dml_table;


create table pk_table(
c1 int primary key,
c2 varchar(30) not null
);

--echo	#报错信息不一致。
--error 5785
alter table zyy_dml_table add CONSTRAINT zyy_c1 FOREIGN key(c1) REFERENCES pk_table(c1);

set foreign_key_checks	= 0;

alter table zyy_dml_table add CONSTRAINT zyy_c1 FOREIGN key(c1) REFERENCES pk_table(c1);

set foreign_key_checks	= 1;

select * from zyy_dml_table;
select * from pk_table;

#--echo	#OB执行成功，mysql报错。
#insert into zyy_dml_table values(11,'6c',11,'6c');


drop table zyy_dml_table;
drop table pk_table;

drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
create table t1(
c1 int primary key,
c2 varchar(30) unique key
);

create table t2(
c1 int,
c2 varchar(30),
FOREIGN KEY(c1) REFERENCES t1(c1),
FOREIGN KEY(c2) REFERENCES t1(c2)
);

insert into t1 values(1,'a'),(3,'b'),(-5,'c'),(-6,'d'),(7,'e'),(8,'f'),(-9,'g'),(10,'h');
insert into t2 values(1,'a'),(3,'b'),(-5,'c'),(-6,null),(-9,'g'),(10,'h');

select * from t1;
select * from t2;

create table t3(
c1 int,
c2 varchar(30)
);
insert into t3 values(1,'a'),(3,'b'),(4,'dd'),(null,'c'),(-6,null),(7,'yy'),(8,'oo'),(-9,'g'),(10,'h'),(11,'v'),(12,'i');
select * from t3;


--echo	#insert + select
insert into t2 select * from t2 where c1 = (select c1 from t3 where c1 = 1);
insert into t2 select * from t2 where c2 = (select c2 from t3 where c2 = 'c');
insert into t2 select * from t3 where c2 = 'c';

--error 1452
insert into t2 select * from t3 where c1 = 11;

set foreign_key_checks	= 0;
insert into t2 select * from t3 where c1 = 11;


--echo	#insert +多表
set foreign_key_checks	= 1;

--error 1452
insert into t2 select t1.c1,t3.c2 from t1,t3 where t1.c1 = t3.c1 and t3.c1 = 8;

insert into t2 select t1.c1,t3.c2 from t1 left join t3 on t1.c2 = t3.c2 where  t3.c2 = 'h';

--error 1452
insert into t2 select t1.c1,t3.c2 from t1 right join t3 on t1.c2 = t3.c2 where  t3.c2 = 'i';

set foreign_key_checks	= 0;
insert into t2 select t1.c1,t3.c2 from t1,t3 where t1.c1 = t3.c1 and t3.c1 = 8;
insert into t2 select t1.c1,t3.c2 from t1 right join t3 on t1.c2 = t3.c2 where  t3.c2 = 'i';

select * from t2;


--echo	#batch insert
set foreign_key_checks	= 1;

alter system flush plan cache global;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;

delimiter /;
insert into t2 values(-5,'c');insert into t2 values(7,'e');insert into t2 values(10,'h');/
delimiter ;/
select * from t2;
rollback;


delimiter /;
insert into t2 values(null,'c');insert into t2 values(7,null);insert into t2 values(null,null);/
delimiter ;/
select * from t2;
rollback;


delimiter /;
--error 1452
insert into t2 values(20,'c');insert into t2 values(-7,'VV');insert into t2 values(null,null);/
delimiter ;/
select * from t2;
rollback;

set foreign_key_checks	= 0;
delimiter /;
insert into t2 values(20,'c');insert into t2 values(-7,'VV');insert into t2 values(null,null);/
delimiter ;/
select * from t2;
rollback;

alter system set ob_enable_batched_multi_statement=false;
set autocommit = 1;
set foreign_key_checks	= 1;

delete from t2 where c1 > 9 or c1 is null;

--echo	#update + select 
update t2 set c1 = 10 where c1 = (select c1 from t1 where c2 = 'd');
update t2 set c1 = 8 where c1 = (select c1 from t1 where c2 = 'g');

--error 1452
update t2 set c1 = 22 where c1 = (select c1 from t1 where c1 = 1);

set foreign_key_checks	= 0;
update t2 set c1 = 22 where c1 = (select c1 from t1 where c1 = 1);

select * from t2;


--echo	#update + join
set foreign_key_checks	= 1;
update t1,t2 set t2.c1 = 7 where t1.c1 = t2.c1 and t1.c1 = 3;

--error 1452
update t1,t2 set t2.c1 = 11 where t1.c1 = t2.c1 and t1.c1 = 7;

update t3,t2 set t2.c1 = t3.c1 where t3.c1 = t2.c1 ;

set foreign_key_checks	= 0;
update t1,t2 set t2.c1 = 11 where t1.c1 = t2.c1 and t1.c1 = 7;
select * from t2;

set foreign_key_checks	= 1;


--echo	#delete + select
delete from t1 where c1 = (select c1 from t3 where c1= 7);

--error 1451
delete from t1 where c1 = (select c1 from t3 where c1= 10);

set foreign_key_checks	= 0;
delete from t1 where c1 = (select c1 from t3 where c1= 10);
select * from t1;

set foreign_key_checks	= 1;
delete from t2 where c1 > (select 0 );

select * from t2;

--error 1451
delete from t1;

set foreign_key_checks	= 1;






--echo	#主外键表+dml+外键检查开关
drop table if exists t2;
drop table if exists t1;
create table t1(c1 int unique key ,c2 int primary key);

create table t2(
a1 int unique key,
a2 int primary key,
constraint aa foreign key(a1) REFERENCES t1(c1),
constraint bb foreign key(a2) REFERENCES t1(c2)
);

insert into t1 values(1,1),(3,3),(5,5);
insert into t2 values(1,1),(3,3);

set foreign_key_checks	= off;
insert into t2 values(5,5),(2,2);

set foreign_key_checks	= on;
--echo	#OB报错，mysql正常执行。
update t2 set a1 = 2 where a2 = 2;



--echo	#DDL+外键检查开关
set foreign_key_checks	= on;
drop table if exists ddl_fk_check2;
drop table if exists ddl_fk_check;

create table ddl_fk_check(
c1 int primary key,
c2 varchar(30) unique,
c3 int
);

create table ddl_fk_check2(
a1 int,
a2 varchar(30) default 'aa',
a3 varchar(40)
);
ALTER TABLE ddl_fk_check2 ADD CONSTRAINT FK_DDL_CHECK FOREIGN KEY (a1) REFERENCES ddl_fk_check(c1);
ALTER TABLE ddl_fk_check2 ADD CONSTRAINT FK_DDL_CHECK2 FOREIGN KEY (a2) REFERENCES ddl_fk_check(c2);

--error 3730
drop table ddl_fk_check;

set foreign_key_checks	= off;
drop table ddl_fk_check;

set foreign_key_checks	= on;
--error 1452
insert into ddl_fk_check2 values(1,'c',2);

create table ddl_fk_check(
c1 int primary key,
c2 varchar(30) unique,
c3 int
);

insert into ddl_fk_check values(1,'a',3),(3,'a3',5),(5,'a5',7);
insert into ddl_fk_check2 values(1,'a',3),(3,'a3',5),(5,'a5',7);

--error 1451
delete from ddl_fk_check where c1 = 1;
--error 1701
truncate ddl_fk_check;

set foreign_key_checks	= off;
delete from ddl_fk_check where c1 = 1;
truncate ddl_fk_check;

select * from ddl_fk_check;

set foreign_key_checks	= 1;
delete from ddl_fk_check2 where a1 = 1;
truncate ddl_fk_check2;

--echo	#修改主键列
alter table ddl_fk_check modify c1 int unique;

--echo	#OB与MYSQL报错信息不一致。
--error 5320
alter table ddl_fk_check modify c1 int AUTO_INCREMENT;

alter table ddl_fk_check modify c1 int not null;

--echo	#OB与MYSQL报错信息不一致。
--error 5320
alter table ddl_fk_check modify c1 bigint;


#set foreign_key_checks	= 0;
#OB报错，预期与mysql行为一致，正常执行。
#--error 5320
#alter table ddl_fk_check modify c1 int AUTO_INCREMENT;
#alter table ddl_fk_check2 modify a1 int AUTO_INCREMENT;

drop table if exists ddl_fk_check2;
drop table if exists ddl_fk_check;





drop database db1;
