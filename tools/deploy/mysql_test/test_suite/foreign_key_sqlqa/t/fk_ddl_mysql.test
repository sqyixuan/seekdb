ALTER TABLE xg_fk_test2 ALTER COLUMN a1 SET DEFAULT 456;
ALTER TABLE xg_fk_test2 ALTER COLUMN a3 SET DEFAULT 777;
ALTER TABLE xg_fk_test2 ALTER COLUMN a3 SET DEFAULT NULL;


desc xg_fk_test1;
