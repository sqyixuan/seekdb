--echo	#修改主键列约束
ALTER TABLE xg_fk_test1 MODIFY COLUMN c1 int unique key;
ALTER TABLE xg_fk_test1 MODIFY COLUMN c1 int not null;


ALTER TABLE xg_fk_test1 MODIFY COLUMN c3 int not null;
--error 1068
ALTER TABLE xg_fk_test1 MODIFY COLUMN c3 int primary key;

--error 1064
alter table xg_fk_test1 modify column c1 int  foreign key(c1) REFERENCES xg_fk_test2(a3); 
