--disable_warnings
drop database if exists db1;
--enable_warnings
 
create database db1;
use db1;
 
 
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;



drop table if exists t2;
drop table if exists t1;
create table t1(c1 int primary key,c2 varchar(30) not null);

--echo	#外键名为字母
create table t2(a1 int,a2 varchar(30) not null,constraint aaa foreign key(a1) REFERENCES t1(c1));

drop table if exists t2;
--echo	#mysql报错，OB正常执行。MYSQL外键名长度限制64个字符，OB128个字符
create table t2(a1 int,a2 varchar(30) not null,constraint aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa foreign key(a1) REFERENCES t1(c1));

drop table if exists t2;
--error 1406
create table t2(a1 int,a2 varchar(30) not null,constraint aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa foreign key(a1) REFERENCES t1(c1));


--echo	#外键名为数字
drop table if exists t2;
--error 1064
create table t2(a1 int,a2 varchar(30) not null,constraint 123 foreign key(a1) REFERENCES t1(c1));


--echo	#外键名为字符串
drop table if exists t2;
create table t2(a1 int,a2 varchar(30) not null,constraint 1a1c2d foreign key(a1) REFERENCES t1(c1));
drop table if exists t2;
create table t2(a1 int,a2 varchar(30) not null,constraint 1234567894321aaaaaaaaaaaaaa2312312321a1c2d foreign key(a1) REFERENCES t1(c1));

drop table if exists t2;
--error 1064
create table t2(a1 int,a2 varchar(30) not null,constraint 'aaaaaaaaaaaaaa2312312321a1c2d' foreign key(a1) REFERENCES t1(c1));

--echo	#外键名位中文
drop table if exists t2;
create table t2(a1 int,a2 varchar(30) not null,constraint 外键 foreign key(a1) REFERENCES t1(c1));

drop table if exists t2;
--error 1406
create table t2(a1 int,a2 varchar(30) not null,constraint 外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外键外外外 foreign key(a1) REFERENCES t1(c1));


--echo	#外键名为特殊字符
drop table if exists t2;
--error 1064
create table t2(a1 int,a2 varchar(30) not null,constraint %*^&^& foreign key(a1) REFERENCES t1(c1));

--error 1064
create table t2(a1 int,a2 varchar(30) not null,constraint 1/2*3 foreign key(a1) REFERENCES t1(c1));


--echo	#外键列引用父表主键列相同/不同
create table t2(a1 int,a2 varchar(30) not null,constraint 相同 foreign key(a1) REFERENCES t1(c1));

drop table if exists t2;
--echo	#OB与MYSQL报错信息不一致。
--error 1215
create table t2(a1 int,a2 varchar(30) not null,constraint 不同 foreign key(a1) REFERENCES t1(c2));

--echo	#外键列引用父表主键列类型相同/不同。
--error 1215
create table t2(a1 bigint,a2 varchar(30) not null,constraint 不同 foreign key(a1) REFERENCES t1(c1));
--error 1215
create table t2(a1 decimal(10,0),a2 varchar(30) not null,constraint 不同 foreign key(a1) REFERENCES t1(c1));

create table t2(a1 int,a2 varchar(30) not null,constraint 相同 foreign key(a1) REFERENCES t1(c1));


--echo	#外键名重复。
drop table if exists t2;
drop table if exists t1;

create table t1(c1 int unique key ,c2 int primary key);
--echo	#OB与MYSQL报错信息不一致。
--error 1215
create table t2(
a1 int unique key,
a2 int primary key,
constraint aa foreign key(a1) REFERENCES t1(c1),
constraint aa foreign key(a2) REFERENCES t1(c2)
);


--error 1215
create table t2(
a1 int unique key,
a2 int primary key,
constraint a。a foreign key(a1) REFERENCES t1(c1),
constraint a。a foreign key(a2) REFERENCES t1(c2)
);


--echo #外键列主键列为不同约束。 
drop table if exists t2;
drop table if exists t1;


create table t1(c1 int unique key AUTO_INCREMENT,c2 varchar(30) not null);
create table t2(a1 int primary key,a2 varchar(30) not null,constraint aa foreign key(a1) REFERENCES t1(c1));

drop table t2;
create table t2(a1 int not null,a2 varchar(30) not null,constraint aa foreign key(a1) REFERENCES t1(c1));

drop table t2;
create table t2(a1 int default 10 not null ,a2 varchar(30) not null,constraint aa foreign key(a1) REFERENCES t1(c1));

drop table t2;
create table t2(a1 int unique key not null default 20 ,a2 varchar(30) not null,constraint aa foreign key(a1) REFERENCES t1(c1));


--echo	#外键列或主键列带索引
drop table if exists t2;
drop table if exists t1;

create table t1(c1 int primary key,c2 varchar(30) not null,index t1_c1 (c1));
create table t2(a1 int,a2 varchar(30) not null,constraint aaa foreign key(a1) REFERENCES t1(c1),index t2_a1(a1));

--echo	#OB与MYSQL报错信息不一致。
--error 5320
drop index t2_a1 on t2;
drop index t1_c1 on t1;

drop table if exists t2;
drop table if exists t1;

create table t1(c1 int ,c2 varchar(30) not null);

--echo	#OB与MYSQL报错信息不一致。
--error 1215
create table t2(a1 int primary key,a2 varchar(30) not null,constraint aa foreign key(a1) REFERENCES t1(c1));

create unique index t1_c1 on t1(c1);
create table t2(a1 int primary key,a2 varchar(30) not null,constraint aa foreign key(a1) REFERENCES t1(c1));

#show create table t2;

--error 4714
drop index t1_c1 on t1;


--echo	#普通索引
drop table if exists t2;
drop table if exists t1;
create table t1(c1 int ,c2 varchar(30),index t1_c1(c1));
desc t1;
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a1) REFERENCES t1(c1));

--echo	#组合索引
drop table if exists t2;
drop table if exists t1;
create table t1(c1 int ,c2 varchar(30) ,index t1_c1_c2(c1,c2));
desc t1;
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a1) REFERENCES t1(c1));

--echo	#唯一索引
drop table if exists t2;
drop table if exists t1;
create table t1(c1 int ,c2 varchar(30),unique(c1));
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a1) REFERENCES t1(c1));

--error 4714
alter table t1 drop index c1;


--echo	#复合外键
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;

--echo	#顺序相同。
create table t1(c1 int ,c2 varchar(30) ,primary KEY(c1,c2));
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a1,a2) REFERENCES t1(c1,c2));

drop table if exists t2;
--echo	#顺序不同
--error 1215
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a2,a1) REFERENCES t1(c1,c2));

--echo	#OB执行成功，mysql报错。
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a2,a1) REFERENCES t1(c2,c1));

drop table t2;
--error 1215
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a1,a2) REFERENCES t1(c2,c1));


--echo	#主键列为唯一索引列
drop table if exists t2;
drop table if exists t1;

create table t1(c1 int ,c2 varchar(30) ,unique KEY(c1,c2));
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a1,a2) REFERENCES t1(c1,c2));

drop table  t2;
--error 1215
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a2,a2) REFERENCES t1(c2,c2));

--echo	#OB执行成功，mysql报错。
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a2,a1) REFERENCES t1(c2,c1));

drop table  t2;
--error 1215
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a1,a2) REFERENCES t1(c2,c1));

drop table if exists t2;
drop table if exists t1;
--echo	#声明类型后加约束，外键创建失败， 所有字段类型声明后 加约束 才可作为主键列引用外键。
create table t1(c1 int unique ,c2 varchar(30) unique);
--error 1215
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a1,a2) REFERENCES t1(c1,c2));



--echo	#主键列既有primary key又有unique key
drop table if exists t2;
drop table if exists t1;

--echo	#主键列为primary key和unique key同时存在时，报错。
create table t1(c1 int primary key,c2 varchar(30) unique key);
--error 1215
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a1,a2) REFERENCES t1(c1,c2));

drop table t1;
create table t1(c1 int,c2 varchar(30),primary key(c1), unique key(c2));
--error 1215
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a1,a2) REFERENCES t1(c1,c2));



--echo	#多个外键约束
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
create table t1(c1 int primary key ,c2 varchar(30) not null);
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a1) REFERENCES t1(c1),unique(a1));
create table t3(b1 int ,b2 varchar(30) not null,CONSTRAINT bb FOREIGN KEY(b1) REFERENCES t2(a1),primary key(b1));


--echo	#顺序不同
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;

create table t1(c1 int primary key ,c2 varchar(30) not null);
--error 1215
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a1) REFERENCES t1(c2),unique(a1));

create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a1) REFERENCES t1(c1),unique(a1));
--error 1215
create table t3(b1 int ,b2 varchar(30) not null,CONSTRAINT bb FOREIGN KEY(b1) REFERENCES t2(a2),primary key(b1));


--echo	#类型不同
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;

create table t1(c1 int primary key ,c2 varchar(30) not null);
create table t2(a1 int ,a2 varchar(30),constraint aa foreign key(a1) REFERENCES t1(c1),unique(a1));
--error 1215
create table t3(b1 bigint ,b2 varchar(30) not null,CONSTRAINT bb FOREIGN KEY(b1) REFERENCES t2(a1),primary key(b1));



--echo	#级联删除
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
DROP TABLE IF EXISTS JL_DELETE;
DROP TABLE IF EXISTS JL_UPDATE;
DROP TABLE IF EXISTS JL_TABLE;

CREATE TABLE JL_TABLE (
    c1 int NOT NULL PRIMARY KEY,
    c2 varchar(60) NOT NULL
);

CREATE TABLE JL_DELETE (
    a1 int NOT NULL PRIMARY KEY,
    a2 int NOT NULL,
    FOREIGN KEY (a1) REFERENCES JL_TABLE(c1) ON DELETE CASCADE
);

insert into JL_TABLE values(1,'AA');
insert into JL_TABLE values(2,'bb');
insert into JL_TABLE values(3,'cc');
insert into JL_TABLE values(4,'DD');
insert into JL_TABLE values(5,'AA');
insert into JL_TABLE values(6,'bb');
insert into JL_TABLE values(7,'cc');
insert into JL_TABLE values(8,'DD');

insert into JL_DELETE values(4,6);
insert into JL_DELETE values(3,5);
insert into JL_DELETE values(2,4);
insert into JL_DELETE values(1,3);

DELETE FROM  JL_DELETE WHERE a1 = 1;
DELETE FROM  JL_TABLE WHERE c1 = 2;
select * from JL_TABLE;
SELECT * FROM JL_DELETE;


--echo	#级联更新
CREATE TABLE JL_UPDATE (
    a1 int NOT NULL PRIMARY KEY,
    a2 int NOT NULL,
    FOREIGN KEY (a1) REFERENCES JL_TABLE(c1) ON UPDATE CASCADE
);


insert into JL_UPDATE values(1,6);
insert into JL_UPDATE values(3,5);
insert into JL_UPDATE values(5,4);
insert into JL_UPDATE values(7,3);

--error 1452
update JL_UPDATE set a1 = 9 where a2 = 6;

update JL_TABLE set c1 = 10 where c1 = 1;

--echo	#报错信息与MYSQL不一致。
--error 1062
UPDATE JL_TABLE SET c1 = 5 where c2 = 'DD';

SELECT * FROM JL_TABLE;
SELECT * FROM JL_UPDATE;

DROP TABLE IF EXISTS JL_DELETE;
DROP TABLE IF EXISTS JL_UPDATE;
DROP TABLE IF EXISTS JL_TABLE;

--echo	#设置NULL
CREATE TABLE JL_TABLE (
    c1 int PRIMARY KEY,
    c2 varchar(60) NOT NULL
);

--echo	#OB报错与MYSQL不一致。


CREATE TABLE JL_NULL (
    a1 int  ,
    a2 int NOT NULL,
    FOREIGN KEY (a1) REFERENCES JL_TABLE(c1) ON DELETE SET NULL ON UPDATE SET NULL
);


--echo	#设置默认值。 OB报错，与MYSQL不一致。
--error 1215
CREATE TABLE JL_DEFAULT (
    a1 int  ,
    a2 int NOT NULL,
    FOREIGN KEY (a1) REFERENCES JL_TABLE(c1) ON DELETE SET DEFAULT 
);


--echo	#外键自引用
drop table if exists for_zyy;
create table for_zyy (
    c1 int NOT NULL PRIMARY KEY,
    c2 varchar(255) NOT NULL,
    c3 int,
    FOREIGN KEY (c3) REFERENCES for_zyy(c1)
);

drop table if exists for_zyy;
create table for_zyy (
    c1 int NOT NULL unique,
    c2 varchar(255) NOT NULL,
    c3 int,
    FOREIGN KEY (c3) REFERENCES for_zyy(c1)
);


drop table if exists for_zyy;
create table for_zyy (
    c1 int NOT NULL,
    c2 varchar(255) NOT NULL,
    c3 int,
    FOREIGN KEY (c3) REFERENCES for_zyy(c1),unique(c1)
);


drop table if exists for_zyy;
create table for_zyy (
    c1 int NOT NULL,
    c2 varchar(255) NOT NULL,
    c3 int,
    FOREIGN KEY (c3) REFERENCES for_zyy(c1),primary key(c1)
);


drop table if exists for_zyy;
create table for_zyy (
    c1 int NOT NULL,
    c2 varchar(255) NOT NULL,
    c3 int,
    FOREIGN KEY (c3) REFERENCES for_zyy(c1),index index_c1(c1)
);

drop table if exists for_zyy;
create table for_zyy (
    c1 int NOT NULL,
    c2 varchar(255) NOT NULL,
    c3 int,
    FOREIGN KEY (c3) REFERENCES for_zyy(c1),index index_c1(c1)
);


