--echo	#alter
--echo	#alter add foreign key
drop table if exists al_fk_table2;
drop table if exists al_fk_table;
create table al_fk_table(
c1 int,
c2 int
);

create table al_fk_table2(
c1 int,
c2 int
);


alter table al_fk_table add CONSTRAINT al_fk_table_c1 primary key(c1);
alter table al_fk_table2 add CONSTRAINT aa FOREIGN KEY(c1) REFERENCES al_fk_table(c1);

--echo	#OB与MYSQL报错信息不一致。
--error 4714
alter table al_fk_table drop primary key;


drop table if exists al_fk_table2;
drop table if exists al_fk_table;
create table al_fk_table(
c1 int,
c2 int
);

create table al_fk_table2(
c1 int,
c2 int
);

alter table al_fk_table add CONSTRAINT al_fk_table_c1 primary key(c1,c2);
--echo	#alter add 复合外键
alter table al_fk_table2 add CONSTRAINT aa FOREIGN KEY(c1,c2) REFERENCES al_fk_table(c1,c2);


--echo	#alter add 自引用外键
drop table if exists pr_fk_zyy;
create table pr_fk_zyy(
c1 int,
c2 int
);

--error 1215
alter table pr_fk_zyy add CONSTRAINT pr_fk_zyy primary key(c1),add CONSTRAINT abc FOREIGN key(c2) REFERENCES pr_fk_zyy(c1);
set foreign_key_checks	= off;
--error 1215
alter table pr_fk_zyy add CONSTRAINT pr_fk_zyy unique key(c1),add CONSTRAINT abc FOREIGN key(c2) REFERENCES pr_fk_zyy(c1);

set foreign_key_checks	= on;
alter table pr_fk_zyy add CONSTRAINT pr_fk_zyy primary key(c1);
alter table pr_fk_zyy add CONSTRAINT abc FOREIGN key(c2) REFERENCES pr_fk_zyy(c1);
desc pr_fk_zyy;

drop table pr_fk_zyy;


drop table if exists uq_fk_zyy;
create table uq_fk_zyy(
c1 int,
c2 int
);

--error 1215
alter table uq_fk_zyy add CONSTRAINT uq_fk_zyy_c1 unique key(c1),add CONSTRAINT zz1 FOREIGN key(c2) REFERENCES uq_fk_zyy(c1);
set foreign_key_checks	= off;
--error 1215
alter table uq_fk_zyy add CONSTRAINT uq_fk_zyy_c1 unique key(c1),add CONSTRAINT zz2 FOREIGN key(c2) REFERENCES uq_fk_zyy(c1);

set foreign_key_checks	= on;

alter table uq_fk_zyy add CONSTRAINT uq_fk_zyy_c1 unique key(c1);
alter table uq_fk_zyy add CONSTRAINT zz3 FOREIGN key(c2) REFERENCES uq_fk_zyy(c1);
desc uq_fk_zyy;



--echo	#修改 外键列/主键列
drop table if exists xg_fk_test2;
drop table if exists xg_fk_test1;
create table xg_fk_test1(
c1 int not null primary key,
c2 varchar(30) not null default 'aa',
c3 int unique key
);

create table xg_fk_test2(
a1 int,
a2 varchar(30),
a3 int
);
--error 1215
alter table xg_fk_test2 add CONSTRAINT xgxg FOREIGN KEY(a1,a3) REFERENCES xg_fk_test1(c1,c3);

alter table xg_fk_test2 add CONSTRAINT xgxg1 FOREIGN KEY(a1) REFERENCES xg_fk_test1(c1);
alter table xg_fk_test2 add CONSTRAINT xgxg2 FOREIGN KEY(a3) REFERENCES xg_fk_test1(c3);
 --source mysql_test/include/show_create_table_old_version.inc
show create table xg_fk_test2;

--echo	#修改主键列
