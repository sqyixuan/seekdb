DROP TABLE IF EXISTS t2;
CREATE TABLE t2(c0 INT,c1 VARCHAR(10));
INSERT INTO t2 VALUES(1,'A'),(2,'B'),(3,'C'),(4,'D'),(5,'E'),(6,'F'),(10,'G'),(13,'H'),(14,'I'),(15,'G'),(19,'H'),(22,'I');


#创建INSERT/UPDATE/DELETE型触发器


DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert AFTER INSERT ON t2
    FOR EACH ROW
    BEGIN
        DECLARE c INT;
        SELECT MAX(c0) INTO c FROM t1;

        IF NEW.c0 = c THEN
            DELETE FROM t1 WHERE c0 = NEW.c0;
        ELSE
            INSERT INTO t1 VALUES(NEW.c0,NEW.c0+0.5,NEW.c0,b'11111',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550','89504E470D0A1A0A00C76FA8640000001E49444154384F6AE843',CONCAT('除列情景',NEW.c1),CONCAT('enish_lanage',NEW.c1),'tesu*符号￥%',CONCAT('SHUZI!34567',NEW.c1),'g','l','22:32:12','2022-12-13','2012-01-01 22:01:01','2013-03-21 14:21:21.34567','2011');
        END IF;
    END;

//


DROP TRIGGER IF EXISTS trg_delete;


CREATE TRIGGER trg_delete AFTER DELETE ON t2
    FOR EACH ROW
    BEGIN
        DELETE FROM t1 WHERE c0=OLD.c0 OR c10=OLD.c1 OR c11=OLD.c1;
    END;

//


DROP TRIGGER IF EXISTS trg_update;


CREATE TRIGGER trg_update BEFORE UPDATE ON t1
FOR EACH ROW
BEGIN
    UPDATE t2 SET c0=NEW.c0,c1=NEW.c10 WHERE c0=OLD.c0;
END
//


#创建存储过程

DROP PROCEDURE IF EXISTS pro1;//

CREATE PROCEDURE pro1(IN v_c0 INT)
BEGIN
    IF v_c0 > 10 AND v_c0 <= 15 THEN
        DELETE FROM t2 WHERE c0=v_c0;
    ELSEIF v_c0 <= 5 THEN
        UPDATE t1 SET c0=v_c0+5,c1=0.5+v_c0,c2=1.5+v_c0,c10='a' WHERE c0=v_c0;
    ELSE
        INSERT INTO t2 VALUES(v_c0,'J');
    END IF;
END;
//
DELIMITER ;//


CALL pro1(13);
SELECT * FROM t2 WHERE c0=13;
SELECT * FROM t1 WHERE c0=13;

--echo #此处执行报参数无效，为已知问题，待开发修复后执行sql

