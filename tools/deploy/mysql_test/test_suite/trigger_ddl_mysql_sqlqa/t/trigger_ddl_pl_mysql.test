#SELECT * FROM t1 WHERE c0 IN(5,10);


CALL pro1(17);
SELECT * FROM t2 WHERE c0=17;
SELECT * FROM t1 WHERE c0=17;


CALL pro1(20);
SELECT * FROM t2 WHERE c0=20;
SELECT * FROM t1 WHERE c0=20;


DROP PROCEDURE IF EXISTS pro1;



#在存储过程中加入DDL操作，然后调用存储过程



DROP PROCEDURE IF EXISTS pro2;

DELIMITER //;

CREATE PROCEDURE pro2(IN v_c0 INT)
BEGIN
    IF v_c0 > 10 AND v_c0 <= 15 THEN
        ALTER TABLE t1 DROP INDEX ind_1,ADD INDEX ind1(c13),RENAME INDEX ind_2 TO ind2;
        DELETE FROM t2 WHERE c0=v_c0;

    ELSEIF v_c0 <= 5 THEN
        ALTER TABLE t1 ADD CONSTRAINT unk UNIQUE KEY(c7,c11),DROP INDEX chk_ind;
        UPDATE t1 SET c0=v_c0+5,c1=0.5+v_c0,c2=1.5+v_c0,c10='a' WHERE c0=v_c0;

    ELSE
        ALTER TABLE t1 SET PARALLEL=10,BLOCK_SIZE=20480,AUTO_INCREMENT=100;
        ALTER TABLE t2 MODIFY c0 BIGINT PRIMARY KEY AUTO_INCREMENT AFTER c1,CHANGE c1 c1 CHAR(10) CHARACTER SET 'binary' COLLATE 'binary' NOT NULL DEFAULT 'TEST' ;
        INSERT INTO t2 VALUES('J',v_c0);

    END IF;
END;
//
DELIMITER ;//


alter system set _enable_drop_and_add_index = true;
sleep 2;
CALL pro2(14);
alter system set _enable_drop_and_add_index = false;
sleep 2;
SELECT * FROM t2 WHERE c0=14;
SELECT * FROM t1 WHERE c0=14;


