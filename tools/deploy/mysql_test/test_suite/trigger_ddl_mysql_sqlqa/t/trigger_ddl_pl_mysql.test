#创建函数并调用函数



DROP FUNCTION IF EXISTS f_test1;//

CREATE FUNCTION f_test1(v_c0 INT)
RETURNS VARCHAR(100)
BEGIN
    DECLARE v_count_t1 INT;
    DECLARE v_count_t2 VARCHAR(100);
    DECLARE v_count_t3 VARCHAR(100);
	IF v_c0 <= 5 THEN
    	UPDATE t1 SET c0=v_c0+6,c1=15+v_c0,c2=1.5+v_c0,c10='a' WHERE c0=v_c0;
    	SELECT c0,c1 INTO v_count_t1,v_count_t2 FROM t2 WHERE c0=v_c0+6;

    ELSEIF v_c0 <= 15 THEN
    	DELETE FROM t2 WHERE c0=v_c0;
    	SELECT c0,c1 INTO v_count_t1,v_count_t2 FROM t1 WHERE c0=v_c0;

    ELSE
        INSERT INTO t2 VALUES(v_c0,'J');
        SELECT c0,c1 INTO v_count_t1,v_count_t2 FROM t1 WHERE c0=v_c0;

    END IF;

    SET v_count_t3 = CONCAT('t1表执行函数后结果c0:：',v_count_t1,'    c1:',v_count_t2);
    RETURN v_count_t3;
END;
//
DELIMITER ;//


