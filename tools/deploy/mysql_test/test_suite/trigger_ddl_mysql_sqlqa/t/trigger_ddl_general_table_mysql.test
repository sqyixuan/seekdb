#UPDATE型


DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert AFTER INSERT ON t2
FOR EACH ROW
BEGIN
    DECLARE c INT;
    SELECT MAX(c0) INTO c FROM t1;

    IF NEW.c0 = c THEN
        DELETE FROM t1 WHERE c0 = NEW.c0;
    ELSE
        INSERT INTO t1(c0,c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) VALUES
        (NEW.c0,NEW.c0+0.5,NEW.c0,b'11111',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550','89504E470D0A1A0A00C76FA8640000001E49444154384F6AE843','除列情景','enish_lanage','tesu*符号￥%','SHUZI!34567','g','l','22:32:12','2022-12-13','2012-01-01 22:01:01','2013-03-21 14:21:21.34567','2011');
    END IF;
END;
//

DELIMITER ;//


