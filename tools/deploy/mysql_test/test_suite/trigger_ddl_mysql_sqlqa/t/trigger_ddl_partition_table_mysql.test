--echo #创建不同类型的分区表，使用不同约束索引条件，然后再创建不同触发类型的trigger，最后对表中的列执行DDL操作后触发trigger



--echo #RANGE分区


SET sql_mode='STRICT_TRANS_TABLES,STRICT_ALL_TABLES,NO_AUTO_VALUE_ON_ZERO';


DROP TABLE IF EXISTS t2;

CREATE TABLE t2(c0 INT,
                c1 VARCHAR(10),
                c2 SET('a','b','c','d','e','f','g'),
                c3 FLOAT,
                c4 DATE,
                c5 YEAR DEFAULT '2000',
                c6 TEXT ,
                c7 VARBINARY(10) DEFAULT 'TEST')
PARTITION BY RANGE(c0)
(PARTITION p1 VALUES LESS THAN(0),
 PARTITION p2 VALUES LESS THAN(50),
 PARTITION p3 VALUES LESS THAN(100),
 PARTITION p4 VALUES LESS THAN(MAXVALUE)
);

INSERT INTO t2 VALUES(0,'AA','a',0.123,'2000-01-01','2000','TEST1','TEST1'),
                     (1,'BB','a',2.123,'2001-11-11','2001','TEST2','TEST2'),
                     (3,'CC','b',3.123,'2002-02-01','2002','TEST3','TEST3'),
                     (4,'DD','b',4.123,'2003-03-11','2003','TEST4','TEST4'),
                     (5,'EE','c',5.123,'2004-04-01','2004','TEST5','TEST5'),
                     (6,'FF','c',6.123,'2005-05-11','2005','TEST6','TEST6');


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 SMALLINT ZEROFILL,
                c1 CHAR(10),
                c2 ENUM('a','b','c','d','e','f','g') NOT NULL DEFAULT 'a',
                c3 DOUBLE,
                c4 TIME,
                c5 INT DEFAULT 0,
                c6 BLOB,
                c7 BINARY(10) DEFAULT 'test',
                CONSTRAINT uni_key UNIQUE KEY(c0,c2))
PARTITION BY RANGE(c0)
(PARTITION r1 VALUES LESS THAN(100),
 PARTITION r2 VALUES LESS THAN(200),
 PARTITION r3 VALUES LESS THAN(300),
 PARTITION r4 VALUES LESS THAN(MAXVALUE)
);

INSERT INTO t1 VALUES(0,'AAA','a',10.123,'20:01:01',2000,'TEST1','TEST1'),
                     (1,'BBB','b',12.123,'21:11:11',2001,'TEST2','TEST2'),
                     (2,'CCC','c',13.123,'22:22:01',2002,'TEST3','TEST3'),
                     (3,'DDD','c',14.123,'23:33:11',2003,'TEST4','TEST4'),
                     (4,'EEE','c',15.123,'19:44:01',2004,'TEST5','TEST5'),
                     (5,'FFF','d',16.123,'18:55:11',2005,'TEST6','TEST6'),
                     (6,'EEE','d',16.123,'17:05:17',2006,'TEST7','TEST7');

CREATE INDEX ind_2 ON t1(c3);

#INSERT型trigger


DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert AFTER INSERT ON t2
    FOR EACH ROW
    BEGIN
        DECLARE c INT;
        SELECT MAX(c0) INTO c FROM t1;

        IF NEW.c0 = c THEN
            DELETE FROM t1 WHERE c0 = NEW.c0;
        ELSE
            INSERT INTO t1(c0,c1,c2,c3,c4) VALUES(NEW.c0,CONCAT(NEW.c1,NEW.c1),NEW.c2,NEW.c3+NEW.c0,TIME(NEW.c4));
        END IF;
    END;

//


#UPDATE型trigger


DROP TRIGGER IF EXISTS trg_update;//


CREATE TRIGGER trg_update AFTER UPDATE ON t1
FOR EACH ROW
BEGIN
    UPDATE t2 SET c0=NEW.c0,c1=CONCAT(NEW.c1,NEW.c1) WHERE c0=OLD.c0;
END
//


#DELETE型trigger


DROP TRIGGER IF EXISTS trg_delete;//


CREATE TRIGGER trg_delete AFTER DELETE ON t2
    FOR EACH ROW
    BEGIN
        DELETE FROM t1 WHERE c0=OLD.c0+1;
    END;

//

DELIMITER ;//



