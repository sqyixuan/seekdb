#owner:zhenjiang.xzj
#owner group: 技术部-存储-索引与DDL
#description: 在RANGE/LIST分区表中，根据创建不同数据类型及不同约束、索引的表去创建trigger，然后执行DDL【CREATE/DROP/ALTER】操作，最后执行trigger
#author: wb-zc01081081

--disable_warnings

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--enable_result_log


#创建数据库naaj_test
CREATE DATABASE IF NOT EXISTS trigger_test;
USE trigger_test;


--echo #mysql_trigger_ddl
--echo #mysql_trigger_ddl-1
--echo #mysql_trigger_ddl-1-1/mysql_trigger_ddl-1-3/mysql_trigger_ddl-1-4
--echo #mysql_trigger_ddl-2
--echo #mysql_trigger_ddl-2-1/mysql_trigger_ddl-2-2/mysql_trigger_ddl-2-3


--echo #创建不同类型的分区表，使用不同约束索引条件，然后再创建不同触发类型的trigger，最后对表执行DDL操作后触发trigger


--echo #RANGE分区

DROP TABLE IF EXISTS t2;

CREATE TABLE t2(c0 INT,
                c1 VARCHAR(10),
                c2 SET('a','b','c','d','e','f','g'),
                c3 FLOAT,
                c4 DATE)
PARTITION BY RANGE(c0)
(PARTITION p1 VALUES LESS THAN(0),
 PARTITION p2 VALUES LESS THAN(50),
 PARTITION p3 VALUES LESS THAN(100),
 PARTITION p4 VALUES LESS THAN(MAXVALUE)
);

INSERT INTO t2 VALUES(0,'AA','a',0.123,'2000-01-01'),
                     (1,'BB','a',2.123,'2001-11-11'),
                     (3,'CC','b',3.123,'2002-02-01'),
                     (4,'DD','b',4.123,'2003-03-11'),
                     (5,'EE','c',5.123,'2004-04-01'),
                     (6,'FF','c',6.123,'2005-05-11');


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 SMALLINT ZEROFILL,
                c1 CHAR(10),
                c2 ENUM('a','b','c','d','e','f','g') NOT NULL DEFAULT 'a',
                c3 DOUBLE,
                c4 TIME,
                CONSTRAINT uni_key UNIQUE KEY(c0,c2))
PARTITION BY RANGE(c0)
(PARTITION r1 VALUES LESS THAN(100),
 PARTITION r2 VALUES LESS THAN(200),
 PARTITION r3 VALUES LESS THAN(300),
 PARTITION r4 VALUES LESS THAN(MAXVALUE)
);

INSERT INTO t1 VALUES(0,'AAA','a',10.123,'20:01:01'),
                     (1,'BBB','b',12.123,'21:11:11'),
                     (2,'CCC','c',13.123,'22:22:01'),
                     (3,'DDD','c',14.123,'23:33:11'),
                     (4,'EEE','c',15.123,'19:44:01'),
                     (5,'FFF','d',16.123,'18:55:11'),
                     (6,'EEE','d',16.123,'17:05:17');

CREATE INDEX ind_1 ON t1(c3,c4);
CREATE INDEX ind_2 ON t1(c3);

#INSERT型trigger


DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert AFTER INSERT ON t2
    FOR EACH ROW
    BEGIN
        DECLARE c INT;
        SELECT MAX(c0) INTO c FROM t1;

        IF NEW.c0 = c THEN
            DELETE FROM t1 WHERE c0 = NEW.c0;
        ELSE
            INSERT INTO t1 VALUES(NEW.c0,CONCAT(NEW.c1,NEW.c1),NEW.c2,NEW.c3+NEW.c0,TIME(NEW.c4));
        END IF;
    END;

//


#UPDATE型trigger


DROP TRIGGER IF EXISTS trg_update;//


CREATE TRIGGER trg_update AFTER UPDATE ON t1
FOR EACH ROW
BEGIN
    UPDATE t2 SET c0=NEW.c0,c1=CONCAT(NEW.c1,NEW.c1) WHERE c0=OLD.c0;
END
//


#DELETE型trigger


DROP TRIGGER IF EXISTS trg_delete;//


CREATE TRIGGER trg_delete AFTER DELETE ON t2
    FOR EACH ROW
    BEGIN
        DELETE FROM t1 WHERE c0=OLD.c0+1;
    END;

//

DELIMITER ;//


#修改引用表的索引

alter system set _enable_drop_and_add_index = true;
sleep 2;
ALTER TABLE t1 DROP INDEX ind_1,ADD INDEX ind1(c1),RENAME INDEX ind_2 TO ind2;
alter system set _enable_drop_and_add_index = false;
sleep 2;
SHOW CREATE TABLE t1;

SELECT /*+INDEX(ind1)*/ * FROM t1 WHERE c1='AAA';
#EXPLAIN BASIC SELECT /*+INDEX(ind1)*/ * FROM t1 WHERE c1='AAA';

--echo #此处执行OB报错，待开发修复后执行，问题链接：

#INSERT INTO t2 VALUES(7,'GG','d',7.89,'2006-02-12');
#SELECT * FROM t2 WHERE c0=7;
#SELECT * FROM t1 WHERE c0=7;


UPDATE t1 SET c0=16,c1='H',c2='a',c3='17.789',c4='06:00:00' WHERE c0=6;
SELECT * FROM t2 WHERE c0=16;
SELECT * FROM t1 WHERE c0=16;

DELETE FROM t2 WHERE c0=1;
SELECT * FROM t2 WHERE c0=1;
SELECT * FROM t1 WHERE c0=2;


#新增、删除约束

alter system set _enable_drop_and_add_index = true;
sleep 2;
ALTER TABLE t1 ADD CONSTRAINT unk UNIQUE KEY(c0),DROP INDEX uni_key;
alter system set _enable_drop_and_add_index = false;
sleep 2;
SHOW CREATE TABLE t1;

--echo #问题同上

#INSERT INTO t2 VALUES(8,'HH','e',8.89,'2008-08-18');
#SELECT * FROM t2 WHERE c0=8;
#SELECT * FROM t1 WHERE c0=8;

UPDATE t1 SET c0=2,c1='A',c2='b',c3='11.189',c4='22:02:20' WHERE c0=3;
SELECT * FROM t2 WHERE c0=2;
SELECT * FROM t1 WHERE c0=2;

DELETE FROM t2 WHERE c0=4;
SELECT * FROM t2 WHERE c0=4;
SELECT * FROM t1 WHERE c0=5;



#修改并行度，block_size，自增值


ALTER TABLE t1 SET PARALLEL=10,BLOCK_SIZE=20480,AUTO_INCREMENT=100;
SHOW CREATE TABLE t1;

--echo #问题同上，修改后执行sql

#INSERT INTO t2 VALUES(16,'BB','e',19.123,'2009-09-01');
#SELECT * FROM t2 WHERE c0=16 ORDER BY 1,2;
#SELECT * FROM t1 WHERE c0=16;


UPDATE t1 SET c0=3,c1='CCC',c2='d',c3='13.139',c4='23:33:30' WHERE c0=4;
SELECT * FROM t2 WHERE c0=3;
SELECT * FROM t1 WHERE c0=3;

DELETE FROM t2 WHERE c0=2;
SELECT * FROM t2 WHERE c0=2;
SELECT * FROM t1 WHERE c0=3;


SET sql_mode='NO_AUTO_VALUE_ON_ZERO';


DROP TABLE IF EXISTS t2;

CREATE TABLE t2(c0 INT,
                c1 VARCHAR(10),
                c2 SET('a','b','c','d','e','f','g'),
                c3 FLOAT,
                c4 DATE)
PARTITION BY RANGE(c0)
(PARTITION p1 VALUES LESS THAN(0),
 PARTITION p2 VALUES LESS THAN(50),
 PARTITION p3 VALUES LESS THAN(100),
 PARTITION p4 VALUES LESS THAN(MAXVALUE)
);

INSERT INTO t2 VALUES(0,'AA','a',0.123,'2000-01-01'),
                     (1,'BB','a',2.123,'2001-11-11'),
                     (3,'CC','b',3.123,'2002-02-01'),
                     (4,'DD','b',4.123,'2003-03-11'),
                     (5,'EE','c',5.123,'2004-04-01'),
                     (6,'FF','c',6.123,'2005-05-11');


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 SMALLINT ZEROFILL,
                c1 CHAR(10),
                c2 ENUM('a','b','c','d','e','f','g') NOT NULL DEFAULT 'a',
                c3 DOUBLE,
                c4 TIME,
                CONSTRAINT uni_key UNIQUE KEY(c0))
PARTITION BY RANGE(c0)
(PARTITION r1 VALUES LESS THAN(100),
 PARTITION r2 VALUES LESS THAN(200),
 PARTITION r3 VALUES LESS THAN(300),
 PARTITION r4 VALUES LESS THAN(MAXVALUE)
);

INSERT INTO t1 VALUES(0,'AAA','a',10.123,'20:01:01'),
                     (1,'BBB','b',12.123,'21:11:11'),
                     (2,'CCC','c',13.123,'22:22:01'),
                     (3,'DDD','c',14.123,'23:33:11'),
                     (4,'EEE','c',15.123,'19:44:01'),
                     (5,'FFF','d',16.123,'18:55:11'),
                     (6,'EEE','d',16.123,'17:05:17');

CREATE INDEX ind_1 ON t1(c3,c4);
CREATE INDEX ind_2 ON t1(c3);

#INSERT型trigger


DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert AFTER INSERT ON t2
    FOR EACH ROW
    BEGIN
        DECLARE c INT;
        SELECT MAX(c0) INTO c FROM t1;

        IF NEW.c0 = c THEN
            DELETE FROM t1 WHERE c0 = NEW.c0;
        ELSE
            INSERT INTO t1 VALUES(NEW.c0,CONCAT(NEW.c1,NEW.c1),LOWER(NEW.c1),2*NEW.c0,'00:00:00');
        END IF;
    END;

//


#UPDATE型trigger


DROP TRIGGER IF EXISTS trg_update;//


CREATE TRIGGER trg_update AFTER UPDATE ON t1
FOR EACH ROW
BEGIN
    UPDATE t2 SET c0=NEW.c0,c1=NEW.c1 WHERE c0=OLD.c0;
END
//


#DELETE型trigger


DROP TRIGGER IF EXISTS trg_delete;//


CREATE TRIGGER trg_delete AFTER DELETE ON t2
    FOR EACH ROW
    BEGIN
        DELETE FROM t1 WHERE c0=OLD.c0+1;
    END;

//

DELIMITER ;//


#设置表级的字符集和字符序，以及表的备注信息

--echo #暂不支持，待支持后执行sql

--disable_parsing

--echo #此处OB执行成功后，发现对enum类型列有影响，问题链接：

ALTER TABLE t1 CONVERT TO CHARACTER SET 'utf16' COLLATE 'utf16_bin',SET COMMENT '修改表级字符集和字符序';
SHOW CREATE TABLE t1;

INSERT INTO t2 VALUES(7,'II','d',7.89,'2006-06-06');
SELECT * FROM t2 WHERE c0=7;
SELECT * FROM t1 WHERE c0=7;

UPDATE t1 SET c0=10,c1='H',c2='a',c3='17.789',c4='06:00:00' WHERE c0=6;
SELECT * FROM t2 WHERE c0=10;
SELECT * FROM t1 WHERE c0=10;

DELETE FROM t2 WHERE c0=0;
SELECT * FROM t2 WHERE c0=0;
SELECT * FROM t1 WHERE c0=1;


--enable_parsing


#带有外键约束时，删除外键约束,MySQL中，不支持引用分区表的列创建外键约束，OB目前支持，bydesign。


DROP TABLE IF EXISTS t2;
CREATE TABLE t2(c0 SMALLINT ZEROFILL,c1 VARCHAR(10),CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t1(c0));
INSERT INTO t2 VALUES(2,'b'),(3,'b'),(4,'c'),(5,'c');

--error 4179
ALTER TABLE t1 DROP INDEX uni_key,ADD CONSTRAINT uni UNIQUE KEY(c0,c2);
SHOW CREATE TABLE t1;


DELIMITER //;

CREATE TRIGGER trg_insert AFTER INSERT ON t2
    FOR EACH ROW
    BEGIN
        DECLARE c INT;
        SELECT MAX(c0) INTO c FROM t1;

        IF NEW.c0 = c THEN
            DELETE FROM t1 WHERE c0 = NEW.c0;
        ELSE
            INSERT INTO t1 VALUES(NEW.c0,CONCAT(NEW.c1,NEW.c1),LOWER(NEW.c1),2*NEW.c0,'00:00:00');
        END IF;
    END;

//


#DELETE型trigger



CREATE TRIGGER trg_delete AFTER DELETE ON t2
    FOR EACH ROW
    BEGIN
        DELETE FROM t1 WHERE c0=OLD.c0+1;
    END;

//

DELIMITER ;//

#此处如果引用键为联合主键或者组合唯一约束，是无法创建外键约束的。

--error 01215
ALTER TABLE t2 DROP FOREIGN KEY fk_c0_c0,ADD CONSTRAINT fk_c1_c2 FOREIGN KEY(c1) REFERENCES t1(c2);
SHOW CREATE TABLE t2;



