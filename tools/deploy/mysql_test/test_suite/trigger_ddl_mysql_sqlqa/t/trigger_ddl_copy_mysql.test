#owner:zhenjiang.xzj
#owner group: 技术部-存储-索引与DDL
#description: 在复制表中，根据创建不同数据类型及不同约束、索引的表去创建trigger，然后执行DDL操作，最后执行trigger
#author: wb-zc01081081

--disable_warnings

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--enable_result_log


#创建数据库naaj_test
CREATE DATABASE IF NOT EXISTS trigger_test;
USE trigger_test;


SET sql_mode='NO_AUTO_VALUE_ON_ZERO';
SET AUTOCOMMIT=0;

--echo #复制表
--echo #创建复制表，使用不同约束索引条件，然后再创建不同触发类型的trigger，最后对表执行DDL操作后触发trigger


DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 TINYINT ZEROFILL AUTO_INCREMENT,
                c1 FLOAT NOT NULL,
                c2 DOUBLE(5,0) ,
                c3 BIT(20) DEFAULT 0,
                c4 BLOB,
                c5 TEXT,
                c6 VARCHAR(50),
                c7 CHAR(50),
                c8 BINARY(50) NOT NULL,
                c9 VARBINARY(50) NOT NULL,
                c10 ENUM('a','b','c','d','e','f','g','h'),
                c11 SET('i','j','k','l','m','n','o','p'),
                c12 TIME NOT NULL,
                c13 DATE NOT NULL,
                c14 DATETIME NOT NULL,
                c15 TIMESTAMP DEFAULT '2000-01-01 00:00:00',
                c16 YEAR ,
                PRIMARY KEY(c0,c1,c2),
                UNIQUE KEY uni_key(c6,c10));
INSERT INTO t1 VALUES(1,1.5,1,'',x'89504E470D0A1A0A0000000D4948445206105000000097048597300000EC300000EC301C76FA8640000001','89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843','','','1teshu*符号@$￥%','SHUZI!123456','a','i','20:12:12','2000-12-12','2000-01-01 01:01:01','2001-01-01 12:01:01.34567','2000'),
                     (2,2.5,2,b'110101',x'89504E470D0A1A0A0000000D4997300000EC300000EC301C76FA8640000001E49444154384','89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843','中文—汉化','1english_language','2teshu*符号@$￥%','SHUZI!12345','b','j','21:12:12','2001-12-22','2001-01-01 13:01:01','2001-11-01 11:01:01.34567','2010'),
                     (3,3.5,3,b'011101',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550F1A8066242','89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843','删除时使用情景','2english_language','3teshu*符号@$￥%','SHUZI!1234','c','k','22:12:12','2002-12-02','2002-01-01 14:01:01','2002-12-01 02:01:01.34567','2000'),
                     (4,4.5,4,b'010111',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550F1A8066242','89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843','删除中——汉化','3english_language','4teshu*符号@$￥%','SHUZI!123','d','l','23:12:12','2003-12-11','2003-01-01 15:01:01','2002-11-01 03:01:01.34567','2010'),
                     (5,5.5,5,b'111101',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550','89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843','删除中文*汉化删除','4english_language','5teshu*符号@$￥%','SHUZI!12','e','m','20:22:12','2004-12-12','2004-01-01 16:01:01','2002-02-04 05:01:01.34567','2000'),
                     (6,6.5,6,b'110111',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550','89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843','除列时使用情景','5english_language','6teshu*符号@$￥%','SHUZI!1','f','n','20:32:12','2021-12-13','2010-01-01 21:01:01','2003-03-01 04:01:01.34567','2010');


CREATE INDEX ind_1 ON t1(c12);
CREATE INDEX ind_2 ON t1(c3,c7,c14);


DROP TABLE IF EXISTS t2;
CREATE TABLE t2(c0 INT,c1 VARCHAR(10));
INSERT INTO t2 VALUES(1,'A'),(2,'B'),(3,'C'),(4,'D'),(5,'E');

#as关键字创建复制表


DROP TABLE IF EXISTS cp_t1;

CREATE TABLE cp_t1 AS SELECT * FROM t1;
SELECT * FROM cp_t1 ORDER BY 1;
DESC cp_t1;
SHOW INDEX FROM cp_t1;


DROP TABLE IF EXISTS cp_t2;

CREATE TABLE cp_t2 AS SELECT * FROM t2;
SELECT * FROM cp_t2 ORDER BY 1;
DESC cp_t2;
SHOW INDEX FROM cp_t2;



#INSERT型触发器



DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert BEFORE INSERT ON cp_t2
    FOR EACH ROW
    BEGIN
        DECLARE c INT;
        SELECT MAX(c0) INTO c FROM cp_t1;

        IF NEW.c0 = c THEN
            DELETE FROM cp_t1 WHERE c0 = NEW.c0;
        ELSE
            INSERT INTO cp_t1 VALUES(NEW.c0,NEW.c0+0.5,NEW.c0,b'11111',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550','89504E470D0A1A0A00C76FA8640000001E49444154384F6AE843','除列情景','enish_lanage','tesu*符号￥%','SHUZI!34567','g','l','22:32:12','2022-12-13','2012-01-01 22:01:01','2013-03-21 14:21:21.34567','2011');
        END IF;
    END;

//

DELIMITER ;//


#修改引用表的索引

ALTER TABLE cp_t1 ADD INDEX ind1(c13),ADD CONSTRAINT uni_key UNIQUE KEY(c0,c1);
SHOW CREATE TABLE cp_t1;

SELECT /*+INDEX(ind1)*/ c0,c1,c2,c13 FROM cp_t1 WHERE c13='2000-12-12';

#EXPLAIN BASIC SELECT /*+INDEX(ind1)*/ c0,c1,c2,c13 FROM cp_t1 WHERE c13='2000-12-12';

INSERT INTO cp_t2 VALUES(6,'F');
SELECT * FROM cp_t2 WHERE c0=6;
SELECT * FROM cp_t1 WHERE c0=6;


#新增、删除约束

alter system set _enable_drop_and_add_index = true;
sleep 2;
ALTER TABLE cp_t1 ADD CONSTRAINT unk1 UNIQUE KEY(c7,c11),RENAME KEY uni_key TO unk2,DROP INDEX ind1;
alter system set _enable_drop_and_add_index = false;
sleep 2;
SHOW CREATE TABLE cp_t1;

INSERT INTO cp_t2 VALUES(7,'G');
SELECT * FROM cp_t2 WHERE c0=7;
SELECT c0,c1,c2 FROM cp_t1 WHERE c0=7;


#修改并行度，block_size，自增值


ALTER TABLE cp_t1 SET PARALLEL=10,BLOCK_SIZE=20480,AUTO_INCREMENT=100;
SHOW CREATE TABLE cp_t1;

INSERT INTO cp_t2 VALUES(7,'H');
SELECT * FROM cp_t2 WHERE c0=7 ORDER BY 1,2;
SELECT c0,c1,c2 FROM cp_t1 WHERE c0=7;


#设置表级的字符集和字符序，以及表的备注信息

--echo #暂不支持，待支持后执行sql

--disable_parsing

ALTER TABLE cp_t1 CONVERT TO CHARACTER SET 'utf16' COLLATE 'utf16_bin',SET COMMENT '修改表级字符集和字符序';
SHOW CREATE TABLE cp_t1;

INSERT INTO cp_t2 VALUES(8,'I');
SELECT * FROM cp_t2 WHERE c0=8;
SELECT c0,c1,c2 FROM cp_t1 WHERE c0=8;

--enable_parsing


#带有外键约束时，删除外键约束

--echo #创建带有外键约束的表报错，是t1表中的复合主键导致的报错，有问题，待开发修复后执行下列sql

--disable_parsing

DROP TABLE IF EXISTS cp_t2;
CREATE TABLE cp_t2 AS SELECT * FROM t2;


DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert BEFORE INSERT ON cp_t2
    FOR EACH ROW
    BEGIN
        DECLARE c INT;
        SELECT MAX(c0) INTO c FROM cp_t1;

        IF NEW.c0 = c THEN
            DELETE FROM cp_t1 WHERE c0 = NEW.c0;
        ELSE
            INSERT INTO cp_t1 VALUES(NEW.c0,NEW.c0+0.5,NEW.c0,b'11111',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550','89504E470D0A1A0A00C76FA8640000001E49444154384F6AE843','除列情景','enish_lanage','tesu*符号￥%','SHUZI!34567','g','l','22:32:12','2022-12-13','2012-01-01 22:01:01','2013-03-21 14:21:21.34567','2011');
        END IF;
    END;

//

DELIMITER ;//

ALTER TABLE cp_t2 MODIFY c0 TINYINT ZEROFILL;
ALTER TABLE cp_t2 ADD CONSTRAINT fk_c1_c10 FOREIGN KEY(c0) REFERENCES t1(c0);
SHOW CREATE TABLE t2;

INSERT INTO cp_t2 VALUES(5,'d');
SELECT * FROM cp_t2 WHERE c0=5;
SELECT c0,c1,c2 FROM cp_t1 WHERE c0=5;


--enable_parsing


#修改表名

DROP TABLE IF EXISTS test1;

ALTER TABLE cp_t1 RENAME test1;
SHOW TABLES;
SELECT test1.c0,test1.c1 FROM test1 ORDER BY 1;

INSERT INTO t2 VALUES(4,'J');
SELECT * FROM t2 WHERE c0=4 ORDER BY 1,2;
SELECT c0,c1,c2 FROM test1 WHERE c0=4;



#DELETE型触发器


DROP TABLE IF EXISTS cp_t1;

CREATE TABLE cp_t1 AS SELECT * FROM t1;
SELECT * FROM cp_t1 ORDER BY 1;
DESC cp_t1;
SHOW INDEX FROM cp_t1;


DROP TABLE IF EXISTS cp_t2;

CREATE TABLE cp_t2 AS SELECT * FROM t2;
SELECT * FROM cp_t2 ORDER BY 1;
DESC cp_t2;
SHOW INDEX FROM cp_t2;


DROP TRIGGER IF EXISTS trg_delete;

DELIMITER //;

CREATE TRIGGER trg_delete BEFORE DELETE ON cp_t2
    FOR EACH ROW
    BEGIN
        DELETE FROM cp_t1 WHERE c0=OLD.c0 OR c10=OLD.c1 OR c11=OLD.c1;
    END;

//

DELIMITER ;//


#修改引用表的索引


ALTER TABLE cp_t1 ADD INDEX ind1(c13),ADD CONSTRAINT uni_key UNIQUE KEY(c0,c1);
SHOW CREATE TABLE cp_t1;

SELECT /*+INDEX(ind1)*/ c0,c1,c2,c13 FROM cp_t1 WHERE c13='2000-12-12';

#EXPLAIN BASIC SELECT /*+INDEX(ind1)*/ c0,c1,c2,c13 FROM cp_t1 WHERE c13='2000-12-12';

DELETE FROM cp_t2 WHERE c0=5;
SELECT c0,c1 FROM cp_t2 ORDER BY 1;
SELECT c0,c1 FROM cp_t1 ORDER BY 1;

ROLLBACK;

SELECT c0,c1 FROM cp_t2 ORDER BY 1;
SELECT c0,c1 FROM cp_t1 ORDER BY 1;


#新增、删除约束

alter system set _enable_drop_and_add_index = true;
sleep 2;
ALTER TABLE cp_t1 ADD CONSTRAINT unk1 UNIQUE KEY(c7,c11),RENAME KEY uni_key TO unk2,DROP INDEX ind1;
alter system set _enable_drop_and_add_index = false;
sleep 2;
SHOW CREATE TABLE cp_t1;

DELETE FROM cp_t2 WHERE c0=4;
SELECT c0,c1 FROM cp_t2 ORDER BY 1;
SELECT c0,c1 FROM cp_t1 ORDER BY 1;

ROLLBACK;
SELECT c0,c1 FROM cp_t2 ORDER BY 1;
SELECT c0,c1 FROM cp_t1 ORDER BY 1;


#修改并行度，block_size，自增值


ALTER TABLE cp_t1 SET PARALLEL=10,BLOCK_SIZE=20480,AUTO_INCREMENT=100;
SHOW CREATE TABLE cp_t1;

DELETE FROM cp_t2 WHERE c0=3;
SELECT c0,c1 FROM cp_t2 ORDER BY 1;
SELECT c0,c1 FROM cp_t1 ORDER BY 1;

ROLLBACK;
SELECT c0,c1 FROM cp_t2 ORDER BY 1;
SELECT c0,c1 FROM cp_t1 ORDER BY 1;


