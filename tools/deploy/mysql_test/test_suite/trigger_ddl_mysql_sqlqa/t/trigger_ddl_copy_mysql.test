DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert AFTER INSERT ON cp_t2
    FOR EACH ROW
    BEGIN
        DECLARE c INT;
        SELECT MAX(c0) INTO c FROM cp_t1;

        IF NEW.c0 = c THEN
