                c3 DOUBLE,
                c4 TIME,
                c5 INT DEFAULT 0,
                c6 BLOB,
                c7 BINARY(10) DEFAULT 'test',
                CONSTRAINT uni_key UNIQUE KEY(c0,c1))
PARTITION BY LIST COLUMNS(c1)
SUBPARTITION BY KEY(c0) SUBPARTITIONS 4
(PARTITION r1 VALUES IN('AAA','BBB','CCC','DDD','EEE','FFF','GGG'),
 PARTITION r2 VALUES IN('HHH','III','JJJ','KKK','LLL','MMM','NNN'),
 PARTITION r3 VALUES IN('OOO','PPP','QQQ','RRR','SSS','TTT','UUU')
);

