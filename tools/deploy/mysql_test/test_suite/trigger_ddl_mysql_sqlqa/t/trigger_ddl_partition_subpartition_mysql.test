--echo #创建不同类型的分区表，使用不同约束索引条件，然后再创建不同触发类型的trigger，最后对表中的列执行DDL操作后触发trigger


#SUBPARTITION分区


DROP TABLE IF EXISTS t2;

CREATE TABLE t2(c0 INT,
                c1 VARCHAR(10),
                c2 SET('a','b','c','d','e','f','g','h','i','j','k','l','m','n'),
                c3 INT,
                c4 DATE,
                c5 YEAR DEFAULT '2000',
                c6 TEXT ,
                c7 VARBINARY(10) DEFAULT 'TEST')
PARTITION BY RANGE(c0)
SUBPARTITION BY KEY(c3) SUBPARTITIONS 3
(PARTITION p1 VALUES LESS THAN(0),
 PARTITION p2 VALUES LESS THAN(50),
 PARTITION p3 VALUES LESS THAN(100),
 PARTITION p4 VALUES LESS THAN(MAXVALUE)
);

