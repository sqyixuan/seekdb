#RANGE_COLUMNS/LIST_COLUMNS分区



DROP TABLE IF EXISTS t2;

CREATE TABLE t2(c0 INT,
                c1 VARCHAR(10),
                c2 SET('a','b','c','d','e','f','g','h','i','j','k','l','m','n'),
                c3 FLOAT,
                c4 DATE,
                PRIMARY KEY(c0,c1))
PARTITION BY RANGE COLUMNS(c1)
SUBPARTITION BY HASH(c0) SUBPARTITIONS 3
(PARTITION p1 VALUES LESS THAN('GG'),
 PARTITION p2 VALUES LESS THAN('NN'),
 PARTITION p3 VALUES LESS THAN('TT'),
 PARTITION p4 VALUES LESS THAN('ZZ')
);

INSERT INTO t2 VALUES(-13,'AA','a',0.123,'2000-01-01'),
                     (-10,'BB','a',2.123,'2001-11-11'),
                     (-5,'CC','b',3.123,'2002-02-01'),
                     (0,'DD','b',4.123,'2003-03-11'),
                     (1,'EE','c',5.123,'2004-04-01'),
                     (3,'FF','d',6.123,'2005-05-19'),
                     (22,'TT','e',7.123,'2006-06-18'),
                     (53,'BB','f',8.123,'2007-07-17'),
                     (71,'QQ','g',9.123,'2008-08-14'),
                     (84,'II','h',10.123,'2009-09-15'),
                     (103,'YY','i',11.123,'2010-10-16'),
                     (120,'LL','a',12.123,'2011-11-13'),
                     (303,'SS','b',13.123,'2012-12-12');


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 SMALLINT ZEROFILL,
                c1 CHAR(10),
                c2 ENUM('a','b','c','d','e','f','g','h','i','j','k','l','m','n') NOT NULL DEFAULT 'a',
                c3 DOUBLE,
                c4 TIME,
                CONSTRAINT uni_key UNIQUE KEY(c0,c1))
PARTITION BY LIST COLUMNS(c1)
SUBPARTITION BY KEY(c0) SUBPARTITIONS 4
(PARTITION r1 VALUES IN('AAAA','BBBB','CCCC','DDDD','EEEE','FFFF','GGGG'),
 PARTITION r2 VALUES IN('HHHH','IIII','JJJJ','KKKK','LLLL','MMMM','NNNN'),
 PARTITION r3 VALUES IN('OOOO','PPPP','QQQQ','RRRR','SSSS','TTTT','UUUU')
);

INSERT INTO t1 VALUES(0,'AAAA','a',10.123,'20:01:01'),
                     (1,'BBBB','b',12.123,'21:11:11'),
                     (7,'CCCC','c',13.123,'22:22:01'),
                     (9,'DDDD','c',14.123,'23:33:11'),
                     (11,'EEEE','c',15.123,'19:44:01'),
                     (14,'KKKK','d',16.123,'18:55:21'),
                     (17,'HHHH','d',17.123,'17:55:31'),
                     (20,'LLLL','e',18.123,'16:55:41'),
                     (22,'NNNN','f',19.123,'15:45:51'),
                     (23,'TTTT','g',26.123,'14:35:31'),
                     (25,'RRRR','g',36.123,'13:25:21'),
                     (27,'QQQQ','i',46.123,'12:15:11');

CREATE INDEX ind_1 ON t1(c3,c4);


#创建INSERT/UPDATE/DELETE型触发器

DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert BEFORE INSERT ON t2
FOR EACH ROW
BEGIN
    DECLARE c INT;
    SELECT MAX(c0) INTO c FROM t1;

    IF NEW.c0 = c THEN
        DELETE FROM t1 WHERE c0 = NEW.c0;
    ELSE
        INSERT INTO t1 VALUES(NEW.c0,CONCAT(NEW.c1,NEW.c1),NEW.c2,NEW.c3+NEW.c0,TIME(NEW.c4));
    END IF;
END;

//


DROP TRIGGER IF EXISTS trg_update;//


CREATE TRIGGER trg_update BEFORE UPDATE ON t1
FOR EACH ROW
BEGIN
    UPDATE t2 SET c0=NEW.c0 WHERE c0=OLD.c0;
END
//


DROP TRIGGER IF EXISTS trg_delete;//


CREATE TRIGGER trg_delete AFTER DELETE ON t2
FOR EACH ROW
BEGIN
    DELETE FROM t1 WHERE c0=OLD.c0+1;
END;

//

DELIMITER ;//


