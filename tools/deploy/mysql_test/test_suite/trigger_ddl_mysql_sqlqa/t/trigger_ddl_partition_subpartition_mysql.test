#RANGE_COLUMNS/LIST_COLUMNS分区



DROP TABLE IF EXISTS t2;

CREATE TABLE t2(c0 INT,
                c1 VARCHAR(10),
                c2 SET('a','b','c','d','e','f','g','h','i','j','k','l','m','n'),
                c3 FLOAT,
                c4 DATE,
                c5 YEAR DEFAULT '2000',
                c6 TEXT ,
                c7 VARBINARY(10) DEFAULT 'TEST',
                PRIMARY KEY(c0,c1))
PARTITION BY RANGE COLUMNS(c1)
SUBPARTITION BY HASH(c0) SUBPARTITIONS 3
(PARTITION p1 VALUES LESS THAN('GG'),
 PARTITION p2 VALUES LESS THAN('NN'),
 PARTITION p3 VALUES LESS THAN('TT'),
 PARTITION p4 VALUES LESS THAN('ZZ')
);

