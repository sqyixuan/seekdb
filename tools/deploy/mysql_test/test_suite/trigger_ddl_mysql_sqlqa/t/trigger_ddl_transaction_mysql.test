#创建INSERT/UPDATE/DELETE型触发器

DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert AFTER INSERT ON t2
FOR EACH ROW
BEGIN
    DECLARE c INT;
    SELECT MAX(c0) INTO c FROM t1;

    IF NEW.c0 = c THEN
        DELETE FROM t1 WHERE c0 = NEW.c0;
    ELSE
        INSERT INTO t1 VALUES(NEW.c0,CONCAT(NEW.c1,NEW.c1),NEW.c2,NEW.c3+NEW.c0,TIME(NEW.c4));
    END IF;
END;

//


DROP TRIGGER IF EXISTS trg_update;//


CREATE TRIGGER trg_update AFTER UPDATE ON t1
FOR EACH ROW
BEGIN
    UPDATE t2 SET c0=NEW.c0,c1=CONCAT(NEW.c1,NEW.c1) WHERE c0=OLD.c0;
END
//


DROP TRIGGER IF EXISTS trg_delete;//


CREATE TRIGGER trg_delete AFTER DELETE ON t2
FOR EACH ROW
BEGIN
    DELETE FROM t1 WHERE c0=OLD.c0+1;
END;

//

DELIMITER ;//



#事务的回滚


BEGIN;

SAVEPOINT s1;
INSERT INTO t2 VALUES(27,'HH','g',27.123,'2017-07-17'),(29,'II','h',29.123,'2019-09-19');

SELECT * FROM t1 WHERE c0 IN(27,29);
SELECT * FROM t2 WHERE c0 IN(27,29);

SAVEPOINT s2;
--error 01526
UPDATE t1 SET c0=31,c1='HHH' WHERE c0=0;
UPDATE t1 SET c0=2,c1='HHH' WHERE c0=0;

SELECT * FROM t1 WHERE c0 IN(2);
SELECT * FROM t2 WHERE c0 IN(2);

SAVEPOINT s3;
DELETE FROM t2 WHERE c0=120;
DELETE FROM t2 WHERE c0=22;

SELECT * FROM t1 WHERE c0 IN(22);
SELECT * FROM t2 WHERE c0 IN(120,22);


ROLLBACK TO s2;
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


COMMIT;


SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;



#在事务中执行DDL操作



