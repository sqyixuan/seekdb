#设置表级的字符集和字符序，以及表的备注信息

--echo #暂不支持，待支持后执行sql

--disable_parsing

--echo #此处OB执行成功后，发现对enum类型列有影响，问题链接：

ALTER TABLE t1 CONVERT TO CHARACTER SET 'utf16' COLLATE 'utf16_bin',SET COMMENT '修改表级字符集和字符序';
SHOW CREATE TABLE t1;

INSERT INTO t2 VALUES(7,'II','d',7.89,'2006-06-06');
SELECT * FROM t2 WHERE c0=7;
SELECT * FROM t1 WHERE c0=7;

ROLLBACK;

UPDATE t1 SET c0=10,c1='H',c2='a',c3='17.789',c4='06:00:00' WHERE c0=6;
SELECT * FROM t2 WHERE c0=10;
SELECT * FROM t1 WHERE c0=10;

ROLLBACK;

DELETE FROM t2 WHERE c0=0;
SELECT * FROM t2 WHERE c0=0;
SELECT * FROM t1 WHERE c0=1;

ROLLBACK;

--enable_parsing


#删除索引，新增外键约束

DROP INDEX ind2 ON t1;

--error 01215
ALTER TABLE t1 DROP INDEX ind1,ADD CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t2(c0);

SHOW CREATE TABLE t1;


INSERT INTO t2 VALUES(7,'II','d',7.89,'2006-06-06');
SELECT * FROM t2 WHERE c0=7;
SELECT * FROM t1 WHERE c0=7;

ROLLBACK;

UPDATE t1 SET c0=10,c1='H',c2='a',c3='17.789',c4='06:00:00' WHERE c0=6;
SELECT * FROM t2 WHERE c0=10;
SELECT * FROM t1 WHERE c0=10;

ROLLBACK;

DELETE FROM t2 WHERE c0=0;
SELECT * FROM t2 WHERE c0=0;
SELECT * FROM t1 WHERE c0=1;

ROLLBACK;


#普通表带有外键约束时，删除外键约束,MySQL中，不支持引用分区表的列创建外键约束，OB目前支持，bydesign。


DROP TABLE IF EXISTS t2;
CREATE TABLE t2(c0 SMALLINT ZEROFILL,c1 VARCHAR(10),CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t1(c0));
INSERT INTO t2 VALUES(0,'a'),(1,'b'),(3,'b'),(4,'c'),(5,'c'),(6,'a');


#创建INSERT/UPDATE/DELETE型触发器

DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert BEFORE INSERT ON t2
FOR EACH ROW
BEGIN
    DECLARE c INT;
    SELECT MAX(c0) INTO c FROM t1;

    IF NEW.c0 = c THEN
        DELETE FROM t1 WHERE c0 = NEW.c0;
    ELSE
        INSERT INTO t1 VALUES(NEW.c0,CONCAT(NEW.c1,NEW.c1),NEW.c1,2*NEW.c0,'00:00:00');
    END IF;
END;

//


DROP TRIGGER IF EXISTS trg_update;//


CREATE TRIGGER trg_update BEFORE UPDATE ON t1
FOR EACH ROW
BEGIN
    UPDATE t2 SET c0=NEW.c0,c1=CONCAT(NEW.c1,NEW.c1) WHERE c0=OLD.c0;
END
//


DROP TRIGGER IF EXISTS trg_delete;//


CREATE TRIGGER trg_delete AFTER DELETE ON t2
FOR EACH ROW
BEGIN
    DELETE FROM t1 WHERE c0=OLD.c0+1;
END;

//

DELIMITER ;//


alter system set _enable_drop_and_add_index = true;
sleep 2;
ALTER TABLE t1 DROP INDEX unk,ADD CONSTRAINT uni UNIQUE KEY(c0,c2);
alter system set _enable_drop_and_add_index = false;
sleep 2;
SHOW CREATE TABLE t1;


INSERT INTO t2 VALUES(7,'d');
SELECT * FROM t2 WHERE c0=7;
SELECT * FROM t1 WHERE c0=7;

ROLLBACK;

--error 01452
UPDATE t1 SET c0=10,c1='H',c2='a',c3='17.789',c4='06:00:00' WHERE c0=6;

SELECT * FROM t2 WHERE c0=10;
SELECT * FROM t1 WHERE c0=10;

ROLLBACK;

--error 01451
DELETE FROM t2 WHERE c0=0;
SELECT * FROM t2 WHERE c0=0;
SELECT * FROM t1 WHERE c0=1;


#修改表名


