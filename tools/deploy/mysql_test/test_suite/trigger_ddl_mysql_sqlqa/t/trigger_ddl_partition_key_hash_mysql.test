UPDATE test1 SET c0=20,c1='b' WHERE c0=3;
--error 01146
DELETE FROM t2 WHERE c0=3;


#创建trigger后对分区进行操作


DROP TABLE IF EXISTS t2;

CREATE TABLE t2(c0 INT,
                c1 VARCHAR(10),
                c2 SET('a','b','c','d','e','f','g'),
                c3 FLOAT,
                c4 DATE)
PARTITION BY HASH(c0)
(PARTITION p1,
 PARTITION p2,
 PARTITION p3,
 PARTITION p4
);

INSERT INTO t2 VALUES(0,'AA','a','0.123','2000-01-01'),
                     (1,'BB','a','2.123','2001-11-11'),
                     (3,'CC','b','3.123','2002-02-01'),
                     (4,'DD','b','4.123','2003-03-11'),
                     (5,'EE','c','5.123','2004-04-01'),
                     (6,'FF','c','6.123','2005-05-11');


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 SMALLINT ZEROFILL PRIMARY KEY,
                c1 CHAR(10),
                c2 ENUM('a','b','c','d','e','f','g') NOT NULL DEFAULT 'a',
                c3 DOUBLE,
                c4 TIME,
                CONSTRAINT uni_key UNIQUE KEY(c0,c2))
PARTITION BY KEY(c0)
(PARTITION r1,
 PARTITION r2,
 PARTITION r3,
 PARTITION r4
);

INSERT INTO t1 VALUES(0,'AAA','a','10.123','20:01:01'),
                     (1,'BBB','b','12.123','21:11:11'),
                     (3,'CCC','c','13.123','22:22:01'),
                     (4,'DDD','c','14.123','23:33:11'),
                     (5,'EEE','c','15.123','19:44:01'),
                     (6,'FFF','d','16.123','18:55:11');

CREATE INDEX ind_1 ON t1(c3,c4);


#创建INSERT/UPDATE/DELETE型触发器

DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert AFTER INSERT ON t2
FOR EACH ROW
BEGIN
    DECLARE c INT;
    SELECT MAX(c0) INTO c FROM t1;

    IF NEW.c0 = c THEN
        DELETE FROM t1 WHERE c0 = NEW.c0;
    ELSE
        INSERT INTO t1 VALUES(NEW.c0,CONCAT(NEW.c1,NEW.c1),NEW.c2,NEW.c3+NEW.c0,TIME(NEW.c4));
    END IF;
END;

//


DROP TRIGGER IF EXISTS trg_update;//


CREATE TRIGGER trg_update AFTER UPDATE ON t1
FOR EACH ROW
BEGIN
    UPDATE t2 SET c0=NEW.c0,c1=CONCAT(NEW.c1,NEW.c1) WHERE c0=OLD.c0;
END
//


DROP TRIGGER IF EXISTS trg_delete;//


CREATE TRIGGER trg_delete BEFORE DELETE ON t2
FOR EACH ROW
BEGIN
    DELETE FROM t1 WHERE c0=OLD.c0+1;
END;

//

DELIMITER ;//

#新增分区并删除其他分区

--error 01235
ALTER TABLE t1 TRUNCATE PARTITION r2;
--error 01064
ALTER TABLE t1 ADD PARTITION (PARTITION r5);
--error 01235
ALTER TABLE t1  DROP PARTITION r4;

SHOW CREATE TABLE t1;

--error 01235
ALTER TABLE t2 TRUNCATE PARTITION p4;
--error 01064
ALTER TABLE t2 ADD PARTITION (PARTITION p5);
--error 01235
ALTER TABLE t2  DROP PARTITION p3;

SHOW CREATE TABLE t2;



--echo #创建不同类型的分区表，使用不同约束索引条件，然后再创建不同触发类型的trigger，最后对表中的列执行DDL操作后触发trigger



DROP TABLE IF EXISTS t2;

CREATE TABLE t2(c0 INT,
                c1 VARCHAR(10),
                c2 SET('a','b','c','d','e','f','g'),
                c3 FLOAT,
                c4 DATE,
                c5 YEAR DEFAULT '2000',
                c6 TEXT ,
                c7 VARBINARY(10) DEFAULT 'TEST')
PARTITION BY HASH(c0)
(PARTITION p1,
 PARTITION p2,
 PARTITION p3,
 PARTITION p4
);

INSERT INTO t2 VALUES(0,'AA','a',0.123,'2000-01-01','2000','TEST1','TEST1'),
                     (1,'BB','a',2.123,'2001-11-11','2001','TEST2','TEST2'),
                     (3,'CC','b',3.123,'2002-02-01','2002','TEST3','TEST3'),
                     (4,'DD','b',4.123,'2003-03-11','2003','TEST4','TEST4'),
                     (5,'EE','c',5.123,'2004-04-01','2004','TEST5','TEST5'),
                     (6,'FF','c',6.123,'2005-05-11','2005','TEST6','TEST6');


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 SMALLINT ZEROFILL PRIMARY KEY,
                c1 CHAR(10),
                c2 ENUM('a','b','c','d','e','f','g') NOT NULL DEFAULT 'a',
                c3 DOUBLE,
                c4 TIME,
                c5 INT DEFAULT 0,
                c6 BLOB,
                c7 BINARY(10) DEFAULT 'test',
                CONSTRAINT uni_key UNIQUE KEY(c0,c2))
PARTITION BY KEY(c0)
(PARTITION r1,
 PARTITION r2,
 PARTITION r3,
 PARTITION r4
);

INSERT INTO t1 VALUES(0,'AAA','a',10.123,'20:01:01',2000,'TEST1','TEST1'),
                     (1,'BBB','b',12.123,'21:11:11',2001,'TEST2','TEST2'),
                     (2,'CCC','c',13.123,'22:22:01',2002,'TEST3','TEST3'),
                     (3,'DDD','c',14.123,'23:33:11',2003,'TEST4','TEST4'),
                     (4,'EEE','c',15.123,'19:44:01',2004,'TEST5','TEST5'),
                     (5,'FFF','d',16.123,'18:55:11',2005,'TEST6','TEST6'),
                     (6,'EEE','d',16.123,'17:05:17',2006,'TEST7','TEST7');

CREATE INDEX ind_1 ON t1(c3,c4);


#创建INSERT/UPDATE/DELETE型触发器

DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert BEFORE INSERT ON t1
FOR EACH ROW
BEGIN
    DECLARE c INT;
    SELECT MAX(c0) INTO c FROM t2;

    IF NEW.c0 = c THEN
        DELETE FROM t2 WHERE c0 = NEW.c0;
    ELSE
        INSERT INTO t2(c0,c1,c2,c3,c4) VALUES(NEW.c0,CONCAT(NEW.c1,NEW.c1),NEW.c2,NEW.c3+NEW.c0,DATE(NEW.c4));
    END IF;
END;

//


DROP TRIGGER IF EXISTS trg_update;//


CREATE TRIGGER trg_update BEFORE UPDATE ON t2
FOR EACH ROW
BEGIN
    UPDATE t1 SET c0=NEW.c0,c1=CONCAT(NEW.c1,NEW.c1) WHERE c0=OLD.c0;
END
//


DROP TRIGGER IF EXISTS trg_delete;//


CREATE TRIGGER trg_delete BEFORE DELETE ON t2
FOR EACH ROW
BEGIN
    DELETE FROM t1 WHERE c0=OLD.c0+1;
END;

//

DELIMITER ;//

