                     (4,4.5,4,b'010111',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550F1A8066242','89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843','删除中——汉化','3english_language','4teshu*符号@$￥%','SHUZI!123','d','l','23:12:12','2003-12-11','2003-01-01 15:01:01','2002-11-01 03:01:01.34567','2010'),
