                     (2,2.5,2,b'110101',x'89504E470D0A1A0A0000000D4997300000EC300000EC301C76FA8640000001E49444154384','89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843','中文—汉化','1english_language','2teshu*符号@$￥%','SHUZI!12345','b','j','21:12:12','2001-12-22','2001-01-01 13:01:01','2001-11-01 11:01:01.34567','2010'),
                     (3,3.5,3,b'011101',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550F1A8066242','89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843','删除时使用情景','2english_language','3teshu*符号@$￥%','SHUZI!1234','c','k','22:12:12','2002-12-02','2002-01-01 14:01:01','2002-12-01 02:01:01.34567','2000'),
                     (4,4.5,4,b'010111',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550F1A8066242','89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843','删除中——汉化','3english_language','4teshu*符号@$￥%','SHUZI!123','d','l','23:12:12','2003-12-11','2003-01-01 15:01:01','2002-11-01 03:01:01.34567','2010'),
                     (5,5.5,5,b'111101',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550','89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843','删除中文*汉化删除','4english_language','5teshu*符号@$￥%','SHUZI!12','e','m','20:22:12','2004-12-12','2004-01-01 16:01:01','2002-02-04 05:01:01.34567','2000'),
                     (6,6.5,6,b'110111',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550','89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843','除列时使用情景','5english_language','6teshu*符号@$￥%','SHUZI!1','f','n','20:32:12','2021-12-13','2010-01-01 21:01:01','2003-03-01 04:01:01.34567','2010');


CREATE INDEX ind_1 ON t1(c12);
CREATE INDEX ind_2 ON t1(c3,c7,c14);


DROP TABLE IF EXISTS t2;
CREATE TABLE t2(c0 INT,c1 VARCHAR(10));
INSERT INTO t2 VALUES(1,'A'),(2,'B'),(3,'C'),(4,'D'),(5,'E');



#在视图基础上创建trigger


DROP VIEW IF EXISTS v1;
DROP VIEW IF EXISTS v2;

CREATE VIEW v1 AS SELECT * FROM t1;
CREATE VIEW v2 AS SELECT * FROM t2;



#在视图中创建INSERT/DELETE/UPDATE型触发器


DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

--error 01235

CREATE TRIGGER trg_insert BEFORE INSERT ON v2
    FOR EACH ROW
    BEGIN
        DECLARE c INT;
        SELECT MAX(c0) INTO c FROM v1;

        IF NEW.c0 = c THEN
            DELETE FROM v1 WHERE c0 = NEW.c0;
        ELSE
            INSERT INTO v1 VALUES(NEW.c0,NEW.c0+0.5,NEW.c0,b'11111',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550','89504E470D0A1A0A00C76FA8640000001E49444154384F6AE843','除列情景','enish_lanage','tesu*符号￥%','SHUZI!34567','g','l','22:32:12','2022-12-13','2012-01-01 22:01:01','2013-03-21 14:21:21.34567','2011');
        END IF;
    END;

//



DROP TRIGGER IF EXISTS trg_delete;//

--error 01235

CREATE TRIGGER trg_delete BEFORE DELETE ON v2
    FOR EACH ROW
    BEGIN
        DELETE FROM v1 WHERE c0=OLD.c0 OR c10=OLD.c1 OR c11=OLD.c1;
    END;

//


DROP TRIGGER IF EXISTS trg_update;//

--error 01235

CREATE TRIGGER trg_update AFTER UPDATE ON v1
FOR EACH ROW
BEGIN
    UPDATE v2 SET c0=NEW.c0,c1=NEW.c10 WHERE c0=OLD.c0;
END
//

DELIMITER ;//



#在基表中创建INSERT/DELETE/UPDATE型触发器


DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;


CREATE TRIGGER trg_insert BEFORE INSERT ON t2
    FOR EACH ROW
    BEGIN
        DECLARE c INT;
        SELECT MAX(c0) INTO c FROM t1;

        IF NEW.c0 = c THEN
            DELETE FROM t1 WHERE c0 = NEW.c0;
        ELSE
            INSERT INTO t1 VALUES(NEW.c0,NEW.c0+0.5,NEW.c0,b'11111',x'89504E470D0A1A0A00C76FA8640000001E49444154384F6350DAE843126220493550','89504E470D0A1A0A00C76FA8640000001E49444154384F6AE843','除列情景','enish_lanage','tesu*符号￥%','SHUZI!34567','g','l','22:32:12','2022-12-13','2012-01-01 22:01:01','2013-03-21 14:21:21.34567','2011');
        END IF;
    END;

//



DROP TRIGGER IF EXISTS trg_delete;//


CREATE TRIGGER trg_delete BEFORE DELETE ON t2
    FOR EACH ROW
    BEGIN
        DELETE FROM t1 WHERE c0=OLD.c0 OR c10=OLD.c1 OR c11=OLD.c1;
    END;

//


DROP TRIGGER IF EXISTS trg_update;//


CREATE TRIGGER trg_update AFTER UPDATE ON t1
FOR EACH ROW
BEGIN
    UPDATE t2 SET c0=NEW.c0,c1=NEW.c10 WHERE c0=OLD.c0;
END
//

DELIMITER ;//


#对基表进行DDL操作


ALTER TABLE t1 ADD INDEX ind1(c13),ADD CONSTRAINT unk UNIQUE KEY(c0,c1);

alter system set _enable_drop_and_add_index = true;
sleep 2;
ALTER TABLE t1 ADD CONSTRAINT unk1 UNIQUE KEY(c7,c11),RENAME KEY uni_key TO unk2,DROP INDEX ind1;
alter system set _enable_drop_and_add_index = false;
sleep 2;

ALTER TABLE t1 SET PARALLEL=10,BLOCK_SIZE=20480,AUTO_INCREMENT=100;

--echo #暂不支持，待支持后执行sql
#ALTER TABLE t1 CONVERT TO CHARACTER SET 'utf16' COLLATE 'utf16_bin',SET COMMENT '修改表级字符集和字符序';
#SHOW CREATE TABLE t1;


#对视图进行DML操作


INSERT INTO v2 VALUES(6,'F');
SELECT * FROM v2 WHERE c0=6;
SELECT * FROM v1 WHERE c0=6;

ROLLBACK;
SELECT c0,c1 FROM v2 ORDER BY 1;
SELECT c0,c1 FROM v1 ORDER BY 1;


INSERT INTO v2 VALUES(7,'H');
SELECT * FROM v2 WHERE c0=7 ORDER BY 1,2;
SELECT c0,c1,c2 FROM v1 WHERE c0=7;

ROLLBACK;
SELECT c0,c1 FROM v2 ORDER BY 1;
SELECT c0,c1 FROM v1 ORDER BY 1;


DELETE FROM v2 WHERE c0=4;
SELECT c0,c1 FROM v2 ORDER BY 1;
SELECT c0,c1 FROM v1 ORDER BY 1;

ROLLBACK;
SELECT c0,c1 FROM v2 ORDER BY 1;
SELECT c0,c1 FROM v1 ORDER BY 1;


