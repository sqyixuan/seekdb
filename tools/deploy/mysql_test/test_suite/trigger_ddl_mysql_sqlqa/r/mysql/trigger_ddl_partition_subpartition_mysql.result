DROP TRIGGER IF EXISTS trg_insert;
CREATE TRIGGER trg_insert AFTER INSERT ON t1
FOR EACH ROW
BEGIN
DECLARE c INT;
SELECT MAX(c0) INTO c FROM t2;
IF NEW.c0 = c THEN
DELETE FROM t2 WHERE c0 = NEW.c0;
ELSE
INSERT INTO t2(c0,c1,c2,c3,c4) VALUES(NEW.c0,CONCAT(NEW.c1,NEW.c1),NEW.c2,NEW.c3+NEW.c0,DATE(NEW.c4));
END IF;
END;
//
DROP TRIGGER IF EXISTS trg_update;//
CREATE TRIGGER trg_update BEFORE UPDATE ON t2
FOR EACH ROW
BEGIN
UPDATE t1 SET c0=NEW.c0,c1=CONCAT(NEW.c1,NEW.c1) WHERE c0=OLD.c0;
END
//
DROP TRIGGER IF EXISTS trg_delete;//
CREATE TRIGGER trg_delete AFTER DELETE ON t2
FOR EACH ROW
BEGIN
DELETE FROM t1 WHERE c0=OLD.c0+1;
END;
