purge recyclebin;
CREATE DATABASE IF NOT EXISTS trigger_test;
USE trigger_test;
SET AUTOCOMMIT=0;
#mysql_trigger_ddl
#mysql_trigger_ddl-1
#mysql_trigger_ddl-1-1/mysql_trigger_ddl-1-3/mysql_trigger_ddl-1-4
#mysql_trigger_ddl-2
#mysql_trigger_ddl-2-1/mysql_trigger_ddl-2-2/mysql_trigger_ddl-2-3
#创建不同类型的分区表，使用不同约束索引条件，然后再创建不同触发类型的trigger，最后对表执行DDL操作后触发trigger
DROP TABLE IF EXISTS t2;
CREATE TABLE t2(c0 INT,
c1 VARCHAR(10),
c2 SET('a','b','c','d','e','f','g'),
c3 FLOAT,
c4 DATE)
PARTITION BY HASH(c0)
(PARTITION p1,
PARTITION p2,
PARTITION p3,
PARTITION p4
);
INSERT INTO t2 VALUES(0,'AA','a','0.123','2000-01-01'),
(1,'BB','a','2.123','2001-11-11'),
(3,'CC','b','3.123','2002-02-01'),
(4,'DD','b','4.123','2003-03-11'),
(5,'EE','c','5.123','2004-04-01'),
(6,'FF','c','6.123','2005-05-11');
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 SMALLINT ZEROFILL PRIMARY KEY,
c1 CHAR(10),
c2 ENUM('a','b','c','d','e','f','g') NOT NULL DEFAULT 'a',
c3 DOUBLE,
c4 TIME,
CONSTRAINT uni_key UNIQUE KEY(c0,c2))
PARTITION BY KEY(c0)
(PARTITION r1,
PARTITION r2,
PARTITION r3,
PARTITION r4
);
INSERT INTO t1 VALUES(0,'AAA','a','10.123','20:01:01'),
(1,'BBB','b','12.123','21:11:11'),
(3,'CCC','c','13.123','22:22:01'),
(4,'DDD','c','14.123','23:33:11'),
(5,'EEE','c','15.123','19:44:01'),
(6,'FFF','d','16.123','18:55:11');
CREATE INDEX ind_1 ON t1(c3,c4);
DROP TRIGGER IF EXISTS trg_insert;
CREATE TRIGGER trg_insert BEFORE INSERT ON t2
FOR EACH ROW
BEGIN
DECLARE c INT;
SELECT MAX(c0) INTO c FROM t1;
IF NEW.c0 = c THEN
DELETE FROM t1 WHERE c0 = NEW.c0;
ELSE
INSERT INTO t1 VALUES(NEW.c0,CONCAT(NEW.c1,NEW.c1),NEW.c2,NEW.c3+NEW.c0,TIME(NEW.c4));
END IF;
END;
//
DROP TRIGGER IF EXISTS trg_update;//
CREATE TRIGGER trg_update BEFORE UPDATE ON t1
FOR EACH ROW
BEGIN
UPDATE t2 SET c0=NEW.c0,c1=CONCAT(NEW.c1,NEW.c1) WHERE c0=OLD.c0;
END
//
DROP TRIGGER IF EXISTS trg_delete;//
CREATE TRIGGER trg_delete AFTER DELETE ON t2
FOR EACH ROW
BEGIN
DELETE FROM t1 WHERE c0=OLD.c0+1;
END;
//
CREATE INDEX ind_2 ON t1(c2);
alter system set _enable_drop_and_add_index = true;
ALTER TABLE t1 DROP INDEX ind_1,ADD INDEX ind1(c1),RENAME INDEX ind_2 TO ind2;
alter system set _enable_drop_and_add_index = false;
alter system set _enable_drop_and_add_index = true;
ALTER TABLE t1 ADD CONSTRAINT unk UNIQUE KEY(c0),DROP INDEX uni_key;
alter system set _enable_drop_and_add_index = false;
ALTER TABLE t1 SET PARALLEL=10,BLOCK_SIZE=20480,AUTO_INCREMENT=100;
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c0` smallint(5) unsigned zerofill NOT NULL,
  `c1` char(10) DEFAULT NULL,
  `c2` enum('a','b','c','d','e','f','g') NOT NULL DEFAULT 'a',
  `c3` double DEFAULT NULL,
  `c4` time DEFAULT NULL,
  PRIMARY KEY (`c0`),
  UNIQUE KEY `unk` (`c0`) BLOCK_SIZE 20480 LOCAL,
  KEY `ind2` (`c2`) BLOCK_SIZE 20480 LOCAL,
  KEY `ind1` (`c1`) BLOCK_SIZE 20480 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 20480 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 PARALLEL 10
 partition by key(c0)
(partition `r1`,
partition `r2`,
partition `r3`,
partition `r4`)
