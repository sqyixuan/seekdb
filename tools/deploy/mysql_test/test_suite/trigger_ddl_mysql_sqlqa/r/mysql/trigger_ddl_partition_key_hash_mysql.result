DROP TABLE IF EXISTS t2;
CREATE TABLE t2(c0 SMALLINT ZEROFILL,c1 VARCHAR(10),CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t1(c0));
INSERT INTO t2 VALUES(0,'a'),(1,'b'),(3,'b'),(4,'c'),(5,'c'),(6,'a');
DROP TRIGGER IF EXISTS trg_insert;
CREATE TRIGGER trg_insert BEFORE INSERT ON t2
FOR EACH ROW
BEGIN
DECLARE c INT;
SELECT MAX(c0) INTO c FROM t1;
IF NEW.c0 = c THEN
DELETE FROM t1 WHERE c0 = NEW.c0;
ELSE
INSERT INTO t1 VALUES(NEW.c0,CONCAT(NEW.c1,NEW.c1),NEW.c1,2*NEW.c0,'00:00:00');
END IF;
END;
//
DROP TRIGGER IF EXISTS trg_update;//
CREATE TRIGGER trg_update BEFORE UPDATE ON t1
FOR EACH ROW
BEGIN
UPDATE t2 SET c0=NEW.c0,c1=CONCAT(NEW.c1,NEW.c1) WHERE c0=OLD.c0;
END
//
DROP TRIGGER IF EXISTS trg_delete;//
CREATE TRIGGER trg_delete AFTER DELETE ON t2
FOR EACH ROW
BEGIN
DELETE FROM t1 WHERE c0=OLD.c0+1;
END;
//
alter system set _enable_drop_and_add_index = true;
ALTER TABLE t1 DROP INDEX unk,ADD CONSTRAINT uni UNIQUE KEY(c0,c2);
