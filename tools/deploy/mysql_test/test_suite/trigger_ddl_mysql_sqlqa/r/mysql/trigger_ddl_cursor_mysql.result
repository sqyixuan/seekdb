purge recyclebin;
CREATE DATABASE IF NOT EXISTS trigger_test;
USE trigger_test;
SET sql_mode='NO_AUTO_VALUE_ON_ZERO';
SET AUTOCOMMIT=0;
#视图
#创建视图，使用不同约束索引条件，然后再创建不同触发类型的trigger，最后对视图执行DDL操作后触发trigger
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 TINYINT ZEROFILL AUTO_INCREMENT,
c1 FLOAT NOT NULL,
c2 DOUBLE(5,0) ,
c3 BIT(20) DEFAULT 0,
c4 BLOB,
c5 TEXT,
c6 VARCHAR(50),
c7 CHAR(50),
c8 BINARY(50) NOT NULL,
c9 VARBINARY(50) NOT NULL,
c10 ENUM('a','b','c','d','e','f','g','h'),
c11 SET('i','j','k','l','m','n','o','p'),
c12 TIME NOT NULL,
c13 DATE NOT NULL,
c14 DATETIME NOT NULL,
c15 TIMESTAMP DEFAULT '2000-01-01 00:00:00',
c16 YEAR ,
PRIMARY KEY(c0,c1,c2),
UNIQUE KEY uni_key(c6,c10));
